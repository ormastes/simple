# RISC-V FPGA Linux Integration
#
# Dual-arch (RV32 + RV64) orchestration layer for RISC-V FPGA boards
# running Linux. Manages board profiles, lane contracts, manifests,
# RTL bundle generation, and boot product metadata.
#
# Tracks plan items 1-6 from doc/03_plan/agent_tasks/riscv_fpga_linux.md:
#   1. Preparation contract and executable lane validation
#   2. Helper-proof surface preservation
#   3. Generated RV32/RV64 Linux lanes in manifests
#   4. DTB and boot ROM packaging
#   5. Vivado materialization for Xilinx board profiles
#   6. Hardware boot-test runners

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_dir_create(path: text, recursive: bool) -> bool
extern fn rt_file_exists(path: text) -> bool

fn rtl_file_write_text(path: text, content: text) -> bool:
    rt_file_write_text(path, content)

fn rtl_file_read_text(path: text) -> text:
    rt_file_read_text(path)

fn rtl_dir_create(path: text) -> bool:
    rt_dir_create(path, true)

fn rtl_file_exists(path: text) -> bool:
    rt_file_exists(path)

use std.hardware.fpga_linux.soc_vhdl_gen.{generate_soc_vhdl_bundle}
use std.hardware.riscv_common.pkg.riscv_generated_core_pkg.{RiscvProofLane}

# ============================================================================
# Readiness Status
# ============================================================================

pub enum RiscvReadinessStatus:
    """Tracks the lifecycle stage of a generated RISC-V Linux lane."""
    Contract
    QemuValidated
    FpgaSynthesized
    HardwareBooted

impl RiscvReadinessStatus:
    fn to_text() -> text:
        match self:
            case Contract: "contract"
            case QemuValidated: "qemu_validated"
            case FpgaSynthesized: "fpga_synthesized"
            case HardwareBooted: "hardware_booted"

# ============================================================================
# XLEN — Architecture Width
# ============================================================================

pub enum Xlen:
    """RISC-V register width selector."""
    Rv32
    Rv64

impl Xlen:
    fn to_text() -> text:
        match self:
            case Rv32: "rv32"
            case Rv64: "rv64"

    fn linux_policy() -> text:
        """Returns the repo-native Linux policy string for this xlen."""
        match self:
            case Rv32: "repo-native-rv32-linux"
            case Rv64: "repo-native-rv64-linux"

    fn core_file_name() -> text:
        """Returns the RTL core top-level VHDL filename for this xlen."""
        match self:
            case Rv32: "rv32i_core.vhd"
            case Rv64: "rv64gc_core.vhd"

    fn isa_string() -> text:
        """
        Returns the honest ISA string for the production FPGA cores.
        Cores implement I+M+C+Zicsr (no F/D, no G, no A, no Zifencei).
        Verified against examples/09_embedded/fpga_riscv/rtl/{rv32,rv64}_exec_core.vhd
        - I: Base integer ISA
        - M: Mul/Div (divider FSM for div/divu/rem/remu and *w variants)
        - C: Compressed (c_addi4spn, c_addi, c_lw, c_sw, c_lui, c_addi16sp)
        - Zicsr: CSR operations (mhartid, mstatus, mtvec, mie, mip)
        """
        match self:
            case Rv32: "rv32imc_zicsr"
            case Rv64: "rv64imc_zicsr"

    fn linux_abi() -> text:
        """
        Returns the honest Linux ABI for the production FPGA cores.
        Cores have NO floating-point hardware (no F/D unit, no FP regfile, no mstatus.FS).
        Must use soft-float ABI (ilp32/lp64), not hard-float (ilp32d/lp64d).
        """
        match self:
            case Rv32: "ilp32"
            case Rv64: "lp64"

    fn validate_isa_abi_consistency(isa: text, abi: text) -> Result<(), text>:
        """
        Validates that ISA and ABI are consistent and reject unsupported combos.
        Returns Ok if consistent, Err with explanation if not.
        """
        val has_f = isa.contains("_f") or (isa.contains("g") and not isa.contains("_g"))
        val has_d = isa.contains("_d")

        # Rule: D requires F (double-precision requires single-precision)
        if has_d and not has_f:
            return Err("ISA has D extension but missing F extension (D requires F)")

        # Rule: Hard-float ABI (ilp32d/lp64d) requires F extension
        val abi_is_hard_float = abi == "ilp32d" or abi == "lp64d"
        if abi_is_hard_float and not has_f:
            return Err("ABI is hard-float ({abi}) but ISA lacks F extension (no FP hardware)")

        # Rule: Reject hard-float binaries when F/D absent from current cores
        val current_has_fp = has_f  # Our current cores don't have F
        if abi_is_hard_float and not current_has_fp:
            return Err("Hard-float ABI ({abi}) rejected: current FPGA cores have no FP unit (no F/D)")

        Ok(())

    fn linux_mmu() -> text:
        match self:
            case Rv32: "sv32"
            case Rv64: "sv39"

    fn rtl_size_budget_luts() -> i64:
        match self:
            case Rv32: 25000
            case Rv64: 45000

    fn perf_target_mhz() -> i64:
        match self:
            case Rv32: 50
            case Rv64: 50

# ============================================================================
# Proof Lane Identifier
# ============================================================================

pub struct ProofLane:
    """Identifies a generated proof lane for manifest tracking."""
    name: text

impl ProofLane:
    fn to_text() -> text:
        self.name

# ============================================================================
# QEMU Machine Profile
# ============================================================================

pub struct QemuMachineProfile:
    """QEMU virt machine configuration for simulation-based validation."""
    xlen: Xlen
    machine: text
    memory: text
    smp: i64

impl QemuMachineProfile:
    static fn default_for(xlen: Xlen) -> QemuMachineProfile:
        match xlen:
            case Rv32:
                QemuMachineProfile(xlen: Xlen.Rv32, machine: "virt", memory: "128M", smp: 1)
            case Rv64:
                QemuMachineProfile(xlen: Xlen.Rv64, machine: "virt", memory: "256M", smp: 2)

    fn qemu_binary() -> text:
        match self.xlen:
            case Rv32: "qemu-system-riscv32"
            case Rv64: "qemu-system-riscv64"

    fn to_id() -> text:
        """Short identifier for manifest summaries."""
        match self.xlen:
            case Rv32: "qemu_virt_rv32"
            case Rv64: "qemu_virt_rv64"

# ============================================================================
# Xilinx Board Profile
# ============================================================================

pub struct XilinxBoardProfile:
    """
    Board support package for a specific Xilinx FPGA board.
    Contains part number, clock frequency, programmer type,
    and constraint file path.
    """
    name: text
    part: text
    clock_hz: i64
    uart_baud: i64
    programmer: text
    constraint_path: text

impl XilinxBoardProfile:
    static fn generic() -> XilinxBoardProfile:
        """
        Generic Xilinx profile with no specific part selected.
        Passes prepare validation but blocks hardware boot.
        """
        XilinxBoardProfile(
            name: "xilinx_generic",
            part: "",
            clock_hz: 0,
            uart_baud: 0,
            programmer: "",
            constraint_path: ""
        )

    static fn from_id(board_id: text) -> Result<XilinxBoardProfile, text>:
        """
        Look up a concrete board profile by ID.
        Currently supports: mlk_s02_100t
        """
        if board_id == "mlk_s02_100t":
            Ok(XilinxBoardProfile(
                name: "mlk_s02_100t",
                part: "xc7a100tfgg484-2",
                clock_hz: 25000000,
                uart_baud: 115200,
                programmer: "openFPGALoader",
                constraint_path: "examples/09_embedded/fpga_riscv/constraints/mlk_s02_100t.xdc"
            ))
        else if board_id == "xilinx_k26":
            Ok(XilinxBoardProfile(
                name: "xilinx_k26",
                part: "xck26-sfvc784-2LV-c",
                clock_hz: 100000000,
                uart_baud: 115200,
                programmer: "xsdb",
                constraint_path: "examples/09_embedded/fpga_riscv/constraints/k26.xdc"
            ))
        else:
            Err("unknown board id: {board_id}")

    fn validate_for_prepare() -> [text]:
        """
        Validation errors for the prepare phase. Generic profiles pass
        since no hardware-specific config is needed for RTL generation.
        """
        var errors: [text] = []
        # Prepare phase only needs a valid name
        if self.name == "":
            errors = errors.push("board name must not be empty")
        return errors

    fn validate_for_hardware_boot() -> text:
        """
        Validation message for hardware boot. Returns empty string if valid,
        otherwise returns the blocking reason.
        """
        if self.part == "":
            return "xilinx part must be selected before hardware boot"
        if self.clock_hz <= 0:
            return "clock frequency must be set before hardware boot"
        if self.programmer == "":
            return "programmer must be configured before hardware boot"
        return ""

    fn xdc_path() -> text:
        """Returns the XDC constraint file path for this board."""
        self.constraint_path

# ============================================================================
# RISC-V FPGA Lane
# ============================================================================

pub struct RiscvFpgaLane:
    """
    A single architecture lane (RV32 or RV64) in the FPGA Linux pipeline.
    Tracks readiness status, proof lane identifier, QEMU profile,
    and boot artifact paths.
    """
    xlen: Xlen
    status: RiscvReadinessStatus
    qemu: QemuMachineProfile

impl RiscvFpgaLane:
    static fn rv32_default() -> RiscvFpgaLane:
        """Default RV32 lane at Contract readiness."""
        RiscvFpgaLane(
            xlen: Xlen.Rv32,
            status: RiscvReadinessStatus.Contract,
            qemu: QemuMachineProfile.default_for(Xlen.Rv32)
        )

    static fn rv64_default() -> RiscvFpgaLane:
        """Default RV64 lane at Contract readiness."""
        RiscvFpgaLane(
            xlen: Xlen.Rv64,
            status: RiscvReadinessStatus.Contract,
            qemu: QemuMachineProfile.default_for(Xlen.Rv64)
        )

    fn readiness_status() -> RiscvReadinessStatus:
        self.status

    fn proof_lane() -> RiscvProofLane:
        """Returns the proof lane identifier for this architecture."""
        match self.xlen:
            case Rv32:
                RiscvProofLane.GeneratedRv32Linux
            case Rv64:
                RiscvProofLane.GeneratedRv64Linux

    fn proof_lane_text() -> text:
        match self.xlen:
            case Rv32: "generated_rv32_linux"
            case Rv64: "generated_rv64_linux"

    fn required_soc_blocks() -> [text]:
        ["opensbi-handoff", "dtb", "uart16550", "clint"]

    fn proof_acceptance_markers() -> [text]:
        ["OpenSBI", "Linux version", "OF: fdt", "Freeing unused kernel memory", "init started"]

    fn proof_lane_summary() -> text:
        "{self.proof_lane_text()} shell=none"

    fn rv32_smoke_testbench_vhdl() -> text:
        "entity tb_generated_rv32_smoke is\nend entity tb_generated_rv32_smoke;\narchitecture tb of tb_generated_rv32_smoke is\nbegin\n  u_cpu : entity work.rv32i_core;\n  process begin\n    assert false report \"GENERATED_RTL_NOT_IMPLEMENTED lane=rv32\" severity failure;\n    wait;\n  end process;\nend architecture tb;\n"

    fn rv32_strobe_testbench_vhdl() -> text:
        "library ieee;\nuse ieee.std_logic_1164.all;\nuse work.simple_rv32i_core_pkg.all;\nentity tb_generated_rv32_strobe is\nend entity tb_generated_rv32_strobe;\narchitecture tb of tb_generated_rv32_strobe is\nbegin\n  u_cpu : entity work.simple_rv32gc_core;\n  process begin\n    assert false report \"GENERATED_RTL_NOT_IMPLEMENTED lane=rv32\" severity failure;\n    wait;\n  end process;\nend architecture tb;\n"

    fn hardware_source_spl() -> text:
        if self.xlen == Xlen.Rv32:
            return rv32_generated_hardware_source_spl()
        generated_core_source(self.xlen.to_text())

    fn rtl_dir_name() -> text:
        self.xlen.to_text()

    fn boot_products_id(board_name: text) -> text:
        """Product ID for manifest boot products."""
        val xl = self.xlen.to_text()
        "{board_name}_{xl}_linux"

    fn summary_token() -> text:
        """Short summary token for readiness reports."""
        val xl = self.xlen.to_text()
        val st = self.status.to_text()
        val qi = self.qemu.to_id()
        "{xl}:{st}:{qi}"

# ============================================================================
# Product Profile
# ============================================================================

pub struct RiscvFpgaProductProfile:
    """Product-level metadata shared by manifests and debug sidecars."""
    product_level: text
    configuration_profile: text
    rv32_luts: i64
    rv64_luts: i64
    rv32_mhz: i64
    rv64_mhz: i64

impl RiscvFpgaProductProfile:
    static fn default_linux_rtl() -> RiscvFpgaProductProfile:
        RiscvFpgaProductProfile(
            product_level: "linux-rtl",
            configuration_profile: "qemu-virt+fpga-board",
            rv32_luts: 25000,
            rv64_luts: 45000,
            rv32_mhz: 50,
            rv64_mhz: 50
        )

    static fn with_configuration_profile(configuration_profile: text) -> RiscvFpgaProductProfile:
        RiscvFpgaProductProfile(
            product_level: "linux-rtl",
            configuration_profile: configuration_profile,
            rv32_luts: 25000,
            rv64_luts: 45000,
            rv32_mhz: 50,
            rv64_mhz: 50
        )

    static fn configured(product_level: text, configuration_profile: text, rv32_luts: i64, rv64_luts: i64, rv32_mhz: i64, rv64_mhz: i64) -> RiscvFpgaProductProfile:
        RiscvFpgaProductProfile(
            product_level: product_level,
            configuration_profile: configuration_profile,
            rv32_luts: rv32_luts,
            rv64_luts: rv64_luts,
            rv32_mhz: rv32_mhz,
            rv64_mhz: rv64_mhz
        )

    fn rtl_size_budget_luts(xlen: Xlen) -> i64:
        match xlen:
            case Rv32: self.rv32_luts
            case Rv64: self.rv64_luts

    fn perf_target_mhz(xlen: Xlen) -> i64:
        match xlen:
            case Rv32: self.rv32_mhz
            case Rv64: self.rv64_mhz

# ============================================================================
# FPGA Linux Manifest
# ============================================================================

pub struct RiscvFpgaLinuxManifest:
    """
    Dual-arch manifest for RISC-V FPGA Linux integration.
    Contains board profile, both architecture lanes, and methods
    for generating machine-readable manifests and boot products.
    """
    board: XilinxBoardProfile
    product: RiscvFpgaProductProfile
    lanes: [RiscvFpgaLane]

impl RiscvFpgaLinuxManifest:
    fn readiness_summary() -> text:
        """Human-readable summary of lane readiness states."""
        var parts: [text] = []
        for lane in self.lanes:
            parts = parts.push(lane.summary_token())
        return parts.join(", ")

    fn vivado_tcl_plan() -> text:
        """
        Returns a Vivado TCL plan snippet referencing the board's
        constraint file and target part.
        """
        val bname = self.board.name
        val bpart = self.board.part
        val bconst = self.board.constraint_path
        var lines: [text] = []
        lines = lines.push("# Vivado TCL Plan for {bname}")
        lines = lines.push("set_property PART {bpart} [current_project]")
        if bconst != "":
            lines = lines.push("add_files -fileset constrs_1 {bconst}")
        for lane in self.lanes:
            val rtl_file = lane.xlen.core_file_name()
            val rdir = lane.rtl_dir_name()
            lines = lines.push("add_files -fileset sources_1 {rdir}/rtl/{rtl_file}")
        return lines.join("\n")

    fn board_linux_boot_products_manifest_text(output_dir: text) -> text:
        """
        Generates the boot products manifest in SDN format for all lanes.
        """
        val bname = self.board.name
        var lines: [text] = []
        lines = lines.push("# Board Linux Boot Products Manifest")
        lines = lines.push("# Board: {bname}")
        lines = lines.push("")
        for lane in self.lanes:
            val product_id = lane.boot_products_id(bname)
            val xl = lane.xlen.to_text()
            val isa = lane.xlen.isa_string()
            lines = lines.push("[[product]]")
            lines = lines.push("product_id = \"{product_id}\"")
            lines = lines.push("lane_id = \"{xl}\"")
            lines = lines.push("xlen = \"{xl}\"")
            lines = lines.push("isa = \"{isa}\"")
            lines = lines.push("board = \"{bname}\"")
            lines = lines.push("boot_script = \"scripts/mlk_s02_100t_generated_linux_boot.shs\"")
            lines = lines.push("validation_kind = \"contract-not-ready\"")
            lines = lines.push("expected_markers = \"OpenSBI|Linux version|OF: fdt|Freeing unused kernel memory|init started\"")
            lines = lines.push("authoritative_rtl_provenance = \"none\"")
            lines = lines.push("")
        return lines.join("\n")

    fn rtl_manifest_text(output_dir: text) -> text:
        var lines: [text] = []
        lines = lines.push("# RISC-V FPGA Linux RTL Manifest")
        lines = lines.push("# Auto-generated contract bundle; product RTL is not ready")
        lines = lines.push("")
        lines = lines.push("[provenance]")
        lines = lines.push("board = \"{self.board.name}\"")
        lines = lines.push("readiness = \"contract-not-ready\"")
        lines = lines.push("reason = \"placeholder-core-no-semantic-rvfi\"")
        lines = lines.push("authoritative_rtl_provenance = \"none\"")
        lines = lines.push("pure_simple_authoritative_rtl = \"false\"")
        lines = lines.push("auxiliary_vhdl_provenance = \"emitted-text-vhdl\"")
        lines = lines.push("runner_testbench_provenance = \"emitted-text-vhdl\"")
        lines = lines.push("")
        for lane in self.lanes:
            val pl = lane.proof_lane_text()
            val xl = lane.xlen.to_text()
            val abi = lane.xlen.linux_abi()
            val mmu = lane.xlen.linux_mmu()
            val luts = self.product.rtl_size_budget_luts(lane.xlen)
            val mhz = self.product.perf_target_mhz(lane.xlen)
            val core = "simple_{xl}gc_core"
            lines = lines.push("[[lane]]")
            lines = lines.push("proof_lane = \"{pl}\"")
            lines = lines.push("lane_id = \"{xl}\"")
            lines = lines.push("xlen = \"{xl}\"")
            lines = lines.push("product_level = \"{self.product.product_level}\"")
            lines = lines.push("configuration_profile = \"{self.product.configuration_profile}\"")
            lines = lines.push("linux_abi = \"{abi}\"")
            lines = lines.push("linux_mmu = \"{mmu}\"")
            lines = lines.push("rtl_size_budget_luts = \"{luts}\"")
            lines = lines.push("perf_target_mhz = \"{mhz}\"")
            lines = lines.push("formal_verification = \"contract-not-ready\"")
            lines = lines.push("formal_gate = \"placeholder-rejected\"")
            lines = lines.push("core_file = \"{output_dir}/{xl}/rtl/{core}.vhd\"")
            lines = lines.push("debug_sidecar_file = \"{output_dir}/{xl}/rtl/{core}.debug.json\"")
            if xl == "rv32":
                lines = lines.push("runner_testbench = \"{output_dir}/{xl}/rtl/tb_generated_rv32_linux_handoff.vhd\"")
                lines = lines.push("runner_testbench = \"{output_dir}/{xl}/rtl/tb_generated_rv32_boot_info_real_dtb.vhd\"")
            else:
                lines = lines.push("runner_testbench = \"{output_dir}/{xl}/rtl/tb_generated_rv64_boot_info_dtb.vhd\"")
                lines = lines.push("runner_testbench = \"{output_dir}/{xl}/rtl/tb_generated_rv64_fw_jump.vhd\"")
                lines = lines.push("runner_testbench = \"{output_dir}/{xl}/rtl/tb_generated_rv64_boot_info_real_dtb.vhd\"")
                lines = lines.push("runner_testbench = \"{output_dir}/{xl}/rtl/tb_generated_rv64_sv39.vhd\"")
                lines = lines.push("runner_testbench = \"{output_dir}/{xl}/rtl/tb_generated_rv64_sv39_fault.vhd\"")
            lines = lines.push("debug_output = \"semi_trigger\"")
            lines = lines.push("debug_output = \"semi_op\"")
            lines = lines.push("debug_output = \"semi_param\"")
            lines = lines.push("debug_output = \"debug_pc\"")
            lines = lines.push("authoritative = \"false\"")
            lines = lines.push("contract_file = \"{output_dir}/{xl}/rtl/{core}.spl\"")
            lines = lines.push("contract_file = \"{output_dir}/{xl}/rtl/{core}_pkg.vhd\"")
            lines = lines.push("contract_file = \"{output_dir}/{xl}/rtl/{core}.vhd\"")
            lines = lines.push("contract_file = \"{output_dir}/{xl}/rtl/{core}.debug.json\"")
            lines = lines.push("")
        lines.join("\n")

    fn product_byl_text() -> text:
        var lines: [text] = []
        lines = lines.push("byl_version = \"0.1\"")
        lines = lines.push("schema = \"simple.riscv_product\"")
        lines = lines.push("generated_surface = \"byl\"")
        lines = lines.push("manual_constraints = \"src/RiscvProduct/Constraints.lean\"")
        lines = lines.push("configurable_fields = \"product_level,configuration_profile,rv32.max_luts,rv64.max_luts,rv32.target_mhz,rv64.target_mhz\"")
        lines = lines.push("")
        for lane in self.lanes:
            val xl = lane.xlen.to_text()
            val abi = lane.xlen.linux_abi()
            val mmu = lane.xlen.linux_mmu()
            val luts = self.product.rtl_size_budget_luts(lane.xlen)
            val mhz = self.product.perf_target_mhz(lane.xlen)
            lines = lines.push("lane {xl} {")
            lines = lines.push("  product_level = \"{self.product.product_level}\"")
            lines = lines.push("  configuration_profile = \"{self.product.configuration_profile}\"")
            lines = lines.push("  abi = \"{abi}\"")
            lines = lines.push("  mmu = \"{mmu}\"")
            lines = lines.push("  max_luts = {luts}")
            lines = lines.push("  target_mhz = {mhz}")
            lines = lines.push("  readiness = \"contract-not-ready\"")
            lines = lines.push("  formal_gate = \"placeholder-rejected\"")
            lines = lines.push("}")
            lines = lines.push("")
        lines = lines.push("resource shared_bus {")
        lines = lines.push("  owner = \"optional_lane\"")
        lines = lines.push("  acquire = \"single_owner_only\"")
        lines = lines.push("  release = \"owner_clears\"")
        lines = lines.push("}")
        lines = lines.push("")
        lines = lines.push("scheduler round_robin {")
        lines = lines.push("  next_lane = \"rv32->rv64,rv64->rv32\"")
        lines = lines.push("  starvation_bound = 2")
        lines = lines.push("}")
        lines.join("\n") + "\n"

# ============================================================================
# RTL Bundle
# ============================================================================

pub struct RtlBundle:
    """Result of RTL bundle generation — paths to generated artifacts."""
    output_dir: text
    manifest_path: text
    board_linux_boot_products_manifest_path: text
    bundle_readme_path: text
    generated_files: [text]

# ============================================================================
# Manifest Factory Functions
# ============================================================================

pub fn create_default_riscv_fpga_linux_manifest() -> RiscvFpgaLinuxManifest:
    """
    Creates the default dual-arch manifest with generic board profile
    and both RV32+RV64 lanes at Contract readiness.
    """
    RiscvFpgaLinuxManifest(
        board: XilinxBoardProfile.generic(),
        product: RiscvFpgaProductProfile.default_linux_rtl(),
        lanes: [RiscvFpgaLane.rv32_default(), RiscvFpgaLane.rv64_default()]
    )

pub fn create_default_riscv_fpga_linux_manifest_with_profile(configuration_profile: text) -> RiscvFpgaLinuxManifest:
    """
    Creates the default dual-arch manifest with a custom configuration profile.
    """
    RiscvFpgaLinuxManifest(
        board: XilinxBoardProfile.generic(),
        product: RiscvFpgaProductProfile.with_configuration_profile(configuration_profile),
        lanes: [RiscvFpgaLane.rv32_default(), RiscvFpgaLane.rv64_default()]
    )

pub fn create_riscv_fpga_linux_manifest_for_board(board_id: text) -> Result<RiscvFpgaLinuxManifest, text>:
    """
    Creates a board-specific dual-arch manifest.
    Returns Err if board_id is not recognized.
    """
    val board_result = XilinxBoardProfile.from_id(board_id)
    val board = match board_result:
        Ok(value):
            value
        Err(message):
            return Err(message)
    Ok(RiscvFpgaLinuxManifest(
        board: board,
        product: RiscvFpgaProductProfile.default_linux_rtl(),
        lanes: [RiscvFpgaLane.rv32_default(), RiscvFpgaLane.rv64_default()]
    ))

pub fn create_riscv_fpga_linux_manifest_for_board_with_profile(board_id: text, configuration_profile: text) -> Result<RiscvFpgaLinuxManifest, text>:
    """
    Creates a board-specific dual-arch manifest with a custom configuration profile.
    """
    val board_result = XilinxBoardProfile.from_id(board_id)
    val board = match board_result:
        Ok(value):
            value
        Err(message):
            return Err(message)
    Ok(RiscvFpgaLinuxManifest(
        board: board,
        product: RiscvFpgaProductProfile.with_configuration_profile(configuration_profile),
        lanes: [RiscvFpgaLane.rv32_default(), RiscvFpgaLane.rv64_default()]
    ))

pub fn create_riscv_fpga_linux_manifest_configured(board_id: text, product_level: text, configuration_profile: text, rv32_luts: i64, rv64_luts: i64, rv32_mhz: i64, rv64_mhz: i64) -> Result<RiscvFpgaLinuxManifest, text>:
    """
    Creates a dual-arch manifest with explicit board, profile, and budget metadata.
    """
    val board_result = if board_id == "":
        Ok(XilinxBoardProfile.generic())
    else:
        XilinxBoardProfile.from_id(board_id)
    val board = match board_result:
        Ok(value):
            value
        Err(message):
            return Err(message)
    val level = if product_level == "": "linux-rtl" else: product_level
    val profile = if configuration_profile == "": "qemu-virt+fpga-board" else: configuration_profile
    Ok(RiscvFpgaLinuxManifest(
        board: board,
        product: RiscvFpgaProductProfile.configured(level, profile, rv32_luts, rv64_luts, rv32_mhz, rv64_mhz),
        lanes: [RiscvFpgaLane.rv32_default(), RiscvFpgaLane.rv64_default()]
    ))

# ============================================================================
# RTL Bundle Generation
# ============================================================================

fn write_manifest_file(output_dir: text, manifest: RiscvFpgaLinuxManifest) -> text:
    """Writes the main RTL manifest to disk and returns its path."""
    val path = "{output_dir}/riscv_fpga_rtl_manifest.sdn"
    rtl_file_write_text(path, manifest.rtl_manifest_text(output_dir))
    return path

fn write_boot_products_file(output_dir: text, manifest: RiscvFpgaLinuxManifest) -> text:
    """Writes the boot products manifest to disk and returns its path."""
    val path = "{output_dir}/board_linux_boot_products.sdn"
    val content = manifest.board_linux_boot_products_manifest_text(output_dir)
    rtl_file_write_text(path, content)
    return path

fn write_product_byl_file(output_dir: text, manifest: RiscvFpgaLinuxManifest) -> text:
    """Writes the generated product BYL model to disk and returns its path."""
    val path = "{output_dir}/riscv_product.byl"
    rtl_file_write_text(path, manifest.product_byl_text())
    return path

fn synth_report_template_text(lane: RiscvFpgaLane, product: RiscvFpgaProductProfile) -> text:
    val xl = lane.xlen.to_text()
    val luts = product.rtl_size_budget_luts(lane.xlen)
    val mhz = product.perf_target_mhz(lane.xlen)
    var lines: [text] = []
    lines = lines.push("lane = \"{xl}\"")
    lines = lines.push("max_luts = {luts}")
    lines = lines.push("target_mhz = {mhz}")
    lines = lines.push("actual_luts = 0")
    lines = lines.push("actual_mhz = 0")
    lines = lines.push("status = \"template-fill-after-synthesis\"")
    lines.join("\n") + "\n"

fn write_synth_report_templates(output_dir: text, manifest: RiscvFpgaLinuxManifest) -> [text]:
    """Writes per-lane synthesis report templates consumed by budget evidence."""
    val synth_dir = "{output_dir}/synth"
    rtl_dir_create(synth_dir)
    var files: [text] = []
    for lane in manifest.lanes:
        val xl = lane.xlen.to_text()
        val path = "{synth_dir}/{xl}_synth.sdn"
        rtl_file_write_text(path, synth_report_template_text(lane, manifest.product))
        files = files.push(path)
    files

fn write_bundle_readme(output_dir: text) -> text:
    """Writes the bundle README to disk and returns its path."""
    val path = "{output_dir}/README.md"
    var lines: [text] = []
    lines = lines.push("# RISC-V FPGA Linux RTL Bundle")
    lines = lines.push("")
    lines = lines.push("Dual-arch RTL bundle for RISC-V FPGA integration with SimpleOS.")
    lines = lines.push("")
    lines = lines.push("## Contents")
    lines = lines.push("")
    lines = lines.push("- `riscv_fpga_rtl_manifest.sdn` — machine-readable lane manifest with provenance")
    lines = lines.push("- `board_linux_boot_products.sdn` — per-arch boot products manifest; per-arch boot products manifest: `board_linux_boot_products.sdn`")
    lines = lines.push("- `riscv_product.byl` — generated product proof-model surface")
    lines = lines.push("- `synth/rv32_synth.sdn`, `synth/rv64_synth.sdn` — synthesis report templates for budget evidence")
    lines = lines.push("- `rv32/rtl/` — generated RV32GC Linux lane RTL plus emitted runner testbenches")
    lines = lines.push("- `rv64/rtl/` — generated RV64GC Linux lane RTL plus emitted runner testbenches")
    lines = lines.push("")
    lines = lines.push("## Provenance")
    lines = lines.push("")
    lines = lines.push("Each lane directory is a non-authoritative contract bundle until a canonical compiler-produced CPU replaces the diagnostic placeholder.")
    lines = lines.push("Contract files are listed by `contract_file`; they must fail execution and formal proof with `GENERATED_RTL_NOT_IMPLEMENTED`.")
    lines = lines.push("Generated-core runners must compile RTL only from the emitted bundle directories `rv32/rtl` and `rv64/rtl`.")
    lines = lines.push("Current RV32 and RV64 CPU VHDL is emitted contract material, not product RTL.")
    lines = lines.push("No file in this bundle is authoritative until the manifest records compiler provenance and semantic execution evidence.")
    lines = lines.push("")
    rtl_file_write_text(path, lines.join("\n"))
    return path

fn generated_core_source(lane: text) -> text:
    "proof_lane: generated_{lane}_linux\nscope: repo-native {lane.upper()}GC generated-core Linux lane\n"

fn rv32_generated_hardware_source_spl() -> text:
    """Generated RV32I decode/control hardware helpers used by the VHDL lane."""
    var src = ""
    src = src + "# proof_lane: generated_rv32_linux\n"
    src = src + "# scope: repo-native RV32GC generated-core Linux lane\n\n"
    src = src + "@hardware\nfn simple_rv32i_core_decode_writeback(imem_rdata: u32, next_rd: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    val v_funct3 = (imem_rdata >> 12) & 7\n"
    src = src + "    val v_funct7 = (imem_rdata >> 25) & 127\n"
    src = src + "    val v_rs1 = (imem_rdata >> 15) & 31\n"
    src = src + "    val v_rs2 = (imem_rdata >> 20) & 31\n"
    src = src + "    if v_opcode == 19:\n"
    src = src + "        return (v_opcode << 8) | (v_funct3 << 5) | next_rd\n"
    src = src + "    else:\n"
    src = src + "        return (v_funct7 << 10) | (v_rs1 << 5) | v_rs2\n\n"

    src = src + "@hardware\nfn simple_rv32i_core_decode_branch_immediate(imem_rdata: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    if v_opcode == 99:\n"
    src = src + "        return (((imem_rdata >> 31) & 1) << 12) | (((imem_rdata >> 7) & 1) << 11) | (((imem_rdata >> 25) & 63) << 5) | (((imem_rdata >> 8) & 15) << 1)\n"
    src = src + "    else:\n"
    src = src + "        return 0\n\n"

    src = src + "@hardware\nfn simple_rv32i_core_decode_store_immediate(imem_rdata: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    if v_opcode == 35:\n"
    src = src + "        return (((imem_rdata >> 25) & 127) << 25) | (((imem_rdata >> 7) & 31) << 20)\n"
    src = src + "    else:\n"
    src = src + "        return 0\n\n"

    src = src + "@hardware\nfn simple_rv32i_core_decode_i_immediate(imem_rdata: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    if v_opcode == 19 or v_opcode == 3:\n"
    src = src + "        return ((imem_rdata >> 20) & 4095) << 20\n"
    src = src + "    else:\n"
    src = src + "        return 0\n\n"

    src = src + "@hardware\nfn simple_rv32i_core_decode_upper_immediate(imem_rdata: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    if v_opcode == 55 or v_opcode == 23:\n"
    src = src + "        return ((imem_rdata >> 12) & 1048575) << 12\n"
    src = src + "    else:\n"
    src = src + "        return 0\n\n"

    src = src + "@hardware\nfn simple_rv32i_core_decode_execute_control(imem_rdata: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    val v_funct3 = (imem_rdata >> 12) & 7\n"
    src = src + "    val v_shamt_low5 = (imem_rdata >> 20) & 31\n"
    src = src + "    val v_shamt_bit5 = (imem_rdata >> 25) & 1\n"
    src = src + "    val v_bit30 = (imem_rdata >> 30) & 1\n"
    src = src + "    if v_opcode == 19 or v_opcode == 51 or v_opcode == 99:\n"
    src = src + "        return (v_funct3 << 7) | (v_shamt_low5 << 2) | (v_shamt_bit5 << 1) | v_bit30\n"
    src = src + "    else:\n"
    src = src + "        return 0\n\n"

    src = src + "@hardware\nfn simple_rv32i_core_decode_execute_datapath(imem_rdata: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    val v_funct3 = (imem_rdata >> 12) & 7\n"
    src = src + "    val v_bit30 = (imem_rdata >> 30) & 1\n"
    src = src + "    if v_opcode == 51:\n"
    src = src + "        return (v_funct3 << 8) | (v_bit30 << 7) | v_opcode\n"
    src = src + "    else:\n"
    src = src + "        return 0\n\n"

    src = src + "@hardware\nfn simple_rv32i_core_decode_branch_datapath(imem_rdata: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    val v_funct3 = (imem_rdata >> 12) & 7\n"
    src = src + "    if v_opcode == 99:\n"
    src = src + "        return (v_funct3 << 7) | v_opcode\n"
    src = src + "    else:\n"
    src = src + "        return 0\n\n"

    src = src + "@hardware\nfn simple_rv32i_core_decode_control_flow_datapath(imem_rdata: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    if v_opcode == 103:\n"
    src = src + "        return (((imem_rdata >> 20) & 4095) << 8) | (((imem_rdata >> 15) & 31) << 3) | ((imem_rdata >> 12) & 7)\n"
    src = src + "    else:\n"
    src = src + "        return (((imem_rdata >> 20) & 4095) << 8) | ((imem_rdata >> 12) & 255)\n\n"

    src = src + "@hardware\nfn simple_rv32i_core_decode_memory_access_control(imem_rdata: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    val v_funct3 = (imem_rdata >> 12) & 7\n"
    src = src + "    if v_opcode == 3 or v_opcode == 35:\n"
    src = src + "        return (v_funct3 << 7) | v_opcode\n"
    src = src + "    else:\n"
    src = src + "        return 0\n\n"

    src = src + "@hardware\nfn simple_rv32i_core_decode_jump_immediate(imem_rdata: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    if v_opcode == 111:\n"
    src = src + "        return (((imem_rdata >> 31) & 1) << 20) | (((imem_rdata >> 12) & 255) << 12) | (((imem_rdata >> 20) & 1) << 11) | (((imem_rdata >> 21) & 1023) << 1)\n"
    src = src + "    else:\n"
    src = src + "        return 0\n\n"

    src = src + "@hardware\nfn simple_rv32i_core_decode_dispatch_class(imem_rdata: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    if v_opcode == 111:\n"
    src = src + "        return (v_opcode << 25) | 1\n"
    src = src + "    else:\n"
    src = src + "        return 0\n\n"

    src = src + "@hardware\nfn simple_rv32i_core_decode_trap_halt_control(imem_rdata: u32) -> u32:\n"
    src = src + "    val v_opcode = imem_rdata & 127\n"
    src = src + "    if v_opcode == 115:\n"
    src = src + "        return (((imem_rdata >> 20) & 4095) << 15) | (((imem_rdata >> 15) & 31) << 10) | (((imem_rdata >> 12) & 7) << 7) | v_opcode\n"
    src = src + "    else:\n"
    src = src + "        return 0\n"
    src

fn rv32_pkg_vhdl() -> text:
    "library ieee;\nuse ieee.std_logic_1164.all;\npackage rv32i_pkg is\n  constant OP_LUI    : std_logic_vector(6 downto 0) := \"0110111\";\nend package rv32i_pkg;\n"

fn rv32_core_pkg_vhdl() -> text:
    "-- generated-from: simple_rv32gc_core.spl\n-- proof-lane: generated_rv32_linux shell=none\n-- readiness: contract-not-ready linux-boot-validated=false\n-- reason: placeholder-core-no-semantic-rvfi\npackage simple_rv32gc_core_pkg is\nend package simple_rv32gc_core_pkg;\n"

fn generated_core_vhdl(entity_name: text, source_name: text, lane: text) -> text:
    "-- generated-from: {source_name}\n-- proof-lane: generated_{lane}_linux shell=none\n-- readiness: contract-not-ready linux-boot-validated=false\n-- reason: placeholder-core-no-semantic-rvfi\nlibrary ieee;\nuse ieee.std_logic_1164.all;\nentity {entity_name} is\n  port (clk : in std_logic; rst : in std_logic);\nend entity {entity_name};\narchitecture rtl of {entity_name} is\nbegin\n  assert false report \"GENERATED_RTL_NOT_IMPLEMENTED lane={lane}\" severity failure;\nend architecture rtl;\n"

fn generated_rvfi_core_vhdl(entity_name: text, source_name: text, lane: text, bits: text) -> text:
    val high = if bits == "32": "31" else: "63"
    val mask_high = if bits == "32": "3" else: "7"
    "-- generated-from: {source_name}\n-- proof-lane: generated_{lane}_linux shell=none\n-- readiness: contract-not-ready linux-boot-validated=false formal-rvfi-ready=false\n-- reason: placeholder-core-no-semantic-rvfi\nlibrary ieee;\nuse ieee.std_logic_1164.all;\nentity {entity_name} is\n  port (\n    clk : in std_logic;\n    rst : in std_logic;\n    rvfi_valid : out std_logic := '0';\n    rvfi_order : out std_logic_vector(63 downto 0) := (others => '0');\n    rvfi_insn : out std_logic_vector(31 downto 0) := (others => '0');\n    rvfi_trap : out std_logic := '0';\n    rvfi_rs1_addr : out std_logic_vector(4 downto 0) := (others => '0');\n    rvfi_rs2_addr : out std_logic_vector(4 downto 0) := (others => '0');\n    rvfi_rs1_rdata : out std_logic_vector({high} downto 0) := (others => '0');\n    rvfi_rs2_rdata : out std_logic_vector({high} downto 0) := (others => '0');\n    rvfi_rd_addr : out std_logic_vector(4 downto 0) := (others => '0');\n    rvfi_rd_wdata : out std_logic_vector({high} downto 0) := (others => '0');\n    rvfi_pc_rdata : out std_logic_vector({high} downto 0) := (others => '0');\n    rvfi_pc_wdata : out std_logic_vector({high} downto 0) := (others => '0');\n    rvfi_mem_addr : out std_logic_vector({high} downto 0) := (others => '0');\n    rvfi_mem_rmask : out std_logic_vector({mask_high} downto 0) := (others => '0');\n    rvfi_mem_wmask : out std_logic_vector({mask_high} downto 0) := (others => '0');\n    rvfi_mem_rdata : out std_logic_vector({high} downto 0) := (others => '0');\n    rvfi_mem_wdata : out std_logic_vector({high} downto 0) := (others => '0');\n    semi_trigger : out std_logic := '0';\n    semi_op : out std_logic_vector(31 downto 0) := (others => '0');\n    semi_param : out std_logic_vector({high} downto 0) := (others => '0');\n    debug_pc : out std_logic_vector({high} downto 0) := (others => '0')\n  );\nend entity {entity_name};\narchitecture rtl of {entity_name} is\nbegin\n  assert false report \"GENERATED_RTL_NOT_IMPLEMENTED lane={lane}\" severity failure;\nend architecture rtl;\n"

fn rv32_wrapper_vhdl() -> text:
    "library ieee;\nuse ieee.std_logic_1164.all;\nuse work.simple_rv32gc_core_pkg.all;\nentity rv32i_generated_wrapper is\n  port (clk : in std_logic; rst : in std_logic);\nend entity rv32i_generated_wrapper;\narchitecture rtl of rv32i_generated_wrapper is\nbegin\n  u_core : entity work.simple_rv32gc_core port map(clk => clk, rst => rst);\nend architecture rtl;\n"

fn runner_tb_vhdl(entity_name: text, core_name: text, package_name: text, lane: text) -> text:
    "library ieee;\nuse ieee.std_logic_1164.all;\nuse work.{package_name}.all;\nentity {entity_name} is\nend entity {entity_name};\narchitecture tb of {entity_name} is\n  signal clk : std_logic := '0';\n  signal rst : std_logic := '0';\nbegin\n  u_cpu : entity work.{core_name} port map(clk => clk, rst => rst);\n  process\n  begin\n    assert false report \"GENERATED_RTL_NOT_IMPLEMENTED lane={lane}\" severity failure;\n    wait;\n  end process;\nend architecture tb;\n"

fn formal_harness_vhdl(lane: text, core: text) -> text:
    val high = if lane == "rv32": "31" else: "63"
    val mask_high = if lane == "rv32": "3" else: "7"
    "library ieee;\nuse ieee.std_logic_1164.all;\n\nentity {core}_formal is\nend entity {core}_formal;\n\narchitecture formal of {core}_formal is\n  signal clk : std_logic := '0';\n  signal rst : std_logic := '0';\n  signal rvfi_valid : std_logic;\n  signal rvfi_order : std_logic_vector(63 downto 0);\n  signal rvfi_insn : std_logic_vector(31 downto 0);\n  signal rvfi_trap : std_logic;\n  signal rvfi_rs1_addr : std_logic_vector(4 downto 0);\n  signal rvfi_rs2_addr : std_logic_vector(4 downto 0);\n  signal rvfi_rs1_rdata : std_logic_vector({high} downto 0);\n  signal rvfi_rs2_rdata : std_logic_vector({high} downto 0);\n  signal rvfi_rd_addr : std_logic_vector(4 downto 0);\n  signal rvfi_rd_wdata : std_logic_vector({high} downto 0);\n  signal rvfi_pc_rdata : std_logic_vector({high} downto 0);\n  signal rvfi_pc_wdata : std_logic_vector({high} downto 0);\n  signal rvfi_mem_addr : std_logic_vector({high} downto 0);\n  signal rvfi_mem_rmask : std_logic_vector({mask_high} downto 0);\n  signal rvfi_mem_wmask : std_logic_vector({mask_high} downto 0);\n  signal rvfi_mem_rdata : std_logic_vector({high} downto 0);\n  signal rvfi_mem_wdata : std_logic_vector({high} downto 0);\nbegin\n  dut: entity work.{core}\n    port map (\n      clk => clk,\n      rst => rst,\n      rvfi_valid => rvfi_valid,\n      rvfi_order => rvfi_order,\n      rvfi_insn => rvfi_insn,\n      rvfi_trap => rvfi_trap,\n      rvfi_rs1_addr => rvfi_rs1_addr,\n      rvfi_rs2_addr => rvfi_rs2_addr,\n      rvfi_rs1_rdata => rvfi_rs1_rdata,\n      rvfi_rs2_rdata => rvfi_rs2_rdata,\n      rvfi_rd_addr => rvfi_rd_addr,\n      rvfi_rd_wdata => rvfi_rd_wdata,\n      rvfi_pc_rdata => rvfi_pc_rdata,\n      rvfi_pc_wdata => rvfi_pc_wdata,\n      rvfi_mem_addr => rvfi_mem_addr,\n      rvfi_mem_rmask => rvfi_mem_rmask,\n      rvfi_mem_wmask => rvfi_mem_wmask,\n      rvfi_mem_rdata => rvfi_mem_rdata,\n      rvfi_mem_wdata => rvfi_mem_wdata\n    );\n  assert false report \"GENERATED_RTL_NOT_IMPLEMENTED lane={lane} formal-proof-unavailable\" severity failure;\nend architecture formal;\n"

fn formal_sby_text(lane: text, core: text) -> text:
    "[options]\nmode prove\ndepth 8\n\n[engines]\nsmtbmc\n\n[script]\nplugin -i ghdl\nghdl --std=08 {core}_pkg.vhd {core}.vhd {core}_formal.vhd -e {core}_formal\nprep -top {core}_formal\n\n[files]\n{core}_pkg.vhd\n{core}.vhd\n{core}_formal.vhd\n"

fn formal_manifest_text(lane: text, core: text) -> text:
    "lane = \"{lane}\"\nstatus = \"contract-not-ready\"\nreason = \"placeholder-core-no-semantic-rvfi\"\nproof_style = \"placeholder-rejected\"\nrunner = \"sby -f {core}.sby\"\nharness = \"{core}_formal.vhd\"\nsby = \"{core}.sby\"\n"

fn sidecar_json(output_dir: text, lane: text, product: RiscvFpgaProductProfile) -> text:
    val xlen = if lane == "rv32": "32" else: "64"
    val abi = if lane == "rv32": "ilp32" else: "lp64"
    val mmu = if lane == "rv32": "sv32" else: "sv39"
    val luts = if lane == "rv32": product.rv32_luts else: product.rv64_luts
    val mhz = if lane == "rv32": product.rv32_mhz else: product.rv64_mhz
    val formal_status = "contract-not-ready"
    val formal_reason = "placeholder-core-no-semantic-rvfi"
    val observed_rvfi_ports = 0
    val runner_testbenches = if lane == "rv32": "[{\"file\":\"tb_generated_rv32_linux_handoff.vhd\", \"status\":\"contract-not-ready\"}, {\"file\":\"tb_generated_rv32_boot_info_real_dtb.vhd\", \"status\":\"contract-not-ready\"}]" else: "[{\"file\":\"tb_generated_rv64_boot_info_dtb.vhd\", \"status\":\"contract-not-ready\"}, {\"file\":\"tb_generated_rv64_fw_jump.vhd\", \"status\":\"contract-not-ready\"}, {\"file\":\"tb_generated_rv64_boot_info_real_dtb.vhd\", \"status\":\"contract-not-ready\"}, {\"file\":\"tb_generated_rv64_sv39.vhd\", \"status\":\"contract-not-ready\"}, {\"file\":\"tb_generated_rv64_sv39_fault.vhd\", \"status\":\"contract-not-ready\"}]"
    val report_markers = "[\"GENERATED_RTL_NOT_IMPLEMENTED\"]"
    val runners = "{}"
    val core = "simple_{lane}gc_core"
    val observability = "{\"fetch\": false, \"trap\": false, \"halt\": false, \"memoryAccess\": false, \"registerProbes\": false, \"debugProbes\": false, \"proofFailureReports\": true}"
    "{\"schemaVersion\": \"riscv_rtl_debuggability_lint/v1\", \"laneId\": \"{lane}\", \"proofLane\": \"generated_{lane}_linux\", \"xlen\": \"{lane}\", \"generatedFrom\": \"{core}.spl\", \"topModule\": \"{core}\", \"rtlDir\": \"{output_dir}/{lane}/rtl\", \"shellSummary\": \"generated_{lane}_linux shell=none\", \"readiness\": \"contract-not-ready\", \"reason\": \"placeholder-core-no-semantic-rvfi\", \"linuxBootValidated\": false, \"platform\": \"qemu_virt_{lane}\", \"scope\": \"repo-native RV{xlen}GC generated-core Linux lane\", \"linuxPolicy\": \"repo-native-{lane}-linux\", \"productLevel\": \"{product.product_level}\", \"configurationProfile\": \"{product.configuration_profile}\", \"authoritative\": false, \"provenance\": {\"authoritativeRtl\": \"none\", \"contractFiles\": [\"{output_dir}/{lane}/rtl/{core}.spl\", \"{output_dir}/{lane}/rtl/{core}_pkg.vhd\", \"{output_dir}/{lane}/rtl/{core}.vhd\", \"{output_dir}/{lane}/rtl/{core}.debug.json\"], \"auxiliaryVhdl\": \"emitted-text-vhdl\", \"runnerTestbenches\": \"emitted-text-vhdl\", \"pureSimpleAuthoritativeRtl\": false}, \"abi\": \"{abi}\", \"mmu\": \"{mmu}\", \"rtlBudget\": {\"maxLuts\": {luts}, \"targetMhz\": {mhz}}, \"formal\": {\"flow\": \"rvfi+sby\", \"gate\": \"placeholder-rejected\", \"status\": \"{formal_status}\", \"reason\": \"{formal_reason}\", \"rvfiPortCount\": 17, \"observedRvfiPortCount\": {observed_rvfi_ports}, \"harness\": \"{output_dir}/{lane}/rtl/{core}_formal.vhd\", \"sby\": \"{output_dir}/{lane}/rtl/{core}.sby\", \"manifest\": \"{output_dir}/{lane}/rtl/{core}_formal.sdn\"}, \"firmwareMode\": \"fw_jump\", \"acceptanceMarkers\": [\"OpenSBI\", \"Linux version\", \"OF: fdt\", \"Freeing unused kernel memory\", \"init started\"], \"observability\": {observability}, \"reportMarkers\": {report_markers}, \"runnerSuccessMarkers\": {runners}, \"runnerTestbenches\": {runner_testbenches}, \"sourceMap\": [], \"debugOutputs\": [\"semi_trigger\", \"semi_op\", \"semi_param\", \"debug_pc\"], \"shellServices\": {\"semihost\": false, \"mailbox\": false}}\n"

fn write_generated_core_lane(output_dir: text, lane: text, rtl_dir: text, product: RiscvFpgaProductProfile) -> [text]:
    val core = "simple_{lane}gc_core"
    var files: [text] = []
    val source_path = "{rtl_dir}/{core}.spl"
    rtl_file_write_text(source_path, if lane == "rv32": RiscvFpgaLane.rv32_default().hardware_source_spl() else: generated_core_source(lane))
    files = files.push(source_path)
    val pkg_path = "{rtl_dir}/{core}_pkg.vhd"
    rtl_file_write_text(pkg_path, if lane == "rv32": rv32_core_pkg_vhdl() else: "-- generated-from: {core}.spl\n-- proof-lane: generated_{lane}_linux shell=none\n-- readiness: contract-not-ready linux-boot-validated=false\n-- reason: placeholder-core-no-semantic-rvfi\npackage {core}_pkg is\nend package {core}_pkg;\n")
    files = files.push(pkg_path)
    val core_path = "{rtl_dir}/{core}.vhd"
    rtl_file_write_text(core_path, generated_rvfi_core_vhdl(core, "{core}.spl", lane, if lane == "rv32": "32" else: "64"))
    files = files.push(core_path)
    val sidecar_path = "{rtl_dir}/{core}.debug.json"
    rtl_file_write_text(sidecar_path, sidecar_json(output_dir, lane, product))
    files = files.push(sidecar_path)
    val formal_harness_path = "{rtl_dir}/{core}_formal.vhd"
    rtl_file_write_text(formal_harness_path, formal_harness_vhdl(lane, core))
    files = files.push(formal_harness_path)
    val formal_sby_path = "{rtl_dir}/{core}.sby"
    rtl_file_write_text(formal_sby_path, formal_sby_text(lane, core))
    files = files.push(formal_sby_path)
    val formal_manifest_path = "{rtl_dir}/{core}_formal.sdn"
    rtl_file_write_text(formal_manifest_path, formal_manifest_text(lane, core))
    files = files.push(formal_manifest_path)
    files

fn write_soc_vhdl(rtl_dir: text):
    """Generates SoC peripheral VHDL into the RTL directory."""
    val soc = generate_soc_vhdl_bundle()
    rtl_file_write_text("{rtl_dir}/bootrom.vhd", soc.bootrom)
    rtl_file_write_text("{rtl_dir}/soc_ram.vhd", soc.ram)
    rtl_file_write_text("{rtl_dir}/uart16550.vhd", soc.uart)
    rtl_file_write_text("{rtl_dir}/clint.vhd", soc.clint)
    rtl_file_write_text("{rtl_dir}/wb_interconnect.vhd", soc.wb_interconnect)
    rtl_file_write_text("{rtl_dir}/soc_mailbox.vhd", soc.mailbox)
    rtl_file_write_text("{rtl_dir}/soc_top.vhd", soc.soc_top)
    rtl_file_write_text("{rtl_dir}/tb_soc_boot.vhd", soc.testbench)

fn write_rtl_sources(output_dir: text, manifest: RiscvFpgaLinuxManifest) -> Result<[text], text>:
    """Copies CPU RTL and generates SoC peripheral VHDL into the bundle."""
    var generated_files: [text] = []
    for lane in manifest.lanes:
        val rdir = lane.rtl_dir_name()
        val arch_dir = "{output_dir}/{rdir}"
        val rtl_dir = "{arch_dir}/rtl"
        rtl_dir_create(arch_dir)
        rtl_dir_create(rtl_dir)

        match lane.xlen:
            case Rv32:
                generated_files = generated_files + write_generated_core_lane(output_dir, "rv32", rtl_dir, manifest.product)
                rtl_file_write_text("{rtl_dir}/rv32i_pkg.vhd", rv32_pkg_vhdl())
                rtl_file_write_text("{rtl_dir}/alu.vhd", generated_core_vhdl("alu", "simple_rv32gc_core.spl", "rv32"))
                rtl_file_write_text("{rtl_dir}/decoder.vhd", generated_core_vhdl("decoder", "simple_rv32gc_core.spl", "rv32"))
                rtl_file_write_text("{rtl_dir}/regfile.vhd", generated_core_vhdl("regfile", "simple_rv32gc_core.spl", "rv32"))
                rtl_file_write_text("{rtl_dir}/rv32i_core.vhd", generated_core_vhdl("rv32i_core", "simple_rv32gc_core.spl", "rv32"))
                rtl_file_write_text("{rtl_dir}/rv32i_generated_wrapper.vhd", rv32_wrapper_vhdl())
                rtl_file_write_text("{rtl_dir}/tb_generated_rv32_linux_handoff.vhd", runner_tb_vhdl("tb_generated_rv32_linux_handoff", "simple_rv32gc_core", "simple_rv32gc_core_pkg", "rv32"))
                rtl_file_write_text("{rtl_dir}/tb_generated_rv32_boot_info_real_dtb.vhd", runner_tb_vhdl("tb_generated_rv32_boot_info_real_dtb", "simple_rv32gc_core", "simple_rv32gc_core_pkg", "rv32"))
                write_soc_vhdl(rtl_dir)
            case Rv64:
                generated_files = generated_files + write_generated_core_lane(output_dir, "rv64", rtl_dir, manifest.product)
                rtl_file_write_text("{rtl_dir}/simple_rv64i_core_pkg.vhd", "-- generated-from: simple_rv64gc_core.spl\npackage simple_rv64i_core_pkg is\nend package simple_rv64i_core_pkg;\n")
                rtl_file_write_text("{rtl_dir}/tb_generated_rv64_linux_handoff.vhd", runner_tb_vhdl("tb_generated_rv64_linux_handoff", "simple_rv64gc_core", "simple_rv64gc_core_pkg", "rv64"))
                rtl_file_write_text("{rtl_dir}/tb_generated_rv64_boot_banner.vhd", runner_tb_vhdl("tb_generated_rv64_boot_banner", "simple_rv64gc_core", "simple_rv64gc_core_pkg", "rv64"))
                rtl_file_write_text("{rtl_dir}/tb_generated_rv64_boot_info_dtb.vhd", runner_tb_vhdl("tb_generated_rv64_boot_info_dtb", "simple_rv64gc_core", "simple_rv64gc_core_pkg", "rv64"))
                rtl_file_write_text("{rtl_dir}/tb_generated_rv64_fw_jump.vhd", runner_tb_vhdl("tb_generated_rv64_fw_jump", "simple_rv64gc_core", "simple_rv64gc_core_pkg", "rv64"))
                rtl_file_write_text("{rtl_dir}/tb_generated_rv64_boot_info_real_dtb.vhd", runner_tb_vhdl("tb_generated_rv64_boot_info_real_dtb", "simple_rv64gc_core", "simple_rv64gc_core_pkg", "rv64"))
                rtl_file_write_text("{rtl_dir}/tb_generated_rv64_sv39.vhd", runner_tb_vhdl("tb_generated_rv64_sv39", "simple_rv64gc_core", "simple_rv64gc_core_pkg", "rv64"))
                rtl_file_write_text("{rtl_dir}/tb_generated_rv64_sv39_fault.vhd", runner_tb_vhdl("tb_generated_rv64_sv39_fault", "simple_rv64gc_core", "simple_rv64gc_core_pkg", "rv64"))
                write_soc_vhdl(rtl_dir)
    Ok(generated_files)

pub fn generate_default_riscv_fpga_rtl_bundle(output_dir: text) -> Result<RtlBundle, text>:
    """
    Generates the default dual-arch RTL bundle (generic board) at the
    given output directory. Copies synthesizable VHDL sources, creates
    manifest, boot products, and README.
    """
    val manifest = create_default_riscv_fpga_linux_manifest()
    rtl_dir_create(output_dir)
    val generated_files = match write_rtl_sources(output_dir, manifest):
        Ok(value):
            value
        Err(message):
            return Err(message)
    val manifest_path = write_manifest_file(output_dir, manifest)
    val products_path = write_boot_products_file(output_dir, manifest)
    val byl_path = write_product_byl_file(output_dir, manifest)
    val synth_templates = write_synth_report_templates(output_dir, manifest)
    val readme_path = write_bundle_readme(output_dir)
    Ok(RtlBundle(
        output_dir: output_dir,
        manifest_path: manifest_path,
        board_linux_boot_products_manifest_path: products_path,
        bundle_readme_path: readme_path,
        generated_files: (generated_files + synth_templates).push(manifest_path).push(products_path).push(byl_path).push(readme_path)
    ))

pub fn generate_default_riscv_fpga_rtl_bundle_with_profile(output_dir: text, configuration_profile: text) -> Result<RtlBundle, text>:
    """
    Generates the default dual-arch RTL bundle with a custom configuration profile.
