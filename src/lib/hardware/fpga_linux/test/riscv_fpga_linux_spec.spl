#![allow(primitive_api)]

# RISC-V FPGA Linux Integration Spec
#
# Tests board profiles, lane contracts, manifest generation, and
# RTL bundle output against the plan requirements in
# doc/03_plan/agent_tasks/riscv_fpga_linux.md

use std.io_runtime
use std.nogc_sync_mut.spec.{describe, it, expect}
use hardware.fpga_linux.riscv_fpga_linux.{
    RiscvReadinessStatus, Xlen, ProofLane, QemuMachineProfile,
    XilinxBoardProfile, RiscvFpgaLane, RiscvFpgaLinuxManifest,
    create_default_riscv_fpga_linux_manifest,
    create_riscv_fpga_linux_manifest_for_board,
    generate_default_riscv_fpga_rtl_bundle,
    generate_riscv_fpga_rtl_bundle_for_board,
    read_generated_riscv_fpga_rtl_file
}

fn main():
    # -----------------------------------------------------------------
    # Readiness status
    # -----------------------------------------------------------------
    describe("RiscvReadinessStatus"):
        it("serializes Contract to text"):
            expect(RiscvReadinessStatus.Contract.to_text()).to_equal("contract")

        it("serializes QemuValidated to text"):
            expect(RiscvReadinessStatus.QemuValidated.to_text()).to_equal("qemu_validated")

        it("serializes FpgaSynthesized to text"):
            expect(RiscvReadinessStatus.FpgaSynthesized.to_text()).to_equal("fpga_synthesized")

        it("serializes HardwareBooted to text"):
            expect(RiscvReadinessStatus.HardwareBooted.to_text()).to_equal("hardware_booted")

    # -----------------------------------------------------------------
    # Xlen
    # -----------------------------------------------------------------
    describe("Xlen"):
        it("returns linux policy for rv32"):
            expect(Xlen.Rv32.linux_policy()).to_equal("repo-native-rv32-linux")

        it("returns linux policy for rv64"):
            expect(Xlen.Rv64.linux_policy()).to_equal("repo-native-rv64-linux")

        it("returns core file name for rv32"):
            expect(Xlen.Rv32.core_file_name()).to_equal("simple_rv32gc_core.spl")

        it("returns core file name for rv64"):
            expect(Xlen.Rv64.core_file_name()).to_equal("simple_rv64gc_core.vhd")

    # -----------------------------------------------------------------
    # QEMU Machine Profile
    # -----------------------------------------------------------------
    describe("QemuMachineProfile"):
        it("creates rv32 default with 128M memory"):
            val qemu = QemuMachineProfile.default_for(Xlen.Rv32)
            expect(qemu.machine).to_equal("virt")
            expect(qemu.memory).to_equal("128M")
            expect(qemu.smp).to_equal(1)

        it("creates rv64 default with 256M memory"):
            val qemu = QemuMachineProfile.default_for(Xlen.Rv64)
            expect(qemu.memory).to_equal("256M")
            expect(qemu.smp).to_equal(2)

        it("selects correct qemu binary"):
            val rv32 = QemuMachineProfile.default_for(Xlen.Rv32)
            val rv64 = QemuMachineProfile.default_for(Xlen.Rv64)
            expect(rv32.qemu_binary()).to_equal("qemu-system-riscv32")
            expect(rv64.qemu_binary()).to_equal("qemu-system-riscv64")

    # -----------------------------------------------------------------
    # Xilinx Board Profile
    # -----------------------------------------------------------------
    describe("XilinxBoardProfile"):
        it("creates generic profile with no part"):
            val generic = XilinxBoardProfile.generic()
            expect(generic.name).to_equal("xilinx_generic")
            expect(generic.part).to_equal("")

        it("generic passes prepare validation"):
            val generic = XilinxBoardProfile.generic()
            expect(generic.validate_for_prepare().len()).to_equal(0)

        it("generic blocks hardware boot"):
            val generic = XilinxBoardProfile.generic()
            val msg = generic.validate_for_hardware_boot()
            expect(msg).to_contain("xilinx part must be selected before hardware boot")

        it("resolves mlk_s02_100t with correct part"):
            val mlk = XilinxBoardProfile.from_id("mlk_s02_100t").ok().unwrap()
            expect(mlk.part).to_equal("xc7a100tfgg484-2")
            expect(mlk.clock_hz).to_equal(25000000)
            expect(mlk.programmer).to_equal("openFPGALoader")

        it("mlk passes hardware boot validation"):
            val mlk = XilinxBoardProfile.from_id("mlk_s02_100t").ok().unwrap()
            expect(mlk.validate_for_hardware_boot()).to_equal("")

        it("returns error for unknown board"):
            val result = XilinxBoardProfile.from_id("nonexistent")
            expect(result.is_err()).to_equal(true)

    # -----------------------------------------------------------------
    # RISC-V FPGA Lane
    # -----------------------------------------------------------------
    describe("RiscvFpgaLane"):
        it("rv32 default is at Contract readiness"):
            val rv32 = RiscvFpgaLane.rv32_default()
            expect(rv32.readiness_status()).to_equal(RiscvReadinessStatus.Contract)

        it("rv32 has correct proof lane"):
            val rv32 = RiscvFpgaLane.rv32_default()
            expect(rv32.proof_lane().to_text()).to_equal("generated_rv32_linux")

        it("rv64 has correct proof lane"):
            val rv64 = RiscvFpgaLane.rv64_default()
            expect(rv64.proof_lane().to_text()).to_equal("generated_rv64_linux")

        it("rv32 xlen has correct linux policy"):
            val rv32 = RiscvFpgaLane.rv32_default()
            expect(rv32.xlen.linux_policy()).to_equal("repo-native-rv32-linux")

        it("summary token contains status and qemu id"):
            val rv32 = RiscvFpgaLane.rv32_default()
            expect(rv32.summary_token()).to_contain("rv32")
            expect(rv32.summary_token()).to_contain("contract")

    # -----------------------------------------------------------------
    # Manifest — default dual-arch
    # -----------------------------------------------------------------
    describe("RiscvFpgaLinuxManifest default"):
        it("has exactly 2 lanes"):
            val manifest = create_default_riscv_fpga_linux_manifest()
            expect(manifest.lanes.len()).to_equal(2)

        it("readiness summary contains both lanes"):
            val manifest = create_default_riscv_fpga_linux_manifest()
            val summary = manifest.readiness_summary()
            expect(summary).to_contain("rv32:contract:qemu_virt_rv32")
            expect(summary).to_contain("rv64:contract:qemu_virt_rv64")

    # -----------------------------------------------------------------
    # Manifest — board-specific
    # -----------------------------------------------------------------
    describe("RiscvFpgaLinuxManifest for board"):
        it("creates manifest for mlk_s02_100t"):
            val result = create_riscv_fpga_linux_manifest_for_board("mlk_s02_100t")
            expect(result.is_ok()).to_equal(true)
            val manifest = result.ok().unwrap()
            expect(manifest.board.name).to_equal("mlk_s02_100t")

        it("vivado tcl plan references constraint file"):
            val manifest = create_riscv_fpga_linux_manifest_for_board("mlk_s02_100t").ok().unwrap()
            val tcl = manifest.vivado_tcl_plan()
            expect(tcl).to_contain("examples/09_embedded/fpga_riscv/constraints/mlk_s02_100t.xdc")

        it("boot products manifest has correct product ids"):
            val manifest = create_riscv_fpga_linux_manifest_for_board("mlk_s02_100t").ok().unwrap()
            val products = manifest.board_linux_boot_products_manifest_text("/tmp/test_boot")
            expect(products).to_contain("product_id = \"mlk_s02_100t_rv32_linux\"")
            expect(products).to_contain("product_id = \"mlk_s02_100t_rv64_linux\"")

        it("boot products contain boot script and validation"):
            val manifest = create_riscv_fpga_linux_manifest_for_board("mlk_s02_100t").ok().unwrap()
            val products = manifest.board_linux_boot_products_manifest_text("/tmp/test_boot")
            expect(products).to_contain("boot_script = \"scripts/mlk_s02_100t_generated_linux_boot.shs\"")
            expect(products).to_contain("validation_kind = \"linux-uart-markers\"")
            expect(products).to_contain("expected_markers = \"OpenSBI|Linux version|OF: fdt|Freeing unused kernel memory|init started\"")

        it("returns error for unknown board"):
            val result = create_riscv_fpga_linux_manifest_for_board("nonexistent")
            expect(result.is_err()).to_equal(true)
