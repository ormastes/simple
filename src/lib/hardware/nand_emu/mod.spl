# NAND Chip Emulator (K9F8G08X0M-compatible) — module declarations
#
# A per-cell threshold-voltage (Vt) byte model NAND emulator. See
# doc/01_research/hardware/nand_emu/nand_emu_fpga_riscv_emulator.md.
#
# - nand_types: shared structs/enums + datasheet constants (Ne-prefixed)
# - geometry:   shrink-profile tables, address latch/decode, OOB policy
# - vt_array:   Vt byte array + page/block metadata + per-cell seed
# - physics:    ISPP program/erase, retention/disturb drift, lazy sense
# - cmd_fsm:    command legality + sequencing state machine
# - status:     70h / F1h / 7Bh status register assembly
# - edc:        1 bit/528 B parity EDC + copy-back validity
# - badblock:   deterministic factory bad-block map
# - fault:      fault injection descriptors (SPO / prog-fail / erase-fail / time)
# - chip:       NeChip composing all of the above; host + test API
# - rtl:        VHDL-2008-subset pin frontend feasibility spike

mod nand_types
mod geometry
mod vt_array
mod physics
mod cmd_fsm
mod status
mod edc
mod badblock
mod fault
mod chip
mod rtl
