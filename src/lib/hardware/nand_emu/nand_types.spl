# ============================================================================
# nand_emu — Shared type definitions (K9F8G08X0M-compatible NAND emulator)
# ============================================================================
#
# ALL shared structs / enums for the NAND emulator live here so that no type
# name is declared twice (a duplicate struct/enum name in two modules is an
# interpreter global-registry collision). Every public type is prefixed `Ne`.
#
# Source of truth: doc/01_research/hardware/nand_emu/nand_emu_fpga_riscv_emulator.md
#   §1 datasheet contract, §3 Vt model, §4 address shrink, §7 firmware design,
#   Appendix A (memory layout) + Appendix B (default physics coefficients).
#
# Constants are exposed as `fn` returning literals (freestanding-safe habit) —
# never module-level collection initializers.
# ============================================================================

# ----------------------------------------------------------------------------
# Shrink profiles (doc §4.1). v1 supports S1/S2/S3 only (No S4+); S1 default.
# ----------------------------------------------------------------------------

pub enum NeProfile:
    """Address-shrink profile selecting the emulated geometry (doc §4.1).

    S1 nano  — 528 B page, 4 pages/blk, 8 blocks  (132 KB Vt RAM), default.
    S2 micro — 528 B page, 8 pages/blk, 32 blocks (1.03 MB Vt RAM).
    S3 small — 4224 B page (real 8-sector), 8 pages/blk, 16 blocks (4.13 MB).
    """
    S1
    S2
    S3

impl NeProfile:
    fn to_text() -> text:
        match self:
            case S1: "s1"
            case S2: "s2"
            case S3: "s3"

# ----------------------------------------------------------------------------
# Geometry (doc §1.1, §4). Fully materialized address-decode parameters.
# ----------------------------------------------------------------------------

pub struct NeGeometry:
    """Resolved geometry for a shrink profile (doc §1.1 / §4).

    page_bytes       — bytes per page including spare (S1/S2 = 528, S3 = 4224).
    sector_bytes     — EDC unit size, always 528 B = 512 main + 16 spare.
    sectors_per_page — 528 B sectors per page (1 for S1/S2, 8 for S3).
    pages_per_block  — pages in one erase block.
    blocks           — number of blocks backed by the model.
    total_pages      — pages_per_block * blocks.
    col_mask         — page-shaped column mask = page_bytes - 1 (doc §4).
    row_mask         — model row mask = total_pages - 1 (doc §4).
    row_base         — base row offset added after masking (doc §4).
    """
    page_bytes: i64
    sector_bytes: i64
    sectors_per_page: i64
    pages_per_block: i64
    blocks: i64
    total_pages: i64
    col_mask: i64
    row_mask: i64
    row_base: i64

# ----------------------------------------------------------------------------
# OOB (out-of-window) address policy (doc §4).
# ----------------------------------------------------------------------------

pub enum NeOobPolicy:
    """What happens when a row falls outside the backed window (doc §4).

    Alias  — wrap into the window (default; smallest surprise for FTL bring-up).
    Window — only the window is backed; outside reads FFh, status pass, no state.
    Trap   — raise an event; firmware decides (synthetic bad block / fail / log).
    """
    Alias
    Window
    Trap

impl NeOobPolicy:
    fn to_text() -> text:
        match self:
            case Alias: "alias"
            case Window: "window"
            case Trap: "trap"

# ----------------------------------------------------------------------------
# Per-cell physics coefficients (doc §7.3 struct, Appendix B defaults).
# ----------------------------------------------------------------------------

pub struct NeCellParams:
    """Phenomenological Vt physics coefficients (doc §7.3, Appendix B).

    Voltage-domain fields are Vt codes: Vt(code) = (code - 128) * 25 mV (§3.1).
    """
    erase_mean: i64        # 88   — erased lobe mean (-1.00 V)
    erase_sigma: i64       # 8    — erased lobe sigma
    pv_level: i64          # 148  — program-verify level (+0.50 V)
    ispp_start: i64        # 130  — first ISPP pulse code
    ispp_step: i64         # 6    — ISPP pulse increment
    ispp_max: i64          # 20   — pulses before program failure
    prog_sigma: i64        # 3    — per-pulse randomness
    wear_coef: f64         # 1.5  — sigma growth per 1000 P/E
    ret_coef: f64          # 2.0  — Vt loss per decade seconds per 1000 P/E
    rd_coef: f64           # +1 code per 10,000 neighbor reads (read disturb)
    pd_coef: f64           # +1 code per 200 neighbor programs (program disturb)
    erase_floor_coef: f64  # +0.8 code per 1000 P/E (erased lobe rises with wear)

pub fn ne_default_cell_params() -> NeCellParams:
    """Return the Appendix B default physics coefficients."""
    NeCellParams(
        erase_mean: 88,
        erase_sigma: 8,
        pv_level: 148,
        ispp_start: 130,
        ispp_step: 6,
        ispp_max: 20,
        prog_sigma: 3,
        wear_coef: 1.5,
        ret_coef: 2.0,
        rd_coef: 1.0,
        pd_coef: 1.0,
        erase_floor_coef: 0.8)

# ----------------------------------------------------------------------------
# Command FSM state (doc §7.2). Payload variants carry in-flight context.
# ----------------------------------------------------------------------------

pub enum NeChipState:
    """Command sequencing state machine (doc §7.2).

    Only FFh escapes Undefined. Payload variants carry the latching command,
    the count of address bytes seen, the selected status register, and the
    two-plane descriptor stage.
    """
    Idle
    AddrLatch(cmd: i64, got: i64)
    ReadBusy
    ReadOut
    ProgLoad
    ProgBusy
    EraseSetup
    EraseBusy
    StatusOut(reg: i64)
    IdOut
    CopyLoad
    TwoPlaneStage(stage: i64)
    Undefined

# ----------------------------------------------------------------------------
# Pin-frontend latch classification (doc §5.1). Owned here; used by rtl/.
# ----------------------------------------------------------------------------

pub enum NeLatchKind:
    """Latch classification from the CLE/ALE strobes (doc §5.1)."""
    Command
    Address
    DataIn
    Illegal

impl NeLatchKind:
    fn to_text() -> text:
        match self:
            case Command: "command"
            case Address: "address"
            case DataIn: "data_in"
            case Illegal: "illegal"

# ----------------------------------------------------------------------------
# Protocol violations (doc §7.2 legality rules, §8 scenario table).
# ----------------------------------------------------------------------------

pub enum NeViolationKind:
    """Protocol / legality violations the FSM must flag (doc §7.2, §8)."""
    CmdDuringBusy         # illegal command while busy (only 70/F1/7B/FF legal)
    NopExceeded           # 5th partial program to a page (Nop <= 4)
    RandomPageProgram     # pages not programmed LSB -> MSB
    ProgramWithoutErase   # program to an unerased page (data ANDs)
    WpDuringBusy          # WP asserted mid program/erase (datasheet prohibited)
    TwoPlaneMisaddress    # two-plane descriptor address constraints violated
    CopyBackCrossPlane    # copy-back across planes
    SubSectorRandomInput  # sub-sector random data input before copy-back
    TimingViolation       # AC parameter (e.g. tADL) violated
    UnsupportedCommand    # recognized-but-unsupported cmd (two-plane / 2 KB)
    IllegalLatch          # CLE and ALE both high

pub struct NeViolation:
    """A recorded protocol violation (doc §7.2)."""
    kind: NeViolationKind
    cmd: i64        # offending command byte (0 if not command-scoped)
    arg: i64        # auxiliary detail (row/pulse/param, context dependent)

# ----------------------------------------------------------------------------
# Event ring records (doc §6.2).
# ----------------------------------------------------------------------------

pub enum NeEventKind:
    """Event categories pushed to the core event ring (doc §6.2)."""
    Violation
    Timing
    ProgramFail
    EraseFail
    SuddenPowerOff
    BadBlockScan
    StateChange
    RingOverflow

pub struct NeEvent:
    """A 16-byte-analog event ring record (doc §6.2)."""
    kind: NeEventKind
    code: i64       # command / status byte associated with the event
    row: i64        # affected row (page index), -1 if n/a
    col: i64        # affected column, -1 if n/a
    time_ns: i64    # emulated timestamp
    arg: i64        # payload (violation kind ordinal / pulse index / ...)

# ----------------------------------------------------------------------------
# Fault injection (doc §7.1 fault.spl, §8 scenarios 5-8, 19).
# ----------------------------------------------------------------------------

pub enum NeOpKind:
    """Operation an injected fault targets."""
    Read
    Program
    Erase
    CopyBack

pub enum NeFaultKind:
    """Injectable fault categories (doc §8 scenarios)."""
    NoFault
    SuddenPowerOff   # abort an op mid-pulse (SPO signature)
    ProgramFail      # force program failure (status I/O0 = 1)
    EraseFail        # force erase failure (block retire)
    TimeAdvance      # advance emulated time (retention/disturb driver)

pub struct NeFault:
    """A single fault-injection descriptor (doc §7.1, §8).

    kind          — fault category.
    op            — operation targeted (for SuddenPowerOff).
    at_pulse      — ISPP pulse index to abort at (SuddenPowerOff during program).
    target_row    — targeted row/page (ProgramFail / SPO), -1 if n/a.
    target_block  — targeted block (EraseFail), -1 if n/a.
    arg_ns        — nanoseconds to advance (TimeAdvance), 0 otherwise.
    """
    kind: NeFaultKind
    op: NeOpKind
    at_pulse: i64
    target_row: i64
    target_block: i64
    arg_ns: i64

# ----------------------------------------------------------------------------
# Status flags (doc §1.4). status.spl assembles 70h / F1h / 7Bh bytes from this.
# ----------------------------------------------------------------------------

pub struct NeStatus:
    """Decoded status flags backing the 70h / F1h / 7Bh registers (doc §1.4).

    pass         — I/O0: true = pass (bit reads 0), false = fail (bit reads 1).
    ready        — I/O6: true = ready (bit 1), false = busy (bit 0).
    wp_enabled   — I/O7: true = write enabled (bit 1), false = protected (bit 0).
    plane0_pass  — F1h I/O1 plane-0 pass/fail.
    plane1_pass  — F1h I/O2 plane-1 pass/fail.
    edc_error    — 7Bh I/O1 EDC error detected.
    edc_valid    — 7Bh I/O2 EDC validity (false = invalidated by sub-sector in).
    """
    pass: bool
    ready: bool
    wp_enabled: bool
    plane0_pass: bool
    plane1_pass: bool
    edc_error: bool
    edc_valid: bool

pub fn ne_default_status(wp_enabled: bool) -> NeStatus:
    """A ready, all-pass status with valid EDC (doc §1.4 nominal)."""
    NeStatus(
        pass: true,
        ready: true,
        wp_enabled: wp_enabled,
        plane0_pass: true,
        plane1_pass: true,
        edc_error: false,
        edc_valid: true)

# ----------------------------------------------------------------------------
# Per-page / per-block metadata (Appendix A). Lazy-drift counters (doc §3.4).
# ----------------------------------------------------------------------------

pub struct NePageMeta:
    """Per-page metadata (Appendix A). Drives lazy retention/disturb (doc §3.4).

    last_prog_time — emulated ns at last program (retention baseline).
    rd_count       — neighbor read count (read disturb driver).
    pd_count       — neighbor program count (program disturb driver).
    nop_count      — partial programs to this page (Nop <= 4 rule).
    flags          — bit flags (programmed / partially programmed / ...).
    """
    last_prog_time: i64
    rd_count: i64
    pd_count: i64
    nop_count: i64
    flags: i64

pub fn ne_page_meta_new() -> NePageMeta:
    """A freshly-erased page's metadata (all counters zero)."""
    NePageMeta(last_prog_time: 0, rd_count: 0, pd_count: 0, nop_count: 0, flags: 0)

pub struct NeBlockMeta:
    """Per-block metadata (Appendix A).

    pe_cycles       — program/erase cycle count (wear driver).
    last_erase_time — emulated ns at last erase.
    bad_flag        — factory or grown bad-block flag.
    edc_state       — copy-back EDC accumulation state.
    reserved        — reserved (Appendix A layout parity).
    """
    pe_cycles: i64
    last_erase_time: i64
    bad_flag: bool
    edc_state: i64
    reserved: i64

pub fn ne_block_meta_new() -> NeBlockMeta:
    """A fresh (good, unworn) block's metadata."""
    NeBlockMeta(pe_cycles: 0, last_erase_time: 0, bad_flag: false, edc_state: 0, reserved: 0)

# ----------------------------------------------------------------------------
# Sense result (doc §3.4 / §7.3 sense()).
# ----------------------------------------------------------------------------

pub struct NeSenseResult:
    """Result of sensing one cell at a given vref (doc §7.3).

    bit      — sensed logical bit (true = 1 / erased, false = 0 / programmed).
    eff_code — effective Vt code after lazy drift was applied.
    """
    bit: bool
    eff_code: i64

# ============================================================================
# Constants (voltage codes §3.1, ID bytes §1.5, command bytes §1.3).
# Exposed as fn-returning-literal for freestanding safety.
# ============================================================================

# --- Vt encoding (doc §3.1) -------------------------------------------------
pub fn ne_vref_default() -> i64: 128      # default read reference (0.00 V)
pub fn ne_vt_deep_erased() -> i64: 40     # over-erase tail (-2.20 V)
pub fn ne_vt_erase_mean() -> i64: 88      # erased distribution mean (-1.00 V)
pub fn ne_vt_ev_level() -> i64: 116       # erase-verify level (-0.30 V)
pub fn ne_vt_pv_level() -> i64: 148       # program-verify level (+0.50 V)
pub fn ne_vt_prog_mean() -> i64: 168      # programmed distribution mean (+1.00 V)
pub fn ne_vt_over_prog() -> i64: 220      # over-programmed (+2.30 V)
pub fn ne_vt_saturated() -> i64: 255      # saturated / broken cell (+3.175 V)
pub fn ne_erased_byte() -> i64: 255       # erased page reads FFh (doc §3.1)

# --- ID bytes (doc §1.5): EC D3 10 A6 64 ------------------------------------
pub fn ne_id_maker() -> i64: 0xEC         # 236 — Samsung maker code
pub fn ne_id_device() -> i64: 0xD3        # 211 — device code
pub fn ne_id_3rd() -> i64: 0x10           # 16
pub fn ne_id_4th() -> i64: 0xA6           # 166 — 4 KB page / 256 KB block enc.
pub fn ne_id_5th() -> i64: 0x64           # 100

# --- Command bytes (doc §1.3) ----------------------------------------------
pub fn ne_cmd_read() -> i64: 0x00
pub fn ne_cmd_read_confirm() -> i64: 0x30
pub fn ne_cmd_read_copyback_confirm() -> i64: 0x35
pub fn ne_cmd_read_id() -> i64: 0x90
pub fn ne_cmd_reset() -> i64: 0xFF
pub fn ne_cmd_page_program() -> i64: 0x80
pub fn ne_cmd_program_confirm() -> i64: 0x10
pub fn ne_cmd_copyback_program() -> i64: 0x85
pub fn ne_cmd_block_erase() -> i64: 0x60
pub fn ne_cmd_erase_confirm() -> i64: 0xD0
pub fn ne_cmd_random_data_in() -> i64: 0x85
pub fn ne_cmd_random_data_out() -> i64: 0x05
pub fn ne_cmd_random_out_confirm() -> i64: 0xE0
pub fn ne_cmd_read_status() -> i64: 0x70
pub fn ne_cmd_read_edc_status() -> i64: 0x7B
pub fn ne_cmd_read_status2() -> i64: 0xF1

# --- Datasheet quantities (doc §1.1, §1.4) ----------------------------------
pub fn ne_sector_bytes() -> i64: 528      # EDC unit = 512 main + 16 spare
pub fn ne_status_reset_wp() -> i64: 0xC0  # status after reset, WP high (§1.4)
pub fn ne_status_reset_ready() -> i64: 0x40  # status after reset, WP low
