use hardware.riscv_common.pkg.riscv_linux_pkg.RiscvPlatformProfile

pub struct Rv32Machine:
    platform: RiscvPlatformProfile
    hartid: i64
    dtb_addr: i64
    satp: i64

impl Rv32Machine:
    static fn create() -> Rv32Machine:
        Rv32Machine(
            platform: RiscvPlatformProfile.qemu_virt_rv32(),
            hartid: 0,
            dtb_addr: 0,
            satp: 0
        )

    fn configure_linux_handoff(hartid: i64, dtb_addr: i64) -> Rv32Machine:
        Rv32Machine(
            platform: self.platform,
            hartid: hartid,
            dtb_addr: dtb_addr,
            satp: 0
        )

pub fn rv32_machine_create() -> Rv32Machine:
    Rv32Machine.create()

pub fn qemu_virt_rv32_platform_profile() -> RiscvPlatformProfile:
    RiscvPlatformProfile.qemu_virt_rv32()
