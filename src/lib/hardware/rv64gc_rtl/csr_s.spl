# ============================================================================
# RV64GC RTL CSR S-Mode Extension — Supervisor Control/Status Registers (64-bit)
# ============================================================================
#
# Extends the M-mode CSR file with supervisor-mode registers required for
# Sv39 virtual memory and S-mode trap delegation.
#
# Supported CSRs:
#   S-mode Trap Setup:    sstatus, sie, stvec
#   S-mode Trap Handling: sscratch, sepc, scause, stval, sip
#   S-mode VM:            satp
#   M-mode Delegation:    medeleg, mideleg (grouped here for organisational
#                         convenience — they are M-mode CSRs that control
#                         trap delegation to S-mode)
#
# RV64 SATP layout:
#   bits [63:60] — MODE (4 bits: 0=Bare, 8=Sv39)
#   bits [59:44] — ASID (16 bits)
#   bits [43:0]  — PPN  (44 bits — physical page number of root page table)
#
# VHDL synthesizable subset: i64, bool, structs only.
# ============================================================================

# ============================================================================
# S-mode CSR Address Constants
# ============================================================================

val CSR_ADDR_SSTATUS_64: u32  = 0x100
val CSR_ADDR_SIE_64: u32      = 0x104
val CSR_ADDR_STVEC_64: u32    = 0x105
val CSR_ADDR_SSCRATCH_64: u32 = 0x140
val CSR_ADDR_SEPC_64: u32     = 0x141
val CSR_ADDR_SCAUSE_64: u32   = 0x142
val CSR_ADDR_STVAL_64: u32    = 0x143
val CSR_ADDR_SIP_64: u32      = 0x144
val CSR_ADDR_SATP_64: u32     = 0x180

# M-mode delegation CSRs (placed here because they enable S-mode traps)
val CSR_ADDR_MEDELEG_64: u32  = 0x302
val CSR_ADDR_MIDELEG_64: u32  = 0x303

# ============================================================================
# SSTATUS Bit Masks (i64 for 64-bit CSR)
# ============================================================================
#
# sstatus is a restricted view of mstatus.  Writable fields:
#   SIE  (bit 1)  — Supervisor Interrupt Enable
#   SPIE (bit 5)  — Previous SIE
#   SPP  (bit 8)  — Previous privilege (0=U, 1=S)
#   SUM  (bit 18) — Supervisor User Memory access
#   MXR  (bit 19) — Make eXecutable Readable

val SSTATUS_SIE_MASK_64: i64   = 0x00000002   # bit 1
val SSTATUS_SPIE_MASK_64: i64  = 0x00000020   # bit 5
val SSTATUS_SPP_MASK_64: i64   = 0x00000100   # bit 8
val SSTATUS_SUM_MASK_64: i64   = 0x00040000   # bit 18
val SSTATUS_MXR_MASK_64: i64   = 0x00080000   # bit 19

# Combined writable mask: SIE | SPIE | SPP | SUM | MXR
val SSTATUS_WRITABLE_64: i64 = 0x000C0122
# UXL=2: user execution is fixed at 64 bits and read-only in sstatus.
val SSTATUS_UXL_FIXED_64: i64 = 2 << 32

val SSTATUS_SIE_BIT_64: i64  = 1
val SSTATUS_SPIE_BIT_64: i64 = 5
val SSTATUS_SPP_BIT_64: i64  = 8

@hardware
fn csr_s64_merge_mstatus(mstatus: i64, sstatus: i64) -> i64:
    """Merge the supervisor-owned architectural sstatus alias into mstatus."""
    (mstatus & (SSTATUS_WRITABLE_64 ^ -1)) |
        (sstatus & SSTATUS_WRITABLE_64)

# ============================================================================
# SIE / SIP Bit Masks (i64)
# ============================================================================

val SIP_SSIP_MASK_64: i64 = 0x00000002   # bit 1 — Supervisor Software Interrupt
val SIP_STIP_MASK_64: i64 = 0x00000020   # bit 5 — Supervisor Timer Interrupt
val SIP_SEIP_MASK_64: i64 = 0x00000200   # bit 9 — Supervisor External Interrupt
val SIP_SUPPORTED_MASK_64: i64 = (SIP_SSIP_MASK_64 | SIP_STIP_MASK_64 |
    SIP_SEIP_MASK_64)

# ============================================================================
# SATP Constants (RV64)
# ============================================================================
#
# RV64 SATP layout:
#   bits [63:60] — MODE (4 bits)
#   bits [59:44] — ASID (16 bits)
#   bits [43:0]  — PPN  (44 bits)

val SATP_MODE_BARE_64: i64 = 0
val SATP_MODE_SV39_64: i64 = 8

val SATP_PPN_MASK_64: i64  = 0x00000FFFFFFFFFFF   # bits [43:0]
val SATP_ASID_MASK_64: i64 = 0x0FFFF00000000000   # bits [59:44]

# SATP_MODE_SHIFT = 60 — build at runtime to avoid sign-bit literal issues
@hardware
fn satp_mode_shift_64() -> i64:
    """Return 60 as the MODE field shift amount for RV64 SATP."""
    60

@hardware
fn satp_extract_mode_64(satp: i64) -> i64:
    """Extract the MODE field from an RV64 SATP value."""
    (satp >> satp_mode_shift_64()) & 0x0F

fn satp_extract_asid_64(satp: i64) -> i64:
    """Extract the ASID field from an RV64 SATP value."""
    (satp >> 44) & 0xFFFF

fn satp_extract_ppn_64(satp: i64) -> i64:
    """Extract the PPN field from an RV64 SATP value."""
    satp & SATP_PPN_MASK_64

fn satp_encode_64(mode: i64, asid: i64, ppn: i64) -> i64:
    """Encode MODE, ASID, and PPN into an RV64 SATP value."""
    val mode_bits = (mode & 0x0F) << satp_mode_shift_64()
    val asid_bits = (asid & 0xFFFF) << 44
    val ppn_bits = ppn & SATP_PPN_MASK_64
    mode_bits | asid_bits | ppn_bits

# ============================================================================
# S-mode CSR File (64-bit)
# ============================================================================

struct CsrSMode64:
    """Supervisor-mode CSR register file (64-bit)."""
    sstatus: i64
    sie: i64
    stvec: i64
    sscratch: i64
    sepc: i64
    scause: i64
    stval: i64
    sip: i64
    satp: i64
    medeleg: i64    # M-mode: exception delegation to S-mode
    mideleg: i64    # M-mode: interrupt delegation to S-mode

# ============================================================================
# Create — initial S-mode CSR state
# ============================================================================

@hardware
fn csr_s64_create() -> CsrSMode64:
    """Create initial S-mode CSR state.  All registers start at zero
    (no delegation, interrupts disabled, Bare addressing mode)."""
    CsrSMode64(
        sstatus: 0,
        sie: 0,
        stvec: 0,
        sscratch: 0,
        sepc: 0,
        scause: 0,
        stval: 0,
        sip: 0,
        satp: 0,
        medeleg: 0,
        mideleg: 0
    )

# ============================================================================
# CSR Read
# ============================================================================

@hardware
fn csr_s64_read(smode: CsrSMode64, addr: u32) -> i64:
    """Read an S-mode CSR by its 12-bit address.  Unknown addresses return 0."""
    if addr == CSR_ADDR_SSTATUS_64:
        return smode.sstatus | SSTATUS_UXL_FIXED_64
    if addr == CSR_ADDR_SIE_64:
        return smode.sie
    if addr == CSR_ADDR_STVEC_64:
        return smode.stvec
    if addr == CSR_ADDR_SSCRATCH_64:
        return smode.sscratch
    if addr == CSR_ADDR_SEPC_64:
        return smode.sepc
    if addr == CSR_ADDR_SCAUSE_64:
        return smode.scause
    if addr == CSR_ADDR_STVAL_64:
        return smode.stval
    if addr == CSR_ADDR_SIP_64:
        return smode.sip
    if addr == CSR_ADDR_SATP_64:
        return smode.satp
    if addr == CSR_ADDR_MEDELEG_64:
        return smode.medeleg
    if addr == CSR_ADDR_MIDELEG_64:
        return smode.mideleg
    0

# ============================================================================
# CSR Write
# ============================================================================

@hardware
fn csr_s64_write(smode: CsrSMode64, addr: u32, value: i64) -> CsrSMode64:
    """Write a value to an S-mode CSR.  Enforces field masks where required.
    Unknown addresses are silently ignored."""
    var out = smode

    if addr == CSR_ADDR_SSTATUS_64:
        # Only allow writable fields: SIE, SPIE, SPP, SUM, MXR
        out.sstatus = value & SSTATUS_WRITABLE_64

    else if addr == CSR_ADDR_SIE_64:
        out.sie = value & SIP_SUPPORTED_MASK_64

    else if addr == CSR_ADDR_STVEC_64:
        # The current trap owner implements Direct mode only.
        out.stvec = value & -4

    else if addr == CSR_ADDR_SSCRATCH_64:
        out.sscratch = value

    else if addr == CSR_ADDR_SEPC_64:
        # C is connected, so supervisor exception PCs use IALIGN=16.
        out.sepc = value & -2

    else if addr == CSR_ADDR_SCAUSE_64:
        out.scause = value

    else if addr == CSR_ADDR_STVAL_64:
        out.stval = value

    else if addr == CSR_ADDR_SIP_64:
        # Only SSIP is software-writable; STIP and SEIP are external
        out.sip = (smode.sip & (SIP_STIP_MASK_64 | SIP_SEIP_MASK_64)) | (value & SIP_SSIP_MASK_64)

    else if addr == CSR_ADDR_SATP_64:
        # This core implements Bare and Sv39 only; other WARL values are ignored.
        val mode = satp_extract_mode_64(value)
        if mode == SATP_MODE_BARE_64:
            out.satp = value
        else if mode == SATP_MODE_SV39_64:
            out.satp = value
        # else: illegal mode, write is silently ignored

    else if addr == CSR_ADDR_MEDELEG_64:
        out.medeleg = value

    else if addr == CSR_ADDR_MIDELEG_64:
        out.mideleg = value & SIP_SUPPORTED_MASK_64

    out

# ============================================================================
# Trap Delegation Check
# ============================================================================

fn csr_s64_is_exception_delegated(smode: CsrSMode64, cause: i64) -> bool:
    """Check if an exception cause is delegated to S-mode via medeleg.
    cause must be a synchronous exception code (bit 63 clear)."""
    if cause < 0:
        return false
    if cause >= 64:
        return false
    val mask = 1 << cause
    (smode.medeleg & mask) != 0

fn csr_s64_is_interrupt_delegated(smode: CsrSMode64, cause: i64) -> bool:
    """Check if an interrupt cause is delegated to S-mode via mideleg.
    cause is the raw interrupt number (without the MSB set)."""
    if cause < 0:
        return false
    if cause >= 64:
        return false
    val mask = 1 << cause
    (smode.mideleg & mask) != 0

# ============================================================================
# SATP Query Helpers
# ============================================================================

fn csr_s64_satp_mode(smode: CsrSMode64) -> i64:
    """Get the current SATP MODE value."""
    satp_extract_mode_64(smode.satp)

fn csr_s64_satp_asid(smode: CsrSMode64) -> i64:
    """Get the current SATP ASID value."""
    satp_extract_asid_64(smode.satp)

fn csr_s64_satp_ppn(smode: CsrSMode64) -> i64:
    """Get the current SATP PPN value (root page table physical page number)."""
    satp_extract_ppn_64(smode.satp)

fn csr_s64_is_vm_enabled(smode: CsrSMode64) -> bool:
    """Check if virtual memory translation is enabled (MODE != Bare)."""
    satp_extract_mode_64(smode.satp) != SATP_MODE_BARE_64

# ============================================================================
# Spec-facing alias
# ============================================================================

fn csr_s_init() -> CsrSMode64:
    csr_s64_create()

export CsrSMode64
export csr_s64_create, csr_s64_read, csr_s64_write, csr_s_init
export csr_s64_is_exception_delegated, csr_s64_is_interrupt_delegated
export csr_s64_satp_mode, csr_s64_satp_asid, csr_s64_satp_ppn, csr_s64_is_vm_enabled
export satp_encode_64, satp_extract_mode_64, satp_extract_asid_64, satp_extract_ppn_64
export CSR_ADDR_SSTATUS_64, CSR_ADDR_SIE_64, CSR_ADDR_STVEC_64
export CSR_ADDR_SSCRATCH_64, CSR_ADDR_SEPC_64, CSR_ADDR_SCAUSE_64
export CSR_ADDR_STVAL_64, CSR_ADDR_SIP_64, CSR_ADDR_SATP_64
export CSR_ADDR_MEDELEG_64, CSR_ADDR_MIDELEG_64
export SSTATUS_SIE_MASK_64, SSTATUS_SPIE_MASK_64, SSTATUS_SPP_MASK_64
export SSTATUS_SUM_MASK_64, SSTATUS_MXR_MASK_64, SSTATUS_WRITABLE_64
export SSTATUS_UXL_FIXED_64
export csr_s64_merge_mstatus
export SSTATUS_SIE_BIT_64, SSTATUS_SPIE_BIT_64, SSTATUS_SPP_BIT_64
export SIP_SSIP_MASK_64, SIP_STIP_MASK_64, SIP_SEIP_MASK_64
export SIP_SUPPORTED_MASK_64
export SATP_MODE_BARE_64, SATP_MODE_SV39_64
export SATP_PPN_MASK_64, SATP_ASID_MASK_64
