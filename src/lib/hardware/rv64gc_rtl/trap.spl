# ============================================================================
# RV64GC RTL Trap Controller — Exception and Interrupt Handling (64-bit)
# ============================================================================
#
# Implements RISC-V M-mode trap entry/exit logic for RV64:
#   - Interrupt priority checking (MEI > MSI > MTI)
#   - Trap entry: save context, jump to mtvec
#   - Trap exit (mret): restore context, return to mepc
#
# All values are i64 (64-bit).  Only direct mtvec mode supported.
#
# VHDL synthesizable subset: i64, bool, structs only.
# ============================================================================

use std.hardware.rv64gc_rtl.csr.{CsrFile64}
use std.hardware.rv64gc_rtl.csr.{MSTATUS_MIE_MASK, MSTATUS_MPIE_MASK, MSTATUS_MPP_MASK}
use std.hardware.rv64gc_rtl.csr.{MSTATUS_MIE_BIT, MSTATUS_MPIE_BIT, MSTATUS_MPP_LO_BIT}
use std.hardware.rv64gc_rtl.csr.{MIP_MSIP_MASK, MIP_MTIP_MASK, MIP_MEIP_MASK}
use std.hardware.rv64gc_rtl.csr_s.{CsrSMode64, csr_s64_create}
use std.hardware.rv64gc_rtl.csr_s.{SSTATUS_SPP_MASK_64, SSTATUS_SPP_BIT_64}
use std.hardware.rv64gc_rtl.csr_s.{csr_s64_is_exception_delegated, csr_s64_is_interrupt_delegated}

# ============================================================================
# Trap phase constants
# ============================================================================

val TRAP_NORMAL: u32 = 0   # Normal execution
val TRAP_ENTER: u32  = 1   # Entering trap handler
val TRAP_EXIT: u32   = 2   # Exiting trap handler (mret)

# ============================================================================
# Exception cause codes (mcause with MSB=0)
# ============================================================================

val CAUSE_MISALIGNED_FETCH: i64  = 0
val CAUSE_ILLEGAL_INSN: i64     = 2
val CAUSE_BREAKPOINT: i64       = 3
val CAUSE_LOAD_MISALIGNED: i64  = 4
val CAUSE_STORE_MISALIGNED: i64 = 6
val CAUSE_ECALL_M: i64         = 11

# ============================================================================
# Interrupt cause codes (mcause with MSB=1, bit 63 set for RV64)
# ============================================================================

# Build at runtime to avoid sign-bit literal issues
fn cause_msi() -> i64:
    """Machine Software Interrupt cause (bit63 | 3)."""
    val int_bit: i64 = 1 << 63
    int_bit | 3

fn cause_mti() -> i64:
    """Machine Timer Interrupt cause (bit63 | 7)."""
    val int_bit: i64 = 1 << 63
    int_bit | 7

fn cause_mei() -> i64:
    """Machine External Interrupt cause (bit63 | 11)."""
    val int_bit: i64 = 1 << 63
    int_bit | 11

# ============================================================================
# Trap State
# ============================================================================

struct TrapState64:
    """Trap controller state."""
    phase: u32   # TRAP_NORMAL, TRAP_ENTER, or TRAP_EXIT

# ============================================================================
# Trap Enter Result
# ============================================================================

struct TrapEnterResult64:
    """Result of entering a trap."""
    csr: CsrFile64    # Updated CSR file (mepc, mcause, mtval, mstatus saved)
    csr_s: CsrSMode64 # Updated supervisor CSR state when delegated
    trap_pc: i64       # Target PC (from mtvec, direct mode)
    target_mode: i64   # Target privilege mode: M=3, S=1

# ============================================================================
# Trap Exit Result
# ============================================================================

struct TrapExitResult64:
    """Result of exiting a trap via mret or sret."""
    csr: CsrFile64    # Updated CSR file (mstatus restored)
    return_pc: i64     # Return PC (from mepc or sepc)
    target_mode: i64   # Target privilege mode after return

# ============================================================================
# Interrupt Check Result
# ============================================================================

struct InterruptCheckResult64:
    """Result of checking for pending interrupts."""
    pending: bool    # True if an interrupt should be taken
    cause: i64       # Interrupt cause code (valid only if pending=true)

# ============================================================================
# Check for Pending Interrupts
# ============================================================================

fn trap64_check_interrupt(csr: CsrFile64) -> InterruptCheckResult64:
    """Check if an interrupt should be taken.
    Priority: MEI > MSI > MTI (per RISC-V spec)."""

    val mie_enabled = (csr.mstatus & MSTATUS_MIE_MASK) != 0
    if mie_enabled == false:
        return InterruptCheckResult64(pending: false, cause: 0)

    val enabled_pending = csr.mie & csr.mip

    if (enabled_pending & MIP_MEIP_MASK) != 0:
        return InterruptCheckResult64(pending: true, cause: cause_mei())
    if (enabled_pending & MIP_MSIP_MASK) != 0:
        return InterruptCheckResult64(pending: true, cause: cause_msi())
    if (enabled_pending & MIP_MTIP_MASK) != 0:
        return InterruptCheckResult64(pending: true, cause: cause_mti())

    InterruptCheckResult64(pending: false, cause: 0)

# ============================================================================
# Trap Entry
# ============================================================================

fn trap64_enter_m_only_from_priv(csr: CsrFile64, pc: i64, cause: i64, tval: i64, priv_mode: i64) -> TrapEnterResult64:
    """Enter a trap: save context to CSRs, compute handler address."""

    var new_csr = csr

    # Save exception context
    new_csr.mepc = pc & -2    # IALIGN=16 with C
    new_csr.mcause = cause
    new_csr.mtval = tval

    # Save and update mstatus
    val old_mie = (csr.mstatus & MSTATUS_MIE_MASK) >> MSTATUS_MIE_BIT
    var new_mstatus = csr.mstatus

    # Clear MIE, MPIE, MPP fields
    new_mstatus = new_mstatus & (MSTATUS_MIE_MASK ^ -1)
    new_mstatus = new_mstatus & (MSTATUS_MPIE_MASK ^ -1)
    new_mstatus = new_mstatus & (MSTATUS_MPP_MASK ^ -1)

    # Set MPIE = old MIE, MIE = 0, MPP = interrupted privilege.
    new_mstatus = new_mstatus | (old_mie << MSTATUS_MPIE_BIT)
    new_mstatus = new_mstatus | ((priv_mode & 0x3) << MSTATUS_MPP_LO_BIT)

    new_csr.mstatus = new_mstatus

    # Compute trap handler PC from mtvec (direct mode)
    val trap_pc = csr.mtvec & 0xFFFFFFFFFFFFFFFC

    TrapEnterResult64(csr: new_csr, csr_s: csr_s64_create(), trap_pc: trap_pc, target_mode: 3)

fn trap64_enter_m_only(csr: CsrFile64, pc: i64, cause: i64, tval: i64) -> TrapEnterResult64:
    """Compatibility entry point for traps already executing in M-mode."""
    trap64_enter_m_only_from_priv(csr, pc, cause, tval, 3)

# ============================================================================
# Trap Exit (mret)
# ============================================================================

fn trap64_exit_mret(csr: CsrFile64) -> TrapExitResult64:
    """Exit from M-mode trap via MRET instruction."""

    var new_mstatus = csr.mstatus

    val old_mpie = (csr.mstatus & MSTATUS_MPIE_MASK) >> MSTATUS_MPIE_BIT
    val mpp = (csr.mstatus & MSTATUS_MPP_MASK) >> MSTATUS_MPP_LO_BIT

    # Clear MIE, MPIE, MPP
    new_mstatus = new_mstatus & (MSTATUS_MIE_MASK ^ -1)
    new_mstatus = new_mstatus & (MSTATUS_MPIE_MASK ^ -1)
    new_mstatus = new_mstatus & (MSTATUS_MPP_MASK ^ -1)

    # MIE <- MPIE, MPIE <- 1, MPP <- U-mode
    new_mstatus = new_mstatus | (old_mpie << MSTATUS_MIE_BIT)
    new_mstatus = new_mstatus | MSTATUS_MPIE_MASK

    var new_csr = csr
    new_csr.mstatus = new_mstatus

    val return_pc = csr.mepc

    TrapExitResult64(csr: new_csr, return_pc: return_pc, target_mode: mpp)

# ============================================================================
# Trap State Init
# ============================================================================

fn trap64_state_init() -> TrapState64:
    """Create zeroed initial trap state (TRAP_NORMAL phase)."""
    TrapState64(phase: 0)

# ============================================================================
# Trap Entry with S-mode delegation (7-arg version)
# ============================================================================

fn trap64_enter(ts: TrapState64, cause: i64, tval: i64, pc: i64, priv_mode: i64, csr_m: CsrFile64, csr_s: CsrSMode64) -> TrapEnterResult64:
    """Enter a trap with S-mode delegation support.
    Checks medeleg/mideleg to route to S-mode (1) or M-mode (3).
    The interrupt bit (bit 63) distinguishes interrupts from exceptions."""

    # Check if this is an interrupt (bit 63 set) or exception
    val int_bit: i64 = 1 << 63
    val is_interrupt = (cause & int_bit) != 0

    var delegated: bool = false
    if priv_mode != 3:
        if is_interrupt:
            val irq_num = cause & (int_bit ^ -1)
            val deleg_bit = (csr_m.mideleg >> irq_num) & 1
            delegated = deleg_bit == 1
        else:
            val deleg_bit = (csr_m.medeleg >> cause) & 1
            delegated = deleg_bit == 1

    if delegated:
        # Route to S-mode: write sepc, scause, stval
        var new_csr_s = csr_s
        new_csr_s.sepc = pc & -2
        new_csr_s.scause = cause
        new_csr_s.stval = tval

        # Save SIE into SPIE, clear SIE, set SPP to current priv_mode (S=1 or U=0)
        val old_sie = (csr_s.sstatus & 0x00000002) >> 1
        var new_sstatus = csr_s.sstatus
        new_sstatus = new_sstatus & (0x00000002 ^ -1)    # Clear SIE
        new_sstatus = new_sstatus & (0x00000020 ^ -1)    # Clear SPIE
        new_sstatus = new_sstatus & (SSTATUS_SPP_MASK_64 ^ -1)  # Clear SPP
        new_sstatus = new_sstatus | (old_sie << 5)       # SPIE = old SIE
        if priv_mode == 1:
            new_sstatus = new_sstatus | SSTATUS_SPP_MASK_64  # SPP = 1 (S-mode)
        # else SPP = 0 (U-mode)
        new_csr_s.sstatus = new_sstatus

        val trap_pc = csr_s.stvec & 0xFFFFFFFFFFFFFFFC
        TrapEnterResult64(csr: csr_m, csr_s: new_csr_s, trap_pc: trap_pc, target_mode: 1)
    else:
        # Route to M-mode via existing logic
        val machine = trap64_enter_m_only_from_priv(csr_m, pc, cause, tval, priv_mode)
        TrapEnterResult64(csr: machine.csr, csr_s: csr_s,
            trap_pc: machine.trap_pc, target_mode: machine.target_mode)

# ============================================================================
# Trap Exit Aliases
# ============================================================================

fn trap64_mret(csr_m: CsrFile64) -> TrapExitResult64:
    """Exit M-mode trap via MRET. Alias for trap64_exit_mret."""
    trap64_exit_mret(csr_m)

fn trap64_sret_csr(csr_s: CsrSMode64) -> CsrSMode64:
    """Return updated S-mode CSR state after SRET."""
    val old_spie = (csr_s.sstatus & 0x00000020) >> 5

    var new_sstatus = csr_s.sstatus
    # Clear SIE, SPIE, SPP
    new_sstatus = new_sstatus & (0x00000002 ^ -1)           # Clear SIE
    new_sstatus = new_sstatus & (0x00000020 ^ -1)           # Clear SPIE
    new_sstatus = new_sstatus & (SSTATUS_SPP_MASK_64 ^ -1)  # Clear SPP

    # SIE <- SPIE, SPIE <- 1
    new_sstatus = new_sstatus | (old_spie << 1)  # SIE = old SPIE
    new_sstatus = new_sstatus | 0x00000020       # SPIE = 1

    var new_csr_s = csr_s
    new_csr_s.sstatus = new_sstatus
    new_csr_s

fn trap64_sret(csr_s: CsrSMode64) -> TrapExitResult64:
    """Exit S-mode trap via SRET.
    Reads sstatus.SPP for target privilege, clears SPP and restores SIE."""

    val spp = (csr_s.sstatus & SSTATUS_SPP_MASK_64) >> SSTATUS_SPP_BIT_64
    val new_csr_s = trap64_sret_csr(csr_s)

    # Return a TrapExitResult64; csr field is unused for S-mode but we embed a zeroed M CSR
    val dummy_csr_m = CsrFile64(mstatus: 0, misa: 0, mie: 0, mtvec: 0, mscratch: 0, mepc: 0, mcause: 0, mtval: 0, mip: 0, medeleg: 0, mideleg: 0, mcycle: 0, minstret: 0, mhartid: 0)
    TrapExitResult64(csr: dummy_csr_m, return_pc: csr_s.sepc, target_mode: spp)

export TrapState64, TrapEnterResult64, TrapExitResult64, InterruptCheckResult64
export trap64_check_interrupt, trap64_enter, trap64_enter_m_only, trap64_exit_mret
export trap64_state_init, trap64_mret, trap64_sret, trap64_sret_csr
export TRAP_NORMAL, TRAP_ENTER, TRAP_EXIT
export CAUSE_MISALIGNED_FETCH, CAUSE_ILLEGAL_INSN, CAUSE_BREAKPOINT
export CAUSE_LOAD_MISALIGNED, CAUSE_STORE_MISALIGNED, CAUSE_ECALL_M
export cause_msi, cause_mti, cause_mei
