# ============================================================================
# RV64GC RTL A Extension — Atomic Memory Operations (LR/SC + AMO)
# ============================================================================
#
# Implements the RISC-V A extension for RV64GC.
# LR (Load-Reserved) / SC (Store-Conditional) pair for lock-free
# synchronization, plus AMO (Atomic Memory Operations).
#
# All values are i64.  Pure functions returning new state.
#
# VHDL synthesizable subset: i64, u32, bool, structs only.
# ============================================================================

use std.hardware.rv64gc_rtl.pkg.{AMO_LR, AMO_SC, AMO_SWAP, AMO_ADD}
use std.hardware.rv64gc_rtl.pkg.{AMO_XOR, AMO_AND, AMO_OR}
use std.hardware.rv64gc_rtl.pkg.{AMO_MIN, AMO_MAX, AMO_MINU, AMO_MAXU}

# ============================================================================
# Atomics State — reservation tracking
# ============================================================================

struct AtomicsState:
    """Tracks the LR/SC reservation set."""
    reservation_valid: bool   # True if a reservation is active
    reservation_addr: i64     # Reserved address (valid only if reservation_valid)

# ============================================================================
# SC Result
# ============================================================================

struct AtomicsScResult:
    """Result of a Store-Conditional operation."""
    success: bool          # True if SC succeeded (reservation matched)
    state: AtomicsState    # Updated atomics state (reservation cleared)

# ============================================================================
# AMO Result
# ============================================================================

struct AmoResult:
    """Result of an atomic memory operation."""
    old_value: i64    # Original value read from memory
    new_value: i64    # New value to write to memory

# ============================================================================
# Create — initial state with no reservation
# ============================================================================

fn atomics_create() -> AtomicsState:
    """Create initial atomics state with no active reservation."""
    AtomicsState(reservation_valid: false, reservation_addr: 0)

# ============================================================================
# LR — Load Reserved
# ============================================================================

fn atomics_lr(state: AtomicsState, addr: i64) -> AtomicsState:
    """Set a reservation for the given address (LR instruction).
    Clears any previous reservation and sets a new one."""
    AtomicsState(reservation_valid: true, reservation_addr: addr)

# ============================================================================
# SC — Store Conditional
# ============================================================================

fn atomics_sc(state: AtomicsState, addr: i64) -> AtomicsScResult:
    """Check and clear reservation (SC instruction).
    Returns success=true if reservation_valid and addr matches.
    Always clears the reservation regardless of success."""
    var success = false
    if state.reservation_valid and state.reservation_addr == addr:
        success = true
    # SC always clears reservation
    val new_state = AtomicsState(reservation_valid: false, reservation_addr: 0)
    AtomicsScResult(success: success, state: new_state)

# ============================================================================
# Invalidate — clear reservation (on any intervening store to reserved addr)
# ============================================================================

fn atomics_invalidate(state: AtomicsState, store_addr: i64) -> AtomicsState:
    """Invalidate reservation if a store hits the reserved address.
    Called by the core on every store to check for reservation conflicts."""
    if state.reservation_valid and state.reservation_addr == store_addr:
        return AtomicsState(reservation_valid: false, reservation_addr: 0)
    state

# ============================================================================
# AMO Compute — atomic read-modify-write operations
# ============================================================================

fn amo_compute(funct5: u32, old_value: i64, rs2_value: i64) -> AmoResult:
    """Compute the AMO result given the old memory value and rs2.
    Returns both old_value (for rd writeback) and new_value (for memory write).

    funct5 is the upper 5 bits of funct7 in the AMO instruction."""
    var new_val: i64 = old_value

    if funct5 == AMO_SWAP:
        new_val = rs2_value

    else if funct5 == AMO_ADD:
        new_val = old_value + rs2_value

    else if funct5 == AMO_XOR:
        new_val = old_value ^ rs2_value

    else if funct5 == AMO_AND:
        new_val = old_value & rs2_value

    else if funct5 == AMO_OR:
        new_val = old_value | rs2_value

    else if funct5 == AMO_MIN:
        # Signed minimum
        if rs2_value < old_value:
            new_val = rs2_value

    else if funct5 == AMO_MAX:
        # Signed maximum
        if rs2_value > old_value:
            new_val = rs2_value

    else if funct5 == AMO_MINU:
        # Unsigned minimum (use XOR-flip trick for unsigned comparison)
        val flip: i64 = 0x8000000000000000
        val u_old = old_value ^ flip
        val u_rs2 = rs2_value ^ flip
        if u_rs2 < u_old:
            new_val = rs2_value

    else if funct5 == AMO_MAXU:
        # Unsigned maximum
        val flip: i64 = 0x8000000000000000
        val u_old = old_value ^ flip
        val u_rs2 = rs2_value ^ flip
        if u_rs2 > u_old:
            new_val = rs2_value

    AmoResult(old_value: old_value, new_value: new_val)

export AtomicsState, AtomicsScResult, AmoResult
export atomics_create, atomics_lr, atomics_sc, atomics_invalidate, amo_compute
