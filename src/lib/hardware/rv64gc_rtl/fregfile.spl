# RV64 F/D register bank — fixed 32 x 64-bit raw architectural values.

struct FRegFile64:
    reg_0: i64
    reg_1: i64
    reg_2: i64
    reg_3: i64
    reg_4: i64
    reg_5: i64
    reg_6: i64
    reg_7: i64
    reg_8: i64
    reg_9: i64
    reg_10: i64
    reg_11: i64
    reg_12: i64
    reg_13: i64
    reg_14: i64
    reg_15: i64
    reg_16: i64
    reg_17: i64
    reg_18: i64
    reg_19: i64
    reg_20: i64
    reg_21: i64
    reg_22: i64
    reg_23: i64
    reg_24: i64
    reg_25: i64
    reg_26: i64
    reg_27: i64
    reg_28: i64
    reg_29: i64
    reg_30: i64
    reg_31: i64

fn fregfile64_create() -> FRegFile64:
    FRegFile64(
        reg_0: 0, reg_1: 0, reg_2: 0, reg_3: 0,
        reg_4: 0, reg_5: 0, reg_6: 0, reg_7: 0,
        reg_8: 0, reg_9: 0, reg_10: 0, reg_11: 0,
        reg_12: 0, reg_13: 0, reg_14: 0, reg_15: 0,
        reg_16: 0, reg_17: 0, reg_18: 0, reg_19: 0,
        reg_20: 0, reg_21: 0, reg_22: 0, reg_23: 0,
        reg_24: 0, reg_25: 0, reg_26: 0, reg_27: 0,
        reg_28: 0, reg_29: 0, reg_30: 0, reg_31: 0
    )

fn fregfile64_read(frf: FRegFile64, index: i64) -> i64:
    val addr = index & 31
    if addr == 1: return frf.reg_1
    if addr == 2: return frf.reg_2
    if addr == 3: return frf.reg_3
    if addr == 4: return frf.reg_4
    if addr == 5: return frf.reg_5
    if addr == 6: return frf.reg_6
    if addr == 7: return frf.reg_7
    if addr == 8: return frf.reg_8
    if addr == 9: return frf.reg_9
    if addr == 10: return frf.reg_10
    if addr == 11: return frf.reg_11
    if addr == 12: return frf.reg_12
    if addr == 13: return frf.reg_13
    if addr == 14: return frf.reg_14
    if addr == 15: return frf.reg_15
    if addr == 16: return frf.reg_16
    if addr == 17: return frf.reg_17
    if addr == 18: return frf.reg_18
    if addr == 19: return frf.reg_19
    if addr == 20: return frf.reg_20
    if addr == 21: return frf.reg_21
    if addr == 22: return frf.reg_22
    if addr == 23: return frf.reg_23
    if addr == 24: return frf.reg_24
    if addr == 25: return frf.reg_25
    if addr == 26: return frf.reg_26
    if addr == 27: return frf.reg_27
    if addr == 28: return frf.reg_28
    if addr == 29: return frf.reg_29
    if addr == 30: return frf.reg_30
    if addr == 31: return frf.reg_31
    frf.reg_0

fn fregfile64_write(frf: FRegFile64, index: i64, bits: i64) -> FRegFile64:
    var out = frf
    val addr = index & 31
    if addr == 0: out.reg_0 = bits
    else if addr == 1: out.reg_1 = bits
    else if addr == 2: out.reg_2 = bits
    else if addr == 3: out.reg_3 = bits
    else if addr == 4: out.reg_4 = bits
    else if addr == 5: out.reg_5 = bits
    else if addr == 6: out.reg_6 = bits
    else if addr == 7: out.reg_7 = bits
    else if addr == 8: out.reg_8 = bits
    else if addr == 9: out.reg_9 = bits
    else if addr == 10: out.reg_10 = bits
    else if addr == 11: out.reg_11 = bits
    else if addr == 12: out.reg_12 = bits
    else if addr == 13: out.reg_13 = bits
    else if addr == 14: out.reg_14 = bits
    else if addr == 15: out.reg_15 = bits
    else if addr == 16: out.reg_16 = bits
    else if addr == 17: out.reg_17 = bits
    else if addr == 18: out.reg_18 = bits
    else if addr == 19: out.reg_19 = bits
    else if addr == 20: out.reg_20 = bits
    else if addr == 21: out.reg_21 = bits
    else if addr == 22: out.reg_22 = bits
    else if addr == 23: out.reg_23 = bits
    else if addr == 24: out.reg_24 = bits
    else if addr == 25: out.reg_25 = bits
    else if addr == 26: out.reg_26 = bits
    else if addr == 27: out.reg_27 = bits
    else if addr == 28: out.reg_28 = bits
    else if addr == 29: out.reg_29 = bits
    else if addr == 30: out.reg_30 = bits
    else: out.reg_31 = bits
    out

export FRegFile64, fregfile64_create, fregfile64_read, fregfile64_write
