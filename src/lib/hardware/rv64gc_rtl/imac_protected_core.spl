# Integer-only RV64IMAC protected controller.
# Reuses the canonical Sv39/PMP/IMAC/CSR/RVFI leaves without behavioral F/D.

use std.hardware.rv64gc_rtl.pkg.{OP_LUI, OP_AUIPC, OP_JAL, OP_JALR}
use std.hardware.rv64gc_rtl.pkg.{OP_BRANCH, OP_LOAD, OP_STORE, OP_SYSTEM, OP_MISC_MEM}
use std.hardware.rv64gc_rtl.pkg.{OP_IMMED, OP_REG, OP_OP_IMM_32, OP_OP_32, OP_AMO}
use std.hardware.rv64gc_rtl.pkg.{BR_BEQ, BR_BNE, BR_BLT, BR_BGE, BR_BLTU, BR_BGEU}
use std.hardware.rv64gc_rtl.pkg.{SEMI_ENTRY, SEMI_BREAK, SEMI_EXIT, SYS_EXIT}
use std.hardware.rv64gc_rtl.decode.{DecodeResult64, decode_instruction_64, sign_extend_to_64}
use std.hardware.rv64gc_rtl.decode.{RvcExpansion, rvc_expand}
use std.hardware.rv64gc_rtl.alu.{AluResult64, alu64_compute, i64_signed_lt}
use std.hardware.rv64gc_rtl.regfile.{RegFile64, RegReadResult64, regfile64_create, regfile64_read, regfile64_write}
use std.hardware.rv64gc_rtl.lsu.lsu64_load
use std.hardware.rv64gc_rtl.mul_div.{MulDivState, mul_div_ready, muldiv_execute, mul_div_start, mul_div_tick}
use std.hardware.rv64gc_rtl.pkg.{MULDIV_MUL, MULDIV_MULH, MULDIV_MULHSU, MULDIV_MULHU}
use std.hardware.rv64gc_rtl.pkg.{MULDIV_DIV, MULDIV_DIVU, MULDIV_REM, MULDIV_REMU}
use std.hardware.rv64gc_rtl.pkg.{MULDIV_MULW, MULDIV_DIVW, MULDIV_DIVUW, MULDIV_REMW, MULDIV_REMUW}
use std.hardware.rv64gc_rtl.atomics.{AtomicsState, atomics_create, atomics_lr, atomics_sc, atomics_invalidate, amo_compute}
use std.hardware.rv64gc_rtl.pkg.{AMO_LR, AMO_SC, AMO_SWAP, AMO_ADD, AMO_XOR, AMO_AND, AMO_OR}
use std.hardware.rv64gc_rtl.pkg.{AMO_MIN, AMO_MAX, AMO_MINU, AMO_MAXU}
use std.hardware.rv64gc_rtl.csr.{CsrFile64, csr64_create, csr64_read, csr64_write, csr64_tick, csr64_retire}
use std.hardware.rv64gc_rtl.csr.csr64_update_mip_s
use std.hardware.rv64gc_rtl.csr.{CsrExt64, csr_ext64_create, csr_ext64_read, csr_ext64_write, csr_ext64_known}
use std.hardware.rv64gc_rtl.csr.{MSTATUS_MIE_MASK, MSTATUS_MPP_MASK, MSTATUS_MPP_LO_BIT, MSTATUS_FS_MASK, MSTATUS_SD_MASK, MIP_MEIP_MASK, MIP_MSIP_MASK, MIP_MTIP_MASK}
use std.hardware.rv64gc_rtl.csr_s.{CsrSMode64, csr_s64_create, csr_s64_read, csr_s64_write}
use std.hardware.rv64gc_rtl.trap.{trap64_mret, trap64_sret, trap64_sret_csr}
use std.hardware.rv64gc_rtl.trap.{InterruptCheckResult64, trap64_check_interrupt_deleg, trap64_enter, trap64_state_init}
use std.hardware.rv64gc_rtl.trap.{CAUSE_ILLEGAL_INSN, CAUSE_BREAKPOINT, cause_mei, cause_msi, cause_mti}
use std.hardware.rv64gc_rtl.trap.{CAUSE_LOAD_MISALIGNED, CAUSE_STORE_MISALIGNED}
use std.hardware.rv64gc_rtl.mmu_sv39.{MmuState64, mmu64_create, mmu64_flush, mmu64_set_satp}
use std.hardware.rv64gc_rtl.mmu_sv39.{ACCESS_FETCH_64, ACCESS_LOAD_64, ACCESS_STORE_64}
use std.hardware.rv64gc_rtl.csr_s.{SSTATUS_SIE_MASK_64, SSTATUS_SUM_MASK_64, SSTATUS_MXR_MASK_64}
use std.hardware.rv64gc_rtl.csr_s.{SIP_SSIP_MASK_64, SIP_STIP_MASK_64, SIP_SEIP_MASK_64}
use std.hardware.rv64gc_rtl.memory_access.MemoryAccessState64
use std.hardware.rv64gc_rtl.memory_access.{memory64_start, memory64_start_atomic_read}
use std.hardware.rv64gc_rtl.memory_access.{memory64_start_lr, memory64_start_atomic_store}
use std.hardware.rv64gc_rtl.memory_access.{memory64_start_conditional_store, memory64_cycle}
use std.hardware.rv64gc_rtl.pmp.PmpEntries64
