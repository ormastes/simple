# RV64 PMP CSR storage access.
#
# RV64 exposes pmpcfg0 and pmpcfg2; each packs eight configuration bytes.
# Fixed fields and fixed branches keep this owner suitable for RTL lowering.

use std.hardware.rv64gc_rtl.pmp.PmpEntries64

val PMP64_CSR_PMPCFG0: u32 = 0x3A0
val PMP64_CSR_PMPCFG2: u32 = 0x3A2
val PMP64_CSR_PMPADDR0: u32 = 0x3B0
val PMP64_CFG_ADDRESS_MASK: u32 = 0x18
val PMP64_CFG_ADDRESS_TOR: u32 = 0x08
val PMP64_CFG_LOCKED: u32 = 0x80
val PMP64_CFG_DEFINED_MASK: u32 = 0x9F
val PMP64_CFG_READ: u32 = 0x01
val PMP64_CFG_WRITE: u32 = 0x02
val PMP64_CSR_PMPADDR_MASK: i64 = 0x003FFFFFFFFFFFFF

struct PmpCsrReadResult64:
    handled: bool
    value: i64

struct PmpCsrWriteResult64:
    handled: bool
    entries: PmpEntries64

@hardware
fn pmp64_entries_reset() -> PmpEntries64:
    PmpEntries64(
        cfg_0: 0, cfg_1: 0, cfg_2: 0, cfg_3: 0,
        cfg_4: 0, cfg_5: 0, cfg_6: 0, cfg_7: 0,
        cfg_8: 0, cfg_9: 0, cfg_10: 0, cfg_11: 0,
        cfg_12: 0, cfg_13: 0, cfg_14: 0, cfg_15: 0,
        addr_0: 0, addr_1: 0, addr_2: 0, addr_3: 0,
        addr_4: 0, addr_5: 0, addr_6: 0, addr_7: 0,
        addr_8: 0, addr_9: 0, addr_10: 0, addr_11: 0,
        addr_12: 0, addr_13: 0, addr_14: 0, addr_15: 0
    )

@hardware
fn pmp64_cfg_normalize(cfg: u32) -> u32:
    """Clear reserved bits and the reserved R=0/W=1 encoding."""
    var normalized = cfg & PMP64_CFG_DEFINED_MASK
    if (normalized & PMP64_CFG_WRITE) != 0 and (normalized & PMP64_CFG_READ) == 0:
        normalized = normalized & 0xFD
    normalized

@hardware
fn pmp64_csr_read(entries: PmpEntries64, csr_addr: u32) -> PmpCsrReadResult64:
    if csr_addr == PMP64_CSR_PMPCFG0:
        val c0 = (entries.cfg_0 & 0xFF) as i64
        val c1 = (entries.cfg_1 & 0xFF) as i64
        val c2 = (entries.cfg_2 & 0xFF) as i64
        val c3 = (entries.cfg_3 & 0xFF) as i64
        val c4 = (entries.cfg_4 & 0xFF) as i64
        val c5 = (entries.cfg_5 & 0xFF) as i64
        val c6 = (entries.cfg_6 & 0xFF) as i64
        val c7 = (entries.cfg_7 & 0xFF) as i64
        val packed = c0 | (c1 << 8) | (c2 << 16) | (c3 << 24) | (c4 << 32) | (c5 << 40) | (c6 << 48) | (c7 << 56)
        return PmpCsrReadResult64(handled: true, value: packed)
    if csr_addr == PMP64_CSR_PMPCFG2:
        val c8 = (entries.cfg_8 & 0xFF) as i64
        val c9 = (entries.cfg_9 & 0xFF) as i64
        val c10 = (entries.cfg_10 & 0xFF) as i64
        val c11 = (entries.cfg_11 & 0xFF) as i64
        val c12 = (entries.cfg_12 & 0xFF) as i64
        val c13 = (entries.cfg_13 & 0xFF) as i64
        val c14 = (entries.cfg_14 & 0xFF) as i64
        val c15 = (entries.cfg_15 & 0xFF) as i64
        val packed = c8 | (c9 << 8) | (c10 << 16) | (c11 << 24) | (c12 << 32) | (c13 << 40) | (c14 << 48) | (c15 << 56)
        return PmpCsrReadResult64(handled: true, value: packed)
    if csr_addr == PMP64_CSR_PMPADDR0:
        return PmpCsrReadResult64(handled: true, value: entries.addr_0)
    if csr_addr == PMP64_CSR_PMPADDR0 + 1:
        return PmpCsrReadResult64(handled: true, value: entries.addr_1)
    if csr_addr == PMP64_CSR_PMPADDR0 + 2:
        return PmpCsrReadResult64(handled: true, value: entries.addr_2)
    if csr_addr == PMP64_CSR_PMPADDR0 + 3:
        return PmpCsrReadResult64(handled: true, value: entries.addr_3)
    if csr_addr == PMP64_CSR_PMPADDR0 + 4:
        return PmpCsrReadResult64(handled: true, value: entries.addr_4)
    if csr_addr == PMP64_CSR_PMPADDR0 + 5:
        return PmpCsrReadResult64(handled: true, value: entries.addr_5)
    if csr_addr == PMP64_CSR_PMPADDR0 + 6:
        return PmpCsrReadResult64(handled: true, value: entries.addr_6)
    if csr_addr == PMP64_CSR_PMPADDR0 + 7:
        return PmpCsrReadResult64(handled: true, value: entries.addr_7)
    if csr_addr == PMP64_CSR_PMPADDR0 + 8:
        return PmpCsrReadResult64(handled: true, value: entries.addr_8)
    if csr_addr == PMP64_CSR_PMPADDR0 + 9:
        return PmpCsrReadResult64(handled: true, value: entries.addr_9)
    if csr_addr == PMP64_CSR_PMPADDR0 + 10:
        return PmpCsrReadResult64(handled: true, value: entries.addr_10)
    if csr_addr == PMP64_CSR_PMPADDR0 + 11:
        return PmpCsrReadResult64(handled: true, value: entries.addr_11)
    if csr_addr == PMP64_CSR_PMPADDR0 + 12:
        return PmpCsrReadResult64(handled: true, value: entries.addr_12)
    if csr_addr == PMP64_CSR_PMPADDR0 + 13:
        return PmpCsrReadResult64(handled: true, value: entries.addr_13)
    if csr_addr == PMP64_CSR_PMPADDR0 + 14:
        return PmpCsrReadResult64(handled: true, value: entries.addr_14)
    if csr_addr == PMP64_CSR_PMPADDR0 + 15:
        return PmpCsrReadResult64(handled: true, value: entries.addr_15)
    PmpCsrReadResult64(handled: false, value: 0)

@hardware
fn pmp64_csr_write(entries: PmpEntries64, csr_addr: u32, value: i64) -> PmpCsrWriteResult64:
    var out = entries
    if csr_addr == PMP64_CSR_PMPCFG0:
        if (entries.cfg_0 & PMP64_CFG_LOCKED) == 0:
            out.cfg_0 = pmp64_cfg_normalize((value & 0xFF) as u32)
        if (entries.cfg_1 & PMP64_CFG_LOCKED) == 0:
            out.cfg_1 = pmp64_cfg_normalize(((value >> 8) & 0xFF) as u32)
        if (entries.cfg_2 & PMP64_CFG_LOCKED) == 0:
            out.cfg_2 = pmp64_cfg_normalize(((value >> 16) & 0xFF) as u32)
        if (entries.cfg_3 & PMP64_CFG_LOCKED) == 0:
            out.cfg_3 = pmp64_cfg_normalize(((value >> 24) & 0xFF) as u32)
        if (entries.cfg_4 & PMP64_CFG_LOCKED) == 0:
            out.cfg_4 = pmp64_cfg_normalize(((value >> 32) & 0xFF) as u32)
        if (entries.cfg_5 & PMP64_CFG_LOCKED) == 0:
            out.cfg_5 = pmp64_cfg_normalize(((value >> 40) & 0xFF) as u32)
        if (entries.cfg_6 & PMP64_CFG_LOCKED) == 0:
            out.cfg_6 = pmp64_cfg_normalize(((value >> 48) & 0xFF) as u32)
        if (entries.cfg_7 & PMP64_CFG_LOCKED) == 0:
            out.cfg_7 = pmp64_cfg_normalize(((value >> 56) & 0xFF) as u32)
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPCFG2:
        if (entries.cfg_8 & PMP64_CFG_LOCKED) == 0:
            out.cfg_8 = pmp64_cfg_normalize((value & 0xFF) as u32)
        if (entries.cfg_9 & PMP64_CFG_LOCKED) == 0:
            out.cfg_9 = pmp64_cfg_normalize(((value >> 8) & 0xFF) as u32)
        if (entries.cfg_10 & PMP64_CFG_LOCKED) == 0:
            out.cfg_10 = pmp64_cfg_normalize(((value >> 16) & 0xFF) as u32)
        if (entries.cfg_11 & PMP64_CFG_LOCKED) == 0:
            out.cfg_11 = pmp64_cfg_normalize(((value >> 24) & 0xFF) as u32)
        if (entries.cfg_12 & PMP64_CFG_LOCKED) == 0:
            out.cfg_12 = pmp64_cfg_normalize(((value >> 32) & 0xFF) as u32)
        if (entries.cfg_13 & PMP64_CFG_LOCKED) == 0:
            out.cfg_13 = pmp64_cfg_normalize(((value >> 40) & 0xFF) as u32)
        if (entries.cfg_14 & PMP64_CFG_LOCKED) == 0:
            out.cfg_14 = pmp64_cfg_normalize(((value >> 48) & 0xFF) as u32)
        if (entries.cfg_15 & PMP64_CFG_LOCKED) == 0:
            out.cfg_15 = pmp64_cfg_normalize(((value >> 56) & 0xFF) as u32)
        return PmpCsrWriteResult64(handled: true, entries: out)

    val masked_value = value & PMP64_CSR_PMPADDR_MASK
    if csr_addr == PMP64_CSR_PMPADDR0:
        val successor_locks = (entries.cfg_1 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_0 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_0 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 1:
        val successor_locks = (entries.cfg_2 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_1 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_1 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 2:
        val successor_locks = (entries.cfg_3 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_2 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_2 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 3:
        val successor_locks = (entries.cfg_4 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_3 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_3 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 4:
        val successor_locks = (entries.cfg_5 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_4 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_4 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 5:
        val successor_locks = (entries.cfg_6 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_5 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_5 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 6:
        val successor_locks = (entries.cfg_7 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_6 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_6 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 7:
        val successor_locks = (entries.cfg_8 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_7 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_7 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 8:
        val successor_locks = (entries.cfg_9 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_8 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_8 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 9:
        val successor_locks = (entries.cfg_10 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_9 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_9 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 10:
        val successor_locks = (entries.cfg_11 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_10 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_10 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 11:
        val successor_locks = (entries.cfg_12 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_11 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_11 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 12:
        val successor_locks = (entries.cfg_13 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_12 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_12 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 13:
        val successor_locks = (entries.cfg_14 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_13 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_13 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 14:
        val successor_locks = (entries.cfg_15 & (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_MASK)) == (PMP64_CFG_LOCKED | PMP64_CFG_ADDRESS_TOR)
        if (entries.cfg_14 & PMP64_CFG_LOCKED) == 0 and not successor_locks:
            out.addr_14 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    if csr_addr == PMP64_CSR_PMPADDR0 + 15:
        if (entries.cfg_15 & PMP64_CFG_LOCKED) == 0:
            out.addr_15 = masked_value
        return PmpCsrWriteResult64(handled: true, entries: out)
    PmpCsrWriteResult64(handled: false, entries: entries)
