# ============================================================================
# RV64GC RTL Package — Constants and Type Aliases
# ============================================================================
#
# Extends RV32I constants for RV64GC.  All values use u32 for opcode/funct
# constants and i64 for ALU-op enum codes (matching the behavioral
# riscv_common convention).
#
# VHDL synthesizable subset: only integer constants; no heap, no closures.
# ============================================================================

# ============================================================================
# Shared constants (Wave-3 W3-1): the 10 opcodes, 11 ALU codes (0..10) and the
# RV32I load/store funct3 subset live in riscv_common/rtl_pkg.spl and are
# re-exported here unchanged. RV64-only consts (W-suffix opcodes/ALU codes,
# OP_AMO, MULDIV_*, FUNCT3_LD/LWU/S*) stay local below.
# ============================================================================

use std.hardware.riscv_common.rtl_pkg.{OP_LUI, OP_AUIPC, OP_JAL, OP_JALR, OP_BRANCH}
use std.hardware.riscv_common.rtl_pkg.{OP_LOAD, OP_STORE, OP_IMMED, OP_REG, OP_SYSTEM}
use std.hardware.riscv_common.rtl_pkg.{ALU_ADD, ALU_SUB, ALU_SLL, ALU_SLT, ALU_SLTU}
use std.hardware.riscv_common.rtl_pkg.{ALU_XOR, ALU_SRL, ALU_SRA, ALU_OR, ALU_AND, ALU_PASS_B}
use std.hardware.riscv_common.rtl_pkg.{FUNCT3_LB, FUNCT3_LH, FUNCT3_LW, FUNCT3_LBU, FUNCT3_LHU}

# ============================================================================
# RV64-only opcode constants (7-bit, stored in u32)
# ============================================================================

# --- RV64I additional opcodes (W-suffix instructions) ---
val OP_OP_IMM_32: u32 = 0x1B   # ADDIW, SLLIW, SRLIW, SRAIW
val OP_OP_32: u32     = 0x3B   # ADDW, SUBW, SLLW, SRLW, SRAW, MULW, DIVW, etc.

# --- Misc-mem (FENCE) — kept RV64-local (see commit e7411180ecc) ---
val OP_MISC_MEM: u32 = 0x0F  # FENCE, FENCE.I

# --- Atomic extension (A) ---
val OP_AMO: u32 = 0x2F   # Atomic memory operations (LR, SC, AMO*)

# ============================================================================
# RV64-only W-suffix ALU operation codes (i64 enum, continue after shared 0..10)
# ============================================================================

# W-suffix ALU operations (operate on low 32 bits, sign-extend result)
val ALU_ADDW: i64   = 11
val ALU_SUBW: i64   = 12
val ALU_SLLW: i64   = 13
val ALU_SRLW: i64   = 14
val ALU_SRAW: i64   = 15

# ============================================================================
# Branch funct3 constants (3-bit, stored in u32)
# ============================================================================

val BR_BEQ: u32  = 0x0   # 000
val BR_BNE: u32  = 0x1   # 001
val BR_BLT: u32  = 0x4   # 100
val BR_BGE: u32  = 0x5   # 101
val BR_BLTU: u32 = 0x6   # 110
val BR_BGEU: u32 = 0x7   # 111

# ============================================================================
# Load/Store funct3 constants
# ============================================================================

# FUNCT3_LB/LH/LW/LBU/LHU are shared (imported above). RV64 adds LD/LWU:
val FUNCT3_LD: u32  = 0x3   # Load doubleword (RV64)
val FUNCT3_LWU: u32 = 0x6   # Load word unsigned (RV64)

val FUNCT3_SB: u32  = 0x0   # Store byte
val FUNCT3_SH: u32  = 0x1   # Store halfword
val FUNCT3_SW: u32  = 0x2   # Store word
val FUNCT3_SD: u32  = 0x3   # Store doubleword (RV64)

# ============================================================================
# Memory width encoding (3-bit for RV64)
# ============================================================================

val MEM_WIDTH_BYTE: u32  = 0x0
val MEM_WIDTH_HALF: u32  = 0x1
val MEM_WIDTH_WORD: u32  = 0x2
val MEM_WIDTH_DWORD: u32 = 0x3

# ============================================================================
# Multiply/divide operation codes (i64 enum)
# ============================================================================

val MULDIV_MUL: i64    = 0
val MULDIV_MULH: i64   = 1
val MULDIV_MULHSU: i64 = 2
val MULDIV_MULHU: i64  = 3
val MULDIV_DIV: i64    = 4
val MULDIV_DIVU: i64   = 5
val MULDIV_REM: i64    = 6
val MULDIV_REMU: i64   = 7
val MULDIV_MULW: i64   = 8
val MULDIV_DIVW: i64   = 9
val MULDIV_DIVUW: i64  = 10
val MULDIV_REMW: i64   = 11
val MULDIV_REMUW: i64  = 12

# ============================================================================
# Atomic funct5 codes (upper 5 bits of funct7)
# ============================================================================

val AMO_LR: u32      = 0x02
val AMO_SC: u32      = 0x03
val AMO_SWAP: u32    = 0x01
val AMO_ADD: u32     = 0x00
val AMO_XOR: u32     = 0x04
val AMO_AND: u32     = 0x0C
val AMO_OR: u32      = 0x08
val AMO_MIN: u32     = 0x10
val AMO_MAX: u32     = 0x14
val AMO_MINU: u32    = 0x18
val AMO_MAXU: u32    = 0x1C

# ============================================================================
# Semihosting magic instruction encodings (same as RV32)
# ============================================================================

val SEMI_ENTRY: u32 = 0x01F01013   # slli zero,zero,0x1f
val SEMI_BREAK: u32 = 0x00100073   # ebreak
val SEMI_EXIT: u32  = 0x40705013   # srai zero,zero,0x7

# ============================================================================
# Semihosting operation codes
# ============================================================================

val SYS_WRITEC: u32 = 0x00000003
val SYS_WRITE0: u32 = 0x00000004
val SYS_EXIT: u32   = 0x00000018

# ============================================================================
# Mailbox MMIO base address and register offsets (same as RV32)
# ============================================================================

val MB_BASE_ADDR: u32     = 0x80FF0000
val MB_OFF_CMD: u32       = 0x00
val MB_OFF_ARG0: u32      = 0x04
val MB_OFF_ARG1: u32      = 0x08
val MB_OFF_STATUS: u32    = 0x0C
val MB_OFF_RESULT: u32    = 0x10
val MB_OFF_SEQ_ID: u32    = 0x14
val MB_OFF_TRIGGER: u32   = 0x18

# ============================================================================
# Mailbox command codes
# ============================================================================

val MB_CMD_PUTC: u32   = 0x00000001
val MB_CMD_EXIT: u32   = 0x00000002
val MB_CMD_RESULT: u32 = 0x00000003

# ============================================================================
# Mailbox sentinel address and values
# ============================================================================

val MB_SENTINEL_ADDR: u32    = 0x80008000
val MB_SENTINEL_SUCCESS: u32 = 0xCAFE0000
val MB_SENTINEL_TIMEOUT: u32 = 0xDEAD0000
val MB_TRIGGER_MAGIC: u32    = 0x0000DEAD

# ============================================================================
# SoC Bus abstraction (shared between core and LSU)
# ============================================================================

struct SocBus64:
    data: i64

fn soc_bus64_init() -> SocBus64:
    SocBus64(data: 0)

export OP_LUI, OP_AUIPC, OP_JAL, OP_JALR, OP_BRANCH, OP_LOAD, OP_STORE
export OP_IMMED, OP_REG, OP_SYSTEM, OP_MISC_MEM, OP_OP_IMM_32, OP_OP_32, OP_AMO
export ALU_ADD, ALU_SUB, ALU_SLL, ALU_SLT, ALU_SLTU, ALU_XOR, ALU_SRL
export ALU_SRA, ALU_OR, ALU_AND, ALU_PASS_B, ALU_ADDW, ALU_SUBW
export ALU_SLLW, ALU_SRLW, ALU_SRAW
export BR_BEQ, BR_BNE, BR_BLT, BR_BGE, BR_BLTU, BR_BGEU
export FUNCT3_LB, FUNCT3_LH, FUNCT3_LW, FUNCT3_LD, FUNCT3_LBU, FUNCT3_LHU, FUNCT3_LWU
export FUNCT3_SB, FUNCT3_SH, FUNCT3_SW, FUNCT3_SD
export MEM_WIDTH_BYTE, MEM_WIDTH_HALF, MEM_WIDTH_WORD, MEM_WIDTH_DWORD
export MULDIV_MUL, MULDIV_MULH, MULDIV_MULHSU, MULDIV_MULHU
export MULDIV_DIV, MULDIV_DIVU, MULDIV_REM, MULDIV_REMU
export MULDIV_MULW, MULDIV_DIVW, MULDIV_DIVUW, MULDIV_REMW, MULDIV_REMUW
export AMO_LR, AMO_SC, AMO_SWAP, AMO_ADD, AMO_XOR, AMO_AND, AMO_OR
export AMO_MIN, AMO_MAX, AMO_MINU, AMO_MAXU
export SEMI_ENTRY, SEMI_BREAK, SEMI_EXIT
export SYS_WRITEC, SYS_WRITE0, SYS_EXIT
export MB_BASE_ADDR, MB_OFF_CMD, MB_OFF_ARG0, MB_OFF_ARG1
export MB_OFF_STATUS, MB_OFF_RESULT, MB_OFF_SEQ_ID, MB_OFF_TRIGGER
export MB_CMD_PUTC, MB_CMD_EXIT, MB_CMD_RESULT
export MB_SENTINEL_ADDR, MB_SENTINEL_SUCCESS, MB_SENTINEL_TIMEOUT, MB_TRIGGER_MAGIC
export SocBus64, soc_bus64_init
