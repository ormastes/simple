# RV64GC RVFI trace metadata.
#
# 64-bit mirror of rv32i_rtl/rvfi.spl. Extracts a per-retire RVFI trace
# from architectural commit snapshots.

struct RvfiTrace64:
    """RISC-V Formal Interface trace bundle for one retired RV64 instruction."""
    rvfi_valid: bool
    rvfi_order: i64
    rvfi_insn: u32
    rvfi_trap: bool
    rvfi_intr: bool
    rvfi_rs1_addr: u32
    rvfi_rs2_addr: u32
    rvfi_rs1_rdata: i64
    rvfi_rs2_rdata: i64
    rvfi_rd_addr: u32
    rvfi_rd_wdata: i64
    rvfi_pc_rdata: i64
    rvfi_pc_wdata: i64
    rvfi_mem_addr: i64
    rvfi_mem_rmask: u32
    rvfi_mem_wmask: u32
    rvfi_mem_rdata: i64
    rvfi_mem_wdata: i64

struct RvfiConfig64:
    enabled: bool
    order_start: i64

struct RvfiCoreSnapshot64:
    """Core signals needed to form a 64-bit RVFI trace."""
    halted: bool
    suppress: bool
    pc: i64
    pc_next: i64
    insn: u32
    rs1_addr: u32
    rs2_addr: u32
    rs1_rdata: i64
    rs2_rdata: i64
    rd_addr: u32
    rd_wdata: i64
    dmem_addr: i64
    dmem_width: u32
    dmem_re: bool
    dmem_we: bool
    dmem_rdata: i64
    dmem_wdata: i64

fn rvfi64_disabled_config() -> RvfiConfig64:
    RvfiConfig64(enabled: false, order_start: 0)

fn rvfi64_enabled_config(order_start: i64) -> RvfiConfig64:
    RvfiConfig64(enabled: true, order_start: order_start)

fn rvfi64_mask_for_width(width: u32) -> u32:
    """Byte-enable mask for a dmem access width (funct3 low bits: 0=B,1=H,2=W,3=D)."""
    if width == 0:
        return 0x1
    if width == 1:
        return 0x3
    if width == 2:
        return 0xF
    0xFF

fn rvfi64_trace_from_snapshot(config: RvfiConfig64, order: i64, snapshot: RvfiCoreSnapshot64) -> RvfiTrace64:
    val valid = config.enabled and not snapshot.halted and not snapshot.suppress
    val mem_mask = rvfi64_mask_for_width(snapshot.dmem_width)
    val rmask = if snapshot.dmem_re: mem_mask else: 0
    val wmask = if snapshot.dmem_we: mem_mask else: 0
    RvfiTrace64(
        rvfi_valid: valid,
        rvfi_order: config.order_start + order,
        rvfi_insn: snapshot.insn,
        rvfi_trap: snapshot.halted,
        rvfi_intr: false,
        rvfi_rs1_addr: snapshot.rs1_addr,
        rvfi_rs2_addr: snapshot.rs2_addr,
        rvfi_rs1_rdata: snapshot.rs1_rdata,
        rvfi_rs2_rdata: snapshot.rs2_rdata,
        rvfi_rd_addr: snapshot.rd_addr,
        rvfi_rd_wdata: snapshot.rd_wdata,
        rvfi_pc_rdata: snapshot.pc,
        rvfi_pc_wdata: snapshot.pc_next,
        rvfi_mem_addr: snapshot.dmem_addr,
        rvfi_mem_rmask: rmask,
        rvfi_mem_wmask: wmask,
        rvfi_mem_rdata: snapshot.dmem_rdata,
        rvfi_mem_wdata: snapshot.dmem_wdata
    )

# ============================================================================
# RVFI trace self-check (retire-chain invariants)
# ============================================================================

fn rvfi64_check_traces(traces: [RvfiTrace64]) -> [text]:
    """Check retire-chain invariants over a collected 64-bit RVFI trace.

    Same invariants as rv32 rvfi_check_traces:
      1. rvfi_order strictly increasing across valid retires.
      2. pc chaining: pc_wdata of retire N == pc_rdata of retire N+1,
         except when retire N trapped or retire N+1 begins an interrupt handler.
      3. x0 gating: rd_addr == 0 implies rd_wdata == 0.
      4. simultaneous rmask/wmask is reserved for one retired AMO.

    Returns violation strings; empty == all invariants hold. Callers must
    reject vacuous runs (fewer than 2 valid retires) separately.
    """
    var violations: [text] = []
    var have_prev = false
    var prev_order: i64 = 0
    var prev_pc_wdata: i64 = 0
    var prev_trap = false
    var idx = 0
    for t in traces:
        if not t.rvfi_valid:
            idx = idx + 1
            continue
        if t.rvfi_rd_addr == 0 and t.rvfi_rd_wdata != 0:
            violations = violations.push("retire {idx}: x0 write nonzero rd_wdata")
        val is_amo = (t.rvfi_insn & 0x7F) == 0x2F
        if t.rvfi_mem_rmask != 0 and t.rvfi_mem_wmask != 0 and not is_amo:
            violations = violations.push("retire {idx}: simultaneous rmask and wmask")
        if have_prev:
            if t.rvfi_order <= prev_order:
                violations = violations.push("retire {idx}: order not monotonic ({t.rvfi_order} after {prev_order})")
            if (not prev_trap and not t.rvfi_intr and
                t.rvfi_pc_rdata != prev_pc_wdata):
                violations = violations.push("retire {idx}: pc chain broken (pc_rdata != prev pc_wdata)")
        prev_order = t.rvfi_order
        prev_pc_wdata = t.rvfi_pc_wdata
        prev_trap = t.rvfi_trap
        have_prev = true
        idx = idx + 1
    violations

fn rvfi64_valid_retire_count(traces: [RvfiTrace64]) -> i64:
    """Count valid retires in a trace (vacuity guard input)."""
    var n: i64 = 0
    for t in traces:
        if t.rvfi_valid:
            n = n + 1
    n
