# ============================================================================
# RV64GC RTL Register File — 2R1W, 32 x 64-bit
# ============================================================================
#
# Adapts RV32I register file for RV64.  x0 is hardwired to zero.
# Combinational reads (async), clocked writes (sync).
# Includes direct a0/a1 read ports for semihosting.
#
# Initial values: x2 (sp) = 0x0000000000000FFC (top of 4 KB DMEM).
# ============================================================================

# ============================================================================
# Initial SP value (64-bit)
# ============================================================================

val INIT_SP_64: i64 = 0x0000000000000FFC   # Top of 4 KB data memory

# ============================================================================
# Register file struct
# ============================================================================

struct RegFile64:
    """31 stored 64-bit registers; x0 is the implicit hardwired zero lane."""
    # ponytail: scalar lanes favor portable RTL; use inferred RAM only if FPGA area/timing evidence requires it.
    x1: i64
    x2: i64
    x3: i64
    x4: i64
    x5: i64
    x6: i64
    x7: i64
    x8: i64
    x9: i64
    x10: i64
    x11: i64
    x12: i64
    x13: i64
    x14: i64
    x15: i64
    x16: i64
    x17: i64
    x18: i64
    x19: i64
    x20: i64
    x21: i64
    x22: i64
    x23: i64
    x24: i64
    x25: i64
    x26: i64
    x27: i64
    x28: i64
    x29: i64
    x30: i64
    x31: i64

# ============================================================================
# Read result bundle
# ============================================================================

struct RegReadResult64:
    """Combinational read port outputs."""
    rs1_data: i64
    rs2_data: i64
    a0_val: i64    # Direct read of x10 (a0) for semihosting
    a1_val: i64    # Direct read of x11 (a1) for semihosting

# ============================================================================
# Register file initialization
# ============================================================================

@hardware
fn regfile64_create() -> RegFile64:
    """Create a register file with initial values.
    x0 = 0 (hardwired), x2 (sp) = INIT_SP_64, all others = 0."""
    RegFile64(
        x1: 0,
        x2: INIT_SP_64,
        x3: 0,
        x4: 0,
        x5: 0,
        x6: 0,
        x7: 0,
        x8: 0,
        x9: 0,
        x10: 0,
        x11: 0,
        x12: 0,
        x13: 0,
        x14: 0,
        x15: 0,
        x16: 0,
        x17: 0,
        x18: 0,
        x19: 0,
        x20: 0,
        x21: 0,
        x22: 0,
        x23: 0,
        x24: 0,
        x25: 0,
        x26: 0,
        x27: 0,
        x28: 0,
        x29: 0,
        x30: 0,
        x31: 0
    )

@hardware
fn regfile64_read_one(rf: RegFile64, addr: u32) -> i64:
    """Read one GPR through the synthesizable 32-way mux."""
    match addr:
        case 1: rf.x1
        case 2: rf.x2
        case 3: rf.x3
        case 4: rf.x4
        case 5: rf.x5
        case 6: rf.x6
        case 7: rf.x7
        case 8: rf.x8
        case 9: rf.x9
        case 10: rf.x10
        case 11: rf.x11
        case 12: rf.x12
        case 13: rf.x13
        case 14: rf.x14
        case 15: rf.x15
        case 16: rf.x16
        case 17: rf.x17
        case 18: rf.x18
        case 19: rf.x19
        case 20: rf.x20
        case 21: rf.x21
        case 22: rf.x22
        case 23: rf.x23
        case 24: rf.x24
        case 25: rf.x25
        case 26: rf.x26
        case 27: rf.x27
        case 28: rf.x28
        case 29: rf.x29
        case 30: rf.x30
        case 31: rf.x31
        case _: 0

# ============================================================================
# Combinational read (async — mirrors VHDL concurrent assignments)
# ============================================================================

@hardware
fn regfile64_read(rf: RegFile64, rs1_addr: u32, rs2_addr: u32) -> RegReadResult64:
    """Read two registers plus a0/a1 direct ports.
    x0 always reads as zero (hardwired)."""

    RegReadResult64(
        rs1_data: regfile64_read_one(rf, rs1_addr),
        rs2_data: regfile64_read_one(rf, rs2_addr),
        a0_val: rf.x10,
        a1_val: rf.x11
    )

# ============================================================================
# Clocked write (sync — mirrors VHDL rising_edge process)
# ============================================================================

@hardware
fn regfile64_write(rf: RegFile64, rd_addr: u32, rd_data: i64, we: bool) -> RegFile64:
    """Write to register file. Writes to x0 are silently discarded.
    Returns the updated register file (functional style for RTL)."""
    var new_rf = rf
    if we:
        match rd_addr:
            case 1: new_rf.x1 = rd_data
            case 2: new_rf.x2 = rd_data
            case 3: new_rf.x3 = rd_data
            case 4: new_rf.x4 = rd_data
            case 5: new_rf.x5 = rd_data
            case 6: new_rf.x6 = rd_data
            case 7: new_rf.x7 = rd_data
            case 8: new_rf.x8 = rd_data
            case 9: new_rf.x9 = rd_data
            case 10: new_rf.x10 = rd_data
            case 11: new_rf.x11 = rd_data
            case 12: new_rf.x12 = rd_data
            case 13: new_rf.x13 = rd_data
            case 14: new_rf.x14 = rd_data
            case 15: new_rf.x15 = rd_data
            case 16: new_rf.x16 = rd_data
            case 17: new_rf.x17 = rd_data
            case 18: new_rf.x18 = rd_data
            case 19: new_rf.x19 = rd_data
            case 20: new_rf.x20 = rd_data
            case 21: new_rf.x21 = rd_data
            case 22: new_rf.x22 = rd_data
            case 23: new_rf.x23 = rd_data
            case 24: new_rf.x24 = rd_data
            case 25: new_rf.x25 = rd_data
            case 26: new_rf.x26 = rd_data
            case 27: new_rf.x27 = rd_data
            case 28: new_rf.x28 = rd_data
            case 29: new_rf.x29 = rd_data
            case 30: new_rf.x30 = rd_data
            case 31: new_rf.x31 = rd_data
            case _: ()
    new_rf
