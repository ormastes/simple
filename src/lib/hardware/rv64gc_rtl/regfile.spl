# ============================================================================
# RV64GC RTL Register File — 2R1W, 32 x 64-bit
# ============================================================================
#
# Adapts RV32I register file for RV64.  x0 is hardwired to zero.
# Combinational reads (async), clocked writes (sync).
# Includes direct a0/a1 read ports for semihosting.
#
# Initial values: x2 (sp) = 0x0000000000000FFC (top of 4 KB DMEM).
# ============================================================================

# ============================================================================
# Initial SP value (64-bit)
# ============================================================================

val INIT_SP_64: i64 = 0x0000000000000FFC   # Top of 4 KB data memory

# ============================================================================
# Register file struct
# ============================================================================

struct RegFile64:
    """32 x 64-bit integer register file (VHDL synthesizable).
    NOTE: uses dynamic [i64] for initialization compatibility;
    VHDL backend maps this to reg_array_t (array 0 to 31 of std_logic_vector(63 downto 0))."""
    regs: [i64]

# ============================================================================
# Read result bundle
# ============================================================================

struct RegReadResult64:
    """Combinational read port outputs."""
    rs1_data: i64
    rs2_data: i64
    a0_val: i64    # Direct read of x10 (a0) for semihosting
    a1_val: i64    # Direct read of x11 (a1) for semihosting

# ============================================================================
# Register file initialization
# ============================================================================

fn regfile64_create() -> RegFile64:
    """Create a register file with initial values.
    x0 = 0 (hardwired), x2 (sp) = INIT_SP_64, all others = 0."""
    var regs: [i64] = []
    var i = 0
    while i < 32:
        regs = regs + [0]
        i = i + 1
    var rf = RegFile64(regs: regs)
    rf.regs[2] = INIT_SP_64
    rf

# ============================================================================
# Combinational read (async — mirrors VHDL concurrent assignments)
# ============================================================================

fn regfile64_read(rf: RegFile64, rs1_addr: u32, rs2_addr: u32) -> RegReadResult64:
    """Read two registers plus a0/a1 direct ports.
    x0 always reads as zero (hardwired)."""

    var rs1_data: i64 = 0
    if rs1_addr != 0:
        rs1_data = rf.regs[rs1_addr]

    var rs2_data: i64 = 0
    if rs2_addr != 0:
        rs2_data = rf.regs[rs2_addr]

    RegReadResult64(
        rs1_data: rs1_data,
        rs2_data: rs2_data,
        a0_val: rf.regs[10],
        a1_val: rf.regs[11]
    )

# ============================================================================
# Clocked write (sync — mirrors VHDL rising_edge process)
# ============================================================================

fn regfile64_write(rf: RegFile64, rd_addr: u32, rd_data: i64, we: bool) -> RegFile64:
    """Write to register file. Writes to x0 are silently discarded.
    Returns the updated register file (functional style for RTL)."""
    var new_rf = rf
    if we and rd_addr != 0:
        new_rf.regs[rd_addr] = rd_data
    new_rf
