# RV64C integer decompressor. Floating-point compressed encodings remain
# illegal because the selected production profile is RV64IMAC, not G.

struct RvcDecode64:
    valid: bool
    instruction: u32

@hardware
fn rvc64_invalid() -> RvcDecode64:
    RvcDecode64(valid: false, instruction: 0)

@hardware
fn rvc64_valid(instruction: u32) -> RvcDecode64:
    RvcDecode64(valid: true, instruction: instruction)

@hardware
fn rvc64_prime(value: u32) -> u32:
    8 + (value & 7)

@hardware
fn rvc64_sign_extend(value: u32, width: u32) -> i64:
    val mask: u32 = (1 << width) - 1
    val low = (value & mask) as i64
    val sign: i64 = 1 << (width - 1)
    if (low & sign) != 0:
        return low | (-1 << width)
    low

@hardware
fn rvc64_encode_i(opcode: u32, rd: u32, funct3: u32, rs1: u32,
                  immediate: i64) -> u32:
    (((immediate as u32) & 0xFFF) << 20) | (rs1 << 15) | (funct3 << 12) |
        (rd << 7) | opcode

@hardware
fn rvc64_encode_r(opcode: u32, rd: u32, funct3: u32, rs1: u32, rs2: u32,
                  funct7: u32) -> u32:
    (funct7 << 25) | (rs2 << 20) | (rs1 << 15) | (funct3 << 12) |
        (rd << 7) | opcode

@hardware
fn rvc64_encode_s(opcode: u32, funct3: u32, rs1: u32, rs2: u32,
                  immediate: i64) -> u32:
    val imm = immediate as u32
    (((imm >> 5) & 0x7F) << 25) | (rs2 << 20) | (rs1 << 15) |
        (funct3 << 12) | ((imm & 0x1F) << 7) | opcode

@hardware
fn rvc64_encode_b(funct3: u32, rs1: u32, rs2: u32,
                  immediate: i64) -> u32:
    val imm = immediate as u32
    (((imm >> 12) & 1) << 31) | (((imm >> 5) & 0x3F) << 25) |
        (rs2 << 20) | (rs1 << 15) | (funct3 << 12) |
        (((imm >> 1) & 0xF) << 8) | (((imm >> 11) & 1) << 7) | 0x63

@hardware
fn rvc64_encode_u(rd: u32, immediate: i64) -> u32:
    ((immediate as u32) & 0xFFFFF000) | (rd << 7) | 0x37

@hardware
fn rvc64_encode_j(rd: u32, immediate: i64) -> u32:
    val imm = immediate as u32
    (((imm >> 20) & 1) << 31) | (((imm >> 1) & 0x3FF) << 21) |
        (((imm >> 11) & 1) << 20) | (((imm >> 12) & 0xFF) << 12) |
        (rd << 7) | 0x6F

@hardware
fn rvc64_ci_imm(parcel: u32) -> i64:
    rvc64_sign_extend((((parcel >> 12) & 1) << 5) | ((parcel >> 2) & 0x1F), 6)

@hardware
fn rvc64_addi4spn_imm(parcel: u32) -> i64:
    ((((parcel >> 7) & 0xF) << 6) | (((parcel >> 11) & 3) << 4) |
     (((parcel >> 5) & 1) << 3) | (((parcel >> 6) & 1) << 2)) as i64

@hardware
fn rvc64_lw_imm(parcel: u32) -> i64:
    ((((parcel >> 5) & 1) << 6) | (((parcel >> 10) & 7) << 3) |
     (((parcel >> 6) & 1) << 2)) as i64

@hardware
fn rvc64_ld_imm(parcel: u32) -> i64:
    ((((parcel >> 5) & 3) << 6) | (((parcel >> 10) & 7) << 3)) as i64

@hardware
fn rvc64_jump_imm(parcel: u32) -> i64:
    val value = (((parcel >> 12) & 1) << 11) |
        (((parcel >> 11) & 1) << 4) | (((parcel >> 9) & 3) << 8) |
        (((parcel >> 8) & 1) << 10) | (((parcel >> 7) & 1) << 6) |
        (((parcel >> 6) & 1) << 7) | (((parcel >> 3) & 7) << 1) |
        (((parcel >> 2) & 1) << 5)
    rvc64_sign_extend(value, 12)

@hardware
fn rvc64_branch_imm(parcel: u32) -> i64:
    val value = (((parcel >> 12) & 1) << 8) |
        (((parcel >> 10) & 3) << 3) | (((parcel >> 5) & 3) << 6) |
        (((parcel >> 3) & 3) << 1) | (((parcel >> 2) & 1) << 5)
    rvc64_sign_extend(value, 9)

@hardware
fn rvc64_addi16sp_imm(parcel: u32) -> i64:
    val value = (((parcel >> 12) & 1) << 9) |
        (((parcel >> 6) & 1) << 4) | (((parcel >> 5) & 1) << 6) |
        (((parcel >> 3) & 3) << 7) | (((parcel >> 2) & 1) << 5)
    rvc64_sign_extend(value, 10)

@hardware
fn rvc64_lwsp_imm(parcel: u32) -> i64:
    ((((parcel >> 2) & 3) << 6) | (((parcel >> 12) & 1) << 5) |
     (((parcel >> 4) & 7) << 2)) as i64

@hardware
fn rvc64_ldsp_imm(parcel: u32) -> i64:
    ((((parcel >> 2) & 7) << 6) | (((parcel >> 12) & 1) << 5) |
     (((parcel >> 5) & 3) << 3)) as i64

@hardware
fn rvc64_swsp_imm(parcel: u32) -> i64:
    ((((parcel >> 7) & 3) << 6) | (((parcel >> 9) & 0xF) << 2)) as i64

@hardware
fn rvc64_sdsp_imm(parcel: u32) -> i64:
    ((((parcel >> 7) & 7) << 6) | (((parcel >> 10) & 7) << 3)) as i64

@hardware
fn rvc64_decompress(parcel: u32) -> RvcDecode64:
    """Expand one 16-bit RV64C integer instruction or fail closed."""
    val c = parcel & 0xFFFF
    val quadrant = c & 3
    val funct3 = (c >> 13) & 7
    val rd = (c >> 7) & 0x1F
    val rs2 = (c >> 2) & 0x1F
    val rs1_prime = rvc64_prime((c >> 7) & 7)
    val rs2_prime = rvc64_prime((c >> 2) & 7)

    if quadrant == 0:
        if funct3 == 0:
            val imm = rvc64_addi4spn_imm(c)
            if imm == 0:
                return rvc64_invalid()
            return rvc64_valid(rvc64_encode_i(0x13, rs2_prime, 0, 2, imm))
        if funct3 == 2:
            return rvc64_valid(rvc64_encode_i(0x03, rs2_prime, 2,
                rs1_prime, rvc64_lw_imm(c)))
        if funct3 == 3:
            return rvc64_valid(rvc64_encode_i(0x03, rs2_prime, 3,
                rs1_prime, rvc64_ld_imm(c)))
        if funct3 == 6:
            return rvc64_valid(rvc64_encode_s(0x23, 2, rs1_prime,
                rs2_prime, rvc64_lw_imm(c)))
        if funct3 == 7:
            return rvc64_valid(rvc64_encode_s(0x23, 3, rs1_prime,
                rs2_prime, rvc64_ld_imm(c)))
        return rvc64_invalid()

    if quadrant == 1:
        val imm = rvc64_ci_imm(c)
        if funct3 == 0:
            return rvc64_valid(rvc64_encode_i(0x13, rd, 0, rd, imm))
        if funct3 == 1:
            if rd == 0:
                return rvc64_invalid()
            return rvc64_valid(rvc64_encode_i(0x1B, rd, 0, rd, imm))
        if funct3 == 2:
            return rvc64_valid(rvc64_encode_i(0x13, rd, 0, 0, imm))
        if funct3 == 3:
            if rd == 2:
                val sp_imm = rvc64_addi16sp_imm(c)
                if sp_imm == 0:
                    return rvc64_invalid()
                return rvc64_valid(rvc64_encode_i(0x13, 2, 0, 2, sp_imm))
            if imm == 0:
                return rvc64_invalid()
            return rvc64_valid(rvc64_encode_u(rd, imm << 12))
        if funct3 == 4:
            val mode = (c >> 10) & 3
            val rd_prime = rvc64_prime((c >> 7) & 7)
            val shamt = (((c >> 12) & 1) << 5) | ((c >> 2) & 0x1F)
            if mode == 0:
                return rvc64_valid(rvc64_encode_i(0x13, rd_prime, 5,
                    rd_prime, shamt as i64))
            if mode == 1:
                return rvc64_valid(rvc64_encode_i(0x13, rd_prime, 5,
                    rd_prime, (0x400 | shamt) as i64))
            if mode == 2:
                return rvc64_valid(rvc64_encode_i(0x13, rd_prime, 7,
                    rd_prime, imm))
            val op = (c >> 5) & 3
            val word = ((c >> 12) & 1) != 0
            if not word:
                if op == 0:
                    return rvc64_valid(rvc64_encode_r(0x33, rd_prime, 0,
                        rd_prime, rs2_prime, 0x20))
                if op == 1:
                    return rvc64_valid(rvc64_encode_r(0x33, rd_prime, 4,
                        rd_prime, rs2_prime, 0))
                if op == 2:
                    return rvc64_valid(rvc64_encode_r(0x33, rd_prime, 6,
                        rd_prime, rs2_prime, 0))
                return rvc64_valid(rvc64_encode_r(0x33, rd_prime, 7,
                    rd_prime, rs2_prime, 0))
            if op == 0:
                return rvc64_valid(rvc64_encode_r(0x3B, rd_prime, 0,
                    rd_prime, rs2_prime, 0x20))
            if op == 1:
                return rvc64_valid(rvc64_encode_r(0x3B, rd_prime, 0,
                    rd_prime, rs2_prime, 0))
            return rvc64_invalid()
        if funct3 == 5:
            return rvc64_valid(rvc64_encode_j(0, rvc64_jump_imm(c)))
        if funct3 == 6:
            return rvc64_valid(rvc64_encode_b(0, rs1_prime, 0,
                rvc64_branch_imm(c)))
        if funct3 == 7:
            return rvc64_valid(rvc64_encode_b(1, rs1_prime, 0,
                rvc64_branch_imm(c)))
        return rvc64_invalid()

    if quadrant == 2:
        if funct3 == 0:
            val shamt = (((c >> 12) & 1) << 5) | ((c >> 2) & 0x1F)
            return rvc64_valid(rvc64_encode_i(0x13, rd, 1, rd,
                shamt as i64))
        if funct3 == 2:
            if rd == 0:
                return rvc64_invalid()
            return rvc64_valid(rvc64_encode_i(0x03, rd, 2, 2,
                rvc64_lwsp_imm(c)))
        if funct3 == 3:
            if rd == 0:
                return rvc64_invalid()
            return rvc64_valid(rvc64_encode_i(0x03, rd, 3, 2,
                rvc64_ldsp_imm(c)))
        if funct3 == 4:
            val high = ((c >> 12) & 1) != 0
            if not high:
                if rs2 == 0:
                    if rd == 0:
                        return rvc64_invalid()
                    return rvc64_valid(rvc64_encode_i(0x67, 0, 0, rd, 0))
                return rvc64_valid(rvc64_encode_r(0x33, rd, 0, 0, rs2, 0))
            if rs2 == 0:
                if rd == 0:
                    return rvc64_valid(0x00100073)
                return rvc64_valid(rvc64_encode_i(0x67, 1, 0, rd, 0))
            return rvc64_valid(rvc64_encode_r(0x33, rd, 0, rd, rs2, 0))
        if funct3 == 6:
            return rvc64_valid(rvc64_encode_s(0x23, 2, 2, rs2,
                rvc64_swsp_imm(c)))
        if funct3 == 7:
            return rvc64_valid(rvc64_encode_s(0x23, 3, 2, rs2,
                rvc64_sdsp_imm(c)))
        return rvc64_invalid()

    rvc64_invalid()

export RvcDecode64, rvc64_decompress
