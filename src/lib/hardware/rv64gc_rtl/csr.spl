# ============================================================================
# RV64GC RTL CSR File — M-Mode Control/Status Registers (64-bit)
# ============================================================================
#
# Implements the machine-mode CSR register file for RV64GC.  All CSR values
# are i64 (64-bit).  No need for mcycleh/minstreth — 64-bit counters
# directly.
#
# Supported CSRs:
#   Trap Setup:    mstatus, misa, mie, mtvec
#   Trap Handling: mscratch, mepc, mcause, mtval, mip
#   Counters:      mcycle, minstret (64-bit directly)
#   Info:          mhartid (read-only)
#
# VHDL synthesizable subset: i64, bool, structs only.
# ============================================================================

# ============================================================================
# CSR Address Constants (u32 for RTL address matching)
# ============================================================================

val CSR_ADDR_MSTATUS: u32   = 0x300
val CSR_ADDR_MISA: u32      = 0x301
val CSR_ADDR_MIE: u32       = 0x304
val CSR_ADDR_MTVEC: u32     = 0x305
val CSR_ADDR_MSCRATCH: u32  = 0x340
val CSR_ADDR_MEPC: u32      = 0x341
val CSR_ADDR_MCAUSE: u32    = 0x342
val CSR_ADDR_MTVAL: u32     = 0x343
val CSR_ADDR_MIP: u32       = 0x344
val CSR_ADDR_MCYCLE: u32    = 0xB00
val CSR_ADDR_MINSTRET: u32  = 0xB02
val CSR_ADDR_MEDELEG: u32   = 0x302
val CSR_ADDR_MIDELEG: u32   = 0x303
val CSR_ADDR_MHARTID: u32   = 0xF14

# ============================================================================
# MSTATUS Bit Masks (i64 for 64-bit CSR)
# ============================================================================

val MSTATUS_MIE_MASK: i64   = 0x00000008   # bit 3
val MSTATUS_MPIE_MASK: i64  = 0x00000080   # bit 7
val MSTATUS_MPP_MASK: i64   = 0x00001800   # bits [12:11]
val MSTATUS_FS_MASK: i64    = 0x00006000   # bits [14:13] — FP unit status

val MSTATUS_MIE_BIT: i64    = 3
val MSTATUS_MPIE_BIT: i64   = 7
val MSTATUS_MPP_LO_BIT: i64 = 11
val MSTATUS_FS_LO_BIT: i64  = 13           # FS field low bit

# SD (State Dirty summary) — bit 63.  Read-only: reads 1 iff FS==Dirty(3)
# (or, on a full impl, VS/XS dirty).  Built at runtime to avoid sign-bit
# literal issues.
val MSTATUS_SD_MASK: i64    = 1 << 63

# FS state encodings (mstatus.FS, bits [14:13])
val FS_OFF: i64     = 0
val FS_INITIAL: i64 = 1
val FS_CLEAN: i64   = 2
val FS_DIRTY: i64   = 3

# MPP = M-mode (0b11) — we only support M-mode
val MPP_M_MODE: i64          = 0x00001800   # 3 << 11

# ============================================================================
# MIE / MIP Bit Masks
# ============================================================================

val MIP_MSIP_MASK: i64 = 0x00000008   # bit 3 — Machine Software Interrupt
val MIP_MTIP_MASK: i64 = 0x00000080   # bit 7 — Machine Timer Interrupt
val MIP_MEIP_MASK: i64 = 0x00000800   # bit 11 — Machine External Interrupt
val MIP_SEIP_MASK: i64 = 0x00000200   # bit 9 — Supervisor External Interrupt (PLIC ctx1)

# ============================================================================
# MISA for RV64IMAC: MXL=2 (bits [63:62]) + I(8) + M(12) + A(0) + C(2)
# Bit positions: I=bit8, M=bit12, A=bit0, C=bit2
# ============================================================================

# Build MISA at runtime to avoid sign-bit literal issues
# MXL=2 -> bits[63:62] = 0b10
fn misa_rv64imac() -> i64:
    """Compute MISA value for RV64IMAC.
    MXL=2 (64-bit) in bits[63:62], plus I+M+A+C extension bits."""
    val mxl: i64 = 2 << 62
    val ext_i: i64 = 1 << 8    # I extension
    val ext_m: i64 = 1 << 12   # M extension
    val ext_a: i64 = 1 << 0    # A extension
    val ext_c: i64 = 1 << 2    # C extension
    mxl | ext_i | ext_m | ext_a | ext_c

# ============================================================================
# CSR funct3 encodings (from SYSTEM instruction)
# ============================================================================

val FUNCT3_CSRRW: u32  = 0x1
val FUNCT3_CSRRS: u32  = 0x2
val FUNCT3_CSRRC: u32  = 0x3
val FUNCT3_CSRRWI: u32 = 0x5
val FUNCT3_CSRRSI: u32 = 0x6
val FUNCT3_CSRRCI: u32 = 0x7

# ============================================================================
# CSR File Struct (64-bit)
# ============================================================================

struct CsrFile64:
    """M-mode CSR register file.  All fields are i64."""
    mstatus: i64
    misa: i64
    mie: i64
    mtvec: i64
    mscratch: i64
    mepc: i64
    mcause: i64
    mtval: i64
    mip: i64
    medeleg: i64
    mideleg: i64
    mcycle: i64
    minstret: i64
    mhartid: i64

# ============================================================================
# CSR Read/Write Result
# ============================================================================

struct CsrRwResult64:
    """Result of a CSR read-modify-write operation."""
    csr: CsrFile64    # Updated CSR file
    old_value: i64     # Previous value (written to rd)

# ============================================================================
# Create — initial CSR state after reset
# ============================================================================

fn csr64_create(hartid: i64) -> CsrFile64:
    """Create initial CSR state for a given hart.
    misa indicates RV64IMAC, mstatus starts with interrupts disabled."""
    CsrFile64(
        mstatus: 0,
        misa: misa_rv64imac(),
        mie: 0,
        mtvec: 0,
        mscratch: 0,
        mepc: 0,
        mcause: 0,
        mtval: 0,
        mip: 0,
        medeleg: 0,
        mideleg: 0,
        mcycle: 0,
        minstret: 0,
        mhartid: hartid
    )

# ============================================================================
# CSR Read — read by 12-bit address
# ============================================================================

fn csr64_read(csr: CsrFile64, addr: u32) -> i64:
    """Read a CSR by its 12-bit address.  Unknown addresses return 0."""
    if addr == CSR_ADDR_MSTATUS:
        return csr.mstatus
    if addr == CSR_ADDR_MISA:
        return csr.misa
    if addr == CSR_ADDR_MIE:
        return csr.mie
    if addr == CSR_ADDR_MTVEC:
        return csr.mtvec
    if addr == CSR_ADDR_MSCRATCH:
        return csr.mscratch
    if addr == CSR_ADDR_MEPC:
        return csr.mepc
    if addr == CSR_ADDR_MCAUSE:
        return csr.mcause
    if addr == CSR_ADDR_MTVAL:
        return csr.mtval
    if addr == CSR_ADDR_MIP:
        return csr.mip
    if addr == CSR_ADDR_MEDELEG:
        return csr.medeleg
    if addr == CSR_ADDR_MIDELEG:
        return csr.mideleg
    if addr == CSR_ADDR_MCYCLE:
        return csr.mcycle
    if addr == CSR_ADDR_MINSTRET:
        return csr.minstret
    if addr == CSR_ADDR_MHARTID:
        return csr.mhartid
    # Unknown CSR — return 0
    0

# ============================================================================
# CSR Write — write by 12-bit address
# ============================================================================

fn csr64_write(csr: CsrFile64, addr: u32, value: i64) -> CsrFile64:
    """Write a value to a CSR by address.  Read-only CSRs (misa, mhartid)
    and unknown addresses are silently ignored."""
    var out = csr
    if addr == CSR_ADDR_MSTATUS:
        # FS (bits [14:13]) is software-writable so `csrw mstatus` can set the
        # FP unit status.  SD (bit 63) is a derived read-only summary; it is
        # recomputed here from FS so SD==1 iff FS==Dirty(3).
        val writable_mask = MSTATUS_MIE_MASK | MSTATUS_MPIE_MASK | MSTATUS_MPP_MASK | MSTATUS_FS_MASK
        val masked = value & writable_mask
        val fs_field = (masked >> MSTATUS_FS_LO_BIT) & 3
        if fs_field == 3:
            out.mstatus = masked | MSTATUS_SD_MASK
        else:
            out.mstatus = masked & (MSTATUS_SD_MASK ^ -1)
    else if addr == CSR_ADDR_MIE:
        out.mie = value
    else if addr == CSR_ADDR_MTVEC:
        out.mtvec = value
    else if addr == CSR_ADDR_MSCRATCH:
        out.mscratch = value
    else if addr == CSR_ADDR_MEPC:
        # IALIGN=16 (C implemented): only mepc[0] is forced 0; mepc[1] is
        # writable, so a trap on / mret to a 2-byte-aligned compressed insn
        # returns to the exact pc. (Was & ~3, which truncated compressed pcs.)
        out.mepc = value & 0xFFFFFFFFFFFFFFFE
    else if addr == CSR_ADDR_MCAUSE:
        out.mcause = value
    else if addr == CSR_ADDR_MTVAL:
        out.mtval = value
    else if addr == CSR_ADDR_MIP:
        # Only MSIP is software-writable in mip; hardware-driven levels
        # (MTIP, MEIP, SEIP) are preserved
        out.mip = (csr.mip & (MIP_MTIP_MASK | MIP_MEIP_MASK | MIP_SEIP_MASK)) | (value & MIP_MSIP_MASK)
    else if addr == CSR_ADDR_MEDELEG:
        out.medeleg = value
    else if addr == CSR_ADDR_MIDELEG:
        out.mideleg = value
    # misa, mhartid, mcycle, minstret — read-only or counter (updated by tick)
    out

# ============================================================================
# MSTATUS.FS (floating-point unit status) helpers
# ============================================================================
#
# FS is mstatus[14:13], 4 states: 0=Off, 1=Initial, 2=Clean, 3=Dirty.
# When FS==Dirty the SD summary bit (mstatus[63]) reads 1.  These helpers let
# the core / FP path query and update FS without open-coding the bit math.
#
# NOTE: S-mode sstatus (csr_s.spl) is a restricted VIEW of mstatus and also
# exposes FS[14:13] + SD.  Mirroring sstatus.FS <-> mstatus.FS can follow in a
# later lane; this change is scoped to the M-mode CsrFile64 only.
# ============================================================================

fn csr64_fs_state(csr: CsrFile64) -> i64:
    """Return the current mstatus.FS field (0=Off,1=Initial,2=Clean,3=Dirty)."""
    (csr.mstatus >> 13) & 3

fn csr64_set_fs(csr: CsrFile64, fs: i64) -> CsrFile64:
    """Return a new CsrFile64 with mstatus.FS[14:13] replaced by (fs & 3), and
    SD (bit 63) set iff the new FS==Dirty(3).  All other fields preserved."""
    val fs2 = fs & 3
    val cleared = csr.mstatus & (MSTATUS_FS_MASK ^ -1)
    val with_fs = cleared | (fs2 << 13)
    var new_mstatus = with_fs
    if fs2 == 3:
        new_mstatus = with_fs | MSTATUS_SD_MASK
    else:
        new_mstatus = with_fs & (MSTATUS_SD_MASK ^ -1)
    CsrFile64(
        mstatus: new_mstatus,
        misa: csr.misa,
        mie: csr.mie,
        mtvec: csr.mtvec,
        mscratch: csr.mscratch,
        mepc: csr.mepc,
        mcause: csr.mcause,
        mtval: csr.mtval,
        mip: csr.mip,
        medeleg: csr.medeleg,
        mideleg: csr.mideleg,
        mcycle: csr.mcycle,
        minstret: csr.minstret,
        mhartid: csr.mhartid
    )

fn csr64_mark_fp_dirty(csr: CsrFile64) -> CsrFile64:
    """Convenience: set mstatus.FS = Dirty(3) (also raises SD)."""
    csr64_set_fs(csr, 3)

# ============================================================================
# CSR Read-Modify-Write — CSRRW, CSRRS, CSRRC
# ============================================================================

fn csr64_rw(csr: CsrFile64, addr: u32, rs1_val: i64, funct3: u32) -> CsrRwResult64:
    """Perform a CSR read-modify-write operation.
    Returns the old value (for rd writeback) and the updated CsrFile64."""
    val old_value = csr64_read(csr, addr)
    var new_value = old_value

    val op = funct3 & 0x3
    if op == 1:
        # CSRRW / CSRRWI — replace entirely
        new_value = rs1_val
    else if op == 2:
        # CSRRS / CSRRSI — set bits
        if rs1_val != 0:
            new_value = old_value | rs1_val
    else if op == 3:
        # CSRRC / CSRRCI — clear bits
        if rs1_val != 0:
            new_value = old_value & (rs1_val ^ -1)

    val new_csr = csr64_write(csr, addr, new_value)
    CsrRwResult64(csr: new_csr, old_value: old_value)

# ============================================================================
# CSR Tick — increment cycle and instruction counters
# ============================================================================

fn csr64_tick(csr: CsrFile64) -> CsrFile64:
    """Increment mcycle and minstret counters (called once per clock cycle).
    64-bit counters — no overflow split needed."""
    var out = csr
    out.mcycle = csr.mcycle + 1
    out.minstret = csr.minstret + 1
    out

# ============================================================================
# Update MIP — set interrupt pending bits from external sources
# ============================================================================

fn csr64_update_mip(csr: CsrFile64, mtip: bool, msip: bool, meip: bool) -> CsrFile64:
    """Update the interrupt-pending register from external interrupt sources."""
    var new_mip: i64 = 0
    if msip:
        new_mip = new_mip | MIP_MSIP_MASK
    if mtip:
        new_mip = new_mip | MIP_MTIP_MASK
    if meip:
        new_mip = new_mip | MIP_MEIP_MASK
    var out = csr
    out.mip = new_mip
    out

fn csr64_update_mip_s(csr: CsrFile64, mtip: bool, msip: bool, meip: bool, seip: bool) -> CsrFile64:
    """Update the interrupt-pending register including the S-mode external
    interrupt level (mip.SEIP, bit 9 — driven from PLIC context 1)."""
    var out = csr64_update_mip(csr, mtip, msip, meip)
    if seip:
        out.mip = out.mip | MIP_SEIP_MASK
    out

# ============================================================================
# Extended CSR storage — PMP + menvcfg/mcounteren/scounteren
# ============================================================================
#
# Readable/writable STORAGE ONLY (no enforcement).  OpenSBI's early boot
# programs PMP (pmpcfg0/pmpaddr0..) and the counter-enable CSRs; without
# somewhere to land those writes the core would trap and stall.  These are
# kept in a separate struct (not CsrFile64) so the M-mode trap machinery in
# trap.spl — which full-literal-constructs CsrFile64 — is unaffected.
#
# Addresses:
#   pmpcfg0-3   0x3A0-0x3A3  (pmpcfg1/pmpcfg3 are RV64-reserved in real HW —
#                             stored here anyway, storage-only, no fault)
#   pmpaddr0-15 0x3B0-0x3BF
#   menvcfg     0x30A        mcounteren 0x306   scounteren 0x106
#
# NOTE: no address matching / access enforcement is performed.  A future lane
# wiring real PMP checks must add it in the fetch/load/store path.
# VHDL synth subset: i64/bool/struct only — individual fields, no arrays.
# ============================================================================

val CSR_ADDR_PMPCFG0: u32    = 0x3A0
val CSR_ADDR_PMPCFG2: u32    = 0x3A2
val CSR_ADDR_PMPADDR0: u32   = 0x3B0
val CSR_ADDR_PMPADDR15: u32  = 0x3BF
val CSR_ADDR_MENVCFG: u32    = 0x30A
val CSR_ADDR_MCOUNTEREN: u32 = 0x306
val CSR_ADDR_SCOUNTEREN: u32 = 0x106

struct CsrExt64:
    """PMP + counter-enable CSR storage (no enforcement)."""
    pmpcfg0: i64
    pmpcfg1: i64
    pmpcfg2: i64
    pmpcfg3: i64
    pmpaddr0: i64
    pmpaddr1: i64
    pmpaddr2: i64
    pmpaddr3: i64
    pmpaddr4: i64
    pmpaddr5: i64
    pmpaddr6: i64
    pmpaddr7: i64
    pmpaddr8: i64
    pmpaddr9: i64
    pmpaddr10: i64
    pmpaddr11: i64
    pmpaddr12: i64
    pmpaddr13: i64
    pmpaddr14: i64
    pmpaddr15: i64
    menvcfg: i64
    mcounteren: i64
    scounteren: i64

fn csr_ext64_create() -> CsrExt64:
    """All extended CSRs reset to 0."""
    CsrExt64(
        pmpcfg0: 0, pmpcfg1: 0, pmpcfg2: 0, pmpcfg3: 0,
        pmpaddr0: 0, pmpaddr1: 0, pmpaddr2: 0, pmpaddr3: 0,
        pmpaddr4: 0, pmpaddr5: 0, pmpaddr6: 0, pmpaddr7: 0,
        pmpaddr8: 0, pmpaddr9: 0, pmpaddr10: 0, pmpaddr11: 0,
        pmpaddr12: 0, pmpaddr13: 0, pmpaddr14: 0, pmpaddr15: 0,
        menvcfg: 0, mcounteren: 0, scounteren: 0
    )

fn csr_ext64_known(addr: u32) -> bool:
    """True for every extended-CSR address (PMP + counter-enable)."""
    if addr >= CSR_ADDR_PMPADDR0 and addr <= CSR_ADDR_PMPADDR15:
        return true
    if addr == CSR_ADDR_PMPCFG0 or addr == 0x3A1 or addr == CSR_ADDR_PMPCFG2 or addr == 0x3A3:
        return true
    addr == CSR_ADDR_MENVCFG or addr == CSR_ADDR_MCOUNTEREN or addr == CSR_ADDR_SCOUNTEREN

fn csr_ext64_read(ext: CsrExt64, addr: u32) -> i64:
    """Read an extended CSR by address.  Unknown -> 0."""
    if addr == CSR_ADDR_PMPCFG0: return ext.pmpcfg0
    if addr == 0x3A1: return ext.pmpcfg1
    if addr == CSR_ADDR_PMPCFG2: return ext.pmpcfg2
    if addr == 0x3A3: return ext.pmpcfg3
    if addr == 0x3B0: return ext.pmpaddr0
    if addr == 0x3B1: return ext.pmpaddr1
    if addr == 0x3B2: return ext.pmpaddr2
    if addr == 0x3B3: return ext.pmpaddr3
    if addr == 0x3B4: return ext.pmpaddr4
    if addr == 0x3B5: return ext.pmpaddr5
    if addr == 0x3B6: return ext.pmpaddr6
    if addr == 0x3B7: return ext.pmpaddr7
    if addr == 0x3B8: return ext.pmpaddr8
    if addr == 0x3B9: return ext.pmpaddr9
    if addr == 0x3BA: return ext.pmpaddr10
    if addr == 0x3BB: return ext.pmpaddr11
    if addr == 0x3BC: return ext.pmpaddr12
    if addr == 0x3BD: return ext.pmpaddr13
    if addr == 0x3BE: return ext.pmpaddr14
    if addr == 0x3BF: return ext.pmpaddr15
    if addr == CSR_ADDR_MENVCFG: return ext.menvcfg
    if addr == CSR_ADDR_MCOUNTEREN: return ext.mcounteren
    if addr == CSR_ADDR_SCOUNTEREN: return ext.scounteren
    0

fn csr_ext64_write(ext: CsrExt64, addr: u32, value: i64) -> CsrExt64:
    """Write an extended CSR by address.  Unknown -> unchanged."""
    var out = ext
    if addr == CSR_ADDR_PMPCFG0: out.pmpcfg0 = value
    else if addr == 0x3A1: out.pmpcfg1 = value
    else if addr == CSR_ADDR_PMPCFG2: out.pmpcfg2 = value
    else if addr == 0x3A3: out.pmpcfg3 = value
    else if addr == 0x3B0: out.pmpaddr0 = value
    else if addr == 0x3B1: out.pmpaddr1 = value
    else if addr == 0x3B2: out.pmpaddr2 = value
    else if addr == 0x3B3: out.pmpaddr3 = value
    else if addr == 0x3B4: out.pmpaddr4 = value
    else if addr == 0x3B5: out.pmpaddr5 = value
    else if addr == 0x3B6: out.pmpaddr6 = value
    else if addr == 0x3B7: out.pmpaddr7 = value
    else if addr == 0x3B8: out.pmpaddr8 = value
    else if addr == 0x3B9: out.pmpaddr9 = value
    else if addr == 0x3BA: out.pmpaddr10 = value
    else if addr == 0x3BB: out.pmpaddr11 = value
    else if addr == 0x3BC: out.pmpaddr12 = value
    else if addr == 0x3BD: out.pmpaddr13 = value
    else if addr == 0x3BE: out.pmpaddr14 = value
    else if addr == 0x3BF: out.pmpaddr15 = value
    else if addr == CSR_ADDR_MENVCFG: out.menvcfg = value
    else if addr == CSR_ADDR_MCOUNTEREN: out.mcounteren = value
    else if addr == CSR_ADDR_SCOUNTEREN: out.scounteren = value
    out

# ============================================================================
# Spec-facing alias
# ============================================================================

fn csr64_init() -> CsrFile64:
    csr64_create(0)

export CsrFile64, CsrRwResult64
export csr64_create, csr64_read, csr64_write, csr64_rw, csr64_tick, csr64_update_mip
export csr64_update_mip_s
export misa_rv64imac, csr64_init
export CsrExt64, csr_ext64_create, csr_ext64_read, csr_ext64_write, csr_ext64_known
export CSR_ADDR_PMPCFG0, CSR_ADDR_PMPCFG2, CSR_ADDR_PMPADDR0, CSR_ADDR_PMPADDR15
export CSR_ADDR_MENVCFG, CSR_ADDR_MCOUNTEREN, CSR_ADDR_SCOUNTEREN
export CSR_ADDR_MSTATUS, CSR_ADDR_MISA, CSR_ADDR_MIE, CSR_ADDR_MTVEC
export CSR_ADDR_MSCRATCH, CSR_ADDR_MEPC, CSR_ADDR_MCAUSE, CSR_ADDR_MTVAL
export CSR_ADDR_MIP, CSR_ADDR_MCYCLE, CSR_ADDR_MINSTRET, CSR_ADDR_MHARTID
export CSR_ADDR_MEDELEG, CSR_ADDR_MIDELEG
export MSTATUS_MIE_MASK, MSTATUS_MPIE_MASK, MSTATUS_MPP_MASK
export MSTATUS_MIE_BIT, MSTATUS_MPIE_BIT, MSTATUS_MPP_LO_BIT, MPP_M_MODE
export MSTATUS_FS_MASK, MSTATUS_FS_LO_BIT, MSTATUS_SD_MASK
export FS_OFF, FS_INITIAL, FS_CLEAN, FS_DIRTY
export csr64_fs_state, csr64_set_fs, csr64_mark_fp_dirty
export MIP_MSIP_MASK, MIP_MTIP_MASK, MIP_MEIP_MASK, MIP_SEIP_MASK
export FUNCT3_CSRRW, FUNCT3_CSRRS, FUNCT3_CSRRC
export FUNCT3_CSRRWI, FUNCT3_CSRRSI, FUNCT3_CSRRCI
