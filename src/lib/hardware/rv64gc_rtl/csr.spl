# ============================================================================
# RV64GC RTL CSR File — M-Mode Control/Status Registers (64-bit)
# ============================================================================
#
# Implements the machine-mode CSR register file for RV64GC.  All CSR values
# are i64 (64-bit).  No need for mcycleh/minstreth — 64-bit counters
# directly.
#
# Supported CSRs:
#   Trap Setup:    mstatus, misa, mie, mtvec
#   Trap Handling: mscratch, mepc, mcause, mtval, mip
#   Counters:      mcycle, minstret (64-bit directly)
#   Info:          mhartid (read-only)
#
# VHDL synthesizable subset: i64, bool, structs only.
# ============================================================================

# ============================================================================
# CSR Address Constants (u32 for RTL address matching)
# ============================================================================

val CSR_ADDR_MSTATUS: u32   = 0x300
val CSR_ADDR_MISA: u32      = 0x301
val CSR_ADDR_MIE: u32       = 0x304
val CSR_ADDR_MTVEC: u32     = 0x305
val CSR_ADDR_MSCRATCH: u32  = 0x340
val CSR_ADDR_MEPC: u32      = 0x341
val CSR_ADDR_MCAUSE: u32    = 0x342
val CSR_ADDR_MTVAL: u32     = 0x343
val CSR_ADDR_MIP: u32       = 0x344
val CSR_ADDR_MCYCLE: u32    = 0xB00
val CSR_ADDR_MINSTRET: u32  = 0xB02
val CSR_ADDR_MEDELEG: u32   = 0x302
val CSR_ADDR_MIDELEG: u32   = 0x303
val CSR_ADDR_MHARTID: u32   = 0xF14

# ============================================================================
# MSTATUS Bit Masks (i64 for 64-bit CSR)
# ============================================================================

val MSTATUS_MIE_MASK: i64   = 0x00000008   # bit 3
val MSTATUS_MPIE_MASK: i64  = 0x00000080   # bit 7
val MSTATUS_MPP_MASK: i64   = 0x00001800   # bits [12:11]
val MSTATUS_MPRV_MASK: i64  = 0x00020000   # bit 17
val MSTATUS_SUM_MASK: i64   = 0x00040000   # bit 18
val MSTATUS_MXR_MASK: i64   = 0x00080000   # bit 19

# SIE/SPIE/SPP/SUM/MXR are the sstatus view stored by the S-mode owner.
val MSTATUS_SSTATUS_MASK: i64 = 0x000C0122
val MSTATUS_WRITABLE_MASK: i64 = (MSTATUS_MIE_MASK | MSTATUS_MPIE_MASK |
    MSTATUS_MPP_MASK | MSTATUS_MPRV_MASK | MSTATUS_SSTATUS_MASK)
# SXL=2 and UXL=2: supervisor and user execution are fixed at 64 bits.
val MSTATUS_XLEN_FIXED: i64 = (2 << 34) | (2 << 32)

val MSTATUS_MIE_BIT: i64    = 3
val MSTATUS_MPIE_BIT: i64   = 7
val MSTATUS_MPP_LO_BIT: i64 = 11

# MPP encoding for M-mode (the core also implements S/U privilege transitions)
val MPP_M_MODE: i64          = 0x00001800   # 3 << 11

# ============================================================================
# MIE / MIP Bit Masks
# ============================================================================

val MIP_MSIP_MASK: i64 = 0x00000008   # bit 3 — Machine Software Interrupt
val MIP_MTIP_MASK: i64 = 0x00000080   # bit 7 — Machine Timer Interrupt
val MIP_MEIP_MASK: i64 = 0x00000800   # bit 11 — Machine External Interrupt
val MIP_SSIP_MASK: i64 = 0x00000002   # bit 1 — Supervisor Software Interrupt
val MIP_STIP_MASK: i64 = 0x00000020   # bit 5 — Supervisor Timer Interrupt
val MIP_SEIP_MASK: i64 = 0x00000200   # bit 9 — Supervisor External Interrupt
val MIP_MACHINE_MASK: i64 = MIP_MSIP_MASK | MIP_MTIP_MASK | MIP_MEIP_MASK
val MIP_SUPERVISOR_MASK: i64 = MIP_SSIP_MASK | MIP_STIP_MASK | MIP_SEIP_MASK
val MIP_SUPPORTED_MASK: i64 = MIP_MACHINE_MASK | MIP_SUPERVISOR_MASK
val MIP_SOFTWARE_WRITABLE_MASK: i64 = MIP_SSIP_MASK | MIP_STIP_MASK | MIP_SEIP_MASK

# ============================================================================
# MISA builders for the reusable core and explicit single-master atomic profile.
# Unsupported extensions must not be advertised.
# ============================================================================

# Build MISA at runtime to avoid sign-bit literal issues
# MXL=2 -> bits[63:62] = 0b10
fn misa_rv64imac() -> i64:
    """Compute MISA value for RV64IMAC.
    MXL=2 (64-bit) in bits[63:62], plus I+M+A+C extension bits."""
    val mxl: i64 = 2 << 62
    val ext_i: i64 = 1 << 8    # I extension
    val ext_m: i64 = 1 << 12   # M extension
    val ext_a: i64 = 1 << 0    # A extension
    val ext_c: i64 = 1 << 2    # C extension
    mxl | ext_i | ext_m | ext_a | ext_c

fn misa_rv64isu() -> i64:
    """Advertise only extensions connected to the production clock path."""
    val mxl: i64 = 2 << 62
    val ext_i: i64 = 1 << 8
    val ext_s: i64 = 1 << 18
    val ext_u: i64 = 1 << 20
    mxl | ext_i | ext_s | ext_u

fn misa_rv64imsu() -> i64:
    """RV64I+M with implemented supervisor and user privilege modes."""
    misa_rv64isu() | (1 << 12)

fn misa_rv64imasu() -> i64:
    """RV64I+M+A with implemented supervisor and user privilege modes."""
    misa_rv64imsu() | 1

fn misa_rv64imcsu() -> i64:
    """Reusable RV64I+M+C core with supervisor and user privilege modes."""
    misa_rv64imsu() | (1 << 2)

fn misa_rv64imacsu() -> i64:
    """Exclusive-bus RV64I+M+A+C profile with S/U privilege modes."""
    misa_rv64imcsu() | 1

# ============================================================================
# CSR funct3 encodings (from SYSTEM instruction)
# ============================================================================

val FUNCT3_CSRRW: u32  = 0x1
val FUNCT3_CSRRS: u32  = 0x2
val FUNCT3_CSRRC: u32  = 0x3
val FUNCT3_CSRRWI: u32 = 0x5
val FUNCT3_CSRRSI: u32 = 0x6
val FUNCT3_CSRRCI: u32 = 0x7

# ============================================================================
# CSR File Struct (64-bit)
# ============================================================================

struct CsrFile64:
    """M-mode CSR register file.  All fields are i64."""
    mstatus: i64
    misa: i64
    mie: i64
    mtvec: i64
    mscratch: i64
    mepc: i64
    mcause: i64
    mtval: i64
    mip: i64
    seip_software: bool
    seip_external: bool
    medeleg: i64
    mideleg: i64
    mcycle: i64
    minstret: i64
    mhartid: i64

# ============================================================================
# CSR Read/Write Result
# ============================================================================

struct CsrRwResult64:
    """Result of a CSR read-modify-write operation."""
    csr: CsrFile64    # Updated CSR file
    old_value: i64     # Previous value (written to rd)

# ============================================================================
# Create — initial CSR state after reset
# ============================================================================

fn csr64_create(hartid: i64) -> CsrFile64:
    """Create initial CSR state for a given hart.
    A remains clear until the embedding SoC guarantees an exclusive atomic bus."""
    CsrFile64(
        mstatus: MSTATUS_XLEN_FIXED,
        misa: misa_rv64imcsu(),
        mie: 0,
        mtvec: 0,
        mscratch: 0,
        mepc: 0,
        mcause: 0,
        mtval: 0,
        mip: 0,
        seip_software: false,
        seip_external: false,
        medeleg: 0,
        mideleg: 0,
        mcycle: 0,
        minstret: 0,
        mhartid: hartid
    )

# ============================================================================
# CSR Read — read by 12-bit address
# ============================================================================

@hardware
fn csr64_read(csr: CsrFile64, addr: u32) -> i64:
    """Read a CSR by its 12-bit address.  Unknown addresses return 0."""
    if addr == CSR_ADDR_MSTATUS:
        return csr.mstatus
    if addr == CSR_ADDR_MISA:
        return csr.misa
    if addr == CSR_ADDR_MIE:
        return csr.mie
    if addr == CSR_ADDR_MTVEC:
        return csr.mtvec
    if addr == CSR_ADDR_MSCRATCH:
        return csr.mscratch
    if addr == CSR_ADDR_MEPC:
        return csr.mepc
    if addr == CSR_ADDR_MCAUSE:
        return csr.mcause
    if addr == CSR_ADDR_MTVAL:
        return csr.mtval
    if addr == CSR_ADDR_MIP:
        return csr.mip
    if addr == CSR_ADDR_MEDELEG:
        return csr.medeleg
    if addr == CSR_ADDR_MIDELEG:
        return csr.mideleg
    if addr == CSR_ADDR_MCYCLE:
        return csr.mcycle
    if addr == CSR_ADDR_MINSTRET:
        return csr.minstret
    if addr == CSR_ADDR_MHARTID:
        return csr.mhartid
    # Unknown CSR — return 0
    0

# ============================================================================
# CSR Write — write by 12-bit address
# ============================================================================

@hardware
fn csr64_write(csr: CsrFile64, addr: u32, value: i64) -> CsrFile64:
    """Write a value to a CSR by address. Read-only and unknown addresses are ignored."""
    var out = csr
    if addr == CSR_ADDR_MSTATUS:
        var normalized = value & MSTATUS_WRITABLE_MASK
        val mpp = (normalized & MSTATUS_MPP_MASK) >> MSTATUS_MPP_LO_BIT
        if mpp == 2:
            # Privilege encoding 2 is reserved; this implementation chooses U.
            normalized = normalized & (MSTATUS_MPP_MASK ^ -1)
        out.mstatus = normalized | MSTATUS_XLEN_FIXED
    else if addr == CSR_ADDR_MIE:
        out.mie = value & MIP_SUPPORTED_MASK
    else if addr == CSR_ADDR_MTVEC:
        # The current trap owner implements Direct mode only.
        out.mtvec = value & -4
    else if addr == CSR_ADDR_MSCRATCH:
        out.mscratch = value
    else if addr == CSR_ADDR_MEPC:
        # C is implemented, so IALIGN=16.
        out.mepc = value & -2
    else if addr == CSR_ADDR_MCAUSE:
        out.mcause = value
    else if addr == CSR_ADDR_MTVAL:
        out.mtval = value
    else if addr == CSR_ADDR_MIP:
        # Machine firmware can inject supervisor pending bits.  SEIP is the
        # logical OR of its software latch and the external PLIC signal.
        out.seip_software = (value & MIP_SEIP_MASK) != 0
        out.mip = (csr.mip & MIP_MACHINE_MASK) |
            (value & (MIP_SSIP_MASK | MIP_STIP_MASK))
        if out.seip_software or csr.seip_external:
            out.mip = out.mip | MIP_SEIP_MASK
    else if addr == CSR_ADDR_MEDELEG:
        out.medeleg = value
    else if addr == CSR_ADDR_MIDELEG:
        # Only supervisor interrupt causes are delegable in this platform.
        out.mideleg = value & MIP_SUPERVISOR_MASK
    else if addr == CSR_ADDR_MCYCLE:
        out.mcycle = value
    else if addr == CSR_ADDR_MINSTRET:
        out.minstret = value
    # misa and mhartid are fixed by this implementation.
    out

# ============================================================================
# CSR Read-Modify-Write — CSRRW, CSRRS, CSRRC
# ============================================================================

fn csr64_rw(csr: CsrFile64, addr: u32, rs1_val: i64, funct3: u32) -> CsrRwResult64:
    """Perform a CSR read-modify-write operation.
    Returns the old value (for rd writeback) and the updated CsrFile64."""
    val old_value = csr64_read(csr, addr)
    var new_value = old_value

    val op = funct3 & 0x3
    if op == 1:
        # CSRRW / CSRRWI — replace entirely
        new_value = rs1_val
    else if op == 2:
        # CSRRS / CSRRSI — set bits
        if rs1_val != 0:
            new_value = old_value | rs1_val
    else if op == 3:
        # CSRRC / CSRRCI — clear bits
        if rs1_val != 0:
            new_value = old_value & (rs1_val ^ -1)

    val new_csr = csr64_write(csr, addr, new_value)
    CsrRwResult64(csr: new_csr, old_value: old_value)

# ============================================================================
# CSR Tick — increment cycle and instruction counters
# ============================================================================

fn csr64_tick(csr: CsrFile64) -> CsrFile64:
    """Increment mcycle and minstret counters (called once per clock cycle).
    64-bit counters — no overflow split needed."""
    var out = csr
    out.mcycle = csr.mcycle + 1
    out.minstret = csr.minstret + 1
    out

# ============================================================================
# Update MIP — set interrupt pending bits from external sources
# ============================================================================

fn csr64_update_mip_ext(csr: CsrFile64, mtip: bool, msip: bool, meip: bool,
                        seip: bool) -> CsrFile64:
    """Update platform-owned pending bits while preserving M-injected S bits."""
    var new_mip = csr.mip & (MIP_SSIP_MASK | MIP_STIP_MASK)
    if msip:
        new_mip = new_mip | MIP_MSIP_MASK
    if mtip:
        new_mip = new_mip | MIP_MTIP_MASK
    if meip:
        new_mip = new_mip | MIP_MEIP_MASK
    if seip or csr.seip_software:
        new_mip = new_mip | MIP_SEIP_MASK
    var out = csr
    out.seip_external = seip
    out.mip = new_mip
    out

fn csr64_update_mip(csr: CsrFile64, mtip: bool, msip: bool,
                    meip: bool) -> CsrFile64:
    """Compatibility update for machine-only platform sources."""
    csr64_update_mip_ext(csr, mtip, msip, meip, false)

# ============================================================================
# Spec-facing alias
# ============================================================================

fn csr64_init() -> CsrFile64:
    csr64_create(0)

export CsrFile64, CsrRwResult64
export csr64_create, csr64_read, csr64_write, csr64_rw, csr64_tick, csr64_update_mip
export csr64_update_mip_ext
export misa_rv64imac, misa_rv64isu, misa_rv64imsu, misa_rv64imasu
export misa_rv64imcsu, misa_rv64imacsu, csr64_init
export CSR_ADDR_MSTATUS, CSR_ADDR_MISA, CSR_ADDR_MIE, CSR_ADDR_MTVEC
export CSR_ADDR_MSCRATCH, CSR_ADDR_MEPC, CSR_ADDR_MCAUSE, CSR_ADDR_MTVAL
export CSR_ADDR_MIP, CSR_ADDR_MCYCLE, CSR_ADDR_MINSTRET, CSR_ADDR_MHARTID
export CSR_ADDR_MEDELEG, CSR_ADDR_MIDELEG
export MSTATUS_MIE_MASK, MSTATUS_MPIE_MASK, MSTATUS_MPP_MASK
export MSTATUS_MPRV_MASK, MSTATUS_SUM_MASK, MSTATUS_MXR_MASK
export MSTATUS_SSTATUS_MASK, MSTATUS_WRITABLE_MASK
export MSTATUS_XLEN_FIXED
export MSTATUS_MIE_BIT, MSTATUS_MPIE_BIT, MSTATUS_MPP_LO_BIT, MPP_M_MODE
export MIP_MSIP_MASK, MIP_MTIP_MASK, MIP_MEIP_MASK
export MIP_SSIP_MASK, MIP_STIP_MASK, MIP_SEIP_MASK
export MIP_MACHINE_MASK, MIP_SUPERVISOR_MASK, MIP_SUPPORTED_MASK
export MIP_SOFTWARE_WRITABLE_MASK
export FUNCT3_CSRRW, FUNCT3_CSRRS, FUNCT3_CSRRC
export FUNCT3_CSRRWI, FUNCT3_CSRRSI, FUNCT3_CSRRCI
