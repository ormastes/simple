# Legacy single-step RV64 RVFI adapter.  The protected clocked core emits its
# trace directly from architectural commit and synchronous-exception sites.

use std.hardware.rv64gc_rtl.core_types.{CoreState64, CoreCombResult64}
use std.hardware.rv64gc_rtl.rvfi_base.{RvfiTrace64, RvfiConfig64, RvfiCoreSnapshot64}
use std.hardware.rv64gc_rtl.rvfi_base.rvfi64_trace_from_snapshot

fn core64_rvfi_snapshot(state: CoreState64, imem_data: u32, dmem_rdata: i64,
                        comb: CoreCombResult64) -> RvfiCoreSnapshot64:
    var rd_addr: u32 = 0
    var rd_wdata: i64 = 0
    if comb.rd_write and comb.dec.rd != 0:
        rd_addr = comb.dec.rd
        rd_wdata = comb.rd_data

    RvfiCoreSnapshot64(
        halted: state.halt,
        suppress: state.semi_suppress,
        pc: state.pc,
        pc_next: comb.pc_next,
        insn: imem_data,
        rs1_addr: comb.dec.rs1,
        rs2_addr: comb.dec.rs2,
        rs1_rdata: comb.rs1_data,
        rs2_rdata: comb.rs2_data,
        rd_addr: rd_addr,
        rd_wdata: rd_wdata,
        dmem_addr: comb.dmem_addr,
        dmem_width: comb.dmem_width,
        dmem_re: comb.dmem_re,
        dmem_we: comb.dmem_we,
        dmem_rdata: dmem_rdata,
        dmem_wdata: comb.dmem_wdata
    )

fn core64_rvfi_trace(config: RvfiConfig64, order: i64, state: CoreState64,
                     imem_data: u32, dmem_rdata: i64,
                     comb: CoreCombResult64) -> RvfiTrace64:
    val snapshot = core64_rvfi_snapshot(state, imem_data, dmem_rdata, comb)
    rvfi64_trace_from_snapshot(config, order, snapshot)

export core64_rvfi_snapshot, core64_rvfi_trace
