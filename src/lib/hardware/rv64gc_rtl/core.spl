# ============================================================================
# RV64GC RTL Core — Clocked Protected Datapath (64-bit)
# ============================================================================
#
# Adapts the RV32I core pattern for the clocked RV64 path. Fetch, protected
# memory, mul/div, and atomic phases stall until their architectural result is
# ready to commit.
#
# Architecture:
#   - core64_combinational()  — all combinational datapath logic
#   - core64_update()         — clocked sequential logic (PC, semihosting, halt)
#   - core64_reset()          — initial state at reset
#
# Semihosting: detects the same 3-instruction magic sequence as RV32
#   slli zero,zero,0x1f  /  ebreak  /  srai zero,zero,0x7
# (32-bit instruction encoding is unchanged).
# ============================================================================

use std.hardware.rv64gc_rtl.pkg.{OP_LUI, OP_AUIPC, OP_JAL, OP_JALR}
use std.hardware.rv64gc_rtl.pkg.{OP_BRANCH, OP_LOAD, OP_STORE, OP_SYSTEM, OP_MISC_MEM}
use std.hardware.rv64gc_rtl.pkg.{OP_IMMED, OP_REG, OP_OP_IMM_32, OP_OP_32, OP_AMO}
use std.hardware.rv64gc_rtl.pkg.{BR_BEQ, BR_BNE, BR_BLT, BR_BGE, BR_BLTU, BR_BGEU}
use std.hardware.rv64gc_rtl.pkg.{SEMI_ENTRY, SEMI_BREAK, SEMI_EXIT, SYS_EXIT}
use std.hardware.rv64gc_rtl.decode.{DecodeResult64, decode_instruction_64}
use std.hardware.rv64gc_rtl.compressed.rvc64_decompress
use std.hardware.rv64gc_rtl.alu.{AluResult64, alu64_compute, i64_signed_lt}
use std.hardware.rv64gc_rtl.regfile.{RegFile64, RegReadResult64, regfile64_create, regfile64_read, regfile64_write}
use std.hardware.rv64gc_rtl.lsu.lsu64_load
use std.hardware.rv64gc_rtl.mul_div.{MulDivState, mul_div_start, mul_div_tick}
use std.hardware.rv64gc_rtl.pkg.{MULDIV_MUL, MULDIV_MULH, MULDIV_MULHSU, MULDIV_MULHU}
use std.hardware.rv64gc_rtl.pkg.{MULDIV_DIV, MULDIV_DIVU, MULDIV_REM, MULDIV_REMU}
use std.hardware.rv64gc_rtl.pkg.{MULDIV_MULW, MULDIV_DIVW, MULDIV_DIVUW, MULDIV_REMW, MULDIV_REMUW}
use std.hardware.rv64gc_rtl.atomics.{AtomicsState, atomics_create, atomics_lr, atomics_invalidate}
use std.hardware.rv64gc_rtl.atomics.{atomics_sign_extend_32, amo_compute, amo_compute_word}
use std.hardware.rv64gc_rtl.pkg.{AMO_LR, AMO_SC, AMO_SWAP, AMO_ADD, AMO_XOR}
use std.hardware.rv64gc_rtl.pkg.{AMO_AND, AMO_OR, AMO_MIN, AMO_MAX, AMO_MINU, AMO_MAXU}
use std.hardware.rv64gc_rtl.csr.{CsrFile64, csr64_create, csr64_read, csr64_write}
use std.hardware.rv64gc_rtl.csr.misa_rv64imacsu
use std.hardware.rv64gc_rtl.csr.{MSTATUS_MIE_MASK, MIP_MEIP_MASK, MIP_MSIP_MASK, MIP_MTIP_MASK}
use std.hardware.rv64gc_rtl.csr.{MSTATUS_MPRV_MASK, MSTATUS_MPP_MASK, MSTATUS_MPP_LO_BIT}
use std.hardware.rv64gc_rtl.csr_s.{CsrSMode64, csr_s64_create, csr_s64_read, csr_s64_write}
use std.hardware.rv64gc_rtl.csr_s.csr_s64_merge_mstatus
use std.hardware.rv64gc_rtl.trap.{trap64_mret, trap64_sret, trap64_sret_csr}
use std.hardware.rv64gc_rtl.trap.{InterruptCheckResult64, trap64_enter, trap64_state_init}
use std.hardware.rv64gc_rtl.trap.{CAUSE_ILLEGAL_INSN, CAUSE_BREAKPOINT, cause_mei, cause_msi, cause_mti}
use std.hardware.rv64gc_rtl.mmu_sv39.{MmuState64, mmu64_create, mmu64_flush, mmu64_set_satp}
use std.hardware.rv64gc_rtl.mmu_sv39.{ACCESS_FETCH_64, ACCESS_LOAD_64, ACCESS_STORE_64}
use std.hardware.rv64gc_rtl.memory_access.MemoryAccessState64
use std.hardware.rv64gc_rtl.memory_access.{memory64_start, memory64_start_atomic_read}
use std.hardware.rv64gc_rtl.memory_access.{memory64_start_lr, memory64_start_atomic_store}
use std.hardware.rv64gc_rtl.memory_access.{memory64_start_conditional_store, memory64_cycle}
use std.hardware.rv64gc_rtl.pmp.PmpEntries64
use std.hardware.rv64gc_rtl.pmp_csr.{pmp64_entries_reset, pmp64_csr_read, pmp64_csr_write}
use std.hardware.rv64gc_rtl.csr_s.{SSTATUS_SIE_MASK_64, SSTATUS_SUM_MASK_64, SSTATUS_MXR_MASK_64}

val CORE64_FETCH_LOW: u32 = 0
val CORE64_FETCH_HIGH: u32 = 1
val CORE64_DATA_ACCESS: u32 = 2
val CORE64_MULDIV: u32 = 3
val CORE64_ATOMIC_LOAD: u32 = 4
val CORE64_ATOMIC_STORE: u32 = 5

# ============================================================================
# Core sequential state (clocked registers)
# ============================================================================

struct CoreState64:
    """Sequential state updated on each clock edge."""
    pc: i64             # Program counter (64-bit)
    halt: bool          # CPU halted
    semi_phase: u32     # Semihosting sequence detector (0/1/2)
    semi_op: i64        # Latched semihosting operation (a0)
    semi_param: i64     # Latched semihosting parameter (a1)
    semi_suppress: bool # Suppress normal execution during semihost sequence
    semi_trigger: bool  # One-cycle pulse when semihosting completes
    mul_div: MulDivState  # M extension state
    atomics: AtomicsState # A extension state
    atomic_old: i64       # Architectural AMO read value held through its store
    atomic_bus_exclusive: bool  # Embedding guarantees no competing memory agent
    priv_mode: i64      # Current privilege mode: M=3, S=1, U=0
    csr_m: CsrFile64    # M-mode CSR file
    csr_s: CsrSMode64   # S-mode CSR file
    mmu: MmuState64      # Sv39 MMU state, including TLB
    pmp: PmpEntries64    # Machine-owned physical memory protection state
    rf: RegFile64         # Architectural integer register file
    memory: MemoryAccessState64  # One protected fetch/data transaction
    pipeline_phase: u32   # Fetch low parcel, fetch high parcel, or data
    fetch_low: u32        # Low 16-bit instruction parcel
    instruction: u32      # Current 32-bit instruction during data access
    instruction_bytes: u32  # Architectural length of current instruction

struct CoreCsrAccess64:
    """One legal CSR read/modify/write result for the clocked core."""
    valid: bool
    old_value: i64
    csr_m: CsrFile64
    csr_s: CsrSMode64
    mmu: MmuState64
    pmp: PmpEntries64

struct Core64CycleResult:
    """One clock result and the canonical physical bus request."""
    state: CoreState64
    bus_valid: bool
    bus_addr: i64
    bus_size: u32
    bus_write: bool
    bus_wdata: i64
    bus_is_pte: bool
    bus_atomic: bool

# ============================================================================
# Combinational result bundle
# ============================================================================

struct CoreCombResult64:
    """All combinational outputs from one cycle of the datapath."""
    # Decoder outputs
    dec: DecodeResult64

    # Register file read results
    rs1_data: i64
    rs2_data: i64
    a0_val: i64
    a1_val: i64

    # ALU results
    alu_result: i64
    alu_zero: bool

    # Branch evaluation
    branch_taken: bool
    branch_target: i64

    # Next PC (combinational)
    pc_next: i64
    pc_plus4: i64

    # Write-back data for rd
    rd_data: i64
    rd_write: bool

    # Data memory interface
    dmem_addr: i64
    dmem_wdata: i64
    dmem_we: bool
    dmem_re: bool
    dmem_width: u32

    # Instruction memory address
    imem_addr: i64

# ============================================================================
# Signed comparison helpers for branch evaluation
# ============================================================================

fn i64_signed_ge(a: i64, b: i64) -> bool:
    """Signed greater-than-or-equal for i64."""
    not i64_signed_lt(a, b)

# ============================================================================
# Unsigned comparison helpers for branch evaluation
# ============================================================================

fn i64_unsigned_lt(a: i64, b: i64) -> bool:
    """Unsigned less-than for i64 (two's complement)."""
    val flip: i64 = 0x8000000000000000
    val fa = a ^ flip
    val fb = b ^ flip
    fa < fb

fn i64_unsigned_ge(a: i64, b: i64) -> bool:
    """Unsigned greater-than-or-equal for i64."""
    not i64_unsigned_lt(a, b)

# ============================================================================
# Branch evaluation
# ============================================================================

fn eval_branch_64(funct3: u32, rs1_data: i64, rs2_data: i64) -> bool:
    """Evaluate branch condition. Returns true if branch is taken."""
    if funct3 == BR_BEQ:
        return rs1_data == rs2_data
    if funct3 == BR_BNE:
        return rs1_data != rs2_data
    if funct3 == BR_BLT:
        return i64_signed_lt(rs1_data, rs2_data)
    if funct3 == BR_BGE:
        return i64_signed_ge(rs1_data, rs2_data)
    if funct3 == BR_BLTU:
        return i64_unsigned_lt(rs1_data, rs2_data)
    if funct3 == BR_BGEU:
        return i64_unsigned_ge(rs1_data, rs2_data)
    false

@hardware
fn core64_amo_funct5(instruction: u32) -> u32:
    (instruction >> 27) & 0x1F

@hardware
fn core64_amo_legal(instruction: u32, dec: DecodeResult64) -> bool:
    if dec.funct3 != 2 and dec.funct3 != 3:
        return false
    val funct5 = core64_amo_funct5(instruction)
    if funct5 == AMO_LR:
        return dec.rs2 == 0
    (funct5 == AMO_SC or funct5 == AMO_SWAP or funct5 == AMO_ADD or
     funct5 == AMO_XOR or funct5 == AMO_AND or funct5 == AMO_OR or
     funct5 == AMO_MIN or funct5 == AMO_MAX or funct5 == AMO_MINU or
     funct5 == AMO_MAXU)

@hardware
fn core64_instruction_legal(instruction: u32, dec: DecodeResult64) -> bool:
    """Fail closed for every encoding the current integer datapath accepts."""
    val op = dec.opcode
    val f3 = dec.funct3
    val f7 = dec.funct7

    if op == OP_LUI or op == OP_AUIPC or op == OP_JAL:
        return true
    if op == OP_JALR:
        return f3 == 0
    if op == OP_BRANCH:
        return f3 == 0 or f3 == 1 or f3 == 4 or f3 == 5 or f3 == 6 or f3 == 7
    if op == OP_LOAD:
        return f3 <= 6
    if op == OP_STORE:
        return f3 <= 3

    if op == OP_IMMED:
        if f3 == 1:
            return ((instruction >> 26) & 0x3F) == 0
        if f3 == 5:
            val funct6 = (instruction >> 26) & 0x3F
            return funct6 == 0 or funct6 == 0x10
        return f3 == 0 or f3 == 2 or f3 == 3 or f3 == 4 or f3 == 6 or f3 == 7

    if op == OP_REG:
        if f7 == 0 or f7 == 1:
            return true
        return f7 == 0x20 and (f3 == 0 or f3 == 5)

    if op == OP_OP_IMM_32:
        if f3 == 0:
            return true
        if f3 == 1:
            return f7 == 0
        if f3 == 5:
            return f7 == 0 or f7 == 0x20
        return false

    if op == OP_OP_32:
        if f7 == 1:
            return f3 == 0 or f3 == 4 or f3 == 5 or f3 == 6 or f3 == 7
        if f7 == 0:
            return f3 == 0 or f3 == 1 or f3 == 5
        return f7 == 0x20 and (f3 == 0 or f3 == 5)

    if op == OP_MISC_MEM:
        if f3 == 0:
            return dec.rd == 0 and dec.rs1 == 0
        return instruction == 0x0000100F

    if op == OP_SYSTEM:
        if dec.is_sfence_vma:
            return dec.rd == 0
        if dec.is_csr or dec.is_mret or dec.is_sret:
            return true
        return instruction == 0x00000073 or instruction == 0x00100073

    if op == OP_AMO:
        return core64_amo_legal(instruction, dec)
    false

@hardware
fn core64_privileged_instruction_legal(state: CoreState64,
                                       dec: DecodeResult64) -> bool:
    if dec.is_mret:
        return state.priv_mode == 3
    if dec.is_sret or dec.is_sfence_vma:
        return state.priv_mode == 1 or state.priv_mode == 3
    true

# ============================================================================
# Privileged CSR routing
# ============================================================================

@hardware
fn core64_machine_csr_known(addr: u32) -> bool:
    (addr == 0x300 or addr == 0x301 or addr == 0x302 or addr == 0x303 or
     addr == 0x304 or addr == 0x305 or addr == 0x340 or addr == 0x341 or
     addr == 0x342 or addr == 0x343 or addr == 0x344 or addr == 0xB00 or
     addr == 0xB02 or addr == 0xF14)

@hardware
fn core64_supervisor_csr_known(addr: u32) -> bool:
    (addr == 0x100 or addr == 0x104 or addr == 0x105 or addr == 0x140 or
     addr == 0x141 or addr == 0x142 or addr == 0x143 or addr == 0x144 or
     addr == 0x180)

fn core64_csr_source(funct3: u32, rs1: u32, rs1_data: i64) -> i64:
    if (funct3 & 0x4) != 0:
        return rs1 as i64
    rs1_data

@hardware
fn core64_csr_write_requested(funct3: u32, source: i64) -> bool:
    val op = funct3 & 0x3
    op == 1 or ((op == 2 or op == 3) and source != 0)

@hardware
fn core64_csr_next_value(old_value: i64, source: i64, funct3: u32) -> i64:
    val op = funct3 & 0x3
    if op == 1:
        return source
    if op == 2:
        return old_value | source
    if op == 3:
        return old_value & (source ^ -1)
    old_value

@hardware
fn core64_invalid_csr_access(state: CoreState64) -> CoreCsrAccess64:
    CoreCsrAccess64(valid: false, old_value: 0, csr_m: state.csr_m,
        csr_s: state.csr_s, mmu: state.mmu, pmp: state.pmp)

@hardware
fn core64_csr_access(state: CoreState64, addr: u32, source: i64, funct3: u32) -> CoreCsrAccess64:
    """Route one Zicsr operation to M, S, or PMP state and fail closed."""
    val op = funct3 & 0x3
    if op == 0:
        return core64_invalid_csr_access(state)

    val required_priv = ((addr >> 8) & 0x3) as i64
    val write_requested = core64_csr_write_requested(funct3, source)
    val read_only = ((addr >> 10) & 0x3) == 0x3
    if state.priv_mode < required_priv or (write_requested and read_only):
        return core64_invalid_csr_access(state)

    val pmp_read = pmp64_csr_read(state.pmp, addr)
    if pmp_read.handled:
        var new_pmp = state.pmp
        if write_requested:
            val next_value = core64_csr_next_value(pmp_read.value, source, funct3)
            val pmp_write = pmp64_csr_write(state.pmp, addr, next_value)
            new_pmp = pmp_write.entries
        return CoreCsrAccess64(valid: true, old_value: pmp_read.value,
            csr_m: state.csr_m, csr_s: state.csr_s, mmu: state.mmu, pmp: new_pmp)

    if core64_machine_csr_known(addr):
        var old_value = csr64_read(state.csr_m, addr)
        var new_csr_m = state.csr_m
        var new_csr_s = state.csr_s
        if addr == 0x300:
            old_value = csr_s64_merge_mstatus(old_value, state.csr_s.sstatus)
        if write_requested:
            new_csr_m = csr64_write(state.csr_m, addr,
                core64_csr_next_value(old_value, source, funct3))
            if addr == 0x300:
                new_csr_s = csr_s64_write(state.csr_s, 0x100,
                    new_csr_m.mstatus)
                new_csr_m.mstatus = csr_s64_merge_mstatus(new_csr_m.mstatus,
                    new_csr_s.sstatus)
        return CoreCsrAccess64(valid: true, old_value: old_value,
            csr_m: new_csr_m, csr_s: new_csr_s, mmu: state.mmu, pmp: state.pmp)

    if core64_supervisor_csr_known(addr):
        val old_value = csr_s64_read(state.csr_s, addr)
        var new_csr_m = state.csr_m
        var new_csr_s = state.csr_s
        var new_mmu = state.mmu
        if write_requested:
            new_csr_s = csr_s64_write(state.csr_s, addr, core64_csr_next_value(old_value, source, funct3))
            if addr == 0x100:
                new_csr_m.mstatus = csr_s64_merge_mstatus(
                    new_csr_m.mstatus, new_csr_s.sstatus)
            if addr == 0x180 and new_csr_s.satp != state.csr_s.satp:
                new_mmu = mmu64_set_satp(mmu64_flush(state.mmu), new_csr_s.satp)
        return CoreCsrAccess64(valid: true, old_value: old_value,
            csr_m: new_csr_m, csr_s: new_csr_s, mmu: new_mmu, pmp: state.pmp)

    core64_invalid_csr_access(state)

# ============================================================================
# Combinational datapath
# ============================================================================

fn core64_combinational(state: CoreState64, imem_data: u32, dmem_rdata: i64, rf: RegFile64) -> CoreCombResult64:
    """Compute all combinational signals for one cycle."""

    val pc = state.pc
    val pc_plus4 = pc + 4

    val imem_addr = pc

    # Decode
    val dec = decode_instruction_64(imem_data)

    # Register file read
    val rr = regfile64_read(rf, dec.rs1, dec.rs2)
    val rs1_data = rr.rs1_data
    val rs2_data = rr.rs2_data

    # ALU input muxes
    var alu_a: i64 = rs1_data
    if dec.opcode == OP_AUIPC or dec.opcode == OP_JAL:
        alu_a = pc

    var alu_b: i64 = rs2_data
    if dec.alu_src:
        alu_b = dec.imm

    # ALU
    val alu_res = alu64_compute(alu_a, alu_b, dec.alu_op)

    # Branch evaluation
    var branch_taken: bool = false
    if dec.branch:
        branch_taken = eval_branch_64(dec.funct3, rs1_data, rs2_data)

    val branch_target = pc + dec.imm

    # Next PC mux
    var pc_next: i64 = pc_plus4
    if dec.opcode == OP_JALR:
        pc_next = alu_res.result & -2
    else if branch_taken or dec.jump:
        pc_next = branch_target

    # Write-back data mux
    var rd_data: i64 = alu_res.result
    var rd_write = dec.reg_write
    if dec.mem_to_reg:
        rd_data = lsu64_load(dmem_rdata, dec.funct3)
    else if dec.jump:
        rd_data = pc_plus4
    else if dec.is_csr:
        val source = core64_csr_source(dec.funct3, dec.rs1, rs1_data)
        val csr_access = core64_csr_access(state, dec.csr_addr, source, dec.funct3)
        if csr_access.valid:
            rd_data = csr_access.old_value
        else:
            rd_write = false

    # Data memory interface
    val dmem_addr = alu_res.result
    val dmem_wdata = rs2_data
    val dmem_we = dec.mem_write and (state.semi_suppress == false)
    val dmem_re = dec.mem_read
    val dmem_width = dec.funct3 & 0x3

    CoreCombResult64(
        dec: dec,
        rs1_data: rs1_data,
        rs2_data: rs2_data,
        a0_val: rr.a0_val,
        a1_val: rr.a1_val,
        alu_result: alu_res.result,
        alu_zero: alu_res.zero,
        branch_taken: branch_taken,
        branch_target: branch_target,
        pc_next: pc_next,
        pc_plus4: pc_plus4,
        rd_data: rd_data,
        rd_write: rd_write,
        dmem_addr: dmem_addr,
        dmem_wdata: dmem_wdata,
        dmem_we: dmem_we,
        dmem_re: dmem_re,
        dmem_width: dmem_width,
        imem_addr: imem_addr
    )

@hardware
fn core64_combinational_length(state: CoreState64, instruction: u32,
                               dmem_rdata: i64, rf: RegFile64,
                               instruction_bytes: u32) -> CoreCombResult64:
    """Apply the architectural 2/4-byte length to PC and link results."""
    var comb = core64_combinational(state, instruction, dmem_rdata, rf)
    val sequential_pc = state.pc + instruction_bytes as i64
    comb.pc_plus4 = sequential_pc
    if comb.dec.jump:
        comb.rd_data = sequential_pc
    if (comb.dec.opcode != OP_JALR and not comb.branch_taken and
        not comb.dec.jump):
        comb.pc_next = sequential_pc
    comb

# ============================================================================
# Sequential update (clocked logic)
# ============================================================================

fn core64_update(state: CoreState64, imem_data: u32, comb: CoreCombResult64, a0_val: i64, a1_val: i64) -> CoreState64:
    """Update sequential state on rising clock edge.
    Handles PC advancement, semihosting detection, and halt."""

    var new_pc = state.pc
    var new_halt = state.halt
    var new_semi_phase = state.semi_phase
    var new_semi_op = state.semi_op
    var new_semi_param = state.semi_param
    var new_semi_suppress = state.semi_suppress
    var new_semi_trigger: bool = false
    var new_mul_div = state.mul_div
    var new_atomics = state.atomics
    var new_priv_mode = state.priv_mode
    var new_csr_m = state.csr_m
    var new_csr_s = state.csr_s
    var new_mmu = state.mmu
    var new_pmp = state.pmp
    var new_rf = state.rf

    if state.halt == false:
        if (state.instruction_bytes == 4 and imem_data == SEMI_ENTRY and
            state.semi_phase == 0):
            new_semi_phase = 1
            new_pc = comb.pc_plus4

        else if (state.instruction_bytes == 4 and imem_data == SEMI_BREAK and
                 state.semi_phase == 1):
            new_semi_phase = 2
            new_semi_op = a0_val
            new_semi_param = a1_val
            new_semi_suppress = true
            new_pc = comb.pc_plus4
            new_pc = comb.pc_plus4

        else if (state.instruction_bytes == 4 and imem_data == SEMI_EXIT and
                 state.semi_phase == 2):
            new_semi_phase = 0
            new_semi_suppress = false
            new_semi_trigger = true
            val exit_code: i64 = SYS_EXIT as i64
            if new_semi_op == exit_code:
                new_halt = true
            else:
                new_pc = comb.pc_plus4

        else if comb.dec.is_mret:
            val result = trap64_mret(state.csr_m)
            new_pc = result.return_pc
            new_priv_mode = result.target_mode
            new_csr_m = result.csr
            new_semi_phase = 0
            new_semi_suppress = false

        else if comb.dec.is_sret:
            val result = trap64_sret(state.csr_s)
            new_pc = result.return_pc
            new_priv_mode = result.target_mode
            new_csr_s = trap64_sret_csr(state.csr_s)
            if new_priv_mode < 3:
                new_csr_m.mstatus = new_csr_m.mstatus &
                    (MSTATUS_MPRV_MASK ^ -1)
            new_semi_phase = 0
            new_semi_suppress = false

        else if comb.dec.is_sfence_vma:
            new_pc = comb.pc_plus4
            new_mmu = mmu64_flush(state.mmu)
            new_semi_phase = 0
            new_semi_suppress = false

        else if comb.dec.is_csr:
            val source = core64_csr_source(comb.dec.funct3, comb.dec.rs1, comb.rs1_data)
            val csr_access = core64_csr_access(state, comb.dec.csr_addr, source, comb.dec.funct3)
            if csr_access.valid:
                new_pc = comb.pc_plus4
                new_csr_m = csr_access.csr_m
                new_csr_s = csr_access.csr_s
                new_mmu = csr_access.mmu
                new_pmp = csr_access.pmp
                new_semi_phase = 0
                new_semi_suppress = false
            else:
                val trap = trap64_enter(trap64_state_init(), CAUSE_ILLEGAL_INSN,
                    imem_data as i64, state.pc, state.priv_mode, state.csr_m, state.csr_s)
                new_pc = trap.trap_pc
                new_priv_mode = trap.target_mode
                new_csr_m = trap.csr
                new_csr_s = trap.csr_s
                new_semi_phase = 0
                new_semi_suppress = false

        else if comb.dec.opcode == OP_SYSTEM:
            var cause = CAUSE_ILLEGAL_INSN
            var tval = imem_data as i64
            if imem_data == 0x00000073:
                cause = if state.priv_mode == 0: 8 else if state.priv_mode == 1: 9 else: 11
                tval = 0
            else if imem_data == 0x00100073:
                cause = CAUSE_BREAKPOINT
                tval = 0
            val trap = trap64_enter(trap64_state_init(), cause, tval,
                state.pc, state.priv_mode, state.csr_m, state.csr_s)
            new_pc = trap.trap_pc
            new_priv_mode = trap.target_mode
            new_csr_m = trap.csr
            new_csr_s = trap.csr_s
            new_semi_phase = 0
            new_semi_suppress = false

        else:
            new_semi_phase = 0
            new_semi_suppress = false
            new_pc = comb.pc_next

        new_rf = regfile64_write(state.rf, comb.dec.rd, comb.rd_data, comb.rd_write)

    new_csr_m.mstatus = csr_s64_merge_mstatus(new_csr_m.mstatus,
        new_csr_s.sstatus)

    CoreState64(
        pc: new_pc,
        halt: new_halt,
        semi_phase: new_semi_phase,
        semi_op: new_semi_op,
        semi_param: new_semi_param,
        semi_suppress: new_semi_suppress,
        semi_trigger: new_semi_trigger,
        mul_div: new_mul_div,
        atomics: new_atomics,
        atomic_old: state.atomic_old,
        atomic_bus_exclusive: state.atomic_bus_exclusive,
        priv_mode: new_priv_mode,
        csr_m: new_csr_m,
        csr_s: new_csr_s,
        mmu: new_mmu,
        pmp: new_pmp,
        rf: new_rf,
        memory: state.memory,
        pipeline_phase: state.pipeline_phase,
        fetch_low: state.fetch_low,
        instruction: state.instruction,
        instruction_bytes: state.instruction_bytes
    )

# ============================================================================
# Semihosting trigger detection
# ============================================================================

fn core64_semi_triggered(state: CoreState64, imem_data: u32) -> bool:
    """Return true if this cycle completes a semihosting sequence."""
    state.instruction_bytes == 4 and imem_data == SEMI_EXIT and state.semi_phase == 2

# ============================================================================
# Reset state
# ============================================================================

fn core64_reset(reset_addr: i64) -> CoreState64:
    """Create initial core state after reset."""
    val mmu = mmu64_create()
    val pmp = pmp64_entries_reset()
    CoreState64(
        pc: reset_addr,
        halt: false,
        semi_phase: 0,
        semi_op: 0,
        semi_param: 0,
        semi_suppress: false,
        semi_trigger: false,
        mul_div: MulDivState(busy: false, op: 0, a: 0, b: 0, result: 0, cycles_left: 0),
        atomics: atomics_create(),
        atomic_old: 0,
        atomic_bus_exclusive: false,
        priv_mode: 3,
        csr_m: csr64_create(0),
        csr_s: csr_s64_create(),
        mmu: mmu,
        pmp: pmp,
        rf: regfile64_create(),
        memory: memory64_start(mmu, pmp, reset_addr, ACCESS_FETCH_64, 2, 3, false, false, 0),
        pipeline_phase: CORE64_FETCH_LOW,
        fetch_low: 0,
        instruction: 0,
        instruction_bytes: 4
    )

# ============================================================================
# Full initialization with privilege and CSR state
# ============================================================================

fn core64_init(reset_vec: i64) -> CoreState64:
    """Create full initial core state with privilege mode and CSR state.
    Starts in M-mode (priv_mode=3) with all CSRs zeroed."""
    val mmu = mmu64_create()
    val pmp = pmp64_entries_reset()
    CoreState64(
        pc: reset_vec,
        halt: false,
        semi_phase: 0,
        semi_op: 0,
        semi_param: 0,
        semi_suppress: false,
        semi_trigger: false,
        mul_div: MulDivState(busy: false, op: 0, a: 0, b: 0, result: 0, cycles_left: 0),
        atomics: atomics_create(),
        atomic_old: 0,
        atomic_bus_exclusive: false,
        priv_mode: 3,
        csr_m: csr64_create(0),
        csr_s: csr_s64_create(),
        mmu: mmu,
        pmp: pmp,
        rf: regfile64_create(),
        memory: memory64_start(mmu, pmp, reset_vec, ACCESS_FETCH_64, 2, 3, false, false, 0),
        pipeline_phase: CORE64_FETCH_LOW,
        fetch_low: 0,
        instruction: 0,
        instruction_bytes: 4
    )

# ============================================================================
# Clocked protected-memory core path
# ============================================================================

fn core64_init_single_master(reset_vec: i64) -> CoreState64:
    """Enable A only when the embedding owns the memory bus exclusively."""
    var out = core64_init(reset_vec)
    out.atomic_bus_exclusive = true
    out.csr_m.misa = misa_rv64imacsu()
    out

@hardware
fn core64_effective_data_privilege(state: CoreState64) -> u32:
    """Apply MPRV/MPP to loads, stores, and atomics, never instruction fetch."""
    if (state.priv_mode == 3 and
        (state.csr_m.mstatus & MSTATUS_MPRV_MASK) != 0):
        val mpp = (state.csr_m.mstatus & MSTATUS_MPP_MASK) >>
            MSTATUS_MPP_LO_BIT
        if mpp == 0 or mpp == 1 or mpp == 3:
            return mpp as u32
        return 0
    state.priv_mode as u32

@hardware
fn core64_sum_enabled(state: CoreState64) -> bool:
    (state.csr_s.sstatus & SSTATUS_SUM_MASK_64) != 0

@hardware
fn core64_mxr_enabled(state: CoreState64) -> bool:
    (state.csr_s.sstatus & SSTATUS_MXR_MASK_64) != 0

@hardware
fn core64_data_size(funct3: u32) -> u32:
    val width = funct3 & 0x3
    if width == 0:
        return 1
    if width == 1:
        return 2
    if width == 2:
        return 4
    8

@hardware
fn core64_atomic_size(dec: DecodeResult64) -> u32:
    if dec.funct3 == 2:
        return 4
    8

@hardware
fn core64_atomic_read_value(dec: DecodeResult64, value: i64) -> i64:
    if dec.funct3 == 2:
        return atomics_sign_extend_32(value)
    value

@hardware
fn core64_muldiv_op(dec: DecodeResult64) -> i64:
    if dec.opcode == OP_OP_32:
        if dec.funct3 == 0: return MULDIV_MULW
        if dec.funct3 == 4: return MULDIV_DIVW
        if dec.funct3 == 5: return MULDIV_DIVUW
        if dec.funct3 == 6: return MULDIV_REMW
        return MULDIV_REMUW
    if dec.funct3 == 0: return MULDIV_MUL
    if dec.funct3 == 1: return MULDIV_MULH
    if dec.funct3 == 2: return MULDIV_MULHSU
    if dec.funct3 == 3: return MULDIV_MULHU
    if dec.funct3 == 4: return MULDIV_DIV
    if dec.funct3 == 5: return MULDIV_DIVU
    if dec.funct3 == 6: return MULDIV_REM
    MULDIV_REMU

@hardware
fn core64_restart_fetch(state: CoreState64) -> CoreState64:
    var out = state
    out.pipeline_phase = CORE64_FETCH_LOW
    out.fetch_low = 0
    out.memory = memory64_start(out.mmu, out.pmp, out.pc, ACCESS_FETCH_64, 2,
        out.priv_mode as u32, core64_sum_enabled(out), core64_mxr_enabled(out), 0)
    out

@hardware
fn core64_raise_exception(state: CoreState64, cause: i64, tval: i64) -> CoreState64:
    val trap = trap64_enter(trap64_state_init(), cause, tval, state.pc,
        state.priv_mode, state.csr_m, state.csr_s)
    var out = state
    out.pc = trap.trap_pc
    out.priv_mode = trap.target_mode
    out.csr_m = trap.csr
    out.csr_s = trap.csr_s
    out.csr_m.mstatus = csr_s64_merge_mstatus(out.csr_m.mstatus,
        out.csr_s.sstatus)
    out.atomics = atomics_create()
    out.atomic_old = 0
    out.semi_phase = 0
    out.semi_suppress = false
    core64_restart_fetch(out)

@hardware
fn core64_interrupt_enabled(state: CoreState64, bit: i64) -> bool:
    if state.priv_mode != 0 and state.priv_mode != 1 and state.priv_mode != 3:
        return false
    val delegated = (state.csr_m.mideleg & bit) != 0
    if delegated:
        if state.priv_mode == 3 or (state.csr_s.sie & bit) == 0:
            return false
        return state.priv_mode == 0 or (state.priv_mode == 1 and
            (state.csr_s.sstatus & SSTATUS_SIE_MASK_64) != 0)

    if (state.csr_m.mie & bit) == 0:
        return false
    state.priv_mode < 3 or (state.priv_mode == 3 and
        (state.csr_m.mstatus & MSTATUS_MIE_MASK) != 0)

@hardware
fn core64_pending_interrupt(state: CoreState64) -> InterruptCheckResult64:
    val pending = state.csr_m.mip
    if (pending & MIP_MEIP_MASK) != 0 and core64_interrupt_enabled(state, MIP_MEIP_MASK):
        return InterruptCheckResult64(pending: true, cause: cause_mei())
    if (pending & MIP_MSIP_MASK) != 0 and core64_interrupt_enabled(state, MIP_MSIP_MASK):
        return InterruptCheckResult64(pending: true, cause: cause_msi())
    if (pending & MIP_MTIP_MASK) != 0 and core64_interrupt_enabled(state, MIP_MTIP_MASK):
        return InterruptCheckResult64(pending: true, cause: cause_mti())
    InterruptCheckResult64(pending: false, cause: 0)

@hardware
fn core64_finish_instruction(state: CoreState64) -> CoreState64:
    if state.halt:
        return state
    val interrupt = core64_pending_interrupt(state)
    if interrupt.pending:
        return core64_raise_exception(state, interrupt.cause, 0)
    core64_restart_fetch(state)

@hardware
fn core64_begin_instruction(state: CoreState64, instruction: u32,
                            instruction_bytes: u32,
                            trap_value: i64) -> CoreState64:
    """Validate and begin one expanded 16/32-bit architectural instruction."""
    var out = state
    out.instruction = instruction
    out.instruction_bytes = instruction_bytes
    val comb = core64_combinational_length(out, instruction, 0, out.rf,
        instruction_bytes)
    val data_privilege = core64_effective_data_privilege(out)
    val legal = (core64_instruction_legal(instruction, comb.dec) and
        core64_privileged_instruction_legal(out, comb.dec) and
        (not comb.dec.is_amo or out.atomic_bus_exclusive))
    if not legal:
        return core64_raise_exception(out, CAUSE_ILLEGAL_INSN, trap_value)

    if comb.dec.is_amo:
        val funct5 = core64_amo_funct5(instruction)
        val size = core64_atomic_size(comb.dec)
        if funct5 == AMO_SC:
            val reservation = out.atomics
            out.atomics = atomics_create()
            out.pipeline_phase = CORE64_ATOMIC_STORE
            out.memory = memory64_start_conditional_store(out.mmu,
                out.pmp, comb.rs1_data, size, data_privilege,
                core64_sum_enabled(out), core64_mxr_enabled(out),
                comb.rs2_data, reservation.reservation_valid,
                reservation.reservation_paddr, reservation.reservation_size)
        else:
            out.pipeline_phase = CORE64_ATOMIC_LOAD
            if funct5 == AMO_LR:
                out.memory = memory64_start_lr(out.mmu, out.pmp,
                    comb.rs1_data, size, data_privilege,
                    core64_sum_enabled(out), core64_mxr_enabled(out))
            else:
                out.memory = memory64_start_atomic_read(out.mmu, out.pmp,
                    comb.rs1_data, size, data_privilege,
                    core64_sum_enabled(out), core64_mxr_enabled(out))
        return out

    if comb.dec.is_muldiv:
        out.pipeline_phase = CORE64_MULDIV
        out.mul_div = mul_div_start(core64_muldiv_op(comb.dec),
            comb.rs1_data, comb.rs2_data)
        return out

    if comb.dec.mem_read or comb.dec.mem_write:
        val access_type = if comb.dec.mem_write: ACCESS_STORE_64 else: ACCESS_LOAD_64
        out.pipeline_phase = CORE64_DATA_ACCESS
        out.memory = memory64_start(out.mmu, out.pmp, comb.dmem_addr,
            access_type, core64_data_size(comb.dec.funct3),
            data_privilege, core64_sum_enabled(out),
            core64_mxr_enabled(out), comb.dmem_wdata)
        return out

    out = core64_update(out, instruction, comb, comb.a0_val, comb.a1_val)
    core64_finish_instruction(out)

@hardware
fn core64_cycle(state: CoreState64, request_ready: bool, response_valid: bool,
                response_error: bool, response_data: i64) -> Core64CycleResult:
    """Advance the only production RV64 core path by one clock.

    Fetches two 16-bit parcels so a 32-bit instruction may cross a page. Data
    accesses reuse the same Sv39/PMP frontend and one-outstanding bus contract.
    """
    var out = state
    var bus_valid = false
    var bus_addr: i64 = 0
    var bus_size: u32 = 1
    var bus_write = false
    var bus_wdata: i64 = 0
    var bus_is_pte = false
    var bus_atomic = false

    if state.halt:
        return Core64CycleResult(state: state, bus_valid: false, bus_addr: 0,
            bus_size: 1, bus_write: false, bus_wdata: 0, bus_is_pte: false,
            bus_atomic: false)

    out.semi_trigger = false

    if state.pipeline_phase == CORE64_MULDIV:
        val mul_div = mul_div_tick(state.mul_div)
        out.mul_div = mul_div
        if not mul_div.busy:
            var comb = core64_combinational_length(out, state.instruction, 0,
                out.rf, state.instruction_bytes)
            comb.rd_data = mul_div.result
            comb.rd_write = true
            out = core64_update(out, state.instruction, comb,
                comb.a0_val, comb.a1_val)
            out = core64_finish_instruction(out)
        return Core64CycleResult(state: out, bus_valid: false, bus_addr: 0,
            bus_size: 1, bus_write: false, bus_wdata: 0, bus_is_pte: false,
            bus_atomic: false)

    val mem = memory64_cycle(state.memory, state.mmu, state.pmp, request_ready,
        response_valid, response_error, response_data)
    out.memory = mem.state
    out.mmu = mem.mmu
    bus_valid = mem.bus_valid
    bus_addr = mem.bus_addr
    bus_size = mem.bus_size
    bus_write = mem.bus_write
    bus_wdata = mem.bus_wdata
    bus_is_pte = mem.bus_is_pte
    bus_atomic = mem.bus_atomic

    if mem.done:
        if mem.fault:
            out = core64_raise_exception(out, mem.fault_cause, mem.fault_tval)

        else if state.pipeline_phase == CORE64_ATOMIC_LOAD:
            var comb = core64_combinational_length(out, state.instruction, 0,
                out.rf, state.instruction_bytes)
            val funct5 = core64_amo_funct5(state.instruction)
            val old_value = core64_atomic_read_value(comb.dec, mem.read_data)
            if funct5 == AMO_LR:
                out.atomics = atomics_lr(out.atomics, mem.state.paddr,
                    core64_atomic_size(comb.dec))
                comb.rd_data = old_value
                comb.rd_write = true
                out = core64_update(out, state.instruction, comb,
                    comb.a0_val, comb.a1_val)
                out = core64_finish_instruction(out)
            else:
                val amo = if comb.dec.funct3 == 2:
                    amo_compute_word(funct5, mem.read_data, comb.rs2_data)
                else:
                    amo_compute(funct5, mem.read_data, comb.rs2_data)
                out.atomic_old = amo.old_value
                out.pipeline_phase = CORE64_ATOMIC_STORE
                out.memory = memory64_start_atomic_store(out.mmu, out.pmp,
                    state.memory.vaddr, core64_atomic_size(comb.dec),
                    state.memory.privilege, state.memory.sum,
                    state.memory.mxr, amo.new_value)

        else if state.pipeline_phase == CORE64_ATOMIC_STORE:
            var comb = core64_combinational_length(out, state.instruction, 0,
                out.rf, state.instruction_bytes)
            val funct5 = core64_amo_funct5(state.instruction)
            if funct5 == AMO_SC:
                comb.rd_data = if mem.state.conditional_failed: 1 else: 0
            else:
                comb.rd_data = state.atomic_old
                out.atomics = atomics_invalidate(out.atomics, mem.state.paddr,
                    core64_atomic_size(comb.dec))
            comb.rd_write = true
            out.atomic_old = 0
            out = core64_update(out, state.instruction, comb,
                comb.a0_val, comb.a1_val)
            out = core64_finish_instruction(out)

        else if state.pipeline_phase == CORE64_FETCH_LOW:
            val parcel = (mem.read_data & 0xFFFF) as u32
            if (parcel & 0x3) != 0x3:
                val expanded = rvc64_decompress(parcel)
                if expanded.valid:
                    out = core64_begin_instruction(out, expanded.instruction,
                        2, parcel as i64)
                else:
                    out = core64_raise_exception(out, CAUSE_ILLEGAL_INSN,
                        parcel as i64)
            else if (parcel & 0x1F) == 0x1F:
                # ILEN is 32. We have only the first 16 bits of this longer
                # instruction, so report zero rather than a partial mtval.
                out = core64_raise_exception(out, CAUSE_ILLEGAL_INSN,
                    0)
            else:
                out.fetch_low = parcel
                out.pipeline_phase = CORE64_FETCH_HIGH
                out.memory = memory64_start(out.mmu, out.pmp, out.pc + 2,
                    ACCESS_FETCH_64, 2, out.priv_mode as u32,
                    core64_sum_enabled(out), core64_mxr_enabled(out), 0)

        else if state.pipeline_phase == CORE64_FETCH_HIGH:
            val insn = state.fetch_low | (((mem.read_data & 0xFFFF) as u32) << 16)
            out = core64_begin_instruction(out, insn, 4, insn as i64)

        else:
            val comb = core64_combinational_length(out, state.instruction,
                mem.read_data, out.rf, state.instruction_bytes)
            if comb.dec.mem_write:
                out.atomics = atomics_invalidate(out.atomics, mem.state.paddr,
                    core64_data_size(comb.dec.funct3))
            out = core64_update(out, state.instruction, comb,
                comb.a0_val, comb.a1_val)
            out = core64_finish_instruction(out)

    Core64CycleResult(state: out, bus_valid: bus_valid, bus_addr: bus_addr,
        bus_size: bus_size, bus_write: bus_write, bus_wdata: bus_wdata,
        bus_is_pte: bus_is_pte, bus_atomic: bus_atomic)
