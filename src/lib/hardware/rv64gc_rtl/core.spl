# ============================================================================
# RV64GC RTL Core — Single-Cycle Datapath (64-bit)
# ============================================================================
#
# Adapts RV32I core pattern for 64-bit RV64GC.  Top-level module that wires
# the decoder, ALU, register file, LSU, mul/div, and atomics into a
# single-cycle pipeline.
#
# Architecture:
#   - core64_combinational()  — all combinational datapath logic
#   - core64_update()         — clocked sequential logic (PC, semihosting, halt)
#   - core64_reset()          — initial state at reset
#
# Semihosting: detects the same 3-instruction magic sequence as RV32
#   slli zero,zero,0x1f  /  ebreak  /  srai zero,zero,0x7
# (32-bit instruction encoding is unchanged).
# ============================================================================

use std.hardware.rv64gc_rtl.pkg.{OP_LUI, OP_AUIPC, OP_JAL, OP_JALR}
use std.hardware.rv64gc_rtl.pkg.{OP_BRANCH, OP_LOAD, OP_STORE, OP_SYSTEM, OP_MISC_MEM}
use std.hardware.rv64gc_rtl.pkg.{OP_IMMED, OP_REG, OP_OP_IMM_32, OP_OP_32, OP_AMO}
use std.hardware.rv64gc_rtl.pkg.{BR_BEQ, BR_BNE, BR_BLT, BR_BGE, BR_BLTU, BR_BGEU}
use std.hardware.rv64gc_rtl.pkg.{SEMI_ENTRY, SEMI_BREAK, SEMI_EXIT, SYS_EXIT}
use std.hardware.rv64gc_rtl.decode.{DecodeResult64, decode_instruction_64, sign_extend_to_64}
use std.hardware.rv64gc_rtl.decode.{RvcExpansion, rvc_expand}
use std.hardware.rv64gc_rtl.alu.{AluResult64, alu64_compute, i64_signed_lt}
use std.hardware.rv64gc_rtl.regfile.{RegFile64, RegReadResult64, regfile64_create, regfile64_read, regfile64_write}
use std.hardware.rv64gc_rtl.lsu.lsu64_load
use std.hardware.rv64gc_rtl.mul_div.{MulDivState, mul_div_ready, muldiv_execute}
use std.hardware.rv64gc_rtl.atomics.{AtomicsState, atomics_create, atomics_lr, atomics_sc, atomics_invalidate, amo_compute}
use std.hardware.rv64gc_rtl.pkg.{AMO_LR, AMO_SC, AMO_SWAP, AMO_ADD, AMO_XOR, AMO_AND, AMO_OR}
use std.hardware.rv64gc_rtl.pkg.{AMO_MIN, AMO_MAX, AMO_MINU, AMO_MAXU}
use std.hardware.rv64gc_rtl.csr.{CsrFile64, csr64_create, csr64_read, csr64_write}
use std.hardware.rv64gc_rtl.csr.{CsrExt64, csr_ext64_create, csr_ext64_read, csr_ext64_write, csr_ext64_known}
use std.hardware.rv64gc_rtl.csr.{MSTATUS_MIE_MASK, MIP_MEIP_MASK, MIP_MSIP_MASK, MIP_MTIP_MASK}
use std.hardware.rv64gc_rtl.csr_s.{CsrSMode64, csr_s64_create, csr_s64_read, csr_s64_write}
use std.hardware.rv64gc_rtl.trap.{trap64_mret, trap64_sret, trap64_sret_csr}
use std.hardware.rv64gc_rtl.trap.{InterruptCheckResult64, trap64_enter, trap64_state_init}
use std.hardware.rv64gc_rtl.trap.{CAUSE_ILLEGAL_INSN, CAUSE_BREAKPOINT, cause_mei, cause_msi, cause_mti}
use std.hardware.rv64gc_rtl.trap.{CAUSE_LOAD_MISALIGNED, CAUSE_STORE_MISALIGNED}
use std.hardware.rv64gc_rtl.mmu_sv39.{MmuState64, mmu64_create, mmu64_flush, mmu64_set_satp}
use std.hardware.rv64gc_rtl.mmu_sv39.{ACCESS_FETCH_64, ACCESS_LOAD_64, ACCESS_STORE_64}
use std.hardware.rv64gc_rtl.csr_s.{SSTATUS_SIE_MASK_64, SSTATUS_SUM_MASK_64, SSTATUS_MXR_MASK_64}
use std.hardware.rv64gc_rtl.fpu.{FpuConfig, FpuUnit, Fcsr, FRegFile64, fregfile_create, fcsr_create, fpu_config_enabled, fpu_config_disabled, fpu_execute, fpu_fmv_from_int, fpu_cvt_int_to_float, FpuStep, OP_FP, OP_FMADD, OP_FMSUB, OP_FNMSUB, OP_FNMADD}

val CORE64_FETCH_LOW: u32 = 0
val CORE64_FETCH_HIGH: u32 = 1
val CORE64_DATA_ACCESS: u32 = 2

# ============================================================================
# Core sequential state (clocked registers)
# ============================================================================

struct CoreState64:
    """Sequential state updated on each clock edge."""
    pc: i64             # Program counter (64-bit)
    halt: bool          # CPU halted
    semi_phase: u32     # Semihosting sequence detector (0/1/2)
    semi_op: i64        # Latched semihosting operation (a0)
    semi_param: i64     # Latched semihosting parameter (a1)
    semi_suppress: bool # Suppress normal execution during semihost sequence
    semi_trigger: bool  # One-cycle pulse when semihosting completes
    mul_div: MulDivState  # M extension state
    atomics: AtomicsState # A extension state
    priv_mode: i64      # Current privilege mode: M=3, S=1, U=0
    csr_m: CsrFile64    # M-mode CSR file
    csr_ext: CsrExt64   # PMP + counter-enable CSR storage (no enforcement)
    csr_s: CsrSMode64   # S-mode CSR file
    mmu: MmuState64      # Sv39 MMU state, including TLB
    rf: RegFile64         # Architectural integer register file
    frf: FRegFile64       # F/D float register file (f0-f31)
    fcsr: Fcsr            # Float control/status (frm + fflags)
    fpu_cfg: FpuConfig    # Injected FPU config; .enabled toggles the F/D unit
    pipeline_phase: u32   # Fetch low parcel, fetch high parcel, or data
    fetch_low: u32        # Low 16-bit instruction parcel
    instruction: u32      # Current 32-bit instruction during data access

struct CoreCsrAccess64:
    """One legal CSR read/modify/write result for the clocked core."""
    valid: bool
    old_value: i64
    csr_m: CsrFile64
    csr_ext: CsrExt64
    csr_s: CsrSMode64
    mmu: MmuState64

struct Core64CycleResult:
    """One clock result and the canonical physical bus request."""
    state: CoreState64
    bus_valid: bool
    bus_addr: i64
    bus_size: u32
    bus_write: bool
    bus_wdata: i64
    bus_is_pte: bool

# ============================================================================
# Combinational result bundle
# ============================================================================

struct CoreCombResult64:
    """All combinational outputs from one cycle of the datapath."""
    # Decoder outputs
    dec: DecodeResult64

    # Register file read results
    rs1_data: i64
    rs2_data: i64
    a0_val: i64
    a1_val: i64

    # ALU results
    alu_result: i64
    alu_zero: bool

    # Branch evaluation
    branch_taken: bool
    branch_target: i64

    # Next PC (combinational)
    pc_next: i64
    pc_plus4: i64

    # Write-back data for rd
    rd_data: i64
    rd_write: bool

    # Data memory interface
    dmem_addr: i64
    dmem_wdata: i64
    dmem_we: bool
    dmem_re: bool
    dmem_width: u32

    # Instruction memory address
    imem_addr: i64

# ============================================================================
# Signed comparison helpers for branch evaluation
# ============================================================================

fn i64_signed_ge(a: i64, b: i64) -> bool:
    """Signed greater-than-or-equal for i64."""
    not i64_signed_lt(a, b)

# ============================================================================
# Unsigned comparison helpers for branch evaluation
# ============================================================================

fn i64_unsigned_lt(a: i64, b: i64) -> bool:
    """Unsigned less-than for i64 (two's complement)."""
    val flip: i64 = 0x8000000000000000
    val fa = a ^ flip
    val fb = b ^ flip
    fa < fb

fn i64_unsigned_ge(a: i64, b: i64) -> bool:
    """Unsigned greater-than-or-equal for i64."""
    not i64_unsigned_lt(a, b)

# ============================================================================
# Misaligned load/store/AMO detection
# ============================================================================
# Natural-alignment enforcement: byte accesses never fault; half/word/dword
# must be 2/4/8-byte aligned. On a misaligned access core64_combinational
# suppresses the memory access and core64_update raises CAUSE_LOAD_MISALIGNED
# (4) or CAUSE_STORE_MISALIGNED (6). Both sides use the SAME predicate so the
# suppressed access and the raised trap stay consistent.

fn core64_access_size(funct3: u32) -> i64:
    """Natural alignment (bytes) for an access whose width is funct3[1:0]."""
    val w = funct3 & 0x3
    if w == 0:
        return 1
    if w == 1:
        return 2
    if w == 2:
        return 4
    8

fn core64_is_mem_op(dec: DecodeResult64) -> bool:
    """A load, store, or atomic memory operation (the only faulting classes)."""
    dec.mem_read or dec.mem_write or dec.is_amo

fn core64_mem_misaligned(dec: DecodeResult64, addr: i64) -> bool:
    """True when this mem op's effective address is not naturally aligned."""
    if core64_is_mem_op(dec) == false:
        return false
    val size = core64_access_size(dec.funct3)
    (addr & (size - 1)) != 0

fn core64_mem_misalign_cause(dec: DecodeResult64) -> i64:
    """CAUSE_LOAD_MISALIGNED for loads; CAUSE_STORE_MISALIGNED for stores/AMO."""
    if dec.mem_read:
        return CAUSE_LOAD_MISALIGNED
    CAUSE_STORE_MISALIGNED

# ============================================================================
# Branch evaluation
# ============================================================================

fn eval_branch_64(funct3: u32, rs1_data: i64, rs2_data: i64) -> bool:
    """Evaluate branch condition. Returns true if branch is taken."""
    if funct3 == BR_BEQ:
        return rs1_data == rs2_data
    if funct3 == BR_BNE:
        return rs1_data != rs2_data
    if funct3 == BR_BLT:
        return i64_signed_lt(rs1_data, rs2_data)
    if funct3 == BR_BGE:
        return i64_signed_ge(rs1_data, rs2_data)
    if funct3 == BR_BLTU:
        return i64_unsigned_lt(rs1_data, rs2_data)
    if funct3 == BR_BGEU:
        return i64_unsigned_ge(rs1_data, rs2_data)
    false

fn core64_instruction_legal(instruction: u32, dec: DecodeResult64) -> bool:
    """Fail closed for every encoding the current integer datapath accepts."""
    val op = dec.opcode
    val f3 = dec.funct3
    val f7 = dec.funct7

    if op == OP_LUI or op == OP_AUIPC or op == OP_JAL:
        return true
    if op == OP_JALR:
        return f3 == 0
    if op == OP_BRANCH:
        return f3 == 0 or f3 == 1 or f3 == 4 or f3 == 5 or f3 == 6 or f3 == 7
    if op == OP_LOAD:
        return f3 <= 6
    if op == OP_STORE:
        return f3 <= 3

    if op == OP_IMMED:
        if f3 == 1:
            return ((instruction >> 26) & 0x3F) == 0
        if f3 == 5:
            val funct6 = (instruction >> 26) & 0x3F
            return funct6 == 0 or funct6 == 0x10
        return f3 == 0 or f3 == 2 or f3 == 3 or f3 == 4 or f3 == 6 or f3 == 7

    if op == OP_REG:
        if f7 == 0 or f7 == 1:
            return true
        return f7 == 0x20 and (f3 == 0 or f3 == 5)

    if op == OP_OP_IMM_32:
        if f3 == 0:
            return true
        if f3 == 1:
            return f7 == 0
        if f3 == 5:
            return f7 == 0 or f7 == 0x20
        return false

    if op == OP_OP_32:
        if f7 == 1:
            return true
        if f7 == 0:
            return f3 == 0 or f3 == 1 or f3 == 5
        return f7 == 0x20 and (f3 == 0 or f3 == 5)

    if op == OP_MISC_MEM:
        if f3 == 0:
            return dec.rd == 0 and dec.rs1 == 0
        return instruction == 0x0000100F

    if op == OP_SYSTEM:
        if dec.is_sfence_vma:
            return dec.rd == 0
        if dec.is_csr or dec.is_mret or dec.is_sret or dec.is_wfi:
            return true
        return instruction == 0x00000073 or instruction == 0x00100073

    # A extension: LR/SC + AMO, .W (f3=2) and .D (f3=3) only. LR requires
    # rs2 == 0. aq/rl bits (funct7[1:0]) are accepted — single-hart, all
    # accesses already sequentially consistent.
    if op == OP_AMO:
        if f3 != 2 and f3 != 3:
            return false
        val f5 = f7 >> 2
        if f5 == AMO_LR:
            return dec.rs2 == 0
        return (f5 == AMO_SC or f5 == AMO_SWAP or f5 == AMO_ADD or
                f5 == AMO_XOR or f5 == AMO_AND or f5 == AMO_OR or
                f5 == AMO_MIN or f5 == AMO_MAX or f5 == AMO_MINU or
                f5 == AMO_MAXU)
    false

fn core64_privileged_instruction_legal(state: CoreState64,
                                       dec: DecodeResult64) -> bool:
    if dec.is_mret:
        return state.priv_mode == 3
    if dec.is_sret or dec.is_sfence_vma:
        return state.priv_mode == 1 or state.priv_mode == 3
    true

# ============================================================================
# Privileged CSR routing
# ============================================================================

fn core64_machine_csr_known(addr: u32) -> bool:
    (addr == 0x300 or addr == 0x301 or addr == 0x302 or addr == 0x303 or
     addr == 0x304 or addr == 0x305 or addr == 0x340 or addr == 0x341 or
     addr == 0x342 or addr == 0x343 or addr == 0x344 or addr == 0xB00 or
     addr == 0xB02 or addr == 0xF14)

fn core64_supervisor_csr_known(addr: u32) -> bool:
    (addr == 0x100 or addr == 0x104 or addr == 0x105 or addr == 0x140 or
     addr == 0x141 or addr == 0x142 or addr == 0x143 or addr == 0x144 or
     addr == 0x180)

fn core64_csr_source(funct3: u32, rs1: u32, rs1_data: i64) -> i64:
    if (funct3 & 0x4) != 0:
        return rs1 as i64
    rs1_data

fn core64_csr_write_requested(funct3: u32, source: i64) -> bool:
    val op = funct3 & 0x3
    op == 1 or ((op == 2 or op == 3) and source != 0)

fn core64_csr_next_value(old_value: i64, source: i64, funct3: u32) -> i64:
    val op = funct3 & 0x3
    if op == 1:
        return source
    if op == 2:
        return old_value | source
    if op == 3:
        return old_value & (source ^ -1)
    old_value

fn core64_invalid_csr_access(state: CoreState64) -> CoreCsrAccess64:
    CoreCsrAccess64(valid: false, old_value: 0, csr_m: state.csr_m,
        csr_ext: state.csr_ext, csr_s: state.csr_s, mmu: state.mmu)

fn core64_csr_access(state: CoreState64, addr: u32, source: i64, funct3: u32) -> CoreCsrAccess64:
    """Route one Zicsr operation to M, S, or PMP state and fail closed."""
    val op = funct3 & 0x3
    if op == 0:
        return core64_invalid_csr_access(state)

    val required_priv = ((addr >> 8) & 0x3) as i64
    val write_requested = core64_csr_write_requested(funct3, source)
    val read_only = ((addr >> 10) & 0x3) == 0x3
    if state.priv_mode < required_priv or (write_requested and read_only):
        return core64_invalid_csr_access(state)

    if core64_machine_csr_known(addr):
        val old_value = csr64_read(state.csr_m, addr)
        var new_csr_m = state.csr_m
        if write_requested:
            new_csr_m = csr64_write(state.csr_m, addr, core64_csr_next_value(old_value, source, funct3))
        return CoreCsrAccess64(valid: true, old_value: old_value,
            csr_m: new_csr_m, csr_ext: state.csr_ext, csr_s: state.csr_s, mmu: state.mmu)

    # PMP + counter-enable CSRs: readable/writable storage, no enforcement.
    # (required_priv already gated above from the address bits — PMP/menvcfg/
    # mcounteren need M, scounteren needs S, which the check enforces.)
    if csr_ext64_known(addr):
        val old_value = csr_ext64_read(state.csr_ext, addr)
        var new_ext = state.csr_ext
        if write_requested:
            new_ext = csr_ext64_write(state.csr_ext, addr, core64_csr_next_value(old_value, source, funct3))
        return CoreCsrAccess64(valid: true, old_value: old_value,
            csr_m: state.csr_m, csr_ext: new_ext, csr_s: state.csr_s, mmu: state.mmu)

    if core64_supervisor_csr_known(addr):
        val old_value = csr_s64_read(state.csr_s, addr)
        var new_csr_s = state.csr_s
        var new_mmu = state.mmu
        if write_requested:
            new_csr_s = csr_s64_write(state.csr_s, addr, core64_csr_next_value(old_value, source, funct3))
            if addr == 0x180 and new_csr_s.satp != state.csr_s.satp:
                new_mmu = mmu64_set_satp(mmu64_flush(state.mmu), new_csr_s.satp)
        return CoreCsrAccess64(valid: true, old_value: old_value,
            csr_m: state.csr_m, csr_ext: state.csr_ext, csr_s: new_csr_s, mmu: new_mmu)

    core64_invalid_csr_access(state)

# ============================================================================
# Combinational datapath
# ============================================================================

fn core64_combinational(state: CoreState64, imem_data: u32, dmem_rdata: i64, rf: RegFile64) -> CoreCombResult64:
    """Compute all combinational signals for one cycle."""

    val pc = state.pc

    # RV64C: if the fetched word is a 16-bit parcel (low 2 bits != 0b11),
    # expand it to its 32-bit equivalent and advance pc by 2 (link = pc+2);
    # otherwise it is a normal 32-bit instruction (pc += 4).  IALIGN=16 when C
    # is implemented, so 2-byte-aligned fetch/branch targets are legal.
    val exp = rvc_expand(imem_data)
    val eff_insn = exp.insn
    val pc_incr: i64 = if exp.compressed: 2 else: 4
    # pc_plus4 carries the sequential-next PC (= link value); named for the
    # historical RV32 field.  For a compressed insn this is pc+2.
    val pc_plus4 = pc + pc_incr

    val imem_addr = pc

    # Decode the (possibly expanded) 32-bit instruction
    val dec = decode_instruction_64(eff_insn)

    # Register file read
    val rr = regfile64_read(rf, dec.rs1, dec.rs2)
    val rs1_data = rr.rs1_data
    val rs2_data = rr.rs2_data

    # ALU input muxes
    var alu_a: i64 = rs1_data
    if dec.opcode == OP_AUIPC or dec.opcode == OP_JAL:
        alu_a = pc

    var alu_b: i64 = rs2_data
    if dec.alu_src:
        alu_b = dec.imm

    # ALU
    val alu_res = alu64_compute(alu_a, alu_b, dec.alu_op)

    # Branch evaluation
    var branch_taken: bool = false
    if dec.branch:
        branch_taken = eval_branch_64(dec.funct3, rs1_data, rs2_data)

    val branch_target = pc + dec.imm

    # Next PC mux
    var pc_next: i64 = pc_plus4
    if dec.opcode == OP_JALR:
        pc_next = alu_res.result
    else if branch_taken or dec.jump:
        pc_next = branch_target

    # Write-back data mux
    var rd_data: i64 = alu_res.result
    var rd_write = dec.reg_write
    if dec.mem_to_reg:
        rd_data = lsu64_load(dmem_rdata, dec.funct3)
    else if dec.jump:
        rd_data = pc_plus4
    else if dec.is_muldiv:
        # M extension: decode routes funct7==1 through the ALU as an ADD
        # placeholder; override rd here with the real product/quotient/
        # remainder. is_word selects the .W (32-bit, sign-extended) forms.
        rd_data = muldiv_execute(dec.opcode == OP_OP_32, dec.funct3, rs1_data, rs2_data)
    else if dec.is_csr:
        val source = core64_csr_source(dec.funct3, dec.rs1, rs1_data)
        val csr_access = core64_csr_access(state, dec.csr_addr, source, dec.funct3)
        if csr_access.valid:
            rd_data = csr_access.old_value
            # decode's reg_write excludes OP_SYSTEM, so the CSR old-value
            # writeback must be enabled here (regfile ignores rd=x0).
            rd_write = true
        else:
            rd_write = false

    # Data memory interface
    val dmem_addr = alu_res.result
    var dmem_wdata = rs2_data
    var dmem_we = dec.mem_write and (state.semi_suppress == false)
    var dmem_re = dec.mem_read
    val dmem_width = dec.funct3 & 0x3

    # ── A extension (OP_AMO): LR / SC / AMO read-modify-write ──
    # Address = rs1 (decode routes imm=0 through the ALU for OP_AMO, so
    # dmem_addr already equals rs1). funct3=2 → .W (4 bytes, sign-extended
    # into rd via lsu64_load), funct3=3 → .D (8 bytes). The SoC tick reads
    # old memory at step 4 and writes dmem_wdata at step 6 of the SAME
    # cycle, so an AMO is a true single-cycle atomic RMW.
    if dec.is_amo:
        val amo_funct5 = dec.funct7 >> 2
        if amo_funct5 == AMO_LR:
            # LR: plain load + reservation set (reservation is sequential
            # state — core64_update marks it).
            dmem_re = true
            rd_data = lsu64_load(dmem_rdata, dec.funct3)
        else if amo_funct5 == AMO_SC:
            # SC: store rs2 iff the reservation is valid and matches this
            # address; rd = 0 on success, 1 on failure.
            val sc_ok = state.atomics.reservation_valid and
                        state.atomics.reservation_addr == dmem_addr
            dmem_we = sc_ok and (state.semi_suppress == false)
            if sc_ok:
                rd_data = 0
            else:
                rd_data = 1
        else:
            # AMOSWAP/ADD/XOR/AND/OR/MIN/MAX/MINU/MAXU: rd gets the
            # (sign-extended for .W) old value, memory gets the computed
            # new value. For .W the rs2 operand is sign-extended from its
            # low 32 bits so signed and unsigned 32-bit min/max order
            # correctly in the 64-bit comparator; the 4-byte store
            # truncates the result back to 32 bits.
            dmem_re = true
            dmem_we = state.semi_suppress == false
            val amo_old = lsu64_load(dmem_rdata, dec.funct3)
            var amo_rs2 = rs2_data
            if dec.funct3 == 2:
                amo_rs2 = sign_extend_to_64(rs2_data & 0xFFFF_FFFF, 32)
            val amo = amo_compute(amo_funct5, amo_old, amo_rs2)
            dmem_wdata = amo.new_value
            rd_data = amo_old

    # ── Misaligned load/store/AMO: suppress the memory access and the rd
    #    writeback; core64_update raises CAUSE_LOAD_MISALIGNED (4) /
    #    CAUSE_STORE_MISALIGNED (6) through the trap path BEFORE any access. ──
    if core64_mem_misaligned(dec, dmem_addr):
        dmem_re = false
        dmem_we = false
        rd_write = false

    CoreCombResult64(
        dec: dec,
        rs1_data: rs1_data,
        rs2_data: rs2_data,
        a0_val: rr.a0_val,
        a1_val: rr.a1_val,
        alu_result: alu_res.result,
        alu_zero: alu_res.zero,
        branch_taken: branch_taken,
        branch_target: branch_target,
        pc_next: pc_next,
        pc_plus4: pc_plus4,
        rd_data: rd_data,
        rd_write: rd_write,
        dmem_addr: dmem_addr,
        dmem_wdata: dmem_wdata,
        dmem_we: dmem_we,
        dmem_re: dmem_re,
        dmem_width: dmem_width,
        imem_addr: imem_addr
    )

# ============================================================================
# Sequential update (clocked logic)
# ============================================================================

fn core64_is_fp_compute(opcode: i64) -> bool:
    """OP-FP and the fused multiply-add family — the F/D compute ops the core
    routes to the injected FPU. Load/store FP are not yet wired (deferred)."""
    opcode == OP_FP or opcode == OP_FMADD or opcode == OP_FMSUB or
        opcode == OP_FNMSUB or opcode == OP_FNMADD

fn core64_set_fpu(state: CoreState64, cfg: FpuConfig) -> CoreState64:
    """Inject/replace the FPU config (the on/off toggle) on an existing core."""
    CoreState64(pc: state.pc, halt: state.halt, semi_phase: state.semi_phase,
        semi_op: state.semi_op, semi_param: state.semi_param,
        semi_suppress: state.semi_suppress, semi_trigger: state.semi_trigger,
        mul_div: state.mul_div, atomics: state.atomics, priv_mode: state.priv_mode,
        csr_m: state.csr_m, csr_ext: state.csr_ext, csr_s: state.csr_s,
        mmu: state.mmu, rf: state.rf, frf: state.frf, fcsr: state.fcsr,
        fpu_cfg: cfg, pipeline_phase: state.pipeline_phase,
        fetch_low: state.fetch_low, instruction: state.instruction)

fn core64_update(state: CoreState64, imem_data: u32, comb: CoreCombResult64, a0_val: i64, a1_val: i64) -> CoreState64:
    """Update sequential state on rising clock edge.
    Handles PC advancement, semihosting detection, and halt."""

    # RV64C: re-derive the expansion so SYSTEM literal matches see the EXPANDED
    # 32-bit insn (e.g. c.ebreak -> 0x00100073 -> BREAKPOINT), and so a
    # reserved 16-bit parcel raises illegal-instruction (cause 2) fail-closed.
    # eff_insn == imem_data for a normal 32-bit instruction.
    val exp = rvc_expand(imem_data)
    val eff_insn = exp.insn
    # Illegal-instruction tval: the 16-bit parcel for a compressed insn, else
    # the full 32-bit word (RISC-V mtval carries the faulting instruction).
    val ill_tval: i64 = if exp.compressed: (imem_data as i64) & 0xFFFF else: eff_insn as i64

    var new_pc = state.pc
    var new_halt = state.halt
    var new_semi_phase = state.semi_phase
    var new_semi_op = state.semi_op
    var new_semi_param = state.semi_param
    var new_semi_suppress = state.semi_suppress
    var new_semi_trigger: bool = false
    var new_mul_div = state.mul_div
    var new_atomics = state.atomics
    var new_priv_mode = state.priv_mode
    var new_csr_m = state.csr_m
    var new_csr_ext = state.csr_ext
    var new_csr_s = state.csr_s
    var new_mmu = state.mmu
    var new_rf = state.rf
    var new_frf = state.frf
    var new_fcsr = state.fcsr
    # FP compute retiring to an integer rd (FMV.X/FCLASS/FEQ/FLT/FLE) overrides
    # the normal integer writeback below.
    var fp_int_write = false
    var fp_int_rd = 0
    var fp_int_val: i64 = 0
    val fp_opcode: i64 = (eff_insn as i64) & 0x7F

    if state.halt == false:
        if imem_data == SEMI_ENTRY and state.semi_phase == 0:
            new_semi_phase = 1
            new_pc = comb.pc_plus4

        else if imem_data == SEMI_BREAK and state.semi_phase == 1:
            new_semi_phase = 2
            new_semi_op = a0_val
            new_semi_param = a1_val
            new_semi_suppress = true
            new_pc = comb.pc_plus4

        else if imem_data == SEMI_EXIT and state.semi_phase == 2:
            new_semi_phase = 0
            new_semi_suppress = false
            new_semi_trigger = true
            val exit_code: i64 = SYS_EXIT as i64
            if new_semi_op == exit_code:
                new_halt = true
            else:
                new_pc = comb.pc_plus4

        else if exp.compressed and (exp.legal == false) and state.semi_phase == 0:
            # Reserved / unsupported (F/D) 16-bit parcel: raise illegal-
            # instruction (cause 2) with the 16-bit parcel as mtval.  Fail
            # closed — never a silent NOP.  pc stays at the faulting insn
            # (trap sets mepc = pc).
            val trap = trap64_enter(trap64_state_init(), CAUSE_ILLEGAL_INSN,
                ill_tval, state.pc, state.priv_mode, state.csr_m, state.csr_s)
            new_pc = trap.trap_pc
            new_priv_mode = trap.target_mode
            new_csr_m = trap.csr
            new_csr_s = trap.csr_s
            new_semi_phase = 0
            new_semi_suppress = false
            new_atomics = atomics_create()

        else if comb.dec.is_mret and state.semi_phase == 0:
            val result = trap64_mret(state.csr_m)
            new_pc = result.return_pc
            new_priv_mode = result.target_mode
            new_csr_m = result.csr
            new_semi_phase = 0
            new_semi_suppress = false

        else if comb.dec.is_sret and state.semi_phase == 0:
            val result = trap64_sret(state.csr_s)
            new_pc = result.return_pc
            new_priv_mode = result.target_mode
            new_csr_s = trap64_sret_csr(state.csr_s)
            new_semi_phase = 0
            new_semi_suppress = false

        else if comb.dec.is_sfence_vma and state.semi_phase == 0:
            new_pc = comb.pc_plus4
            new_mmu = mmu64_flush(state.mmu)
            new_semi_phase = 0
            new_semi_suppress = false

        else if comb.dec.is_csr and state.semi_phase == 0:
            val source = core64_csr_source(comb.dec.funct3, comb.dec.rs1, comb.rs1_data)
            val csr_access = core64_csr_access(state, comb.dec.csr_addr, source, comb.dec.funct3)
            if csr_access.valid:
                new_pc = comb.pc_plus4
                new_csr_m = csr_access.csr_m
                new_csr_ext = csr_access.csr_ext
                new_csr_s = csr_access.csr_s
                new_mmu = csr_access.mmu
                new_semi_phase = 0
                new_semi_suppress = false
            else:
                val trap = trap64_enter(trap64_state_init(), CAUSE_ILLEGAL_INSN,
                    ill_tval, state.pc, state.priv_mode, state.csr_m, state.csr_s)
                new_pc = trap.trap_pc
                new_priv_mode = trap.target_mode
                new_csr_m = trap.csr
                new_csr_s = trap.csr_s
                new_semi_phase = 0
                new_semi_suppress = false
                new_atomics = atomics_create()

        else if comb.dec.is_wfi and state.semi_phase == 0:
            # WFI — wait for interrupt. Chosen semantics (documented):
            #   * retire as a NOP (pc <- pc+4) when an enabled interrupt is
            #     already pending (mie & mip != 0) — the SoC's step-8
            #     interrupt take then fires with mepc = wfi+4, so mret
            #     resumes AFTER the wfi (RISC-V: mepc = next instruction);
            #   * retire as a NOP when mstatus.MIE = 0 — the spec allows
            #     WFI to be a no-op, and this avoids a permanent hang when
            #     interrupts are globally disabled (OpenSBI relies on this
            #     in its early idle paths);
            #   * otherwise hold pc (stall). Peripherals (CLINT/PLIC) keep
            #     ticking in the SoC loop, so a future mie&mip match wakes
            #     the core on the cycle it pends.
            new_semi_phase = 0
            new_semi_suppress = false
            val wfi_mie_on = (state.csr_m.mstatus & MSTATUS_MIE_MASK) != 0
            val wfi_pending = (state.csr_m.mie & state.csr_m.mip) != 0
            if wfi_pending or wfi_mie_on == false:
                new_pc = comb.pc_plus4
            # else: new_pc stays state.pc — architectural stall

        else if comb.dec.opcode == OP_SYSTEM and state.semi_phase == 0:
            # Compare the EXPANDED insn so c.ebreak (-> 0x00100073) is a
            # breakpoint, not an illegal instruction.
            var cause = CAUSE_ILLEGAL_INSN
            var tval = ill_tval
            if eff_insn == 0x00000073:
                cause = if state.priv_mode == 0: 8 else if state.priv_mode == 1: 9 else: 11
                tval = 0
            else if eff_insn == 0x00100073:
                cause = CAUSE_BREAKPOINT
                tval = 0
            val trap = trap64_enter(trap64_state_init(), cause, tval,
                state.pc, state.priv_mode, state.csr_m, state.csr_s)
            new_pc = trap.trap_pc
            new_priv_mode = trap.target_mode
            new_csr_m = trap.csr
            new_csr_s = trap.csr_s
            new_semi_phase = 0
            new_semi_suppress = false
            new_atomics = atomics_create()

        else if core64_mem_misaligned(comb.dec, comb.dmem_addr) and state.semi_phase == 0:
            # Misaligned load/store/AMO: enter a synchronous exception with
            # cause 4 (load) / 6 (store/AMO) and the faulting address as
            # tval. The memory access was suppressed in the combinational
            # path, so no data was read or written. Clear the reservation.
            val cause = core64_mem_misalign_cause(comb.dec)
            val trap = trap64_enter(trap64_state_init(), cause, comb.dmem_addr,
                state.pc, state.priv_mode, state.csr_m, state.csr_s)
            new_pc = trap.trap_pc
            new_priv_mode = trap.target_mode
            new_csr_m = trap.csr
            new_csr_s = trap.csr_s
            new_semi_phase = 0
            new_semi_suppress = false
            new_atomics = atomics_create()

        else if core64_is_fp_compute(fp_opcode) and state.semi_phase == 0:
            # ── F/D extension: route OP-FP / FMADD-family to the injected FPU.
            #    Disabled (mstatus.FS==Off equivalent) -> illegal-instruction. ──
            new_semi_phase = 0
            new_semi_suppress = false
            if state.fpu_cfg.enabled:
                val fp_instr: i64 = eff_insn as i64
                val fp_funct5 = (fp_instr >> 27) & 0x1F
                val fp_unit = FpuUnit(cfg: state.fpu_cfg, frf: state.frf, fcsr: state.fcsr)
                var fp_step = fpu_execute(fp_unit, fp_instr)
                if fp_opcode == OP_FP and fp_funct5 == 0x1E:
                    # FMV.W.X / FMV.D.X: move integer rs1 bits into float rd.
                    val fp_is_d = ((fp_instr >> 25) & 3) == 1
                    fp_step = fpu_fmv_from_int(fp_unit, comb.dec.rd, fp_is_d, comb.rs1_data)
                else if fp_opcode == OP_FP and fp_funct5 == 0x1A:
                    # FCVT.S/D.W/WU/L/LU: convert integer rs1 to float rd.
                    fp_step = fpu_cvt_int_to_float(fp_unit, fp_instr, comb.rs1_data)
                if fp_step.illegal:
                    val trap = trap64_enter(trap64_state_init(), CAUSE_ILLEGAL_INSN,
                        ill_tval, state.pc, state.priv_mode, state.csr_m, state.csr_s)
                    new_pc = trap.trap_pc
                    new_priv_mode = trap.target_mode
                    new_csr_m = trap.csr
                    new_csr_s = trap.csr_s
                    new_atomics = atomics_create()
                else:
                    new_frf = fp_step.un.frf
                    new_fcsr = fp_step.un.fcsr
                    new_pc = comb.pc_plus4
                    if fp_step.writes_int:
                        fp_int_write = true
                        fp_int_rd = comb.dec.rd
                        fp_int_val = fp_step.int_result
            else:
                val trap = trap64_enter(trap64_state_init(), CAUSE_ILLEGAL_INSN,
                    ill_tval, state.pc, state.priv_mode, state.csr_m, state.csr_s)
                new_pc = trap.trap_pc
                new_priv_mode = trap.target_mode
                new_csr_m = trap.csr
                new_csr_s = trap.csr_s
                new_atomics = atomics_create()

        else:
            new_semi_phase = 0
            new_semi_suppress = false
            new_pc = comb.pc_next
            # A-extension reservation tracking (single-hart rule,
            # documented): LR sets the reservation on its address; SC
            # ALWAYS clears it (success or fail); any other store — plain
            # SW/SD/... or an AMO — to the reserved address clears it;
            # synchronous trap entry clears it (branches above). A store
            # to a DIFFERENT address leaves the reservation intact, which
            # is architecturally sound on a single hart (the reserved
            # location cannot have changed).
            if comb.dec.is_amo:
                val amo_funct5 = comb.dec.funct7 >> 2
                if amo_funct5 == AMO_LR:
                    new_atomics = atomics_lr(state.atomics, comb.dmem_addr)
                else if amo_funct5 == AMO_SC:
                    val sc = atomics_sc(state.atomics, comb.dmem_addr)
                    new_atomics = sc.state
                else:
                    new_atomics = atomics_invalidate(state.atomics, comb.dmem_addr)
            else if comb.dec.mem_write:
                new_atomics = atomics_invalidate(state.atomics, comb.dmem_addr)

        if fp_int_write:
            new_rf = regfile64_write(state.rf, fp_int_rd, fp_int_val, true)
        else:
            new_rf = regfile64_write(state.rf, comb.dec.rd, comb.rd_data, comb.rd_write)

    CoreState64(
        pc: new_pc,
        halt: new_halt,
        semi_phase: new_semi_phase,
        semi_op: new_semi_op,
        semi_param: new_semi_param,
        semi_suppress: new_semi_suppress,
        semi_trigger: new_semi_trigger,
        mul_div: new_mul_div,
        atomics: new_atomics,
        priv_mode: new_priv_mode,
        csr_m: new_csr_m,
        csr_ext: new_csr_ext,
        csr_s: new_csr_s,
        mmu: new_mmu,
        rf: new_rf,
        frf: new_frf,
        fcsr: new_fcsr,
        fpu_cfg: state.fpu_cfg,
        pipeline_phase: state.pipeline_phase,
        fetch_low: state.fetch_low,
        instruction: state.instruction
    )

# ============================================================================
# Semihosting trigger detection
# ============================================================================

fn core64_semi_triggered(state: CoreState64, imem_data: u32) -> bool:
    """Return true if this cycle completes a semihosting sequence."""
    imem_data == SEMI_EXIT and state.semi_phase == 2

# ============================================================================
# Reset state
# ============================================================================

fn core64_reset(reset_addr: i64) -> CoreState64:
    """Create initial core state after reset."""
    val mmu = mmu64_create()
    CoreState64(
        pc: reset_addr,
        halt: false,
        semi_phase: 0,
        semi_op: 0,
        semi_param: 0,
        semi_suppress: false,
        semi_trigger: false,
        mul_div: MulDivState(busy: false, op: 0, a: 0, b: 0, result: 0, cycles_left: 0),
        atomics: AtomicsState(reservation_valid: false, reservation_addr: 0),
        priv_mode: 3,
        csr_m: csr64_create(0),
        csr_ext: csr_ext64_create(),
        csr_s: csr_s64_create(),
        mmu: mmu,
        rf: regfile64_create(),
        frf: fregfile_create(),
        fcsr: fcsr_create(),
        fpu_cfg: fpu_config_enabled(),
        pipeline_phase: CORE64_FETCH_LOW,
        fetch_low: 0,
        instruction: 0
    )

# ============================================================================
# Full initialization with privilege and CSR state
# ============================================================================

fn core64_init(reset_vec: i64) -> CoreState64:
    """Create full initial core state with privilege mode and CSR state.
    Starts in M-mode (priv_mode=3) with all CSRs zeroed."""
    val mmu = mmu64_create()
    CoreState64(
        pc: reset_vec,
        halt: false,
        semi_phase: 0,
        semi_op: 0,
        semi_param: 0,
        semi_suppress: false,
        semi_trigger: false,
        mul_div: MulDivState(busy: false, op: 0, a: 0, b: 0, result: 0, cycles_left: 0),
        atomics: AtomicsState(reservation_valid: false, reservation_addr: 0),
        priv_mode: 3,
        csr_m: csr64_create(0),
        csr_ext: csr_ext64_create(),
        csr_s: csr_s64_create(),
        mmu: mmu,
        rf: regfile64_create(),
        frf: fregfile_create(),
        fcsr: fcsr_create(),
        fpu_cfg: fpu_config_enabled(),
        pipeline_phase: CORE64_FETCH_LOW,
        fetch_low: 0,
        instruction: 0
    )

