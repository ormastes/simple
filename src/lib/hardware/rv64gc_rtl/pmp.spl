# RV64 physical memory protection matching.
#
# The fixed entry fields and fixed call chain are deliberate hardware shapes:
# no arrays, loops, or data-dependent shifts are used in this owner.

val PMP64_ADDRESS_MASK: u32 = 0x18
val PMP64_ADDRESS_OFF: u32 = 0x00
val PMP64_ADDRESS_TOR: u32 = 0x08
val PMP64_ADDRESS_NA4: u32 = 0x10
val PMP64_ADDRESS_NAPOT: u32 = 0x18
val PMP64_READ: u32 = 0x01
val PMP64_WRITE: u32 = 0x02
val PMP64_EXECUTE: u32 = 0x04
val PMP64_LOCKED: u32 = 0x80
val PMP64_ACCESS_EXECUTE: u32 = 0
val PMP64_ACCESS_READ: u32 = 1
val PMP64_ACCESS_WRITE: u32 = 2
val PMP64_PRIV_U: u32 = 0
val PMP64_PRIV_S: u32 = 1
val PMP64_PRIV_M: u32 = 3
val PMP64_MAX_PMPADDR: i64 = 0x003FFFFFFFFFFFFF
val PMP64_MAX_PADDR: i64 = 0x00FFFFFFFFFFFFFF
val PMP64_PADDR_LIMIT: i64 = 0x0100000000000000
val PMP64_NO_MATCH: u32 = 16
val PMP64_CAUSE_INSN_ACCESS_FAULT: i64 = 1
val PMP64_CAUSE_LOAD_ACCESS_FAULT: i64 = 5
val PMP64_CAUSE_STORE_ACCESS_FAULT: i64 = 7

struct PmpEntries64:
    cfg_0: u32
    cfg_1: u32
    cfg_2: u32
    cfg_3: u32
    cfg_4: u32
    cfg_5: u32
    cfg_6: u32
    cfg_7: u32
    cfg_8: u32
    cfg_9: u32
    cfg_10: u32
    cfg_11: u32
    cfg_12: u32
    cfg_13: u32
    cfg_14: u32
    cfg_15: u32
    addr_0: i64
    addr_1: i64
    addr_2: i64
    addr_3: i64
    addr_4: i64
    addr_5: i64
    addr_6: i64
    addr_7: i64
    addr_8: i64
    addr_9: i64
    addr_10: i64
    addr_11: i64
    addr_12: i64
    addr_13: i64
    addr_14: i64
    addr_15: i64

struct PmpCheckResult64:
    matched: bool
    allowed: bool
    matched_index: u32

struct PmpAccessGateResult64:
    bus_valid: bool
    paddr: i64
    fault: bool
    fault_cause: i64
    matched_index: u32

@hardware
fn pmp64_check_entry(cfg: u32, prev_addr: i64, addr: i64, first: i64, last: i64, access_kind: u32, effective_priv: u32) -> (matched: bool, allowed: bool):
    """Check one PMP entry against an already validated inclusive byte range."""
    val address_mode = cfg & PMP64_ADDRESS_MASK
    if address_mode == PMP64_ADDRESS_OFF:
        return (matched: false, allowed: false)

    if addr < 0 or addr > PMP64_MAX_PMPADDR:
        return (matched: true, allowed: false)

    var region_first: i64 = 0
    var region_top: i64 = 0
    if address_mode == PMP64_ADDRESS_TOR:
        if prev_addr < 0 or prev_addr > PMP64_MAX_PMPADDR:
            return (matched: true, allowed: false)
        region_first = prev_addr << 2
        region_top = addr << 2
    else if address_mode == PMP64_ADDRESS_NA4:
        region_first = addr << 2
        region_top = region_first + 4
    else:
        # For NAPOT, addr & (addr + 1) clears all trailing one bits.
        # addr xor (addr + 1) derives the region size without a variable shift.
        val next_addr = addr + 1
        region_first = (addr & next_addr) << 2
        val differing_bits = addr ^ next_addr
        val region_size = (differing_bits + 1) << 2
        region_top = region_first + region_size
        if region_size <= 0:
            return (matched: true, allowed: false)
        if region_top > PMP64_PADDR_LIMIT:
            region_top = PMP64_PADDR_LIMIT

    if region_top <= region_first:
        return (matched: false, allowed: false)

    val overlaps = first < region_top and last >= region_first
    if not overlaps:
        return (matched: false, allowed: false)

    val contained = first >= region_first and last < region_top
    if not contained:
        return (matched: true, allowed: false)

    val valid_privilege = effective_priv == PMP64_PRIV_U or effective_priv == PMP64_PRIV_S or effective_priv == PMP64_PRIV_M
    if access_kind > PMP64_ACCESS_WRITE or not valid_privilege:
        return (matched: true, allowed: false)

    val locked = (cfg & PMP64_LOCKED) != 0
    if effective_priv == PMP64_PRIV_M and not locked:
        return (matched: true, allowed: true)

    val readable = (cfg & PMP64_READ) != 0
    val writable = (cfg & PMP64_WRITE) != 0
    val executable = (cfg & PMP64_EXECUTE) != 0
    if writable and not readable:
        return (matched: true, allowed: false)
    if access_kind == PMP64_ACCESS_EXECUTE:
        return (matched: true, allowed: executable)
    if access_kind == PMP64_ACCESS_READ:
        return (matched: true, allowed: readable)
    if access_kind == PMP64_ACCESS_WRITE:
        return (matched: true, allowed: writable)
    (matched: true, allowed: false)

@hardware
fn pmp64_check16(entries: PmpEntries64, paddr: i64, size_bytes: u32, access_kind: u32, effective_priv: u32) -> PmpCheckResult64:
    """Apply sixteen PMP entries in architectural priority order."""
    val valid_privilege = effective_priv == PMP64_PRIV_U or effective_priv == PMP64_PRIV_S or effective_priv == PMP64_PRIV_M
    if size_bytes == 0 or size_bytes > 8 or access_kind > PMP64_ACCESS_WRITE or not valid_privilege:
        return PmpCheckResult64(matched: false, allowed: false, matched_index: PMP64_NO_MATCH)
    if paddr < 0 or paddr > PMP64_MAX_PADDR:
        return PmpCheckResult64(matched: false, allowed: false, matched_index: PMP64_NO_MATCH)

    val last = paddr + (size_bytes as i64) - 1
    if last < paddr or last > PMP64_MAX_PADDR:
        return PmpCheckResult64(matched: false, allowed: false, matched_index: PMP64_NO_MATCH)

    val r0 = pmp64_check_entry(entries.cfg_0, 0, entries.addr_0, paddr, last, access_kind, effective_priv)
    if r0.matched:
        return PmpCheckResult64(matched: true, allowed: r0.allowed, matched_index: 0)
    val r1 = pmp64_check_entry(entries.cfg_1, entries.addr_0, entries.addr_1, paddr, last, access_kind, effective_priv)
    if r1.matched:
        return PmpCheckResult64(matched: true, allowed: r1.allowed, matched_index: 1)
    val r2 = pmp64_check_entry(entries.cfg_2, entries.addr_1, entries.addr_2, paddr, last, access_kind, effective_priv)
    if r2.matched:
        return PmpCheckResult64(matched: true, allowed: r2.allowed, matched_index: 2)
    val r3 = pmp64_check_entry(entries.cfg_3, entries.addr_2, entries.addr_3, paddr, last, access_kind, effective_priv)
    if r3.matched:
        return PmpCheckResult64(matched: true, allowed: r3.allowed, matched_index: 3)
    val r4 = pmp64_check_entry(entries.cfg_4, entries.addr_3, entries.addr_4, paddr, last, access_kind, effective_priv)
    if r4.matched:
        return PmpCheckResult64(matched: true, allowed: r4.allowed, matched_index: 4)
    val r5 = pmp64_check_entry(entries.cfg_5, entries.addr_4, entries.addr_5, paddr, last, access_kind, effective_priv)
    if r5.matched:
        return PmpCheckResult64(matched: true, allowed: r5.allowed, matched_index: 5)
    val r6 = pmp64_check_entry(entries.cfg_6, entries.addr_5, entries.addr_6, paddr, last, access_kind, effective_priv)
    if r6.matched:
        return PmpCheckResult64(matched: true, allowed: r6.allowed, matched_index: 6)
    val r7 = pmp64_check_entry(entries.cfg_7, entries.addr_6, entries.addr_7, paddr, last, access_kind, effective_priv)
    if r7.matched:
        return PmpCheckResult64(matched: true, allowed: r7.allowed, matched_index: 7)
    val r8 = pmp64_check_entry(entries.cfg_8, entries.addr_7, entries.addr_8, paddr, last, access_kind, effective_priv)
    if r8.matched:
        return PmpCheckResult64(matched: true, allowed: r8.allowed, matched_index: 8)
    val r9 = pmp64_check_entry(entries.cfg_9, entries.addr_8, entries.addr_9, paddr, last, access_kind, effective_priv)
    if r9.matched:
        return PmpCheckResult64(matched: true, allowed: r9.allowed, matched_index: 9)
    val r10 = pmp64_check_entry(entries.cfg_10, entries.addr_9, entries.addr_10, paddr, last, access_kind, effective_priv)
    if r10.matched:
        return PmpCheckResult64(matched: true, allowed: r10.allowed, matched_index: 10)
    val r11 = pmp64_check_entry(entries.cfg_11, entries.addr_10, entries.addr_11, paddr, last, access_kind, effective_priv)
    if r11.matched:
        return PmpCheckResult64(matched: true, allowed: r11.allowed, matched_index: 11)
    val r12 = pmp64_check_entry(entries.cfg_12, entries.addr_11, entries.addr_12, paddr, last, access_kind, effective_priv)
    if r12.matched:
        return PmpCheckResult64(matched: true, allowed: r12.allowed, matched_index: 12)
    val r13 = pmp64_check_entry(entries.cfg_13, entries.addr_12, entries.addr_13, paddr, last, access_kind, effective_priv)
    if r13.matched:
        return PmpCheckResult64(matched: true, allowed: r13.allowed, matched_index: 13)
    val r14 = pmp64_check_entry(entries.cfg_14, entries.addr_13, entries.addr_14, paddr, last, access_kind, effective_priv)
    if r14.matched:
        return PmpCheckResult64(matched: true, allowed: r14.allowed, matched_index: 14)
    val r15 = pmp64_check_entry(entries.cfg_15, entries.addr_14, entries.addr_15, paddr, last, access_kind, effective_priv)
    if r15.matched:
        return PmpCheckResult64(matched: true, allowed: r15.allowed, matched_index: 15)

    val no_match_allowed = effective_priv == PMP64_PRIV_M
    PmpCheckResult64(matched: false, allowed: no_match_allowed, matched_index: PMP64_NO_MATCH)

@hardware
fn pmp64_gate_access(entries: PmpEntries64, paddr: i64, size_bytes: u32, access_kind: u32, effective_priv: u32, translation_fault: bool, translation_fault_cause: i64) -> PmpAccessGateResult64:
    """Suppress bus issue on translation or PMP failure."""
    if translation_fault:
        return PmpAccessGateResult64(bus_valid: false, paddr: paddr, fault: true, fault_cause: translation_fault_cause, matched_index: PMP64_NO_MATCH)

    val protection = pmp64_check16(entries, paddr, size_bytes, access_kind, effective_priv)
    if not protection.allowed:
        val cause = if access_kind == PMP64_ACCESS_EXECUTE:
            PMP64_CAUSE_INSN_ACCESS_FAULT
        else if access_kind == PMP64_ACCESS_READ:
            PMP64_CAUSE_LOAD_ACCESS_FAULT
        else if access_kind == PMP64_ACCESS_WRITE:
            PMP64_CAUSE_STORE_ACCESS_FAULT
        else:
            0
        return PmpAccessGateResult64(bus_valid: false, paddr: paddr, fault: true, fault_cause: cause, matched_index: protection.matched_index)

    PmpAccessGateResult64(bus_valid: true, paddr: paddr, fault: false, fault_cause: 0, matched_index: protection.matched_index)
