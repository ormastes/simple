# RV64 Sv39 address decomposition.
#
# This owner is intentionally a small, combinational compiler boundary.  It
# does not claim to implement the page-table walker or PMP enforcement.

@hardware
fn sv39_full_vpn(vaddr: i64) -> i64:
    """Extract VPN[2]:VPN[1]:VPN[0] (virtual-address bits [38:12])."""
    (vaddr >> 12) & 0x7FFFFFF
