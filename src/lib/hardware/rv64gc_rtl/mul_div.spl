# ============================================================================
# RV64GC RTL M Extension — Multi-Cycle Multiply/Divide Unit
# ============================================================================
#
# Implements the RISC-V M extension for RV64GC.  Multi-cycle functional
# unit with busy/ready handshake.
#
# Operations: MUL, MULH, MULHSU, MULHU, DIV, DIVU, REM, REMU
# W-suffix:   MULW, DIVW, DIVUW, REMW, REMUW
#
# All operands and results are i64.  Pure functions returning new state.
#
# VHDL synthesizable subset: i64, u32, bool, structs only.
# ============================================================================

use std.hardware.rv64gc_rtl.pkg.{MULDIV_MUL, MULDIV_MULH, MULDIV_MULHSU, MULDIV_MULHU}
use std.hardware.rv64gc_rtl.pkg.{MULDIV_DIV, MULDIV_DIVU, MULDIV_REM, MULDIV_REMU}
use std.hardware.rv64gc_rtl.pkg.{MULDIV_MULW, MULDIV_DIVW, MULDIV_DIVUW, MULDIV_REMW, MULDIV_REMUW}

# ============================================================================
# Mul/Div State
# ============================================================================

struct MulDivState:
    """Multi-cycle multiply/divide unit state."""
    busy: bool       # Unit is executing an operation
    op: i64          # Operation code (MULDIV_*)
    a: i64           # Operand A
    b: i64           # Operand B
    result: i64      # Computed result (valid when busy=false after start)
    cycles_left: u32 # Remaining cycles until done

# ============================================================================
# Helper — sign-extend 32-bit to 64-bit
# ============================================================================

fn muldiv_sign_extend_32(value: i64) -> i64:
    """Sign-extend bit 31 into bits [63:32]."""
    val low32 = value & 0xFFFFFFFF
    val sign_bit = low32 & 0x80000000
    if sign_bit != 0:
        low32 | 0xFFFFFFFF00000000
    else:
        low32

# ============================================================================
# Create — initial idle state
# ============================================================================

fn mul_div_create() -> MulDivState:
    """Create an idle mul/div unit."""
    MulDivState(busy: false, op: 0, a: 0, b: 0, result: 0, cycles_left: 0)

# ============================================================================
# Start — begin a multiply or divide operation
# ============================================================================

fn mul_div_start(op: i64, a: i64, b: i64) -> MulDivState:
    """Start a mul/div operation. Sets busy and latches operands.
    Multiply takes 4 cycles, divide takes 8 cycles (simplified model)."""
    var cycles: u32 = 4
    if (op == MULDIV_DIV or op == MULDIV_DIVU or op == MULDIV_REM or
        op == MULDIV_REMU or op == MULDIV_DIVW or op == MULDIV_DIVUW or
        op == MULDIV_REMW or op == MULDIV_REMUW):
        cycles = 8

    MulDivState(busy: true, op: op, a: a, b: b, result: 0, cycles_left: cycles)

# ============================================================================
# Tick — advance one cycle
# ============================================================================

fn mul_div_tick(state: MulDivState) -> MulDivState:
    """Advance the mul/div unit by one clock cycle.
    When cycles_left reaches 0, compute the result and clear busy."""
    if state.busy == false:
        return state

    if state.cycles_left > 1:
        var out = state
        out.cycles_left = state.cycles_left - 1
        return out

    # Last cycle — compute result
    val op = state.op
    val a = state.a
    val b = state.b
    var res: i64 = 0

    if op == MULDIV_MUL:
        # Low 64 bits of a * b
        res = a * b

    else if op == MULDIV_MULH:
        # Upper 64 bits of signed * signed (simplified: use low product)
        # In real RTL this would use a 128-bit multiplier
        res = a * b

    else if op == MULDIV_MULHSU:
        # Upper 64 bits of signed * unsigned (simplified)
        res = a * b

    else if op == MULDIV_MULHU:
        # Upper 64 bits of unsigned * unsigned (simplified)
        res = a * b

    else if op == MULDIV_DIV:
        # Signed division
        if b == 0:
            res = -1   # Division by zero returns -1
        else:
            res = a / b

    else if op == MULDIV_DIVU:
        # Unsigned division (approximated via signed for simulation)
        if b == 0:
            res = -1   # All ones
        else:
            res = a / b

    else if op == MULDIV_REM:
        # Signed remainder
        if b == 0:
            res = a   # Remainder of x/0 = x
        else:
            res = a - (a / b) * b

    else if op == MULDIV_REMU:
        # Unsigned remainder (approximated)
        if b == 0:
            res = a
        else:
            res = a - (a / b) * b

    else if op == MULDIV_MULW:
        # Low 32 bits of (a[31:0] * b[31:0]), sign-extended
        val a32 = muldiv_sign_extend_32(a)
        val b32 = muldiv_sign_extend_32(b)
        res = muldiv_sign_extend_32(a32 * b32)

    else if op == MULDIV_DIVW:
        # Signed 32-bit division, sign-extended
        val a32 = muldiv_sign_extend_32(a)
        val b32 = muldiv_sign_extend_32(b)
        if b32 == 0:
            res = -1
        else:
            res = muldiv_sign_extend_32(a32 / b32)

    else if op == MULDIV_DIVUW:
        # Unsigned 32-bit division, sign-extended
        val a32 = a & 0xFFFFFFFF
        val b32 = b & 0xFFFFFFFF
        if b32 == 0:
            res = -1
        else:
            res = muldiv_sign_extend_32(a32 / b32)

    else if op == MULDIV_REMW:
        # Signed 32-bit remainder, sign-extended
        val a32 = muldiv_sign_extend_32(a)
        val b32 = muldiv_sign_extend_32(b)
        if b32 == 0:
            res = muldiv_sign_extend_32(a32)
        else:
            res = muldiv_sign_extend_32(a32 - (a32 / b32) * b32)

    else if op == MULDIV_REMUW:
        # Unsigned 32-bit remainder, sign-extended
        val a32 = a & 0xFFFFFFFF
        val b32 = b & 0xFFFFFFFF
        if b32 == 0:
            res = muldiv_sign_extend_32(a32)
        else:
            res = muldiv_sign_extend_32(a32 - (a32 / b32) * b32)

    MulDivState(busy: false, op: op, a: a, b: b, result: res, cycles_left: 0)

# ============================================================================
# Ready — check if unit has completed
# ============================================================================

fn mul_div_ready(state: MulDivState) -> bool:
    """Returns true when the mul/div unit is idle (not busy)."""
    state.busy == false
