# ============================================================================
# RV64GC RTL MMU — Sv39 Three-Level Page Table Walker
# ============================================================================
#
# Implements the RISC-V Sv39 virtual memory translation unit for RV64.
# All operations are pure functions returning new state — suitable for
# synthesizable RTL.
#
# Sv39 virtual address (39-bit):
#   VPN[2] = bits [38:30]  (9 bits)
#   VPN[1] = bits [29:21]  (9 bits)
#   VPN[0] = bits [20:12]  (9 bits)
#   Offset = bits [11:0]   (12 bits)
#
# Sv39 PTE (64-bit):
#   PPN[2] = bits [53:28]  (26 bits)
#   PPN[1] = bits [27:19]  (9 bits)
#   PPN[0] = bits [18:10]  (9 bits)
#   RSW    = bits [9:8]    (2 bits, reserved)
#   Flags  = bits [7:0]    (D,A,G,U,X,W,R,V)
#
# Translation modes (from satp register, RV64):
#   MODE=0 (Bare) — no translation
#   MODE=8 (Sv39) — three-level page table walk
#
# M-mode always bypasses translation (identity map).
#
# VHDL synthesizable subset: i64, u32, bool, structs only.
# ============================================================================

use std.hardware.soc_rtl.ram.{RamState, ram_read}
use std.hardware.rv64gc_rtl.sv39_address.{sv39_full_vpn, sv39_is_canonical}

# ============================================================================
# Constants
# ============================================================================

val MMU39_TLB_SIZE: u32     = 16    # Number of TLB entries
val PAGE_SIZE_64: i64       = 4096  # 4 KiB
val PAGE_OFFSET_BITS_64: i64 = 12
val VPN_BITS_SV39: i64      = 9
val PTE_SIZE_64: i64         = 8    # 8 bytes per PTE (64-bit)

# SATP mode values for RV64
val SATP_MODE_BARE: i64 = 0
val SATP_MODE_SV39: i64 = 8

# PTE flag bit positions (same as Sv32)
val PTE64_V_BIT: i64 = 0   # Valid
val PTE64_R_BIT: i64 = 1   # Readable
val PTE64_W_BIT: i64 = 2   # Writable
val PTE64_X_BIT: i64 = 3   # Executable
val PTE64_U_BIT: i64 = 4   # User accessible
val PTE64_G_BIT: i64 = 5   # Global
val PTE64_A_BIT: i64 = 6   # Accessed
val PTE64_D_BIT: i64 = 7   # Dirty

# PTE flag masks
val PTE64_V_MASK: i64 = 1   # bit 0
val PTE64_R_MASK: i64 = 2   # bit 1
val PTE64_W_MASK: i64 = 4   # bit 2
val PTE64_X_MASK: i64 = 8   # bit 3
val PTE64_U_MASK: i64 = 16  # bit 4
val PTE64_G_MASK: i64 = 32  # bit 5
val PTE64_A_MASK: i64 = 64  # bit 6
val PTE64_D_MASK: i64 = 128 # bit 7

# Access type codes
val ACCESS_FETCH_64: u32 = 0
val ACCESS_LOAD_64: u32  = 1
val ACCESS_STORE_64: u32 = 2

# Privilege levels
val PRIV_U_64: u32 = 0   # User
val PRIV_S_64: u32 = 1   # Supervisor
val PRIV_M_64: u32 = 3   # Machine

# Page fault cause codes
val CAUSE_INSN_PAGE_FAULT_64: i64  = 12
val CAUSE_LOAD_PAGE_FAULT_64: i64  = 13
val CAUSE_STORE_PAGE_FAULT_64: i64 = 15

# ============================================================================
# TLB Entry (64-bit)
# ============================================================================

struct TlbEntry64:
    """Single TLB entry caching a virtual-to-physical mapping."""
    vpn: i64      # Virtual page number (VPN[2]:VPN[1]:VPN[0], 27 bits)
    ppn: i64      # Physical page number (44 bits)
    flags: i64    # PTE flags (lower 8 bits)
    asid: u32     # Address-space identifier at refill time
    level: u32    # Leaf level: 0=4 KiB, 1=2 MiB, 2=1 GiB
    valid: bool   # Entry is valid

# ============================================================================
# MMU State (Sv39)
# ============================================================================

struct MmuState64:
    """Sv39 MMU state with 16-entry TLB."""
    tlb_0: TlbEntry64
    tlb_1: TlbEntry64
    tlb_2: TlbEntry64
    tlb_3: TlbEntry64
    tlb_4: TlbEntry64
    tlb_5: TlbEntry64
    tlb_6: TlbEntry64
    tlb_7: TlbEntry64
    tlb_8: TlbEntry64
    tlb_9: TlbEntry64
    tlb_10: TlbEntry64
    tlb_11: TlbEntry64
    tlb_12: TlbEntry64
    tlb_13: TlbEntry64
    tlb_14: TlbEntry64
    tlb_15: TlbEntry64
    tlb_count: u32     # FIFO write pointer (wraps at MMU39_TLB_SIZE)
    satp_mode: i64     # 0=Bare, 8=Sv39
    satp_asid: u32     # Current 16-bit ASID
    satp_ppn: i64      # Root page table PPN (44 bits)

# ============================================================================
# Translation Result
# ============================================================================

struct MmuTranslateResult64:
    """Result of a virtual-to-physical address translation."""
    paddr: i64         # Translated physical address
    fault: bool        # True if a page fault occurred
    fault_cause: i64   # 12=insn, 13=load, 15=store page fault

# ============================================================================
# TLB Lookup Result
# ============================================================================

struct TlbLookupResult64:
    """Result of searching the TLB."""
    ppn: i64      # Physical page number (valid only if hit)
    flags: i64    # PTE flags (valid only if hit)
    level: u32    # Cached leaf level
    hit: bool     # True if TLB contains a matching valid entry

# ============================================================================
# Create — initial MMU state (Bare mode, empty TLB)
# ============================================================================

fn mmu64_create() -> MmuState64:
    """Create initial MMU state.  Translation disabled (Bare mode)."""
    val empty = TlbEntry64(vpn: 0, ppn: 0, flags: 0, asid: 0, level: 0, valid: false)
    MmuState64(
        tlb_0: empty, tlb_1: empty, tlb_2: empty, tlb_3: empty,
        tlb_4: empty, tlb_5: empty, tlb_6: empty, tlb_7: empty,
        tlb_8: empty, tlb_9: empty, tlb_10: empty, tlb_11: empty,
        tlb_12: empty, tlb_13: empty, tlb_14: empty, tlb_15: empty,
        tlb_count: 0,
        satp_mode: 0,
        satp_asid: 0,
        satp_ppn: 0
    )

# ============================================================================
# Set SATP — parse mode and ppn from satp CSR value
# ============================================================================

@hardware
fn mmu64_set_satp(state: MmuState64, satp_val: i64) -> MmuState64:
    """Parse the SATP register and update MMU configuration.
    RV64 SATP layout:
      bits [63:60] — MODE (0=Bare, 8=Sv39)
      bits [59:44] — ASID
      bits [43:0]  — PPN  (44 bits)"""
    val mode = (satp_val >> 60) & 0xF
    if mode != SATP_MODE_BARE and mode != SATP_MODE_SV39:
        return state
    var out = state
    out.satp_mode = mode
    out.satp_asid = ((satp_val >> 44) & 0xFFFF) as u32
    out.satp_ppn = satp_val & 0x00000FFFFFFFFFFF
    out

# ============================================================================
# TLB Lookup
# ============================================================================

@hardware
fn mmu64_tlb_entry_matches(entry: TlbEntry64, vpn: i64, asid: u32) -> bool:
    if not entry.valid:
        return false
    if (entry.flags & PTE64_G_MASK) == 0 and entry.asid != asid:
        return false
    if entry.level == 2:
        return (entry.vpn >> 18) == (vpn >> 18)
    if entry.level == 1:
        return (entry.vpn >> 9) == (vpn >> 9)
    entry.level == 0 and entry.vpn == vpn

@hardware
fn mmu64_tlb_lookup(state: MmuState64, vpn: i64) -> TlbLookupResult64:
    """Search the fixed TLB in priority order without dynamic indexing."""
    if mmu64_tlb_entry_matches(state.tlb_0, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_0.ppn, flags: state.tlb_0.flags, level: state.tlb_0.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_1, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_1.ppn, flags: state.tlb_1.flags, level: state.tlb_1.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_2, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_2.ppn, flags: state.tlb_2.flags, level: state.tlb_2.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_3, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_3.ppn, flags: state.tlb_3.flags, level: state.tlb_3.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_4, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_4.ppn, flags: state.tlb_4.flags, level: state.tlb_4.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_5, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_5.ppn, flags: state.tlb_5.flags, level: state.tlb_5.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_6, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_6.ppn, flags: state.tlb_6.flags, level: state.tlb_6.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_7, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_7.ppn, flags: state.tlb_7.flags, level: state.tlb_7.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_8, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_8.ppn, flags: state.tlb_8.flags, level: state.tlb_8.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_9, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_9.ppn, flags: state.tlb_9.flags, level: state.tlb_9.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_10, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_10.ppn, flags: state.tlb_10.flags, level: state.tlb_10.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_11, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_11.ppn, flags: state.tlb_11.flags, level: state.tlb_11.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_12, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_12.ppn, flags: state.tlb_12.flags, level: state.tlb_12.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_13, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_13.ppn, flags: state.tlb_13.flags, level: state.tlb_13.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_14, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_14.ppn, flags: state.tlb_14.flags, level: state.tlb_14.level, hit: true)
    if mmu64_tlb_entry_matches(state.tlb_15, vpn, state.satp_asid):
        return TlbLookupResult64(ppn: state.tlb_15.ppn, flags: state.tlb_15.flags, level: state.tlb_15.level, hit: true)
    TlbLookupResult64(ppn: 0, flags: 0, level: 0, hit: false)

# ============================================================================
# TLB Insert — FIFO replacement
# ============================================================================

@hardware
fn mmu64_tlb_write_entry(state: MmuState64, idx: u32, entry: TlbEntry64) -> MmuState64:
    """Write a TLB entry by index (flat field access)."""
    var out = state
    if idx == 0:
        out.tlb_0 = entry
    else if idx == 1:
        out.tlb_1 = entry
    else if idx == 2:
        out.tlb_2 = entry
    else if idx == 3:
        out.tlb_3 = entry
    else if idx == 4:
        out.tlb_4 = entry
    else if idx == 5:
        out.tlb_5 = entry
    else if idx == 6:
        out.tlb_6 = entry
    else if idx == 7:
        out.tlb_7 = entry
    else if idx == 8:
        out.tlb_8 = entry
    else if idx == 9:
        out.tlb_9 = entry
    else if idx == 10:
        out.tlb_10 = entry
    else if idx == 11:
        out.tlb_11 = entry
    else if idx == 12:
        out.tlb_12 = entry
    else if idx == 13:
        out.tlb_13 = entry
    else if idx == 14:
        out.tlb_14 = entry
    else if idx == 15:
        out.tlb_15 = entry
    out

@hardware
fn mmu64_tlb_insert_level(state: MmuState64, vpn: i64, ppn: i64, flags: i64, level: u32) -> MmuState64:
    """Insert a 4 KiB, 2 MiB, or 1 GiB leaf using FIFO replacement."""
    val entry = TlbEntry64(vpn: vpn, ppn: ppn, flags: flags, asid: state.satp_asid, level: level, valid: true)
    val idx = state.tlb_count & 0xF
    var out = mmu64_tlb_write_entry(state, idx, entry)
    out.tlb_count = (state.tlb_count + 1) & 0xF
    out

fn mmu64_tlb_insert(state: MmuState64, vpn: i64, ppn: i64, flags: i64) -> MmuState64:
    """Compatibility wrapper for a 4 KiB TLB entry."""
    mmu64_tlb_insert_level(state, vpn, ppn, flags, 0)

# ============================================================================
# TLB Flush — clear all entries (for SFENCE.VMA)
# ============================================================================

@hardware
fn mmu64_flush(state: MmuState64) -> MmuState64:
    """Clear all TLB entries.  Called on SFENCE.VMA."""
    val empty = TlbEntry64(vpn: 0, ppn: 0, flags: 0, asid: 0, level: 0, valid: false)
    var out = state
    out.tlb_0 = empty
    out.tlb_1 = empty
    out.tlb_2 = empty
    out.tlb_3 = empty
    out.tlb_4 = empty
    out.tlb_5 = empty
    out.tlb_6 = empty
    out.tlb_7 = empty
    out.tlb_8 = empty
    out.tlb_9 = empty
    out.tlb_10 = empty
    out.tlb_11 = empty
    out.tlb_12 = empty
    out.tlb_13 = empty
    out.tlb_14 = empty
    out.tlb_15 = empty
    out.tlb_count = 0
    out

# ============================================================================
# Helpers — Sv39 address field extraction
# ============================================================================

@hardware
fn sv39_vpn2(vaddr: i64) -> i64:
    """Extract VPN[2] from a Sv39 virtual address (bits [38:30])."""
    (vaddr >> 30) & 0x1FF

@hardware
fn sv39_vpn1(vaddr: i64) -> i64:
    """Extract VPN[1] from a Sv39 virtual address (bits [29:21])."""
    (vaddr >> 21) & 0x1FF

@hardware
fn sv39_vpn0(vaddr: i64) -> i64:
    """Extract VPN[0] from a Sv39 virtual address (bits [20:12])."""
    (vaddr >> 12) & 0x1FF

@hardware
fn sv39_offset(vaddr: i64) -> i64:
    """Extract the 12-bit page offset from a virtual address."""
    vaddr & 0xFFF

@hardware
fn pte64_ppn2(pte: i64) -> i64:
    """Extract PPN[2] from an Sv39 PTE (bits [53:28])."""
    (pte >> 28) & 0x3FFFFFF

@hardware
fn pte64_ppn1(pte: i64) -> i64:
    """Extract PPN[1] from an Sv39 PTE (bits [27:19])."""
    (pte >> 19) & 0x1FF

@hardware
fn pte64_ppn0(pte: i64) -> i64:
    """Extract PPN[0] from an Sv39 PTE (bits [18:10])."""
    (pte >> 10) & 0x1FF

@hardware
fn pte64_ppn_full(pte: i64) -> i64:
    """Extract the full 44-bit PPN from an Sv39 PTE (bits [53:10])."""
    (pte >> 10) & 0x00000FFFFFFFFFFF

@hardware
fn pte64_flags_extract(pte: i64) -> i64:
    """Extract the 8-bit flags from an Sv39 PTE (bits [7:0])."""
    pte & 0xFF

# ============================================================================
# Fault cause from access type
# ============================================================================

@hardware
fn fault64_cause_for(access_type: u32) -> i64:
    """Return the page-fault exception cause code for the given access type."""
    if access_type == ACCESS_FETCH_64:
        return CAUSE_INSN_PAGE_FAULT_64
    if access_type == ACCESS_STORE_64:
        return CAUSE_STORE_PAGE_FAULT_64
    CAUSE_LOAD_PAGE_FAULT_64

# ============================================================================
# Permission Check
# ============================================================================

@hardware
fn pte64_check_perms_ext(flags: i64, access_type: u32, privilege: u32, sum: bool, mxr: bool) -> bool:
    """Check leaf permissions using the Svade fault-on-clear A/D policy."""

    if (flags & PTE64_V_MASK) == 0:
        return false

    if (flags & (PTE64_R_MASK | PTE64_W_MASK | PTE64_X_MASK)) == 0:
        return false

    val w_set = (flags & PTE64_W_MASK) != 0
    val r_set = (flags & PTE64_R_MASK) != 0
    if w_set and r_set == false:
        return false

    val is_user_page = (flags & PTE64_U_MASK) != 0
    if privilege == PRIV_U_64 and is_user_page == false:
        return false
    if privilege == PRIV_S_64 and is_user_page and (access_type == ACCESS_FETCH_64 or not sum):
        return false
    if privilege != PRIV_U_64 and privilege != PRIV_S_64:
        return false

    if (flags & PTE64_A_MASK) == 0:
        return false
    if access_type == ACCESS_STORE_64 and (flags & PTE64_D_MASK) == 0:
        return false

    if access_type == ACCESS_FETCH_64:
        if (flags & PTE64_X_MASK) == 0:
            return false
    else if access_type == ACCESS_LOAD_64:
        if (flags & PTE64_R_MASK) == 0 and (not mxr or (flags & PTE64_X_MASK) == 0):
            return false
    else if access_type == ACCESS_STORE_64:
        if (flags & PTE64_W_MASK) == 0:
            return false

    else:
        return false

    true

fn pte64_check_perms(flags: i64, access_type: u32, privilege: u32) -> bool:
    pte64_check_perms_ext(flags, access_type, privilege, false, false)

@hardware
fn mmu64_tlb_paddr(vaddr: i64, ppn: i64, level: u32) -> i64:
    if level == 2:
        return (((ppn >> 18) & 0x3FFFFFF) << 30) | (sv39_vpn1(vaddr) << 21) | (sv39_vpn0(vaddr) << 12) | sv39_offset(vaddr)
    if level == 1:
        return (((ppn >> 18) & 0x3FFFFFF) << 30) | (((ppn >> 9) & 0x1FF) << 21) | (sv39_vpn0(vaddr) << 12) | sv39_offset(vaddr)
    (ppn << PAGE_OFFSET_BITS_64) | sv39_offset(vaddr)

# ============================================================================
# Read 64-bit PTE from RAM (two 32-bit reads)
# ============================================================================

fn read_pte64_from_ram(ram: RamState, addr: i64) -> i64:
    """Read a 64-bit PTE from RAM by performing two 32-bit reads.
    Assumes little-endian byte order."""
    val addr_u32 = addr & 0xFFFFFFFF
    val lo: i64 = ram_read(ram, addr_u32) as i64
    val hi: i64 = ram_read(ram, addr_u32 + 4) as i64
    (hi << 32) | (lo & 0xFFFFFFFF)

# ============================================================================
# Translate — main entry point
# ============================================================================

fn mmu64_translate_ram_test_adapter(state: MmuState64, vaddr: i64, access_type: u32, privilege: u32, ram: RamState) -> MmuTranslateResult64:
    """TEST ONLY: translate through direct RamState reads.

    access_type: 0=fetch, 1=load, 2=store
    privilege: 0=U, 1=S, 3=M

    If satp_mode==0 (Bare) or privilege==M, return identity mapping.
    Otherwise perform Sv39 three-level page table walk with TLB."""

    if access_type > ACCESS_STORE_64:
        return MmuTranslateResult64(paddr: 0, fault: true, fault_cause: fault64_cause_for(access_type))
    if privilege != PRIV_U_64 and privilege != PRIV_S_64 and privilege != PRIV_M_64:
        return MmuTranslateResult64(paddr: 0, fault: true, fault_cause: fault64_cause_for(access_type))

    # M-mode or Bare mode — identity mapping
    if privilege == PRIV_M_64 or state.satp_mode == SATP_MODE_BARE:
        return MmuTranslateResult64(paddr: vaddr, fault: false, fault_cause: 0)

    if state.satp_mode != SATP_MODE_SV39 or not sv39_is_canonical(vaddr):
        return MmuTranslateResult64(paddr: 0, fault: true, fault_cause: fault64_cause_for(access_type))

    # ── TLB lookup ──────────────────────────────────────────────────────
    val vpn = sv39_full_vpn(vaddr)
    val tlb_result = mmu64_tlb_lookup(state, vpn)
    if tlb_result.hit:
        if pte64_check_perms(tlb_result.flags, access_type, privilege) == false:
            return MmuTranslateResult64(
                paddr: 0,
                fault: true,
                fault_cause: fault64_cause_for(access_type)
            )
        val paddr = mmu64_tlb_paddr(vaddr, tlb_result.ppn, tlb_result.level)
        return MmuTranslateResult64(paddr: paddr, fault: false, fault_cause: 0)

    # ── Page table walk (three levels) ──────────────────────────────────
    val vpn2 = sv39_vpn2(vaddr)
    val vpn1 = sv39_vpn1(vaddr)
    val vpn0 = sv39_vpn0(vaddr)
    val offset = sv39_offset(vaddr)

    # Level 2: read PTE from root page table
    val l2_pte_addr = (state.satp_ppn * PAGE_SIZE_64) + (vpn2 * PTE_SIZE_64)
    val l2_pte = read_pte64_from_ram(ram, l2_pte_addr)

    if (l2_pte & PTE64_V_MASK) == 0:
        return MmuTranslateResult64(
            paddr: 0,
            fault: true,
            fault_cause: fault64_cause_for(access_type)
        )

    # Check if level-2 is a leaf (gigapage — 1 GiB)
    val l2_is_leaf = (l2_pte & (PTE64_R_MASK | PTE64_W_MASK | PTE64_X_MASK)) != 0
    if l2_is_leaf:
        # Gigapage: PPN[1] and PPN[0] must be zero
        if pte64_ppn1(l2_pte) != 0 or pte64_ppn0(l2_pte) != 0:
            return MmuTranslateResult64(
                paddr: 0,
                fault: true,
                fault_cause: fault64_cause_for(access_type)
            )

        val l2_flags = pte64_flags_extract(l2_pte)
        if pte64_check_perms(l2_flags, access_type, privilege) == false:
            return MmuTranslateResult64(
                paddr: 0,
                fault: true,
                fault_cause: fault64_cause_for(access_type)
            )

        # Gigapage: paddr = PPN[2] << 30 | VPN[1] << 21 | VPN[0] << 12 | offset
        val giga_ppn2 = pte64_ppn2(l2_pte)
        val paddr = (giga_ppn2 << 30) | (vpn1 << 21) | (vpn0 << 12) | offset
        return MmuTranslateResult64(paddr: paddr, fault: false, fault_cause: 0)

    # Level 2 is a pointer to level-1 page table
    val l1_table_ppn = pte64_ppn_full(l2_pte)
    val l1_pte_addr = (l1_table_ppn * PAGE_SIZE_64) + (vpn1 * PTE_SIZE_64)
    val l1_pte = read_pte64_from_ram(ram, l1_pte_addr)

    if (l1_pte & PTE64_V_MASK) == 0:
        return MmuTranslateResult64(
            paddr: 0,
            fault: true,
            fault_cause: fault64_cause_for(access_type)
        )

    # Check if level-1 is a leaf (megapage — 2 MiB)
    val l1_is_leaf = (l1_pte & (PTE64_R_MASK | PTE64_W_MASK | PTE64_X_MASK)) != 0
    if l1_is_leaf:
        # Megapage: PPN[0] must be zero
        if pte64_ppn0(l1_pte) != 0:
            return MmuTranslateResult64(
                paddr: 0,
                fault: true,
                fault_cause: fault64_cause_for(access_type)
            )

        val l1_flags = pte64_flags_extract(l1_pte)
        if pte64_check_perms(l1_flags, access_type, privilege) == false:
            return MmuTranslateResult64(
                paddr: 0,
                fault: true,
                fault_cause: fault64_cause_for(access_type)
            )

        # Megapage: paddr = PPN[2] << 30 | PPN[1] << 21 | VPN[0] << 12 | offset
        val mega_ppn2 = pte64_ppn2(l1_pte)
        val mega_ppn1 = pte64_ppn1(l1_pte)
        val paddr = (mega_ppn2 << 30) | (mega_ppn1 << 21) | (vpn0 << 12) | offset
        return MmuTranslateResult64(paddr: paddr, fault: false, fault_cause: 0)

    # Level 1 is a pointer to level-0 page table
    val l0_table_ppn = pte64_ppn_full(l1_pte)
    val l0_pte_addr = (l0_table_ppn * PAGE_SIZE_64) + (vpn0 * PTE_SIZE_64)
    val l0_pte = read_pte64_from_ram(ram, l0_pte_addr)

    if (l0_pte & PTE64_V_MASK) == 0:
        return MmuTranslateResult64(
            paddr: 0,
            fault: true,
            fault_cause: fault64_cause_for(access_type)
        )

    # Level 0 must be a leaf
    val l0_is_leaf = (l0_pte & (PTE64_R_MASK | PTE64_W_MASK | PTE64_X_MASK)) != 0
    if l0_is_leaf == false:
        return MmuTranslateResult64(
            paddr: 0,
            fault: true,
            fault_cause: fault64_cause_for(access_type)
        )

    val l0_flags = pte64_flags_extract(l0_pte)
    if pte64_check_perms(l0_flags, access_type, privilege) == false:
        return MmuTranslateResult64(
            paddr: 0,
            fault: true,
            fault_cause: fault64_cause_for(access_type)
        )

    # 4K page: paddr = PPN << 12 | offset
    val leaf_ppn = pte64_ppn_full(l0_pte)
    val paddr = (leaf_ppn << PAGE_OFFSET_BITS_64) | offset
    MmuTranslateResult64(paddr: paddr, fault: false, fault_cause: 0)

# ============================================================================
# Spec-facing alias
# ============================================================================

fn mmu_sv39_init() -> MmuState64:
    mmu64_create()
