use std.hardware.rv64gc_rtl.core.{CoreState64, Core64CycleResult}
use std.hardware.rv64gc_rtl.core.{core64_init_single_master, core64_cycle}

struct Core64ClockedResult:
    """Registered product boundary plus its reset-initialization witness."""
    initialized: bool
    cycle: Core64CycleResult

@clocked(clk, reset_n)
@hardware
fn core64_clocked(initialized: bool, state: CoreState64, reset_addr: i64,
                  request_ready: bool, response_valid: bool,
                  response_error: bool,
                  response_data: i64) -> Core64ClockedResult:
    """Register one RV64 transition; zero reset initializes on the first edge."""
    if not initialized:
        return Core64ClockedResult(
            initialized: true,
            cycle: Core64CycleResult(
                state: core64_init_single_master(reset_addr),
                bus_valid: false,
                bus_addr: 0,
                bus_size: 1,
                bus_write: false,
                bus_wdata: 0,
                bus_is_pte: false,
                bus_atomic: false
            )
        )
    Core64ClockedResult(
        initialized: true,
        cycle: core64_cycle(state, request_ready, response_valid,
            response_error, response_data)
    )
