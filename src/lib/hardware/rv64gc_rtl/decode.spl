# ============================================================================
# RV64GC RTL Decoder — Combinational Instruction Decoder
# ============================================================================
#
# Adapts RV32I decoder for RV64GC.  Pure functions only (combinational).
# Extracts all fields from a 32-bit instruction, selects ALU op, generates
# control signals, and sign-extends immediates.
#
# Supports all RV64I instruction formats: R, I, S, B, U, J
# plus W-suffix instructions (OP_OP_IMM_32, OP_OP_32).
# ============================================================================

use std.hardware.rv64gc_rtl.pkg.{OP_LUI, OP_AUIPC, OP_JAL, OP_JALR}
use std.hardware.rv64gc_rtl.pkg.{OP_BRANCH, OP_LOAD, OP_STORE, OP_IMMED, OP_REG, OP_SYSTEM}
use std.hardware.rv64gc_rtl.pkg.{OP_OP_IMM_32, OP_OP_32, OP_AMO}
# ALU_ADD is the M-ext placeholder; the RV64-only W-suffix codes stay local.
use std.hardware.rv64gc_rtl.pkg.ALU_ADD
use std.hardware.rv64gc_rtl.pkg.{ALU_ADDW, ALU_SUBW, ALU_SLLW, ALU_SRLW, ALU_SRAW}
# Shared XLEN-neutral bit-assembly + ALU-op base (Wave-3 W3-2/W3-3). rv64 wraps
# the raw bits with its own 64-bit sign-extend; width is fixed at compile time.
use std.hardware.riscv_common.rtl_decode.{rtl_i_imm_bits, rtl_s_imm_bits, rtl_b_imm_bits}
use std.hardware.riscv_common.rtl_decode.{rtl_u_imm_bits, rtl_j_imm_bits, rtl_select_alu_op_base}

# ============================================================================
# Decode result — all decoder output signals
# ============================================================================

struct DecodeResult64:
    """All outputs from the combinational decoder."""
    opcode: u32       # bits [6:0]
    rd: u32           # bits [11:7]   — destination register
    rs1: u32          # bits [19:15]  — source register 1
    rs2: u32          # bits [24:20]  — source register 2
    funct3: u32       # bits [14:12]
    funct7: u32       # bits [31:25]
    imm: i64          # Sign-extended immediate (64-bit)
    alu_op: i64       # ALU operation code
    reg_write: bool   # Write-back to register file
    mem_read: bool    # Read from data memory
    mem_write: bool   # Write to data memory
    mem_to_reg: bool  # Load result goes to rd
    alu_src: bool     # true = ALU op_b from immediate; false = from rs2
    branch: bool      # Conditional branch instruction
    jump: bool        # JAL or JALR
    is_word_op: bool  # W-suffix instruction (operate on low 32 bits)
    is_amo: bool      # Atomic memory operation
    is_muldiv: bool   # M extension multiply/divide
    is_mret: bool     # Machine Return (0x30200073)
    is_sret: bool     # Supervisor Return (0x10200073)
    is_sfence_vma: bool  # SFENCE.VMA (opcode=SYSTEM, funct7=0x09, funct3=0x0)
    is_csr: bool      # Zicsr op (opcode=SYSTEM, funct3 selects CSRRW/S/C[I])
    is_wfi: bool      # WFI — Wait For Interrupt (0x10500073)
    csr_addr: u32     # CSR address: bits [31:20]

# ============================================================================
# Sign-extension helper (to 64-bit)
# ============================================================================

fn sign_extend_to_64(value: i64, width: u32) -> i64:
    """Sign-extend a value of the given bit width to 64 bits."""
    val sign_bit: i64 = 1 << (width - 1)
    if (value & sign_bit) != 0:
        val fill: i64 = -1 << width
        value | fill
    else:
        value

# ============================================================================
# Immediate extraction (all produce i64 sign-extended to 64 bits)
# ============================================================================

# Thin rv64 shims: shared bit-assembly (rtl_*_imm_bits, i64) then the 64-bit
# sign-extend. `sign_extend_to_64` is kept here (core.spl imports it).

fn extract_i_imm_64(insn: u32) -> i64:
    """I-type immediate: bits [31:20], sign-extended to 64 bits."""
    sign_extend_to_64(rtl_i_imm_bits(insn as i64), 12)

fn extract_s_imm_64(insn: u32) -> i64:
    """S-type immediate: [31:25] | [11:7], sign-extended to 64 bits."""
    sign_extend_to_64(rtl_s_imm_bits(insn as i64), 12)

fn extract_b_imm_64(insn: u32) -> i64:
    """B-type immediate: 13-bit, sign-extended, bit[0]=0."""
    sign_extend_to_64(rtl_b_imm_bits(insn as i64), 13)

fn extract_u_imm_64(insn: u32) -> i64:
    """U-type immediate: bits [31:12] in place, sign-extended to 64."""
    sign_extend_to_64(rtl_u_imm_bits(insn as i64), 32)

fn extract_j_imm_64(insn: u32) -> i64:
    """J-type immediate: 21-bit, sign-extended, bit[0]=0."""
    sign_extend_to_64(rtl_j_imm_bits(insn as i64), 21)

# ============================================================================
# ALU operation selection
# ============================================================================

fn select_alu_op_64(opcode: u32, funct3: u32, funct7: u32) -> i64:
    """Select ALU operation based on opcode, funct3, and funct7."""

    # RV64-only arms handled first, then delegate the 10 shared opcodes to the
    # base mapping (Wave-3 W3-3). Width is compile-time (this file = XLEN 64).

    # M extension (OP_REG, funct7 == 0x01) is handled separately downstream;
    # return ALU_ADD as a placeholder — matches the base ADD default too.
    if opcode == OP_REG and funct7 == 0x01:
        return ALU_ADD

    if opcode == OP_OP_32:
        # W-suffix register-register
        if funct7 == 0x01:
            # M extension W-suffix — handled separately
            return ALU_ADDW
        if funct3 == 0x0:
            if (funct7 & 0x20) != 0:
                return ALU_SUBW
            else:
                return ALU_ADDW
        if funct3 == 0x1: return ALU_SLLW
        if funct3 == 0x5:
            if (funct7 & 0x20) != 0:
                return ALU_SRAW
            else:
                return ALU_SRLW
        return ALU_ADDW

    if opcode == OP_OP_IMM_32:
        # W-suffix register-immediate
        if funct3 == 0x0: return ALU_ADDW
        if funct3 == 0x1: return ALU_SLLW
        if funct3 == 0x5:
            if (funct7 & 0x20) != 0:
                return ALU_SRAW
            else:
                return ALU_SRLW
        return ALU_ADDW

    # Shared opcodes (OP_REG w/ funct7!=1, OP_IMMED, OP_LUI) + ADD default.
    rtl_select_alu_op_base(opcode, funct3, funct7)

# ============================================================================
# Main decode function
# ============================================================================

fn decode_instruction_64(instruction: u32) -> DecodeResult64:
    """Decode a 32-bit RV64GC instruction into all control and data signals."""

    # Field extraction
    val op = instruction & 0x7F
    val rd = (instruction >> 7) & 0x1F
    val f3 = (instruction >> 12) & 0x7
    val rs1 = (instruction >> 15) & 0x1F
    val rs2 = (instruction >> 20) & 0x1F
    val f7 = (instruction >> 25) & 0x7F

    # Immediate extraction based on opcode format
    var imm: i64 = 0
    if op == OP_IMMED or op == OP_LOAD or op == OP_JALR or op == OP_OP_IMM_32:
        imm = extract_i_imm_64(instruction)
    else if op == OP_STORE:
        imm = extract_s_imm_64(instruction)
    else if op == OP_BRANCH:
        imm = extract_b_imm_64(instruction)
    else if op == OP_LUI or op == OP_AUIPC:
        imm = extract_u_imm_64(instruction)
    else if op == OP_JAL:
        imm = extract_j_imm_64(instruction)

    # ALU operation
    val alu_op = select_alu_op_64(op, f3, f7)

    # Control signals
    val is_word = op == OP_OP_IMM_32 or op == OP_OP_32
    val is_amo = op == OP_AMO
    val is_muldiv = (op == OP_REG or op == OP_OP_32) and f7 == 0x01
    val is_mret = instruction == 0x30200073u32
    val is_sret = instruction == 0x10200073u32
    val is_wfi = instruction == 0x10500073u32
    val is_sfence_vma = op == OP_SYSTEM and f7 == 0x09 and f3 == 0x0
    # CSR ops are funct3 1/2/3 (register) and 5/6/7 (immediate); f3&0x3==0
    # covers both non-CSR encodings (0 = ECALL/EBREAK/xRET/SFENCE, 4 = reserved).
    val is_csr = op == OP_SYSTEM and (f3 & 0x3) != 0
    val csr_addr = (instruction >> 20) & 0xFFF

    val reg_w = (op == OP_REG or op == OP_IMMED or op == OP_LOAD or
                 op == OP_LUI or op == OP_AUIPC or op == OP_JAL or op == OP_JALR or
                 op == OP_OP_IMM_32 or op == OP_OP_32 or op == OP_AMO)
    val m_read = op == OP_LOAD
    val m_write = op == OP_STORE
    val m_to_reg = op == OP_LOAD
    # OP_AMO uses the ALU as an address unit: imm stays 0 for AMO (no
    # immediate branch matches opcode 0x2F), so alu_result = rs1 + 0 = rs1,
    # the A-extension memory address.
    val a_src = (op == OP_IMMED or op == OP_LOAD or op == OP_STORE or
                 op == OP_LUI or op == OP_AUIPC or op == OP_JAL or op == OP_JALR or
                 op == OP_OP_IMM_32 or op == OP_AMO)
    val br = op == OP_BRANCH
    val jmp = op == OP_JAL or op == OP_JALR

    DecodeResult64(
        opcode: op,
        rd: rd,
        rs1: rs1,
        rs2: rs2,
        funct3: f3,
        funct7: f7,
        imm: imm,
        alu_op: alu_op,
        reg_write: reg_w,
        mem_read: m_read,
        mem_write: m_write,
        mem_to_reg: m_to_reg,
        alu_src: a_src,
        branch: br,
        jump: jmp,
        is_word_op: is_word,
        is_amo: is_amo,
        is_muldiv: is_muldiv,
        is_mret: is_mret,
        is_sret: is_sret,
        is_sfence_vma: is_sfence_vma,
        is_csr: is_csr,
        is_wfi: is_wfi,
        csr_addr: csr_addr
    )

# ============================================================================
# Spec-facing alias
# ============================================================================

fn decode64(instruction: u32) -> DecodeResult64:
    decode_instruction_64(instruction)
