# ============================================================================
# RV64GC RTL Decoder — Combinational Instruction Decoder
# ============================================================================
#
# Adapts RV32I decoder for RV64GC.  Pure functions only (combinational).
# Extracts all fields from a 32-bit instruction, selects ALU op, generates
# control signals, and sign-extends immediates.
#
# Supports all RV64I instruction formats: R, I, S, B, U, J
# plus W-suffix instructions (OP_OP_IMM_32, OP_OP_32).
# ============================================================================

use std.hardware.rv64gc_rtl.pkg.{OP_LUI, OP_AUIPC, OP_JAL, OP_JALR}
use std.hardware.rv64gc_rtl.pkg.{OP_BRANCH, OP_LOAD, OP_STORE, OP_IMMED, OP_REG, OP_SYSTEM}
use std.hardware.rv64gc_rtl.pkg.{OP_OP_IMM_32, OP_OP_32, OP_AMO}
# ALU_ADD is the M-ext placeholder; the RV64-only W-suffix codes stay local.
use std.hardware.rv64gc_rtl.pkg.ALU_ADD
use std.hardware.rv64gc_rtl.pkg.{ALU_ADDW, ALU_SUBW, ALU_SLLW, ALU_SRLW, ALU_SRAW}
# Shared XLEN-neutral bit-assembly + ALU-op base (Wave-3 W3-2/W3-3). rv64 wraps
# the raw bits with its own 64-bit sign-extend; width is fixed at compile time.
use std.hardware.riscv_common.rtl_decode.{rtl_i_imm_bits, rtl_s_imm_bits, rtl_b_imm_bits}
use std.hardware.riscv_common.rtl_decode.{rtl_u_imm_bits, rtl_j_imm_bits, rtl_select_alu_op_base}

# ============================================================================
# Decode result — all decoder output signals
# ============================================================================

struct DecodeResult64:
    """All outputs from the combinational decoder."""
    opcode: u32       # bits [6:0]
    rd: u32           # bits [11:7]   — destination register
    rs1: u32          # bits [19:15]  — source register 1
    rs2: u32          # bits [24:20]  — source register 2
    funct3: u32       # bits [14:12]
    funct7: u32       # bits [31:25]
    imm: i64          # Sign-extended immediate (64-bit)
    alu_op: i64       # ALU operation code
    reg_write: bool   # Write-back to register file
    mem_read: bool    # Read from data memory
    mem_write: bool   # Write to data memory
    mem_to_reg: bool  # Load result goes to rd
    alu_src: bool     # true = ALU op_b from immediate; false = from rs2
    branch: bool      # Conditional branch instruction
    jump: bool        # JAL or JALR
    is_word_op: bool  # W-suffix instruction (operate on low 32 bits)
    is_amo: bool      # Atomic memory operation
    is_muldiv: bool   # M extension multiply/divide
    is_mret: bool     # Machine Return (0x30200073)
    is_sret: bool     # Supervisor Return (0x10200073)
    is_sfence_vma: bool  # SFENCE.VMA (opcode=SYSTEM, funct7=0x09, funct3=0x0)
    is_csr: bool      # Zicsr op (opcode=SYSTEM, funct3 selects CSRRW/S/C[I])
    is_wfi: bool      # WFI — Wait For Interrupt (0x10500073)
    csr_addr: u32     # CSR address: bits [31:20]

# ============================================================================
# Sign-extension helper (to 64-bit)
# ============================================================================

fn sign_extend_to_64(value: i64, width: u32) -> i64:
    """Sign-extend a value of the given bit width to 64 bits."""
    val sign_bit: i64 = 1 << (width - 1)
    if (value & sign_bit) != 0:
        val fill: i64 = -1 << width
        value | fill
    else:
        value

# ============================================================================
# Immediate extraction (all produce i64 sign-extended to 64 bits)
# ============================================================================

# Thin rv64 shims: shared bit-assembly (rtl_*_imm_bits, i64) then the 64-bit
# sign-extend. `sign_extend_to_64` is kept here (core.spl imports it).

fn extract_i_imm_64(insn: u32) -> i64:
    """I-type immediate: bits [31:20], sign-extended to 64 bits."""
    sign_extend_to_64(rtl_i_imm_bits(insn as i64), 12)

fn extract_s_imm_64(insn: u32) -> i64:
    """S-type immediate: [31:25] | [11:7], sign-extended to 64 bits."""
    sign_extend_to_64(rtl_s_imm_bits(insn as i64), 12)

fn extract_b_imm_64(insn: u32) -> i64:
    """B-type immediate: 13-bit, sign-extended, bit[0]=0."""
    sign_extend_to_64(rtl_b_imm_bits(insn as i64), 13)

fn extract_u_imm_64(insn: u32) -> i64:
    """U-type immediate: bits [31:12] in place, sign-extended to 64."""
    sign_extend_to_64(rtl_u_imm_bits(insn as i64), 32)

fn extract_j_imm_64(insn: u32) -> i64:
    """J-type immediate: 21-bit, sign-extended, bit[0]=0."""
    sign_extend_to_64(rtl_j_imm_bits(insn as i64), 21)

# ============================================================================
# ALU operation selection
# ============================================================================

fn select_alu_op_64(opcode: u32, funct3: u32, funct7: u32) -> i64:
    """Select ALU operation based on opcode, funct3, and funct7."""

    # RV64-only arms handled first, then delegate the 10 shared opcodes to the
    # base mapping (Wave-3 W3-3). Width is compile-time (this file = XLEN 64).

    # M extension (OP_REG, funct7 == 0x01) is handled separately downstream;
    # return ALU_ADD as a placeholder — matches the base ADD default too.
    if opcode == OP_REG and funct7 == 0x01:
        return ALU_ADD

    if opcode == OP_OP_32:
        # W-suffix register-register
        if funct7 == 0x01:
            # M extension W-suffix — handled separately
            return ALU_ADDW
        if funct3 == 0x0:
            if (funct7 & 0x20) != 0:
                return ALU_SUBW
            else:
                return ALU_ADDW
        if funct3 == 0x1: return ALU_SLLW
        if funct3 == 0x5:
            if (funct7 & 0x20) != 0:
                return ALU_SRAW
            else:
                return ALU_SRLW
        return ALU_ADDW

    if opcode == OP_OP_IMM_32:
        # W-suffix register-immediate
        if funct3 == 0x0: return ALU_ADDW
        if funct3 == 0x1: return ALU_SLLW
        if funct3 == 0x5:
            if (funct7 & 0x20) != 0:
                return ALU_SRAW
            else:
                return ALU_SRLW
        return ALU_ADDW

    # Shared opcodes (OP_REG w/ funct7!=1, OP_IMMED, OP_LUI) + ADD default.
    rtl_select_alu_op_base(opcode, funct3, funct7)

# ============================================================================
# RV64C (compressed) expander — 16-bit parcel -> 32-bit equivalent
# ============================================================================
#
# Canonical approach: every 16-bit parcel whose low two bits != 0b11 is
# mapped to the exact 32-bit instruction it aliases, BEFORE the 32-bit
# decoder runs.  The core then decodes/executes the 32-bit form and advances
# pc by 2 (link = pc+2).  Reserved / unsupported (F/D) 16-bit patterns set
# `legal=false` so the core raises illegal-instruction (cause 2) fail-closed —
# never a silent NOP.
#
# Compressed register fields x8..x15 are encoded 3-bit as reg' = field + 8.
# Immediates are scrambled per the C-ext quadrant tables; every expansion
# below is cross-checked against riscv64-linux-gnu-gcc -march=rv64gc + objdump
# (see the isa_conformance probe rvc cross-check + report).
#
# insn  -> 32-bit expansion (gcc-verified 16-bit -> 32-bit hex):
#   Q0: c.addi4spn 0040->00410413  c.lw 4080->0004a403  c.ld 6480->0084b403
#       c.sw c0c0->0084a223        c.sd e880->0084b823
#   Q1: c.nop 0001->00000013  c.addi 0505->00150513  c.addiw 35fd->fff5859b
#       c.li 557d->fff00513   c.addi16sp 6105->02010113  c.lui 6605->00001637
#       c.srli 8005->00145413 c.srai 947d->43f45413  c.andi 9861->ff847413
#       c.sub 8c05->40940433  c.xor 8c25->00944433  c.or 8c45->00946433
#       c.and 8c65->00947433  c.subw 9c05->4094043b  c.addw 9c25->0094043b
#       c.j / c.beqz / c.bnez -> jal x0 / beq/bne rs1',x0 (pc-relative)
#   Q2: c.slli 050e->00351513  c.lwsp 4512->00412503  c.ldsp 6522->00813503
#       c.jr 8502->00050067    c.mv 852e->00b00533 (add rd,x0,rs2, spec §16.3)
#       c.jalr 9502->000500e7  c.add 952e->00b50533  c.swsp c22a->00a12223
#       c.sdsp e42a->00a13423  c.ebreak 9002->00100073
#   Reserved -> legal=false: c.addi4spn nzuimm=0, c.addiw/c.lwsp/c.ldsp rd=0,
#       c.lui/c.addi16sp nzimm=0, c.lui rd=0, c.jr rs1=0, C.FLD/FSD/FLDSP/FSDSP.

struct RvcExpansion:
    """Result of examining one fetched word for RV64C compression."""
    insn: u32         # 32-bit equivalent (valid when legal); 0 when illegal
    legal: bool       # false = reserved / unsupported 16-bit pattern
    compressed: bool  # true = the fetched word's low 16 bits are a C parcel

# --- 32-bit format builders (i64 fields -> u32 encoding) ---

fn rvc_i(imm: i64, rs1: i64, f3: i64, rd: i64, op: i64) -> u32:
    (((imm & 0xFFF) << 20) | ((rs1 & 0x1F) << 15) | ((f3 & 0x7) << 12) |
     ((rd & 0x1F) << 7) | (op & 0x7F)) as u32

fn rvc_r(f7: i64, rs2: i64, rs1: i64, f3: i64, rd: i64, op: i64) -> u32:
    (((f7 & 0x7F) << 25) | ((rs2 & 0x1F) << 20) | ((rs1 & 0x1F) << 15) |
     ((f3 & 0x7) << 12) | ((rd & 0x1F) << 7) | (op & 0x7F)) as u32

fn rvc_s(imm: i64, rs2: i64, rs1: i64, f3: i64, op: i64) -> u32:
    ((((imm >> 5) & 0x7F) << 25) | ((rs2 & 0x1F) << 20) | ((rs1 & 0x1F) << 15) |
     ((f3 & 0x7) << 12) | ((imm & 0x1F) << 7) | (op & 0x7F)) as u32

fn rvc_b(imm: i64, rs2: i64, rs1: i64, f3: i64, op: i64) -> u32:
    ((((imm >> 12) & 0x1) << 31) | (((imm >> 5) & 0x3F) << 25) |
     ((rs2 & 0x1F) << 20) | ((rs1 & 0x1F) << 15) | ((f3 & 0x7) << 12) |
     (((imm >> 1) & 0xF) << 8) | (((imm >> 11) & 0x1) << 7) | (op & 0x7F)) as u32

fn rvc_u(imm20: i64, rd: i64, op: i64) -> u32:
    (((imm20 & 0xFFFFF) << 12) | ((rd & 0x1F) << 7) | (op & 0x7F)) as u32

fn rvc_j(imm: i64, rd: i64, op: i64) -> u32:
    ((((imm >> 20) & 0x1) << 31) | (((imm >> 1) & 0x3FF) << 21) |
     (((imm >> 11) & 0x1) << 20) | (((imm >> 12) & 0xFF) << 12) |
     ((rd & 0x1F) << 7) | (op & 0x7F)) as u32

fn rvc_illegal() -> RvcExpansion:
    RvcExpansion(insn: 0, legal: false, compressed: true)

fn rvc_ok(insn: u32) -> RvcExpansion:
    RvcExpansion(insn: insn, legal: true, compressed: true)

# Sign-extend a 6-bit field (imm[5:0]) to 64 bits.
fn rvc_sext6(v: i64) -> i64:
    if (v & 0x20) != 0:
        return v | (-1 << 6)
    v

# --- Quadrant 0 (op == 0b00): stack-pointer-relative loads/stores + addi4spn ---
fn rvc_expand_q0(c: i64) -> RvcExpansion:
    val f3 = (c >> 13) & 0x7
    val rdp = ((c >> 2) & 0x7) + 8
    val rs1p = ((c >> 7) & 0x7) + 8
    if f3 == 0:
        # c.addi4spn: rd', x2, nzuimm[5:4|9:6|2|3]
        val nz = (((c >> 11) & 0x3) << 4) | (((c >> 7) & 0xF) << 6) |
                 (((c >> 6) & 0x1) << 2) | (((c >> 5) & 0x1) << 3)
        if nz == 0:
            return rvc_illegal()   # reserved (also catches all-zero 0x0000)
        return rvc_ok(rvc_i(nz, 2, 0, rdp, 0x13))
    if f3 == 2:
        # c.lw: uimm[5:3|2|6]
        val uw = (((c >> 10) & 0x7) << 3) | (((c >> 6) & 0x1) << 2) | (((c >> 5) & 0x1) << 6)
        return rvc_ok(rvc_i(uw, rs1p, 2, rdp, 0x03))
    if f3 == 3:
        # c.ld: uimm[5:3|7:6]
        val ud = (((c >> 10) & 0x7) << 3) | (((c >> 5) & 0x3) << 6)
        return rvc_ok(rvc_i(ud, rs1p, 3, rdp, 0x03))
    if f3 == 6:
        # c.sw: uimm[5:3|2|6]
        val uw = (((c >> 10) & 0x7) << 3) | (((c >> 6) & 0x1) << 2) | (((c >> 5) & 0x1) << 6)
        return rvc_ok(rvc_s(uw, rdp, rs1p, 2, 0x23))
    if f3 == 7:
        # c.sd: uimm[5:3|7:6]
        val ud = (((c >> 10) & 0x7) << 3) | (((c >> 5) & 0x3) << 6)
        return rvc_ok(rvc_s(ud, rdp, rs1p, 3, 0x23))
    # f3 == 1 (C.FLD), 4 (reserved), 5 (C.FSD): unsupported D-ext -> illegal
    rvc_illegal()

# --- Quadrant 1 (op == 0b01): integer register-immediate + control flow ---
fn rvc_expand_q1(c: i64) -> RvcExpansion:
    val f3 = (c >> 13) & 0x7
    val rd = (c >> 7) & 0x1F
    val rdp = ((c >> 7) & 0x7) + 8
    val rs2p = ((c >> 2) & 0x7) + 8
    val imm6 = rvc_sext6(((c >> 2) & 0x1F) | (((c >> 12) & 0x1) << 5))
    if f3 == 0:
        # c.addi / c.nop  ->  addi rd, rd, imm6
        return rvc_ok(rvc_i(imm6, rd, 0, rd, 0x13))
    if f3 == 1:
        # c.addiw  ->  addiw rd, rd, imm6 (rd=0 reserved)
        if rd == 0:
            return rvc_illegal()
        return rvc_ok(rvc_i(imm6, rd, 0, rd, 0x1B))
    if f3 == 2:
        # c.li  ->  addi rd, x0, imm6
        return rvc_ok(rvc_i(imm6, 0, 0, rd, 0x13))
    if f3 == 3:
        if rd == 2:
            # c.addi16sp -> addi x2, x2, nzimm[9|4|6|8:7|5]
            var n = (((c >> 12) & 0x1) << 9) | (((c >> 3) & 0x3) << 7) |
                    (((c >> 5) & 0x1) << 6) | (((c >> 2) & 0x1) << 5) |
                    (((c >> 6) & 0x1) << 4)
            if n == 0:
                return rvc_illegal()
            if (n & 0x200) != 0:
                n = n | (-1 << 10)
            return rvc_ok(rvc_i(n, 2, 0, 2, 0x13))
        # c.lui -> lui rd, nzimm[17:12] (rd != 0,2)
        if rd == 0:
            return rvc_illegal()
        val v6 = ((c >> 2) & 0x1F) | (((c >> 12) & 0x1) << 5)
        if v6 == 0:
            return rvc_illegal()
        val sv = rvc_sext6(v6)
        return rvc_ok(rvc_u(sv, rd, 0x37))
    if f3 == 4:
        val sub2 = (c >> 10) & 0x3
        if sub2 == 0:
            # c.srli -> srli rd', rd', shamt6
            val sh = ((c >> 2) & 0x1F) | (((c >> 12) & 0x1) << 5)
            return rvc_ok(rvc_i(sh, rdp, 5, rdp, 0x13))
        if sub2 == 1:
            # c.srai -> srai rd', rd', shamt6 (bit30 set)
            val sh = ((c >> 2) & 0x1F) | (((c >> 12) & 0x1) << 5)
            return rvc_ok(((rvc_i(sh, rdp, 5, rdp, 0x13) as i64) | 0x40000000) as u32)
        if sub2 == 2:
            # c.andi -> andi rd', rd', imm6
            return rvc_ok(rvc_i(imm6, rdp, 7, rdp, 0x13))
        # sub2 == 3: register-register
        val sel = (((c >> 12) & 0x1) << 2) | ((c >> 5) & 0x3)
        if sel == 0: return rvc_ok(rvc_r(0x20, rs2p, rdp, 0, rdp, 0x33))   # c.sub
        if sel == 1: return rvc_ok(rvc_r(0x00, rs2p, rdp, 4, rdp, 0x33))   # c.xor
        if sel == 2: return rvc_ok(rvc_r(0x00, rs2p, rdp, 6, rdp, 0x33))   # c.or
        if sel == 3: return rvc_ok(rvc_r(0x00, rs2p, rdp, 7, rdp, 0x33))   # c.and
        if sel == 4: return rvc_ok(rvc_r(0x20, rs2p, rdp, 0, rdp, 0x3B))   # c.subw
        if sel == 5: return rvc_ok(rvc_r(0x00, rs2p, rdp, 0, rdp, 0x3B))   # c.addw
        return rvc_illegal()   # sel 6/7 reserved
    if f3 == 5:
        # c.j -> jal x0, offset[11|4|9:8|10|6|7|3:1|5]
        var j = (((c >> 12) & 0x1) << 11) | (((c >> 11) & 0x1) << 4) |
                (((c >> 9) & 0x3) << 8) | (((c >> 8) & 0x1) << 10) |
                (((c >> 7) & 0x1) << 6) | (((c >> 6) & 0x1) << 7) |
                (((c >> 3) & 0x7) << 1) | (((c >> 2) & 0x1) << 5)
        if (j & 0x800) != 0:
            j = j | (-1 << 12)
        return rvc_ok(rvc_j(j, 0, 0x6F))
    # f3 == 6 (c.beqz) / 7 (c.bnez): branch offset[8|4:3|7:6|2:1|5]
    var b = (((c >> 12) & 0x1) << 8) | (((c >> 10) & 0x3) << 3) |
            (((c >> 5) & 0x3) << 6) | (((c >> 3) & 0x3) << 1) |
            (((c >> 2) & 0x1) << 5)
    if (b & 0x100) != 0:
        b = b | (-1 << 9)
    val bf3 = if f3 == 6: 0 else: 1
    rvc_ok(rvc_b(b, 0, rdp, bf3, 0x63))

# --- Quadrant 2 (op == 0b10): sp-relative + register moves/jumps ---
fn rvc_expand_q2(c: i64) -> RvcExpansion:
    val f3 = (c >> 13) & 0x7
    val rd = (c >> 7) & 0x1F
    val rs2 = (c >> 2) & 0x1F
    if f3 == 0:
        # c.slli -> slli rd, rd, shamt6
        val sh = ((c >> 2) & 0x1F) | (((c >> 12) & 0x1) << 5)
        return rvc_ok(rvc_i(sh, rd, 1, rd, 0x13))
    if f3 == 2:
        # c.lwsp -> lw rd, uimm[5|4:2|7:6](x2)  (rd != 0)
        if rd == 0:
            return rvc_illegal()
        val u = (((c >> 12) & 0x1) << 5) | (((c >> 4) & 0x7) << 2) | (((c >> 2) & 0x3) << 6)
        return rvc_ok(rvc_i(u, 2, 2, rd, 0x03))
    if f3 == 3:
        # c.ldsp -> ld rd, uimm[5|4:3|8:6](x2)  (rd != 0)
        if rd == 0:
            return rvc_illegal()
        val u = (((c >> 12) & 0x1) << 5) | (((c >> 5) & 0x3) << 3) | (((c >> 2) & 0x7) << 6)
        return rvc_ok(rvc_i(u, 2, 3, rd, 0x03))
    if f3 == 4:
        val bit12 = (c >> 12) & 0x1
        if bit12 == 0:
            if rs2 == 0:
                # c.jr -> jalr x0, 0(rs1)  (rs1 != 0)
                if rd == 0:
                    return rvc_illegal()
                return rvc_ok(rvc_i(0, rd, 0, 0, 0x67))
            # c.mv -> add rd, x0, rs2  (spec §16.3 canonical form)
            return rvc_ok(rvc_r(0, rs2, 0, 0, rd, 0x33))
        if rs2 == 0 and rd == 0:
            return rvc_ok(0x00100073 as u32)   # c.ebreak
        if rs2 == 0:
            # c.jalr -> jalr x1, 0(rs1)
            return rvc_ok(rvc_i(0, rd, 0, 1, 0x67))
        # c.add -> add rd, rd, rs2
        return rvc_ok(rvc_r(0, rs2, rd, 0, rd, 0x33))
    if f3 == 6:
        # c.swsp -> sw rs2, uimm[5:2|7:6](x2)
        val u = (((c >> 9) & 0xF) << 2) | (((c >> 7) & 0x3) << 6)
        return rvc_ok(rvc_s(u, rs2, 2, 2, 0x23))
    if f3 == 7:
        # c.sdsp -> sd rs2, uimm[5:3|8:6](x2)
        val u = (((c >> 10) & 0x7) << 3) | (((c >> 7) & 0x7) << 6)
        return rvc_ok(rvc_s(u, rs2, 2, 3, 0x23))
    # f3 == 1 (C.FLDSP) / 5 (C.FSDSP): unsupported D-ext -> illegal
    rvc_illegal()

fn rvc_expand(iword: u32) -> RvcExpansion:
    """Examine a fetched word.  If its low two bits are 0b11 it is a normal
    32-bit instruction (pass through, compressed=false).  Otherwise the low
    16 bits are a C parcel: expand to the 32-bit equivalent (or flag illegal)."""
    if (iword & 0x3) == 0x3:
        return RvcExpansion(insn: iword, legal: true, compressed: false)
    val c = (iword as i64) & 0xFFFF
    val quad = c & 0x3
    if quad == 0:
        return rvc_expand_q0(c)
    if quad == 1:
        return rvc_expand_q1(c)
    rvc_expand_q2(c)

# ============================================================================
# Main decode function
# ============================================================================

fn decode_instruction_64(instruction: u32) -> DecodeResult64:
    """Decode a 32-bit RV64GC instruction into all control and data signals."""

    # Field extraction
    val op = instruction & 0x7F
    val rd = (instruction >> 7) & 0x1F
    val f3 = (instruction >> 12) & 0x7
    val rs1 = (instruction >> 15) & 0x1F
    val rs2 = (instruction >> 20) & 0x1F
    val f7 = (instruction >> 25) & 0x7F

    # Immediate extraction based on opcode format
    var imm: i64 = 0
    if op == OP_IMMED or op == OP_LOAD or op == OP_JALR or op == OP_OP_IMM_32:
        imm = extract_i_imm_64(instruction)
    else if op == OP_STORE:
        imm = extract_s_imm_64(instruction)
    else if op == OP_BRANCH:
        imm = extract_b_imm_64(instruction)
    else if op == OP_LUI or op == OP_AUIPC:
        imm = extract_u_imm_64(instruction)
    else if op == OP_JAL:
        imm = extract_j_imm_64(instruction)

    # ALU operation
    val alu_op = select_alu_op_64(op, f3, f7)

    # Control signals
    val is_word = op == OP_OP_IMM_32 or op == OP_OP_32
    val is_amo = op == OP_AMO
    val is_muldiv = (op == OP_REG or op == OP_OP_32) and f7 == 0x01
    val is_mret = instruction == 0x30200073u32
    val is_sret = instruction == 0x10200073u32
    val is_wfi = instruction == 0x10500073u32
    val is_sfence_vma = op == OP_SYSTEM and f7 == 0x09 and f3 == 0x0
    # CSR ops are funct3 1/2/3 (register) and 5/6/7 (immediate); f3&0x3==0
    # covers both non-CSR encodings (0 = ECALL/EBREAK/xRET/SFENCE, 4 = reserved).
    val is_csr = op == OP_SYSTEM and (f3 & 0x3) != 0
    val csr_addr = (instruction >> 20) & 0xFFF

    val reg_w = (op == OP_REG or op == OP_IMMED or op == OP_LOAD or
                 op == OP_LUI or op == OP_AUIPC or op == OP_JAL or op == OP_JALR or
                 op == OP_OP_IMM_32 or op == OP_OP_32 or op == OP_AMO)
    val m_read = op == OP_LOAD
    val m_write = op == OP_STORE
    val m_to_reg = op == OP_LOAD
    # OP_AMO uses the ALU as an address unit: imm stays 0 for AMO (no
    # immediate branch matches opcode 0x2F), so alu_result = rs1 + 0 = rs1,
    # the A-extension memory address.
    val a_src = (op == OP_IMMED or op == OP_LOAD or op == OP_STORE or
                 op == OP_LUI or op == OP_AUIPC or op == OP_JAL or op == OP_JALR or
                 op == OP_OP_IMM_32 or op == OP_AMO)
    val br = op == OP_BRANCH
    val jmp = op == OP_JAL or op == OP_JALR

    DecodeResult64(
        opcode: op,
        rd: rd,
        rs1: rs1,
        rs2: rs2,
        funct3: f3,
        funct7: f7,
        imm: imm,
        alu_op: alu_op,
        reg_write: reg_w,
        mem_read: m_read,
        mem_write: m_write,
        mem_to_reg: m_to_reg,
        alu_src: a_src,
        branch: br,
        jump: jmp,
        is_word_op: is_word,
        is_amo: is_amo,
        is_muldiv: is_muldiv,
        is_mret: is_mret,
        is_sret: is_sret,
        is_sfence_vma: is_sfence_vma,
        is_csr: is_csr,
        is_wfi: is_wfi,
        csr_addr: csr_addr
    )

# ============================================================================
# Spec-facing alias
# ============================================================================

fn decode64(instruction: u32) -> DecodeResult64:
    decode_instruction_64(instruction)
