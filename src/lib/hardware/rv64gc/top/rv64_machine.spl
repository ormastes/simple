use hardware.riscv_common.pkg.riscv_linux_pkg.RiscvPlatformProfile

pub struct Rv64Machine:
    platform: RiscvPlatformProfile
    hartid: i64
    dtb_addr: i64
    satp: i64

impl Rv64Machine:
    static fn create() -> Rv64Machine:
        Rv64Machine(
            platform: RiscvPlatformProfile.qemu_virt_rv64(),
            hartid: 0,
            dtb_addr: 0,
            satp: 0
        )

    fn configure_linux_handoff(hartid: i64, dtb_addr: i64) -> Rv64Machine:
        Rv64Machine(
            platform: self.platform,
            hartid: hartid,
            dtb_addr: dtb_addr,
            satp: 0
        )

pub fn rv64_machine_create() -> Rv64Machine:
    Rv64Machine.create()

pub fn qemu_virt_rv64_platform_profile() -> RiscvPlatformProfile:
    RiscvPlatformProfile.qemu_virt_rv64()
