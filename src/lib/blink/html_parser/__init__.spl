# Blink html_parser — public surface for the HTML tokenizer.
#
# Re-exports the tokenizer's types and entry point so downstream consumers
# (tree builder, DOM constructor) can import from `std.blink.html_parser`
# without reaching into submodules.

use std.blink.html_parser.tokenizer.{
    HtmlTokenKind,
    HtmlAttribute,
    HtmlToken,
    tokenize_html
}

export HtmlTokenKind
export HtmlAttribute
export HtmlToken
export tokenize_html
