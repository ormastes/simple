# Blink DOM interaction state — blink.dom.interaction_state
#
# Tracks tree-level interaction state (which node is hovered / focused) for
# CSS pseudo-class matching in the selector engine. A node id of -1 means
# "no node in this state".
# Consumers: blink/css_parser/selector.spl, style cascade, form paint.

struct InteractionState:
    """Tree-level interaction state used by CSS pseudo-class selectors."""
    hovered_id: i64
    focused_id: i64

fn interaction_state_empty() -> InteractionState:
    """Return an InteractionState with no hovered/focused node (default/idle state)."""
    InteractionState(hovered_id: -1, focused_id: -1)

fn interaction_state_with_hover(node_id: i64) -> InteractionState:
    """Return an InteractionState where `node_id` is hovered."""
    InteractionState(hovered_id: node_id, focused_id: -1)

fn interaction_state_with_focus(node_id: i64) -> InteractionState:
    """Return an InteractionState where `node_id` is focused."""
    InteractionState(hovered_id: -1, focused_id: node_id)
