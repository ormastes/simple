# Blink DOM node types — blink.dom.node
#
# Core DOM tree types: DomNode, DomTree, NodeType, Attribute.
# Consumer: blink/css_parser/selector.spl

enum NodeType:
    """W3C DOM node type discriminants."""
    Element
    Text
    Comment
    Document
    DocumentType
    ProcessingInstruction
    CdataSection

struct Attribute:
    """A single XML/HTML attribute key-value pair."""
    name: text
    value: text

struct DomNode:
    """A single node in the DOM tree."""
    id: i64
    node_type: NodeType
    tag_name: text
    attributes: [Attribute]
    children: [i64]
    parent: i64
    text_content: text

struct DomTree:
    """An arena-allocated DOM tree."""
    nodes: [DomNode]
    root: i64

fn dom_tree_empty() -> DomTree:
    """Return an empty DomTree with no nodes."""
    DomTree(nodes: [], root: -1)

fn dom_node_get(tree: DomTree, id: i64) -> DomNode?:
    """Look up a node by id. Returns nil if id is out of range."""
    if id < 0 or id >= tree.nodes.len():
        return nil
    Some(tree.nodes[id as i32])
