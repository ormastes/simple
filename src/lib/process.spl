# Process execution shim for `use std.process.{...}`.
#
# The canonical host process helpers live under nogc_sync_mut/io. This module
# keeps the public std.process import path stable for system specs and tools.

use lib.nogc_sync_mut.io.process_ops.{ProcessResult, process_run}

fn run(cmd: text, args: [text]) -> ProcessResult:
    val (stdout, stderr, exit_code) = process_run(cmd, args)
    ProcessResult(
        stdout: stdout,
        stderr: stderr,
        exit_code: exit_code,
        limit_exceeded: false,
        limit_type: ""
    )
