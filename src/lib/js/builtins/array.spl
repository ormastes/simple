# JS Array Built-in Methods
# Pure-Simple implementations of JS Array prototype methods operating on JsValue arrays.

use std.js.types.js_types.JsValue

fn array_map(arr: [JsValue], callback: (JsValue) -> JsValue) -> [JsValue]:
    var result: [JsValue] = []
    for elem in arr:
        result.push(callback(elem))
    result

fn array_filter(arr: [JsValue], predicate: (JsValue) -> bool) -> [JsValue]:
    var result: [JsValue] = []
    for elem in arr:
        if predicate(elem):
            result.push(elem)
    result

fn array_reduce(arr: [JsValue], callback: (JsValue, JsValue) -> JsValue, initial: JsValue) -> JsValue:
    var acc = initial
    for elem in arr:
        acc = callback(acc, elem)
    acc

fn array_forEach(arr: [JsValue], callback: (JsValue) -> Nil):
    for elem in arr:
        callback(elem)

fn array_find(arr: [JsValue], predicate: (JsValue) -> bool) -> JsValue:
    for elem in arr:
        if predicate(elem):
            return elem
    JsValue.Undefined

fn array_findIndex(arr: [JsValue], predicate: (JsValue) -> bool) -> i64:
    var i = 0
    for elem in arr:
        if predicate(elem):
            return i
        i = i + 1
    -1

fn array_some(arr: [JsValue], predicate: (JsValue) -> bool) -> bool:
    for elem in arr:
        if predicate(elem):
            return true
    false

fn array_every(arr: [JsValue], predicate: (JsValue) -> bool) -> bool:
    for elem in arr:
        if not predicate(elem):
            return false
    true

fn array_sort_with(arr: [JsValue], compare: (JsValue, JsValue) -> i64) -> [JsValue]:
    # Bubble sort — correct but not efficient
    var result = arr.copy()
    val n = result.len()
    var i = 0
    while i < n:
        var j = 0
        while j < n - i - 1:
            if compare(result[j], result[j + 1]) > 0:
                val tmp = result[j]
                result[j] = result[j + 1]
                result[j + 1] = tmp
            j = j + 1
        i = i + 1
    result

fn array_isArray(v: JsValue) -> bool:
    match v:
        JsValue.Array(_): true
        _: false

fn array_from_values(values: [JsValue]) -> [JsValue]:
    values
