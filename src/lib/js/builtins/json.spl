# JS JSON Builtins
# JSON.parse and JSON.stringify for the Simple Browser JS engine.

use std.js.types.js_types.{JsValue, JsObject, JsProperty}

fn _json_skip_ws(source: text, pos: i64) -> i64:
    var i = pos
    while i < source.len():
        val ch = source.slice(i, i + 1)
        if ch == " " or ch == "\n" or ch == "\r" or ch == "\t":
            i = i + 1
        else:
            return i
    i

fn _json_string_end(source: text, pos: i64) -> i64:
    if pos >= source.len() or source.slice(pos, pos + 1) != "\"":
        return -1
    var i = pos + 1
    var escaped = false
    while i < source.len():
        val ch = source.slice(i, i + 1)
        if escaped:
            escaped = false
        else if ch == "\\":
            escaped = true
        else if ch == "\"":
            return i + 1
        i = i + 1
    -1

fn _json_number_end(source: text, pos: i64) -> i64:
    var i = pos
    while i < source.len():
        val ch = source.slice(i, i + 1)
        if (ch >= "0" and ch <= "9") or ch == "-" or ch == "+" or ch == "." or ch == "e" or ch == "E":
            i = i + 1
        else:
            break
    if i == pos:
        return -1
    val candidate = source.slice(pos, i)
    if candidate.parse_f64() == nil:
        return -1
    i

fn _json_value_end(source: text, pos_in: i64) -> i64:
    val pos = _json_skip_ws(source, pos_in)
    if pos >= source.len():
        return -1
    val ch = source.slice(pos, pos + 1)
    if ch == "\"":
        return _json_string_end(source, pos)
    if source.slice(pos, source.len()).starts_with("true"):
        return pos + 4
    if source.slice(pos, source.len()).starts_with("false"):
        return pos + 5
    if source.slice(pos, source.len()).starts_with("null"):
        return pos + 4
    if ch == "[":
        return _json_array_end(source, pos)
    if ch == "{":
        return _json_object_end(source, pos)
    _json_number_end(source, pos)

fn _json_array_end(source: text, pos: i64) -> i64:
    var i = _json_skip_ws(source, pos + 1)
    if i < source.len() and source.slice(i, i + 1) == "]":
        return i + 1
    while i < source.len():
        val value_end = _json_value_end(source, i)
        if value_end < 0:
            return -1
        i = _json_skip_ws(source, value_end)
        if i < source.len() and source.slice(i, i + 1) == "]":
            return i + 1
        if i >= source.len() or source.slice(i, i + 1) != ",":
            return -1
        i = _json_skip_ws(source, i + 1)
    -1

fn _json_object_end(source: text, pos: i64) -> i64:
    var i = _json_skip_ws(source, pos + 1)
    if i < source.len() and source.slice(i, i + 1) == "}":
        return i + 1
    while i < source.len():
        val key_end = _json_string_end(source, i)
        if key_end < 0:
            return -1
        i = _json_skip_ws(source, key_end)
        if i >= source.len() or source.slice(i, i + 1) != ":":
            return -1
        i = _json_skip_ws(source, i + 1)
        val value_end = _json_value_end(source, i)
        if value_end < 0:
            return -1
        i = _json_skip_ws(source, value_end)
        if i < source.len() and source.slice(i, i + 1) == "}":
            return i + 1
        if i >= source.len() or source.slice(i, i + 1) != ",":
            return -1
        i = _json_skip_ws(source, i + 1)
    -1

fn json_is_valid(text: text) -> bool:
    val s = text.trim()
    if s == "":
        return false
    val end = _json_value_end(s, 0)
    end == s.len()

fn json_parse(text: text) -> JsValue:
    val s = text.trim()
    if s == "null":
        return JsValue.Null
    if s == "true":
        return JsValue.Boolean(true)
    if s == "false":
        return JsValue.Boolean(false)
    if s == "undefined":
        return JsValue.Undefined
    # Number
    val maybe_num = s.parse_f64()
    if maybe_num != nil:
        return JsValue.Number(maybe_num!)
    # String
    if s.starts_with("\"") and s.ends_with("\""):
        return JsValue.String(s.slice(1, s.len() - 1))
    if json_is_valid(s):
        if s.starts_with("["):
            return JsValue.Array(id: -1)
        if s.starts_with("{"):
            return JsValue.Object(id: -1)
    JsValue.Undefined

fn json_stringify(v: JsValue) -> text:
    match v:
        JsValue.Null: "null"
        JsValue.Undefined: "undefined"
        JsValue.Boolean(b): if b: "true" else: "false"
        JsValue.Number(n): "{n}"
        JsValue.String(s): "\"{s}\""
        JsValue.Object(_): "{}"
        JsValue.Array(_): "[]"
        JsValue.Function(_): "null"
