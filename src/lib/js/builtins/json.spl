# JS JSON Builtins
# JSON.parse and JSON.stringify for the Simple Browser JS engine.

use std.js.types.js_types.{JsValue, JsObject, JsProperty}

fn json_parse(text: text) -> JsValue:
    val s = text.trim()
    if s == "null":
        return JsValue.Null
    if s == "true":
        return JsValue.Boolean(true)
    if s == "false":
        return JsValue.Boolean(false)
    if s == "undefined":
        return JsValue.Undefined
    # Number
    val maybe_num = s.parse_f64()
    if maybe_num != nil:
        return JsValue.Number(maybe_num!)
    # String
    if s.starts_with("\"") and s.ends_with("\""):
        return JsValue.String(s.slice(1, s.len() - 1))
    # Array or object — stub: return undefined
    JsValue.Undefined

fn json_stringify(v: JsValue) -> text:
    match v:
        JsValue.Null: "null"
        JsValue.Undefined: "undefined"
        JsValue.Boolean(b): if b: "true" else: "false"
        JsValue.Number(n): "{n}"
        JsValue.String(s): "\"{s}\""
        JsValue.Object(_): "{}"
        JsValue.Array(_): "[]"
        JsValue.Function(_): "null"
