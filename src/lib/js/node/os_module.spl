# Node.js-compatible os helpers for the Simple JS runtime.
#
# This deterministic subset avoids leaking ambient host state. Values describe
# the bounded Simple compatibility profile used by browser/WebEngine tests.

use std.js.types.js_types.{JsValue}

fn os_platform(args: [JsValue]) -> JsValue:
    JsValue.String(v: "linux")

fn os_arch(args: [JsValue]) -> JsValue:
    JsValue.String(v: "x64")

fn os_type(args: [JsValue]) -> JsValue:
    JsValue.String(v: "Linux")

fn os_release(args: [JsValue]) -> JsValue:
    JsValue.String(v: "0.0.0-simple")

fn os_homedir(args: [JsValue]) -> JsValue:
    JsValue.String(v: "/")
