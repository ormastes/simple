# Node.js-compatible Buffer helpers for deterministic JS/Node infrastructure.
#
# This module models a bounded `Buffer` surface without host I/O or process
# state. It is intentionally byte-oriented so WASM and WebEngine encoding paths
# can share the same UTF-8, hex, and base64 behavior in tests.

use std.js.types.js_types.{JsValue}
use std.common.base_encoding.base64.{base64_encode, base64_decode}

class NodeBuffer:
    bytes: [u8]

    static fn alloc(size: i64, fill: i64) -> NodeBuffer:
        var out: [u8] = []
        var n = size
        if n < 0:
            n = 0
        var byte = fill % 256
        if byte < 0:
            byte = byte + 256
        var i = 0
        while i < n:
            out.push(byte as u8)
            i = i + 1
        NodeBuffer(bytes: out)

    static fn from_text(value: text, encoding: text) -> NodeBuffer:
        NodeBuffer(bytes: _buffer_decode(value, encoding))

    static fn from_bytes(values: [i64]) -> NodeBuffer:
        var out: [u8] = []
        for value in values:
            var byte = value % 256
            if byte < 0:
                byte = byte + 256
            out.push(byte as u8)
        NodeBuffer(bytes: out)

    static fn concat(buffers: [NodeBuffer]) -> NodeBuffer:
        var out: [u8] = []
        for buffer in buffers:
            for b in buffer.bytes:
                out.push(b)
        NodeBuffer(bytes: out)

    fn length() -> i64:
        self.bytes.len()

    fn to_string(encoding: text) -> text:
        _buffer_encode(self.bytes, encoding)

    fn slice(start: i64, end: i64) -> NodeBuffer:
        var from = start
        var to = end
        val n = self.bytes.len()
        if from < 0:
            from = n + from
        if to < 0:
            to = n + to
        if from < 0:
            from = 0
        if to < 0:
            to = 0
        if from > n:
            from = n
        if to > n:
            to = n
        if to < from:
            to = from
        var out: [u8] = []
        var i = from
        while i < to:
            out.push(self.bytes[i])
            i = i + 1
        NodeBuffer(bytes: out)

    fn read_uint8(offset: i64) -> i64:
        if offset < 0 or offset >= self.bytes.len():
            return 0
        self.bytes[offset] as i64

    fn read_uint16_le(offset: i64) -> i64:
        if offset < 0 or offset + 1 >= self.bytes.len():
            return 0
        val b0 = self.bytes[offset] as i64
        val b1 = self.bytes[offset + 1] as i64
        b0 | (b1 << 8)

    fn read_uint16_be(offset: i64) -> i64:
        if offset < 0 or offset + 1 >= self.bytes.len():
            return 0
        val b0 = self.bytes[offset] as i64
        val b1 = self.bytes[offset + 1] as i64
        (b0 << 8) | b1

    fn read_uint32_le(offset: i64) -> i64:
        if offset < 0 or offset + 3 >= self.bytes.len():
            return 0
        val b0 = self.bytes[offset] as i64
        val b1 = self.bytes[offset + 1] as i64
        val b2 = self.bytes[offset + 2] as i64
        val b3 = self.bytes[offset + 3] as i64
        b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

    fn read_uint32_be(offset: i64) -> i64:
        if offset < 0 or offset + 3 >= self.bytes.len():
            return 0
        val b0 = self.bytes[offset] as i64
        val b1 = self.bytes[offset + 1] as i64
        val b2 = self.bytes[offset + 2] as i64
        val b3 = self.bytes[offset + 3] as i64
        (b0 << 24) | (b1 << 16) | (b2 << 8) | b3

    fn write_uint8(value: i64, offset: i64) -> NodeBuffer:
        var out: [u8] = []
        for b in self.bytes:
            out.push(b)
        if offset >= 0 and offset < out.len():
            out[offset] = _buffer_byte(value)
        NodeBuffer(bytes: out)

    fn write_uint16_le(value: i64, offset: i64) -> NodeBuffer:
        var out: [u8] = []
        for b in self.bytes:
            out.push(b)
        if offset >= 0 and offset + 1 < out.len():
            out[offset] = _buffer_byte(value)
            out[offset + 1] = _buffer_byte(value >> 8)
        NodeBuffer(bytes: out)

    fn write_uint16_be(value: i64, offset: i64) -> NodeBuffer:
        var out: [u8] = []
        for b in self.bytes:
            out.push(b)
        if offset >= 0 and offset + 1 < out.len():
            out[offset] = _buffer_byte(value >> 8)
            out[offset + 1] = _buffer_byte(value)
        NodeBuffer(bytes: out)

    fn write_uint32_le(value: i64, offset: i64) -> NodeBuffer:
        var out: [u8] = []
        for b in self.bytes:
            out.push(b)
        if offset >= 0 and offset + 3 < out.len():
            out[offset] = _buffer_byte(value)
            out[offset + 1] = _buffer_byte(value >> 8)
            out[offset + 2] = _buffer_byte(value >> 16)
            out[offset + 3] = _buffer_byte(value >> 24)
        NodeBuffer(bytes: out)

    fn write_uint32_be(value: i64, offset: i64) -> NodeBuffer:
        var out: [u8] = []
        for b in self.bytes:
            out.push(b)
        if offset >= 0 and offset + 3 < out.len():
            out[offset] = _buffer_byte(value >> 24)
            out[offset + 1] = _buffer_byte(value >> 16)
            out[offset + 2] = _buffer_byte(value >> 8)
            out[offset + 3] = _buffer_byte(value)
        NodeBuffer(bytes: out)

    fn equals(other: NodeBuffer) -> bool:
        if self.bytes.len() != other.bytes.len():
            return false
        var i = 0
        while i < self.bytes.len():
            if self.bytes[i] != other.bytes[i]:
                return false
            i = i + 1
        true

    fn compare(other: NodeBuffer) -> i64:
        var i = 0
        while i < self.bytes.len() and i < other.bytes.len():
            val left = self.bytes[i] as i64
            val right = other.bytes[i] as i64
            if left < right:
                return -1
            if left > right:
                return 1
            i = i + 1
        if self.bytes.len() < other.bytes.len():
            return -1
        if self.bytes.len() > other.bytes.len():
            return 1
        0

fn _buffer_arg_string(args: [JsValue], index: i64) -> text:
    if index < 0 or index >= args.len():
        return ""
    match args[index]:
        JsValue.String(v): v
        _: ""

fn _buffer_byte(value: i64) -> u8:
    var byte = value % 256
    if byte < 0:
        byte = byte + 256
    byte as u8

fn _buffer_normalize_encoding(encoding: text) -> text:
    val clean = encoding.trim().lower()
    if clean == "" or clean == "utf-8":
        return "utf8"
    clean

fn _buffer_hex_digit(ch: text) -> i64:
    if ch >= "0" and ch <= "9":
        return ch.char_at(0) as i64 - 48
    if ch >= "a" and ch <= "f":
        return ch.char_at(0) as i64 - 87
    if ch >= "A" and ch <= "F":
        return ch.char_at(0) as i64 - 55
    -1

fn _buffer_decode_hex(value: text) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i + 1 < value.len():
        val hi = _buffer_hex_digit(value.substring(i, i + 1))
        val lo = _buffer_hex_digit(value.substring(i + 1, i + 2))
        if hi < 0 or lo < 0:
            return out
        out.push(((hi << 4) | lo) as u8)
        i = i + 2
    out

fn _buffer_encode_hex(bytes: [u8]) -> text:
    val table = "0123456789abcdef"
    var out = ""
    for b in bytes:
        val n = b as i64
        out = out + table.substring((n >> 4) & 15, ((n >> 4) & 15) + 1)
        out = out + table.substring(n & 15, (n & 15) + 1)
    out

fn _buffer_bytes_to_text(bytes: [u8]) -> text:
    var out = ""
    for b in bytes:
        out = out + (b as i64).chr()
    out

fn _buffer_decode(value: text, encoding: text) -> [u8]:
    val enc = _buffer_normalize_encoding(encoding)
    if enc == "hex":
        return _buffer_decode_hex(value)
    if enc == "base64":
        return base64_decode(value).bytes()
    value.bytes()

fn _buffer_encode(bytes: [u8], encoding: text) -> text:
    val enc = _buffer_normalize_encoding(encoding)
    if enc == "hex":
        return _buffer_encode_hex(bytes)
    if enc == "base64":
        return base64_encode(_buffer_bytes_to_text(bytes))
    _buffer_bytes_to_text(bytes)

fn buffer_byteLength(args: [JsValue]) -> JsValue:
    val value = _buffer_arg_string(args, 0)
    val encoding = _buffer_arg_string(args, 1)
    JsValue.Number(v: _buffer_decode(value, encoding).len().to_f64())

fn buffer_from_toString(args: [JsValue]) -> JsValue:
    val value = _buffer_arg_string(args, 0)
    val input_encoding = _buffer_arg_string(args, 1)
    val output_encoding = _buffer_arg_string(args, 2)
    val buffer = NodeBuffer.from_text(value, input_encoding)
    JsValue.String(v: buffer.to_string(output_encoding))

fn buffer_concat_toString(args: [JsValue]) -> JsValue:
    val left = NodeBuffer.from_text(_buffer_arg_string(args, 0), _buffer_arg_string(args, 1))
    val right = NodeBuffer.from_text(_buffer_arg_string(args, 2), _buffer_arg_string(args, 3))
    val output_encoding = _buffer_arg_string(args, 4)
    JsValue.String(v: NodeBuffer.concat([left, right]).to_string(output_encoding))
