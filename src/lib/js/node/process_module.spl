# Node.js-compatible process helpers for the Simple JS runtime.
#
# This deterministic subset intentionally avoids ambient host process state. JS
# object, array, and callback scheduling integration require runtime support, so
# unsupported capabilities return typed unavailable values instead of fake state.

use std.js.types.js_types.{JsValue}

fn _process_arg_string(args: [JsValue], index: i64) -> text:
    if index < 0 or index >= args.len():
        return ""
    match args[index]:
        JsValue.String(v): v
        _: ""

fn process_platform(args: [JsValue]) -> JsValue:
    JsValue.String(v: "linux")

fn process_arch(args: [JsValue]) -> JsValue:
    JsValue.String(v: "x64")

fn process_version(args: [JsValue]) -> JsValue:
    JsValue.String(v: "v0.0.0-simple")

fn process_versions_node(args: [JsValue]) -> JsValue:
    JsValue.String(v: "0.0.0-simple")

fn process_versions_v8(args: [JsValue]) -> JsValue:
    JsValue.String(v: "simple-js")

fn process_versions_uv(args: [JsValue]) -> JsValue:
    JsValue.String(v: "unavailable")

fn process_release_name(args: [JsValue]) -> JsValue:
    JsValue.String(v: "node")

fn process_release_sourceUrl(args: [JsValue]) -> JsValue:
    JsValue.Undefined

fn process_release_lts(args: [JsValue]) -> JsValue:
    JsValue.Boolean(v: false)

fn process_cwd(args: [JsValue]) -> JsValue:
    JsValue.String(v: "/")

fn process_argv(args: [JsValue]) -> [text]:
    ["simple", ""]

fn process_env_get(args: [JsValue]) -> JsValue:
    val key = _process_arg_string(args, 0)
    if key == "":
        return JsValue.Undefined
    JsValue.Undefined

fn process_nextTick(args: [JsValue]) -> JsValue:
    JsValue.Undefined
