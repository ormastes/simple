# Node.js-compatible crypto helpers for deterministic JS/Node infrastructure.
#
# This covers bounded hashing needed by CLI bundles without exposing host
# randomness, key stores, TLS state, or native OpenSSL handles.

use std.js.types.js_types.{JsValue}
use std.crypto.sha256.{sha256_text}
use std.crypto.sha1.{sha1_hex}

fn _crypto_arg_string(args: [JsValue], index: i64) -> text:
    if index < 0 or index >= args.len():
        return ""
    match args[index]:
        JsValue.String(v): v
        _: ""

fn crypto_normalize_algorithm(algorithm: text) -> text:
    val clean = algorithm.trim().lower()
    if clean == "sha256" or clean == "sha-256":
        return "sha256"
    if clean == "sha1" or clean == "sha-1":
        return "sha1"
    ""

fn crypto_hash_digest_text(algorithm: text, data: text, encoding: text) -> JsValue:
    val normalized = crypto_normalize_algorithm(algorithm)
    if normalized == "":
        return JsValue.String(v: "denied")
    val digest_encoding = encoding.trim().lower()
    if digest_encoding != "" and digest_encoding != "hex":
        return JsValue.String(v: "denied")
    if normalized == "sha1":
        return JsValue.String(v: sha1_hex(data))
    JsValue.String(v: sha256_text(data))

fn crypto_createHash_digest(args: [JsValue]) -> JsValue:
    crypto_hash_digest_text(_crypto_arg_string(args, 0), _crypto_arg_string(args, 1), _crypto_arg_string(args, 2))
