# JS AST node types for the Simple Browser JS parser and interpreter.

use std.js.types.js_types.JsValue

class DestructProp:
    key: text
    value: JsExpression

class SwitchCase:
    test: JsExpression?
    consequent: [JsStatement]

enum JsExpression:
    Literal(value: JsValue)
    Identifier(name: text)
    Binary(op: text, left: JsExpression, right: JsExpression)
    Unary(op: text, operand: JsExpression)
    Call(callee: JsExpression, args: [JsExpression])
    Member(object: JsExpression, property: text)
    ComputedMember(object: JsExpression, property: JsExpression)
    Assignment(target: JsExpression, value: JsExpression)
    Array(elements: [JsExpression])
    ObjectExpr(properties: [DestructProp])
    Ternary(condition: JsExpression, consequent: JsExpression, alternate: JsExpression)
    ArrowFunction(params: [text], body: [JsStatement])
    SpreadElement(argument: JsExpression)
    TemplateLiteral(quasis: [text], expressions: [JsExpression])
    Delete(del_expr: JsExpression)
    InstanceOf(left: JsExpression, right: JsExpression)
    InExpr(left: JsExpression, right: JsExpression)
    NewExpr(callee: JsExpression, args: [JsExpression])
    ObjectPattern(props: [DestructProp])
    ArrayPattern(elements: [JsExpression])
    # Regex literal: /pattern/flags
    RegexLiteral(pattern: text, flags: text)

enum JsStatement:
    VarDecl(name: text, init: JsExpression)
    LetDecl(name: text, init: JsExpression)
    ConstDecl(name: text, init: JsExpression)
    DestructVarDecl(pattern: JsExpression, init: JsExpression, kind: text)
    ExprStmt(expr: JsExpression)
    Return(value: JsExpression)
    If(cond: JsExpression, then_body: [JsStatement], else_body: [JsStatement])
    While(cond: JsExpression, body: [JsStatement])
    DoWhile(cond: JsExpression, body: [JsStatement])
    For(init: JsStatement?, cond: JsExpression?, update: JsExpression?, body: [JsStatement])
    ForIn(binding: text, object: JsExpression, body: [JsStatement])
    ForOf(binding: text, iterable: JsExpression, body: [JsStatement])
    Block(stmts: [JsStatement])
    FnDecl(name: text, params: [text], body: [JsStatement])
    TryCatch(try_body: [JsStatement], catch_param: text, catch_body: [JsStatement], finally_body: [JsStatement])
    Switch(discriminant: JsExpression, cases: [SwitchCase])
    ThrowStmt(expr: JsExpression)
    BreakStmt
    ContinueStmt
    ClassDecl(name: text, parent_name: text, constructor: JsStatement, methods: [JsStatement])
    LabeledStmt(label: text, body: JsStatement)
