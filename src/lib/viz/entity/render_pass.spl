# RenderPass: ordered list of quads composited into an output rectangle

use std.skia.entity.geometry.{SkRect}
use std.skia.entity.matrix.{Matrix3x3}
use std.viz.entity.draw_quad.{DrawQuad, SharedQuadState}

class RenderPass:
    id: i32
    output_rect: SkRect
    damage_rect: SkRect
    transform_to_root_target: Matrix3x3
    filters_disabled: bool
    quads: [DrawQuad]
    shared_quad_states: [SharedQuadState]
    backdrop_filter_bounds: Option<SkRect>

    static fn new(id: i32, output_rect: SkRect) -> RenderPass:
        RenderPass(
            id: id,
            output_rect: output_rect,
            damage_rect: output_rect,
            transform_to_root_target: Matrix3x3.identity(),
            filters_disabled: false,
            quads: [],
            shared_quad_states: [],
            backdrop_filter_bounds: None
        )

    me add_shared_quad_state(sqs: SharedQuadState) -> i32:
        val idx = me.shared_quad_states.len().to_i32()
        me.shared_quad_states = me.shared_quad_states + [sqs]
        idx

    me add_quad(q: DrawQuad):
        me.quads = me.quads + [q]

    me quad_count() -> i32:
        me.quads.len().to_i32()
