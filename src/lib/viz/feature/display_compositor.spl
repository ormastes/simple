# DisplayCompositor: top-level compositor that submits and draws frames

use std.viz.entity.compositor_frame.{CompositorFrame}
use std.viz.entity.surface_id.{SurfaceId}
use std.viz.feature.aggregator.{Aggregator, AggregatorEntry}
use std.skia.entity.geometry.{SkRect}

class DisplayCompositor:
    aggregator: Aggregator
    output_bounds: SkRect

    static fn new(output_bounds: SkRect) -> DisplayCompositor:
        DisplayCompositor(
            aggregator: Aggregator.new(),
            output_bounds: output_bounds
        )

    me submit_frame(entry: AggregatorEntry):
        me.aggregator.register_frame(entry)

    me draw_frame(root: SurfaceId) -> CompositorFrame:
        me.aggregator.aggregate(root)
