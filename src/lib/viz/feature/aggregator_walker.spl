# AggregatorWalker: walk + inline referenced surfaces without coord-space composition

use std.viz.entity.compositor_frame.{CompositorFrame, FrameMetadata}
use std.viz.entity.render_pass.{RenderPass}
use std.viz.entity.draw_quad.{DrawQuad, DrawQuadKind}
use std.viz.entity.surface_id.{SurfaceId, FrameSinkId, LocalSurfaceId}
use std.skia.entity.geometry.{SkRect}
use std.viz.feature.aggregator.{AggregatorEntry}

enum SurfaceResolution:
    Present
    Missing
    Deferred

class WalkerContext:
    known_frames: [AggregatorEntry]
    deferred_ids: [SurfaceId]

    static fn new(known_frames: [AggregatorEntry]) -> WalkerContext:
        WalkerContext(known_frames: known_frames, deferred_ids: [])

    me mark_deferred(id: SurfaceId):
        me.deferred_ids = me.deferred_ids + [id]

    me resolve(id: SurfaceId) -> SurfaceResolution:
        var i = 0
        while i < me.deferred_ids.len().to_i32():
            val did = me.deferred_ids[i.to_i64()]
            if did.equals(id):
                return SurfaceResolution.Deferred
            i = i + 1
        var j = 0
        while j < me.known_frames.len().to_i32():
            val entry = me.known_frames[j.to_i64()]
            if entry.surface_id.equals(id):
                return SurfaceResolution.Present
            j = j + 1
        SurfaceResolution.Missing

fn find_frame_for(context: WalkerContext, id: SurfaceId) -> Option<CompositorFrame>:
    var i = 0
    while i < context.known_frames.len().to_i32():
        val entry = context.known_frames[i.to_i64()]
        if entry.surface_id.equals(id):
            return Some(entry.frame)
        i = i + 1
    None

fn _sid_already_visited(visited: [SurfaceId], id: SurfaceId) -> bool:
    var i = 0
    while i < visited.len().to_i32():
        val v = visited[i.to_i64()]
        if v.equals(id):
            return true
        i = i + 1
    false

fn walk_referenced_surfaces(root_frame: CompositorFrame, context: WalkerContext) -> [SurfaceId]:
    var result: [SurfaceId] = []
    var visited: [SurfaceId] = []
    var queue: [SurfaceId] = root_frame.referenced_surfaces
    while queue.len().to_i32() > 0:
        val head = queue[0]
        var tail: [SurfaceId] = []
        var qi = 1
        while qi < queue.len().to_i32():
            tail = tail + [queue[qi.to_i64()]]
            qi = qi + 1
        queue = tail
        if _sid_already_visited(visited, head):
            pass_do_nothing
        else:
            visited = visited + [head]
            result = result + [head]
            val maybe_frame = find_frame_for(context, head)
            if val Some(child_frame) = maybe_frame:
                var ci = 0
                while ci < child_frame.referenced_surfaces.len().to_i32():
                    val child_ref = child_frame.referenced_surfaces[ci.to_i64()]
                    if _sid_already_visited(visited, child_ref):
                        pass_do_nothing
                    else:
                        queue = queue + [child_ref]
                    ci = ci + 1
    result

fn _remap_quad_sqs(q: DrawQuad, offset: i32) -> DrawQuad:
    DrawQuad(
        kind: q.kind,
        shared_quad_state_index: q.shared_quad_state_index + offset,
        rect: q.rect,
        visible_rect: q.visible_rect,
        needs_blending: q.needs_blending,
        solid_color: q.solid_color,
        texture_mailbox: q.texture_mailbox,
        texture_premultiplied: q.texture_premultiplied,
        uv_top_left: q.uv_top_left,
        uv_bottom_right: q.uv_bottom_right,
        render_pass_id: q.render_pass_id,
        mask_resource_id: q.mask_resource_id,
        mask_uv_rect: q.mask_uv_rect,
        filters_scale: q.filters_scale,
        video_plane_count: q.video_plane_count,
        debug_width: q.debug_width
    )

fn inline_render_pass(parent_pass: RenderPass, child_frame: CompositorFrame) -> RenderPass:
    val child_pass_count = child_frame.render_pass_list.len().to_i32()
    if child_pass_count == 0:
        return parent_pass
    val child_root_pass = child_frame.render_pass_list[(child_pass_count - 1).to_i64()]
    val sqs_offset = parent_pass.shared_quad_states.len().to_i32()
    var merged_sqs = parent_pass.shared_quad_states
    var ci = 0
    while ci < child_root_pass.shared_quad_states.len().to_i32():
        merged_sqs = merged_sqs + [child_root_pass.shared_quad_states[ci.to_i64()]]
        ci = ci + 1
    var merged_quads = parent_pass.quads
    var qi = 0
    while qi < child_root_pass.quads.len().to_i32():
        val child_q = child_root_pass.quads[qi.to_i64()]
        val remapped = _remap_quad_sqs(child_q, sqs_offset)
        merged_quads = merged_quads + [remapped]
        qi = qi + 1
    RenderPass(
        id: parent_pass.id,
        output_rect: parent_pass.output_rect,
        damage_rect: parent_pass.damage_rect,
        transform_to_root_target: parent_pass.transform_to_root_target,
        filters_disabled: parent_pass.filters_disabled,
        quads: merged_quads,
        shared_quad_states: merged_sqs,
        backdrop_filter_bounds: parent_pass.backdrop_filter_bounds
    )

fn drop_missing_surface(pass: RenderPass, missing_id_hint: text) -> RenderPass:
    # Drops RenderPassDrawQuads whose render_pass_id matches missing_id_hint (parsed as i32).
    # Convention: a RenderPassDrawQuad referencing a missing surface has render_pass_id < 0,
    # specifically render_pass_id == -client_id. The hint is the string of that client_id.
    # For simplicity, drop any RenderPass quad whose render_pass_id.to_text() == missing_id_hint.
    var kept_quads: [DrawQuad] = []
    var i = 0
    while i < pass.quads.len().to_i32():
        val q = pass.quads[i.to_i64()]
        var drop = false
        match q.kind:
            DrawQuadKind.RenderPass:
                if q.render_pass_id.to_text() == missing_id_hint:
                    drop = true
            _:
                pass_do_nothing
        if drop:
            pass_do_nothing
        else:
            kept_quads = kept_quads + [q]
        i = i + 1
    RenderPass(
        id: pass.id,
        output_rect: pass.output_rect,
        damage_rect: pass.damage_rect,
        transform_to_root_target: pass.transform_to_root_target,
        filters_disabled: pass.filters_disabled,
        quads: kept_quads,
        shared_quad_states: pass.shared_quad_states,
        backdrop_filter_bounds: pass.backdrop_filter_bounds
    )

fn placeholder_deferred_surface(pass: RenderPass, surface_id: SurfaceId) -> RenderPass:
    # TODO(viz-aggregator-placeholder): emit a CheckerDrawQuad covering the surface region.
    # For now, return pass unmodified; real impl would append a debug solid-color quad.
    pass

fn _rewrite_pass(pass: RenderPass, context: WalkerContext) -> RenderPass:
    var current = pass
    var i = 0
    while i < pass.quads.len().to_i32():
        val q = pass.quads[i.to_i64()]
        match q.kind:
            DrawQuadKind.RenderPass:
                if q.render_pass_id < 0:
                    val client_id = (0 - q.render_pass_id)
                    val probe_sid = SurfaceId(
                        frame_sink_id: FrameSinkId(client_id: client_id, sink_id: 0),
                        local_surface_id: LocalSurfaceId(parent_sequence_number: 0, child_sequence_number: 0)
                    )
                    val resolution = context.resolve(probe_sid)
                    match resolution:
                        SurfaceResolution.Present:
                            val maybe_frame = find_frame_for(context, probe_sid)
                            if val Some(child_frame) = maybe_frame:
                                current = inline_render_pass(current, child_frame)
                        SurfaceResolution.Missing:
                            current = drop_missing_surface(current, q.render_pass_id.to_text())
                        SurfaceResolution.Deferred:
                            current = placeholder_deferred_surface(current, probe_sid)
            _:
                pass_do_nothing
        i = i + 1
    current

fn walk_and_inline(root_frame: CompositorFrame, context: WalkerContext) -> CompositorFrame:
    # TODO(viz-aggregator): coord-space composition lives in 6b aggregator_compose.spl (next wave)
    var new_passes: [RenderPass] = []
    var i = 0
    while i < root_frame.render_pass_list.len().to_i32():
        val pass = root_frame.render_pass_list[i.to_i64()]
        val rewritten = _rewrite_pass(pass, context)
        new_passes = new_passes + [rewritten]
        i = i + 1
    CompositorFrame(
        metadata: root_frame.metadata,
        render_pass_list: new_passes,
        referenced_surfaces: root_frame.referenced_surfaces,
        device_viewport_rect: root_frame.device_viewport_rect
    )
