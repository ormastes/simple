# Aggregator: collects CompositorFrames per SurfaceId and resolves root frame

use std.viz.entity.compositor_frame.{CompositorFrame}
use std.viz.entity.surface_id.{SurfaceId}

class AggregatorEntry:
    surface_id: SurfaceId
    frame: CompositorFrame

class Aggregator:
    known_frames: [AggregatorEntry]

    static fn new() -> Aggregator:
        Aggregator(known_frames: [])

    me register_frame(entry: AggregatorEntry):
        var found = false
        var i = 0
        var result: [AggregatorEntry] = []
        while i < me.known_frames.len().to_i32():
            val existing = me.known_frames[i.to_i64()]
            if existing.surface_id.equals(entry.surface_id):
                result = result + [entry]
                found = true
            else:
                result = result + [existing]
            i = i + 1
        if found:
            me.known_frames = result
        else:
            me.known_frames = me.known_frames + [entry]

    # TODO(viz-aggregator): inline referenced_surfaces' render passes into root frame
    me aggregate(root: SurfaceId) -> CompositorFrame:
        var i = 0
        while i < me.known_frames.len().to_i32():
            val entry = me.known_frames[i.to_i64()]
            if entry.surface_id.equals(root):
                return entry.frame
            i = i + 1
        CompositorFrame.empty()
