"""
# RV32 Pipeline Control
"""

class Rv32PipelineControl:
    halted: bool
    trapped: bool

    static fn create() -> Rv32PipelineControl:
        Rv32PipelineControl(halted: false, trapped: false)

    me mark_halt():
        self.halted = true

    me mark_trap():
        self.trapped = true

    fn active() -> bool:
        not self.halted and not self.trapped
