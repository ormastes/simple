"""
# RV32 Execute Helpers
"""

use hardware.rv32gc.core.rv32_decode.{Rv32DecodedInstruction}

fn rv32_execute_add(decoded: Rv32DecodedInstruction, rs1_value: i64, rs2_value: i64) -> i64:
    if decoded.opcode == 0x33 and decoded.funct3 == 0 and decoded.funct7 == 0:
        return (rs1_value + rs2_value) and 0xFFFFFFFF
    0

fn rv32_execute_addi(decoded: Rv32DecodedInstruction, rs1_value: i64, imm12: i64) -> i64:
    if decoded.opcode == 0x13 and decoded.funct3 == 0:
        return (rs1_value + imm12) and 0xFFFFFFFF
    0
