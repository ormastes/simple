"""
# RV32 Decode Helpers
"""

struct Rv32DecodedInstruction:
    raw: i64
    opcode: i64
    rd: i64
    funct3: i64
    rs1: i64
    rs2: i64
    funct7: i64

fn rv32_decode_inst(word: i64) -> Rv32DecodedInstruction:
    Rv32DecodedInstruction(
        raw: word and 0xFFFFFFFF,
        opcode: word and 0x7F,
        rd: (word >> 7) and 0x1F,
        funct3: (word >> 12) and 0x7,
        rs1: (word >> 15) and 0x1F,
        rs2: (word >> 20) and 0x1F,
        funct7: (word >> 25) and 0x7F
    )
