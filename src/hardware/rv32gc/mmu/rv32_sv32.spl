"""
# RV32 Sv32 MMU
"""

use hardware.rv32gc.mmu.rv32_tlb.{Rv32Tlb}

class Rv32Sv32:
    tlb: Rv32Tlb
    enabled: bool

    static fn create() -> Rv32Sv32:
        Rv32Sv32(tlb: Rv32Tlb.create(), enabled: false)

    fn mmu_mode() -> text:
        if self.enabled:
            return "sv32"
        "bare"

    fn translate(vaddr: i64) -> i64:
        if not self.enabled:
            return vaddr and 0xFFFFFFFF
        self.tlb.translate(vaddr and 0xFFFFFFFF)

    me set_enabled(enabled: bool):
        self.enabled = enabled
