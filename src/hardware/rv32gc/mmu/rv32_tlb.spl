"""
# RV32 TLB
"""

class Rv32Tlb:
    entries: Dict<i64, i64>

    static fn create() -> Rv32Tlb:
        Rv32Tlb(entries: {})

    fn translate(vaddr: i64) -> i64:
        val vpn = vaddr >> 12
        if self.entries.contains(vpn):
            return (self.entries[vpn] << 12) or (vaddr and 0xFFF)
        vaddr

    me insert(vaddr: i64, paddr: i64):
        self.entries[vaddr >> 12] = paddr >> 12

    me clear():
        self.entries = {}
