"""
# RV32 RAM
"""

use hardware.rv32gc.core.rv32_memory.{MemResult, mem_ok, mem_fault}

class Rv32Ram:
    bytes: [i64]
    size: i64

    static fn create(size: i64) -> Rv32Ram:
        var data: [i64] = []
        var idx = 0
        while idx < size:
            data.push(0)
            idx = idx + 1
        Rv32Ram(bytes: data, size: size)

    fn _in_bounds(offset: i64, width: i64) -> bool:
        offset >= 0 and (offset + width) <= self.size

    fn read8(offset: i64) -> MemResult:
        if not self._in_bounds(offset, 1):
            return mem_fault(5)
        mem_ok(self.bytes[offset] and 0xFF)

    fn read16(offset: i64) -> MemResult:
        if not self._in_bounds(offset, 2):
            return mem_fault(5)
        mem_ok((self.bytes[offset] and 0xFF) or ((self.bytes[offset + 1] and 0xFF) << 8))

    fn read32(offset: i64) -> MemResult:
        if not self._in_bounds(offset, 4):
            return mem_fault(5)
        mem_ok(
            (self.bytes[offset] and 0xFF) or
            ((self.bytes[offset + 1] and 0xFF) << 8) or
            ((self.bytes[offset + 2] and 0xFF) << 16) or
            ((self.bytes[offset + 3] and 0xFF) << 24)
        )

    me write8(offset: i64, value: i64) -> MemResult:
        if not self._in_bounds(offset, 1):
            return mem_fault(7)
        self.bytes[offset] = value and 0xFF
        mem_ok(0)

    me write16(offset: i64, value: i64) -> MemResult:
        if not self._in_bounds(offset, 2):
            return mem_fault(7)
        self.bytes[offset] = value and 0xFF
        self.bytes[offset + 1] = (value >> 8) and 0xFF
        mem_ok(0)

    me write32(offset: i64, value: i64) -> MemResult:
        if not self._in_bounds(offset, 4):
            return mem_fault(7)
        self.bytes[offset] = value and 0xFF
        self.bytes[offset + 1] = (value >> 8) and 0xFF
        self.bytes[offset + 2] = (value >> 16) and 0xFF
        self.bytes[offset + 3] = (value >> 24) and 0xFF
        mem_ok(0)

    me load_bytes(offset: i64, data: [i64]):
        var idx = 0
        while idx < data.len() and (offset + idx) < self.size:
            self.bytes[offset + idx] = data[idx] and 0xFF
            idx = idx + 1
