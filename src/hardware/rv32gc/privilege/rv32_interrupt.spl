"""
# RV32 Interrupt State
"""

class Rv32InterruptController:
    machine_software_pending: bool
    machine_timer_pending: bool
    machine_external_pending: bool

    static fn create() -> Rv32InterruptController:
        Rv32InterruptController(
            machine_software_pending: false,
            machine_timer_pending: false,
            machine_external_pending: false
        )

    fn has_pending() -> bool:
        self.machine_software_pending or self.machine_timer_pending or self.machine_external_pending
