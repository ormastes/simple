"""
# RV32 Privilege State
"""

enum Rv32PrivilegeMode:
    Machine
    Supervisor
    User

class Rv32PrivilegeState:
    mode: Rv32PrivilegeMode

    static fn create() -> Rv32PrivilegeState:
        Rv32PrivilegeState(mode: Rv32PrivilegeMode.Machine)

    me enter_supervisor():
        self.mode = Rv32PrivilegeMode.Supervisor

    me enter_machine():
        self.mode = Rv32PrivilegeMode.Machine
