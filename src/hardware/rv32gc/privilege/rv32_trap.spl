"""
# RV32 Trap Control
"""

class Rv32TrapController:
    last_cause: i64
    last_tval: i64

    static fn create() -> Rv32TrapController:
        Rv32TrapController(last_cause: 0, last_tval: 0)

    me take(cause: i64, tval: i64):
        self.last_cause = cause and 0xFFFFFFFF
        self.last_tval = tval and 0xFFFFFFFF
