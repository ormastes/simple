# RV32 Writeback Stage (WB)
#
# Register file write, writeback mux (ALU result vs load data).
#
# @hardware

use compiler.backend.vhdl.vhdl_builder.VhdlBuilder
use hardware.rv32imac.pkg.rv32_types_pkg.*

# ============================================================================
# Writeback Model
# ============================================================================

fn writeback_data(mem_op: MemOp, alu_result: i64, load_data: i64) -> i64:
    """Select writeback data source."""
    if mem_op == MemOp.Load:
        return load_data
    alu_result

# ============================================================================
# VHDL Generation
# ============================================================================

fn generate_rv32_writeback_vhdl() -> text:
    """Generate VHDL for writeback stage."""
    var b = VhdlBuilder.create("rv32_writeback")
    b.emit_library_header()
    b.emit_use_package("work", "rv32_types_pkg")

    b.emit_entity_begin("rv32_writeback")
    b.emit_port_begin()
    b.emit_comment("From MEM stage")
    b.emit_port("mem_pc", "in", "word_t", false)
    b.emit_port("mem_alu_result", "in", "word_t", false)
    b.emit_port("mem_load_data", "in", "word_t", false)
    b.emit_port("mem_rd", "in", "reg_addr_t", false)
    b.emit_port("mem_mem_op", "in", "mem_op_t", false)
    b.emit_port("mem_reg_write", "in", "std_logic", false)
    b.emit_port("mem_valid", "in", "std_logic", false)
    b.emit_comment("Register file write port")
    b.emit_port("wb_rd", "out", "reg_addr_t", false)
    b.emit_port("wb_data", "out", "word_t", false)
    b.emit_port("wb_we", "out", "std_logic", false)
    b.emit_comment("Retirement trace")
    b.emit_port("retire_valid", "out", "std_logic", false)
    b.emit_port("retire_pc", "out", "word_t", true)
    b.emit_port_end()
    b.emit_entity_end("rv32_writeback")

    b.emit_architecture_begin("rv32_writeback", "rtl")
    b.emit_architecture_body_begin()

    b.emit_comment("Writeback mux: load data or ALU result")
    b.emit_signal_assign("wb_data", "mem_load_data when mem_mem_op = MEM_LOAD else mem_alu_result")
    b.emit_signal_assign("wb_rd", "mem_rd")
    b.emit_signal_assign("wb_we", "mem_reg_write and mem_valid")
    b.emit_raw("")

    b.emit_comment("Retirement trace port")
    b.emit_signal_assign("retire_valid", "mem_valid")
    b.emit_signal_assign("retire_pc", "mem_pc")

    b.emit_architecture_end("rtl")
    b.build()
