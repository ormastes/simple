# RV32 Memory Stage (MEM)
#
# Load/store execution, byte/half/word access, sign extension.
#
# @hardware

use hardware.rv32imac.pkg.rv32_types_pkg.*

# ============================================================================
# Memory Access Model
# ============================================================================

fn mem_load(memory: [i64], addr: i64, width: MemWidth, signed: bool) -> i64:
    """Load from memory with byte/half/word access and sign extension."""
    val byte_addr = addr and 0xFFFFFFFC
    val word_idx = byte_addr / 4
    if word_idx >= memory.len():
        return 0
    val word = memory[word_idx]
    val offset = addr and 0x3

    if width == MemWidth.Byte:
        val byte_val = (word >> (offset * 8)) and 0xFF
        if signed and (byte_val and 0x80) != 0:
            return byte_val or 0xFFFFFF00
        return byte_val
    elif width == MemWidth.Half:
        val half_val = (word >> ((offset and 0x2) * 8)) and 0xFFFF
        if signed and (half_val and 0x8000) != 0:
            return half_val or 0xFFFF0000
        return half_val
    word and 0xFFFFFFFF

fn mem_store(memory: [i64], addr: i64, data: i64, width: MemWidth) -> [i64]:
    """Store to memory with byte/half/word access."""
    val byte_addr = addr and 0xFFFFFFFC
    val word_idx = byte_addr / 4
    if word_idx >= memory.len():
        return memory
    val word = memory[word_idx]
    val offset = addr and 0x3

    var new_word = word
    if width == MemWidth.Byte:
        val mask = 0xFF << (offset * 8)
        val shifted = (data and 0xFF) << (offset * 8)
        new_word = (word and (0xFFFFFFFF xor mask)) or shifted
    elif width == MemWidth.Half:
        val shift = (offset and 0x2) * 8
        val mask = 0xFFFF << shift
        val shifted = (data and 0xFFFF) << shift
        new_word = (word and (0xFFFFFFFF xor mask)) or shifted
    else:
        new_word = data and 0xFFFFFFFF

    var result = memory
    result[word_idx] = new_word
    result

# ============================================================================
# VHDL Generation
# ============================================================================

fn generate_rv32_memory_vhdl() -> text:
    """Generate VHDL for memory stage."""
    use compiler.backend.vhdl.vhdl_builder.VhdlBuilder
    var b = VhdlBuilder.create("rv32_memory")
    b.emit_library_header()
    b.emit_use_package("work", "rv32_types_pkg")

    b.emit_entity_begin("rv32_memory")
    b.emit_port_begin()
    b.emit_port("clk", "in", "std_logic", false)
    b.emit_port("rst", "in", "std_logic", false)
    b.emit_comment("From EX stage")
    b.emit_port("ex_pc", "in", "word_t", false)
    b.emit_port("ex_alu_result", "in", "word_t", false)
    b.emit_port("ex_rs2_data", "in", "word_t", false)
    b.emit_port("ex_rd", "in", "reg_addr_t", false)
    b.emit_port("ex_mem_op", "in", "mem_op_t", false)
    b.emit_port("ex_mem_width", "in", "mem_width_t", false)
    b.emit_port("ex_reg_write", "in", "std_logic", false)
    b.emit_port("ex_valid", "in", "std_logic", false)
    b.emit_comment("Data memory interface")
    b.emit_port("dmem_addr", "out", "word_t", false)
    b.emit_port("dmem_wdata", "out", "word_t", false)
    b.emit_port("dmem_rdata", "in", "word_t", false)
    b.emit_port("dmem_we", "out", "std_logic", false)
    b.emit_port("dmem_be", "out", "std_logic_vector(3 downto 0)", false)
    b.emit_comment("Output to WB stage")
    b.emit_port("mem_pc", "out", "word_t", false)
    b.emit_port("mem_alu_result", "out", "word_t", false)
    b.emit_port("mem_load_data", "out", "word_t", false)
    b.emit_port("mem_rd", "out", "reg_addr_t", false)
    b.emit_port("mem_mem_op", "out", "mem_op_t", false)
    b.emit_port("mem_reg_write", "out", "std_logic", false)
    b.emit_port("mem_valid", "out", "std_logic", true)
    b.emit_port_end()
    b.emit_entity_end("rv32_memory")

    b.emit_architecture_begin("rv32_memory", "rtl")
    b.emit_architecture_body_begin()

    b.emit_comment("Pass-through signals")
    b.emit_signal_assign("mem_pc", "ex_pc")
    b.emit_signal_assign("mem_alu_result", "ex_alu_result")
    b.emit_signal_assign("mem_rd", "ex_rd")
    b.emit_signal_assign("mem_mem_op", "ex_mem_op")
    b.emit_signal_assign("mem_reg_write", "ex_reg_write")
    b.emit_signal_assign("mem_valid", "ex_valid")
    b.emit_raw("")

    b.emit_comment("Data memory interface")
    b.emit_signal_assign("dmem_addr", "ex_alu_result")
    b.emit_signal_assign("dmem_wdata", "ex_rs2_data")
    b.emit_signal_assign("dmem_we", "'1' when ex_mem_op = MEM_STORE and ex_valid = '1' else '0'")
    b.emit_signal_assign("dmem_be", "\"1111\"")
    b.emit_signal_assign("mem_load_data", "dmem_rdata")

    b.emit_architecture_end("rtl")
    b.build()
