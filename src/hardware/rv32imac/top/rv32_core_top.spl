# RV32IMAC Core Top-Level
#
# Instantiates all 5 pipeline stages, register file, CSR file,
# and pipeline control unit.
#
# @hardware

use compiler.backend.vhdl.vhdl_builder.VhdlBuilder

# ============================================================================
# VHDL Generation
# ============================================================================

fn generate_rv32_core_top_vhdl() -> text:
    """Generate VHDL for the core top-level."""
    var b = VhdlBuilder.create("rv32_core_top")
    b.emit_library_header()
    b.emit_use_package("work", "rv32_types_pkg")
    b.emit_use_package("work", "rv32_isa_pkg")
    b.emit_use_package("work", "rv32_config_pkg")

    b.emit_entity_begin("rv32_core_top")
    b.emit_generic_begin()
    b.emit_generic_param("BOOT_ADDR", "word_t", Some("x\"00000000\""), true)
    b.emit_generic_end()
    b.emit_port_begin()
    b.emit_port("clk", "in", "std_logic", false)
    b.emit_port("rst", "in", "std_logic", false)
    b.emit_comment("Instruction memory interface")
    b.emit_port("imem_addr", "out", "word_t", false)
    b.emit_port("imem_rdata", "in", "word_t", false)
    b.emit_port("imem_valid", "in", "std_logic", false)
    b.emit_comment("Data memory interface")
    b.emit_port("dmem_addr", "out", "word_t", false)
    b.emit_port("dmem_wdata", "out", "word_t", false)
    b.emit_port("dmem_rdata", "in", "word_t", false)
    b.emit_port("dmem_we", "out", "std_logic", false)
    b.emit_port("dmem_be", "out", "std_logic_vector(3 downto 0)", false)
    b.emit_comment("Debug/trace")
    b.emit_port("retire_valid", "out", "std_logic", false)
    b.emit_port("retire_pc", "out", "word_t", true)
    b.emit_port_end()
    b.emit_entity_end("rv32_core_top")

    b.emit_architecture_begin("rv32_core_top", "rtl")

    b.emit_comment("Pipeline stage signals")
    b.emit_signal_decl("if_pc", "word_t", nil)
    b.emit_signal_decl("if_instr", "word_t", nil)
    b.emit_signal_decl("if_valid", "std_logic", nil)
    b.emit_raw("")
    b.emit_signal_decl("id_pc", "word_t", nil)
    b.emit_signal_decl("id_rs1_data", "word_t", nil)
    b.emit_signal_decl("id_rs2_data", "word_t", nil)
    b.emit_signal_decl("id_rd", "reg_addr_t", nil)
    b.emit_signal_decl("id_imm", "word_t", nil)
    b.emit_signal_decl("id_alu_op", "alu_op_t", nil)
    b.emit_signal_decl("id_branch_op", "branch_op_t", nil)
    b.emit_signal_decl("id_mem_op", "mem_op_t", nil)
    b.emit_signal_decl("id_mem_width", "mem_width_t", nil)
    b.emit_signal_decl("id_reg_write", "std_logic", nil)
    b.emit_signal_decl("id_use_imm", "std_logic", nil)
    b.emit_signal_decl("id_valid", "std_logic", nil)
    b.emit_raw("")
    b.emit_signal_decl("ex_pc", "word_t", nil)
    b.emit_signal_decl("ex_alu_result", "word_t", nil)
    b.emit_signal_decl("ex_rs2_data", "word_t", nil)
    b.emit_signal_decl("ex_rd", "reg_addr_t", nil)
    b.emit_signal_decl("ex_mem_op", "mem_op_t", nil)
    b.emit_signal_decl("ex_mem_width", "mem_width_t", nil)
    b.emit_signal_decl("ex_reg_write", "std_logic", nil)
    b.emit_signal_decl("ex_valid", "std_logic", nil)
    b.emit_raw("")
    b.emit_signal_decl("branch_taken_i", "std_logic", nil)
    b.emit_signal_decl("branch_target_i", "word_t", nil)
    b.emit_raw("")
    b.emit_signal_decl("mem_pc", "word_t", nil)
    b.emit_signal_decl("mem_alu_result", "word_t", nil)
    b.emit_signal_decl("mem_load_data", "word_t", nil)
    b.emit_signal_decl("mem_rd", "reg_addr_t", nil)
    b.emit_signal_decl("mem_mem_op", "mem_op_t", nil)
    b.emit_signal_decl("mem_reg_write_i", "std_logic", nil)
    b.emit_signal_decl("mem_valid", "std_logic", nil)
    b.emit_raw("")
    b.emit_signal_decl("wb_rd", "reg_addr_t", nil)
    b.emit_signal_decl("wb_data", "word_t", nil)
    b.emit_signal_decl("wb_we", "std_logic", nil)
    b.emit_raw("")
    b.emit_signal_decl("rs1_addr", "reg_addr_t", nil)
    b.emit_signal_decl("rs2_addr", "reg_addr_t", nil)
    b.emit_signal_decl("rs1_data", "word_t", nil)
    b.emit_signal_decl("rs2_data", "word_t", nil)
    b.emit_raw("")
    b.emit_signal_decl("stall_if", "std_logic", nil)
    b.emit_signal_decl("stall_id", "std_logic", nil)
    b.emit_signal_decl("flush_if", "std_logic", nil)
    b.emit_signal_decl("flush_id", "std_logic", nil)
    b.emit_signal_decl("flush_ex", "std_logic", nil)

    b.emit_architecture_body_begin()

    # Component instantiations
    b.emit_comment("=== Fetch Stage ===")
    b.emit_instance_begin("u_fetch", "rv32_fetch")
    b.emit_port_map_begin()
    b.emit_port_map_entry("clk", "clk", false)
    b.emit_port_map_entry("rst", "rst", false)
    b.emit_port_map_entry("stall", "stall_if", false)
    b.emit_port_map_entry("flush", "flush_if", false)
    b.emit_port_map_entry("branch_taken", "branch_taken_i", false)
    b.emit_port_map_entry("branch_target", "branch_target_i", false)
    b.emit_port_map_entry("imem_addr", "imem_addr", false)
    b.emit_port_map_entry("imem_data", "imem_rdata", false)
    b.emit_port_map_entry("imem_valid", "imem_valid", false)
    b.emit_port_map_entry("if_pc", "if_pc", false)
    b.emit_port_map_entry("if_instr", "if_instr", false)
    b.emit_port_map_entry("if_valid", "if_valid", true)
    b.emit_port_map_end()
    b.emit_raw("")

    b.emit_comment("=== Register File ===")
    b.emit_instance_begin("u_regfile", "rv32_regfile")
    b.emit_port_map_begin()
    b.emit_port_map_entry("clk", "clk", false)
    b.emit_port_map_entry("rst", "rst", false)
    b.emit_port_map_entry("rs1_addr", "rs1_addr", false)
    b.emit_port_map_entry("rs1_data", "rs1_data", false)
    b.emit_port_map_entry("rs2_addr", "rs2_addr", false)
    b.emit_port_map_entry("rs2_data", "rs2_data", false)
    b.emit_port_map_entry("wr_en", "wb_we", false)
    b.emit_port_map_entry("wr_addr", "wb_rd", false)
    b.emit_port_map_entry("wr_data", "wb_data", true)
    b.emit_port_map_end()
    b.emit_raw("")

    b.emit_comment("=== Decode Stage ===")
    b.emit_instance_begin("u_decode", "rv32_decode")
    b.emit_port_map_begin()
    b.emit_port_map_entry("clk", "clk", false)
    b.emit_port_map_entry("rst", "rst", false)
    b.emit_port_map_entry("stall", "stall_id", false)
    b.emit_port_map_entry("flush", "flush_id", false)
    b.emit_port_map_entry("if_pc", "if_pc", false)
    b.emit_port_map_entry("if_instr", "if_instr", false)
    b.emit_port_map_entry("if_valid", "if_valid", false)
    b.emit_port_map_entry("rs1_addr", "rs1_addr", false)
    b.emit_port_map_entry("rs2_addr", "rs2_addr", false)
    b.emit_port_map_entry("rs1_data", "rs1_data", false)
    b.emit_port_map_entry("rs2_data", "rs2_data", false)
    b.emit_port_map_entry("id_pc", "id_pc", false)
    b.emit_port_map_entry("id_rs1_data", "id_rs1_data", false)
    b.emit_port_map_entry("id_rs2_data", "id_rs2_data", false)
    b.emit_port_map_entry("id_rd", "id_rd", false)
    b.emit_port_map_entry("id_imm", "id_imm", false)
    b.emit_port_map_entry("id_alu_op", "id_alu_op", false)
    b.emit_port_map_entry("id_branch_op", "id_branch_op", false)
    b.emit_port_map_entry("id_mem_op", "id_mem_op", false)
    b.emit_port_map_entry("id_mem_width", "id_mem_width", false)
    b.emit_port_map_entry("id_reg_write", "id_reg_write", false)
    b.emit_port_map_entry("id_use_imm", "id_use_imm", false)
    b.emit_port_map_entry("id_valid", "id_valid", true)
    b.emit_port_map_end()
    b.emit_raw("")

    b.emit_comment("=== Writeback Stage ===")
    b.emit_instance_begin("u_writeback", "rv32_writeback")
    b.emit_port_map_begin()
    b.emit_port_map_entry("mem_pc", "mem_pc", false)
    b.emit_port_map_entry("mem_alu_result", "mem_alu_result", false)
    b.emit_port_map_entry("mem_load_data", "mem_load_data", false)
    b.emit_port_map_entry("mem_rd", "mem_rd", false)
    b.emit_port_map_entry("mem_mem_op", "mem_mem_op", false)
    b.emit_port_map_entry("mem_reg_write", "mem_reg_write_i", false)
    b.emit_port_map_entry("mem_valid", "mem_valid", false)
    b.emit_port_map_entry("wb_rd", "wb_rd", false)
    b.emit_port_map_entry("wb_data", "wb_data", false)
    b.emit_port_map_entry("wb_we", "wb_we", false)
    b.emit_port_map_entry("retire_valid", "retire_valid", false)
    b.emit_port_map_entry("retire_pc", "retire_pc", true)
    b.emit_port_map_end()

    b.emit_architecture_end("rtl")
    b.build()
