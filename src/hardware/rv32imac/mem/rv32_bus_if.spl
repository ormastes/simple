# RV32 Bus Interface
#
# Simple address-based bus decoder for the SoC memory map.
#
# @hardware

use hardware.rv32imac.top.rv32_soc_top.{BusTarget, decode_bus_target, ADDR_ROM_BASE, ADDR_SRAM_BASE, ADDR_UART_BASE, ADDR_TIMER_BASE}

# ============================================================================
# Bus Transaction
# ============================================================================

struct BusTransaction:
    addr: i64
    wdata: i64
    we: bool
    be: i64
    target: BusTarget

    static fn read(addr: i64) -> BusTransaction:
        BusTransaction(
            addr: addr,
            wdata: 0,
            we: false,
            be: 0xF,
            target: decode_bus_target(addr)
        )

    static fn write(addr: i64, data: i64, be: i64) -> BusTransaction:
        BusTransaction(
            addr: addr,
            wdata: data,
            we: true,
            be: be,
            target: decode_bus_target(addr)
        )

    fn local_addr() -> i64:
        """Get address relative to the target's base."""
        if self.target == BusTarget.Rom:
            return self.addr - ADDR_ROM_BASE
        elif self.target == BusTarget.Sram:
            return self.addr - ADDR_SRAM_BASE
        elif self.target == BusTarget.Uart:
            return self.addr - ADDR_UART_BASE
        elif self.target == BusTarget.Timer:
            return self.addr - ADDR_TIMER_BASE
        self.addr
