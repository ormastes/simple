# RV32IMAC Type Definitions Package
#
# Core type definitions for the RV32IMAC processor.
# Defines word types, register types, pipeline records, and ALU operations.
#
# @hardware

use compiler.backend.vhdl.vhdl_builder.VhdlBuilder

# ============================================================================
# Constants
# ============================================================================

val XLEN: i64 = 32
val NUM_REGS: i64 = 32
val ADDR_WIDTH: i64 = 32
val INSTR_WIDTH: i64 = 32

# ============================================================================
# ALU Operations
# ============================================================================

enum AluOp:
    Add
    Sub
    And
    Or
    Xor
    Sll
    Srl
    Sra
    Slt
    Sltu
    Mul
    Mulh
    Mulhsu
    Mulhu
    Div
    Divu
    Rem
    Remu
    PassB

# ============================================================================
# Branch Operations
# ============================================================================

enum BranchOp:
    Beq
    Bne
    Blt
    Bge
    Bltu
    Bgeu
    Jal
    Jalr
    None

# ============================================================================
# Memory Operations
# ============================================================================

enum MemOp:
    Load
    Store
    None

enum MemWidth:
    Byte
    Half
    Word

# ============================================================================
# Pipeline Register Records
# ============================================================================

struct IfIdReg:
    """IF/ID pipeline register."""
    pc: i64
    instruction: i64
    valid: bool

    static fn empty() -> IfIdReg:
        IfIdReg(pc: 0, instruction: 0, valid: false)

struct IdExReg:
    """ID/EX pipeline register."""
    pc: i64
    rs1_data: i64
    rs2_data: i64
    rd: i64
    rs1: i64
    rs2: i64
    imm: i64
    alu_op: AluOp
    branch_op: BranchOp
    mem_op: MemOp
    mem_width: MemWidth
    mem_signed: bool
    reg_write: bool
    use_imm: bool
    is_csr: bool
    csr_addr: i64
    valid: bool

    static fn empty() -> IdExReg:
        IdExReg(
            pc: 0, rs1_data: 0, rs2_data: 0,
            rd: 0, rs1: 0, rs2: 0, imm: 0,
            alu_op: AluOp.Add, branch_op: BranchOp.None,
            mem_op: MemOp.None, mem_width: MemWidth.Word,
            mem_signed: false, reg_write: false, use_imm: false,
            is_csr: false, csr_addr: 0, valid: false
        )

struct ExMemReg:
    """EX/MEM pipeline register."""
    pc: i64
    alu_result: i64
    rs2_data: i64
    rd: i64
    mem_op: MemOp
    mem_width: MemWidth
    mem_signed: bool
    reg_write: bool
    branch_taken: bool
    branch_target: i64
    valid: bool

    static fn empty() -> ExMemReg:
        ExMemReg(
            pc: 0, alu_result: 0, rs2_data: 0, rd: 0,
            mem_op: MemOp.None, mem_width: MemWidth.Word,
            mem_signed: false, reg_write: false,
            branch_taken: false, branch_target: 0, valid: false
        )

struct MemWbReg:
    """MEM/WB pipeline register."""
    pc: i64
    alu_result: i64
    mem_data: i64
    rd: i64
    mem_op: MemOp
    reg_write: bool
    valid: bool

    static fn empty() -> MemWbReg:
        MemWbReg(
            pc: 0, alu_result: 0, mem_data: 0, rd: 0,
            mem_op: MemOp.None, reg_write: false, valid: false
        )

# ============================================================================
# VHDL Package Generation
# ============================================================================

fn generate_rv32_types_pkg() -> text:
    """Generate VHDL package with RV32 type definitions."""
    var b = VhdlBuilder.create("rv32_types")
    b.emit_library_header()

    b.emit_package_begin("rv32_types")

    # Word type
    b.emit_subtype_decl("word_t", "std_logic_vector", "(31 downto 0)")
    b.emit_subtype_decl("half_t", "std_logic_vector", "(15 downto 0)")
    b.emit_subtype_decl("byte_t", "std_logic_vector", "(7 downto 0)")
    b.emit_subtype_decl("reg_addr_t", "std_logic_vector", "(4 downto 0)")
    b.emit_raw("")

    # Constants
    b.emit_constant_decl("XLEN", "integer", "32")
    b.emit_constant_decl("NUM_REGS", "integer", "32")
    b.emit_constant_decl("ZERO_WORD", "word_t", "(others => '0')")
    b.emit_raw("")

    # ALU operation type
    b.emit_type_decl("alu_op_t", "(ALU_ADD, ALU_SUB, ALU_AND, ALU_OR, ALU_XOR, ALU_SLL, ALU_SRL, ALU_SRA, ALU_SLT, ALU_SLTU, ALU_MUL, ALU_MULH, ALU_MULHSU, ALU_MULHU, ALU_DIV, ALU_DIVU, ALU_REM, ALU_REMU, ALU_PASS_B)")
    b.emit_raw("")

    # Branch operation type
    b.emit_type_decl("branch_op_t", "(BR_BEQ, BR_BNE, BR_BLT, BR_BGE, BR_BLTU, BR_BGEU, BR_JAL, BR_JALR, BR_NONE)")
    b.emit_raw("")

    # Memory operation type
    b.emit_type_decl("mem_op_t", "(MEM_LOAD, MEM_STORE, MEM_NONE)")
    b.emit_type_decl("mem_width_t", "(MW_BYTE, MW_HALF, MW_WORD)")
    b.emit_raw("")

    # Register file array type
    b.emit_type_decl("regfile_t", "array(0 to 31) of word_t")

    b.emit_package_end("rv32_types")
    b.build()
