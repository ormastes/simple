# RV32IMAC Debug Module Register Definitions
#
# RISC-V Debug Specification 0.13 register addresses and field definitions.
#
# @hardware

use compiler.backend.vhdl.vhdl_builder.VhdlBuilder

# ============================================================================
# Debug Module Registers (0x13 spec)
# ============================================================================

val DM_DATA0: i64        = 0x04
val DM_DATA1: i64        = 0x05
val DM_DMCONTROL: i64    = 0x10
val DM_DMSTATUS: i64     = 0x11
val DM_HARTINFO: i64     = 0x12
val DM_ABSTRACTCS: i64   = 0x16
val DM_COMMAND: i64      = 0x17
val DM_ABSTRACTAUTO: i64 = 0x18
val DM_PROGBUF0: i64     = 0x20
val DM_PROGBUF1: i64     = 0x21

# ============================================================================
# dmcontrol fields
# ============================================================================

val DMCONTROL_DMACTIVE: i64     = 0
val DMCONTROL_NDMRESET: i64     = 1
val DMCONTROL_HARTSELHI: i64    = 6
val DMCONTROL_HARTSELLO: i64    = 16
val DMCONTROL_HASEL: i64        = 26
val DMCONTROL_RESUMEREQ: i64    = 30
val DMCONTROL_HALTREQ: i64      = 31

# ============================================================================
# abstractcs fields
# ============================================================================

val ABSTRACTCS_DATACOUNT: i64   = 0
val ABSTRACTCS_CMDERR: i64      = 8
val ABSTRACTCS_BUSY: i64        = 12
val ABSTRACTCS_PROGBUFSIZE: i64 = 24

# ============================================================================
# Abstract command types
# ============================================================================

val CMD_ACCESS_REG: i64  = 0
val CMD_QUICK_ACCESS: i64 = 1
val CMD_ACCESS_MEM: i64  = 2

# ============================================================================
# Trigger Module registers
# ============================================================================

val CSR_TSELECT: i64  = 0x7A0
val CSR_TDATA1: i64   = 0x7A1
val CSR_TDATA2: i64   = 0x7A2
val CSR_TDATA3: i64   = 0x7A3

# ============================================================================
# Trigger types (tdata1.type)
# ============================================================================

val TRIGGER_NONE: i64       = 0
val TRIGGER_LEGACY: i64     = 1
val TRIGGER_MCONTROL: i64   = 2
val TRIGGER_ICOUNT: i64     = 3
val TRIGGER_ITRIGGER: i64   = 4
val TRIGGER_ETRIGGER: i64   = 5

# ============================================================================
# Debug State
# ============================================================================

struct DebugState:
    halted: bool
    running: bool
    resumeack: bool
    havereset: bool

    static fn initial() -> DebugState:
        DebugState(halted: false, running: true, resumeack: false, havereset: true)

# ============================================================================
# VHDL Package Generation
# ============================================================================

fn generate_rv32_debug_pkg() -> text:
    """Generate VHDL package with debug register definitions."""
    var b = VhdlBuilder.create("rv32_debug")
    b.emit_library_header()

    b.emit_package_begin("rv32_debug")

    b.emit_comment("Debug Module register addresses")
    b.emit_constant_decl("DM_DMCONTROL", "std_logic_vector(7 downto 0)", "x\"10\"")
    b.emit_constant_decl("DM_DMSTATUS", "std_logic_vector(7 downto 0)", "x\"11\"")
    b.emit_constant_decl("DM_HARTINFO", "std_logic_vector(7 downto 0)", "x\"12\"")
    b.emit_constant_decl("DM_ABSTRACTCS", "std_logic_vector(7 downto 0)", "x\"16\"")
    b.emit_constant_decl("DM_COMMAND", "std_logic_vector(7 downto 0)", "x\"17\"")
    b.emit_constant_decl("DM_PROGBUF0", "std_logic_vector(7 downto 0)", "x\"20\"")
    b.emit_constant_decl("DM_PROGBUF1", "std_logic_vector(7 downto 0)", "x\"21\"")
    b.emit_constant_decl("DM_DATA0", "std_logic_vector(7 downto 0)", "x\"04\"")
    b.emit_raw("")

    b.emit_comment("Trigger CSR addresses")
    b.emit_constant_decl("CSR_TSELECT_ADDR", "std_logic_vector(11 downto 0)", "x\"7A0\"")
    b.emit_constant_decl("CSR_TDATA1_ADDR", "std_logic_vector(11 downto 0)", "x\"7A1\"")
    b.emit_constant_decl("CSR_TDATA2_ADDR", "std_logic_vector(11 downto 0)", "x\"7A2\"")

    b.emit_package_end("rv32_debug")
    b.build()
