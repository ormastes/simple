# RV32IMAC ISA Constants Package
#
# Opcodes, funct3/funct7 fields, and CSR addresses for RV32IMAC.
# Mirrors constants from riscv_encoding.spl for hardware use.
#
# @hardware

use compiler.backend.vhdl.vhdl_builder.VhdlBuilder

# ============================================================================
# Opcode Constants (bits [6:0])
# ============================================================================

val OP_LUI: i64       = 0x37
val OP_AUIPC: i64     = 0x17
val OP_JAL: i64       = 0x6F
val OP_JALR: i64      = 0x67
val OP_BRANCH: i64    = 0x63
val OP_LOAD: i64      = 0x03
val OP_STORE: i64     = 0x23
val OP_OP_IMM: i64    = 0x13
val OP_OP: i64        = 0x33
val OP_MISC_MEM: i64  = 0x0F
val OP_SYSTEM: i64    = 0x73
val OP_AMO: i64       = 0x2F

# ============================================================================
# funct3 for ALU R-type / I-type (OP / OP_IMM)
# ============================================================================

val F3_ADD_SUB: i64   = 0x0
val F3_SLL: i64       = 0x1
val F3_SLT: i64       = 0x2
val F3_SLTU: i64      = 0x3
val F3_XOR: i64       = 0x4
val F3_SRL_SRA: i64   = 0x5
val F3_OR: i64        = 0x6
val F3_AND: i64       = 0x7

# ============================================================================
# funct7 distinguishers
# ============================================================================

val F7_NORMAL: i64    = 0x00
val F7_SUB_SRA: i64   = 0x20
val F7_MULDIV: i64    = 0x01

# ============================================================================
# funct3 for Branch
# ============================================================================

val F3_BEQ: i64       = 0x0
val F3_BNE: i64       = 0x1
val F3_BLT: i64       = 0x4
val F3_BGE: i64       = 0x5
val F3_BLTU: i64      = 0x6
val F3_BGEU: i64      = 0x7

# ============================================================================
# funct3 for Load/Store
# ============================================================================

val F3_LB: i64        = 0x0
val F3_LH: i64        = 0x1
val F3_LW: i64        = 0x2
val F3_LBU: i64       = 0x4
val F3_LHU: i64       = 0x5
val F3_SB: i64        = 0x0
val F3_SH: i64        = 0x1
val F3_SW: i64        = 0x2

# ============================================================================
# funct3 for M extension
# ============================================================================

val F3_MUL: i64       = 0x0
val F3_MULH: i64      = 0x1
val F3_MULHSU: i64    = 0x2
val F3_MULHU: i64     = 0x3
val F3_DIV: i64       = 0x4
val F3_DIVU: i64      = 0x5
val F3_REM: i64       = 0x6
val F3_REMU: i64      = 0x7

# ============================================================================
# funct5 for A extension (AMO)
# ============================================================================

val F5_LR: i64        = 0x02
val F5_SC: i64        = 0x03
val F5_AMOSWAP: i64   = 0x01
val F5_AMOADD: i64    = 0x00
val F5_AMOXOR: i64    = 0x04
val F5_AMOAND: i64    = 0x0C
val F5_AMOOR: i64     = 0x08
val F5_AMOMIN: i64    = 0x10
val F5_AMOMAX: i64    = 0x14
val F5_AMOMINU: i64   = 0x18
val F5_AMOMAXU: i64   = 0x1C

# ============================================================================
# CSR Addresses (M-mode)
# ============================================================================

val CSR_MSTATUS: i64   = 0x300
val CSR_MISA: i64      = 0x301
val CSR_MIE: i64       = 0x304
val CSR_MTVEC: i64     = 0x305
val CSR_MSCRATCH: i64  = 0x340
val CSR_MEPC: i64      = 0x341
val CSR_MCAUSE: i64    = 0x342
val CSR_MTVAL: i64     = 0x343
val CSR_MIP: i64       = 0x344
val CSR_MCYCLE: i64    = 0xB00
val CSR_MINSTRET: i64  = 0xB02

# ============================================================================
# System Instructions
# ============================================================================

val F3_CSRRW: i64     = 0x1
val F3_CSRRS: i64     = 0x2
val F3_CSRRC: i64     = 0x3
val F3_CSRRWI: i64    = 0x5
val F3_CSRRSI: i64    = 0x6
val F3_CSRRCI: i64    = 0x7

val F12_ECALL: i64    = 0x000
val F12_EBREAK: i64   = 0x001
val F12_MRET: i64     = 0x302
val F12_WFI: i64      = 0x105

# ============================================================================
# RVC (Compressed) Quadrants
# ============================================================================

val RVC_Q0: i64       = 0x0
val RVC_Q1: i64       = 0x1
val RVC_Q2: i64       = 0x2

# ============================================================================
# VHDL Package Generation
# ============================================================================

fn generate_rv32_isa_pkg() -> text:
    """Generate VHDL package with ISA constants."""
    var b = VhdlBuilder.create("rv32_isa")
    b.emit_library_header()

    b.emit_package_begin("rv32_isa")

    b.emit_comment("Opcodes")
    b.emit_constant_decl("OP_LUI", "std_logic_vector(6 downto 0)", "\"0110111\"")
    b.emit_constant_decl("OP_AUIPC", "std_logic_vector(6 downto 0)", "\"0010111\"")
    b.emit_constant_decl("OP_JAL", "std_logic_vector(6 downto 0)", "\"1101111\"")
    b.emit_constant_decl("OP_JALR", "std_logic_vector(6 downto 0)", "\"1100111\"")
    b.emit_constant_decl("OP_BRANCH", "std_logic_vector(6 downto 0)", "\"1100011\"")
    b.emit_constant_decl("OP_LOAD", "std_logic_vector(6 downto 0)", "\"0000011\"")
    b.emit_constant_decl("OP_STORE", "std_logic_vector(6 downto 0)", "\"0100011\"")
    b.emit_constant_decl("OP_OP_IMM", "std_logic_vector(6 downto 0)", "\"0010011\"")
    b.emit_constant_decl("OP_OP", "std_logic_vector(6 downto 0)", "\"0110011\"")
    b.emit_constant_decl("OP_MISC_MEM", "std_logic_vector(6 downto 0)", "\"0001111\"")
    b.emit_constant_decl("OP_SYSTEM", "std_logic_vector(6 downto 0)", "\"1110011\"")
    b.emit_constant_decl("OP_AMO", "std_logic_vector(6 downto 0)", "\"0101111\"")
    b.emit_raw("")

    b.emit_comment("CSR addresses")
    b.emit_constant_decl("CSR_MSTATUS", "std_logic_vector(11 downto 0)", "x\"300\"")
    b.emit_constant_decl("CSR_MISA", "std_logic_vector(11 downto 0)", "x\"301\"")
    b.emit_constant_decl("CSR_MIE", "std_logic_vector(11 downto 0)", "x\"304\"")
    b.emit_constant_decl("CSR_MTVEC", "std_logic_vector(11 downto 0)", "x\"305\"")
    b.emit_constant_decl("CSR_MSCRATCH", "std_logic_vector(11 downto 0)", "x\"340\"")
    b.emit_constant_decl("CSR_MEPC", "std_logic_vector(11 downto 0)", "x\"341\"")
    b.emit_constant_decl("CSR_MCAUSE", "std_logic_vector(11 downto 0)", "x\"342\"")
    b.emit_constant_decl("CSR_MTVAL", "std_logic_vector(11 downto 0)", "x\"343\"")
    b.emit_constant_decl("CSR_MIP", "std_logic_vector(11 downto 0)", "x\"344\"")

    b.emit_package_end("rv32_isa")
    b.build()
