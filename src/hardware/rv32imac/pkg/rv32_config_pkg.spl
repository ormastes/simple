# RV32IMAC Configuration Package
#
# Parameterized configuration for the RV32IMAC processor.
# Supports in-order and future out-of-order design points.
#
# @hardware

use compiler.backend.vhdl.vhdl_builder.VhdlBuilder

# ============================================================================
# Design Point Selection
# ============================================================================

enum Rv32DesignPoint:
    InOrder
    SmallOoO
    WideOoO

# ============================================================================
# Processor Configuration
# ============================================================================

struct Rv32Config:
    design_point: Rv32DesignPoint
    icache_size_kb: i64
    dcache_size_kb: i64
    rob_entries: i64
    issue_width: i64
    has_m_ext: bool
    has_a_ext: bool
    has_c_ext: bool
    has_debug: bool
    has_trace: bool

    static fn in_order_default() -> Rv32Config:
        """Default in-order RV32IMAC configuration."""
        Rv32Config(
            design_point: Rv32DesignPoint.InOrder,
            icache_size_kb: 8,
            dcache_size_kb: 8,
            rob_entries: 0,
            issue_width: 1,
            has_m_ext: true,
            has_a_ext: true,
            has_c_ext: true,
            has_debug: true,
            has_trace: true
        )

    static fn minimal() -> Rv32Config:
        """Minimal RV32I-only configuration for testing."""
        Rv32Config(
            design_point: Rv32DesignPoint.InOrder,
            icache_size_kb: 4,
            dcache_size_kb: 4,
            rob_entries: 0,
            issue_width: 1,
            has_m_ext: false,
            has_a_ext: false,
            has_c_ext: false,
            has_debug: false,
            has_trace: false
        )

    static fn small_ooo() -> Rv32Config:
        """Small out-of-order configuration (future)."""
        Rv32Config(
            design_point: Rv32DesignPoint.SmallOoO,
            icache_size_kb: 16,
            dcache_size_kb: 16,
            rob_entries: 48,
            issue_width: 2,
            has_m_ext: true,
            has_a_ext: true,
            has_c_ext: true,
            has_debug: true,
            has_trace: true
        )

    fn isa_string() -> text:
        """Return ISA string (e.g., 'rv32imac')."""
        var s = "rv32i"
        if self.has_m_ext:
            s = "{s}m"
        if self.has_a_ext:
            s = "{s}a"
        if self.has_c_ext:
            s = "{s}c"
        s

# ============================================================================
# VHDL Package Generation
# ============================================================================

fn generate_rv32_config_pkg(config: Rv32Config) -> text:
    """Generate VHDL package with configuration constants."""
    var b = VhdlBuilder.create("rv32_config")
    b.emit_library_header()

    b.emit_package_begin("rv32_config")

    b.emit_constant_decl("CFG_HAS_M_EXT", "boolean", if config.has_m_ext: "true" else: "false")
    b.emit_constant_decl("CFG_HAS_A_EXT", "boolean", if config.has_a_ext: "true" else: "false")
    b.emit_constant_decl("CFG_HAS_C_EXT", "boolean", if config.has_c_ext: "true" else: "false")
    b.emit_constant_decl("CFG_HAS_DEBUG", "boolean", if config.has_debug: "true" else: "false")
    b.emit_constant_decl("CFG_HAS_TRACE", "boolean", if config.has_trace: "true" else: "false")
    b.emit_raw("")
    b.emit_constant_decl("CFG_ICACHE_SIZE_KB", "integer", "{config.icache_size_kb}")
    b.emit_constant_decl("CFG_DCACHE_SIZE_KB", "integer", "{config.dcache_size_kb}")
    b.emit_constant_decl("CFG_ROB_ENTRIES", "integer", "{config.rob_entries}")
    b.emit_constant_decl("CFG_ISSUE_WIDTH", "integer", "{config.issue_width}")

    b.emit_package_end("rv32_config")
    b.build()
