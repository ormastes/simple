# RV32 Timer Peripheral
#
# RISC-V mtime/mtimecmp timer.
# Generates timer interrupt when mtime >= mtimecmp.
#
# Register map (relative to base 0x02000000):
#   +0x00  mtime_lo     (R/W)
#   +0x04  mtime_hi     (R/W)
#   +0x08  mtimecmp_lo  (R/W)
#   +0x0C  mtimecmp_hi  (R/W)
#
# @hardware


# ============================================================================
# Timer Model
# ============================================================================

class Rv32TimerModel:
    """Timer model for simulation."""

    mtime: i64
    mtimecmp: i64

    static fn create() -> Rv32TimerModel:
        Rv32TimerModel(mtime: 0, mtimecmp: 0xFFFFFFFFFFFFFFFF)

    me tick():
        """Increment mtime by 1."""
        self.mtime = self.mtime + 1

    fn interrupt_pending() -> bool:
        """Check if timer interrupt is pending."""
        self.mtime >= self.mtimecmp

    me set_mtimecmp(value: i64):
        self.mtimecmp = value

    fn read_reg(offset: i64) -> i64:
        if offset == 0x00: return self.mtime and 0xFFFFFFFF
        elif offset == 0x04: return (self.mtime >> 32) and 0xFFFFFFFF
        elif offset == 0x08: return self.mtimecmp and 0xFFFFFFFF
        elif offset == 0x0C: return (self.mtimecmp >> 32) and 0xFFFFFFFF
        0

# ============================================================================
# VHDL Generation
# ============================================================================

fn generate_rv32_timer_vhdl() -> text:
    """Generate VHDL for mtime/mtimecmp timer."""
    use compiler.backend.vhdl.vhdl_builder.VhdlBuilder
    var b = VhdlBuilder.create("rv32_timer")
    b.emit_library_header()
    b.emit_use_package("work", "rv32_types_pkg")

    b.emit_entity_begin("rv32_timer")
    b.emit_port_begin()
    b.emit_port("clk", "in", "std_logic", false)
    b.emit_port("rst", "in", "std_logic", false)
    b.emit_comment("Register interface")
    b.emit_port("addr", "in", "std_logic_vector(3 downto 0)", false)
    b.emit_port("wdata", "in", "word_t", false)
    b.emit_port("rdata", "out", "word_t", false)
    b.emit_port("we", "in", "std_logic", false)
    b.emit_comment("Interrupt output")
    b.emit_port("timer_irq", "out", "std_logic", true)
    b.emit_port_end()
    b.emit_entity_end("rv32_timer")

    b.emit_architecture_begin("rv32_timer", "rtl")
    b.emit_signal_decl("mtime", "unsigned(63 downto 0)", Some("(others => '0')"))
    b.emit_signal_decl("mtimecmp", "unsigned(63 downto 0)", Some("(others => '1')"))
    b.emit_architecture_body_begin()

    b.emit_comment("Timer interrupt: mtime >= mtimecmp")
    b.emit_signal_assign("timer_irq", "'1' when mtime >= mtimecmp else '0'")
    b.emit_raw("")

    # Register read
    b.emit_process_begin(Some("reg_read"), ["addr", "mtime", "mtimecmp"])
    b.emit_process_body_begin()
    b.emit_signal_assign("rdata", "ZERO_WORD")
    b.emit_line("case addr is")
    b.emit_line("  when x\"0\" => rdata <= std_logic_vector(mtime(31 downto 0));")
    b.emit_line("  when x\"4\" => rdata <= std_logic_vector(mtime(63 downto 32));")
    b.emit_line("  when x\"8\" => rdata <= std_logic_vector(mtimecmp(31 downto 0));")
    b.emit_line("  when x\"C\" => rdata <= std_logic_vector(mtimecmp(63 downto 32));")
    b.emit_line("  when others => null;")
    b.emit_line("end case;")
    b.emit_process_end(Some("reg_read"))
    b.emit_raw("")

    # Clocked process
    b.emit_clocked_process_begin(Some("timer_proc"), "clk", Some("rst"))
    b.emit_process_body_begin()
    b.emit_if_begin("rst = '1'")
    b.emit_signal_assign("mtime", "(others => '0')")
    b.emit_signal_assign("mtimecmp", "(others => '1')")
    b.emit_elsif("rising_edge(clk)")
    b.emit_comment("Free-running counter")
    b.emit_signal_assign("mtime", "mtime + 1")
    b.emit_if_begin("we = '1'")
    b.emit_line("case addr is")
    b.emit_line("  when x\"0\" => mtime(31 downto 0) <= unsigned(wdata);")
    b.emit_line("  when x\"4\" => mtime(63 downto 32) <= unsigned(wdata);")
    b.emit_line("  when x\"8\" => mtimecmp(31 downto 0) <= unsigned(wdata);")
    b.emit_line("  when x\"C\" => mtimecmp(63 downto 32) <= unsigned(wdata);")
    b.emit_line("  when others => null;")
    b.emit_line("end case;")
    b.emit_if_end()
    b.emit_if_end()
    b.emit_process_end(Some("timer_proc"))

    b.emit_architecture_end("rtl")
    b.build()
