"""
# RISC-V Shared Compressed Instruction Support

Detection and base decompression shared between RV32C and RV64C.
RV64-specific expansions are handled in the RV64 compressed module.
"""

fn is_compressed(instr: i64) -> bool:
    """Check if instruction is 16-bit compressed (bits [1:0] != 11)."""
    (instr and 0x3) != 0x3

fn rvc_reg(idx: i64) -> i64:
    """Map 3-bit compressed register index to full register (x8-x15)."""
    idx + 8
