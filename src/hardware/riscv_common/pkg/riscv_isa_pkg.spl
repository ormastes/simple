"""
# RISC-V ISA Package — Shared Opcode and Funct Constants

Shared between RV32 and RV64. All base RISC-V instruction opcodes are identical
regardless of XLEN.

Reference: RISC-V ISA Manual, Volume I (Unprivileged), Chapter 24.
"""

# ===========================================================================
# Base Opcodes (bits [6:0])
# ===========================================================================

val OP_LUI: i64 = 0x37
val OP_AUIPC: i64 = 0x17
val OP_JAL: i64 = 0x6F
val OP_JALR: i64 = 0x67
val OP_BRANCH: i64 = 0x63
val OP_LOAD: i64 = 0x03
val OP_STORE: i64 = 0x23
val OP_OP_IMM: i64 = 0x13
val OP_OP: i64 = 0x33
val OP_MISC_MEM: i64 = 0x0F
val OP_SYSTEM: i64 = 0x73

# RV64-specific opcodes
val OP_OP_IMM_32: i64 = 0x1B
val OP_OP_32: i64 = 0x3B

# Atomic (A extension)
val OP_AMO: i64 = 0x2F

# FP opcodes
val OP_LOAD_FP: i64 = 0x07
val OP_STORE_FP: i64 = 0x27
val OP_FMADD: i64 = 0x43
val OP_FMSUB: i64 = 0x47
val OP_FNMSUB: i64 = 0x4B
val OP_FNMADD: i64 = 0x4F
val OP_OP_FP: i64 = 0x53

# ===========================================================================
# Funct3 Constants
# ===========================================================================

# ALU
val F3_ADD_SUB: i64 = 0
val F3_SLL: i64 = 1
val F3_SLT: i64 = 2
val F3_SLTU: i64 = 3
val F3_XOR: i64 = 4
val F3_SRL_SRA: i64 = 5
val F3_OR: i64 = 6
val F3_AND: i64 = 7

# Branch
val F3_BEQ: i64 = 0
val F3_BNE: i64 = 1
val F3_BLT: i64 = 4
val F3_BGE: i64 = 5
val F3_BLTU: i64 = 6
val F3_BGEU: i64 = 7

# Load
val F3_LB: i64 = 0
val F3_LH: i64 = 1
val F3_LW: i64 = 2
val F3_LD: i64 = 3
val F3_LBU: i64 = 4
val F3_LHU: i64 = 5
val F3_LWU: i64 = 6

# Store
val F3_SB: i64 = 0
val F3_SH: i64 = 1
val F3_SW: i64 = 2
val F3_SD: i64 = 3

# CSR
val F3_CSRRW: i64 = 1
val F3_CSRRS: i64 = 2
val F3_CSRRC: i64 = 3
val F3_CSRRWI: i64 = 5
val F3_CSRRSI: i64 = 6
val F3_CSRRCI: i64 = 7

# ===========================================================================
# Funct7 Constants
# ===========================================================================

val F7_NORMAL: i64 = 0x00
val F7_SUB_SRA: i64 = 0x20
val F7_MULDIV: i64 = 0x01
