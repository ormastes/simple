"""
# RISC-V Generated Core Contracts

Shared proof-lane and shell-seam contracts for the incremental migration from
handwritten/external RTL to repo-native generated RISC-V cores.
"""

enum RiscvProofLane:
    ReferenceExternalRv32Linux
    ReferenceExternalRv64Linux
    GeneratedRv32Baremetal
    GeneratedRv64Linux
    GeneratedRv32Linux

impl RiscvProofLane:
    fn to_text() -> text:
        match self:
            ReferenceExternalRv32Linux: "reference_external_rv32_linux"
            ReferenceExternalRv64Linux: "reference_external_rv64_linux"
            GeneratedRv32Baremetal: "generated_rv32_baremetal"
            GeneratedRv64Linux: "generated_rv64_linux"
            GeneratedRv32Linux: "generated_rv32_linux"

    fn canonical_lane_id() -> text:
        if self == RiscvProofLane.ReferenceExternalRv64Linux or self == RiscvProofLane.GeneratedRv64Linux:
            return "rv64"
        "rv32"

    fn is_external_reference() -> bool:
        self == RiscvProofLane.ReferenceExternalRv32Linux or self == RiscvProofLane.ReferenceExternalRv64Linux

    fn requires_linux_boot() -> bool:
        self == RiscvProofLane.ReferenceExternalRv32Linux or
            self == RiscvProofLane.ReferenceExternalRv64Linux or
            self == RiscvProofLane.GeneratedRv64Linux or
            self == RiscvProofLane.GeneratedRv32Linux

struct GeneratedInstructionFetch:
    addr: i64
    valid: bool
    ready: bool
    rdata: i64
    fault: bool

impl GeneratedInstructionFetch:
    static fn empty() -> GeneratedInstructionFetch:
        GeneratedInstructionFetch(addr: 0, valid: false, ready: false, rdata: 0, fault: false)

struct GeneratedMemoryAccess:
    addr: i64
    re: bool
    we: bool
    width_bytes: i64
    wstrb_mask: i64
    wdata: i64
    rdata: i64
    misaligned: bool
    fault: bool

impl GeneratedMemoryAccess:
    static fn empty() -> GeneratedMemoryAccess:
        GeneratedMemoryAccess(
            addr: 0,
            re: false,
            we: false,
            width_bytes: 4,
            wstrb_mask: 0,
            wdata: 0,
            rdata: 0,
            misaligned: false,
            fault: false
        )

struct GeneratedTrapStatus:
    trap: bool
    halt: bool
    cause: i64
    tval: i64
    privilege_return_target: i64
    unsupported: bool

impl GeneratedTrapStatus:
    static fn empty() -> GeneratedTrapStatus:
        GeneratedTrapStatus(
            trap: false,
            halt: false,
            cause: 0,
            tval: 0,
            privilege_return_target: 0,
            unsupported: false
        )

struct GeneratedBootContract:
    reset_vector: i64
    opensbi_fw_jump: bool
    kernel_entry: i64
    dtb_addr: i64
    hartid_register: text
    dtb_register: text

impl GeneratedBootContract:
    static fn baremetal(reset_vector: i64) -> GeneratedBootContract:
        GeneratedBootContract(
            reset_vector: reset_vector,
            opensbi_fw_jump: false,
            kernel_entry: reset_vector,
            dtb_addr: 0,
            hartid_register: "",
            dtb_register: ""
        )

    static fn fw_jump(reset_vector: i64, kernel_entry: i64, dtb_addr: i64) -> GeneratedBootContract:
        GeneratedBootContract(
            reset_vector: reset_vector,
            opensbi_fw_jump: true,
            kernel_entry: kernel_entry,
            dtb_addr: dtb_addr,
            hartid_register: "a0",
            dtb_register: "a1"
        )

struct GeneratedCoreDebugSourceMapEntry:
    signal_name: text
    slice_text: text

    fn comment_line() -> text:
        "-- source-map: {self.signal_name} => {self.slice_text}\n"

struct GeneratedCoreDebugObservability:
    fetch: bool
    trap: bool
    halt: bool
    memory_access: bool
    register_probes: bool
    debug_probes: bool
    proof_failure_reports: bool

struct GeneratedCoreDebugRunnerTestbench:
    file_name: text
    pass_marker: text

struct GeneratedCoreDebugMetadata:
    schema_version: text
    lane_id: text
    proof_lane: RiscvProofLane
    xlen_bits: i64
    acceptance_markers: [text]
    debug_outputs: [text]
    source_map: [GeneratedCoreDebugSourceMapEntry]
    observability: GeneratedCoreDebugObservability
    report_markers: [text]
    runner_testbenches: [GeneratedCoreDebugRunnerTestbench]

struct GeneratedCoreShellContract:
    xlen_bits: i64
    proof_lane: RiscvProofLane
    fetch: GeneratedInstructionFetch
    data: GeneratedMemoryAccess
    trap_status: GeneratedTrapStatus
    interrupt_inputs: [text]
    debug_outputs: [text]
    semihost_shell_service: bool
    mailbox_shell_service: bool
    boot: GeneratedBootContract

impl GeneratedCoreShellContract:
    static fn rv32_baremetal() -> GeneratedCoreShellContract:
        GeneratedCoreShellContract(
            xlen_bits: 32,
            proof_lane: RiscvProofLane.GeneratedRv32Baremetal,
            fetch: GeneratedInstructionFetch.empty(),
            data: GeneratedMemoryAccess.empty(),
            trap_status: GeneratedTrapStatus.empty(),
            interrupt_inputs: ["machine_software", "machine_timer", "machine_external"],
            debug_outputs: ["debug_pc", "semi_trigger", "semi_op", "semi_param", "trap", "halt"],
            semihost_shell_service: true,
            mailbox_shell_service: true,
            boot: GeneratedBootContract.baremetal(0x80000000)
        )

    static fn rv64_linux() -> GeneratedCoreShellContract:
        GeneratedCoreShellContract(
            xlen_bits: 64,
            proof_lane: RiscvProofLane.GeneratedRv64Linux,
            fetch: GeneratedInstructionFetch.empty(),
            data: GeneratedMemoryAccess.empty(),
            trap_status: GeneratedTrapStatus.empty(),
            interrupt_inputs: ["machine_software", "machine_timer", "machine_external", "supervisor_external"],
            debug_outputs: ["semi_trigger", "semi_op", "semi_param", "debug_priv_mode", "debug_last_load_value", "debug_ra", "debug_sp", "debug_s0", "debug_a0", "debug_a1", "debug_a2", "debug_load_rd", "debug_pc", "trap", "halt"],
            semihost_shell_service: false,
            mailbox_shell_service: false,
            boot: GeneratedBootContract.fw_jump(0x80000000, 0x80200000, 0x88000000)
        )

    static fn rv32_linux() -> GeneratedCoreShellContract:
        GeneratedCoreShellContract(
            xlen_bits: 32,
            proof_lane: RiscvProofLane.GeneratedRv32Linux,
            fetch: GeneratedInstructionFetch.empty(),
            data: GeneratedMemoryAccess.empty(),
            trap_status: GeneratedTrapStatus.empty(),
            interrupt_inputs: ["machine_software", "machine_timer", "machine_external"],
            debug_outputs: ["debug_pc", "semi_trigger", "semi_op", "semi_param", "trap", "halt"],
            semihost_shell_service: false,
            mailbox_shell_service: false,
            boot: GeneratedBootContract.fw_jump(0x80000000, 0x80200000, 0x88000000)
        )

    fn shell_services_summary() -> text:
        var parts: [text] = []
        if self.semihost_shell_service:
            parts.push("semihost")
        if self.mailbox_shell_service:
            parts.push("mailbox")
        if parts.len() == 0:
            return "none"
        parts.join("+")

    fn acceptance_markers() -> [text]:
        if self.proof_lane.requires_linux_boot():
            return ["OpenSBI", "Linux version", "OF: fdt", "Freeing unused kernel memory", "init started"]
        ["semihost-exit-0", "mailbox-sentinel", "ghdl-synth"]

    fn instruction_bitfield_name() -> text:
        if self.xlen_bits == 32:
            return "Rv32Instruction"
        "Rv64Instruction"

    fn debug_source_map_entries() -> [GeneratedCoreDebugSourceMapEntry]:
        val inst = self.instruction_bitfield_name()
        [
            GeneratedCoreDebugSourceMapEntry(signal_name: "{inst}.opcode", slice_text: "imem_rdata(6 downto 0)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "{inst}.rd", slice_text: "imem_rdata(11 downto 7)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "{inst}.funct3", slice_text: "imem_rdata(14 downto 12)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "{inst}.rs1", slice_text: "imem_rdata(19 downto 15)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "{inst}.rs2", slice_text: "imem_rdata(24 downto 20)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "{inst}.funct7", slice_text: "imem_rdata(31 downto 25)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvBranchEncoding.bit11", slice_text: "imem_rdata(7 downto 7)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvBranchEncoding.low", slice_text: "imem_rdata(11 downto 8)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvBranchEncoding.high", slice_text: "imem_rdata(30 downto 25)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvBranchEncoding.bit12", slice_text: "imem_rdata(31 downto 31)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvStoreEncoding.low", slice_text: "imem_rdata(11 downto 7)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvStoreEncoding.high", slice_text: "imem_rdata(31 downto 25)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvIImmediateEncoding.value", slice_text: "imem_rdata(31 downto 20)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvUpperImmediateEncoding.high20", slice_text: "imem_rdata(31 downto 12)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvExecuteControlEncoding.funct3", slice_text: "imem_rdata(14 downto 12)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvExecuteControlEncoding.shamt_low5", slice_text: "imem_rdata(24 downto 20)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvExecuteControlEncoding.shamt_bit5", slice_text: "imem_rdata(25 downto 25)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvExecuteControlEncoding.bit30", slice_text: "imem_rdata(30 downto 30)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvExecuteDatapathEncoding.opcode", slice_text: "imem_rdata(6 downto 0)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvExecuteDatapathEncoding.funct3", slice_text: "imem_rdata(14 downto 12)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvExecuteDatapathEncoding.bit30", slice_text: "imem_rdata(30 downto 30)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvBranchDatapathEncoding.opcode", slice_text: "imem_rdata(6 downto 0)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvBranchDatapathEncoding.funct3", slice_text: "imem_rdata(14 downto 12)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvControlFlowDatapathEncoding.opcode", slice_text: "imem_rdata(6 downto 0)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvMemoryAccessControlEncoding.funct3", slice_text: "imem_rdata(14 downto 12)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvJumpEncoding.high8", slice_text: "imem_rdata(19 downto 12)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvJumpEncoding.bit11", slice_text: "imem_rdata(20 downto 20)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvJumpEncoding.low10", slice_text: "imem_rdata(30 downto 21)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvJumpEncoding.bit20", slice_text: "imem_rdata(31 downto 31)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvDispatchClassEncoding.opcode", slice_text: "imem_rdata(6 downto 0)"),
            GeneratedCoreDebugSourceMapEntry(signal_name: "RiscvTrapHaltControlEncoding.opcode", slice_text: "imem_rdata(6 downto 0)")
        ]

    fn debug_observability() -> GeneratedCoreDebugObservability:
        GeneratedCoreDebugObservability(
            fetch: true,
            trap: true,
            halt: true,
            memory_access: true,
            register_probes: true,
            debug_probes: true,
            proof_failure_reports: true
        )

    fn debug_report_markers() -> [text]:
        if self.proof_lane == RiscvProofLane.GeneratedRv64Linux:
            return [
                "PASS_WORD:",
                "A0_LOW32:",
                "A1_LOW32:",
                "UART_BYTES_LOW32:",
                "PC_LOW32:",
                "DTB_PROBE_SEEN:",
                "TRAP_EDGE_PC_HEX32",
                "HALT_EDGE_PC_HEX32",
                "HEARTBEAT_PC_HEX32",
                "PROGRESS_PC_HEX32",
                "CHECK_PRIV_MODE_OK:",
                "TRAP_CAUSE_WORD:",
                "TRAP_TVAL_WORD:",
                "CAUSE_WORD:",
                "TVAL_WORD:"
            ]
        if self.proof_lane == RiscvProofLane.GeneratedRv32Linux:
            return [
                "PASS_WORD:",
                "A0_LOW32:",
                "A1_LOW32:",
                "UART_BYTES_LOW32:",
                "DTB_PROBE_SEEN:",
                "FINAL_PC_HEX32:",
                "HALT_SEEN:",
                "TRAP_SEEN:"
            ]
        ["PASS_WORD:", "PC_LOW32:", "UART_BYTES_LOW32:"]

    fn debug_runner_testbenches() -> [GeneratedCoreDebugRunnerTestbench]:
        if self.proof_lane == RiscvProofLane.GeneratedRv64Linux:
            return [
                GeneratedCoreDebugRunnerTestbench(file_name: "tb_generated_rv64_linux_handoff.vhd", pass_marker: "GENERATED_RV64_LINUX_HANDOFF: PASS"),
                GeneratedCoreDebugRunnerTestbench(file_name: "tb_generated_rv64_boot_banner.vhd", pass_marker: "GENERATED_RV64_BOOT_BANNER: PASS"),
                GeneratedCoreDebugRunnerTestbench(file_name: "tb_generated_rv64_boot_info_dtb.vhd", pass_marker: "GENERATED_RV64_BOOT_INFO_DTB: PASS"),
                GeneratedCoreDebugRunnerTestbench(file_name: "tb_generated_rv64_fw_jump.vhd", pass_marker: "GENERATED_RV64_FW_JUMP: PASS"),
                GeneratedCoreDebugRunnerTestbench(file_name: "tb_generated_rv64_boot_info_real_dtb.vhd", pass_marker: "GENERATED_RV64_BOOT_INFO_REAL_DTB: PASS"),
                GeneratedCoreDebugRunnerTestbench(file_name: "tb_generated_rv64_sv39.vhd", pass_marker: "GENERATED_RV64_SV39: PASS"),
                GeneratedCoreDebugRunnerTestbench(file_name: "tb_generated_rv64_sv39_fault.vhd", pass_marker: "GENERATED_RV64_SV39_FAULT: PASS")
            ]
        if self.proof_lane == RiscvProofLane.GeneratedRv32Linux:
            return [
                GeneratedCoreDebugRunnerTestbench(file_name: "tb_generated_rv32_linux_handoff.vhd", pass_marker: "GENERATED_RV32_LINUX_HANDOFF: PASS"),
                GeneratedCoreDebugRunnerTestbench(file_name: "tb_generated_rv32_boot_info_real_dtb.vhd", pass_marker: "GENERATED_RV32_BOOT_INFO_REAL_DTB: PASS")
            ]
        [
            GeneratedCoreDebugRunnerTestbench(file_name: "tb_generated_rv32_smoke.vhd", pass_marker: "GENERATED_RV32_SMOKE: PASS"),
            GeneratedCoreDebugRunnerTestbench(file_name: "tb_generated_rv32_strobe.vhd", pass_marker: "GENERATED_RV32_STROBE: PASS"),
            GeneratedCoreDebugRunnerTestbench(file_name: "tb_semi_run.vhd", pass_marker: "GENERATED_RV32_SEMIHOST: PASS"),
            GeneratedCoreDebugRunnerTestbench(file_name: "tb_mailbox.vhd", pass_marker: "GENERATED_RV32_MAILBOX: PASS")
        ]

    fn debug_metadata() -> GeneratedCoreDebugMetadata:
        GeneratedCoreDebugMetadata(
            schema_version: "riscv_rtl_debuggability_lint/v1",
            lane_id: self.proof_lane.canonical_lane_id(),
            proof_lane: self.proof_lane,
            xlen_bits: self.xlen_bits,
            acceptance_markers: self.acceptance_markers(),
            debug_outputs: self.debug_outputs,
            source_map: self.debug_source_map_entries(),
            observability: self.debug_observability(),
            report_markers: self.debug_report_markers(),
            runner_testbenches: self.debug_runner_testbenches()
        )
