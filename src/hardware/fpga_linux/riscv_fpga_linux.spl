    fn boot_info_dtb_testbench_vhdl() -> text:
        val package_name = self.package_name()
        val top = self.top_module
        "library ieee;\n" +
            "use ieee.std_logic_1164.all;\n" +
            "use ieee.numeric_std.all;\n" +
            "use std.textio.all;\n" +
            "use work.test_program.all;\n" +
            "use work.{package_name}.all;\n\n" +
            "entity tb_generated_rv64_boot_info_dtb is\n" +
            "    generic (\n" +
            "        MAX_CYCLES : integer := 300000\n" +
            "    );\n" +
            "end entity tb_generated_rv64_boot_info_dtb;\n\n" +
            "architecture sim of tb_generated_rv64_boot_info_dtb is\n" +
            "    constant CLK_PERIOD : time := 10 ns;\n" +
            "    constant FW_WINDOW_BYTES : integer := 16#200000#;\n" +
            "    constant PAYLOAD_BOOT_WINDOW_BYTES : integer := 16#200000#;\n" +
            "    constant PAYLOAD_RUNTIME_WINDOW_BYTES : integer := 16#1200000#;\n" +
            "    constant MEM_WORDS : integer := (FW_WINDOW_BYTES + PAYLOAD_BOOT_WINDOW_BYTES + PAYLOAD_RUNTIME_WINDOW_BYTES) / 8;\n" +
            "    constant PROGRESS_REPORT_INTERVAL : integer := 100000;\n\n" +
            "    constant PAYLOAD_CHUNK_WORDS : integer := 65536;\n\n" +
            "    constant MAGIC_ADDR_BITS        : std_logic_vector(63 downto 0) := x\"0000000080FF1000\";\n" +
            "    constant DONE_ADDR_BITS         : std_logic_vector(63 downto 0) := x\"0000000080FF1008\";\n" +
            "    constant HART_ID_ADDR_BITS      : std_logic_vector(63 downto 0) := x\"0000000080FF1010\";\n" +
            "    constant DTB_ADDR_ADDR_BITS     : std_logic_vector(63 downto 0) := x\"0000000080FF1018\";\n" +
            "    constant DTB_VALID_ADDR_BITS    : std_logic_vector(63 downto 0) := x\"0000000080FF1020\";\n" +
            "    constant RAM_BASE_ADDR_BITS     : std_logic_vector(63 downto 0) := x\"0000000080FF1028\";\n" +
            "    constant RAM_SIZE_ADDR_BITS     : std_logic_vector(63 downto 0) := x\"0000000080FF1030\";\n" +
            "    constant SERIAL_BASE_ADDR_BITS  : std_logic_vector(63 downto 0) := x\"0000000080FF1038\";\n" +
            "    constant SERIAL_MMIO_ADDR_BITS  : std_logic_vector(63 downto 0) := x\"0000000080FF1040\";\n" +
            "    constant MAP_LEN_ADDR_BITS      : std_logic_vector(63 downto 0) := x\"0000000080FF1048\";\n" +
            "    constant REGION0_BASE_ADDR_BITS : std_logic_vector(63 downto 0) := x\"0000000080FF1050\";\n" +
            "    constant REGION0_SIZE_ADDR_BITS : std_logic_vector(63 downto 0) := x\"0000000080FF1058\";\n" +
            "    constant REGION0_KIND_ADDR_BITS : std_logic_vector(63 downto 0) := x\"0000000080FF1060\";\n" +
            "    constant REGION1_BASE_ADDR_BITS : std_logic_vector(63 downto 0) := x\"0000000080FF1068\";\n" +
            "    constant REGION1_SIZE_ADDR_BITS : std_logic_vector(63 downto 0) := x\"0000000080FF1070\";\n" +
            "    constant REGION1_KIND_ADDR_BITS : std_logic_vector(63 downto 0) := x\"0000000080FF1078\";\n" +
            "    constant REGION2_BASE_ADDR_BITS : std_logic_vector(63 downto 0) := x\"0000000080FF1080\";\n" +
            "    constant REGION2_SIZE_ADDR_BITS : std_logic_vector(63 downto 0) := x\"0000000080FF1088\";\n" +
            "    constant REGION2_KIND_ADDR_BITS : std_logic_vector(63 downto 0) := x\"0000000080FF1090\";\n\n" +
            "    constant UART_ADDR            : std_logic_vector(63 downto 0) := x\"0000000010000000\";\n" +
            "    constant UART_MARKER_WORD     : std_logic_vector(31 downto 0) := x\"42490D0A\";\n" +
            "    constant PROOF_MAGIC_EXPECTED : std_logic_vector(63 downto 0) := x\"42494F50524F4F46\";\n" +
            "    constant PROOF_DONE_EXPECTED  : std_logic_vector(63 downto 0) := x\"0000000000000001\";\n" +
            "    constant BOOT_HART_ID         : std_logic_vector(63 downto 0) := x\"0000000000000000\";\n" +
            "    constant BOOT_DTB_ADDR        : std_logic_vector(63 downto 0) := x\"0000000088000000\";\n" +
            "    constant DTB_VALID_TRUE       : std_logic_vector(63 downto 0) := x\"0000000000000001\";\n" +
            "    constant RAM_BASE_EXPECTED    : std_logic_vector(63 downto 0) := x\"0000000080000000\";\n" +
            "    constant RAM_SIZE_EXPECTED    : std_logic_vector(63 downto 0) := x\"0000000008000000\";\n" +
            "    constant SERIAL_BASE_EXPECTED : std_logic_vector(63 downto 0) := x\"0000000010000000\";\n" +
            "    constant SERIAL_MMIO_TRUE     : std_logic_vector(63 downto 0) := x\"0000000000000001\";\n" +
            "    constant MAP_LEN_EXPECTED     : std_logic_vector(63 downto 0) := x\"0000000000000003\";\n" +
            "    constant REGION0_BASE_EXPECTED : std_logic_vector(63 downto 0) := x\"0000000080000000\";\n" +
            "    constant REGION0_SIZE_EXPECTED : std_logic_vector(63 downto 0) := x\"0000000000200000\";\n" +
            "    constant REGION0_KIND_EXPECTED : std_logic_vector(63 downto 0) := x\"0000000000000002\";\n" +
            "    constant REGION1_BASE_EXPECTED : std_logic_vector(63 downto 0) := x\"0000000080200000\";\n" +
            "    constant REGION1_SIZE_EXPECTED : std_logic_vector(63 downto 0) := x\"0000000000200000\";\n" +
            "    constant REGION1_KIND_EXPECTED : std_logic_vector(63 downto 0) := x\"0000000000000008\";\n" +
            "    constant REGION2_BASE_EXPECTED : std_logic_vector(63 downto 0) := x\"0000000080400000\";\n" +
            "    constant REGION2_SIZE_EXPECTED : std_logic_vector(63 downto 0) := x\"0000000007C00000\";\n" +
            "    constant REGION2_KIND_EXPECTED : std_logic_vector(63 downto 0) := x\"0000000000000001\";\n\n" +
            "    type byte_array_t is array (natural range <>) of std_logic_vector(7 downto 0);\n\n" +
            "    constant DTB_SIZE_BYTES      : integer := 239;\n" +
            "    constant DTB_BYTES           : byte_array_t(0 to DTB_SIZE_BYTES - 1) := (\n" +
            "        x\"D0\", x\"0D\", x\"FE\", x\"ED\", x\"00\", x\"00\", x\"00\", x\"EF\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"38\", x\"00\", x\"00\", x\"00\", x\"D0\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"28\", x\"00\", x\"00\", x\"00\", x\"11\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"10\", x\"00\", x\"00\", x\"00\", x\"00\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"1F\", x\"00\", x\"00\", x\"00\", x\"98\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"00\", x\"00\", x\"00\", x\"00\", x\"00\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"00\", x\"00\", x\"00\", x\"00\", x\"00\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"01\", x\"00\", x\"00\", x\"00\", x\"00\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"03\", x\"00\", x\"00\", x\"00\", x\"04\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"00\", x\"00\", x\"00\", x\"00\", x\"02\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"03\", x\"00\", x\"00\", x\"00\", x\"04\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"0F\", x\"00\", x\"00\", x\"00\", x\"02\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"01\", x\"6D\", x\"65\", x\"6D\", x\"6F\",\n" +
            "        x\"72\", x\"79\", x\"40\", x\"38\", x\"30\", x\"30\", x\"30\", x\"30\",\n" +
            "        x\"30\", x\"30\", x\"30\", x\"00\", x\"00\", x\"00\", x\"00\", x\"03\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"10\", x\"00\", x\"00\", x\"00\", x\"1B\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"00\", x\"80\", x\"00\", x\"00\", x\"00\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"00\", x\"08\", x\"00\", x\"00\", x\"00\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"02\", x\"00\", x\"00\", x\"00\", x\"01\",\n" +
            "        x\"73\", x\"65\", x\"72\", x\"69\", x\"61\", x\"6C\", x\"40\", x\"31\",\n" +
            "        x\"30\", x\"30\", x\"30\", x\"30\", x\"30\", x\"30\", x\"30\", x\"00\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"03\", x\"00\", x\"00\", x\"00\", x\"10\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"1B\", x\"00\", x\"00\", x\"00\", x\"00\",\n" +
            "        x\"10\", x\"00\", x\"00\", x\"00\", x\"00\", x\"00\", x\"00\", x\"00\",\n" +
            "        x\"00\", x\"00\", x\"01\", x\"00\", x\"00\", x\"00\", x\"00\", x\"02\",\n" +
            "        x\"00\", x\"00\", x\"00\", x\"02\", x\"00\", x\"00\", x\"00\", x\"09\",\n" +
            "        x\"23\", x\"61\", x\"64\", x\"64\", x\"72\", x\"65\", x\"73\", x\"73\",\n" +
            "        x\"2D\", x\"63\", x\"65\", x\"6C\", x\"6C\", x\"73\", x\"00\", x\"23\",\n" +
            "        x\"73\", x\"69\", x\"7A\", x\"65\", x\"2D\", x\"63\", x\"65\", x\"6C\",\n" +
            "        x\"6C\", x\"73\", x\"00\", x\"72\", x\"65\", x\"67\", x\"00\"\n" +
            "    );\n\n" +
            "    signal clk        : std_logic := '0';\n" +
            "    signal reset_n    : std_logic := '0';\n" +
            "    signal imem_addr  : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal imem_data  : std_logic_vector(31 downto 0) := (others => '0');\n" +
            "    signal dmem_addr  : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal dmem_wdata : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal dmem_rdata : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal dmem_we    : std_logic := '0';\n" +
            "    signal dmem_re    : std_logic := '0';\n" +
            "    signal dmem_width : std_logic_vector(1 downto 0) := (others => '0');\n" +
            "    signal dmem_wstrb : std_logic_vector(7 downto 0) := (others => '0');\n" +
            "    signal irq_software : std_logic := '0';\n" +
            "    signal irq_timer    : std_logic := '0';\n" +
            "    signal irq_external : std_logic := '0';\n" +
            "    signal debug_priv_mode : std_logic_vector(1 downto 0) := (others => '0');\n" +
            "    signal debug_last_load_value : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal debug_ra   : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal debug_sp   : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal debug_s0   : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal debug_a0   : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal debug_a1   : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal debug_a2   : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal debug_load_rd : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal debug_pc   : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal trap       : std_logic := '0';\n" +
            "    signal halt       : std_logic := '0';\n\n" +
            "    subtype word32_t is std_logic_vector(31 downto 0);\n" +
            "    subtype word64_t is std_logic_vector(63 downto 0);\n" +
            "    type mem_t is array (0 to MEM_WORDS - 1) of word64_t;\n" +
            "    shared variable mem : mem_t := (others => (others => '0'));\n" +
            "    type proof_mem_t is array (0 to 31) of word64_t;\n" +
            "    type proof_count_t is array (0 to 31) of integer;\n" +
            "    signal proof_mem : proof_mem_t := (others => (others => '0'));\n" +
            "    signal proof_store_call_count : integer := 0;\n" +
            "    signal proof_mmio_write_count : integer := 0;\n" +
            "    signal proof_slot_write_count : proof_count_t := (others => 0);\n" +
            "    signal proof_slot_first_seen : std_logic_vector(31 downto 0) := (others => '0');\n" +
            "    signal proof_slot_first_value : proof_mem_t := (others => (others => '0'));\n" +
            "    signal proof_slot_last_value : proof_mem_t := (others => (others => '0'));\n\n" +
            "    function hex_to_slv4(ch : character) return std_logic_vector is\n" +
            "    begin\n" +
            "        case ch is\n" +
            "            when '0' => return \"0000\";\n" +
            "            when '1' => return \"0001\";\n" +
            "            when '2' => return \"0010\";\n" +
            "            when '3' => return \"0011\";\n" +
            "            when '4' => return \"0100\";\n" +
            "            when '5' => return \"0101\";\n" +
            "            when '6' => return \"0110\";\n" +
            "            when '7' => return \"0111\";\n" +
            "            when '8' => return \"1000\";\n" +
            "            when '9' => return \"1001\";\n" +
            "            when 'A' | 'a' => return \"1010\";\n" +
            "            when 'B' | 'b' => return \"1011\";\n" +
            "            when 'C' | 'c' => return \"1100\";\n" +
            "            when 'D' | 'd' => return \"1101\";\n" +
            "            when 'E' | 'e' => return \"1110\";\n" +
            "            when others => return \"1111\";\n" +
            "        end case;\n" +
            "    end function;\n\n" +
            "    function hex_to_byte(text_value : string) return std_logic_vector is\n" +
            "        variable result : std_logic_vector(7 downto 0);\n" +
            "    begin\n" +
            "        result(7 downto 4) := hex_to_slv4(text_value(text_value'low));\n" +
            "        result(3 downto 0) := hex_to_slv4(text_value(text_value'low + 1));\n" +
            "        return result;\n" +
            "    end function;\n\n" +
            "    function hex_to_word64(text_value : string) return std_logic_vector is\n" +
            "        variable result : std_logic_vector(63 downto 0);\n" +
            "        variable high_bit : integer;\n" +
            "    begin\n" +
            "        for i in 0 to 15 loop\n" +
            "            high_bit := 63 - (i * 4);\n" +
            "            result(high_bit downto high_bit - 3) := hex_to_slv4(text_value(text_value'low + i));\n" +
            "        end loop;\n" +
            "        return result;\n" +
            "    end function;\n\n" +
            "    procedure load_preload_file(\n" +
            "        label_name : in string;\n" +
            "        path : in string;\n" +
            "        base_offset : in integer;\n" +
            "        variable mem_state : inout mem_t\n" +
            "    ) is\n" +
            "        file input_file : text open read_mode is path;\n" +
            "        variable word_idx : integer;\n" +
            "        variable byte_idx : integer;\n" +
            "        variable bytes_loaded : integer := 0;\n" +
            "        variable words_loaded : integer := 0;\n" +
            "        variable row_len : integer;\n" +
            "        variable current_word : std_logic_vector(63 downto 0);\n" +
            "        variable next_word : std_logic_vector(63 downto 0);\n" +
            "        variable row : line;\n" +
            "    begin\n" +
            "        while not endfile(input_file) loop\n" +
            "            readline(input_file, row);\n" +
            "            row_len := row.all'length;\n" +
            "            if row_len = 16 then\n" +
            "                assert (base_offset mod 8) = 0\n" +
            "                    report \"word preload requires 8-byte aligned base offset for \" & label_name\n" +
            "                    severity failure;\n" +
            "                word_idx := (base_offset / 8) + words_loaded;\n" +
            "                if word_idx < mem_state'length then\n" +
            "                    next_word := hex_to_word64(row.all(1 to 16));\n" +
            "                    mem_state(word_idx) := next_word;\n" +
            "                end if;\n" +
            "                words_loaded := words_loaded + 1;\n" +
            "                bytes_loaded := bytes_loaded + 8;\n" +
            "                if (words_loaded mod PROGRESS_REPORT_INTERVAL) = 0 then\n" +
            "                    report \"PRELOAD_\" & label_name & \"_WORDS: \" & integer'image(words_loaded);\n" +
            "                    report \"PRELOAD_\" & label_name & \"_BYTES: \" & integer'image(bytes_loaded);\n" +
            "                end if;\n" +
            "            elsif row_len = 2 then\n" +
            "                word_idx := (base_offset + bytes_loaded) / 8;\n" +
            "                byte_idx := (base_offset + bytes_loaded) mod 8;\n" +
            "                if word_idx < mem_state'length then\n" +
            "                    current_word := mem_state(word_idx);\n" +
            "                    current_word((byte_idx * 8) + 7 downto byte_idx * 8) := hex_to_byte(row.all(1 to 2));\n" +
            "                    mem_state(word_idx) := current_word;\n" +
            "                end if;\n" +
            "                bytes_loaded := bytes_loaded + 1;\n" +
            "                if (bytes_loaded mod PROGRESS_REPORT_INTERVAL) = 0 then\n" +
            "                    report \"PRELOAD_\" & label_name & \"_BYTES: \" & integer'image(bytes_loaded);\n" +
            "                end if;\n" +
            "            elsif row_len /= 0 then\n" +
            "                assert false\n" +
            "                    report \"unsupported preload line width for \" & label_name & \": \" & integer'image(row_len)\n" +
            "                    severity failure;\n" +
            "            end if;\n" +
            "            deallocate(row);\n" +
            "        end loop;\n" +
            "        if words_loaded > 0 then\n" +
            "            report \"PRELOAD_\" & label_name & \"_DONE_WORDS: \" & integer'image(words_loaded);\n" +
            "        end if;\n" +
            "        report \"PRELOAD_\" & label_name & \"_DONE_BYTES: \" & integer'image(bytes_loaded);\n" +
            "    end procedure;\n\n" +
            "    function safe_index(bits : std_logic_vector) return integer is\n" +
            "    begin\n" +
            "        for i in bits'range loop\n" +
            "            if bits(i) /= '0' and bits(i) /= '1' then\n" +
            "                return 0;\n" +
            "            end if;\n" +
            "        end loop;\n" +
            "        return to_integer(unsigned(bits));\n" +
            "    end function;\n\n" +
            "    function word32_to_report_int(word_val : std_logic_vector(31 downto 0)) return integer is\n" +
            "    begin\n" +
            "        if word_val(31) = '1' then\n" +
            "            return -1;\n" +
            "        end if;\n" +
            "        return safe_index(word_val(30 downto 0));\n" +
            "    end function;\n\n" +
            "    function hex_char(nibble : std_logic_vector(3 downto 0)) return character is\n" +
            "        variable idx : integer;\n" +
            "    begin\n" +
            "        idx := safe_index(nibble);\n" +
            "        case idx is\n" +
            "            when 0 => return '0';\n" +
            "            when 1 => return '1';\n" +
            "            when 2 => return '2';\n" +
            "            when 3 => return '3';\n" +
            "            when 4 => return '4';\n" +
            "            when 5 => return '5';\n" +
            "            when 6 => return '6';\n" +
            "            when 7 => return '7';\n" +
            "            when 8 => return '8';\n" +
            "            when 9 => return '9';\n" +
            "            when 10 => return 'A';\n" +
            "            when 11 => return 'B';\n" +
            "            when 12 => return 'C';\n" +
            "            when 13 => return 'D';\n" +
            "            when 14 => return 'E';\n" +
            "            when others => return 'F';\n" +
            "        end case;\n" +
            "    end function;\n\n" +
            "    function hex32(bits : std_logic_vector(31 downto 0)) return string is\n" +
            "        variable result : string(1 to 8);\n" +
            "    begin\n" +
            "        for i in 0 to 7 loop\n" +
            "            result(i + 1) := hex_char(bits(31 - (i * 4) downto 28 - (i * 4)));\n" +
            "        end loop;\n" +
            "        return result;\n" +
            "    end function;\n\n" +
            "    function hex64(bits : std_logic_vector(63 downto 0)) return string is\n" +
            "        variable result : string(1 to 16);\n" +
            "    begin\n" +
            "        for i in 0 to 15 loop\n" +
            "            result(i + 1) := hex_char(bits(63 - (i * 4) downto 60 - (i * 4)));\n" +
            "        end loop;\n" +
            "        return result;\n" +
            "    end function;\n\n" +
            "    function hex8(bits : std_logic_vector(7 downto 0)) return string is\n" +
            "        variable result : string(1 to 2);\n" +
            "    begin\n" +
            "        result(1) := hex_char(bits(7 downto 4));\n" +
            "        result(2) := hex_char(bits(3 downto 0));\n" +
            "        return result;\n" +
            "    end function;\n\n" +
            "    function mem_index(addr : std_logic_vector(63 downto 0)) return integer is\n" +
            "    begin\n" +
            "        if addr(63 downto 32) /= x\"00000000\" or addr(31) /= '1' then\n" +
            "            return MEM_WORDS;\n" +
            "        end if;\n" +
            "        return safe_index(addr(30 downto 3));\n" +
            "    end function;\n\n" +
            "    function dtb_offset(addr : std_logic_vector(63 downto 0)) return integer is\n" +
            "        variable addr_int : integer;\n" +
            "        variable base_int : integer;\n" +
            "    begin\n" +
            "        addr_int := safe_index(addr(30 downto 0));\n" +
            "        base_int := safe_index(BOOT_DTB_ADDR(30 downto 0));\n" +
            "        return addr_int - base_int;\n" +
            "    end function;\n\n" +
            "    function dtb_in_range(addr : std_logic_vector(63 downto 0)) return boolean is\n" +
            "        variable offs : integer;\n" +
            "    begin\n" +
            "        offs := dtb_offset(addr);\n" +
            "        return offs >= 0 and offs < DTB_SIZE_BYTES;\n" +
            "    end function;\n\n" +
            "    function proof_in_range(addr : std_logic_vector(63 downto 0)) return boolean is\n" +
            "    begin\n" +
            "        return addr(63 downto 8) = x\"0000000080FF10\";\n" +
            "    end function;\n\n" +
            "    function proof_index(addr : std_logic_vector(63 downto 0)) return integer is\n" +
            "    begin\n" +
            "        return safe_index(addr(7 downto 3));\n" +
            "    end function;\n\n" +
            "    function dtb_word(addr : std_logic_vector(63 downto 0)) return std_logic_vector is\n" +
            "        variable result : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "        variable base_offs : integer;\n" +
            "    begin\n" +
            "        base_offs := (dtb_offset(addr) / 8) * 8;\n" +
            "        for i in 0 to 7 loop\n" +
            "            if base_offs + i >= 0 and base_offs + i < DTB_SIZE_BYTES then\n" +
            "                result((i * 8) + 7 downto i * 8) := DTB_BYTES(base_offs + i);\n" +
            "            end if;\n" +
            "        end loop;\n" +
            "        return result;\n" +
            "    end function;\n\n\n" +
            "    impure function mem64(addr : std_logic_vector(63 downto 0)) return word64_t is\n" +
            "        variable idx : integer;\n" +
            "        variable zero_word : word64_t := (others => '0');\n" +
            "    begin\n" +
            "        if proof_in_range(addr) then\n" +
            "            idx := proof_index(addr);\n" +
            "            if idx < proof_mem'length then\n" +
            "                return proof_mem(idx);\n" +
            "            end if;\n" +
            "            return zero_word;\n" +
            "        end if;\n" +
            "        idx := mem_index(addr);\n" +
            "        if idx >= MEM_WORDS then\n" +
            "            return zero_word;\n" +
            "        end if;\n" +
            "        return mem(idx);\n" +
            "    end function;\n\n" +
            "    impure function fetch_imem_word(addr : std_logic_vector(63 downto 0)) return word32_t is\n" +
            "        variable idx : integer;\n" +
            "        variable next_idx : integer;\n" +
            "        variable current_word : word64_t;\n" +
            "        variable next_word : word64_t := x\"0000001300000013\";\n" +
            "        variable result : word32_t := x\"00000013\";\n" +
            "    begin\n" +
            "        idx := mem_index(addr);\n" +
            "        if idx >= MEM_WORDS then\n" +
            "            return result;\n" +
            "        end if;\n" +
            "        current_word := mem(idx);\n" +
            "        case addr(2 downto 1) is\n" +
            "            when \"00\" => result := current_word(31 downto 0);\n" +
            "            when \"01\" => result := current_word(47 downto 16);\n" +
            "            when \"10\" => result := current_word(63 downto 32);\n" +
            "            when others =>\n" +
            "                next_idx := idx + 1;\n" +
            "                if next_idx < MEM_WORDS then\n" +
            "                    next_word := mem(next_idx);\n" +
            "                end if;\n" +
            "                result(15 downto 0) := current_word(63 downto 48);\n" +
            "                result(31 downto 16) := next_word(15 downto 0);\n" +
            "        end case;\n" +
            "        return result;\n" +
            "    end function;\n\n" +
            "    signal uart_word : std_logic_vector(31 downto 0) := (others => '0');\n" +
            "    signal uart_marker_seen : boolean := false;\n" +
            "    signal dtb_probe_seen : boolean := false;\n" +
            "    signal dtb_probe_addr : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal dmem_write_seen : boolean := false;\n" +
            "    signal dmem_write_addr : std_logic_vector(63 downto 0) := (others => '0');\n" +
            "    signal watch_rt_alloc_reload_seen : boolean := false;\n" +
            "    signal watch_magic_load_complete_seen : boolean := false;\n" +
            "    signal watch_boot_main_post_load_seen : boolean := false;\n" +
            "    signal watch_boot_main_pre_call_seen : boolean := false;\n" +
            "    signal watch_boot_main_call_seen : boolean := false;\n" +
            "    signal watch_proof_store_entry_seen : boolean := false;\n" +
            "    signal watch_proof_mmio_entry_seen : boolean := false;\n" +
            "    signal watch_proof_mmio_store_seen : boolean := false;\n" +
            "    signal watch_save_boot_args_ret_seen : boolean := false;\n" +
            "    signal watch_parse_boot_info_ret_seen : boolean := false;\n" +
            "    signal watch_hart_id_ret_seen : boolean := false;\n" +
            "    signal watch_slot2_call_seen : boolean := false;\n" +
            "    signal watch_slot3_call_seen : boolean := false;\n" +
            "    signal watch_slot5_call_seen : boolean := false;\n" +
            "    signal watch_slot6_call_seen : boolean := false;\n" +
            "    signal watch_slot7_call_seen : boolean := false;\n" +
            "    signal watch_slot9_call_seen : boolean := false;\n" +
            "    signal fw_preload_done : boolean := false;\n" +
            "    signal payload_boot_chunk_ready : boolean := false;\n" +
            "    signal mem_epoch : std_logic := '0';\n" +
            "    signal done : boolean := false;\n" +
            "begin\n" +
            "    preload_fw_mem : process\n" +
            "        file input_file : text;\n" +
            "        variable words_loaded : integer := 0;\n" +
            "        variable row : line;\n" +
            "        variable row_len : integer;\n" +
            "        variable next_word : std_logic_vector(63 downto 0);\n" +
            "    begin\n" +
            "        report \"PRELOAD_FW_PROCESS_START\";\n" +
            "        file_open(input_file, FW_HEX_PATH, read_mode);\n" +
            "        while not endfile(input_file) loop\n" +
            "            readline(input_file, row);\n" +
            "            row_len := row.all'length;\n" +
            "            if row_len = 16 then\n" +
            "                next_word := hex_to_word64(row.all(1 to 16));\n" +
            "                if words_loaded < MEM_WORDS then\n" +
            "                    mem(words_loaded) := next_word;\n" +
            "                end if;\n" +
            "                words_loaded := words_loaded + 1;\n" +
            "            elsif row_len /= 0 then\n" +
            "                assert false\n" +
            "                    report \"unsupported preload line width for FW: \" & integer'image(row_len)\n" +
            "                    severity failure;\n" +
            "            end if;\n" +
            "            deallocate(row);\n" +
            "        end loop;\n" +
            "        mem_epoch <= not mem_epoch;\n" +
            "        fw_preload_done <= true;\n" +
            "        report \"PRELOAD_FW_READY\";\n" +
            "        wait;\n" +
            "    end process;\n\n" +
            "    preload_payload_mem : process\n" +
            "        file input_file : text;\n" +
            "        variable word_idx : integer;\n" +
            "        variable byte_idx : integer;\n" +
            "        variable bytes_loaded : integer := 0;\n" +
            "        variable words_loaded : integer := 0;\n" +
            "        variable chunk_words : integer := 0;\n" +
            "        variable row_len : integer;\n" +
            "        variable current_word : std_logic_vector(63 downto 0);\n" +
            "        variable next_word : std_logic_vector(63 downto 0);\n" +
            "        variable row : line;\n" +
            "    begin\n" +
            "        report \"PRELOAD_PAYLOAD_PROCESS_WAIT_FW\";\n" +
            "        wait until fw_preload_done;\n" +
            "        report \"PRELOAD_PAYLOAD_PROCESS_START\";\n" +
            "        file_open(input_file, PAYLOAD_HEX_PATH, read_mode);\n" +
            "        while not endfile(input_file) loop\n" +
            "            chunk_words := 0;\n" +
            "            while not endfile(input_file) and chunk_words < PAYLOAD_CHUNK_WORDS loop\n" +
            "                readline(input_file, row);\n" +
            "                row_len := row.all'length;\n" +
            "                if row_len = 16 then\n" +
            "                    word_idx := (16#200000# / 8) + words_loaded;\n" +
            "                    if word_idx < MEM_WORDS then\n" +
            "                        next_word := hex_to_word64(row.all(1 to 16));\n" +
            "                        mem(word_idx) := next_word;\n" +
            "                    end if;\n" +
            "                    words_loaded := words_loaded + 1;\n" +
            "                    bytes_loaded := bytes_loaded + 8;\n" +
            "                    chunk_words := chunk_words + 1;\n" +
            "                    if (words_loaded mod PROGRESS_REPORT_INTERVAL) = 0 then\n" +
            "                        report \"PRELOAD_PAYLOAD_WORDS: \" & integer'image(words_loaded);\n" +
            "                        report \"PRELOAD_PAYLOAD_BYTES: \" & integer'image(bytes_loaded);\n" +
            "                    end if;\n" +
            "                elsif row_len = 2 then\n" +
            "                    word_idx := (16#200000# + bytes_loaded) / 8;\n" +
            "                    byte_idx := (16#200000# + bytes_loaded) mod 8;\n" +
            "                    if word_idx < MEM_WORDS then\n" +
            "                        current_word := mem(word_idx);\n" +
            "                        current_word((byte_idx * 8) + 7 downto byte_idx * 8) := hex_to_byte(row.all(1 to 2));\n" +
            "                        mem(word_idx) := current_word;\n" +
            "                    end if;\n" +
            "                    bytes_loaded := bytes_loaded + 1;\n" +
            "                    if (bytes_loaded mod PROGRESS_REPORT_INTERVAL) = 0 then\n" +
            "                        report \"PRELOAD_PAYLOAD_BYTES: \" & integer'image(bytes_loaded);\n" +
            "                    end if;\n" +
            "                elsif row_len /= 0 then\n" +
            "                    assert false\n" +
            "                        report \"unsupported preload line width for PAYLOAD: \" & integer'image(row_len)\n" +
            "                        severity failure;\n" +
            "                end if;\n" +
            "                deallocate(row);\n" +
            "            end loop;\n" +
            "            if not payload_boot_chunk_ready then\n" +
            "                mem_epoch <= not mem_epoch;\n" +
            "                payload_boot_chunk_ready <= true;\n" +
            "                report \"PRELOAD_PAYLOAD_BOOT_CHUNK_READY_BYTES: \" & integer'image(bytes_loaded);\n" +
            "            end if;\n" +
            "            if words_loaded >= (PAYLOAD_BOOT_WINDOW_BYTES / 8) then\n" +
            "                report \"PRELOAD_PAYLOAD_BOOT_WINDOW_FILLED_BYTES: \" & integer'image(bytes_loaded);\n" +
            "                exit;\n" +
            "            end if;\n" +
            "            wait for 1 ns;\n" +
            "        end loop;\n" +
            "        report \"PRELOAD_PAYLOAD_DONE_WORDS: \" & integer'image(words_loaded);\n" +
            "        report \"PRELOAD_PAYLOAD_DONE_BYTES: \" & integer'image(bytes_loaded);\n" +
            "        wait;\n" +
            "    end process;\n\n" +
            "    u_cpu : entity work.{top}\n" +
            "        port map (\n" +
            "            clk        => clk,\n" +
            "            reset_n    => reset_n,\n" +
            "            imem_addr  => imem_addr,\n" +
            "            imem_rdata => imem_data,\n" +
            "            dmem_addr  => dmem_addr,\n" +
            "            dmem_wdata => dmem_wdata,\n" +
            "            dmem_rdata => dmem_rdata,\n" +
            "            dmem_we    => dmem_we,\n" +
            "            dmem_re    => dmem_re,\n" +
            "            dmem_width => dmem_width,\n" +
            "            dmem_wstrb => dmem_wstrb,\n" +
            "            irq_software => irq_software,\n" +
            "            irq_timer  => irq_timer,\n" +
            "            irq_external => irq_external,\n" +
            "            mmu_dmem_l2_pte => (others => '0'),\n" +
            "            mmu_dmem_l1_pte => (others => '0'),\n" +
            "            mmu_dmem_l0_pte => (others => '0'),\n" +
            "            debug_priv_mode => debug_priv_mode,\n" +
            "            debug_last_load_value => debug_last_load_value,\n" +
            "            debug_ra   => debug_ra,\n" +
            "            debug_sp   => debug_sp,\n" +
            "            debug_s0   => debug_s0,\n" +
            "            debug_a0   => debug_a0,\n" +
            "            debug_a1   => debug_a1,\n" +
            "            debug_a2   => debug_a2,\n" +
            "            debug_load_rd => debug_load_rd,\n" +
            "            debug_pc   => debug_pc,\n" +
            "            trap       => trap,\n" +
            "            halt       => halt\n" +
            "        );\n\n" +
            "    clk <= not clk after CLK_PERIOD / 2 when not done else '0';\n\n" +
            "    process(all)\n" +
            "    begin\n" +
            "        if mem_epoch = '1' then\n" +
            "            null;\n" +
            "        end if;\n" +
            "        imem_data <= fetch_imem_word(imem_addr);\n" +
            "    end process;\n\n" +
            "    process(clk)\n" +
            "        variable word_idx : integer;\n" +
            "        variable current_word : std_logic_vector(63 downto 0);\n" +
            "        variable next_uart_word : std_logic_vector(31 downto 0);\n" +
            "        variable trap_prev : std_logic := '0';\n" +
            "        variable halt_prev : std_logic := '0';\n" +
            "    begin\n" +
            "        if rising_edge(clk) then\n" +
            "            if trap = '1' and trap_prev = '0' then\n" +
            "                report \"TRAP_EDGE_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"TRAP_EDGE_PRIV_MODE: \" & integer'image(safe_index(debug_priv_mode));\n" +
            "                report \"TRAP_EDGE_IMEM_HEX32: \" & hex32(imem_data);\n" +
            "                report \"TRAP_EDGE_DMEM_ADDR_HEX32: \" & hex32(dmem_addr(31 downto 0));\n" +
            "                report \"TRAP_EDGE_DMEM_RDATA_HEX32: \" & hex32(dmem_rdata(31 downto 0));\n" +
            "                report \"TRAP_EDGE_LAST_LOAD_HEX32: \" & hex32(debug_last_load_value(31 downto 0));\n" +
            "                report \"TRAP_EDGE_RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "                report \"TRAP_EDGE_S0_HEX32: \" & hex32(debug_s0(31 downto 0));\n" +
            "                report \"TRAP_EDGE_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"TRAP_EDGE_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "            end if;\n" +
            "            if halt = '1' and halt_prev = '0' then\n" +
            "                report \"HALT_EDGE_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"HALT_EDGE_PRIV_MODE: \" & integer'image(safe_index(debug_priv_mode));\n" +
            "                report \"HALT_EDGE_IMEM_HEX32: \" & hex32(imem_data);\n" +
            "            end if;\n" +
            "            trap_prev := trap;\n" +
            "            halt_prev := halt;\n" +
            "            if debug_pc = x\"0000000080207CAC\" then\n" +
            "                report \"WATCH_STACK_MAGIC_STORE_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_STORE_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_STORE_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_STORE_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_STORE_LAST_HEX32: \" & hex32(debug_last_load_value(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_SLOT_HEX64: \" & hex64(mem64(debug_a0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207CBA\" then\n" +
            "                report \"WATCH_STACK_MAGIC_RELOAD_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_RELOAD_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_RELOAD_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_RELOAD_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_RELOAD_RD_HEX32: \" & hex32(debug_load_rd(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_RELOAD_LAST_HEX32: \" & hex32(debug_last_load_value(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_SLOT_HEX64: \" & hex64(mem64(debug_a0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207CC4\" then\n" +
            "                report \"WATCH_STACK_MAGIC_USE_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_USE_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_USE_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_USE_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_USE_RD_HEX32: \" & hex32(debug_load_rd(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_USE_LAST_HEX32: \" & hex32(debug_last_load_value(31 downto 0));\n" +
            "                report \"WATCH_STACK_MAGIC_SLOT_HEX64: \" & hex64(mem64(debug_a0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080209D70\" and not watch_rt_alloc_reload_seen then\n" +
            "                watch_rt_alloc_reload_seen <= true;\n" +
            "                report \"WATCH_RT_ALLOC_RELOAD_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_RT_ALLOC_RELOAD_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_RT_ALLOC_RELOAD_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_RT_ALLOC_RELOAD_S0_HEX32: \" & hex32(debug_s0(31 downto 0));\n" +
            "                report \"WATCH_RT_ALLOC_RELOAD_S0_M24_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(24, 64)))(31 downto 0));\n" +
            "                report \"WATCH_RT_ALLOC_RELOAD_S0_M32_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(32, 64)))(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207CD6\" and not watch_boot_main_post_load_seen then\n" +
            "                watch_boot_main_post_load_seen <= true;\n" +
            "                report \"WATCH_BOOT_MAIN_POST_LOAD_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_BOOT_MAIN_POST_LOAD_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_BOOT_MAIN_POST_LOAD_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_BOOT_MAIN_POST_LOAD_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207CCC\" and not watch_boot_main_pre_call_seen then\n" +
            "                watch_boot_main_pre_call_seen <= true;\n" +
            "                report \"WATCH_PROOF_STORE_POST_MMIO_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_PROOF_STORE_POST_MMIO_RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "                report \"WATCH_PROOF_STORE_POST_MMIO_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_PROOF_STORE_POST_MMIO_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_PROOF_STORE_POST_MMIO_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207CD6\" and not watch_boot_main_call_seen then\n" +
            "                watch_boot_main_call_seen <= true;\n" +
            "                report \"WATCH_PROOF_STORE_RA_RELOAD_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_PROOF_STORE_RA_RELOAD_RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "                report \"WATCH_PROOF_STORE_RA_RELOAD_SP_HEX32: \" & hex32(debug_sp(31 downto 0));\n" +
            "                report \"WATCH_PROOF_STORE_RA_RELOAD_SP_P58_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_sp) + to_unsigned(16#58#, 64)))(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207CD6\" and not watch_magic_load_complete_seen then\n" +
            "                watch_magic_load_complete_seen <= true;\n" +
            "                report \"WATCH_BOOT_MAIN_CALL_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_BOOT_MAIN_CALL_RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "                report \"WATCH_BOOT_MAIN_CALL_S0_HEX32: \" & hex32(debug_s0(31 downto 0));\n" +
            "                report \"WATCH_BOOT_MAIN_CALL_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_BOOT_MAIN_CALL_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_BOOT_MAIN_CALL_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "                report \"WATCH_BOOT_MAIN_CALL_S0_M8_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(8, 64)))(31 downto 0));\n" +
            "                report \"WATCH_BOOT_MAIN_CALL_S0_M16_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(16, 64)))(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"00000000802008EA\" then\n" +
            "                proof_store_call_count <= proof_store_call_count + 1;\n" +
            "                report \"PROOF_STORE_CALL_COUNT: \" & integer'image(proof_store_call_count + 1);\n" +
            "                report \"PROOF_STORE_CALL_SLOT: \" & integer'image(word32_to_report_int(debug_a0(31 downto 0)));\n" +
            "                report \"PROOF_STORE_CALL_SLOT_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"PROOF_STORE_CALL_VALUE_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"PROOF_STORE_CALL_VALUE_HEX64: \" & hex64(debug_a1);\n" +
            "                if not watch_proof_store_entry_seen then\n" +
            "                    watch_proof_store_entry_seen <= true;\n" +
            "                    report \"WATCH_PROOF_STORE_ENTRY_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                    report \"WATCH_PROOF_STORE_ENTRY_RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "                    report \"WATCH_PROOF_STORE_ENTRY_S0_HEX32: \" & hex32(debug_s0(31 downto 0));\n" +
            "                    report \"WATCH_PROOF_STORE_ENTRY_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                    report \"WATCH_PROOF_STORE_ENTRY_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                    report \"WATCH_PROOF_STORE_ENTRY_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "                end if;\n" +
            "            end if;\n" +
            "            if debug_pc = x\"00000000802008F6\" and not watch_proof_mmio_entry_seen then\n" +
            "                watch_proof_mmio_entry_seen <= true;\n" +
            "                report \"WATCH_PROOF_MMIO_ENTRY_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_PROOF_MMIO_ENTRY_RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "                report \"WATCH_PROOF_MMIO_ENTRY_S0_HEX32: \" & hex32(debug_s0(31 downto 0));\n" +
            "                report \"WATCH_PROOF_MMIO_ENTRY_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_PROOF_MMIO_ENTRY_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_PROOF_MMIO_ENTRY_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"00000000802008F8\" and not watch_proof_mmio_store_seen then\n" +
            "                watch_proof_mmio_store_seen <= true;\n" +
            "                report \"WATCH_PROOF_MMIO_STORE_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_PROOF_MMIO_STORE_RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "                report \"WATCH_PROOF_MMIO_STORE_S0_HEX32: \" & hex32(debug_s0(31 downto 0));\n" +
            "                report \"WATCH_PROOF_MMIO_STORE_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_PROOF_MMIO_STORE_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_PROOF_MMIO_STORE_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207D04\" and not watch_save_boot_args_ret_seen then\n" +
            "                watch_save_boot_args_ret_seen <= true;\n" +
            "                report \"WATCH_SAVE_BOOT_ARGS_RET_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_SAVE_BOOT_ARGS_RET_RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "                report \"WATCH_SAVE_BOOT_ARGS_RET_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_SAVE_BOOT_ARGS_RET_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_SAVE_BOOT_ARGS_RET_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207D0E\" and not watch_parse_boot_info_ret_seen then\n" +
            "                watch_parse_boot_info_ret_seen <= true;\n" +
            "                report \"WATCH_PARSE_BOOT_INFO_RET_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_PARSE_BOOT_INFO_RET_RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "                report \"WATCH_PARSE_BOOT_INFO_RET_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_PARSE_BOOT_INFO_RET_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_PARSE_BOOT_INFO_RET_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207D22\" and not watch_hart_id_ret_seen then\n" +
            "                watch_hart_id_ret_seen <= true;\n" +
            "                report \"WATCH_HART_ID_RET_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_HART_ID_RET_RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "                report \"WATCH_HART_ID_RET_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_HART_ID_RET_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_HART_ID_RET_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207D2C\" and not watch_slot2_call_seen then\n" +
            "                watch_slot2_call_seen <= true;\n" +
            "                report \"WATCH_SLOT2_CALL_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_SLOT2_CALL_RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "                report \"WATCH_SLOT2_CALL_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_SLOT2_CALL_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_SLOT2_CALL_A2_HEX32: \" & hex32(debug_a2(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207C04\" and not watch_slot3_call_seen then\n" +
            "                watch_slot3_call_seen <= true;\n" +
            "                report \"WATCH_SLOT3_CALL_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_SLOT3_CALL_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_SLOT3_CALL_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_SLOT3_CALL_SP_P392_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_sp) + to_unsigned(392, 64)))(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207C2A\" and not watch_slot5_call_seen then\n" +
            "                watch_slot5_call_seen <= true;\n" +
            "                report \"WATCH_SLOT5_CALL_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_SLOT5_CALL_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_SLOT5_CALL_SP_P600_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_sp) + to_unsigned(600, 64)))(31 downto 0));\n" +
            "                report \"WATCH_SLOT5_CALL_SP_P144_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_sp) + to_unsigned(144, 64)))(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207C48\" and not watch_slot6_call_seen then\n" +
            "                watch_slot6_call_seen <= true;\n" +
            "                report \"WATCH_SLOT6_CALL_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_SLOT6_CALL_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_SLOT6_CALL_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_SLOT6_CALL_SP_P320_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_sp) + to_unsigned(320, 64)))(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"00000000802079D4\" and not watch_slot7_call_seen then\n" +
            "                watch_slot7_call_seen <= true;\n" +
            "                report \"WATCH_SLOT7_CALL_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_SLOT7_CALL_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_SLOT7_CALL_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_SLOT7_CALL_SP_P584_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_sp) + to_unsigned(584, 64)))(31 downto 0));\n" +
            "            end if;\n" +
            "            if debug_pc = x\"0000000080207A04\" and not watch_slot9_call_seen then\n" +
            "                watch_slot9_call_seen <= true;\n" +
            "                report \"WATCH_SLOT9_CALL_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"WATCH_SLOT9_CALL_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"WATCH_SLOT9_CALL_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"WATCH_SLOT9_CALL_SP_P568_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_sp) + to_unsigned(568, 64)))(31 downto 0));\n" +
            "            end if;\n" +
            "            if dmem_re = '1' and dtb_in_range(dmem_addr) then\n" +
            "                dtb_probe_seen <= true;\n" +
            "                if not dtb_probe_seen then\n" +
            "                    dtb_probe_addr <= dmem_addr;\n" +
            "                end if;\n" +
            "            end if;\n" +
            "            if dmem_re = '1' then\n" +
            "                if dtb_in_range(dmem_addr) then\n" +
            "                    dmem_rdata <= dtb_word(dmem_addr);\n" +
            "                elsif proof_in_range(dmem_addr) then\n" +
            "                    dmem_rdata <= mem64(dmem_addr);\n" +
            "                elsif mem_index(dmem_addr) < MEM_WORDS then\n" +
            "                    dmem_rdata <= mem64(dmem_addr);\n" +
            "                else\n" +
            "                    dmem_rdata <= (others => '0');\n" +
            "                end if;\n" +
            "            end if;\n" +
            "            if dmem_re = '1' and now <= 1000 ns then\n" +
            "                report \"DMEM_READ_EVENT_ADDR_HEX32: \" & hex32(dmem_addr(31 downto 0));\n" +
            "                report \"DMEM_READ_EVENT_DATA_HEX32: \" & hex32(dmem_rdata(31 downto 0));\n" +
            "                report \"DMEM_READ_EVENT_DATA_HEX64: \" & hex64(dmem_rdata);\n" +
            "            end if;\n\n" +
            "            if dmem_we = '1' and dmem_addr = UART_ADDR and dmem_wstrb(0) = '1' then\n" +
            "                if now <= 1000 ns then\n" +
            "                    report \"DMEM_WRITE_EVENT_ADDR_HEX32: \" & hex32(dmem_addr(31 downto 0));\n" +
            "                    report \"DMEM_WRITE_EVENT_DATA_HEX32: \" & hex32(dmem_wdata(31 downto 0));\n" +
            "                    report \"DMEM_WRITE_EVENT_DATA_HEX64: \" & hex64(dmem_wdata);\n" +
            "                    report \"DMEM_WRITE_EVENT_WSTRB_HEX8: \" & hex8(dmem_wstrb);\n" +
            "                end if;\n" +
            "                report \"UART_CHAR_HEX8: \" & hex8(dmem_wdata(7 downto 0));\n" +
            "                next_uart_word := uart_word(23 downto 0) & dmem_wdata(7 downto 0);\n" +
            "                uart_word <= next_uart_word;\n" +
            "                if next_uart_word = UART_MARKER_WORD then\n" +
            "                    uart_marker_seen <= true;\n" +
            "                end if;\n" +
            "            elsif dmem_we = '1' then\n" +
            "                if proof_in_range(dmem_addr) then\n" +
            "                    word_idx := proof_index(dmem_addr);\n" +
            "                    proof_mmio_write_count <= proof_mmio_write_count + 1;\n" +
            "                    report \"PROOF_WRITE_COUNT: \" & integer'image(proof_mmio_write_count + 1);\n" +
            "                    report \"PROOF_WRITE_SLOT: \" & integer'image(word_idx);\n" +
            "                    report \"PROOF_WRITE_ADDR_HEX32: \" & hex32(dmem_addr(31 downto 0));\n" +
            "                    report \"PROOF_WRITE_DATA_HEX32: \" & hex32(dmem_wdata(31 downto 0));\n" +
            "                    report \"PROOF_WRITE_DATA_HEX64: \" & hex64(dmem_wdata);\n" +
            "                    report \"PROOF_WRITE_WSTRB_HEX8: \" & hex8(dmem_wstrb);\n" +
            "                end if;\n" +
            "                if now <= 1000 ns then\n" +
            "                    report \"DMEM_WRITE_EVENT_ADDR_HEX32: \" & hex32(dmem_addr(31 downto 0));\n" +
            "                    report \"DMEM_WRITE_EVENT_DATA_HEX32: \" & hex32(dmem_wdata(31 downto 0));\n" +
            "                    report \"DMEM_WRITE_EVENT_DATA_HEX64: \" & hex64(dmem_wdata);\n" +
            "                    report \"DMEM_WRITE_EVENT_WSTRB_HEX8: \" & hex8(dmem_wstrb);\n" +
            "                end if;\n" +
            "                dmem_write_seen <= true;\n" +
            "                dmem_write_addr <= dmem_addr;\n" +
            "                if proof_in_range(dmem_addr) then\n" +
            "                    word_idx := proof_index(dmem_addr);\n" +
            "                    if word_idx < proof_mem'length then\n" +
            "                        current_word := proof_mem(word_idx);\n" +
            "                        for i in 0 to 7 loop\n" +
            "                            if dmem_wstrb(i) = '1' then\n" +
            "                                current_word((i * 8) + 7 downto i * 8) := dmem_wdata((i * 8) + 7 downto i * 8);\n" +
            "                            end if;\n" +
            "                        end loop;\n" +
            "                        proof_mem(word_idx) <= current_word;\n" +
            "                        proof_slot_write_count(word_idx) <= proof_slot_write_count(word_idx) + 1;\n" +
            "                        if proof_slot_first_seen(word_idx) = '0' then\n" +
            "                            proof_slot_first_seen(word_idx) <= '1';\n" +
            "                            proof_slot_first_value(word_idx) <= current_word;\n" +
            "                        end if;\n" +
            "                        proof_slot_last_value(word_idx) <= current_word;\n" +
            "                        mem_epoch <= not mem_epoch;\n" +
            "                    end if;\n" +
            "                else\n" +
            "                    word_idx := mem_index(dmem_addr);\n" +
            "                    if word_idx < MEM_WORDS then\n" +
            "                        current_word := mem(word_idx);\n" +
            "                        for i in 0 to 7 loop\n" +
            "                            if dmem_wstrb(i) = '1' then\n" +
            "                                current_word((i * 8) + 7 downto i * 8) := dmem_wdata((i * 8) + 7 downto i * 8);\n" +
            "                            end if;\n" +
            "                        end loop;\n" +
            "                        mem(word_idx) := current_word;\n" +
            "                        mem_epoch <= not mem_epoch;\n" +
            "                    end if;\n" +
            "                end if;\n" +
            "            end if;\n" +
            "        end if;\n" +
            "    end process;\n\n" +
            "    process\n" +
            "        variable cycles : integer := 0;\n" +
            "    begin\n" +
            "        report \"RESET_PROCESS_WAIT_PRELOAD\";\n" +
            "        wait until fw_preload_done and payload_boot_chunk_ready;\n" +
            "        report \"RESET_PROCESS_START\";\n" +
            "        reset_n <= '0';\n" +
            "        wait for CLK_PERIOD * 5;\n" +
            "        reset_n <= '1';\n\n" +
            "        while halt = '0' and trap = '0' and cycles < MAX_CYCLES loop\n" +
            "            wait for CLK_PERIOD;\n" +
            "            cycles := cycles + 1;\n" +
            "            if cycles <= 80 then\n" +
            "                report \"HEARTBEAT_CYCLES: \" & integer'image(cycles);\n" +
            "                report \"HEARTBEAT_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"HEARTBEAT_PRIV_MODE: \" & integer'image(safe_index(debug_priv_mode));\n" +
            "                report \"HEARTBEAT_IMEM_HEX32: \" & hex32(imem_data);\n" +
            "                report \"HEARTBEAT_LAST_LOAD_HEX32: \" & hex32(debug_last_load_value(31 downto 0));\n" +
            "                report \"HEARTBEAT_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"HEARTBEAT_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "            elsif (cycles mod PROGRESS_REPORT_INTERVAL) = 0 then\n" +
            "                report \"PROGRESS_CYCLES: \" & integer'image(cycles);\n" +
            "                report \"PROGRESS_PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "                report \"PROGRESS_PRIV_MODE: \" & integer'image(safe_index(debug_priv_mode));\n" +
            "                report \"PROGRESS_IMEM_HEX32: \" & hex32(imem_data);\n" +
            "                report \"PROGRESS_LAST_LOAD_HEX32: \" & hex32(debug_last_load_value(31 downto 0));\n" +
            "                report \"PROGRESS_RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "                report \"PROGRESS_S0_HEX32: \" & hex32(debug_s0(31 downto 0));\n" +
            "                report \"PROGRESS_A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "                report \"PROGRESS_A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "                report \"PROGRESS_UART_WORD_HEX32: \" & hex32(uart_word);\n" +
            "            end if;\n" +
            "        end loop;\n\n" +
            "        report \"CYCLES: \" & integer'image(cycles);\n" +
            "        report \"MAGIC_LOW32: \" & integer'image(word32_to_report_int(mem64(MAGIC_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"DONE_LOW32: \" & integer'image(word32_to_report_int(mem64(DONE_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"HART_ID_LOW32: \" & integer'image(word32_to_report_int(mem64(HART_ID_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"DTB_ADDR_LOW32: \" & integer'image(word32_to_report_int(mem64(DTB_ADDR_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"DTB_ADDR_HEX32: \" & hex32(mem64(DTB_ADDR_ADDR_BITS)(31 downto 0));\n" +
            "        report \"DTB_VALID_LOW32: \" & integer'image(word32_to_report_int(mem64(DTB_VALID_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"RAM_BASE_LOW32: \" & integer'image(word32_to_report_int(mem64(RAM_BASE_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"RAM_SIZE_LOW32: \" & integer'image(word32_to_report_int(mem64(RAM_SIZE_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"SERIAL_BASE_LOW32: \" & integer'image(word32_to_report_int(mem64(SERIAL_BASE_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"SERIAL_MMIO_LOW32: \" & integer'image(word32_to_report_int(mem64(SERIAL_MMIO_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"MAP_LEN_LOW32: \" & integer'image(word32_to_report_int(mem64(MAP_LEN_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"REGION0_BASE_LOW32: \" & integer'image(word32_to_report_int(mem64(REGION0_BASE_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"REGION0_BASE_HEX32: \" & hex32(mem64(REGION0_BASE_ADDR_BITS)(31 downto 0));\n" +
            "        report \"REGION0_SIZE_LOW32: \" & integer'image(word32_to_report_int(mem64(REGION0_SIZE_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"REGION0_SIZE_HEX32: \" & hex32(mem64(REGION0_SIZE_ADDR_BITS)(31 downto 0));\n" +
            "        report \"REGION0_KIND_LOW32: \" & integer'image(word32_to_report_int(mem64(REGION0_KIND_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"REGION1_BASE_LOW32: \" & integer'image(word32_to_report_int(mem64(REGION1_BASE_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"REGION1_BASE_HEX32: \" & hex32(mem64(REGION1_BASE_ADDR_BITS)(31 downto 0));\n" +
            "        report \"REGION1_SIZE_LOW32: \" & integer'image(word32_to_report_int(mem64(REGION1_SIZE_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"REGION1_SIZE_HEX32: \" & hex32(mem64(REGION1_SIZE_ADDR_BITS)(31 downto 0));\n" +
            "        report \"REGION1_KIND_LOW32: \" & integer'image(word32_to_report_int(mem64(REGION1_KIND_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"REGION2_BASE_LOW32: \" & integer'image(word32_to_report_int(mem64(REGION2_BASE_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"REGION2_BASE_HEX32: \" & hex32(mem64(REGION2_BASE_ADDR_BITS)(31 downto 0));\n" +
            "        report \"REGION2_SIZE_LOW32: \" & integer'image(word32_to_report_int(mem64(REGION2_SIZE_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"REGION2_SIZE_HEX32: \" & hex32(mem64(REGION2_SIZE_ADDR_BITS)(31 downto 0));\n" +
            "        report \"REGION2_KIND_LOW32: \" & integer'image(word32_to_report_int(mem64(REGION2_KIND_ADDR_BITS)(31 downto 0)));\n" +
            "        report \"RAM_BASE_HEX32: \" & hex32(mem64(RAM_BASE_ADDR_BITS)(31 downto 0));\n" +
            "        report \"RAM_SIZE_HEX32: \" & hex32(mem64(RAM_SIZE_ADDR_BITS)(31 downto 0));\n" +
            "        report \"SERIAL_BASE_HEX32: \" & hex32(mem64(SERIAL_BASE_ADDR_BITS)(31 downto 0));\n" +
            "        report \"PROOF_STORE_CALL_COUNT_FINAL: \" & integer'image(proof_store_call_count);\n" +
            "        report \"PROOF_MMIO_WRITE_COUNT_FINAL: \" & integer'image(proof_mmio_write_count);\n" +
            "        report \"PROOF_SLOT0_WRITE_COUNT: \" & integer'image(proof_slot_write_count(0));\n" +
            "        report \"PROOF_SLOT0_FIRST_HEX64: \" & hex64(proof_slot_first_value(0));\n" +
            "        report \"PROOF_SLOT0_LAST_HEX64: \" & hex64(proof_slot_last_value(0));\n" +
            "        report \"PROOF_SLOT1_WRITE_COUNT: \" & integer'image(proof_slot_write_count(1));\n" +
            "        report \"PROOF_SLOT1_FIRST_HEX64: \" & hex64(proof_slot_first_value(1));\n" +
            "        report \"PROOF_SLOT1_LAST_HEX64: \" & hex64(proof_slot_last_value(1));\n" +
            "        report \"PROOF_SLOT2_WRITE_COUNT: \" & integer'image(proof_slot_write_count(2));\n" +
            "        report \"PROOF_SLOT2_FIRST_HEX64: \" & hex64(proof_slot_first_value(2));\n" +
            "        report \"PROOF_SLOT2_LAST_HEX64: \" & hex64(proof_slot_last_value(2));\n" +
            "        report \"DTB_PROBE_SEEN: \" & boolean'image(dtb_probe_seen);\n" +
            "        report \"DTB_PROBE_ADDR_HEX32: \" & hex32(dtb_probe_addr(31 downto 0));\n" +
            "        report \"UART_BYTES_LOW32: \" & integer'image(word32_to_report_int(uart_word));\n" +
            "        report \"UART_MARKER_SEEN: \" & boolean'image(uart_marker_seen);\n" +
            "        report \"PRIV_MODE: \" & integer'image(safe_index(debug_priv_mode));\n" +
            "        report \"HALT_SEEN: \" & std_logic'image(halt);\n" +
            "        report \"TRAP_SEEN: \" & std_logic'image(trap);\n" +
            "        report \"PC_LOW32: \" & integer'image(word32_to_report_int(debug_pc(31 downto 0)));\n" +
            "        report \"PC_HEX32: \" & hex32(debug_pc(31 downto 0));\n" +
            "        report \"RA_HEX32: \" & hex32(debug_ra(31 downto 0));\n" +
            "        report \"S0_HEX32: \" & hex32(debug_s0(31 downto 0));\n" +
            "        report \"A0_HEX32: \" & hex32(debug_a0(31 downto 0));\n" +
            "        report \"A1_HEX32: \" & hex32(debug_a1(31 downto 0));\n" +
            "        report \"S0_M8_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(8, 64)))(31 downto 0));\n" +
            "        report \"S0_M16_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(16, 64)))(31 downto 0));\n" +
            "        report \"S0_M24_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(24, 64)))(31 downto 0));\n" +
            "        report \"S0_M32_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(32, 64)))(31 downto 0));\n" +
            "        report \"S0_M64_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(64, 64)))(31 downto 0));\n" +
            "        report \"S0_M56_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(56, 64)))(31 downto 0));\n" +
            "        report \"S0_M40_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(40, 64)))(31 downto 0));\n" +
            "        report \"CALLER_S0_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(16, 64)))(31 downto 0));\n" +
            "        report \"CALLER_RA_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(16, 64)))) - to_unsigned(8, 64)))(31 downto 0));\n" +
            "        report \"CALLER_S0_M24_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(16, 64)))) - to_unsigned(24, 64)))(31 downto 0));\n" +
            "        report \"CALLER_S0_M32_HEX32: \" & hex32(mem64(std_logic_vector(unsigned(mem64(std_logic_vector(unsigned(debug_s0) - to_unsigned(16, 64)))) - to_unsigned(32, 64)))(31 downto 0));\n" +
            "        report \"DMEM_WRITE_SEEN: \" & boolean'image(dmem_write_seen);\n" +
            "        report \"DMEM_WRITE_ADDR_HEX32: \" & hex32(dmem_write_addr(31 downto 0));\n" +
            "        report \"CHECK_MAGIC_OK: \" & boolean'image(mem64(MAGIC_ADDR_BITS) = PROOF_MAGIC_EXPECTED);\n" +
            "        report \"CHECK_DONE_OK: \" & boolean'image(mem64(DONE_ADDR_BITS) = PROOF_DONE_EXPECTED);\n" +
            "        report \"CHECK_HART_ID_OK: \" & boolean'image(mem64(HART_ID_ADDR_BITS) = BOOT_HART_ID);\n" +
            "        report \"CHECK_DTB_ADDR_OK: \" & boolean'image(mem64(DTB_ADDR_ADDR_BITS) = BOOT_DTB_ADDR);\n" +
            "        report \"CHECK_DTB_VALID_OK: \" & boolean'image(mem64(DTB_VALID_ADDR_BITS) = DTB_VALID_TRUE);\n" +
            "        report \"CHECK_RAM_BASE_OK: \" & boolean'image(mem64(RAM_BASE_ADDR_BITS) = RAM_BASE_EXPECTED);\n" +
            "        report \"CHECK_RAM_SIZE_OK: \" & boolean'image(mem64(RAM_SIZE_ADDR_BITS) = RAM_SIZE_EXPECTED);\n" +
            "        report \"CHECK_SERIAL_BASE_OK: \" & boolean'image(mem64(SERIAL_BASE_ADDR_BITS) = SERIAL_BASE_EXPECTED);\n" +
            "        report \"CHECK_SERIAL_MMIO_OK: \" & boolean'image(mem64(SERIAL_MMIO_ADDR_BITS) = SERIAL_MMIO_TRUE);\n" +
            "        report \"CHECK_MAP_LEN_OK: \" & boolean'image(mem64(MAP_LEN_ADDR_BITS) = MAP_LEN_EXPECTED);\n" +
            "        report \"CHECK_REGION0_BASE_OK: \" & boolean'image(mem64(REGION0_BASE_ADDR_BITS) = REGION0_BASE_EXPECTED);\n" +
            "        report \"CHECK_REGION0_SIZE_OK: \" & boolean'image(mem64(REGION0_SIZE_ADDR_BITS) = REGION0_SIZE_EXPECTED);\n" +
            "        report \"CHECK_REGION0_KIND_OK: \" & boolean'image(mem64(REGION0_KIND_ADDR_BITS) = REGION0_KIND_EXPECTED);\n" +
            "        report \"CHECK_REGION1_BASE_OK: \" & boolean'image(mem64(REGION1_BASE_ADDR_BITS) = REGION1_BASE_EXPECTED);\n" +
            "        report \"CHECK_REGION1_SIZE_OK: \" & boolean'image(mem64(REGION1_SIZE_ADDR_BITS) = REGION1_SIZE_EXPECTED);\n" +
            "        report \"CHECK_REGION1_KIND_OK: \" & boolean'image(mem64(REGION1_KIND_ADDR_BITS) = REGION1_KIND_EXPECTED);\n" +
            "        report \"CHECK_REGION2_BASE_OK: \" & boolean'image(mem64(REGION2_BASE_ADDR_BITS) = REGION2_BASE_EXPECTED);\n" +
            "        report \"CHECK_REGION2_SIZE_OK: \" & boolean'image(mem64(REGION2_SIZE_ADDR_BITS) = REGION2_SIZE_EXPECTED);\n" +
            "        report \"CHECK_REGION2_KIND_OK: \" & boolean'image(mem64(REGION2_KIND_ADDR_BITS) = REGION2_KIND_EXPECTED);\n" +
            "        report \"CHECK_UART_MARKER_OK: \" & boolean'image(uart_marker_seen);\n" +
            "        report \"CHECK_PRIV_MODE_OK: \" & boolean'image(debug_priv_mode = \"01\");\n" +
            "        report \"CHECK_DTB_PROBE_OK: \" & boolean'image(dtb_probe_seen);\n" +
            "        report \"CHECK_DTB_PROBE_ADDR_OK: \" & boolean'image(dtb_probe_addr = BOOT_DTB_ADDR);\n" +
            "        if (halt = '1' or trap = '1') and\n" +
            "            mem64(MAGIC_ADDR_BITS) = PROOF_MAGIC_EXPECTED and\n" +
            "            mem64(DONE_ADDR_BITS) = PROOF_DONE_EXPECTED and\n" +
            "            mem64(HART_ID_ADDR_BITS) = BOOT_HART_ID and\n" +
            "            mem64(DTB_ADDR_ADDR_BITS) = BOOT_DTB_ADDR and\n" +
            "            mem64(DTB_VALID_ADDR_BITS) = DTB_VALID_TRUE and\n" +
            "            mem64(RAM_BASE_ADDR_BITS) = RAM_BASE_EXPECTED and\n" +
            "            mem64(RAM_SIZE_ADDR_BITS) = RAM_SIZE_EXPECTED and\n" +
            "            mem64(SERIAL_BASE_ADDR_BITS) = SERIAL_BASE_EXPECTED and\n" +
            "            mem64(SERIAL_MMIO_ADDR_BITS) = SERIAL_MMIO_TRUE and\n" +
            "            mem64(MAP_LEN_ADDR_BITS) = MAP_LEN_EXPECTED and\n" +
            "            mem64(REGION0_BASE_ADDR_BITS) = REGION0_BASE_EXPECTED and\n" +
            "            mem64(REGION0_SIZE_ADDR_BITS) = REGION0_SIZE_EXPECTED and\n" +
            "            mem64(REGION0_KIND_ADDR_BITS) = REGION0_KIND_EXPECTED and\n" +
            "            mem64(REGION1_BASE_ADDR_BITS) = REGION1_BASE_EXPECTED and\n" +
            "            mem64(REGION1_SIZE_ADDR_BITS) = REGION1_SIZE_EXPECTED and\n" +
            "            mem64(REGION1_KIND_ADDR_BITS) = REGION1_KIND_EXPECTED and\n" +
            "            mem64(REGION2_BASE_ADDR_BITS) = REGION2_BASE_EXPECTED and\n" +
            "            mem64(REGION2_SIZE_ADDR_BITS) = REGION2_SIZE_EXPECTED and\n" +
            "            mem64(REGION2_KIND_ADDR_BITS) = REGION2_KIND_EXPECTED and\n" +
            "            uart_marker_seen and\n" +
            "            debug_priv_mode = \"01\" and\n" +
            "            dtb_probe_seen and\n" +
            "            dtb_probe_addr = BOOT_DTB_ADDR then\n" +
            "            report \"GENERATED_RV64_BOOT_INFO_DTB: PASS\";\n" +
            "        else\n" +
            "            report \"GENERATED_RV64_BOOT_INFO_DTB: FAIL\";\n" +
            "        end if;\n" +
            "        done <= true;\n" +
            "        wait;\n" +
            "    end process;\n" +
            "end architecture sim;\n"

struct FpgaPrepareManifest:
    board: XilinxBoardProfile
    lanes: [RiscvFpgaLane]
    vivado_project_dir: text
    generated_dir: text

struct BoardLinuxBootProduct:
    product_id: text
    board_id: text
    lane_id: text
    arch: text
    generated_bundle_dir: text
    rtl_dir: text
    product_dir: text
    vivado_project_dir: text
    bitstream_path: text
    opensbi_path: text
    kernel_image_path: text
    dtb_path: text
    initramfs_path: text
    boot_script_path: text
    uart_log_path: text
    expected_markers: [text]

impl FpgaPrepareManifest:
    static fn for_board(board: XilinxBoardProfile) -> FpgaPrepareManifest:
        FpgaPrepareManifest(
            board: board,
            lanes: [RiscvFpgaLane.rv32_default(), RiscvFpgaLane.rv64_default()],
            vivado_project_dir: "build/fpga/{board.id}/vivado",
            generated_dir: "build/fpga/{board.id}/generated"
        )

    static fn default_xilinx() -> FpgaPrepareManifest:
        FpgaPrepareManifest.for_board(XilinxBoardProfile.generic())

    fn validate_for_prepare() -> [text]:
        var errors = self.board.validate_for_prepare()
        if self.vivado_project_dir == "":
            errors.push("vivado_project_dir is required")
        if self.generated_dir == "":
            errors.push("generated_dir is required")
        if self.lanes.len() == 0:
            errors.push("at least one RISC-V lane is required")
        for lane in self.lanes:
            val lane_errors = lane.validate_for_prepare()
            for err in lane_errors:
                errors.push("{lane.xlen.to_text()}: {err}")
            val source_errors = lane.hardware_source_contract_errors()
            for err in source_errors:
                errors.push(err)
        errors

    fn vivado_tcl_plan() -> text:
        var out = "create_project simple_riscv_fpga {self.vivado_project_dir} -part {self.board.part}\n"
        out = out + "set_property target_language VHDL [current_project]\n"
        out = out + "add_files {self.board.constraints_path}\n"
        for lane in self.lanes:
            out = out + "add_files {lane.rtl_dir}\n"
            out = out + "set_property top {lane.top_module} [current_fileset]\n"
        out = out + "synth_design\n"
        out

    fn readiness_summary() -> text:
        var out = "board={self.board.name} part={self.board.part} lanes={self.lanes.len()}"
        for lane in self.lanes:
            out = out + " {lane.lane_id}:{lane.readiness_status().to_text()}:{lane.platform_profile.name}:{lane.top_module}:{lane.proof_lane().to_text()}"
        out

    fn board_linux_boot_products(root_dir: text) -> [BoardLinuxBootProduct]:
        var products: [BoardLinuxBootProduct] = []
        for lane in self.lanes:
            val product_id = "{self.board.id}_{lane.xlen.to_text()}_linux"
            val product_dir = "{root_dir}/products/{product_id}"
            products.push(BoardLinuxBootProduct(
                product_id: product_id,
                board_id: self.board.id,
                lane_id: lane.lane_id,
                arch: lane.xlen.to_text(),
                generated_bundle_dir: "{root_dir}/{lane.bundle_root_name()}",
                rtl_dir: "{root_dir}/{lane.bundle_root_name()}/rtl",
                product_dir: product_dir,
                vivado_project_dir: "{product_dir}/vivado",
                bitstream_path: "{product_dir}/bitstream/{product_id}.bit",
                opensbi_path: "{product_dir}/boot/opensbi/fw_jump.bin",
                kernel_image_path: "{product_dir}/boot/Image",
                dtb_path: "{product_dir}/boot/{product_id}.dtb",
                initramfs_path: "{product_dir}/boot/{product_id}.cpio",
                boot_script_path: "scripts/mlk_s02_100t_generated_linux_boot.shs",
                uart_log_path: "{product_dir}/logs/uart.log",
                expected_markers: lane.expected_boot_markers()
            ))
        products

    fn board_linux_boot_products_manifest_text(root_dir: text) -> text:
        var out = "[board_linux_boot_products]\n"
        out = out + "board_id = \"{self.board.id}\"\n"
        out = out + "board = \"{self.board.name}\"\n"
        for product in self.board_linux_boot_products(root_dir):
            out = out + "\n[[product]]\n"
            out = out + "product_id = \"{product.product_id}\"\n"
            out = out + "board_id = \"{product.board_id}\"\n"
            out = out + "lane_id = \"{product.lane_id}\"\n"
            out = out + "arch = \"{product.arch}\"\n"
            out = out + "generated_bundle_dir = \"{product.generated_bundle_dir}\"\n"
            out = out + "rtl_dir = \"{product.rtl_dir}\"\n"
            out = out + "product_dir = \"{product.product_dir}\"\n"
            out = out + "vivado_project_dir = \"{product.vivado_project_dir}\"\n"
            out = out + "bitstream = \"{product.bitstream_path}\"\n"
            out = out + "opensbi = \"{product.opensbi_path}\"\n"
            out = out + "kernel_image = \"{product.kernel_image_path}\"\n"
            out = out + "dtb = \"{product.dtb_path}\"\n"
            out = out + "initramfs = \"{product.initramfs_path}\"\n"
            out = out + "boot_script = \"{product.boot_script_path}\"\n"
            out = out + "uart_log = \"{product.uart_log_path}\"\n"
            out = out + "expected_markers = \"{product.expected_markers.join(\"|\")}\"\n"
            out = out + "validation_kind = \"linux-uart-markers\"\n"
            out = out + "authoritative_rtl_provenance = \"simple-compiler-generated\"\n"
        out

    fn rtl_manifest_text(root_dir: text) -> text:
        var out = "[riscv_fpga_rtl]\n"
        out = out + "board_id = \"{self.board.id}\"\n"
        out = out + "board = \"{self.board.name}\"\n"
        out = out + "part = \"{self.board.part}\"\n"
        out = out + "clock_hz = {self.board.clock_hz}\n"
        out = out + "reset_polarity = \"{self.board.reset_polarity}\"\n"
        out = out + "memory_kind = \"{self.board.memory_kind}\"\n"
        out = out + "memory_base = {self.board.memory_base}\n"
        out = out + "memory_size_bytes = {self.board.memory_size_bytes}\n"
        out = out + "uart_baud = {self.board.uart_baud}\n"
        out = out + "constraints_path = \"{self.board.constraints_path}\"\n"
        out = out + "programmer = \"{self.board.programmer}\"\n"
        out = out + "vivado_mode = \"{self.board.vivado_mode}\"\n"
        for lane in self.lanes:
            val metadata = lane.debug_metadata()
            val lane_dir = "{root_dir}/{lane.bundle_root_name()}/rtl"
            val authoritative_text = "true"
            out = out + "\n[[lane]]\n"
            out = out + "lane_id = \"{lane.lane_id}\"\n"
            out = out + "arch = \"{lane.xlen.to_text()}\"\n"
            out = out + "xlen = {lane.xlen.bits()}\n"
            out = out + "bundle_dir = \"{lane.bundle_root_name()}\"\n"
            out = out + "top = \"{lane.top_module}\"\n"
            out = out + "rtl_dir = \"{lane_dir}\"\n"
            out = out + "authoritative_rtl_root = \"{lane_dir}\"\n"
            out = out + "rtl_sim_backend = \"{lane.rtl_sim_backend}\"\n"
            out = out + "package = \"{lane.package_name()}\"\n"
            out = out + "source_file = \"{lane_dir}/{lane.hardware_source_file_name()}\"\n"
            out = out + "package_file = \"{lane_dir}/{lane.package_name()}.vhd\"\n"
            out = out + "core_file = \"{lane_dir}/{lane.top_module}.vhd\"\n"
            out = out + "debug_sidecar_file = \"{lane_dir}/{lane.debug_sidecar_file_name()}\"\n"
            for authoritative_file in lane.authoritative_files(lane_dir):
                out = out + "authoritative_file = \"{authoritative_file}\"\n"
            if lane.has_support_package():
                out = out + "support_package_file = \"{lane_dir}/{lane.support_package_file_name()}\"\n"
            if lane.has_wrapper():
                out = out + "wrapper_file = \"{lane_dir}/{lane.wrapper_file_name()}\"\n"
            for runner in metadata.runner_testbenches:
                out = out + "runner_testbench = \"{lane_dir}/{runner.file_name}\"\n"
            out = out + "readiness = \"{lane.readiness_status().to_text()}\"\n"
            out = out + "proof_lane = \"{lane.proof_lane().to_text()}\"\n"
            out = out + "platform = \"{lane.platform_profile.name}\"\n"
            out = out + "scope = \"{lane.scope_note}\"\n"
            out = out + "shell_contract = \"{lane.proof_lane_summary()}\"\n"
            for debug_output in metadata.debug_outputs:
                out = out + "debug_output = \"{debug_output}\"\n"
            out = out + "linux_policy = \"{lane.linux_policy()}\"\n"
            out = out + "authoritative = \"{authoritative_text}\"\n"
            out = out + "authoritative_rtl_provenance = \"{lane.authoritative_rtl_provenance()}\"\n"
            out = out + "auxiliary_vhdl_provenance = \"{lane.auxiliary_vhdl_provenance()}\"\n"
            out = out + "runner_testbench_provenance = \"{lane.runner_testbench_provenance()}\"\n"
            out = out + "pure_simple_authoritative_rtl = \"true\"\n"
            out = out + "abi = \"{lane.linux_profile.abi.to_text()}\"\n"
            out = out + "mmu = \"{lane.linux_profile.mmu_mode.to_text()}\"\n"
            out = out + "firmware_mode = \"{lane.linux_profile.firmware_mode.to_text()}\"\n"
            out = out + "kernel_alignment = {lane.linux_profile.kernel_alignment}\n"
        out

class RiscvFpgaRtlBundle:
    root_dir: text
    manifest_path: text
    vivado_plan_path: text
    board_interface_contract_path: text
    board_linux_boot_products_manifest_path: text
    bundle_readme_path: text
    generated_files: [text]

fn _write_text_file(path: text, content: text) -> Result<(), text>:
    if not rt_file_write_text(path, content):
        return Err("failed to write {path}")
    Ok(())

fn _bundle_readme_text(manifest: FpgaPrepareManifest, root_dir: text) -> text:
    var out = "# RISC-V FPGA RTL Bundle\n\n"
    out = out + "Board: `{manifest.board.name}` (`{manifest.board.part}`)\n\n"
    out = out + "Generated bundle root: `{root_dir}`\n\n"
    out = out + "Included artifacts:\n"
    out = out + "- board-scoped manifest: `riscv_fpga_rtl_manifest.sdn`\n"
    out = out + "- Vivado plan scaffold: `vivado_project_plan.tcl`\n"
    out = out + "- logical board I/O contract: `board_interface_contract.sdn`\n"
    out = out + "- per-arch boot products manifest: `board_linux_boot_products.sdn`\n"
    for lane in manifest.lanes:
        out = out + "- {lane.lane_id} generated Simple source: `{lane.bundle_root_name()}/rtl/{lane.hardware_source_file_name()}`\n"
        out = out + "- {lane.lane_id} generated VHDL package: `{lane.bundle_root_name()}/rtl/{lane.package_name()}.vhd`\n"
        out = out + "- {lane.lane_id} generated VHDL core: `{lane.bundle_root_name()}/rtl/{lane.top_module}.vhd`\n"
        out = out + "- {lane.lane_id} debug sidecar (canonical machine-readable debug metadata): `{lane.bundle_root_name()}/rtl/{lane.debug_sidecar_file_name()}`\n"
        if lane.has_support_package():
            out = out + "- {lane.lane_id} emitted support package: `{lane.bundle_root_name()}/rtl/{lane.support_package_file_name()}`\n"
        if lane.has_wrapper():
            out = out + "- {lane.lane_id} emitted wrapper: `{lane.bundle_root_name()}/rtl/{lane.wrapper_file_name()}`\n"
    out = out + "\nBoundary:\n"
    out = out + "- This bundle is the authoritative source for runner-consumed generated-core RTL.\n"
    out = out + "- Within each lane, `authoritative_rtl_root` is the lane bundle directory that contains the authoritative generated RTL set plus transitional emitted assets.\n"
    out = out + "- The machine-readable authoritative subset is listed explicitly by `authoritative_file` entries in the manifest and `provenance.authoritativeFiles` in the debug sidecar.\n"
    out = out + "- Auxiliary emitted VHDL text such as wrappers, support packages, and most runner testbenches remains transitional and is labeled separately in the manifest/debug sidecar provenance.\n"
    out = out + "- Generated-core runners must compile RTL only from the emitted bundle directories `rv32/rtl` and `rv64/rtl`.\n"
    out = out + "- The emitted boot product manifest defines the stable per-arch MLK-S02-100T outputs: generated RTL bundle, bitstream, OpenSBI payload, kernel image, DTB, initramfs, boot script, and UART log.\n"
    out = out + "- This bundle proves source and RTL artifact generation. Synth/program/UART success still depends on local board files, toolchains, and hardware.\n"
    out

fn _board_interface_contract_text(board: XilinxBoardProfile) -> text:
    if board.id == "mlk_s02_100t":
        return "[board_interface]\n" +
            "board_id = \"mlk_s02_100t\"\n" +
            "board = \"mlk_s02_100t\"\n" +
            "clock = \"clk25\"\n" +
            "clock_hz = 25000000\n" +
            "reset = \"rst_n\"\n" +
            "reset_polarity = \"active-low\"\n" +
            "uart_tx = \"uart_tx\"\n" +
            "uart_rx = \"uart_rx\"\n" +
            "led_bus = \"led\"\n" +
            "led_count = 8\n" +
            "button_bus = \"btn\"\n" +
            "button_count = 4\n"
    "[board_interface]\n" +
        "board_id = \"xilinx_generic\"\n" +
        "board = \"xilinx_generic\"\n" +
        "clock = \"sys_clk\"\n" +
        "clock_hz = 100000000\n" +
        "reset = \"rst_n\"\n" +
        "reset_polarity = \"active-low\"\n" +
        "uart_tx = \"uart_tx\"\n" +
        "uart_rx = \"uart_rx\"\n" +
        "led_bus = \"led\"\n" +
        "led_count = 8\n" +
        "button_bus = \"btn\"\n" +
        "button_count = 4\n"

fn generate_riscv_fpga_rtl_bundle(root_dir: text, manifest: FpgaPrepareManifest) -> Result<RiscvFpgaRtlBundle, text>:
    val errors = manifest.validate_for_prepare()
    if errors.len() != 0:
        return Err(errors.join("; "))
    if not rt_dir_exists(root_dir) and not rt_dir_create(root_dir, true):
        return Err("failed to create rtl root dir: {root_dir}")

    var generated: [text] = []
    for lane in manifest.lanes:
        val lane_root = "{root_dir}/{lane.bundle_root_name()}"
        val authoritative = true
        if not rt_dir_exists(lane_root) and not rt_dir_create(lane_root, true):
            return Err("failed to create rtl lane root dir: {lane_root}")
        val lane_dir = "{lane_root}/rtl"
        if not rt_dir_exists(lane_dir) and not rt_dir_create(lane_dir, true):
            return Err("failed to create rtl lane dir: {lane_dir}")
        val package_path = "{lane_dir}/{lane.package_name()}.vhd"
        val core_path = "{lane_dir}/{lane.top_module}.vhd"
        val source_path = "{lane_dir}/{lane.hardware_source_file_name()}"
        val debug_sidecar_path = "{lane_dir}/{lane.debug_sidecar_file_name()}"
        _write_text_file(source_path, lane.hardware_source_spl())?
        _write_text_file(package_path, lane.package_vhdl())?
        _write_text_file(core_path, lane.core_vhdl())?
        _write_text_file(debug_sidecar_path, lane.debug_sidecar_json(lane_dir, authoritative))?
        generated.push(source_path)
        generated.push(package_path)
        generated.push(core_path)
        generated.push(debug_sidecar_path)
        if lane.has_support_package():
            val support_package_path = "{lane_dir}/{lane.support_package_file_name()}"
            _write_text_file(support_package_path, lane.support_package_vhdl())?
            generated.push(support_package_path)
        if lane.has_wrapper():
            val wrapper_path = "{lane_dir}/{lane.wrapper_file_name()}"
            _write_text_file(wrapper_path, lane.wrapper_vhdl())?
            generated.push(wrapper_path)
        if lane.has_rv32_smoke_testbench():
            val testbench_path = "{lane_dir}/{lane.rv32_smoke_testbench_file_name()}"
            _write_text_file(testbench_path, lane.rv32_smoke_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_rv32_strobe_testbench():
            val testbench_path = "{lane_dir}/{lane.rv32_strobe_testbench_file_name()}"
            _write_text_file(testbench_path, lane.rv32_strobe_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_rv32_semihost_testbench():
            val testbench_path = "{lane_dir}/{lane.rv32_semihost_testbench_file_name()}"
            _write_text_file(testbench_path, lane.rv32_semihost_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_rv32_mailbox_testbench():
            val testbench_path = "{lane_dir}/{lane.rv32_mailbox_testbench_file_name()}"
            _write_text_file(testbench_path, lane.rv32_mailbox_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_rv32_linux_handoff_testbench():
            val testbench_path = "{lane_dir}/{lane.rv32_linux_handoff_testbench_file_name()}"
            _write_text_file(testbench_path, lane.rv32_linux_handoff_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_rv32_boot_info_real_dtb_testbench():
            val testbench_path = "{lane_dir}/{lane.rv32_boot_info_real_dtb_testbench_file_name()}"
            _write_text_file(testbench_path, lane.rv32_boot_info_real_dtb_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_rv64_smoke_testbench():
            val testbench_path = "{lane_dir}/{lane.rv64_smoke_testbench_file_name()}"
            _write_text_file(testbench_path, lane.rv64_smoke_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_rv64_irq_testbench():
            val testbench_path = "{lane_dir}/{lane.rv64_irq_testbench_file_name()}"
            _write_text_file(testbench_path, lane.rv64_irq_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_rv64_linux_handoff_testbench():
            val testbench_path = "{lane_dir}/{lane.rv64_linux_handoff_testbench_file_name()}"
            _write_text_file(testbench_path, lane.rv64_linux_handoff_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_rv64_boot_banner_testbench():
            val testbench_path = "{lane_dir}/{lane.rv64_boot_banner_testbench_file_name()}"
            _write_text_file(testbench_path, lane.rv64_boot_banner_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_boot_info_dtb_testbench():
            val testbench_path = "{lane_dir}/{lane.boot_info_dtb_testbench_file_name()}"
            _write_text_file(testbench_path, lane.boot_info_dtb_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_fw_jump_testbench():
            val testbench_path = "{lane_dir}/{lane.fw_jump_testbench_file_name()}"
            _write_text_file(testbench_path, lane.fw_jump_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_boot_info_real_dtb_testbench():
            val testbench_path = "{lane_dir}/{lane.boot_info_real_dtb_testbench_file_name()}"
            _write_text_file(testbench_path, lane.boot_info_real_dtb_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_sv39_testbench():
            val testbench_path = "{lane_dir}/{lane.sv39_testbench_file_name()}"
            _write_text_file(testbench_path, lane.sv39_testbench_vhdl())?
            generated.push(testbench_path)
        if lane.has_sv39_fault_testbench():
            val testbench_path = "{lane_dir}/{lane.sv39_fault_testbench_file_name()}"
            _write_text_file(testbench_path, lane.sv39_fault_testbench_vhdl())?
            generated.push(testbench_path)

    val manifest_path = "{root_dir}/riscv_fpga_rtl_manifest.sdn"
    val vivado_plan_path = "{root_dir}/vivado_project_plan.tcl"
    val board_interface_contract_path = "{root_dir}/board_interface_contract.sdn"
    val board_linux_boot_products_manifest_path = "{root_dir}/board_linux_boot_products.sdn"
    val bundle_readme_path = "{root_dir}/README.md"
    _write_text_file(manifest_path, manifest.rtl_manifest_text(root_dir))?
    _write_text_file(vivado_plan_path, manifest.vivado_tcl_plan())?
    _write_text_file(board_interface_contract_path, _board_interface_contract_text(manifest.board))?
    _write_text_file(board_linux_boot_products_manifest_path, manifest.board_linux_boot_products_manifest_text(root_dir))?
    _write_text_file(bundle_readme_path, _bundle_readme_text(manifest, root_dir))?
    generated.push(manifest_path)
    generated.push(vivado_plan_path)
    generated.push(board_interface_contract_path)
    generated.push(board_linux_boot_products_manifest_path)
    generated.push(bundle_readme_path)
    Ok(RiscvFpgaRtlBundle(
        root_dir: root_dir,
        manifest_path: manifest_path,
        vivado_plan_path: vivado_plan_path,
        board_interface_contract_path: board_interface_contract_path,
        board_linux_boot_products_manifest_path: board_linux_boot_products_manifest_path,
        bundle_readme_path: bundle_readme_path,
        generated_files: generated
    ))

fn generate_default_riscv_fpga_rtl_bundle(root_dir: text) -> Result<RiscvFpgaRtlBundle, text>:
    generate_riscv_fpga_rtl_bundle(root_dir, FpgaPrepareManifest.default_xilinx())

fn create_riscv_fpga_linux_manifest_for_board(board_id: text) -> Result<FpgaPrepareManifest, text>:
    val board = XilinxBoardProfile.from_id(board_id)?
    Ok(FpgaPrepareManifest.for_board(board))

fn generate_riscv_fpga_rtl_bundle_for_board(root_dir: text, board_id: text) -> Result<RiscvFpgaRtlBundle, text>:
    val manifest = create_riscv_fpga_linux_manifest_for_board(board_id)?
    generate_riscv_fpga_rtl_bundle(root_dir, manifest)

fn read_generated_riscv_fpga_rtl_file(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn create_default_riscv_fpga_linux_manifest() -> FpgaPrepareManifest:
    FpgaPrepareManifest.default_xilinx()

fn known_riscv_fpga_board_ids() -> [text]:
    XilinxBoardProfile.known_board_ids()
