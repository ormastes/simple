"""
# RISC-V FPGA Linux Preparation Contracts

Board-profiled preparation model for RISC-V CPU SoC RTL bring-up on Xilinx
FPGAs. This module describes the pre-hardware contract: what must be generated,
validated, and later consumed by Vivado/programming/boot-test wrappers.
"""

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_dir_create(path: text, recursive: bool) -> bool

enum RiscvXlen:
    Rv32
    Rv64

enum RiscvReadinessStatus:
    Preparation
    CoreGenerated
    SocGenerated
    LinuxBootValidated

impl RiscvReadinessStatus:
    fn to_text() -> text:
        match self:
            Preparation: "preparation"
            CoreGenerated: "core-generated"
            SocGenerated: "soc-generated"
            LinuxBootValidated: "linux-boot-validated"

impl RiscvXlen:
    fn bits() -> i64:
        match self:
            Rv32: 32
            Rv64: 64

    fn to_text() -> text:
        match self:
            Rv32: "rv32"
            Rv64: "rv64"

    fn linux_policy() -> text:
        match self:
            Rv32: "experimental"
            Rv64: "upstream"

    fn mmu_mode() -> text:
        match self:
            Rv32: "sv32"
            Rv64: "sv39"

struct XilinxBoardProfile:
    name: text
    part: text
    clock_hz: i64
    reset_polarity: text
    memory_kind: text
    memory_base: i64
    memory_size_bytes: i64
    uart_baud: i64
    constraints_path: text
    programmer: text
    vivado_mode: text

impl XilinxBoardProfile:
    static fn generic() -> XilinxBoardProfile:
        XilinxBoardProfile(
            name: "xilinx_generic",
            part: "BOARD_PART_TBD",
            clock_hz: 100000000,
            reset_polarity: "active-low",
            memory_kind: "ddr",
            memory_base: 0x80000000,
            memory_size_bytes: 0,
            uart_baud: 115200,
            constraints_path: "constraints/xilinx_generic.xdc",
            programmer: "hw_server",
            vivado_mode: "batch"
        )

    fn is_generic() -> bool:
        self.part == "BOARD_PART_TBD"

    fn validate_for_prepare() -> [text]:
        var errors: [text] = []
        if self.name == "":
            errors.push("board name is required")
        if self.clock_hz <= 0:
            errors.push("clock_hz must be positive")
        if self.reset_polarity != "active-low" and self.reset_polarity != "active-high":
            errors.push("reset_polarity must be active-low or active-high")
        if self.memory_kind != "ddr" and self.memory_kind != "bram":
            errors.push("memory_kind must be ddr or bram")
        if self.uart_baud <= 0:
            errors.push("uart_baud must be positive")
        if self.constraints_path == "":
            errors.push("constraints_path is required")
        if self.programmer == "":
            errors.push("programmer is required")
        if self.vivado_mode != "batch":
            errors.push("vivado_mode must be batch")
        errors

    fn validate_for_hardware_boot() -> [text]:
        var errors = self.validate_for_prepare()
        if self.is_generic():
            errors.push("xilinx part must be selected before hardware boot")
        if self.memory_size_bytes <= 0:
            errors.push("memory_size_bytes must be set before hardware boot")
        errors

struct LinuxArtifactSet:
    kernel_image: text
    rootfs_image: text
    opensbi_image: text
    uboot_image: text
    dtb_path: text
    toolchain_prefix: text

impl LinuxArtifactSet:
    static fn empty() -> LinuxArtifactSet:
        LinuxArtifactSet(
            kernel_image: "",
            rootfs_image: "",
            opensbi_image: "",
            uboot_image: "",
            dtb_path: "",
            toolchain_prefix: ""
        )

    fn configured() -> bool:
        self.kernel_image != "" and self.rootfs_image != "" and self.dtb_path != "" and self.toolchain_prefix != ""

    fn firmware_configured() -> bool:
        self.opensbi_image != "" or self.uboot_image != ""

struct RiscvFpgaLane:
    xlen: RiscvXlen
    top_module: text
    rtl_dir: text
    rtl_sim_backend: text
    bootrom_path: text
    linux: LinuxArtifactSet

impl RiscvFpgaLane:
    static fn rv64_default() -> RiscvFpgaLane:
        RiscvFpgaLane(
            xlen: RiscvXlen.Rv64,
            top_module: "simple_rv64i_core",
            rtl_dir: "build/fpga/rv64/rtl",
            rtl_sim_backend: "ghdl-vhdl-2008",
            bootrom_path: "build/fpga/rv64/bootrom.bin",
            linux: LinuxArtifactSet.empty()
        )

    static fn rv32_default() -> RiscvFpgaLane:
        RiscvFpgaLane(
            xlen: RiscvXlen.Rv32,
            top_module: "simple_rv32i_core",
            rtl_dir: "build/fpga/rv32/rtl",
            rtl_sim_backend: "ghdl-vhdl-2008",
            bootrom_path: "build/fpga/rv32/bootrom.bin",
            linux: LinuxArtifactSet.empty()
        )

    fn expected_boot_markers() -> [text]:
        if self.xlen == RiscvXlen.Rv32:
            var markers: [text] = []
            markers.push("Linux version")
            markers.push("OF: fdt")
            markers.push("Freeing unused kernel memory")
            markers.push("init started")
            markers.push("rv32-linux-experimental")
            return markers
        var markers: [text] = []
        markers.push("OpenSBI")
        markers.push("Linux version")
        markers.push("OF: fdt")
        markers.push("Freeing unused kernel memory")
        markers.push("init started")
        markers

    fn required_soc_blocks() -> [text]:
        if self.xlen == RiscvXlen.Rv32:
            var blocks: [text] = []
            blocks.push("rv32ima-core")
            blocks.push("sv32-mmu")
            blocks.push("clint")
            blocks.push("plic")
            blocks.push("uart16550")
            blocks.push("bootrom")
            blocks.push("memory-bus")
            blocks.push("dtb")
            return blocks
        var blocks: [text] = []
        blocks.push("rv64ima-core")
        blocks.push("sv39-mmu")
        blocks.push("clint")
        blocks.push("plic")
        blocks.push("uart16550")
        blocks.push("bootrom")
        blocks.push("memory-bus")
        blocks.push("dtb")
        blocks.push("opensbi-handoff")
        blocks

    fn validate_for_prepare() -> [text]:
        var errors: [text] = []
        if self.top_module == "":
            errors.push("top_module is required")
        if self.rtl_dir == "":
            errors.push("rtl_dir is required")
        if self.rtl_sim_backend == "":
            errors.push("rtl_sim_backend is required")
        if self.bootrom_path == "":
            errors.push("bootrom_path is required")
        errors

    fn validate_for_linux_boot() -> [text]:
        var errors = self.validate_for_prepare()
        if self.readiness_status() != RiscvReadinessStatus.LinuxBootValidated:
            errors.push("{self.xlen.to_text()} readiness must be linux-boot-validated before claiming Linux boot")
        if not self.linux.configured():
            errors.push("{self.xlen.to_text()} linux kernel, rootfs, dtb, and toolchain must be configured")
        if self.xlen == RiscvXlen.Rv64 and not self.linux.firmware_configured():
            errors.push("rv64 linux requires OpenSBI or U-Boot firmware")
        if self.xlen == RiscvXlen.Rv32 and self.xlen.linux_policy() != "experimental":
            errors.push("rv32 linux must remain marked experimental")
        errors

    fn readiness_status() -> RiscvReadinessStatus:
        RiscvReadinessStatus.CoreGenerated

    fn hardware_source_file_name() -> text:
        "{self.top_module}.spl"

    fn instruction_bitfield_name() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "Rv32Instruction"
        "Rv64Instruction"

    fn base_integer_instruction_mnemonics() -> [text]:
        [
            "lui", "auipc", "jal", "jalr",
            "beq", "bne", "blt", "bge", "bltu", "bgeu",
            "lb", "lh", "lw", "lbu", "lhu", "sb", "sh", "sw",
            "addi", "slti", "sltiu", "xori", "ori", "andi", "slli", "srli", "srai",
            "add", "sub", "sll", "slt", "sltu", "xor", "srl", "sra", "or", "and",
            "fence", "ecall", "ebreak"
        ]

    fn package_name() -> text:
        "simple_{self.xlen.to_text()}i_core_pkg"

    fn reset_vector_hex() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "80000000"
        "0000000080000000"

    fn boot_stride_decimal() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "4"
        "4"

    fn hardware_source_spl() -> text:
        val bitfield_name = self.instruction_bitfield_name()
        "\"\"\"\n" +
            "# {self.top_module} Hardware Source Contract\n\n" +
            "Pure Simple source-of-truth sketch for the generated VHDL lane. The\n" +
            "current bundle writes this next to RTL so backend work can replace the\n" +
            "temporary emitter without inventing a RISC-V-specific bitfield language.\n" +
            "\"\"\"\n\n" +
            "bitfield {bitfield_name}(u32):\n" +
            "    opcode: 7\n" +
            "    rd: 5\n" +
            "    funct3: 3\n" +
            "    rs1: 5\n" +
            "    rs2: 5\n" +
            "    funct7: 7\n\n" +
            "bitfield RiscvBranchImmediate(u32):\n" +
            "    low: 4\n" +
            "    high: 6\n" +
            "    bit11: 1\n" +
            "    bit12: 1\n" +
            "    _: 20\n\n" +
            "bitfield RiscvBranchEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    bit11: 1\n" +
            "    low: 4\n" +
            "    funct3: 3\n" +
            "    rs1: 5\n" +
            "    rs2: 5\n" +
            "    high: 6\n" +
            "    bit12: 1\n\n" +
            "bitfield RiscvJumpImmediate(u32):\n" +
            "    low10: 10\n" +
            "    bit11: 1\n" +
            "    high8: 8\n" +
            "    bit20: 1\n" +
            "    _: 12\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_writeback(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    val funct3 = inst.funct3 as u32\n" +
            "    val funct7 = inst.funct7 as u32\n" +
            "    var writeback = {bitfield_name}.new(imem_rdata)\n" +
            "    if opcode == 19 as u32:\n" +
            "        writeback.rd = inst.rs1 as u32\n" +
            "        writeback\n" +
            "    elif opcode == 51 as u32 and funct3 == 0 as u32 and funct7 == 0 as u32:\n" +
            "        writeback.rd = inst.rs2 as u32\n" +
            "        writeback\n" +
            "    elif opcode == 99 as u32:\n" +
            "        val branch_inst = RiscvBranchEncoding.new(imem_rdata)\n" +
            "        var branch_imm = RiscvBranchImmediate.new(0 as u32)\n" +
            "        branch_imm.low = branch_inst.low as u32\n" +
            "        branch_imm.high = branch_inst.high as u32\n" +
            "        branch_imm.bit11 = branch_inst.bit11 as u32\n" +
            "        branch_imm.bit12 = branch_inst.bit12 as u32\n" +
            "        branch_imm\n" +
            "    else:\n" +
            "        imem_rdata\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}(clk: bool, reset_n: bool, imem_rdata: u32, dmem_rdata: u{self.xlen.bits()}) -> u{self.xlen.bits()}:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    val funct3 = inst.funct3 as u32\n" +
            "    val funct7 = inst.funct7 as u32\n" +
            "    val rd = inst.rd as u32\n" +
            "    # VHDL lowering owns these bitfield reads as slices:\n" +
            "    # inst.opcode -> imem_rdata(6 downto 0)\n" +
            "    # inst.rd -> imem_rdata(11 downto 7)\n" +
            "    # inst.funct3 -> imem_rdata(14 downto 12)\n" +
            "    # inst.rs1 -> imem_rdata(19 downto 15)\n" +
            "    # inst.rs2 -> imem_rdata(24 downto 20)\n" +
            "    # inst.funct7 -> imem_rdata(31 downto 25)\n" +
            "    # base integer instructions: {self.base_integer_instruction_mnemonics().join(\",\")}\n" +
            "    if opcode == 19 as u32:\n" +
            "        rd as u{self.xlen.bits()}\n" +
            "    elif opcode == 51 as u32 and funct3 == 0 as u32 and funct7 == 0 as u32:\n" +
            "        rd as u{self.xlen.bits()}\n" +
            "    else:\n" +
            "        imem_rdata as u{self.xlen.bits()}\n"

    fn hardware_source_contract_errors() -> [text]:
        val source = self.hardware_source_spl()
        var errors: [text] = []
        if not source.contains("bitfield {self.instruction_bitfield_name()}(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define instruction bitfield")
        if not source.contains("opcode: 7"):
            errors.push("{self.xlen.to_text()} hardware source must define seven-bit opcode")
        if not source.contains("@hardware"):
            errors.push("{self.xlen.to_text()} hardware source must preserve @hardware metadata")
        if not source.contains("@clocked"):
            errors.push("{self.xlen.to_text()} hardware source must preserve @clocked metadata")
        if not source.contains("fn {self.top_module}_decode_writeback"):
            errors.push("{self.xlen.to_text()} hardware source must define decode/writeback helper")
        if not source.contains("writeback.rd = inst.rs1 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must express I-type writeback field update")
        if not source.contains("writeback.rd = inst.rs2 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must express R-type writeback field update")
        if not source.contains("bitfield RiscvBranchImmediate(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define branch immediate bitfield")
        if not source.contains("bitfield RiscvBranchEncoding(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define branch immediate source-layout bitfield")
        if not source.contains("val opcode = inst.opcode as u32"):
            errors.push("{self.xlen.to_text()} hardware source must express opcode decode through bitfield reads")
        if not source.contains("val funct3 = inst.funct3 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must express funct3 decode through bitfield reads")
        if not source.contains("val funct7 = inst.funct7 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must express funct7 decode through bitfield reads")
        if not source.contains("opcode == 51 as u32 and funct3 == 0 as u32 and funct7 == 0 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must express R-type add decode guard")
        if not source.contains("elif opcode == 99 as u32:"):
            errors.push("{self.xlen.to_text()} hardware source must express branch immediate decode guard")
        if not source.contains("val branch_inst = RiscvBranchEncoding.new(imem_rdata)"):
            errors.push("{self.xlen.to_text()} hardware source must read branch immediate pieces through the branch layout bitfield")
        if not source.contains("var branch_imm = RiscvBranchImmediate.new(0 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must reconstruct branch immediate through bitfield writes")
        if not source.contains("branch_imm.low = branch_inst.low as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve branch immediate low bits")
        if not source.contains("branch_imm.high = branch_inst.high as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve branch immediate high bits")
        if not source.contains("branch_imm.bit11 = branch_inst.bit11 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve branch immediate bit11")
        if not source.contains("branch_imm.bit12 = branch_inst.bit12 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve the branch immediate sign bit")
        if not source.contains("base integer instructions:"):
            errors.push("{self.xlen.to_text()} hardware source must list RV base integer instructions")
        if source.contains("pass_todo") or source.contains("todo("):
            errors.push("{self.xlen.to_text()} hardware source must not contain stubs")
        if source.contains("async ") or source.contains("spawn ") or source.contains("rt_file_"):
            errors.push("{self.xlen.to_text()} hardware source uses unsupported hardware construct")
        errors

    fn source_map_header() -> text:
        "-- generated-from: {self.hardware_source_file_name()}\n" +
            "-- source-map: {self.instruction_bitfield_name()}.opcode => imem_rdata(6 downto 0)\n" +
            "-- source-map: {self.instruction_bitfield_name()}.rd => imem_rdata(11 downto 7)\n" +
            "-- source-map: {self.instruction_bitfield_name()}.rs1 => imem_rdata(19 downto 15)\n" +
            "-- source-map: {self.instruction_bitfield_name()}.rs2 => imem_rdata(24 downto 20)\n" +
            "-- readiness: {self.readiness_status().to_text()} linux-boot-validated=false\n\n"

    fn package_vhdl() -> text:
        val bits = self.xlen.bits()
        val package_name = self.package_name()
        self.source_map_header() +
            "library ieee;\n" +
            "use ieee.std_logic_1164.all;\n" +
            "use ieee.numeric_std.all;\n\n" +
            "package {package_name} is\n" +
            "    constant XLEN : natural := {bits};\n" +
            "    subtype xword_t is std_logic_vector(XLEN - 1 downto 0);\n" +
            "    constant RESET_VECTOR : xword_t := x\"{self.reset_vector_hex()}\";\n" +
            "    constant BOOT_STRIDE : natural := {self.boot_stride_decimal()};\n" +
            "end package {package_name};\n\n" +
            "package body {package_name} is\n" +
            "end package body {package_name};\n"

    fn core_vhdl() -> text:
        val package_name = self.package_name()
        val top = self.top_module
        self.source_map_header() +
            "library ieee;\n" +
            "use ieee.std_logic_1164.all;\n" +
            "use ieee.numeric_std.all;\n" +
            "use work.{package_name}.all;\n\n" +
            "entity {top} is\n" +
            "    port (\n" +
            "        clk           : in  std_logic;\n" +
            "        reset_n       : in  std_logic;\n" +
            "        imem_addr     : out xword_t;\n" +
            "        imem_rdata    : in  std_logic_vector(31 downto 0);\n" +
            "        dmem_addr     : out xword_t;\n" +
            "        dmem_wdata    : out xword_t;\n" +
            "        dmem_rdata    : in  xword_t;\n" +
            "        dmem_we       : out std_logic;\n" +
            "        debug_pc      : out xword_t;\n" +
            "        trap          : out std_logic;\n" +
            "        halt          : out std_logic\n" +
            "    );\n" +
            "end entity {top};\n\n" +
            "architecture rtl of {top} is\n" +
            "    type reg_file_t is array (0 to 31) of xword_t;\n" +
            "    signal pc_reg : xword_t := RESET_VECTOR;\n" +
            "    signal regs : reg_file_t := (others => (others => '0'));\n" +
            "    signal dmem_addr_reg : xword_t := (others => '0');\n" +
            "    signal dmem_wdata_reg : xword_t := (others => '0');\n" +
            "    signal dmem_we_reg : std_logic := '0';\n" +
            "    signal trap_reg : std_logic := '0';\n" +
            "    signal halt_reg : std_logic := '0';\n" +
            "begin\n" +
            "    imem_addr <= pc_reg;\n" +
            "    dmem_addr <= dmem_addr_reg;\n" +
            "    dmem_wdata <= dmem_wdata_reg;\n" +
            "    dmem_we <= dmem_we_reg;\n" +
            "    debug_pc <= pc_reg;\n" +
            "    trap <= trap_reg;\n" +
            "    halt <= halt_reg;\n\n" +
            "    process(clk, reset_n)\n" +
            "        variable rd_i : integer range 0 to 31;\n" +
            "        variable rs1_i : integer range 0 to 31;\n" +
            "        variable rs2_i : integer range 0 to 31;\n" +
            "        variable imm_i : signed(XLEN - 1 downto 0);\n" +
            "        variable addr_i : unsigned(XLEN - 1 downto 0);\n" +
            "        variable branch_i : signed(XLEN - 1 downto 0);\n" +
            "        variable jump_i : signed(XLEN - 1 downto 0);\n" +
            "        variable imm_u : xword_t;\n" +
            "        variable decode_writeback_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_writeback_rd_i : integer range 0 to 31;\n" +
            "        variable branch_taken : boolean;\n" +
            "        variable shift_i : natural range 0 to 63;\n" +
            "    begin\n" +
            "        if reset_n = '0' then\n" +
            "            pc_reg <= RESET_VECTOR;\n" +
            "            regs <= (others => (others => '0'));\n" +
            "            dmem_addr_reg <= (others => '0');\n" +
            "            dmem_wdata_reg <= (others => '0');\n" +
            "            dmem_we_reg <= '0';\n" +
            "            trap_reg <= '0';\n" +
            "            halt_reg <= '0';\n" +
            "        elsif rising_edge(clk) then\n" +
            "            dmem_we_reg <= '0';\n" +
            "            if halt_reg = '0' and trap_reg = '0' then\n" +
            "                rd_i := to_integer(unsigned(imem_rdata(11 downto 7)));\n" +
            "                rs1_i := to_integer(unsigned(imem_rdata(19 downto 15)));\n" +
            "                rs2_i := to_integer(unsigned(imem_rdata(24 downto 20)));\n" +
            "                decode_writeback_bits := imem_rdata;\n" +
            "                if imem_rdata(6 downto 0) = \"0010011\" then\n" +
            "                    decode_writeback_bits := imem_rdata(31 downto 12) & imem_rdata(19 downto 15) & imem_rdata(6 downto 0);\n" +
            "                elsif imem_rdata(6 downto 0) = \"0110011\" and imem_rdata(14 downto 12) = \"000\" and imem_rdata(31 downto 25) = \"0000000\" then\n" +
            "                    decode_writeback_bits := imem_rdata(31 downto 12) & imem_rdata(24 downto 20) & imem_rdata(6 downto 0);\n" +
            "                end if;\n" +
            "                decode_writeback_rd_i := to_integer(unsigned(decode_writeback_bits(11 downto 7)));\n" +
            "                imm_i := resize(signed(imem_rdata(31 downto 20)), XLEN);\n" +
            "                imm_u := std_logic_vector(resize(signed(imem_rdata(31 downto 12) & x\"000\"), XLEN));\n" +
            "                branch_i := resize(signed(imem_rdata(31) & imem_rdata(7) & imem_rdata(30 downto 25) & imem_rdata(11 downto 8) & '0'), XLEN);\n" +
            "                jump_i := resize(signed(imem_rdata(31) & imem_rdata(19 downto 12) & imem_rdata(20) & imem_rdata(30 downto 21) & '0'), XLEN);\n" +
            "                branch_taken := false;\n" +
            "                shift_i := to_integer(unsigned(regs(rs2_i)(5 downto 0)));\n" +
            "                case imem_rdata(6 downto 0) is\n" +
            "                    when \"0110111\" =>\n" +
            "                        if rd_i /= 0 then\n" +
            "                            regs(rd_i) <= imm_u;\n" +
            "                        end if;\n" +
            "                        pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                    when \"0010111\" =>\n" +
            "                        if rd_i /= 0 then\n" +
            "                            regs(rd_i) <= std_logic_vector(signed(pc_reg) + signed(imm_u));\n" +
            "                        end if;\n" +
            "                        pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                    when \"0010011\" =>\n" +
            "                        if decode_writeback_rd_i /= 0 then\n" +
            "                            case imem_rdata(14 downto 12) is\n" +
            "                                when \"000\" => regs(decode_writeback_rd_i) <= std_logic_vector(signed(regs(rs1_i)) + imm_i);\n" +
            "                                when \"010\" =>\n" +
            "                                    if signed(regs(rs1_i)) < imm_i then\n" +
            "                                        regs(decode_writeback_rd_i) <= std_logic_vector(to_unsigned(1, XLEN));\n" +
            "                                    else\n" +
            "                                        regs(decode_writeback_rd_i) <= (others => '0');\n" +
            "                                    end if;\n" +
            "                                when \"011\" =>\n" +
            "                                    if unsigned(regs(rs1_i)) < unsigned(std_logic_vector(imm_i)) then\n" +
            "                                        regs(decode_writeback_rd_i) <= std_logic_vector(to_unsigned(1, XLEN));\n" +
            "                                    else\n" +
            "                                        regs(decode_writeback_rd_i) <= (others => '0');\n" +
            "                                    end if;\n" +
            "                                when \"100\" => regs(decode_writeback_rd_i) <= regs(rs1_i) xor std_logic_vector(imm_i);\n" +
            "                                when \"110\" => regs(decode_writeback_rd_i) <= regs(rs1_i) or std_logic_vector(imm_i);\n" +
            "                                when \"111\" => regs(decode_writeback_rd_i) <= regs(rs1_i) and std_logic_vector(imm_i);\n" +
            "                                when \"001\" => regs(decode_writeback_rd_i) <= std_logic_vector(shift_left(unsigned(regs(rs1_i)), to_integer(unsigned(imem_rdata(25 downto 20)))));\n" +
            "                                when \"101\" =>\n" +
            "                                    if imem_rdata(30) = '1' then\n" +
            "                                        regs(decode_writeback_rd_i) <= std_logic_vector(shift_right(signed(regs(rs1_i)), to_integer(unsigned(imem_rdata(25 downto 20)))));\n" +
            "                                    else\n" +
            "                                        regs(decode_writeback_rd_i) <= std_logic_vector(shift_right(unsigned(regs(rs1_i)), to_integer(unsigned(imem_rdata(25 downto 20)))));\n" +
            "                                    end if;\n" +
            "                                when others => trap_reg <= '1';\n" +
            "                            end case;\n" +
            "                        end if;\n" +
            "                        pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                    when \"0110011\" =>\n" +
            "                        if decode_writeback_rd_i /= 0 then\n" +
            "                            case imem_rdata(14 downto 12) is\n" +
            "                                when \"000\" =>\n" +
            "                                    if imem_rdata(30) = '1' then\n" +
            "                                        regs(decode_writeback_rd_i) <= std_logic_vector(signed(regs(rs1_i)) - signed(regs(rs2_i)));\n" +
            "                                    else\n" +
            "                                        regs(decode_writeback_rd_i) <= std_logic_vector(signed(regs(rs1_i)) + signed(regs(rs2_i)));\n" +
            "                                    end if;\n" +
            "                                when \"001\" => regs(decode_writeback_rd_i) <= std_logic_vector(shift_left(unsigned(regs(rs1_i)), shift_i));\n" +
            "                                when \"010\" =>\n" +
            "                                    if signed(regs(rs1_i)) < signed(regs(rs2_i)) then\n" +
            "                                        regs(decode_writeback_rd_i) <= std_logic_vector(to_unsigned(1, XLEN));\n" +
            "                                    else\n" +
            "                                        regs(decode_writeback_rd_i) <= (others => '0');\n" +
            "                                    end if;\n" +
            "                                when \"011\" =>\n" +
            "                                    if unsigned(regs(rs1_i)) < unsigned(regs(rs2_i)) then\n" +
            "                                        regs(decode_writeback_rd_i) <= std_logic_vector(to_unsigned(1, XLEN));\n" +
            "                                    else\n" +
            "                                        regs(decode_writeback_rd_i) <= (others => '0');\n" +
            "                                    end if;\n" +
            "                                when \"100\" => regs(decode_writeback_rd_i) <= regs(rs1_i) xor regs(rs2_i);\n" +
            "                                when \"101\" =>\n" +
            "                                    if imem_rdata(30) = '1' then\n" +
            "                                        regs(decode_writeback_rd_i) <= std_logic_vector(shift_right(signed(regs(rs1_i)), shift_i));\n" +
            "                                    else\n" +
            "                                        regs(decode_writeback_rd_i) <= std_logic_vector(shift_right(unsigned(regs(rs1_i)), shift_i));\n" +
            "                                    end if;\n" +
            "                                when \"110\" => regs(decode_writeback_rd_i) <= regs(rs1_i) or regs(rs2_i);\n" +
            "                                when \"111\" => regs(decode_writeback_rd_i) <= regs(rs1_i) and regs(rs2_i);\n" +
            "                                when others => trap_reg <= '1';\n" +
            "                            end case;\n" +
            "                        end if;\n" +
            "                        pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                    when \"0000011\" =>\n" +
            "                        addr_i := unsigned(signed(regs(rs1_i)) + imm_i);\n" +
            "                        dmem_addr_reg <= std_logic_vector(addr_i);\n" +
            "                        if rd_i /= 0 then\n" +
            "                            regs(rd_i) <= dmem_rdata;\n" +
            "                        end if;\n" +
            "                        pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                    when \"0100011\" =>\n" +
            "                        imm_i := resize(signed(imem_rdata(31 downto 25) & imem_rdata(11 downto 7)), XLEN);\n" +
            "                        addr_i := unsigned(signed(regs(rs1_i)) + imm_i);\n" +
            "                        dmem_addr_reg <= std_logic_vector(addr_i);\n" +
            "                        dmem_wdata_reg <= regs(rs2_i);\n" +
            "                        dmem_we_reg <= '1';\n" +
            "                        pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                    when \"1100011\" =>\n" +
            "                        case imem_rdata(14 downto 12) is\n" +
            "                            when \"000\" => branch_taken := regs(rs1_i) = regs(rs2_i);\n" +
            "                            when \"001\" => branch_taken := regs(rs1_i) /= regs(rs2_i);\n" +
            "                            when \"100\" => branch_taken := signed(regs(rs1_i)) < signed(regs(rs2_i));\n" +
            "                            when \"101\" => branch_taken := signed(regs(rs1_i)) >= signed(regs(rs2_i));\n" +
            "                            when \"110\" => branch_taken := unsigned(regs(rs1_i)) < unsigned(regs(rs2_i));\n" +
            "                            when \"111\" => branch_taken := unsigned(regs(rs1_i)) >= unsigned(regs(rs2_i));\n" +
            "                            when others => trap_reg <= '1';\n" +
            "                        end case;\n" +
            "                        if branch_taken then\n" +
            "                            pc_reg <= std_logic_vector(unsigned(signed(pc_reg) + branch_i));\n" +
            "                        else\n" +
            "                            pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                        end if;\n" +
            "                    when \"1100111\" =>\n" +
            "                        if rd_i /= 0 then\n" +
            "                            regs(rd_i) <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                        end if;\n" +
            "                        addr_i := unsigned(signed(regs(rs1_i)) + imm_i);\n" +
            "                        addr_i(0) := '0';\n" +
            "                        pc_reg <= std_logic_vector(addr_i);\n" +
            "                    when \"1101111\" =>\n" +
            "                        if rd_i /= 0 then\n" +
            "                            regs(rd_i) <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                        end if;\n" +
            "                        pc_reg <= std_logic_vector(unsigned(signed(pc_reg) + jump_i));\n" +
            "                    when \"0001111\" =>\n" +
            "                        pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                    when \"1110011\" =>\n" +
            "                        halt_reg <= '1';\n" +
            "                    when others =>\n" +
            "                        trap_reg <= '1';\n" +
            "                end case;\n" +
            "                regs(0) <= (others => '0');\n" +
            "            end if;\n" +
            "        end if;\n" +
            "    end process;\n" +
            "end architecture rtl;\n"

struct FpgaPrepareManifest:
    board: XilinxBoardProfile
    lanes: [RiscvFpgaLane]
    vivado_project_dir: text
    generated_dir: text

impl FpgaPrepareManifest:
    static fn default_xilinx() -> FpgaPrepareManifest:
        FpgaPrepareManifest(
            board: XilinxBoardProfile.generic(),
            lanes: [RiscvFpgaLane.rv32_default(), RiscvFpgaLane.rv64_default()],
            vivado_project_dir: "build/fpga/xilinx_generic/vivado",
            generated_dir: "build/fpga/xilinx_generic/generated"
        )

    fn validate_for_prepare() -> [text]:
        var errors = self.board.validate_for_prepare()
        if self.vivado_project_dir == "":
            errors.push("vivado_project_dir is required")
        if self.generated_dir == "":
            errors.push("generated_dir is required")
        if self.lanes.len() == 0:
            errors.push("at least one RISC-V lane is required")
        for lane in self.lanes:
            val lane_errors = lane.validate_for_prepare()
            for err in lane_errors:
                errors.push("{lane.xlen.to_text()}: {err}")
            val source_errors = lane.hardware_source_contract_errors()
            for err in source_errors:
                errors.push(err)
        errors

    fn vivado_tcl_plan() -> text:
        var out = "create_project simple_riscv_fpga {self.vivado_project_dir} -part {self.board.part}\n"
        out = out + "set_property target_language VHDL [current_project]\n"
        out = out + "add_files {self.board.constraints_path}\n"
        for lane in self.lanes:
            out = out + "add_files {lane.rtl_dir}\n"
            out = out + "set_property top {lane.top_module} [current_fileset]\n"
        out = out + "synth_design\n"
        out

    fn readiness_summary() -> text:
        var out = "board={self.board.name} part={self.board.part} lanes={self.lanes.len()}"
        for lane in self.lanes:
            out = out + " {lane.xlen.to_text()}:{lane.readiness_status().to_text()}:{lane.top_module}"
        out

    fn rtl_manifest_text(root_dir: text) -> text:
        var out = "[riscv_fpga_rtl]\n"
        out = out + "board = \"{self.board.name}\"\n"
        out = out + "part = \"{self.board.part}\"\n"
        for lane in self.lanes:
            val lane_dir = "{root_dir}/{lane.xlen.to_text()}/rtl"
            out = out + "\n[[lane]]\n"
            out = out + "arch = \"{lane.xlen.to_text()}\"\n"
            out = out + "xlen = {lane.xlen.bits()}\n"
            out = out + "top = \"{lane.top_module}\"\n"
            out = out + "rtl_dir = \"{lane_dir}\"\n"
            out = out + "rtl_sim_backend = \"{lane.rtl_sim_backend}\"\n"
            out = out + "package = \"{lane.package_name()}\"\n"
            out = out + "source_file = \"{lane_dir}/{lane.hardware_source_file_name()}\"\n"
            out = out + "package_file = \"{lane_dir}/{lane.package_name()}.vhd\"\n"
            out = out + "core_file = \"{lane_dir}/{lane.top_module}.vhd\"\n"
            out = out + "readiness = \"{lane.readiness_status().to_text()}\"\n"
            out = out + "linux_policy = \"{lane.xlen.linux_policy()}\"\n"
            out = out + "mmu = \"{lane.xlen.mmu_mode()}\"\n"
        out

class RiscvFpgaRtlBundle:
    root_dir: text
    manifest_path: text
    generated_files: [text]

fn _write_text_file(path: text, content: text) -> Result<(), text>:
    if not rt_file_write_text(path, content):
        return Err("failed to write {path}")
    Ok(())

fn generate_riscv_fpga_rtl_bundle(root_dir: text, manifest: FpgaPrepareManifest) -> Result<RiscvFpgaRtlBundle, text>:
    val errors = manifest.validate_for_prepare()
    if errors.len() != 0:
        return Err(errors.join("; "))
    if not rt_dir_create(root_dir, true):
        return Err("failed to create rtl root dir: {root_dir}")

    var generated: [text] = []
    for lane in manifest.lanes:
        val lane_root = "{root_dir}/{lane.xlen.to_text()}"
        if not rt_dir_create(lane_root, true):
            return Err("failed to create rtl lane root dir: {lane_root}")
        val lane_dir = "{lane_root}/rtl"
        if not rt_dir_create(lane_dir, true):
            return Err("failed to create rtl lane dir: {lane_dir}")
        val package_path = "{lane_dir}/{lane.package_name()}.vhd"
        val core_path = "{lane_dir}/{lane.top_module}.vhd"
        val source_path = "{lane_dir}/{lane.hardware_source_file_name()}"
        _write_text_file(source_path, lane.hardware_source_spl())?
        _write_text_file(package_path, lane.package_vhdl())?
        _write_text_file(core_path, lane.core_vhdl())?
        generated.push(source_path)
        generated.push(package_path)
        generated.push(core_path)

    val manifest_path = "{root_dir}/riscv_fpga_rtl_manifest.sdn"
    _write_text_file(manifest_path, manifest.rtl_manifest_text(root_dir))?
    generated.push(manifest_path)
    Ok(RiscvFpgaRtlBundle(
        root_dir: root_dir,
        manifest_path: manifest_path,
        generated_files: generated
    ))

fn generate_default_riscv_fpga_rtl_bundle(root_dir: text) -> Result<RiscvFpgaRtlBundle, text>:
    generate_riscv_fpga_rtl_bundle(root_dir, FpgaPrepareManifest.default_xilinx())

fn read_generated_riscv_fpga_rtl_file(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn create_default_riscv_fpga_linux_manifest() -> FpgaPrepareManifest:
    FpgaPrepareManifest.default_xilinx()
