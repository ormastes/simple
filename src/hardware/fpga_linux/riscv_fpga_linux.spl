        if not source.contains("writeback.rd = inst.rs1 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must express I-type writeback field update")
        if not source.contains("writeback.rd = inst.rs2 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must express R-type writeback field update")
        if not source.contains("bitfield RiscvBranchImmediate(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define branch immediate bitfield")
        if not source.contains("bitfield RiscvBranchEncoding(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define branch immediate source-layout bitfield")
        if not source.contains("bitfield RiscvStoreImmediate(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define store immediate bitfield")
        if not source.contains("bitfield RiscvStoreEncoding(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define store immediate source-layout bitfield")
        if not source.contains("bitfield RiscvIImmediate(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define I-type immediate bitfield")
        if not source.contains("bitfield RiscvIImmediateEncoding(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define I-type immediate source-layout bitfield")
        if not source.contains("bitfield RiscvUpperImmediate(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define upper immediate bitfield")
        if not source.contains("bitfield RiscvUpperImmediateEncoding(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define upper immediate source-layout bitfield")
        if not source.contains("bitfield RiscvExecuteControl(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define execute control bitfield")
        if not source.contains("bitfield RiscvExecuteControlEncoding(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define execute control source-layout bitfield")
        if not source.contains("bitfield RiscvExecuteDatapath(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define execute datapath bitfield")
        if not source.contains("bitfield RiscvExecuteDatapathEncoding(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define execute datapath source-layout bitfield")
        if not source.contains("bitfield RiscvBranchDatapath(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define branch datapath bitfield")
        if not source.contains("bitfield RiscvBranchDatapathEncoding(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define branch datapath source-layout bitfield")
        if not source.contains("bitfield RiscvControlFlowDatapath(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define control flow datapath bitfield")
        if not source.contains("bitfield RiscvControlFlowDatapathEncoding(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define control flow datapath source-layout bitfield")
        if not source.contains("bitfield RiscvMemoryAccessControl(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define memory access control bitfield")
        if not source.contains("bitfield RiscvMemoryAccessControlEncoding(u32):"):
