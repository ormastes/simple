            errors.push("{self.xlen.to_text()} hardware source must define jump immediate bitfield")
        if not source.contains("bitfield RiscvJumpEncoding(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define jump immediate source-layout bitfield")
        if not source.contains("bitfield RiscvDispatchClass(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define dispatch-class bitfield")
        if not source.contains("bitfield RiscvDispatchClassEncoding(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define dispatch-class source-layout bitfield")
        if not source.contains("bitfield RiscvTrapHaltControl(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define trap/halt bitfield")
        if not source.contains("bitfield RiscvTrapHaltControlEncoding(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define trap/halt source-layout bitfield")
        if not source.contains("val opcode = inst.opcode as u32"):
            errors.push("{self.xlen.to_text()} hardware source must express opcode decode through bitfield reads")
        if not source.contains("val funct3 = inst.funct3 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must express funct3 decode through bitfield reads")
        if not source.contains("val funct7 = inst.funct7 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must express funct7 decode through bitfield reads")
        if not source.contains("if opcode == 19 as u32:"):
            errors.push("{self.xlen.to_text()} hardware source must express I-type decode guard")
        if not source.contains("opcode == 51 as u32 and funct3 == 0 as u32 and funct7 == 0 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must express R-type add decode guard")
        if not source.contains("if opcode == 99 as u32:"):
            errors.push("{self.xlen.to_text()} hardware source must express branch immediate decode guard")
        if not source.contains("if opcode == 35 as u32:"):
            errors.push("{self.xlen.to_text()} hardware source must express store immediate decode guard")
        if not source.contains("if opcode == 111 as u32:"):
            errors.push("{self.xlen.to_text()} hardware source must express jump immediate decode guard")
        if not source.contains("val branch_inst = RiscvBranchEncoding.new(imem_rdata)"):
            errors.push("{self.xlen.to_text()} hardware source must read branch immediate pieces through the branch layout bitfield")
        if not source.contains("var branch_imm = RiscvBranchImmediate.new(0 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must reconstruct branch immediate through bitfield writes")
        if not source.contains("branch_imm.low = branch_inst.low as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve branch immediate low bits")
        if not source.contains("branch_imm.high = branch_inst.high as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve branch immediate high bits")
        if not source.contains("branch_imm.bit11 = branch_inst.bit11 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve branch immediate bit11")
        if not source.contains("branch_imm.bit12 = branch_inst.bit12 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve the branch immediate sign bit")
        if not source.contains("val store_inst = RiscvStoreEncoding.new(imem_rdata)"):
            errors.push("{self.xlen.to_text()} hardware source must read store immediate pieces through the store layout bitfield")
        if not source.contains("var store_imm = RiscvStoreImmediate.new(0 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must reconstruct store immediate through bitfield writes")
        if not source.contains("store_imm.low = store_inst.low as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve store immediate low bits")
        if not source.contains("store_imm.high = store_inst.high as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve store immediate high bits")
        if not source.contains("val imm_inst = RiscvIImmediateEncoding.new(imem_rdata)"):
            errors.push("{self.xlen.to_text()} hardware source must read I-type immediate through the I-immediate layout bitfield")
        if not source.contains("var imm = RiscvIImmediate.new(0 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must reconstruct I-type immediate through bitfield writes")
        if not source.contains("imm.value = imm_inst.value as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve the I-type immediate payload bits")
        if not source.contains("val upper_inst = RiscvUpperImmediateEncoding.new(imem_rdata)"):
            errors.push("{self.xlen.to_text()} hardware source must read upper immediate through the upper-immediate layout bitfield")
        if not source.contains("var upper_imm = RiscvUpperImmediate.new(0 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must reconstruct upper immediate through bitfield writes")
        if not source.contains("upper_imm.high20 = upper_inst.high20 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve the upper immediate high bits")
        if not source.contains("val control_inst = RiscvExecuteControlEncoding.new(imem_rdata)"):
            errors.push("{self.xlen.to_text()} hardware source must read execute control through the execute-control layout bitfield")
        if not source.contains("var control = RiscvExecuteControl.new(0 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must reconstruct execute control through bitfield writes")
        if not source.contains("control.funct3 = control_inst.funct3 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve execute control funct3 bits")
        if not source.contains("control.bit30 = control_inst.bit30 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve execute control bit30")
        if not source.contains("control.shamt6 = ((control_inst.shamt_bit5 as u32) << 5) | (control_inst.shamt_low5 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must preserve execute control shift amount bits")
        if not source.contains("val datapath_inst = RiscvExecuteDatapathEncoding.new(imem_rdata)"):
            errors.push("{self.xlen.to_text()} hardware source must read execute datapath through the datapath layout bitfield")
        if not source.contains("var datapath = RiscvExecuteDatapath.new(0 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must reconstruct execute datapath through bitfield writes")
        if not source.contains("val opcode = datapath_inst.opcode as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve execute datapath opcode")
        if not source.contains("val funct3 = datapath_inst.funct3 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve execute datapath funct3")
        if not source.contains("val bit30 = datapath_inst.bit30 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve execute datapath bit30")
        if not source.contains("datapath.operation_kind = 0 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must encode the ALU immediate execute datapath kind")
        if not source.contains("datapath.operation_kind = 1 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must encode the ALU register execute datapath kind")
        if not source.contains("if opcode == 19 as u32:"):
            errors.push("{self.xlen.to_text()} hardware source must guard I-type execute datapath decode by opcode")
        if not source.contains("elif opcode == 51 as u32:"):
            errors.push("{self.xlen.to_text()} hardware source must guard R-type execute datapath decode by opcode")
        if not source.contains("elif funct3 == 5 as u32 and bit30 == 0 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must guard logical right shift execute datapath decode")
        if not source.contains("elif funct3 == 5 as u32 and bit30 == 1 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must guard arithmetic right shift execute datapath decode")
        if not source.contains("datapath.alu_op = 9 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must encode the execute datapath ALU operation set")
        if not source.contains("variable decode_execute_datapath_bits : std_logic_vector(31 downto 0);"):
            errors.push("{self.xlen.to_text()} hardware source must expose execute datapath helper bits in the VHDL shell")
        if not source.contains("decode_execute_alu_op := decode_execute_datapath_bits(4 downto 1);"):
            errors.push("{self.xlen.to_text()} hardware source must derive the ALU op from execute datapath helper bits")
        if not source.contains("decode_execute_is_reg := decode_execute_datapath_bits(0);"):
            errors.push("{self.xlen.to_text()} hardware source must derive the ALU input kind from execute datapath helper bits")
        if not source.contains("val datapath_inst = RiscvBranchDatapathEncoding.new(imem_rdata)"):
            errors.push("{self.xlen.to_text()} hardware source must read branch datapath through the branch datapath layout bitfield")
        if not source.contains("var datapath = RiscvBranchDatapath.new(0 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must reconstruct branch datapath through bitfield writes")
        if not source.contains("val opcode = datapath_inst.opcode as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve branch datapath opcode")
        if not source.contains("val funct3 = datapath_inst.funct3 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve branch datapath funct3")
        if not source.contains("datapath.branch_op = 5 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must encode the branch datapath compare operation set")
        if not source.contains("variable decode_branch_datapath_bits : std_logic_vector(31 downto 0);"):
            errors.push("{self.xlen.to_text()} hardware source must expose branch datapath helper bits in the VHDL shell")
        if not source.contains("decode_branch_op := decode_branch_datapath_bits(2 downto 0);"):
            errors.push("{self.xlen.to_text()} hardware source must derive branch compare selection from branch datapath helper bits")
        if not source.contains("val datapath_inst = RiscvControlFlowDatapathEncoding.new(imem_rdata)"):
            errors.push("{self.xlen.to_text()} hardware source must read control flow datapath through the control-flow layout bitfield")
        if not source.contains("var datapath = RiscvControlFlowDatapath.new(0 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must reconstruct control flow datapath through bitfield writes")
        if not source.contains("datapath.next_pc_op = 3 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must encode the control flow next-pc operation set")
        if not source.contains("datapath.writes_link = 1 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must encode link-register write intent for control flow")
        if not source.contains("variable decode_control_flow_datapath_bits : std_logic_vector(31 downto 0);"):
            errors.push("{self.xlen.to_text()} hardware source must expose control flow datapath helper bits in the VHDL shell")
        if not source.contains("decode_next_pc_op := decode_control_flow_datapath_bits(1 downto 0);"):
            errors.push("{self.xlen.to_text()} hardware source must derive next-pc selection from control flow datapath helper bits")
        if not source.contains("decode_writes_link := decode_control_flow_datapath_bits(2);"):
            errors.push("{self.xlen.to_text()} hardware source must derive link-register intent from control flow datapath helper bits")
        if source.contains("case decode_funct3 is"):
            errors.push("{self.xlen.to_text()} hardware source must not keep handwritten funct3 selection at the execute or branch use sites")
        if not source.contains("val access_inst = RiscvMemoryAccessControlEncoding.new(imem_rdata)"):
            errors.push("{self.xlen.to_text()} hardware source must read memory access control through the memory-access layout bitfield")
        if not source.contains("var access = RiscvMemoryAccessControl.new(0 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must reconstruct memory access control through bitfield writes")
        if not source.contains("access.funct3 = access_inst.funct3 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve memory access control funct3 bits")
        if not source.contains("if decode_memory_funct3 = \"001\" or decode_memory_funct3 = \"101\" then"):
            errors.push("{self.xlen.to_text()} hardware source must guard halfword memory accesses through helper-derived funct3")
        if not source.contains("if addr_i(1 downto 0) /= \"00\" then"):
            errors.push("{self.xlen.to_text()} hardware source must guard word-aligned memory accesses")
        if not source.contains("if addr_i(2 downto 0) /= \"000\" then"):
            errors.push("{self.xlen.to_text()} hardware source must guard doubleword-aligned memory accesses")
        if not source.contains("dmem_re       : out std_logic;"):
            errors.push("{self.xlen.to_text()} hardware source must expose a dmem read-enable output")
        if not source.contains("dmem_width    : out std_logic_vector(1 downto 0);"):
            errors.push("{self.xlen.to_text()} hardware source must expose a dmem width output")
        if not source.contains("dmem_wstrb    : out std_logic_vector((XLEN / 8) - 1 downto 0);"):
            errors.push("{self.xlen.to_text()} hardware source must expose a dmem write-strobe output")
        if not source.contains("dmem_re_reg <= '1';"):
            errors.push("{self.xlen.to_text()} hardware source must drive dmem read-enable for loads")
        if not source.contains("dmem_width_reg <= \"00\";") or not source.contains("dmem_width_reg <= \"01\";") or not source.contains("dmem_width_reg <= \"10\";") or not source.contains("dmem_width_reg <= \"11\";"):
            errors.push("{self.xlen.to_text()} hardware source must drive byte/halfword/word/doubleword width codes")
        if not source.contains("shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(2 downto 0))) * 8)") and not source.contains("shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(1 downto 0))) * 8)"):
            errors.push("{self.xlen.to_text()} hardware source must extract load lanes through address-derived bus shifts")
        if not source.contains("dmem_wstrb_reg <= (others => '0');"):
            errors.push("{self.xlen.to_text()} hardware source must clear write strobes when idle")
        if not source.contains("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(1, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0))))))") and not source.contains("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(1, XLEN / 8), to_integer(unsigned(addr_i(1 downto 0))))))"):
            errors.push("{self.xlen.to_text()} hardware source must drive byte store strobes from address lane bits")
        if not source.contains("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(3, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0))))))") and not source.contains("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(3, XLEN / 8), to_integer(unsigned(addr_i(1 downto 0))))))"):
            errors.push("{self.xlen.to_text()} hardware source must drive halfword store strobes from address lane bits")
        if not source.contains("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(15, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0))))))") or not source.contains("dmem_wstrb_reg <= std_logic_vector(to_unsigned(15, XLEN / 8));") or not source.contains("dmem_wstrb_reg <= (others => '1');"):
            errors.push("{self.xlen.to_text()} hardware source must drive word and doubleword store strobes for supported widths")
        if not source.contains("val jump_inst = RiscvJumpEncoding.new(imem_rdata)"):
            errors.push("{self.xlen.to_text()} hardware source must read jump immediate pieces through the jump layout bitfield")
        if not source.contains("var jump_imm = RiscvJumpImmediate.new(0 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must reconstruct jump immediate through bitfield writes")
        if not source.contains("jump_imm.low10 = jump_inst.low10 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve jump immediate low bits")
        if not source.contains("jump_imm.bit11 = jump_inst.bit11 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve jump immediate bit11")
        if not source.contains("jump_imm.high8 = jump_inst.high8 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve jump immediate middle bits")
        if not source.contains("jump_imm.bit20 = jump_inst.bit20 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve the jump immediate sign bit")
        if not source.contains("base integer instructions:"):
            errors.push("{self.xlen.to_text()} hardware source must list RV base integer instructions")
        if source.contains("pass_todo") or source.contains("todo("):
            errors.push("{self.xlen.to_text()} hardware source must not contain stubs")
        if source.contains("async ") or source.contains("spawn ") or source.contains("rt_file_"):
            errors.push("{self.xlen.to_text()} hardware source uses unsupported hardware construct")
        errors

    fn source_map_header() -> text:
        "-- generated-from: {self.hardware_source_file_name()}\n" +
            "-- source-map: {self.instruction_bitfield_name()}.opcode => imem_rdata(6 downto 0)\n" +
            "-- source-map: {self.instruction_bitfield_name()}.rd => imem_rdata(11 downto 7)\n" +
            "-- source-map: {self.instruction_bitfield_name()}.funct3 => imem_rdata(14 downto 12)\n" +
            "-- source-map: {self.instruction_bitfield_name()}.rs1 => imem_rdata(19 downto 15)\n" +
            "-- source-map: {self.instruction_bitfield_name()}.rs2 => imem_rdata(24 downto 20)\n" +
            "-- source-map: {self.instruction_bitfield_name()}.funct7 => imem_rdata(31 downto 25)\n" +
            "-- source-map: RiscvBranchEncoding.bit11 => imem_rdata(7 downto 7)\n" +
            "-- source-map: RiscvBranchEncoding.low => imem_rdata(11 downto 8)\n" +
            "-- source-map: RiscvBranchEncoding.high => imem_rdata(30 downto 25)\n" +
            "-- source-map: RiscvBranchEncoding.bit12 => imem_rdata(31 downto 31)\n" +
            "-- source-map: RiscvStoreEncoding.low => imem_rdata(11 downto 7)\n" +
            "-- source-map: RiscvStoreEncoding.high => imem_rdata(31 downto 25)\n" +
            "-- source-map: RiscvIImmediateEncoding.value => imem_rdata(31 downto 20)\n" +
            "-- source-map: RiscvUpperImmediateEncoding.high20 => imem_rdata(31 downto 12)\n" +
            "-- source-map: RiscvExecuteControlEncoding.funct3 => imem_rdata(14 downto 12)\n" +
            "-- source-map: RiscvExecuteControlEncoding.shamt_low5 => imem_rdata(24 downto 20)\n" +
            "-- source-map: RiscvExecuteControlEncoding.shamt_bit5 => imem_rdata(25 downto 25)\n" +
            "-- source-map: RiscvExecuteControlEncoding.bit30 => imem_rdata(30 downto 30)\n" +
            "-- source-map: RiscvExecuteDatapathEncoding.opcode => imem_rdata(6 downto 0)\n" +
            "-- source-map: RiscvExecuteDatapathEncoding.funct3 => imem_rdata(14 downto 12)\n" +
            "-- source-map: RiscvExecuteDatapathEncoding.bit30 => imem_rdata(30 downto 30)\n" +
            "-- source-map: RiscvBranchDatapathEncoding.opcode => imem_rdata(6 downto 0)\n" +
            "-- source-map: RiscvBranchDatapathEncoding.funct3 => imem_rdata(14 downto 12)\n" +
            "-- source-map: RiscvControlFlowDatapathEncoding.opcode => imem_rdata(6 downto 0)\n" +
            "-- source-map: RiscvMemoryAccessControlEncoding.funct3 => imem_rdata(14 downto 12)\n" +
            "-- source-map: RiscvJumpEncoding.high8 => imem_rdata(19 downto 12)\n" +
            "-- source-map: RiscvJumpEncoding.bit11 => imem_rdata(20 downto 20)\n" +
            "-- source-map: RiscvJumpEncoding.low10 => imem_rdata(30 downto 21)\n" +
            "-- source-map: RiscvJumpEncoding.bit20 => imem_rdata(31 downto 31)\n" +
            "-- source-map: RiscvDispatchClassEncoding.opcode => imem_rdata(6 downto 0)\n" +
            "-- source-map: RiscvTrapHaltControlEncoding.opcode => imem_rdata(6 downto 0)\n" +
            "-- readiness: {self.readiness_status().to_text()} linux-boot-validated={self.readiness_is_boot_validated()}\n\n"

    fn package_vhdl() -> text:
        val bits = self.xlen.bits()
        val package_name = self.package_name()
        self.source_map_header() +
            "library ieee;\n" +
            "use ieee.std_logic_1164.all;\n" +
            "use ieee.numeric_std.all;\n\n" +
            "package {package_name} is\n" +
            "    constant XLEN : natural := {bits};\n" +
            "    subtype xword_t is std_logic_vector(XLEN - 1 downto 0);\n" +
            "    constant RESET_VECTOR : xword_t := x\"{self.reset_vector_hex()}\";\n" +
            "    constant BOOT_STRIDE : natural := {self.boot_stride_decimal()};\n" +
            "end package {package_name};\n\n" +
            "package body {package_name} is\n" +
            "end package body {package_name};\n"

    fn core_vhdl_process_variables() -> text:
        "        variable rd_i : integer range 0 to 31;\n" +
            "        variable rs1_i : integer range 0 to 31;\n" +
            "        variable rs2_i : integer range 0 to 31;\n" +
            "        variable imm_i : signed(XLEN - 1 downto 0);\n" +
            "        variable addr_i : unsigned(XLEN - 1 downto 0);\n" +
            "        variable branch_i : signed(XLEN - 1 downto 0);\n" +
            "        variable jump_i : signed(XLEN - 1 downto 0);\n" +
            "        variable imm_u : xword_t;\n" +
            "        variable decode_writeback_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_branch_immediate_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_store_immediate_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_i_immediate_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_upper_immediate_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_execute_control_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_execute_datapath_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_branch_datapath_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_control_flow_datapath_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_memory_access_control_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_jump_immediate_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_dispatch_class_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_trap_halt_control_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_writeback_rd_i : integer range 0 to 31;\n" +
            "        variable branch_taken : boolean;\n" +
            "        variable shift_i : natural range 0 to 63;\n" +
            "        variable decode_execute_alu_op : std_logic_vector(3 downto 0);\n" +
            "        variable decode_execute_is_reg : std_logic;\n" +
            "        variable decode_branch_op : std_logic_vector(2 downto 0);\n" +
            "        variable decode_next_pc_op : std_logic_vector(1 downto 0);\n" +
            "        variable decode_writes_link : std_logic;\n" +
            "        variable decode_memory_funct3 : std_logic_vector(2 downto 0);\n" +
            "        variable decode_dispatch_class : std_logic_vector(3 downto 0);\n" +
            "        variable decode_continue_exec : std_logic;\n" +
            "        variable decode_should_trap : std_logic;\n" +
            "        variable decode_should_halt : std_logic;\n"

    fn core_vhdl_decode_staging_region() -> text:
        "                decode_writeback_bits := imem_rdata;\n" +
            "                decode_branch_immediate_bits := (others => '0');\n" +
            "                decode_store_immediate_bits := (others => '0');\n" +
            "                decode_i_immediate_bits := (others => '0');\n" +
            "                decode_upper_immediate_bits := (others => '0');\n" +
            "                decode_execute_control_bits := (others => '0');\n" +
            "                decode_execute_datapath_bits := (others => '0');\n" +
            "                decode_branch_datapath_bits := (others => '0');\n" +
            "                decode_control_flow_datapath_bits := (others => '0');\n" +
            "                decode_memory_access_control_bits := (others => '0');\n" +
            "                decode_jump_immediate_bits := (others => '0');\n" +
            "                decode_dispatch_class_bits := (others => '0');\n" +
            "                decode_trap_halt_control_bits := (others => '0');\n" +
            "                if imem_rdata(6 downto 0) = \"0110111\" then\n" +
            "                    decode_dispatch_class_bits := \"0000000000000000000000000000\" & \"0001\";\n" +
            "                    decode_trap_halt_control_bits := \"00000000000000000000000000000\" & '0' & '0' & '1';\n" +
            "                elsif imem_rdata(6 downto 0) = \"0010111\" then\n" +
            "                    decode_dispatch_class_bits := \"0000000000000000000000000000\" & \"0010\";\n" +
            "                    decode_trap_halt_control_bits := \"00000000000000000000000000000\" & '0' & '0' & '1';\n" +
            "                elsif imem_rdata(6 downto 0) = \"0010011\" then\n" +
            "                    decode_dispatch_class_bits := \"0000000000000000000000000000\" & \"0011\";\n" +
            "                    decode_trap_halt_control_bits := \"00000000000000000000000000000\" & '0' & '0' & '1';\n" +
            "                elsif imem_rdata(6 downto 0) = \"0110011\" then\n" +
            "                    decode_dispatch_class_bits := \"0000000000000000000000000000\" & \"0100\";\n" +
            "                    decode_trap_halt_control_bits := \"00000000000000000000000000000\" & '0' & '0' & '1';\n" +
            "                elsif imem_rdata(6 downto 0) = \"0000011\" then\n" +
            "                    decode_dispatch_class_bits := \"0000000000000000000000000000\" & \"0101\";\n" +
            "                    decode_trap_halt_control_bits := \"00000000000000000000000000000\" & '0' & '0' & '1';\n" +
            "                elsif imem_rdata(6 downto 0) = \"0100011\" then\n" +
            "                    decode_dispatch_class_bits := \"0000000000000000000000000000\" & \"0110\";\n" +
            "                    decode_trap_halt_control_bits := \"00000000000000000000000000000\" & '0' & '0' & '1';\n" +
            "                elsif imem_rdata(6 downto 0) = \"1100011\" then\n" +
            "                    decode_dispatch_class_bits := \"0000000000000000000000000000\" & \"0111\";\n" +
            "                    decode_trap_halt_control_bits := \"00000000000000000000000000000\" & '0' & '0' & '1';\n" +
            "                elsif imem_rdata(6 downto 0) = \"1100111\" then\n" +
            "                    decode_dispatch_class_bits := \"0000000000000000000000000000\" & \"1000\";\n" +
            "                    decode_trap_halt_control_bits := \"00000000000000000000000000000\" & '0' & '0' & '1';\n" +
            "                elsif imem_rdata(6 downto 0) = \"1101111\" then\n" +
            "                    decode_dispatch_class_bits := \"0000000000000000000000000000\" & \"1001\";\n" +
            "                    decode_trap_halt_control_bits := \"00000000000000000000000000000\" & '0' & '0' & '1';\n" +
            "                elsif imem_rdata(6 downto 0) = \"0001111\" then\n" +
            "                    decode_dispatch_class_bits := \"0000000000000000000000000000\" & \"1010\";\n" +
            "                    decode_trap_halt_control_bits := \"00000000000000000000000000000\" & '0' & '0' & '1';\n" +
            "                elsif imem_rdata(6 downto 0) = \"1110011\" then\n" +
            "                    decode_dispatch_class_bits := \"0000000000000000000000000000\" & \"1011\";\n" +
            "                    decode_trap_halt_control_bits := \"00000000000000000000000000000\" & '1' & '0' & '0';\n" +
            "                else\n" +
            "                    decode_trap_halt_control_bits := \"00000000000000000000000000000\" & '0' & '1' & '0';\n" +
            "                end if;\n" +
            "                case decode_dispatch_class_bits(3 downto 0) is\n" +
            "                    when \"0001\" | \"0010\" =>\n" +
            "                        decode_upper_immediate_bits := imem_rdata(31 downto 12) & \"000000000000\";\n" +
            "                    when \"0011\" =>\n" +
            "                        decode_writeback_bits := imem_rdata(31 downto 12) & imem_rdata(19 downto 15) & imem_rdata(6 downto 0);\n" +
            "                        decode_i_immediate_bits := \"00000000000000000000\" & imem_rdata(31 downto 20);\n" +
            "                        decode_execute_control_bits := \"0000000000000000000000\" & imem_rdata(25 downto 25) & imem_rdata(30 downto 30) & imem_rdata(14 downto 12);\n" +
            "                        if imem_rdata(14 downto 12) = \"000\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0000\" & '0';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"001\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0010\" & '0';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"010\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0011\" & '0';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"011\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0100\" & '0';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"100\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0101\" & '0';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"101\" and imem_rdata(30 downto 30) = \"0\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0110\" & '0';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"101\" and imem_rdata(30 downto 30) = \"1\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0111\" & '0';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"110\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"1000\" & '0';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"111\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"1001\" & '0';\n" +
            "                        end if;\n" +
            "                    when \"0100\" =>\n" +
            "                        decode_execute_control_bits := \"0000000000000000000000\" & imem_rdata(25 downto 25) & imem_rdata(30 downto 30) & imem_rdata(14 downto 12);\n" +
            "                        if imem_rdata(14 downto 12) = \"000\" and imem_rdata(31 downto 25) = \"0000000\" then\n" +
            "                            decode_writeback_bits := imem_rdata(31 downto 12) & imem_rdata(24 downto 20) & imem_rdata(6 downto 0);\n" +
            "                        end if;\n" +
            "                        if imem_rdata(14 downto 12) = \"000\" and imem_rdata(30 downto 30) = \"0\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0000\" & '1';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"000\" and imem_rdata(30 downto 30) = \"1\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0001\" & '1';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"001\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0010\" & '1';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"010\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0011\" & '1';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"011\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0100\" & '1';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"100\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0101\" & '1';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"101\" and imem_rdata(30 downto 30) = \"0\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0110\" & '1';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"101\" and imem_rdata(30 downto 30) = \"1\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"0111\" & '1';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"110\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"1000\" & '1';\n" +
            "                        elsif imem_rdata(14 downto 12) = \"111\" then\n" +
            "                            decode_execute_datapath_bits := \"00000000000000000000000000000\" & \"1001\" & '1';\n" +
            "                        end if;\n" +
            "                    when \"0101\" =>\n" +
            "                        decode_i_immediate_bits := \"00000000000000000000\" & imem_rdata(31 downto 20);\n" +
            "                        decode_memory_access_control_bits := \"00000000000000000000000000000\" & imem_rdata(14 downto 12);\n" +
            "                    when \"0110\" =>\n" +
            "                        decode_store_immediate_bits := \"00000000000000000000\" & imem_rdata(31 downto 25) & imem_rdata(11 downto 7);\n" +
            "                        decode_memory_access_control_bits := \"00000000000000000000000000000\" & imem_rdata(14 downto 12);\n" +
            "                    when \"0111\" =>\n" +
            "                        decode_branch_immediate_bits := \"00000000000000000000\" & imem_rdata(31 downto 31) & imem_rdata(7 downto 7) & imem_rdata(30 downto 25) & imem_rdata(11 downto 8);\n" +
            "                        decode_execute_control_bits := \"0000000000000000000000\" & imem_rdata(25 downto 25) & imem_rdata(30 downto 30) & imem_rdata(14 downto 12);\n" +
            "                        if imem_rdata(14 downto 12) = \"000\" then\n" +
            "                            decode_branch_datapath_bits := \"00000000000000000000000000000\" & \"000\";\n" +
            "                        elsif imem_rdata(14 downto 12) = \"001\" then\n" +
            "                            decode_branch_datapath_bits := \"00000000000000000000000000000\" & \"001\";\n" +
            "                        elsif imem_rdata(14 downto 12) = \"100\" then\n" +
            "                            decode_branch_datapath_bits := \"00000000000000000000000000000\" & \"010\";\n" +
            "                        elsif imem_rdata(14 downto 12) = \"101\" then\n" +
            "                            decode_branch_datapath_bits := \"00000000000000000000000000000\" & \"011\";\n" +
            "                        elsif imem_rdata(14 downto 12) = \"110\" then\n" +
            "                            decode_branch_datapath_bits := \"00000000000000000000000000000\" & \"100\";\n" +
            "                        elsif imem_rdata(14 downto 12) = \"111\" then\n" +
            "                            decode_branch_datapath_bits := \"00000000000000000000000000000\" & \"101\";\n" +
            "                        end if;\n" +
            "                        decode_control_flow_datapath_bits := \"00000000000000000000000000000\" & '0' & \"01\";\n" +
            "                    when \"1000\" =>\n" +
            "                        decode_control_flow_datapath_bits := \"00000000000000000000000000000\" & '1' & \"10\";\n" +
            "                    when \"1001\" =>\n" +
            "                        decode_jump_immediate_bits := \"000000000000\" & imem_rdata(31 downto 31) & imem_rdata(19 downto 12) & imem_rdata(20 downto 20) & imem_rdata(30 downto 21);\n" +
            "                        decode_control_flow_datapath_bits := \"00000000000000000000000000000\" & '1' & \"11\";\n" +
            "                    when others => null;\n" +
            "                end case;\n" +
            "                decode_writeback_rd_i := to_integer(unsigned(decode_writeback_bits(11 downto 7)));\n" +
            "                imm_i := resize(signed(decode_i_immediate_bits(11 downto 0)), XLEN);\n" +
            "                imm_u := std_logic_vector(resize(signed(decode_upper_immediate_bits(31 downto 12) & \"000000000000\"), XLEN));\n" +
            "                branch_i := resize(signed(decode_branch_immediate_bits(11) & decode_branch_immediate_bits(10) & decode_branch_immediate_bits(9 downto 4) & decode_branch_immediate_bits(3 downto 0) & '0'), XLEN);\n" +
            "                jump_i := resize(signed(decode_jump_immediate_bits(19) & decode_jump_immediate_bits(18 downto 11) & decode_jump_immediate_bits(10) & decode_jump_immediate_bits(9 downto 0) & '0'), XLEN);\n" +
            "                branch_taken := false;\n" +
            "                shift_i := to_integer(unsigned(regs(rs2_i)(5 downto 0)));\n" +
            "                decode_execute_alu_op := decode_execute_datapath_bits(4 downto 1);\n" +
            "                decode_execute_is_reg := decode_execute_datapath_bits(0);\n" +
            "                decode_branch_op := decode_branch_datapath_bits(2 downto 0);\n" +
            "                decode_next_pc_op := decode_control_flow_datapath_bits(1 downto 0);\n" +
            "                decode_writes_link := decode_control_flow_datapath_bits(2);\n" +
            "                decode_memory_funct3 := decode_memory_access_control_bits(2 downto 0);\n" +
            "                decode_dispatch_class := decode_dispatch_class_bits(3 downto 0);\n" +
            "                decode_continue_exec := decode_trap_halt_control_bits(0);\n" +
            "                decode_should_trap := decode_trap_halt_control_bits(1);\n" +
            "                decode_should_halt := decode_trap_halt_control_bits(2);\n"

    fn core_vhdl_execute_load_store_region() -> text:
        "                        case decode_dispatch_class is\n" +
            "                            when \"0001\" =>\n" +
            "                                if rd_i /= 0 then\n" +
            "                                    regs(rd_i) <= imm_u;\n" +
            "                                end if;\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                            when \"0010\" =>\n" +
            "                                if rd_i /= 0 then\n" +
            "                                    regs(rd_i) <= std_logic_vector(signed(pc_reg) + signed(imm_u));\n" +
            "                                end if;\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                            when \"0011\" =>\n" +
            "                                if decode_writeback_rd_i /= 0 then\n" +
            "                                    if decode_execute_is_reg = '0' then\n" +
            "                                        case decode_execute_alu_op is\n" +
            "                                            when \"0000\" => regs(decode_writeback_rd_i) <= std_logic_vector(signed(regs(rs1_i)) + imm_i);\n" +
            "                                            when \"0011\" =>\n" +
            "                                                if signed(regs(rs1_i)) < imm_i then\n" +
            "                                                    regs(decode_writeback_rd_i) <= std_logic_vector(to_unsigned(1, XLEN));\n" +
            "                                                else\n" +
            "                                                    regs(decode_writeback_rd_i) <= (others => '0');\n" +
            "                                                end if;\n" +
            "                                            when \"0100\" =>\n" +
            "                                                if unsigned(regs(rs1_i)) < unsigned(std_logic_vector(imm_i)) then\n" +
            "                                                    regs(decode_writeback_rd_i) <= std_logic_vector(to_unsigned(1, XLEN));\n" +
            "                                                else\n" +
            "                                                    regs(decode_writeback_rd_i) <= (others => '0');\n" +
            "                                                end if;\n" +
            "                                            when \"0101\" => regs(decode_writeback_rd_i) <= regs(rs1_i) xor std_logic_vector(imm_i);\n" +
            "                                            when \"1000\" => regs(decode_writeback_rd_i) <= regs(rs1_i) or std_logic_vector(imm_i);\n" +
            "                                            when \"1001\" => regs(decode_writeback_rd_i) <= regs(rs1_i) and std_logic_vector(imm_i);\n" +
            "                                            when \"0010\" => regs(decode_writeback_rd_i) <= std_logic_vector(shift_left(unsigned(regs(rs1_i)), to_integer(unsigned(decode_execute_control_bits(9 downto 4)))));\n" +
            "                                            when \"0110\" => regs(decode_writeback_rd_i) <= std_logic_vector(shift_right(unsigned(regs(rs1_i)), to_integer(unsigned(decode_execute_control_bits(9 downto 4)))));\n" +
            "                                            when \"0111\" => regs(decode_writeback_rd_i) <= std_logic_vector(shift_right(signed(regs(rs1_i)), to_integer(unsigned(decode_execute_control_bits(9 downto 4)))));\n" +
            "                                            when others => trap_reg <= '1';\n" +
            "                                        end case;\n" +
            "                                    else\n" +
            "                                        trap_reg <= '1';\n" +
            "                                    end if;\n" +
            "                                end if;\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                            when \"0100\" =>\n" +
            "                                if decode_writeback_rd_i /= 0 then\n" +
            "                                    if decode_execute_is_reg = '1' then\n" +
            "                                        case decode_execute_alu_op is\n" +
            "                                            when \"0000\" => regs(decode_writeback_rd_i) <= std_logic_vector(signed(regs(rs1_i)) + signed(regs(rs2_i)));\n" +
            "                                            when \"0001\" => regs(decode_writeback_rd_i) <= std_logic_vector(signed(regs(rs1_i)) - signed(regs(rs2_i)));\n" +
            "                                            when \"0010\" => regs(decode_writeback_rd_i) <= std_logic_vector(shift_left(unsigned(regs(rs1_i)), shift_i));\n" +
            "                                            when \"0011\" =>\n" +
            "                                                if signed(regs(rs1_i)) < signed(regs(rs2_i)) then\n" +
            "                                                    regs(decode_writeback_rd_i) <= std_logic_vector(to_unsigned(1, XLEN));\n" +
            "                                                else\n" +
            "                                                    regs(decode_writeback_rd_i) <= (others => '0');\n" +
            "                                                end if;\n" +
            "                                            when \"0100\" =>\n" +
            "                                                if unsigned(regs(rs1_i)) < unsigned(regs(rs2_i)) then\n" +
            "                                                    regs(decode_writeback_rd_i) <= std_logic_vector(to_unsigned(1, XLEN));\n" +
            "                                                else\n" +
            "                                                    regs(decode_writeback_rd_i) <= (others => '0');\n" +
            "                                                end if;\n" +
            "                                            when \"0101\" => regs(decode_writeback_rd_i) <= regs(rs1_i) xor regs(rs2_i);\n" +
            "                                            when \"0110\" => regs(decode_writeback_rd_i) <= std_logic_vector(shift_right(unsigned(regs(rs1_i)), shift_i));\n" +
            "                                            when \"0111\" => regs(decode_writeback_rd_i) <= std_logic_vector(shift_right(signed(regs(rs1_i)), shift_i));\n" +
            "                                            when \"1000\" => regs(decode_writeback_rd_i) <= regs(rs1_i) or regs(rs2_i);\n" +
            "                                            when \"1001\" => regs(decode_writeback_rd_i) <= regs(rs1_i) and regs(rs2_i);\n" +
            "                                            when others => trap_reg <= '1';\n" +
            "                                        end case;\n" +
            "                                    else\n" +
            "                                        trap_reg <= '1';\n" +
            "                                    end if;\n" +
            "                                end if;\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                            when \"0101\" =>\n" +
            "                                addr_i := unsigned(signed(regs(rs1_i)) + imm_i);\n" +
            "                                dmem_addr_reg <= std_logic_vector(addr_i);\n" +
            "                                dmem_re_reg <= '1';\n" +
            "                                case decode_memory_funct3 is\n" +
            "                                    when \"000\" =>\n" +
            "                                        dmem_width_reg <= \"00\";\n" +
            "                                        if XLEN = 64 then\n" +
            "                                            if rd_i /= 0 then\n" +
            "                                                regs(rd_i) <= std_logic_vector(resize(signed(std_logic_vector(shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(2 downto 0))) * 8))(7 downto 0)), XLEN));\n" +
            "                                            end if;\n" +
            "                                        elif rd_i /= 0 then\n" +
            "                                            regs(rd_i) <= std_logic_vector(resize(signed(std_logic_vector(shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(1 downto 0))) * 8))(7 downto 0)), XLEN));\n" +
            "                                        end if;\n" +
            "                                    when \"001\" =>\n" +
            "                                        dmem_width_reg <= \"01\";\n" +
            "                                        if addr_i(0) = '1' then\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        elif XLEN = 64 then\n" +
            "                                            if rd_i /= 0 then\n" +
            "                                                regs(rd_i) <= std_logic_vector(resize(signed(std_logic_vector(shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(2 downto 0))) * 8))(15 downto 0)), XLEN));\n" +
            "                                            end if;\n" +
            "                                        elif rd_i /= 0 then\n" +
            "                                            regs(rd_i) <= std_logic_vector(resize(signed(std_logic_vector(shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(1 downto 0))) * 8))(15 downto 0)), XLEN));\n" +
            "                                        end if;\n" +
            "                                    when \"010\" =>\n" +
            "                                        dmem_width_reg <= \"10\";\n" +
            "                                        if addr_i(1 downto 0) /= \"00\" then\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        elif XLEN = 64 then\n" +
            "                                            if rd_i /= 0 then\n" +
            "                                                regs(rd_i) <= std_logic_vector(resize(signed(std_logic_vector(shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(2 downto 0))) * 8))(31 downto 0)), XLEN));\n" +
            "                                            end if;\n" +
            "                                        elif rd_i /= 0 then\n" +
            "                                            regs(rd_i) <= std_logic_vector(resize(signed(dmem_rdata(31 downto 0)), XLEN));\n" +
            "                                        end if;\n" +
            "                                    when \"011\" =>\n" +
            "                                        dmem_width_reg <= \"11\";\n" +
            "                                        if XLEN = 64 then\n" +
            "                                            if addr_i(2 downto 0) /= \"000\" then\n" +
            "                                                trap_reg <= '1';\n" +
            "                                            elif rd_i /= 0 then\n" +
            "                                                regs(rd_i) <= dmem_rdata;\n" +
            "                                            end if;\n" +
            "                                        else\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        end if;\n" +
            "                                    when \"100\" =>\n" +
            "                                        dmem_width_reg <= \"00\";\n" +
            "                                        if XLEN = 64 then\n" +
            "                                            if rd_i /= 0 then\n" +
            "                                                regs(rd_i) <= std_logic_vector(resize(unsigned(std_logic_vector(shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(2 downto 0))) * 8))(7 downto 0)), XLEN));\n" +
            "                                            end if;\n" +
            "                                        elif rd_i /= 0 then\n" +
            "                                            regs(rd_i) <= std_logic_vector(resize(unsigned(std_logic_vector(shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(1 downto 0))) * 8))(7 downto 0)), XLEN));\n" +
            "                                        end if;\n" +
            "                                    when \"101\" =>\n" +
            "                                        dmem_width_reg <= \"01\";\n" +
            "                                        if addr_i(0) = '1' then\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        elif XLEN = 64 then\n" +
            "                                            if rd_i /= 0 then\n" +
            "                                                regs(rd_i) <= std_logic_vector(resize(unsigned(std_logic_vector(shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(2 downto 0))) * 8))(15 downto 0)), XLEN));\n" +
            "                                            end if;\n" +
            "                                        elif rd_i /= 0 then\n" +
            "                                            regs(rd_i) <= std_logic_vector(resize(unsigned(std_logic_vector(shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(1 downto 0))) * 8))(15 downto 0)), XLEN));\n" +
            "                                        end if;\n" +
            "                                    when \"110\" =>\n" +
            "                                        dmem_width_reg <= \"10\";\n" +
            "                                        if XLEN = 64 then\n" +
            "                                            if addr_i(1 downto 0) /= \"00\" then\n" +
            "                                                trap_reg <= '1';\n" +
            "                                            elif rd_i /= 0 then\n" +
            "                                                regs(rd_i) <= std_logic_vector(resize(unsigned(std_logic_vector(shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(2 downto 0))) * 8))(31 downto 0)), XLEN));\n" +
            "                                            end if;\n" +
            "                                        else\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        end if;\n" +
            "                                    when others => trap_reg <= '1';\n" +
            "                                end case;\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                            when \"0110\" =>\n" +
            "                                imm_i := resize(signed(decode_store_immediate_bits(11 downto 5) & decode_store_immediate_bits(4 downto 0)), XLEN);\n" +
            "                                addr_i := unsigned(signed(regs(rs1_i)) + imm_i);\n" +
            "                                dmem_addr_reg <= std_logic_vector(addr_i);\n" +
            "                                case decode_memory_funct3 is\n" +
            "                                    when \"000\" =>\n" +
            "                                        dmem_width_reg <= \"00\";\n" +
            "                                        if XLEN = 64 then\n" +
            "                                            dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(2 downto 0))) * 8));\n" +
            "                                            dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(1, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));\n" +
            "                                        else\n" +
            "                                            dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(1 downto 0))) * 8));\n" +
            "                                            dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(1, XLEN / 8), to_integer(unsigned(addr_i(1 downto 0)))));\n" +
            "                                        end if;\n" +
            "                                        dmem_we_reg <= '1';\n" +
            "                                    when \"001\" =>\n" +
            "                                        dmem_width_reg <= \"01\";\n" +
            "                                        if addr_i(0) = '1' then\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        elif XLEN = 64 then\n" +
            "                                            dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(2 downto 0))) * 8));\n" +
            "                                            dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(3, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));\n" +
            "                                            dmem_we_reg <= '1';\n" +
            "                                        else\n" +
            "                                            dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(1 downto 0))) * 8));\n" +
            "                                            dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(3, XLEN / 8), to_integer(unsigned(addr_i(1 downto 0)))));\n" +
            "                                            dmem_we_reg <= '1';\n" +
            "                                        end if;\n" +
            "                                    when \"010\" =>\n" +
            "                                        dmem_width_reg <= \"10\";\n" +
            "                                        if addr_i(1 downto 0) /= \"00\" then\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        elif XLEN = 64 then\n" +
            "                                            dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(2 downto 0))) * 8));\n" +
            "                                            dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(15, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));\n" +
            "                                            dmem_we_reg <= '1';\n" +
            "                                        elif XLEN = 32 then\n" +
            "                                            dmem_wdata_reg <= regs(rs2_i);\n" +
            "                                            dmem_wstrb_reg <= std_logic_vector(to_unsigned(15, XLEN / 8));\n" +
            "                                            dmem_we_reg <= '1';\n" +
            "                                        else\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        end if;\n" +
            "                                    when \"011\" =>\n" +
            "                                        dmem_width_reg <= \"11\";\n" +
            "                                        if XLEN = 64 then\n" +
            "                                            if addr_i(2 downto 0) /= \"000\" then\n" +
            "                                                trap_reg <= '1';\n" +
            "                                            else\n" +
            "                                                dmem_wdata_reg <= regs(rs2_i);\n" +
            "                                                dmem_wstrb_reg <= (others => '1');\n" +
            "                                                dmem_we_reg <= '1';\n" +
            "                                            end if;\n" +
            "                                        else\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        end if;\n" +
            "                                    when others =>\n" +
            "                                        dmem_width_reg <= \"00\";\n" +
            "                                        trap_reg <= '1';\n" +
            "                                end case;\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n"

    fn core_vhdl_control_region() -> text:
        "                            when \"0111\" =>\n" +
            "                                case decode_branch_op is\n" +
            "                                    when \"000\" => branch_taken := regs(rs1_i) = regs(rs2_i);\n" +
            "                                    when \"001\" => branch_taken := regs(rs1_i) /= regs(rs2_i);\n" +
            "                                    when \"010\" => branch_taken := signed(regs(rs1_i)) < signed(regs(rs2_i));\n" +
            "                                    when \"011\" => branch_taken := signed(regs(rs1_i)) >= signed(regs(rs2_i));\n" +
            "                                    when \"100\" => branch_taken := unsigned(regs(rs1_i)) < unsigned(regs(rs2_i));\n" +
            "                                    when \"101\" => branch_taken := unsigned(regs(rs1_i)) >= unsigned(regs(rs2_i));\n" +
            "                                    when others => trap_reg <= '1';\n" +
            "                                end case;\n" +
            "                                if decode_next_pc_op = \"01\" and branch_taken then\n" +
            "                                    pc_reg <= std_logic_vector(unsigned(signed(pc_reg) + branch_i));\n" +
            "                                else\n" +
            "                                    pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                                end if;\n" +
            "                            when \"1000\" =>\n" +
            "                                if decode_writes_link = '1' and rd_i /= 0 then\n" +
            "                                    regs(rd_i) <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                                end if;\n" +
            "                                addr_i := unsigned(signed(regs(rs1_i)) + imm_i);\n" +
            "                                addr_i(0) := '0';\n" +
            "                                if decode_next_pc_op = \"10\" then\n" +
            "                                    pc_reg <= std_logic_vector(addr_i);\n" +
            "                                else\n" +
            "                                    trap_reg <= '1';\n" +
            "                                end if;\n" +
            "                            when \"1001\" =>\n" +
            "                                if decode_writes_link = '1' and rd_i /= 0 then\n" +
            "                                    regs(rd_i) <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                                end if;\n" +
            "                                if decode_next_pc_op = \"11\" then\n" +
            "                                    pc_reg <= std_logic_vector(unsigned(signed(pc_reg) + jump_i));\n" +
            "                                else\n" +
            "                                    trap_reg <= '1';\n" +
            "                                end if;\n" +
            "                            when \"1010\" =>\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(BOOT_STRIDE, XLEN));\n" +
            "                            when others =>\n" +
            "                                trap_reg <= '1';\n" +
            "                        end case;\n" +
            "                    elsif decode_should_halt = '1' then\n" +
            "                        halt_reg <= '1';\n" +
            "                    elsif decode_should_trap = '1' then\n" +
            "                        trap_reg <= '1';\n" +
            "                    end if;\n" +
            "                    regs(0) <= (others => '0');\n"

    fn core_vhdl() -> text:
        val package_name = self.package_name()
        val top = self.top_module
        self.source_map_header() +
            "library ieee;\n" +
            "use ieee.std_logic_1164.all;\n" +
            "use ieee.numeric_std.all;\n" +
            "use work.{package_name}.all;\n\n" +
            "entity {top} is\n" +
            "    port (\n" +
            "        clk           : in  std_logic;\n" +
            "        reset_n       : in  std_logic;\n" +
            "        imem_addr     : out xword_t;\n" +
            "        imem_rdata    : in  std_logic_vector(31 downto 0);\n" +
            "        dmem_addr     : out xword_t;\n" +
            "        dmem_wdata    : out xword_t;\n" +
            "        dmem_rdata    : in  xword_t;\n" +
            "        dmem_we       : out std_logic;\n" +
            "        dmem_re       : out std_logic;\n" +
            "        dmem_width    : out std_logic_vector(1 downto 0);\n" +
            "        dmem_wstrb    : out std_logic_vector((XLEN / 8) - 1 downto 0);\n" +
            "        debug_pc      : out xword_t;\n" +
            "        trap          : out std_logic;\n" +
            "        halt          : out std_logic\n" +
            "    );\n" +
            "end entity {top};\n\n" +
            "architecture rtl of {top} is\n" +
            "    type reg_file_t is array (0 to 31) of xword_t;\n" +
            "    signal pc_reg : xword_t := RESET_VECTOR;\n" +
            "    signal regs : reg_file_t := (others => (others => '0'));\n" +
            "    signal dmem_addr_reg : xword_t := (others => '0');\n" +
            "    signal dmem_wdata_reg : xword_t := (others => '0');\n" +
            "    signal dmem_we_reg : std_logic := '0';\n" +
            "    signal dmem_re_reg : std_logic := '0';\n" +
            "    signal dmem_width_reg : std_logic_vector(1 downto 0) := \"10\";\n" +
            "    signal dmem_wstrb_reg : std_logic_vector((XLEN / 8) - 1 downto 0) := (others => '0');\n" +
            "    signal trap_reg : std_logic := '0';\n" +
            "    signal halt_reg : std_logic := '0';\n" +
            "begin\n" +
            "    imem_addr <= pc_reg;\n" +
            "    dmem_addr <= dmem_addr_reg;\n" +
            "    dmem_wdata <= dmem_wdata_reg;\n" +
            "    dmem_we <= dmem_we_reg;\n" +
            "    dmem_re <= dmem_re_reg;\n" +
            "    dmem_width <= dmem_width_reg;\n" +
            "    dmem_wstrb <= dmem_wstrb_reg;\n" +
            "    debug_pc <= pc_reg;\n" +
            "    trap <= trap_reg;\n" +
            "    halt <= halt_reg;\n\n" +
            "    process(clk, reset_n)\n" +
            self.core_vhdl_process_variables() +
            "    begin\n" +
            "        if reset_n = '0' then\n" +
            "            pc_reg <= RESET_VECTOR;\n" +
            "            regs <= (others => (others => '0'));\n" +
            "            dmem_addr_reg <= (others => '0');\n" +
            "            dmem_wdata_reg <= (others => '0');\n" +
            "            dmem_we_reg <= '0';\n" +
            "            dmem_re_reg <= '0';\n" +
            "            dmem_width_reg <= \"10\";\n" +
            "            dmem_wstrb_reg <= (others => '0');\n" +
            "            trap_reg <= '0';\n" +
            "            halt_reg <= '0';\n" +
            "        elsif rising_edge(clk) then\n" +
            "            dmem_we_reg <= '0';\n" +
            "            dmem_re_reg <= '0';\n" +
            "            dmem_width_reg <= \"10\";\n" +
            "            dmem_wstrb_reg <= (others => '0');\n" +
            "            if halt_reg = '0' and trap_reg = '0' then\n" +
            "                rd_i := to_integer(unsigned(imem_rdata(11 downto 7)));\n" +
            "                rs1_i := to_integer(unsigned(imem_rdata(19 downto 15)));\n" +
            "                rs2_i := to_integer(unsigned(imem_rdata(24 downto 20)));\n" +
            self.core_vhdl_decode_staging_region() +
            "                if decode_continue_exec = '1' then\n" +
            self.core_vhdl_execute_load_store_region() +
            self.core_vhdl_control_region() +
            "            end if;\n" +
            "        end if;\n" +
            "    end process;\n" +
            "end architecture rtl;\n"

struct FpgaPrepareManifest:
    board: XilinxBoardProfile
    lanes: [RiscvFpgaLane]
    vivado_project_dir: text
    generated_dir: text

impl FpgaPrepareManifest:
    static fn default_xilinx() -> FpgaPrepareManifest:
        FpgaPrepareManifest(
            board: XilinxBoardProfile.generic(),
            lanes: [RiscvFpgaLane.rv32_default(), RiscvFpgaLane.rv64_default()],
            vivado_project_dir: "build/fpga/xilinx_generic/vivado",
            generated_dir: "build/fpga/xilinx_generic/generated"
        )

    fn validate_for_prepare() -> [text]:
        var errors = self.board.validate_for_prepare()
        if self.vivado_project_dir == "":
            errors.push("vivado_project_dir is required")
        if self.generated_dir == "":
            errors.push("generated_dir is required")
        if self.lanes.len() == 0:
            errors.push("at least one RISC-V lane is required")
        for lane in self.lanes:
            val lane_errors = lane.validate_for_prepare()
            for err in lane_errors:
                errors.push("{lane.xlen.to_text()}: {err}")
            val source_errors = lane.hardware_source_contract_errors()
            for err in source_errors:
                errors.push(err)
        errors

    fn vivado_tcl_plan() -> text:
        var out = "create_project simple_riscv_fpga {self.vivado_project_dir} -part {self.board.part}\n"
        out = out + "set_property target_language VHDL [current_project]\n"
        out = out + "add_files {self.board.constraints_path}\n"
        for lane in self.lanes:
            out = out + "add_files {lane.rtl_dir}\n"
            out = out + "set_property top {lane.top_module} [current_fileset]\n"
        out = out + "synth_design\n"
        out

    fn readiness_summary() -> text:
        var out = "board={self.board.name} part={self.board.part} lanes={self.lanes.len()}"
        for lane in self.lanes:
            out = out + " {lane.xlen.to_text()}:{lane.readiness_status().to_text()}:{lane.platform_profile.name}:{lane.top_module}"
        out

    fn rtl_manifest_text(root_dir: text) -> text:
        var out = "[riscv_fpga_rtl]\n"
        out = out + "board = \"{self.board.name}\"\n"
        out = out + "part = \"{self.board.part}\"\n"
        for lane in self.lanes:
            val lane_dir = "{root_dir}/{lane.xlen.to_text()}/rtl"
            out = out + "\n[[lane]]\n"
            out = out + "arch = \"{lane.xlen.to_text()}\"\n"
            out = out + "xlen = {lane.xlen.bits()}\n"
            out = out + "top = \"{lane.top_module}\"\n"
            out = out + "rtl_dir = \"{lane_dir}\"\n"
            out = out + "rtl_sim_backend = \"{lane.rtl_sim_backend}\"\n"
            out = out + "package = \"{lane.package_name()}\"\n"
            out = out + "source_file = \"{lane_dir}/{lane.hardware_source_file_name()}\"\n"
            out = out + "package_file = \"{lane_dir}/{lane.package_name()}.vhd\"\n"
            out = out + "core_file = \"{lane_dir}/{lane.top_module}.vhd\"\n"
            out = out + "readiness = \"{lane.readiness_status().to_text()}\"\n"
            out = out + "platform = \"{lane.platform_profile.name}\"\n"
            out = out + "scope = \"{lane.scope_note}\"\n"
            out = out + "linux_policy = \"{lane.xlen.linux_policy()}\"\n"
            out = out + "abi = \"{lane.linux_profile.abi.to_text()}\"\n"
            out = out + "mmu = \"{lane.linux_profile.mmu_mode.to_text()}\"\n"
            out = out + "firmware_mode = \"{lane.linux_profile.firmware_mode.to_text()}\"\n"
            out = out + "kernel_alignment = {lane.linux_profile.kernel_alignment}\n"
        out

class RiscvFpgaRtlBundle:
    root_dir: text
    manifest_path: text
    generated_files: [text]

fn _write_text_file(path: text, content: text) -> Result<(), text>:
    if not rt_file_write_text(path, content):
        return Err("failed to write {path}")
    Ok(())

fn generate_riscv_fpga_rtl_bundle(root_dir: text, manifest: FpgaPrepareManifest) -> Result<RiscvFpgaRtlBundle, text>:
    val errors = manifest.validate_for_prepare()
    if errors.len() != 0:
        return Err(errors.join("; "))
    if not rt_dir_create(root_dir, true):
        return Err("failed to create rtl root dir: {root_dir}")

    var generated: [text] = []
    for lane in manifest.lanes:
        val lane_root = "{root_dir}/{lane.xlen.to_text()}"
        if not rt_dir_create(lane_root, true):
            return Err("failed to create rtl lane root dir: {lane_root}")
        val lane_dir = "{lane_root}/rtl"
        if not rt_dir_create(lane_dir, true):
            return Err("failed to create rtl lane dir: {lane_dir}")
        val package_path = "{lane_dir}/{lane.package_name()}.vhd"
        val core_path = "{lane_dir}/{lane.top_module}.vhd"
        val source_path = "{lane_dir}/{lane.hardware_source_file_name()}"
        _write_text_file(source_path, lane.hardware_source_spl())?
        _write_text_file(package_path, lane.package_vhdl())?
        _write_text_file(core_path, lane.core_vhdl())?
        generated.push(source_path)
        generated.push(package_path)
        generated.push(core_path)

    val manifest_path = "{root_dir}/riscv_fpga_rtl_manifest.sdn"
    _write_text_file(manifest_path, manifest.rtl_manifest_text(root_dir))?
    generated.push(manifest_path)
    Ok(RiscvFpgaRtlBundle(
        root_dir: root_dir,
        manifest_path: manifest_path,
        generated_files: generated
    ))

fn generate_default_riscv_fpga_rtl_bundle(root_dir: text) -> Result<RiscvFpgaRtlBundle, text>:
    generate_riscv_fpga_rtl_bundle(root_dir, FpgaPrepareManifest.default_xilinx())

fn read_generated_riscv_fpga_rtl_file(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn create_default_riscv_fpga_linux_manifest() -> FpgaPrepareManifest:
    FpgaPrepareManifest.default_xilinx()
