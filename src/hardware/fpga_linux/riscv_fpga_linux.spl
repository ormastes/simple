        if not source.contains("dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(15, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));") or not source.contains("dmem_wstrb_reg <= std_logic_vector(to_unsigned(15, XLEN / 8));") or not source.contains("dmem_wstrb_reg <= (others => '1');"):
            errors.push("{self.xlen.to_text()} hardware source must drive word and doubleword store strobes for supported widths")
        if not source.contains("val jump_inst = RiscvJumpEncoding.new(imem_rdata)"):
            errors.push("{self.xlen.to_text()} hardware source must read jump immediate pieces through the jump layout bitfield")
        if not source.contains("var jump_imm = RiscvJumpImmediate.new(0 as u32)"):
            errors.push("{self.xlen.to_text()} hardware source must reconstruct jump immediate through bitfield writes")
        if not source.contains("jump_imm.low10 = jump_inst.low10 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve jump immediate low bits")
        if not source.contains("jump_imm.bit11 = jump_inst.bit11 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve jump immediate bit11")
        if not source.contains("jump_imm.high8 = jump_inst.high8 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve jump immediate middle bits")
        if not source.contains("jump_imm.bit20 = jump_inst.bit20 as u32"):
            errors.push("{self.xlen.to_text()} hardware source must preserve the jump immediate sign bit")
        if not source.contains("base integer instructions:"):
            errors.push("{self.xlen.to_text()} hardware source must list RV base integer instructions")
        if source.contains("pass_todo") or source.contains("todo("):
            errors.push("{self.xlen.to_text()} hardware source must not contain stubs")
        if source.contains("async ") or source.contains("spawn ") or source.contains("rt_file_"):
            errors.push("{self.xlen.to_text()} hardware source uses unsupported hardware construct")
        errors

    fn source_map_header() -> text:
        var out = "-- generated-from: {self.hardware_source_file_name()}\n"
        for entry in self.generated_core_shell_contract().debug_source_map_entries():
            out = out + entry.comment_line()
        out = out + "-- proof-lane: {self.proof_lane().to_text()} shell={self.generated_core_shell_contract().shell_services_summary()}\n"
        out = out + "-- readiness: {self.readiness_status().to_text()} linux-boot-validated={self.readiness_is_boot_validated()}\n\n"
        out

    fn package_vhdl() -> text:
        val bits = self.xlen.bits()
        val package_name = self.package_name()
        self.source_map_header() +
            "library ieee;\n" +
            "use ieee.std_logic_1164.all;\n" +
            "use ieee.numeric_std.all;\n\n" +
            "package {package_name} is\n" +
            "    constant XLEN : natural := {bits};\n" +
            "    subtype xword_t is std_logic_vector(XLEN - 1 downto 0);\n" +
            "    constant RESET_VECTOR : xword_t := x\"{self.reset_vector_hex()}\";\n" +
            "    constant BOOT_STRIDE : natural := {self.boot_stride_decimal()};\n" +
            "    function rv64c_is_compressed(instr : std_logic_vector(31 downto 0)) return boolean;\n" +
            "    function rv64c_decompress(instr : std_logic_vector(15 downto 0)) return std_logic_vector;\n" +
            "end package {package_name};\n\n" +
            "package body {package_name} is\n" +
            "    function sign_extend(bits : std_logic_vector; width : natural) return std_logic_vector is\n" +
            "        variable result : std_logic_vector(width - 1 downto 0);\n" +
            "    begin\n" +
            "        result := std_logic_vector(resize(signed(bits), width));\n" +
            "        return result;\n" +
            "    end function;\n\n" +
            "    function encode_r(opcode : std_logic_vector(6 downto 0); rd : natural; funct3 : std_logic_vector(2 downto 0); rs1 : natural; rs2 : natural; funct7 : std_logic_vector(6 downto 0)) return std_logic_vector is\n" +
            "    begin\n" +
            "        return funct7 & std_logic_vector(to_unsigned(rs2, 5)) & std_logic_vector(to_unsigned(rs1, 5)) & funct3 & std_logic_vector(to_unsigned(rd, 5)) & opcode;\n" +
            "    end function;\n\n" +
            "    function encode_i(opcode : std_logic_vector(6 downto 0); rd : natural; funct3 : std_logic_vector(2 downto 0); rs1 : natural; imm : std_logic_vector(11 downto 0)) return std_logic_vector is\n" +
            "    begin\n" +
            "        return imm & std_logic_vector(to_unsigned(rs1, 5)) & funct3 & std_logic_vector(to_unsigned(rd, 5)) & opcode;\n" +
            "    end function;\n\n" +
            "    function encode_s(opcode : std_logic_vector(6 downto 0); funct3 : std_logic_vector(2 downto 0); rs1 : natural; rs2 : natural; imm : std_logic_vector(11 downto 0)) return std_logic_vector is\n" +
            "    begin\n" +
            "        return imm(11 downto 5) & std_logic_vector(to_unsigned(rs2, 5)) & std_logic_vector(to_unsigned(rs1, 5)) & funct3 & imm(4 downto 0) & opcode;\n" +
            "    end function;\n\n" +
            "    function encode_b(opcode : std_logic_vector(6 downto 0); funct3 : std_logic_vector(2 downto 0); rs1 : natural; rs2 : natural; imm : std_logic_vector(12 downto 0)) return std_logic_vector is\n" +
            "    begin\n" +
            "        return imm(12) & imm(10 downto 5) & std_logic_vector(to_unsigned(rs2, 5)) & std_logic_vector(to_unsigned(rs1, 5)) & funct3 & imm(4 downto 1) & imm(11) & opcode;\n" +
            "    end function;\n\n" +
            "    function encode_u(opcode : std_logic_vector(6 downto 0); rd : natural; imm : std_logic_vector(19 downto 0)) return std_logic_vector is\n" +
            "    begin\n" +
            "        return imm & std_logic_vector(to_unsigned(rd, 5)) & opcode;\n" +
            "    end function;\n\n" +
            "    function encode_j(opcode : std_logic_vector(6 downto 0); rd : natural; imm : std_logic_vector(20 downto 0)) return std_logic_vector is\n" +
            "    begin\n" +
            "        return imm(20) & imm(10 downto 1) & imm(11) & imm(19 downto 12) & std_logic_vector(to_unsigned(rd, 5)) & opcode;\n" +
            "    end function;\n\n" +
            "    function rvc_reg(bits : std_logic_vector(2 downto 0)) return natural is\n" +
            "    begin\n" +
            "        return 8 + to_integer(unsigned(bits));\n" +
            "    end function;\n\n" +
            "    function rv64c_is_compressed(instr : std_logic_vector(31 downto 0)) return boolean is\n" +
            "    begin\n" +
            "        return instr(1 downto 0) /= \"11\";\n" +
            "    end function;\n\n" +
            "    function rv64c_decompress(instr : std_logic_vector(15 downto 0)) return std_logic_vector is\n" +
            "        variable result : std_logic_vector(31 downto 0) := (others => '0');\n" +
            "        variable funct3 : std_logic_vector(2 downto 0);\n" +
            "        variable funct2 : std_logic_vector(1 downto 0);\n" +
            "        variable funct2b : std_logic_vector(1 downto 0);\n" +
            "        variable rd : natural;\n" +
            "        variable rs1_c : natural;\n" +
            "        variable rs2_c : natural;\n" +
            "        variable rs2 : natural;\n" +
            "        variable imm12 : std_logic_vector(11 downto 0);\n" +
            "        variable imm13 : std_logic_vector(12 downto 0);\n" +
            "        variable imm20 : std_logic_vector(19 downto 0);\n" +
            "        variable imm21 : std_logic_vector(20 downto 0);\n" +
            "        variable shamt6 : std_logic_vector(5 downto 0);\n" +
            "    begin\n" +
            "        funct3 := instr(15 downto 13);\n" +
            "        case instr(1 downto 0) is\n" +
            "            when \"00\" =>\n" +
            "                case funct3 is\n" +
            "                    when \"000\" =>\n" +
            "                        imm12 := \"00\" & instr(10 downto 7) & instr(12 downto 11) & instr(5) & instr(6) & \"00\";\n" +
            "                        if imm12 = x\"000\" then\n" +
            "                            return x\"00000000\";\n" +
            "                        end if;\n" +
            "                        rd := rvc_reg(instr(4 downto 2));\n" +
            "                        return encode_i(\"0010011\", rd, \"000\", 2, imm12);\n" +
            "                    when \"010\" =>\n" +
            "                        imm12 := \"00000\" & instr(5) & instr(12 downto 10) & instr(6) & \"00\";\n" +
            "                        rd := rvc_reg(instr(4 downto 2));\n" +
            "                        rs1_c := rvc_reg(instr(9 downto 7));\n" +
            "                        return encode_i(\"0000011\", rd, \"010\", rs1_c, imm12);\n" +
            "                    when \"011\" =>\n" +
            "                        imm12 := \"0000\" & instr(6 downto 5) & instr(12 downto 10) & \"000\";\n" +
            "                        rd := rvc_reg(instr(4 downto 2));\n" +
            "                        rs1_c := rvc_reg(instr(9 downto 7));\n" +
            "                        return encode_i(\"0000011\", rd, \"011\", rs1_c, imm12);\n" +
            "                    when \"110\" =>\n" +
            "                        imm12 := \"00000\" & instr(5) & instr(12 downto 10) & instr(6) & \"00\";\n" +
            "                        rs2_c := rvc_reg(instr(4 downto 2));\n" +
            "                        rs1_c := rvc_reg(instr(9 downto 7));\n" +
            "                        return encode_s(\"0100011\", \"010\", rs1_c, rs2_c, imm12);\n" +
            "                    when \"111\" =>\n" +
            "                        imm12 := \"0000\" & instr(6 downto 5) & instr(12 downto 10) & \"000\";\n" +
            "                        rs2_c := rvc_reg(instr(4 downto 2));\n" +
            "                        rs1_c := rvc_reg(instr(9 downto 7));\n" +
            "                        return encode_s(\"0100011\", \"011\", rs1_c, rs2_c, imm12);\n" +
            "                    when others =>\n" +
            "                        return x\"00000000\";\n" +
            "                end case;\n" +
            "            when \"01\" =>\n" +
            "                case funct3 is\n" +
            "                    when \"000\" =>\n" +
            "                        rd := to_integer(unsigned(instr(11 downto 7)));\n" +
            "                        imm12 := sign_extend(instr(12) & instr(6 downto 2), 12);\n" +
            "                        return encode_i(\"0010011\", rd, \"000\", rd, imm12);\n" +
            "                    when \"001\" =>\n" +
            "                        rd := to_integer(unsigned(instr(11 downto 7)));\n" +
            "                        if rd = 0 then\n" +
            "                            return x\"00000000\";\n" +
            "                        end if;\n" +
            "                        imm12 := sign_extend(instr(12) & instr(6 downto 2), 12);\n" +
            "                        return encode_i(\"0011011\", rd, \"000\", rd, imm12);\n" +
            "                    when \"010\" =>\n" +
            "                        rd := to_integer(unsigned(instr(11 downto 7)));\n" +
            "                        imm12 := sign_extend(instr(12) & instr(6 downto 2), 12);\n" +
            "                        return encode_i(\"0010011\", rd, \"000\", 0, imm12);\n" +
            "                    when \"011\" =>\n" +
            "                        rd := to_integer(unsigned(instr(11 downto 7)));\n" +
            "                        if rd = 2 then\n" +
            "                            imm12 := sign_extend(instr(12) & instr(4) & instr(3) & instr(5) & instr(2) & instr(6) & \"0000\", 12);\n" +
            "                            if imm12 = x\"000\" then\n" +
            "                                return x\"00000000\";\n" +
            "                            end if;\n" +
            "                            return encode_i(\"0010011\", 2, \"000\", 2, imm12);\n" +
            "                        end if;\n" +
            "                        imm20 := instr(12) & instr(12) & instr(12) & instr(6 downto 2) & \"000000000000\";\n" +
            "                        if imm20 = x\"00000\" then\n" +
            "                            return x\"00000000\";\n" +
            "                        end if;\n" +
            "                        return encode_u(\"0110111\", rd, imm20);\n" +
            "                    when \"100\" =>\n" +
            "                        funct2 := instr(11 downto 10);\n" +
            "                        rd := rvc_reg(instr(9 downto 7));\n" +
            "                        case funct2 is\n" +
            "                            when \"00\" =>\n" +
            "                                shamt6 := instr(12) & instr(6 downto 2);\n" +
            "                                return encode_i(\"0010011\", rd, \"101\", rd, \"000000\" & shamt6);\n" +
            "                            when \"01\" =>\n" +
            "                                shamt6 := instr(12) & instr(6 downto 2);\n" +
            "                                return encode_i(\"0010011\", rd, \"101\", rd, \"010000\" & shamt6);\n" +
            "                            when \"10\" =>\n" +
            "                                imm12 := sign_extend(instr(12) & instr(6 downto 2), 12);\n" +
            "                                return encode_i(\"0010011\", rd, \"111\", rd, imm12);\n" +
            "                            when others =>\n" +
            "                                rs2_c := rvc_reg(instr(4 downto 2));\n" +
            "                                funct2b := instr(6 downto 5);\n" +
            "                                if instr(12) = '0' then\n" +
            "                                    case funct2b is\n" +
            "                                        when \"00\" => return encode_r(\"0110011\", rd, \"000\", rd, rs2_c, \"0100000\");\n" +
            "                                        when \"01\" => return encode_r(\"0110011\", rd, \"100\", rd, rs2_c, \"0000000\");\n" +
            "                                        when \"10\" => return encode_r(\"0110011\", rd, \"110\", rd, rs2_c, \"0000000\");\n" +
            "                                        when \"11\" => return encode_r(\"0110011\", rd, \"111\", rd, rs2_c, \"0000000\");\n" +
            "                                        when others => return x\"00000000\";\n" +
            "                                    end case;\n" +
            "                                end if;\n" +
            "                                case funct2b is\n" +
            "                                    when \"00\" => return encode_r(\"0111011\", rd, \"000\", rd, rs2_c, \"0100000\");\n" +
            "                                    when \"01\" => return encode_r(\"0111011\", rd, \"000\", rd, rs2_c, \"0000000\");\n" +
            "                                    when others => return x\"00000000\";\n" +
            "                                end case;\n" +
            "                        end case;\n" +
            "                    when \"101\" =>\n" +
            "                        imm21 := sign_extend(instr(12) & instr(8) & instr(10 downto 9) & instr(6) & instr(7) & instr(2) & instr(11) & instr(5 downto 3) & '0', 21);\n" +
            "                        return encode_j(\"1101111\", 0, imm21);\n" +
            "                    when \"110\" =>\n" +
            "                        rs1_c := rvc_reg(instr(9 downto 7));\n" +
            "                        imm13 := sign_extend(instr(12) & instr(6 downto 5) & instr(2) & instr(11 downto 10) & instr(4 downto 3) & '0', 13);\n" +
            "                        return encode_b(\"1100011\", \"000\", rs1_c, 0, imm13);\n" +
            "                    when \"111\" =>\n" +
            "                        rs1_c := rvc_reg(instr(9 downto 7));\n" +
            "                        imm13 := sign_extend(instr(12) & instr(6 downto 5) & instr(2) & instr(11 downto 10) & instr(4 downto 3) & '0', 13);\n" +
            "                        return encode_b(\"1100011\", \"001\", rs1_c, 0, imm13);\n" +
            "                    when others =>\n" +
            "                        return x\"00000000\";\n" +
            "                end case;\n" +
            "            when \"10\" =>\n" +
            "                case funct3 is\n" +
            "                    when \"000\" =>\n" +
            "                        rd := to_integer(unsigned(instr(11 downto 7)));\n" +
            "                        if rd = 0 then\n" +
            "                            return x\"00000000\";\n" +
            "                        end if;\n" +
            "                        shamt6 := instr(12) & instr(6 downto 2);\n" +
            "                        return encode_i(\"0010011\", rd, \"001\", rd, \"000000\" & shamt6);\n" +
            "                    when \"010\" =>\n" +
            "                        rd := to_integer(unsigned(instr(11 downto 7)));\n" +
            "                        if rd = 0 then\n" +
            "                            return x\"00000000\";\n" +
            "                        end if;\n" +
            "                        imm12 := \"0000\" & instr(3 downto 2) & instr(12) & instr(6 downto 4) & \"00\";\n" +
            "                        return encode_i(\"0000011\", rd, \"010\", 2, imm12);\n" +
            "                    when \"011\" =>\n" +
            "                        rd := to_integer(unsigned(instr(11 downto 7)));\n" +
            "                        if rd = 0 then\n" +
            "                            return x\"00000000\";\n" +
            "                        end if;\n" +
            "                        imm12 := \"000\" & instr(4 downto 2) & instr(12) & instr(6 downto 5) & \"000\";\n" +
            "                        return encode_i(\"0000011\", rd, \"011\", 2, imm12);\n" +
            "                    when \"100\" =>\n" +
            "                        rd := to_integer(unsigned(instr(11 downto 7)));\n" +
            "                        rs2 := to_integer(unsigned(instr(6 downto 2)));\n" +
            "                        if instr(12) = '0' then\n" +
            "                            if rs2 = 0 then\n" +
            "                                if rd = 0 then\n" +
            "                                    return x\"00000000\";\n" +
            "                                end if;\n" +
            "                                return encode_i(\"1100111\", 0, \"000\", rd, x\"000\");\n" +
            "                            end if;\n" +
            "                            return encode_r(\"0110011\", rd, \"000\", 0, rs2, \"0000000\");\n" +
            "                        elsif rs2 = 0 then\n" +
            "                            if rd = 0 then\n" +
            "                                return x\"00100073\";\n" +
            "                            end if;\n" +
            "                            return encode_i(\"1100111\", 1, \"000\", rd, x\"000\");\n" +
            "                        else\n" +
            "                            return encode_r(\"0110011\", rd, \"000\", rd, rs2, \"0000000\");\n" +
            "                        end if;\n" +
            "                    when \"110\" =>\n" +
            "                        rs2 := to_integer(unsigned(instr(6 downto 2)));\n" +
            "                        imm12 := \"0000\" & instr(8 downto 7) & instr(12 downto 9) & \"00\";\n" +
            "                        return encode_s(\"0100011\", \"010\", 2, rs2, imm12);\n" +
            "                    when \"111\" =>\n" +
            "                        rs2 := to_integer(unsigned(instr(6 downto 2)));\n" +
            "                        imm12 := \"000\" & instr(9 downto 7) & instr(12 downto 10) & \"000\";\n" +
            "                        return encode_s(\"0100011\", \"011\", 2, rs2, imm12);\n" +
            "                    when others =>\n" +
            "                        return x\"00000000\";\n" +
            "                end case;\n" +
            "            when others =>\n" +
            "                return x\"00000000\";\n" +
            "        end case;\n" +
            "    end function;\n" +
            "end package body {package_name};\n"

    fn core_vhdl_process_variables() -> text:
        "        variable instr_word_v : std_logic_vector(31 downto 0);\n" +
            "        variable instr_size_bytes : natural range 2 to 4;\n" +
            "        variable rd_i : integer range 0 to 31;\n" +
            "        variable rs1_i : integer range 0 to 31;\n" +
            "        variable rs2_i : integer range 0 to 31;\n" +
            "        variable imm_i : signed(XLEN - 1 downto 0);\n" +
            "        variable addr_i : unsigned(XLEN - 1 downto 0);\n" +
            "        variable branch_i : signed(XLEN - 1 downto 0);\n" +
            "        variable jump_i : signed(XLEN - 1 downto 0);\n" +
            "        variable imm_u : xword_t;\n" +
            "        variable decode_writeback_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_branch_immediate_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_store_immediate_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_i_immediate_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_upper_immediate_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_execute_control_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_execute_datapath_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_branch_datapath_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_control_flow_datapath_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_memory_access_control_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_jump_immediate_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_dispatch_class_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_trap_halt_control_bits : std_logic_vector(31 downto 0);\n" +
            "        variable decode_writeback_rd_i : integer range 0 to 31;\n" +
            "        variable branch_taken : boolean;\n" +
            "        variable shift_i : natural range 0 to 63;\n" +
            "        variable decode_execute_alu_op : std_logic_vector(3 downto 0);\n" +
            "        variable decode_execute_is_reg : std_logic;\n" +
            "        variable decode_branch_op : std_logic_vector(2 downto 0);\n" +
            "        variable decode_next_pc_op : std_logic_vector(1 downto 0);\n" +
            "        variable decode_writes_link : std_logic;\n" +
            "        variable decode_memory_funct3 : std_logic_vector(2 downto 0);\n" +
            "        variable decode_dispatch_class : std_logic_vector(3 downto 0);\n" +
            "        variable decode_continue_exec : std_logic;\n" +
            "        variable decode_should_trap : std_logic;\n" +
            "        variable decode_should_halt : std_logic;\n" +
            "        variable csr_old_val : xword_t;\n" +
            "        variable csr_new_val : xword_t;\n" +
            "        variable mret_mpp_v : std_logic_vector(1 downto 0);\n" +
            "        variable translated_addr_v : xword_t;\n" +
            "        variable translated_fault_v : std_logic;\n" +
            "        variable atomic_old_word32_v : std_logic_vector(31 downto 0);\n" +
            "        variable atomic_new_word32_v : std_logic_vector(31 downto 0);\n" +
            "        variable atomic_old_word64_v : xword_t;\n" +
            "        variable atomic_new_word64_v : xword_t;\n" +
            "        variable load_should_issue_v : boolean;\n"

    fn core_vhdl_mmu_port_lines() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return ""
        "        mmu_dmem_l2_pte : in  xword_t;\n" +
            "        mmu_dmem_l1_pte : in  xword_t;\n" +
            "        mmu_dmem_l0_pte : in  xword_t;\n" +
            "        debug_priv_mode : out std_logic_vector(1 downto 0);\n" +
            "        debug_last_load_value : out xword_t;\n" +
            "        debug_ra   : out xword_t;\n" +
            "        debug_sp   : out xword_t;\n" +
            "        debug_s0   : out xword_t;\n" +
            "        debug_a0   : out xword_t;\n" +
            "        debug_a1   : out xword_t;\n" +
            "        debug_a2   : out xword_t;\n" +
            "        debug_load_rd : out xword_t;\n"

    fn core_vhdl_mmu_helper_lines() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return ""
        "    procedure sv39_translate_data(\n" +
            "        vaddr      : in  xword_t;\n" +
            "        satp       : in  xword_t;\n" +
            "        priv_mode  : in  std_logic_vector(1 downto 0);\n" +
            "        is_write   : in  std_logic;\n" +
            "        l2_pte     : in  xword_t;\n" +
            "        l1_pte     : in  xword_t;\n" +
            "        l0_pte     : in  xword_t;\n" +
            "        paddr      : out xword_t;\n" +
            "        fault      : out std_logic\n" +
            "    ) is\n" +
            "        variable pte_v : xword_t;\n" +
            "        variable translated_v : xword_t;\n" +
            "    begin\n" +
            "        translated_v := vaddr;\n" +
            "        fault := '0';\n" +
            "        if priv_mode = \"11\" then\n" +
            "            paddr := translated_v;\n" +
            "            return;\n" +
            "        end if;\n" +
            "        if satp(63 downto 60) /= \"1000\" then\n" +
            "            paddr := translated_v;\n" +
            "            return;\n" +
