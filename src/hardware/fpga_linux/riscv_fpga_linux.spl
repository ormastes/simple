"""
# RISC-V FPGA Linux Preparation Contracts

Board-profiled preparation model for RISC-V CPU SoC RTL bring-up on Xilinx
FPGAs. This module describes the pre-hardware contract: what must be generated,
validated, and later consumed by Vivado/programming/boot-test wrappers.
"""

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_dir_create(path: text, recursive: bool) -> bool
extern fn rt_dir_exists(path: text) -> bool

use hardware.riscv_common.pkg.riscv_linux_pkg.{RiscvLinuxProfile, RiscvPlatformProfile, Rv32LinuxBootArtifacts, Rv64LinuxBootArtifacts}
use hardware.riscv_common.pkg.riscv_generated_core_pkg.{RiscvProofLane, GeneratedCoreShellContract, GeneratedCoreDebugMetadata, GeneratedCoreDebugSourceMapEntry, GeneratedCoreDebugRunnerTestbench}
use hardware.rv32gc.top.rv32_machine.{qemu_virt_rv32_platform_profile, rv32_qemu_virt_linux_profile}
use hardware.rv64gc.top.rv64_machine.{qemu_virt_rv64_platform_profile, rv64_qemu_virt_linux_profile}

fn generated_rv32_support_package_vhdl_text() -> text:
    """library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

package rv32i_pkg is
    constant OP_LUI    : std_logic_vector(6 downto 0) := "0110111";
    constant OP_AUIPC  : std_logic_vector(6 downto 0) := "0010111";
    constant OP_JAL    : std_logic_vector(6 downto 0) := "1101111";
    constant OP_JALR   : std_logic_vector(6 downto 0) := "1100111";
    constant OP_BRANCH : std_logic_vector(6 downto 0) := "1100011";
    constant OP_LOAD   : std_logic_vector(6 downto 0) := "0000011";
    constant OP_STORE  : std_logic_vector(6 downto 0) := "0100011";
    constant OP_IMMED  : std_logic_vector(6 downto 0) := "0010011";
    constant OP_REG    : std_logic_vector(6 downto 0) := "0110011";
    constant OP_SYSTEM : std_logic_vector(6 downto 0) := "1110011";

    type alu_op_t is (
        ALU_ADD, ALU_SUB, ALU_SLL, ALU_SLT, ALU_SLTU,
        ALU_XOR, ALU_SRL, ALU_SRA, ALU_OR, ALU_AND, ALU_PASS_B
    );

    constant BR_BEQ  : std_logic_vector(2 downto 0) := "000";
    constant BR_BNE  : std_logic_vector(2 downto 0) := "001";
    constant BR_BLT  : std_logic_vector(2 downto 0) := "100";
    constant BR_BGE  : std_logic_vector(2 downto 0) := "101";
    constant BR_BLTU : std_logic_vector(2 downto 0) := "110";
    constant BR_BGEU : std_logic_vector(2 downto 0) := "111";

    constant SEMI_ENTRY : std_logic_vector(31 downto 0) := x"01f01013";
    constant SEMI_BREAK : std_logic_vector(31 downto 0) := x"00100073";
    constant SEMI_EXIT  : std_logic_vector(31 downto 0) := x"40705013";

    constant SYS_WRITEC  : std_logic_vector(31 downto 0) := x"00000003";
    constant SYS_WRITE0  : std_logic_vector(31 downto 0) := x"00000004";
    constant SYS_EXIT    : std_logic_vector(31 downto 0) := x"00000018";

    constant MB_BASE_ADDR    : std_logic_vector(31 downto 0) := x"80FF0000";
    constant MB_OFF_CMD      : integer := 16#00#;
    constant MB_OFF_ARG0     : integer := 16#04#;
    constant MB_OFF_ARG1     : integer := 16#08#;
    constant MB_OFF_STATUS   : integer := 16#0C#;
    constant MB_OFF_RESULT   : integer := 16#10#;
    constant MB_OFF_SEQ_ID   : integer := 16#14#;
    constant MB_OFF_TRIGGER  : integer := 16#18#;

    constant MB_CMD_PUTC   : std_logic_vector(31 downto 0) := x"00000001";
    constant MB_CMD_EXIT   : std_logic_vector(31 downto 0) := x"00000002";
    constant MB_CMD_RESULT : std_logic_vector(31 downto 0) := x"00000003";

    constant MB_SENTINEL_ADDR : std_logic_vector(31 downto 0) := x"80008000";
    constant MB_SENTINEL_SUCCESS : std_logic_vector(31 downto 0) := x"CAFE0000";
    constant MB_SENTINEL_TIMEOUT : std_logic_vector(31 downto 0) := x"DEAD0000";
    constant MB_TRIGGER_MAGIC : std_logic_vector(31 downto 0) := x"0000DEAD";
end package rv32i_pkg;
"""

fn generated_rv32_wrapper_vhdl_text() -> text:
    """library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
use work.simple_rv32i_core_pkg.all;

entity rv32i_core is
    generic (
        RESET_ADDR : std_logic_vector(31 downto 0) := x"80000000"
    );
    port (
        clk          : in  std_logic;
        reset_n      : in  std_logic;
        imem_addr    : out std_logic_vector(31 downto 0);
        imem_data    : in  std_logic_vector(31 downto 0);
        dmem_addr    : out std_logic_vector(31 downto 0);
        dmem_wdata   : out std_logic_vector(31 downto 0);
        dmem_rdata   : in  std_logic_vector(31 downto 0);
        dmem_we      : out std_logic;
        dmem_re      : out std_logic;
        dmem_width   : out std_logic_vector(1 downto 0);
        halted       : out std_logic;
        semi_trigger : out std_logic;
        semi_op      : out std_logic_vector(31 downto 0);
        semi_param   : out std_logic_vector(31 downto 0)
    );
end entity rv32i_core;

architecture rtl of rv32i_core is
    signal dmem_wstrb_i : std_logic_vector(3 downto 0);
    signal debug_pc_i   : std_logic_vector(31 downto 0);
    signal trap_i       : std_logic;
    signal halt_i       : std_logic;
begin
    u_core : entity work.simple_rv32gc_core
        port map (
            clk        => clk,
            reset_n    => reset_n,
            imem_addr  => imem_addr,
            imem_rdata => imem_data,
            dmem_addr  => dmem_addr,
            dmem_wdata => dmem_wdata,
            dmem_rdata => dmem_rdata,
            dmem_we    => dmem_we,
            dmem_re    => dmem_re,
            dmem_width => dmem_width,
            dmem_wstrb => dmem_wstrb_i,
            irq_software => '0',
            irq_timer  => '0',
            irq_external => '0',
            mmu_dmem_l2_pte => (others => '0'),
            mmu_dmem_l1_pte => (others => '0'),
            mmu_dmem_l0_pte => (others => '0'),
            debug_pc   => debug_pc_i,
            semi_trigger => semi_trigger,
            semi_op    => semi_op,
            semi_param => semi_param,
            trap       => trap_i,
            halt       => halt_i
        );

    halted <= halt_i or trap_i;
end architecture rtl;
"""

fn generated_rv32_linux_handoff_testbench_vhdl_text() -> text:
    """library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
use work.test_program.all;
use work.simple_rv32i_core_pkg.all;

entity tb_generated_rv32_linux_handoff is
    generic (
        MAX_CYCLES : integer := 200000
    );
end entity tb_generated_rv32_linux_handoff;

architecture sim of tb_generated_rv32_linux_handoff is
    constant CLK_PERIOD : time := 10 ns;
    constant MEM_WORDS  : integer := 2048;
    constant PASS_ADDR  : integer := 16#100#;
    constant A0_ADDR    : integer := 16#110#;
    constant A1_ADDR    : integer := 16#114#;
    constant UART_ADDR  : std_logic_vector(31 downto 0) := x"10000000";
    constant UART_MAGIC : std_logic_vector(31 downto 0) := x"48584E4C";
    constant BOOT_A0    : std_logic_vector(31 downto 0) := x"00000000";
    constant BOOT_A1    : std_logic_vector(31 downto 0) := x"88000000";

    signal clk        : std_logic := '0';
    signal reset_n    : std_logic := '0';
    signal imem_addr  : std_logic_vector(31 downto 0) := (others => '0');
    signal imem_data  : std_logic_vector(31 downto 0) := (others => '0');
    signal dmem_addr  : std_logic_vector(31 downto 0) := (others => '0');
    signal dmem_wdata : std_logic_vector(31 downto 0) := (others => '0');
    signal dmem_rdata : std_logic_vector(31 downto 0) := (others => '0');
    signal dmem_we    : std_logic := '0';
    signal dmem_re    : std_logic := '0';
    signal dmem_width : std_logic_vector(1 downto 0) := (others => '0');
    signal dmem_wstrb : std_logic_vector(3 downto 0) := (others => '0');
    signal trap       : std_logic := '0';
    signal halt       : std_logic := '0';

    type mem_t is array (0 to MEM_WORDS - 1) of std_logic_vector(31 downto 0);

    function safe_index(bits : std_logic_vector) return integer is
    begin
        for i in bits'range loop
            if bits(i) /= '0' and bits(i) /= '1' then
                return 0;
            end if;
        end loop;
        return to_integer(unsigned(bits));
    end function;

    function word32_to_report_int(word_val : std_logic_vector(31 downto 0)) return integer is
    begin
        if word_val(31) = '1' then
            return -1;
        end if;
        return safe_index(word_val(30 downto 0));
    end function;

    function mem_word_index(addr : std_logic_vector(31 downto 0)) return integer is
    begin
        return safe_index(addr(12 downto 2));
    end function;

    function init_mem return mem_t is
        variable m : mem_t := (others => x"00000013");
    begin
        for i in 0 to PROGRAM_SIZE - 1 loop
            if i < MEM_WORDS then
                m(i) := PROGRAM_DATA(i);
            end if;
        end loop;
        return m;
    end function;

    signal mem : mem_t := init_mem;
    signal uart_word : std_logic_vector(31 downto 0) := (others => '0');
    signal uart_count : integer range 0 to 4 := 0;
    signal done : boolean := false;
begin
    u_cpu : entity work.simple_rv32gc_core
        port map (
            clk        => clk,
            reset_n    => reset_n,
            imem_addr  => imem_addr,
            imem_rdata => imem_data,
            dmem_addr  => dmem_addr,
            dmem_wdata => dmem_wdata,
            dmem_rdata => dmem_rdata,
            dmem_we    => dmem_we,
            dmem_re    => dmem_re,
            dmem_width => dmem_width,
            dmem_wstrb => dmem_wstrb,
            irq_software => '0',
            irq_timer  => '0',
            irq_external => '0',
            trap       => trap,
            halt       => halt
        );

    clk <= not clk after CLK_PERIOD / 2 when not done else '0';

    imem_data <= mem(mem_word_index(imem_addr))
        when mem_word_index(imem_addr) < MEM_WORDS
        else x"00000013";

    process(clk)
        variable word_idx : integer;
        variable current_word : std_logic_vector(31 downto 0);
    begin
        if rising_edge(clk) then
            if dmem_we = '1' and dmem_addr = UART_ADDR and dmem_wstrb(0) = '1' then
                if uart_count < 4 then
                    uart_word((uart_count * 8) + 7 downto uart_count * 8) <= dmem_wdata(7 downto 0);
                    uart_count <= uart_count + 1;
                end if;
            elsif dmem_we = '1' then
                report "DMEM_WRITE_ADDR_HEX32: " & to_hstring(dmem_addr);
                report "DMEM_WRITE_DATA_HEX32: " & to_hstring(dmem_wdata);
                report "DMEM_WRITE_WSTRB_HEX4: " & to_hstring(dmem_wstrb);
                word_idx := mem_word_index(dmem_addr);
                if word_idx < MEM_WORDS then
                    current_word := mem(word_idx);
                    for i in 0 to 3 loop
                        if dmem_wstrb(i) = '1' then
                            current_word((i * 8) + 7 downto i * 8) := dmem_wdata((i * 8) + 7 downto i * 8);
                        end if;
                    end loop;
                    mem(word_idx) <= current_word;
                end if;
            end if;
        end if;
    end process;

    dmem_rdata <= mem(mem_word_index(dmem_addr))
        when mem_word_index(dmem_addr) < MEM_WORDS
        else (others => '0');

    process
        variable cycles : integer := 0;
        variable pass_value : integer;
        variable a0_value : integer;
        variable a1_value : integer;
    begin
        reset_n <= '0';
        wait for CLK_PERIOD * 5;
        reset_n <= '1';

        while halt = '0' and trap = '0' and cycles < MAX_CYCLES loop
            wait for CLK_PERIOD;
            cycles := cycles + 1;
        end loop;

        pass_value := word32_to_report_int(mem(PASS_ADDR / 4));
        a0_value := word32_to_report_int(mem(A0_ADDR / 4));
        a1_value := word32_to_report_int(mem(A1_ADDR / 4));
        report "CYCLES: " & integer'image(cycles);
        report "PASS_WORD: " & integer'image(pass_value);
        report "A0_LOW32: " & integer'image(a0_value);
        report "A1_LOW32: " & integer'image(a1_value);
        report "UART_BYTES_LOW32: " & integer'image(word32_to_report_int(uart_word));
        if halt = '1' and pass_value = 42 and mem(A0_ADDR / 4) = BOOT_A0 and mem(A1_ADDR / 4) = BOOT_A1 and uart_word = UART_MAGIC then
            report "GENERATED_RV32_LINUX_HANDOFF: PASS";
        else
            report "GENERATED_RV32_LINUX_HANDOFF: FAIL";
        end if;
        done <= true;
        wait;
    end process;
end architecture sim;
"""

fn generated_rv64_fw_jump_testbench_template() -> text:
    """library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
use work.test_program.all;
use work.simple_rv64i_core_pkg.all;

entity tb_generated_rv64_fw_jump is
    generic (
        MAX_CYCLES : integer := 300000
    );
end entity tb_generated_rv64_fw_jump;

architecture sim of tb_generated_rv64_fw_jump is
    constant CLK_PERIOD : time := 10 ns;
    constant MEM_WORDS  : integer := 270000;
    constant PASS_ADDR_BITS : std_logic_vector(63 downto 0) := x"0000000080200100";
    constant A0_ADDR_BITS   : std_logic_vector(63 downto 0) := x"0000000080200110";
    constant A1_ADDR_BITS   : std_logic_vector(63 downto 0) := x"0000000080200118";
    constant UART_ADDR  : std_logic_vector(63 downto 0) := x"0000000010000000";
    constant UART_MAGIC : std_logic_vector(31 downto 0) := x"544F4253";
    constant BOOT_A0    : std_logic_vector(63 downto 0) := x"0000000000000000";
    constant BOOT_A1    : std_logic_vector(63 downto 0) := x"0000000088000000";

    signal clk        : std_logic := '0';
    signal reset_n    : std_logic := '0';
    signal imem_addr  : std_logic_vector(63 downto 0) := (others => '0');
    signal imem_data  : std_logic_vector(31 downto 0) := (others => '0');
    signal dmem_addr  : std_logic_vector(63 downto 0) := (others => '0');
    signal dmem_wdata : std_logic_vector(63 downto 0) := (others => '0');
    signal dmem_rdata : std_logic_vector(63 downto 0) := (others => '0');
    signal dmem_we    : std_logic := '0';
    signal dmem_re    : std_logic := '0';
    signal dmem_width : std_logic_vector(1 downto 0) := (others => '0');
    signal dmem_wstrb : std_logic_vector(7 downto 0) := (others => '0');
    signal irq_software : std_logic := '0';
    signal irq_timer    : std_logic := '0';
    signal irq_external : std_logic := '0';
    signal debug_priv_mode : std_logic_vector(1 downto 0) := (others => '0');
    signal debug_last_load_value : std_logic_vector(63 downto 0) := (others => '0');
    signal debug_pc   : std_logic_vector(63 downto 0) := (others => '0');
    signal trap       : std_logic := '0';
    signal halt       : std_logic := '0';

    type mem_t is array (0 to MEM_WORDS - 1) of std_logic_vector(63 downto 0);

    function init_mem return mem_t is
        variable m : mem_t := (others => x"0000001300000013");
        variable word_idx : integer;
        variable byte_idx : integer;
        variable current_word : std_logic_vector(63 downto 0);
    begin
        for i in 0 to FW_SIZE_BYTES - 1 loop
            word_idx := i / 8;
            byte_idx := i mod 8;
            if word_idx < MEM_WORDS then
                current_word := m(word_idx);
                current_word((byte_idx * 8) + 7 downto byte_idx * 8) := FW_BYTES(i);
                m(word_idx) := current_word;
            end if;
        end loop;
        for i in 0 to PAYLOAD_SIZE_BYTES - 1 loop
            word_idx := (16#200000# + i) / 8;
            byte_idx := (16#200000# + i) mod 8;
            if word_idx < MEM_WORDS then
                current_word := m(word_idx);
                current_word((byte_idx * 8) + 7 downto byte_idx * 8) := PAYLOAD_BYTES(i);
                m(word_idx) := current_word;
            end if;
        end loop;
        return m;
    end function;

    function safe_index(bits : std_logic_vector) return integer is
    begin
        for i in bits'range loop
            if bits(i) /= '0' and bits(i) /= '1' then
                return 0;
            end if;
        end loop;
        return to_integer(unsigned(bits));
    end function;

    function word32_to_report_int(word_val : std_logic_vector(31 downto 0)) return integer is
    begin
        if word_val(31) = '1' then
            return -1;
        end if;
        return safe_index(word_val(30 downto 0));
    end function;

    function mem_index(addr : std_logic_vector(63 downto 0)) return integer is
    begin
        return safe_index(addr(21 downto 3));
    end function;

    function fetch_imem_word(mem_state : mem_t; addr : std_logic_vector(63 downto 0)) return std_logic_vector is
        variable idx : integer;
        variable next_idx : integer;
        variable current_word : std_logic_vector(63 downto 0);
        variable next_word : std_logic_vector(63 downto 0) := x"0000001300000013";
        variable result : std_logic_vector(31 downto 0) := x"00000013";
    begin
        idx := mem_index(addr);
        if idx >= MEM_WORDS then
            return result;
        end if;
        current_word := mem_state(idx);
        case addr(2 downto 1) is
            when "00" => result := current_word(31 downto 0);
            when "01" => result := current_word(47 downto 16);
            when "10" => result := current_word(63 downto 32);
            when others =>
                next_idx := idx + 1;
                if next_idx < MEM_WORDS then
                    next_word := mem_state(next_idx);
                end if;
                result(15 downto 0) := current_word(63 downto 48);
                result(31 downto 16) := next_word(15 downto 0);
        end case;
        return result;
    end function;

    signal mem : mem_t := init_mem;
    signal uart_word : std_logic_vector(31 downto 0) := (others => '0');
    signal uart_count : integer range 0 to 4 := 0;
    signal done : boolean := false;
begin
    u_cpu : entity work.simple_rv64gc_core
        port map (
            clk        => clk,
            reset_n    => reset_n,
            imem_addr  => imem_addr,
            imem_rdata => imem_data,
            dmem_addr  => dmem_addr,
            dmem_wdata => dmem_wdata,
            dmem_rdata => dmem_rdata,
            dmem_we    => dmem_we,
            dmem_re    => dmem_re,
            dmem_width => dmem_width,
            dmem_wstrb => dmem_wstrb,
            irq_software => irq_software,
            irq_timer  => irq_timer,
            irq_external => irq_external,
            mmu_dmem_l2_pte => (others => '0'),
            mmu_dmem_l1_pte => (others => '0'),
            mmu_dmem_l0_pte => (others => '0'),
            debug_priv_mode => debug_priv_mode,
            debug_last_load_value => debug_last_load_value,
            debug_pc   => debug_pc,
            trap       => trap,
            halt       => halt
        );

    clk <= not clk after CLK_PERIOD / 2 when not done else '0';

    imem_data <= fetch_imem_word(mem, imem_addr);

    process(clk)
        variable word_idx : integer;
        variable current_word : std_logic_vector(63 downto 0);
    begin
        if rising_edge(clk) then
            if dmem_we = '1' and dmem_addr = UART_ADDR and dmem_wstrb(0) = '1' then
                if uart_count < 4 then
                    uart_word((uart_count * 8) + 7 downto uart_count * 8) <= dmem_wdata(7 downto 0);
                    uart_count <= uart_count + 1;
                end if;
            elsif dmem_we = '1' then
                word_idx := mem_index(dmem_addr);
                if word_idx < MEM_WORDS then
                    current_word := mem(word_idx);
                    for i in 0 to 7 loop
                        if dmem_wstrb(i) = '1' then
                            current_word((i * 8) + 7 downto i * 8) := dmem_wdata((i * 8) + 7 downto i * 8);
                        end if;
                    end loop;
                    mem(word_idx) <= current_word;
                end if;
            end if;
        end if;
    end process;

    dmem_rdata <= mem(mem_index(dmem_addr))
        when mem_index(dmem_addr) < MEM_WORDS
        else (others => '0');

    process
        variable cycles : integer := 0;
        variable pass_value : integer;
        variable a0_low_value : integer;
        variable a1_low_value : integer;
        variable a1_high_value : integer;
    begin
        reset_n <= '0';
        wait for CLK_PERIOD * 5;
        reset_n <= '1';

        while halt = '0' and trap = '0' and cycles < MAX_CYCLES loop
            wait for CLK_PERIOD;
            cycles := cycles + 1;
        end loop;

        pass_value := word32_to_report_int(mem(mem_index(PASS_ADDR_BITS))(31 downto 0));
        a0_low_value := word32_to_report_int(mem(mem_index(A0_ADDR_BITS))(31 downto 0));
        a1_low_value := word32_to_report_int(mem(mem_index(A1_ADDR_BITS))(31 downto 0));
        a1_high_value := word32_to_report_int(mem(mem_index(A1_ADDR_BITS))(63 downto 32));
        report "CYCLES: " & integer'image(cycles);
        report "PASS_WORD: " & integer'image(pass_value);
        report "A0_LOW32: " & integer'image(a0_low_value);
        report "A1_LOW32: " & integer'image(a1_low_value);
        report "A1_HIGH32: " & integer'image(a1_high_value);
        report "UART_BYTES_LOW32: " & integer'image(word32_to_report_int(uart_word));
        report "PRIV_MODE: " & integer'image(safe_index(debug_priv_mode));
        report "PC_LOW32: " & integer'image(word32_to_report_int(debug_pc(31 downto 0)));
        if halt = '1' and pass_value = 42 and uart_word = UART_MAGIC and mem(mem_index(A0_ADDR_BITS)) = BOOT_A0 and mem(mem_index(A1_ADDR_BITS)) = BOOT_A1 and debug_priv_mode = "01" then
            report "GENERATED_RV64_FW_JUMP: PASS";
        else
            report "GENERATED_RV64_FW_JUMP: FAIL";
        end if;
        done <= true;
        wait;
    end process;
end architecture sim;
"""

fn generated_rv64_linux_handoff_testbench_template() -> text:
    """library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
use work.test_program.all;
use work.simple_rv64i_core_pkg.all;

entity tb_generated_rv64_linux_handoff is
    generic (
        MAX_CYCLES : integer := 200000
    );
end entity tb_generated_rv64_linux_handoff;

architecture sim of tb_generated_rv64_linux_handoff is
    constant CLK_PERIOD : time := 10 ns;
    constant MEM_WORDS  : integer := 8192;
    constant PASS_ADDR  : integer := 16#100#;
    constant FAIL_ADDR  : integer := 16#108#;
    constant A0_ADDR    : integer := 16#110#;
    constant A1_ADDR    : integer := 16#118#;
    constant UART_ADDR  : std_logic_vector(63 downto 0) := x"0000000010000000";
    constant UART_MAGIC : std_logic_vector(31 downto 0) := x"48584E4C";
    constant BOOT_A0    : std_logic_vector(63 downto 0) := x"0000000000000000";
    constant BOOT_A1    : std_logic_vector(63 downto 0) := x"0000000088000000";

    signal clk        : std_logic := '0';
    signal reset_n    : std_logic := '0';
    signal imem_addr  : std_logic_vector(63 downto 0) := (others => '0');
    signal imem_data  : std_logic_vector(31 downto 0) := (others => '0');
    signal dmem_addr  : std_logic_vector(63 downto 0) := (others => '0');
    signal dmem_wdata : std_logic_vector(63 downto 0) := (others => '0');
    signal dmem_rdata : std_logic_vector(63 downto 0) := (others => '0');
    signal dmem_we    : std_logic := '0';
    signal dmem_re    : std_logic := '0';
    signal dmem_width : std_logic_vector(1 downto 0) := (others => '0');
    signal dmem_wstrb : std_logic_vector(7 downto 0) := (others => '0');
    signal irq_software : std_logic := '0';
    signal irq_timer    : std_logic := '0';
    signal irq_external : std_logic := '0';
    signal debug_priv_mode : std_logic_vector(1 downto 0) := (others => '0');
    signal debug_last_load_value : std_logic_vector(63 downto 0) := (others => '0');
    signal debug_pc   : std_logic_vector(63 downto 0) := (others => '0');
    signal trap       : std_logic := '0';
    signal halt       : std_logic := '0';

    type mem_t is array (0 to MEM_WORDS - 1) of std_logic_vector(63 downto 0);

    function init_mem return mem_t is
        variable m : mem_t := (others => x"0000001300000013");
        variable word_idx : integer;
        variable byte_idx : integer;
        variable current_word : std_logic_vector(63 downto 0);
    begin
        for i in 0 to PROGRAM_SIZE_BYTES - 1 loop
            word_idx := i / 8;
            byte_idx := i mod 8;
            current_word := m(word_idx);
            current_word((byte_idx * 8) + 7 downto byte_idx * 8) := PROGRAM_BYTES(i);
            m(word_idx) := current_word;
        end loop;
        return m;
    end function;

    function safe_index(bits : std_logic_vector) return integer is
    begin
        for i in bits'range loop
            if bits(i) /= '0' and bits(i) /= '1' then
                return 0;
            end if;
        end loop;
        return to_integer(unsigned(bits));
    end function;

    function word32_to_report_int(word_val : std_logic_vector(31 downto 0)) return integer is
    begin
        if word_val(31) = '1' then
            return -1;
        end if;
        return safe_index(word_val(30 downto 0));
    end function;

    function fetch_imem_word(mem_state : mem_t; addr : std_logic_vector(63 downto 0)) return std_logic_vector is
        variable idx : integer;
        variable next_idx : integer;
        variable current_word : std_logic_vector(63 downto 0);
        variable next_word : std_logic_vector(63 downto 0) := x"0000001300000013";
        variable result : std_logic_vector(31 downto 0) := x"00000013";
    begin
        idx := safe_index(addr(15 downto 3));
        if idx >= MEM_WORDS then
            return result;
        end if;
        current_word := mem_state(idx);
        case addr(2 downto 1) is
            when "00" => result := current_word(31 downto 0);
            when "01" => result := current_word(47 downto 16);
            when "10" => result := current_word(63 downto 32);
            when others =>
                next_idx := idx + 1;
                if next_idx < MEM_WORDS then
                    next_word := mem_state(next_idx);
                end if;
                result(15 downto 0) := current_word(63 downto 48);
                result(31 downto 16) := next_word(15 downto 0);
        end case;
        return result;
    end function;

    signal mem : mem_t := init_mem;
    signal uart_word : std_logic_vector(31 downto 0) := (others => '0');
    signal uart_count : integer range 0 to 4 := 0;
    signal done : boolean := false;
begin
    u_cpu : entity work.simple_rv64gc_core
        port map (
            clk        => clk,
            reset_n    => reset_n,
            imem_addr  => imem_addr,
            imem_rdata => imem_data,
            dmem_addr  => dmem_addr,
            dmem_wdata => dmem_wdata,
            dmem_rdata => dmem_rdata,
            dmem_we    => dmem_we,
            dmem_re    => dmem_re,
            dmem_width => dmem_width,
            dmem_wstrb => dmem_wstrb,
            irq_software => irq_software,
            irq_timer  => irq_timer,
            irq_external => irq_external,
            mmu_dmem_l2_pte => (others => '0'),
            mmu_dmem_l1_pte => (others => '0'),
            mmu_dmem_l0_pte => (others => '0'),
            debug_priv_mode => debug_priv_mode,
            debug_last_load_value => debug_last_load_value,
            debug_pc   => debug_pc,
            trap       => trap,
            halt       => halt
        );

    clk <= not clk after CLK_PERIOD / 2 when not done else '0';
    imem_data <= fetch_imem_word(mem, imem_addr);

    process(clk)
        variable word_idx : integer;
        variable current_word : std_logic_vector(63 downto 0);
    begin
        if rising_edge(clk) then
            if dmem_we = '1' and dmem_addr = UART_ADDR and dmem_wstrb(0) = '1' then
                if uart_count < 4 then
                    uart_word((uart_count * 8) + 7 downto uart_count * 8) <= dmem_wdata(7 downto 0);
                    uart_count <= uart_count + 1;
                end if;
            elsif dmem_we = '1' then
                word_idx := safe_index(dmem_addr(15 downto 3));
                if word_idx < MEM_WORDS then
                    current_word := mem(word_idx);
                    for i in 0 to 7 loop
                        if dmem_wstrb(i) = '1' then
                            current_word((i * 8) + 7 downto i * 8) := dmem_wdata((i * 8) + 7 downto i * 8);
                        end if;
                    end loop;
                    mem(word_idx) <= current_word;
                end if;
            end if;
        end if;
    end process;

    dmem_rdata <= mem(safe_index(dmem_addr(15 downto 3)))
        when safe_index(dmem_addr(15 downto 3)) < MEM_WORDS
        else (others => '0');

    process
        variable cycles : integer := 0;
        variable pass_value : integer;
        variable fail_value : integer;
        variable a0_low_value : integer;
        variable a1_low_value : integer;
        variable a1_high_value : integer;
    begin
        reset_n <= '0';
        wait for CLK_PERIOD * 5;
        reset_n <= '1';

        while halt = '0' and trap = '0' and cycles < MAX_CYCLES loop
            wait for CLK_PERIOD;
            cycles := cycles + 1;
        end loop;

        pass_value := word32_to_report_int(mem(PASS_ADDR / 8)(31 downto 0));
        fail_value := word32_to_report_int(mem(FAIL_ADDR / 8)(31 downto 0));
        a0_low_value := word32_to_report_int(mem(A0_ADDR / 8)(31 downto 0));
        a1_low_value := word32_to_report_int(mem(A1_ADDR / 8)(31 downto 0));
        a1_high_value := word32_to_report_int(mem(A1_ADDR / 8)(63 downto 32));
        report "CYCLES: " & integer'image(cycles);
        report "PASS_WORD: " & integer'image(pass_value);
        report "FAIL_WORD: " & integer'image(fail_value);
        report "A0_LOW32: " & integer'image(a0_low_value);
        report "A1_LOW32: " & integer'image(a1_low_value);
        report "A1_HIGH32: " & integer'image(a1_high_value);
        report "UART_BYTES_LOW32: " & integer'image(word32_to_report_int(uart_word));
        if halt = '1' and pass_value = 42 and uart_word = UART_MAGIC and mem(A0_ADDR / 8) = BOOT_A0 and mem(A1_ADDR / 8) = BOOT_A1 then
            report "GENERATED_RV64_LINUX_HANDOFF: PASS";
        else
            report "GENERATED_RV64_LINUX_HANDOFF: FAIL";
        end if;
        done <= true;
        wait;
    end process;
end architecture sim;
"""

fn generated_rv32_boot_info_real_dtb_testbench_vhdl_text() -> text:
    """library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
use work.test_program.all;
use work.simple_rv32i_core_pkg.all;

entity tb_generated_rv32_boot_info_real_dtb is
    generic (
        MAX_CYCLES : integer := 200000
    );
end entity tb_generated_rv32_boot_info_real_dtb;

architecture sim of tb_generated_rv32_boot_info_real_dtb is
    constant CLK_PERIOD : time := 10 ns;
    constant MEM_WORDS  : integer := 2048;
    constant PASS_ADDR      : integer := 16#100#;
    constant A0_ADDR        : integer := 16#110#;
    constant A1_ADDR        : integer := 16#114#;
    constant DTB_VALID_ADDR : integer := 16#118#;
    constant SATP_ADDR      : integer := 16#11C#;
    constant UART_ADDR      : std_logic_vector(31 downto 0) := x"10000000";
    constant UART_MAGIC     : std_logic_vector(31 downto 0) := x"42544452";
    constant BOOT_A0        : std_logic_vector(31 downto 0) := x"00000000";
    constant BOOT_A1        : std_logic_vector(31 downto 0) := x"88000000";
    constant DTB_BASE_ADDR  : std_logic_vector(31 downto 0) := x"88000000";
    constant DTB_SIZE_BYTES : integer := 32;

    signal clk        : std_logic := '0';
    signal reset_n    : std_logic := '0';
    signal imem_addr  : std_logic_vector(31 downto 0) := (others => '0');
    signal imem_data  : std_logic_vector(31 downto 0) := (others => '0');
    signal dmem_addr  : std_logic_vector(31 downto 0) := (others => '0');
    signal dmem_wdata : std_logic_vector(31 downto 0) := (others => '0');
    signal dmem_rdata : std_logic_vector(31 downto 0) := (others => '0');
    signal dmem_we    : std_logic := '0';
    signal dmem_re    : std_logic := '0';
    signal dmem_width : std_logic_vector(1 downto 0) := (others => '0');
    signal dmem_wstrb : std_logic_vector(3 downto 0) := (others => '0');
    signal trap       : std_logic := '0';
    signal halt       : std_logic := '0';

    type mem_t is array (0 to MEM_WORDS - 1) of std_logic_vector(31 downto 0);
    type byte_array_t is array (0 to DTB_SIZE_BYTES - 1) of std_logic_vector(7 downto 0);
    constant DTB_BYTES : byte_array_t := (
        x"D0", x"0D", x"FE", x"ED",
        x"00", x"00", x"00", x"20",
        x"00", x"00", x"00", x"20",
        x"00", x"00", x"00", x"00",
        x"00", x"00", x"00", x"00",
        x"00", x"00", x"00", x"00",
        x"00", x"00", x"00", x"00",
        x"00", x"00", x"00", x"00"
    );

    function safe_index(bits : std_logic_vector) return integer is
    begin
        for i in bits'range loop
            if bits(i) /= '0' and bits(i) /= '1' then
                return 0;
            end if;
        end loop;
        return to_integer(unsigned(bits));
    end function;

    function word32_to_report_int(word_val : std_logic_vector(31 downto 0)) return integer is
    begin
        if word_val(31) = '1' then
            return -1;
        end if;
        return safe_index(word_val(30 downto 0));
    end function;

    function hex_char(nibble : std_logic_vector(3 downto 0)) return character is
        variable idx : integer;
    begin
        idx := safe_index(nibble);
        case idx is
            when 0 => return '0';
            when 1 => return '1';
            when 2 => return '2';
            when 3 => return '3';
            when 4 => return '4';
            when 5 => return '5';
            when 6 => return '6';
            when 7 => return '7';
            when 8 => return '8';
            when 9 => return '9';
            when 10 => return 'A';
            when 11 => return 'B';
            when 12 => return 'C';
            when 13 => return 'D';
            when 14 => return 'E';
            when others => return 'F';
        end case;
    end function;

    function hex8(bits : std_logic_vector(7 downto 0)) return string is
        variable result : string(1 to 2);
    begin
        result(1) := hex_char(bits(7 downto 4));
        result(2) := hex_char(bits(3 downto 0));
        return result;
    end function;

    function mem_word_index(addr : std_logic_vector(31 downto 0)) return integer is
    begin
        return safe_index(addr(12 downto 2));
    end function;

    function init_mem return mem_t is
        variable m : mem_t := (others => x"00000013");
    begin
        for i in 0 to PROGRAM_SIZE - 1 loop
            if i < MEM_WORDS then
                m(i) := PROGRAM_DATA(i);
            end if;
        end loop;
        return m;
    end function;

    function is_dtb_addr(addr : std_logic_vector(31 downto 0)) return boolean is
    begin
        return addr(31 downto 8) = DTB_BASE_ADDR(31 downto 8);
    end function;

    function dtb_word_at(addr : std_logic_vector(31 downto 0)) return std_logic_vector is
        variable out_word : std_logic_vector(31 downto 0) := (others => '0');
        variable offset : integer;
    begin
        offset := safe_index(addr(7 downto 2)) * 4;
        for i in 0 to 3 loop
            if offset + i >= 0 and offset + i < DTB_SIZE_BYTES then
                out_word((i * 8) + 7 downto i * 8) := DTB_BYTES(offset + i);
            end if;
        end loop;
        return out_word;
    end function;

    signal mem : mem_t := init_mem;
    signal uart_word : std_logic_vector(31 downto 0) := (others => '0');
    signal uart_count : integer range 0 to 4 := 0;
    signal dtb_probe_seen : boolean := false;
    signal done : boolean := false;
begin
    u_cpu : entity work.simple_rv32gc_core
        port map (
            clk        => clk,
            reset_n    => reset_n,
            imem_addr  => imem_addr,
            imem_rdata => imem_data,
            dmem_addr  => dmem_addr,
            dmem_wdata => dmem_wdata,
            dmem_rdata => dmem_rdata,
            dmem_we    => dmem_we,
            dmem_re    => dmem_re,
            dmem_width => dmem_width,
            dmem_wstrb => dmem_wstrb,
            irq_software => '0',
            irq_timer  => '0',
            irq_external => '0',
            trap       => trap,
            halt       => halt
        );

    clk <= not clk after CLK_PERIOD / 2 when not done else '0';

    imem_data <= mem(mem_word_index(imem_addr))
        when mem_word_index(imem_addr) < MEM_WORDS
        else x"00000013";

    process(clk)
        variable word_idx : integer;
        variable current_word : std_logic_vector(31 downto 0);
    begin
        if rising_edge(clk) then
            if dmem_re = '1' and is_dtb_addr(dmem_addr) then
                dtb_probe_seen <= true;
                report "DTB_READ_ADDR_HEX32: " & to_hstring(dmem_addr);
                report "DTB_READ_DATA_HEX32: " & to_hstring(dtb_word_at(dmem_addr));
            end if;
            if dmem_we = '1' and dmem_addr = UART_ADDR and dmem_wstrb(0) = '1' then
                report "UART_CHAR_HEX8: " & hex8(dmem_wdata(7 downto 0));
                if uart_count < 4 then
                    uart_word((uart_count * 8) + 7 downto uart_count * 8) <= dmem_wdata(7 downto 0);
                    uart_count <= uart_count + 1;
                end if;
            elsif dmem_we = '1' then
                report "DMEM_WRITE_ADDR_HEX32: " & to_hstring(dmem_addr);
                report "DMEM_WRITE_DATA_HEX32: " & to_hstring(dmem_wdata);
                report "DMEM_WRITE_WSTRB_HEX4: " & to_hstring(dmem_wstrb);
                word_idx := mem_word_index(dmem_addr);
                if word_idx < MEM_WORDS then
                    current_word := mem(word_idx);
                    for i in 0 to 3 loop
                        if dmem_wstrb(i) = '1' then
                            current_word((i * 8) + 7 downto i * 8) := dmem_wdata((i * 8) + 7 downto i * 8);
                        end if;
                    end loop;
                    mem(word_idx) <= current_word;
                end if;
            end if;
        end if;
    end process;

    dmem_rdata <= dtb_word_at(dmem_addr)
        when is_dtb_addr(dmem_addr)
        else mem(mem_word_index(dmem_addr))
        when mem_word_index(dmem_addr) < MEM_WORDS
        else (others => '0');

    process
        variable cycles : integer := 0;
        variable pass_value : integer;
        variable a0_value : integer;
        variable a1_value : integer;
        variable dtb_valid_value : integer;
        variable satp_value : integer;
    begin
        reset_n <= '0';
        wait for CLK_PERIOD * 5;
        reset_n <= '1';

        while halt = '0' and trap = '0' and cycles < MAX_CYCLES loop
            wait for CLK_PERIOD;
            cycles := cycles + 1;
        end loop;

        pass_value := word32_to_report_int(mem(PASS_ADDR / 4));
        a0_value := word32_to_report_int(mem(A0_ADDR / 4));
        a1_value := word32_to_report_int(mem(A1_ADDR / 4));
        dtb_valid_value := word32_to_report_int(mem(DTB_VALID_ADDR / 4));
        satp_value := word32_to_report_int(mem(SATP_ADDR / 4));
        report "CYCLES: " & integer'image(cycles);
        report "PASS_WORD: " & integer'image(pass_value);
        report "A0_LOW32: " & integer'image(a0_value);
        report "A1_LOW32: " & integer'image(a1_value);
        report "DTB_VALID_LOW32: " & integer'image(dtb_valid_value);
        report "SATP_LOW32: " & integer'image(satp_value);
        if dtb_probe_seen then
            report "DTB_PROBE_SEEN: 1";
        else
            report "DTB_PROBE_SEEN: 0";
        end if;
        report "UART_BYTES_LOW32: " & integer'image(word32_to_report_int(uart_word));
        report "FINAL_PC_HEX32: " & to_hstring(imem_addr);
        if halt = '1' then
            report "HALT_SEEN: 1";
        else
            report "HALT_SEEN: 0";
        end if;
        if trap = '1' then
            report "TRAP_SEEN: 1";
        else
            report "TRAP_SEEN: 0";
        end if;
        if halt = '1' and pass_value = 42 and mem(A0_ADDR / 4) = BOOT_A0 and mem(A1_ADDR / 4) = BOOT_A1 and mem(DTB_VALID_ADDR / 4) = x"00000001" and dtb_probe_seen and uart_word = UART_MAGIC then
            report "GENERATED_RV32_BOOT_INFO_REAL_DTB: PASS";
        else
            report "GENERATED_RV32_BOOT_INFO_REAL_DTB: FAIL";
        end if;
        done <= true;
        wait;
    end process;
end architecture sim;
"""

fn generated_rv32_semihost_testbench_vhdl_text() -> text:
    """-- Semihosting test runner -- loads program from test_program package
library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
use std.textio.all;
use work.rv32i_pkg.all;
use work.test_program.all;

entity tb_semi_run is
end entity tb_semi_run;

architecture sim of tb_semi_run is
    constant CLK_PERIOD : time := 10 ns;
    constant MEM_WORDS  : integer := 16384;

    signal clk     : std_logic := '0';
    signal reset_n : std_logic := '0';
    signal imem_addr, dmem_addr     : std_logic_vector(31 downto 0);
    signal imem_data, dmem_wdata    : std_logic_vector(31 downto 0);
    signal dmem_rdata               : std_logic_vector(31 downto 0);
    signal dmem_we, dmem_re         : std_logic;
    signal dmem_width               : std_logic_vector(1 downto 0);
    signal halted                   : std_logic;
    signal semi_trigger             : std_logic;
    signal semi_op, semi_param      : std_logic_vector(31 downto 0);

    type mem_t is array (0 to MEM_WORDS-1) of std_logic_vector(31 downto 0);

    function init_mem return mem_t is
        variable m : mem_t := (others => x"00000013");
    begin
        for i in 0 to PROGRAM_SIZE-1 loop
            m(i) := PROGRAM_DATA(i);
        end loop;
        return m;
    end function;

    signal mem : mem_t := init_mem;
    signal done : boolean := false;
begin
    u_cpu : entity work.rv32i_core
        generic map (RESET_ADDR => x"80000000")
        port map (
            clk=>clk, reset_n=>reset_n,
            imem_addr=>imem_addr, imem_data=>imem_data,
            dmem_addr=>dmem_addr, dmem_wdata=>dmem_wdata,
            dmem_rdata=>dmem_rdata, dmem_we=>dmem_we,
            dmem_re=>dmem_re, dmem_width=>dmem_width,
            halted=>halted,
            semi_trigger=>semi_trigger, semi_op=>semi_op, semi_param=>semi_param
        );

    clk <= not clk after CLK_PERIOD/2 when not done else '0';

    imem_data <= mem(to_integer(unsigned(imem_addr(15 downto 2))))
                 when to_integer(unsigned(imem_addr(15 downto 2))) < MEM_WORDS
                 else x"00000013";

    process(clk)
        variable idx : integer;
    begin
        if rising_edge(clk) then
            if dmem_we = '1' then
                idx := to_integer(unsigned(dmem_addr(15 downto 2)));
                if idx < MEM_WORDS then
                    mem(idx) <= dmem_wdata;
                end if;
            end if;
        end if;
    end process;

    dmem_rdata <= mem(to_integer(unsigned(dmem_addr(15 downto 2))))
                  when dmem_re = '1' and to_integer(unsigned(dmem_addr(15 downto 2))) < MEM_WORDS
                  else (others => '0');

    process
        variable cycles    : integer := 0;
        variable str_addr  : unsigned(15 downto 0);
        variable ch_val    : integer;
        variable word_val  : std_logic_vector(31 downto 0);
        variable byte_off  : integer;
        variable idx       : integer;
        variable out_line  : line;
    begin
        reset_n <= '0';
        wait for CLK_PERIOD * 5;
        reset_n <= '1';

        while halted = '0' and cycles < 500000 loop
            wait until falling_edge(clk);
            cycles := cycles + 1;

            if semi_trigger = '1' then
                if semi_op = SYS_WRITE0 then
                    str_addr := unsigned(semi_param(15 downto 0));
                    for i in 0 to 1023 loop
                        idx := to_integer(str_addr(15 downto 2));
                        if idx < MEM_WORDS then
                            word_val := mem(idx);
                        else
                            word_val := (others => '0');
                        end if;
                        byte_off := to_integer(str_addr(1 downto 0));
                        case byte_off is
                            when 0 => ch_val := to_integer(unsigned(word_val(7 downto 0)));
                            when 1 => ch_val := to_integer(unsigned(word_val(15 downto 8)));
                            when 2 => ch_val := to_integer(unsigned(word_val(23 downto 16)));
                            when 3 => ch_val := to_integer(unsigned(word_val(31 downto 24)));
                            when others => ch_val := 0;
                        end case;
                        exit when ch_val = 0;
                        if ch_val >= 32 and ch_val < 127 then
                            write(out_line, character'val(ch_val));
                        elif ch_val = 10 then
                            write(out_line, string'("\n"));
                        end if;
                        str_addr := str_addr + 1;
                    end loop;
                end if;
            end if;
        end loop;

        report "CYCLES: " & integer'image(cycles);
        report "EXIT_CODE: " & integer'image(to_integer(unsigned(semi_param)));

        if out_line /= null then
            report "OUTPUT: " & out_line.all;
        else
            report "OUTPUT: (empty)";
        end if;

        done <= true;
        wait;
    end process;
end architecture sim;
"""

fn generated_rv32_mailbox_testbench_vhdl_text() -> text:
    """-- Mailbox Testbench for RV32I CPU
-- Memory: unified 64KB at 0x80000000 (remapped internally)
-- Mailbox MMIO registers at 0x80FF0000 (debugger-independent I/O)

library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
use std.textio.all;
use work.rv32i_pkg.all;
use work.test_program.all;

entity tb_mailbox is
    generic (
        MAX_CYCLES : integer := 1000000
    );
end entity tb_mailbox;

architecture sim of tb_mailbox is
    constant CLK_PERIOD : time := 10 ns;
    constant MEM_WORDS  : integer := 16384;

    signal clk     : std_logic := '0';
    signal reset_n : std_logic := '0';
    signal imem_addr, dmem_addr     : std_logic_vector(31 downto 0);
    signal imem_data, dmem_wdata    : std_logic_vector(31 downto 0);
    signal dmem_rdata               : std_logic_vector(31 downto 0);
    signal dmem_we, dmem_re         : std_logic;
    signal dmem_width               : std_logic_vector(1 downto 0);
    signal halted                   : std_logic;
    signal semi_trigger             : std_logic;
    signal semi_op, semi_param      : std_logic_vector(31 downto 0);

    type mem_t is array (0 to MEM_WORDS-1) of std_logic_vector(31 downto 0);

    function init_mem return mem_t is
        variable m : mem_t := (others => x"00000013");
    begin
        for i in 0 to PROGRAM_SIZE-1 loop
            m(i) := PROGRAM_DATA(i);
        end loop;
        return m;
    end function;

    signal mem : mem_t := init_mem;
    signal done : boolean := false;
    signal mb_cmd     : std_logic_vector(31 downto 0) := (others => '0');
    signal mb_arg0    : std_logic_vector(31 downto 0) := (others => '0');
    signal mb_arg1    : std_logic_vector(31 downto 0) := (others => '0');
    signal mb_status  : std_logic_vector(31 downto 0) := (others => '0');
    signal mb_result  : std_logic_vector(31 downto 0) := (others => '0');
    signal mb_seq_id  : std_logic_vector(31 downto 0) := (others => '0');
    signal mb_trigger : std_logic_vector(31 downto 0) := (others => '0');

    constant MB_BASE : unsigned(31 downto 0) := x"80FF0000";

    function is_mailbox_addr(addr : std_logic_vector(31 downto 0)) return boolean is
    begin
        return unsigned(addr) >= MB_BASE and
               unsigned(addr) <= (MB_BASE + x"0000001B");
    end function;

    function mb_offset(addr : std_logic_vector(31 downto 0)) return integer is
    begin
        return to_integer(unsigned(addr) - MB_BASE);
    end function;

begin
    u_cpu : entity work.rv32i_core
        generic map (RESET_ADDR => x"80000000")
        port map (
            clk=>clk, reset_n=>reset_n,
            imem_addr=>imem_addr, imem_data=>imem_data,
            dmem_addr=>dmem_addr, dmem_wdata=>dmem_wdata,
            dmem_rdata=>dmem_rdata, dmem_we=>dmem_we,
            dmem_re=>dmem_re, dmem_width=>dmem_width,
            halted=>halted,
            semi_trigger=>semi_trigger, semi_op=>semi_op, semi_param=>semi_param
        );

    clk <= not clk after CLK_PERIOD/2 when not done else '0';

    imem_data <= mem(to_integer(unsigned(imem_addr(15 downto 2))))
                 when to_integer(unsigned(imem_addr(15 downto 2))) < MEM_WORDS
                 else x"00000013";

    process(clk)
        variable idx    : integer;
        variable offset : integer;
    begin
        if rising_edge(clk) then
            if dmem_we = '1' then
                if is_mailbox_addr(dmem_addr) then
                    offset := mb_offset(dmem_addr);
                    case offset is
                        when 16#00# => mb_cmd     <= dmem_wdata;
                        when 16#04# => mb_arg0    <= dmem_wdata;
                        when 16#08# => mb_arg1    <= dmem_wdata;
                        when 16#0C# => mb_status  <= dmem_wdata;
                        when 16#10# => mb_result  <= dmem_wdata;
                        when 16#14# => mb_seq_id  <= dmem_wdata;
                        when 16#18# => mb_trigger <= dmem_wdata;
                        when others => null;
                    end case;
                else
                    idx := to_integer(unsigned(dmem_addr(15 downto 2)));
                    if idx < MEM_WORDS then
                        mem(idx) <= dmem_wdata;
                    end if;
                end if;
            end if;
        end if;
    end process;

    dmem_rdata <= mb_cmd    when dmem_re = '1' and is_mailbox_addr(dmem_addr) and mb_offset(dmem_addr) = 16#00# else
                  mb_arg0   when dmem_re = '1' and is_mailbox_addr(dmem_addr) and mb_offset(dmem_addr) = 16#04# else
                  mb_arg1   when dmem_re = '1' and is_mailbox_addr(dmem_addr) and mb_offset(dmem_addr) = 16#08# else
                  mb_status when dmem_re = '1' and is_mailbox_addr(dmem_addr) and mb_offset(dmem_addr) = 16#0C# else
                  mb_result when dmem_re = '1' and is_mailbox_addr(dmem_addr) and mb_offset(dmem_addr) = 16#10# else
                  mb_seq_id when dmem_re = '1' and is_mailbox_addr(dmem_addr) and mb_offset(dmem_addr) = 16#14# else
                  mb_trigger when dmem_re = '1' and is_mailbox_addr(dmem_addr) and mb_offset(dmem_addr) = 16#18# else
                  mem(to_integer(unsigned(dmem_addr(15 downto 2))))
                      when dmem_re = '1' and to_integer(unsigned(dmem_addr(15 downto 2))) < MEM_WORDS else
                  (others => '0');

    process
        variable cycles   : integer := 0;
        variable ch_val   : integer;
        variable out_line : line;
        variable sentinel : std_logic_vector(31 downto 0);
        variable last_seq_id : std_logic_vector(31 downto 0) := (others => '0');
        constant SENTINEL_IDX : integer := 16#8000# / 4;
    begin
        reset_n <= '0';
        wait for CLK_PERIOD * 5;
        reset_n <= '1';

        while not done and cycles < MAX_CYCLES loop
            wait until falling_edge(clk);
            cycles := cycles + 1;

            if mb_trigger = MB_TRIGGER_MAGIC and mb_seq_id /= last_seq_id then
                last_seq_id := mb_seq_id;
                if mb_cmd = MB_CMD_PUTC then
                    ch_val := to_integer(unsigned(mb_arg0(7 downto 0)));
                    if ch_val >= 32 and ch_val < 127 then
                        write(out_line, character'val(ch_val));
                    elsif ch_val = 10 then
                        write(out_line, string'("\n"));
                    end if;
                elsif mb_cmd = MB_CMD_EXIT then
                    sentinel := MB_SENTINEL_SUCCESS or
                                (x"0000" & mb_arg0(15 downto 0));
                    mem(SENTINEL_IDX) <= sentinel;
                    report "SENTINEL: 0x" & to_hstring(unsigned(sentinel));
                    report "EXIT_CODE: " & integer'image(to_integer(unsigned(mb_arg0)));
                    done <= true;
                elsif mb_cmd = MB_CMD_RESULT then
                    report "RESULT: pass=" & integer'image(to_integer(unsigned(mb_arg0))) &
                           " value=" & integer'image(to_integer(unsigned(mb_arg1)));
                end if;
            end if;
        end loop;

        if not done then
            mem(SENTINEL_IDX) <= MB_SENTINEL_TIMEOUT;
            report "SENTINEL: 0x" & to_hstring(unsigned(MB_SENTINEL_TIMEOUT));
            report "TIMEOUT after " & integer'image(cycles) & " cycles";
            done <= true;
        end if;

        report "CYCLES: " & integer'image(cycles);

        if out_line /= null then
            report "OUTPUT: " & out_line.all;
        else
            report "OUTPUT: (empty)";
        end if;

        wait;
    end process;
end architecture sim;
"""

enum RiscvXlen:
    Rv32
    Rv64

enum RiscvReadinessStatus:
    Contract
    RtlGenerated
    QemuBootValidated
    RtlLinuxValidated
    FpgaValidated

impl RiscvReadinessStatus:
    fn to_text() -> text:
        match self:
            Contract: "contract"
            RtlGenerated: "rtl-generated"
            QemuBootValidated: "qemu-boot-validated"
            RtlLinuxValidated: "rtl-linux-validated"
            FpgaValidated: "fpga-validated"

impl RiscvXlen:
    fn bits() -> i64:
        match self:
            Rv32: 32
            Rv64: 64

    fn to_text() -> text:
        match self:
            Rv32: "rv32"
            Rv64: "rv64"

    fn linux_policy() -> text:
        match self:
            Rv32: "repo-native-rv32-linux"
            Rv64: "repo-native-rv64-linux"

    fn mmu_mode() -> text:
        match self:
            Rv32: "sv32"
            Rv64: "sv39"

struct XilinxBoardProfile:
    id: text
    name: text
    part: text
    clock_hz: i64
    reset_polarity: text
    memory_kind: text
    memory_base: i64
    memory_size_bytes: i64
    uart_baud: i64
    constraints_path: text
    programmer: text
    vivado_mode: text

impl XilinxBoardProfile:
    static fn generic() -> XilinxBoardProfile:
        XilinxBoardProfile(
            id: "xilinx_generic",
            name: "xilinx_generic",
            part: "BOARD_PART_TBD",
            clock_hz: 100000000,
            reset_polarity: "active-low",
            memory_kind: "ddr",
            memory_base: 0x80000000,
            memory_size_bytes: 0,
            uart_baud: 115200,
            constraints_path: "constraints/xilinx_generic.xdc",
            programmer: "hw_server",
            vivado_mode: "batch"
        )

    static fn mlk_s02_100t() -> XilinxBoardProfile:
        XilinxBoardProfile(
            id: "mlk_s02_100t",
            name: "mlk_s02_100t",
            part: "xc7a100t-2ffg484i",
            clock_hz: 25000000,
            reset_polarity: "active-low",
            memory_kind: "ddr",
            memory_base: 0x80000000,
            memory_size_bytes: 268435456,
            uart_baud: 115200,
            constraints_path: "examples/09_embedded/fpga_riscv/constraints/mlk_s02_100t.xdc",
            programmer: "openFPGALoader",
            vivado_mode: "batch"
        )

    static fn known_board_ids() -> [text]:
        ["xilinx_generic", "mlk_s02_100t"]

    static fn from_id(board_id: text) -> Result<XilinxBoardProfile, text>:
        if board_id == "xilinx_generic":
            return Ok(XilinxBoardProfile.generic())
        if board_id == "mlk_s02_100t" or board_id == "mlk-s02-100t":
            return Ok(XilinxBoardProfile.mlk_s02_100t())
        Err("unknown xilinx board profile: {board_id}; known boards: {XilinxBoardProfile.known_board_ids().join(\", \")}")

    fn is_generic() -> bool:
        self.id == "xilinx_generic"

    fn validate_for_prepare() -> [text]:
        var errors: [text] = []
        if self.id == "":
            errors.push("board id is required")
        if self.name == "":
            errors.push("board name is required")
        if self.clock_hz <= 0:
            errors.push("clock_hz must be positive")
        if self.reset_polarity != "active-low" and self.reset_polarity != "active-high":
            errors.push("reset_polarity must be active-low or active-high")
        if self.memory_kind != "ddr" and self.memory_kind != "bram":
            errors.push("memory_kind must be ddr or bram")
        if self.uart_baud <= 0:
            errors.push("uart_baud must be positive")
        if self.constraints_path == "":
            errors.push("constraints_path is required")
        if self.programmer == "":
            errors.push("programmer is required")
        if self.vivado_mode != "batch":
            errors.push("vivado_mode must be batch")
        errors

    fn validate_for_hardware_boot() -> [text]:
        var errors = self.validate_for_prepare()
        if self.is_generic():
            errors.push("xilinx part must be selected before hardware boot")
        if self.memory_size_bytes <= 0:
            errors.push("memory_size_bytes must be set before hardware boot")
        errors

struct LinuxArtifactSet:
    kernel_image: text
    rootfs_image: text
    opensbi_image: text
    uboot_image: text
    dtb_path: text
    toolchain_prefix: text

impl LinuxArtifactSet:
    static fn empty() -> LinuxArtifactSet:
        LinuxArtifactSet(
            kernel_image: "",
            rootfs_image: "",
            opensbi_image: "",
            uboot_image: "",
            dtb_path: "",
            toolchain_prefix: ""
        )

    fn configured() -> bool:
        self.kernel_image != "" and self.rootfs_image != "" and self.dtb_path != "" and self.toolchain_prefix != ""

    fn firmware_configured() -> bool:
        self.opensbi_image != "" or self.uboot_image != ""

    fn to_rv64_boot_artifacts() -> Rv64LinuxBootArtifacts:
        Rv64LinuxBootArtifacts(
            opensbi: self.opensbi_image,
            kernel_image: self.kernel_image,
            initrd_rootfs: self.rootfs_image,
            dtb: self.dtb_path,
            uboot: self.uboot_image
        )

    fn to_rv32_boot_artifacts() -> Rv32LinuxBootArtifacts:
        Rv32LinuxBootArtifacts(
            opensbi: self.opensbi_image,
            kernel_image: self.kernel_image,
            initrd_rootfs: self.rootfs_image,
            dtb: self.dtb_path,
            uboot: self.uboot_image
        )

struct RiscvFpgaLane:
    lane_id: text
    xlen: RiscvXlen
    proof_lane_kind: RiscvProofLane
    linux_policy_text: text
    bundle_dir_name: text
    top_module: text
    rtl_dir: text
    rtl_sim_backend: text
    bootrom_path: text
    readiness: RiscvReadinessStatus
    linux_profile: RiscvLinuxProfile
    platform_profile: RiscvPlatformProfile
    scope_note: text
    linux: LinuxArtifactSet

impl RiscvFpgaLane:
    static fn rv64_default() -> RiscvFpgaLane:
        val platform = qemu_virt_rv64_platform_profile()
        RiscvFpgaLane(
            lane_id: "rv64",
            xlen: RiscvXlen.Rv64,
            proof_lane_kind: RiscvProofLane.GeneratedRv64Linux,
            linux_policy_text: "repo-native-rv64-linux",
            bundle_dir_name: "rv64",
            top_module: "simple_rv64gc_core",
            rtl_dir: "build/fpga/rv64/rtl",
            rtl_sim_backend: "ghdl-vhdl-2008",
            bootrom_path: "build/fpga/rv64/bootrom.bin",
            readiness: RiscvReadinessStatus.Contract,
            linux_profile: rv64_qemu_virt_linux_profile(),
            platform_profile: platform,
            scope_note: "repo-native RV64GC generated-core Linux lane",
            linux: LinuxArtifactSet.empty()
        )

    static fn rv32_default() -> RiscvFpgaLane:
        val platform = qemu_virt_rv32_platform_profile()
        RiscvFpgaLane(
            lane_id: "rv32",
            xlen: RiscvXlen.Rv32,
            proof_lane_kind: RiscvProofLane.GeneratedRv32Linux,
            linux_policy_text: "repo-native-rv32-linux",
            bundle_dir_name: "rv32",
            top_module: "simple_rv32gc_core",
            rtl_dir: "build/fpga/rv32/rtl",
            rtl_sim_backend: "ghdl-vhdl-2008",
            bootrom_path: "build/fpga/rv32/bootrom.bin",
            readiness: RiscvReadinessStatus.Contract,
            linux_profile: rv32_qemu_virt_linux_profile(),
            platform_profile: platform,
            scope_note: "repo-native RV32GC generated-core Linux lane",
            linux: LinuxArtifactSet.empty()
        )

    static fn rv32_linux_experimental() -> RiscvFpgaLane:
        RiscvFpgaLane.rv32_default()

    fn proof_lane() -> RiscvProofLane:
        self.proof_lane_kind

    fn linux_policy() -> text:
        self.linux_policy_text

    fn bundle_root_name() -> text:
        self.bundle_dir_name

    fn generated_core_shell_contract() -> GeneratedCoreShellContract:
        if self.proof_lane_kind == RiscvProofLane.GeneratedRv32Linux:
            return GeneratedCoreShellContract.rv32_linux()
        GeneratedCoreShellContract.rv64_linux()

    fn expected_boot_markers() -> [text]:
        var markers: [text] = []
        if self.linux_profile.opensbi_required:
            markers.push("OpenSBI")
        markers.push("Linux version")
        markers.push("OF: fdt")
        markers.push("Freeing unused kernel memory")
        markers.push("init started")
        markers

    fn proof_acceptance_markers() -> [text]:
        self.generated_core_shell_contract().acceptance_markers()

    fn required_soc_blocks() -> [text]:
        var blocks = self.platform_profile.required_soc_blocks()
        blocks.push("generated-core-shell")
        if self.generated_core_shell_contract().semihost_shell_service:
            blocks.push("semihost-shell-service")
        if self.generated_core_shell_contract().mailbox_shell_service:
            blocks.push("mailbox-shell-service")
        blocks

    fn proof_lane_summary() -> text:
        val shell = self.generated_core_shell_contract()
        "{self.proof_lane().to_text()} shell={shell.shell_services_summary()}"

    fn authoritative_rtl_provenance() -> text:
        "simple-compiler-generated"

    fn auxiliary_vhdl_provenance() -> text:
        "emitted-text-vhdl"

    fn runner_testbench_provenance() -> text:
        "emitted-text-vhdl"

    fn validate_for_prepare() -> [text]:
        var errors: [text] = []
        if self.top_module == "":
            errors.push("top_module is required")
        if self.rtl_dir == "":
            errors.push("rtl_dir is required")
        if self.rtl_sim_backend == "":
            errors.push("rtl_sim_backend is required")
        if self.bootrom_path == "":
            errors.push("bootrom_path is required")
        if self.linux_profile.xlen != self.xlen.bits():
            errors.push("linux profile xlen must match lane xlen")
        if self.platform_profile.linux.xlen != self.xlen.bits():
            errors.push("platform profile xlen must match lane xlen")
        errors

    fn validate_for_linux_boot() -> [text]:
        var errors = self.validate_for_prepare()
        if not self.readiness_is_boot_validated():
            errors.push("{self.xlen.to_text()} readiness must be qemu-boot-validated, rtl-linux-validated, or fpga-validated before claiming Linux boot")
        var boot_errors: [text] = []
        if self.xlen == RiscvXlen.Rv32:
            boot_errors = self.linux.to_rv32_boot_artifacts().validate_for(self.linux_profile)
        else:
            boot_errors = self.linux.to_rv64_boot_artifacts().validate_for(self.linux_profile)
        for err in boot_errors:
            errors.push(err)
        if self.toolchain_prefix() == "":
            errors.push("{self.xlen.to_text()} toolchain prefix must be configured")
        errors

    fn readiness_is_boot_validated() -> bool:
        self.readiness == RiscvReadinessStatus.QemuBootValidated or self.readiness == RiscvReadinessStatus.RtlLinuxValidated or self.readiness == RiscvReadinessStatus.FpgaValidated

    fn readiness_status() -> RiscvReadinessStatus:
        self.readiness

    fn toolchain_prefix() -> text:
        self.linux.toolchain_prefix

    fn hardware_source_file_name() -> text:
        "{self.top_module}.spl"

    fn instruction_bitfield_name() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "Rv32Instruction"
        "Rv64Instruction"

    fn base_integer_instruction_mnemonics() -> [text]:
        [
            "lui", "auipc", "jal", "jalr",
            "beq", "bne", "blt", "bge", "bltu", "bgeu",
            "lb", "lh", "lw", "lbu", "lhu", "sb", "sh", "sw",
            "addi", "slti", "sltiu", "xori", "ori", "andi", "slli", "srli", "srai",
            "add", "sub", "sll", "slt", "sltu", "xor", "srl", "sra", "or", "and",
            "fence", "ecall", "ebreak"
        ]

    fn package_name() -> text:
        "simple_{self.xlen.to_text()}i_core_pkg"

    fn reset_vector_hex() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "80000000"
        "0000000080000000"

    fn stack_pointer_hex() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "00000FFC"
        "0000000000000FFC"

    fn boot_hartid_hex() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "00000000"
        "0000000000000000"

    fn boot_dtb_hex() -> text:
        val boot = self.generated_core_shell_contract().boot
        if not boot.opensbi_fw_jump:
            if self.xlen == RiscvXlen.Rv32:
                return "00000000"
            return "0000000000000000"
        if self.xlen == RiscvXlen.Rv32:
            return "88000000"
        "0000000088000000"

    fn reg_file_init_hex() -> text:
        val boot = self.generated_core_shell_contract().boot
        if boot.opensbi_fw_jump:
            return "(2 => x\"{self.stack_pointer_hex()}\", 10 => x\"{self.boot_hartid_hex()}\", 11 => x\"{self.boot_dtb_hex()}\", others => (others => '0'))"
        "(2 => x\"{self.stack_pointer_hex()}\", others => (others => '0'))"

    fn sstatus_mask_hex() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "800DE133"
        "00000000800DE133"

    fn all_ones_hex() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "FFFFFFFF"
        "FFFFFFFFFFFFFFFF"

    fn min_signed_hex() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "80000000"
        "8000000000000000"

    fn misa_reset_hex() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "40141105"
        "8000000000141105"

    fn word_div_overflow_hex() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "80000000"
        "FFFFFFFF80000000"

    fn mmu_translate_lines(vaddr_expr: text, is_write: bool) -> text:
        val write_bit = if is_write: "'1'" else "'0'"
        if self.xlen == RiscvXlen.Rv64:
            return "sv39_translate_data({vaddr_expr}, csr_satp_reg, priv_mode_reg, {write_bit}, mmu_dmem_l2_pte, mmu_dmem_l1_pte, mmu_dmem_l0_pte, translated_addr_v, translated_fault_v);\n"
        "translated_addr_v := {vaddr_expr};\n" +
            "translated_fault_v := '0';\n"

    fn sv39_page_fault_cause_decimal(access_kind: text) -> text:
        if access_kind == "read":
            return "13"
        if access_kind == "write":
            return "15"
        "12"

    fn boot_stride_decimal() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "4"
        "4"

    fn hardware_source_intro() -> text:
        "\"\"\"\n" +
            "# {self.top_module} Hardware Source Contract\n\n" +
            "Pure Simple source-of-truth sketch for the generated VHDL lane. The\n" +
            "current bundle writes this next to RTL so backend work can replace the\n" +
            "temporary emitter without inventing a RISC-V-specific bitfield language.\n" +
            "platform: {self.platform_profile.name}\n" +
            "proof_lane: {self.proof_lane().to_text()}\n" +
            "scope: {self.scope_note}\n" +
            "\"\"\"\n\n"

    fn hardware_source_bitfield_definitions(bitfield_name: text) -> text:
        "bitfield {bitfield_name}(u32):\n" +
            "    opcode: 7\n" +
            "    rd: 5\n" +
            "    funct3: 3\n" +
            "    rs1: 5\n" +
            "    rs2: 5\n" +
            "    funct7: 7\n\n" +
            "bitfield RiscvBranchImmediate(u32):\n" +
            "    low: 4\n" +
            "    high: 6\n" +
            "    bit11: 1\n" +
            "    bit12: 1\n" +
            "    _: 20\n\n" +
            "bitfield RiscvBranchEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    bit11: 1\n" +
            "    low: 4\n" +
            "    funct3: 3\n" +
            "    rs1: 5\n" +
            "    rs2: 5\n" +
            "    high: 6\n" +
            "    bit12: 1\n\n" +
            "bitfield RiscvStoreImmediate(u32):\n" +
            "    low: 5\n" +
            "    high: 7\n" +
            "    _: 20\n\n" +
            "bitfield RiscvStoreEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    low: 5\n" +
            "    funct3: 3\n" +
            "    rs1: 5\n" +
            "    rs2: 5\n" +
            "    high: 7\n\n" +
            "bitfield RiscvIImmediate(u32):\n" +
            "    value: 12\n" +
            "    _: 20\n\n" +
            "bitfield RiscvIImmediateEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    rd: 5\n" +
            "    funct3: 3\n" +
            "    rs1: 5\n" +
            "    value: 12\n\n" +
            "bitfield RiscvUpperImmediate(u32):\n" +
            "    _: 12\n" +
            "    high20: 20\n\n" +
            "bitfield RiscvUpperImmediateEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    rd: 5\n" +
            "    high20: 20\n\n" +
            "bitfield RiscvExecuteControl(u32):\n" +
            "    funct3: 3\n" +
            "    bit30: 1\n" +
            "    shamt6: 6\n" +
            "    _: 22\n\n" +
            "bitfield RiscvExecuteControlEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    rd: 5\n" +
            "    funct3: 3\n" +
            "    rs1: 5\n" +
            "    shamt_low5: 5\n" +
            "    shamt_bit5: 1\n" +
            "    bit30: 1\n" +
            "    _: 5\n\n" +
            "bitfield RiscvExecuteDatapath(u32):\n" +
            "    operation_kind: 1\n" +
            "    alu_op: 4\n" +
            "    _: 27\n\n" +
            "bitfield RiscvExecuteDatapathEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    _: 5\n" +
            "    funct3: 3\n" +
            "    _: 15\n" +
            "    bit30: 1\n" +
            "    _: 1\n\n" +
            "bitfield RiscvBranchDatapath(u32):\n" +
            "    branch_op: 3\n" +
            "    _: 29\n\n" +
            "bitfield RiscvBranchDatapathEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    _: 5\n" +
            "    funct3: 3\n" +
            "    _: 17\n\n" +
            "bitfield RiscvControlFlowDatapath(u32):\n" +
            "    next_pc_op: 2\n" +
            "    writes_link: 1\n" +
            "    _: 29\n\n" +
            "bitfield RiscvControlFlowDatapathEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    _: 25\n\n" +
            "bitfield RiscvMemoryAccessControl(u32):\n" +
            "    funct3: 3\n" +
            "    _: 29\n\n" +
            "bitfield RiscvMemoryAccessControlEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    low5: 5\n" +
            "    funct3: 3\n" +
            "    high17: 17\n\n" +
            "bitfield RiscvJumpImmediate(u32):\n" +
            "    low10: 10\n" +
            "    bit11: 1\n" +
            "    high8: 8\n" +
            "    bit20: 1\n" +
            "    _: 12\n\n" +
            "bitfield RiscvJumpEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    rd: 5\n" +
            "    high8: 8\n" +
            "    bit11: 1\n" +
            "    low10: 10\n" +
            "    bit20: 1\n\n" +
            "bitfield RiscvDispatchClass(u32):\n" +
            "    class_code: 4\n" +
            "    _: 28\n\n" +
            "bitfield RiscvDispatchClassEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    _: 25\n\n" +
            "bitfield RiscvTrapHaltControl(u32):\n" +
            "    continue_exec: 1\n" +
            "    trap: 1\n" +
            "    halt: 1\n" +
            "    _: 29\n\n" +
            "bitfield RiscvTrapHaltControlEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    _: 25\n\n"

    fn hardware_source_helper_definitions(bitfield_name: text) -> text:
        "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_writeback(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    val funct3 = inst.funct3 as u32\n" +
            "    val funct7 = inst.funct7 as u32\n" +
            "    var writeback = {bitfield_name}.new(imem_rdata)\n" +
            "    if opcode == 19 as u32:\n" +
            "        writeback.rd = inst.rs1 as u32\n" +
            "        writeback\n" +
            "    elif opcode == 51 as u32 and funct3 == 0 as u32 and funct7 == 0 as u32:\n" +
            "        writeback.rd = inst.rs2 as u32\n" +
            "        writeback\n" +
            "    else:\n" +
            "        imem_rdata\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_branch_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 99 as u32:\n" +
            "        val branch_inst = RiscvBranchEncoding.new(imem_rdata)\n" +
            "        var branch_imm = RiscvBranchImmediate.new(0 as u32)\n" +
            "        branch_imm.low = branch_inst.low as u32\n" +
            "        branch_imm.high = branch_inst.high as u32\n" +
            "        branch_imm.bit11 = branch_inst.bit11 as u32\n" +
            "        branch_imm.bit12 = branch_inst.bit12 as u32\n" +
            "        branch_imm\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_store_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 35 as u32:\n" +
            "        val store_inst = RiscvStoreEncoding.new(imem_rdata)\n" +
            "        var store_imm = RiscvStoreImmediate.new(0 as u32)\n" +
            "        store_imm.low = store_inst.low as u32\n" +
            "        store_imm.high = store_inst.high as u32\n" +
            "        store_imm\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_i_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 19 as u32 or opcode == 3 as u32:\n" +
            "        val imm_inst = RiscvIImmediateEncoding.new(imem_rdata)\n" +
            "        var imm = RiscvIImmediate.new(0 as u32)\n" +
            "        imm.value = imm_inst.value as u32\n" +
            "        imm\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_upper_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 55 as u32 or opcode == 23 as u32:\n" +
            "        val upper_inst = RiscvUpperImmediateEncoding.new(imem_rdata)\n" +
            "        var upper_imm = RiscvUpperImmediate.new(0 as u32)\n" +
            "        upper_imm.high20 = upper_inst.high20 as u32\n" +
            "        upper_imm\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_execute_control(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 19 as u32 or opcode == 51 as u32 or opcode == 99 as u32:\n" +
            "        val control_inst = RiscvExecuteControlEncoding.new(imem_rdata)\n" +
            "        var control = RiscvExecuteControl.new(0 as u32)\n" +
            "        control.funct3 = control_inst.funct3 as u32\n" +
            "        control.bit30 = control_inst.bit30 as u32\n" +
            "        control.shamt6 = ((control_inst.shamt_bit5 as u32) << 5) | (control_inst.shamt_low5 as u32)\n" +
            "        control\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_execute_datapath(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val datapath_inst = RiscvExecuteDatapathEncoding.new(imem_rdata)\n" +
            "    val opcode = datapath_inst.opcode as u32\n" +
            "    val funct3 = datapath_inst.funct3 as u32\n" +
            "    val bit30 = datapath_inst.bit30 as u32\n" +
            "    var datapath = RiscvExecuteDatapath.new(0 as u32)\n" +
            "    if opcode == 19 as u32:\n" +
            "        datapath.operation_kind = 0 as u32\n" +
            "        if funct3 == 0 as u32:\n" +
            "            datapath.alu_op = 0 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 1 as u32:\n" +
            "            datapath.alu_op = 2 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 2 as u32:\n" +
            "            datapath.alu_op = 3 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 3 as u32:\n" +
            "            datapath.alu_op = 4 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 4 as u32:\n" +
            "            datapath.alu_op = 5 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 5 as u32 and bit30 == 0 as u32:\n" +
            "            datapath.alu_op = 6 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 5 as u32 and bit30 == 1 as u32:\n" +
            "            datapath.alu_op = 7 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 6 as u32:\n" +
            "            datapath.alu_op = 8 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 7 as u32:\n" +
            "            datapath.alu_op = 9 as u32\n" +
            "            datapath\n" +
            "        else:\n" +
            "            0 as u32\n" +
            "    elif opcode == 51 as u32:\n" +
            "        datapath.operation_kind = 1 as u32\n" +
            "        if funct3 == 0 as u32 and bit30 == 0 as u32:\n" +
            "            datapath.alu_op = 0 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 0 as u32 and bit30 == 1 as u32:\n" +
            "            datapath.alu_op = 1 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 1 as u32:\n" +
            "            datapath.alu_op = 2 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 2 as u32:\n" +
            "            datapath.alu_op = 3 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 3 as u32:\n" +
            "            datapath.alu_op = 4 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 4 as u32:\n" +
            "            datapath.alu_op = 5 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 5 as u32 and bit30 == 0 as u32:\n" +
            "            datapath.alu_op = 6 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 5 as u32 and bit30 == 1 as u32:\n" +
            "            datapath.alu_op = 7 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 6 as u32:\n" +
            "            datapath.alu_op = 8 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 7 as u32:\n" +
            "            datapath.alu_op = 9 as u32\n" +
            "            datapath\n" +
            "        else:\n" +
            "            0 as u32\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_branch_datapath(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val datapath_inst = RiscvBranchDatapathEncoding.new(imem_rdata)\n" +
            "    val opcode = datapath_inst.opcode as u32\n" +
            "    val funct3 = datapath_inst.funct3 as u32\n" +
            "    var datapath = RiscvBranchDatapath.new(0 as u32)\n" +
            "    if opcode == 99 as u32:\n" +
            "        if funct3 == 0 as u32:\n" +
            "            datapath.branch_op = 0 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 1 as u32:\n" +
            "            datapath.branch_op = 1 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 4 as u32:\n" +
            "            datapath.branch_op = 2 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 5 as u32:\n" +
            "            datapath.branch_op = 3 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 6 as u32:\n" +
            "            datapath.branch_op = 4 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 7 as u32:\n" +
            "            datapath.branch_op = 5 as u32\n" +
            "            datapath\n" +
            "        else:\n" +
            "            0 as u32\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_control_flow_datapath(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val datapath_inst = RiscvControlFlowDatapathEncoding.new(imem_rdata)\n" +
            "    val opcode = datapath_inst.opcode as u32\n" +
            "    var datapath = RiscvControlFlowDatapath.new(0 as u32)\n" +
            "    if opcode == 99 as u32:\n" +
            "        datapath.next_pc_op = 1 as u32\n" +
            "        datapath.writes_link = 0 as u32\n" +
            "        datapath\n" +
            "    elif opcode == 103 as u32:\n" +
            "        datapath.next_pc_op = 2 as u32\n" +
            "        datapath.writes_link = 1 as u32\n" +
            "        datapath\n" +
            "    elif opcode == 111 as u32:\n" +
            "        datapath.next_pc_op = 3 as u32\n" +
            "        datapath.writes_link = 1 as u32\n" +
            "        datapath\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_memory_access_control(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 3 as u32 or opcode == 35 as u32:\n" +
            "        val access_inst = RiscvMemoryAccessControlEncoding.new(imem_rdata)\n" +
            "        var access = RiscvMemoryAccessControl.new(0 as u32)\n" +
            "        access.funct3 = access_inst.funct3 as u32\n" +
            "        access\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_jump_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 111 as u32:\n" +
            "        val jump_inst = RiscvJumpEncoding.new(imem_rdata)\n" +
            "        var jump_imm = RiscvJumpImmediate.new(0 as u32)\n" +
            "        jump_imm.low10 = jump_inst.low10 as u32\n" +
            "        jump_imm.bit11 = jump_inst.bit11 as u32\n" +
            "        jump_imm.high8 = jump_inst.high8 as u32\n" +
            "        jump_imm.bit20 = jump_inst.bit20 as u32\n" +
            "        jump_imm\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_dispatch_class(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val dispatch_inst = RiscvDispatchClassEncoding.new(imem_rdata)\n" +
            "    val opcode = dispatch_inst.opcode as u32\n" +
            "    var dispatch = RiscvDispatchClass.new(0 as u32)\n" +
            "    if opcode == 55 as u32:\n" +
            "        dispatch.class_code = 1 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 23 as u32:\n" +
            "        dispatch.class_code = 2 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 19 as u32:\n" +
            "        dispatch.class_code = 3 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 51 as u32:\n" +
            "        dispatch.class_code = 4 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 3 as u32:\n" +
            "        dispatch.class_code = 5 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 35 as u32:\n" +
            "        dispatch.class_code = 6 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 99 as u32:\n" +
            "        dispatch.class_code = 7 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 103 as u32:\n" +
            "        dispatch.class_code = 8 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 111 as u32:\n" +
            "        dispatch.class_code = 9 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 15 as u32:\n" +
            "        dispatch.class_code = 10 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 47 as u32:\n" +
            "        dispatch.class_code = 14 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 115 as u32:\n" +
            "        dispatch.class_code = 11 as u32\n" +
            "        dispatch\n" +
            "    else:\n" +
            "        dispatch\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_trap_halt_control(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val control_inst = RiscvTrapHaltControlEncoding.new(imem_rdata)\n" +
            "    val opcode = control_inst.opcode as u32\n" +
            "    var control = RiscvTrapHaltControl.new(0 as u32)\n" +
            "    if opcode == 55 as u32 or opcode == 23 as u32 or opcode == 19 as u32 or opcode == 51 as u32 or opcode == 3 as u32 or opcode == 35 as u32 or opcode == 99 as u32 or opcode == 103 as u32 or opcode == 111 as u32 or opcode == 15 as u32 or opcode == 47 as u32:\n" +
            "        control.continue_exec = 1 as u32\n" +
            "        control\n" +
            "    elif opcode == 115 as u32:\n" +
            "        control.halt = 1 as u32\n" +
            "        control\n" +
            "    else:\n" +
            "        control.trap = 1 as u32\n" +
            "        control\n\n"

    fn hardware_source_top_level_contract(bitfield_name: text) -> text:
        "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}(clk: bool, reset_n: bool, imem_rdata: u32, dmem_rdata: u{self.xlen.bits()}) -> u{self.xlen.bits()}:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    val funct3 = inst.funct3 as u32\n" +
            "    val funct7 = inst.funct7 as u32\n" +
            "    val rd = inst.rd as u32\n" +
            "    # VHDL lowering owns these bitfield reads as slices:\n" +
            "    # inst.opcode -> imem_rdata(6 downto 0)\n" +
            "    # inst.rd -> imem_rdata(11 downto 7)\n" +
            "    # inst.funct3 -> imem_rdata(14 downto 12)\n" +
            "    # inst.rs1 -> imem_rdata(19 downto 15)\n" +
            "    # inst.rs2 -> imem_rdata(24 downto 20)\n" +
            "    # inst.funct7 -> imem_rdata(31 downto 25)\n" +
            "    # RiscvBranchEncoding.bit11 -> imem_rdata(7 downto 7)\n" +
            "    # RiscvBranchEncoding.low -> imem_rdata(11 downto 8)\n" +
            "    # RiscvBranchEncoding.high -> imem_rdata(30 downto 25)\n" +
            "    # RiscvBranchEncoding.bit12 -> imem_rdata(31 downto 31)\n" +
            "    # RiscvStoreEncoding.low -> imem_rdata(11 downto 7)\n" +
            "    # RiscvStoreEncoding.high -> imem_rdata(31 downto 25)\n" +
            "    # RiscvIImmediateEncoding.value -> imem_rdata(31 downto 20)\n" +
            "    # RiscvUpperImmediateEncoding.high20 -> imem_rdata(31 downto 12)\n" +
            "    # RiscvExecuteControlEncoding.funct3 -> imem_rdata(14 downto 12)\n" +
            "    # RiscvExecuteControlEncoding.shamt_low5 -> imem_rdata(24 downto 20)\n" +
            "    # RiscvExecuteControlEncoding.shamt_bit5 -> imem_rdata(25 downto 25)\n" +
            "    # RiscvExecuteControlEncoding.bit30 -> imem_rdata(30 downto 30)\n" +
            "    # RiscvExecuteDatapathEncoding.opcode -> imem_rdata(6 downto 0)\n" +
            "    # RiscvExecuteDatapathEncoding.funct3 -> imem_rdata(14 downto 12)\n" +
            "    # RiscvExecuteDatapathEncoding.bit30 -> imem_rdata(30 downto 30)\n" +
            "    # RiscvBranchDatapathEncoding.opcode -> imem_rdata(6 downto 0)\n" +
            "    # RiscvBranchDatapathEncoding.funct3 -> imem_rdata(14 downto 12)\n" +
            "    # RiscvControlFlowDatapathEncoding.opcode -> imem_rdata(6 downto 0)\n" +
            "    # RiscvMemoryAccessControlEncoding.funct3 -> imem_rdata(14 downto 12)\n" +
            "    # RiscvJumpEncoding.high8 -> imem_rdata(19 downto 12)\n" +
            "    # RiscvJumpEncoding.bit11 -> imem_rdata(20 downto 20)\n" +
            "    # RiscvJumpEncoding.low10 -> imem_rdata(30 downto 21)\n" +
            "    # RiscvJumpEncoding.bit20 -> imem_rdata(31 downto 31)\n" +
            "    # RiscvDispatchClassEncoding.opcode -> imem_rdata(6 downto 0)\n" +
            "    # RiscvTrapHaltControlEncoding.opcode -> imem_rdata(6 downto 0)\n" +
            "    # base integer instructions: {self.base_integer_instruction_mnemonics().join(\",\")}\n" +
            "    if opcode == 19 as u32:\n" +
            "        rd as u{self.xlen.bits()}\n" +
            "    elif opcode == 51 as u32 and funct3 == 0 as u32 and funct7 == 0 as u32:\n" +
            "        rd as u{self.xlen.bits()}\n" +
            "    else:\n" +
            "        imem_rdata as u{self.xlen.bits()}\n"

    fn hardware_source_spl() -> text:
        val bitfield_name = self.instruction_bitfield_name()
        self.hardware_source_intro() +
            self.hardware_source_bitfield_definitions(bitfield_name) +
            self.hardware_source_helper_definitions(bitfield_name) +
            self.hardware_source_top_level_contract(bitfield_name)

    fn hardware_source_contract_errors() -> [text]:
        val source = self.hardware_source_spl() + "\n" + self.core_vhdl()
        var errors: [text] = []
