    fn generated_testbench_from_template(template_path: text) -> text:
        val package_name = self.package_name()
        val top = self.top_module
        val template_text =
            if template_path == "tb_generated_rv64_linux_handoff.vhd":
                generated_rv64_linux_handoff_testbench_template()
            elif template_path == "tb_generated_rv64_boot_banner.vhd":
                generated_rv64_boot_banner_testbench_template()
            elif template_path == "tb_generated_rv64_fw_jump.vhd":
                generated_rv64_fw_jump_testbench_template()
            elif template_path == "tb_generated_rv64_boot_info_real_dtb.vhd":
                generated_rv64_boot_info_real_dtb_testbench_template()
            elif template_path == "tb_generated_rv64_sv39.vhd":
                generated_rv64_sv39_testbench_template()
            elif template_path == "tb_generated_rv64_sv39_fault.vhd":
                generated_rv64_sv39_fault_testbench_template()
            else:
                ""
        val with_rv64_package = template_text.replace("use work.simple_rv64i_core_pkg.all;", "use work.{package_name}.all;")
        val with_rv32_package = with_rv64_package.replace("use work.simple_rv32i_core_pkg.all;", "use work.{package_name}.all;")
        val with_rv64_top = with_rv32_package.replace("entity work.simple_rv64gc_core", "entity work.{top}")
        val with_top = with_rv64_top.replace("entity work.simple_rv32gc_core", "entity work.{top}")
        with_top

    fn debug_sidecar_file_name() -> text:
        "{self.top_module}.debug.json"

    fn debug_metadata() -> GeneratedCoreDebugMetadata:
        self.generated_core_shell_contract().debug_metadata()

    fn runner_testbench_file_names() -> [text]:
        var files: [text] = []
        for entry in self.debug_metadata().runner_testbenches:
            files.push(entry.file_name)
        files

    fn json_escape(value: text) -> text:
        var out = value.replace("\\", "\\\\")
        out = out.replace("\"", "\\\"")
        out

    fn json_text_array(values: [text]) -> text:
        var parts: [text] = []
        for value in values:
            parts.push("\"{self.json_escape(value)}\"")
        "[" + parts.join(", ") + "]"

    fn json_source_map_array(entries: [GeneratedCoreDebugSourceMapEntry]) -> text:
        var parts: [text] = []
        for entry in entries:
            parts.push("{\"signal\":\"{self.json_escape(entry.signal_name)}\",\"slice\":\"{self.json_escape(entry.slice_text)}\"}")
        "[" + parts.join(", ") + "]"

    fn authoritative_files(lane_dir: text) -> [text]:
        [
            "{lane_dir}/{self.hardware_source_file_name()}",
            "{lane_dir}/{self.package_name()}.vhd",
            "{lane_dir}/{self.top_module}.vhd",
            "{lane_dir}/{self.debug_sidecar_file_name()}"
        ]

    fn json_runner_testbench_array(entries: [GeneratedCoreDebugRunnerTestbench], lane_dir: text) -> text:
        var parts: [text] = []
        for entry in entries:
            parts.push("{\"file\":\"{self.json_escape(entry.file_name)}\",\"path\":\"{self.json_escape(lane_dir)}/{self.json_escape(entry.file_name)}\",\"passMarker\":\"{self.json_escape(entry.pass_marker)}\"}")
        "[" + parts.join(", ") + "]"

    fn json_runner_success_markers(entries: [GeneratedCoreDebugRunnerTestbench]) -> text:
        var parts: [text] = []
        for entry in entries:
            parts.push("\"{self.json_escape(entry.file_name)}\":\"{self.json_escape(entry.pass_marker)}\"")
        "{" + parts.join(", ") + "}"

    fn debug_sidecar_json(lane_dir: text, authoritative: bool) -> text:
        val metadata = self.debug_metadata()
        "{\n" +
            "  \"schemaVersion\": \"{metadata.schema_version}\",\n" +
            "  \"laneId\": \"{metadata.lane_id}\",\n" +
            "  \"topModule\": \"{self.top_module}\",\n" +
            "  \"generatedFrom\": \"{self.hardware_source_file_name()}\",\n" +
            "  \"rtlDir\": \"{lane_dir}\",\n" +
            "  \"proofLane\": \"{metadata.proof_lane.to_text()}\",\n" +
            "  \"shellSummary\": \"{self.proof_lane_summary()}\",\n" +
            "  \"readiness\": \"{self.readiness_status().to_text()}\",\n" +
            "  \"linuxBootValidated\": {self.readiness_is_boot_validated()},\n" +
            "  \"platform\": \"{self.platform_profile.name}\",\n" +
            "  \"scope\": \"{self.scope_note}\",\n" +
            "  \"linuxPolicy\": \"{self.linux_policy()}\",\n" +
            "  \"authoritative\": {authoritative},\n" +
            "  \"provenance\": {\"authoritativeRtl\": \"{self.authoritative_rtl_provenance()}\", \"authoritativeFiles\": {self.json_text_array(self.authoritative_files(lane_dir))}, \"auxiliaryVhdl\": \"{self.auxiliary_vhdl_provenance()}\", \"runnerTestbenches\": \"{self.runner_testbench_provenance()}\", \"pureSimpleAuthoritativeRtl\": true},\n" +
            "  \"abi\": \"{self.linux_profile.abi.to_text()}\",\n" +
            "  \"mmu\": \"{self.linux_profile.mmu_mode.to_text()}\",\n" +
            "  \"firmwareMode\": \"{self.linux_profile.firmware_mode.to_text()}\",\n" +
            "  \"kernelAlignment\": {self.linux_profile.kernel_alignment},\n" +
            "  \"xlen\": {metadata.xlen_bits},\n" +
            "  \"acceptanceMarkers\": {self.json_text_array(metadata.acceptance_markers)},\n" +
            "  \"debugOutputs\": {self.json_text_array(metadata.debug_outputs)},\n" +
            "  \"sourceMap\": {self.json_source_map_array(metadata.source_map)},\n" +
            "  \"observability\": {\"fetch\": {metadata.observability.fetch}, \"trap\": {metadata.observability.trap}, \"halt\": {metadata.observability.halt}, \"memoryAccess\": {metadata.observability.memory_access}, \"registerProbes\": {metadata.observability.register_probes}, \"debugProbes\": {metadata.observability.debug_probes}, \"proofFailureReports\": {metadata.observability.proof_failure_reports}},\n" +
            "  \"reportMarkers\": {self.json_text_array(metadata.report_markers)},\n" +
            "  \"runnerSuccessMarkers\": {self.json_runner_success_markers(metadata.runner_testbenches)},\n" +
            "  \"runnerTestbenches\": {self.json_runner_testbench_array(metadata.runner_testbenches, lane_dir)},\n" +
            "  \"shellServices\": {\"semihost\": {self.generated_core_shell_contract().semihost_shell_service}, \"mailbox\": {self.generated_core_shell_contract().mailbox_shell_service}}\n" +
            "}\n"

