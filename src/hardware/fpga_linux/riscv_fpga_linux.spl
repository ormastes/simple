        if not source.contains("fn {self.top_module}_decode_execute_control"):
            errors.push("{self.xlen.to_text()} hardware source must define execute control helper")
        if not source.contains("fn {self.top_module}_decode_execute_datapath"):
            errors.push("{self.xlen.to_text()} hardware source must define execute datapath helper")
        if not source.contains("fn {self.top_module}_decode_branch_datapath"):
            errors.push("{self.xlen.to_text()} hardware source must define branch datapath helper")
        if not source.contains("fn {self.top_module}_decode_control_flow_datapath"):
            errors.push("{self.xlen.to_text()} hardware source must define control flow datapath helper")
        if not source.contains("fn {self.top_module}_decode_memory_access_control"):
            errors.push("{self.xlen.to_text()} hardware source must define memory access control helper")
        if not source.contains("fn {self.top_module}_decode_jump_immediate"):
            errors.push("{self.xlen.to_text()} hardware source must define jump immediate helper")
