    fn support_package_file_name() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "rv32i_pkg.vhd"
        ""

    fn has_support_package() -> bool:
        self.xlen == RiscvXlen.Rv32

    fn support_package_vhdl() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return generated_rv32_support_package_vhdl_text()
        ""

    fn wrapper_file_name() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "rv32i_generated_wrapper.vhd"
        ""

    fn has_wrapper() -> bool:
        self.xlen == RiscvXlen.Rv32

