"""
# RISC-V FPGA Linux Preparation Contracts

Board-profiled preparation model for RISC-V CPU SoC RTL bring-up on Xilinx
FPGAs. This module describes the pre-hardware contract: what must be generated,
validated, and later consumed by Vivado/programming/boot-test wrappers.
"""

extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_dir_create(path: text, recursive: bool) -> bool

use hardware.riscv_common.pkg.riscv_linux_pkg.{RiscvLinuxProfile, RiscvPlatformProfile, Rv32LinuxBootArtifacts, Rv64LinuxBootArtifacts}
use hardware.rv32gc.top.rv32_machine.{qemu_virt_rv32_platform_profile, rv32_qemu_virt_linux_profile}
use hardware.rv64gc.top.rv64_machine.{qemu_virt_rv64_platform_profile, rv64_qemu_virt_linux_profile}

enum RiscvXlen:
    Rv32
    Rv64

enum RiscvReadinessStatus:
    Contract
    RtlGenerated
    QemuBootValidated
    RtlLinuxValidated
    FpgaValidated

impl RiscvReadinessStatus:
    fn to_text() -> text:
        match self:
            Contract: "contract"
            RtlGenerated: "rtl-generated"
            QemuBootValidated: "qemu-boot-validated"
            RtlLinuxValidated: "rtl-linux-validated"
            FpgaValidated: "fpga-validated"

impl RiscvXlen:
    fn bits() -> i64:
        match self:
            Rv32: 32
            Rv64: 64

    fn to_text() -> text:
        match self:
            Rv32: "rv32"
            Rv64: "rv64"

    fn linux_policy() -> text:
        match self:
            Rv32: "repo-native-rv32-linux"
            Rv64: "repo-native-rv64-linux"

    fn mmu_mode() -> text:
        match self:
            Rv32: "sv32"
            Rv64: "sv39"

struct XilinxBoardProfile:
    name: text
    part: text
    clock_hz: i64
    reset_polarity: text
    memory_kind: text
    memory_base: i64
    memory_size_bytes: i64
    uart_baud: i64
    constraints_path: text
    programmer: text
    vivado_mode: text

impl XilinxBoardProfile:
    static fn generic() -> XilinxBoardProfile:
        XilinxBoardProfile(
            name: "xilinx_generic",
            part: "BOARD_PART_TBD",
            clock_hz: 100000000,
            reset_polarity: "active-low",
            memory_kind: "ddr",
            memory_base: 0x80000000,
            memory_size_bytes: 0,
            uart_baud: 115200,
            constraints_path: "constraints/xilinx_generic.xdc",
            programmer: "hw_server",
            vivado_mode: "batch"
        )

    fn is_generic() -> bool:
        self.part == "BOARD_PART_TBD"

    fn validate_for_prepare() -> [text]:
        var errors: [text] = []
        if self.name == "":
            errors.push("board name is required")
        if self.clock_hz <= 0:
            errors.push("clock_hz must be positive")
        if self.reset_polarity != "active-low" and self.reset_polarity != "active-high":
            errors.push("reset_polarity must be active-low or active-high")
        if self.memory_kind != "ddr" and self.memory_kind != "bram":
            errors.push("memory_kind must be ddr or bram")
        if self.uart_baud <= 0:
            errors.push("uart_baud must be positive")
        if self.constraints_path == "":
            errors.push("constraints_path is required")
        if self.programmer == "":
            errors.push("programmer is required")
        if self.vivado_mode != "batch":
            errors.push("vivado_mode must be batch")
        errors

    fn validate_for_hardware_boot() -> [text]:
        var errors = self.validate_for_prepare()
        if self.is_generic():
            errors.push("xilinx part must be selected before hardware boot")
        if self.memory_size_bytes <= 0:
            errors.push("memory_size_bytes must be set before hardware boot")
        errors

struct LinuxArtifactSet:
    kernel_image: text
    rootfs_image: text
    opensbi_image: text
    uboot_image: text
    dtb_path: text
    toolchain_prefix: text

impl LinuxArtifactSet:
    static fn empty() -> LinuxArtifactSet:
        LinuxArtifactSet(
            kernel_image: "",
            rootfs_image: "",
            opensbi_image: "",
            uboot_image: "",
            dtb_path: "",
            toolchain_prefix: ""
        )

    fn configured() -> bool:
        self.kernel_image != "" and self.rootfs_image != "" and self.dtb_path != "" and self.toolchain_prefix != ""

    fn firmware_configured() -> bool:
        self.opensbi_image != "" or self.uboot_image != ""

    fn to_rv64_boot_artifacts() -> Rv64LinuxBootArtifacts:
        Rv64LinuxBootArtifacts(
            opensbi: self.opensbi_image,
            kernel_image: self.kernel_image,
            initrd_rootfs: self.rootfs_image,
            dtb: self.dtb_path,
            uboot: self.uboot_image
        )

    fn to_rv32_boot_artifacts() -> Rv32LinuxBootArtifacts:
        Rv32LinuxBootArtifacts(
            opensbi: self.opensbi_image,
            kernel_image: self.kernel_image,
            initrd_rootfs: self.rootfs_image,
            dtb: self.dtb_path,
            uboot: self.uboot_image
        )

struct RiscvFpgaLane:
    xlen: RiscvXlen
    top_module: text
    rtl_dir: text
    rtl_sim_backend: text
    bootrom_path: text
    readiness: RiscvReadinessStatus
    linux_profile: RiscvLinuxProfile
    platform_profile: RiscvPlatformProfile
    scope_note: text
    linux: LinuxArtifactSet

impl RiscvFpgaLane:
    static fn rv64_default() -> RiscvFpgaLane:
        val platform = qemu_virt_rv64_platform_profile()
        RiscvFpgaLane(
            xlen: RiscvXlen.Rv64,
            top_module: "simple_rv64gc_core",
            rtl_dir: "build/fpga/rv64/rtl",
            rtl_sim_backend: "ghdl-vhdl-2008",
            bootrom_path: "build/fpga/rv64/bootrom.bin",
            readiness: RiscvReadinessStatus.Contract,
            linux_profile: rv64_qemu_virt_linux_profile(),
            platform_profile: platform,
            scope_note: "repo-native RV64GC Linux contract lane",
            linux: LinuxArtifactSet.empty()
        )

    static fn rv32_default() -> RiscvFpgaLane:
        val platform = qemu_virt_rv32_platform_profile()
        RiscvFpgaLane(
            xlen: RiscvXlen.Rv32,
            top_module: "simple_rv32gc_core",
            rtl_dir: "build/fpga/rv32/rtl",
            rtl_sim_backend: "ghdl-vhdl-2008",
            bootrom_path: "build/fpga/rv32/bootrom.bin",
            readiness: RiscvReadinessStatus.Contract,
            linux_profile: rv32_qemu_virt_linux_profile(),
            platform_profile: platform,
            scope_note: "repo-native RV32GC Linux contract lane",
            linux: LinuxArtifactSet.empty()
        )

    fn expected_boot_markers() -> [text]:
        var markers: [text] = []
        if self.linux_profile.opensbi_required:
            markers.push("OpenSBI")
        markers.push("Linux version")
        markers.push("OF: fdt")
        markers.push("Freeing unused kernel memory")
        markers.push("init started")
        markers

    fn required_soc_blocks() -> [text]:
        self.platform_profile.required_soc_blocks()

    fn validate_for_prepare() -> [text]:
        var errors: [text] = []
        if self.top_module == "":
            errors.push("top_module is required")
        if self.rtl_dir == "":
            errors.push("rtl_dir is required")
        if self.rtl_sim_backend == "":
            errors.push("rtl_sim_backend is required")
        if self.bootrom_path == "":
            errors.push("bootrom_path is required")
        if self.linux_profile.xlen != self.xlen.bits():
            errors.push("linux profile xlen must match lane xlen")
        if self.platform_profile.linux.xlen != self.xlen.bits():
            errors.push("platform profile xlen must match lane xlen")
        errors

    fn validate_for_linux_boot() -> [text]:
        var errors = self.validate_for_prepare()
        if not self.readiness_is_boot_validated():
            errors.push("{self.xlen.to_text()} readiness must be qemu-boot-validated, rtl-linux-validated, or fpga-validated before claiming Linux boot")
        var boot_errors: [text] = []
        if self.xlen == RiscvXlen.Rv32:
            boot_errors = self.linux.to_rv32_boot_artifacts().validate_for(self.linux_profile)
        else:
            boot_errors = self.linux.to_rv64_boot_artifacts().validate_for(self.linux_profile)
        for err in boot_errors:
            errors.push(err)
        if self.toolchain_prefix() == "":
            errors.push("{self.xlen.to_text()} toolchain prefix must be configured")
        errors

    fn readiness_is_boot_validated() -> bool:
        self.readiness == RiscvReadinessStatus.QemuBootValidated or self.readiness == RiscvReadinessStatus.RtlLinuxValidated or self.readiness == RiscvReadinessStatus.FpgaValidated

    fn readiness_status() -> RiscvReadinessStatus:
        self.readiness

    fn toolchain_prefix() -> text:
        self.linux.toolchain_prefix

    fn hardware_source_file_name() -> text:
        "{self.top_module}.spl"

    fn instruction_bitfield_name() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "Rv32Instruction"
        "Rv64Instruction"

    fn base_integer_instruction_mnemonics() -> [text]:
        [
            "lui", "auipc", "jal", "jalr",
            "beq", "bne", "blt", "bge", "bltu", "bgeu",
            "lb", "lh", "lw", "lbu", "lhu", "sb", "sh", "sw",
            "addi", "slti", "sltiu", "xori", "ori", "andi", "slli", "srli", "srai",
            "add", "sub", "sll", "slt", "sltu", "xor", "srl", "sra", "or", "and",
            "fence", "ecall", "ebreak"
        ]

    fn package_name() -> text:
        "simple_{self.xlen.to_text()}i_core_pkg"

    fn reset_vector_hex() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "80000000"
        "0000000080000000"

    fn boot_stride_decimal() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return "4"
        "4"

    fn hardware_source_intro() -> text:
        "\"\"\"\n" +
            "# {self.top_module} Hardware Source Contract\n\n" +
            "Pure Simple source-of-truth sketch for the generated VHDL lane. The\n" +
            "current bundle writes this next to RTL so backend work can replace the\n" +
            "temporary emitter without inventing a RISC-V-specific bitfield language.\n" +
            "platform: {self.platform_profile.name}\n" +
            "scope: {self.scope_note}\n" +
            "\"\"\"\n\n"

    fn hardware_source_bitfield_definitions(bitfield_name: text) -> text:
        "bitfield {bitfield_name}(u32):\n" +
            "    opcode: 7\n" +
            "    rd: 5\n" +
            "    funct3: 3\n" +
            "    rs1: 5\n" +
            "    rs2: 5\n" +
            "    funct7: 7\n\n" +
            "bitfield RiscvBranchImmediate(u32):\n" +
            "    low: 4\n" +
            "    high: 6\n" +
            "    bit11: 1\n" +
            "    bit12: 1\n" +
            "    _: 20\n\n" +
            "bitfield RiscvBranchEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    bit11: 1\n" +
            "    low: 4\n" +
            "    funct3: 3\n" +
            "    rs1: 5\n" +
            "    rs2: 5\n" +
            "    high: 6\n" +
            "    bit12: 1\n\n" +
            "bitfield RiscvStoreImmediate(u32):\n" +
            "    low: 5\n" +
            "    high: 7\n" +
            "    _: 20\n\n" +
            "bitfield RiscvStoreEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    low: 5\n" +
            "    funct3: 3\n" +
            "    rs1: 5\n" +
            "    rs2: 5\n" +
            "    high: 7\n\n" +
            "bitfield RiscvIImmediate(u32):\n" +
            "    value: 12\n" +
            "    _: 20\n\n" +
            "bitfield RiscvIImmediateEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    rd: 5\n" +
            "    funct3: 3\n" +
            "    rs1: 5\n" +
            "    value: 12\n\n" +
            "bitfield RiscvUpperImmediate(u32):\n" +
            "    _: 12\n" +
            "    high20: 20\n\n" +
            "bitfield RiscvUpperImmediateEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    rd: 5\n" +
            "    high20: 20\n\n" +
            "bitfield RiscvExecuteControl(u32):\n" +
            "    funct3: 3\n" +
            "    bit30: 1\n" +
            "    shamt6: 6\n" +
            "    _: 22\n\n" +
            "bitfield RiscvExecuteControlEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    rd: 5\n" +
            "    funct3: 3\n" +
            "    rs1: 5\n" +
            "    shamt_low5: 5\n" +
            "    shamt_bit5: 1\n" +
            "    bit30: 1\n" +
            "    _: 5\n\n" +
            "bitfield RiscvExecuteDatapath(u32):\n" +
            "    operation_kind: 1\n" +
            "    alu_op: 4\n" +
            "    _: 27\n\n" +
            "bitfield RiscvExecuteDatapathEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    _: 5\n" +
            "    funct3: 3\n" +
            "    _: 15\n" +
            "    bit30: 1\n" +
            "    _: 1\n\n" +
            "bitfield RiscvBranchDatapath(u32):\n" +
            "    branch_op: 3\n" +
            "    _: 29\n\n" +
            "bitfield RiscvBranchDatapathEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    _: 5\n" +
            "    funct3: 3\n" +
            "    _: 17\n\n" +
            "bitfield RiscvControlFlowDatapath(u32):\n" +
            "    next_pc_op: 2\n" +
            "    writes_link: 1\n" +
            "    _: 29\n\n" +
            "bitfield RiscvControlFlowDatapathEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    _: 25\n\n" +
            "bitfield RiscvMemoryAccessControl(u32):\n" +
            "    funct3: 3\n" +
            "    _: 29\n\n" +
            "bitfield RiscvMemoryAccessControlEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    low5: 5\n" +
            "    funct3: 3\n" +
            "    high17: 17\n\n" +
            "bitfield RiscvJumpImmediate(u32):\n" +
            "    low10: 10\n" +
            "    bit11: 1\n" +
            "    high8: 8\n" +
            "    bit20: 1\n" +
            "    _: 12\n\n" +
            "bitfield RiscvJumpEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    rd: 5\n" +
            "    high8: 8\n" +
            "    bit11: 1\n" +
            "    low10: 10\n" +
            "    bit20: 1\n\n" +
            "bitfield RiscvDispatchClass(u32):\n" +
            "    class_code: 4\n" +
            "    _: 28\n\n" +
            "bitfield RiscvDispatchClassEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    _: 25\n\n" +
            "bitfield RiscvTrapHaltControl(u32):\n" +
            "    continue_exec: 1\n" +
            "    trap: 1\n" +
            "    halt: 1\n" +
            "    _: 29\n\n" +
            "bitfield RiscvTrapHaltControlEncoding(u32):\n" +
            "    opcode: 7\n" +
            "    _: 25\n\n"

    fn hardware_source_helper_definitions(bitfield_name: text) -> text:
        "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_writeback(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    val funct3 = inst.funct3 as u32\n" +
            "    val funct7 = inst.funct7 as u32\n" +
            "    var writeback = {bitfield_name}.new(imem_rdata)\n" +
            "    if opcode == 19 as u32:\n" +
            "        writeback.rd = inst.rs1 as u32\n" +
            "        writeback\n" +
            "    elif opcode == 51 as u32 and funct3 == 0 as u32 and funct7 == 0 as u32:\n" +
            "        writeback.rd = inst.rs2 as u32\n" +
            "        writeback\n" +
            "    else:\n" +
            "        imem_rdata\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_branch_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 99 as u32:\n" +
            "        val branch_inst = RiscvBranchEncoding.new(imem_rdata)\n" +
            "        var branch_imm = RiscvBranchImmediate.new(0 as u32)\n" +
            "        branch_imm.low = branch_inst.low as u32\n" +
            "        branch_imm.high = branch_inst.high as u32\n" +
            "        branch_imm.bit11 = branch_inst.bit11 as u32\n" +
            "        branch_imm.bit12 = branch_inst.bit12 as u32\n" +
            "        branch_imm\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_store_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 35 as u32:\n" +
            "        val store_inst = RiscvStoreEncoding.new(imem_rdata)\n" +
            "        var store_imm = RiscvStoreImmediate.new(0 as u32)\n" +
            "        store_imm.low = store_inst.low as u32\n" +
            "        store_imm.high = store_inst.high as u32\n" +
            "        store_imm\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_i_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 19 as u32 or opcode == 3 as u32:\n" +
            "        val imm_inst = RiscvIImmediateEncoding.new(imem_rdata)\n" +
            "        var imm = RiscvIImmediate.new(0 as u32)\n" +
            "        imm.value = imm_inst.value as u32\n" +
            "        imm\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_upper_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 55 as u32 or opcode == 23 as u32:\n" +
            "        val upper_inst = RiscvUpperImmediateEncoding.new(imem_rdata)\n" +
            "        var upper_imm = RiscvUpperImmediate.new(0 as u32)\n" +
            "        upper_imm.high20 = upper_inst.high20 as u32\n" +
            "        upper_imm\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_execute_control(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 19 as u32 or opcode == 51 as u32 or opcode == 99 as u32:\n" +
            "        val control_inst = RiscvExecuteControlEncoding.new(imem_rdata)\n" +
            "        var control = RiscvExecuteControl.new(0 as u32)\n" +
            "        control.funct3 = control_inst.funct3 as u32\n" +
            "        control.bit30 = control_inst.bit30 as u32\n" +
            "        control.shamt6 = ((control_inst.shamt_bit5 as u32) << 5) | (control_inst.shamt_low5 as u32)\n" +
            "        control\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_execute_datapath(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val datapath_inst = RiscvExecuteDatapathEncoding.new(imem_rdata)\n" +
            "    val opcode = datapath_inst.opcode as u32\n" +
            "    val funct3 = datapath_inst.funct3 as u32\n" +
            "    val bit30 = datapath_inst.bit30 as u32\n" +
            "    var datapath = RiscvExecuteDatapath.new(0 as u32)\n" +
            "    if opcode == 19 as u32:\n" +
            "        datapath.operation_kind = 0 as u32\n" +
            "        if funct3 == 0 as u32:\n" +
            "            datapath.alu_op = 0 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 1 as u32:\n" +
            "            datapath.alu_op = 2 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 2 as u32:\n" +
            "            datapath.alu_op = 3 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 3 as u32:\n" +
            "            datapath.alu_op = 4 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 4 as u32:\n" +
            "            datapath.alu_op = 5 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 5 as u32 and bit30 == 0 as u32:\n" +
            "            datapath.alu_op = 6 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 5 as u32 and bit30 == 1 as u32:\n" +
            "            datapath.alu_op = 7 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 6 as u32:\n" +
            "            datapath.alu_op = 8 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 7 as u32:\n" +
            "            datapath.alu_op = 9 as u32\n" +
            "            datapath\n" +
            "        else:\n" +
            "            0 as u32\n" +
            "    elif opcode == 51 as u32:\n" +
            "        datapath.operation_kind = 1 as u32\n" +
            "        if funct3 == 0 as u32 and bit30 == 0 as u32:\n" +
            "            datapath.alu_op = 0 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 0 as u32 and bit30 == 1 as u32:\n" +
            "            datapath.alu_op = 1 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 1 as u32:\n" +
            "            datapath.alu_op = 2 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 2 as u32:\n" +
            "            datapath.alu_op = 3 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 3 as u32:\n" +
            "            datapath.alu_op = 4 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 4 as u32:\n" +
            "            datapath.alu_op = 5 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 5 as u32 and bit30 == 0 as u32:\n" +
            "            datapath.alu_op = 6 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 5 as u32 and bit30 == 1 as u32:\n" +
            "            datapath.alu_op = 7 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 6 as u32:\n" +
            "            datapath.alu_op = 8 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 7 as u32:\n" +
            "            datapath.alu_op = 9 as u32\n" +
            "            datapath\n" +
            "        else:\n" +
            "            0 as u32\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_branch_datapath(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val datapath_inst = RiscvBranchDatapathEncoding.new(imem_rdata)\n" +
            "    val opcode = datapath_inst.opcode as u32\n" +
            "    val funct3 = datapath_inst.funct3 as u32\n" +
            "    var datapath = RiscvBranchDatapath.new(0 as u32)\n" +
            "    if opcode == 99 as u32:\n" +
            "        if funct3 == 0 as u32:\n" +
            "            datapath.branch_op = 0 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 1 as u32:\n" +
            "            datapath.branch_op = 1 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 4 as u32:\n" +
            "            datapath.branch_op = 2 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 5 as u32:\n" +
            "            datapath.branch_op = 3 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 6 as u32:\n" +
            "            datapath.branch_op = 4 as u32\n" +
            "            datapath\n" +
            "        elif funct3 == 7 as u32:\n" +
            "            datapath.branch_op = 5 as u32\n" +
            "            datapath\n" +
            "        else:\n" +
            "            0 as u32\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_control_flow_datapath(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val datapath_inst = RiscvControlFlowDatapathEncoding.new(imem_rdata)\n" +
            "    val opcode = datapath_inst.opcode as u32\n" +
            "    var datapath = RiscvControlFlowDatapath.new(0 as u32)\n" +
            "    if opcode == 99 as u32:\n" +
            "        datapath.next_pc_op = 1 as u32\n" +
            "        datapath.writes_link = 0 as u32\n" +
            "        datapath\n" +
            "    elif opcode == 103 as u32:\n" +
            "        datapath.next_pc_op = 2 as u32\n" +
            "        datapath.writes_link = 1 as u32\n" +
            "        datapath\n" +
            "    elif opcode == 111 as u32:\n" +
            "        datapath.next_pc_op = 3 as u32\n" +
            "        datapath.writes_link = 1 as u32\n" +
            "        datapath\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_memory_access_control(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 3 as u32 or opcode == 35 as u32:\n" +
            "        val access_inst = RiscvMemoryAccessControlEncoding.new(imem_rdata)\n" +
            "        var access = RiscvMemoryAccessControl.new(0 as u32)\n" +
            "        access.funct3 = access_inst.funct3 as u32\n" +
            "        access\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_jump_immediate(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    if opcode == 111 as u32:\n" +
            "        val jump_inst = RiscvJumpEncoding.new(imem_rdata)\n" +
            "        var jump_imm = RiscvJumpImmediate.new(0 as u32)\n" +
            "        jump_imm.low10 = jump_inst.low10 as u32\n" +
            "        jump_imm.bit11 = jump_inst.bit11 as u32\n" +
            "        jump_imm.high8 = jump_inst.high8 as u32\n" +
            "        jump_imm.bit20 = jump_inst.bit20 as u32\n" +
            "        jump_imm\n" +
            "    else:\n" +
            "        0 as u32\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_dispatch_class(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val dispatch_inst = RiscvDispatchClassEncoding.new(imem_rdata)\n" +
            "    val opcode = dispatch_inst.opcode as u32\n" +
            "    var dispatch = RiscvDispatchClass.new(0 as u32)\n" +
            "    if opcode == 55 as u32:\n" +
            "        dispatch.class_code = 1 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 23 as u32:\n" +
            "        dispatch.class_code = 2 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 19 as u32:\n" +
            "        dispatch.class_code = 3 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 51 as u32:\n" +
            "        dispatch.class_code = 4 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 3 as u32:\n" +
            "        dispatch.class_code = 5 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 35 as u32:\n" +
            "        dispatch.class_code = 6 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 99 as u32:\n" +
            "        dispatch.class_code = 7 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 103 as u32:\n" +
            "        dispatch.class_code = 8 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 111 as u32:\n" +
            "        dispatch.class_code = 9 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 15 as u32:\n" +
            "        dispatch.class_code = 10 as u32\n" +
            "        dispatch\n" +
            "    elif opcode == 115 as u32:\n" +
            "        dispatch.class_code = 11 as u32\n" +
            "        dispatch\n" +
            "    else:\n" +
            "        dispatch\n\n" +
            "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}_decode_trap_halt_control(clk: bool, reset_n: bool, imem_rdata: u32) -> u32:\n" +
            "    val control_inst = RiscvTrapHaltControlEncoding.new(imem_rdata)\n" +
            "    val opcode = control_inst.opcode as u32\n" +
            "    var control = RiscvTrapHaltControl.new(0 as u32)\n" +
            "    if opcode == 55 as u32 or opcode == 23 as u32 or opcode == 19 as u32 or opcode == 51 as u32 or opcode == 3 as u32 or opcode == 35 as u32 or opcode == 99 as u32 or opcode == 103 as u32 or opcode == 111 as u32 or opcode == 15 as u32:\n" +
            "        control.continue_exec = 1 as u32\n" +
            "        control\n" +
            "    elif opcode == 115 as u32:\n" +
            "        control.halt = 1 as u32\n" +
            "        control\n" +
            "    else:\n" +
            "        control.trap = 1 as u32\n" +
            "        control\n\n"

    fn hardware_source_top_level_contract(bitfield_name: text) -> text:
        "@hardware\n" +
            "@clocked(clk, reset_n)\n" +
            "fn {self.top_module}(clk: bool, reset_n: bool, imem_rdata: u32, dmem_rdata: u{self.xlen.bits()}) -> u{self.xlen.bits()}:\n" +
            "    val inst = {bitfield_name}.new(imem_rdata)\n" +
            "    val opcode = inst.opcode as u32\n" +
            "    val funct3 = inst.funct3 as u32\n" +
            "    val funct7 = inst.funct7 as u32\n" +
            "    val rd = inst.rd as u32\n" +
            "    # VHDL lowering owns these bitfield reads as slices:\n" +
            "    # inst.opcode -> imem_rdata(6 downto 0)\n" +
            "    # inst.rd -> imem_rdata(11 downto 7)\n" +
            "    # inst.funct3 -> imem_rdata(14 downto 12)\n" +
            "    # inst.rs1 -> imem_rdata(19 downto 15)\n" +
            "    # inst.rs2 -> imem_rdata(24 downto 20)\n" +
            "    # inst.funct7 -> imem_rdata(31 downto 25)\n" +
            "    # RiscvBranchEncoding.bit11 -> imem_rdata(7 downto 7)\n" +
            "    # RiscvBranchEncoding.low -> imem_rdata(11 downto 8)\n" +
            "    # RiscvBranchEncoding.high -> imem_rdata(30 downto 25)\n" +
            "    # RiscvBranchEncoding.bit12 -> imem_rdata(31 downto 31)\n" +
            "    # RiscvStoreEncoding.low -> imem_rdata(11 downto 7)\n" +
            "    # RiscvStoreEncoding.high -> imem_rdata(31 downto 25)\n" +
            "    # RiscvIImmediateEncoding.value -> imem_rdata(31 downto 20)\n" +
            "    # RiscvUpperImmediateEncoding.high20 -> imem_rdata(31 downto 12)\n" +
            "    # RiscvExecuteControlEncoding.funct3 -> imem_rdata(14 downto 12)\n" +
            "    # RiscvExecuteControlEncoding.shamt_low5 -> imem_rdata(24 downto 20)\n" +
            "    # RiscvExecuteControlEncoding.shamt_bit5 -> imem_rdata(25 downto 25)\n" +
            "    # RiscvExecuteControlEncoding.bit30 -> imem_rdata(30 downto 30)\n" +
            "    # RiscvExecuteDatapathEncoding.opcode -> imem_rdata(6 downto 0)\n" +
            "    # RiscvExecuteDatapathEncoding.funct3 -> imem_rdata(14 downto 12)\n" +
            "    # RiscvExecuteDatapathEncoding.bit30 -> imem_rdata(30 downto 30)\n" +
            "    # RiscvBranchDatapathEncoding.opcode -> imem_rdata(6 downto 0)\n" +
            "    # RiscvBranchDatapathEncoding.funct3 -> imem_rdata(14 downto 12)\n" +
            "    # RiscvControlFlowDatapathEncoding.opcode -> imem_rdata(6 downto 0)\n" +
            "    # RiscvMemoryAccessControlEncoding.funct3 -> imem_rdata(14 downto 12)\n" +
            "    # RiscvJumpEncoding.high8 -> imem_rdata(19 downto 12)\n" +
            "    # RiscvJumpEncoding.bit11 -> imem_rdata(20 downto 20)\n" +
            "    # RiscvJumpEncoding.low10 -> imem_rdata(30 downto 21)\n" +
            "    # RiscvJumpEncoding.bit20 -> imem_rdata(31 downto 31)\n" +
            "    # RiscvDispatchClassEncoding.opcode -> imem_rdata(6 downto 0)\n" +
            "    # RiscvTrapHaltControlEncoding.opcode -> imem_rdata(6 downto 0)\n" +
            "    # base integer instructions: {self.base_integer_instruction_mnemonics().join(\",\")}\n" +
            "    if opcode == 19 as u32:\n" +
            "        rd as u{self.xlen.bits()}\n" +
            "    elif opcode == 51 as u32 and funct3 == 0 as u32 and funct7 == 0 as u32:\n" +
            "        rd as u{self.xlen.bits()}\n" +
            "    else:\n" +
            "        imem_rdata as u{self.xlen.bits()}\n"

    fn hardware_source_spl() -> text:
        val bitfield_name = self.instruction_bitfield_name()
        self.hardware_source_intro() +
            self.hardware_source_bitfield_definitions(bitfield_name) +
            self.hardware_source_helper_definitions(bitfield_name) +
            self.hardware_source_top_level_contract(bitfield_name)

    fn hardware_source_contract_errors() -> [text]:
        val source = self.hardware_source_spl()
        var errors: [text] = []
        if not source.contains("bitfield {self.instruction_bitfield_name()}(u32):"):
            errors.push("{self.xlen.to_text()} hardware source must define instruction bitfield")
        if not source.contains("opcode: 7"):
            errors.push("{self.xlen.to_text()} hardware source must define seven-bit opcode")
        if not source.contains("@hardware"):
            errors.push("{self.xlen.to_text()} hardware source must preserve @hardware metadata")
        if not source.contains("@clocked"):
            errors.push("{self.xlen.to_text()} hardware source must preserve @clocked metadata")
        if not source.contains("fn {self.top_module}_decode_writeback"):
            errors.push("{self.xlen.to_text()} hardware source must define decode/writeback helper")
        if not source.contains("fn {self.top_module}_decode_branch_immediate"):
            errors.push("{self.xlen.to_text()} hardware source must define branch immediate helper")
        if not source.contains("fn {self.top_module}_decode_store_immediate"):
            errors.push("{self.xlen.to_text()} hardware source must define store immediate helper")
        if not source.contains("fn {self.top_module}_decode_i_immediate"):
            errors.push("{self.xlen.to_text()} hardware source must define I-type immediate helper")
        if not source.contains("fn {self.top_module}_decode_upper_immediate"):
