            "                                        trap_reg <= '1';\n" +
            "                                    end if;\n" +
            "                                end if;\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(instr_size_bytes, XLEN));\n" +
            "                            when \"1100\" =>\n" +
            "                                if decode_writeback_rd_i /= 0 then\n" +
            "                                    if XLEN = 64 and decode_execute_is_reg = '0' then\n" +
            "                                        case decode_execute_alu_op is\n" +
            "                                            when \"0000\" => regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(regs(rs1_i)(31 downto 0)) + signed(imm_i(31 downto 0)), XLEN));\n" +
            "                                            when \"0010\" => regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(std_logic_vector(shift_left(unsigned(regs(rs1_i)(31 downto 0)), to_integer(unsigned(instr_word_v(24 downto 20)))))), XLEN));\n" +
            "                                            when \"0110\" => regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(std_logic_vector(shift_right(unsigned(regs(rs1_i)(31 downto 0)), to_integer(unsigned(instr_word_v(24 downto 20)))))), XLEN));\n" +
            "                                            when \"0111\" => regs(decode_writeback_rd_i) <= std_logic_vector(resize(shift_right(signed(regs(rs1_i)(31 downto 0)), to_integer(unsigned(instr_word_v(24 downto 20)))), XLEN));\n" +
            "                                            when others => trap_reg <= '1';\n" +
            "                                        end case;\n" +
            "                                    else\n" +
            "                                        trap_reg <= '1';\n" +
            "                                    end if;\n" +
            "                                end if;\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(instr_size_bytes, XLEN));\n" +
            "                            when \"0100\" =>\n" +
            "                                if decode_writeback_rd_i /= 0 then\n" +
            "                                    if decode_execute_is_reg = '1' then\n" +
            "                                        if decode_execute_alu_op = \"1111\" then\n" +
            "                                            case instr_word_v(14 downto 12) is\n" +
            "                                                when \"000\" => regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(regs(rs1_i)) * signed(regs(rs2_i)), XLEN));\n" +
            "                                                when \"100\" =>\n" +
            "                                                    if regs(rs2_i) = x\"0000000000000000\" then\n" +
            "                                                        regs(decode_writeback_rd_i) <= (others => '1');\n" +
            "                                                    elsif regs(rs1_i) = x\"{self.min_signed_hex()}\" and regs(rs2_i) = x\"{self.all_ones_hex()}\" then\n" +
            "                                                        regs(decode_writeback_rd_i) <= regs(rs1_i);\n" +
            "                                                    else\n" +
            "                                                        regs(decode_writeback_rd_i) <= std_logic_vector(signed(regs(rs1_i)) / signed(regs(rs2_i)));\n" +
            "                                                    end if;\n" +
            "                                                when \"101\" =>\n" +
            "                                                    if regs(rs2_i) = x\"0000000000000000\" then\n" +
            "                                                        regs(decode_writeback_rd_i) <= (others => '1');\n" +
            "                                                    else\n" +
            "                                                        regs(decode_writeback_rd_i) <= std_logic_vector(unsigned(regs(rs1_i)) / unsigned(regs(rs2_i)));\n" +
            "                                                    end if;\n" +
            "                                                when \"110\" =>\n" +
            "                                                    if regs(rs2_i) = x\"0000000000000000\" then\n" +
            "                                                        regs(decode_writeback_rd_i) <= regs(rs1_i);\n" +
            "                                                    elsif regs(rs1_i) = x\"{self.min_signed_hex()}\" and regs(rs2_i) = x\"{self.all_ones_hex()}\" then\n" +
            "                                                        regs(decode_writeback_rd_i) <= (others => '0');\n" +
            "                                                    else\n" +
            "                                                        regs(decode_writeback_rd_i) <= std_logic_vector(signed(regs(rs1_i)) rem signed(regs(rs2_i)));\n" +
            "                                                    end if;\n" +
            "                                                when \"111\" =>\n" +
            "                                                    if regs(rs2_i) = x\"0000000000000000\" then\n" +
            "                                                        regs(decode_writeback_rd_i) <= regs(rs1_i);\n" +
            "                                                    else\n" +
            "                                                        regs(decode_writeback_rd_i) <= std_logic_vector(unsigned(regs(rs1_i)) rem unsigned(regs(rs2_i)));\n" +
            "                                                    end if;\n" +
            "                                                when others => trap_reg <= '1';\n" +
            "                                            end case;\n" +
            "                                        else\n" +
            "                                        case decode_execute_alu_op is\n" +
            "                                            when \"0000\" => regs(decode_writeback_rd_i) <= std_logic_vector(signed(regs(rs1_i)) + signed(regs(rs2_i)));\n" +
            "                                            when \"0001\" => regs(decode_writeback_rd_i) <= std_logic_vector(signed(regs(rs1_i)) - signed(regs(rs2_i)));\n" +
            "                                            when \"0010\" => regs(decode_writeback_rd_i) <= std_logic_vector(shift_left(unsigned(regs(rs1_i)), shift_i));\n" +
            "                                            when \"0011\" =>\n" +
            "                                                if signed(regs(rs1_i)) < signed(regs(rs2_i)) then\n" +
            "                                                    regs(decode_writeback_rd_i) <= std_logic_vector(to_unsigned(1, XLEN));\n" +
            "                                                else\n" +
            "                                                    regs(decode_writeback_rd_i) <= (others => '0');\n" +
            "                                                end if;\n" +
            "                                            when \"0100\" =>\n" +
            "                                                if unsigned(regs(rs1_i)) < unsigned(regs(rs2_i)) then\n" +
            "                                                    regs(decode_writeback_rd_i) <= std_logic_vector(to_unsigned(1, XLEN));\n" +
            "                                                else\n" +
            "                                                    regs(decode_writeback_rd_i) <= (others => '0');\n" +
            "                                                end if;\n" +
            "                                            when \"0101\" => regs(decode_writeback_rd_i) <= regs(rs1_i) xor regs(rs2_i);\n" +
            "                                            when \"0110\" => regs(decode_writeback_rd_i) <= std_logic_vector(shift_right(unsigned(regs(rs1_i)), shift_i));\n" +
            "                                            when \"0111\" => regs(decode_writeback_rd_i) <= std_logic_vector(shift_right(signed(regs(rs1_i)), shift_i));\n" +
            "                                            when \"1000\" => regs(decode_writeback_rd_i) <= regs(rs1_i) or regs(rs2_i);\n" +
            "                                            when \"1001\" => regs(decode_writeback_rd_i) <= regs(rs1_i) and regs(rs2_i);\n" +
            "                                            when others => trap_reg <= '1';\n" +
            "                                        end case;\n" +
            "                                        end if;\n" +
            "                                    else\n" +
            "                                        trap_reg <= '1';\n" +
            "                                    end if;\n" +
            "                                end if;\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(instr_size_bytes, XLEN));\n" +
            "                            when \"1101\" =>\n" +
            "                                if decode_writeback_rd_i /= 0 then\n" +
            "                                    if XLEN = 64 and decode_execute_is_reg = '1' then\n" +
            "                                        if decode_execute_alu_op = \"1111\" then\n" +
            "                                            case instr_word_v(14 downto 12) is\n" +
            "                                                when \"000\" => regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(std_logic_vector(resize(signed(regs(rs1_i)(31 downto 0)) * signed(regs(rs2_i)(31 downto 0)), 32))), XLEN));\n" +
            "                                                when \"100\" =>\n" +
            "                                                    if regs(rs2_i)(31 downto 0) = x\"00000000\" then\n" +
            "                                                        regs(decode_writeback_rd_i) <= x\"{self.all_ones_hex()}\";\n" +
            "                                                    elsif regs(rs1_i)(31 downto 0) = x\"80000000\" and regs(rs2_i)(31 downto 0) = x\"FFFFFFFF\" then\n" +
            "                                                        regs(decode_writeback_rd_i) <= x\"{self.word_div_overflow_hex()}\";\n" +
            "                                                    else\n" +
            "                                                        regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(std_logic_vector(signed(regs(rs1_i)(31 downto 0)) / signed(regs(rs2_i)(31 downto 0)))), XLEN));\n" +
            "                                                    end if;\n" +
            "                                                when \"101\" =>\n" +
            "                                                    if regs(rs2_i)(31 downto 0) = x\"00000000\" then\n" +
            "                                                        regs(decode_writeback_rd_i) <= x\"{self.all_ones_hex()}\";\n" +
            "                                                    else\n" +
            "                                                        regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(std_logic_vector(unsigned(regs(rs1_i)(31 downto 0)) / unsigned(regs(rs2_i)(31 downto 0)))), XLEN));\n" +
            "                                                    end if;\n" +
            "                                                when \"110\" =>\n" +
            "                                                    if regs(rs2_i)(31 downto 0) = x\"00000000\" then\n" +
            "                                                        regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(regs(rs1_i)(31 downto 0)), XLEN));\n" +
            "                                                    elsif regs(rs1_i)(31 downto 0) = x\"80000000\" and regs(rs2_i)(31 downto 0) = x\"FFFFFFFF\" then\n" +
            "                                                        regs(decode_writeback_rd_i) <= (others => '0');\n" +
            "                                                    else\n" +
            "                                                        regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(std_logic_vector(signed(regs(rs1_i)(31 downto 0)) rem signed(regs(rs2_i)(31 downto 0)))), XLEN));\n" +
            "                                                    end if;\n" +
            "                                                when \"111\" =>\n" +
            "                                                    if regs(rs2_i)(31 downto 0) = x\"00000000\" then\n" +
            "                                                        regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(regs(rs1_i)(31 downto 0)), XLEN));\n" +
            "                                                    else\n" +
            "                                                        regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(std_logic_vector(unsigned(regs(rs1_i)(31 downto 0)) rem unsigned(regs(rs2_i)(31 downto 0)))), XLEN));\n" +
            "                                                    end if;\n" +
            "                                                when others => trap_reg <= '1';\n" +
            "                                            end case;\n" +
            "                                        else\n" +
            "                                        case decode_execute_alu_op is\n" +
            "                                            when \"0000\" => regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(regs(rs1_i)(31 downto 0)) + signed(regs(rs2_i)(31 downto 0)), XLEN));\n" +
            "                                            when \"0001\" => regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(regs(rs1_i)(31 downto 0)) - signed(regs(rs2_i)(31 downto 0)), XLEN));\n" +
            "                                            when \"0010\" => regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(std_logic_vector(shift_left(unsigned(regs(rs1_i)(31 downto 0)), to_integer(unsigned(regs(rs2_i)(4 downto 0)))))), XLEN));\n" +
            "                                            when \"0110\" => regs(decode_writeback_rd_i) <= std_logic_vector(resize(signed(std_logic_vector(shift_right(unsigned(regs(rs1_i)(31 downto 0)), to_integer(unsigned(regs(rs2_i)(4 downto 0)))))), XLEN));\n" +
            "                                            when \"0111\" => regs(decode_writeback_rd_i) <= std_logic_vector(resize(shift_right(signed(regs(rs1_i)(31 downto 0)), to_integer(unsigned(regs(rs2_i)(4 downto 0)))), XLEN));\n" +
            "                                            when others => trap_reg <= '1';\n" +
            "                                        end case;\n" +
            "                                        end if;\n" +
            "                                    else\n" +
            "                                        trap_reg <= '1';\n" +
            "                                    end if;\n" +
            "                                end if;\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(instr_size_bytes, XLEN));\n" +
            "                            when \"0101\" =>\n" +
            "                                addr_i := unsigned(signed(regs(rs1_i)) + imm_i);\n" +
            "                                {load_translate_lines}" +
            "                                dmem_addr_reg <= translated_addr_v;\n" +
            "                                dmem_re_reg <= '1';\n" +
            "                                if translated_fault_v = '1' then\n" +
            "                                    dmem_re_reg <= '0';\n" +
            "                                    csr_mepc_reg <= pc_reg;\n" +
            "                                    csr_mcause_reg <= std_logic_vector(to_unsigned({self.sv39_page_fault_cause_decimal(\"read\")}, XLEN));\n" +
            "                                    csr_mtval_reg <= std_logic_vector(addr_i);\n" +
            "                                    csr_mstatus_reg(7) <= csr_mstatus_reg(3);\n" +
            "                                    csr_mstatus_reg(3) <= '0';\n" +
            "                                    csr_mstatus_reg(12 downto 11) <= priv_mode_reg;\n" +
            "                                    priv_mode_reg <= \"11\";\n" +
            "                                    pc_reg <= csr_mtvec_reg;\n" +
            "                                else\n" +
            "                                load_should_issue_v := false;\n" +
            "                                case decode_memory_funct3 is\n" +
            "                                    when \"000\" =>\n" +
            "                                        dmem_width_reg <= \"00\";\n" +
            "                                        load_should_issue_v := true;\n" +
            "                                    when \"001\" =>\n" +
            "                                        dmem_width_reg <= \"01\";\n" +
            "                                        if addr_i(0) = '1' then\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        else\n" +
            "                                            load_should_issue_v := true;\n" +
            "                                        end if;\n" +
            "                                    when \"010\" =>\n" +
            "                                        dmem_width_reg <= \"10\";\n" +
            "                                        if addr_i(1 downto 0) /= \"00\" then\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        else\n" +
            "                                            load_should_issue_v := true;\n" +
            "                                        end if;\n" +
            "                                    when \"011\" =>\n" +
            "                                        dmem_width_reg <= \"11\";\n" +
            "                                        if XLEN = 64 then\n" +
            "                                            if addr_i(2 downto 0) /= \"000\" then\n" +
            "                                                trap_reg <= '1';\n" +
            "                                            else\n" +
            "                                                load_should_issue_v := true;\n" +
            "                                            end if;\n" +
            "                                        else\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        end if;\n" +
            "                                    when \"100\" =>\n" +
            "                                        dmem_width_reg <= \"00\";\n" +
            "                                        load_should_issue_v := true;\n" +
            "                                    when \"101\" =>\n" +
            "                                        dmem_width_reg <= \"01\";\n" +
            "                                        if addr_i(0) = '1' then\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        else\n" +
            "                                            load_should_issue_v := true;\n" +
            "                                        end if;\n" +
            "                                    when \"110\" =>\n" +
            "                                        dmem_width_reg <= \"10\";\n" +
            "                                        if XLEN = 64 then\n" +
            "                                            if addr_i(1 downto 0) /= \"00\" then\n" +
            "                                                trap_reg <= '1';\n" +
            "                                            else\n" +
            "                                                load_should_issue_v := true;\n" +
            "                                            end if;\n" +
            "                                        else\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        end if;\n" +
            "                                    when others => trap_reg <= '1';\n" +
            "                                end case;\n" +
            "                                if load_should_issue_v then\n" +
            "                                    load_issue_reg <= '1';\n" +
            "                                    load_pending_reg <= '1';\n" +
            "                                    load_pending_rd_reg <= rd_i;\n" +
            "                                    load_pending_addr_reg <= std_logic_vector(addr_i);\n" +
            "                                    load_pending_funct3_reg <= decode_memory_funct3;\n" +
            "                                    pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(instr_size_bytes, XLEN));\n" +
            "                                else\n" +
            "                                    dmem_re_reg <= '0';\n" +
            "                                end if;\n" +
            "                                end if;\n" +
            "                            when \"0110\" =>\n" +
            "                                imm_i := resize(signed(decode_store_immediate_bits(11 downto 0)), XLEN);\n" +
            "                                addr_i := unsigned(signed(regs(rs1_i)) + imm_i);\n" +
            "                                {store_translate_lines}" +
            "                                dmem_addr_reg <= translated_addr_v;\n" +
            "                                if translated_fault_v = '1' then\n" +
            "                                    dmem_we_reg <= '0';\n" +
            "                                    dmem_wstrb_reg <= (others => '0');\n" +
            "                                    csr_mepc_reg <= pc_reg;\n" +
            "                                    csr_mcause_reg <= std_logic_vector(to_unsigned({self.sv39_page_fault_cause_decimal(\"write\")}, XLEN));\n" +
            "                                    csr_mtval_reg <= std_logic_vector(addr_i);\n" +
            "                                    csr_mstatus_reg(7) <= csr_mstatus_reg(3);\n" +
            "                                    csr_mstatus_reg(3) <= '0';\n" +
            "                                    csr_mstatus_reg(12 downto 11) <= priv_mode_reg;\n" +
            "                                    priv_mode_reg <= \"11\";\n" +
            "                                    pc_reg <= csr_mtvec_reg;\n" +
            "                                else\n" +
            "                                case decode_memory_funct3 is\n" +
            "                                    when \"000\" =>\n" +
            "                                        dmem_width_reg <= \"00\";\n" +
            "                                        if XLEN = 64 then\n" +
            "                                            dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(2 downto 0))) * 8));\n" +
            "                                            dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(1, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));\n" +
            "                                        else\n" +
            "                                            dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(1 downto 0))) * 8));\n" +
            "                                            dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(1, XLEN / 8), to_integer(unsigned(addr_i(1 downto 0)))));\n" +
            "                                        end if;\n" +
            "                                        dmem_we_reg <= '1';\n" +
            "                                    when \"001\" =>\n" +
            "                                        dmem_width_reg <= \"01\";\n" +
            "                                        if addr_i(0) = '1' then\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        elsif XLEN = 64 then\n" +
            "                                            dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(2 downto 0))) * 8));\n" +
            "                                            dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(3, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));\n" +
            "                                            dmem_we_reg <= '1';\n" +
            "                                        else\n" +
            "                                            dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(1 downto 0))) * 8));\n" +
            "                                            dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(3, XLEN / 8), to_integer(unsigned(addr_i(1 downto 0)))));\n" +
            "                                            dmem_we_reg <= '1';\n" +
            "                                        end if;\n" +
            "                                    when \"010\" =>\n" +
            "                                        dmem_width_reg <= \"10\";\n" +
            "                                        if addr_i(1 downto 0) /= \"00\" then\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        elsif XLEN = 64 then\n" +
            "                                            dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(regs(rs2_i)), to_integer(unsigned(addr_i(2 downto 0))) * 8));\n" +
            "                                            dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(15, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));\n" +
            "                                            dmem_we_reg <= '1';\n" +
            "                                        elsif XLEN = 32 then\n" +
            "                                            dmem_wdata_reg <= regs(rs2_i);\n" +
            "                                            dmem_wstrb_reg <= std_logic_vector(to_unsigned(15, XLEN / 8));\n" +
            "                                            dmem_we_reg <= '1';\n" +
            "                                        else\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        end if;\n" +
            "                                    when \"011\" =>\n" +
            "                                        dmem_width_reg <= \"11\";\n" +
            "                                        if XLEN = 64 then\n" +
            "                                            if addr_i(2 downto 0) /= \"000\" then\n" +
            "                                                trap_reg <= '1';\n" +
            "                                            else\n" +
            "                                                dmem_wdata_reg <= regs(rs2_i);\n" +
            "                                                dmem_wstrb_reg <= (others => '1');\n" +
            "                                                dmem_we_reg <= '1';\n" +
            "                                            end if;\n" +
            "                                        else\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        end if;\n" +
            "                                    when others =>\n" +
            "                                        dmem_width_reg <= \"00\";\n" +
            "                                        trap_reg <= '1';\n" +
            "                                end case;\n" +
            "                                if trap_reg = '0' then\n" +
            "                                    reservation_valid_reg <= '0';\n" +
            "                                end if;\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(instr_size_bytes, XLEN));\n" +
            "                                end if;\n"

    fn core_vhdl_control_region() -> text:
        val amo_translate_lines = self.mmu_translate_lines("std_logic_vector(addr_i)", true)
        "                            when \"0111\" =>\n" +
            "                                case decode_branch_op is\n" +
            "                                    when \"000\" => branch_taken := regs(rs1_i) = regs(rs2_i);\n" +
            "                                    when \"001\" => branch_taken := regs(rs1_i) /= regs(rs2_i);\n" +
            "                                    when \"010\" => branch_taken := signed(regs(rs1_i)) < signed(regs(rs2_i));\n" +
            "                                    when \"011\" => branch_taken := signed(regs(rs1_i)) >= signed(regs(rs2_i));\n" +
            "                                    when \"100\" => branch_taken := unsigned(regs(rs1_i)) < unsigned(regs(rs2_i));\n" +
            "                                    when \"101\" => branch_taken := unsigned(regs(rs1_i)) >= unsigned(regs(rs2_i));\n" +
            "                                    when others => trap_reg <= '1';\n" +
            "                                end case;\n" +
            "                                if decode_next_pc_op = \"01\" and branch_taken then\n" +
            "                                    pc_reg <= std_logic_vector(unsigned(signed(pc_reg) + branch_i));\n" +
            "                                else\n" +
            "                                    pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(instr_size_bytes, XLEN));\n" +
            "                                end if;\n" +
            "                            when \"1000\" =>\n" +
            "                                addr_i := unsigned(signed(regs(rs1_i)) + imm_i);\n" +
            "                                addr_i(0) := '0';\n" +
            "                                if decode_writes_link = '1' and rd_i /= 0 then\n" +
            "                                    regs(rd_i) <= std_logic_vector(unsigned(pc_reg) + to_unsigned(instr_size_bytes, XLEN));\n" +
            "                                end if;\n" +
            "                                if decode_next_pc_op = \"10\" then\n" +
            "                                    pc_reg <= std_logic_vector(addr_i);\n" +
            "                                else\n" +
            "                                    trap_reg <= '1';\n" +
            "                                end if;\n" +
            "                            when \"1001\" =>\n" +
            "                                if decode_writes_link = '1' and rd_i /= 0 then\n" +
            "                                    regs(rd_i) <= std_logic_vector(unsigned(pc_reg) + to_unsigned(instr_size_bytes, XLEN));\n" +
            "                                end if;\n" +
            "                                if decode_next_pc_op = \"11\" then\n" +
            "                                    pc_reg <= std_logic_vector(unsigned(signed(pc_reg) + jump_i));\n" +
            "                                else\n" +
            "                                    trap_reg <= '1';\n" +
            "                                end if;\n" +
            "                            when \"1110\" =>\n" +
            "                                addr_i := unsigned(regs(rs1_i));\n" +
            "                                {amo_translate_lines}" +
            "                                dmem_addr_reg <= translated_addr_v;\n" +
            "                                dmem_re_reg <= '1';\n" +
            "                                if translated_fault_v = '1' then\n" +
            "                                    dmem_re_reg <= '0';\n" +
            "                                    csr_mepc_reg <= pc_reg;\n" +
            "                                    csr_mcause_reg <= std_logic_vector(to_unsigned({self.sv39_page_fault_cause_decimal(\"write\")}, XLEN));\n" +
            "                                    csr_mtval_reg <= std_logic_vector(addr_i);\n" +
            "                                    csr_mstatus_reg(7) <= csr_mstatus_reg(3);\n" +
            "                                    csr_mstatus_reg(3) <= '0';\n" +
            "                                    csr_mstatus_reg(12 downto 11) <= priv_mode_reg;\n" +
            "                                    priv_mode_reg <= \"11\";\n" +
            "                                    pc_reg <= csr_mtvec_reg;\n" +
            "                                else\n" +
            "                                    if instr_word_v(14 downto 12) = \"010\" then\n" +
            "                                        dmem_width_reg <= \"10\";\n" +
            "                                        if addr_i(1 downto 0) /= \"00\" then\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        else\n" +
            "                                            amo_pending_reg <= '1';\n" +
            "                                        end if;\n" +
            "                                    elsif XLEN = 64 and instr_word_v(14 downto 12) = \"011\" then\n" +
            "                                        dmem_width_reg <= \"11\";\n" +
            "                                        if addr_i(2 downto 0) /= \"000\" then\n" +
            "                                            trap_reg <= '1';\n" +
            "                                        else\n" +
            "                                            amo_pending_reg <= '1';\n" +
            "                                        end if;\n" +
            "                                    else\n" +
            "                                        trap_reg <= '1';\n" +
            "                                    end if;\n" +
            "                                    if trap_reg = '0' then\n" +
            "                                        amo_pending_rd_reg <= rd_i;\n" +
            "                                        amo_pending_addr_reg <= translated_addr_v;\n" +
            "                                        amo_pending_funct3_reg <= instr_word_v(14 downto 12);\n" +
            "                                        amo_pending_funct5_reg <= instr_word_v(31 downto 27);\n" +
            "                                        amo_pending_rs2_value_reg <= regs(rs2_i);\n" +
            "                                    end if;\n" +
            "                                end if;\n" +
            "                            when \"1010\" =>\n" +
            "                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(instr_size_bytes, XLEN));\n" +
            "                            when \"1011\" =>\n" +
            "                                if instr_word_v(14 downto 12) = \"000\" then\n" +
            "                                    if instr_word_v = x\"00100073\" then\n" +
            "                                        halt_reg <= '1';\n" +
            "                                    elsif instr_word_v = x\"00000073\" then\n" +
            "                                        if priv_mode_reg = \"00\" and csr_medeleg_reg(8) = '1' then\n" +
            "                                            csr_sepc_reg <= pc_reg;\n" +
            "                                            csr_scause_reg <= std_logic_vector(to_unsigned(8, XLEN));\n" +
            "                                            csr_stval_reg <= (others => '0');\n" +
            "                                            csr_mstatus_reg(5) <= csr_mstatus_reg(1);\n" +
            "                                            csr_mstatus_reg(1) <= '0';\n" +
            "                                            csr_mstatus_reg(8) <= '0';\n" +
            "                                            priv_mode_reg <= \"01\";\n" +
            "                                            pc_reg <= csr_stvec_reg;\n" +
            "                                        else\n" +
            "                                            csr_mepc_reg <= pc_reg;\n" +
            "                                            if priv_mode_reg = \"00\" then\n" +
            "                                                csr_mcause_reg <= std_logic_vector(to_unsigned(8, XLEN));\n" +
            "                                            elsif priv_mode_reg = \"01\" then\n" +
            "                                                csr_mcause_reg <= std_logic_vector(to_unsigned(9, XLEN));\n" +
            "                                            else\n" +
            "                                                csr_mcause_reg <= std_logic_vector(to_unsigned(11, XLEN));\n" +
            "                                            end if;\n" +
            "                                            csr_mtval_reg <= (others => '0');\n" +
            "                                            csr_mstatus_reg(7) <= csr_mstatus_reg(3);\n" +
            "                                            csr_mstatus_reg(3) <= '0';\n" +
            "                                            csr_mstatus_reg(12 downto 11) <= priv_mode_reg;\n" +
            "                                            priv_mode_reg <= \"11\";\n" +
            "                                            pc_reg <= csr_mtvec_reg;\n" +
            "                                        end if;\n" +
            "                                    elsif instr_word_v = x\"30200073\" then\n" +
            "                                        mret_mpp_v := csr_mstatus_reg(12 downto 11);\n" +
            "                                        csr_mstatus_reg(3) <= csr_mstatus_reg(7);\n" +
            "                                        csr_mstatus_reg(7) <= '1';\n" +
            "                                        csr_mstatus_reg(12 downto 11) <= \"00\";\n" +
            "                                        priv_mode_reg <= mret_mpp_v;\n" +
            "                                        pc_reg <= csr_mepc_reg;\n" +
            "                                    elsif instr_word_v = x\"10200073\" then\n" +
            "                                        csr_mstatus_reg(1) <= csr_mstatus_reg(5);\n" +
            "                                        csr_mstatus_reg(5) <= '1';\n" +
            "                                        if csr_mstatus_reg(8) = '1' then\n" +
            "                                            priv_mode_reg <= \"01\";\n" +
            "                                        else\n" +
            "                                            priv_mode_reg <= \"00\";\n" +
            "                                        end if;\n" +
            "                                        csr_mstatus_reg(8) <= '0';\n" +
            "                                        pc_reg <= csr_sepc_reg;\n" +
            "                                    elsif instr_word_v(31 downto 25) = \"0001001\" then\n" +
            "                                        pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(instr_size_bytes, XLEN));\n" +
            "                                    else\n" +
            "                                        trap_reg <= '1';\n" +
            "                                    end if;\n" +
            "                                else\n" +
            "                                    csr_old_val := (others => '0');\n" +
            "                                    csr_new_val := (others => '0');\n" +
            "                                    case instr_word_v(31 downto 20) is\n" +
            "                                        when x\"100\" => csr_old_val := csr_mstatus_reg and x\"{self.sstatus_mask_hex()}\";\n" +
            "                                        when x\"301\" => csr_old_val := x\"{self.misa_reset_hex()}\";\n" +
            "                                        when x\"300\" => csr_old_val := csr_mstatus_reg;\n" +
            "                                        when x\"104\" => csr_old_val := csr_mie_reg and csr_mideleg_reg;\n" +
            "                                        when x\"304\" => csr_old_val := csr_mie_reg;\n" +
            "                                        when x\"105\" => csr_old_val := csr_stvec_reg;\n" +
            "                                        when x\"106\" => csr_old_val := csr_scounteren_reg;\n" +
            "                                        when x\"305\" => csr_old_val := csr_mtvec_reg;\n" +
            "                                        when x\"306\" => csr_old_val := csr_mcounteren_reg;\n" +
            "                                        when x\"140\" => csr_old_val := csr_sscratch_reg;\n" +
            "                                        when x\"340\" => csr_old_val := csr_mscratch_reg;\n" +
            "                                        when x\"141\" => csr_old_val := csr_sepc_reg;\n" +
            "                                        when x\"341\" => csr_old_val := csr_mepc_reg;\n" +
            "                                        when x\"142\" => csr_old_val := csr_scause_reg;\n" +
            "                                        when x\"342\" => csr_old_val := csr_mcause_reg;\n" +
            "                                        when x\"143\" => csr_old_val := csr_stval_reg;\n" +
            "                                        when x\"180\" => csr_old_val := csr_satp_reg;\n" +
            "                                        when x\"343\" => csr_old_val := csr_mtval_reg;\n" +
            "                                        when x\"144\" =>\n" +
            "                                            csr_old_val := (others => '0');\n" +
            "                                            csr_old_val(9) := irq_external;\n" +
            "                                            csr_old_val(5) := irq_timer;\n" +
            "                                            csr_old_val(1) := irq_software;\n" +
            "                                            csr_old_val := csr_old_val and csr_mideleg_reg;\n" +
            "                                        when x\"302\" => csr_old_val := csr_medeleg_reg;\n" +
            "                                        when x\"303\" => csr_old_val := csr_mideleg_reg;\n" +
            "                                        when x\"344\" =>\n" +
            "                                            csr_old_val := (others => '0');\n" +
            "                                            csr_old_val(11) := irq_external;\n" +
            "                                            csr_old_val(7) := irq_timer;\n" +
            "                                            csr_old_val(3) := irq_software;\n" +
            "                                        when x\"F11\" => csr_old_val := (others => '0');\n" +
            "                                        when x\"F12\" => csr_old_val := (others => '0');\n" +
            "                                        when x\"F13\" => csr_old_val := (others => '0');\n" +
            "                                        when x\"F14\" => csr_old_val := (others => '0');\n" +
            "                                        when others => trap_reg <= '1';\n" +
            "                                    end case;\n" +
            "                                    if trap_reg = '0' then\n" +
            "                                        case instr_word_v(14 downto 12) is\n" +
            "                                            when \"001\" => csr_new_val := regs(rs1_i);\n" +
            "                                            when \"010\" =>\n" +
            "                                                if rs1_i = 0 then\n" +
            "                                                    csr_new_val := csr_old_val;\n" +
            "                                                else\n" +
            "                                                    csr_new_val := csr_old_val or regs(rs1_i);\n" +
            "                                                end if;\n" +
            "                                            when \"011\" =>\n" +
            "                                                if rs1_i = 0 then\n" +
            "                                                    csr_new_val := csr_old_val;\n" +
            "                                                else\n" +
            "                                                    csr_new_val := csr_old_val and (not regs(rs1_i));\n" +
            "                                                end if;\n" +
            "                                            when \"101\" => csr_new_val := std_logic_vector(to_unsigned(rs1_i, XLEN));\n" +
            "                                            when \"110\" =>\n" +
            "                                                if rs1_i = 0 then\n" +
            "                                                    csr_new_val := csr_old_val;\n" +
            "                                                else\n" +
            "                                                    csr_new_val := csr_old_val or std_logic_vector(to_unsigned(rs1_i, XLEN));\n" +
            "                                                end if;\n" +
            "                                            when \"111\" =>\n" +
            "                                                if rs1_i = 0 then\n" +
            "                                                    csr_new_val := csr_old_val;\n" +
            "                                                else\n" +
            "                                                    csr_new_val := csr_old_val and (not std_logic_vector(to_unsigned(rs1_i, XLEN)));\n" +
            "                                                end if;\n" +
            "                                            when others => trap_reg <= '1';\n" +
            "                                        end case;\n" +
            "                                    end if;\n" +
            "                                    if trap_reg = '0' then\n" +
            "                                        if rd_i /= 0 then\n" +
            "                                            regs(rd_i) <= csr_old_val;\n" +
            "                                        end if;\n" +
            "                                        case instr_word_v(14 downto 12) is\n" +
            "                                            when \"001\" | \"010\" | \"011\" | \"101\" | \"110\" | \"111\" =>\n" +
            "                                                case instr_word_v(31 downto 20) is\n" +
            "                                                    when x\"100\" => csr_mstatus_reg <= (csr_mstatus_reg and (not x\"{self.sstatus_mask_hex()}\")) or (csr_new_val and x\"{self.sstatus_mask_hex()}\");\n" +
            "                                                    when x\"300\" => csr_mstatus_reg <= csr_new_val;\n" +
            "                                                    when x\"104\" => csr_mie_reg <= (csr_mie_reg and (not csr_mideleg_reg)) or (csr_new_val and csr_mideleg_reg);\n" +
            "                                                    when x\"304\" => csr_mie_reg <= csr_new_val;\n" +
            "                                                    when x\"105\" => csr_stvec_reg <= csr_new_val;\n" +
            "                                                    when x\"106\" => csr_scounteren_reg <= csr_new_val;\n" +
            "                                                    when x\"305\" => csr_mtvec_reg <= csr_new_val;\n" +
            "                                                    when x\"306\" => csr_mcounteren_reg <= csr_new_val;\n" +
            "                                                    when x\"140\" => csr_sscratch_reg <= csr_new_val;\n" +
            "                                                    when x\"340\" => csr_mscratch_reg <= csr_new_val;\n" +
            "                                                    when x\"141\" => csr_sepc_reg <= csr_new_val;\n" +
            "                                                    when x\"341\" => csr_mepc_reg <= csr_new_val;\n" +
            "                                                    when x\"142\" => csr_scause_reg <= csr_new_val;\n" +
            "                                                    when x\"342\" => csr_mcause_reg <= csr_new_val;\n" +
            "                                                    when x\"143\" => csr_stval_reg <= csr_new_val;\n" +
            "                                                    when x\"180\" => csr_satp_reg <= csr_new_val;\n" +
            "                                                    when x\"343\" => csr_mtval_reg <= csr_new_val;\n" +
            "                                                    when x\"302\" => csr_medeleg_reg <= csr_new_val;\n" +
            "                                                    when x\"303\" => csr_mideleg_reg <= csr_new_val;\n" +
            "                                                    when others => null;\n" +
            "                                                end case;\n" +
            "                                                pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(instr_size_bytes, XLEN));\n" +
            "                                            when others => trap_reg <= '1';\n" +
            "                                        end case;\n" +
            "                                    end if;\n" +
            "                                end if;\n" +
            "                            when others =>\n" +
            "                                trap_reg <= '1';\n" +
            "                        end case;\n" +
            "                    elsif decode_should_halt = '1' then\n" +
            "                        halt_reg <= '1';\n" +
            "                    elsif decode_should_trap = '1' then\n" +
            "                        trap_reg <= '1';\n" +
            "                    end if;\n" +
            "                    semi_phase_reg <= 0;\n" +
            "                    regs(0) <= (others => '0');\n"

    fn core_vhdl_semihost_port_lines() -> text:
        "        semi_trigger  : out std_logic;\n" +
            "        semi_op       : out xword_t;\n" +
            "        semi_param    : out xword_t;\n"

    fn core_vhdl_semihost_signal_lines() -> text:
        "    signal semi_phase_reg : integer range 0 to 2 := 0;\n" +
            "    signal semi_trigger_reg : std_logic := '0';\n" +
            "    signal semi_op_reg : xword_t := (others => '0');\n" +
            "    signal semi_param_reg : xword_t := (others => '0');\n" +
            "    signal priv_mode_reg : std_logic_vector(1 downto 0) := \"11\";\n" +
            "    signal csr_mstatus_reg : xword_t := (others => '0');\n" +
            "    signal csr_mie_reg : xword_t := (others => '0');\n" +
            "    signal csr_mideleg_reg : xword_t := (others => '0');\n" +
            "    signal csr_medeleg_reg : xword_t := (others => '0');\n" +
            "    signal csr_mtvec_reg : xword_t := (others => '0');\n" +
            "    signal csr_mscratch_reg : xword_t := (others => '0');\n" +
            "    signal csr_mepc_reg : xword_t := (others => '0');\n" +
            "    signal csr_mcause_reg : xword_t := (others => '0');\n" +
            "    signal csr_mtval_reg : xword_t := (others => '0');\n" +
            "    signal csr_stvec_reg : xword_t := (others => '0');\n" +
            "    signal csr_scounteren_reg : xword_t := (others => '0');\n" +
            "    signal csr_sscratch_reg : xword_t := (others => '0');\n" +
            "    signal csr_sepc_reg : xword_t := (others => '0');\n" +
            "    signal csr_scause_reg : xword_t := (others => '0');\n" +
            "    signal csr_stval_reg : xword_t := (others => '0');\n" +
            "    signal csr_satp_reg : xword_t := (others => '0');\n" +
            "    signal csr_mcounteren_reg : xword_t := (others => '0');\n" +
            "    signal debug_last_load_value_reg : xword_t := (others => '0');\n" +
            "    signal load_data_reg : xword_t := (others => '0');\n" +
            "    signal amo_pending_reg : std_logic := '0';\n" +
            "    signal amo_pending_rd_reg : integer range 0 to 31 := 0;\n" +
            "    signal amo_pending_addr_reg : xword_t := (others => '0');\n" +
            "    signal amo_pending_funct3_reg : std_logic_vector(2 downto 0) := (others => '0');\n" +
            "    signal amo_pending_funct5_reg : std_logic_vector(4 downto 0) := (others => '0');\n" +
            "    signal amo_pending_rs2_value_reg : xword_t := (others => '0');\n" +
            "    signal reservation_valid_reg : std_logic := '0';\n" +
            "    signal reservation_addr_reg : xword_t := (others => '0');\n"

    fn core_vhdl_semihost_reset_lines() -> text:
        "            semi_phase_reg <= 0;\n" +
            "            semi_trigger_reg <= '0';\n" +
            "            semi_op_reg <= (others => '0');\n" +
            "            semi_param_reg <= (others => '0');\n" +
            "            priv_mode_reg <= \"11\";\n" +
            "            csr_mstatus_reg <= (others => '0');\n" +
            "            csr_mie_reg <= (others => '0');\n" +
            "            csr_mideleg_reg <= (others => '0');\n" +
            "            csr_medeleg_reg <= (others => '0');\n" +
            "            csr_mtvec_reg <= (others => '0');\n" +
            "            csr_mscratch_reg <= (others => '0');\n" +
            "            csr_mepc_reg <= (others => '0');\n" +
            "            csr_mcause_reg <= (others => '0');\n" +
            "            csr_mtval_reg <= (others => '0');\n" +
            "            csr_stvec_reg <= (others => '0');\n" +
            "            csr_scounteren_reg <= (others => '0');\n" +
            "            csr_sscratch_reg <= (others => '0');\n" +
            "            csr_sepc_reg <= (others => '0');\n" +
            "            csr_scause_reg <= (others => '0');\n" +
            "            csr_stval_reg <= (others => '0');\n" +
            "            csr_satp_reg <= (others => '0');\n" +
            "            csr_mcounteren_reg <= (others => '0');\n" +
            "            debug_last_load_value_reg <= (others => '0');\n" +
            "            load_data_reg <= (others => '0');\n" +
            "            amo_pending_reg <= '0';\n" +
            "            amo_pending_rd_reg <= 0;\n" +
            "            amo_pending_addr_reg <= (others => '0');\n" +
            "            amo_pending_funct3_reg <= (others => '0');\n" +
            "            amo_pending_funct5_reg <= (others => '0');\n" +
            "            amo_pending_rs2_value_reg <= (others => '0');\n" +
            "            reservation_valid_reg <= '0';\n" +
            "            reservation_addr_reg <= (others => '0');\n"

    fn core_vhdl_semihost_default_lines() -> text:
        "            semi_trigger_reg <= '0';\n"

    fn core_vhdl_semihost_output_lines() -> text:
        "    semi_trigger <= semi_trigger_reg;\n" +
            "    semi_op <= semi_op_reg;\n" +
            "    semi_param <= semi_param_reg;\n"

    fn core_vhdl_mmu_output_lines() -> text:
        if self.xlen == RiscvXlen.Rv32:
            return ""
        "    debug_priv_mode <= priv_mode_reg;\n" +
            "    debug_last_load_value <= debug_last_load_value_reg;\n" +
            "    debug_ra <= regs(1);\n" +
            "    debug_sp <= regs(2);\n" +
            "    debug_s0 <= regs(8);\n" +
            "    debug_a0 <= regs(10);\n" +
            "    debug_a1 <= regs(11);\n" +
            "    debug_a2 <= regs(12);\n" +
            "    debug_load_rd <= std_logic_vector(to_unsigned(load_pending_rd_reg, XLEN));\n"

    fn core_vhdl() -> text:
        val package_name = self.package_name()
        val top = self.top_module
        self.source_map_header() +
            "library ieee;\n" +
            "use ieee.std_logic_1164.all;\n" +
            "use ieee.numeric_std.all;\n" +
            "use work.{package_name}.all;\n\n" +
            "entity {top} is\n" +
            "    port (\n" +
            "        clk           : in  std_logic;\n" +
            "        reset_n       : in  std_logic;\n" +
            "        imem_addr     : out xword_t;\n" +
            "        imem_rdata    : in  std_logic_vector(31 downto 0);\n" +
            "        dmem_addr     : out xword_t;\n" +
            "        dmem_wdata    : out xword_t;\n" +
            "        dmem_rdata    : in  xword_t;\n" +
            "        dmem_we       : out std_logic;\n" +
            "        dmem_re       : out std_logic;\n" +
            "        dmem_width    : out std_logic_vector(1 downto 0);\n" +
            "        dmem_wstrb    : out std_logic_vector((XLEN / 8) - 1 downto 0);\n" +
            "        irq_software  : in  std_logic;\n" +
            "        irq_timer     : in  std_logic;\n" +
            "        irq_external  : in  std_logic;\n" +
            self.core_vhdl_mmu_port_lines() +
            "        debug_pc      : out xword_t;\n" +
            self.core_vhdl_semihost_port_lines() +
            "        trap          : out std_logic;\n" +
            "        halt          : out std_logic\n" +
            "    );\n" +
            "end entity {top};\n\n" +
            "architecture rtl of {top} is\n" +
            "    type reg_file_t is array (0 to 31) of xword_t;\n" +
            "    alias imem_rdata_raw : std_logic_vector(31 downto 0) is imem_rdata;\n" +
            "    signal pc_reg : xword_t := RESET_VECTOR;\n" +
            "    signal regs : reg_file_t := {self.reg_file_init_hex()};\n" +
            "    signal dmem_addr_reg : xword_t := (others => '0');\n" +
            "    signal dmem_wdata_reg : xword_t := (others => '0');\n" +
            "    signal dmem_we_reg : std_logic := '0';\n" +
            "    signal dmem_re_reg : std_logic := '0';\n" +
            "    signal dmem_width_reg : std_logic_vector(1 downto 0) := \"10\";\n" +
            "    signal dmem_wstrb_reg : std_logic_vector((XLEN / 8) - 1 downto 0) := (others => '0');\n" +
            "    signal trap_reg : std_logic := '0';\n" +
            "    signal halt_reg : std_logic := '0';\n" +
            self.core_vhdl_semihost_signal_lines() +
            "    signal load_issue_reg : std_logic := '0';\n" +
            "    signal load_wait_reg : std_logic := '0';\n" +
            "    signal load_settle_reg : std_logic := '0';\n" +
            "    signal load_capture_reg : std_logic := '0';\n" +
            "    signal load_pending_reg : std_logic := '0';\n" +
            "    signal load_writeback_reg : std_logic := '0';\n" +
            "    signal load_pending_rd_reg : integer range 0 to 31 := 0;\n" +
            "    signal load_pending_addr_reg : xword_t := (others => '0');\n" +
            "    signal load_pending_funct3_reg : std_logic_vector(2 downto 0) := (others => '0');\n" +
            self.core_vhdl_mmu_helper_lines() +
            "begin\n" +
            "    imem_addr <= pc_reg;\n" +
            "    dmem_addr <= dmem_addr_reg;\n" +
            "    dmem_wdata <= dmem_wdata_reg;\n" +
            "    dmem_we <= dmem_we_reg;\n" +
            "    dmem_re <= dmem_re_reg;\n" +
            "    dmem_width <= dmem_width_reg;\n" +
            "    dmem_wstrb <= dmem_wstrb_reg;\n" +
            "    debug_pc <= pc_reg;\n" +
            self.core_vhdl_mmu_output_lines() +
            self.core_vhdl_semihost_output_lines() +
            "    trap <= trap_reg;\n" +
            "    halt <= halt_reg;\n\n" +
            "    process(clk, reset_n)\n" +
            self.core_vhdl_process_variables() +
            "    begin\n" +
            "        if reset_n = '0' then\n" +
            "            pc_reg <= RESET_VECTOR;\n" +
            "            regs <= {self.reg_file_init_hex()};\n" +
            "            dmem_addr_reg <= (others => '0');\n" +
            "            dmem_wdata_reg <= (others => '0');\n" +
            "            dmem_we_reg <= '0';\n" +
            "            dmem_re_reg <= '0';\n" +
            "            dmem_width_reg <= \"10\";\n" +
            "            dmem_wstrb_reg <= (others => '0');\n" +
            "            trap_reg <= '0';\n" +
            "            halt_reg <= '0';\n" +
            self.core_vhdl_semihost_reset_lines() +
            "            load_issue_reg <= '0';\n" +
            "            load_wait_reg <= '0';\n" +
            "            load_settle_reg <= '0';\n" +
            "            load_capture_reg <= '0';\n" +
            "            load_pending_reg <= '0';\n" +
            "            load_writeback_reg <= '0';\n" +
            "            load_pending_rd_reg <= 0;\n" +
            "            load_pending_addr_reg <= (others => '0');\n" +
            "            load_pending_funct3_reg <= (others => '0');\n" +
            "        elsif rising_edge(clk) then\n" +
            "            dmem_we_reg <= '0';\n" +
            "            dmem_re_reg <= '0';\n" +
            "            dmem_width_reg <= \"10\";\n" +
            "            dmem_wstrb_reg <= (others => '0');\n" +
            self.core_vhdl_semihost_default_lines() +
            "            if load_issue_reg = '1' then\n" +
            "                load_issue_reg <= '0';\n" +
            "                load_wait_reg <= '1';\n" +
            "                regs(0) <= (others => '0');\n" +
            "            elsif load_wait_reg = '1' then\n" +
            "                load_wait_reg <= '0';\n" +
            "                load_settle_reg <= '1';\n" +
            "                regs(0) <= (others => '0');\n" +
            "            elsif load_settle_reg = '1' then\n" +
            "                load_settle_reg <= '0';\n" +
            "                load_capture_reg <= '1';\n" +
            "                regs(0) <= (others => '0');\n" +
            "            elsif load_capture_reg = '1' then\n" +
            "                load_capture_reg <= '0';\n" +
            "                load_writeback_reg <= '1';\n" +
            "                load_data_reg <= dmem_rdata;\n" +
            "                regs(0) <= (others => '0');\n" +
            "            elsif load_writeback_reg = '1' then\n" +
            "                addr_i := unsigned(load_pending_addr_reg);\n" +
            "                case load_pending_funct3_reg is\n" +
            "                    when \"000\" =>\n" +
            "                        if XLEN = 64 then\n" +
            "                            if load_pending_rd_reg /= 0 then\n" +
            "                                regs(load_pending_rd_reg) <= std_logic_vector(resize(signed(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(2 downto 0))) * 8)(7 downto 0)), XLEN));\n" +
            "                                debug_last_load_value_reg <= std_logic_vector(resize(signed(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(2 downto 0))) * 8)(7 downto 0)), XLEN));\n" +
            "                            end if;\n" +
            "                        elsif load_pending_rd_reg /= 0 then\n" +
            "                            regs(load_pending_rd_reg) <= std_logic_vector(resize(signed(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(1 downto 0))) * 8)(7 downto 0)), XLEN));\n" +
            "                            debug_last_load_value_reg <= std_logic_vector(resize(signed(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(1 downto 0))) * 8)(7 downto 0)), XLEN));\n" +
            "                        end if;\n" +
            "                    when \"001\" =>\n" +
            "                        if XLEN = 64 then\n" +
            "                            if load_pending_rd_reg /= 0 then\n" +
            "                                regs(load_pending_rd_reg) <= std_logic_vector(resize(signed(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(2 downto 0))) * 8)(15 downto 0)), XLEN));\n" +
            "                                debug_last_load_value_reg <= std_logic_vector(resize(signed(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(2 downto 0))) * 8)(15 downto 0)), XLEN));\n" +
            "                            end if;\n" +
            "                        elsif load_pending_rd_reg /= 0 then\n" +
            "                            regs(load_pending_rd_reg) <= std_logic_vector(resize(signed(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(1 downto 0))) * 8)(15 downto 0)), XLEN));\n" +
            "                            debug_last_load_value_reg <= std_logic_vector(resize(signed(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(1 downto 0))) * 8)(15 downto 0)), XLEN));\n" +
            "                        end if;\n" +
            "                    when \"010\" =>\n" +
            "                        if XLEN = 64 then\n" +
            "                            if load_pending_rd_reg /= 0 then\n" +
            "                                regs(load_pending_rd_reg) <= std_logic_vector(resize(signed(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(2 downto 2))) * 32)(31 downto 0)), XLEN));\n" +
            "                                debug_last_load_value_reg <= std_logic_vector(resize(signed(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(2 downto 2))) * 32)(31 downto 0)), XLEN));\n" +
            "                            end if;\n" +
            "                        elsif load_pending_rd_reg /= 0 then\n" +
            "                            regs(load_pending_rd_reg) <= std_logic_vector(resize(signed(load_data_reg(31 downto 0)), XLEN));\n" +
            "                            debug_last_load_value_reg <= std_logic_vector(resize(signed(load_data_reg(31 downto 0)), XLEN));\n" +
            "                        end if;\n" +
            "                    when \"011\" =>\n" +
            "                        if XLEN = 64 then\n" +
            "                            if load_pending_rd_reg /= 0 then\n" +
            "                                regs(load_pending_rd_reg) <= load_data_reg;\n" +
            "                                debug_last_load_value_reg <= load_data_reg;\n" +
            "                            end if;\n" +
            "                        else\n" +
            "                            trap_reg <= '1';\n" +
            "                        end if;\n" +
            "                    when \"100\" =>\n" +
            "                        if XLEN = 64 then\n" +
            "                            if load_pending_rd_reg /= 0 then\n" +
            "                                regs(load_pending_rd_reg) <= std_logic_vector(resize(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(2 downto 0))) * 8)(7 downto 0), XLEN));\n" +
            "                                debug_last_load_value_reg <= std_logic_vector(resize(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(2 downto 0))) * 8)(7 downto 0), XLEN));\n" +
            "                            end if;\n" +
            "                        elsif load_pending_rd_reg /= 0 then\n" +
            "                            regs(load_pending_rd_reg) <= std_logic_vector(resize(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(1 downto 0))) * 8)(7 downto 0), XLEN));\n" +
            "                            debug_last_load_value_reg <= std_logic_vector(resize(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(1 downto 0))) * 8)(7 downto 0), XLEN));\n" +
            "                        end if;\n" +
            "                    when \"101\" =>\n" +
            "                        if XLEN = 64 then\n" +
            "                            if load_pending_rd_reg /= 0 then\n" +
            "                                regs(load_pending_rd_reg) <= std_logic_vector(resize(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(2 downto 0))) * 8)(15 downto 0), XLEN));\n" +
            "                                debug_last_load_value_reg <= std_logic_vector(resize(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(2 downto 0))) * 8)(15 downto 0), XLEN));\n" +
            "                            end if;\n" +
            "                        elsif load_pending_rd_reg /= 0 then\n" +
            "                            regs(load_pending_rd_reg) <= std_logic_vector(resize(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(1 downto 0))) * 8)(15 downto 0), XLEN));\n" +
            "                            debug_last_load_value_reg <= std_logic_vector(resize(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(1 downto 0))) * 8)(15 downto 0), XLEN));\n" +
            "                        end if;\n" +
            "                    when \"110\" =>\n" +
            "                        if XLEN = 64 then\n" +
            "                            if load_pending_rd_reg /= 0 then\n" +
            "                                regs(load_pending_rd_reg) <= std_logic_vector(resize(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(2 downto 0))) * 8)(31 downto 0), XLEN));\n" +
            "                                debug_last_load_value_reg <= std_logic_vector(resize(shift_right(unsigned(load_data_reg), to_integer(unsigned(addr_i(2 downto 0))) * 8)(31 downto 0), XLEN));\n" +
            "                            end if;\n" +
            "                        else\n" +
            "                            trap_reg <= '1';\n" +
            "                        end if;\n" +
            "                    when others => trap_reg <= '1';\n" +
            "                end case;\n" +
            "                load_writeback_reg <= '0';\n" +
            "                load_pending_reg <= '0';\n" +
            "                regs(0) <= (others => '0');\n" +
            "            elsif load_pending_reg = '1' then\n" +
            "                regs(0) <= (others => '0');\n" +
            "            elsif amo_pending_reg = '1' then\n" +
            "                addr_i := unsigned(amo_pending_addr_reg);\n" +
            "                atomic_old_word32_v := std_logic_vector(shift_right(unsigned(dmem_rdata), to_integer(unsigned(addr_i(2 downto 0))) * 8)(31 downto 0));\n" +
            "                atomic_old_word64_v := dmem_rdata;\n" +
            "                if amo_pending_funct5_reg = \"00010\" then\n" +
            "                    reservation_valid_reg <= '1';\n" +
            "                    reservation_addr_reg <= amo_pending_addr_reg;\n" +
            "                    if amo_pending_rd_reg /= 0 then\n" +
            "                        if amo_pending_funct3_reg = \"010\" then\n" +
            "                            regs(amo_pending_rd_reg) <= std_logic_vector(resize(signed(atomic_old_word32_v), XLEN));\n" +
            "                        elsif XLEN = 64 and amo_pending_funct3_reg = \"011\" then\n" +
            "                            regs(amo_pending_rd_reg) <= atomic_old_word64_v;\n" +
            "                        else\n" +
            "                            trap_reg <= '1';\n" +
            "                        end if;\n" +
            "                    end if;\n" +
            "                    pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(4, XLEN));\n" +
            "                elsif amo_pending_funct5_reg = \"00011\" then\n" +
            "                    if amo_pending_rd_reg /= 0 then\n" +
            "                        if reservation_valid_reg = '1' and reservation_addr_reg = amo_pending_addr_reg then\n" +
            "                            regs(amo_pending_rd_reg) <= (others => '0');\n" +
            "                        else\n" +
            "                            regs(amo_pending_rd_reg) <= std_logic_vector(to_unsigned(1, XLEN));\n" +
            "                        end if;\n" +
            "                    end if;\n" +
            "                    if reservation_valid_reg = '1' and reservation_addr_reg = amo_pending_addr_reg then\n" +
            "                        dmem_addr_reg <= amo_pending_addr_reg;\n" +
            "                        if amo_pending_funct3_reg = \"010\" then\n" +
            "                            dmem_width_reg <= \"10\";\n" +
            "                            dmem_wdata_reg <= std_logic_vector(shift_left(unsigned(amo_pending_rs2_value_reg), to_integer(unsigned(addr_i(2 downto 0))) * 8));\n" +
            "                            dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(15, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));\n" +
            "                            dmem_we_reg <= '1';\n" +
            "                        elsif XLEN = 64 and amo_pending_funct3_reg = \"011\" then\n" +
            "                            dmem_width_reg <= \"11\";\n" +
            "                            dmem_wdata_reg <= amo_pending_rs2_value_reg;\n" +
            "                            dmem_wstrb_reg <= (others => '1');\n" +
            "                            dmem_we_reg <= '1';\n" +
            "                        else\n" +
            "                            trap_reg <= '1';\n" +
            "                        end if;\n" +
            "                    end if;\n" +
            "                    reservation_valid_reg <= '0';\n" +
            "                    pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(4, XLEN));\n" +
            "                else\n" +
            "                    if amo_pending_funct3_reg = \"010\" then\n" +
            "                        if amo_pending_rd_reg /= 0 then\n" +
            "                            regs(amo_pending_rd_reg) <= std_logic_vector(resize(signed(atomic_old_word32_v), XLEN));\n" +
            "                        end if;\n" +
            "                        case amo_pending_funct5_reg is\n" +
            "                            when \"00000\" => atomic_new_word32_v := std_logic_vector(unsigned(atomic_old_word32_v) + unsigned(amo_pending_rs2_value_reg(31 downto 0)));\n" +
            "                            when \"00001\" => atomic_new_word32_v := amo_pending_rs2_value_reg(31 downto 0);\n" +
            "                            when \"00100\" => atomic_new_word32_v := atomic_old_word32_v xor amo_pending_rs2_value_reg(31 downto 0);\n" +
            "                            when \"01000\" => atomic_new_word32_v := atomic_old_word32_v or amo_pending_rs2_value_reg(31 downto 0);\n" +
            "                            when \"01100\" => atomic_new_word32_v := atomic_old_word32_v and amo_pending_rs2_value_reg(31 downto 0);\n" +
            "                            when \"10000\" => if signed(atomic_old_word32_v) < signed(amo_pending_rs2_value_reg(31 downto 0)) then atomic_new_word32_v := atomic_old_word32_v; else atomic_new_word32_v := amo_pending_rs2_value_reg(31 downto 0); end if;\n" +
            "                            when \"10100\" => if signed(atomic_old_word32_v) > signed(amo_pending_rs2_value_reg(31 downto 0)) then atomic_new_word32_v := atomic_old_word32_v; else atomic_new_word32_v := amo_pending_rs2_value_reg(31 downto 0); end if;\n" +
            "                            when \"11000\" => if unsigned(atomic_old_word32_v) < unsigned(amo_pending_rs2_value_reg(31 downto 0)) then atomic_new_word32_v := atomic_old_word32_v; else atomic_new_word32_v := amo_pending_rs2_value_reg(31 downto 0); end if;\n" +
            "                            when \"11100\" => if unsigned(atomic_old_word32_v) > unsigned(amo_pending_rs2_value_reg(31 downto 0)) then atomic_new_word32_v := atomic_old_word32_v; else atomic_new_word32_v := amo_pending_rs2_value_reg(31 downto 0); end if;\n" +
            "                            when others => trap_reg <= '1';\n" +
            "                        end case;\n" +
            "                        if trap_reg = '0' then\n" +
            "                            dmem_addr_reg <= amo_pending_addr_reg;\n" +
            "                            dmem_width_reg <= \"10\";\n" +
            "                            dmem_wdata_reg <= std_logic_vector(shift_left(resize(unsigned(atomic_new_word32_v), XLEN), to_integer(unsigned(addr_i(2 downto 0))) * 8));\n" +
            "                            dmem_wstrb_reg <= std_logic_vector(shift_left(to_unsigned(15, XLEN / 8), to_integer(unsigned(addr_i(2 downto 0)))));\n" +
            "                            dmem_we_reg <= '1';\n" +
            "                            reservation_valid_reg <= '0';\n" +
            "                            pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(4, XLEN));\n" +
            "                        end if;\n" +
            "                    elsif XLEN = 64 and amo_pending_funct3_reg = \"011\" then\n" +
            "                        if amo_pending_rd_reg /= 0 then\n" +
            "                            regs(amo_pending_rd_reg) <= atomic_old_word64_v;\n" +
            "                        end if;\n" +
            "                        case amo_pending_funct5_reg is\n" +
            "                            when \"00000\" => atomic_new_word64_v := std_logic_vector(unsigned(atomic_old_word64_v) + unsigned(amo_pending_rs2_value_reg));\n" +
            "                            when \"00001\" => atomic_new_word64_v := amo_pending_rs2_value_reg;\n" +
            "                            when \"00100\" => atomic_new_word64_v := atomic_old_word64_v xor amo_pending_rs2_value_reg;\n" +
            "                            when \"01000\" => atomic_new_word64_v := atomic_old_word64_v or amo_pending_rs2_value_reg;\n" +
            "                            when \"01100\" => atomic_new_word64_v := atomic_old_word64_v and amo_pending_rs2_value_reg;\n" +
            "                            when \"10000\" => if signed(atomic_old_word64_v) < signed(amo_pending_rs2_value_reg) then atomic_new_word64_v := atomic_old_word64_v; else atomic_new_word64_v := amo_pending_rs2_value_reg; end if;\n" +
            "                            when \"10100\" => if signed(atomic_old_word64_v) > signed(amo_pending_rs2_value_reg) then atomic_new_word64_v := atomic_old_word64_v; else atomic_new_word64_v := amo_pending_rs2_value_reg; end if;\n" +
            "                            when \"11000\" => if unsigned(atomic_old_word64_v) < unsigned(amo_pending_rs2_value_reg) then atomic_new_word64_v := atomic_old_word64_v; else atomic_new_word64_v := amo_pending_rs2_value_reg; end if;\n" +
            "                            when \"11100\" => if unsigned(atomic_old_word64_v) > unsigned(amo_pending_rs2_value_reg) then atomic_new_word64_v := atomic_old_word64_v; else atomic_new_word64_v := amo_pending_rs2_value_reg; end if;\n" +
            "                            when others => trap_reg <= '1';\n" +
            "                        end case;\n" +
            "                        if trap_reg = '0' then\n" +
            "                            dmem_addr_reg <= amo_pending_addr_reg;\n" +
            "                            dmem_width_reg <= \"11\";\n" +
            "                            dmem_wdata_reg <= atomic_new_word64_v;\n" +
            "                            dmem_wstrb_reg <= (others => '1');\n" +
            "                            dmem_we_reg <= '1';\n" +
            "                            reservation_valid_reg <= '0';\n" +
            "                            pc_reg <= std_logic_vector(unsigned(pc_reg) + to_unsigned(4, XLEN));\n" +
            "                        end if;\n" +
            "                    else\n" +
            "                        trap_reg <= '1';\n" +
            "                    end if;\n" +
            "                end if;\n" +
            "                amo_pending_reg <= '0';\n" +
            "                regs(0) <= (others => '0');\n" +
            "            elsif halt_reg = '0' and trap_reg = '0' then\n" +
            "                if priv_mode_reg /= \"11\" and csr_mstatus_reg(1) = '1' then\n" +
            "                    if irq_external = '1' and csr_mideleg_reg(9) = '1' and csr_mie_reg(9) = '1' then\n" +
            "                        csr_sepc_reg <= pc_reg;\n" +
            "                        csr_new_val := std_logic_vector(to_unsigned(9, XLEN));\n" +
            "                        csr_new_val(XLEN - 1) := '1';\n" +
            "                        csr_scause_reg <= csr_new_val;\n" +
            "                        csr_stval_reg <= (others => '0');\n" +
            "                        csr_mstatus_reg(5) <= csr_mstatus_reg(1);\n" +
            "                        csr_mstatus_reg(1) <= '0';\n" +
            "                        if priv_mode_reg = \"01\" then\n" +
            "                            csr_mstatus_reg(8) <= '1';\n" +
            "                        else\n" +
            "                            csr_mstatus_reg(8) <= '0';\n" +
            "                        end if;\n" +
            "                        priv_mode_reg <= \"01\";\n" +
            "                        pc_reg <= csr_stvec_reg;\n" +
            "                    elsif irq_timer = '1' and csr_mideleg_reg(5) = '1' and csr_mie_reg(5) = '1' then\n" +
            "                        csr_sepc_reg <= pc_reg;\n" +
            "                        csr_new_val := std_logic_vector(to_unsigned(5, XLEN));\n" +
            "                        csr_new_val(XLEN - 1) := '1';\n" +
            "                        csr_scause_reg <= csr_new_val;\n" +
            "                        csr_stval_reg <= (others => '0');\n" +
            "                        csr_mstatus_reg(5) <= csr_mstatus_reg(1);\n" +
            "                        csr_mstatus_reg(1) <= '0';\n" +
            "                        if priv_mode_reg = \"01\" then\n" +
            "                            csr_mstatus_reg(8) <= '1';\n" +
            "                        else\n" +
            "                            csr_mstatus_reg(8) <= '0';\n" +
            "                        end if;\n" +
            "                        priv_mode_reg <= \"01\";\n" +
            "                        pc_reg <= csr_stvec_reg;\n" +
            "                    elsif irq_software = '1' and csr_mideleg_reg(1) = '1' and csr_mie_reg(1) = '1' then\n" +
            "                        csr_sepc_reg <= pc_reg;\n" +
            "                        csr_new_val := std_logic_vector(to_unsigned(1, XLEN));\n" +
            "                        csr_new_val(XLEN - 1) := '1';\n" +
            "                        csr_scause_reg <= csr_new_val;\n" +
            "                        csr_stval_reg <= (others => '0');\n" +
            "                        csr_mstatus_reg(5) <= csr_mstatus_reg(1);\n" +
            "                        csr_mstatus_reg(1) <= '0';\n" +
            "                        if priv_mode_reg = \"01\" then\n" +
            "                            csr_mstatus_reg(8) <= '1';\n" +
            "                        else\n" +
            "                            csr_mstatus_reg(8) <= '0';\n" +
            "                        end if;\n" +
            "                        priv_mode_reg <= \"01\";\n" +
            "                        pc_reg <= csr_stvec_reg;\n" +
            "                    elsif csr_mstatus_reg(3) = '1' then\n" +
            "                    if irq_external = '1' and csr_mie_reg(11) = '1' then\n" +
            "                        csr_mepc_reg <= pc_reg;\n" +
            "                        csr_new_val := std_logic_vector(to_unsigned(11, XLEN));\n" +
            "                        csr_new_val(XLEN - 1) := '1';\n" +
            "                        csr_mcause_reg <= csr_new_val;\n" +
            "                        csr_mtval_reg <= (others => '0');\n" +
            "                        csr_mstatus_reg(7) <= csr_mstatus_reg(3);\n" +
            "                        csr_mstatus_reg(3) <= '0';\n" +
            "                        csr_mstatus_reg(12 downto 11) <= priv_mode_reg;\n" +
            "                        priv_mode_reg <= \"11\";\n" +
            "                        pc_reg <= csr_mtvec_reg;\n" +
            "                    elsif irq_timer = '1' and csr_mie_reg(7) = '1' then\n" +
            "                        csr_mepc_reg <= pc_reg;\n" +
            "                        csr_new_val := std_logic_vector(to_unsigned(7, XLEN));\n" +
            "                        csr_new_val(XLEN - 1) := '1';\n" +
            "                        csr_mcause_reg <= csr_new_val;\n" +
            "                        csr_mtval_reg <= (others => '0');\n" +
            "                        csr_mstatus_reg(7) <= csr_mstatus_reg(3);\n" +
            "                        csr_mstatus_reg(3) <= '0';\n" +
            "                        csr_mstatus_reg(12 downto 11) <= priv_mode_reg;\n" +
            "                        priv_mode_reg <= \"11\";\n" +
            "                        pc_reg <= csr_mtvec_reg;\n" +
            "                    elsif irq_software = '1' and csr_mie_reg(3) = '1' then\n" +
            "                        csr_mepc_reg <= pc_reg;\n" +
            "                        csr_new_val := std_logic_vector(to_unsigned(3, XLEN));\n" +
            "                        csr_new_val(XLEN - 1) := '1';\n" +
            "                        csr_mcause_reg <= csr_new_val;\n" +
            "                        csr_mtval_reg <= (others => '0');\n" +
            "                        csr_mstatus_reg(7) <= csr_mstatus_reg(3);\n" +
            "                        csr_mstatus_reg(3) <= '0';\n" +
            "                        csr_mstatus_reg(12 downto 11) <= priv_mode_reg;\n" +
            "                        priv_mode_reg <= \"11\";\n" +
            "                        pc_reg <= csr_mtvec_reg;\n" +
            "                    else\n" +
            "                instr_word_v := imem_rdata_raw;\n" +
            "                instr_size_bytes := 4;\n" +
            "                if rv64c_is_compressed(imem_rdata_raw) then\n" +
            "                    instr_word_v := rv64c_decompress(imem_rdata_raw(15 downto 0));\n" +
            "                    instr_size_bytes := 2;\n" +
            "                    if instr_word_v = x\"00000000\" then\n" +
            "                        trap_reg <= '1';\n" +
            "                    end if;\n" +
            "                end if;\n" +
            self.core_vhdl_semihost_region() +
            "                rd_i := to_integer(unsigned(instr_word_v(11 downto 7)));\n" +
            "                rs1_i := to_integer(unsigned(instr_word_v(19 downto 15)));\n" +
            "                rs2_i := to_integer(unsigned(instr_word_v(24 downto 20)));\n" +
            self.core_vhdl_decode_staging_region() +
            "                if decode_continue_exec = '1' then\n" +
            self.core_vhdl_execute_load_store_region() +
            self.core_vhdl_control_region() +
            "                end if;\n" +
            "                    end if;\n" +
            "                    else\n" +
            "                instr_word_v := imem_rdata_raw;\n" +
            "                instr_size_bytes := 4;\n" +
            "                if rv64c_is_compressed(imem_rdata_raw) then\n" +
            "                    instr_word_v := rv64c_decompress(imem_rdata_raw(15 downto 0));\n" +
            "                    instr_size_bytes := 2;\n" +
            "                    if instr_word_v = x\"00000000\" then\n" +
            "                        trap_reg <= '1';\n" +
            "                    end if;\n" +
            "                end if;\n" +
            self.core_vhdl_semihost_region() +
            "                rd_i := to_integer(unsigned(instr_word_v(11 downto 7)));\n" +
            "                rs1_i := to_integer(unsigned(instr_word_v(19 downto 15)));\n" +
            "                rs2_i := to_integer(unsigned(instr_word_v(24 downto 20)));\n" +
            self.core_vhdl_decode_staging_region() +
            "                if decode_continue_exec = '1' then\n" +
            self.core_vhdl_execute_load_store_region() +
            self.core_vhdl_control_region() +
            "                end if;\n" +
            "                    end if;\n" +
            "                else\n" +
            "                instr_word_v := imem_rdata_raw;\n" +
            "                instr_size_bytes := 4;\n" +
            "                if rv64c_is_compressed(imem_rdata_raw) then\n" +
            "                    instr_word_v := rv64c_decompress(imem_rdata_raw(15 downto 0));\n" +
            "                    instr_size_bytes := 2;\n" +
            "                    if instr_word_v = x\"00000000\" then\n" +
            "                        trap_reg <= '1';\n" +
            "                    end if;\n" +
            "                end if;\n" +
            self.core_vhdl_semihost_region() +
            "                rd_i := to_integer(unsigned(instr_word_v(11 downto 7)));\n" +
            "                rs1_i := to_integer(unsigned(instr_word_v(19 downto 15)));\n" +
            "                rs2_i := to_integer(unsigned(instr_word_v(24 downto 20)));\n" +
            self.core_vhdl_decode_staging_region() +
            "                if decode_continue_exec = '1' then\n" +
            self.core_vhdl_execute_load_store_region() +
            self.core_vhdl_control_region() +
            "                end if;\n" +
            "                end if;\n" +
            "            end if;\n" +
            "        end if;\n" +
            "    end process;\n" +
            "end architecture rtl;\n"

    fn boot_info_dtb_testbench_file_name() -> text:
        "tb_generated_rv64_boot_info_dtb.vhd"

