use std.cli.cli_util (get_cli_args)
use lib.hardware.fpga_linux.riscv_fpga_linux.{generate_default_riscv_fpga_rtl_bundle}

fn main() -> i64:
    val args = get_cli_args()
    val output_dir = if args.len() > 0: args[0] else: "/tmp/simple_riscv_fpga_rtl_bundle"
    val result = generate_default_riscv_fpga_rtl_bundle(output_dir)
    match result:
        Ok(_bundle):
            print "generated RISC-V FPGA RTL bundle: {output_dir}"
            return 0
        Err(message):
            print "failed to generate RISC-V FPGA RTL bundle: {message}"
            return 1
