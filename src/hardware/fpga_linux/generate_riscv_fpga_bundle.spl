# Generate the repo-native RISC-V FPGA RTL bundle.
#
# Usage:
#   bin/simple run src/hardware/fpga_linux/generate_riscv_fpga_bundle.spl -- <out-dir>

use hardware.fpga_linux.riscv_fpga_linux.generate_default_riscv_fpga_rtl_bundle

extern fn sys_get_args() -> [text]

fn main() -> i32:
    val args = sys_get_args()
    var out_dir = ""
    var idx: i64 = 1
    while idx < args.len():
        val arg = args[idx]
        if arg != "--":
            out_dir = arg
            break
        idx = idx + 1

    if out_dir == "":
        print "usage: bin/simple run src/hardware/fpga_linux/generate_riscv_fpga_bundle.spl -- <out-dir>"
        return 1

    val result = generate_default_riscv_fpga_rtl_bundle(out_dir)
    if result.is_ok():
        print "generated: {out_dir}"
        return 0
    print "error: {result.unwrap_err()}"
    1
