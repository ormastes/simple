"""
# RV64 Floating-Point Register File

32 x 64-bit FP registers (FLEN=64 for D extension).
Supports NaN-boxing for single-precision access.
"""

use hardware.rv64gc.pkg.rv64_fp_types_pkg.{NAN_BOX_MASK, SP_QNAN}

class Rv64FpuRegFile:
    regs: [i64]

    static fn create() -> Rv64FpuRegFile:
        var r: [i64] = []
        var i = 0
        while i < 32:
            r = r + [0]
            i = i + 1
        Rv64FpuRegFile(regs: r)

    fn read(idx: i64) -> i64:
        """Read full 64-bit FP register."""
        self.regs[idx]

    me write(idx: i64, value: i64):
        """Write full 64-bit FP register."""
        self.regs[idx] = value

    fn read_single(idx: i64) -> i64:
        """Read single-precision value. Returns lower 32 bits if NaN-boxed,
        otherwise returns canonical NaN (0x7FC00000)."""
        val raw = self.regs[idx]
        val upper = raw and NAN_BOX_MASK
        if upper == NAN_BOX_MASK:
            # Properly NaN-boxed: return lower 32 bits
            raw and 0xFFFFFFFF
        else:
            # Not NaN-boxed: return canonical NaN
            SP_QNAN

    me write_single(idx: i64, value: i64):
        """Write single-precision value with NaN-boxing.
        Sets upper 32 bits to all 1s."""
        val boxed = (value and 0xFFFFFFFF) or NAN_BOX_MASK
        self.regs[idx] = boxed
