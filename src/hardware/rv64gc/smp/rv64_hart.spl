"""
# RV64 Hart (Hardware Thread)

Composes all per-hart state: integer registers, FP registers, CSRs,
program counter, privilege mode, and reservation set.
"""

use hardware.rv64gc.core.rv64_regfile.Rv64RegFile
use hardware.rv64gc.core.rv64_fpu_regfile.Rv64FpuRegFile
use hardware.rv64gc.core.rv64_csr.Rv64CsrFile
use hardware.rv64gc.pkg.rv64_types_pkg.{PrivilegeMode, priv_to_i64}
use hardware.rv64gc.ext.rv64_atomics.ReservationSet64
use hardware.rv64gc.ext.rv64_zifencei.FenceIState

class Rv64Hart:
    hartid: i64
    pc: i64
    priv_mode: PrivilegeMode
    regs: Rv64RegFile
    fp_regs: Rv64FpuRegFile
    csrs: Rv64CsrFile
    reservation: ReservationSet64
    fence_i: FenceIState
    halted: bool
    wfi: bool  # Waiting for interrupt

    static fn create(hartid: i64, reset_vector: i64) -> Rv64Hart:
        Rv64Hart(
            hartid: hartid,
            pc: reset_vector,
            priv_mode: PrivilegeMode.Machine,
            regs: Rv64RegFile.create(),
            fp_regs: Rv64FpuRegFile.create(),
            csrs: Rv64CsrFile.create(hartid),
            reservation: ReservationSet64.create(),
            fence_i: FenceIState.create(),
            halted: false,
            wfi: false
        )

    fn get_pc() -> i64:
        self.pc

    me set_pc(addr: i64):
        self.pc = addr

    me advance_pc(offset: i64):
        """Advance PC by offset (typically 4 for 32-bit, 2 for compressed)."""
        self.pc = self.pc + offset

    fn get_priv() -> PrivilegeMode:
        self.priv_mode

    me set_priv(mode: PrivilegeMode):
        self.priv_mode = mode

    fn read_reg(idx: i64) -> i64:
        self.regs.read(idx)

    me write_reg(idx: i64, value: i64):
        self.regs.write(idx, value)

    fn read_fp(idx: i64) -> i64:
        self.fp_regs.read(idx)

    me write_fp(idx: i64, value: i64):
        self.fp_regs.write(idx, value)

    fn read_fp_single(idx: i64) -> i64:
        self.fp_regs.read_single(idx)

    me write_fp_single(idx: i64, value: i64):
        self.fp_regs.write_single(idx, value)

    fn read_csr(addr: i64) -> i64:
        self.csrs.read(addr)

    me write_csr(addr: i64, value: i64):
        self.csrs.write(addr, value)

    me tick():
        """Advance one cycle."""
        self.csrs.tick()

    me retire():
        """Mark one instruction retired."""
        self.csrs.retire()

    me halt():
        self.halted = true

    me resume():
        self.halted = false

    fn is_halted() -> bool:
        self.halted

    me enter_wfi():
        """Enter wait-for-interrupt state."""
        self.wfi = true

    me exit_wfi():
        """Exit wait-for-interrupt state."""
        self.wfi = false

    fn is_wfi() -> bool:
        self.wfi
