"""
# RV64M Multiply/Divide Extension

64-bit and 32-bit (W-variant) multiply/divide operations.
"""

use hardware.riscv_common.pkg.riscv_types_pkg.MulDivOp

fn _sign_extend_32(val_: i64) -> i64:
    val low32 = val_ and 0xFFFFFFFF
    if (low32 and 0x80000000) != 0:
        low32 or 0xFFFFFFFF00000000
    else:
        low32

fn _unsigned_lt(a: i64, b: i64) -> bool:
    val a_sign = (a >> 63) and 1
    val b_sign = (b >> 63) and 1
    if a_sign != b_sign:
        a_sign == 0
    else:
        a < b

fn _mulhu_impl(a: i64, b: i64) -> i64:
    """Unsigned high multiply: returns upper 64 bits of a*b (unsigned).
    Uses split-into-halves approach to avoid overflow."""
    val a_lo = a and 0xFFFFFFFF
    val a_hi = (a >> 32) and 0xFFFFFFFF
    val b_lo = b and 0xFFFFFFFF
    val b_hi = (b >> 32) and 0xFFFFFFFF

    val lo_lo = a_lo * b_lo
    val lo_hi = a_lo * b_hi
    val hi_lo = a_hi * b_lo
    val hi_hi = a_hi * b_hi

    # Accumulate cross terms (carry propagation)
    val mid = lo_hi + hi_lo + ((lo_lo >> 32) and 0xFFFFFFFF)
    # Upper 64 bits
    hi_hi + ((lo_hi >> 32) and 0xFFFFFFFF) + ((mid >> 32) and 0xFFFFFFFF)

fn muldiv_execute(op: MulDivOp, a: i64, b: i64) -> i64:
    """Execute a 64-bit M-extension operation."""
    match op:
        MulDivOp.Mul:
            a * b  # Lower 64 bits of signed multiply

        MulDivOp.Mulh:
            # Signed high multiply
            val a_neg = a < 0
            val b_neg = b < 0
            var ua = a
            var ub = b
            if a_neg: ua = 0 - a
            if b_neg: ub = 0 - b
            val hi = _mulhu_impl(ua, ub)
            val lo = ua * ub
            # Negate 128-bit result if signs differ
            if a_neg xor b_neg:
                val neg_lo = (lo xor 0xFFFFFFFFFFFFFFFF) + 1
                var neg_hi = hi xor 0xFFFFFFFFFFFFFFFF
                if neg_lo == 0: neg_hi = neg_hi + 1  # Carry
                neg_hi
            else:
                hi

        MulDivOp.Mulhsu:
            # Signed x Unsigned high multiply
            val a_neg = a < 0
            var ua = a
            if a_neg: ua = 0 - a
            val hi = _mulhu_impl(ua, b)
            val lo = ua * b
            if a_neg:
                val neg_lo = (lo xor 0xFFFFFFFFFFFFFFFF) + 1
                var neg_hi = hi xor 0xFFFFFFFFFFFFFFFF
                if neg_lo == 0: neg_hi = neg_hi + 1
                neg_hi
            else:
                hi

        MulDivOp.Mulhu:
            _mulhu_impl(a, b)

        MulDivOp.Div:
            # Signed division
            if b == 0:
                0xFFFFFFFFFFFFFFFF  # Division by zero -> -1
            elif a == 0x8000000000000000 and b == 0xFFFFFFFFFFFFFFFF:
                a  # Overflow -> return dividend
            else:
                a / b

        MulDivOp.Divu:
            # Unsigned division (approximate via signed with careful handling)
            if b == 0:
                0xFFFFFFFFFFFFFFFF  # Division by zero -> all 1s
            else:
                # Simple unsigned division using shifts for large values
                pass_todo("precise unsigned 64-bit division")
                a / b  # Approximate for now

        MulDivOp.Rem:
            if b == 0:
                a  # Remainder by zero -> dividend
            elif a == 0x8000000000000000 and b == 0xFFFFFFFFFFFFFFFF:
                0  # Overflow -> 0
            else:
                a - (a / b) * b

        MulDivOp.Remu:
            if b == 0:
                a  # Remainder by zero -> dividend
            else:
                pass_todo("precise unsigned 64-bit remainder")
                a - (a / b) * b  # Approximate

        _: 0

fn muldiv_execute_word(op: MulDivOp, a: i64, b: i64) -> i64:
    """Execute a W-variant (32-bit) M-extension operation.
    Operates on lower 32 bits, sign-extends result to 64."""
    val a32 = _sign_extend_32(a)
    val b32 = _sign_extend_32(b)

    match op:
        MulDivOp.Mulw:
            _sign_extend_32(a32 * b32)

        MulDivOp.Divw:
            if b32 == 0:
                0xFFFFFFFFFFFFFFFF
            elif a32 == _sign_extend_32(0x80000000) and b32 == -1:
                _sign_extend_32(0x80000000)
            else:
                _sign_extend_32(a32 / b32)

        MulDivOp.Divuw:
            val ua = a and 0xFFFFFFFF
            val ub = b and 0xFFFFFFFF
            if ub == 0:
                0xFFFFFFFFFFFFFFFF
            else:
                _sign_extend_32(ua / ub)

        MulDivOp.Remw:
            if b32 == 0:
                _sign_extend_32(a32)
            elif a32 == _sign_extend_32(0x80000000) and b32 == -1:
                0
            else:
                _sign_extend_32(a32 - (a32 / b32) * b32)

        MulDivOp.Remuw:
            val ua = a and 0xFFFFFFFF
            val ub = b and 0xFFFFFFFF
            if ub == 0:
                _sign_extend_32(ua)
            else:
                _sign_extend_32(ua - (ua / ub) * ub)

        _: 0
