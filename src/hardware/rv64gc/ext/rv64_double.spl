    pass_todo("IEEE 754 single-to-double widening conversion")
    _fp_result_d(DP_QNAN, FP_FLAG_NV)

# ---------------------------------------------------------------------------
# Move (bit-level reinterpret)
# ---------------------------------------------------------------------------

fn fmv_x_d(a: i64) -> i64:
    """FMV.X.D: move double bits to integer register."""
    a

fn fmv_d_x(a: i64) -> i64:
    """FMV.D.X: move integer bits to double register."""
    a
