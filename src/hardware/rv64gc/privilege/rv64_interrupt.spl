"""
# RV64 Interrupt Priority and Pending Logic

Handles interrupt priority resolution per RISC-V privilege spec.
"""

use hardware.rv64gc.pkg.rv64_types_pkg.{PrivilegeMode, priv_to_i64}
use hardware.rv64gc.pkg.rv64_csr_addrs.*
use hardware.rv64gc.privilege.rv64_trap.{INTERRUPT_BIT, make_interrupt_cause}

# Standard interrupt codes
val IRQ_S_SOFTWARE: i64 = 1
val IRQ_M_SOFTWARE: i64 = 3
val IRQ_S_TIMER: i64 = 5
val IRQ_M_TIMER: i64 = 7
val IRQ_S_EXTERNAL: i64 = 9
val IRQ_M_EXTERNAL: i64 = 11

# Interrupt priority order (highest first): MEI, MSI, MTI, SEI, SSI, STI
val INTERRUPT_PRIORITY: [i64] = [11, 3, 7, 9, 1, 5]

fn interrupts_enabled(mstatus: i64, priv_mode: PrivilegeMode) -> bool:
    """Check if interrupts are globally enabled for the current privilege mode."""
    val level = priv_to_i64(priv_mode)
    if level == 3:
        # M-mode: check MIE
        (mstatus and MSTATUS_MIE) != 0
    elif level == 1:
        # S-mode: check SIE (also always interruptible by M-mode interrupts)
        (mstatus and MSTATUS_SIE) != 0
    else:
        # U-mode: always interruptible
        true

fn pending_interrupts(mip: i64, mie: i64) -> i64:
    """Get mask of enabled and pending interrupts."""
    mip and mie

fn should_take_interrupt(mip: i64, mie: i64, mstatus: i64, mideleg: i64,
                          priv_mode: PrivilegeMode) -> i64:
    """Determine if an interrupt should be taken. Returns the interrupt cause
    (with bit 63 set) or 0 if no interrupt should be taken."""
    val pending = pending_interrupts(mip, mie)
    if pending == 0: 0
    else:
        val level = priv_to_i64(priv_mode)
        var result: i64 = 0
        var idx = 0

        while idx < 6 and result == 0:
            val irq = INTERRUPT_PRIORITY[idx]
            val irq_bit = 1 << irq

            if (pending and irq_bit) != 0:
                val delegated = (mideleg and irq_bit) != 0

                if delegated:
                    # Delegated to S-mode
                    if level < 1:
                        # U-mode: always take S-mode interrupt
                        result = make_interrupt_cause(irq)
                    elif level == 1 and (mstatus and MSTATUS_SIE) != 0:
                        # S-mode with SIE: take it
                        result = make_interrupt_cause(irq)
                    # M-mode or S-mode with SIE=0: don't take delegated interrupt
                else:
                    # Not delegated: M-mode handles it
                    if level < 3:
                        # S/U mode: always take M-mode interrupt
                        result = make_interrupt_cause(irq)
                    elif (mstatus and MSTATUS_MIE) != 0:
                        # M-mode with MIE: take it
                        result = make_interrupt_cause(irq)

            idx = idx + 1

        result
