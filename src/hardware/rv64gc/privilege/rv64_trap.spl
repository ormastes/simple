"""
# RV64 Trap Handling

Trap delegation, entry, and return logic.
"""

use hardware.rv64gc.pkg.rv64_types_pkg.{PrivilegeMode, priv_to_i64, i64_to_priv}
use hardware.rv64gc.pkg.rv64_csr_addrs.*
use hardware.rv64gc.privilege.rv64_privilege.determine_trap_target

# Interrupt bit in mcause/scause (bit 63 for RV64)
val INTERRUPT_BIT: i64 = 0x8000000000000000

fn is_interrupt_cause(cause: i64) -> bool:
    """Check if a cause value represents an interrupt (bit 63 set)."""
    (cause and INTERRUPT_BIT) != 0

fn make_interrupt_cause(code: i64) -> i64:
    """Create an interrupt cause value (sets bit 63)."""
    code or INTERRUPT_BIT

fn make_exception_cause(code: i64) -> i64:
    """Create an exception cause value (bit 63 clear)."""
    code and 0x7FFFFFFFFFFFFFFF

fn compute_trap_vector(tvec: i64, cause: i64) -> i64:
    """Compute trap handler address from xTVEC register and cause.
    Mode 0 (Direct): handler at BASE
    Mode 1 (Vectored): handler at BASE + 4*cause for interrupts"""
    val mode = tvec and 0x3
    val base = tvec and 0xFFFFFFFFFFFFFFFC

    if mode == 1 and is_interrupt_cause(cause):
        val code = cause and 0x7FFFFFFFFFFFFFFF
        base + (code * 4)
    else:
        base

class TrapHandler:
    """Coordinates trap entry and return."""
    dummy: i64

    static fn create() -> TrapHandler:
        TrapHandler(dummy: 0)

fn handle_trap_entry(cause: i64, tval: i64, pc: i64,
                      medeleg: i64, mideleg: i64,
                      current_mode: PrivilegeMode) -> PrivilegeMode:
    """Determine which mode should handle a trap.
    The caller is responsible for updating CSRs via CsrFile.trap_enter()."""
    val is_int = is_interrupt_cause(cause)
    determine_trap_target(cause, medeleg, mideleg, is_int, current_mode)

fn compute_mret_target(mstatus: i64) -> PrivilegeMode:
    """Compute the target privilege mode after MRET."""
    val mpp = (mstatus and MSTATUS_MPP_MASK) >> MSTATUS_MPP_SHIFT
    i64_to_priv(mpp)

fn compute_sret_target(mstatus: i64) -> PrivilegeMode:
    """Compute the target privilege mode after SRET."""
    if (mstatus and MSTATUS_SPP) != 0:
        PrivilegeMode.Supervisor
    else:
        PrivilegeMode.User
