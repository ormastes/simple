"""
# RV64 Types Package

Re-exports shared types and defines RV64-specific constants.
"""

# Re-export all shared types
use hardware.riscv_common.pkg.riscv_types_pkg.*

val XLEN: i64 = 64
val FLEN: i64 = 64
val NUM_REGS: i64 = 32

# Privilege levels
enum PrivilegeMode:
    User
    Supervisor
    Machine

fn priv_to_i64(mode: PrivilegeMode) -> i64:
    match mode:
        PrivilegeMode.User: 0
        PrivilegeMode.Supervisor: 1
        PrivilegeMode.Machine: 3

fn i64_to_priv(val_: i64) -> PrivilegeMode:
    if val_ == 0: PrivilegeMode.User
    elif val_ == 1: PrivilegeMode.Supervisor
    else: PrivilegeMode.Machine

# Access types for MMU
enum AccessType:
    Read_
    Write_
    Execute

# Trap causes
val TRAP_INSTR_MISALIGNED: i64 = 0
val TRAP_INSTR_ACCESS_FAULT: i64 = 1
val TRAP_ILLEGAL_INSTR: i64 = 2
val TRAP_BREAKPOINT: i64 = 3
val TRAP_LOAD_MISALIGNED: i64 = 4
val TRAP_LOAD_ACCESS_FAULT: i64 = 5
val TRAP_STORE_MISALIGNED: i64 = 6
val TRAP_STORE_ACCESS_FAULT: i64 = 7
val TRAP_ECALL_U: i64 = 8
val TRAP_ECALL_S: i64 = 9
val TRAP_ECALL_M: i64 = 11
val TRAP_INSTR_PAGE_FAULT: i64 = 12
val TRAP_LOAD_PAGE_FAULT: i64 = 13
val TRAP_STORE_PAGE_FAULT: i64 = 15
