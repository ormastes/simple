# Pure-Simple `simple-core` environment ABI wrappers.
#
# Provides rt_env_get, rt_env_set, and rt_env_cwd by delegating to libc
# getenv, setenv, and getcwd.  All parameters and return values use the
# runtime tagged-value ABI (i64).

extern fn getenv(name: i64) -> i64
extern fn setenv(key: i64, value: i64, overwrite: i64) -> i64
extern fn getcwd(buf: i64, size: i64) -> i64
extern fn malloc(size: i64) -> i64
extern fn free(ptr: i64)
extern fn strlen(s: i64) -> i64
extern fn rt_string_data(value: i64) -> i64
extern fn rt_string_new(bytes: i64, len: i64) -> i64

pub fn rt_env_get(key: i64) -> i64:
    val key_ptr = rt_string_data(key)
    if key_ptr < 1:
        return rt_string_new(0, 0)
    val result = getenv(key_ptr)
    if result < 1:
        return rt_string_new(0, 0)
    val len = strlen(result)
    return rt_string_new(result, len)

pub fn rt_env_set(key: i64, value: i64) -> i64:
    val key_ptr = rt_string_data(key)
    if key_ptr < 1:
        return 0
    val value_ptr = rt_string_data(value)
    if value_ptr < 1:
        return 0
    val result = setenv(key_ptr, value_ptr, 1)
    if result < 0:
        return 0
    return 1

pub fn rt_env_cwd() -> i64:
    val buf = malloc(4096)
    if buf < 1:
        return rt_string_new(0, 0)
    val result = getcwd(buf, 4096)
    if result < 1:
        free(buf)
        return rt_string_new(0, 0)
    val len = strlen(buf)
    val out = rt_string_new(buf, len)
    free(buf)
    return out
