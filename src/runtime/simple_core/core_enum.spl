# Pure-Simple enum heap-object ABI.

extern fn malloc(size: i64) -> i64
extern fn spl_load_i64(ptr: i64, offset: i64) -> i64
extern fn spl_store_i64(ptr: i64, offset: i64, value: i64)

fn enum_ptr(value: i64) -> i64:
    if (value & 7) < 1 or (value & 7) > 1:
        return 0
    val ptr = value & -8
    if ptr < 1:
        return 0
    val header = spl_load_i64(ptr, 0)
    if (header & 255) != 7:
        return 0
    return ptr

pub fn rt_simple_enum_new(enum_id: i64, discriminant: i64, payload: i64) -> i64:
    val ptr = malloc(24)
    if ptr < 1:
        return 3
    spl_store_i64(ptr, 0, 103079215111)
    spl_store_i64(ptr, 8, (enum_id & 4294967295) | ((discriminant & 4294967295) << 32))
    spl_store_i64(ptr, 16, payload)
    return ptr | 1

pub fn rt_enum_discriminant(value: i64) -> i64:
    val ptr = enum_ptr(value)
    if ptr < 1:
        return -1
    return (spl_load_i64(ptr, 8) >> 32) & 4294967295

pub fn rt_enum_payload(value: i64) -> i64:
    val ptr = enum_ptr(value)
    if ptr < 1:
        return 3
    return spl_load_i64(ptr, 16)

pub fn rt_enum_check_discriminant(value: i64, discriminant: i64) -> i8:
    if rt_enum_discriminant(value) == (discriminant & 4294967295):
        return 1
    return 0
