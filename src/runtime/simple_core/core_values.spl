# Pure-Simple `simple-core` ABI subset.
#
# This file intentionally implements only runtime symbols that do not require
# host memory, string, stdio, time, or process primitives.

extern fn rt_enum_discriminant(value: i64) -> i64
extern fn rt_enum_id(value: i64) -> i64
extern fn rt_enum_payload(value: i64) -> i64

pub fn __simple_runtime_init() -> i64:
    return 0

pub fn __simple_runtime_shutdown() -> i64:
    return 0

pub fn rt_value_int(value: i64) -> i64:
    return value << 3

pub fn rt_value_as_int(value: i64) -> i64:
    return value >> 3

pub fn rt_pool_safepoint() -> i64:
    # simple-core bootstrap execution is single-threaded.
    return 0

pub fn rt_value_float(raw_bits: i64) -> i64:
    return (raw_bits & -8) | 2

pub fn rt_value_bool(value: i64) -> i64:
    return ((2 - value) << 3) | 3

pub fn rt_value_nil() -> i64:
    return 3

pub fn rt_is_some(value: i64) -> i8:
    return if rt_is_none(value) != 0: 0 else: 1

pub fn rt_is_none(value: i64) -> i8:
    if value == 3:
        return 1
    if rt_enum_id(value) != 1:
        return 0
    return if rt_enum_discriminant(value) == 1: 1 else: 0

pub fn rt_unwrap_or_self(value: i64) -> i64:
    if rt_enum_discriminant(value) >= 0:
        return rt_enum_payload(value)
    value

pub fn rt_enum_check_discriminant(value: i64, expected: i64) -> i8:
    val discriminant = rt_enum_discriminant(value)
    return if discriminant < expected or discriminant > expected: 0 else: 1
