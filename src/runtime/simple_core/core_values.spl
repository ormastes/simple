# Pure-Simple `simple-core` ABI subset.
#
# This file intentionally implements only runtime symbols that do not require
# host memory, string, stdio, time, or process primitives.

pub fn __simple_runtime_init() -> i64:
    return 0

pub fn __simple_runtime_shutdown() -> i64:
    return 0

pub fn rt_value_int(value: i64) -> i64:
    return value << 3

pub fn rt_value_float(raw_bits: i64) -> i64:
    return (raw_bits & -8) | 2

pub fn rt_value_bool(value: i64) -> i64:
    return ((2 - value) << 3) | 3

pub fn rt_value_nil() -> i64:
    return 3

pub fn rt_is_some(value: i64) -> i8:
    if value == 3:
        return 0
    return 1

pub fn rt_enum_check_discriminant(value: i64, expected: i64) -> i8:
    return 1
