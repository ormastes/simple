# Pure-Simple `simple-core` async/future ABI.
#
# This module gives the no-GC simple-core lane concrete ownership of the async
# state-machine symbols that compiler lowering may emit.  It intentionally uses
# a compact pointer layout backed by the existing core memory and array ABI, so
# native builds do not fall back to generated C stubs for async entry points.

extern fn calloc(count: i64, size: i64) -> i64
extern fn free(ptr: i64)
extern fn spl_load_i64(ptr: i64, offset: i64) -> i64
extern fn spl_store_i64(ptr: i64, offset: i64, value: i64)
extern fn rt_array_new(cap: i64) -> i64
extern fn rt_array_len(array: i64) -> i64
extern fn rt_array_get(array: i64, idx: i64) -> i64
extern fn rt_array_push(array: i64, value: i64) -> i8

const FUTURE_SIZE: i64 = 48
const FUTURE_STATE: i64 = 0
const FUTURE_RESULT: i64 = 8
const FUTURE_BODY: i64 = 16
const FUTURE_ASYNC_STATE: i64 = 24
const FUTURE_CTX: i64 = 32
const FUTURE_DONE: i64 = 40
const NIL_VALUE: i64 = 3

fn is_future_handle(future: i64) -> i8:
    if future < 4096:
        return 0
    if (future & 7) > 0:
        return 0
    return 1

fn future_get(future: i64, offset: i64) -> i64:
    if is_future_handle(future) < 1:
        return 0
    return spl_load_i64(future, offset)

fn future_set(future: i64, offset: i64, value: i64):
    if is_future_handle(future) > 0:
        spl_store_i64(future, offset, value)

fn future_alloc(state: i64, result: i64, body_func: i64, ctx: i64) -> i64:
    val future = calloc(1, FUTURE_SIZE)
    if future < 1:
        return NIL_VALUE
    future_set(future, FUTURE_STATE, state)
    future_set(future, FUTURE_RESULT, result)
    future_set(future, FUTURE_BODY, body_func)
    future_set(future, FUTURE_ASYNC_STATE, 0)
    future_set(future, FUTURE_CTX, ctx)
    if state >= 1 and state <= 1:
        future_set(future, FUTURE_DONE, 1)
    else:
        future_set(future, FUTURE_DONE, 0)
    return future

pub fn rt_future_new(body_func: i64, ctx: i64) -> i64:
    return future_alloc(0, NIL_VALUE, body_func, ctx)

pub fn rt_future_resolve(value: i64) -> i64:
    return future_alloc(1, value, 0, NIL_VALUE)

pub fn rt_future_reject(error: i64) -> i64:
    return rt_future_resolve(error)

pub fn rt_future_is_ready(future: i64) -> i64:
    if is_future_handle(future) < 1:
        return 0
    val state = future_get(future, FUTURE_STATE)
    if state >= 1 and state <= 1:
        return 1
    return 0

pub fn rt_future_get_result(future: i64) -> i64:
    if rt_future_is_ready(future) > 0:
        return future_get(future, FUTURE_RESULT)
    return NIL_VALUE

pub fn rt_future_await(future: i64) -> i64:
    if is_future_handle(future) < 1:
        return NIL_VALUE
    if rt_future_is_ready(future) > 0:
        return future_get(future, FUTURE_RESULT)

    # The pure Simple core lane cannot call arbitrary native function pointers.
    # Preserve the future as pending; richer host runtimes may execute body_func.
    return NIL_VALUE

pub fn rt_future_all(futures_array: i64) -> i64:
    val len = rt_array_len(futures_array)
    val results = rt_array_new(len)
    var i = 0
    while i < len:
        val future = rt_array_get(futures_array, i)
        rt_array_push(results, rt_future_await(future))
        i = i + 1
    return results

pub fn rt_future_race(futures_array: i64) -> i64:
    val len = rt_array_len(futures_array)
    if len < 1:
        return NIL_VALUE

    var i = 0
    while i < len:
        val future = rt_array_get(futures_array, i)
        if rt_future_is_ready(future) > 0:
            return rt_future_get_result(future)
        i = i + 1

    return rt_future_await(rt_array_get(futures_array, 0))

pub fn rt_future_free(future: i64):
    if is_future_handle(future) > 0:
        free(future)

pub fn rt_async_get_state(future: i64) -> i64:
    return future_get(future, FUTURE_ASYNC_STATE)

pub fn rt_async_set_state(future: i64, state: i64):
    var next_state = state
    if next_state < 0:
        next_state = 0
    future_set(future, FUTURE_ASYNC_STATE, next_state)

pub fn rt_async_get_ctx(future: i64) -> i64:
    if is_future_handle(future) < 1:
        return NIL_VALUE
    return future_get(future, FUTURE_CTX)

pub fn rt_async_mark_done(future: i64):
    if is_future_handle(future) > 0:
        future_set(future, FUTURE_DONE, 1)
        future_set(future, FUTURE_STATE, 1)

pub fn rt_async_spawn(future: i64) -> i64:
    return future

pub fn rt_async_spawn_task(future: i64) -> i64:
    return future

pub fn rt_async_poll_tasks() -> i64:
    return 0

pub fn rt_async_current_task_id() -> i64:
    return 0

pub fn rt_executor_current_task_id() -> i64:
    return 0

pub fn rt_async_schedule_await(future: i64) -> i64:
    return rt_future_await(future)

pub fn rt_async_run_until_complete(future: i64) -> i64:
    return rt_future_await(future)
