# Pure-Simple `simple-core` raw-pointer atomic fallback.
#
# The simple-core lane owns the rt_atomic_* ABI used by no-GC libraries during
# bootstrap and single-threaded package builds. Hosted/platform runtimes may
# replace these with true atomic operations for concurrent execution.

extern fn rt_ptr_read_i64(addr: i64, offset: i64) -> i64
extern fn rt_ptr_write_i64(addr: i64, offset: i64, value: i64)
extern fn rt_ptr_write_i32(addr: i64, offset: i64, value: i64)
extern fn rt_ptr_write_u8(addr: i64, offset: i64, value: i64)
extern fn calloc(count: i64, size: i64) -> i64
extern fn free(ptr: i64)

pub fn rt_atomic_load_u64(addr: i64) -> i64:
    return rt_ptr_read_i64(addr, 0)

pub fn rt_atomic_store_u64(addr: i64, value: i64):
    rt_ptr_write_i64(addr, 0, value)

pub fn rt_atomic_fetch_add_u64(addr: i64, delta: i64) -> i64:
    val old = rt_atomic_load_u64(addr)
    rt_atomic_store_u64(addr, old + delta)
    return old

pub fn rt_atomic_store_u32(addr: i64, value: i64):
    rt_ptr_write_i32(addr, 0, value)

pub fn rt_atomic_store_u8(addr: i64, value: i64):
    rt_ptr_write_u8(addr, 0, value)

# Hosted runtimes use a registry of true atomics. The bootstrap simple-core
# lane is single-threaded, so a pointer-backed i64 provides the same handle ABI
# without generated stubs; hosted concurrency continues to select its richer
# runtime owner.
pub fn rt_atomic_int_new(initial: i64) -> i64:
    val handle = calloc(1, 8)
    if handle > 0:
        rt_ptr_write_i64(handle, 0, initial)
    handle

pub fn rt_atomic_int_load(handle: i64) -> i64:
    if handle < 4096: 0 else: rt_ptr_read_i64(handle, 0)

pub fn rt_atomic_int_compare_exchange(handle: i64, current: i64, new_value: i64) -> i8:
    if handle < 4096:
        return 0
    if rt_ptr_read_i64(handle, 0) != current:
        return 0
    rt_ptr_write_i64(handle, 0, new_value)
    1

pub fn rt_atomic_int_free(handle: i64):
    if handle >= 4096:
        free(handle)
