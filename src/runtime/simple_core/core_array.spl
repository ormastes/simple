# Pure-Simple `simple-core` array ABI.

extern fn malloc(size: i64) -> i64
extern fn calloc(count: i64, size: i64) -> i64
extern fn realloc(ptr: i64, size: i64) -> i64
extern fn free(ptr: i64)
extern fn memcpy(dst: i64, src: i64, n: i64) -> i64
extern fn spl_load_i64(ptr: i64, offset: i64) -> i64
extern fn spl_store_i64(ptr: i64, offset: i64, value: i64)
extern fn rt_string_join(array: i64, separator: i64) -> i64

fn array_items(array: i64) -> i64:
    return spl_load_i64(array, 0)

fn array_len_value(array: i64) -> i64:
    return spl_load_i64(array, 8)

fn array_cap(array: i64) -> i64:
    return spl_load_i64(array, 16)

fn array_is_valid(array: i64) -> i64:
    if array < 4096:
        return 0
    if (array & 7) > 0:
        return 0
    val len = array_len_value(array)
    val cap = array_cap(array)
    if len < 0 or cap < 0:
        return 0
    if len > cap:
        return 0
    if cap > 100000000:
        return 0
    return 1

fn set_array_items(array: i64, items: i64):
    spl_store_i64(array, 0, items)

fn set_array_len(array: i64, len: i64):
    spl_store_i64(array, 8, len)

fn set_array_cap(array: i64, cap: i64):
    spl_store_i64(array, 16, cap)

fn numeric_index(value: i64) -> i64:
    if (value & 7) < 1 and value >= 8:
        return value >> 3
    return value

fn normalize_index(array: i64, idx: i64) -> i64:
    val raw_idx = numeric_index(idx)
    if raw_idx < 0:
        return array_len_value(array) + raw_idx
    return raw_idx

pub fn rt_array_new(cap: i64) -> i64:
    var actual_cap = cap
    if actual_cap < 4:
        actual_cap = 4
    val array = malloc(24)
    if array < 1:
        return 0
    val items = calloc(actual_cap, 8)
    if items < 1:
        return 0
    set_array_items(array, items)
    set_array_len(array, 0)
    set_array_cap(array, actual_cap)
    return array

pub fn rt_array_len(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    return array_len_value(array)

pub fn rt_array_get(array: i64, idx: i64) -> i64:
    if array_is_valid(array) < 1:
        return 3
    val actual_idx = normalize_index(array, idx)
    if actual_idx < 0 or actual_idx >= array_len_value(array):
        return 3
    return spl_load_i64(array_items(array), actual_idx * 8)

pub fn rt_array_set(array: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = normalize_index(array, idx)
    if actual_idx < 0 or actual_idx >= array_len_value(array):
        return 0
    spl_store_i64(array_items(array), actual_idx * 8, value)
    return 1

pub fn rt_array_push(array: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    var len = array_len_value(array)
    var cap = array_cap(array)
    if len >= cap:
        var new_cap = cap * 2
        if new_cap < 4:
            new_cap = 4
        val new_items = realloc(array_items(array), new_cap * 8)
        if new_items < 1:
            set_array_len(array, 0)
            set_array_cap(array, 0)
            return 0
        set_array_items(array, new_items)
        set_array_cap(array, new_cap)
        cap = new_cap
    spl_store_i64(array_items(array), len * 8, value)
    set_array_len(array, len + 1)
    return 1

pub fn rt_array_pop(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 3
    val len = array_len_value(array)
    if len <= 0:
        return 3
    val new_len = len - 1
    val value = spl_load_i64(array_items(array), new_len * 8)
    set_array_len(array, new_len)
    return value

# ============================================================================
# Value tag helpers
# ============================================================================

fn val_is_int(v: i64) -> i64:
    if (v & 7) < 1:
        return 1
    return 0

fn val_as_int(v: i64) -> i64:
    return v >> 3

fn val_is_falsy(v: i64) -> i64:
    # NIL (3) is falsy
    if v > 2 and v < 4:
        return 1
    # false (19) is falsy
    if v > 18 and v < 20:
        return 1
    # int 0 is falsy (tagged: 0 << 3 = 0)
    if v < 1 and v > -1:
        return 1
    return 0

fn val_from_int(i: i64) -> i64:
    return i << 3

# ============================================================================
# Tier 1: Mechanical, no extra dependencies
# ============================================================================

pub fn rt_array_clear(array: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    set_array_len(array, 0)
    return 1

pub fn rt_array_free(array: i64):
    if array_is_valid(array) < 1:
        return
    val items = array_items(array)
    if items > 0:
        free(items)
    free(array)

pub fn rt_array_new_with_cap(cap: i64) -> i64:
    return rt_array_new(cap)

pub fn rt_array_new_with_cap_i64(cap: i64) -> i64:
    return rt_array_new(cap)

pub fn rt_array_new_with_cap_text(cap: i64) -> i64:
    return rt_array_new(cap)

pub fn rt_array_new_with_cap_bool(cap: i64) -> i64:
    return rt_array_new(cap)

pub fn rt_array_new_with_cap_js_value(cap: i64) -> i64:
    return rt_array_new(cap)

pub fn rt_array_first(array: i64) -> i64:
    return rt_array_get(array, 0)

pub fn rt_array_last(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 3
    val len = array_len_value(array)
    if len <= 0:
        return 3
    return spl_load_i64(array_items(array), (len - 1) * 8)

pub fn rt_array_copy(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val result = rt_array_new(len)
    if result < 1:
        return 0
    if len > 0:
        memcpy(array_items(result), array_items(array), len * 8)
        set_array_len(result, len)
    return result

pub fn rt_array_concat(a: i64, b: i64) -> i64:
    if array_is_valid(a) < 1 or array_is_valid(b) < 1:
        return 0
    val len_a = array_len_value(a)
    val len_b = array_len_value(b)
    val total = len_a + len_b
    val result = rt_array_new(total)
    if result < 1:
        return 0
    if len_a > 0:
        memcpy(array_items(result), array_items(a), len_a * 8)
    if len_b > 0:
        memcpy(array_items(result) + len_a * 8, array_items(b), len_b * 8)
    set_array_len(result, total)
    return result

pub fn rt_array_reverse(array: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val items = array_items(array)
    var lo = 0
    var hi = len - 1
    while lo < hi:
        val tmp = spl_load_i64(items, lo * 8)
        spl_store_i64(items, lo * 8, spl_load_i64(items, hi * 8))
        spl_store_i64(items, hi * 8, tmp)
        lo = lo + 1
        hi = hi - 1
    return 1

pub fn rt_array_reversed(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val result = rt_array_new(len)
    if result < 1:
        return 0
    val src = array_items(array)
    val dst = array_items(result)
    var i = 0
    while i < len:
        spl_store_i64(dst, i * 8, spl_load_i64(src, (len - 1 - i) * 8))
        i = i + 1
    set_array_len(result, len)
    return result

pub fn rt_array_take(array: i64, n: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    var take_n = n
    if take_n < 0:
        take_n = 0
    if take_n > len:
        take_n = len
    val result = rt_array_new(take_n)
    if result < 1:
        return 0
    if take_n > 0:
        memcpy(array_items(result), array_items(array), take_n * 8)
        set_array_len(result, take_n)
    return result

pub fn rt_array_drop(array: i64, n: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    var drop_count = n
    if drop_count < 0:
        drop_count = 0
    if drop_count > len:
        drop_count = len
    val result_len = len - drop_count
    val result = rt_array_new(result_len)
    if result < 1:
        return 0
    if result_len > 0:
        memcpy(array_items(result), array_items(array) + drop_count * 8, result_len * 8)
        set_array_len(result, result_len)
    return result

pub fn rt_array_fill(array: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val items = array_items(array)
    var i = 0
    while i < len:
        spl_store_i64(items, i * 8, value)
        i = i + 1
    return 1

pub fn rt_array_repeat(value: i64, count: i64) -> i64:
    if count <= 0:
        return rt_array_new(0)
    val result = rt_array_new(count)
    if result < 1:
        return 0
    val items = array_items(result)
    var i = 0
    while i < count:
        spl_store_i64(items, i * 8, value)
        i = i + 1
    set_array_len(result, count)
    return result

pub fn rt_array_range(start: i64, end: i64, step: i64) -> i64:
    if step < 1 and step > -1:
        return 3
    var count = 0
    if step > 0:
        if end > start:
            count = (end - start + step - 1) / step
    if step < 0:
        if start > end:
            count = (start - end + (0 - step) - 1) / (0 - step)
    val result = rt_array_new(count)
    if result < 1:
        return 0
    val items = array_items(result)
    var cur = start
    var idx = 0
    while idx < count:
        spl_store_i64(items, idx * 8, val_from_int(cur))
        cur = cur + step
        idx = idx + 1
    set_array_len(result, count)
    return result

pub fn rt_array_push_grow(array: i64, value: i64) -> i8:
    return rt_array_push(array, value)

pub fn rt_array_push_no_grow(array: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val cap = array_cap(array)
    if len >= cap:
        return 0
    spl_store_i64(array_items(array), len * 8, value)
    set_array_len(array, len + 1)
    return 1

pub fn rt_typed_words_u32_at(array: i64, idx: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = normalize_index(array, idx)
    if actual_idx < 0 or actual_idx >= array_len_value(array):
        return 0
    return spl_load_i64(array_items(array), actual_idx * 8) & 0xffffffff

pub fn rt_typed_words_u32_unchecked(array: i64, idx: i64) -> i64:
    return spl_load_i64(array_items(array), numeric_index(idx) * 8) & 0xffffffff

pub fn rt_typed_words_u32_data_at(items: i64, idx: i64) -> i64:
    return spl_load_i64(items, numeric_index(idx) * 8) & 0xffffffff

pub fn rt_typed_words_u32_push(array: i64, value: i64) -> i8:
    return rt_array_push(array, value & 0xffffffff)

pub fn rt_typed_words_u32_push_known_at(array: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = numeric_index(idx)
    if actual_idx < 0 or actual_idx >= array_cap(array):
        return 0
    spl_store_i64(array_items(array), actual_idx * 8, value & 0xffffffff)
    if actual_idx >= array_len_value(array):
        set_array_len(array, actual_idx + 1)
    return 1

pub fn rt_typed_words_u32_push_known_data_at(array: i64, items: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = numeric_index(idx)
    if actual_idx < 0 or actual_idx >= array_cap(array):
        return 0
    spl_store_i64(items, numeric_index(idx) * 8, value & 0xffffffff)
    if actual_idx >= array_len_value(array):
        set_array_len(array, actual_idx + 1)
    return 1

pub fn rt_typed_words_u32_set(array: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = normalize_index(array, idx)
    if actual_idx < 0 or actual_idx >= array_len_value(array):
        return 0
    spl_store_i64(array_items(array), actual_idx * 8, value & 0xffffffff)
    return 1

pub fn rt_typed_words_u64_at(array: i64, idx: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = normalize_index(array, idx)
    if actual_idx < 0 or actual_idx >= array_len_value(array):
        return 0
    return spl_load_i64(array_items(array), actual_idx * 8)

pub fn rt_typed_words_u64_unchecked(array: i64, idx: i64) -> i64:
    return spl_load_i64(array_items(array), numeric_index(idx) * 8)

pub fn rt_typed_words_u64_data_at(items: i64, idx: i64) -> i64:
    return spl_load_i64(items, numeric_index(idx) * 8)

pub fn rt_typed_words_u64_push(array: i64, value: i64) -> i8:
    return rt_array_push(array, value)

pub fn rt_typed_words_u64_push_known_at(array: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = numeric_index(idx)
    if actual_idx < 0 or actual_idx >= array_cap(array):
        return 0
    spl_store_i64(array_items(array), actual_idx * 8, value)
    if actual_idx >= array_len_value(array):
        set_array_len(array, actual_idx + 1)
    return 1

pub fn rt_typed_words_u64_push_known_data_at(array: i64, items: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = numeric_index(idx)
    if actual_idx < 0 or actual_idx >= array_cap(array):
        return 0
    spl_store_i64(items, numeric_index(idx) * 8, value)
    if actual_idx >= array_len_value(array):
        set_array_len(array, actual_idx + 1)
    return 1

pub fn rt_typed_words_u64_set(array: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = normalize_index(array, idx)
    if actual_idx < 0 or actual_idx >= array_len_value(array):
        return 0
    spl_store_i64(array_items(array), actual_idx * 8, value)
    return 1

pub fn rt_array_extend_i64(dst: i64, src: i64, count: i64) -> i8:
    if count <= 0:
        return 1
    if array_is_valid(dst) < 1 or array_is_valid(src) < 1:
        return 0
    val src_len = array_len_value(src)
    if count > src_len:
        return 0
    val dst_len = array_len_value(dst)
    val needed = dst_len + count
    var dst_cap = array_cap(dst)
    if needed > dst_cap:
        var new_cap = dst_cap * 2
        if new_cap < needed:
            new_cap = needed
        if new_cap < 4:
            new_cap = 4
        val new_items = realloc(array_items(dst), new_cap * 8)
        if new_items < 1:
            return 0
        set_array_items(dst, new_items)
        set_array_cap(dst, new_cap)
    memcpy(array_items(dst) + dst_len * 8, array_items(src), count * 8)
    set_array_len(dst, dst_len + count)
    return 1

# ============================================================================
# Tier 2: Value equality (raw i64 comparison for tagged values)
# ============================================================================

pub fn rt_array_index_of(array: i64, value: i64) -> i64:
    if array_is_valid(array) < 1:
        return -1
    val len = array_len_value(array)
    val items = array_items(array)
    var i = 0
    while i < len:
        if spl_load_i64(items, i * 8) > value - 1 and spl_load_i64(items, i * 8) < value + 1:
            return i
        i = i + 1
    return -1

pub fn rt_array_last_index_of(array: i64, value: i64) -> i64:
    if array_is_valid(array) < 1:
        return -1
    val len = array_len_value(array)
    val items = array_items(array)
    var i = len - 1
    while i >= 0:
        if spl_load_i64(items, i * 8) > value - 1 and spl_load_i64(items, i * 8) < value + 1:
            return i
        i = i - 1
    return -1

pub fn rt_array_count(array: i64, value: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val items = array_items(array)
    var c = 0
    var i = 0
    while i < len:
        if spl_load_i64(items, i * 8) > value - 1 and spl_load_i64(items, i * 8) < value + 1:
            c = c + 1
        i = i + 1
    return c

pub fn rt_array_unique(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val result = rt_array_new(len)
    if result < 1:
        return 0
    val src_items = array_items(array)
    var i = 0
    while i < len:
        val item = spl_load_i64(src_items, i * 8)
        # Check if item already in result
        val rlen = array_len_value(result)
        val ritems = array_items(result)
        var found = 0
        var j = 0
        while j < rlen and found < 1:
            val existing = spl_load_i64(ritems, j * 8)
            if existing > item - 1 and existing < item + 1:
                found = 1
            j = j + 1
        if found < 1:
            rt_array_push(result, item)
        i = i + 1
    return result

# ============================================================================
# Tier 3: Tag inspection
# ============================================================================

pub fn rt_array_all_truthy(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val items = array_items(array)
    var i = 0
    while i < len:
        val item = spl_load_i64(items, i * 8)
        if val_is_falsy(item) > 0:
            return 0
        i = i + 1
    return 1

pub fn rt_array_any_truthy(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val items = array_items(array)
    var i = 0
    while i < len:
        val item = spl_load_i64(items, i * 8)
        if val_is_falsy(item) < 1:
            return 1
        i = i + 1
    return 0

pub fn rt_array_sum(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return val_from_int(0)
    val len = array_len_value(array)
    if len <= 0:
        return val_from_int(0)
    val items = array_items(array)
    var total = 0
    var i = 0
    while i < len:
        val item = spl_load_i64(items, i * 8)
        if val_is_int(item) > 0:
            total = total + val_as_int(item)
        i = i + 1
    return val_from_int(total)

pub fn rt_array_min(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 3
    val len = array_len_value(array)
    if len <= 0:
        return 3
    val items = array_items(array)
    var min_val = spl_load_i64(items, 0)
    var i = 1
    while i < len:
        val item = spl_load_i64(items, i * 8)
        if val_is_int(item) > 0 and val_is_int(min_val) > 0:
            if val_as_int(item) < val_as_int(min_val):
                min_val = item
        i = i + 1
    return min_val

pub fn rt_array_max(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 3
    val len = array_len_value(array)
    if len <= 0:
        return 3
    val items = array_items(array)
    var max_val = spl_load_i64(items, 0)
    var i = 1
    while i < len:
        val item = spl_load_i64(items, i * 8)
        if val_is_int(item) > 0 and val_is_int(max_val) > 0:
            if val_as_int(item) > val_as_int(max_val):
                max_val = item
        i = i + 1
    return max_val

# ============================================================================
# Tier 4: Sort (insertion sort on tagged i64 values)
# ============================================================================

fn sort_compare(a: i64, b: i64) -> i64:
    # Compare two tagged values for sorting.
    # Ints: compare decoded values. Non-ints: compare raw bits.
    if val_is_int(a) > 0 and val_is_int(b) > 0:
        val ia = val_as_int(a)
        val ib = val_as_int(b)
        if ia < ib:
            return -1
        if ia > ib:
            return 1
        return 0
    # Fallback: compare raw tagged values
    if a < b:
        return -1
    if a > b:
        return 1
    return 0

pub fn rt_array_sort(array: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    if len <= 1:
        return 1
    val items = array_items(array)
    # Insertion sort: shift elements right until we find the insert position
    var i = 1
    while i < len:
        val key = spl_load_i64(items, i * 8)
        var j = i - 1
        while j >= 0 and sort_compare(spl_load_i64(items, j * 8), key) > 0:
            spl_store_i64(items, (j + 1) * 8, spl_load_i64(items, j * 8))
            j = j - 1
        spl_store_i64(items, (j + 1) * 8, key)
        i = i + 1
    return 1

pub fn rt_array_sorted(array: i64) -> i64:
    val result = rt_array_copy(array)
    if result < 1:
        return 0
    rt_array_sort(result)
    return result

pub fn rt_array_sort_desc(array: i64) -> i8:
    if rt_array_sort(array) < 1:
        return 0
    return rt_array_reverse(array)

# ============================================================================
# Tier 5: Depend on tuple/string or heap-type detection
#
# rt_array_zip and rt_array_enumerate: Tuples (rt_tuple_new/rt_tuple_set)
# do not exist in simple-core yet. We use 2-element arrays as pairs instead.
#
# rt_array_flatten: Uses array_is_valid to detect nested arrays since
# simple-core arrays are not heap-tagged.
#
# rt_array_join: Delegates to rt_string_join (declared as extern from
# core_string.spl, linked at archive level).
# ============================================================================

pub fn rt_array_zip(a: i64, b: i64) -> i64:
    if array_is_valid(a) < 1 or array_is_valid(b) < 1:
        return 0
    val len_a = array_len_value(a)
    val len_b = array_len_value(b)
    var result_len = len_a
    if len_b < result_len:
        result_len = len_b
    val result = rt_array_new(result_len)
    if result < 1:
        return 0
    var i = 0
    while i < result_len:
        val pair = rt_array_new(2)
        if pair < 1:
            return 0
        rt_array_push(pair, spl_load_i64(array_items(a), i * 8))
        rt_array_push(pair, spl_load_i64(array_items(b), i * 8))
        rt_array_push(result, pair)
        i = i + 1
    return result

pub fn rt_array_enumerate(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val result = rt_array_new(len)
    if result < 1:
        return 0
    val items = array_items(array)
    var i = 0
    while i < len:
        val pair = rt_array_new(2)
        if pair < 1:
            return 0
        rt_array_push(pair, val_from_int(i))
        rt_array_push(pair, spl_load_i64(items, i * 8))
        rt_array_push(result, pair)
        i = i + 1
    return result

pub fn rt_array_flatten(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    # First pass: count total elements
    val items = array_items(array)
    var total = 0
    var i = 0
    while i < len:
        val item = spl_load_i64(items, i * 8)
        if array_is_valid(item) > 0:
            total = total + array_len_value(item)
        if array_is_valid(item) < 1:
            total = total + 1
        i = i + 1
    val result = rt_array_new(total)
    if result < 1:
        return 0
    # Second pass: copy
    i = 0
    while i < len:
        val item = spl_load_i64(items, i * 8)
        if array_is_valid(item) > 0:
            val inner_len = array_len_value(item)
            val inner_items = array_items(item)
            var k = 0
            while k < inner_len:
                rt_array_push(result, spl_load_i64(inner_items, k * 8))
                k = k + 1
        if array_is_valid(item) < 1:
            rt_array_push(result, item)
        i = i + 1
    return result

pub fn rt_array_join(array: i64, separator: i64) -> i64:
    return rt_string_join(array, separator)
