# Pure-Simple `simple-core` process, time, and panic ABI wrappers.

extern fn exit(code: i64)
extern fn time(ptr: i64) -> i64
extern fn usleep(usec: i64) -> i64
extern fn abort()
extern fn gettimeofday(tv: i64, tz: i64) -> i64
extern fn clock_gettime(clk_id: i64, tp: i64) -> i64
extern fn malloc(size: i64) -> i64
extern fn calloc(count: i64, size: i64) -> i64
extern fn free(ptr: i64)
extern fn spl_load_i64(ptr: i64, offset: i64) -> i64
extern fn spl_load_u8(ptr: i64, offset: i64) -> i64
extern fn spl_store_i64(ptr: i64, offset: i64, value: i64)
extern fn spl_store_u8(ptr: i64, offset: i64, value: i64)
extern fn rt_array_new(cap: i64) -> i64
extern fn rt_array_len(array: i64) -> i64
extern fn rt_array_get_text(array: i64, idx: i64) -> i64
extern fn rt_array_push(array: i64, value: i64) -> i8
extern fn rt_tuple_new(len: i64) -> i64
extern fn rt_tuple_set(tuple: i64, idx: i64, value: i64) -> i8
extern fn rt_value_int(value: i64) -> i64
extern fn rt_string_data(value: i64) -> i64
extern fn rt_string_len(value: i64) -> i64
extern fn rt_string_new(bytes: i64, len: i64) -> i64
extern fn rt_stderr_write(value: i64) -> i64
extern fn fork() -> i64
extern fn execvp(path: i64, argv: i64) -> i64
extern fn waitpid(pid: i64, status: i64, options: i64) -> i64
extern fn getpid() -> i64
extern fn kill(pid: i64, signal_num: i64) -> i64
extern fn sigpending(set_ptr: i64) -> i64
extern fn sigismember(set_ptr: i64, signal_num: i64) -> i64
extern fn sysconf(name: i64) -> i64
extern fn strlen(ptr: i64) -> i64

var _rt_cli_argc: i64 = 0
var _rt_cli_argv: i64 = 0

var _rt_debug_mode_enabled = false

pub fn rt_set_debug_mode(enabled: bool):
    _rt_debug_mode_enabled = enabled

pub fn rt_is_debug_mode_enabled() -> bool:
    _rt_debug_mode_enabled

pub fn rt_exit(code: i64) -> i64:
    exit(code)
    return 0

pub fn rt_set_args(argc: i64, argv: i64) -> i64:
    _rt_cli_argc = argc
    _rt_cli_argv = argv
    return 0

pub fn rt_cli_get_args() -> i64:
    val out = rt_array_new(_rt_cli_argc)
    var i = 0
    while i < _rt_cli_argc:
        val cstr = spl_load_i64(_rt_cli_argv, i * 8)
        val value = if cstr < 1: rt_string_new(0, 0) else: rt_string_new(cstr, strlen(cstr))
        rt_array_push(out, value)
        i = i + 1
    out

pub fn rt_getpid() -> i64:
    getpid()

pub fn rt_cli_arg_count() -> i64:
    return _rt_cli_argc

pub fn rt_cli_arg_at(index: i64) -> i64:
    if index < 0 or index >= _rt_cli_argc or _rt_cli_argv < 1:
        return rt_string_new(0, 0)
    val cstr = spl_load_i64(_rt_cli_argv, index * 8)
    if cstr < 1:
        return rt_string_new(0, 0)
    return rt_string_new(cstr, strlen(cstr))

pub fn rt_time_now_unix() -> i64:
    return time(0)

pub fn rt_time_now_unix_micros() -> i64:
    # struct timeval { time_t tv_sec; suseconds_t tv_usec; } — 16 bytes
    val tv = malloc(16)
    if tv < 1:
        return 0
    val result = gettimeofday(tv, 0)
    if result < 0:
        free(tv)
        return 0
    val sec = spl_load_i64(tv, 0)
    val usec = spl_load_i64(tv, 8)
    free(tv)
    return sec * 1000000 + usec

pub fn rt_time_now_nanos() -> i64:
    # CLOCK_MONOTONIC = 1 on Linux
    # struct timespec { time_t tv_sec; long tv_nsec; } — 16 bytes
    val ts = malloc(16)
    if ts < 1:
        return 0
    val result = clock_gettime(1, ts)
    if result < 0:
        free(ts)
        return 0
    val sec = spl_load_i64(ts, 0)
    val nsec = spl_load_i64(ts, 8)
    free(ts)
    return sec * 1000000000 + nsec

pub fn rt_time_now_micros() -> i64:
    # CLOCK_MONOTONIC = 1 on Linux
    val ts = malloc(16)
    if ts < 1:
        return 0
    val result = clock_gettime(1, ts)
    if result < 0:
        free(ts)
        return 0
    val sec = spl_load_i64(ts, 0)
    val nsec = spl_load_i64(ts, 8)
    free(ts)
    return sec * 1000000 + nsec / 1000

pub fn rt_time_now_monotonic_ms() -> i64:
    rt_time_now_micros() / 1000

pub fn rt_entropy_hardware_ready() -> i64:
    return 0

pub fn rt_platform_name() -> text:
    return "linux"

pub fn rt_term_enable_ansi() -> i64:
    return 1

pub fn rt_term_poll(timeout_ms: i64) -> i8:
    return 0

pub fn rt_term_read_timeout(max_len: i64, timeout_ms: i64) -> text:
    return ""

fn _process_result(exit_code: i64) -> i64:
    val result = rt_tuple_new(3)
    rt_tuple_set(result, 0, rt_string_new(0, 0))
    rt_tuple_set(result, 1, rt_string_new(0, 0))
    rt_tuple_set(result, 2, rt_value_int(exit_code))
    result

fn _process_run_inherit(cmd_ptr: i64, cmd_len: i64, args: i64) -> i64:
    if cmd_ptr < 1 or cmd_len < 1:
        return -1
    val command = malloc(cmd_len + 1)
    if command < 1:
        return -1
    var i = 0
    while i < cmd_len:
        spl_store_u8(command, i, spl_load_u8(cmd_ptr, i))
        i = i + 1
    spl_store_u8(command, cmd_len, 0)

    val argc = rt_array_len(args)
    val argv = calloc(argc + 2, 8)
    if argv < 1:
        free(command)
        return -1
    spl_store_i64(argv, 0, command)
    i = 0
    while i < argc:
        spl_store_i64(argv, (i + 1) * 8, rt_string_data(rt_array_get_text(args, i)))
        i = i + 1

    val status = calloc(1, 8)
    if status < 1:
        free(argv)
        free(command)
        return -1
    val pid = fork()
    if pid == 0:
        execvp(command, argv)
        exit(127)
        return 127
    if pid < 1:
        free(status)
        free(argv)
        free(command)
        return -1

    val waited = waitpid(pid, status, 0)
    val exit_code = if waited < 1: -1 else: (spl_load_i64(status, 0) >> 8) & 255
    free(status)
    free(argv)
    free(command)
    exit_code

pub fn rt_process_run_inherit(cmd_ptr: i64, cmd_len: i64, args: i64) -> i64:
    _process_run_inherit(cmd_ptr, cmd_len, args)

pub fn rt_process_run_inherit_value(cmd: i64, args: i64) -> i64:
    _process_run_inherit(rt_string_data(cmd), rt_string_len(cmd), args)

pub fn rt_process_run(cmd_ptr: i64, cmd_len: i64, args: i64) -> i64:
    # ponytail: stdout/stderr inherit the guest console; add pipe capture when
    # task-local descriptor inheritance is proven by the live process gate.
    _process_result(_process_run_inherit(cmd_ptr, cmd_len, args))

pub fn rt_sleep_ms(ms: i64) -> i64:
    usleep(ms * 1000)
    return 0

pub fn rt_thread_sleep(ms: i64):
    if ms > 0:
        usleep(ms * 1000)

pub fn spl_thread_cpu_count() -> i64:
    # Darwin exposes _SC_NPROCESSORS_ONLN as 58. Fail closed to one worker if
    # this bootstrap fallback is selected on a target with another value.
    val count = sysconf(58)
    if count > 0: count else: 1

pub fn rt_signal_check(signal_num: i64) -> i64:
    if signal_num <= 0:
        return 0
    val pending = calloc(1, 128)
    if pending < 1:
        return 0
    val queried = sigpending(pending)
    val present = if queried == 0: sigismember(pending, signal_num) else: 0
    free(pending)
    if present > 0: 1 else: 0

pub fn rt_atexit_check() -> i64:
    if rt_signal_check(2) > 0 or rt_signal_check(15) > 0: 1 else: 0

pub fn rt_process_spawn_async(cmd_ptr: i64, cmd_len: i64, args: i64) -> i64:
    if cmd_ptr < 1 or cmd_len < 1:
        return -1
    val command = malloc(cmd_len + 1)
    if command < 1:
        return -1
    var i = 0
    while i < cmd_len:
        spl_store_u8(command, i, spl_load_u8(cmd_ptr, i))
        i = i + 1
    spl_store_u8(command, cmd_len, 0)
    val argc = rt_array_len(args)
    val argv = calloc(argc + 2, 8)
    if argv < 1:
        free(command)
        return -1
    spl_store_i64(argv, 0, command)
    i = 0
    while i < argc:
        spl_store_i64(argv, (i + 1) * 8, rt_string_data(rt_array_get_text(args, i)))
        i = i + 1
    val pid = fork()
    if pid == 0:
        execvp(command, argv)
        exit(127)
        return -1
    free(argv)
    free(command)
    pid

fn _process_exit_code(status: i64) -> i64:
    if (status & 127) != 0: -1 else: (status >> 8) & 255

pub fn rt_process_wait(pid: i64, timeout_ms: i64) -> i64:
    if pid <= 0:
        return -1
    val status = calloc(1, 8)
    if status < 1:
        return -1
    if timeout_ms <= 0:
        val waited = waitpid(pid, status, 0)
        val code = if waited == pid: _process_exit_code(spl_load_i64(status, 0)) else: -1
        free(status)
        return code
    var elapsed = 0
    while elapsed < timeout_ms:
        val waited = waitpid(pid, status, 1)
        if waited == pid:
            val code = _process_exit_code(spl_load_i64(status, 0))
            free(status)
            return code
        if waited < 0:
            free(status)
            return -1
        usleep(10000)
        elapsed = elapsed + 10
    free(status)
    -2

pub fn rt_process_is_running(pid: i64) -> i8:
    if pid <= 0: 0 else: (if kill(pid, 0) == 0: 1 else: 0)

pub fn rt_process_kill(pid: i64) -> i8:
    if pid <= 0:
        return 0
    if kill(pid, 15) != 0:
        return 0
    usleep(100000)
    if kill(pid, 0) == 0:
        if kill(pid, 9) != 0:
            return 0
    val status = calloc(1, 8)
    if status > 0:
        waitpid(pid, status, 0)
        free(status)
    1

pub fn rt_panic(msg: i64) -> i64:
    rt_stderr_write(msg)
    abort()
    return 0

pub fn panic(msg: i64):
    rt_panic(msg)
