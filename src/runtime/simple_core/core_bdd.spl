# Pure-Simple BDD runtime subset used by native SPipe specs.

extern fn rt_stdout_write(value: i64) -> i64
extern fn rt_println_value(value: i64) -> i64
extern fn rt_raw_i64_to_string(value: i64) -> i64

var bdd_passed: i64 = 0
var bdd_failed: i64 = 0
var bdd_current_failed = false

pub fn rt_bdd_describe_start_rv(name: i64):
    rt_println_value(name)

pub fn rt_bdd_describe_end():
    rt_stdout_write(rt_raw_i64_to_string(bdd_passed + bdd_failed))
    rt_stdout_write(" examples, ")
    rt_stdout_write(rt_raw_i64_to_string(bdd_failed))
    rt_stdout_write(" failures\n")

pub fn rt_bdd_it_start_rv(name: i64):
    bdd_current_failed = false
    rt_stdout_write("  ")
    rt_stdout_write(name)

pub fn rt_bdd_it_end(passed: i64):
    if passed != 0 and not bdd_current_failed:
        bdd_passed = bdd_passed + 1
        rt_stdout_write(" pass\n")
    else:
        bdd_failed = bdd_failed + 1
        rt_stdout_write(" fail\n")

pub fn rt_bdd_expect_truthy_rv(value: i64):
    if value == 0 or value == 3 or value == 19:
        bdd_current_failed = true

pub fn rt_bdd_expect_truthy(value: i64):
    rt_bdd_expect_truthy_rv(value)

pub fn rt_bdd_format_results() -> i64:
    rt_bdd_describe_end()
    bdd_failed

pub fn rt_bdd_executed_count() -> i64:
    bdd_passed + bdd_failed

pub fn rt_bdd_clear_state():
    bdd_passed = 0
    bdd_failed = 0
    bdd_current_failed = false
