# Pure-Simple `simple-core` array operations — Tier 1 mechanical ops.
# Depends on core_array.spl (linked at archive level).

extern fn malloc(size: i64) -> i64
extern fn calloc(count: i64, size: i64) -> i64
extern fn realloc(ptr: i64, size: i64) -> i64
extern fn free(ptr: i64)
extern fn memcpy(dst: i64, src: i64, n: i64) -> i64
extern fn spl_load_i64(ptr: i64, offset: i64) -> i64
extern fn spl_store_i64(ptr: i64, offset: i64, value: i64)
extern fn spl_load_u8(ptr: i64, offset: i64) -> i64
extern fn spl_store_u8(ptr: i64, offset: i64, value: i64)

# Helpers from core_array.spl (archive-level linking)
extern fn array_ptr(array: i64) -> i64
extern fn array_items(array: i64) -> i64
extern fn array_len_value(array: i64) -> i64
extern fn array_cap(array: i64) -> i64
extern fn array_flags(array: i64) -> i64
extern fn array_is_valid(array: i64) -> i64
extern fn set_array_items(array: i64, items: i64)
extern fn set_array_len(array: i64, len: i64)
extern fn set_array_cap(array: i64, cap: i64)
extern fn numeric_index(value: i64) -> i64
extern fn normalize_index(array: i64, idx: i64) -> i64
extern fn rt_array_new(cap: i64) -> i64
extern fn rt_array_push(array: i64, value: i64) -> i8

# ============================================================================
# Value tag helpers
# ============================================================================

fn val_is_int(v: i64) -> i64:
    if (v & 7) < 1:
        return 1
    return 0

fn val_as_int(v: i64) -> i64:
    return v >> 3

fn val_is_falsy(v: i64) -> i64:
    # NIL (3) is falsy
    if v > 2 and v < 4:
        return 1
    # false (19) is falsy
    if v > 18 and v < 20:
        return 1
    # int 0 is falsy (tagged: 0 << 3 = 0)
    if v < 1 and v > -1:
        return 1
    return 0

fn val_from_int(i: i64) -> i64:
    return i << 3

fn typed_word_encode(array: i64, value: i64) -> i64:
    if (array_flags(array) & 16) != 0:
        return value
    return val_from_int(value)

fn typed_word_decode(array: i64, value: i64) -> i64:
    if (array_flags(array) & 16) != 0:
        return value
    return val_as_int(value)

# ============================================================================
# Tier 1: Mechanical, no extra dependencies
# ============================================================================

pub fn rt_array_clear(array: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    set_array_len(array, 0)
    return 1

pub fn rt_array_free(array: i64):
    if array_is_valid(array) < 1:
        return
    val items = array_items(array)
    if items > 0:
        free(items)
    free(array_ptr(array))

pub fn rt_array_new_with_cap(cap: i64) -> i64:
    return rt_array_new(cap)

pub fn rt_array_new_with_cap_u64(cap: i64) -> i64:
    # flags=16, elem_size=8 — re-implemented locally since array_new_with_flags is private
    var actual_cap = cap
    if actual_cap < 4:
        actual_cap = 4
    val array = calloc(1, 32)
    if array < 1:
        return 0
    val items = calloc(actual_cap, 8)
    if items < 1:
        return 0
    spl_store_u8(array, 0, 2)
    spl_store_u8(array, 1, 16)
    set_array_items(array, items)
    set_array_len(array, 0)
    set_array_cap(array, actual_cap)
    return array | 1

pub fn rt_array_new_with_cap_i64(cap: i64) -> i64:
    return rt_array_new(cap)

pub fn rt_array_new_with_cap_text(cap: i64) -> i64:
    return rt_array_new(cap)

pub fn rt_array_new_with_cap_bool(cap: i64) -> i64:
    return rt_array_new(cap)

pub fn rt_array_new_with_cap_js_value(cap: i64) -> i64:
    return rt_array_new(cap)

fn rt_array_repeat_new_uninit(cap: i64) -> i64:
    var actual_cap = cap
    if actual_cap < 4:
        actual_cap = 4
    val array = calloc(1, 32)
    if array < 1:
        return 0
    val items = malloc(actual_cap * 8)
    if items < 1:
        free(array)
        return 0
    spl_store_u8(array, 0, 2)
    spl_store_u8(array, 1, 0)
    set_array_items(array, items)
    set_array_len(array, 0)
    set_array_cap(array, actual_cap)
    return array | 1

pub fn rt_array_first(array: i64) -> i64:
    return rt_array_get_local(array, 0)

# Local inline version of rt_array_get to avoid extern call for first/last
fn rt_array_get_local(array: i64, idx: i64) -> i64:
    if array_is_valid(array) < 1:
        return 3
    val actual_idx = normalize_index(array, idx)
    if actual_idx < 0 or actual_idx >= array_len_value(array):
        return 3
    return spl_load_i64(array_items(array), actual_idx * 8)

pub fn rt_array_last(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 3
    val len = array_len_value(array)
    if len <= 0:
        return 3
    return spl_load_i64(array_items(array), (len - 1) * 8)

pub fn rt_array_copy(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val result = rt_array_new(len)
    if result < 1:
        return 0
    if len > 0:
        memcpy(array_items(result), array_items(array), len * 8)
        set_array_len(result, len)
    return result

pub fn rt_array_concat(a: i64, b: i64) -> i64:
    if array_is_valid(a) < 1 or array_is_valid(b) < 1:
        return 0
    val len_a = array_len_value(a)
    val len_b = array_len_value(b)
    val total = len_a + len_b
    val result = rt_array_new(total)
    if result < 1:
        return 0
    if len_a > 0:
        memcpy(array_items(result), array_items(a), len_a * 8)
    if len_b > 0:
        memcpy(array_items(result) + len_a * 8, array_items(b), len_b * 8)
    set_array_len(result, total)
    return result

pub fn rt_array_reverse(array: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val items = array_items(array)
    var lo = 0
    var hi = len - 1
    while lo < hi:
        val tmp = spl_load_i64(items, lo * 8)
        spl_store_i64(items, lo * 8, spl_load_i64(items, hi * 8))
        spl_store_i64(items, hi * 8, tmp)
        lo = lo + 1
        hi = hi - 1
    return 1

pub fn rt_array_reversed(array: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val result = rt_array_new(len)
    if result < 1:
        return 0
    val src = array_items(array)
    val dst = array_items(result)
    var i = 0
    while i < len:
        spl_store_i64(dst, i * 8, spl_load_i64(src, (len - 1 - i) * 8))
        i = i + 1
    set_array_len(result, len)
    return result

pub fn rt_array_take(array: i64, n: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    var take_n = n
    if take_n < 0:
        take_n = 0
    if take_n > len:
        take_n = len
    val result = rt_array_new(take_n)
    if result < 1:
        return 0
    if take_n > 0:
        memcpy(array_items(result), array_items(array), take_n * 8)
        set_array_len(result, take_n)
    return result

pub fn rt_array_drop(array: i64, n: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    var drop_count = n
    if drop_count < 0:
        drop_count = 0
    if drop_count > len:
        drop_count = len
    val result_len = len - drop_count
    val result = rt_array_new(result_len)
    if result < 1:
        return 0
    if result_len > 0:
        memcpy(array_items(result), array_items(array) + drop_count * 8, result_len * 8)
        set_array_len(result, result_len)
    return result

pub fn rt_array_fill(array: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val items = array_items(array)
    var i = 0
    while i < len:
        spl_store_i64(items, i * 8, value)
        i = i + 1
    return 1

pub fn rt_array_repeat(value: i64, count: i64) -> i64:
    if count <= 0:
        return rt_array_new(0)
    val result = rt_array_repeat_new_uninit(count)
    if result < 1:
        return 0
    val items = array_items(result)
    spl_store_i64(items, 0, value)
    var filled = 1
    while filled < count:
        var chunk = filled
        if chunk > count - filled:
            chunk = count - filled
        memcpy(items + filled * 8, items, chunk * 8)
        filled = filled + chunk
    set_array_len(result, count)
    return result

pub fn rt_array_range(start: i64, end: i64, step: i64) -> i64:
    if step < 1 and step > -1:
        return 3
    var count = 0
    if step > 0:
        if end > start:
            count = (end - start + step - 1) / step
    if step < 0:
        if start > end:
            count = (start - end + (0 - step) - 1) / (0 - step)
    val result = rt_array_new(count)
    if result < 1:
        return 0
    val items = array_items(result)
    var cur = start
    var idx = 0
    while idx < count:
        spl_store_i64(items, idx * 8, val_from_int(cur))
        cur = cur + step
        idx = idx + 1
    set_array_len(result, count)
    return result

pub fn rt_range(start: i64, end: i64) -> i64:
    rt_array_range(start, end, 1)

pub fn rt_array_push_grow(array: i64, value: i64) -> i8:
    return rt_array_push(array, value)

pub fn rt_array_push_no_grow(array: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    val cap = array_cap(array)
    if len >= cap:
        return 0
    spl_store_i64(array_items(array), len * 8, value)
    set_array_len(array, len + 1)
    return 1

fn byte_array_reserve(array: i64, needed: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    var cap = array_cap(array)
    if needed <= cap:
        return 1
    var new_cap = cap * 2
    if new_cap < 4:
        new_cap = 4
    while new_cap < needed:
        new_cap = new_cap * 2
    val new_items = realloc(array_items(array), new_cap)
    if new_items < 1:
        set_array_len(array, 0)
        set_array_cap(array, 0)
        return 0
    set_array_items(array, new_items)
    set_array_cap(array, new_cap)
    return 1

pub fn rt_bytes_u32_le_at(array: i64, idx: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = normalize_index(array, idx)
    if actual_idx < 0 or actual_idx + 4 > array_len_value(array):
        return 0
    val items = array_items(array)
    return (spl_load_u8(items, actual_idx) & 255) |
        ((spl_load_u8(items, actual_idx + 1) & 255) << 8) |
        ((spl_load_u8(items, actual_idx + 2) & 255) << 16) |
        ((spl_load_u8(items, actual_idx + 3) & 255) << 24)

pub fn rt_bytes_u64_le_at(array: i64, idx: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = normalize_index(array, idx)
    if actual_idx < 0 or actual_idx + 8 > array_len_value(array):
        return 0
    val items = array_items(array)
    var out = 0
    var shift = 0
    while shift < 8:
        out = out | ((spl_load_u8(items, actual_idx + shift) & 255) << (shift * 8))
        shift = shift + 1
    return out

pub fn rt_typed_bytes_u8_push(array: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val len = array_len_value(array)
    if byte_array_reserve(array, len + 1) < 1:
        return 0
    spl_store_u8(array_items(array), len, value & 255)
    set_array_len(array, len + 1)
    return 1

pub fn rt_typed_words_u32_at(array: i64, idx: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = if idx < 0: array_len_value(array) + idx else: idx
    if actual_idx < 0 or actual_idx >= array_len_value(array):
        return 0
    return typed_word_decode(array, spl_load_i64(array_items(array), actual_idx * 8)) & 0xffffffff

pub fn rt_typed_words_u32_unchecked(array: i64, idx: i64) -> i64:
    return typed_word_decode(array, spl_load_i64(array_items(array), idx * 8)) & 0xffffffff

pub fn rt_typed_words_u32_data_at(items: i64, idx: i64) -> i64:
    return val_as_int(spl_load_i64(items, idx * 8)) & 0xffffffff

pub fn rt_typed_words_u32_push(array: i64, value: i64) -> i8:
    return rt_array_push(array, typed_word_encode(array, value & 0xffffffff))

pub fn rt_typed_words_u32_push_known_at(array: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = idx
    if actual_idx < 0 or actual_idx >= array_cap(array):
        return 0
    spl_store_i64(array_items(array), actual_idx * 8, typed_word_encode(array, value & 0xffffffff))
    if actual_idx >= array_len_value(array):
        set_array_len(array, actual_idx + 1)
    return 1

pub fn rt_typed_words_u32_push_known_data_at(array: i64, items: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = idx
    if actual_idx < 0 or actual_idx >= array_cap(array):
        return 0
    spl_store_i64(items, actual_idx * 8, typed_word_encode(array, value & 0xffffffff))
    if actual_idx >= array_len_value(array):
        set_array_len(array, actual_idx + 1)
    return 1

# Runtime-local one-call construction for Metal/Processing readback. Returning
# an array created by a different hosted runtime registry makes rt_array_len
# observe zero when simple-core owns the executable's array ABI. Keep the
# external GPU boundary pointer-only and construct the [u32] in this owner.
pub fn rt_u32s_from_raw(data_ptr: i64, count: i64) -> i64:
    if data_ptr <= 0 or count <= 0:
        return rt_array_new_with_cap_u64(0)
    val result = rt_array_new_with_cap_u64(count)
    if array_is_valid(result) < 1:
        return result
    var i = 0
    while i < count:
        val offset = i * 4
        val byte0 = spl_load_u8(data_ptr, offset)
        val byte1 = spl_load_u8(data_ptr, offset + 1)
        val byte2 = spl_load_u8(data_ptr, offset + 2)
        val byte3 = spl_load_u8(data_ptr, offset + 3)
        val word = byte0 | (byte1 << 8) | (byte2 << 16) | (byte3 << 24)
        if rt_typed_words_u32_push_known_at(result, i, word) < 1:
            rt_array_free(result)
            return rt_array_new_with_cap_u64(0)
        i = i + 1
    result

pub fn rt_typed_words_u32_store_known_data_at(array: i64, items: i64, idx: i64, value: i64) -> i8:
    return rt_typed_words_u32_push_known_data_at(array, items, idx, value)

pub fn rt_typed_words_u32_set(array: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = if idx < 0: array_len_value(array) + idx else: idx
    if actual_idx < 0 or actual_idx >= array_len_value(array):
        return 0
    spl_store_i64(array_items(array), actual_idx * 8, typed_word_encode(array, value & 0xffffffff))
    return 1

pub fn rt_typed_words_u64_at(array: i64, idx: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = if idx < 0: array_len_value(array) + idx else: idx
    if actual_idx < 0 or actual_idx >= array_len_value(array):
        return 0
    return typed_word_decode(array, spl_load_i64(array_items(array), actual_idx * 8))

pub fn rt_typed_words_u64_unchecked(array: i64, idx: i64) -> i64:
    return typed_word_decode(array, spl_load_i64(array_items(array), idx * 8))

pub fn rt_typed_words_u64_data_at(items: i64, idx: i64) -> i64:
    return val_as_int(spl_load_i64(items, idx * 8))

pub fn rt_typed_words_u64_data_at_checked(array: i64, items: i64, idx: i64) -> i64:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = if idx < 0: array_len_value(array) + idx else: idx
    if actual_idx < 0 or actual_idx >= array_len_value(array):
        return 0
    return typed_word_decode(array, spl_load_i64(items, actual_idx * 8))

pub fn rt_typed_words_u64_raw_data_at(items: i64, idx: i64) -> i64:
    return spl_load_i64(items, idx * 8)

pub fn rt_numeric_xor_sum_u64_data(items: i64, length: i64, xor_value: i64) -> i64:
    if length < 0:
        return 0
    var sum: i64 = 0
    var idx: i64 = 0
    var cursor = items
    while idx + 15 < length:
        sum = sum + (spl_load_i64(cursor, 0) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 8) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 16) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 24) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 32) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 40) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 48) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 56) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 64) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 72) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 80) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 88) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 96) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 104) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 112) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 120) ^ xor_value)
        idx = idx + 16
        cursor = cursor + 128
    while idx < length:
        sum = sum + (spl_load_i64(cursor, 0) ^ xor_value)
        idx = idx + 1
        cursor = cursor + 8
    return sum

pub fn rt_numeric_xor_sum_u64_repeated_data(items: i64, length: i64, iters: i64) -> i64:
    if length < 0 or iters < 0:
        return 0
    var present_bits: i64 = 0
    var present_idx: i64 = 0
    var present_cursor = items
    while present_idx < length:
        present_bits = present_bits | spl_load_i64(present_cursor, 0)
        present_idx = present_idx + 1
        present_cursor = present_cursor + 8

    var total: i64 = 0
    var bit: i64 = 0
    var bit_value: i64 = 1
    while bit < 63:
        var ones: i64 = 0
        if (present_bits & bit_value) != 0:
            var idx: i64 = 0
            var cursor = items
            while idx < length:
                if (spl_load_i64(cursor, 0) & bit_value) != 0:
                    ones = ones + 1
                idx = idx + 1
                cursor = cursor + 8

        var iter_ones: i64 = 0
        if bit_value <= iters:
            val cycle = bit_value << 1
            val full_cycles = iters / cycle
            val remainder = iters - full_cycles * cycle
            iter_ones = full_cycles * bit_value
            if remainder > bit_value:
                iter_ones = iter_ones + (remainder - bit_value)

        val iter_zeros = iters - iter_ones
        val data_zeros = length - ones
        total = total + (ones * iter_zeros + data_zeros * iter_ones) * bit_value
        bit = bit + 1
        bit_value = bit_value << 1
    if (present_bits & bit_value) != 0:
        var sign_ones: i64 = 0
        var sign_idx: i64 = 0
        var sign_cursor = items
        while sign_idx < length:
            if (spl_load_i64(sign_cursor, 0) & bit_value) != 0:
                sign_ones = sign_ones + 1
            sign_idx = sign_idx + 1
            sign_cursor = sign_cursor + 8
        total = total + sign_ones * iters * bit_value
    return total

pub fn rt_numeric_xor_sum_u64(array: i64, xor_value: i64) -> i64:
    if array < 4096:
        return 0
    val ptr = array_ptr(array)
    if (ptr & 7) > 0:
        return 0
    if spl_load_u8(ptr, 0) != 2:
        return 0
    val length = spl_load_i64(ptr, 8)
    if length < 0:
        return 0
    val items = spl_load_i64(ptr, 24)
    var sum: i64 = 0
    var idx: i64 = 0
    var cursor = items
    while idx + 15 < length:
        sum = sum + (spl_load_i64(cursor, 0) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 8) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 16) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 24) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 32) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 40) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 48) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 56) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 64) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 72) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 80) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 88) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 96) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 104) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 112) ^ xor_value)
        sum = sum + (spl_load_i64(cursor, 120) ^ xor_value)
        idx = idx + 16
        cursor = cursor + 128
    while idx < length:
        sum = sum + (spl_load_i64(cursor, 0) ^ xor_value)
        idx = idx + 1
        cursor = cursor + 8
    sum << 3

pub fn rt_numeric_contains_u64(array: i64, value: i64) -> i8:
    if array < 4096:
        return 0
    val ptr = array_ptr(array)
    if (ptr & 7) > 0:
        return 0
    if spl_load_u8(ptr, 0) != 2:
        return 0
    val length = spl_load_i64(ptr, 8)
    if length < 0:
        return 0
    val items = spl_load_i64(ptr, 24)
    var idx: i64 = 0
    var cursor = items
    var found: i8 = 0
    while idx + 7 < length:
        val item0 = spl_load_i64(cursor, 0)
        if item0 == value:
            found = 1
            break
        val item1 = spl_load_i64(cursor, 8)
        if item1 == value:
            found = 1
            break
        val item2 = spl_load_i64(cursor, 16)
        if item2 == value:
            found = 1
            break
        val item3 = spl_load_i64(cursor, 24)
        if item3 == value:
            found = 1
            break
        val item4 = spl_load_i64(cursor, 32)
        if item4 == value:
            found = 1
            break
        val item5 = spl_load_i64(cursor, 40)
        if item5 == value:
            found = 1
            break
        val item6 = spl_load_i64(cursor, 48)
        if item6 == value:
            found = 1
            break
        val item7 = spl_load_i64(cursor, 56)
        if item7 == value:
            found = 1
            break
        idx = idx + 8
        cursor = cursor + 64
    while found == 0 and idx < length:
        val item = spl_load_i64(cursor, 0)
        if item == value:
            found = 1
            break
        idx = idx + 1
        cursor = cursor + 8
    return found

pub fn rt_typed_words_u64_push(array: i64, value: i64) -> i8:
    return rt_array_push(array, typed_word_encode(array, value))

pub fn rt_typed_words_u64_push_known_at(array: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = idx
    if actual_idx < 0 or actual_idx >= array_cap(array):
        return 0
    spl_store_i64(array_items(array), actual_idx * 8, typed_word_encode(array, value))
    if actual_idx >= array_len_value(array):
        set_array_len(array, actual_idx + 1)
    return 1

pub fn rt_typed_words_u64_push_known_data_at(array: i64, items: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = idx
    if actual_idx < 0 or actual_idx >= array_cap(array):
        return 0
    spl_store_i64(items, actual_idx * 8, typed_word_encode(array, value))
    if actual_idx >= array_len_value(array):
        set_array_len(array, actual_idx + 1)
    return 1

pub fn rt_typed_words_u64_store_known_data_at(array: i64, items: i64, idx: i64, value: i64) -> i8:
    return rt_typed_words_u64_push_known_data_at(array, items, idx, value)

pub fn rt_typed_words_u64_set(array: i64, idx: i64, value: i64) -> i8:
    if array_is_valid(array) < 1:
        return 0
    val actual_idx = if idx < 0: array_len_value(array) + idx else: idx
    if actual_idx < 0 or actual_idx >= array_len_value(array):
        return 0
    spl_store_i64(array_items(array), actual_idx * 8, typed_word_encode(array, value))
    return 1

pub fn rt_array_extend_i64(dst: i64, src: i64, count: i64) -> i8:
    if count <= 0:
        return 1
    if array_is_valid(dst) < 1 or array_is_valid(src) < 1:
        return 0
    val src_len = array_len_value(src)
    if count > src_len:
        return 0
    val dst_len = array_len_value(dst)
    val needed = dst_len + count
    var dst_cap = array_cap(dst)
    if needed > dst_cap:
        var new_cap = dst_cap * 2
        if new_cap < needed:
            new_cap = needed
        if new_cap < 4:
            new_cap = 4
        val new_items = realloc(array_items(dst), new_cap * 8)
        if new_items < 1:
            return 0
        set_array_items(dst, new_items)
        set_array_cap(dst, new_cap)
    memcpy(array_items(dst) + dst_len * 8, array_items(src), count * 8)
    set_array_len(dst, dst_len + count)
    return 1
