# Pure-Simple `simple-core` memory ABI wrappers.
#
# These are the first explicit host-primitive boundary for `simple-core`: the
# Simple runtime archive owns the required `rt_*` symbols and delegates raw
# allocation/memory operations to the platform C ABI.

extern fn malloc(size: i64) -> i64
extern fn free(ptr: i64)
extern fn realloc(ptr: i64, size: i64) -> i64
extern fn memcpy(dst: i64, src: i64, n: i64) -> i64
extern fn memset(dst: i64, value: i64, n: i64) -> i64
extern fn spl_load_i64(ptr: i64, offset: i64) -> i64
extern fn spl_store_i64(ptr: i64, offset: i64, value: i64)
extern fn spl_store_u8(ptr: i64, offset: i64, value: i64)

pub fn rt_alloc(size: i64) -> i64:
    return malloc(size)

pub fn rt_realloc(ptr: i64, size: i64) -> i64:
    return realloc(ptr, size)

pub fn rt_free(ptr: i64) -> i64:
    free(ptr)
    return 0

pub fn rt_memcpy(dst: i64, src: i64, n: i64) -> i64:
    return memcpy(dst, src, n)

# Core-library primitive. Callers pass a byte count; generic collections must
# scale their element count before crossing this ABI boundary.
pub fn copy_mem(dst: i64, src: i64, n: i64) -> i64:
    return rt_memcpy(dst, src, n)

pub fn rt_memset(dst: i64, value: i64, n: i64) -> i64:
    return memset(dst, value, n)

pub fn rt_ptr_read_i64(addr: i64, offset: i64) -> i64:
    spl_load_i64(addr, offset)

pub fn rt_ptr_write_i64(addr: i64, offset: i64, value: i64) -> i64:
    spl_store_i64(addr, offset, value)
    return 0

pub fn rt_ptr_write_i32(addr: i64, offset: i64, value: i64) -> i64:
    spl_store_i64(addr, offset, value)
    return 0

pub fn rt_ptr_write_u8(addr: i64, offset: i64, value: i64) -> i64:
    spl_store_u8(addr, offset, value)
    return 0

pub fn rt_function_not_found(name: i64, len: i64) -> i64:
    return 3

pub fn rt_interp_call(name: i64, len: i64, argc: i64, argv: i64) -> i64:
    return rt_function_not_found(name, len)
