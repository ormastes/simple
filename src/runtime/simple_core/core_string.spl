# Pure-Simple `simple-core` string and string-backed stdio ABI.

extern fn malloc(size: i64) -> i64
extern fn realloc(ptr: i64, size: i64) -> i64
extern fn free(ptr: i64)
extern fn memcpy(dst: i64, src: i64, n: i64) -> i64
extern fn memcmp(left: i64, right: i64, n: i64) -> i64
extern fn strtoll(ptr: i64, endptr: i64, base: i64) -> i64
extern fn strtod(ptr: i64, endptr: i64) -> f64
extern fn spl_f64_to_bits(value: f64) -> i64
extern fn write(fd: i64, ptr: i64, count: i64) -> i64
extern fn read(fd: i64, ptr: i64, count: i64) -> i64
extern fn spl_load_i64(ptr: i64, offset: i64) -> i64
extern fn spl_store_i64(ptr: i64, offset: i64, value: i64)
extern fn spl_load_u8(ptr: i64, offset: i64) -> i64
extern fn spl_store_u8(ptr: i64, offset: i64, value: i64)
extern fn rt_array_len(array: i64) -> i64
extern fn rt_array_len_safe(array: i64) -> i64
extern fn rt_array_new(cap: i64) -> i64
extern fn rt_array_new_with_cap_u64(cap: i64) -> i64
extern fn rt_byte_array_new(cap: i64) -> i64
extern fn rt_array_push(array: i64, value: i64) -> i8
extern fn rt_array_get(array: i64, idx: i64) -> i64
extern fn array_is_valid(array: i64) -> i64
extern fn rt_dict_len(dict: i64) -> i64
extern fn rt_dict_contains(dict: i64, key: i64) -> i8
extern fn rt_value_int(value: i64) -> i64
extern fn rt_value_as_int(value: i64) -> i64
extern fn rt_value_float(raw_bits: i64) -> i64
extern fn rt_enum_new(enum_id: i32, discriminant: i32, payload: i64) -> i64

fn string_ptr(value: i64) -> i64:
    if (value & 7) < 1 or (value & 7) > 1:
        return 0
    val ptr = value & -8
    if ptr < 1:
        return 0
    val kind = spl_load_i64(ptr, 0) & 4294967295
    if kind < 1398034993 or kind > 1398034993:
        return 0
    return ptr

fn string_data_ptr_value(ptr: i64) -> i64:
    return ptr + 16

fn string_len_ptr(ptr: i64) -> i64:
    return spl_load_i64(ptr, 8)

fn write_string_to_fd(fd: i64, value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return 0
    val len = string_len_ptr(ptr)
    if len < 1:
        return 0
    return write(fd, string_data_ptr_value(ptr), len)

fn is_space_byte(ch: i64) -> i64:
    if ch > 31 and ch < 33:
        return 1
    if ch > 8 and ch < 14:
        return 1
    return 0

fn alloc_string(len: i64) -> i64:
    val ptr = malloc(17 + len)
    if ptr < 1:
        return 3
    spl_store_i64(ptr, 0, 1398034993)
    spl_store_i64(ptr, 8, len)
    spl_store_u8(ptr, 16 + len, 0)
    return ptr | 1

pub fn rt_string_new(bytes: i64, len: i64) -> i64:
    if bytes < 1 and len > 0:
        return 3
    val out = alloc_string(len)
    val ptr = string_ptr(out)
    if ptr < 1:
        return 3
    if len > 0:
        memcpy(ptr + 16, bytes, len)
    return out

pub fn rt_string_len(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return -1
    return string_len_ptr(ptr)

pub fn rt_string_data(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return 0
    return string_data_ptr_value(ptr)

# Raw builder handle layout: len @0, cap @8, byte buffer @16.
pub fn rt_string_builder_new() -> i64:
    val handle = malloc(24)
    if handle < 1:
        return 0
    val data = malloc(64)
    if data < 1:
        free(handle)
        return 0
    spl_store_i64(handle, 0, 0)
    spl_store_i64(handle, 8, 64)
    spl_store_i64(handle, 16, data)
    handle

pub fn rt_string_builder_push(handle: i64, value: i64) -> i64:
    if handle < 4096:
        return 0
    val src = rt_string_data(value)
    val add_len = rt_string_len(value)
    if src < 1 or add_len < 0:
        return 0
    val len = spl_load_i64(handle, 0)
    var cap = spl_load_i64(handle, 8)
    var data = spl_load_i64(handle, 16)
    val needed = len + add_len
    if len < 0 or cap < 1 or data < 1 or needed < len:
        return 0
    if needed > cap:
        var new_cap = cap * 2
        while new_cap < needed:
            new_cap = new_cap * 2
        val grown = realloc(data, new_cap)
        if grown < 1:
            return 0
        data = grown
        cap = new_cap
        spl_store_i64(handle, 8, cap)
        spl_store_i64(handle, 16, data)
    if add_len > 0:
        memcpy(data + len, src, add_len)
    spl_store_i64(handle, 0, needed)
    1

pub fn rt_string_builder_finish(handle: i64) -> i64:
    if handle < 4096:
        return 3
    val len = spl_load_i64(handle, 0)
    val data = spl_load_i64(handle, 16)
    if len < 0 or data < 1:
        return 3
    val out = rt_string_new(data, len)
    free(data)
    free(handle)
    out

pub fn rt_string_builder_len(handle: i64) -> i64:
    if handle < 4096:
        return -1
    spl_load_i64(handle, 0)

pub fn rt_string_builder_free(handle: i64):
    if handle < 4096:
        return
    val data = spl_load_i64(handle, 16)
    if data > 0:
        free(data)
    free(handle)

pub fn rt_string_bytes(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return rt_array_new(0)
    val len = string_len_ptr(ptr)
    val out = rt_array_new(len)
    var i = 0
    while i < len:
        rt_array_push(out, rt_value_int(spl_load_u8(string_data_ptr_value(ptr), i) & 255))
        i = i + 1
    return out

pub fn rt_string_chars(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return rt_array_new(0)
    val data = string_data_ptr_value(ptr)
    val len = string_len_ptr(ptr)
    val out = rt_array_new(len)
    var byte_index = 0
    while byte_index < len:
        val b0 = spl_load_u8(data, byte_index) & 255
        var width = 1
        if b0 >= 194 and b0 <= 223 and byte_index + 1 < len:
            width = 2
        elif b0 >= 224 and b0 <= 239 and byte_index + 2 < len:
            width = 3
        elif b0 >= 240 and b0 <= 244 and byte_index + 3 < len:
            width = 4
        rt_array_push(out, rt_string_new(data + byte_index, width))
        byte_index = byte_index + width
    return out

pub fn rt_string_char_code_at(value: i64, index: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1 or index < 0:
        return 0
    val data = string_data_ptr_value(ptr)
    val len = string_len_ptr(ptr)
    var byte_index = 0
    var char_index = 0
    while byte_index < len:
        val b0 = spl_load_u8(data, byte_index) & 255
        var width = 1
        var code = b0
        if b0 >= 194 and b0 <= 223 and byte_index + 1 < len:
            width = 2
            code = ((b0 & 31) << 6) | (spl_load_u8(data, byte_index + 1) & 63)
        elif b0 >= 224 and b0 <= 239 and byte_index + 2 < len:
            width = 3
            code = ((b0 & 15) << 12) | ((spl_load_u8(data, byte_index + 1) & 63) << 6) | (spl_load_u8(data, byte_index + 2) & 63)
        elif b0 >= 240 and b0 <= 244 and byte_index + 3 < len:
            width = 4
            code = ((b0 & 7) << 18) | ((spl_load_u8(data, byte_index + 1) & 63) << 12) | ((spl_load_u8(data, byte_index + 2) & 63) << 6) | (spl_load_u8(data, byte_index + 3) & 63)
        if char_index == index:
            return code
        byte_index = byte_index + width
        char_index = char_index + 1
    return 0

pub fn text_dot_from_char_code(code: i64) -> i64:
    if code < 0 or code > 1114111 or (code >= 55296 and code <= 57343):
        return 3
    val data = malloc(4)
    if data < 1:
        return 3
    var len = 1
    if code <= 127:
        spl_store_u8(data, 0, code)
    elif code <= 2047:
        len = 2
        spl_store_u8(data, 0, 192 | (code >> 6))
        spl_store_u8(data, 1, 128 | (code & 63))
    elif code <= 65535:
        len = 3
        spl_store_u8(data, 0, 224 | (code >> 12))
        spl_store_u8(data, 1, 128 | ((code >> 6) & 63))
        spl_store_u8(data, 2, 128 | (code & 63))
    else:
        len = 4
        spl_store_u8(data, 0, 240 | (code >> 18))
        spl_store_u8(data, 1, 128 | ((code >> 12) & 63))
        spl_store_u8(data, 2, 128 | ((code >> 6) & 63))
        spl_store_u8(data, 3, 128 | (code & 63))
    val out = rt_string_new(data, len)
    free(data)
    out

pub fn rt_any_add(left: i64, right: i64) -> i64:
    if (left & 7) == 1 or (right & 7) == 1:
        return rt_string_concat(rt_to_string(left), rt_to_string(right))
    return rt_value_int(rt_value_as_int(left) + rt_value_as_int(right))

pub fn rt_str_hash(value: i64) -> i64:
    if (value & 7) < 1 or (value & 7) > 1:
        return 0
    val ptr = value & -8
    if ptr < 1:
        return 0
    val kind = spl_load_i64(ptr, 0) & 4294967295
    if kind < 1398034993 or kind > 1398034993:
        return 0
    val len = spl_load_i64(ptr, 8)
    val data = ptr + 16
    var h = 5381
    var i = 0
    while i + 3 < len:
        h = h * 1185921 +
            ((spl_load_u8(data, i) & 255) * 35937) +
            ((spl_load_u8(data, i + 1) & 255) * 1089) +
            ((spl_load_u8(data, i + 2) & 255) * 33) +
            (spl_load_u8(data, i + 3) & 255)
        i = i + 4
    while i < len:
        h = (h << 5) + h + (spl_load_u8(data, i) & 255)
        i = i + 1
    return h

pub fn rt_hash_text(value: i64) -> i64:
    if (value & 7) < 1 or (value & 7) > 1:
        return 0
    val ptr = value & -8
    if ptr < 1:
        return 0
    val kind = spl_load_i64(ptr, 0) & 4294967295
    if kind < 1398034993 or kind > 1398034993:
        return 0
    val len = spl_load_i64(ptr, 8)
    val data = ptr + 16
    var h = 5381
    var i = 0
    while i + 3 < len:
        h = h * 1185921 +
            ((spl_load_u8(data, i) & 255) * 35937) +
            ((spl_load_u8(data, i + 1) & 255) * 1089) +
            ((spl_load_u8(data, i + 2) & 255) * 33) +
            (spl_load_u8(data, i + 3) & 255)
        i = i + 4
    while i < len:
        h = (h << 5) + h + (spl_load_u8(data, i) & 255)
        i = i + 1
    return h

pub fn rt_string_concat(left: i64, right: i64) -> i64:
    val left_ptr = string_ptr(left)
    val right_ptr = string_ptr(right)
    if left_ptr < 1 or right_ptr < 1:
        return 3
    val left_len = string_len_ptr(left_ptr)
    val right_len = string_len_ptr(right_ptr)
    val out_len = left_len + right_len
    val out = alloc_string(out_len)
    val out_ptr = string_ptr(out)
    if out_ptr < 1:
        return 3
    if left_len > 0:
        memcpy(string_data_ptr_value(out_ptr), string_data_ptr_value(left_ptr), left_len)
    if right_len > 0:
        memcpy(string_data_ptr_value(out_ptr) + left_len, string_data_ptr_value(right_ptr), right_len)
    return out

# Concat-drop fix: pure-Simple mirror of the native rt_strcat_tagged
# (runtime_native.c). The native side has to normalize a "raw-char*-or-tagged"
# operand duality that only exists on the LLVM native path (string-literal
# globals lower to untagged char*); the interpreter always represents strings
# as tagged RtCoreString handles, so this is exactly rt_string_concat -- kept
# as a distinct named entry point so callers don't need to know which path
# they're on.
pub fn rt_strcat_tagged(left: i64, right: i64) -> i64:
    return rt_string_concat(left, right)

pub fn rt_len(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr > 0:
        return string_len_ptr(ptr)
    if (value & 7) == 1 and value > 4095:
        val kind = spl_load_u8(value & -8, 0)
        if kind == 2:
            return rt_array_len(value)
        if kind == 6:
            return rt_dict_len(value)
    return 0

pub fn rt_native_eq(left: i64, right: i64) -> i64:
    val left_text_tag = left >= 4096 and (left & 7) == 1
    val right_text_tag = right >= 4096 and (right & 7) == 1
    if left_text_tag or right_text_tag:
        if not left_text_tag or not right_text_tag:
            return 0
        val left_ptr = left & -8
        val right_ptr = right & -8
        if left_ptr < 1 or right_ptr < 1:
            return 0
        if left_ptr == right_ptr:
            return 1
        val left_kind = spl_load_i64(left_ptr, 0) & 4294967295
        val right_kind = spl_load_i64(right_ptr, 0) & 4294967295
        if left_kind < 1398034993 or left_kind > 1398034993:
            return 0
        if right_kind < 1398034993 or right_kind > 1398034993:
            return 0
        val len = spl_load_i64(left_ptr, 8)
        if len != spl_load_i64(right_ptr, 8):
            return 0
        if len < 1:
            return 1
        val cmp = memcmp(left_ptr + 16, right_ptr + 16, len)
        if cmp < 0 or cmp > 0:
            return 0
        return 1
    if left < right or left > right:
        return 0
    return 1

pub fn rt_native_neq(left: i64, right: i64) -> i64:
    val eq = rt_native_eq(left, right)
    if eq < 1:
        return 1
    return 0

pub fn rt_contains(collection: i64, value: i64) -> i8:
    val text_ptr = string_ptr(collection)
    val needle_ptr = string_ptr(value)
    if text_ptr > 0 and needle_ptr > 0:
        val idx = rt_string_find(collection, value)
        if idx >= 0:
            return 1
        return 0
    if (collection & 7) == 1 and collection > 4095:
        val kind = spl_load_u8(collection & -8, 0)
        if kind == 6:
            return rt_dict_contains(collection, value)
        if kind == 2:
            val len = rt_array_len(collection)
            var i = 0
            while i < len:
                if rt_native_eq(rt_array_get(collection, i), value) > 0:
                    return 1
                i = i + 1
    return 0

pub fn rt_slice(value: i64, start: i64, end: i64, step: i64) -> i64:
    if step == 0:
        return 3
    val ptr = string_ptr(value)
    if ptr < 1:
        if array_is_valid(value) < 1:
            return 3
        val array_ptr = value & -8
        val array_len = rt_array_len_safe(value)
        var array_begin = if start < 0: array_len + start else: start
        var array_finish = if end < 0: array_len + end else: end
        if array_begin < 0:
            array_begin = 0
        if array_begin > array_len:
            array_begin = array_len
        if array_finish < 0:
            array_finish = 0
        if array_finish > array_len:
            array_finish = array_len
        var count = 0
        var count_i = array_begin
        while (step > 0 and count_i < array_finish) or (step < 0 and count_i > array_finish):
            count = count + 1
            count_i = count_i + step
        val flags = spl_load_u8(array_ptr, 1)
        val out = if (flags & 8) > 0: rt_byte_array_new(count) elif (flags & 16) > 0: rt_array_new_with_cap_u64(count) else: rt_array_new(count)
        if out < 4096:
            return 3
        val source_items = spl_load_i64(array_ptr, 24)
        val out_ptr = out & -8
        val out_items = spl_load_i64(out_ptr, 24)
        var out_i = 0
        var array_i = array_begin
        while (step > 0 and array_i < array_finish) or (step < 0 and array_i > array_finish):
            if (flags & 8) > 0:
                spl_store_u8(out_items, out_i, spl_load_u8(source_items, array_i))
            else:
                spl_store_i64(out_items, out_i * 8, spl_load_i64(source_items, array_i * 8))
            out_i = out_i + 1
            array_i = array_i + step
        spl_store_i64(out_ptr, 8, out_i)
        return out
    val len = string_len_ptr(ptr)
    var begin = start
    var finish = end
    var stride = step
    if stride < 1:
        stride = 1
    if begin < 0:
        begin = len + begin
    if finish < 0:
        finish = len + finish
    if begin < 0:
        begin = 0
    if finish < begin:
        finish = begin
    if begin > len:
        begin = len
    if finish > len:
        finish = len
    if stride > 1:
        var out_len = 0
        var i = begin
        while i < finish:
            out_len = out_len + 1
            i = i + stride
        val out = alloc_string(out_len)
        val out_ptr = string_ptr(out)
        if out_ptr < 1:
            return 3
        var out_i = 0
        i = begin
        while i < finish:
            spl_store_u8(string_data_ptr_value(out_ptr), out_i, spl_load_u8(string_data_ptr_value(ptr), i))
            out_i = out_i + 1
            i = i + stride
        return out
    return rt_string_new(string_data_ptr_value(ptr) + begin, finish - begin)

pub fn rt_string_starts_with(value: i64, prefix: i64) -> i64:
    val ptr = string_ptr(value)
    val prefix_ptr = string_ptr(prefix)
    if ptr < 1 or prefix_ptr < 1:
        return 0
    val prefix_len = string_len_ptr(prefix_ptr)
    if prefix_len > string_len_ptr(ptr):
        return 0
    if prefix_len < 1:
        return 1
    val cmp = memcmp(string_data_ptr_value(ptr), string_data_ptr_value(prefix_ptr), prefix_len)
    if cmp < 0 or cmp > 0:
        return 0
    return 1

pub fn rt_string_ends_with(value: i64, suffix: i64) -> i64:
    val ptr = string_ptr(value)
    val suffix_ptr = string_ptr(suffix)
    if ptr < 1 or suffix_ptr < 1:
        return 0
    val len = string_len_ptr(ptr)
    val suffix_len = string_len_ptr(suffix_ptr)
    if suffix_len > len:
        return 0
    if suffix_len < 1:
        return 1
    val cmp = memcmp(string_data_ptr_value(ptr) + len - suffix_len, string_data_ptr_value(suffix_ptr), suffix_len)
    if cmp < 0 or cmp > 0:
        return 0
    return 1

pub fn rt_string_trim(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return value
    var begin = 0
    var finish = string_len_ptr(ptr)
    while begin < finish and is_space_byte(spl_load_u8(string_data_ptr_value(ptr), begin)) > 0:
        begin = begin + 1
    while finish > begin and is_space_byte(spl_load_u8(string_data_ptr_value(ptr), finish - 1)) > 0:
        finish = finish - 1
    return rt_string_new(string_data_ptr_value(ptr) + begin, finish - begin)

pub fn rt_string_trim_end(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return value
    var finish = string_len_ptr(ptr)
    while finish > 0 and is_space_byte(spl_load_u8(string_data_ptr_value(ptr), finish - 1)) > 0:
        finish = finish - 1
    return rt_string_new(string_data_ptr_value(ptr), finish)

pub fn rt_string_to_int(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return 0
    return strtoll(string_data_ptr_value(ptr), 0, 10)

# Task #118: sibling of rt_string_to_int() with the canonical `int(text)`
# semantics — a total, leading-numeric-prefix parse. strtoll() already IS
# this (skips whitespace/sign, parses leading digits, stops at the first
# non-digit, returns 0 if none), so this is byte-for-byte identical to
# rt_string_to_int() above. Named distinctly so the Rust-native
# `simple-runtime` crate's stricter, whole-string-match rt_string_to_int()
# (used by .to_int()/.parse_int()/to_i64() there) stays unaffected.
pub fn rt_string_to_int_lenient(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return 0
    return strtoll(string_data_ptr_value(ptr), 0, 10)

pub fn rt_to_string(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr > 0:
        return value
    if value > 2 and value < 4:
        return rt_string_new(0, 0)
    if value > 10 and value < 12:
        val out = alloc_string(4)
        val out_ptr = string_ptr(out)
        if out_ptr < 1:
            return 3
        spl_store_u8(string_data_ptr_value(out_ptr), 0, 116)
        spl_store_u8(string_data_ptr_value(out_ptr), 1, 114)
        spl_store_u8(string_data_ptr_value(out_ptr), 2, 117)
        spl_store_u8(string_data_ptr_value(out_ptr), 3, 101)
        return out
    if value > 18 and value < 20:
        val out = alloc_string(5)
        val out_ptr = string_ptr(out)
        if out_ptr < 1:
            return 3
        spl_store_u8(string_data_ptr_value(out_ptr), 0, 102)
        spl_store_u8(string_data_ptr_value(out_ptr), 1, 97)
        spl_store_u8(string_data_ptr_value(out_ptr), 2, 108)
        spl_store_u8(string_data_ptr_value(out_ptr), 3, 115)
        spl_store_u8(string_data_ptr_value(out_ptr), 4, 101)
        return out
    if (value & 7) > 0:
        return rt_string_new(0, 0)

    var n = value >> 3
    val buf = malloc(32)
    if buf < 1:
        return 3
    if n < 1 and n > -1:
        spl_store_u8(buf, 0, 48)
        return rt_string_new(buf, 1)

    var negative = 0
    if n < 0:
        negative = 1
        n = 0 - n

    var len = 0
    while n > 0:
        val digit = n % 10
        spl_store_u8(buf, len, 48 + digit)
        len = len + 1
        n = n / 10

    val out = alloc_string(len + negative)
    val out_ptr = string_ptr(out)
    if out_ptr < 1:
        return 3
    var out_i = 0
    if negative > 0:
        spl_store_u8(string_data_ptr_value(out_ptr), 0, 45)
        out_i = 1
    var i = len - 1
    while i >= 0:
        spl_store_u8(string_data_ptr_value(out_ptr), out_i, spl_load_u8(buf, i))
        out_i = out_i + 1
        i = i - 1
    return out

pub fn rt_value_to_string(value: i64) -> i64:
    rt_to_string(value)

pub fn rt_raw_u64_to_string(raw: i64) -> i64:
    var n = raw
    val buf = malloc(32)
    if buf < 1:
        return 3
    if n < 1:
        spl_store_u8(buf, 0, 48)
        return rt_string_new(buf, 1)

    var len = 0
    while n > 0:
        val digit = n % 10
        spl_store_u8(buf, len, 48 + digit)
        len = len + 1
        n = n / 10

    val out = alloc_string(len)
    val out_ptr = string_ptr(out)
    if out_ptr < 1:
        return 3
    var out_i = 0
    var i = len - 1
    while i >= 0:
        spl_store_u8(string_data_ptr_value(out_ptr), out_i, spl_load_u8(buf, i))
        out_i = out_i + 1
        i = i - 1
    out

pub fn rt_raw_i64_to_string(raw: i64) -> i64:
    # Signed sibling of rt_raw_u64_to_string. Digits are extracted on the
    # negative side (digit = 0 - (n % 10)) so INT64_MIN never overflows.
    if raw == 0:
        val zbuf = malloc(32)
        if zbuf < 1:
            return 3
        spl_store_u8(zbuf, 0, 48)
        return rt_string_new(zbuf, 1)

    var n = raw
    val neg = raw < 0
    if not neg:
        n = 0 - n

    val buf = malloc(32)
    if buf < 1:
        return 3
    var len = 0
    while n < 0:
        val digit = 0 - (n % 10)
        spl_store_u8(buf, len, 48 + digit)
        len = len + 1
        n = n / 10
    if neg:
        spl_store_u8(buf, len, 45)
        len = len + 1

    val out = alloc_string(len)
    val out_ptr = string_ptr(out)
    if out_ptr < 1:
        return 3
    var out_i = 0
    var i = len - 1
    while i >= 0:
        spl_store_u8(string_data_ptr_value(out_ptr), out_i, spl_load_u8(buf, i))
        out_i = out_i + 1
        i = i - 1
    out

pub fn rt_string_replace(value: i64, old_value: i64, new_value: i64) -> i64:
    val ptr = string_ptr(value)
    val old_ptr = string_ptr(old_value)
    val new_ptr = string_ptr(new_value)
    if ptr < 1 or old_ptr < 1 or new_ptr < 1:
        return value
    val len = string_len_ptr(ptr)
    val old_len = string_len_ptr(old_ptr)
    val new_len = string_len_ptr(new_ptr)
    if old_len < 1:
        return value

    var count = 0
    var i = 0
    while i + old_len <= len:
        val cmp = memcmp(string_data_ptr_value(ptr) + i, string_data_ptr_value(old_ptr), old_len)
        if cmp > -1 and cmp < 1:
            count = count + 1
            i = i + old_len
        else:
            i = i + 1
    if count < 1:
        return value

    var out_len = len
    if new_len >= old_len:
        out_len = out_len + count * (new_len - old_len)
    else:
        out_len = out_len - count * (old_len - new_len)
    val out = alloc_string(out_len)
    val out_ptr = string_ptr(out)
    if out_ptr < 1:
        return 3

    var in_i = 0
    var out_i = 0
    while in_i < len:
        var matched = 0
        if in_i + old_len <= len:
            val cmp = memcmp(string_data_ptr_value(ptr) + in_i, string_data_ptr_value(old_ptr), old_len)
            if cmp > -1 and cmp < 1:
                matched = 1
        if matched > 0:
            if new_len > 0:
                memcpy(string_data_ptr_value(out_ptr) + out_i, string_data_ptr_value(new_ptr), new_len)
            out_i = out_i + new_len
            in_i = in_i + old_len
        else:
            spl_store_u8(string_data_ptr_value(out_ptr), out_i, spl_load_u8(string_data_ptr_value(ptr), in_i))
            out_i = out_i + 1
            in_i = in_i + 1
    return out

pub fn rt_stdout_write(value: i64) -> i64:
    return write_string_to_fd(1, value)

pub fn rt_stderr_write(value: i64) -> i64:
    return write_string_to_fd(2, value)

pub fn print_raw(value: i64) -> i64:
    write_string_to_fd(1, value)
    return 0

pub fn rt_print_value(value: i64) -> i64:
    write_string_to_fd(1, value)
    return 0

# Writes a fixed one-line diagnostic to `fd` when rt_print_str/rt_eprint_str
# is handed a (ptr, len) pair whose ptr falls inside the null page (< 4096) —
# never a legitimate heap/rodata address. Distinguishes a corrupted/miscompiled
# argument pair (silent data loss) from a legitimate empty string (ptr == 0),
# which stays silent unchanged. Byte-stored via spl_store_u8 (same idiom the
# file already uses to emit the trailing newline in rt_println_str et al.)
# rather than a string literal, since this file predates/implements the
# String type itself.
fn write_null_page_diag(fd: i64) -> i64:
    val buf = malloc(45)
    if buf < 1:
        return 0
    spl_store_u8(buf, 0, 105)
    spl_store_u8(buf, 1, 110)
    spl_store_u8(buf, 2, 118)
    spl_store_u8(buf, 3, 97)
    spl_store_u8(buf, 4, 108)
    spl_store_u8(buf, 5, 105)
    spl_store_u8(buf, 6, 100)
    spl_store_u8(buf, 7, 32)
    spl_store_u8(buf, 8, 116)
    spl_store_u8(buf, 9, 101)
    spl_store_u8(buf, 10, 120)
    spl_store_u8(buf, 11, 116)
    spl_store_u8(buf, 12, 32)
    spl_store_u8(buf, 13, 112)
    spl_store_u8(buf, 14, 116)
    spl_store_u8(buf, 15, 114)
    spl_store_u8(buf, 16, 32)
    spl_store_u8(buf, 17, 40)
    spl_store_u8(buf, 18, 110)
    spl_store_u8(buf, 19, 117)
    spl_store_u8(buf, 20, 108)
    spl_store_u8(buf, 21, 108)
    spl_store_u8(buf, 22, 45)
    spl_store_u8(buf, 23, 112)
    spl_store_u8(buf, 24, 97)
    spl_store_u8(buf, 25, 103)
    spl_store_u8(buf, 26, 101)
    spl_store_u8(buf, 27, 41)
    spl_store_u8(buf, 28, 58)
    spl_store_u8(buf, 29, 32)
    spl_store_u8(buf, 30, 111)
    spl_store_u8(buf, 31, 117)
    spl_store_u8(buf, 32, 116)
    spl_store_u8(buf, 33, 112)
    spl_store_u8(buf, 34, 117)
    spl_store_u8(buf, 35, 116)
    spl_store_u8(buf, 36, 32)
    spl_store_u8(buf, 37, 100)
    spl_store_u8(buf, 38, 114)
    spl_store_u8(buf, 39, 111)
    spl_store_u8(buf, 40, 112)
    spl_store_u8(buf, 41, 112)
    spl_store_u8(buf, 42, 101)
    spl_store_u8(buf, 43, 100)
    spl_store_u8(buf, 44, 10)
    write(fd, buf, 45)
    return 0

pub fn rt_print_str(ptr: i64, len: i64) -> i64:
    if ptr != 0 and ptr < 4096:
        write_null_page_diag(2)
        return 0
    if ptr > 0 and len > 0:
        write(1, ptr, len)
    return 0

pub fn rt_println_value(value: i64) -> i64:
    write_string_to_fd(1, value)
    val nl = malloc(1)
    if nl > 0:
        spl_store_u8(nl, 0, 10)
        write(1, nl, 1)
    return 0

pub fn rt_println_str(ptr: i64, len: i64) -> i64:
    rt_print_str(ptr, len)
    val nl = malloc(1)
    if nl > 0:
        spl_store_u8(nl, 0, 10)
        write(1, nl, 1)
    return 0

pub fn rt_eprint_value(value: i64) -> i64:
    write_string_to_fd(2, value)
    return 0

pub fn rt_eprint_str(ptr: i64, len: i64) -> i64:
    if ptr != 0 and ptr < 4096:
        write_null_page_diag(2)
        return 0
    if ptr > 0 and len > 0:
        write(2, ptr, len)
    return 0

pub fn rt_eprintln_value(value: i64) -> i64:
    write_string_to_fd(2, value)
    val nl = malloc(1)
    if nl > 0:
        spl_store_u8(nl, 0, 10)
        write(2, nl, 1)
    return 0

pub fn rt_eprintln_str(ptr: i64, len: i64) -> i64:
    rt_eprint_str(ptr, len)
    val nl = malloc(1)
    if nl > 0:
        spl_store_u8(nl, 0, 10)
        write(2, nl, 1)
    return 0

pub fn stdin_read_char() -> i64:
    val byte = malloc(1)
    if byte < 1:
        return rt_string_new(0, 0)
    val count = read(0, byte, 1)
    if count < 1:
        return rt_string_new(0, 0)
    return rt_string_new(byte, 1)

# ---------------------------------------------------------------------------
# Missing rt_string_* functions ported from the Rust runtime.
# ---------------------------------------------------------------------------

pub fn rt_string_eq(left: i64, right: i64) -> i64:
    if (left & 7) != 1 or (right & 7) != 1:
        return 0
    val left_ptr = left & -8
    val right_ptr = right & -8
    if left_ptr < 1 or right_ptr < 1:
        return 0
    if left_ptr == right_ptr:
        return 1
    val left_kind = spl_load_i64(left_ptr, 0) & 4294967295
    val right_kind = spl_load_i64(right_ptr, 0) & 4294967295
    if left_kind != 1398034993 or right_kind != 1398034993:
        return 0
    val left_len = spl_load_i64(left_ptr, 8)
    if left_len != spl_load_i64(right_ptr, 8):
        return 0
    if left_len < 1:
        return 1
    val cmp = memcmp(left_ptr + 16, right_ptr + 16, left_len)
    if cmp < 0 or cmp > 0:
        return 0
    return 1

# rt_string_char_at — byte-indexed (not UTF-8 codepoint-indexed like the Rust
# version).  Returns a 1-byte string for the byte at `index`, or nil (3) if
# out of bounds.
pub fn rt_string_char_at(value: i64, index: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return 3
    val len = string_len_ptr(ptr)
    if index < 0 or index >= len:
        return 3
    val byte = spl_load_u8(string_data_ptr_value(ptr), index)
    val out = alloc_string(1)
    val out_ptr = string_ptr(out)
    if out_ptr < 1:
        return 3
    spl_store_u8(string_data_ptr_value(out_ptr), 0, byte)
    return out

# rt_string_find — return byte-offset of first occurrence of needle, or -1.
pub fn rt_string_find(value: i64, needle: i64) -> i64:
    val ptr = string_ptr(value)
    val needle_ptr = string_ptr(needle)
    if ptr < 1 or needle_ptr < 1:
        return -1
    val len = string_len_ptr(ptr)
    val needle_len = string_len_ptr(needle_ptr)
    if needle_len < 1:
        return 0
    if needle_len > len:
        return -1
    var i = 0
    while i + needle_len <= len:
        val cmp = memcmp(string_data_ptr_value(ptr) + i, string_data_ptr_value(needle_ptr), needle_len)
        if cmp > -1 and cmp < 1:
            return i
        i = i + 1
    return -1

# rt_text_find — positional byte search used by parsers that cannot safely
# materialize and search a non-zero substring receiver in native mode.
pub fn rt_text_find(value: i64, needle: i64, start: i64) -> i64:
    val ptr = string_ptr(value)
    val needle_ptr = string_ptr(needle)
    if ptr < 1 or needle_ptr < 1 or start < 0:
        return -1
    val len = string_len_ptr(ptr)
    val needle_len = string_len_ptr(needle_ptr)
    if needle_len < 1:
        return if start < len: start else: len
    if start >= len or needle_len > len:
        return -1
    var i = start
    while i + needle_len <= len:
        val cmp = memcmp(string_data_ptr_value(ptr) + i, string_data_ptr_value(needle_ptr), needle_len)
        if cmp > -1 and cmp < 1:
            return i
        i = i + 1
    -1

# rt_string_rfind — return byte-offset of last occurrence of needle, or -1.
pub fn rt_string_rfind(value: i64, needle: i64) -> i64:
    val ptr = string_ptr(value)
    val needle_ptr = string_ptr(needle)
    if ptr < 1 or needle_ptr < 1:
        return -1
    val len = string_len_ptr(ptr)
    val needle_len = string_len_ptr(needle_ptr)
    if needle_len < 1:
        return len
    if needle_len > len:
        return -1
    var i = len - needle_len
    while i >= 0:
        val cmp = memcmp(string_data_ptr_value(ptr) + i, string_data_ptr_value(needle_ptr), needle_len)
        if cmp > -1 and cmp < 1:
            return i
        i = i - 1
    return -1

pub fn rt_string_index_of(value: i64, needle: i64) -> i64:
    val found = rt_string_find(value, needle)
    if found < 0:
        return rt_enum_new(1, 1, 3)
    return rt_enum_new(1, 0, found)

# rt_string_split — split value by delimiter, returning a new array of strings.
pub fn rt_string_split(value: i64, delimiter: i64) -> i64:
    val ptr = string_ptr(value)
    val del_ptr = string_ptr(delimiter)
    if ptr < 1 or del_ptr < 1:
        return rt_array_new(4)
    val len = string_len_ptr(ptr)
    val del_len = string_len_ptr(del_ptr)
    val result = rt_array_new(4)

    if del_len < 1:
        # Empty delimiter: split every byte into its own string.
        var i = 0
        while i < len:
            val part = rt_string_new(string_data_ptr_value(ptr) + i, 1)
            rt_array_push(result, part)
            i = i + 1
        return result

    var start = 0
    while start <= len:
        # Search for delimiter starting at `start`.
        var found = -1
        if start + del_len <= len:
            var j = start
            while j + del_len <= len:
                val cmp = memcmp(string_data_ptr_value(ptr) + j, string_data_ptr_value(del_ptr), del_len)
                if cmp > -1 and cmp < 1:
                    found = j
                    j = len + 1
                else:
                    j = j + 1
        if found < 0:
            # No more delimiters — push remainder and break.
            val part = rt_string_new(string_data_ptr_value(ptr) + start, len - start)
            rt_array_push(result, part)
            start = len + 1
        else:
            val part = rt_string_new(string_data_ptr_value(ptr) + start, found - start)
            rt_array_push(result, part)
            start = found + del_len
    return result

# rt_string_join — join an array of strings with a separator.
pub fn rt_string_join(array: i64, separator: i64) -> i64:
    # Raw low-address gate BEFORE rt_array_len: under one-binary freestanding
    # the seed inlines rt_array_len at this first use and folds away its
    # internal array_is_valid guard, so a raw-0 / nil array handle reaches the
    # bare (handle&-8)+8 length load and faults (cr2=0x8). This explicit literal
    # check runs first and is not folded away (mirror of array_is_valid's own
    # `< 4096` gate).
    if array < 4096:
        return rt_string_new(0, 0)
    val arr_len = rt_array_len_safe(array)
    if arr_len <= 0:
        return rt_string_new(0, 0)
    val sep_ptr = string_ptr(separator)
    var sep_len = 0
    if sep_ptr > 0:
        sep_len = string_len_ptr(sep_ptr)

    # First pass: compute total length.
    var total = 0
    var i = 0
    while i < arr_len:
        val elem = rt_array_get(array, i)
        val elem_ptr = string_ptr(elem)
        if elem_ptr > 0:
            total = total + string_len_ptr(elem_ptr)
        if i > 0 and sep_len > 0:
            total = total + sep_len
        i = i + 1

    val out = alloc_string(total)
    val out_ptr = string_ptr(out)
    if out_ptr < 1:
        return 3

    # Second pass: copy.
    var offset = 0
    i = 0
    while i < arr_len:
        if i > 0 and sep_len > 0:
            memcpy(string_data_ptr_value(out_ptr) + offset, string_data_ptr_value(sep_ptr), sep_len)
            offset = offset + sep_len
        val elem = rt_array_get(array, i)
        val elem_ptr = string_ptr(elem)
        if elem_ptr > 0:
            val elem_len = string_len_ptr(elem_ptr)
            if elem_len > 0:
                memcpy(string_data_ptr_value(out_ptr) + offset, string_data_ptr_value(elem_ptr), elem_len)
                offset = offset + elem_len
        i = i + 1
    return out

# rt_string_to_upper — ASCII-only uppercase conversion (a-z -> A-Z).
pub fn rt_string_to_upper(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return value
    val len = string_len_ptr(ptr)
    if len < 1:
        return value
    val out = alloc_string(len)
    val out_ptr = string_ptr(out)
    if out_ptr < 1:
        return 3
    var i = 0
    while i < len:
        var ch = spl_load_u8(string_data_ptr_value(ptr), i)
        if ch >= 97 and ch <= 122:
            ch = ch - 32
        spl_store_u8(string_data_ptr_value(out_ptr), i, ch)
        i = i + 1
    return out

# rt_string_to_lower — ASCII-only lowercase conversion (A-Z -> a-z).
pub fn rt_string_to_lower(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return value
    val len = string_len_ptr(ptr)
    if len < 1:
        return value
    val out = alloc_string(len)
    val out_ptr = string_ptr(out)
    if out_ptr < 1:
        return 3
    var i = 0
    while i < len:
        var ch = spl_load_u8(string_data_ptr_value(ptr), i)
        if ch >= 65 and ch <= 90:
            ch = ch + 32
        spl_store_u8(string_data_ptr_value(out_ptr), i, ch)
        i = i + 1
    return out

# rt_string_to_float — parse a decimal float string and return a tagged float
# value (tag 2).  Returns nil (3) on failure.
pub fn rt_string_to_float(value: i64) -> i64:
    val ptr = string_ptr(value)
    if ptr < 1:
        return 3
    val len = string_len_ptr(ptr)
    if len < 1:
        return 3
    val data = string_data_ptr_value(ptr)
    val end_slot = malloc(8)
    if end_slot < 1:
        return 3
    val parsed = strtod(data, end_slot)
    val end_ptr = spl_load_i64(end_slot, 0)
    free(end_slot)
    if end_ptr <= data:
        return 3
    val finish = data + len
    var cursor = end_ptr
    while cursor < finish:
        if is_space_byte(spl_load_u8(cursor, 0)) < 1:
            return 3
        cursor = cursor + 1
    return rt_value_float(spl_f64_to_bits(parsed))

# -- Lexer source cache (mirrors src/runtime/runtime_native.c
# rt_lexer_source_set / rt_lexer_source_slice). The parser/lexer set the
# active source once and slice it by CHAR index. Scalar module vars land in
# zeroed .bss, which is reliable under freestanding native-build (unlike
# module-level array initializers — see fs_exec_resolve.spl's
# FREESTANDING DISCIPLINE note). Single-threaded guest tool: no lock needed
# here, unlike the hosted C twin.
var g_lexer_source_ptr: i64 = 0
var g_lexer_source_len: i64 = 0

pub fn rt_lexer_source_set(source_ptr: i64, source_len: i64) -> i8:
    if source_ptr < 1 and source_len > 0:
        return 0
    val replacement = malloc(source_len + 1)
    if replacement < 1:
        return 0
    if source_len > 0:
        memcpy(replacement, source_ptr, source_len)
    spl_store_u8(replacement, source_len, 0)
    if g_lexer_source_ptr > 0:
        free(g_lexer_source_ptr)
    g_lexer_source_ptr = replacement
    g_lexer_source_len = source_len
    return 1

fn lexer_source_char_to_byte(target: i64) -> i64:
    """Char index -> byte offset in the cached lexer source, or -1."""
    var chars = 0
    var i = 0
    while i < g_lexer_source_len:
        val marker = spl_load_u8(g_lexer_source_ptr, i) & 192
        if marker < 128 or marker > 128:
            if chars >= target and chars <= target:
                return i
            chars = chars + 1
        i = i + 1
    if chars >= target and chars <= target:
        return g_lexer_source_len
    return -1

pub fn rt_lexer_source_slice(start: i64, end: i64) -> i64:
    if start < 0 or end < start:
        return 3
    val ustart = lexer_source_char_to_byte(start)
    val uend = lexer_source_char_to_byte(end)
    if ustart < 0 or uend < 0:
        return 3
    if g_lexer_source_ptr < 1:
        return rt_string_new(0, 0)
    return rt_string_new(g_lexer_source_ptr + ustart, uend - ustart)
