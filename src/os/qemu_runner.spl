fn arm_fs_exec_disk_image_path(arch: Architecture) -> text:
    match arch:
        Architecture.Arm64: simpleos_platform_disk_image_output("arm64")
        Architecture.Arm32: simpleos_platform_disk_image_output("arm32")
        _: "build/os/fat32-arm.img"

fn arm_fs_exec_kernel_bin_path(arch: Architecture) -> text:
    match arch:
        Architecture.Arm64: "build/os/simpleos_arm64_fs_exec.bin"
        Architecture.Arm32: "build/os/simpleos_arm32_fs_exec.bin"
        _: "build/os/simpleos_arm_fs_exec.bin"

fn _arm_virtio_blk_exec_disk_args(arch: Architecture) -> [text]:
    val img = arm_fs_exec_disk_image_path(arch)
    ["-global", "virtio-mmio.force-legacy=false", "-drive", "file={img},if=none,id=armdisk,format=raw", "-device", "virtio-blk-device,drive=armdisk"]

fn riscv_fs_exec_disk_image_path(arch: Architecture) -> text:
    match arch:
        Architecture.Riscv64: simpleos_platform_disk_image_output("riscv64")
        Architecture.Riscv32: simpleos_platform_disk_image_output("riscv32")
        _: "build/os/fat32-riscv.img"

fn _riscv_virtio_blk_exec_disk_args(arch: Architecture) -> [text]:
    val img = riscv_fs_exec_disk_image_path(arch)
    ["-global", "virtio-mmio.force-legacy=false", "-drive", "file={img},if=none,id=rvdisk,format=raw", "-device", "virtio-blk-device,drive=rvdisk"]

fn ovmf_code_candidates() -> [text]:
    [
        "/usr/share/OVMF/OVMF_CODE_4M.fd",
        "/usr/share/OVMF/OVMF_CODE.fd",
        "/usr/share/edk2/ovmf/OVMF_CODE.fd",
        "/usr/share/edk2-ovmf/x64/OVMF_CODE.fd",
        "/usr/share/qemu/OVMF.fd",
        "/opt/homebrew/share/qemu/edk2-x86_64-code.fd"
    ]

fn ovmf_code_path() -> text:
    """Resolve the OVMF code image for x86_64 UEFI QEMU boots."""
    val env_path = rt_env_get("SIMPLEOS_OVMF_CODE") ?? ""
    if env_path != "":
        return env_path
    for candidate in ovmf_code_candidates():
        if rt_file_exists(candidate):
            return candidate
    ""

fn desktop_uefi_bootloader_candidates() -> [text]:
    [
        "build/os/esp/EFI/BOOT/BOOTX64.EFI",
        "build/os/EFI/BOOT/BOOTX64.EFI",
        "build/os/BOOTX64.EFI",
        "third_party/limine/BOOTX64.EFI",
        "vendor/limine/BOOTX64.EFI"
    ]

fn desktop_uefi_bootloader_path() -> text:
    """Resolve a repo-managed EFI bootloader artifact for the desktop UEFI lane."""
    val env_path = rt_env_get("SIMPLEOS_UEFI_BOOTLOADER") ?? ""
    if env_path != "":
        return env_path
    for candidate in desktop_uefi_bootloader_candidates():
        if rt_file_exists(candidate):
            return candidate
    ""

fn desktop_uefi_disk_image_path() -> text:
    """Generated FAT32 image used by the desktop UEFI acceptance lane."""
    simpleos_platform_disk_image_output("x86_64")

fn desktop_uefi_boot_media_ready() -> bool:
    """True when the local disk image can be expected to boot under OVMF."""
    ovmf_code_path() != "" and desktop_uefi_bootloader_path() != "" and rt_file_exists(desktop_uefi_disk_image_path())

fn _x64_desktop_uefi_args() -> [text]:
    val fw = ovmf_code_path()
    val img_path = desktop_uefi_disk_image_path()
    var args: [text] = [
        "-drive", "if=pflash,format=raw,readonly=on,file={fw}",
        "-global", "q35-pcihost.pci-hole64-size=0",
        "-drive", "file={img_path},if=none,id=uefidisk,format=raw",
        "-device", "nvme,serial=uefi-desktop,drive=uefidisk",
        "-netdev", "user,id=n0",
        "-device", "virtio-net-pci,netdev=n0",
        "-device", "virtio-gpu,disable-modern=on,disable-legacy=off",
        "-vga", "none",
        "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"
    ]
    args

fn scenario_x64_desktop_uefi() -> QemuScenario:
    """x86_64 desktop acceptance lane booted through OVMF/UEFI from disk."""
    QemuScenario(
        name: "x64-desktop-uefi",
        arch: Architecture.X86_64,
        machine: "q35",
        cpu: "qemu64",
        memory: "2048M",
        qemu_extra: _x64_desktop_uefi_args(),
        gui_mode: false,
        description: "x86_64 SimpleOS desktop UEFI/OVMF disk boot acceptance lane"
    )

fn get_all_scenarios() -> [QemuScenario]:
    """Returns all defined QEMU scenarios."""
    [
        scenario_rv64_base(),
        scenario_rv64_dtb_pci(),
        scenario_x64_pci_lab(),
        scenario_x64_nvme(),
        scenario_x64_net_user(),
        scenario_x64_gpu_2d(),
        scenario_x64_gui(),
        scenario_x64_gui_tablet(),
        scenario_x64_wm_input_test(),
        scenario_x64_nvme_fat32(),
        scenario_arm64_virtio_fat32_smf(),
        scenario_arm32_virtio_fat32_smf(),
        scenario_riscv64_virtio_fat32_smf(),
        scenario_riscv32_virtio_fat32_smf(),
        scenario_x64_full_stack(),
        scenario_x64_desktop_test(),
        scenario_x64_desktop_disk(),
        scenario_x64_desktop_uefi()
    ]

fn get_scenario(name: text) -> QemuScenario?:
    """Look up a scenario by name."""
    for s in get_all_scenarios():
        if s.name == name:
            return s
    nil

fn scenario_target(scenario: QemuScenario) -> OsTarget:
    """Resolve which kernel target should be built for a named scenario."""
    if scenario.name == "x64-nvme-fat32":
        return get_fs_test_target()
    if scenario.name == "arm64-virtio-fat32-smf":
        return get_arm64_fs_exec_target()
    if scenario.name == "arm32-virtio-fat32-smf":
        return get_arm32_fs_exec_target()
    if scenario.name == "riscv64-virtio-fat32-smf":
        return get_riscv64_fs_exec_target()
    if scenario.name == "riscv32-virtio-fat32-smf":
        return get_riscv32_fs_exec_target()
    if scenario.name == "x64-desktop-test":
        return get_desktop_browser_target()
    if scenario.name == "x64-desktop-disk":
        return get_desktop_browser_target()
    if scenario.name == "x64-desktop-uefi":
        return get_desktop_browser_target()
    get_target(scenario.arch)

fn get_arm64_fs_exec_target() -> OsTarget:
    """ARM64 filesystem executable acceptance target."""
    OsTarget(
        arch: Architecture.Arm64,
        entry: "examples/simple_os/arch/arm64/fs_exec_entry.spl",
        linker_script: "examples/simple_os/arch/arm64/fs_exec_linker.ld",
        target_triple: "aarch64-unknown-none",
        output: "build/os/simpleos_arm64_fs_exec.elf",
        qemu_system: "qemu-system-aarch64",
        qemu_machine: "virt",
        qemu_cpu: "cortex-a72",
        qemu_memory: "384M",
        qemu_bios: "",
        qemu_extra: _arm_virtio_blk_exec_disk_args(Architecture.Arm64) + ["-semihosting-config", "enable=on,target=native"],
        gui_mode: false
    )

