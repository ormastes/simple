fn arm_fs_exec_disk_image_path(arch: Architecture) -> text:
    match arch:
        Architecture.Arm64: simpleos_platform_disk_image_output("arm64")
        Architecture.Arm32: simpleos_platform_disk_image_output("arm32")
        _: "build/os/fat32-arm.img"

fn arm_fs_exec_kernel_bin_path(arch: Architecture) -> text:
    match arch:
        Architecture.Arm64: "build/os/simpleos_arm64_fs_exec.bin"
        Architecture.Arm32: "build/os/simpleos_arm32_fs_exec.bin"
        _: "build/os/simpleos_arm_fs_exec.bin"

fn _arm_virtio_blk_exec_disk_args(arch: Architecture) -> [text]:
    val img = arm_fs_exec_disk_image_path(arch)
    ["-global", "virtio-mmio.force-legacy=false", "-drive", "file={img},if=none,id=armdisk,format=raw", "-device", "virtio-blk-device,drive=armdisk"]

fn riscv_fs_exec_disk_image_path(arch: Architecture) -> text:
    match arch:
        Architecture.Riscv64: simpleos_platform_disk_image_output("riscv64")
        Architecture.Riscv32: simpleos_platform_disk_image_output("riscv32")
        _: "build/os/fat32-riscv.img"

fn _riscv_virtio_blk_exec_disk_args(arch: Architecture) -> [text]:
    val img = riscv_fs_exec_disk_image_path(arch)
    ["-global", "virtio-mmio.force-legacy=false", "-drive", "file={img},if=none,id=rvdisk,format=raw", "-device", "virtio-blk-device,drive=rvdisk"]

fn ovmf_code_candidates() -> [text]:
    [
        "/usr/share/OVMF/OVMF_CODE_4M.fd",
        "/usr/share/OVMF/OVMF_CODE.fd",
        "/usr/share/edk2/ovmf/OVMF_CODE.fd",
        "/usr/share/edk2-ovmf/x64/OVMF_CODE.fd",
        "/usr/share/qemu/OVMF.fd",
        "/opt/homebrew/share/qemu/edk2-x86_64-code.fd"
    ]

fn ovmf_code_path() -> text:
    """Resolve the OVMF code image for x86_64 UEFI QEMU boots."""
    val env_path = rt_env_get("SIMPLEOS_OVMF_CODE") ?? ""
    if env_path != "":
        return env_path
    for candidate in ovmf_code_candidates():
        if rt_file_exists(candidate):
            return candidate
    ""

fn desktop_uefi_bootloader_candidates() -> [text]:
    [
        "build/os/esp/EFI/BOOT/BOOTX64.EFI",
        "build/os/EFI/BOOT/BOOTX64.EFI",
        "build/os/BOOTX64.EFI",
        "third_party/limine/BOOTX64.EFI",
        "vendor/limine/BOOTX64.EFI"
    ]

fn desktop_uefi_bootloader_path() -> text:
    """Resolve a repo-managed EFI bootloader artifact for the desktop UEFI lane."""
    val env_path = rt_env_get("SIMPLEOS_UEFI_BOOTLOADER") ?? ""
    if env_path != "":
        return env_path
    for candidate in desktop_uefi_bootloader_candidates():
        if rt_file_exists(candidate):
            return candidate
    ""

fn desktop_uefi_disk_image_path() -> text:
    """Generated FAT32 image used by the desktop UEFI acceptance lane."""
    simpleos_platform_disk_image_output("x86_64")

fn desktop_uefi_boot_media_ready() -> bool:
    """True when the local disk image can be expected to boot under OVMF."""
    ovmf_code_path() != "" and desktop_uefi_bootloader_path() != "" and rt_file_exists(desktop_uefi_disk_image_path())

fn _x64_desktop_uefi_args() -> [text]:
    val fw = ovmf_code_path()
    val img_path = desktop_uefi_disk_image_path()
    var args: [text] = [
        "-drive", "if=pflash,format=raw,readonly=on,file={fw}",
        "-global", "q35-pcihost.pci-hole64-size=0",
        "-drive", "file={img_path},if=none,id=uefidisk,format=raw",
        "-device", "nvme,serial=uefi-desktop,drive=uefidisk",
        "-netdev", "user,id=n0",
        "-device", "virtio-net-pci,netdev=n0",
        "-device", "virtio-gpu,disable-modern=on,disable-legacy=off",
        "-vga", "none",
        "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"
    ]
    args

fn scenario_x64_desktop_uefi() -> QemuScenario:
    """x86_64 desktop acceptance lane booted through OVMF/UEFI from disk."""
    QemuScenario(
        name: "x64-desktop-uefi",
        arch: Architecture.X86_64,
        machine: "q35",
        cpu: "qemu64",
        memory: "2048M",
        qemu_extra: _x64_desktop_uefi_args(),
        gui_mode: false,
        description: "x86_64 SimpleOS desktop UEFI/OVMF disk boot acceptance lane"
    )

fn get_all_scenarios() -> [QemuScenario]:
    """Returns all defined QEMU scenarios."""
    [
        scenario_rv64_base(),
        scenario_rv64_dtb_pci(),
        scenario_x64_pci_lab(),
        scenario_x64_nvme(),
        scenario_x64_net_user(),
        scenario_x64_ssh(),
        scenario_x64_gpu_2d(),
        scenario_x64_gui(),
        scenario_x64_gui_tablet(),
        scenario_x64_wm_input_test(),
        scenario_x64_wm_simple_web_check(),
        scenario_x64_nvme_fat32(),
        scenario_arm64_virtio_fat32_smf(),
        scenario_arm32_virtio_fat32_smf(),
        scenario_riscv64_virtio_fat32_smf(),
        scenario_riscv64_hosted(),
        scenario_riscv32_virtio_fat32_smf(),
        scenario_x64_full_stack(),
        scenario_x64_desktop_test(),
        scenario_x64_desktop_disk(),
        scenario_x64_desktop_uefi()
    ]

fn get_scenario(name: text) -> QemuScenario?:
    """Look up a scenario by name."""
    for s in get_all_scenarios():
        if s.name == name:
            return s
    nil

fn _arm_fs_exec_scenario_name(arch: Architecture) -> text:
    _arm_fs_exec_platform_name(arch) + "-virtio-fat32-smf"

fn _riscv_fs_exec_scenario_name(arch: Architecture) -> text:
    _riscv_fs_exec_platform_name(arch) + "-virtio-fat32-smf"

fn _is_arm_fs_exec_scenario_name(name: text) -> bool:
    name == "arm64-virtio-fat32-smf" or name == "arm32-virtio-fat32-smf"

fn _is_arm_fs_exec_scenario(scenario: QemuScenario) -> bool:
    _is_arm_fs_exec_scenario_name(scenario.name)

fn _is_riscv_fs_exec_scenario_name(name: text) -> bool:
    name == "riscv64-virtio-fat32-smf" or name == "riscv32-virtio-fat32-smf"

fn _is_riscv_fs_exec_scenario(scenario: QemuScenario) -> bool:
    _is_riscv_fs_exec_scenario_name(scenario.name)

fn _catalog_platform_name_for_scenario(scenario: QemuScenario) -> text:
    match scenario.arch:
        Architecture.Arm64: "arm64"
        Architecture.Arm32: "arm32"
        Architecture.Riscv64: "riscv64"
        Architecture.Riscv32: "riscv32"
        _: ""

fn _catalog_lane_for_scenario(scenario: QemuScenario) -> SimpleOsLaneContract?:
    val platform_name = _catalog_platform_name_for_scenario(scenario)
    if platform_name != "":
        return simpleos_platform_qemu_lane(platform_name, scenario.name)
    nil

fn _ensure_catalog_scenario_media(scenario: QemuScenario) -> bool?:
    if _catalog_lane_for_scenario(scenario) == nil:
        return nil
    if scenario.arch == Architecture.Arm64 or scenario.arch == Architecture.Arm32:
        return ensure_arm_fs_exec_disk_image(scenario.arch)
    if scenario.arch == Architecture.Riscv64 or scenario.arch == Architecture.Riscv32:
        return ensure_riscv_fs_exec_disk_image(scenario.arch)
    nil

fn scenario_target(scenario: QemuScenario) -> OsTarget:
    """Resolve which kernel target should be built for a named scenario."""
    if scenario.name == "x64-nvme-fat32":
        return get_fs_test_target()
    val platform_name = _catalog_platform_name_for_scenario(scenario)
    if platform_name != "":
        if val lane = simpleos_platform_qemu_lane(platform_name, scenario.name):
            return _lane_to_target(platform_name, lane)
    if _is_arm_fs_exec_scenario(scenario):
        if val lane = simpleos_platform_qemu_lane(_arm_fs_exec_platform_name(scenario.arch), scenario.name):
            return _lane_to_target(_arm_fs_exec_platform_name(scenario.arch), lane)
        return _lane_to_target(_arm_fs_exec_platform_name(scenario.arch), simpleos_platform_qemu_acceptance_lane(_arm_fs_exec_platform_name(scenario.arch)))
    if scenario.name == "riscv64-hosted":
        if val lane = simpleos_platform_qemu_lane("riscv64", "riscv64-hosted"):
            return _lane_to_target("riscv64", lane)
        return get_riscv64_hosted_target()
    if _is_riscv_fs_exec_scenario(scenario):
        if val lane = simpleos_platform_qemu_lane(_riscv_fs_exec_platform_name(scenario.arch), scenario.name):
            return _lane_to_target(_riscv_fs_exec_platform_name(scenario.arch), lane)
        return _riscv_fs_exec_target(scenario.arch)
    if val desktop_target = _desktop_disk_scenario_target(scenario.name):
        return desktop_target
    get_target(scenario.arch)

fn get_arm64_fs_exec_target() -> OsTarget:
    """ARM64 filesystem executable acceptance target."""
    _lane_to_target("arm64", simpleos_platform_qemu_acceptance_lane("arm64"))

fn get_arm32_fs_exec_target() -> OsTarget:
    """ARM32 filesystem executable acceptance target."""
    _lane_to_target("arm32", simpleos_platform_qemu_acceptance_lane("arm32"))

fn get_riscv64_fs_exec_target() -> OsTarget:
    """RV64 filesystem SMF acceptance target."""
    OsTarget(
        arch: Architecture.Riscv64,
        entry: "examples/simple_os/arch/riscv64/smoke_entry.spl",
        linker_script: "examples/simple_os/arch/riscv64/linker.ld",
        target_triple: "riscv64-unknown-none",
        output: "build/os/simpleos_riscv64_smf_fs.elf",
        qemu_system: "qemu-system-riscv64",
        qemu_machine: "virt",
        qemu_cpu: "rv64",
        qemu_memory: "512M",
        qemu_bios: "default",
        qemu_extra: _riscv_virtio_blk_exec_disk_args(Architecture.Riscv64),
        gui_mode: false
    )

fn get_riscv32_fs_exec_target() -> OsTarget:
    """RV32 filesystem SMF acceptance target."""
    OsTarget(
        arch: Architecture.Riscv32,
        entry: "examples/simple_os/arch/riscv32/smoke_entry.spl",
        linker_script: "examples/simple_os/arch/riscv32/linker.ld",
        target_triple: "riscv32-unknown-none",
        output: "build/os/simpleos_riscv32_smf_fs.elf",
        qemu_system: "qemu-system-riscv32",
        qemu_machine: "virt",
        qemu_cpu: "rv32",
        qemu_memory: "256M",
        qemu_bios: "none",
        qemu_extra: _riscv_virtio_blk_exec_disk_args(Architecture.Riscv32),
        gui_mode: false
    )

fn get_riscv64_hosted_target() -> OsTarget:
    """RV64 hosted-preflight target."""
    _lane_to_target("riscv64", simpleos_platform_qemu_acceptance_lane("riscv64"))
fn _desktop_release_version() -> text:
    os_version().to_text()

fn desktop_release_disk_image_path_in(release_root: text) -> text:
    val arch_name = "x86_64"
    val ver_str = _desktop_release_version()
    "{release_root}/{arch_name}/images/simpleos-{ver_str}-{arch_name}.img"

fn desktop_release_disk_image_path() -> text:
    desktop_release_disk_image_path_in("release")

fn desktop_release_installer_iso_path_in(release_root: text) -> text:
    val arch_name = "x86_64"
    val ver_str = _desktop_release_version()
    "{release_root}/{arch_name}/images/simpleos-{ver_str}-{arch_name}-installer.iso"

fn desktop_release_installer_iso_path() -> text:
    desktop_release_installer_iso_path_in("release")

fn desktop_disk_image_candidates_in(release_root: text) -> [text]:
    [
        desktop_release_disk_image_path_in(release_root),
        simpleos_platform_disk_image_output("x86_64"),
        "build/os/fat32.img"
    ]

fn desktop_disk_image_candidates() -> [text]:
    desktop_disk_image_candidates_in("release")

fn desktop_installer_iso_candidates_in(release_root: text) -> [text]:
    [desktop_release_installer_iso_path_in(release_root)]

fn desktop_installer_iso_candidates() -> [text]:
    desktop_installer_iso_candidates_in("release")

fn desktop_disk_image_path_in(release_root: text) -> text:
    val release_path = desktop_release_disk_image_path_in(release_root)
    if rt_file_exists(release_path):
        return release_path
    val platform_path = simpleos_platform_disk_image_output("x86_64")
    if rt_file_exists(platform_path):
        return platform_path
    "build/os/fat32.img"

fn desktop_disk_image_path() -> text:
    desktop_disk_image_path_in("release")

fn desktop_disk_make_script_args(img_path: text) -> [text]:
    ["scripts/make_os_disk.shs", "64", img_path]

fn desktop_uefi_disk_make_script_args(img_path: text, kernel_path: text) -> [text]:
    ["-c", "SIMPLEOS_UEFI_KERNEL=\"$1\" exec /bin/sh scripts/make_os_disk.shs 64 \"$2\" \"\" x86_64", "simpleos-uefi-disk", kernel_path, img_path]

fn fs_test_disk_image_path() -> text:
    simpleos_platform_disk_image_output("x86_64")

fn _x64_nvme_fs_test_disk_args() -> [text]:
    val img_path = fs_test_disk_image_path()
    [
        "-drive", "file={img_path},if=none,id=nvm,format=raw",
        "-device", "nvme,serial=deadbeef,drive=nvm"
    ]

fn desktop_installer_iso_path_in(release_root: text) -> text?:
    val iso_path = desktop_release_installer_iso_path_in(release_root)
    if rt_file_exists(iso_path):
        return iso_path
    nil

fn desktop_installer_iso_path() -> text?:
    desktop_installer_iso_path_in("release")

fn _x64_nvme_disk_args() -> [text]:
    val img_path = desktop_disk_image_path()
    [
        "-drive", "file={img_path},if=none,id=nvm,format=raw",
        "-device", "nvme,serial=deadbeef,drive=nvm"
    ]

# ===========================================================================
# Storage-backed desktop lane — release-first disk artifact selection
# ===========================================================================

fn scenario_x64_desktop_disk() -> QemuScenario:
    """x86_64 desktop lane with release-first disk image selection.

    Boots the same desktop_e2e entry as x64-desktop-test but attaches the
    preferred release/installer-built disk artifact when it exists. The
    helper still falls back to the legacy FAT32 fixture when a release image
    is not available, which keeps the lane usable before the rollout lands.
    """
    QemuScenario(
        name: "x64-desktop-disk",
        arch: Architecture.X86_64,
        machine: "q35",
        cpu: "qemu64",
        memory: "512M",
        qemu_extra: ["-device", "isa-debug-exit,iobase=0xf4,iosize=0x04", "-vga", "std"] + _x64_nvme_disk_args(),
        gui_mode: false,
        description: "x86_64 SimpleOS desktop with release-first NVMe+FAT32 disk"
    )

fn ensure_desktop_disk_image() -> bool:
    """Ensure a preferred disk image exists for the desktop storage lane.

    Release builds are preferred when present. Otherwise, fall back to the
    legacy `build/os/fat32.img` fixture and materialize it via
    `scripts/make_os_disk.shs` if needed.
    """
    val release_img = desktop_release_disk_image_path()
    if rt_file_exists(release_img):
        print "[ensure_desktop_disk_image] using release disk image {release_img}"
        return true
    val img_path = simpleos_platform_disk_image_output("x86_64")
    if rt_file_exists(img_path) and _desktop_disk_image_has_required_manifests(img_path):
        return true
    print "[ensure_desktop_disk_image] {img_path} missing or incomplete, invoking scripts/make_os_disk.shs"
    val (stdout, stderr, exit_code) = rt_process_run_timeout(
        "/bin/sh", desktop_disk_make_script_args(img_path), 60000)
    if stdout != "":
        print "[ensure_desktop_disk_image] stdout:\n{stdout}"
    if stderr != "":
        print "[ensure_desktop_disk_image] stderr:\n{stderr}"
    if exit_code != 0:
        print "[ensure_desktop_disk_image] make_os_disk.shs exited {exit_code}"
        print "[ensure_desktop_disk_image] prerequisite: install mtools or python3 for unprivileged FAT32 population; qemu-img is optional but preferred for raw image creation"
        return false
    if not rt_file_exists(img_path):
        print "[ensure_desktop_disk_image] expected disk image was not created: {img_path}"
        return false
    if not _desktop_disk_image_has_required_manifests(img_path):
        val legacy_img = "build/os/fat32.img"
        if rt_file_exists(legacy_img) and _desktop_disk_image_has_required_manifests(legacy_img):
            print "[ensure_desktop_disk_image] using legacy disk image {legacy_img}"
            return true
        print "[ensure_desktop_disk_image] image exists but required app manifest markers are missing"
        return false
    true

pub fn desktop_uefi_disk_image_tool_app_validation_command(img_path: text) -> text:
    """Build the host-side validation command for migrated desktop UEFI tool apps."""
    "if command -v mdir >/dev/null 2>&1; then " +
        "mdir -i \"{img_path}\" ::/SYS/APPS/simple_browser >/dev/null 2>&1 && " +
        "mdir -i \"{img_path}\" ::/SYS/APPS/simple_browser.smf >/dev/null 2>&1 && " +
        "mdir -i \"{img_path}\" ::/SYS/APPS/smux >/dev/null 2>&1 && " +
