fn scenario_x64_full_stack() -> QemuScenario:
    """x86_64 with NVMe + VirtIO-net + VirtIO-GPU — full driver stack."""
    QemuScenario(
        name: "x64-full-stack",
        arch: Architecture.X86_64,
        machine: "q35",
        cpu: "qemu64",
        memory: "512M",
        qemu_extra: [
            "-drive", "file=build/os/fat32.img,if=none,id=nvm,format=raw",
            "-device", "nvme,serial=deadbeef,drive=nvm",
            "-netdev", "user,id=n0",
            "-device", "virtio-net-pci,netdev=n0",
            "-device", "virtio-gpu,disable-modern=on,disable-legacy=off",
            "-vga", "none",
            "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"
