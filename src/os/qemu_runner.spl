        machine: "q35",
        cpu: "qemu64",
        memory: "512M",
        qemu_extra: [
            "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04",
            "-netdev", "user,id=n0",
            "-device", "virtio-net-pci,netdev=n0"
        ],
        gui_mode: false,
        description: "x86_64 with virtio-net (QEMU user-mode networking)"
    )

fn scenario_x64_gpu_2d() -> QemuScenario:
