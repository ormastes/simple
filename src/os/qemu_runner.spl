fn get_all_targets() -> [OsTarget]:
    """Returns all 6 architecture targets."""
    [
        get_qemu_target(Architecture.X86_64),
        get_qemu_target(Architecture.X86),
        get_qemu_target(Architecture.Riscv64),
        get_qemu_target(Architecture.Riscv32),
        get_qemu_target(Architecture.Arm64),
        get_qemu_target(Architecture.Arm32)
    ]

fn arch_from_name(name: text) -> Architecture?:
    """Parse architecture name string to Architecture enum.

    Accepts: x86_64, x86_32, x86, i386, i686, riscv64, riscv32, arm64, aarch64, arm32, armv7.
    Returns nil for unrecognized names.
    """
    if name == "x86_64":
        Architecture.X86_64
    elif name == "x86_32" or name == "x86" or name == "i386" or name == "i686":
        Architecture.X86
    elif name == "riscv64":
        Architecture.Riscv64
    elif name == "riscv32":
        Architecture.Riscv32
    elif name == "arm64" or name == "aarch64":
        Architecture.Arm64
    elif name == "arm32" or name == "armv7":
        Architecture.Arm32
    else:
        nil

fn arch_display_name(arch: Architecture) -> text:
    """Human-readable name for an architecture."""
    match arch:
        Architecture.X86_64: "x86_64"
        Architecture.X86: "x86_32"
        Architecture.Riscv64: "riscv64"
        Architecture.Riscv32: "riscv32"
        Architecture.Arm64: "arm64"
        Architecture.Arm32: "arm32"

# ===========================================================================
# Build
# ===========================================================================

fn build_os(target: OsTarget) -> bool:
    build_os_with_backend(target, _os_build_backend_for_target(target))

pub fn os_native_build_sources(target: OsTarget) -> [text]:
    """Return the source roots passed to `simple native-build` for an OS target."""
    _build_sources(target)

pub fn os_native_build_env_prefix(target: OsTarget, objcopy_prefix: text) -> text:
    """Return the build environment prefix for an OS target."""
    _build_env_prefix(target, objcopy_prefix)

fn os_native_build_args(target: OsTarget, backend: text) -> [text]:
    """Build the argv passed to `simple native-build` for an OS target."""
    val backend_name = if backend == "llvm": "llvm" else: "cranelift"
    val log_mode = _os_build_log_mode()
    var args: [text] = ["native-build"]
    for source in _build_sources(target):
        args.push("--source")
        args.push(source)
    args.push("--backend")
    args.push(backend_name)
    args.push("--opt-level=aggressive")
    args.push("--log")
    args.push(log_mode)
    if _is_arm_fs_exec_target(target) or _is_riscv_fs_exec_target(target) or _is_riscv64_hosted_target(target):
        args.push("--timeout")
        args.push("180")
    elif _is_ssh_live_target(target):
        # The SSH live image pulls in the full network/storage/userland slice,
        # and several reachable modules routinely exceed the default 60s
        # per-file watchdog on cold LLVM builds even when the lane is healthy.
        args.push("--timeout")
        args.push("180")
    args.push("--entry-closure")
    args.push("--entry")
    args.push(target.entry)
    args.push("--target")
    args.push(target.target_triple)
    args.push("-o")
    args.push(target.output)
    args.push("--linker-script")
    args.push(target.linker_script)
    args

fn build_os_with_backend(target: OsTarget, backend: text) -> bool:
    """Builds the OS kernel for the given target.

    Runs the native-build command via rt_process_run_timeout. Returns true on success.

    Phase-level diagnostics are printed so a stalled build identifies which phase
    ran long rather than surfacing as a generic 'Process timed out'. The timeout
    defaults to 15 minutes and can be overridden with SIMPLE_OS_BUILD_TIMEOUT_MS.
    """
    val arch_label = arch_display_name(target.arch)
    val timeout_ms = _os_build_timeout_ms()
    val build_marker = if _is_ssh_live_target(target): _ssh_live_build_marker_value(backend) else: ""
    val log_mode = _os_build_log_mode()
    val old_bootstrap = rt_env_get("SIMPLE_BOOTSTRAP") ?? ""
    val old_lib = rt_env_get("SIMPLE_LIB") ?? ""
    val old_boot_minimal = rt_env_get("SIMPLE_BOOT_MINIMAL") ?? ""
    val old_stub_env = rt_env_get("SIMPLE_ALLOW_FREESTANDING_STUBS") ?? ""
    val old_log_mode = rt_env_get("SIMPLE_OS_LOG_MODE") ?? ""
    val old_path = rt_env_get("PATH") ?? ""
    val old_build_marker = rt_env_get("SIMPLE_SSH_LIVE_BUILD_MARKER") ?? ""
    if not _prepare_build_output(target, build_marker):
        _cleanup_generated_build_helpers(build_marker)
        _restore_build_env(old_bootstrap, old_lib, old_boot_minimal, old_stub_env, old_log_mode, old_path, old_build_marker)
        print "[build][{arch_label}] phase=prepare FAILED output={target.output}"
        return false

    val backend_name = if backend == "llvm": "llvm" else: "cranelift"
    print "[build][{arch_label}] phase=plan entry={target.entry} target={target.target_triple} backend={backend_name} log={log_mode}"
    val args = os_native_build_args(target, backend_name)
    val objcopy_prefix = _objcopy_path_prefix()
    if _needs_elf32_wrap(target) and objcopy_prefix == "":
        print "[build][{arch_label}] phase=tooling FAILED: llvm-objcopy not found for {target.entry}"
        _cleanup_generated_build_helpers(build_marker)
        _restore_build_env(old_bootstrap, old_lib, old_boot_minimal, old_stub_env, old_log_mode, old_path, old_build_marker)
        return false

    val simple_bin = _find_simple_binary()
    val env_prefix = _build_env_prefix(target, objcopy_prefix)
    if not _apply_build_env(target, objcopy_prefix):
        print "[build][{arch_label}] phase=env FAILED could not export build environment"
        _cleanup_generated_build_helpers(build_marker)
        _restore_build_env(old_bootstrap, old_lib, old_boot_minimal, old_stub_env, old_log_mode, old_path, old_build_marker)
        return false
    val started_ms = _now_ms()
    print "[build][{arch_label}] phase=spawn timeout_ms={timeout_ms}"
    if env_prefix != "":
        print "[build][{arch_label}] env: {env_prefix}"
    print "[build][{arch_label}] cmd: {simple_bin} {args.join(" ")}"
    val (stdout, stderr, exit_code) = rt_process_run_timeout(simple_bin, args, timeout_ms)
    val elapsed_ms = _now_ms() - started_ms
    if exit_code != 0:
        print "[build][{arch_label}] phase=native-build FAILED exit={exit_code} elapsed_ms={elapsed_ms} timeout_ms={timeout_ms}"
        _print_native_build_failure_hint(arch_label, backend_name, stderr)
        if stdout != "":
            print "[build][{arch_label}] stdout tail:\n{_tail_lines(stdout, 20)}"
        if stderr != "":
            print "[build][{arch_label}] stderr tail:\n{_tail_lines(stderr, 40)}"
        _cleanup_generated_build_helpers(build_marker)
        _restore_build_env(old_bootstrap, old_lib, old_boot_minimal, old_stub_env, old_log_mode, old_path, old_build_marker)
        return false
    print "[build][{arch_label}] phase=native-build OK elapsed_ms={elapsed_ms}"
    if not rt_file_exists(target.output):
        print "[build][{arch_label}] phase=artifact FAILED output missing: {target.output}"
        _cleanup_generated_build_helpers(build_marker)
        _restore_build_env(old_bootstrap, old_lib, old_boot_minimal, old_stub_env, old_log_mode, old_path, old_build_marker)
        return false
    if build_marker != "":
        print "[build][{arch_label}] phase=artifact OK marker={build_marker}"
    _restore_build_env(old_bootstrap, old_lib, old_boot_minimal, old_stub_env, old_log_mode, old_path, old_build_marker)
    true

fn _objcopy_path_prefix() -> text:
    # macOS Homebrew locations
    if rt_file_exists("/opt/homebrew/opt/llvm/bin/llvm-objcopy"):
        return "/opt/homebrew/opt/llvm/bin"
    if rt_file_exists("/usr/local/opt/llvm/bin/llvm-objcopy"):
        return "/usr/local/opt/llvm/bin"
    # Linux system locations (Debian/Ubuntu packaged LLVM)
    if rt_file_exists("/usr/bin/llvm-objcopy"):
        return "/usr/bin"
    if rt_file_exists("/usr/lib/llvm-20/bin/llvm-objcopy"):
        return "/usr/lib/llvm-20/bin"
    if rt_file_exists("/usr/lib/llvm-19/bin/llvm-objcopy"):
        return "/usr/lib/llvm-19/bin"
    if rt_file_exists("/usr/lib/llvm-18/bin/llvm-objcopy"):
        return "/usr/lib/llvm-18/bin"
    if rt_file_exists("/usr/lib/llvm-17/bin/llvm-objcopy"):
        return "/usr/lib/llvm-17/bin"
    ""

fn _simple_binary_is_valid(candidate: text) -> bool:
    """Validate a candidate `simple` binary by running `<candidate> --version`.

    Requires exit code 0 and non-empty stdout. Guards against stale or
    corrupt bootstrap binaries (e.g. ones that segfault on startup, which
    the Linux bootstrap binary at src/compiler_rust/target/release/simple
    was observed to do on 2026-04-13).
    """
    if not rt_file_exists(candidate):
        return false
    val (stdout, _stderr, exit_code) = rt_process_run_timeout(candidate, ["--version"], 5000)
    exit_code == 0 and stdout != ""

fn _find_simple_binary() -> text:
    val env_bin = rt_env_get("SIMPLE_BINARY") ?? ""
    if env_bin != "":
        return env_bin
    # Probe in priority order. Prefer freshly built local binaries first so
    # QEMU/native-build lanes see the current source tree instead of an older
    # release artifact that merely still passes `--version`.
    # Each candidate is validated via `<candidate> --version` (exit 0 +
    # non-empty stdout) so stale or segfaulting binaries fall through.
    val candidates: [text] = [
        "src/compiler_rust/target/debug/simple",
        "src/compiler_rust/target/bootstrap/simple",
        "src/compiler_rust/target/release/simple",
        "bin/simple",
        "bin/release/aarch64-apple-darwin-macho/simple",
        "bin/release/macos-arm64/simple",
        "bin/release/darwin-aarch64/simple",
        "bin/release/macos-x86_64/simple",
        "bin/release/linux-x86_64/simple",
    ]
    for cand in candidates:
        if _simple_binary_is_valid(cand):
            return cand
    "bin/simple"

fn _build_sources(target: OsTarget) -> [text]:
    if _is_ssh_live_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/simple_os"]
    if _is_x86_64_kernel_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/simple_os"]
    if _is_browser_wrapper_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/simple_os"]
    if _is_desktop_wrapper_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/simple_os"]
    if _is_gui_engine2d_wrapper_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/simple_os"]
    if _is_js_browser_runtime_probe_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/simple_os"]
    if _is_fs_wrapper_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/simple_os"]
    if _is_riscv64_fs_exec_target(target):
        return ["build/os/generated", "examples/simple_os/arch/riscv64"]
    if _is_riscv64_hosted_target(target):
        return ["build/os/generated", "src", "examples"]
    if _is_riscv32_fs_exec_target(target):
        return ["build/os/generated", "examples/simple_os/arch/riscv32"]
    ["build/os/generated", "src", "examples"]

fn _build_env_prefix(target: OsTarget, objcopy_prefix: text) -> text:
    var envs: [text] = []
    if _is_x86_64_kernel_target(target) or _uses_baremetal_wrapper_profile(target):
        envs.push("SIMPLE_BOOTSTRAP=1")
        envs.push("SIMPLE_LIB=\"$(pwd)/src\"")
    if _is_arm_fs_exec_target(target):
        envs.push("SIMPLE_BOOT_MINIMAL=1")
        envs.push("SIMPLE_ALLOW_FREESTANDING_STUBS=1")
        envs.push("SIMPLE_LIB=\"$(pwd)/src\"")
    if _is_riscv_fs_exec_target(target) or _is_riscv64_hosted_target(target):
        envs.push("SIMPLE_BOOT_MINIMAL=1")
    if _needs_freestanding_stub_env(target):
        envs.push("SIMPLE_ALLOW_FREESTANDING_STUBS=1")
    envs.push("SIMPLE_OS_LOG_MODE={_os_build_log_mode()}")
    if objcopy_prefix != "":
        envs.push("PATH=\"{objcopy_prefix}:$PATH\"")
    envs.join(" ")

fn _is_ssh_live_target(target: OsTarget) -> bool:
    target.entry == "examples/simple_os/arch/x86_64/ssh_live_entry.spl"

fn _ssh_live_build_marker_value(backend: text) -> text:
    "ssh-live-build:{backend}:{_now_ms()}"

fn _ssh_live_build_marker_path() -> text:
    "build/os/generated/ssh_live_build_marker.spl"

fn _ssh_live_build_marker_source(marker: text) -> text:
    "pub fn ssh_live_build_marker() -> text:\n" +
        "    \"" + marker + "\"\n"

fn _simpleos_log_config_path() -> text:
    "build/os/generated/generated/simpleos_log_config.spl"

fn _legacy_simpleos_log_config_path() -> text:
    "build/os/generated/lib/simpleos_log_config.spl"

fn _simpleos_log_config_source(enabled: bool) -> text:
    val default_value = if enabled: "true" else: "false"
    "val SIMPLEOS_LOG_COMPILED: bool = {default_value}\n" +
        "\n" +
        "fn simpleos_log_compile_enabled() -> bool:\n" +
        "    SIMPLEOS_LOG_COMPILED\n" +
        "\n" +
        "fn simpleos_log_compile_mode_name() -> text:\n" +
        "    if SIMPLEOS_LOG_COMPILED:\n" +
        "        return \"on\"\n" +
        "    \"off\"\n"

fn _prepare_build_output(target: OsTarget, build_marker: text) -> bool:
    if rt_file_exists(target.output):
        if not rt_file_delete(target.output):
            print "[build] could not remove stale artifact: {target.output}"
            return false
    if rt_file_exists(_legacy_simpleos_log_config_path()):
        rt_file_delete(_legacy_simpleos_log_config_path())
    if not rt_dir_create_all("build/os/generated/generated"):
        print "[build] could not create build/os/generated/generated"
        return false
    if not rt_file_write_text(_simpleos_log_config_path(), _simpleos_log_config_source(_os_build_log_mode() == "on")):
        print "[build] could not write SimpleOS log compile config"
        return false
    if _is_ssh_live_target(target):
        if not rt_file_write_text(_ssh_live_build_marker_path(), _ssh_live_build_marker_source(build_marker)):
            print "[build] could not write SSH live build marker"
            return false
        if not rt_env_set("SIMPLE_SSH_LIVE_BUILD_MARKER", build_marker):
            print "[build] could not export SIMPLE_SSH_LIVE_BUILD_MARKER"
            return false
    true

fn _cleanup_generated_build_helpers(build_marker: text):
    if rt_file_exists(_simpleos_log_config_path()):
        rt_file_delete(_simpleos_log_config_path())
    if build_marker != "" and rt_file_exists(_ssh_live_build_marker_path()):
        rt_file_delete(_ssh_live_build_marker_path())
    if build_marker != "":
        rt_env_set("SIMPLE_SSH_LIVE_BUILD_MARKER", "")

fn _restore_build_env(old_bootstrap: text, old_lib: text, old_boot_minimal: text, old_stub_env: text, old_log_mode: text, old_path: text, old_build_marker: text):
    rt_env_set("SIMPLE_BOOTSTRAP", old_bootstrap)
    rt_env_set("SIMPLE_LIB", old_lib)
    rt_env_set("SIMPLE_BOOT_MINIMAL", old_boot_minimal)
    rt_env_set("SIMPLE_ALLOW_FREESTANDING_STUBS", old_stub_env)
    rt_env_set("SIMPLE_OS_LOG_MODE", old_log_mode)
    rt_env_set("PATH", old_path)
    rt_env_set("SIMPLE_SSH_LIVE_BUILD_MARKER", old_build_marker)

fn _apply_build_env(target: OsTarget, objcopy_prefix: text) -> bool:
    val cwd = rt_env_cwd()
    if _is_x86_64_kernel_target(target) or _uses_baremetal_wrapper_profile(target):
        if not rt_env_set("SIMPLE_BOOTSTRAP", "1"):
            return false
        if not rt_env_set("SIMPLE_LIB", "{cwd}/src"):
            return false
    if _is_arm_fs_exec_target(target):
        if not rt_env_set("SIMPLE_BOOT_MINIMAL", "1"):
            return false
        if not rt_env_set("SIMPLE_ALLOW_FREESTANDING_STUBS", "1"):
            return false
        if not rt_env_set("SIMPLE_LIB", "{cwd}/src"):
            return false
    if _is_riscv_fs_exec_target(target) or _is_riscv64_hosted_target(target):
        if not rt_env_set("SIMPLE_BOOT_MINIMAL", "1"):
            return false
    if _needs_freestanding_stub_env(target):
        if not rt_env_set("SIMPLE_ALLOW_FREESTANDING_STUBS", "1"):
            return false
    if not rt_env_set("SIMPLE_OS_LOG_MODE", _os_build_log_mode()):
        return false
    if objcopy_prefix != "":
        val old_path = rt_env_get("PATH") ?? ""
        if old_path == "":
            if not rt_env_set("PATH", objcopy_prefix):
                return false
        else:
            if not rt_env_set("PATH", "{objcopy_prefix}:{old_path}"):
                return false
    true

fn _needs_elf32_wrap(target: OsTarget) -> bool:
    _uses_baremetal_wrapper_profile(target)

fn _uses_baremetal_wrapper_profile(target: OsTarget) -> bool:
    _is_browser_wrapper_target(target) or _is_desktop_wrapper_target(target) or _is_gui_engine2d_wrapper_target(target) or _is_js_browser_runtime_probe_target(target) or _is_fs_wrapper_target(target)

fn _needs_freestanding_stub_env(target: OsTarget) -> bool:
    _is_x86_64_kernel_target(target) or _is_desktop_wrapper_target(target) or _is_gui_engine2d_wrapper_target(target) or _is_js_browser_runtime_probe_target(target) or _is_fs_wrapper_target(target)

fn _is_x86_64_kernel_target(target: OsTarget) -> bool:
    target.entry == "examples/simple_os/arch/x86_64/os_entry.spl"

fn _is_browser_wrapper_target(target: OsTarget) -> bool:
    target.entry == "examples/simple_os/arch/x86_64/browser_soft_entry.spl" or
        target.entry == "examples/simple_os/arch/x86_64/browser_probe_entry.spl" or
        target.entry == "examples/simple_os/arch/x86_64/gui_entry_browser.spl"

fn _is_desktop_wrapper_target(target: OsTarget) -> bool:
    target.entry == "examples/simple_os/arch/x86_64/desktop_e2e_entry.spl" or
        target.entry == "examples/simple_os/arch/x86_64/desktop_probe_entry.spl" or
        target.entry == "examples/simple_os/arch/x86_64/ssh_live_entry.spl" or
        target.entry == "examples/simple_os/arch/x86_64/ssh_x25519_probe_entry.spl" or
        target.entry == "examples/simple_os/arch/x86_64/sys_gui_008_entry.spl"

fn _is_gui_engine2d_wrapper_target(target: OsTarget) -> bool:
    target.entry == "examples/simple_os/arch/x86_64/gui_entry.spl" or
        target.entry == "examples/simple_os/arch/x86_64/gui_entry_engine2d.spl" or
        target.entry == "examples/simple_os/arch/x86_64/gui_entry_engine2d_min.spl" or
        target.entry == "examples/simple_os/arch/x86_64/gui_engine2d_primitives_entry.spl" or
        target.entry == "examples/simple_os/arch/x86_64/gui_entry_engine2d_virtio.spl"

fn _is_js_browser_runtime_probe_target(target: OsTarget) -> bool:
    target.entry == "examples/simple_os/arch/x86_64/js_runtime_probe_entry.spl" or
        target.entry == "examples/simple_os/arch/x86_64/browser_runtime_probe_entry.spl" or
        target.entry == "examples/simple_os/arch/x86_64/js_env_stack_probe_entry.spl" or
        target.entry == "examples/simple_os/arch/x86_64/js_object_store_probe_entry.spl" or
        target.entry == "examples/simple_os/arch/x86_64/js_runtime_browser_state_probe_entry.spl"

fn _is_fs_wrapper_target(target: OsTarget) -> bool:
    target.entry == "examples/simple_os/arch/x86_64/fs_test_entry.spl"

fn _is_arm_fs_exec_target(target: OsTarget) -> bool:
    target.entry == "examples/simple_os/arch/arm64/fs_exec_entry.spl" or
        target.entry == "examples/simple_os/arch/arm32/fs_exec_entry.spl"

fn _is_riscv64_fs_exec_target(target: OsTarget) -> bool:
    target.entry == "examples/simple_os/arch/riscv64/smoke_entry.spl" and
        target.output == "build/os/simpleos_riscv64_smf_fs.elf"

fn _is_riscv32_fs_exec_target(target: OsTarget) -> bool:
    target.entry == "examples/simple_os/arch/riscv32/smoke_entry.spl" and
        target.output == "build/os/simpleos_riscv32_smf_fs.elf"

fn _is_riscv64_hosted_target(target: OsTarget) -> bool:
    target.entry == "examples/simple_os/arch/riscv64/hosted_entry.spl" and
        target.output == "build/os/simpleos_riscv64_hosted.elf"

fn _is_riscv_fs_exec_target(target: OsTarget) -> bool:
    _is_riscv64_fs_exec_target(target) or _is_riscv32_fs_exec_target(target)

# ===========================================================================
# QEMU Command Construction
# ===========================================================================

fn build_qemu_command(target: OsTarget) -> [text]:
    build_qemu_command_with_options(target, qemu_run_options_default())

fn verify_qemu_formal_output(arch: Architecture, output: text) -> Result<text, text>:
    match arch:
        Architecture.Riscv64:
            verify_rv64_qemu_user_proof_contract(output)
        _:
            Ok("no formal qemu contract for {arch_display_name(arch)}")

fn build_qemu_command_with_options(target: OsTarget, options: QemuRunOptions) -> [text]:
    """Returns QEMU command line as a list of strings.

    Includes machine, cpu, memory, serial routing, display mode, no reboot,
    optional BIOS flags, kernel path, and extra architecture-specific flags.
    """
    var args: [text] = []

    # QEMU system binary
    args.push(target.qemu_system)

    for hardening_arg in qemu_target_hardening_args(target):
        args.push(hardening_arg)

    # Machine and CPU
    args.push("-machine")
    args.push(target.qemu_machine)
    args.push("-cpu")
    args.push(target.qemu_cpu)

    # Memory
    args.push("-m")
    args.push(target.qemu_memory)

    # Serial routing:
    # - headless/test lanes keep serial on stdio
    # - GUI lanes hide boot logs for a macOS-style windowed startup
    args.push("-serial")
    if target.gui_mode and not options.debug_gui_serial:
        args.push("none")
    else:
        args.push("stdio")

    # Display mode: headless for text-mode, show window for GUI
    if not target.gui_mode:
        args.push("-display")
        args.push("none")

    # Don't reboot on crash
    args.push("-no-reboot")

    # BIOS/firmware (OpenSBI uses "default", empty means no -bios flag)
    if target.qemu_bios == "default":
        args.push("-bios")
        args.push("default")
    elif target.qemu_bios != "":
        args.push("-bios")
        args.push(target.qemu_bios)

    # Kernel ELF
    args.push("-kernel")
    args.push(target.output)

    # Extra architecture-specific flags
    for extra in target.qemu_extra:
        args.push(extra)

    args

fn qemu_target_hardening_args(target: OsTarget) -> [text]:
    """Return host-side QEMU hardening flags for a target launch.

    These flags avoid ambient host/user QEMU configuration and disable the
    interactive HMP monitor. x86_64 lanes that do not intentionally attach a
    netdev also disable networking explicitly so future QEMU defaults cannot
    add a host-facing device by accident.
    """
    var args: [text] = []
    if _target_uses_qemu_x86_64(target):
        args.push("-no-user-config")
        args.push("-monitor")
        args.push("none")
        if not _qemu_extra_enables_network(target.qemu_extra):
            args.push("-net")
            args.push("none")
    args

fn qemu_scenario_hardening_args(scenario: QemuScenario) -> [text]:
    """Return host-side QEMU hardening flags for a named scenario."""
    var args: [text] = []
    if scenario.arch == Architecture.X86_64:
        args.push("-no-user-config")
        args.push("-monitor")
        args.push("none")
        if not _qemu_extra_enables_network(scenario.qemu_extra):
            args.push("-net")
            args.push("none")
    args

fn _target_uses_qemu_x86_64(target: OsTarget) -> bool:
    target.arch == Architecture.X86_64 and target.qemu_system == "qemu-system-x86_64"

fn _qemu_extra_enables_network(qemu_extra: [text]) -> bool:
    for arg in qemu_extra:
        if arg == "-netdev" or arg == "-nic" or arg == "-net":
            return true
        if arg.contains("virtio-net") or arg.contains("e1000") or arg.contains("rtl8139"):
            return true
        if arg.contains("hostfwd="):
            return true
    false

# ===========================================================================
# Run
# ===========================================================================

fn run_os(target: OsTarget) -> bool:
    run_os_with_options(target, qemu_run_options_default())

fn run_os_debug_gui(target: OsTarget) -> bool:
    run_os_with_options(target, qemu_run_options_debug_gui())

fn run_os_with_options(target: OsTarget, options: QemuRunOptions) -> bool:
    """Runs QEMU with the built kernel for the given target.

    Checks that the binary exists, then spawns QEMU. Returns true on success.
    """
    if not rt_file_exists(target.output):
        print "[run] ERROR: kernel binary not found: {target.output}"
        print "[run] Run 'bin/simple os build --arch={arch_display_name(target.arch)}' first"
        return false
    val cmd_parts = build_qemu_command_with_options(target, options)
    val qemu_bin = cmd_parts[0]
    val qemu_args = cmd_parts.slice(1)
    if target.gui_mode and options.debug_gui_serial:
        print "[run] GUI debug lane enabled: serial output is attached to stdio"
    print "[run] {arch_display_name(target.arch)}: {cmd_parts.join(" ")}"
    val timeout: i64 = if target.gui_mode: 600000 else: 30000
    val (stdout, stderr, exit_code) = rt_process_run_timeout(qemu_bin, qemu_args, timeout)
    if stdout != "":
        print "[run] serial output:\n{stdout}"
    if stderr != "":
        print "[run] stderr:\n{stderr}"
    val success = is_qemu_success(target, exit_code)
    if not success:
        print "[run] FAILED (exit code {exit_code})"
    success

# ===========================================================================
# Test
# ===========================================================================

fn test_os(target: OsTarget, timeout_ms: u64) -> bool:
    """Runs QEMU and checks serial output for 'SimpleOS' within timeout.

    Returns true if the kernel boots, prints the expected banner, and exits successfully.
    """
    if not rt_file_exists(target.output):
        print "[test] ERROR: kernel binary not found: {target.output}"
        print "[test] Run 'bin/simple os build --arch={arch_display_name(target.arch)}' first"
        return false
    val cmd_parts = build_qemu_command(target)
    val qemu_bin = cmd_parts[0]
    val qemu_args = cmd_parts.slice(1)
    print "[test] {arch_display_name(target.arch)} (timeout: {timeout_ms}ms): {cmd_parts.join(" ")}"
    val (stdout, stderr, exit_code) = rt_process_run_timeout(qemu_bin, qemu_args, timeout_ms as i64)
    val serial_output = stdout + stderr
    print "[test] serial output:\n{serial_output}"
    val has_banner = serial_output.contains("SimpleOS")
    val success = has_banner and is_qemu_success(target, exit_code)
    if not has_banner:
        print "[test] FAILED: 'SimpleOS' banner not found in serial output"
    if not is_qemu_success(target, exit_code):
        print "[test] FAILED: unexpected exit code {exit_code}"
    success

# ===========================================================================
# Batch Operations
# ===========================================================================

fn run_all_architectures():
    """Build and run SimpleOS for all 6 architectures."""
    val targets = get_all_targets()
    for target in targets:
        print "=== {arch_display_name(target.arch)} ==="
        val built = build_os(target)
        if built:
            run_os(target)
        else:
            print "[error] Build failed for {arch_display_name(target.arch)}, skipping run"
        print ""

fn test_all_architectures() -> bool:
    """Build and test all 6 architectures, report results.

    Returns true only if all architectures pass the boot smoke test.
    """
    val targets = get_all_targets()
    var all_passed = true
    var passed_count: u64 = 0
    var failed_count: u64 = 0
    val timeout_ms: u64 = 10000

    print "SimpleOS Boot Smoke Test — All Architectures"
    print "============================================="
    print ""

    for target in targets:
        val name = arch_display_name(target.arch)
        print "--- {name} ---"

        val built = build_os(target)
        if not built:
            print "[FAIL] {name}: build failed"
            all_passed = false
            failed_count = failed_count + 1
            continue

        val ok = test_os(target, timeout_ms)
        if ok:
            print "[PASS] {name}"
            passed_count = passed_count + 1
        else:
            print "[FAIL] {name}: boot test failed"
            all_passed = false
            failed_count = failed_count + 1
        print ""

    print "============================================="
    print "Results: {passed_count} passed, {failed_count} failed"

    all_passed

# ===========================================================================
# QEMU Scenarios — named device/machine configurations for testing
# ===========================================================================

class QemuScenario:
    """Named QEMU configuration for specific test/development scenarios.

    Instead of hardcoding QEMU flags per target, scenarios let tests
    bind to specific machine shapes (e.g., NVMe lab, GPU test, network).
    """
    name: text
    arch: Architecture
    machine: text
    cpu: text
    memory: text
    qemu_extra: [text]
    gui_mode: bool
    description: text

pub fn scenario_lane_kind(scenario: QemuScenario) -> SimpleOsLaneKind:
    """Classify a QEMU scenario into the shared lane model."""
    if val lane = _catalog_lane_for_scenario(scenario):
        return lane.lane_kind
    if _is_arm_fs_exec_scenario(scenario):
        return simpleos_platform_qemu_acceptance_lane(_arm_fs_exec_platform_name(scenario.arch)).lane_kind
    if scenario.name == "riscv64-hosted":
        return simpleos_platform_qemu_acceptance_lane("riscv64").lane_kind
    if _is_riscv_fs_exec_scenario(scenario):
        return SimpleOsLaneKind.FsExec
    if scenario.name == "x64-nvme-fat32":
        return SimpleOsLaneKind.FsExec
    if scenario.name == "x64-desktop-disk" or scenario.name == "x64-desktop-uefi" or scenario.name == "x64-ssh":
        return SimpleOsLaneKind.HostedCompileSmoke
    SimpleOsLaneKind.Smoke

fn _acceptance_lane_scenario(platform_name: text, description: text) -> QemuScenario:
    val lane = simpleos_platform_qemu_acceptance_lane(platform_name)
    QemuScenario(
        name: lane.name,
        arch: simpleos_platform_arch(platform_name),
        machine: simpleos_platform_qemu_machine(platform_name),
        cpu: simpleos_platform_qemu_cpu(platform_name),
        memory: lane.qemu_memory,
        qemu_extra: lane.qemu_extra,
        gui_mode: false,
        description: description
    )

fn _scenario_from_target(name: text, target: OsTarget, description: text) -> QemuScenario:
    QemuScenario(
        name: name,
        arch: target.arch,
        machine: target.qemu_machine,
        cpu: target.qemu_cpu,
        memory: target.qemu_memory,
        qemu_extra: target.qemu_extra,
        gui_mode: target.gui_mode,
        description: description
    )

fn _arm_fs_exec_platform_name(arch: Architecture) -> text:
    if arch == Architecture.Arm64:
        return "arm64"
    "arm32"

fn _riscv_fs_exec_platform_name(arch: Architecture) -> text:
    if arch == Architecture.Riscv64:
        return "riscv64"
    "riscv32"

fn _arm_fs_exec_scenario(arch: Architecture, description: text) -> QemuScenario:
    _acceptance_lane_scenario(_arm_fs_exec_platform_name(arch), description)

fn _riscv_fs_exec_target(arch: Architecture) -> OsTarget:
    if arch == Architecture.Riscv64:
        return get_riscv64_fs_exec_target()
    get_riscv32_fs_exec_target()

fn _riscv_fs_exec_scenario(arch: Architecture, description: text) -> QemuScenario:
    _scenario_from_target(_riscv_fs_exec_scenario_name(arch), _riscv_fs_exec_target(arch), description)

fn _desktop_disk_scenario_target(name: text) -> OsTarget?:
    if name == "x64-ssh":
        return get_ssh_live_target()
    if name == "x64-desktop-test" or name == "x64-desktop-disk" or name == "x64-desktop-uefi":
        return get_desktop_browser_target()
    if name == "x64-wm-simple-web-check":
        return get_wm_simple_web_check_target()
    nil

fn _desktop_scenario_timeout_ms(name: text) -> u64?:
    if name == "x64-desktop-uefi":
        return 180000
    if name == "x64-desktop-test" or name == "x64-ssh" or name == "x64-desktop-disk" or name == "x64-wm-simple-web-check":
        return 120000
    nil

fn _ensure_desktop_scenario_media(name: text) -> bool?:
    if name == "x64-nvme-fat32":
        return ensure_fs_test_disk_image()
    if name == "x64-ssh" or name == "x64-desktop-disk":
        return ensure_desktop_disk_image()
    if name != "x64-desktop-uefi":
        return nil
    if ovmf_code_path() == "":
        print "[ensure_scenario_media] OVMF firmware not found; set SIMPLEOS_OVMF_CODE to an x86_64 OVMF_CODE.fd path"
        return false
    if desktop_uefi_bootloader_path() == "":
        print "[ensure_scenario_media] UEFI desktop bootloader not found; set SIMPLEOS_UEFI_BOOTLOADER to EFI/BOOT/BOOTX64.EFI"
        return false
    if not rt_file_exists(desktop_uefi_disk_image_path()):
        print "[ensure_scenario_media] UEFI desktop disk image missing; call ensure_desktop_uefi_boot_image(kernel_path) first"
        return false
    true

