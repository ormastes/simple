fn get_all_scenarios() -> [QemuScenario]:
    """Returns all defined QEMU scenarios."""
    [
        scenario_rv64_base(),
        scenario_rv64_dtb_pci(),
        scenario_x64_pci_lab(),
        scenario_x64_nvme(),
        scenario_x64_net_user(),
        scenario_x64_gpu_2d(),
        scenario_x64_gui(),
        scenario_x64_nvme_fat32(),
        scenario_x64_full_stack(),
        scenario_x64_desktop_test()
    ]

fn get_scenario(name: text) -> QemuScenario?:
    """Look up a scenario by name."""
    for s in get_all_scenarios():
        if s.name == name:
            return s
    nil

fn build_scenario_command(scenario: QemuScenario, kernel_path: text) -> [text]:
    """Build QEMU command line from a scenario."""
    val qemu_bin = match scenario.arch:
        Architecture.X86_64: "qemu-system-x86_64"
        Architecture.Riscv64: "qemu-system-riscv64"
        Architecture.Riscv32: "qemu-system-riscv32"
        Architecture.Arm64: "qemu-system-aarch64"
        Architecture.Arm32: "qemu-system-arm"
        _: "qemu-system-x86_64"

    var args: [text] = [qemu_bin]
    args.push("-machine")
    args.push(scenario.machine)
    args.push("-cpu")
    args.push(scenario.cpu)
    args.push("-m")
    args.push(scenario.memory)
    args.push("-serial")
    args.push("stdio")
    if not scenario.gui_mode:
        args.push("-display")
        args.push("none")
    args.push("-no-reboot")
    args.push("-kernel")
    args.push(kernel_path)
    for extra in scenario.qemu_extra:
        args.push(extra)
    args
