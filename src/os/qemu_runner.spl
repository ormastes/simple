        "grep -a -q 'SMF' \"{img_path}\"; " +
        "fi"

fn _desktop_uefi_disk_image_has_required_tool_apps(img_path: text) -> bool:
    """Validate seeded filesystem-loaded tool app payloads in the desktop UEFI FAT image."""
    val cmd = desktop_uefi_disk_image_tool_app_validation_command(img_path)
    val (_stdout, _stderr, exit_code) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 30000)
    exit_code == 0

fn ensure_desktop_uefi_boot_image(kernel_path: text) -> bool:
    """Rebuild the desktop UEFI FAT32 image with the compiled kernel and EFI fallback loader."""
    if ovmf_code_path() == "":
        print "[ensure_desktop_uefi_boot_image] OVMF firmware not found; set SIMPLEOS_OVMF_CODE to an x86_64 OVMF_CODE.fd path"
        return false
    if not rt_file_exists(kernel_path):
        print "[ensure_desktop_uefi_boot_image] kernel image not found: {kernel_path}"
        return false
    val img_path = desktop_uefi_disk_image_path()
    print "[ensure_desktop_uefi_boot_image] rebuilding {img_path} with UEFI kernel {kernel_path}"
    val (stdout, stderr, exit_code) = rt_process_run_timeout(
        "/bin/sh", desktop_uefi_disk_make_script_args(img_path, kernel_path), 120000)
    if stdout != "":
        print "[ensure_desktop_uefi_boot_image] stdout:\n{stdout}"
    if stderr != "":
        print "[ensure_desktop_uefi_boot_image] stderr:\n{stderr}"
    if exit_code != 0:
        print "[ensure_desktop_uefi_boot_image] make_os_disk.shs exited {exit_code}"
        return false
    if not desktop_uefi_boot_media_ready():
        print "[ensure_desktop_uefi_boot_image] UEFI boot media was not materialized"
        return false
    if not _desktop_uefi_disk_image_has_required_tool_apps(img_path):
        print "[ensure_desktop_uefi_boot_image] UEFI disk image missing seeded tool app payloads or SMF wrappers"
        return false
    true

pub fn board_bundle_command(platform_name: text, kernel_path: text, output_path: text) -> [text]:
    """Build the host-side command for a representative board packaging lane."""
    if platform_name == "x86_64":
        return ["/bin/sh"] + desktop_uefi_disk_make_script_args(output_path, kernel_path)
    if platform_name == "arm64":
        return ["/bin/sh", "scripts/make_os_disk.shs", "64", output_path, "", "arm64"]
    if platform_name == "riscv64":
        return ["bin/simple", "run", "src/hardware/fpga_linux/generate_riscv_fpga_bundle.spl", "--", "--board=mlk_s02_100t", output_path]
    []

fn _board_bundle_expected_artifact(platform_name: text, output_path: text) -> text:
    if platform_name == "riscv64":
        return output_path + "/board_linux_boot_products.sdn"
    output_path

fn _board_bundle_output_path(platform_name: text) -> text:
    if platform_name == "x86_64":
        return desktop_uefi_disk_image_path()
    if platform_name == "arm64":
        return simpleos_platform_disk_image_output("arm64")
    if platform_name == "riscv64":
        return "build/os/board-riscv64-mlk_s02_100t"
    ""

pub fn board_lane_test_command(platform_name: text, output_path: text) -> [text]:
    """Build the host-side command for a representative board execution lane."""
    if platform_name == "riscv64":
        return [
            "/bin/sh",
            "scripts/mlk_s02_100t_generated_linux.shs",
            "--arch=rv64",
            "--bundle-root={output_path}",
            "--product-root={output_path}/products"
        ]
    []

pub fn ensure_board_bundle(platform_name: text, kernel_path: text, output_path: text) -> bool:
    """Materialize the representative board bundle for a first-class platform."""
    if simpleos_platform_board_lane(platform_name) == nil:
        print "[ensure_board_bundle] no representative board lane declared for {platform_name}"
        return false
    if platform_name == "x86_64":
        if output_path == "" or output_path == desktop_uefi_disk_image_path():
            return ensure_desktop_uefi_boot_image(kernel_path)
    val cmd = board_bundle_command(platform_name, kernel_path, output_path)
    if cmd.len() == 0:
        print "[ensure_board_bundle] unsupported board bundle platform: {platform_name}"
        return false
    val timeout_ms = if platform_name == "riscv64": 120000 else: 60000
    val exec_cmd = cmd[0]
    var exec_args: [text] = []
    var i: i64 = 1
    while i < cmd.len() as i64:
        exec_args.push(cmd[i as i32])
        i = i + 1
    val (stdout, stderr, exit_code) = rt_process_run_timeout(exec_cmd, exec_args, timeout_ms)
    if stdout != "":
        print "[ensure_board_bundle] stdout:\n{stdout}"
    if stderr != "":
        print "[ensure_board_bundle] stderr:\n{stderr}"
    if exit_code != 0:
        print "[ensure_board_bundle] command exited {exit_code}"
        return false
    val expected = _board_bundle_expected_artifact(platform_name, output_path)
    if not rt_file_exists(expected):
        print "[ensure_board_bundle] expected artifact missing: {expected}"
        return false
    true

pub fn test_board_lane(platform_name: text, kernel_path: text, output_path: text) -> bool:
    """Run the representative board compile-smoke lane for a first-class platform."""
    if simpleos_platform_board_lane(platform_name) == nil:
        print "[test_board_lane] no representative board lane declared for {platform_name}"
        return false
    val cmd = board_lane_test_command(platform_name, output_path)
    if cmd.len() == 0:
        print "[test_board_lane] board execution lane not implemented for {platform_name}"
        return false
    if not ensure_board_bundle(platform_name, kernel_path, output_path):
        return false
    val exec_cmd = cmd[0]
    var exec_args: [text] = []
    var i: i64 = 1
    while i < cmd.len() as i64:
        exec_args.push(cmd[i as i32])
        i = i + 1
    val timeout_ms = 900000
    val (stdout, stderr, exit_code) = rt_process_run_timeout(exec_cmd, exec_args, timeout_ms)
    if stdout != "":
        print "[test_board_lane] stdout:\n{stdout}"
    if stderr != "":
        print "[test_board_lane] stderr:\n{stderr}"
    if exit_code != 0:
        print "[test_board_lane] command exited {exit_code}"
        return false
    val expected = _board_bundle_expected_artifact(platform_name, output_path)
    if not rt_file_exists(expected):
        print "[test_board_lane] expected artifact missing after board run: {expected}"
        return false
    true

pub fn test_board(platform_name: text) -> bool:
    """Build and run the representative board compile-smoke lane for a platform."""
    if val lane = simpleos_platform_board_lane(platform_name):
        val output_path = _board_bundle_output_path(platform_name)
        if output_path == "":
            print "[test_board] no bundle output path configured for {platform_name}"
            return false
        if board_lane_test_command(platform_name, output_path).len() == 0:
            print "[test_board] board execution lane not implemented for {platform_name}"
            return false
        val target = _lane_to_target(platform_name, lane)
        if not build_os(target):
            return false
        return test_board_lane(platform_name, target.output, output_path)
    print "[test_board] no representative board lane declared for {platform_name}"
    false

fn ensure_fs_test_disk_image() -> bool:
    """Ensure the FAT32 fixture image used by x64-nvme-fat32 exists.

    This is intentionally narrower than ensure_desktop_disk_image(): the
    filesystem contract needs the canonical fixture files, while desktop lanes
    need the resident app manifests and may prefer release-built media.
    """
    val img_path = fs_test_disk_image_path()
    if rt_file_exists(img_path) and _fs_test_disk_image_has_required_fixtures(img_path):
        return true
    print "[ensure_fs_test_disk_image] {img_path} missing or incomplete, invoking scripts/make_os_disk.shs"
    val (stdout, stderr, exit_code) = rt_process_run_timeout(
        "/bin/sh", ["scripts/make_os_disk.shs", "64", img_path], 60000)
    if stdout != "":
        print "[ensure_fs_test_disk_image] stdout:\n{stdout}"
    if stderr != "":
        print "[ensure_fs_test_disk_image] stderr:\n{stderr}"
    if exit_code != 0:
        print "[ensure_fs_test_disk_image] make_os_disk.shs exited {exit_code}"
        return false
    if not rt_file_exists(img_path):
        return false
    if not _fs_test_disk_image_has_required_fixtures(img_path):
        print "[ensure_fs_test_disk_image] image exists but required fixture markers are missing"
        return false
    true

fn ensure_arm_fs_exec_disk_image(arch: Architecture) -> bool:
    """Ensure the ARM FAT32 image has the SMF executable acceptance fixture."""
    _ensure_catalog_fs_exec_disk_image(
        "ensure_arm_fs_exec_disk_image",
        "ARM SMF markers are missing",
        arm_fs_exec_disk_image_path(arch),
        arch_display_name(arch),
        _arm_fs_exec_platform_name(arch),
        arch
    )

fn ensure_riscv_fs_exec_disk_image(arch: Architecture) -> bool:
    """Ensure the RISC-V FAT32 image has SMF CLI and WM GUI acceptance fixtures."""
    _ensure_catalog_fs_exec_disk_image(
        "ensure_riscv_fs_exec_disk_image",
        "RISC-V SMF markers are missing",
        riscv_fs_exec_disk_image_path(arch),
        arch_display_name(arch),
        _riscv_fs_exec_platform_name(arch),
        arch
    )

fn _fs_test_disk_image_has_required_fixtures(img_path: text) -> bool:
    val cmd =
        "if command -v mtype >/dev/null 2>&1; then " +
        "mtype -i \"{img_path}\" ::/HELLO.TXT 2>/dev/null | grep -q 'Hello from SimpleOS' && " +
        "mtype -i \"{img_path}\" ::/NUMBERS.TXT 2>/dev/null | grep -q '^5$' && " +
        "mtype -i \"{img_path}\" ::/HELLO.SPL 2>/dev/null | grep -q 'fn main'; " +
        "else " +
        "grep -a -q 'Hello from SimpleOS' \"{img_path}\" && " +
        "grep -a -q 'fn main' \"{img_path}\"; " +
        "fi"
    val (_stdout, _stderr, exit_code) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 5000)
    exit_code == 0

fn _ensure_catalog_fs_exec_disk_image(
    log_prefix: text,
    missing_message: text,
    img_path: text,
    arch_label: text,
    platform_name: text,
    arch: Architecture
) -> bool:
    if rt_file_exists(img_path) and _catalog_fs_exec_disk_image_has_required_smf(img_path, platform_name, arch):
        return true
    print "[{log_prefix}] {img_path} missing or incomplete, invoking scripts/make_os_disk.shs for {arch_label}"
    val (stdout, stderr, exit_code) = rt_process_run_timeout(
        "/bin/sh", ["scripts/make_os_disk.shs", "64", img_path, "", arch_label], 60000)
    if stdout != "":
        print "[{log_prefix}] stdout:\n{stdout}"
    if stderr != "":
        print "[{log_prefix}] stderr:\n{stderr}"
    if exit_code != 0:
        print "[{log_prefix}] make_os_disk.shs exited {exit_code}"
        return false
    if not rt_file_exists(img_path):
        return false
    if not _catalog_fs_exec_disk_image_has_required_smf(img_path, platform_name, arch):
        print "[{log_prefix}] image exists but {missing_message}"
        return false
    true

fn _catalog_fs_exec_disk_image_has_required_smf(img_path: text, platform_name: text, arch: Architecture) -> bool:
    if platform_name == "arm64" or platform_name == "arm32":
        return _arm_fs_exec_disk_image_has_required_smf(img_path, arch)
    _riscv_fs_exec_disk_image_has_required_smf(img_path, arch)

fn _staged_tool_app_smf_name(app_name: text) -> text:
    if app_name == "simple_compiler":
        return "SCOMPSMF"
    if app_name == "simple_loader":
        return "SLOADSMF"
    if app_name == "simple_interpreter":
        return "SINTSMF"
    if app_name == "llvm":
        return "LLVMSMF"
    if app_name == "clang":
        return "CLANGSMF"
    if app_name == "rust":
        return "RUSTSMF"
    if app_name == "hello_world":
        return "HELLOSMF"
    if app_name == "simple_browser":
        return "BROWSMF"
    ""

fn _native_tool_version_path(app_name: text) -> text:
    if app_name == "llvm":
        return "/SYS/LLVMVER.TXT"
    if app_name == "clang":
        return "/SYS/CLANGVER.TXT"
    if app_name == "rust":
        return "/SYS/RUSTVER.TXT"
    ""

fn _native_tool_version_pattern(app_name: text) -> text:
    if app_name == "llvm":
        return "standalone app"
    if app_name == "clang":
        return "clang version"
    if app_name == "rust":
        return "standalone app"
    ""

fn _native_tool_pipeline_path(app_name: text) -> text:
    if app_name == "llvm":
        return "/usr/share/simpleos/toolchain/llvm/pipeline.step"
    if app_name == "clang":
        return "/usr/share/simpleos/toolchain/clang/pipeline.step"
    if app_name == "rust":
        return "/usr/share/simpleos/toolchain/rust/pipeline.step"
    ""

fn _native_tool_pipeline_pattern(app_name: text) -> text:
    if app_name == "llvm":
        return "pipeline=compile-pipeline-step"
    if app_name == "clang":
        return "pipeline=compile-pipeline-step"
    if app_name == "rust":
        return "pipeline=build-pipeline-step"
    ""

fn _catalog_lane_disk_image_has_required_staged_apps(img_path: text, lane: SimpleOsLaneContract) -> bool:
    var mtype_checks: [text] = []
    var grep_checks: [text] = []
    var has_native_tool = false
    for app in lane.staged_apps:
        val smf_name = _staged_tool_app_smf_name(app.app_name)
        if smf_name != "":
            mtype_checks.push("mtype -i \"{img_path}\" ::/SYS/APPS/{smf_name}.SMF 2>/dev/null | strings | grep -q '{app.app_path}'")
            mtype_checks.push("mtype -i \"{img_path}\" ::/SYS/APPS/{smf_name}.SMF 2>/dev/null | grep -a -q 'SMF'")
            grep_checks.push("grep -a -q '{smf_name}' \"{img_path}\"")
        grep_checks.push("grep -a -q '{app.app_path}' \"{img_path}\"")
        if app.native_launch_mode != "":
            has_native_tool = true
            mtype_checks.push("mtype -i \"{img_path}\" ::{app.manifest_path} 2>/dev/null | grep -q 'entry_app={app.app_path}'")
            mtype_checks.push("mtype -i \"{img_path}\" ::{app.manifest_path} 2>/dev/null | grep -q 'lane={lane.name}'")
            mtype_checks.push("mtype -i \"{img_path}\" ::{app.manifest_path} 2>/dev/null | grep -q 'mode={app.native_launch_mode}'")
            mtype_checks.push("mtype -i \"{img_path}\" ::{app.manifest_path} 2>/dev/null | grep -q 'status={app.native_launch_status}'")
            grep_checks.push("grep -a -q 'entry_app={app.app_path}' \"{img_path}\"")
            grep_checks.push("grep -a -q 'lane={lane.name}' \"{img_path}\"")
            grep_checks.push("grep -a -q 'mode={app.native_launch_mode}' \"{img_path}\"")
            grep_checks.push("grep -a -q 'status={app.native_launch_status}' \"{img_path}\"")
            val version_path = _native_tool_version_path(app.app_name)
            val version_pattern = _native_tool_version_pattern(app.app_name)
            if version_path != "" and version_pattern != "":
                mtype_checks.push("mtype -i \"{img_path}\" ::{version_path} 2>/dev/null | grep -q '{version_pattern}'")
                grep_checks.push("grep -a -q '{version_pattern}' \"{img_path}\"")
            val pipeline_path = _native_tool_pipeline_path(app.app_name)
            val pipeline_pattern = _native_tool_pipeline_pattern(app.app_name)
            if pipeline_path != "" and pipeline_pattern != "":
                mtype_checks.push("mtype -i \"{img_path}\" ::{pipeline_path} 2>/dev/null | grep -q '{pipeline_pattern}'")
                mtype_checks.push("mtype -i \"{img_path}\" ::{app.manifest_path} 2>/dev/null | grep -q 'proof_pipeline={pipeline_path}'")
                grep_checks.push("grep -a -q '{pipeline_path}' \"{img_path}\"")
            grep_checks.push("grep -a -q '{app.app_path} status={app.native_launch_status}' \"{img_path}\"")
    if has_native_tool:
        mtype_checks.push("mtype -i \"{img_path}\" ::/SYS/TOOLSET.SDN 2>/dev/null | grep -q 'lane = \"{lane.name}\"'")
        grep_checks.push("grep -a -q 'lane = \"{lane.name}\"' \"{img_path}\"")
    if mtype_checks.len() == 0 and grep_checks.len() == 0:
        return true
    val mtype_cmd = if mtype_checks.len() == 0: "true" else: mtype_checks.join(" && ")
    val grep_cmd = if grep_checks.len() == 0: "true" else: grep_checks.join(" && ")
    val cmd =
        "if command -v mtype >/dev/null 2>&1; then " +
        mtype_cmd + "; " +
        "else " +
        grep_cmd + "; " +
        "fi"
    val (_stdout, _stderr, exit_code) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 5000)
    exit_code == 0

fn _arm_fs_exec_disk_image_has_required_smf(img_path: text, arch: Architecture) -> bool:
    val marker = if arch == Architecture.Arm64: "SIMPLEOS_ARM64_HELLO_ELF" else: "SIMPLEOS_ARM32_HELLO_ELF"
    val platform_name = _arm_fs_exec_platform_name(arch)
    val lane_name = _arm_fs_exec_scenario_name(arch)
    val lane = simpleos_platform_qemu_lane(platform_name, lane_name)
    if val resolved_lane = lane:
        val cmd =
            "if command -v mtype >/dev/null 2>&1; then " +
            "mtype -i \"{img_path}\" ::/SYS/APPS/HELLOSMF.SMF 2>/dev/null | grep -a -q '{marker}' && " +
            "mtype -i \"{img_path}\" ::/SYS/APPS/HELLOSMF.SMF 2>/dev/null | grep -a -q 'SMF'; " +
            "else " +
            "grep -a -q '{marker}' \"{img_path}\" && " +
            "grep -a -q 'HELLOSMF' \"{img_path}\" && " +
            "grep -a -q 'SMF' \"{img_path}\"; " +
            "fi"
        val (_stdout, _stderr, exit_code) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 5000)
        return exit_code == 0 and _catalog_lane_disk_image_has_required_staged_apps(img_path, resolved_lane)
    false

fn _riscv_fs_exec_disk_image_has_required_smf(img_path: text, arch: Architecture) -> bool:
    val hello_marker = if arch == Architecture.Riscv64: "SIMPLEOS_RISCV64_HELLO_ELF" else: "SIMPLEOS_RISCV32_HELLO_ELF"
    val gui_marker = if arch == Architecture.Riscv64: "SIMPLEOS_RISCV64_GUI_ELF" else: "SIMPLEOS_RISCV32_GUI_ELF"
    val platform_name = _riscv_fs_exec_platform_name(arch)
    val lane_name = if arch == Architecture.Riscv64: "riscv64-hosted" else: _riscv_fs_exec_scenario_name(arch)
    val lane = simpleos_platform_qemu_lane(platform_name, lane_name)
    if val resolved_lane = lane:
        val cmd =
            "if command -v mtype >/dev/null 2>&1; then " +
            "mtype -i \"{img_path}\" ::/SYS/APPS/HELLOSMF.SMF 2>/dev/null | grep -a -q '{hello_marker}' && " +
            "mtype -i \"{img_path}\" ::/SYS/APPS/BROWSMF.SMF 2>/dev/null | grep -a -q '{gui_marker}' && " +
            "mtype -i \"{img_path}\" ::/SYS/APPS/HELLOSMF.SMF 2>/dev/null | grep -a -q 'SMF'; " +
            "else " +
            "grep -a -q '{hello_marker}' \"{img_path}\" && " +
            "grep -a -q '{gui_marker}' \"{img_path}\" && " +
            "grep -a -q 'HELLOSMF' \"{img_path}\" && " +
            "grep -a -q 'BROWSMF' \"{img_path}\" && " +
            "grep -a -q 'SMF' \"{img_path}\"; " +
            "fi"
        val (_stdout, _stderr, exit_code) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 5000)
        return exit_code == 0 and _catalog_lane_disk_image_has_required_staged_apps(img_path, resolved_lane)
    false

fn ensure_arm_fs_exec_kernel_binary(scenario: QemuScenario, target: OsTarget) -> bool:
    if not _is_arm_fs_exec_scenario(scenario):
        return true
    if scenario.arch == Architecture.Arm32:
        return rt_file_exists(target.output)
    val bin_path = arm_fs_exec_kernel_bin_path(scenario.arch)
    val cmd =
        "if command -v llvm-objcopy >/dev/null 2>&1; then OBJCOPY=llvm-objcopy; " +
        "elif [ -x /opt/homebrew/opt/llvm/bin/llvm-objcopy ]; then OBJCOPY=/opt/homebrew/opt/llvm/bin/llvm-objcopy; " +
        "else echo llvm-objcopy not found >&2; exit 127; fi; " +
        "$OBJCOPY -O binary \"{target.output}\" \"{bin_path}\""
    val (stdout, stderr, exit_code) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 30000)
    if stdout != "":
        print "[ensure_arm_fs_exec_kernel_binary] stdout:\n{stdout}"
    if stderr != "":
        print "[ensure_arm_fs_exec_kernel_binary] stderr:\n{stderr}"
    exit_code == 0 and rt_file_exists(bin_path)

fn scenario_kernel_path(scenario: QemuScenario, target: OsTarget) -> text:
    if scenario.arch == Architecture.Arm32 and _is_arm_fs_exec_scenario(scenario):
        return target.output
    if _is_arm_fs_exec_scenario(scenario):
        return arm_fs_exec_kernel_bin_path(scenario.arch)
    target.output

fn _desktop_disk_image_has_required_manifests(img_path: text) -> bool:
    """Best-effort host-side validation that the disk image is populated.

    The desktop disk lane currently packages plain-text resident manifests
    for the remote-capable desktop apps plus at least one real filesystem-
    backed user ELF marker. Grepping for each marker is lightweight and
    avoids false-positive success on an empty FAT32 image.
    """
    val markers = [
        "browser_demo_remote_main",
        "hello_world_remote_main",
        "file_manager_remote_main",
        "shell_remote_main",
        "editor_remote_main",
        "smux_remote_main"
    ]
    var i: u64 = 0
    while i < markers.len():
        val marker = markers[i]
        val shell_cmd = "grep -a -q '{marker}' \"{img_path}\""
        val (_stdout, _stderr, exit_code) = rt_process_run_timeout("/bin/sh", ["-c", shell_cmd], 5000)
        if exit_code != 0:
            return false
        i = i + 1
    val payload_cmd = "if command -v mtype >/dev/null 2>&1; then " +
        "mtype -i \"{img_path}\" ::/SYS/APPS/hello_world 2>/dev/null | strings | grep -q 'SIMPLEOS_DISK_HELLO_ELF'; " +
        "else grep -a -q 'SIMPLEOS_DISK_HELLO_ELF' \"{img_path}\"; fi"
    val (_payload_stdout, _payload_stderr, payload_exit) = rt_process_run_timeout("/bin/sh", ["-c", payload_cmd], 5000)
    if payload_exit != 0:
        return false
    val ssh_cmd =
        "if command -v mtype >/dev/null 2>&1; then " +
        "mtype -i \"{img_path}\" ::/SYS/APPS/SHELL.APP 2>/dev/null | grep -q 'shell_remote_main' && " +
        "mtype -i \"{img_path}\" ::/SYS/APPS/SMUX.APP 2>/dev/null | grep -q 'smux_remote_main' && " +
        "mtype -i \"{img_path}\" ::/SYS/APPS/SIMPLECLI.CAT 2>/dev/null | grep -q '^info|src/app/info/main.spl|smoke|staged$' && " +
        "mtype -i \"{img_path}\" ::/SYS/APPS/SIMPLECLI.CAT 2>/dev/null | grep -q '^list|src/app/list/main.spl|smoke|staged$' && " +
        "mtype -i \"{img_path}\" ::/SYS/APPS/SIMPLECLI.CAT 2>/dev/null | grep -q '^stats|src/app/stats/main.spl|smoke|staged$'; " +
        "else " +
        "grep -a -q 'info|src/app/info/main.spl|smoke|staged' \"{img_path}\" && " +
        "grep -a -q 'list|src/app/list/main.spl|smoke|staged' \"{img_path}\" && " +
        "grep -a -q 'stats|src/app/stats/main.spl|smoke|staged' \"{img_path}\" && " +
        "grep -a -q 'shell_remote_main' \"{img_path}\" && " +
        "grep -a -q 'smux_remote_main' \"{img_path}\"; " +
        "fi"
    val (_ssh_stdout, _ssh_stderr, ssh_exit) = rt_process_run_timeout("/bin/sh", ["-c", ssh_cmd], 5000)
    if ssh_exit != 0:
        return false
    true

fn build_scenario_command(scenario: QemuScenario, kernel_path: text) -> [text]:
    """Build QEMU command line from a scenario."""
    val qemu_bin = match scenario.arch:
        Architecture.X86_64: "qemu-system-x86_64"
        Architecture.Riscv64: "qemu-system-riscv64"
        Architecture.Riscv32: "qemu-system-riscv32"
        Architecture.Arm64: "qemu-system-aarch64"
        Architecture.Arm32: "qemu-system-arm"
        _: "qemu-system-x86_64"

    var args: [text] = [qemu_bin]
    for hardening_arg in qemu_scenario_hardening_args(scenario):
        args.push(hardening_arg)
    args.push("-machine")
    args.push(scenario.machine)
    args.push("-cpu")
    args.push(scenario.cpu)
    args.push("-m")
    args.push(scenario.memory)
    args.push("-serial")
    if scenario.name == "x64-desktop-uefi":
        args.push("file:" + desktop_uefi_serial_log_path())
    else:
        args.push("stdio")
    if not scenario.gui_mode:
        args.push("-display")
        args.push("none")
    args.push("-no-reboot")
    if _is_arm_fs_exec_scenario(scenario) and scenario.arch == Architecture.Arm32:
        args.push("-device")
        args.push("loader,file={kernel_path},addr=0x40200000")
        args.push("-device")
        args.push("loader,addr=0x40200000,cpu-num=0")
    elif _is_arm_fs_exec_scenario(scenario):
        args.push("-device")
        args.push("loader,file={kernel_path},addr=0x40200000,force-raw=on")
        args.push("-device")
        args.push("loader,addr=0x40200000,cpu-num=0")
    elif scenario.name == "x64-desktop-uefi":
        # UEFI lane boots the disk image through OVMF/Limine, not QEMU -kernel.
        pass
    else:
        args.push("-kernel")
        args.push(kernel_path)
    for extra in scenario.qemu_extra:
        args.push(extra)
    args

fn desktop_uefi_serial_log_path() -> text:
    "build/os/x64-desktop-uefi.serial.log"

fn _clear_serial_log(path: text):
    val _ = rt_process_run_timeout("/bin/sh", ["-c", "rm -f \"" + path + "\""], 5000)

fn _read_serial_log(path: text) -> text:
    if not rt_file_exists(path):
        return ""
    val (stdout, _stderr, exit_code) = rt_process_run_timeout("/bin/sh", ["-c", "cat \"" + path + "\""], 5000)
    if exit_code != 0:
        return ""
    stdout

fn build_scenario(scenario: QemuScenario) -> bool:
    """Build the kernel image required by a named scenario."""
    if not ensure_scenario_media(scenario):
        return false
    val target = scenario_target(scenario)
    if not build_os(target):
        return false
    if scenario.name == "x64-desktop-uefi":
        return ensure_desktop_uefi_boot_image(target.output)
    ensure_arm_fs_exec_kernel_binary(scenario, target)

fn run_scenario(scenario: QemuScenario) -> bool:
    """Build and run a named QEMU scenario."""
    if not ensure_scenario_media(scenario):
        return false
    val target = scenario_target(scenario)
    if scenario.name == "x64-desktop-uefi":
        if not ensure_desktop_uefi_boot_image(target.output):
            return false
    if not ensure_arm_fs_exec_kernel_binary(scenario, target):
        return false
    val cmd_parts = build_scenario_command(scenario, scenario_kernel_path(scenario, target))
    val qemu_bin = cmd_parts[0]
    val qemu_args = cmd_parts.slice(1)
    print "[run] {scenario.name}: {cmd_parts.join(" ")}"
    val timeout: i64 = if scenario.gui_mode: 600000 else: 30000
    if scenario.name == "x64-desktop-uefi":
        _clear_serial_log(desktop_uefi_serial_log_path())
    val (stdout, stderr, exit_code) = rt_process_run_timeout(qemu_bin, qemu_args, timeout)
    val serial_output = if scenario.name == "x64-desktop-uefi":
        _read_serial_log(desktop_uefi_serial_log_path())
    else:
        stdout
    if serial_output != "":
        print "[run] serial output:\n{serial_output}"
    if stderr != "":
        print "[run] stderr:\n{stderr}"
    val success = exit_code == 0 or exit_code == 1
    if not success:
        print "[run] FAILED (exit code {exit_code})"
    success

fn test_scenario(scenario: QemuScenario, timeout_ms: u64) -> bool:
    """Run a named QEMU scenario as a smoke/integration test."""
    if not ensure_scenario_media(scenario):
        return false
    val target = scenario_target(scenario)
    if scenario.name == "x64-desktop-uefi":
        if not ensure_desktop_uefi_boot_image(target.output):
            return false
    if not ensure_arm_fs_exec_kernel_binary(scenario, target):
        return false
    val cmd_parts = build_scenario_command(scenario, scenario_kernel_path(scenario, target))
    val qemu_bin = cmd_parts[0]
    val qemu_args = cmd_parts.slice(1)
    print "[test] {scenario.name} (timeout: {timeout_ms}ms): {cmd_parts.join(" ")}"
    if scenario.name == "x64-desktop-uefi":
        _clear_serial_log(desktop_uefi_serial_log_path())
    val (stdout, stderr, exit_code) = rt_process_run_timeout(qemu_bin, qemu_args, timeout_ms as i64)
    val serial_output = if scenario.name == "x64-desktop-uefi":
        _read_serial_log(desktop_uefi_serial_log_path()) + stderr
    else:
        stdout + stderr
    print "[test] serial output:\n{serial_output}"
    val accepted = if scenario.name == "x64-desktop-uefi":
        desktop_uefi_serial_accepts_completion(serial_output)
    else if _scenario_uses_catalog_completion_contract(scenario):
        _scenario_serial_accepts_completion(scenario, serial_output)
    else:
        serial_output.contains("TEST PASSED")
    val success = accepted and (exit_code == 0 or exit_code == 1)
    if not success:
        if scenario.name == "x64-desktop-uefi":
            print "[test] FAILED: scenario {scenario.name} did not satisfy desktop driver completion markers"
            print_desktop_uefi_missing_markers(serial_output)
        else if _scenario_uses_catalog_completion_contract(scenario):
            print "[test] FAILED: scenario {scenario.name} did not satisfy catalog lane completion markers"
            _print_scenario_missing_markers(scenario, serial_output)
        else:
            print "[test] FAILED: scenario {scenario.name} did not report TEST PASSED"
    success

fn arm_fs_exec_required_marker_fragments(scenario: QemuScenario) -> [text]:
    if val lane = _catalog_lane_for_scenario(scenario):
        return lane.required_serial_markers
    []

fn arm_fs_exec_serial_accepts_completion(scenario: QemuScenario, serial_output: text) -> bool:
    for marker in arm_fs_exec_required_marker_fragments(scenario):
        if not serial_output.contains(marker):
            return false
    true

fn print_arm_fs_exec_missing_markers(scenario: QemuScenario, serial_output: text):
    for marker in arm_fs_exec_required_marker_fragments(scenario):
        if not serial_output.contains(marker):
            print "[test] missing marker fragment: {marker}"

fn riscv64_hosted_required_marker_fragments() -> [text]:
    if val lane = _catalog_lane_for_scenario(scenario_riscv64_hosted()):
        return lane.required_serial_markers
    []

fn _scenario_required_marker_fragments(scenario: QemuScenario) -> [text]:
    if val lane = _catalog_lane_for_scenario(scenario):
        return lane.required_serial_markers
    []

fn _scenario_uses_catalog_completion_contract(scenario: QemuScenario) -> bool:
    if val _lane = _catalog_lane_for_scenario(scenario):
        return true
    false

fn _scenario_serial_accepts_completion(scenario: QemuScenario, serial_output: text) -> bool:
    for marker in _scenario_required_marker_fragments(scenario):
        if not serial_output.contains(marker):
            return false
    true

fn _print_scenario_missing_markers(scenario: QemuScenario, serial_output: text):
    for marker in _scenario_required_marker_fragments(scenario):
        if not serial_output.contains(marker):
            print "[test] missing marker fragment: {marker}"

fn riscv64_hosted_serial_accepts_completion(serial_output: text) -> bool:
    for marker in riscv64_hosted_required_marker_fragments():
        if not serial_output.contains(marker):
            return false
    true

fn print_riscv64_hosted_missing_markers(serial_output: text):
    for marker in riscv64_hosted_required_marker_fragments():
        if not serial_output.contains(marker):
            print "[test] missing marker fragment: {marker}"

fn desktop_uefi_serial_accepts_completion(serial_output: text) -> bool:
    """Accept live x64 desktop UEFI serial only when it satisfies driver, VFS app, and WM process markers."""
    if not desktop_driver_summary_accepts_complete_qemu(serial_output):
        return false
    for marker in desktop_uefi_required_marker_fragments():
        if not serial_output.contains(marker):
            return false
    true

fn desktop_uefi_required_marker_fragments() -> [text]:
    """Serial marker families required by x64-desktop-uefi live acceptance.

    The driver summary itself is validated by desktop_driver_summary_accepts_complete_qemu.
    These fragments document the process/VFS/network evidence that must also be
    present in the same serial stream for actionable live-QEMU diagnostics:
      [desktop-e2e] process-backed:ok app=<app> pid=<pid>
      [desktop-e2e] native-toolchain-launch:ok app=<app> lane=<lane> mode=<mode> status=<status>
      [desktop-e2e] native-capability:ok app=<app> capability=<capability> proof=<path>
      [desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/browser_demo bytes=<n>
      [desktop-e2e] virtio-net:mac=<mac>
      [desktop-e2e] virtio-net:rx-queue=ok queue=0
      [desktop-e2e] virtio-net:tx-queue=ok queue=0
      [desktop-e2e] network-smoke:bounded ok packets=<n> timeout_ms=<ms>
    """
    [
        "[desktop-e2e] process-backed:ok app=browser_demo pid=",
        "[desktop-e2e] process-backed:ok app=hello_world pid=",
        "[desktop-e2e] process-backed:ok app=editor pid=",
        "[desktop-e2e] process-backed:ok app=terminal pid=",
        "[desktop-e2e] process-backed:ok app=file_manager pid=",
        "[desktop-e2e] simple-cli:ok app=info pid=",
        "[desktop-e2e] process-backed:ok app=simple_browser pid=",
        "[desktop-e2e] wm-owner:ok app=simple_browser pid=",
        "[desktop-e2e] render-proof:ok app=simple_browser pid=",
        "[simple_browser] page_rendered app_id=/sys/apps/simple_browser",
        "[desktop-e2e] process-backed:ok app=simple_compiler pid=",
        "[desktop-e2e] process-backed:ok app=simple_interpreter pid=",
        "[desktop-e2e] process-backed:ok app=simple_loader pid=",
        "[desktop-e2e] process-backed:ok app=llvm pid=",
        "[desktop-e2e] process-backed:ok app=clang pid=",
        "[desktop-e2e] process-backed:ok app=rust pid=",
        "[desktop-e2e] native-toolchain-launch:ok app=llvm lane=x86_64-uefi-hardware mode=native-filesystem-app status=standalone-required tool=/sys/apps/llvm manifest=/SYS/LLVMMAN.TXT",
        "[desktop-e2e] native-toolchain-launch:ok app=clang lane=x86_64-uefi-hardware mode=native-filesystem-app status=standalone-required tool=/sys/apps/clang manifest=/SYS/CLANGMAN.TXT",
        "[desktop-e2e] native-toolchain-launch:ok app=rust lane=x86_64-uefi-hardware mode=native-filesystem-app status=standalone-required tool=/sys/apps/rust manifest=/SYS/RUSTMAN.TXT",
        "[desktop-e2e] native-capability:ok app=llvm capability=local-ir-inspection proof=/usr/share/simpleos/toolchain/llvm/hello.ll",
        "[desktop-e2e] native-capability:ok app=llvm capability=object-assembly-inspection proof=/usr/share/simpleos/toolchain/llvm/hello.s",
        "[desktop-e2e] native-capability:ok app=llvm capability=compile-pipeline-step proof=/usr/share/simpleos/toolchain/llvm/pipeline.step",
        "[desktop-e2e] native-capability:ok app=clang capability=local-c-source-inspection proof=/usr/share/simpleos/toolchain/clang/hello.c",
        "[desktop-e2e] native-capability:ok app=clang capability=driver-flag-inspection proof=/usr/share/simpleos/toolchain/clang/flags.rsp",
        "[desktop-e2e] native-capability:ok app=clang capability=compile-pipeline-step proof=/usr/share/simpleos/toolchain/clang/pipeline.step",
        "[desktop-e2e] native-capability:ok app=rust capability=local-source-inspection proof=/usr/share/simpleos/toolchain/rust/hello.rs",
        "[desktop-e2e] native-capability:ok app=rust capability=package-layout-inspection proof=/usr/share/simpleos/toolchain/rust/Cargo.toml",
        "[desktop-e2e] native-capability:ok app=rust capability=build-pipeline-step proof=/usr/share/simpleos/toolchain/rust/pipeline.step",
        "[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/browser_demo bytes=",
        "[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/info bytes=",
        "[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/simple_browser bytes=",
        "[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/simple_compiler bytes=",
        "[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/simple_interpreter bytes=",
        "[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/simple_loader bytes=",
        "[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/llvm bytes=",
        "[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/clang bytes=",
        "[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/rust bytes=",
        "[desktop-e2e] virtio-net:mac=",
        "[desktop-e2e] virtio-net:rx-queue=ok queue=0",
        "[desktop-e2e] virtio-net:tx-queue=ok queue=0",
        "[desktop-e2e] network-smoke:bounded ok packets="
    ]

fn print_desktop_uefi_missing_markers(serial_output: text):
    if not desktop_driver_summary_accepts_complete_qemu(serial_output):
        print "[test] missing/invalid: complete desktop driver summary contract"
    for marker in desktop_uefi_required_marker_fragments():
        if not serial_output.contains(marker):
            print "[test] missing marker fragment: {marker}"

fn scenario_test_timeout_ms(scenario: QemuScenario) -> u64:
    """Return a realistic smoke-test timeout for a named QEMU scenario."""
    if scenario.name == "x64-nvme-fat32":
        return 60000
    if _is_arm_fs_exec_scenario(scenario):
        if val lane = simpleos_platform_qemu_lane(_arm_fs_exec_platform_name(scenario.arch), scenario.name):
            return lane.timeout_ms as u64
        return 60000
    if scenario.name == "riscv64-hosted":
        if val lane = simpleos_platform_qemu_lane("riscv64", "riscv64-hosted"):
            return lane.timeout_ms as u64
        return 120000
    if _is_riscv_fs_exec_scenario(scenario):
        if val lane = simpleos_platform_qemu_lane(_riscv_fs_exec_platform_name(scenario.arch), scenario.name):
            return lane.timeout_ms as u64
        return 60000
    if val timeout_ms = _desktop_scenario_timeout_ms(scenario.name):
        return timeout_ms
    10000

fn ensure_scenario_media(scenario: QemuScenario) -> bool:
    """Materialize required host-side disk media for scenarios that attach storage."""
    if val ready = _ensure_desktop_scenario_media(scenario.name):
        return ready
    if val ready = _ensure_catalog_scenario_media(scenario):
        return ready
    true

fn boot_disk_image_serial(image: text, timeout_ms: i64) -> (text, text, i32):
    """Boot a raw disk image in QEMU x86_64 and capture serial output.

    Uses the standard q35 machine with COM1 mapped to stdio so the caller
    can grep for [phase-3-*] markers in the returned stdout+stderr tuple.
    No -kernel flag — the firmware boots directly from the disk image.
    """
    val args = [
        "-no-user-config",
        "-monitor", "none",
        "-machine", "q35",
        "-cpu", "qemu64",
        "-m", "512M",
        "-serial", "stdio",
        "-display", "none",
        "-net", "none",
        "-no-reboot",
        "-drive", "file=" + image + ",format=raw,if=virtio",
        "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"
    ]
    rt_process_run_timeout("qemu-system-x86_64", args, timeout_ms)
