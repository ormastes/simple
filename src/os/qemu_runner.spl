    """x86_64 desktop integration test.

    Same as x64-gui but with the desktop E2E test entry point.
    Tests the full desktop stack: launcher, dock, WM integration.
    """
    QemuScenario(
        name: "x64-desktop-test",
        arch: Architecture.X86_64,
        machine: "q35",
        cpu: "qemu64",
        memory: "512M",
        qemu_extra: [
            "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04",
