fn desktop_uefi_disk_make_script_args(img_path: text, kernel_path: text) -> [text]:
    ["-c", "SIMPLEOS_UEFI_KERNEL=\"$1\" exec /bin/sh scripts/make_os_disk.shs 64 \"$2\" \"\" x86_64", "simpleos-uefi-disk", kernel_path, img_path]

