        "mdir -i \"{img_path}\" ::/SYS/APPS/simple_compiler >/dev/null 2>&1 && " +
        "mdir -i \"{img_path}\" ::/SYS/APPS/simple_compiler.smf >/dev/null 2>&1 && " +
        "mdir -i \"{img_path}\" ::/SYS/APPS/simple_interpreter >/dev/null 2>&1 && " +
        "mdir -i \"{img_path}\" ::/SYS/APPS/simple_interpreter.smf >/dev/null 2>&1 && " +
        "mdir -i \"{img_path}\" ::/SYS/APPS/simple_loader >/dev/null 2>&1 && " +
