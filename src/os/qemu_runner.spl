    """Returns x86_64 filesystem contract target with NVMe + FAT32 media.

    The target entry is filesystem-specific and the disk image is supplied by
    the x64-nvme-fat32 scenario. Keeping the entry target separate lets SSpec
    reuse the same named-scenario machinery as other QEMU lanes while binding
    the FAT32 contract to the dedicated fs test program.
    """
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/simple_os/arch/x86_64/fs_test_entry.spl",
        linker_script: "examples/simple_os/arch/x86_64/linker.ld",
