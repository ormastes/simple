        memory: "512M",
        qemu_extra: [
            "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04",
            "-drive", "file=build/os/nvme.img,if=none,id=nvm,format=raw",
            "-device", "nvme,serial=deadbeef,drive=nvm"
        ],
        gui_mode: false,
        description: "x86_64 with NVMe block device"
    )

