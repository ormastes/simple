"""Linux ABI capability matrix for SimpleOS game compatibility.

Covers ELF loading, dynamic linking, mmap/mprotect, futex, clone,
signal, epoll, eventfd, timerfd, signalfd, ioctl, procfs, sysfs, devfs.
"""

class LinuxCapability:
    cap_name: text
    subsystem: text
    status: text
    blocker: text

    static fn ready(name: text, sub: text) -> LinuxCapability:
        LinuxCapability(cap_name: name, subsystem: sub, status: "ready", blocker: "")

    static fn partial(name: text, sub: text, note: text) -> LinuxCapability:
        LinuxCapability(cap_name: name, subsystem: sub, status: "partial", blocker: note)

    static fn missing(name: text, sub: text, note: text) -> LinuxCapability:
        LinuxCapability(cap_name: name, subsystem: sub, status: "missing", blocker: note)

    me is_ready() -> bool:
        self.status == "ready"

    me is_blocking() -> bool:
        self.status == "missing"

    me summary() -> text:
        "[" + self.subsystem + "] " + self.cap_name + " => " + self.status +
            if self.blocker == "" { "" } else { " (" + self.blocker + ")" }


class LinuxCapabilityMatrix:
    count: i64
    c0_name: text
    c0_status: text
    c1_name: text
    c1_status: text
    c2_name: text
    c2_status: text
    c3_name: text
    c3_status: text
    c4_name: text
    c4_status: text
    c5_name: text
    c5_status: text
    c6_name: text
    c6_status: text
    c7_name: text
    c7_status: text
    c8_name: text
    c8_status: text
    c9_name: text
    c9_status: text
    c10_name: text
    c10_status: text
    c11_name: text
    c11_status: text
    c12_name: text
    c12_status: text
    c13_name: text
    c13_status: text

    static fn create() -> LinuxCapabilityMatrix:
        LinuxCapabilityMatrix(
            count: 0,
            c0_name: "", c0_status: "",
            c1_name: "", c1_status: "",
            c2_name: "", c2_status: "",
            c3_name: "", c3_status: "",
            c4_name: "", c4_status: "",
            c5_name: "", c5_status: "",
            c6_name: "", c6_status: "",
            c7_name: "", c7_status: "",
            c8_name: "", c8_status: "",
            c9_name: "", c9_status: "",
            c10_name: "", c10_status: "",
            c11_name: "", c11_status: "",
            c12_name: "", c12_status: "",
            c13_name: "", c13_status: ""
        )

    me add(cap: LinuxCapability) -> i64:
        if self.count == 0:
            self.c0_name = cap.cap_name
            self.c0_status = cap.status
        if self.count == 1:
            self.c1_name = cap.cap_name
            self.c1_status = cap.status
        if self.count == 2:
            self.c2_name = cap.cap_name
            self.c2_status = cap.status
        if self.count == 3:
            self.c3_name = cap.cap_name
            self.c3_status = cap.status
        if self.count == 4:
            self.c4_name = cap.cap_name
            self.c4_status = cap.status
        if self.count == 5:
            self.c5_name = cap.cap_name
            self.c5_status = cap.status
        if self.count == 6:
            self.c6_name = cap.cap_name
            self.c6_status = cap.status
        if self.count == 7:
            self.c7_name = cap.cap_name
            self.c7_status = cap.status
        if self.count == 8:
            self.c8_name = cap.cap_name
            self.c8_status = cap.status
        if self.count == 9:
            self.c9_name = cap.cap_name
            self.c9_status = cap.status
        if self.count == 10:
            self.c10_name = cap.cap_name
            self.c10_status = cap.status
        if self.count == 11:
            self.c11_name = cap.cap_name
            self.c11_status = cap.status
        if self.count == 12:
            self.c12_name = cap.cap_name
            self.c12_status = cap.status
        if self.count == 13:
            self.c13_name = cap.cap_name
            self.c13_status = cap.status
        self.count = self.count + 1
        self.count

    me ready_count() -> i64:
        var n = 0
        if self.c0_status == "ready": n = n + 1
        if self.c1_status == "ready": n = n + 1
        if self.c2_status == "ready": n = n + 1
        if self.c3_status == "ready": n = n + 1
        if self.c4_status == "ready": n = n + 1
        if self.c5_status == "ready": n = n + 1
        if self.c6_status == "ready": n = n + 1
        if self.c7_status == "ready": n = n + 1
        if self.c8_status == "ready": n = n + 1
        if self.c9_status == "ready": n = n + 1
        if self.c10_status == "ready": n = n + 1
        if self.c11_status == "ready": n = n + 1
        if self.c12_status == "ready": n = n + 1
        if self.c13_status == "ready": n = n + 1
        n

    me missing_count() -> i64:
        var n = 0
        if self.c0_status == "missing": n = n + 1
        if self.c1_status == "missing": n = n + 1
        if self.c2_status == "missing": n = n + 1
        if self.c3_status == "missing": n = n + 1
        if self.c4_status == "missing": n = n + 1
        if self.c5_status == "missing": n = n + 1
        if self.c6_status == "missing": n = n + 1
        if self.c7_status == "missing": n = n + 1
        if self.c8_status == "missing": n = n + 1
        if self.c9_status == "missing": n = n + 1
        if self.c10_status == "missing": n = n + 1
        if self.c11_status == "missing": n = n + 1
        if self.c12_status == "missing": n = n + 1
        if self.c13_status == "missing": n = n + 1
        n

    me coverage_percent() -> i64:
        if self.count == 0:
            return 0
        (self.ready_count() * 100) / self.count

    me all_ready() -> bool:
        self.missing_count() == 0

    me report() -> text:
        "linux_abi: total=" + self.count.to_text() +
            " ready=" + self.ready_count().to_text() +
            " missing=" + self.missing_count().to_text() +
            " coverage=" + self.coverage_percent().to_text() + "%"


fn build_simpleos_linux_capability_matrix() -> LinuxCapabilityMatrix:
    var m = LinuxCapabilityMatrix.create()
    m.add(LinuxCapability.ready("elf_load", "loader"))
    m.add(LinuxCapability.partial("dynlink", "loader", "plt-stub only"))
    m.add(LinuxCapability.partial("mmap", "mm", "anonymous only"))
    m.add(LinuxCapability.missing("mprotect", "mm", "no page permission API"))
    m.add(LinuxCapability.ready("futex", "sync"))
    m.add(LinuxCapability.partial("clone", "proc", "no namespaces"))
    m.add(LinuxCapability.partial("signal", "proc", "SIGKILL/SIGTERM only"))
    m.add(LinuxCapability.missing("epoll", "io", "not implemented"))
    m.add(LinuxCapability.missing("eventfd", "io", "not implemented"))
    m.add(LinuxCapability.missing("timerfd", "io", "not implemented"))
    m.add(LinuxCapability.missing("signalfd", "io", "not implemented"))
    m.add(LinuxCapability.partial("ioctl", "dev", "TCGETS/TCSETS only"))
    m.add(LinuxCapability.missing("procfs", "vfs", "stub only"))
    m.add(LinuxCapability.missing("sysfs", "vfs", "not implemented"))
    m
