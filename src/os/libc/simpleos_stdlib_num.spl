# SimpleOS libc — pure-Simple, musl-shaped stdlib core.
# Numeric parsing and arithmetic functions (integer, no float).
#
# Syscall-free subset of musl libc for numeric parsing (strtoul, strtoll, strtoull),
# integer division, and pseudo-random number generation.
# Written in pure Simple (replaces the hand-written C).

# ---- structs for multi-return values ----------------------------------------

struct DivResult:
    quot: i64
    rem: i64

struct RandResult:
    state: i64
    value: i64

# ---- strtoul: unsigned integer parse with base auto-detect -----------------

fn libc_strtoul(s: [u8], base: i64) -> i64:
    """Parse unsigned integer from byte array.
    base 0 => auto-detect: "0x"/"0X" hex, "0" octal, else decimal.
    base 2..16 supported. Skip leading spaces, stop at first non-digit.
    Return parsed value (as i64).
    C strtoul accepts a leading +/- and negates (wrapping unsigned); this i64
    model returns the negated value for '-' (the faithful signed-domain form)."""
    val n = s.len()
    var i = 0

    # Skip leading whitespace
    while i < n and (s[i] == 32 or s[i] == 9 or s[i] == 10 or s[i] == 13 or s[i] == 11 or s[i] == 12):
        i = i + 1

    # Optional +/- sign (C strtoul accepts and negates)
    var sign = 1
    if i < n and (s[i] == 43 or s[i] == 45):  # '+' or '-'
        if s[i] == 45:
            sign = -1
        i = i + 1

    # Determine base if auto-detect (base == 0)
    var effective_base = base
    if effective_base == 0:
        if i < n and s[i] == 48:  # '0'
            if i + 1 < n and (s[i + 1] == 120 or s[i + 1] == 88):  # 'x' or 'X'
                effective_base = 16
                i = i + 2
            else:
                effective_base = 8
                i = i + 1
        else:
            effective_base = 10
    else:
        # Check for 0x/0X prefix when base is explicitly 16
        if effective_base == 16 and i < n and s[i] == 48:
            if i + 1 < n and (s[i + 1] == 120 or s[i + 1] == 88):
                i = i + 2

    # Parse digits
    var acc = 0
    while i < n:
        val ch = s[i]
        var digit_val = -1
        if ch >= 48 and ch <= 57:  # '0'..'9'
            digit_val = ch - 48
        elif ch >= 97 and ch <= 102:  # 'a'..'f'
            digit_val = ch - 97 + 10
        elif ch >= 65 and ch <= 70:  # 'A'..'F'
            digit_val = ch - 65 + 10

        if digit_val < 0 or digit_val >= effective_base:
            return sign * acc
        acc = acc * effective_base + digit_val
        i = i + 1

    sign * acc

# ---- strtoll: signed integer parse with base auto-detect -------------------

fn libc_strtoll(s: [u8], base: i64) -> i64:
    """Parse signed integer from byte array.
    Like strtoul, but handle optional +/- sign.
    base 0 => auto-detect: "0x"/"0X" hex, "0" octal, else decimal."""
    val n = s.len()
    var i = 0

    # Skip leading whitespace
    while i < n and (s[i] == 32 or s[i] == 9 or s[i] == 10 or s[i] == 13 or s[i] == 11 or s[i] == 12):
        i = i + 1

    # Optional +/- sign
    var sign = 1
    if i < n and (s[i] == 43 or s[i] == 45):  # '+' or '-'
        if s[i] == 45:
            sign = -1
        i = i + 1

    # Determine base if auto-detect
    var effective_base = base
    if effective_base == 0:
        if i < n and s[i] == 48:  # '0'
            if i + 1 < n and (s[i + 1] == 120 or s[i + 1] == 88):  # 'x' or 'X'
                effective_base = 16
                i = i + 2
            else:
                effective_base = 8
                i = i + 1
        else:
            effective_base = 10
    else:
        # Check for 0x/0X prefix when base is explicitly 16
        if effective_base == 16 and i < n and s[i] == 48:
            if i + 1 < n and (s[i + 1] == 120 or s[i + 1] == 88):
                i = i + 2

    # Parse digits
    var acc = 0
    while i < n:
        val ch = s[i]
        var digit_val = -1
        if ch >= 48 and ch <= 57:  # '0'..'9'
            digit_val = ch - 48
        elif ch >= 97 and ch <= 102:  # 'a'..'f'
            digit_val = ch - 97 + 10
        elif ch >= 65 and ch <= 70:  # 'A'..'F'
            digit_val = ch - 65 + 10

        if digit_val < 0 or digit_val >= effective_base:
            return sign * acc
        acc = acc * effective_base + digit_val
        i = i + 1

    sign * acc

# ---- strtoull: same as strtoul (unsigned, but i64 result) -------------------

fn libc_strtoull(s: [u8], base: i64) -> i64:
    """Parse unsigned long long (same as strtoul in this implementation)."""
    libc_strtoul(s, base)

# ---- div: integer division with remainder (toward zero) ---------------------

fn libc_div(numer: i64, denom: i64) -> DivResult:
    """Divide numer by denom, truncating quotient toward zero.
    Return DivResult(quot, rem) where rem = numer - quot*denom."""
    if denom == 0:
        return DivResult(quot: 0, rem: 0)  # Undefined behavior guard

    val quot = numer / denom
    val rem = numer - quot * denom
    DivResult(quot: quot, rem: rem)

# ---- ldiv: same as div (for i64) -----------------------------------------------

fn libc_ldiv(numer: i64, denom: i64) -> DivResult:
    """Long division (same as div for i64)."""
    libc_div(numer, denom)

# ---- lldiv: same as div (for i64) -----------------------------------------------

fn libc_lldiv(numer: i64, denom: i64) -> DivResult:
    """Long long division (same as div for i64)."""
    libc_div(numer, denom)

# ---- rand_next: glibc-style LCG -------------------------------------------------

fn libc_rand_next(state: i64) -> RandResult:
    """Linear congruential generator (glibc style).
    new_state = (state * 1103515245 + 12345) & 0x7fffffff
    value = (new_state >> 16) & 0x7fff
    Return RandResult(state: new_state, value: value).
    Pure/reentrant; caller threads the state."""
    val new_state = ((state * 1103515245 + 12345) & 0x7fffffff)
    val value = (new_state >> 16) & 0x7fff
    RandResult(state: new_state, value: value)
