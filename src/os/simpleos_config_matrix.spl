    )

pub fn profile_all_requirements_status(
    profile: SimpleOsRuntimeProfile,
    capabilities: [text]
) -> text:
    for capability in capabilities:
        val status = profile_requirement_status(profile, capability)
        if status != "ready":
            return status
    "ready"

pub fn simpleos_multiconfig_goal_status() -> text:
    val qemu_status = profile_all_requirements_status(
        qemu_riscv64_desktop_profile(),
        qemu_riscv64_required_capabilities()
    )
    if qemu_status != "ready":
        return "qemu:" + qemu_status
    val fpga_status = profile_all_requirements_status(
        fpga_riscv64_serial_profile(),
        fpga_riscv64_allowed_capabilities()
    )
    if fpga_status != "ready":
        return "fpga:" + fpga_status
    "profiles-ready-live-evidence-required"

