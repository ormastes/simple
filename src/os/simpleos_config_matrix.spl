class SimpleOsRuntimeProfile:
    name: text
    arch: text
    target_kind: text
    terminal_kind: text
    ssh_host_port: int
    http_host_port: int
    supports_gpu: bool
    supports_framebuffer: bool
    supports_wm: bool
    supports_simple2d_engine2d: bool
    requires_vulkan: bool
    requires_renderdoc: bool
    requires_host_wm_compare: bool
    blocked_reason: text

    me is_qemu_riscv64_desktop() -> bool:
        self.name == "qemu-riscv64-desktop"

    me is_fpga_riscv64_serial() -> bool:
        self.name == "fpga-riscv64-serial"

    me ssh_endpoint() -> text:
        if self.ssh_host_port <= 0:
            return "blocked:" + self.blocked_reason
        "127.0.0.1:" + self.ssh_host_port.to_text()

    me http_endpoint() -> text:
        if self.http_host_port <= 0:
            return "blocked:" + self.blocked_reason
        "127.0.0.1:" + self.http_host_port.to_text()

    me summary() -> text:
        self.name + " arch=" + self.arch +
            " target=" + self.target_kind +
            " terminal=" + self.terminal_kind

class SimpleOsWmRenderdocEvidence:
    simple_rdc_magic: text
    simple_runtime_backend: text
    simple_scene: text
    simple2d_readback_status: text
    qemu_gpu_readback_status: text
    qemu_wm_status: text
    host_wm_status: text
    structured_compare_status: text

    me status() -> text:
        if self.simple_rdc_magic != "RDOC":
            return "blocked:missing-simple-rdoc-magic"
        if self.simple_runtime_backend != "vulkan":
            return "blocked:missing-simple-vulkan-runtime"
        if self.simple_scene != "vulkan-engine2d":
            return "blocked:missing-engine2d-vulkan-scene"
        if self.simple2d_readback_status != "pass":
            return "blocked:missing-simple2d-readback"
        if self.qemu_gpu_readback_status != "pass":
            return "blocked:missing-qemu-gpu-readback"
        if self.qemu_wm_status != "pass":
            return "blocked:missing-qemu-wm-evidence"
        if self.host_wm_status != "pass":
            return "blocked:missing-host-wm-evidence"
        if self.structured_compare_status != "pass":
            return "blocked:missing-structured-wm-compare"
        "pass"

class SimpleOsQemuServiceEvidence:
    serial_console_status: text
    ssh_banner: text
    ssh_probe_status: text
    http_status_code: int
    http_probe_status: text
    gpu_readback_status: text
    wm_marker_status: text

    me status() -> text:
        if self.serial_console_status != "pass":
            return "blocked:missing-qemu-serial-console"
        if self.ssh_banner == "":
            return "blocked:missing-qemu-ssh-banner"
        if self.ssh_probe_status != "pass":
            return "blocked:missing-qemu-ssh-probe"
        if self.http_status_code != 200:
            return "blocked:missing-qemu-http-200"
        if self.http_probe_status != "pass":
            return "blocked:missing-qemu-http-probe"
        if self.gpu_readback_status != "pass":
            return "blocked:missing-qemu-gpu-readback"
        if self.wm_marker_status != "pass":
            return "blocked:missing-qemu-wm-marker"
        "pass"

class SimpleOsWmStructuredCompareEvidence:
    qemu_scene: text
    host_scene: text
    qemu_window_count: int
    host_window_count: int
    qemu_focus_id: text
    host_focus_id: text
    qemu_titlebar_status: text
    host_titlebar_status: text
    qemu_taskbar_status: text
    host_taskbar_status: text
    renderdoc_log_compare_status: text
    argb_diff_status: text
    argb_mismatch_count: int

    me status() -> text:
        if self.qemu_scene == "":
            return "blocked:missing-qemu-wm-scene"
        if self.host_scene == "":
            return "blocked:missing-host-wm-scene"
        if self.qemu_scene != self.host_scene:
            return "blocked:wm-scene-mismatch"
        if self.qemu_window_count <= 0:
            return "blocked:missing-qemu-window-count"
        if self.host_window_count <= 0:
            return "blocked:missing-host-window-count"
        if self.qemu_window_count != self.host_window_count:
            return "blocked:wm-window-count-mismatch"
        if self.qemu_focus_id == "":
            return "blocked:missing-qemu-focus"
        if self.host_focus_id == "":
            return "blocked:missing-host-focus"
        if self.qemu_focus_id != self.host_focus_id:
            return "blocked:wm-focus-mismatch"
        if self.qemu_titlebar_status != "pass":
            return "blocked:missing-qemu-titlebar-controls"
        if self.host_titlebar_status != "pass":
            return "blocked:missing-host-titlebar-controls"
        if self.qemu_taskbar_status != "pass":
            return "blocked:missing-qemu-taskbar"
        if self.host_taskbar_status != "pass":
            return "blocked:missing-host-taskbar"
        if self.renderdoc_log_compare_status != "pass":
            return "blocked:missing-renderdoc-log-compare"
        if self.argb_diff_status != "pass":
            return "blocked:missing-wm-argb-diff"
        if self.argb_mismatch_count != 0:
            return "blocked:wm-argb-mismatch"
        "pass"

class SimpleOsEngine2dVulkanEvidence:
    runtime_backend: text
    engine_scene: text
    simple2d_command_status: text
    device_name: text
    viewport_width: int
    viewport_height: int
    readback_checksum: text
    readback_nonblank_status: text
    qemu_gpu_readback_status: text

    me status() -> text:
        if self.runtime_backend != "vulkan":
            return "blocked:missing-engine2d-vulkan-backend"
        if self.engine_scene != "vulkan-engine2d":
            return "blocked:missing-engine2d-vulkan-scene"
        if self.simple2d_command_status != "pass":
            return "blocked:missing-simple2d-command-evidence"
        if self.device_name == "":
            return "blocked:missing-vulkan-device-name"
        if self.viewport_width <= 0:
            return "blocked:missing-engine2d-viewport-width"
        if self.viewport_height <= 0:
            return "blocked:missing-engine2d-viewport-height"
        if self.readback_checksum == "":
            return "blocked:missing-engine2d-readback-checksum"
        if self.readback_nonblank_status != "pass":
            return "blocked:missing-engine2d-nonblank-readback"
        if self.qemu_gpu_readback_status != "pass":
            return "blocked:missing-qemu-gpu-readback"
        "pass"

class SimpleOsRenderdocArtifactEvidence:
    capture_mode: text
    rdc_path: text
    rdc_magic: text
    rdc_size_bytes: int
    capture_log_path: text
    capture_log_status: text
    simple_runtime_backend: text
    simple_scene: text
    renderdoc_helper_status: text
    qemu_wm_log_path: text
    host_wm_log_path: text

    me status() -> text:
        if self.capture_mode != "capture-simple":
            return "blocked:missing-renderdoc-capture-simple-mode"
        if self.rdc_path == "":
            return "blocked:missing-simpleos-rdc-path"
        if self.rdc_magic != "RDOC":
            return "blocked:missing-simple-rdoc-magic"
        if self.rdc_size_bytes <= 4:
            return "blocked:missing-simple-rdoc-payload"
        if self.capture_log_path == "":
            return "blocked:missing-renderdoc-capture-log-path"
        if self.capture_log_status != "pass":
            return "blocked:missing-renderdoc-capture-log"
        if self.simple_runtime_backend != "vulkan":
            return "blocked:missing-simple-vulkan-runtime"
        if self.simple_scene != "vulkan-engine2d":
            return "blocked:missing-engine2d-vulkan-scene"
        if self.renderdoc_helper_status != "pass":
            return "blocked:missing-renderdoc-helper-pass"
        if self.qemu_wm_log_path == "":
            return "blocked:missing-qemu-wm-renderdoc-log"
        if self.host_wm_log_path == "":
            return "blocked:missing-host-wm-renderdoc-log"
        "pass"

class SimpleOsFpgaSerialEvidence:
    board_profile: text
    uart_terminal_status: text
    serial_device: text
    serial_boot_marker: text
    toolchain_status: text
    bitstream_status: text
    ssh_status: text
    http_status: text
    gpu_status: text
    wm_status: text
    vulkan_status: text
    renderdoc_status: text

    me status() -> text:
        if self.board_profile != "fpga-riscv64-serial":
            return "blocked:wrong-fpga-profile"
        if self.uart_terminal_status != "pass":
            return "blocked:missing-fpga-uart-terminal"
        if self.serial_device == "":
            return "blocked:missing-fpga-serial-device"
        if self.serial_boot_marker == "":
            return "blocked:missing-fpga-serial-boot-marker"
        if self.toolchain_status != "pass":
            return "blocked:missing-fpga-toolchain"
        if self.bitstream_status != "pass":
            return "blocked:missing-fpga-bitstream"
        if self.ssh_status != "blocked":
            return "blocked:fpga-ssh-must-remain-blocked"
        if self.http_status != "blocked":
            return "blocked:fpga-http-must-remain-blocked"
        if self.gpu_status != "blocked":
            return "blocked:fpga-gpu-must-remain-blocked"
        if self.wm_status != "blocked":
            return "blocked:fpga-wm-must-remain-blocked"
        if self.vulkan_status != "blocked":
            return "blocked:fpga-vulkan-must-remain-blocked"
        if self.renderdoc_status != "blocked":
            return "blocked:fpga-renderdoc-must-remain-blocked"
        "pass"

class SimpleOsMulticonfigLiveEvidence:
    qemu_service_status: text
    fpga_serial_status: text
    engine2d_vulkan_status: text
    renderdoc_artifact_status: text
    wm_structured_compare_status: text
    wm_renderdoc_status: text

    me status() -> text:
        if self.qemu_service_status != "pass":
            return "blocked:qemu-service:" + self.qemu_service_status
        if self.fpga_serial_status != "pass":
            return "blocked:fpga-serial:" + self.fpga_serial_status
        if self.engine2d_vulkan_status != "pass":
            return "blocked:engine2d-vulkan:" + self.engine2d_vulkan_status
        if self.renderdoc_artifact_status != "pass":
            return "blocked:renderdoc-artifact:" + self.renderdoc_artifact_status
        if self.wm_structured_compare_status != "pass":
            return "blocked:wm-structured-compare:" + self.wm_structured_compare_status
        if self.wm_renderdoc_status != "pass":
            return "blocked:wm-renderdoc:" + self.wm_renderdoc_status
        "pass"

class SimpleOsEngine2dVulkanBridgePlan:
    profile_name: text
    drawing_backend: text
    processing_backend: text
    qemu_gpu_device: text
    scene_name: text
    simple2d_command_path: text
    requires_device_readback: bool
    requires_qmp_screendump: bool
    renderdoc_capture_mode: text
    wm_compare_scene: text

    me status() -> text:
        if self.profile_name != "qemu-riscv64-desktop":
            return "blocked:wrong-simpleos-profile"
        if self.drawing_backend != "virtio_gpu":
            return "blocked:missing-qemu-virtio-gpu-drawing-backend"
        if self.processing_backend != "vulkan":
            return "blocked:missing-engine2d-vulkan-processing-backend"
        if self.qemu_gpu_device != "virtio-gpu-pci,disable-modern=on,disable-legacy=off":
            return "blocked:missing-qemu-virtio-gpu-device"
        if self.scene_name != "vulkan-engine2d":
            return "blocked:missing-vulkan-engine2d-scene"
        if self.simple2d_command_path != "draw_ir-to-engine2d":
            return "blocked:missing-simple2d-engine2d-command-path"
        if not self.requires_device_readback:
            return "blocked:missing-engine2d-device-readback-requirement"
        if not self.requires_qmp_screendump:
            return "blocked:missing-qemu-qmp-screendump-requirement"
        if self.renderdoc_capture_mode != "capture-simple":
            return "blocked:missing-renderdoc-capture-simple-mode"
        if self.wm_compare_scene == "":
            return "blocked:missing-wm-compare-scene"
        "ready"

class SimpleOsEngine2dSourceBridgeAudit:
    qemu_entry_status: text
    baremetal_core_status: text
    virtio_surface_status: text
    vulkan_session_status: text
    current_draw_path: text
    target_processing_backend: text

    me status() -> text:
        if self.qemu_entry_status != "pass":
            return "blocked:missing-qemu-desktop-service-entry"
        if self.baremetal_core_status != "pass":
            return "blocked:missing-baremetal-engine2d-core"
        if self.virtio_surface_status != "pass":
            return "blocked:missing-engine2d-virtio-surface-contract"
        if self.vulkan_session_status != "pass":
            return "blocked:missing-engine2d-vulkan-session"
        if self.current_draw_path != "freestanding-display-runtime":
            return "blocked:unknown-qemu-draw-path"
        if self.target_processing_backend != "vulkan":
            return "blocked:missing-engine2d-vulkan-target"
        "blocked:desktop-service-not-wired-to-vulkan-engine2d-session"

pub fn qemu_riscv64_desktop_profile() -> SimpleOsRuntimeProfile:
    SimpleOsRuntimeProfile(
        name: "qemu-riscv64-desktop",
        arch: "riscv64",
        target_kind: "qemu-virt",
        terminal_kind: "serial+graphical",
        ssh_host_port: 2222,
        http_host_port: 8080,
        supports_gpu: true,
        supports_framebuffer: true,
        supports_wm: true,
        supports_simple2d_engine2d: true,
        requires_vulkan: true,
        requires_renderdoc: true,
        requires_host_wm_compare: true,
        blocked_reason: ""
    )

pub fn fpga_riscv64_serial_profile() -> SimpleOsRuntimeProfile:
    SimpleOsRuntimeProfile(
        name: "fpga-riscv64-serial",
        arch: "riscv64",
        target_kind: "fpga-softcore",
        terminal_kind: "uart-serial",
        ssh_host_port: 0,
        http_host_port: 0,
        supports_gpu: false,
        supports_framebuffer: false,
        supports_wm: false,
        supports_simple2d_engine2d: false,
        requires_vulkan: false,
        requires_renderdoc: false,
        requires_host_wm_compare: false,
        blocked_reason: "fpga-riscv64-currently-uart-serial-only"
    )

pub fn profile_supports_capability(
    profile: SimpleOsRuntimeProfile,
    capability: text
) -> bool:
    if capability == "serial-terminal":
        return profile.terminal_kind.contains("serial")
    if capability == "ssh":
        return profile.ssh_host_port > 0
    if capability == "http":
        return profile.http_host_port > 0
    if capability == "gpu":
        return profile.supports_gpu
    if capability == "framebuffer":
        return profile.supports_framebuffer
    if capability == "wm":
        return profile.supports_wm
    if capability == "simple2d-engine2d":
        return profile.supports_simple2d_engine2d
    if capability == "vulkan":
        return profile.requires_vulkan
    if capability == "renderdoc":
        return profile.requires_renderdoc
    if capability == "host-wm-compare":
        return profile.requires_host_wm_compare
    false

pub fn profile_requirement_status(
    profile: SimpleOsRuntimeProfile,
    capability: text
) -> text:
    if profile_supports_capability(profile, capability):
        return "ready"
    if profile.blocked_reason != "":
        return "blocked:" + profile.blocked_reason + ":" + capability
    "blocked:capability-not-configured:" + capability

pub fn qemu_riscv64_required_capabilities() -> [text]:
    [
        "serial-terminal",
        "ssh",
        "http",
        "gpu",
        "framebuffer",
        "wm",
        "simple2d-engine2d",
        "vulkan",
        "renderdoc",
        "host-wm-compare"
    ]

pub fn fpga_riscv64_allowed_capabilities() -> [text]:
    ["serial-terminal"]

pub fn fpga_riscv64_serial_entry_path() -> text:
    "examples/09_embedded/simple_os/arch/riscv64/fpga_serial_entry.spl"

pub fn fpga_riscv64_serial_kernel_path() -> text:
    "build/os/simpleos_riscv64_fpga.elf"

pub fn fpga_riscv64_serial_boot_marker() -> text:
    "SIMPLEOS_FPGA_RISCV64_SERIAL_BOOT"

pub fn qemu_riscv64_desktop_artifact_dir() -> text:
    "build/os/systest/qemu-riscv64-desktop"

pub fn qemu_riscv64_desktop_kernel_path() -> text:
    "build/os/simpleos_riscv64_desktop_service.elf"

pub fn qemu_riscv64_desktop_image_path() -> text:
    "build/os/fat32-riscv64.img"

pub fn qemu_riscv64_desktop_ssh_endpoint() -> text:
    "127.0.0.1:2222"

pub fn qemu_riscv64_desktop_http_endpoint() -> text:
    "127.0.0.1:8080"

pub fn qemu_riscv64_desktop_qemu_args() -> [text]:
    [
        "-machine",
        "virt",
        "-cpu",
        "rv64",
        "-m",
        "512M",
        "-serial",
        "file:build/os/systest/qemu-riscv64-desktop/serial.log",
        "-display",
        "none",
        "-monitor",
        "none",
        "-qmp",
        "tcp:127.0.0.1:4444,server,nowait",
        "-bios",
        "default",
        "-global",
        "virtio-mmio.force-legacy=false",
        "-netdev",
        "user,id=rvnet,hostfwd=tcp::2222-:22,hostfwd=tcp::8080-:8080",
        "-device",
        "virtio-net-pci,netdev=rvnet",
        "-device",
        "virtio-gpu-pci,disable-modern=on,disable-legacy=off",
        "-drive",
        "file=build/os/fat32-riscv64.img,if=none,id=rvdisk,format=raw",
        "-device",
        "virtio-blk-device,drive=rvdisk",
        "-kernel",
        "build/os/simpleos_riscv64_desktop_service.elf"
    ]

pub fn text_list_contains_value(values: [text], expected: text) -> bool:
    for value in values:
        if value == expected:
            return true
    false

pub fn qemu_riscv64_desktop_qemu_args_status(args: [text]) -> text:
    if not text_list_contains_value(args, "user,id=rvnet,hostfwd=tcp::2222-:22,hostfwd=tcp::8080-:8080"):
        return "blocked:missing-qemu-user-net-hostfwd"
    if not text_list_contains_value(args, "virtio-net-pci,netdev=rvnet"):
        return "blocked:missing-virtio-net-device"
    if not text_list_contains_value(args, "virtio-gpu-pci,disable-modern=on,disable-legacy=off"):
        return "blocked:missing-virtio-gpu-device"
    if not text_list_contains_value(args, "none"):
        return "blocked:missing-qemu-headless-display"
    if not text_list_contains_value(args, "tcp:127.0.0.1:4444,server,nowait"):
        return "blocked:missing-qemu-qmp-screendump-channel"
    if not text_list_contains_value(args, "file:build/os/systest/qemu-riscv64-desktop/serial.log"):
        return "blocked:missing-serial-log"
    if not text_list_contains_value(args, qemu_riscv64_desktop_kernel_path()):
        return "blocked:missing-rv64-kernel"
    if not text_list_contains_value(args, "file=build/os/fat32-riscv64.img,if=none,id=rvdisk,format=raw"):
        return "blocked:missing-rv64-disk"
    "ready"

