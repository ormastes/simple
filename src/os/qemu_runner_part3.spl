fn scenario_x64_q35_pure_nvme_perf() -> QemuScenario:
    """x86_64 q35 pure-Simple NVMe + FAT/NVFS/DBFS performance proof lane."""
    val lane = simpleos_platform_qemu_lane("x86_64", "x86_64-q35-pure-nvme-perf")
    if val resolved = lane:
        return QemuScenario(
            name: resolved.name,
            arch: Architecture.X86_64,
            machine: "q35",
            cpu: "qemu64",
            memory: resolved.qemu_memory,
            qemu_extra: resolved.qemu_extra,
            gui_mode: false,
            description: "x86_64 q35 pure-Simple NVMe shared-DMA FAT/NVFS/DBFS performance proof"
        )
    QemuScenario(
        name: "x86_64-q35-pure-nvme-perf",
        arch: Architecture.X86_64,
        machine: "q35",
        cpu: "qemu64",
        memory: "512M",
        qemu_extra: [],
        gui_mode: false,
        description: "x86_64 q35 pure-Simple NVMe shared-DMA FAT/NVFS/DBFS performance proof"
    )

