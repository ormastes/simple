fn scenario_x64_nvme_fat32() -> QemuScenario:
    """x86_64 with NVMe + FAT32 disk image for file I/O testing.

    Uses the fixture disk built by scripts/make_os_disk.shs. Unlike desktop
    lanes this does not prefer release images because the filesystem contract
    asserts on fixture files such as HELLO.TXT, NUMBERS.TXT, and HELLO.SPL.
    """
    QemuScenario(
        name: "x64-nvme-fat32",
        arch: Architecture.X86_64,
        machine: "q35",
        cpu: "qemu64",
        memory: "384M",
        qemu_extra: _x64_nvme_fs_test_disk_args() + ["-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"],
        gui_mode: false,
        description: "x86_64 with NVMe + FAT32 disk image for file I/O testing"
    )

