// Unified Storage Interface — shared DMA descriptors, results, metrics, and acceptance gate
// Supports NVMe and VirtIO-BLK backends

class DmaDescriptor:
    phys_addr: i64
    length: i64
    direction: text
    completed: bool
    error: bool
    error_code: i64
    timeout_ms: i64
    elapsed_ms: i64

    static fn read_op(addr: i64, len: i64, timeout: i64) -> DmaDescriptor:
        DmaDescriptor(
            phys_addr: addr,
            length: len,
            direction: "read",
            completed: false,
            error: false,
            error_code: 0,
            timeout_ms: timeout,
            elapsed_ms: 0
        )

    static fn write_op(addr: i64, len: i64, timeout: i64) -> DmaDescriptor:
        DmaDescriptor(
            phys_addr: addr,
            length: len,
            direction: "write",
            completed: false,
            error: false,
            error_code: 0,
            timeout_ms: timeout,
            elapsed_ms: 0
        )

    me complete_ok(elapsed: i64) -> text:
        self.completed = true
        self.elapsed_ms = elapsed
        "dma:" + self.direction + ":ok:elapsed=" + elapsed.to_text() + "ms"

    me complete_error(code: i64, elapsed: i64) -> text:
        self.completed = true
        self.error = true
        self.error_code = code
        self.elapsed_ms = elapsed
        "dma:" + self.direction + ":error:code=" + code.to_text() + ":elapsed=" + elapsed.to_text() + "ms"

    me is_timeout() -> bool:
        self.elapsed_ms > self.timeout_ms

    me summary() -> text:
        val status = if self.error == true: "error(code=" + self.error_code.to_text() + ")"
                     else if self.completed == true: "ok"
                     else: "pending"
        "DmaDescriptor{dir=" + self.direction + ",addr=" + self.phys_addr.to_text() +
            ",len=" + self.length.to_text() + ",status=" + status +
            ",elapsed=" + self.elapsed_ms.to_text() + "ms}"


class StorageResult:
    op_type: text
    backend: text
    lba: i64
    sector_count: i64
    bytes_transferred: i64
    success: bool
    error_msg: text
    dma: DmaDescriptor

    static fn success_read(backend: text, lba: i64, sectors: i64, bytes: i64, dma: DmaDescriptor) -> StorageResult:
        StorageResult(
            op_type: "read",
            backend: backend,
            lba: lba,
            sector_count: sectors,
            bytes_transferred: bytes,
            success: true,
            error_msg: "",
            dma: dma
        )

    static fn success_write(backend: text, lba: i64, sectors: i64, bytes: i64, dma: DmaDescriptor) -> StorageResult:
        StorageResult(
            op_type: "write",
            backend: backend,
            lba: lba,
            sector_count: sectors,
            bytes_transferred: bytes,
            success: true,
            error_msg: "",
            dma: dma
        )

    static fn error(backend: text, op: text, lba: i64, msg: text) -> StorageResult:
        val placeholder = DmaDescriptor.read_op(0, 0, 0)
        StorageResult(
            op_type: op,
            backend: backend,
            lba: lba,
            sector_count: 0,
            bytes_transferred: 0,
            success: false,
            error_msg: msg,
            dma: placeholder
        )

    me is_ok() -> bool:
        self.success

    me summary() -> text:
        val status = if self.success == true: "ok:bytes=" + self.bytes_transferred.to_text()
                     else: "error:" + self.error_msg
        "StorageResult{op=" + self.op_type + ",backend=" + self.backend +
            ",lba=" + self.lba.to_text() + ",sectors=" + self.sector_count.to_text() +
            "," + status + "}"


class StorageQueueMetrics:
    submitted: i64
    completed: i64
    errors: i64
    timeouts: i64
    avg_latency_us: i64
    max_latency_us: i64

    static fn create() -> StorageQueueMetrics:
        StorageQueueMetrics(
            submitted: 0,
            completed: 0,
            errors: 0,
            timeouts: 0,
            avg_latency_us: 0,
            max_latency_us: 0
        )

    me record_completion(latency_us: i64) -> i64:
        self.submitted = self.submitted + 1
        self.completed = self.completed + 1
        val total = self.avg_latency_us * (self.completed - 1) + latency_us
        self.avg_latency_us = total / self.completed
        if latency_us > self.max_latency_us:
            self.max_latency_us = latency_us
        self.completed

    me record_error() -> i64:
        self.submitted = self.submitted + 1
        self.errors = self.errors + 1
        self.errors

    me record_timeout() -> i64:
        self.submitted = self.submitted + 1
        self.timeouts = self.timeouts + 1
        self.timeouts

    me pending() -> i64:
        self.submitted - self.completed - self.errors - self.timeouts

    me stats() -> text:
        "StorageQueueMetrics{submitted=" + self.submitted.to_text() +
            ",completed=" + self.completed.to_text() +
            ",errors=" + self.errors.to_text() +
            ",timeouts=" + self.timeouts.to_text() +
            ",avg_us=" + self.avg_latency_us.to_text() +
            ",max_us=" + self.max_latency_us.to_text() +
            ",pending=" + self.pending().to_text() + "}"


class UnifiedStorageDriver:
    backend: text
    initialized: bool
    sector_size: i64
    total_sectors: i64
    metrics: StorageQueueMetrics

    static fn nvme(sectors: i64) -> UnifiedStorageDriver:
        UnifiedStorageDriver(
            backend: "nvme",
            initialized: true,
            sector_size: 512,
            total_sectors: sectors,
            metrics: StorageQueueMetrics.create()
        )

    static fn virtio_blk(sectors: i64) -> UnifiedStorageDriver:
        UnifiedStorageDriver(
            backend: "virtio_blk",
            initialized: true,
            sector_size: 512,
            total_sectors: sectors,
            metrics: StorageQueueMetrics.create()
        )

    me read_sectors(lba: i64, count: i64) -> StorageResult:
        if self.initialized == false:
            return StorageResult.error(self.backend, "read", lba, "driver not initialized")
        if lba + count > self.total_sectors:
            return StorageResult.error(self.backend, "read", lba, "lba out of range")
        val bytes = count * self.sector_size
        val addr = lba * self.sector_size
        var dma = DmaDescriptor.read_op(addr, bytes, 5000)
        dma.complete_ok(1)
        self.metrics.record_completion(1000)
        StorageResult.success_read(self.backend, lba, count, bytes, dma)

    me write_sectors(lba: i64, count: i64) -> StorageResult:
        if self.initialized == false:
            return StorageResult.error(self.backend, "write", lba, "driver not initialized")
        if lba + count > self.total_sectors:
            return StorageResult.error(self.backend, "write", lba, "lba out of range")
        val bytes = count * self.sector_size
        val addr = lba * self.sector_size
        var dma = DmaDescriptor.write_op(addr, bytes, 5000)
        dma.complete_ok(2)
        self.metrics.record_completion(2000)
        StorageResult.success_write(self.backend, lba, count, bytes, dma)

    me capacity_bytes() -> i64:
        self.sector_size * self.total_sectors

    me stats() -> text:
        "UnifiedStorageDriver{backend=" + self.backend +
            ",initialized=" + self.initialized.to_text() +
            ",capacity=" + self.capacity_bytes().to_text() +
            "," + self.metrics.stats() + "}"


class StorageAcceptance:
    nvme_available: bool
    virtio_blk_available: bool
    primary_backend: text
    mount_tested: bool
    app_read_tested: bool
    uses_vfs_streams: bool
    uses_host_bridge: bool

    static fn create() -> StorageAcceptance:
        StorageAcceptance(
            nvme_available: false,
            virtio_blk_available: false,
            primary_backend: "none",
            mount_tested: false,
            app_read_tested: false,
            uses_vfs_streams: false,
            uses_host_bridge: false
        )

    me select_primary() -> text:
        if self.nvme_available == true:
            self.primary_backend = "nvme"
        else if self.virtio_blk_available == true:
            self.primary_backend = "virtio_blk"
        else:
            self.primary_backend = "none"
        self.primary_backend

    me passes() -> bool:
        val primary = self.select_primary()
        val backend_ok = primary == "nvme" || primary == "virtio_blk"
        backend_ok && self.mount_tested && self.app_read_tested &&
            self.uses_vfs_streams && self.uses_host_bridge == false

    me report() -> text:
        val primary = self.select_primary()
        val pass_str = if self.passes() == true: "PASS" else: "FAIL"
        "StorageAcceptance{primary=" + primary +
            ",mount_tested=" + self.mount_tested.to_text() +
            ",app_read_tested=" + self.app_read_tested.to_text() +
            ",uses_vfs_streams=" + self.uses_vfs_streams.to_text() +
            ",uses_host_bridge=" + self.uses_host_bridge.to_text() +
            ",result=" + pass_str + "}"
