# Framebuffer Driver — Pixel Rendering on Limine Framebuffer
#
# MDSOC: feature dimension, drivers layer
# Input: BootOutputPort.framebuffer (address, width, height, pitch, bpp)
# Provides: fill_rect, draw_char, blit, swap_buffers
#
# Uses double buffering: draw to back buffer, swap to front on vsync.

use os.kernel.boot.ports.{FramebufferInfo, framebuffer_info_phys_addr}
use os.kernel.boot.mmio.{mmio_write32, mmio_read32}
use std.gpu.engine2d.framebuffer_surface.{FramebufferSurface}
use os.drivers.framebuffer.fb_font.{get_glyph_8x16}

# ============================================================================
# Color
# ============================================================================

struct Color:
    """32-bit ARGB color."""
    r: u8
    g: u8
    b: u8
    a: u8

impl Color:
    fn to_u32() -> u32:
        """Convert to 32-bit ARGB pixel value."""
        ((self.a.to_u32() << 24) | (self.r.to_u32() << 16) | (self.g.to_u32() << 8) | self.b.to_u32())

    static fn rgb(r: u8, g: u8, b: u8) -> Color:
        Color(r: r, g: g, b: b, a: 255)

    static fn black() -> Color: Color.rgb(0, 0, 0)
    static fn white() -> Color: Color.rgb(255, 255, 255)
    static fn red() -> Color: Color.rgb(255, 0, 0)
    static fn green() -> Color: Color.rgb(0, 255, 0)
    static fn blue() -> Color: Color.rgb(0, 0, 255)
    static fn gray() -> Color: Color.rgb(128, 128, 128)
    static fn dark_gray() -> Color: Color.rgb(64, 64, 64)
    static fn light_gray() -> Color: Color.rgb(192, 192, 192)

struct DamageRect:
    """Exclusive-end framebuffer damage rectangle."""
    x1: u32
    y1: u32
    x2: u32
    y2: u32
    valid: bool

impl DamageRect:
    fn width() -> u32:
        if not self.valid or self.x2 <= self.x1:
            return 0
        self.x2 - self.x1

    fn height() -> u32:
        if not self.valid or self.y2 <= self.y1:
            return 0
        self.y2 - self.y1

struct FramebufferCapabilities:
    """Display backend capability summary for compositor selection."""
    backend_kind: text
    width: u32
    height: u32
    bpp: u32
    flush_mode: text
    cache_policy: text

# ============================================================================
# Framebuffer Driver
# ============================================================================

class FramebufferDriver:
    """Double-buffered framebuffer driver.

    Three modes:
    - Direct MMIO (`from_boot_info`): writes via `mmio_write32` against the
      hardware framebuffer at `front_addr`. `host_buffer` is empty.
    - Empty stub (`empty`): no-op for hosted mode where the hardware FB is
      unused.
    - Host-backed headless (`from_buffer`): writes go to the in-process
      `host_buffer: [u32]` ARGB array. Used by V1/V2 parity tests so the
      same `FramebufferDriver`-based render path can be exercised without
      QEMU. See doc/03_plan/sys_test/wm_compare_v1_v2_parity.md.
    """
    front_addr: u64         # Hardware framebuffer address (from Limine), 0 in headless mode
    back_buffer: [u32]      # Software back buffer (currently unused)
    host_buffer: [u32]      # Host-backed headless buffer (ARGB8888, len = w*h)
    width: u32
    height: u32
    pitch: u32              # Bytes per scanline
    bpp: u32                # Bits per pixel
    dirty: bool             # Buffer has changes
    dirty_x1: u32
    dirty_y1: u32
    dirty_x2: u32
    dirty_y2: u32

impl FramebufferDriver:

    static fn empty() -> FramebufferDriver:
        """Create a dummy driver (for hosted mode where hardware FB is unused)."""
        FramebufferDriver(
            front_addr: 0,
            back_buffer: [],
            host_buffer: [],
            width: 0,
            height: 0,
            pitch: 0,
            bpp: 0,
            dirty: false,
            dirty_x1: 0,
            dirty_y1: 0,
            dirty_x2: 0,
            dirty_y2: 0
        )

    static fn from_boot_info(fb: FramebufferInfo) -> FramebufferDriver:
        """Create driver from Limine framebuffer info.

        Direct-write mode: no back buffer allocated. All rendering
        writes directly to the hardware framebuffer via MMIO.
        """
        FramebufferDriver(
            front_addr: framebuffer_info_phys_addr(fb),
            back_buffer: [],
            host_buffer: [],
            width: fb.width,
            height: fb.height,
            pitch: fb.pitch,
            bpp: fb.bpp,
            dirty: false,
            dirty_x1: 0,
            dirty_y1: 0,
            dirty_x2: 0,
            dirty_y2: 0
        )

    static fn from_buffer(width: u32, height: u32) -> FramebufferDriver:
        """Create a host-backed headless framebuffer driver.

        The driver wraps an in-process `[u32]` ARGB8888 buffer of
        `width * height` pixels. All draw/read methods route through
        the buffer instead of MMIO. Used by the wm_compare V1/V2 parity
        harness so `fb_backend` can be exercised without booting QEMU.

        See doc/03_plan/sys_test/wm_compare_v1_v2_parity.md.
        """
        var buf: [u32] = []
        var i: u32 = 0
        val total = width * height
        while i < total:
            buf = buf + [0u32]
            i = i + 1
        FramebufferDriver(
            front_addr: 0,
            back_buffer: [],
            host_buffer: buf,
            width: width,
            height: height,
            pitch: width * 4,
            bpp: 32,
            dirty: false,
            dirty_x1: 0,
            dirty_y1: 0,
            dirty_x2: 0,
            dirty_y2: 0
        )

    fn is_host_backed() -> bool:
        """True if this driver is wrapping an in-process pixel buffer."""
        self.front_addr == 0 and self.width > 0 and self.height > 0

    fn host_pixels() -> [u32]:
        """Snapshot of the host-backed pixel buffer (ARGB8888, row-major).

        Returns an empty array on non-host-backed drivers. Callers that
        want a stable snapshot should treat the result as read-only —
        the array is the live buffer reference, not a copy.
        """
        self.host_buffer

    me mark_dirty_rect(x: u32, y: u32, w: u32, h: u32):
        """Record framebuffer damage using exclusive-end coordinates."""
        if w == 0 or h == 0 or self.width == 0 or self.height == 0:
            return
        if x >= self.width or y >= self.height:
            return
        var x2_u = x.to_u64() + w.to_u64()
        var y2_u = y.to_u64() + h.to_u64()
        if x2_u > self.width.to_u64():
            x2_u = self.width.to_u64()
        if y2_u > self.height.to_u64():
            y2_u = self.height.to_u64()
        val x2 = x2_u.to_u32()
        val y2 = y2_u.to_u32()
        if x2 <= x or y2 <= y:
            return
        if not self.dirty:
            self.dirty_x1 = x
            self.dirty_y1 = y
            self.dirty_x2 = x2
            self.dirty_y2 = y2
        else:
            if x < self.dirty_x1:
                self.dirty_x1 = x
            if y < self.dirty_y1:
                self.dirty_y1 = y
            if x2 > self.dirty_x2:
                self.dirty_x2 = x2
            if y2 > self.dirty_y2:
                self.dirty_y2 = y2
        self.dirty = true

    fn dirty_rect() -> DamageRect:
        DamageRect(
            x1: self.dirty_x1,
            y1: self.dirty_y1,
            x2: self.dirty_x2,
            y2: self.dirty_y2,
            valid: self.dirty
        )

    me clear_dirty():
        self.dirty = false
        self.dirty_x1 = 0
        self.dirty_y1 = 0
        self.dirty_x2 = 0
        self.dirty_y2 = 0

    fn capabilities() -> FramebufferCapabilities:
        val backend = if self.front_addr == 0: "host-buffer" else: "framebuffer-mmio"
        FramebufferCapabilities(
            backend_kind: backend,
            width: self.width,
            height: self.height,
            bpp: self.bpp,
            flush_mode: "dirty-rect",
            cache_policy: if self.front_addr == 0: "coherent" else: "uncached"
        )

    me put_pixel(x: u32, y: u32, color: Color):
        """Set a single pixel on the active surface (MMIO or host buffer)."""
        if x >= self.width or y >= self.height:
            return
        val pixel = color.to_u32()
        if self.front_addr != 0:
            val offset = (y * self.width + x) * 4
            mmio_write32(self.front_addr + offset.to_u64(), pixel)
        else:
            val idx = (y * self.width + x).to_i64()
            if idx < self.host_buffer.length().to_i64():
                self.host_buffer[idx] = pixel
        self.mark_dirty_rect(x, y, 1, 1)

    me fill_rect(x: u32, y: u32, w: u32, h: u32, color: Color):
        """Fill a rectangle on the active surface (MMIO or host buffer)."""
        val pixel = color.to_u32()
        val host_backed = self.front_addr == 0
        var row: u32 = 0
        while row < h:
            val py = y + row
            if py >= self.height:
                return
            var col: u32 = 0
            while col < w:
                val px = x + col
                if px < self.width:
                    if host_backed:
                        val idx = (py * self.width + px).to_i64()
                        if idx < self.host_buffer.length().to_i64():
                            self.host_buffer[idx] = pixel
                    else:
                        val offset = (py * self.width + px) * 4
                        mmio_write32(self.front_addr + offset.to_u64(), pixel)
                col = col + 1
            row = row + 1
        self.mark_dirty_rect(x, y, w, h)

    me draw_char_8x16(x: u32, y: u32, ch: u8, fg: Color, bg: Color):
        """Draw a single character using built-in 8x16 bitmap font.

        Each character is 8 pixels wide, 16 pixels tall.
        Font data from VGA ROM bitmap (PSF format).
        """
        val glyph = get_glyph_8x16(ch)
        var row: u32 = 0
        while row < 16:
            val bits = glyph[row]
            var col: u32 = 0
            while col < 8:
                val mask = 0x80 >> col
                val color = if (bits & mask) != 0: fg else: bg
                val px = x + col
                val py = y + row
                self.put_pixel(px, py, color)
                col = col + 1
            row = row + 1

    me draw_text(x: u32, y: u32, text_str: text, fg: Color, bg: Color):
        """Draw a text string using 8x16 font."""
        var cx = x
        for ch in text_str:
            val ch_byte = ch.to_u8()
            self.draw_char_8x16(cx, y, ch_byte, fg, bg)
            cx = cx + 8

    me swap_buffers():
        """No-op in direct-write mode (already writing to hardware FB)."""
        self.clear_dirty()

    me present_rect(x: u32, y: u32, w: u32, h: u32):
        """Present a bounded region when the backend supports partial flush."""
        self.mark_dirty_rect(x, y, w, h)
        self.clear_dirty()

    me flush_dirty_rects():
        """Flush tracked damage and clear the damage state.

        Direct-MMIO and host-backed framebuffer modes write pixels eagerly, so
        this currently clears bookkeeping. GPU backends consume the same
        DamageRect contract before issuing transfer/flush commands.
        """
        self.clear_dirty()

    me clear(color: Color):
        """Clear entire framebuffer (MMIO or host buffer)."""
        val pixel = color.to_u32()
        val total = self.width * self.height
        if self.front_addr != 0:
            var i: u32 = 0
            while i < total:
                val offset = (i * 4).to_u64()
                mmio_write32(self.front_addr + offset, pixel)
                i = i + 1
        else:
            val cap = self.host_buffer.length().to_i64()
            var j: i64 = 0
            val tot_i = total.to_i64()
            while j < tot_i and j < cap:
                self.host_buffer[j] = pixel
                j = j + 1
        self.mark_dirty_rect(0, 0, self.width, self.height)

    fn pixel_count() -> u32:
        self.width * self.height

    me blend_pixel(x: u32, y: u32, color: Color, alpha: u8):
        """Alpha-blend a pixel on the active surface (MMIO or host buffer)."""
        if x >= self.width or y >= self.height:
            return
        val inv = 255 - alpha.to_u32()
        val sr = color.r.to_u32()
        val sg = color.g.to_u32()
        val sb = color.b.to_u32()
        var dst: u32 = 0
        if self.front_addr != 0:
            val offset = ((y * self.width + x) * 4).to_u64()
            dst = mmio_read32(self.front_addr + offset)
        else:
            val idx = (y * self.width + x).to_i64()
            if idx >= self.host_buffer.length().to_i64():
                return
            dst = self.host_buffer[idx]
        val dr = (dst >> 16) & 0xFF
        val dg = (dst >> 8) & 0xFF
        val db = dst & 0xFF
        val rr = (sr * alpha.to_u32() + dr * inv + 128) >> 8
        val rg = (sg * alpha.to_u32() + dg * inv + 128) >> 8
        val rb = (sb * alpha.to_u32() + db * inv + 128) >> 8
        val out = 0xFF000000 | (rr << 16) | (rg << 8) | rb
        if self.front_addr != 0:
            val offset2 = ((y * self.width + x) * 4).to_u64()
            mmio_write32(self.front_addr + offset2, out)
        else:
            val idx2 = (y * self.width + x).to_i64()
            self.host_buffer[idx2] = out
        self.mark_dirty_rect(x, y, 1, 1)

    me blend_rect(x: u32, y: u32, w: u32, h: u32, color: Color, alpha: u8):
        """Alpha-blend a filled rectangle directly on the hardware framebuffer."""
        var row: u32 = 0
        while row < h:
            var col: u32 = 0
            while col < w:
                self.blend_pixel(x + col, y + row, color, alpha)
                col = col + 1
            row = row + 1

    fn read_pixel(x: u32, y: u32) -> u32:
        """Read a pixel from the active surface (MMIO or host buffer)."""
        if x >= self.width or y >= self.height:
            return 0
        if self.front_addr != 0:
            val offset = ((y * self.width + x) * 4).to_u64()
            return mmio_read32(self.front_addr + offset)
        val idx = (y * self.width + x).to_i64()
        if idx >= self.host_buffer.length().to_i64():
            return 0
        self.host_buffer[idx]

fn framebuffer_argb_to_color(argb: u32) -> Color:
    Color(
        r: ((argb >> 16) & 0xFF).to_u8(),
        g: ((argb >> 8) & 0xFF).to_u8(),
        b: (argb & 0xFF).to_u8(),
        a: ((argb >> 24) & 0xFF).to_u8()
    )

impl FramebufferSurface for FramebufferDriver:
    fn framebuffer_width() -> u32:
        self.width

    fn framebuffer_height() -> u32:
        self.height

    me framebuffer_clear_argb(color: u32):
        self.clear(framebuffer_argb_to_color(color))

    me framebuffer_fill_rect_argb(x: u32, y: u32, w: u32, h: u32, color: u32):
        self.fill_rect(x, y, w, h, framebuffer_argb_to_color(color))

    me framebuffer_put_pixel_argb(x: u32, y: u32, color: u32):
        self.put_pixel(x, y, framebuffer_argb_to_color(color))

    fn framebuffer_read_pixel_argb(x: u32, y: u32) -> u32:
        self.read_pixel(x, y)

    me framebuffer_present():
        self.swap_buffers()
