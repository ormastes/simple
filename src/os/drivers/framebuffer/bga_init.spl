# BGA (Bochs Graphics Adapter) Framebuffer Init
#
# Programs the Bochs VGA Extension via I/O ports to set up a linear
# framebuffer mode. Works with QEMU's -vga std on Q35/PC machines.
# No bootloader support needed -- kernel programs the VGA device directly.
#
# BGA I/O ports:
#   0x01CE - Index register (select which BGA register to access)
#   0x01CF - Data register (read/write the selected register)
#
# PCI BAR0 of the VGA device holds the linear framebuffer address.

use os.kernel.arch.x86_64.cpu.{port_outw, port_inw, port_outl, port_inl}
use os.kernel.boot.ports.{FramebufferInfo}
use os.kernel.types.memory_types.{PhysAddr}

# BGA I/O ports
val BGA_INDEX_PORT: u16 = 0x01CE
val BGA_DATA_PORT: u16 = 0x01CF

# BGA register indices
val VBE_DISPI_INDEX_ID: u16 = 0x00
val VBE_DISPI_INDEX_XRES: u16 = 0x01
val VBE_DISPI_INDEX_YRES: u16 = 0x02
val VBE_DISPI_INDEX_BPP: u16 = 0x03
val VBE_DISPI_INDEX_ENABLE: u16 = 0x04
val VBE_DISPI_INDEX_VIRT_WIDTH: u16 = 0x06

# BGA enable flags
val VBE_DISPI_DISABLED: u16 = 0x00
val VBE_DISPI_ENABLED: u16 = 0x01
val VBE_DISPI_LFB_ENABLED: u16 = 0x40

# PCI configuration space I/O ports
val PCI_CONFIG_ADDRESS: u16 = 0x0CF8
val PCI_CONFIG_DATA: u16 = 0x0CFC

# PCI address for VGA device on Q35: bus 0, device 1, function 0
# PCI_CONFIG_ADDRESS format: bit 31=enable, bits 23:16=bus, 15:11=device, 10:8=function, 7:2=register
val PCI_VGA_BASE: u32 = 0x80000800  # enable + bus 0 + device 1 + function 0

# Fallback LFB address for QEMU Q35 with -vga std
val FALLBACK_LFB_ADDR: u64 = 0xFD000000

fn bga_write(index: u16, value: u16):
    """Write a value to a BGA register."""
    port_outw(BGA_INDEX_PORT, index)
    port_outw(BGA_DATA_PORT, value)

fn bga_read(index: u16) -> u16:
    """Read a value from a BGA register."""
    port_outw(BGA_INDEX_PORT, index)
    port_inw(BGA_DATA_PORT)

fn pci_config_read32(bus: u8, device: u8, function: u8, offset: u8) -> u32:
    """Read a 32-bit PCI configuration space register."""
    val address: u32 = 0x80000000 |
        (bus.to_u32() << 16) |
        (device.to_u32() << 11) |
        (function.to_u32() << 8) |
        (offset.to_u32() & 0xFC)
    port_outl(PCI_CONFIG_ADDRESS, address)
    port_inl(PCI_CONFIG_DATA)

fn detect_vga_lfb_address() -> u64:
    """Detect the VGA linear framebuffer address via PCI BAR0.

    Scans PCI bus 0 for a VGA-compatible controller (class 0x03, subclass 0x00).
    Returns BAR0 address masked to page boundary, or fallback 0xFD000000.
    """
    # Scan bus 0, devices 0-31 for VGA controller
    var dev: u8 = 0
    while dev < 32:
        val vendor = pci_config_read32(0, dev, 0, 0x00) & 0xFFFF
        if vendor != 0xFFFF and vendor != 0x0000:
            # Read class code (offset 0x08, bits 31:24=class, 23:16=subclass)
            val class_reg = pci_config_read32(0, dev, 0, 0x08)
            val class_code = (class_reg >> 24) & 0xFF
            val subclass = (class_reg >> 16) & 0xFF
            if class_code == 0x03 and subclass == 0x00:
                # Found VGA controller -- read BAR0 (offset 0x10)
                val bar0 = pci_config_read32(0, dev, 0, 0x10)
                val lfb_addr = (bar0 & 0xFFFFFFF0).to_u64()
                if lfb_addr != 0:
                    return lfb_addr
        dev = dev + 1
    # Fallback for QEMU Q35
    FALLBACK_LFB_ADDR

fn bga_init_framebuffer(width: u32, height: u32, bpp: u32) -> FramebufferInfo:
    """Initialize BGA framebuffer to the requested resolution.

    Programs the Bochs Graphics Adapter via I/O ports and detects
    the linear framebuffer address via PCI BAR0 scan.

    Returns FramebufferInfo ready for FramebufferDriver.from_boot_info().
    """
    # Verify BGA is present (ID register should be >= 0xB0C0)
    val id = bga_read(VBE_DISPI_INDEX_ID)

    # Disable display first
    bga_write(VBE_DISPI_INDEX_ENABLE, VBE_DISPI_DISABLED)

    # Set resolution and color depth
    bga_write(VBE_DISPI_INDEX_XRES, width.to_u16())
    bga_write(VBE_DISPI_INDEX_YRES, height.to_u16())
    bga_write(VBE_DISPI_INDEX_BPP, bpp.to_u16())
    bga_write(VBE_DISPI_INDEX_VIRT_WIDTH, width.to_u16())

    # Enable with LFB (Linear Framebuffer) mode
    bga_write(VBE_DISPI_INDEX_ENABLE, VBE_DISPI_ENABLED | VBE_DISPI_LFB_ENABLED)

    # Detect LFB address from PCI
    val lfb_addr = detect_vga_lfb_address()

    val pitch = width * (bpp / 8)

    FramebufferInfo(
        addr: PhysAddr(addr: lfb_addr),
        width: width,
        height: height,
        pitch: pitch,
        bpp: bpp
    )
