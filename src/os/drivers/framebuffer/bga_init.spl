# BGA (Bochs Graphics Adapter) Framebuffer Init
#
# Programs the Bochs VGA Extension via I/O ports to set up a linear
# framebuffer mode. Works with QEMU's -vga std on Q35/PC machines.
# No bootloader support needed -- kernel programs the VGA device directly.
#
# BGA I/O ports:
#   0x01CE - Index register (select which BGA register to access)
#   0x01CF - Data register (read/write the selected register)
#
# PCI BAR0 of the VGA device holds the linear framebuffer address.

use os.kernel.arch_adapt.x86_64.cpu.{port_outw, port_inw, port_outl, port_inl}
use os.kernel.boot.mmio.{mmio_read16, mmio_write16}
use os.kernel.boot.ports.{FramebufferInfo, framebuffer_info_phys_addr}
use os.kernel.types.memory_types.{PhysAddr}

# BGA I/O ports
val BGA_INDEX_PORT: u16 = 0x01CE
val BGA_DATA_PORT: u16 = 0x01D0

# BGA register indices
val VBE_DISPI_INDEX_ID: u16 = 0x00
val VBE_DISPI_INDEX_XRES: u16 = 0x01
val VBE_DISPI_INDEX_YRES: u16 = 0x02
val VBE_DISPI_INDEX_BPP: u16 = 0x03
val VBE_DISPI_INDEX_ENABLE: u16 = 0x04
val VBE_DISPI_INDEX_VIRT_WIDTH: u16 = 0x06

# BGA enable flags
val VBE_DISPI_DISABLED: u16 = 0x00
val VBE_DISPI_ENABLED: u16 = 0x01
val VBE_DISPI_LFB_ENABLED: u16 = 0x40

# PCI configuration space I/O ports
val PCI_CONFIG_ADDRESS: u16 = 0x0CF8
val PCI_CONFIG_DATA: u16 = 0x0CFC

# PCI address for VGA device on Q35: bus 0, device 1, function 0
# PCI_CONFIG_ADDRESS format: bit 31=enable, bits 23:16=bus, 15:11=device, 10:8=function, 7:2=register
val PCI_VGA_BASE: u32 = 0x80000800  # enable + bus 0 + device 1 + function 0

# Fallback LFB address for QEMU Q35 with -vga std
val FALLBACK_LFB_ADDR: u64 = 0xFD000000

struct BgaDisplayCapabilities:
    backend_kind: text
    flush_mode: text
    cache_policy: text
    dma_accelerated: bool

struct ScanoutEvidence:
    """Authoritative metadata for one initialized hardware scanout."""
    address: u64
    width: u32
    height: u32
    stride: u32
    pixel_format: text
    generation: u64

struct BgaPciDevice:
    found: bool
    device: u8
    framebuffer_bar: u64
    mmio_bar: u64

fn scanout_pixel_format(bpp: u32) -> text:
    if bpp == 32:
        return "argb8888"
    if bpp == 24:
        return "rgb888"
    if bpp == 16:
        return "rgb565"
    "unknown"

fn scanout_evidence_from_framebuffer(fb: FramebufferInfo, generation: u64) -> ScanoutEvidence:
    """Describe initialized framebuffer state without re-reading hardware."""
    ScanoutEvidence(
        address: framebuffer_info_phys_addr(fb),
        width: fb.width,
        height: fb.height,
        stride: fb.pitch,
        pixel_format: scanout_pixel_format(fb.bpp),
        generation: generation
    )

fn scanout_stride_pixels(scanout: ScanoutEvidence) -> u32:
    """Return row pitch in pixels, or zero for an unsupported format."""
    if scanout.pixel_format != "argb8888":
        return 0
    if scanout.stride % 4 != 0:
        return 0
    scanout.stride / 4

fn scanout_evidence_is_valid(scanout: ScanoutEvidence) -> bool:
    """Reject incomplete, unsupported, or undersized scanout metadata."""
    if scanout.address == 0 or scanout.width == 0 or scanout.height == 0:
        return false
    if scanout.generation == 0 or scanout.pixel_format != "argb8888":
        return false
    val stride_pixels = scanout_stride_pixels(scanout)
    stride_pixels >= scanout.width

fn bga_display_capabilities() -> BgaDisplayCapabilities:
    """Return the legacy BGA capability summary.

    BGA exposes a linear MMIO framebuffer. It may benefit from write-combining
    mappings, but it is not a DMA transfer path.
    """
    BgaDisplayCapabilities(
        backend_kind: "bga-write-combining",
        flush_mode: "dirty-rect",
        cache_policy: "write-combining",
        dma_accelerated: false
    )

fn bga_write(index: u16, value: u16):
    """Write a value to a BGA register."""
    # Freestanding calls can occur before module-value initialization. Keep
    # hardware protocol addresses immediate at the I/O boundary.
    port_outw(0x01CE, index)
    # QEMU exposes 0x1d0 as the aligned 16-bit data port. 0x1cf is an
    # x86-only compatibility port whose odd-address word access is not
    # reliable across the freestanding/QEMU path.
    port_outw(0x01D0, value)

fn bga_read(index: u16) -> u16:
    """Read a value from a BGA register."""
    port_outw(0x01CE, index)
    port_inw(0x01D0)

fn bga_device_id() -> u32:
    """Read the active Bochs/QEMU VBE device identifier for diagnostics."""
    bga_read(0x00) as u32

fn pci_config_read32(bus: u8, device: u8, pci_fn: u8, offset: u8) -> u32:
    """Read a 32-bit PCI configuration space register."""
    val address: u32 = 0x80000000 |
        ((bus as u32) << 16) |
        ((device as u32) << 11) |
        ((pci_fn as u32) << 8) |
        ((offset as u32) & 0xFC)
    port_outl(0x0CF8, address)
    port_inl(0x0CFC)

fn pci_config_write16(bus: u8, device: u8, pci_fn: u8, offset: u8, value: u16):
    val address: u32 = 0x80000000 |
        ((bus as u32) << 16) |
        ((device as u32) << 11) |
        ((pci_fn as u32) << 8) |
        ((offset as u32) & 0xFC)
    port_outl(0x0CF8, address)
    port_outw((0x0CFC + ((offset as u16) & 0x02)), value)

fn find_bga_pci_device() -> BgaPciDevice:
    var dev: u8 = 0
    while dev < 32:
        val identity = pci_config_read32(0, dev, 0, 0x00)
        val vendor = identity & 0xFFFF
        if vendor != 0xFFFF and vendor != 0x0000:
            val class_reg = pci_config_read32(0, dev, 0, 0x08)
            if ((class_reg >> 24) & 0xFF) == 0x03:
                val bar0 = (pci_config_read32(0, dev, 0, 0x10) & 0xFFFFFFF0) as u64
                val bar2 = (pci_config_read32(0, dev, 0, 0x18) & 0xFFFFFFF0) as u64
                return BgaPciDevice(found: true, device: dev, framebuffer_bar: bar0, mmio_bar: bar2)
        dev = dev + 1
    BgaPciDevice(found: false, device: 0, framebuffer_bar: 0, mmio_bar: 0)

fn enable_vga_pci_decode() -> bool:
    """Enable I/O and memory decoding on the discovered VGA controller."""
    var dev: u8 = 0
    while dev < 32:
        val identity = pci_config_read32(0, dev, 0, 0x00)
        val vendor = identity & 0xFFFF
        if vendor != 0xFFFF and vendor != 0x0000:
            val class_reg = pci_config_read32(0, dev, 0, 0x08)
            if ((class_reg >> 24) & 0xFF) == 0x03:
                val command = (pci_config_read32(0, dev, 0, 0x04) & 0xFFFF) as u16
                pci_config_write16(0, dev, 0, 0x04, command | 0x0003)
                val active_command = pci_config_read32(0, dev, 0, 0x04) & 0xFFFF
                return (active_command & 0x0003) == 0x0003
        dev = dev + 1
    false

fn bga_pci_decode_is_enabled(device: BgaPciDevice) -> bool:
    if not device.found:
        return false
    (pci_config_read32(0, device.device, 0, 0x04) & 0x0003) == 0x0003

fn bga_mmio_write(mmio_bar: u64, index: u16, value: u16):
    mmio_write16(mmio_bar + 0x0500 + (index as u64) * 2, value)

fn bga_mmio_read(mmio_bar: u64, index: u16) -> u16:
    mmio_read16(mmio_bar + 0x0500 + (index as u64) * 2)

fn detect_vga_lfb_address() -> u64:
    """Detect the VGA linear framebuffer address via PCI BAR0.

    Scans PCI bus 0 for a VGA-compatible controller (class 0x03, subclass 0x00).
    Returns BAR0 address masked to page boundary, or fallback 0xFD000000.
    """
    # Scan bus 0, devices 0-31 for VGA controller
    var dev: u8 = 0
    while dev < 32:
        val vendor = pci_config_read32(0, dev, 0, 0x00) & 0xFFFF
        if vendor != 0xFFFF and vendor != 0x0000:
            # Read class code (offset 0x08, bits 31:24=class, 23:16=subclass)
            val class_reg = pci_config_read32(0, dev, 0, 0x08)
            val class_code = (class_reg >> 24) & 0xFF
            val subclass = (class_reg >> 16) & 0xFF
            if class_code == 0x03 and subclass == 0x00:
                # Found VGA controller -- read BAR0 (offset 0x10)
                val bar0 = pci_config_read32(0, dev, 0, 0x10)
                val lfb_addr = (bar0 & 0xFFFFFFF0) as u64
                # Reject legacy VGA apertures like 0xA0000. The desktop path
                # needs the linear framebuffer BAR, and QEMU stdvga falls back
                # to the known high MMIO LFB when BAR0 only exposes legacy VGA
                # memory instead of the real LFB aperture.
                if lfb_addr >= 0x01000000:
                    return lfb_addr
        dev = dev + 1
    # Fallback for QEMU Q35
    0xFD000000

fn bga_init_framebuffer(width: u32, height: u32, bpp: u32) -> FramebufferInfo:
    """Initialize BGA framebuffer to the requested resolution.

    Programs the Bochs Graphics Adapter via I/O ports and detects
    the linear framebuffer address via PCI BAR0 scan.

    Returns FramebufferInfo ready for FramebufferDriver.from_boot_info().
    """
    # Direct-kernel boot must not assume firmware enabled PCI decode.
    val pci_decode_enabled = enable_vga_pci_decode()
    val pci_device = find_bga_pci_device()
    val mmio_bar = pci_device.mmio_bar

    if mmio_bar >= 0x01000000:
        bga_mmio_write(mmio_bar, 0x04, 0x00)
        bga_mmio_write(mmio_bar, 0x01, width as u16)
        bga_mmio_write(mmio_bar, 0x02, height as u16)
        bga_mmio_write(mmio_bar, 0x03, bpp as u16)
        bga_mmio_write(mmio_bar, 0x06, width as u16)
        bga_mmio_write(mmio_bar, 0x04, 0x01 | 0x40)

        val active_width = bga_mmio_read(mmio_bar, 0x01) as u32
        val active_height = bga_mmio_read(mmio_bar, 0x02) as u32
        val active_bpp = bga_mmio_read(mmio_bar, 0x03) as u32
        val active_stride_pixels = bga_mmio_read(mmio_bar, 0x06) as u32
        val pitch = active_stride_pixels * (active_bpp / 8)
        return FramebufferInfo(
            addr: PhysAddr(addr: pci_device.framebuffer_bar),
            width: active_width,
            height: active_height,
            pitch: pitch,
            bpp: active_bpp
        )

    # Verify BGA is present (ID register should be >= 0xB0C0)
    val id = bga_read(0x00)

    # Disable display first
    bga_write(0x04, 0x00)

    # Set resolution and color depth
    bga_write(0x01, width as u16)
    bga_write(0x02, height as u16)
    bga_write(0x03, bpp as u16)
    bga_write(0x06, width as u16)

    # Enable with LFB (Linear Framebuffer) mode
    bga_write(0x04, 0x01 | 0x40)

    # Detect LFB address from PCI
    val lfb_addr = detect_vga_lfb_address()

    # Read the active mode back after enabling it. The scanout contract must
    # describe device state, not merely echo the requested mode.
    val active_width = bga_read(0x01) as u32
    val active_height = bga_read(0x02) as u32
    val active_bpp = bga_read(0x03) as u32
    val active_stride_pixels = bga_read(0x06) as u32
    val pitch = active_stride_pixels * (active_bpp / 8)

    FramebufferInfo(
        addr: PhysAddr(addr: lfb_addr),
        width: active_width,
        height: active_height,
        pitch: pitch,
        bpp: active_bpp
    )

fn bga_init_scanout(width: u32, height: u32, bpp: u32) -> ScanoutEvidence:
    """Initialize BGA and return generation-one authoritative scanout state."""
    val fb = bga_init_framebuffer(width, height, bpp)
    scanout_evidence_from_framebuffer(fb, 1)
