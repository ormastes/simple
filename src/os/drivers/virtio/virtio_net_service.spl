# VirtIO Network Service — IPC wrapper for VirtIO-net driver
#
# MDSOC: feature dimension, services layer
# Exposes the VirtIO-net driver as a named IPC service ("net0").
# Other processes send IPC messages to send/receive Ethernet frames,
# query MAC address, and check link status.
#
# Syscalls used:
#   22 (IpcCreatePort)  — create "net0" service port
#   21 (IpcRecv)        — receive IPC messages
#   83 (MapBar)         — used by driver init (via DeviceGrant)
#   84 (AllocDma)       — used by driver init (DMA buffers)
#   26 (NotificationWait) — IRQ-driven frame receive

use os.drivers.virtio.virtio_net.{VirtioNetDriver}
use os.drivers.virtio.virtio_net_async.{VirtioNetSendFuture}
use os.kernel.types.device_mem_types.{DeviceGrant}
use os.kernel.boot.mmio.{mmio_write8, mmio_read32, mmio_read64}
use os.userlib.syscall_raw.{syscall}
use os.async.os_waker.{OsWaker}
use os.async.os_poll.{OsPoll}
use os.async.os_future.{OsFuture}
use os.kernel.log.klog_api.{log_init, log_info, log_warn, log_error, log_raw, log_raw_println}


# ============================================================================
# IPC Method IDs
# ============================================================================

val NET_METHOD_SEND_FRAME: u32 = 1
val NET_METHOD_RECV_FRAME: u32 = 2
val NET_METHOD_GET_MAC: u32 = 3
val NET_METHOD_LINK_STATUS: u32 = 4
val NET_METHOD_RECV_ASYNC: u32 = 5
val NET_METHOD_SEND_ASYNC: u32 = 6

# ============================================================================
# Shared State
# ============================================================================

# Module-level driver instance (single NIC supported)
var driver: VirtioNetDriver = VirtioNetDriver.new()
var service_ready: bool = false
var pending_sends: [VirtioNetSendFuture] = []
var next_send_handle: i64 = 1

# ============================================================================
# Service Entry Point
# ============================================================================

fn virtio_net_service_start(grant: DeviceGrant):
    """Start the VirtIO network IPC service.

    Initializes the VirtIO-net driver from the given DeviceGrant,
    creates an IPC port, and enters the service dispatch loop.
    """
    log_info("[virtio] " + "[virtio-net-svc] Starting network service...")

    val init_result = driver.init_from_grant(grant)
    if init_result.is_err():
        log_info("[virtio] " + "[virtio-net-svc] Driver init failed")
        return

    log_info("[virtio] " + "[virtio-net-svc] Driver initialized, MAC={driver.mac_string()}")

    # Create IPC port for "net0" service
    val port_result = syscall(22, 0, 0, 0, 0, 0)
    if port_result < 0:
        log_info("[virtio] " + "[virtio-net-svc] FATAL: Failed to create IPC port (error {port_result})")
        return

    val port_handle = port_result as u64
    service_ready = true
    log_info("[virtio] " + "[virtio-net-svc] Service ready on IPC port (handle={port_handle})")

    # Enter service loop
    net_service_loop(port_handle)

# ============================================================================
# Service Dispatch Loop
# ============================================================================

fn net_service_loop(port_handle: u64):
    """Main service loop — receive IPC messages and dispatch to driver.

    IPC message layout (expected):
      word 0: method ID (NET_METHOD_*)
      word 1: sender task ID
      word 2..N: method-specific arguments

    Responses are written back via IPC reply (syscall 20).
    """
    log_info("[virtio] " + "[virtio-net-svc] Entering service loop...")

    while true:
        # Block on IPC receive (syscall 21 = IpcRecv)
        val msg_result = syscall(21, port_handle, 0, 0, 0, 0)
        if msg_result < 0:
            log_info("[virtio] " + "[virtio-net-svc] IPC recv error: {msg_result}")
            continue

        log_info("[virtio] " + "[virtio-net-svc] Received request (raw={msg_result})")

        # IpcMessage layout (@repr("C")):
        #   offset  0: src_port: u64
        #   offset  8: dst_port: u64
        #   offset 16: method: u32
        #   offset 20: flags: u32
        #   offset 24: payload_len: u32
        #   offset 28: cap_count: u32
        #   offset 32: payload words (u64 each)
        val msg_ptr = msg_result as u64
        val sender_task = mmio_read64(msg_ptr)
        val method_id = mmio_read32(msg_ptr + 16) as u32

        match method_id:
            NET_METHOD_SEND_FRAME:
                val frame_virt = mmio_read64(msg_ptr + 32)
                val frame_phys = mmio_read64(msg_ptr + 40)
                val frame_len  = mmio_read64(msg_ptr + 48)
                val ret = handle_send_frame(frame_virt, frame_phys, frame_len)
                syscall(20, sender_task, 0, ret as u64, 0, 0)
            NET_METHOD_RECV_FRAME:
                val dst_virt = mmio_read64(msg_ptr + 32)
                val dst_len  = mmio_read64(msg_ptr + 40)
                val ret = handle_recv_frame(dst_virt, dst_len)
                syscall(20, sender_task, 0, ret as u64, 0, 0)
            NET_METHOD_GET_MAC:
                val dst_virt = mmio_read64(msg_ptr + 32)
                val ret = handle_get_mac(dst_virt)
                syscall(20, sender_task, 0, ret as u64, 0, 0)
            NET_METHOD_LINK_STATUS:
                val ret = handle_link_status()
                syscall(20, sender_task, 0, ret as u64, 0, 0)
            NET_METHOD_RECV_ASYNC:
                val dst_virt = mmio_read64(msg_ptr + 32)
                val dst_len  = mmio_read64(msg_ptr + 40)
                val ret = handle_recv_async(dst_virt, dst_len)
                syscall(20, sender_task, 0, ret as u64, 0, 0)
            NET_METHOD_SEND_ASYNC:
                val frame_virt = mmio_read64(msg_ptr + 32)
                val frame_phys = mmio_read64(msg_ptr + 40)
                val frame_len  = mmio_read64(msg_ptr + 48)
                val ret = handle_send_async(frame_virt, frame_phys, frame_len)
                syscall(20, sender_task, 0, ret as u64, 0, 0)
            _:
                log_info("[virtio] " + "[virtio-net-svc] Unknown method ID: {method_id}")
                syscall(20, sender_task, 0xFFFF, 0, 0, 0)

# ============================================================================
# Method Handlers
# ============================================================================

fn handle_send_frame(frame_virt: u64, frame_phys: u64, frame_len: u64) -> i64:
    """Handle NET_METHOD_SEND_FRAME: send an Ethernet frame.

    Args:
        frame_virt: virtual address of frame data in caller's address space
        frame_phys: physical address of frame data
        frame_len: frame length in bytes

    Returns 0 on success, negative error code on failure.
    """
    if not service_ready:
        return -1
    val result = driver.send_frame(frame_virt, frame_phys, frame_len)
    if result.is_err():
        log_info("[virtio] " + "[virtio-net-svc] Send failed")
        return -1
    0

fn handle_recv_frame(dst_virt: u64, dst_len: u64) -> i64:
    """Handle NET_METHOD_RECV_FRAME: receive an Ethernet frame.

    Blocks until a frame is available and writes it directly into the
    caller-provided destination buffer.

    Args:
        dst_virt: virtual address of destination buffer
        dst_len: size of destination buffer

    Returns frame length on success, 0 if no frame, negative on error.
    """
    if not service_ready:
        return -1
    val frame_len = driver.recv_frame(dst_virt, dst_len)
    if frame_len == 0:
        return 0

    frame_len as i64

fn handle_get_mac(dst_virt: u64) -> i64:
    """Handle NET_METHOD_GET_MAC: return the 6-byte MAC address.

    Writes 6 bytes to the destination virtual address.
    Returns 6 on success (number of bytes written).
    """
    if not service_ready:
        return -1
    mmio_write8(dst_virt, driver.mac0)
    mmio_write8(dst_virt + 1, driver.mac1)
    mmio_write8(dst_virt + 2, driver.mac2)
    mmio_write8(dst_virt + 3, driver.mac3)
    mmio_write8(dst_virt + 4, driver.mac4)
    mmio_write8(dst_virt + 5, driver.mac5)
    6

fn handle_link_status() -> i64:
    """Handle NET_METHOD_LINK_STATUS: return link state.

    Returns 1 if link is up, 0 if down, -1 if not initialized.
    """
    if not service_ready:
        return -1
    if driver.link_up():
        1
    else:
        0

# ============================================================================
# Async Method Handlers
# ============================================================================

fn handle_recv_async(dst_virt: u64, dst_len: u64) -> i64:
    """Handle NET_METHOD_RECV_ASYNC: non-blocking receive.

    Returns immediately with:
      - Frame length (positive) if a frame was already available
      - 0 if no frame is available yet (caller should retry or wait)
      - Negative error code on failure

    Uses recv_frame_poll() which checks the RX used ring without blocking.
    """
    if not service_ready:
        return -1

    val result = driver.recv_frame_poll(dst_virt, dst_len)
    match result:
        Ok(frame_len):
            frame_len as i64
        Err(msg):
            # "no frame available" is not a hard error, return 0
            0

fn handle_send_async(frame_virt: u64, frame_phys: u64, frame_len: u64) -> i64:
    """Handle NET_METHOD_SEND_ASYNC: non-blocking send.

    Creates a VirtioNetSendFuture via send_frame_async and pushes it onto
    pending_sends. Returns a handle ID immediately; tick_pending_sends()
    advances the futures on each service tick.
    """
    if not service_ready:
        return -1

    val future_result = driver.send_frame_async(frame_virt, frame_phys, frame_len)
    if future_result.is_err():
        log_info("[virtio] " + "[virtio-net-svc] Async send setup failed: {future_result.unwrap_err()}")
        return -1
    pending_sends.push(future_result.unwrap())
    val handle = next_send_handle
    next_send_handle = next_send_handle + 1
    handle

fn tick_pending_sends():
    """Poll all pending send futures; remove completed ones."""
    # No-op waker: notification_id=0, bit=0 (futures use their own notif_id field)
    val waker = OsWaker.new(0, 0)
    var i = 0
    while i < pending_sends.len():
        val result = pending_sends[i].poll(waker)
        match result:
            OsPoll.Ready(v):
                pending_sends.remove(i)
            OsPoll.Pending:
                i = i + 1
