# VirtIO-Net — NetworkDevice and AsyncNetworkDevice Trait Implementations
#
# MDSOC: feature dimension, drivers layer
# Bridges VirtioNetDriver to the abstract network device traits.

use os.drivers.virtio.network_device.{NetworkDevice, AsyncNetworkDevice}
use os.drivers.virtio.virtio_net.{VirtioNetDriver}
use os.drivers.virtio.virtio_net_async.{VirtioNetRecvFuture, VirtioNetSendFuture}
use os.async.os_future.{OsFuture, ReadyFuture}

# ============================================================================
# Sync Implementation
# ============================================================================

impl NetworkDevice for VirtioNetDriver:

    fn send_frame(data_virt: u64, data_phys: u64, len: u64) -> Result<bool, text>:
        """Send an Ethernet frame (blocking)."""
        self.send_frame(data_virt, data_phys, len)

    fn recv_frame(buf_virt: u64, buf_len: u64) -> u64:
        """Receive an Ethernet frame (blocking)."""
        self.recv_frame(buf_virt, buf_len)

    fn mac_address() -> [u8]:
        """Return the 6-byte MAC address."""
        self.mac_address()

    fn link_up() -> bool:
        """Check if the network link is active."""
        self.link_up()

    fn is_initialized() -> bool:
        """Check if the driver has been initialized."""
        self.is_initialized()

# ============================================================================
# Async Implementation
# ============================================================================

impl AsyncNetworkDevice for VirtioNetDriver:

    fn send_frame_async(data_virt: u64, data_phys: u64, len: u64) -> OsFuture<Result<bool, text>>:
        """Send an Ethernet frame asynchronously (returns Future)."""
        val r = self.send_frame_async(data_virt, data_phys, len)
        match r:
            Ok(future): future
            Err(e): ReadyFuture.new(Err(e))

    fn recv_frame_async(max_len: u64) -> OsFuture<Result<[u8], text>>:
        """Receive an Ethernet frame asynchronously (returns Future)."""
        self.recv_frame_async(max_len)

    fn mac_address() -> [u8]:
        self.mac_address()

    fn link_up() -> bool:
        self.link_up()

    fn is_initialized() -> bool:
        self.is_initialized()
