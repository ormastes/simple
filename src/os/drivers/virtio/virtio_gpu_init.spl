# VirtIO-GPU Initialization — DeviceGrant and legacy BAR0 init paths
#
# Companion to virtio_gpu.spl. Contains the two long initialization free
# functions so the hub stays under 800 lines.

use os.kernel.types.device_mem_types.{DeviceGrant}
use os.userlib.syscall_raw.{syscall}
use os.kernel.log.klog_api.{log_info}
use os.drivers.virtio.virtio_gpu.{
    VirtioGpuDriver, VirtioGpuInitResult,
    STATUS_ACKNOWLEDGE, STATUS_DRIVER, STATUS_FEATURES_OK, STATUS_DRIVER_OK, STATUS_FAILED,
    MODERN_COMMON_DEVICE_STATUS, MODERN_COMMON_DEVICE_FEATURE_SELECT, MODERN_COMMON_DEVICE_FEATURE,
    MODERN_COMMON_DRIVER_FEATURE_SELECT, MODERN_COMMON_DRIVER_FEATURE,
    VIRTIO_PCI_HOST_FEATURES, VIRTIO_PCI_GUEST_FEATURES
}

# ============================================================================
# Grant-based Initialization
# ============================================================================

fn virtio_gpu_init_from_grant(drv_in: VirtioGpuDriver, grant: DeviceGrant) -> VirtioGpuInitResult:
    """Initialize VirtIO-GPU device from a kernel DeviceGrant.

    Steps:
      1. Map BAR0 via syscall 83
      2. Reset device, negotiate features
      3. Set up controlq (queue 0) with DMA-allocated rings
      4. Allocate command/response DMA buffers
      5. GET_DISPLAY_INFO to discover display dimensions
      6. RESOURCE_CREATE_2D for a BGRA resource
      7. Allocate framebuffer DMA and ATTACH_BACKING
      8. SET_SCANOUT to bind resource to scanout 0
      9. Set DRIVER_OK
    """
    var drv = drv_in
    drv.notif_id = grant.irq_notification_id
    drv.device_bdf = (grant.pci_bus as u64) << 16 | (grant.pci_dev as u64) << 8 | (grant.pci_func as u64)
    drv.kernel_dma_available = true
    log_info("[virtio] " + "[virtio-gpu] grant bar0=0x{grant.bar0_phys} bar0_cap={grant.bar0_cap}")

    if grant.bar0_cap != 1 and (grant.bar0_phys & 1) == 0 and drv.try_map_modern_pci_caps(grant):
        log_info("[virtio] " + "[virtio-gpu] using modern virtio-pci capabilities")

        drv.modern_write8(MODERN_COMMON_DEVICE_STATUS, 0)
        drv.modern_write8(MODERN_COMMON_DEVICE_STATUS, STATUS_ACKNOWLEDGE)
        drv.modern_write8(MODERN_COMMON_DEVICE_STATUS, STATUS_ACKNOWLEDGE | STATUS_DRIVER)

        drv.modern_write32(MODERN_COMMON_DEVICE_FEATURE_SELECT, 0)
        val host_features = drv.modern_read32(MODERN_COMMON_DEVICE_FEATURE)
        log_info("[virtio] " + "[virtio-gpu] modern host_features=0x{host_features}")
        drv.modern_write32(MODERN_COMMON_DRIVER_FEATURE_SELECT, 0)
        drv.modern_write32(MODERN_COMMON_DRIVER_FEATURE, 0)
        drv.modern_write32(MODERN_COMMON_DRIVER_FEATURE_SELECT, 1)
        drv.modern_write32(MODERN_COMMON_DRIVER_FEATURE, 1)

        val feat_status = STATUS_ACKNOWLEDGE | STATUS_DRIVER | STATUS_FEATURES_OK
        drv.modern_write8(MODERN_COMMON_DEVICE_STATUS, feat_status)
        val current_status = drv.modern_read8(MODERN_COMMON_DEVICE_STATUS)
        if (current_status & STATUS_FEATURES_OK) == 0:
            drv.modern_write8(MODERN_COMMON_DEVICE_STATUS, STATUS_FAILED)
            return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Modern feature negotiation failed")

        val ctrl_result = drv.setup_controlq_modern()
        if val Err(msg) = ctrl_result:
            drv.modern_write8(MODERN_COMMON_DEVICE_STATUS, STATUS_FAILED)
            return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Controlq setup failed: {msg}")
        log_info("[virtio] " + "[virtio-gpu] Controlq ready (modern size={drv.ctrl_queue_size})")

        val ok_status = STATUS_ACKNOWLEDGE | STATUS_DRIVER | STATUS_FEATURES_OK | STATUS_DRIVER_OK
        drv.modern_write8(MODERN_COMMON_DEVICE_STATUS, ok_status)

        val cmd_dma = drv.alloc_dma(4096)
        if cmd_dma.is_err():
            return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Command buffer DMA alloc failed")
        drv.cmd_buf_virt = cmd_dma.unwrap_virt()
        drv.cmd_buf_phys = cmd_dma.unwrap_device()
        drv.cmd_buf_allocation_id = cmd_dma.unwrap_allocation_id()

        val resp_dma = drv.alloc_dma(4096)
        if resp_dma.is_err():
            return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Response buffer DMA alloc failed")
        drv.resp_buf_virt = resp_dma.unwrap_virt()
        drv.resp_buf_phys = resp_dma.unwrap_device()
        drv.resp_buf_allocation_id = resp_dma.unwrap_allocation_id()
        log_info("[virtio] " + "[virtio-gpu] DMA cmd=0x{drv.cmd_buf_virt} resp=0x{drv.resp_buf_virt}")

        val display_result = drv.cmd_get_display_info()
        if display_result.is_err():
            return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "GET_DISPLAY_INFO failed")
        log_info("[virtio] " + "[virtio-gpu] Display: {drv.width}x{drv.height}")

        drv.resource_id = 1
        drv.next_resource_id = 2
        val create_result = drv.cmd_resource_create_2d_raw(drv.resource_id.to_u64(), drv.width.to_u64(), drv.height.to_u64())
        if create_result.is_err():
            return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "RESOURCE_CREATE_2D failed")
        log_info("[virtio] " + "[virtio-gpu] Resource {drv.resource_id} created")

        drv.fb_size = drv.width.to_u64() * drv.height.to_u64() * 4
        val fb_dma = drv.alloc_dma(drv.fb_size)
        if fb_dma.is_err():
            return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Framebuffer DMA alloc failed")
        drv.fb_virt = fb_dma.unwrap_virt()
        drv.fb_phys = fb_dma.unwrap_device()
        drv.fb_allocation_id = fb_dma.unwrap_allocation_id()
        log_info("[virtio] " + "[virtio-gpu] FB virt=0x{drv.fb_virt} phys=0x{drv.fb_phys} size={drv.fb_size}")

        drv.clear(0x00000000)

        val attach_result = drv.cmd_resource_attach_backing_raw(drv.resource_id.to_u64(), drv.fb_phys, drv.fb_size)
        if attach_result.is_err():
            return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "RESOURCE_ATTACH_BACKING failed")
        log_info("[virtio] " + "[virtio-gpu] Backing attached")

        val scanout_result = drv.cmd_set_scanout_raw(0, drv.resource_id.to_u64(), drv.width.to_u64(), drv.height.to_u64())
        if scanout_result.is_err():
            return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "SET_SCANOUT failed")
        log_info("[virtio] " + "[virtio-gpu] Scanout 0 bound to resource {drv.resource_id}")

        drv.initialized = true
        log_info("[virtio] " + "[virtio-gpu] Device initialized: {drv.width}x{drv.height} BGRA (modern)")
        return VirtioGpuInitResult(driver: drv, ok: true, err_msg: "")

    if (grant.bar0_phys & 1) != 0:
        drv.is_io_bar = true
        drv.bar0_port = (grant.bar0_phys & 0xFFFC).to_u16()
        drv.bar0_virt = 0
        log_info("[virtio] " + "[virtio-gpu] BAR0 is I/O port: 0x{drv.bar0_port}")
    else:
        drv.is_io_bar = false
        val bar_result = syscall(83, grant.bar0_phys, grant.bar0_size, 0, 0, 0)
        if bar_result < 0:
            return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "MapBar failed: error {bar_result}")
        drv.bar0_virt = bar_result as u64
        drv.bar0_port = 0
        log_info("[virtio] " + "[virtio-gpu] BAR0 mapped at virt=0x{drv.bar0_virt}")

    drv.write_status(0)
    drv.write_status(STATUS_ACKNOWLEDGE)
    drv.write_status(STATUS_ACKNOWLEDGE | STATUS_DRIVER)

    val host_features = drv.read_reg32(VIRTIO_PCI_HOST_FEATURES)
    log_info("[virtio] " + "[virtio-gpu] host_features=0x{host_features}")
    drv.write_reg32(VIRTIO_PCI_GUEST_FEATURES, 0)

    val ctrl_result = drv.setup_controlq()
    if val Err(msg) = ctrl_result:
        drv.write_status(STATUS_FAILED)
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Controlq setup failed: {msg}")
    log_info("[virtio] " + "[virtio-gpu] Controlq ready (size={drv.ctrl_queue_size})")

    val ok_status = STATUS_ACKNOWLEDGE | STATUS_DRIVER | STATUS_DRIVER_OK
    drv.write_status(ok_status)

    val cmd_dma = drv.alloc_dma(4096)
    if cmd_dma.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Command buffer DMA alloc failed")
    drv.cmd_buf_virt = cmd_dma.unwrap_virt()
    drv.cmd_buf_phys = cmd_dma.unwrap_device()
    drv.cmd_buf_allocation_id = cmd_dma.unwrap_allocation_id()

    val resp_dma = drv.alloc_dma(4096)
    if resp_dma.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Response buffer DMA alloc failed")
    drv.resp_buf_virt = resp_dma.unwrap_virt()
    drv.resp_buf_phys = resp_dma.unwrap_device()
    drv.resp_buf_allocation_id = resp_dma.unwrap_allocation_id()
    log_info("[virtio] " + "[virtio-gpu] DMA cmd=0x{drv.cmd_buf_virt} resp=0x{drv.resp_buf_virt}")

    val display_result = drv.cmd_get_display_info()
    if display_result.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "GET_DISPLAY_INFO failed")
    log_info("[virtio] " + "[virtio-gpu] Display: {drv.width}x{drv.height}")

    drv.resource_id = 1
    drv.next_resource_id = 2
    val create_result = drv.cmd_resource_create_2d_raw(drv.resource_id.to_u64(), drv.width.to_u64(), drv.height.to_u64())
    if create_result.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "RESOURCE_CREATE_2D failed")
    log_info("[virtio] " + "[virtio-gpu] Resource {drv.resource_id} created")

    drv.fb_size = drv.width.to_u64() * drv.height.to_u64() * 4
    val fb_dma = drv.alloc_dma(drv.fb_size)
    if fb_dma.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Framebuffer DMA alloc failed")
    drv.fb_virt = fb_dma.unwrap_virt()
    drv.fb_phys = fb_dma.unwrap_device()
    drv.fb_allocation_id = fb_dma.unwrap_allocation_id()
    log_info("[virtio] " + "[virtio-gpu] FB virt=0x{drv.fb_virt} phys=0x{drv.fb_phys} size={drv.fb_size}")

    drv.clear(0x00000000)

    val attach_result = drv.cmd_resource_attach_backing_raw(drv.resource_id.to_u64(), drv.fb_phys, drv.fb_size)
    if attach_result.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "RESOURCE_ATTACH_BACKING failed")
    log_info("[virtio] " + "[virtio-gpu] Backing attached")

    val scanout_result = drv.cmd_set_scanout_raw(0, drv.resource_id.to_u64(), drv.width.to_u64(), drv.height.to_u64())
    if scanout_result.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "SET_SCANOUT failed")
    log_info("[virtio] " + "[virtio-gpu] Scanout 0 bound to resource {drv.resource_id}")

    drv.initialized = true
    log_info("[virtio] " + "[virtio-gpu] Device initialized: {drv.width_raw}x{drv.height_raw} BGRA")
    VirtioGpuInitResult(driver: drv, ok: true, err_msg: "")

# ============================================================================
# Legacy BAR0 Initialization
# ============================================================================

fn virtio_gpu_init_legacy(drv_in: VirtioGpuDriver, bar0_phys: u64, bar0_size: u64, notif_id: u64) -> VirtioGpuInitResult:
    """Initialize the legacy transport from scalar grant fields.

    Baremetal wrapper entries use this to avoid the current large-struct
    DeviceGrant ABI issue where fields after pci_subclass arrive as zero.
    """
    var drv = drv_in
    drv.kernel_dma_available = false
    drv.device_bdf = 0
    drv.notif_id = notif_id
    log_info("[virtio] " + "[virtio-gpu] scalar legacy bar0=0x{bar0_phys}")

    if (bar0_phys & 1) != 0:
        drv.is_io_bar = true
        drv.bar0_port = (bar0_phys & 0xFFFC).to_u16()
        drv.bar0_virt = 0
        log_info("[virtio] " + "[virtio-gpu] BAR0 is I/O port: 0x{drv.bar0_port}")
    else:
        drv.is_io_bar = false
        val bar_result = syscall(83, bar0_phys, bar0_size, 0, 0, 0)
        if bar_result < 0:
            return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "MapBar failed: error {bar_result}")
        drv.bar0_virt = bar_result as u64
        drv.bar0_port = 0
        log_info("[virtio] " + "[virtio-gpu] BAR0 mapped at virt=0x{drv.bar0_virt}")

    drv.write_status(0)
    drv.write_status(STATUS_ACKNOWLEDGE)
    drv.write_status(STATUS_ACKNOWLEDGE | STATUS_DRIVER)

    val host_features = drv.read_reg32(VIRTIO_PCI_HOST_FEATURES)
    log_info("[virtio] " + "[virtio-gpu] host_features=0x{host_features}")
    drv.write_reg32(VIRTIO_PCI_GUEST_FEATURES, 0)

    val ctrl_result = drv.setup_controlq()
    if val Err(msg) = ctrl_result:
        drv.write_status(STATUS_FAILED)
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Controlq setup failed: {msg}")
    log_info("[virtio] " + "[virtio-gpu] Controlq ready (size={drv.ctrl_queue_size})")

    drv.write_status(STATUS_ACKNOWLEDGE | STATUS_DRIVER | STATUS_DRIVER_OK)

    val cmd_dma = drv.alloc_dma(4096)
    if cmd_dma.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Command buffer DMA alloc failed")
    drv.cmd_buf_virt = cmd_dma.unwrap_virt()
    drv.cmd_buf_phys = cmd_dma.unwrap_device()
    drv.cmd_buf_allocation_id = cmd_dma.unwrap_allocation_id()

    val resp_dma = drv.alloc_dma(4096)
    if resp_dma.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Response buffer DMA alloc failed")
    drv.resp_buf_virt = resp_dma.unwrap_virt()
    drv.resp_buf_phys = resp_dma.unwrap_device()
    drv.resp_buf_allocation_id = resp_dma.unwrap_allocation_id()
    log_info("[virtio] " + "[virtio-gpu] DMA cmd=0x{drv.cmd_buf_virt} resp=0x{drv.resp_buf_virt}")

    val display_result = drv.cmd_get_display_info()
    if display_result.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "GET_DISPLAY_INFO failed")
    log_info("[virtio] " + "[virtio-gpu] Display: {drv.width}x{drv.height}")

    drv.resource_id = 1
    drv.next_resource_id = 2
    val create_result = drv.cmd_resource_create_2d_raw(drv.resource_id.to_u64(), drv.width.to_u64(), drv.height.to_u64())
    if create_result.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "RESOURCE_CREATE_2D failed")
    log_info("[virtio] " + "[virtio-gpu] Resource {drv.resource_id} created")

    drv.fb_size = drv.width.to_u64() * drv.height.to_u64() * 4
    val fb_dma = drv.alloc_dma(drv.fb_size)
    if fb_dma.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "Framebuffer DMA alloc failed")
    drv.fb_virt = fb_dma.unwrap_virt()
    drv.fb_phys = fb_dma.unwrap_device()
    drv.fb_allocation_id = fb_dma.unwrap_allocation_id()
    log_info("[virtio] " + "[virtio-gpu] FB virt=0x{drv.fb_virt} phys=0x{drv.fb_phys} size={drv.fb_size}")

    drv.clear(0x00000000)

    val attach_result = drv.cmd_resource_attach_backing_raw(drv.resource_id.to_u64(), drv.fb_phys, drv.fb_size)
    if attach_result.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "RESOURCE_ATTACH_BACKING failed")
    log_info("[virtio] " + "[virtio-gpu] Backing attached")

    val scanout_result = drv.cmd_set_scanout_raw(0, drv.resource_id.to_u64(), drv.width.to_u64(), drv.height.to_u64())
    if scanout_result.is_err():
        return VirtioGpuInitResult(driver: drv, ok: false, err_msg: "SET_SCANOUT failed")
    log_info("[virtio] " + "[virtio-gpu] Scanout 0 bound to resource {drv.resource_id}")

    drv.initialized = true
    log_info("[virtio] " + "[virtio-gpu] Device initialized: {drv.width_raw}x{drv.height_raw} BGRA")
    VirtioGpuInitResult(driver: drv, ok: true, err_msg: "")
