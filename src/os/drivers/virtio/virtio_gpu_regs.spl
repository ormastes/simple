# VirtIO-GPU Register Definitions and Virtqueue Helpers
#
# MDSOC: feature dimension, drivers layer
# Contains:
#   - VirtIO legacy PCI BAR0 register offsets
#   - Modern virtio-pci vendor capability layout constants
#   - Device status bits
#   - Virtqueue ring layout helpers
#   - RAM read/write helper functions

use os.kernel.boot.mmio.{mmio_read16, mmio_read32, mmio_read64, mmio_write16, mmio_write32, mmio_write64}

extern fn rt_mem_read_u32_boxed(addr: u64) -> u32
extern fn rt_mem_write_u32_boxed(addr: u64, value: u32)
extern fn rt_mmio_write_u16_real(addr: u64, value: u64)
extern fn rt_mmio_write_u32_real(addr: u64, value: u64)
extern fn rt_mmio_write_u64_real(addr: u64, value: u64)
extern fn rt_mmio_read_u32_real(addr: u64) -> u64
extern fn rt_mmio_read_u64_real(addr: u64) -> u64
extern fn rt_mmio_write_u64(addr: u64, value: u64)

# ============================================================================
# VirtIO Legacy PCI BAR0 Register Offsets
# ============================================================================

pub val VIRTIO_PCI_HOST_FEATURES: u64 = 0x00
pub val VIRTIO_PCI_GUEST_FEATURES: u64 = 0x04
pub val VIRTIO_PCI_QUEUE_PFN: u64 = 0x08
pub val VIRTIO_PCI_QUEUE_SIZE: u64 = 0x0C
pub val VIRTIO_PCI_QUEUE_SEL: u64 = 0x0E
pub val VIRTIO_PCI_QUEUE_NOTIFY: u64 = 0x10
pub val VIRTIO_PCI_STATUS: u64 = 0x12
pub val VIRTIO_PCI_ISR: u64 = 0x13

# Modern virtio-pci vendor capability and common-config layout
pub val PCI_CAP_ID_VENDOR_SPECIFIC: u8 = 0x09
pub val VIRTIO_PCI_CAP_COMMON_CFG: u8 = 1
pub val VIRTIO_PCI_CAP_NOTIFY_CFG: u8 = 2
pub val VIRTIO_PCI_CAP_ISR_CFG: u8 = 3

pub val MODERN_COMMON_DEVICE_FEATURE_SELECT: u64 = 0x00
pub val MODERN_COMMON_DEVICE_FEATURE: u64 = 0x04
pub val MODERN_COMMON_DRIVER_FEATURE_SELECT: u64 = 0x08
pub val MODERN_COMMON_DRIVER_FEATURE: u64 = 0x0C
pub val MODERN_COMMON_DEVICE_STATUS: u64 = 0x14
pub val MODERN_COMMON_QUEUE_SELECT: u64 = 0x16
pub val MODERN_COMMON_QUEUE_SIZE: u64 = 0x18
pub val MODERN_COMMON_QUEUE_ENABLE: u64 = 0x1C
pub val MODERN_COMMON_QUEUE_NOTIFY_OFF: u64 = 0x1E
pub val MODERN_COMMON_QUEUE_DESC_LO: u64 = 0x20
pub val MODERN_COMMON_QUEUE_DESC_HI: u64 = 0x24
pub val MODERN_COMMON_QUEUE_AVAIL_LO: u64 = 0x28
pub val MODERN_COMMON_QUEUE_AVAIL_HI: u64 = 0x2C
pub val MODERN_COMMON_QUEUE_USED_LO: u64 = 0x30
pub val MODERN_COMMON_QUEUE_USED_HI: u64 = 0x34

# Device status bits
pub val STATUS_ACKNOWLEDGE: u8 = 1
pub val STATUS_DRIVER: u8 = 2
pub val STATUS_DRIVER_OK: u8 = 4
pub val STATUS_FEATURES_OK: u8 = 8
pub val STATUS_FAILED: u8 = 128

# Controlq index
pub val VIRTIO_GPU_CONTROLQ: u16 = 0

# ============================================================================
# Virtqueue Ring Layout Helpers
# ============================================================================
# For a queue of size N:
#   Descriptor table: N * 16 bytes
#   Available ring:   4 + 2*N bytes (flags:u16, idx:u16, ring[N]:u16)
#   Used ring:        4 + 8*N bytes (flags:u16, idx:u16, ring[N]:(id:u32,len:u32))
# Legacy PCI virtqueue: all three placed contiguously, PFN = phys >> 12

pub fn virtqueue_desc_size(queue_size: u64) -> u64:
    queue_size * 16

pub fn virtqueue_avail_size(queue_size: u64) -> u64:
    4 + 2 * queue_size

pub fn virtqueue_used_size(queue_size: u64) -> u64:
    4 + 8 * queue_size

pub fn virtqueue_total_size(queue_size: u64) -> u64:
    val ds = virtqueue_desc_size(queue_size)
    val avs = virtqueue_avail_size(queue_size)
    val us = virtqueue_used_size(queue_size)
    # Align used ring to 4096 boundary (virtio spec requirement for legacy)
    val desc_avail = ds + avs
    val aligned = (desc_avail + 4095) & ~4095
    aligned + us

pub fn ram_read32(addr: u64) -> u32:
    mmio_read32(addr)

pub fn ram_read16(addr: u64) -> u16:
    mmio_read16(addr)

pub fn ram_read64(addr: u64) -> u64:
    mmio_read64(addr)

pub fn ram_write16(addr: u64, value: u16):
    mmio_write16(addr, value)

pub fn ram_write32(addr: u64, value: u32):
    rt_mem_write_u32_boxed(addr, value)

pub fn ram_write64(addr: u64, value: u64):
    rt_mmio_write_u64(addr, value)

pub fn ram_write16_raw(addr: u64, value: u64):
    rt_mmio_write_u16_real(addr, value)

pub fn ram_write32_raw(addr: u64, value: u64):
    rt_mmio_write_u32_real(addr, value)

pub fn ram_write64_raw(addr: u64, value: u64):
    rt_mmio_write_u64_real(addr, value)

pub fn ram_read32_raw(addr: u64) -> u32:
    rt_mmio_read_u32_real(addr).to_u32()

pub fn ram_read64_raw(addr: u64) -> u64:
    rt_mmio_read_u64_real(addr)

pub fn ram_read32_boxed(addr: u64) -> u32:
    rt_mem_read_u32_boxed(addr)
