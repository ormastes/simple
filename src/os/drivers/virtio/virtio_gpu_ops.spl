# VirtIO-GPU GPU Commands and Framebuffer Operations
#
# Companion to virtio_gpu.spl. Contains GPU protocol command functions
# and framebuffer pixel-drawing functions, as free functions taking
# VirtioGpuDriver so the hub stays under 800 lines.

use os.drivers.virtio.virtio_gpu.{
    VirtioGpuDriver,
    ram_read16, ram_read32, ram_write32, ram_write64,
    ram_write16_raw, ram_write32_raw, ram_write64_raw, ram_read32_raw
}
use os.kernel.log.klog_api.{log_info}

# ============================================================================
# GPU Commands
# ============================================================================

fn virtio_gpu_cmd_get_display_info(drv: VirtioGpuDriver) -> Result<bool, text>:
    """Send GET_DISPLAY_INFO and read display dimensions from response."""
    drv._write_ctrl_hdr(0x0100)
    if ram_read32(drv.cmd_buf_virt) == 0x0100 and ram_read32(drv.cmd_buf_virt + 4) == 0:
        log_info("[virtio] " + "[virtio-gpu] GET_DISPLAY_INFO hdr-ok")
    else:
        log_info("[virtio] " + "[virtio-gpu] GET_DISPLAY_INFO hdr-bad")
    log_info("[virtio] " + "[virtio-gpu] GET_DISPLAY_INFO submit")
    val resp_type = drv._send_command(24, 408)
    log_info("[virtio] " + "[virtio-gpu] GET_DISPLAY_INFO resp_type=0x{resp_type}")

    if resp_type != 0x1101:
        log_info("[virtio] " + "[virtio-gpu] GET_DISPLAY_INFO error: resp=0x{resp_type}")
        return Err("GET_DISPLAY_INFO failed (resp=0x{resp_type})")

    Ok(true)

fn virtio_gpu_cmd_resource_create_2d_raw(drv: VirtioGpuDriver, res_id: u64, w: u64, h: u64) -> Result<bool, text>:
    drv._write_ctrl_hdr(0x0101)
    ram_write32_raw(drv.cmd_buf_virt + 24, res_id)
    ram_write32_raw(drv.cmd_buf_virt + 28, 1)
    ram_write32_raw(drv.cmd_buf_virt + 32, w)
    ram_write32_raw(drv.cmd_buf_virt + 36, h)
    val resp_type = drv._send_command(40, 24)
    if resp_type != 0x1100:
        log_info("[virtio] " + "[virtio-gpu] RESOURCE_CREATE_2D error: resp=0x{resp_type}")
        return Err("RESOURCE_CREATE_2D failed")
    Ok(true)

fn virtio_gpu_cmd_resource_attach_backing_raw(drv: VirtioGpuDriver, res_id: u64, backing_phys: u64, backing_size: u64) -> Result<bool, text>:
    drv._write_ctrl_hdr(0x0106)
    ram_write32_raw(drv.cmd_buf_virt + 24, res_id)
    ram_write32_raw(drv.cmd_buf_virt + 28, 1)
    ram_write64_raw(drv.cmd_buf_virt + 32, backing_phys)
    ram_write32_raw(drv.cmd_buf_virt + 40, backing_size)
    ram_write32_raw(drv.cmd_buf_virt + 44, 0)
    val resp_type = drv._send_command(48, 24)
    if resp_type != 0x1100:
        log_info("[virtio] " + "[virtio-gpu] ATTACH_BACKING error: resp=0x{resp_type}")
        return Err("RESOURCE_ATTACH_BACKING failed")
    Ok(true)

fn virtio_gpu_cmd_set_scanout_raw(drv: VirtioGpuDriver, scanout_id: u64, res_id: u64, w: u64, h: u64) -> Result<bool, text>:
    drv._write_ctrl_hdr(0x0103)
    ram_write32_raw(drv.cmd_buf_virt + 24, 0)
    ram_write32_raw(drv.cmd_buf_virt + 28, 0)
    ram_write32_raw(drv.cmd_buf_virt + 32, w)
    ram_write32_raw(drv.cmd_buf_virt + 36, h)
    ram_write32_raw(drv.cmd_buf_virt + 40, scanout_id)
    ram_write32_raw(drv.cmd_buf_virt + 44, res_id)
    val resp_type = drv._send_command(48, 24)
    if resp_type != 0x1100:
        log_info("[virtio] " + "[virtio-gpu] SET_SCANOUT error: resp=0x{resp_type}")
        return Err("SET_SCANOUT failed")
    Ok(true)

fn virtio_gpu_cmd_resource_create_2d(drv: VirtioGpuDriver, res_id: u32, w: u32, h: u32) -> Result<bool, text>:
    drv._write_ctrl_hdr(0x0101)
    ram_write32(drv.cmd_buf_virt + 24, res_id)
    ram_write32(drv.cmd_buf_virt + 28, 1)
    ram_write32(drv.cmd_buf_virt + 32, w)
    ram_write32(drv.cmd_buf_virt + 36, h)
    val resp_type = drv._send_command(40, 24)
    if resp_type != 0x1100:
        log_info("[virtio] " + "[virtio-gpu] RESOURCE_CREATE_2D error: resp=0x{resp_type}")
        return Err("RESOURCE_CREATE_2D failed")
    Ok(true)

fn virtio_gpu_cmd_resource_attach_backing(drv: VirtioGpuDriver, res_id: u32, backing_phys: u64, backing_size: u64) -> Result<bool, text>:
    drv._write_ctrl_hdr(0x0106)
    ram_write32(drv.cmd_buf_virt + 24, res_id)
    ram_write32(drv.cmd_buf_virt + 28, 1)
    ram_write64(drv.cmd_buf_virt + 32, backing_phys)
    ram_write32(drv.cmd_buf_virt + 40, backing_size.to_u32())
    ram_write32(drv.cmd_buf_virt + 44, 0)
    val resp_type = drv._send_command(48, 24)
    if resp_type != 0x1100:
        log_info("[virtio] " + "[virtio-gpu] ATTACH_BACKING error: resp=0x{resp_type}")
        return Err("RESOURCE_ATTACH_BACKING failed")
    Ok(true)

fn virtio_gpu_cmd_set_scanout(drv: VirtioGpuDriver, scanout_id: u32, res_id: u32, w: u32, h: u32) -> Result<bool, text>:
    drv._write_ctrl_hdr(0x0103)
    ram_write32(drv.cmd_buf_virt + 24, 0)
    ram_write32(drv.cmd_buf_virt + 28, 0)
    ram_write32(drv.cmd_buf_virt + 32, w)
    ram_write32(drv.cmd_buf_virt + 36, h)
    ram_write32(drv.cmd_buf_virt + 40, scanout_id)
    ram_write32(drv.cmd_buf_virt + 44, res_id)
    val resp_type = drv._send_command(48, 24)
    if resp_type != 0x1100:
        log_info("[virtio] " + "[virtio-gpu] SET_SCANOUT error: resp=0x{resp_type}")
        return Err("SET_SCANOUT failed")
    Ok(true)

fn virtio_gpu_cmd_resource_detach_backing(drv: VirtioGpuDriver, res_id: u32) -> Result<bool, text>:
    drv._write_ctrl_hdr(0x0107)
    ram_write32(drv.cmd_buf_virt + 24, res_id)
    ram_write32(drv.cmd_buf_virt + 28, 0)
    val resp_type = drv._send_command(32, 24)
    if resp_type != 0x1100:
        log_info("[virtio] " + "[virtio-gpu] DETACH_BACKING error: resp=0x{resp_type}")
        return Err("RESOURCE_DETACH_BACKING failed")
    Ok(true)

fn virtio_gpu_cmd_resource_unref(drv: VirtioGpuDriver, res_id: u32) -> Result<bool, text>:
    drv._write_ctrl_hdr(0x0102)
    ram_write32(drv.cmd_buf_virt + 24, res_id)
    ram_write32(drv.cmd_buf_virt + 28, 0)
    val resp_type = drv._send_command(32, 24)
    if resp_type != 0x1100:
        log_info("[virtio] " + "[virtio-gpu] RESOURCE_UNREF error: resp=0x{resp_type}")
        return Err("RESOURCE_UNREF failed")
    Ok(true)

# ============================================================================
# Framebuffer Flush
# ============================================================================

fn virtio_gpu_flush(drv: VirtioGpuDriver):
    """Flush the full framebuffer to the display via TRANSFER_TO_HOST_2D + RESOURCE_FLUSH."""
    if not drv.initialized:
        return
    drv._write_ctrl_hdr(0x0105)
    ram_write32(drv.cmd_buf_virt + 24, 0)
    ram_write32(drv.cmd_buf_virt + 28, 0)
    ram_write32_raw(drv.cmd_buf_virt + 32, drv.width.to_u64())
    ram_write32_raw(drv.cmd_buf_virt + 36, drv.height.to_u64())
    ram_write64(drv.cmd_buf_virt + 40, 0)
    ram_write32_raw(drv.cmd_buf_virt + 48, drv.resource_id.to_u64())
    ram_write32(drv.cmd_buf_virt + 52, 0)
    drv._send_command(56, 24)

    drv._write_ctrl_hdr(0x0104)
    ram_write32(drv.cmd_buf_virt + 24, 0)
    ram_write32(drv.cmd_buf_virt + 28, 0)
    ram_write32_raw(drv.cmd_buf_virt + 32, drv.width.to_u64())
    ram_write32_raw(drv.cmd_buf_virt + 36, drv.height.to_u64())
    ram_write32_raw(drv.cmd_buf_virt + 40, drv.resource_id.to_u64())
    ram_write32(drv.cmd_buf_virt + 44, 0)
    drv._send_command(48, 24)

fn virtio_gpu_flush_rect(drv: VirtioGpuDriver, x: u32, y: u32, w: u32, h: u32):
    """Flush a rectangular region of the framebuffer to the display."""
    if not drv.initialized:
        return
    var rw: u32 = w
    var rh: u32 = h
    if x.to_u64() + rw.to_u64() > drv.width.to_u64():
        rw = (drv.width.to_u64() - x.to_u64()).to_u32()
    if y.to_u64() + rh.to_u64() > drv.height.to_u64():
        rh = (drv.height.to_u64() - y.to_u64()).to_u32()

    val offset = (y.to_u64() * drv.width.to_u64() + x.to_u64()) * 4
    drv._write_ctrl_hdr(0x0105)
    ram_write32(drv.cmd_buf_virt + 24, x)
    ram_write32(drv.cmd_buf_virt + 28, y)
    ram_write32(drv.cmd_buf_virt + 32, rw)
    ram_write32(drv.cmd_buf_virt + 36, rh)
    ram_write64(drv.cmd_buf_virt + 40, offset)
    ram_write32_raw(drv.cmd_buf_virt + 48, drv.resource_id.to_u64())
    ram_write32(drv.cmd_buf_virt + 52, 0)
    drv._send_command(56, 24)

    drv._write_ctrl_hdr(0x0104)
    ram_write32(drv.cmd_buf_virt + 24, x)
    ram_write32(drv.cmd_buf_virt + 28, y)
    ram_write32(drv.cmd_buf_virt + 32, rw)
    ram_write32(drv.cmd_buf_virt + 36, rh)
    ram_write32_raw(drv.cmd_buf_virt + 40, drv.resource_id.to_u64())
    ram_write32(drv.cmd_buf_virt + 44, 0)
    drv._send_command(48, 24)

# ============================================================================
# Framebuffer Pixel Drawing
# ============================================================================

fn virtio_gpu_put_pixel(drv: VirtioGpuDriver, x: u32, y: u32, color: u32):
    """Write a single pixel to the framebuffer (BGRA). Does not flush."""
    if x.to_u64() < drv.width.to_u64() and y.to_u64() < drv.height.to_u64():
        val offset = (y.to_u64() * drv.width.to_u64() + x.to_u64()) * 4
        ram_write32(drv.fb_virt + offset, color)

fn virtio_gpu_fill_rect(drv: VirtioGpuDriver, x: u32, y: u32, w: u32, h: u32, color: u32):
    """Fill a rectangle in the framebuffer. Does not flush."""
    var py: u32 = y
    while py.to_u64() < (y + h).to_u64() and py.to_u64() < drv.height.to_u64():
        var px: u32 = x
        while px.to_u64() < (x + w).to_u64() and px.to_u64() < drv.width.to_u64():
            val offset = (py.to_u64() * drv.width.to_u64() + px.to_u64()) * 4
            ram_write32(drv.fb_virt + offset, color)
            px = px + 1
        py = py + 1

fn virtio_gpu_clear(drv: VirtioGpuDriver, color: u32):
    """Fill the entire framebuffer with a solid color."""
    var y: u32 = 0
    while y.to_u64() < drv.height.to_u64():
        var x: u32 = 0
        while x.to_u64() < drv.width.to_u64():
            val offset = (y.to_u64() * drv.width.to_u64() + x.to_u64()) * 4
            ram_write32(drv.fb_virt + offset, color)
            x = x + 1
        y = y + 1

fn virtio_gpu_draw_hline(drv: VirtioGpuDriver, x: u32, y: u32, length: u32, color: u32):
    """Draw a horizontal line."""
    if y.to_u64() >= drv.height.to_u64():
        return
    var px: u32 = x
    while px.to_u64() < (x + length).to_u64() and px.to_u64() < drv.width.to_u64():
        val offset = (y.to_u64() * drv.width.to_u64() + px.to_u64()) * 4
        ram_write32(drv.fb_virt + offset, color)
        px = px + 1

fn virtio_gpu_draw_vline(drv: VirtioGpuDriver, x: u32, y: u32, length: u32, color: u32):
    """Draw a vertical line."""
    if x.to_u64() >= drv.width.to_u64():
        return
    var py: u32 = y
    while py.to_u64() < (y + length).to_u64() and py.to_u64() < drv.height.to_u64():
        val offset = (py.to_u64() * drv.width.to_u64() + x.to_u64()) * 4
        ram_write32(drv.fb_virt + offset, color)
        py = py + 1

fn virtio_gpu_draw_rect(drv: VirtioGpuDriver, x: u32, y: u32, w: u32, h: u32, color: u32):
    """Draw an unfilled rectangle (border only)."""
    virtio_gpu_draw_hline(drv, x, y, w, color)
    virtio_gpu_draw_hline(drv, x, y + h - 1, w, color)
    virtio_gpu_draw_vline(drv, x, y, h, color)
    virtio_gpu_draw_vline(drv, x + w - 1, y, h, color)
