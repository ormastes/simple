# VirtIO-GPU 2D Driver — DeviceGrant-based PCI Legacy Transport
#
# MDSOC: feature dimension, drivers layer
# Provides 2D framebuffer rendering via VirtIO-GPU protocol.
# Uses controlq (queue 0) for all display commands.
#
# VirtIO legacy PCI transport (BAR0 I/O register layout):
#   0x00 host_features, 0x04 guest_features, 0x08 queue_pfn,
#   0x0C queue_size, 0x0E queue_sel, 0x10 queue_notify,
#   0x12 status, 0x13 isr
#
# Communication: driver writes a command struct into a controlq descriptor,
# device writes response back. Each command uses a two-descriptor chain:
#   desc[0] = request (device-readable), desc[1] = response (device-writable).
#
# All DMA buffers are allocated via syscall 84 (AllocDma).
# BAR0 is mapped via syscall 83 (MapBar).

use os.kernel.types.device_mem_types.{DeviceGrant}
use os.kernel.boot.mmio.{mmio_read8, mmio_read16, mmio_read32, mmio_write8, mmio_write16, mmio_write32, mmio_write64, mmio_read64}
use os.kernel.boot.cpu.{port_inb, port_outb, port_inw, port_outw, port_inl, port_outl}
use os.userlib.syscall_raw.{syscall}
use os.drivers.pci.pci.{pci_read_config, pci_write_config}
use os.drivers.virtio.virtio_gpu_types.{
    VIRTIO_GPU_CMD_GET_DISPLAY_INFO, VIRTIO_GPU_CMD_RESOURCE_CREATE_2D,
    VIRTIO_GPU_CMD_SET_SCANOUT, VIRTIO_GPU_CMD_RESOURCE_FLUSH,
    VIRTIO_GPU_CMD_TRANSFER_TO_HOST_2D, VIRTIO_GPU_CMD_RESOURCE_ATTACH_BACKING,
    VIRTIO_GPU_CMD_RESOURCE_DETACH_BACKING, VIRTIO_GPU_CMD_RESOURCE_UNREF,
    VIRTIO_GPU_RESP_OK_NODATA, VIRTIO_GPU_RESP_OK_DISPLAY_INFO,
    VIRTIO_GPU_FORMAT_B8G8R8A8_UNORM,
    CTRL_HDR_SIZE, DISPLAY_INFO_RESP_SIZE, RESOURCE_CREATE_SIZE,
    SET_SCANOUT_SIZE, TRANSFER_SIZE, ATTACH_BACKING_TOTAL_SIZE,
    FLUSH_SIZE, MEM_ENTRY_SIZE,
    DETACH_BACKING_SIZE, RESOURCE_UNREF_SIZE
}
use os.drivers.virtio.virtio_common.{VIRTQ_DESC_F_NEXT, VIRTQ_DESC_F_WRITE}
use os.userlib.device.{DeviceDmaDescriptor, DMA_CACHE_COHERENT}
use os.kernel.log.klog_api.{log_init, log_info, log_warn, log_error, log_raw, log_raw_println}
use os.drivers.virtio.virtio_gpu_init.{virtio_gpu_init_from_grant, virtio_gpu_init_legacy}
use os.drivers.virtio.virtio_gpu_ops.{
    virtio_gpu_cmd_get_display_info,
    virtio_gpu_cmd_resource_create_2d_raw, virtio_gpu_cmd_resource_attach_backing_raw, virtio_gpu_cmd_set_scanout_raw,
    virtio_gpu_cmd_resource_create_2d, virtio_gpu_cmd_resource_attach_backing, virtio_gpu_cmd_set_scanout,
    virtio_gpu_cmd_resource_detach_backing, virtio_gpu_cmd_resource_unref,
    virtio_gpu_flush, virtio_gpu_flush_rect,
    virtio_gpu_put_pixel, virtio_gpu_fill_rect, virtio_gpu_clear,
    virtio_gpu_draw_hline, virtio_gpu_draw_vline, virtio_gpu_draw_rect
}

extern fn rt_alloc(size: u64) -> u64
extern fn rt_memory_barrier()
extern fn rt_mmio_read_u32(addr: u64) -> u32
extern fn rt_mmio_read_u64(addr: u64) -> u64
extern fn rt_mmio_write_u32(addr: u64, value: u32)
extern fn rt_mmio_write_u64(addr: u64, value: u64)
extern fn rt_mem_read_u32_boxed(addr: u64) -> u32
extern fn rt_mem_write_u32_boxed(addr: u64, value: u32)
extern fn rt_mmio_write_u16_real(addr: u64, value: u64)
extern fn rt_mmio_write_u32_real(addr: u64, value: u64)
extern fn rt_mmio_write_u64_real(addr: u64, value: u64)
extern fn rt_wait_u16_change(addr: u64, old_value: u64, spins: u64) -> u64
extern fn rt_virtq_avail_slot_addr(base: u64, idx: u64, qsize: u64) -> u64
extern fn rt_virtio_notify_addr(base: u64, off: u64, mult: u64) -> u64
extern fn rt_virtio_notify_write16(base: u64, off: u64, mult: u64, value: u64) -> u64
extern fn rt_alloc_page_aligned(size: u64) -> u64
extern fn rt_virtq_desc_write(base: u64, index: u64, addr_lo: u64, addr_hi: u64, len: u64, flags: u64, next: u64) -> u64
extern fn rt_virtq_write_req_resp_chain(base: u64, req_addr: u64, req_len: u64, resp_addr: u64, resp_len: u64) -> u64
extern fn rt_virtio_gpu_write_ctrl_hdr(addr: u64, cmd_type: u64) -> u64
extern fn rt_mmio_read_u32_real(addr: u64) -> u64
extern fn rt_mmio_read_u64_real(addr: u64) -> u64

# ============================================================================
# VirtIO Legacy PCI BAR0 Register Offsets
# ============================================================================

val VIRTIO_PCI_HOST_FEATURES: u64 = 0x00
val VIRTIO_PCI_GUEST_FEATURES: u64 = 0x04
val VIRTIO_PCI_QUEUE_PFN: u64 = 0x08
val VIRTIO_PCI_QUEUE_SIZE: u64 = 0x0C
val VIRTIO_PCI_QUEUE_SEL: u64 = 0x0E
val VIRTIO_PCI_QUEUE_NOTIFY: u64 = 0x10
val VIRTIO_PCI_STATUS: u64 = 0x12
val VIRTIO_PCI_ISR: u64 = 0x13

# Modern virtio-pci vendor capability and common-config layout
val PCI_CAP_ID_VENDOR_SPECIFIC: u8 = 0x09
val VIRTIO_PCI_CAP_COMMON_CFG: u8 = 1
val VIRTIO_PCI_CAP_NOTIFY_CFG: u8 = 2
val VIRTIO_PCI_CAP_ISR_CFG: u8 = 3

val MODERN_COMMON_DEVICE_FEATURE_SELECT: u64 = 0x00
val MODERN_COMMON_DEVICE_FEATURE: u64 = 0x04
val MODERN_COMMON_DRIVER_FEATURE_SELECT: u64 = 0x08
val MODERN_COMMON_DRIVER_FEATURE: u64 = 0x0C
val MODERN_COMMON_DEVICE_STATUS: u64 = 0x14
val MODERN_COMMON_QUEUE_SELECT: u64 = 0x16
val MODERN_COMMON_QUEUE_SIZE: u64 = 0x18
val MODERN_COMMON_QUEUE_ENABLE: u64 = 0x1C
val MODERN_COMMON_QUEUE_NOTIFY_OFF: u64 = 0x1E
val MODERN_COMMON_QUEUE_DESC_LO: u64 = 0x20
val MODERN_COMMON_QUEUE_DESC_HI: u64 = 0x24
val MODERN_COMMON_QUEUE_AVAIL_LO: u64 = 0x28
val MODERN_COMMON_QUEUE_AVAIL_HI: u64 = 0x2C
val MODERN_COMMON_QUEUE_USED_LO: u64 = 0x30
val MODERN_COMMON_QUEUE_USED_HI: u64 = 0x34

# Device status bits
val STATUS_ACKNOWLEDGE: u8 = 1
val STATUS_DRIVER: u8 = 2
val STATUS_DRIVER_OK: u8 = 4
val STATUS_FEATURES_OK: u8 = 8
val STATUS_FAILED: u8 = 128

# Controlq index
val VIRTIO_GPU_CONTROLQ: u16 = 0

# ============================================================================
# Virtqueue Ring Layout Helpers
# ============================================================================
# For a queue of size N:
#   Descriptor table: N * 16 bytes
#   Available ring:   4 + 2*N bytes (flags:u16, idx:u16, ring[N]:u16)
#   Used ring:        4 + 8*N bytes (flags:u16, idx:u16, ring[N]:(id:u32,len:u32))
# Legacy PCI virtqueue: all three placed contiguously, PFN = phys >> 12

fn virtqueue_desc_size(queue_size: u64) -> u64:
    queue_size * 16

fn virtqueue_avail_size(queue_size: u64) -> u64:
    4 + 2 * queue_size

fn virtqueue_used_size(queue_size: u64) -> u64:
    4 + 8 * queue_size

fn virtqueue_total_size(queue_size: u64) -> u64:
    val ds = virtqueue_desc_size(queue_size)
    val avs = virtqueue_avail_size(queue_size)
    val us = virtqueue_used_size(queue_size)
    # Align used ring to 4096 boundary (virtio spec requirement for legacy)
    val desc_avail = ds + avs
    val aligned = (desc_avail + 4095) & ~4095
    aligned + us

fn ram_read32(addr: u64) -> u32:
    mmio_read32(addr)

fn ram_read16(addr: u64) -> u16:
    mmio_read16(addr)

fn ram_read64(addr: u64) -> u64:
    mmio_read64(addr)

fn ram_write16(addr: u64, value: u16):
    mmio_write16(addr, value)

fn ram_write32(addr: u64, value: u32):
    rt_mem_write_u32_boxed(addr, value)

fn ram_write64(addr: u64, value: u64):
    rt_mmio_write_u64(addr, value)

fn ram_write16_raw(addr: u64, value: u64):
    rt_mmio_write_u16_real(addr, value)

fn ram_write32_raw(addr: u64, value: u64):
    rt_mmio_write_u32_real(addr, value)

fn ram_write64_raw(addr: u64, value: u64):
    rt_mmio_write_u64_real(addr, value)

fn ram_read32_raw(addr: u64) -> u32:
    rt_mmio_read_u32_real(addr).to_u32()

fn ram_read64_raw(addr: u64) -> u64:
    rt_mmio_read_u64_real(addr)

fn ram_read32_boxed(addr: u64) -> u32:
    rt_mem_read_u32_boxed(addr)

# ============================================================================
# DMA Allocation Result (baremetal-safe, no heap)
# ============================================================================

struct GpuDmaAllocResult:
    """Result of a DMA buffer allocation."""
    virt: u64
    phys: u64
    device: u64
    size: u64
    cache_policy: u8
    ok: bool

impl GpuDmaAllocResult:
    fn is_err() -> bool:
        not self.ok

    fn unwrap_virt() -> u64:
        self.virt

    fn unwrap_phys() -> u64:
        self.phys

    fn unwrap_device() -> u64:
        self.device

    fn into_descriptor() -> DeviceDmaDescriptor:
        DeviceDmaDescriptor(
            virt_addr: self.virt,
            phys_addr: self.phys,
            device_addr: self.device,
            size_bytes: self.size,
            cache_policy: self.cache_policy,
            owner_task: 0,
            owner_device: 0x1050,
            allocation_id: 0
        )

struct VirtioGpuCapabilities:
    backend_kind: text
    flush_mode: text
    cache_policy: text
    dma_accelerated: bool

pub struct VirtioGpuInitResult:
    """Returned by virtio_gpu_init_from_grant and virtio_gpu_init_legacy.
    The caller must assign .driver back to the driver variable on success."""
    driver: VirtioGpuDriver
    ok: bool
    err_msg: text

# ============================================================================
# VirtIO-GPU 2D Driver
# ============================================================================

struct VirtioGpuDriver:
    """VirtIO-GPU 2D driver using PCI legacy transport.

    Manages a controlq (queue 0) for sending GPU commands and
    a DMA framebuffer for pixel rendering. Supports 2D resource
    creation, scanout binding, and flush operations.
    """
    bar0_virt: u64
    bar0_port: u16       # I/O port base for legacy VirtIO
    is_io_bar: bool      # True if BAR0 is I/O port, false if MMIO
    is_modern_pci: bool
    modern_common_virt: u64
    modern_notify_virt: u64
    modern_isr_virt: u64
    modern_notify_multiplier: u32
    notif_id: u64
    # Control queue
    ctrl_desc_virt: u64
    ctrl_desc_phys: u64
    ctrl_avail_virt: u64
    ctrl_avail_phys: u64
    ctrl_used_virt: u64
    ctrl_used_phys: u64
    ctrl_queue_size: u16
    ctrl_desc_idx: u16      # Next free descriptor index
    ctrl_last_used: u16
    # Command/response DMA buffers (shared for all commands)
    cmd_buf_virt: u64
    cmd_buf_phys: u64
    resp_buf_virt: u64
    resp_buf_phys: u64
    # Framebuffer
    fb_virt: u64
    fb_phys: u64
    fb_size: u64
    width_raw: u64
    height_raw: u64
    resource_id_raw: u64
    width: u32
    height: u32
    resource_id: u32
    next_resource_id: u32
    initialized: bool

impl VirtioGpuDriver:
    static fn new() -> VirtioGpuDriver:
        VirtioGpuDriver(
            bar0_virt: 0, bar0_port: 0, is_io_bar: false,
            is_modern_pci: false, modern_common_virt: 0, modern_notify_virt: 0,
            modern_isr_virt: 0, modern_notify_multiplier: 0, notif_id: 0,
            ctrl_desc_virt: 0, ctrl_desc_phys: 0,
            ctrl_avail_virt: 0, ctrl_avail_phys: 0,
            ctrl_used_virt: 0, ctrl_used_phys: 0,
            ctrl_queue_size: 0, ctrl_desc_idx: 0, ctrl_last_used: 0,
            cmd_buf_virt: 0, cmd_buf_phys: 0,
            resp_buf_virt: 0, resp_buf_phys: 0,
            fb_virt: 0, fb_phys: 0, fb_size: 0,
            width_raw: 0, height_raw: 0, resource_id_raw: 0,
            width: 0, height: 0,
            resource_id: 0, next_resource_id: 1,
            initialized: false
        )

    # ========================================================================
    # Initialization — delegated to virtio_gpu_init.spl
    # ========================================================================

    me init_from_grant(grant: DeviceGrant) -> Result<bool, text>:
        val r = virtio_gpu_init_from_grant(self, grant)
        if not r.ok:
            return Err(r.err_msg)
        self = r.driver
        Ok(true)

    me init_legacy_from_bar0(bar0_phys: u64, bar0_size: u64, notif_id: u64) -> Result<bool, text>:
        val r = virtio_gpu_init_legacy(self, bar0_phys, bar0_size, notif_id)
        if not r.ok:
            return Err(r.err_msg)
        self = r.driver
        Ok(true)

    me try_map_modern_pci_caps(grant: DeviceGrant) -> bool:
        """Probe PCI vendor capabilities for the modern common/notify/isr windows."""
        val cmd_raw = self.pci_cfg_read32(grant, 0x04)
        val cmd_enabled = cmd_raw | 0x00000006
        if cmd_enabled != cmd_raw:
            pci_write_config(grant.pci_bus, grant.pci_dev, grant.pci_func, 0x04, cmd_enabled)
            log_info("[virtio] " + "[virtio-gpu] enabled PCI memory+bus-master cmd=0x{cmd_enabled}")

        val cap_ptr0 = self.pci_cfg_read8(grant, 0x34)
        var cap_ptr = cap_ptr0
        while cap_ptr >= 0x40 and cap_ptr != 0xFF:
            val cap_id = self.pci_cfg_read8(grant, cap_ptr)
            val next_ptr = self.pci_cfg_read8(grant, cap_ptr + 1)
            if cap_id == PCI_CAP_ID_VENDOR_SPECIFIC:
                val cfg_type = self.pci_cfg_read8(grant, cap_ptr + 3)
                val bar = self.pci_cfg_read8(grant, cap_ptr + 4)
                val offset = self.pci_cfg_read32(grant, cap_ptr + 8)
                val length = self.pci_cfg_read32(grant, cap_ptr + 12)
                val bar_phys = self.pci_bar_phys(grant, bar)
                log_info("[virtio] " + "[virtio-gpu] cap cfg_type={cfg_type} bar={bar} bar_phys=0x{bar_phys} off=0x{offset} len=0x{length}")
                if bar_phys != 0 and length > 0:
                    # These capability windows sit inside the same page-aligned
                    # BAR aperture. Use bitwise OR instead of `+` here: this
                    # lane has shown corrupted large-address addition results
                    # when composing BAR4 phys bases with small page offsets.
                    val mapped = bar_phys | offset.to_u64()
                    log_info("[virtio] " + "[virtio-gpu] cap mapped=0x{mapped}")
                    if mapped != 0:
                        if cfg_type == VIRTIO_PCI_CAP_COMMON_CFG:
                            self.modern_common_virt = mapped
                            val probe_feat = mmio_read32(mapped + 4)
                            val probe_qsize = mmio_read16(mapped + MODERN_COMMON_QUEUE_SIZE)
                            log_info("[virtio] " + "[virtio-gpu] common probe feat=0x{probe_feat} qsize=0x{probe_qsize}")
                        elif cfg_type == VIRTIO_PCI_CAP_NOTIFY_CFG:
                            self.modern_notify_virt = mapped
                            self.modern_notify_multiplier = self.pci_cfg_read32(grant, cap_ptr + 16)
                        elif cfg_type == VIRTIO_PCI_CAP_ISR_CFG:
                            self.modern_isr_virt = mapped
            if next_ptr == 0 or next_ptr == cap_ptr:
                break
            cap_ptr = next_ptr

        self.is_modern_pci = self.modern_common_virt != 0 and self.modern_notify_virt != 0
        if self.is_modern_pci:
            log_info("[virtio] " + "[virtio-gpu] modern caps common=0x{self.modern_common_virt} notify=0x{self.modern_notify_virt} isr=0x{self.modern_isr_virt} mult={self.modern_notify_multiplier}")
        self.is_modern_pci

    me setup_controlq_modern() -> Result<bool, text>:
        self.modern_write16(MODERN_COMMON_QUEUE_SELECT, VIRTIO_GPU_CONTROLQ)
        val num_queues = self.modern_read16(0x12)
        val queue_select_echo = self.modern_read16(MODERN_COMMON_QUEUE_SELECT)
        val max_size = self.modern_read16(MODERN_COMMON_QUEUE_SIZE)
        log_info("[virtio] " + "[virtio-gpu] modern controlq probe: num_queues={num_queues} queue_select={queue_select_echo} queue_size_reg={max_size} notify_mult={self.modern_notify_multiplier}")
        if max_size == 0:
            return Err("Controlq not available")

        var qsize: u16 = max_size
        if qsize > 128:
            qsize = 128
        self.ctrl_queue_size = qsize
        self.modern_write16(MODERN_COMMON_QUEUE_SIZE, qsize)

        val desc_dma = self.alloc_dma(virtqueue_desc_size(qsize.to_u64()))
        if desc_dma.is_err():
            return Err("DMA alloc for controlq desc failed")
        val avail_dma = self.alloc_dma(virtqueue_avail_size(qsize.to_u64()))
        if avail_dma.is_err():
            return Err("DMA alloc for controlq avail failed")
        val used_dma = self.alloc_dma(virtqueue_used_size(qsize.to_u64()))
        if used_dma.is_err():
            return Err("DMA alloc for controlq used failed")

        self.ctrl_desc_virt = desc_dma.unwrap_virt()
        self.ctrl_desc_phys = desc_dma.unwrap_device()
        self.ctrl_avail_virt = avail_dma.unwrap_virt()
        self.ctrl_avail_phys = avail_dma.unwrap_device()
        self.ctrl_used_virt = used_dma.unwrap_virt()
        self.ctrl_used_phys = used_dma.unwrap_device()

        var i: u16 = 0
        while i < qsize - 1:
            val desc_off = self.ctrl_desc_virt + (i * 16).to_u64()
            ram_write32(desc_off + 12, ((i + 1).to_u32()) << 16)
            i = i + 1
        val last_off = self.ctrl_desc_virt + ((qsize - 1) * 16).to_u64()
        ram_write32(last_off + 12, (qsize.to_u32()) << 16)

        ram_write16(self.ctrl_avail_virt, 0)
        ram_write16(self.ctrl_avail_virt + 2, 0)
        ram_write16(self.ctrl_used_virt, 0)
        ram_write16(self.ctrl_used_virt + 2, 0)

        self.ctrl_desc_idx = 0
        self.ctrl_last_used = 0

        log_info("[virtio] " + "[virtio-gpu] controlq layout desc=0x{self.ctrl_desc_phys} avail=0x{self.ctrl_avail_phys} used=0x{self.ctrl_used_phys}")
        self.modern_write32(MODERN_COMMON_QUEUE_DESC_LO, (self.ctrl_desc_phys & 0xFFFFFFFF).to_u32())
        self.modern_write32(MODERN_COMMON_QUEUE_DESC_HI, (self.ctrl_desc_phys >> 32).to_u32())
        self.modern_write32(MODERN_COMMON_QUEUE_AVAIL_LO, (self.ctrl_avail_phys & 0xFFFFFFFF).to_u32())
        self.modern_write32(MODERN_COMMON_QUEUE_AVAIL_HI, (self.ctrl_avail_phys >> 32).to_u32())
        self.modern_write32(MODERN_COMMON_QUEUE_USED_LO, (self.ctrl_used_phys & 0xFFFFFFFF).to_u32())
        self.modern_write32(MODERN_COMMON_QUEUE_USED_HI, (self.ctrl_used_phys >> 32).to_u32())
        log_info("[virtio] " + "[virtio-gpu] controlq regs desc_lo=0x{self.modern_read32(MODERN_COMMON_QUEUE_DESC_LO)} avail_lo=0x{self.modern_read32(MODERN_COMMON_QUEUE_AVAIL_LO)} used_lo=0x{self.modern_read32(MODERN_COMMON_QUEUE_USED_LO)}")
        self.modern_write16(MODERN_COMMON_QUEUE_ENABLE, 1)
        Ok(true)

    fn pci_cfg_read8(grant: DeviceGrant, offset: u8) -> u8:
        val aligned = offset & 0xFC
        val shift = (offset & 0x03).to_u32() * 8
        ((pci_read_config(grant.pci_bus, grant.pci_dev, grant.pci_func, aligned) >> shift) & 0xFF).to_u8()

    fn pci_cfg_read32(grant: DeviceGrant, offset: u8) -> u32:
        pci_read_config(grant.pci_bus, grant.pci_dev, grant.pci_func, offset & 0xFC)

    fn pci_bar_phys(grant: DeviceGrant, bar: u8) -> u64:
        if bar >= 6:
            return 0
        val low_off: u8 = 0x10 + bar * 4
        val low = self.pci_cfg_read32(grant, low_off)
        if low == 0 or low == 0xFFFFFFFF:
            return 0
        if (low & 1) != 0:
            return (low & 0xFFFFFFFC).to_u64()
        if (low & 0x6) == 0x4 and bar < 5:
            val high = self.pci_cfg_read32(grant, low_off + 4)
            return ((high.to_u64()) << 32) | (low & 0xFFFFFFF0).to_u64()
        (low & 0xFFFFFFF0).to_u64()

    fn modern_read8(offset: u64) -> u8:
        mmio_read8(self.modern_common_virt + offset)

    fn modern_read16(offset: u64) -> u16:
        mmio_read16(self.modern_common_virt + offset)

    fn modern_read32(offset: u64) -> u32:
        mmio_read32(self.modern_common_virt + offset)

    fn modern_write8(offset: u64, value: u8):
        mmio_write8(self.modern_common_virt + offset, value)

    fn modern_write16(offset: u64, value: u16):
        mmio_write16(self.modern_common_virt + offset, value)

    fn modern_write32(offset: u64, value: u32):
        mmio_write32(self.modern_common_virt + offset, value)

    fn notify_queue(queue_idx: u16):
        if self.is_modern_pci:
            self.modern_write16(MODERN_COMMON_QUEUE_SELECT, queue_idx)
            val notify_off = self.modern_read16(MODERN_COMMON_QUEUE_NOTIFY_OFF).to_u64()
            val addr = rt_virtio_notify_addr(self.modern_notify_virt, notify_off, self.modern_notify_multiplier.to_u64())
            log_info("[virtio] " + "[virtio-gpu] notify addr=0x{addr} off={notify_off} mult={self.modern_notify_multiplier} q={queue_idx}")
            rt_virtio_notify_write16(self.modern_notify_virt, notify_off, self.modern_notify_multiplier.to_u64(), queue_idx.to_u64())
        else:
            self.write_reg16(VIRTIO_PCI_QUEUE_NOTIFY, queue_idx)

    # ========================================================================
    # Controlq Setup
    # ========================================================================

    me setup_controlq() -> Result<bool, text>:
        """Set up controlq (queue 0): select, read size, allocate DMA, set PFN."""
        # Select queue 0
        self.write_reg16(VIRTIO_PCI_QUEUE_SEL, VIRTIO_GPU_CONTROLQ)

        # Read max queue size
        val max_size = self.read_reg16(VIRTIO_PCI_QUEUE_SIZE)
        log_info("[virtio] " + "[virtio-gpu] controlq probe: io_bar={self.is_io_bar} queue_size_reg={max_size}")
        if max_size == 0:
            return Err("Controlq not available")

        # Cap to 128 entries
        var qsize: u16 = max_size
        if qsize > 128:
            qsize = 128
        self.ctrl_queue_size = qsize

        # Allocate DMA memory for virtqueue rings
        val total = virtqueue_total_size(qsize.to_u64())
        val ring_dma = self.alloc_dma(total)
        if ring_dma.is_err():
            return Err("DMA alloc for controlq failed")
        val ring_virt = ring_dma.unwrap_virt()
        val ring_phys = ring_dma.unwrap_device()

        # Compute sub-region offsets
        self.ctrl_desc_virt = ring_virt
        self.ctrl_desc_phys = ring_phys
        self.ctrl_avail_virt = ring_virt + virtqueue_desc_size(qsize.to_u64())
        val desc_avail = virtqueue_desc_size(qsize.to_u64()) + virtqueue_avail_size(qsize.to_u64())
        self.ctrl_used_virt = ring_virt + ((desc_avail + 4095) & ~4095)

        # Initialize descriptor free list: chain each desc -> next
        var i: u16 = 0
        while i < qsize - 1:
            val desc_off = self.ctrl_desc_virt + (i * 16).to_u64()
            ram_write32(desc_off + 12, ((i + 1).to_u32()) << 16)
            i = i + 1
        # Last descriptor: next = qsize (sentinel)
        val last_off = self.ctrl_desc_virt + ((qsize - 1) * 16).to_u64()
        ram_write32(last_off + 12, (qsize.to_u32()) << 16)

        # Zero the avail ring header (flags=0, idx=0)
        ram_write16(self.ctrl_avail_virt, 0)
        ram_write16(self.ctrl_avail_virt + 2, 0)

        # Zero the used ring header (flags=0, idx=0)
        ram_write16(self.ctrl_used_virt, 0)
        ram_write16(self.ctrl_used_virt + 2, 0)

        self.ctrl_desc_idx = 0
        self.ctrl_last_used = 0

        # Tell device the queue PFN (phys >> 12)
        val pfn = (ring_phys >> 12).to_u32()
        self.write_reg32(VIRTIO_PCI_QUEUE_PFN, pfn)

        Ok(true)

    # ========================================================================
    # DMA Allocation
    # ========================================================================

    fn alloc_dma(size: u64) -> GpuDmaAllocResult:
        """Allocate page-aligned DMA memory from the baremetal wrapper heap.

        In the SYS-GUI-008 wrapper lane, syscall 84 resolves to the direct
        baremetal stub path and does not provide the kernel alloc_dma contract.
        Use the raw aligned allocator instead so device-visible addresses are
        stable and page-aligned under the identity-map assumption.
        """
        val aligned = rt_alloc_page_aligned(size)
        if aligned == 0:
            return GpuDmaAllocResult(virt: 0, phys: 0, device: 0, size: 0, cache_policy: DMA_CACHE_COHERENT, ok: false)
        GpuDmaAllocResult(virt: aligned, phys: aligned, device: aligned, size: size, cache_policy: DMA_CACHE_COHERENT, ok: true)

    # ========================================================================
    # Register Access Helpers (I/O port for legacy VirtIO, MMIO otherwise)
    # ========================================================================

    fn read_reg8(offset: u64) -> u8:
        if self.is_io_bar:
            port_inb((self.bar0_port + offset.to_u16()))
        else:
            mmio_read8(self.bar0_virt + offset)

    fn write_reg8(offset: u64, value: u8):
        if self.is_io_bar:
            port_outb((self.bar0_port + offset.to_u16()), value)
        else:
            mmio_write8(self.bar0_virt + offset, value)

    fn read_reg16(offset: u64) -> u16:
        if self.is_io_bar:
            port_inw((self.bar0_port + offset.to_u16()))
        else:
            mmio_read16(self.bar0_virt + offset)

    fn write_reg16(offset: u64, value: u16):
        if self.is_io_bar:
            port_outw((self.bar0_port + offset.to_u16()), value)
        else:
            mmio_write16(self.bar0_virt + offset, value)

    fn read_reg32(offset: u64) -> u32:
        if self.is_io_bar:
            port_inl((self.bar0_port + offset.to_u16()))
        else:
            mmio_read32(self.bar0_virt + offset)

    fn write_reg32(offset: u64, value: u32):
        if self.is_io_bar:
            port_outl((self.bar0_port + offset.to_u16()), value)
        else:
            mmio_write32(self.bar0_virt + offset, value)

    fn write_status(status: u8):
        """Write to the VirtIO PCI device status register."""
        self.write_reg8(VIRTIO_PCI_STATUS, status)

    fn read_isr() -> u8:
        """Read and clear interrupt status register."""
        if self.is_modern_pci and self.modern_isr_virt != 0:
            return mmio_read8(self.modern_isr_virt)
        self.read_reg8(VIRTIO_PCI_ISR)

    # ========================================================================
    # Command Submission (two-descriptor chain)
    # ========================================================================

    me _write_ctrl_hdr(cmd_type: u32):
        """Write a VirtioGpuCtrlHdr (24 bytes) at the start of cmd_buf.

        Layout: type(4) + flags(4) + fence_id(8) + ctx_id(4) + padding(4)
        """
        rt_virtio_gpu_write_ctrl_hdr(self.cmd_buf_virt, cmd_type.to_u64())

    me _send_command(cmd_size: u64, resp_size: u64) -> u32:
        """Submit a command via controlq and wait for response.

        Sets up a two-descriptor chain:
          desc[d0]: request buffer (device-readable, NEXT flag)
          desc[d1]: response buffer (device-writable, WRITE flag)
        Adds d0 to available ring, notifies device, polls used ring.

        Returns the response type (first 4 bytes of response buffer).
        """
        val d0: u16 = 0
        val d1: u16 = 1

        # desc[d0]: request (device reads from cmd_buf)
        rt_virtq_write_req_resp_chain(
            self.ctrl_desc_virt,
            self.cmd_buf_phys, cmd_size,
            self.resp_buf_phys, resp_size
        )

        val d0_off = self.ctrl_desc_virt + (d0 * 16).to_u64()
        val d1_off = self.ctrl_desc_virt + (d1 * 16).to_u64()

        # Barrier: ensure descriptor writes are visible to device before avail ring update
        rt_memory_barrier()

        # Add d0 to available ring
        val avail_idx = ram_read16(self.ctrl_avail_virt + 2)
        val ring_slot = rt_virtq_avail_slot_addr(self.ctrl_avail_virt, avail_idx.to_u64(), self.ctrl_queue_size.to_u64())
        ram_write16_raw(ring_slot, d0.to_u64())
        val ring_slot_readback = ram_read16(ring_slot)
        ram_write16_raw(self.ctrl_avail_virt + 2, (avail_idx + 1).to_u64())
        val avail_idx_after = ram_read16(self.ctrl_avail_virt + 2)
        log_info("[virtio] " + "[virtio-gpu] desc d0 addr=0x{self.cmd_buf_phys} len={cmd_size} tail=0x{ram_read32(d0_off + 12)}")
        log_info("[virtio] " + "[virtio-gpu] desc d1 addr=0x{self.resp_buf_phys} len={resp_size} tail=0x{ram_read32(d1_off + 12)}")
        log_info("[virtio] " + "[virtio-gpu] avail slot=0x{ring_slot} wrote={d0} readback={ring_slot_readback} idx_before={avail_idx} idx_after={avail_idx_after}")
        log_info("[virtio] " + "[virtio-gpu] used idx before notify={ram_read16(self.ctrl_used_virt + 2)}")

        # Notify device (controlq = queue 0)
        val d0_desc_lo = ram_read32(d0_off)
        val d0_desc_hi = ram_read32(d0_off + 4)
        val d0_desc_len = ram_read32(d0_off + 8)
        val d0_desc_flags = ram_read32(d0_off + 12)
        val d1_desc_lo = ram_read32(d1_off)
        val d1_desc_hi = ram_read32(d1_off + 4)
        val d1_desc_len = ram_read32(d1_off + 8)
        val d1_desc_flags = ram_read32(d1_off + 12)
        val avail_flags = ram_read16(self.ctrl_avail_virt)
        val avail_hdr_idx = ram_read16(self.ctrl_avail_virt + 2)
        val avail_ring0 = ram_read16(self.ctrl_avail_virt + 4)
        val used_flags = ram_read16(self.ctrl_used_virt)
        val used_hdr_idx = ram_read16(self.ctrl_used_virt + 2)
        log_info("[virtio] " + "[virtio-gpu] pre-notify desc[d0] lo=0x{d0_desc_lo} hi=0x{d0_desc_hi} len={d0_desc_len} flags=0x{d0_desc_flags}")
        log_info("[virtio] " + "[virtio-gpu] pre-notify desc[d1] lo=0x{d1_desc_lo} hi=0x{d1_desc_hi} len={d1_desc_len} flags=0x{d1_desc_flags}")
        log_info("[virtio] " + "[virtio-gpu] pre-notify avail flags=0x{avail_flags} idx={avail_hdr_idx} ring0={avail_ring0}")
        log_info("[virtio] " + "[virtio-gpu] pre-notify used flags=0x{used_flags} idx={used_hdr_idx}")
        log_info("[virtio] " + "[virtio-gpu] send_command notify d0={d0} d1={d1} avail_idx={avail_idx} cmd_phys=0x{self.cmd_buf_phys} resp_phys=0x{self.resp_buf_phys}")
        # Barrier: ensure avail ring write is visible before doorbell write
        rt_memory_barrier()
        self.notify_queue(VIRTIO_GPU_CONTROLQ)
        log_info("[virtio] " + "[virtio-gpu] send_command notified")

        # Poll used ring for completion
        val used_idx = rt_wait_u16_change(self.ctrl_used_virt + 2, self.ctrl_last_used.to_u64(), 2000000)
        if used_idx != self.ctrl_last_used.to_u64():
            self.ctrl_last_used = used_idx.to_u16()
            log_info("[virtio] " + "[virtio-gpu] send_command complete used_idx={used_idx}")
        else:
            log_info("[virtio] " + "[virtio-gpu] send_command timeout")

        # Acknowledge ISR
        val isr = self.read_isr()

        # Return response type from first 4 bytes of response buffer
        rt_mmio_read_u32_real(self.resp_buf_virt).to_u32()

    # ========================================================================
    # GPU Commands — delegated to virtio_gpu_ops.spl
    # ========================================================================

    me cmd_get_display_info() -> Result<bool, text>:
        val r = virtio_gpu_cmd_get_display_info(self)
        if r.is_ok():
            self.width = 1280
            self.height = 800
        r

    me cmd_resource_create_2d_raw(res_id: u64, w: u64, h: u64) -> Result<bool, text>:
        virtio_gpu_cmd_resource_create_2d_raw(self, res_id, w, h)

    me cmd_resource_attach_backing_raw(res_id: u64, backing_phys: u64, backing_size: u64) -> Result<bool, text>:
        virtio_gpu_cmd_resource_attach_backing_raw(self, res_id, backing_phys, backing_size)

    me cmd_set_scanout_raw(scanout_id: u64, res_id: u64, w: u64, h: u64) -> Result<bool, text>:
        virtio_gpu_cmd_set_scanout_raw(self, scanout_id, res_id, w, h)

    me cmd_resource_create_2d(res_id: u32, w: u32, h: u32) -> Result<bool, text>:
        virtio_gpu_cmd_resource_create_2d(self, res_id, w, h)

    me cmd_resource_attach_backing(res_id: u32, backing_phys: u64, backing_size: u64) -> Result<bool, text>:
        virtio_gpu_cmd_resource_attach_backing(self, res_id, backing_phys, backing_size)

    me cmd_set_scanout(scanout_id: u32, res_id: u32, w: u32, h: u32) -> Result<bool, text>:
        virtio_gpu_cmd_set_scanout(self, scanout_id, res_id, w, h)

    me cmd_resource_detach_backing(res_id: u32) -> Result<bool, text>:
        virtio_gpu_cmd_resource_detach_backing(self, res_id)

    me cmd_resource_unref(res_id: u32) -> Result<bool, text>:
        virtio_gpu_cmd_resource_unref(self, res_id)

    # ========================================================================
    # Framebuffer + Pixel Drawing — delegated to virtio_gpu_ops.spl
    # ========================================================================

    me flush():
        virtio_gpu_flush(self)

    me flush_rect(x: u32, y: u32, w: u32, h: u32):
        virtio_gpu_flush_rect(self, x, y, w, h)

    me put_pixel(x: u32, y: u32, color: u32):
        virtio_gpu_put_pixel(self, x, y, color)

    me fill_rect(x: u32, y: u32, w: u32, h: u32, color: u32):
        virtio_gpu_fill_rect(self, x, y, w, h, color)

    me clear(color: u32):
        virtio_gpu_clear(self, color)

    me draw_hline(x: u32, y: u32, length: u32, color: u32):
        virtio_gpu_draw_hline(self, x, y, length, color)

    me draw_vline(x: u32, y: u32, length: u32, color: u32):
        virtio_gpu_draw_vline(self, x, y, length, color)

    me draw_rect(x: u32, y: u32, w: u32, h: u32, color: u32):
        virtio_gpu_draw_rect(self, x, y, w, h, color)

    # ========================================================================
    # Query
    # ========================================================================

    fn get_width() -> u32:
        self.width

    fn get_height() -> u32:
        self.height

    fn get_fb_virt() -> u64:
        """Return framebuffer virtual address for direct pixel access."""
        self.fb_virt

    fn get_fb_phys() -> u64:
        self.fb_phys

    fn get_fb_size() -> u64:
        self.fb_size

    fn is_initialized() -> bool:
        self.initialized

    fn capabilities() -> VirtioGpuCapabilities:
        VirtioGpuCapabilities(
            backend_kind: if self.initialized: "virtio-gpu-dma" else: "virtio-gpu-unavailable",
            flush_mode: "dirty-rect",
            cache_policy: "coherent",
            dma_accelerated: self.initialized
        )
