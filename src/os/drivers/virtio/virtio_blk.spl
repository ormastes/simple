# VirtIO Block Device Driver
#
# MDSOC: feature dimension, drivers layer
# Implements BlockDevice trait for VirtIO block devices in QEMU.
#
# VirtIO-blk uses a single virtqueue for read/write requests.
# Each request: header (type, sector) → data buffer → status byte.

# Split from src/os/drivers/virtio/virtio_blk.spl to keep module cohesion under the 800-line source limit.
export use os.drivers.virtio.virtio_blk_part1.*
export use os.drivers.virtio.virtio_blk_part2.*
export use os.drivers.virtio.virtio_blk_part3.*
