# VirtIO Block Device Driver
#
# MDSOC: feature dimension, drivers layer
# Implements BlockDevice trait for VirtIO block devices in QEMU.
#
# VirtIO-blk uses a single virtqueue for read/write requests.
# Each request: header (type, sector) → data buffer → status byte.

use os.drivers.virtio.virtio_common.{Virtqueue}
use os.kernel.boot.mmio.{mmio_read8, mmio_read16, mmio_read32, mmio_write8, mmio_write16, mmio_write32, mmio_read64}
use os.services.block_device.{BlockDevice}

# VirtIO MMIO probe constants for QEMU virt ARM acceptance lanes.
val VIRTIO_MMIO_BASE: u64 = 0x0A000000
val VIRTIO_MMIO_STRIDE: u64 = 0x200
val VIRTIO_MMIO_SLOTS: u64 = 32
val VIRTIO_MAGIC: u32 = 0x74726976     # "virt" little-endian
val VIRTIO_DEV_BLK: u32 = 2
val VIRTIO_MMIO_VERSION: u64 = 0x004
val VIRTIO_MMIO_DEVICE_ID: u64 = 0x008
val VIRTIO_MMIO_DEVICE_FEATURES: u64 = 0x010
val VIRTIO_MMIO_DEVICE_FEATURES_SEL: u64 = 0x014
val VIRTIO_MMIO_DRIVER_FEATURES: u64 = 0x020
val VIRTIO_MMIO_DRIVER_FEATURES_SEL: u64 = 0x024
val VIRTIO_MMIO_GUEST_PAGE_SIZE: u64 = 0x028
val VIRTIO_MMIO_QUEUE_SEL: u64 = 0x030
val VIRTIO_MMIO_QUEUE_NUM_MAX: u64 = 0x034
val VIRTIO_MMIO_QUEUE_NUM: u64 = 0x038
val VIRTIO_MMIO_QUEUE_ALIGN: u64 = 0x03C
val VIRTIO_MMIO_QUEUE_PFN: u64 = 0x040
val VIRTIO_MMIO_QUEUE_READY: u64 = 0x044
val VIRTIO_MMIO_QUEUE_NOTIFY: u64 = 0x050
val VIRTIO_MMIO_STATUS: u64 = 0x070
val VIRTIO_MMIO_QUEUE_DESC_LOW: u64 = 0x080
val VIRTIO_MMIO_QUEUE_DESC_HIGH: u64 = 0x084
val VIRTIO_MMIO_QUEUE_AVAIL_LOW: u64 = 0x090
val VIRTIO_MMIO_QUEUE_AVAIL_HIGH: u64 = 0x094
val VIRTIO_MMIO_QUEUE_USED_LOW: u64 = 0x0A0
val VIRTIO_MMIO_QUEUE_USED_HIGH: u64 = 0x0A4
val VIRTIO_STATUS_ACKNOWLEDGE: u32 = 1
val VIRTIO_STATUS_DRIVER: u32 = 2
val VIRTIO_STATUS_DRIVER_OK: u32 = 4
val VIRTIO_STATUS_FEATURES_OK: u32 = 8
val VIRTIO_STATUS_FAILED: u32 = 128
val VIRTQUEUE_SIZE: i32 = 128
val VIRTQ_DESC_F_NEXT: u16 = 1
val VIRTQ_DESC_F_WRITE: u16 = 2

# VirtIO block request types
val VIRTIO_BLK_T_IN: u32 = 0           # Read
val VIRTIO_BLK_T_OUT: u32 = 1          # Write
val VIRTIO_BLK_T_FLUSH: u32 = 4        # Flush

# VirtIO block status
val VIRTIO_BLK_S_OK: u8 = 0
val VIRTIO_BLK_S_IOERR: u8 = 1
val VIRTIO_BLK_S_UNSUPP: u8 = 2

# VirtIO block config offsets (from device base + 0x100)
val VIRTIO_BLK_CFG_CAPACITY: u64 = 0x100  # Total sectors (u64)
val VIRTIO_BLK_CFG_SEG_MAX: u64 = 0x10C
val VIRTIO_BLK_CFG_BLK_SIZE: u64 = 0x114  # Sector size

@repr("C")
struct VirtioBlkReqHeader:
    """VirtIO block request header (16 bytes)."""
    type_: u32          # VIRTIO_BLK_T_*
    reserved: u32
    sector: u64         # Starting sector (LBA)

struct VirtioBlkDmaRegion:
    """Caller-owned contiguous DMA region for zero-copy requests."""
    virt_addr: u64      # CPU-visible base address
    phys_addr: u64      # Device-visible base address
    total_len: u64      # Total allocated bytes (header + payload + status)

# ============================================================================
# VirtIO Block Driver
# ============================================================================

# Poll iterations before declaring a completion timeout (~1 s at typical QEMU speeds)
val BLK_COMPLETION_TIMEOUT_POLLS: u32 = 1000000

# Fixed early-boot DMA scratch area on QEMU virt. ARM fs-exec runs before the
# kernel syscall/device-service path is available, so this driver must not
# import userlib syscall helpers into the freestanding kernel closure.
val VIRTIO_BLK_DMA_BASE: u64 = 0x51000000
val VIRTIO_BLK_DMA_LIMIT: u64 = 0x52000000
var g_virtio_blk_dma_next: u64 = VIRTIO_BLK_DMA_BASE
var g_virtio_blk_mmio_base: u64 = 0
var g_virtio_blk_queue_size: u32 = 0
var g_virtio_blk_free_head: u32 = 0
var g_virtio_blk_last_used_idx: u32 = 0
var g_virtio_blk_desc_addr: u64 = 0
var g_virtio_blk_avail_addr: u64 = 0
var g_virtio_blk_used_addr: u64 = 0
var g_virtio_blk_last_read_bytes: [u8] = []

# rt_memcpy: bulk copy from DMA virtual address to output buffer (zero-copy fast path).
# Destination is the slice data pointer extracted from the [u8] fat-pointer header.
# On the Simple baremetal runtime the fat pointer layout is: [data_ptr: u64, len: u64],
# so unsafe_addr_of(slice) + 8 dereferences to the actual data base address.
extern fn rt_memcpy(dest: i64, src: i64, len: i64)
extern fn unsafe_addr_of(ref: any) -> u64
extern fn serial_println(msg: text)
extern fn rt_memory_barrier()
extern fn rt_virtq_desc_write(base: u64, index: u64, addr_lo: u64, addr_hi: u64, len: u64, flags: u64, next: u64) -> u64
extern fn rt_dma_bytes_to_array(addr: u64, len: u64) -> [u8]
extern fn rt_arm_virtio_blk_mmio_read_u32(off: u64) -> u32
extern fn rt_arm_virtio_blk_mmio_read_u64(off: u64) -> u64
extern fn rt_arm_virtio_blk_mmio_write_u32(off: u64, value: u32)
extern fn rt_arm_virtq_used_idx() -> u32
extern fn rt_arm_virtq_push_avail(desc_idx: u32)
extern fn rt_arm_virtio_blk_status_u8() -> u32
extern fn rt_arm_virtq_reset()
extern fn rt_arm_virtio_blk_prepare_read(lba: u64)
extern fn rt_arm_virtio_blk_read_sector_direct(lba: u64) -> u32
extern fn rt_arm_virtio_blk_queue_base() -> u64
extern fn rt_arm_virtio_blk_dma_base() -> u64
extern fn rt_arm_virtio_blk_sector_bytes() -> [u8]
extern fn rt_arm_virtio_blk_set_mmio_base(base: u64)
extern fn rt_arm_virtio_blk_configure_queue(version: u32)
extern fn rt_arm_virtio_blk_wait_completion(timeout_polls: u32) -> u32

struct VirtioBlkDmaAlloc:
    virt_addr: u64
    phys_addr: u64

fn _align_up_u64(value: u64, align: u64) -> u64:
    ((value + align - 1) / align) * align

fn _virtio_blk_zero(addr: u64, size: u64):
    var off: u64 = 0
    while off < size:
        mmio_write32(addr + off, 0)
        off = off + 4

fn _virtio_blk_alloc_dma(size: u64) -> Result<VirtioBlkDmaAlloc, text>:
    val alloc_size: u64 = 1024
    val addr: u64 = VIRTIO_BLK_DMA_BASE
    g_virtio_blk_dma_next = addr + alloc_size
    _virtio_blk_zero(addr: addr, size: alloc_size)
    Result.Ok(VirtioBlkDmaAlloc(
        virt_addr: addr,
        phys_addr: addr
    ))

fn _virtio_blk_alloc_dma_addr(size: u64) -> u64:
    val alloc_size: u64 = 1024
    var addr: u64 = rt_arm_virtio_blk_dma_base()
    if addr == 0:
        val fallback = _virtio_blk_alloc_dma(size)
        if fallback.is_err():
            return 0
        addr = fallback.unwrap().virt_addr
    _virtio_blk_zero(addr, alloc_size)
    addr


fn _virtio_blk_free_dma(_virt_addr: u64, _size: u64) -> Result<bool, text>:
    # Early boot allocations are arena-backed and live until QEMU exits.
    Result.Ok(true)

fn _virtio_blk_base() -> u64:
    if g_virtio_blk_mmio_base != 0:
        return g_virtio_blk_mmio_base
    VIRTIO_MMIO_BASE

fn _virtio_blk_reg_read32(off: u64) -> u32:
    rt_arm_virtio_blk_mmio_read_u32(off)

fn _virtio_blk_reg_read64(off: u64) -> u64:
    rt_arm_virtio_blk_mmio_read_u64(off)

fn _virtio_blk_reg_write32(off: u64, value: u32):
    rt_arm_virtio_blk_mmio_write_u32(off, value)

fn _virtq_desc_addr(idx: u32) -> u64:
    g_virtio_blk_desc_addr + (idx.to_u64() * 16)

fn _virtq_setup(base: u64):
    g_virtio_blk_queue_size = 128
    g_virtio_blk_free_head = 0
    g_virtio_blk_last_used_idx = 0
    g_virtio_blk_desc_addr = base
    g_virtio_blk_avail_addr = base + 2048
    g_virtio_blk_used_addr = base + 4096
    _virtio_blk_zero(addr: base, size: 8192)

    var i: u32 = 0
    while i + 1 < 128:
        mmio_write16(g_virtio_blk_desc_addr + (i.to_u64() * 16) + 14, (i + 1).to_u16())
        i = i + 1
    mmio_write16(g_virtio_blk_desc_addr + (127 * 16).to_u64() + 14, 128)
    mmio_write16(g_virtio_blk_avail_addr, 0)
    mmio_write16(g_virtio_blk_avail_addr + 2, 0)
    mmio_write16(g_virtio_blk_used_addr, 0)
    mmio_write16(g_virtio_blk_used_addr + 2, 0)

fn _virtq_alloc_desc() -> i32:
    if g_virtio_blk_free_head >= 128:
        return -1
    val idx = g_virtio_blk_free_head
    g_virtio_blk_free_head = mmio_read16(_virtq_desc_addr(idx) + 14).to_u32()
    idx.to_i32()

fn _virtq_free_desc(idx: u32):
    mmio_write16(_virtq_desc_addr(idx) + 14, g_virtio_blk_free_head.to_u16())
    g_virtio_blk_free_head = idx

fn _virtq_push_avail(desc_idx: u32):
    val avail_idx = mmio_read16(g_virtio_blk_avail_addr + 2)
    val ring_slot = g_virtio_blk_avail_addr + 4 + ((avail_idx.to_u64() % 128) * 2)
    mmio_write16(ring_slot, desc_idx.to_u16())
    rt_memory_barrier()
    mmio_write16(g_virtio_blk_avail_addr + 2, avail_idx + 1)
    rt_memory_barrier()

fn _virtq_wait_completion(timeout_polls: u32) -> bool:
    var i: u32 = 0
    while i < timeout_polls:
        val used_idx = mmio_read16(g_virtio_blk_used_addr + 2)
        if used_idx.to_u32() != g_virtio_blk_last_used_idx:
            g_virtio_blk_last_used_idx = used_idx.to_u32()
            return true
        i = i + 1
    false

fn _virtq_wait_completion_early(timeout_polls: u32) -> bool:
    var i: u32 = 0
    while i < timeout_polls:
        val used_idx = rt_arm_virtq_used_idx()
        if used_idx != g_virtio_blk_last_used_idx:
            g_virtio_blk_last_used_idx = used_idx
            return true
        i = i + 1
    false

fn _virtio_blk_wait_status(status_addr: u64, timeout_polls: u32) -> bool:
    var i: u32 = 0
    while i < timeout_polls:
        if mmio_read8(status_addr).to_u32() != 1:
            return true
        i = i + 1
    false

fn virtio_blk_last_read_bytes() -> [u8]:
    g_virtio_blk_last_read_bytes

class VirtioBlkDriver:
    """VirtIO block device driver.

    Provides sector-level read/write on a virtual disk.
    Used by FAT32 and other filesystem drivers.
    """
    base_addr: u64
    capacity_sectors: u64
    sector_size: u32
    initialized: bool
    notif_id: u64       # IRQ notification ID for interrupt-driven completion

impl VirtioBlkDriver:
    static fn arm_qemu_virt() -> VirtioBlkDriver:
        """Return the ARM QEMU virt block device at the known high MMIO slot."""
        val fixed_addr: u64 = 0x0A003E00
        g_virtio_blk_mmio_base = fixed_addr
        rt_arm_virtio_blk_set_mmio_base(fixed_addr)
        VirtioBlkDriver(
            base_addr: fixed_addr,
            capacity_sectors: 0,
            sector_size: 512,
            initialized: false,
            notif_id: 0
        )

    static fn new(base_addr: u64) -> VirtioBlkDriver:
        VirtioBlkDriver(
            base_addr: base_addr,
            capacity_sectors: 0,
            sector_size: 512,
            initialized: false,
            notif_id: 0
        )

    static fn probe() -> VirtioBlkDriver?:
        """Scan well-known QEMU virtio-mmio addresses for a block device.

        Reads the VirtIO magic at offset 0 and device type at offset 8.
        Returns the first VirtioBlkDriver whose slot advertises type 2 (blk),
        or nil if no device is found.
        """
        var i: i32 = 0
        while i < 32:
            val addr = VIRTIO_MMIO_BASE + ((i as u64) * VIRTIO_MMIO_STRIDE)
            val magic = mmio_read32(addr)
            if magic == VIRTIO_MAGIC:
                val dev_type = mmio_read32(addr + 8)
                if dev_type == VIRTIO_DEV_BLK:
                    serial_println("[virtio-blk-probe] mmio=0x{addr}")
                    g_virtio_blk_mmio_base = addr
                    rt_arm_virtio_blk_set_mmio_base(addr)
                    return Some(VirtioBlkDriver.new(addr))
            i = i + 1
        nil

    me init_ok() -> bool:
        """Initialize VirtIO block device with a bool-only result.

        Early ARM filesystem-exec boots avoid generic Result values here
        because that path runs before the full hosted runtime contract is
        available.
        """
        val magic = _virtio_blk_reg_read32(0)
        serial_println("[virtio-blk-init] magic={magic}")
        if magic == 0:
            return false

        val version = _virtio_blk_reg_read32(4)
        serial_println("[virtio-blk-init] version={version}")
        if version == 0:
            return false

        val device_id = _virtio_blk_reg_read32(8)
        serial_println("[virtio-blk-init] device_id={device_id}")
        if device_id != 2:
            return false

        _virtio_blk_reg_write32(112, 0)
        _virtio_blk_reg_write32(112, 1)
        _virtio_blk_reg_write32(112, 3)

        _virtio_blk_reg_write32(20, 0)
        val _features = _virtio_blk_reg_read32(16)
        _virtio_blk_reg_write32(36, 0)
        _virtio_blk_reg_write32(32, 0)
        if version != 1:
            _virtio_blk_reg_write32(20, 1)
            val _features_hi = _virtio_blk_reg_read32(16)
            _virtio_blk_reg_write32(36, 1)
            _virtio_blk_reg_write32(32, 1)

        _virtio_blk_reg_write32(112, 11)
        val status = _virtio_blk_reg_read32(112)
        serial_println("[virtio-blk-init] status={status}")
        if (status & 8) == 0:
            _virtio_blk_reg_write32(112, 128)
            return false

        _virtio_blk_reg_write32(48, 0)
        val max_queue = _virtio_blk_reg_read32(52)
        serial_println("[virtio-blk-init] max_queue={max_queue}")
        if max_queue == 0:
            return false
        val queue_size: u32 = 128
        _virtio_blk_reg_write32(56, queue_size)

        val queue_base: u64 = rt_arm_virtio_blk_queue_base()
        _virtq_setup(queue_base)

        rt_arm_virtio_blk_configure_queue(version)

        _virtio_blk_reg_write32(112, 15)

        # Read capacity
        val cap_off: u64 = 256
        self.capacity_sectors = _virtio_blk_reg_read64(cap_off)

        # Read sector size (if feature supported, else default 512)
        val blk_off: u64 = 276
        val blk_size = _virtio_blk_reg_read32(blk_off)
        if blk_size > 0:
            self.sector_size = blk_size

        self.initialized = true
        # Early ARM boot runs before syscall-backed notifications are
        # available; completion falls back to bounded polling.
        self.notif_id = 0
        true

    me init() -> Result<bool, text>:
        """Initialize VirtIO block device."""
        if self.init_ok():
            return Result.Ok(true)
        Result.Err("virtio init failed")

    me wait_completion(timeout_polls: u32) -> bool:
        """Wait for a virtqueue completion using interrupt-driven notification.

        Quick-polls the used ring first; if not ready, blocks on the IRQ
        notification via syscall 26 (NotificationWait) — the kernel signals
        this notification when the device fires its interrupt. After wakeup,
        polls once more and falls back to a limited spin for coalesced IRQs.

        Falls back to spin-only if notif_id was not allocated (notif_id == 0).
        """
        _virtq_wait_completion(timeout_polls)

    me read_sector_bytes(lba: u64) -> [u8]:
        """Read one sector and return its bytes for early ARM filesystem boot."""
        val status = rt_arm_virtio_blk_read_sector_direct(lba)
        if status == 0xFFFFFFFF:
            serial_println("[virtio-blk] direct read timeout lba={lba}")
            return []
        if status != 0:
            serial_println("[virtio-blk] direct read status={status} lba={lba}")
            return []
        rt_arm_virtio_blk_sector_bytes()

    me read_sectors(lba: u64, count: u32, buffer: [u8]) -> Result<bool, text>:
        """Read sectors from device into buffer."""
        if self.capacity_sectors != 0 and lba >= self.capacity_sectors:
            serial_println("[virtio-blk] read capacity reject lba={lba} count={count} cap={self.capacity_sectors}")
            return Result.Err("read beyond disk capacity")
        if count != 1:
            serial_println("[virtio-blk] read unsupported count={count}")
            return Result.Err("early virtio-blk supports single-sector reads")
        val data_len: u32 = 512
        if data_len.to_i32() > buffer.len():
            serial_println("[virtio-blk] read buffer too small need={data_len} got={buffer.len()}")
            return Result.Err("buffer too small for {count} sectors")

        # Use driver-owned DMA memory instead of fixed scratch addresses.
        val dma_total: u64 = 529
        val dma_result = _virtio_blk_alloc_dma(dma_total)
        if dma_result.is_err():
            serial_println("[virtio-blk] read DMA allocation failed bytes={dma_total}")
            return Result.Err("virtio-blk read DMA allocation failed")
        val dma = dma_result.unwrap()
        val header_addr = dma.virt_addr
        val data_addr = header_addr + 16
        val status_addr = data_addr + data_len.to_u64()
        mmio_write32(status_addr, 0x01010101)

        # Build 3-descriptor chain: header → data (device-writable) → status
        val desc0: i32 = 0

        # Descriptor 0: request header (driver-readable)
        mmio_write32(header_addr, VIRTIO_BLK_T_IN)          # type = read
        mmio_write32(header_addr + 4, 0)                      # reserved
        val lba_low = lba & 0xFFFFFFFF
        val lba_low_u32 = lba_low.to_u32()
        mmio_write32(header_addr + 8, lba_low_u32)  # sector low
        val lba_high = lba >> 32
        val lba_high_u32 = lba_high.to_u32()
        mmio_write32(header_addr + 12, lba_high_u32)        # sector high

        # Set descriptor 0
        val ha_low = header_addr & 0xFFFFFFFF
        val ha_high = header_addr >> 32
        rt_virtq_desc_write(g_virtio_blk_desc_addr, 0, ha_low, ha_high, 16, 1, 1)

        # Descriptor 1: data buffer (device-writable)
        val da_low = data_addr & 0xFFFFFFFF
        val da_high = data_addr >> 32
        rt_virtq_desc_write(g_virtio_blk_desc_addr, 1, da_low, da_high, 512, 3, 2)

        # Descriptor 2: status byte (device-writable)
        val sa_low = status_addr & 0xFFFFFFFF
        val sa_high = status_addr >> 32
        rt_virtq_desc_write(g_virtio_blk_desc_addr, 2, sa_low, sa_high, 1, 2, 0)

        # Submit to available ring
        _virtq_push_avail(desc0.to_u32())
        _virtio_blk_reg_write32(80, 0)

        # Wait for completion: quick poll → NotificationWait (IRQ) → limited spin
        if not _virtio_blk_wait_status(status_addr, BLK_COMPLETION_TIMEOUT_POLLS):
            serial_println("[virtio-blk] read timeout lba={lba} count={count}")
            val _ = _virtio_blk_free_dma(dma.virt_addr, dma_total)
            return Result.Err("virtio-blk read timeout")

        # Check status
        val status = mmio_read8(status_addr)
        if status != VIRTIO_BLK_S_OK:
            serial_println("[virtio-blk] read status={status} lba={lba} count={count}")
            val _ = _virtio_blk_free_dma(dma.virt_addr, dma_total)
            return Result.Err("virtio-blk read error (status={status})")

        val direct_out = rt_dma_bytes_to_array(data_addr, 512)
        g_virtio_blk_last_read_bytes = direct_out

        var copy_i: i32 = 0
        while copy_i < 512 and copy_i < buffer.len():
            val copy_byte_u32 = mmio_read8(data_addr + copy_i.to_u64()) as u32
            buffer[copy_i] = copy_byte_u32.to_u8()
            copy_i = copy_i + 1

        # Free descriptors
        val _ = _virtio_blk_free_dma(dma.virt_addr, dma_total)

        Result.Ok(true)

    me read_sectors_dma(lba: u64, count: u32, dma: VirtioBlkDmaRegion) -> Result<bool, text>:
        """Read sectors directly into caller-owned DMA memory."""
        if not self.initialized:
            return Result.Err("device not initialized")
        val count_u64 = count.to_u64()
        if lba + count_u64 > self.capacity_sectors:
            return Result.Err("read beyond disk capacity")
        val data_len = count * self.sector_size
        val required_total = 16 + data_len.to_u64() + 1
        if dma.total_len < required_total:
            return Result.Err("DMA region too small for {count} sectors")

        var desc0 = _virtq_alloc_desc()
        var desc1 = _virtq_alloc_desc()
        var desc2 = _virtq_alloc_desc()
        if desc0 < 0 or desc1 < 0 or desc2 < 0:
            return Result.Err("no free descriptors")

        mmio_write32(dma.virt_addr, VIRTIO_BLK_T_IN)
        mmio_write32(dma.virt_addr + 4, 0)
        val lba_low = lba & 0xFFFFFFFF
        val lba_low_u32 = lba_low.to_u32()
        mmio_write32(dma.virt_addr + 8, lba_low_u32)
        val lba_high = lba >> 32
        val lba_high_u32 = lba_high.to_u32()
        mmio_write32(dma.virt_addr + 12, lba_high_u32)

        val d0_off = desc0 * 16
        val d0_off_u64 = d0_off.to_u64()
        val d0_addr = g_virtio_blk_desc_addr + d0_off_u64
        val header_low = dma.phys_addr & 0xFFFFFFFF
        val header_low_u32 = header_low.to_u32()
        mmio_write32(d0_addr, header_low_u32)
        val header_high = dma.phys_addr >> 32
        val header_high_u32 = header_high.to_u32()
        mmio_write32(d0_addr + 4, header_high_u32)
        mmio_write32(d0_addr + 8, 16)
        val d1_u32 = desc1.to_u32()
        val d0_flags = VIRTQ_DESC_F_NEXT.to_u32()
        mmio_write32(d0_addr + 12, (d0_flags << 16) | d1_u32)

        val data_phys = dma.phys_addr + 16
        val d1_off = desc1 * 16
        val d1_off_u64 = d1_off.to_u64()
        val d1_addr = g_virtio_blk_desc_addr + d1_off_u64
        val data_low = data_phys & 0xFFFFFFFF
        val data_low_u32 = data_low.to_u32()
        mmio_write32(d1_addr, data_low_u32)
        val data_high = data_phys >> 32
        val data_high_u32 = data_high.to_u32()
        mmio_write32(d1_addr + 4, data_high_u32)
        mmio_write32(d1_addr + 8, data_len)
        val d1_flags = VIRTQ_DESC_F_NEXT.to_u32() | VIRTQ_DESC_F_WRITE.to_u32()
        val d2_u32 = desc2.to_u32()
        mmio_write32(d1_addr + 12, (d1_flags << 16) | d2_u32)

        val status_phys = dma.phys_addr + 16 + data_len.to_u64()
        val d2_off = desc2 * 16
        val d2_off_u64 = d2_off.to_u64()
        val d2_addr = g_virtio_blk_desc_addr + d2_off_u64
        val status_low = status_phys & 0xFFFFFFFF
        val status_low_u32 = status_low.to_u32()
        mmio_write32(d2_addr, status_low_u32)
        val status_high = status_phys >> 32
        val status_high_u32 = status_high.to_u32()
        mmio_write32(d2_addr + 4, status_high_u32)
        mmio_write32(d2_addr + 8, 1)
        val d2_flags = VIRTQ_DESC_F_WRITE.to_u32()
        mmio_write32(d2_addr + 12, d2_flags << 16)

        val d0_u16 = desc0.to_u16()
        _virtq_push_avail(d0_u16.to_u32())
        _virtio_blk_reg_write32(80, 0)

        if not self.wait_completion(BLK_COMPLETION_TIMEOUT_POLLS):
            val fd0 = desc0.to_u16()
            val fd1 = desc1.to_u16()
            val fd2 = desc2.to_u16()
            _virtq_free_desc(fd0.to_u32())
            _virtq_free_desc(fd1.to_u32())
            _virtq_free_desc(fd2.to_u32())
            return Result.Err("virtio-blk read timeout")

        val status_virt = dma.virt_addr + 16 + data_len.to_u64()
        val status = mmio_read8(status_virt)
        if status != VIRTIO_BLK_S_OK:
            val fd0 = desc0.to_u16()
            val fd1 = desc1.to_u16()
            val fd2 = desc2.to_u16()
            _virtq_free_desc(fd0.to_u32())
            _virtq_free_desc(fd1.to_u32())
            _virtq_free_desc(fd2.to_u32())
            return Result.Err("virtio-blk read error (status={status})")

        val fd0 = desc0.to_u16()
        val fd1 = desc1.to_u16()
        val fd2 = desc2.to_u16()
        _virtq_free_desc(fd0.to_u32())
        _virtq_free_desc(fd1.to_u32())
        _virtq_free_desc(fd2.to_u32())
        Result.Ok(true)

    me write_sector_dma(lba: u64, dma: VirtioBlkDmaRegion) -> Result<bool, text>:
        """Write a sector directly from caller-owned DMA memory."""
        if not self.initialized:
            return Result.Err("device not initialized")
        if lba >= self.capacity_sectors:
            return Result.Err("write beyond disk capacity")
        val data_len = self.sector_size.to_u64()
        val required_total = 16 + data_len + 1
        if dma.total_len < required_total:
            return Result.Err("DMA region too small for one sector")

        var desc0 = _virtq_alloc_desc()
        var desc1 = _virtq_alloc_desc()
        var desc2 = _virtq_alloc_desc()
        if desc0 < 0 or desc1 < 0 or desc2 < 0:
            return Result.Err("no free descriptors")

        mmio_write32(dma.virt_addr, VIRTIO_BLK_T_OUT)
        mmio_write32(dma.virt_addr + 4, 0)
        val w_lba_low = lba & 0xFFFFFFFF
        val w_lba_low_u32 = w_lba_low.to_u32()
        mmio_write32(dma.virt_addr + 8, w_lba_low_u32)
        val w_lba_high = lba >> 32
        val w_lba_high_u32 = w_lba_high.to_u32()
        mmio_write32(dma.virt_addr + 12, w_lba_high_u32)

        val d0_off = desc0 * 16
        val d0_off_u64 = d0_off.to_u64()
        val d0_addr = g_virtio_blk_desc_addr + d0_off_u64
        val header_low = dma.phys_addr & 0xFFFFFFFF
        val header_low_u32 = header_low.to_u32()
        mmio_write32(d0_addr, header_low_u32)
        val header_high = dma.phys_addr >> 32
        val header_high_u32 = header_high.to_u32()
        mmio_write32(d0_addr + 4, header_high_u32)
        mmio_write32(d0_addr + 8, 16)
        val d1_u32 = desc1.to_u32()
        val d0_flags = VIRTQ_DESC_F_NEXT.to_u32()
        mmio_write32(d0_addr + 12, (d0_flags << 16) | d1_u32)

        val data_phys = dma.phys_addr + 16
        val d1_off = desc1 * 16
        val d1_off_u64 = d1_off.to_u64()
        val d1_addr = g_virtio_blk_desc_addr + d1_off_u64
        val data_low = data_phys & 0xFFFFFFFF
        val data_low_u32 = data_low.to_u32()
        mmio_write32(d1_addr, data_low_u32)
        val data_high = data_phys >> 32
        val data_high_u32 = data_high.to_u32()
        mmio_write32(d1_addr + 4, data_high_u32)
        mmio_write32(d1_addr + 8, data_len.to_u32())
        val d1_flags = VIRTQ_DESC_F_NEXT.to_u32()
        val d2_u32 = desc2.to_u32()
        mmio_write32(d1_addr + 12, (d1_flags << 16) | d2_u32)

        val status_phys = dma.phys_addr + 16 + data_len
        val d2_off = desc2 * 16
        val d2_off_u64 = d2_off.to_u64()
        val d2_addr = g_virtio_blk_desc_addr + d2_off_u64
        val status_low = status_phys & 0xFFFFFFFF
        val status_low_u32 = status_low.to_u32()
        mmio_write32(d2_addr, status_low_u32)
        val status_high = status_phys >> 32
        val status_high_u32 = status_high.to_u32()
        mmio_write32(d2_addr + 4, status_high_u32)
        mmio_write32(d2_addr + 8, 1)
        val d2_flags = VIRTQ_DESC_F_WRITE.to_u32()
        mmio_write32(d2_addr + 12, d2_flags << 16)

        val d0_u16 = desc0.to_u16()
        _virtq_push_avail(d0_u16.to_u32())
        _virtio_blk_reg_write32(80, 0)

        if not self.wait_completion(BLK_COMPLETION_TIMEOUT_POLLS):
            val fd0 = desc0.to_u16()
            val fd1 = desc1.to_u16()
            val fd2 = desc2.to_u16()
            _virtq_free_desc(fd0.to_u32())
            _virtq_free_desc(fd1.to_u32())
            _virtq_free_desc(fd2.to_u32())
            return Result.Err("virtio-blk write timeout")

        val status_virt = dma.virt_addr + 16 + data_len
        val status = mmio_read8(status_virt)
        if status != VIRTIO_BLK_S_OK:
            val fd0 = desc0.to_u16()
            val fd1 = desc1.to_u16()
            val fd2 = desc2.to_u16()
            _virtq_free_desc(fd0.to_u32())
            _virtq_free_desc(fd1.to_u32())
            _virtq_free_desc(fd2.to_u32())
            return Result.Err("virtio-blk write error (status={status})")

        val fd0 = desc0.to_u16()
        val fd1 = desc1.to_u16()
        val fd2 = desc2.to_u16()
        _virtq_free_desc(fd0.to_u32())
        _virtq_free_desc(fd1.to_u32())
        _virtq_free_desc(fd2.to_u32())
        Result.Ok(true)

    fn capacity_bytes() -> u64:
        val ss = self.sector_size.to_u64()
        self.capacity_sectors * ss

# Implement BlockDevice trait for FAT32 integration
impl BlockDevice for VirtioBlkDriver:
    me read_sector(lba: u64, buffer: [u8]) -> Result<bool, text>:
        val one: u32 = 1
        self.read_sectors(lba, one, buffer)

    me write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        """Write a single sector to device."""
        if not self.initialized:
            return Result.Err("device not initialized")
        if lba >= self.capacity_sectors:
            return Result.Err("write beyond disk capacity")
        val data_len = self.sector_size.to_u64()
        val dma_total = 16 + data_len + 1
        val dma_result = _virtio_blk_alloc_dma(dma_total)
        if dma_result.is_err():
            return Result.Err("virtio-blk write DMA allocation failed")
        val dma = dma_result.unwrap()
        val header_addr = dma.virt_addr
        val data_addr = header_addr + 16
        val status_addr = data_addr + data_len

        # Build 3-descriptor chain: header → data (driver-readable) → status
        val desc0 = _virtq_alloc_desc()
        val desc1 = _virtq_alloc_desc()
        val desc2 = _virtq_alloc_desc()
        if desc0 < 0 or desc1 < 0 or desc2 < 0:
            val _ = _virtio_blk_free_dma(dma.virt_addr, dma_total)
            return Result.Err("no free descriptors")

        # Header: VIRTIO_BLK_T_OUT (write)
        mmio_write32(header_addr, VIRTIO_BLK_T_OUT)
        mmio_write32(header_addr + 4, 0)
        val w_lba_low = lba & 0xFFFFFFFF
        val w_lba_low_u32 = w_lba_low.to_u32()
        mmio_write32(header_addr + 8, w_lba_low_u32)
        val w_lba_high = lba >> 32
        val w_lba_high_u32 = w_lba_high.to_u32()
        mmio_write32(header_addr + 12, w_lba_high_u32)

        val w_d0_off = desc0 * 16
        val w_d0_off_u64 = w_d0_off.to_u64()
        val d0_addr = g_virtio_blk_desc_addr + w_d0_off_u64
        val w_ha_low = header_addr & 0xFFFFFFFF
        val w_ha_low_u32 = w_ha_low.to_u32()
        mmio_write32(d0_addr, w_ha_low_u32)
        val w_ha_high = header_addr >> 32
        val w_ha_high_u32 = w_ha_high.to_u32()
        mmio_write32(d0_addr + 4, w_ha_high_u32)
        mmio_write32(d0_addr + 8, 16)
        val w_fn_u32 = VIRTQ_DESC_F_NEXT.to_u32()
        val w_d1_u32 = desc1.to_u32()
        mmio_write32(d0_addr + 12, (w_fn_u32 << 16) | w_d1_u32)

        # Data buffer: bulk-copy caller slice into DMA memory (zero-copy write staging).
        # Fat-pointer layout [data_ptr: u64, len: u64] — dereference header to get data base.
        val data_hdr = unsafe_addr_of(data)
        val data_src_ptr = mmio_read64(data_hdr)
        rt_memcpy(data_addr.to_i64(), data_src_ptr.to_i64(), data_len.to_i64())

        val w_d1_off = desc1 * 16
        val w_d1_off_u64 = w_d1_off.to_u64()
        val d1_addr = g_virtio_blk_desc_addr + w_d1_off_u64
        val w_da_low = data_addr & 0xFFFFFFFF
        val w_da_low_u32 = w_da_low.to_u32()
        mmio_write32(d1_addr, w_da_low_u32)
        val w_da_high = data_addr >> 32
        val w_da_high_u32 = w_da_high.to_u32()
        mmio_write32(d1_addr + 4, w_da_high_u32)
        mmio_write32(d1_addr + 8, self.sector_size)
        val w_fn2_u32 = VIRTQ_DESC_F_NEXT.to_u32()
        val w_d2_u32 = desc2.to_u32()
        mmio_write32(d1_addr + 12, (w_fn2_u32 << 16) | w_d2_u32)

        # Status byte: device-writable
        val w_d2_off = desc2 * 16
        val w_d2_off_u64 = w_d2_off.to_u64()
        val d2_addr = g_virtio_blk_desc_addr + w_d2_off_u64
        val w_sa_low = status_addr & 0xFFFFFFFF
        val w_sa_low_u32 = w_sa_low.to_u32()
        mmio_write32(d2_addr, w_sa_low_u32)
        val w_sa_high = status_addr >> 32
        val w_sa_high_u32 = w_sa_high.to_u32()
        mmio_write32(d2_addr + 4, w_sa_high_u32)
        mmio_write32(d2_addr + 8, 1)
        val w_fw_u32 = VIRTQ_DESC_F_WRITE.to_u32()
        mmio_write32(d2_addr + 12, w_fw_u32 << 16)

        val w_avail_u16 = desc0.to_u16()
        _virtq_push_avail(w_avail_u16.to_u32())
        _virtio_blk_reg_write32(80, 0)

        if not self.wait_completion(BLK_COMPLETION_TIMEOUT_POLLS):
            val wfd0 = desc0.to_u16()
            val wfd1 = desc1.to_u16()
            val wfd2 = desc2.to_u16()
            _virtq_free_desc(wfd0.to_u32())
            _virtq_free_desc(wfd1.to_u32())
            _virtq_free_desc(wfd2.to_u32())
            val _ = _virtio_blk_free_dma(dma.virt_addr, dma_total)
            return Result.Err("virtio-blk write timeout")

        val status = mmio_read8(status_addr)
        if status != VIRTIO_BLK_S_OK:
            val wfd0 = desc0.to_u16()
            val wfd1 = desc1.to_u16()
            val wfd2 = desc2.to_u16()
            _virtq_free_desc(wfd0.to_u32())
            _virtq_free_desc(wfd1.to_u32())
            _virtq_free_desc(wfd2.to_u32())
            val _ = _virtio_blk_free_dma(dma.virt_addr, dma_total)
            return Result.Err("virtio-blk write error (status={status})")

        val wfd0 = desc0.to_u16()
        val wfd1 = desc1.to_u16()
        val wfd2 = desc2.to_u16()
        _virtq_free_desc(wfd0.to_u32())
        _virtq_free_desc(wfd1.to_u32())
        _virtq_free_desc(wfd2.to_u32())
        val _ = _virtio_blk_free_dma(dma.virt_addr, dma_total)
        Result.Ok(true)

    fn sector_size() -> u32:
        self.sector_size
