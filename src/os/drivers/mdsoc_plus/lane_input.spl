# Input lane MDSOC+ platform contract helpers.

fn input_lane_ps2_bus() -> text:
    "ps2"

fn input_lane_usb_hid_bus() -> text:
    "usb-hid"

fn input_lane_ps2_hotplug_supported() -> bool:
    false

fn input_lane_usb_hid_hotplug_supported() -> bool:
    true

fn input_lane_hidraw_requires_usb(bus: text) -> bool:
    bus == "usb-hid"

fn input_lane_probe_label(bus: text, keyboard: bool, mouse: bool, events: bool) -> text:
    if keyboard and mouse and events:
        return "input-lane:ready:" + bus
    if not keyboard:
        return "input-lane:missing-keyboard:" + bus
    if not mouse:
        return "input-lane:missing-mouse:" + bus
    "input-lane:missing-events:" + bus

fn input_lane_usb_partial_without_hotplug(bus: text, hotplug: bool, hidraw: bool) -> bool:
    bus == "usb-hid" and (not hotplug or not hidraw)

fn input_lane_events_required() -> bool:
    true
