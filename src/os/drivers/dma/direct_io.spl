// Direct I/O file driver extension and block backend DMA wiring
// AC-4: direct I/O capability and request/result types
// AC-5: shared block DMA submit/completion for NVMe and VirtIO-BLK backends

class DirectIoCapability:
    supported: bool
    min_alignment: i32
    max_transfer: i64

    static fn available(alignment: i32, max_transfer: i64) -> DirectIoCapability:
        DirectIoCapability(
            supported: true,
            min_alignment: alignment,
            max_transfer: max_transfer
        )

    static fn not_available() -> DirectIoCapability:
        DirectIoCapability(
            supported: false,
            min_alignment: 0,
            max_transfer: 0
        )

    me requires_dma_buffer() -> bool:
        self.supported == true

    me validate_alignment(offset: i64) -> text:
        if self.min_alignment == 0:
            return ""
        var align = self.min_alignment.to_i64()
        var rem = offset % align
        if rem == 0:
            return ""
        "alignment error: offset " + offset.to_text() + " not aligned to " + self.min_alignment.to_text()

    me summary() -> text:
        if self.supported == false:
            return "DirectIoCapability{supported=false}"
        "DirectIoCapability{supported=true,min_alignment=" + self.min_alignment.to_text() +
            ",max_transfer=" + self.max_transfer.to_text() + "}"


class DirectIoRequest:
    file_offset: i64
    dma_vaddr: i64
    byte_length: i64
    operation: text
    owner_task: i32

    static fn read_req(file_offset: i64, dma_vaddr: i64, byte_length: i64, owner_task: i32) -> DirectIoRequest:
        DirectIoRequest(
            file_offset: file_offset,
            dma_vaddr: dma_vaddr,
            byte_length: byte_length,
            operation: "read",
            owner_task: owner_task
        )

    static fn write_req(file_offset: i64, dma_vaddr: i64, byte_length: i64, owner_task: i32) -> DirectIoRequest:
        DirectIoRequest(
            file_offset: file_offset,
            dma_vaddr: dma_vaddr,
            byte_length: byte_length,
            operation: "write",
            owner_task: owner_task
        )

    me is_read() -> bool:
        self.operation == "read"

    me is_write() -> bool:
        self.operation == "write"

    me summary() -> text:
        "DirectIoRequest{op=" + self.operation +
            ",file_offset=" + self.file_offset.to_text() +
            ",dma_vaddr=" + self.dma_vaddr.to_text() +
            ",byte_length=" + self.byte_length.to_text() +
            ",owner_task=" + self.owner_task.to_text() + "}"


class DirectIoResult:
    success: bool
    bytes_transferred: i64
    error_msg: text
    latency_us: i64

    static fn ok(bytes_transferred: i64, latency_us: i64) -> DirectIoResult:
        DirectIoResult(
            success: true,
            bytes_transferred: bytes_transferred,
            error_msg: "",
            latency_us: latency_us
        )

    static fn error(msg: text) -> DirectIoResult:
        DirectIoResult(
            success: false,
            bytes_transferred: 0,
            error_msg: msg,
            latency_us: 0
        )

    static fn timeout(bytes_partial: i64) -> DirectIoResult:
        DirectIoResult(
            success: false,
            bytes_transferred: bytes_partial,
            error_msg: "timeout",
            latency_us: 0
        )

    me is_timeout() -> bool:
        self.error_msg == "timeout"

    me summary() -> text:
        if self.success == true:
            return "DirectIoResult{ok,bytes=" + self.bytes_transferred.to_text() +
                ",latency_us=" + self.latency_us.to_text() + "}"
        "DirectIoResult{error=" + self.error_msg +
            ",bytes_partial=" + self.bytes_transferred.to_text() + "}"


class BlockDmaSubmit:
    backend: text
    queue_id: i32
    dma_paddr: i64
    byte_length: i64
    operation: text
    timeout_ms: i32

    static fn nvme_submit(queue_id: i32, dma_paddr: i64, byte_length: i64, operation: text, timeout_ms: i32) -> BlockDmaSubmit:
        BlockDmaSubmit(
            backend: "nvme",
            queue_id: queue_id,
            dma_paddr: dma_paddr,
            byte_length: byte_length,
            operation: operation,
            timeout_ms: timeout_ms
        )

    static fn virtio_submit(queue_id: i32, dma_paddr: i64, byte_length: i64, operation: text, timeout_ms: i32) -> BlockDmaSubmit:
        BlockDmaSubmit(
            backend: "virtio_blk",
            queue_id: queue_id,
            dma_paddr: dma_paddr,
            byte_length: byte_length,
            operation: operation,
            timeout_ms: timeout_ms
        )

    me is_nvme() -> bool:
        self.backend == "nvme"

    me is_virtio() -> bool:
        self.backend == "virtio_blk"

    me summary() -> text:
        "BlockDmaSubmit{backend=" + self.backend +
            ",queue=" + self.queue_id.to_text() +
            ",paddr=" + self.dma_paddr.to_text() +
            ",len=" + self.byte_length.to_text() +
            ",op=" + self.operation +
            ",timeout=" + self.timeout_ms.to_text() + "ms}"


class BlockDmaCompletion:
    success: bool
    bytes_done: i64
    error_code: i32
    timed_out: bool

    static fn completed(bytes_done: i64) -> BlockDmaCompletion:
        BlockDmaCompletion(
            success: true,
            bytes_done: bytes_done,
            error_code: 0,
            timed_out: false
        )

    static fn failed(error_code: i32) -> BlockDmaCompletion:
        BlockDmaCompletion(
            success: false,
            bytes_done: 0,
            error_code: error_code,
            timed_out: false
        )

    static fn timeout() -> BlockDmaCompletion:
        BlockDmaCompletion(
            success: false,
            bytes_done: 0,
            error_code: 0,
            timed_out: true
        )

    me has_error() -> bool:
        self.success == false

    me summary() -> text:
        if self.timed_out == true:
            return "BlockDmaCompletion{timed_out}"
        if self.success == true:
            return "BlockDmaCompletion{ok,bytes=" + self.bytes_done.to_text() + "}"
        "BlockDmaCompletion{error,code=" + self.error_code.to_text() + "}"
