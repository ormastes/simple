# NVMe reversible sector probe contract.
#
# Real production readiness requires evidence from hardware execution: a command
# completion, a sector read, a sector write, and restoration of the original
# sector contents. This module records those results without performing I/O.

struct NvmeSectorProbeResult:
    lba: u64
    byte_len: u64
    completion_status: u32
    read_ok: bool
    write_ok: bool
    restore_ok: bool
    used_shared_transfer_logic: bool

fn nvme_sector_probe_result(
    lba: u64,
    byte_len: u64,
    completion_status: u32,
    read_ok: bool,
    write_ok: bool,
    restore_ok: bool,
    used_shared_transfer_logic: bool
) -> NvmeSectorProbeResult:
    NvmeSectorProbeResult(
        lba: lba,
        byte_len: byte_len,
        completion_status: completion_status,
        read_ok: read_ok,
        write_ok: write_ok,
        restore_ok: restore_ok,
        used_shared_transfer_logic: used_shared_transfer_logic
    )

fn nvme_sector_probe_reason(p: NvmeSectorProbeResult) -> text:
    if p.byte_len == 0u64:
        return "nvme-sector-probe-empty"
    if not p.used_shared_transfer_logic:
        return "nvme-sector-probe-not-shared-transfer"
    if p.completion_status != 0u32:
        return "nvme-sector-probe-completion-error"
    if not p.read_ok:
        return "nvme-sector-probe-read-missing"
    if not p.write_ok:
        return "nvme-sector-probe-write-missing"
    if not p.restore_ok:
        return "nvme-sector-probe-restore-missing"
    "ready"

fn nvme_sector_probe_completion_seen(p: NvmeSectorProbeResult) -> bool:
    p.completion_status == 0u32

fn nvme_sector_probe_ready(p: NvmeSectorProbeResult) -> bool:
    nvme_sector_probe_reason(p) == "ready"
