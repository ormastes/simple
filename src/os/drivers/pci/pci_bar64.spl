# codex-impl
"""Pure 64-bit PCI memory BAR decoding and assignment planning."""

struct PciBar64Info:
    raw_low: u32
    raw_high: u32
    probe_low: u32
    probe_high: u32
    implemented: bool
    prefetchable: bool
    base: u64
    size: u64
    reason: text

struct PciBar64Assignment:
    ok: bool
    base: u64
    size: u64
    programmed_low: u32
    programmed_high: u32
    reason: text

fn pci_bar64_size_from_probe(probe_low: u32, probe_high: u32) -> u64:
    if probe_low == 0u32 or probe_low == 0xFFFFFFFFu32:
        return 0u64
    val mask_low = (probe_low & 0xFFFFFFF0u32).to_u64()
    val mask = (probe_high.to_u64() << 32) | mask_low
    if mask == 0u64 or mask == 0xFFFFFFFFFFFFFFFFu64:
        return 0u64
    (mask ^ 0xFFFFFFFFFFFFFFFFu64) + 1u64

fn pci_bar64_decode(raw_low: u32, raw_high: u32, probe_low: u32, probe_high: u32) -> PciBar64Info:
    val is_io = (raw_low & 1u32) != 0u32
    val memory_type = (raw_low >> 1) & 0x3u32
    val valid_pair = not is_io and memory_type == 0x2u32
    val size = if valid_pair:
        pci_bar64_size_from_probe(probe_low, probe_high)
    else:
        0u64
    val base = (raw_high.to_u64() << 32) | (raw_low & 0xFFFFFFF0u32).to_u64()
    var reason = "ready"
    if not valid_pair:
        reason = "not-64-bit-memory-bar"
    elif size == 0u64:
        reason = "bar-unimplemented"
    elif base == 0u64:
        reason = "bar-unassigned"
    PciBar64Info(
        raw_low: raw_low,
        raw_high: raw_high,
        probe_low: probe_low,
        probe_high: probe_high,
        implemented: valid_pair and size > 0u64,
        prefetchable: valid_pair and (raw_low & 0x8u32) != 0u32,
        base: base,
        size: size,
        reason: reason
    )

fn pci_bar64_align_up(base: u64, alignment: u64) -> u64:
    if alignment == 0u64:
        return 0u64
    val mask = alignment - 1u64
    (base + mask) & (mask ^ 0xFFFFFFFFFFFFFFFFu64)

fn pci_bar64_assignment(info: PciBar64Info, window_base: u64, window_limit: u64) -> PciBar64Assignment:
    if not info.implemented:
        return PciBar64Assignment(ok: false, base: 0u64, size: 0u64, programmed_low: 0u32, programmed_high: 0u32, reason: info.reason)
    if info.size == 0u64 or (info.size & (info.size - 1u64)) != 0u64:
        return PciBar64Assignment(ok: false, base: 0u64, size: info.size, programmed_low: 0u32, programmed_high: 0u32, reason: "bar-size-not-power-of-two")
    val assigned = pci_bar64_align_up(window_base, info.size)
    if assigned < window_base or assigned + info.size < assigned or assigned + info.size > window_limit:
        return PciBar64Assignment(ok: false, base: assigned, size: info.size, programmed_low: 0u32, programmed_high: 0u32, reason: "bar-window-exhausted")
    val flags = info.raw_low & 0xFu32
    val low = ((assigned & 0xFFFFFFF0u64).to_u32()) | flags
    val high = (assigned >> 32).to_u32()
    PciBar64Assignment(ok: true, base: assigned, size: info.size, programmed_low: low, programmed_high: high, reason: "ready")

fn pci_function_is_qemu_ivshmem(vendor_id: u16, device_id: u16, class_code: u8, subclass: u8) -> bool:
    vendor_id == 0x1AF4u16 and device_id == 0x1110u16 and class_code == 0x05u8 and subclass == 0x00u8

export PciBar64Info, PciBar64Assignment
export pci_bar64_size_from_probe, pci_bar64_decode, pci_bar64_align_up, pci_bar64_assignment
export pci_function_is_qemu_ivshmem
