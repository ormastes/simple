# PCI provider contracts for Simple-side driver bring-up.

enum PciProviderKind:
    NoPci
    X86ConfigIo
    Q35ConfigIo
    Ecam

struct PciConfigTarget:
    bus: u8
    device: u8
    func: u8
    offset: u16

struct PciBarInfo:
    raw: u32
    probe_mask: u32
    implemented: bool
    is_io: bool
    is_mem64: bool
    is_prefetchable: bool
    base_low: u64
    size: u64

struct PciConfigSnapshot:
    target: PciConfigTarget
    id_dword: u32
    class_dword: u32
    header_dword: u32
    bar0_raw: u32
    bar0_probe_mask: u32
    bar1_raw: u32
    bar1_probe_mask: u32
    irq_dword: u32

struct PciEnumeratedFunction:
    target: PciConfigTarget
    vendor_id: u16
    device_id: u16
    class_code: u8
    subclass: u8
    prog_if: u8
    header_type: u8
    multifunction: bool
    bar0: PciBarInfo
    bar1: PciBarInfo
    irq_line: u8

fn pci_provider_kind_name(kind: PciProviderKind) -> text:
    match kind:
        PciProviderKind.NoPci: "no-pci"
        PciProviderKind.X86ConfigIo: "x86-config-io"
        PciProviderKind.Q35ConfigIo: "q35-config-io"
        PciProviderKind.Ecam: "pci-ecam"

fn pci_provider_from_board(board_id: text) -> PciProviderKind:
    if board_id == "x86_64-q35":
        return PciProviderKind.Q35ConfigIo
    if board_id == "riscv64-virt" or board_id == "xck26-ml-carrier":
        return PciProviderKind.Ecam
    PciProviderKind.NoPci

fn pci_provider_can_enumerate(kind: PciProviderKind) -> bool:
    kind != PciProviderKind.NoPci

fn pci_config_io_addr(target: PciConfigTarget) -> u32:
    val b = target.bus.to_u32()
    val d = target.device.to_u32()
    val f = target.func.to_u32()
    val o = target.offset.to_u32()
    (1u32 << 31) | (b << 16) | (d << 11) | (f << 8) | (o & 0xFC)

fn pci_ecam_addr(ecam_base: u64, target: PciConfigTarget) -> u64:
    ecam_base +
        (target.bus.to_u64() << 20) +
        (target.device.to_u64() << 15) +
        (target.func.to_u64() << 12) +
        (target.offset.to_u64() & 0xFFFu64)

fn pci_provider_config_addr(kind: PciProviderKind, ecam_base: u64, target: PciConfigTarget) -> u64:
    match kind:
        PciProviderKind.NoPci: 0u64
        PciProviderKind.X86ConfigIo: pci_config_io_addr(target).to_u64()
        PciProviderKind.Q35ConfigIo: pci_config_io_addr(target).to_u64()
        PciProviderKind.Ecam: pci_ecam_addr(ecam_base, target)

fn pci_bar_size_from_probe(probe_mask: u32, is_io: bool) -> u64:
    if probe_mask == 0u32 or probe_mask == 0xFFFFFFFFu32:
        return 0u64
    val masked = if is_io:
        probe_mask & 0xFFFFFFFCu32
    else:
        probe_mask & 0xFFFFFFF0u32
    if masked == 0u32:
        return 0u64
    ((masked ^ 0xFFFFFFFFu32) + 1u32).to_u64()

fn pci_bar_decode(raw: u32, probe_mask: u32) -> PciBarInfo:
    val implemented = raw != 0u32 and raw != 0xFFFFFFFFu32
    val is_io = (raw & 1u32) != 0u32
    val mem_type = (raw >> 1) & 0x3u32
    val is_mem64 = (not is_io) and mem_type == 0x2u32
    val is_prefetchable = (not is_io) and (raw & 0x8u32) != 0u32
    val base_low = if is_io:
        (raw & 0xFFFFFFFCu32).to_u64()
    else:
        (raw & 0xFFFFFFF0u32).to_u64()
    val size = if implemented:
        pci_bar_size_from_probe(probe_mask, is_io)
    else:
        0u64
    PciBarInfo(
        raw: raw,
        probe_mask: probe_mask,
        implemented: implemented,
        is_io: is_io,
        is_mem64: is_mem64,
        is_prefetchable: is_prefetchable,
        base_low: base_low,
        size: size
    )

fn pci_provider_refusal_reason(kind: PciProviderKind, board_id: text) -> text:
    if kind == PciProviderKind.NoPci:
        return "pci-unavailable:" + board_id
    "ready:" + pci_provider_kind_name(kind)

fn pci_id_vendor(id_dword: u32) -> u16:
    (id_dword & 0xFFFFu32).to_u16()

fn pci_id_device(id_dword: u32) -> u16:
    ((id_dword >> 16) & 0xFFFFu32).to_u16()

fn pci_vendor_present(vendor_id: u16) -> bool:
    vendor_id != 0xFFFF and vendor_id != 0x0000

fn pci_class_code(class_dword: u32) -> u8:
    ((class_dword >> 24) & 0xFFu32).to_u8()

fn pci_subclass(class_dword: u32) -> u8:
    ((class_dword >> 16) & 0xFFu32).to_u8()

fn pci_prog_if(class_dword: u32) -> u8:
    ((class_dword >> 8) & 0xFFu32).to_u8()

fn pci_header_type(header_dword: u32) -> u8:
    ((header_dword >> 16) & 0xFFu32).to_u8()

fn pci_header_multifunction(header_type: u8) -> bool:
    (header_type & 0x80) != 0

fn pci_function_from_snapshot(s: PciConfigSnapshot) -> PciEnumeratedFunction?:
    val vendor_id = pci_id_vendor(s.id_dword)
    if not pci_vendor_present(vendor_id):
        return nil
    val header = pci_header_type(s.header_dword)
    PciEnumeratedFunction(
        target: s.target,
        vendor_id: vendor_id,
        device_id: pci_id_device(s.id_dword),
        class_code: pci_class_code(s.class_dword),
        subclass: pci_subclass(s.class_dword),
        prog_if: pci_prog_if(s.class_dword),
        header_type: header,
        multifunction: pci_header_multifunction(header),
        bar0: pci_bar_decode(s.bar0_raw, s.bar0_probe_mask),
        bar1: pci_bar_decode(s.bar1_raw, s.bar1_probe_mask),
        irq_line: (s.irq_dword & 0xFFu32).to_u8()
    )

fn pci_enumerate_snapshots(snapshots: [PciConfigSnapshot]) -> [PciEnumeratedFunction]:
    var result: [PciEnumeratedFunction] = []
    for snapshot in snapshots:
        val parsed = pci_function_from_snapshot(snapshot)
        if parsed.?:
            result.push(parsed)
    result

fn pci_function_is_nvme(f: PciEnumeratedFunction) -> bool:
    f.class_code == 0x01 and f.subclass == 0x08 and f.prog_if == 0x02

fn pci_function_is_virtio_net(f: PciEnumeratedFunction) -> bool:
    f.vendor_id == 0x1AF4 and (f.device_id == 0x1000 or f.device_id == 0x1041) and f.class_code == 0x02

fn pci_function_is_e1000(f: PciEnumeratedFunction) -> bool:
    f.vendor_id == 0x8086 and (f.device_id == 0x100Eu16 or f.device_id == 0x100Fu16 or f.device_id == 0x10D3u16)

fn pci_function_is_infiniband(f: PciEnumeratedFunction) -> bool:
    f.class_code == 0x0C and f.subclass == 0x06

fn pci_count_class(functions: [PciEnumeratedFunction], class_code: u8, subclass: u8) -> i32:
    var count = 0
    for f in functions:
        if f.class_code == class_code and f.subclass == subclass:
            count = count + 1
    count
