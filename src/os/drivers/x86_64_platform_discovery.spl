# ============================================================================
# x86_64 Platform Discovery — UEFI/ACPI/PCI Discovery Logging
# ============================================================================
# MDSOC: feature dimension, drivers layer
#
# Records UEFI boot path, ACPI RSDP/MADT parse results, and PCI resource
# ownership before driver bind. Provides a flat registry (max 8 devices)
# and an aggregate platform readiness report.
# ============================================================================

# ============================================================================
# UefiBootRecord — UEFI/OVMF boot path logging
# ============================================================================

class UefiBootRecord:
    """UEFI/OVMF boot path record for platform discovery logging."""
    firmware: text
    ovmf_detected: bool
    secure_boot: bool
    boot_device: text
    boot_partition: text
    efi_system_table: i64

    static fn create() -> UefiBootRecord:
        """Create unknown/default boot record."""
        UefiBootRecord(
            firmware: "unknown",
            ovmf_detected: false,
            secure_boot: false,
            boot_device: "",
            boot_partition: "",
            efi_system_table: 0
        )

    static fn uefi(ovmf: bool, secure: bool, table_addr: i64) -> UefiBootRecord:
        """Create UEFI boot record with OVMF and secure boot flags."""
        UefiBootRecord(
            firmware: "uefi",
            ovmf_detected: ovmf,
            secure_boot: secure,
            boot_device: "",
            boot_partition: "",
            efi_system_table: table_addr
        )

    static fn bios() -> UefiBootRecord:
        """Create legacy BIOS boot record."""
        UefiBootRecord(
            firmware: "bios",
            ovmf_detected: false,
            secure_boot: false,
            boot_device: "",
            boot_partition: "",
            efi_system_table: 0
        )

    me is_uefi() -> bool:
        """Return true if booted via UEFI."""
        self.firmware == "uefi"

    me summary() -> text:
        """Human-readable boot summary."""
        val ovmf_str = if self.ovmf_detected: "ovmf=yes" else: "ovmf=no"
        val sb_str = if self.secure_boot: "secure=yes" else: "secure=no"
        "boot: firmware=" + self.firmware + " " + ovmf_str + " " + sb_str + " table=" + self.efi_system_table.to_text()

# ============================================================================
# AcpiParseStatus — ACPI RSDP/MADT parse results
# ============================================================================

class AcpiParseStatus:
    """ACPI RSDP/MADT parse result record."""
    rsdp_found: bool
    rsdp_addr: i64
    rsdp_revision: i64
    madt_found: bool
    madt_addr: i64
    lapic_count: i64
    ioapic_count: i64
    hpet_found: bool
    parse_errors: i64
    last_error: text

    static fn create() -> AcpiParseStatus:
        """Create empty ACPI parse status."""
        AcpiParseStatus(
            rsdp_found: false,
            rsdp_addr: 0,
            rsdp_revision: 0,
            madt_found: false,
            madt_addr: 0,
            lapic_count: 0,
            ioapic_count: 0,
            hpet_found: false,
            parse_errors: 0,
            last_error: ""
        )

    me set_rsdp(addr: i64, rev: i64) -> text:
        """Record RSDP location and revision. Returns status text."""
        self.rsdp_found = true
        self.rsdp_addr = addr
        self.rsdp_revision = rev
        "acpi: rsdp found at " + addr.to_text() + " rev=" + rev.to_text()

    me set_madt(addr: i64, lapics: i64, ioapics: i64) -> text:
        """Record MADT location and APIC counts. Returns status text."""
        self.madt_found = true
        self.madt_addr = addr
        self.lapic_count = lapics
        self.ioapic_count = ioapics
        "acpi: madt found at " + addr.to_text() + " lapic=" + lapics.to_text() + " ioapic=" + ioapics.to_text()

    me set_hpet(found: bool) -> text:
        """Record HPET presence. Returns status text."""
        self.hpet_found = found
        if found:
            "acpi: hpet present"
        else:
            "acpi: hpet absent"

    me record_error(msg: text) -> i64:
        """Record parse error message, increment error count. Returns new count."""
        self.parse_errors = self.parse_errors + 1
        self.last_error = msg
        self.parse_errors

    me is_valid() -> bool:
        """Return true if RSDP and MADT found with no parse errors."""
        self.rsdp_found and self.madt_found and self.parse_errors == 0

    me interrupt_mode() -> text:
        """Return 'apic' if I/O APIC present, else 'polling'."""
        if self.ioapic_count > 0:
            "apic"
        else:
            "polling"

    me summary() -> text:
        """Human-readable ACPI summary."""
        val rsdp_str = if self.rsdp_found: "rsdp=yes" else: "rsdp=no"
        val madt_str = if self.madt_found: "madt=yes" else: "madt=no"
        val hpet_str = if self.hpet_found: "hpet=yes" else: "hpet=no"
        "acpi: " + rsdp_str + " " + madt_str + " lapic=" + self.lapic_count.to_text() + " ioapic=" + self.ioapic_count.to_text() + " " + hpet_str + " errors=" + self.parse_errors.to_text()

# ============================================================================
# PciOwnershipRecord — resource ownership before driver bind
# ============================================================================

class PciOwnershipRecord:
    """PCI device resource ownership record before driver bind."""
    bus: i64
    device: i64
    function: i64
    device_class: text
    vendor_id: i64
    device_id: i64
    bar0_addr: i64
    bar0_size: i64
    irq_line: i64
    irq_pin: i64
    dma_capable: bool
    bound_driver: text
    bound: bool

    static fn create(b: i64, d: i64, f: i64, cls: text, vid: i64, did: i64) -> PciOwnershipRecord:
        """Create unbound PCI ownership record."""
        PciOwnershipRecord(
            bus: b,
            device: d,
            function: f,
            device_class: cls,
            vendor_id: vid,
            device_id: did,
            bar0_addr: 0,
            bar0_size: 0,
            irq_line: -1,
            irq_pin: -1,
            dma_capable: false,
            bound_driver: "",
            bound: false
        )

    me set_bar0(addr: i64, size: i64) -> text:
        """Record BAR0 address and size. Returns status text."""
        self.bar0_addr = addr
        self.bar0_size = size
        "pci: bar0 addr=" + addr.to_text() + " size=" + size.to_text()

    me set_irq(line: i64, pin: i64) -> text:
        """Record IRQ line and pin. Returns status text."""
        self.irq_line = line
        self.irq_pin = pin
        "pci: irq line=" + line.to_text() + " pin=" + pin.to_text()

    me bind_driver(name: text) -> text:
        """Bind a driver to this device. Returns status text."""
        self.bound_driver = name
        self.bound = true
        "pci: " + self.bus.to_text() + ":" + self.device.to_text() + "." + self.function.to_text() + " bound to " + name

    me unbind() -> text:
        """Unbind current driver. Returns status text."""
        val prev = self.bound_driver
        self.bound_driver = ""
        self.bound = false
        "pci: " + self.bus.to_text() + ":" + self.device.to_text() + "." + self.function.to_text() + " unbound from " + prev

    me summary() -> text:
        """Human-readable PCI device ownership summary."""
        val bound_str = if self.bound: "bound=" + self.bound_driver else: "unbound"
        "pci " + self.bus.to_text() + ":" + self.device.to_text() + "." + self.function.to_text() + " class=" + self.device_class + " vid=" + self.vendor_id.to_text() + " did=" + self.device_id.to_text() + " " + bound_str

# ============================================================================
# PciDeviceRegistry — flat registry (max 8 devices)
# ============================================================================

class PciDeviceRegistry:
    """Flat PCI device registry supporting up to 8 devices."""
    count: i64
    p0_bus: i64
    p0_dev: i64
    p0_func: i64
    p0_class: text
    p0_vid: i64
    p0_did: i64
    p0_bound: bool
    p0_driver: text
    p1_bus: i64
    p1_dev: i64
    p1_func: i64
    p1_class: text
    p1_vid: i64
    p1_did: i64
    p1_bound: bool
    p1_driver: text
    p2_bus: i64
    p2_dev: i64
    p2_func: i64
    p2_class: text
    p2_vid: i64
    p2_did: i64
    p2_bound: bool
    p2_driver: text
    p3_bus: i64
    p3_dev: i64
    p3_func: i64
    p3_class: text
    p3_vid: i64
    p3_did: i64
    p3_bound: bool
    p3_driver: text
    p4_bus: i64
    p4_dev: i64
    p4_func: i64
    p4_class: text
    p4_vid: i64
    p4_did: i64
    p4_bound: bool
    p4_driver: text
    p5_bus: i64
    p5_dev: i64
    p5_func: i64
    p5_class: text
    p5_vid: i64
    p5_did: i64
    p5_bound: bool
    p5_driver: text
    p6_bus: i64
    p6_dev: i64
    p6_func: i64
    p6_class: text
    p6_vid: i64
    p6_did: i64
    p6_bound: bool
    p6_driver: text
    p7_bus: i64
    p7_dev: i64
    p7_func: i64
    p7_class: text
    p7_vid: i64
    p7_did: i64
    p7_bound: bool
    p7_driver: text

    static fn create() -> PciDeviceRegistry:
        """Create empty PCI device registry."""
        PciDeviceRegistry(
            count: 0,
            p0_bus: 0, p0_dev: 0, p0_func: 0, p0_class: "", p0_vid: 0, p0_did: 0, p0_bound: false, p0_driver: "",
            p1_bus: 0, p1_dev: 0, p1_func: 0, p1_class: "", p1_vid: 0, p1_did: 0, p1_bound: false, p1_driver: "",
            p2_bus: 0, p2_dev: 0, p2_func: 0, p2_class: "", p2_vid: 0, p2_did: 0, p2_bound: false, p2_driver: "",
            p3_bus: 0, p3_dev: 0, p3_func: 0, p3_class: "", p3_vid: 0, p3_did: 0, p3_bound: false, p3_driver: "",
            p4_bus: 0, p4_dev: 0, p4_func: 0, p4_class: "", p4_vid: 0, p4_did: 0, p4_bound: false, p4_driver: "",
            p5_bus: 0, p5_dev: 0, p5_func: 0, p5_class: "", p5_vid: 0, p5_did: 0, p5_bound: false, p5_driver: "",
            p6_bus: 0, p6_dev: 0, p6_func: 0, p6_class: "", p6_vid: 0, p6_did: 0, p6_bound: false, p6_driver: "",
            p7_bus: 0, p7_dev: 0, p7_func: 0, p7_class: "", p7_vid: 0, p7_did: 0, p7_bound: false, p7_driver: ""
        )

    me add(bus: i64, dev: i64, func: i64, cls: text, vid: i64, did: i64) -> text:
        """Add device to registry. Returns status or 'registry full'."""
        if self.count == 0:
            self.p0_bus = bus
            self.p0_dev = dev
            self.p0_func = func
            self.p0_class = cls
            self.p0_vid = vid
            self.p0_did = did
            self.p0_bound = false
            self.p0_driver = ""
            self.count = 1
            "pci: added slot 0 " + bus.to_text() + ":" + dev.to_text() + "." + func.to_text()
        else:
            if self.count == 1:
                self.p1_bus = bus
                self.p1_dev = dev
                self.p1_func = func
                self.p1_class = cls
                self.p1_vid = vid
                self.p1_did = did
                self.p1_bound = false
                self.p1_driver = ""
                self.count = 2
                "pci: added slot 1 " + bus.to_text() + ":" + dev.to_text() + "." + func.to_text()
            else:
                if self.count == 2:
                    self.p2_bus = bus
                    self.p2_dev = dev
                    self.p2_func = func
                    self.p2_class = cls
                    self.p2_vid = vid
                    self.p2_did = did
                    self.p2_bound = false
                    self.p2_driver = ""
                    self.count = 3
                    "pci: added slot 2 " + bus.to_text() + ":" + dev.to_text() + "." + func.to_text()
                else:
                    if self.count == 3:
                        self.p3_bus = bus
                        self.p3_dev = dev
                        self.p3_func = func
                        self.p3_class = cls
                        self.p3_vid = vid
                        self.p3_did = did
                        self.p3_bound = false
                        self.p3_driver = ""
                        self.count = 4
                        "pci: added slot 3 " + bus.to_text() + ":" + dev.to_text() + "." + func.to_text()
                    else:
                        if self.count == 4:
                            self.p4_bus = bus
                            self.p4_dev = dev
                            self.p4_func = func
                            self.p4_class = cls
                            self.p4_vid = vid
                            self.p4_did = did
                            self.p4_bound = false
                            self.p4_driver = ""
                            self.count = 5
                            "pci: added slot 4 " + bus.to_text() + ":" + dev.to_text() + "." + func.to_text()
                        else:
                            if self.count == 5:
                                self.p5_bus = bus
                                self.p5_dev = dev
                                self.p5_func = func
                                self.p5_class = cls
                                self.p5_vid = vid
                                self.p5_did = did
                                self.p5_bound = false
                                self.p5_driver = ""
                                self.count = 6
                                "pci: added slot 5 " + bus.to_text() + ":" + dev.to_text() + "." + func.to_text()
                            else:
                                if self.count == 6:
                                    self.p6_bus = bus
                                    self.p6_dev = dev
                                    self.p6_func = func
                                    self.p6_class = cls
                                    self.p6_vid = vid
                                    self.p6_did = did
                                    self.p6_bound = false
                                    self.p6_driver = ""
                                    self.count = 7
                                    "pci: added slot 6 " + bus.to_text() + ":" + dev.to_text() + "." + func.to_text()
                                else:
                                    if self.count == 7:
                                        self.p7_bus = bus
                                        self.p7_dev = dev
                                        self.p7_func = func
                                        self.p7_class = cls
                                        self.p7_vid = vid
                                        self.p7_did = did
                                        self.p7_bound = false
                                        self.p7_driver = ""
                                        self.count = 8
                                        "pci: added slot 7 " + bus.to_text() + ":" + dev.to_text() + "." + func.to_text()
                                    else:
                                        "pci: registry full (max 8)"

    me bind(idx: i64, driver: text) -> text:
        """Bind driver to device at index. Returns status text."""
        if idx == 0:
            self.p0_bound = true
            self.p0_driver = driver
            "pci: slot 0 bound to " + driver
        else:
            if idx == 1:
                self.p1_bound = true
                self.p1_driver = driver
                "pci: slot 1 bound to " + driver
            else:
                if idx == 2:
                    self.p2_bound = true
                    self.p2_driver = driver
                    "pci: slot 2 bound to " + driver
                else:
                    if idx == 3:
                        self.p3_bound = true
                        self.p3_driver = driver
                        "pci: slot 3 bound to " + driver
                    else:
                        if idx == 4:
                            self.p4_bound = true
                            self.p4_driver = driver
                            "pci: slot 4 bound to " + driver
                        else:
                            if idx == 5:
                                self.p5_bound = true
                                self.p5_driver = driver
                                "pci: slot 5 bound to " + driver
                            else:
                                if idx == 6:
                                    self.p6_bound = true
                                    self.p6_driver = driver
                                    "pci: slot 6 bound to " + driver
                                else:
                                    if idx == 7:
                                        self.p7_bound = true
                                        self.p7_driver = driver
                                        "pci: slot 7 bound to " + driver
                                    else:
                                        "pci: bind index out of range"

    me bound_count() -> i64:
        """Return number of bound devices."""
        var n = 0
        if self.count > 0 and self.p0_bound:
            n = n + 1
        if self.count > 1 and self.p1_bound:
            n = n + 1
        if self.count > 2 and self.p2_bound:
            n = n + 1
        if self.count > 3 and self.p3_bound:
            n = n + 1
        if self.count > 4 and self.p4_bound:
            n = n + 1
        if self.count > 5 and self.p5_bound:
            n = n + 1
        if self.count > 6 and self.p6_bound:
            n = n + 1
        if self.count > 7 and self.p7_bound:
            n = n + 1
        n

    me unbound_count() -> i64:
        """Return number of unbound devices."""
        self.count - self.bound_count()

    me device_count() -> i64:
        """Return total number of registered devices."""
        self.count

    me report() -> text:
        """Multi-line registry report."""
        "pci registry: total=" + self.count.to_text() + " bound=" + self.bound_count().to_text() + " unbound=" + self.unbound_count().to_text()

# ============================================================================
# PlatformDiscoveryReport — aggregate platform readiness
# ============================================================================

class PlatformDiscoveryReport:
    """Aggregate platform discovery report for x86_64 desktop readiness."""
    boot: UefiBootRecord
    acpi: AcpiParseStatus
    pci_count: i64
    pci_bound: i64
    interrupt_mode: text

    static fn create() -> PlatformDiscoveryReport:
        """Create empty platform discovery report."""
        PlatformDiscoveryReport(
            boot: UefiBootRecord.create(),
            acpi: AcpiParseStatus.create(),
            pci_count: 0,
            pci_bound: 0,
            interrupt_mode: "polling"
        )

    me finalize() -> text:
        """Set interrupt_mode from ACPI status. Returns mode text."""
        self.interrupt_mode = self.acpi.interrupt_mode()
        "platform: interrupt_mode=" + self.interrupt_mode

    me is_desktop_ready() -> bool:
        """Return true if UEFI booted, ACPI valid, and at least one PCI device found."""
        self.boot.is_uefi() and self.acpi.is_valid() and self.pci_count > 0

    me summary() -> text:
        """Human-readable platform readiness summary."""
        val ready_str = if self.is_desktop_ready(): "ready" else: "not-ready"
        self.boot.summary() + "\n" + self.acpi.summary() + "\n" + "platform: pci=" + self.pci_count.to_text() + " bound=" + self.pci_bound.to_text() + " irq=" + self.interrupt_mode + " status=" + ready_str
