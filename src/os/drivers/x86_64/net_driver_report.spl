class VirtioNetInit:
  device_id: i32
  mac_addr: text
  queue_count: i32
  link_up: bool
  init_ok: bool

  me is_ready():
    return self.init_ok and self.link_up

class NetDriverCapability:
  has_checksum_offload: bool
  has_tso: bool
  has_multiqueue: bool
  tier: text

  static fn from_features(csum: bool, tso: bool, mq: bool) -> NetDriverCapability:
    var tier = "minimal"
    if csum and tso and mq:
      tier = "advanced"
    else if csum:
      tier = "basic"
    return NetDriverCapability(has_checksum_offload: csum, has_tso: tso, has_multiqueue: mq, tier: tier)

class AcceptanceGate:
  driver_name: text
  claims_resident: bool
  actually_loaded: bool
  claims_dma: bool
  has_dma_desc: bool
  claims_accel: bool
  has_accel_proof: bool

  me passes():
    if self.claims_resident and self.actually_loaded == false:
      return false
    if self.claims_dma and self.has_dma_desc == false:
      return false
    if self.claims_accel and self.has_accel_proof == false:
      return false
    return true

  me rejection_reason():
    if self.claims_resident and self.actually_loaded == false:
      return "claims_resident not backed: driver not actually loaded"
    if self.claims_dma and self.has_dma_desc == false:
      return "claims_dma not backed: no DMA descriptor found"
    if self.claims_accel and self.has_accel_proof == false:
      return "claims_accel not backed: no acceleration proof"
    return "none"

class AcceptanceReport:
  net_init: VirtioNetInit
  capability: NetDriverCapability
  gate: AcceptanceGate
  accepted: bool

  static fn evaluate(net: VirtioNetInit, cap: NetDriverCapability, gate: AcceptanceGate) -> AcceptanceReport:
    var ok = net.is_ready() and gate.passes()
    return AcceptanceReport(net_init: net, capability: cap, gate: gate, accepted: ok)

fn main():
  val init = VirtioNetInit(device_id: 1, mac_addr: "52:54:00:12:34:56", queue_count: 2, link_up: true, init_ok: true)
  val cap = NetDriverCapability.from_features(true, true, false)
  val gate = AcceptanceGate(driver_name: "virtio-net", claims_resident: true, actually_loaded: true, claims_dma: true, has_dma_desc: true, claims_accel: false, has_accel_proof: false)
  val report = AcceptanceReport.evaluate(init, cap, gate)
  print("accepted: " + report.accepted.to_text())
  print("tier: " + report.capability.tier)
  print("rejection_reason: " + report.gate.rejection_reason())
