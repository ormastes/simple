use std.io_runtime

class PciResource:
    device_id: i32
    device_class: text
    bar_base: i64
    bar_size: i32
    irq_line: i32
    has_dma: bool
    is_bound: bool

    static fn create(did: i32, dclass: text, bar: i64, bsize: i32, irq: i32, dma: bool) -> PciResource:
        return PciResource(device_id: did, device_class: dclass, bar_base: bar, bar_size: bsize, irq_line: irq, has_dma: dma, is_bound: false)

    me bind() -> PciResource:
        return PciResource(device_id: self.device_id, device_class: self.device_class, bar_base: self.bar_base, bar_size: self.bar_size, irq_line: self.irq_line, has_dma: self.has_dma, is_bound: true)

    me owns_bar() -> bool:
        return self.bar_size > 0

class PciResourceTable:
    r0_id: i32
    r0_class: text
    r0_bound: bool
    r1_id: i32
    r1_class: text
    r1_bound: bool
    r2_id: i32
    r2_class: text
    r2_bound: bool
    r3_id: i32
    r3_class: text
    r3_bound: bool
    total_devices: i32

    static fn from_four(r0: PciResource, r1: PciResource, r2: PciResource, r3: PciResource) -> PciResourceTable:
        return PciResourceTable(r0_id: r0.device_id, r0_class: r0.device_class, r0_bound: r0.is_bound, r1_id: r1.device_id, r1_class: r1.device_class, r1_bound: r1.is_bound, r2_id: r2.device_id, r2_class: r2.device_class, r2_bound: r2.is_bound, r3_id: r3.device_id, r3_class: r3.device_class, r3_bound: r3.is_bound, total_devices: 4)

    me bound_count() -> i32:
        var count = 0
        if self.r0_bound == true:
            count = count + 1
        if self.r1_bound == true:
            count = count + 1
        if self.r2_bound == true:
            count = count + 1
        if self.r3_bound == true:
            count = count + 1
        return count

    me all_bound() -> bool:
        return self.bound_count() == self.total_devices

class BootDiscovery:
    boot_path: text
    rsdp_found: bool
    madt_parsed: bool
    pci_device_count: i32
    interrupt_mode: text

    static fn uefi_boot(rsdp: bool, madt: bool, pci_count: i32, intr: text) -> BootDiscovery:
        return BootDiscovery(boot_path: "uefi-ovmf", rsdp_found: rsdp, madt_parsed: madt, pci_device_count: pci_count, interrupt_mode: intr)

    me acpi_ok() -> bool:
        return self.rsdp_found and self.madt_parsed

    me has_devices() -> bool:
        return self.pci_device_count > 0

    me discovery_complete() -> bool:
        return self.acpi_ok() and self.has_devices()

class DiscoveryLog:
    step_count: i32
    s0: text
    s1: text
    s2: text
    s3: text

    static fn create(s0: text, s1: text, s2: text, s3: text) -> DiscoveryLog:
        return DiscoveryLog(step_count: 4, s0: s0, s1: s1, s2: s2, s3: s3)

    me has_step(name: text) -> bool:
        if self.s0 == name:
            return true
        if self.s1 == name:
            return true
        if self.s2 == name:
            return true
        if self.s3 == name:
            return true
        return false

    me summary() -> text:
        return "steps=" + self.step_count.to_text() + ": " + self.s0 + ", " + self.s1 + ", " + self.s2 + ", " + self.s3
