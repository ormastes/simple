# XHCI TRB Structures — Transfer Request Block definitions and ring management
#
# MDSOC: feature dimension, drivers layer
# xHCI specification section 6: TRB formats
#
# TRBs are 16-byte structures placed in rings (arrays of TRBs).
# Each TRB has a 64-bit parameter, 32-bit status, and 32-bit control word.
# The cycle bit in the control word is used for producer/consumer synchronization.

use os.kernel.boot.mmio.{mmio_read32, mmio_write32, mmio_read64, mmio_write64}

# ============================================================================
# TRB Type constants (bits [15:10] of control word)
# ============================================================================

val TRB_TYPE_NORMAL: u32            = 1
val TRB_TYPE_SETUP: u32             = 2
val TRB_TYPE_DATA: u32              = 3
val TRB_TYPE_STATUS: u32            = 4
val TRB_TYPE_LINK: u32              = 6
val TRB_TYPE_EVENT_DATA: u32        = 7
val TRB_TYPE_CMD_ENABLE_SLOT: u32   = 9
val TRB_TYPE_CMD_ADDRESS_DEVICE: u32 = 11
val TRB_TYPE_CMD_CONFIGURE_EP: u32  = 12
val TRB_TYPE_TRANSFER_EVENT: u32    = 32
val TRB_TYPE_CMD_COMPLETION: u32    = 33
val TRB_TYPE_PORT_STATUS_CHANGE: u32 = 34

# TRB type field position in control word
val TRB_TYPE_SHIFT: u32 = 10

# ============================================================================
# Completion Code constants (bits [31:24] of TRB status in Event TRBs)
# ============================================================================

val TRB_CC_SUCCESS: u32              = 1
val TRB_CC_DATA_BUFFER_ERROR: u32    = 2
val TRB_CC_BABBLE_DETECTED: u32      = 3
val TRB_CC_USB_TRANSACTION_ERROR: u32 = 4
val TRB_CC_TRB_ERROR: u32            = 5
val TRB_CC_STALL: u32                = 6
val TRB_CC_RESOURCE_ERROR: u32       = 7
val TRB_CC_BANDWIDTH_ERROR: u32      = 8
val TRB_CC_SHORT_PACKET: u32         = 13

# ============================================================================
# TRB Control word bit constants
# ============================================================================

val TRB_CYCLE: u32        = 0x1    # Cycle bit — producer/consumer sync
val TRB_TOGGLE_CYCLE: u32 = 0x2    # Toggle Cycle on Link TRB
val TRB_IOC: u32          = 0x20   # Interrupt On Completion
val TRB_IDT: u32          = 0x40   # Immediate Data (data in TRB itself)
val TRB_DIR_IN: u32       = 0x10   # Transfer Direction = IN (Status/Data stage)
val TRB_ISP: u32          = 0x4    # Interrupt on Short Packet

# ============================================================================
# TRB Ring
# ============================================================================

class TrbRing:
    """Circular ring of 16-byte TRBs in physical memory.

    The last TRB slot is always reserved for a Link TRB that wraps back to
    the start, so usable entries = size - 1.
    """
    base: u64    # Physical base address of the ring
    size: u32    # Total number of TRB slots (including Link TRB)
    enqueue: u32 # Current enqueue index (0 .. size-1)
    cycle: bool  # Current producer cycle state (toggled on wrap)

# ============================================================================
# Low-level TRB read/write helpers
# ============================================================================

fn trb_addr(base: u64, index: u32) -> u64:
    """Physical address of TRB at given index (each TRB is 16 bytes)."""
    base + (index * 16).to_u64()

fn trb_read(base: u64, index: u32) -> (u64, u32, u32):
    """Read a TRB from the ring.

    Returns (param, status, control).
    """
    val addr = trb_addr(base, index)
    val param   = mmio_read64(addr)
    val status  = mmio_read32(addr + 8)
    val control = mmio_read32(addr + 12)
    (param, status, control)

fn trb_write_raw(base: u64, index: u32, param: u64, status: u32, control: u32):
    """Write a 16-byte TRB directly (no cycle fixup)."""
    val addr = trb_addr(base, index)
    mmio_write64(addr, param)
    mmio_write32(addr + 8, status)
    mmio_write32(addr + 12, control)

# ============================================================================
# Ring write with cycle bit management and Link TRB auto-insert
# ============================================================================

fn trb_type_field(ty: u32) -> u32:
    """Encode TRB type into control word position."""
    ty << TRB_TYPE_SHIFT

me trb_write(ring: TrbRing, param: u64, status: u32, control: u32):
    """Enqueue one TRB onto the ring.

    Applies the current cycle bit to the control word, writes the TRB at
    ring.enqueue, then advances the enqueue pointer. When the pointer reaches
    the last slot (Link TRB position), a Link TRB pointing back to slot 0 is
    written with toggle_cycle, the cycle state is inverted, and the enqueue
    pointer wraps to 0.
    """
    val last_slot = ring.size - 1

    # Apply cycle bit
    var ctrl = control & ~TRB_CYCLE
    if ring.cycle:
        ctrl = ctrl | TRB_CYCLE

    trb_write_raw(ring.base, ring.enqueue, param, status, ctrl)
    ring.enqueue = ring.enqueue + 1

    # If we've just written into the second-to-last slot, install the Link TRB
    if ring.enqueue >= last_slot:
        var link_ctrl = trb_type_field(TRB_TYPE_LINK) | TRB_TOGGLE_CYCLE
        if ring.cycle:
            link_ctrl = link_ctrl | TRB_CYCLE
        trb_write_raw(ring.base, last_slot, ring.base, 0, link_ctrl)
        ring.cycle = !ring.cycle
        ring.enqueue = 0

# ============================================================================
# TRB constructors — return (param, status, control) tuples
# ============================================================================

fn trb_normal_cmd(ptr: u64, len: u32, cycle: bool) -> (u64, u32, u32):
    """Normal Transfer TRB — transfers data from/to buffer at ptr."""
    var ctrl = trb_type_field(TRB_TYPE_NORMAL) | TRB_IOC
    if cycle:
        ctrl = ctrl | TRB_CYCLE
    (ptr, len & 0x1FFFF, ctrl)

fn trb_setup(request_type: u8, request: u8, value: u16, index: u16, length: u16, cycle: bool) -> (u64, u32, u32):
    """Setup Stage TRB — encodes USB SETUP packet inline (IDT)."""
    # USB SETUP packet packed into 8 bytes (param field)
    val p0 = request_type.to_u64()
    val p1 = request.to_u64() << 8
    val p2 = value.to_u64()   << 16
    val p3 = index.to_u64()   << 32
    val p4 = length.to_u64()  << 48
    val param = p0 | p1 | p2 | p3 | p4
    # Status: transfer length = 8 (SETUP packet always 8 bytes)
    val stat: u32 = 8
    var ctrl = trb_type_field(TRB_TYPE_SETUP) | TRB_IDT
    if cycle:
        ctrl = ctrl | TRB_CYCLE
    (param, stat, ctrl)

fn trb_data(ptr: u64, len: u32, dir_in: bool, cycle: bool) -> (u64, u32, u32):
    """Data Stage TRB — follows a Setup TRB for control transfers with data."""
    var ctrl = trb_type_field(TRB_TYPE_DATA) | TRB_IOC
    if dir_in:
        ctrl = ctrl | TRB_DIR_IN
    if cycle:
        ctrl = ctrl | TRB_CYCLE
    (ptr, len & 0x1FFFF, ctrl)

fn trb_status(dir_in: bool, cycle: bool) -> (u64, u32, u32):
    """Status Stage TRB — completes a control transfer."""
    var ctrl = trb_type_field(TRB_TYPE_STATUS) | TRB_IOC
    if dir_in:
        ctrl = ctrl | TRB_DIR_IN
    if cycle:
        ctrl = ctrl | TRB_CYCLE
    (0, 0, ctrl)

fn trb_link(ring_base: u64, toggle_cycle: bool, cycle: bool) -> (u64, u32, u32):
    """Link TRB — wraps around to ring_base; optionally toggles cycle bit."""
    var ctrl = trb_type_field(TRB_TYPE_LINK)
    if toggle_cycle:
        ctrl = ctrl | TRB_TOGGLE_CYCLE
    if cycle:
        ctrl = ctrl | TRB_CYCLE
    (ring_base, 0, ctrl)

fn trb_event_data(data: u64, cycle: bool) -> (u64, u32, u32):
    """Event Data TRB — generates a Transfer Event with data field."""
    var ctrl = trb_type_field(TRB_TYPE_EVENT_DATA) | TRB_IOC
    if cycle:
        ctrl = ctrl | TRB_CYCLE
    (data, 0, ctrl)

fn trb_cmd_enable_slot(cycle: bool) -> (u64, u32, u32):
    """Enable Slot Command TRB — requests a new device context slot."""
    var ctrl = trb_type_field(TRB_TYPE_CMD_ENABLE_SLOT)
    if cycle:
        ctrl = ctrl | TRB_CYCLE
    (0, 0, ctrl)

fn trb_cmd_address_device(slot: u32, input_ctx: u64, cycle: bool) -> (u64, u32, u32):
    """Address Device Command TRB — assigns a USB address to a slot."""
    var ctrl = trb_type_field(TRB_TYPE_CMD_ADDRESS_DEVICE) | (slot << 24)
    if cycle:
        ctrl = ctrl | TRB_CYCLE
    (input_ctx, 0, ctrl)

fn trb_cmd_configure_ep(slot: u32, input_ctx: u64, cycle: bool) -> (u64, u32, u32):
    """Configure Endpoint Command TRB — configures endpoints for a slot."""
    var ctrl = trb_type_field(TRB_TYPE_CMD_CONFIGURE_EP) | (slot << 24)
    if cycle:
        ctrl = ctrl | TRB_CYCLE
    (input_ctx, 0, ctrl)

# ============================================================================
# Event TRB field extractors
# ============================================================================

fn trb_event_completion_code(status: u32) -> u8:
    """Extract Completion Code from event TRB status word (bits [31:24])."""
    ((status >> 24) & 0xFF).to_u8()

fn trb_event_slot_id(control: u32) -> u8:
    """Extract Slot ID from event TRB control word (bits [31:24])."""
    ((control >> 24) & 0xFF).to_u8()

fn trb_event_type(control: u32) -> u8:
    """Extract TRB type from control word (bits [15:10])."""
    ((control >> TRB_TYPE_SHIFT) & 0x3F).to_u8()

fn trb_event_transfer_length(status: u32) -> u32:
    """Extract residual transfer length from Transfer Event TRB (bits [23:0])."""
    status & 0x00FFFFFF
