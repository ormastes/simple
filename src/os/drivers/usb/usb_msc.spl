# USB Mass Storage Class driver — Bulk-Only Transport (BOT) + minimal SCSI.
#
# MDSOC: feature dimension, drivers layer
#
# Implements the USB MSC Bulk-Only Transport protocol (USB.org "Universal
# Serial Bus Mass Storage Class Bulk-Only Transport" rev 1.0): 31-byte CBW
# out, optional data stage, 13-byte CSW in — plus the minimal SCSI command
# set needed for block storage: TEST UNIT READY, INQUIRY, READ CAPACITY(10),
# READ(10), WRITE(10).
#
# The device is exposed as the stdlib BlockDevice trait
# (std.fs_driver.block_device) — the same trait NVMe/virtio-blk adapters
# implement — so VFS/FAT32/DBFS mount on a usb-storage drive unchanged.
#
# Transport abstraction: UsbBulkTransport carries raw bulk-endpoint traffic.
# The xHCI bulk-endpoint transport (Configure Endpoint + bulk transfer rings
# on the enumerated usb-storage device) plugs in underneath; unit gates drive
# the full BOT/SCSI state machine over an in-memory transport.
#
# Fail-closed: any CSW signature/tag/status mismatch, short data stage, or
# transport error surfaces as Err — never a partial/garbage sector.
#
# TODO(usb-msc-xhci): implement the xHCI UsbBulkTransport — Configure
# Endpoint for the usb-storage device's bulk IN/OUT endpoints + per-endpoint
# transfer rings — and wire a `-device usb-storage,drive=X` lane into
# scripts/check/check-simpleos-usb-xhci-qemu.shs asserting mount+read of a
# FAT32 file over real QEMU usb-storage.
# TODO(usb-arm64): prove the same xHCI probe/enumeration lane on arm64
# (qemu-system-aarch64 -M virt has PCIe; the driver stack is MMIO/PCI-only
# and arch-neutral) once an aarch64 kernel entry exists for it.

use std.fs_driver.block_device.{BlockDevice}

# CBW/CSW signatures (little-endian on the wire)
val MSC_CBW_SIGNATURE: u32 = 0x43425355   # 'USBC'
val MSC_CSW_SIGNATURE: u32 = 0x53425355   # 'USBS'

val MSC_CBW_LEN: i64 = 31
val MSC_CSW_LEN: i64 = 13

# CBW flags
val MSC_FLAG_DATA_IN: u8  = 0x80
val MSC_FLAG_DATA_OUT: u8 = 0x00

# SCSI opcodes
val SCSI_TEST_UNIT_READY: u8 = 0x00
val SCSI_INQUIRY: u8         = 0x12
val SCSI_READ_CAPACITY10: u8 = 0x25
val SCSI_READ10: u8          = 0x28
val SCSI_WRITE10: u8         = 0x2A

# BOT tag counter. Tags are opaque echo-checked tokens; only equality between
# CBW and CSW matters, so any starting value is sound.
var _msc_next_tag: i64 = 1

fn _msc_alloc_tag() -> i64:
    val tag = _msc_next_tag & 0xFFFFFFFF
    _msc_next_tag = _msc_next_tag + 1
    tag

trait UsbBulkTransport:
    fn bulk_out(data: [u8]) -> Result<i64, text>
    fn bulk_in(max_len: i64) -> Result<[u8], text>

class UsbMscCapacity:
    """READ CAPACITY(10) result."""
    sector_count: u64
    sector_size: u32

# ---------------------------------------------------------------------------
# Wire helpers
# ---------------------------------------------------------------------------

fn _msc_build_cbw(tag: i64, data_len: i64, flags: u8, lun: u8, cdb: [u8]) -> [u8]:
    """Build a 31-byte Command Block Wrapper around a SCSI CDB."""
    var cbw: [u8] = []
    # dCBWSignature (LE)
    cbw.push(0x55u8)
    cbw.push(0x53u8)
    cbw.push(0x42u8)
    cbw.push(0x43u8)
    # dCBWTag (LE)
    cbw.push((tag & 0xFF).to_u8())
    cbw.push(((tag >> 8) & 0xFF).to_u8())
    cbw.push(((tag >> 16) & 0xFF).to_u8())
    cbw.push(((tag >> 24) & 0xFF).to_u8())
    # dCBWDataTransferLength (LE)
    cbw.push((data_len & 0xFF).to_u8())
    cbw.push(((data_len >> 8) & 0xFF).to_u8())
    cbw.push(((data_len >> 16) & 0xFF).to_u8())
    cbw.push(((data_len >> 24) & 0xFF).to_u8())
    # bmCBWFlags, bCBWLUN, bCBWCBLength
    cbw.push(flags)
    cbw.push(lun)
    cbw.push(cdb.len().to_u8())
    # CBWCB — 16 bytes, zero-padded
    var i: i64 = 0
    while i < 16:
        if i < cdb.len():
            cbw.push(cdb[i])
        else:
            cbw.push(0x00u8)
        i = i + 1
    cbw

fn _msc_check_csw(csw: [u8], tag: i64) -> Result<bool, text>:
    """Validate a 13-byte Command Status Wrapper. Fail-closed on any mismatch."""
    if csw.len() != MSC_CSW_LEN:
        return Err("usb-msc: CSW length " + csw.len().to_text() + " != 13")
    val sig = csw[0].to_i64() | (csw[1].to_i64() << 8) | (csw[2].to_i64() << 16) | (csw[3].to_i64() << 24)
    if sig != 0x53425355:
        return Err("usb-msc: bad CSW signature")
    val csw_tag = csw[4].to_i64() | (csw[5].to_i64() << 8) | (csw[6].to_i64() << 16) | (csw[7].to_i64() << 24)
    if csw_tag != (tag & 0xFFFFFFFF):
        return Err("usb-msc: CSW tag mismatch")
    val status = csw[12].to_i64()
    if status != 0:
        return Err("usb-msc: command failed, CSW status=" + status.to_text())
    Ok(true)

fn _msc_transact_in(transport: UsbBulkTransport, cdb: [u8], data_len: i64) -> Result<[u8], text>:
    """One BOT transaction with an IN data stage: CBW -> data -> CSW."""
    val tag = _msc_alloc_tag()
    val cbw = _msc_build_cbw(tag, data_len, MSC_FLAG_DATA_IN, 0, cdb)
    val out_rc = transport.bulk_out(cbw)
    if val Err(out_err) = out_rc:
        return Err("usb-msc: CBW send failed: " + out_err)

    var data: [u8] = []
    if data_len > 0:
        val data_rc = transport.bulk_in(data_len)
        if val Err(data_err) = data_rc:
            return Err("usb-msc: data stage failed: " + data_err)
        if val Ok(received) = data_rc:
            data = received

    val csw_rc = transport.bulk_in(MSC_CSW_LEN)
    if val Err(csw_err) = csw_rc:
        return Err("usb-msc: CSW receive failed: " + csw_err)
    if val Ok(csw) = csw_rc:
        val check = _msc_check_csw(csw, tag)
        if val Err(check_err) = check:
            return Err(check_err)

    if data.len() != data_len:
        return Err("usb-msc: short data stage: got " + data.len().to_text() + " of " + data_len.to_text())
    Ok(data)

fn _msc_transact_out(transport: UsbBulkTransport, cdb: [u8], data: [u8]) -> Result<bool, text>:
    """One BOT transaction with an OUT data stage: CBW -> data -> CSW."""
    val tag = _msc_alloc_tag()
    val cbw = _msc_build_cbw(tag, data.len(), MSC_FLAG_DATA_OUT, 0, cdb)
    val out_rc = transport.bulk_out(cbw)
    if val Err(out_err) = out_rc:
        return Err("usb-msc: CBW send failed: " + out_err)

    if data.len() > 0:
        val data_rc = transport.bulk_out(data)
        if val Err(data_err) = data_rc:
            return Err("usb-msc: data stage failed: " + data_err)

    val csw_rc = transport.bulk_in(MSC_CSW_LEN)
    if val Err(csw_err) = csw_rc:
        return Err("usb-msc: CSW receive failed: " + csw_err)
    if val Ok(csw) = csw_rc:
        val check = _msc_check_csw(csw, tag)
        if val Err(check_err) = check:
            return Err(check_err)
    Ok(true)

# ---------------------------------------------------------------------------
# SCSI commands
# ---------------------------------------------------------------------------

fn usb_msc_test_unit_ready(transport: UsbBulkTransport) -> Result<bool, text>:
    """SCSI TEST UNIT READY — no data stage; CSW status is the answer."""
    val cdb: [u8] = [0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]
    val rc = _msc_transact_in(transport, cdb, 0)
    if val Err(e) = rc:
        return Err(e)
    Ok(true)

fn usb_msc_inquiry(transport: UsbBulkTransport) -> Result<[u8], text>:
    """SCSI INQUIRY — 36-byte standard inquiry data.

    Fails unless the peripheral device type is 0x00 (direct-access block
    device) — fail-closed against non-disk devices.
    """
    val cdb: [u8] = [0x12u8, 0x00u8, 0x00u8, 0x00u8, 0x24u8, 0x00u8]
    val rc = _msc_transact_in(transport, cdb, 36)
    if val Err(e) = rc:
        return Err(e)
    if val Ok(data) = rc:
        val device_type = data[0].to_i64() & 0x1F
        if device_type != 0:
            return Err("usb-msc: not a direct-access device, type=" + device_type.to_text())
        return Ok(data)
    Err("usb-msc: inquiry failed")

fn usb_msc_read_capacity(transport: UsbBulkTransport) -> Result<UsbMscCapacity, text>:
    """SCSI READ CAPACITY(10) — last LBA + block size (both big-endian)."""
    val cdb: [u8] = [0x25u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]
    val rc = _msc_transact_in(transport, cdb, 8)
    if val Err(e) = rc:
        return Err(e)
    if val Ok(data) = rc:
        val last_lba = (data[0].to_i64() << 24) | (data[1].to_i64() << 16) | (data[2].to_i64() << 8) | data[3].to_i64()
        val block_size = (data[4].to_i64() << 24) | (data[5].to_i64() << 16) | (data[6].to_i64() << 8) | data[7].to_i64()
        if block_size <= 0 or block_size > 65536:
            return Err("usb-msc: implausible block size " + block_size.to_text())
        return Ok(UsbMscCapacity(
            sector_count: (last_lba + 1).to_u64(),
            sector_size: block_size.to_u32()
        ))
    Err("usb-msc: read capacity failed")

fn _msc_rw10_cdb(opcode: u8, lba: u64, count: i64) -> [u8]:
    """Build a READ(10)/WRITE(10) CDB (big-endian LBA + transfer length)."""
    val lba_i = lba.to_i64()
    [
        opcode,
        0x00u8,
        ((lba_i >> 24) & 0xFF).to_u8(),
        ((lba_i >> 16) & 0xFF).to_u8(),
        ((lba_i >> 8) & 0xFF).to_u8(),
        (lba_i & 0xFF).to_u8(),
        0x00u8,
        ((count >> 8) & 0xFF).to_u8(),
        (count & 0xFF).to_u8(),
        0x00u8
    ]

# ---------------------------------------------------------------------------
# Block device
# ---------------------------------------------------------------------------

class UsbMscDevice:
    """A USB mass-storage LUN exposed as the stdlib BlockDevice trait."""
    transport: UsbBulkTransport
    sector_size_: u32
    sector_count_: u64

impl UsbMscDevice:
    fn sector_count() -> u64:
        self.sector_count_

impl BlockDevice for UsbMscDevice:
    fn read_sector(lba: u64) -> Result<[u8], text>:
        """Read one sector via SCSI READ(10) over BOT."""
        if lba >= self.sector_count_:
            return Err("usb-msc: read lba out of range")
        val cdb = _msc_rw10_cdb(SCSI_READ10, lba, 1)
        _msc_transact_in(self.transport, cdb, self.sector_size_.to_i64())

    me fn write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        """Write one sector via SCSI WRITE(10) over BOT."""
        if lba >= self.sector_count_:
            return Err("usb-msc: write lba out of range")
        if data.len() != self.sector_size_.to_i64():
            return Err("usb-msc: write size " + data.len().to_text() + " != sector size")
        val cdb = _msc_rw10_cdb(SCSI_WRITE10, lba, 1)
        _msc_transact_out(self.transport, cdb, data)

    fn sector_size() -> u32:
        self.sector_size_

fn usb_msc_init(transport: UsbBulkTransport) -> Result<UsbMscDevice, text>:
    """Initialize a USB mass-storage LUN: INQUIRY + READ CAPACITY.

    Returns a BlockDevice-conforming UsbMscDevice on success; any protocol
    error, non-disk device type, or implausible geometry fails closed.
    """
    val inquiry = usb_msc_inquiry(transport)
    if val Err(inq_err) = inquiry:
        return Err(inq_err)
    val capacity = usb_msc_read_capacity(transport)
    if val Err(cap_err) = capacity:
        return Err(cap_err)
    if val Ok(cap) = capacity:
        if cap.sector_count == 0:
            return Err("usb-msc: zero-capacity device")
        return Ok(UsbMscDevice(
            transport: transport,
            sector_size_: cap.sector_size,
            sector_count_: cap.sector_count
        ))
    Err("usb-msc: init failed")
