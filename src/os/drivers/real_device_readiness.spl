# Truthful real-device readiness gates for SimpleOS board hardening.

use os.drivers.user_space_driver_contract.{user_space_driver_all_direct_access_reason}
use os.drivers.nvme.nvme_performance_contract.{
    nvme_production_perf_report_line_from_measurements,
    nvme_production_perf_serial_acceptance_reason,
    nvme_real_hardware_perf_report_line_from_measurements,
    nvme_real_hardware_perf_serial_acceptance_reason
}
use os.kernel.types.capability_types.{SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID}

struct RealDeviceReadiness:
    board_id: text
    pci_provider: text
    pci_enumerated: bool
    storage_mode: text
    nvme_identify: bool
    nvme_read_write: bool
    network_mode: text
    network_queue: bool
    network_rx_tx: bool
    rdma_mode: text
    rdma_device: bool
    dma_isolated: bool
    iommu_or_broker: bool
    storage_provider: text
    network_provider: text
    rdma_provider: text
    storage_placement: text
    storage_grant: text
    storage_namespace: text
    storage_common_logic_shared: bool
    network_placement: text
    network_grant: text
    network_namespace: text
    network_common_logic_shared: bool
    rdma_placement: text
    rdma_grant: text
    rdma_namespace: text
    rdma_common_logic_shared: bool

fn real_device_readiness(
    board_id: text,
    pci_provider: text,
    pci_enumerated: bool,
    storage_mode: text,
    nvme_identify: bool,
    nvme_read_write: bool,
    network_mode: text,
    network_queue: bool,
    network_rx_tx: bool,
    rdma_mode: text,
    rdma_device: bool,
    dma_isolated: bool,
    iommu_or_broker: bool
) -> RealDeviceReadiness:
    real_device_readiness_with_providers(
        board_id: board_id,
        pci_provider: pci_provider,
        pci_enumerated: pci_enumerated,
        storage_mode: storage_mode,
        nvme_identify: nvme_identify,
        nvme_read_write: nvme_read_write,
        network_mode: network_mode,
        network_queue: network_queue,
        network_rx_tx: network_rx_tx,
        rdma_mode: rdma_mode,
        rdma_device: rdma_device,
        dma_isolated: dma_isolated,
        iommu_or_broker: iommu_or_broker,
        storage_provider: "unspecified",
        network_provider: "unspecified",
        rdma_provider: "unspecified"
    )

fn real_device_readiness_with_providers(
    board_id: text,
    pci_provider: text,
    pci_enumerated: bool,
    storage_mode: text,
    nvme_identify: bool,
    nvme_read_write: bool,
    network_mode: text,
    network_queue: bool,
    network_rx_tx: bool,
    rdma_mode: text,
    rdma_device: bool,
    dma_isolated: bool,
    iommu_or_broker: bool,
    storage_provider: text,
    network_provider: text,
    rdma_provider: text
) -> RealDeviceReadiness:
    real_device_readiness_with_access(
        board_id: board_id,
        pci_provider: pci_provider,
        pci_enumerated: pci_enumerated,
        storage_mode: storage_mode,
        nvme_identify: nvme_identify,
        nvme_read_write: nvme_read_write,
        network_mode: network_mode,
        network_queue: network_queue,
        network_rx_tx: network_rx_tx,
        rdma_mode: rdma_mode,
        rdma_device: rdma_device,
        dma_isolated: dma_isolated,
        iommu_or_broker: iommu_or_broker,
        storage_provider: storage_provider,
        network_provider: network_provider,
        rdma_provider: rdma_provider,
        storage_placement: "unknown",
        storage_grant: "none",
        storage_namespace: "none",
        storage_common_logic_shared: false,
        network_placement: "unknown",
        network_grant: "none",
        network_namespace: "none",
        network_common_logic_shared: false,
        rdma_placement: "unknown",
        rdma_grant: "none",
        rdma_namespace: "none",
        rdma_common_logic_shared: false
    )

fn real_device_readiness_with_access(
    board_id: text,
    pci_provider: text,
    pci_enumerated: bool,
    storage_mode: text,
    nvme_identify: bool,
    nvme_read_write: bool,
    network_mode: text,
    network_queue: bool,
    network_rx_tx: bool,
    rdma_mode: text,
    rdma_device: bool,
    dma_isolated: bool,
    iommu_or_broker: bool,
    storage_provider: text,
    network_provider: text,
    rdma_provider: text,
    storage_placement: text,
    storage_grant: text,
    storage_namespace: text,
    storage_common_logic_shared: bool,
    network_placement: text,
    network_grant: text,
    network_namespace: text,
    network_common_logic_shared: bool,
    rdma_placement: text,
    rdma_grant: text,
    rdma_namespace: text,
    rdma_common_logic_shared: bool
) -> RealDeviceReadiness:
    RealDeviceReadiness(
        board_id: board_id,
        pci_provider: pci_provider,
        pci_enumerated: pci_enumerated,
        storage_mode: storage_mode,
        nvme_identify: nvme_identify,
        nvme_read_write: nvme_read_write,
        network_mode: network_mode,
        network_queue: network_queue,
        network_rx_tx: network_rx_tx,
        rdma_mode: rdma_mode,
        rdma_device: rdma_device,
        dma_isolated: dma_isolated,
        iommu_or_broker: iommu_or_broker,
        storage_provider: storage_provider,
        network_provider: network_provider,
        rdma_provider: rdma_provider,
        storage_placement: storage_placement,
        storage_grant: storage_grant,
        storage_namespace: storage_namespace,
        storage_common_logic_shared: storage_common_logic_shared,
        network_placement: network_placement,
        network_grant: network_grant,
        network_namespace: network_namespace,
        network_common_logic_shared: network_common_logic_shared,
        rdma_placement: rdma_placement,
        rdma_grant: rdma_grant,
        rdma_namespace: rdma_namespace,
        rdma_common_logic_shared: rdma_common_logic_shared
    )

fn real_device_pci_supported(board_id: text) -> bool:
    board_id == "x86_64-q35" or board_id == "riscv64-virt" or board_id == "xck26-ml-carrier"

fn real_device_pci_provider_supported(provider: text) -> bool:
    provider == "x86-config-io" or provider == "pci-ecam" or provider == "q35-config-io"

fn real_device_storage_ready(c: RealDeviceReadiness) -> bool:
    if c.storage_mode == "off" or c.storage_mode == "none":
        return true
    if c.storage_mode == "nvme":
        return real_device_provider_is_hardware(c.storage_provider) and real_device_pci_supported(c.board_id) and real_device_pci_provider_supported(c.pci_provider) and c.pci_enumerated and c.nvme_identify and c.nvme_read_write and c.dma_isolated
    false

fn real_device_network_ready(c: RealDeviceReadiness) -> bool:
    if c.network_mode == "off" or c.network_mode == "none":
        return true
    if c.network_mode == "virtio-net" or c.network_mode == "e1000":
        return real_device_provider_is_hardware(c.network_provider) and real_device_pci_supported(c.board_id) and real_device_pci_provider_supported(c.pci_provider) and c.pci_enumerated and c.network_queue and c.network_rx_tx and c.dma_isolated
    if c.network_mode == "rdma":
        return real_device_rdma_ready(c)
    false

fn real_device_rdma_ready(c: RealDeviceReadiness) -> bool:
    if c.rdma_mode == "off" or c.rdma_mode == "none":
        return true
    if c.rdma_mode == "model" or c.rdma_mode == "sffi-host":
        return false
    if c.rdma_mode == "device":
        return real_device_provider_is_hardware(c.rdma_provider) and real_device_pci_supported(c.board_id) and real_device_pci_provider_supported(c.pci_provider) and c.pci_enumerated and c.rdma_device and c.dma_isolated and c.iommu_or_broker
    false

fn real_device_provider_is_simple(provider: text) -> bool:
    provider == "simple-driver"

fn real_device_provider_is_hardware(provider: text) -> bool:
    real_device_provider_is_simple(provider)

fn real_device_pure_simple_ready(c: RealDeviceReadiness) -> bool:
    real_device_readiness_ready(c) and
        (c.storage_mode == "off" or c.storage_mode == "none" or real_device_provider_is_simple(c.storage_provider)) and
        (c.network_mode == "off" or c.network_mode == "none" or real_device_provider_is_simple(c.network_provider)) and
        (c.rdma_mode == "off" or c.rdma_mode == "none" or real_device_provider_is_simple(c.rdma_provider)) and
        real_device_direct_access_reason(c) == "ready"

fn real_device_readiness_ready(c: RealDeviceReadiness) -> bool:
    real_device_storage_ready(c) and real_device_network_ready(c) and real_device_rdma_ready(c)

fn real_device_readiness_reason(c: RealDeviceReadiness) -> text:
    if not real_device_pci_supported(c.board_id) and (c.storage_mode == "nvme" or c.network_mode == "virtio-net" or c.network_mode == "e1000" or c.network_mode == "rdma" or c.rdma_mode == "device"):
        return "missing-pci-board:" + c.board_id
    if not real_device_pci_provider_supported(c.pci_provider) and c.pci_provider != "none":
        return "unsupported-pci-provider:" + c.pci_provider
    if (c.storage_mode == "nvme" or c.network_mode == "virtio-net" or c.network_mode == "e1000" or c.rdma_mode == "device") and not c.pci_enumerated:
        return "missing-pci-enumeration"
    if c.storage_mode == "nvme" and not c.nvme_identify:
        return "missing-nvme-identify"
    if c.storage_mode == "nvme" and not c.nvme_read_write:
        return "missing-nvme-read-write"
    if c.storage_mode == "nvme" and not real_device_provider_is_hardware(c.storage_provider):
        return "storage-provider-not-hardware:" + c.storage_provider
    if (c.storage_mode == "nvme" or c.network_mode == "virtio-net" or c.network_mode == "e1000" or c.rdma_mode == "device") and not c.dma_isolated:
        return "missing-dma-isolation"
    if (c.network_mode == "virtio-net" or c.network_mode == "e1000") and not c.network_queue:
        return "missing-network-queue:" + c.network_mode
    if (c.network_mode == "virtio-net" or c.network_mode == "e1000") and not c.network_rx_tx:
        return "missing-network-rx-tx:" + c.network_mode
    if (c.network_mode == "virtio-net" or c.network_mode == "e1000") and not real_device_provider_is_hardware(c.network_provider):
        return "network-provider-not-hardware:" + c.network_provider
    if c.rdma_mode == "model" or c.rdma_mode == "sffi-host":
        return "rdma-not-hardware:" + c.rdma_mode
    if c.rdma_mode == "device" and not c.rdma_device:
        return "missing-rdma-device"
    if c.rdma_mode == "device" and not c.iommu_or_broker:
        return "missing-rdma-iommu-or-broker"
    if c.rdma_mode == "device" and not real_device_provider_is_hardware(c.rdma_provider):
        return "rdma-provider-not-hardware:" + c.rdma_provider
    if real_device_readiness_ready(c):
        return "ready"
    "unsupported-device-claim"

fn real_device_pure_simple_reason(c: RealDeviceReadiness) -> text:
    val hardware_reason = real_device_readiness_reason(c)
    if hardware_reason != "ready":
        return hardware_reason
    if c.storage_mode != "off" and c.storage_mode != "none" and not real_device_provider_is_simple(c.storage_provider):
        return "storage-not-pure-simple:" + c.storage_provider
    if c.network_mode != "off" and c.network_mode != "none" and not real_device_provider_is_simple(c.network_provider):
        return "network-not-pure-simple:" + c.network_provider
    if c.rdma_mode != "off" and c.rdma_mode != "none" and not real_device_provider_is_simple(c.rdma_provider):
        return "rdma-not-pure-simple:" + c.rdma_provider
    real_device_direct_access_reason(c)

fn real_device_direct_access_reason(c: RealDeviceReadiness) -> text:
    if c.storage_mode == "nvme":
        val storage_reason = user_space_driver_all_direct_access_reason(
            "nvme",
            c.storage_placement,
            c.storage_grant,
            c.storage_namespace,
            c.storage_common_logic_shared,
            c.iommu_or_broker,
            c.storage_provider
        )
        if storage_reason != "ready":
            return "storage-direct-access:" + storage_reason
    if c.network_mode == "virtio-net" or c.network_mode == "e1000":
        val network_reason = user_space_driver_all_direct_access_reason(
            c.network_mode,
            c.network_placement,
            c.network_grant,
            c.network_namespace,
            c.network_common_logic_shared,
            c.iommu_or_broker,
            c.network_provider
        )
        if network_reason != "ready":
            return "network-direct-access:" + network_reason
    if c.rdma_mode == "device":
        val rdma_reason = user_space_driver_all_direct_access_reason(
            "rdma",
            c.rdma_placement,
            c.rdma_grant,
            c.rdma_namespace,
            c.rdma_common_logic_shared,
            c.iommu_or_broker,
            c.rdma_provider
        )
        if rdma_reason != "ready":
            return "rdma-direct-access:" + rdma_reason
    "ready"

fn real_device_current_q35_c_bridge_readiness() -> RealDeviceReadiness:
    real_device_readiness_with_providers(
        "x86_64-q35",
        "q35-config-io",
        true,
        "nvme",
        true,
        true,
        "virtio-net",
        true,
        true,
        "off",
        false,
        true,
        true,
        "c-boot-bridge",
        "c-boot-bridge",
        "none"
    )

fn real_device_qemu_args_for_image(c: RealDeviceReadiness, nvme_image: text) -> [text]:
    var args: [text] = []
    if c.storage_mode == "nvme":
        args.push("-drive")
        args.push("file=" + nvme_image + ",if=none,id=nvme0,format=raw")
        args.push("-device")
        args.push("nvme,drive=nvme0,serial=simpleos0")
    if c.network_mode == "virtio-net":
        args.push("-netdev")
        args.push("user,id=net0")
        args.push("-device")
        args.push("virtio-net-pci,netdev=net0")
    if c.network_mode == "e1000":
        args.push("-netdev")
        args.push("user,id=net0")
        args.push("-device")
        args.push("e1000,netdev=net0")
    args

fn real_device_qemu_args(c: RealDeviceReadiness) -> [text]:
    real_device_qemu_args_for_image(c, "build/os/simpleos-nvme.img")

fn real_device_q35_qemu_command(c: RealDeviceReadiness, kernel_path: text, nvme_image: text) -> [text]:
    if c.board_id != "x86_64-q35":
        return []
    if not real_device_pci_provider_supported(c.pci_provider):
        return []
    [
        "qemu-system-x86_64",
        "-machine", "q35",
        "-cpu", "qemu64",
        "-m", "512M",
        "-kernel", kernel_path,
        "-serial", "stdio",
        "-monitor", "none",
        "-display", "none",
        "-no-reboot",
        "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"
    ] + real_device_qemu_args_for_image(c, nvme_image)

fn real_device_marker(c: RealDeviceReadiness) -> text:
    "[real-device] board=" + c.board_id +
        " pci=" + c.pci_provider +
        " storage=" + c.storage_mode +
        " storage_provider=" + c.storage_provider +
        " network=" + c.network_mode +
        " network_provider=" + c.network_provider +
        " rdma=" + c.rdma_mode +
        " rdma_provider=" + c.rdma_provider +
        " reason=" + real_device_readiness_reason(c)

fn real_device_q35_boot_markers() -> [text]:
    [
        "[stage1] pci_count=",
        "[stage1] nvme_pci=present",
        "[stage1] nvme_identify_read=pass",
        "[stage1] nvme_rw_restore=pass",
        "[stage1] net_pci=present",
        "[stage1] virtio_net_tx_rx=pass",
        "TEST PASSED"
    ]

fn real_device_q35_pure_simple_boot_markers() -> [text]:
    [
        "[stage1] pci_count=",
        "[stage1] nvme_pci=present",
        "[stage1] nvme_identify_read=pass",
        "[stage1] nvme_rw_restore=pass",
        "[stage1] net_pci=present",
        "[stage1] virtio_net_tx_rx=pass",
        "storage_provider=simple-driver",
        "network_provider=simple-driver",
        "storage_placement=user-space-driver",
        "system_storage_placement=system-driver",
        "network_placement=user-space-driver",
        "storage_namespace=non-secure-resource-namespace",
        "network_namespace=non-secure-resource-namespace",
        "storage_grant=resource-grant-set:tok=",
        "network_grant=resource-grant-set:tok=",
        "common_driver_logic=shared",
        "nvme_perf reason=ready",
        "fat32_direct_io=read-write",
        "nvfs_direct_io=read-write",
        "dbfs_direct_io=read-write",
        "TEST PASSED"
    ]

fn real_device_q35_pure_simple_access_marker(storage_grant: text, network_grant: text) -> text:
    """Build the guest serial marker proving pure Simple user-space driver placement."""
    "[real-device] storage_provider=simple-driver network_provider=simple-driver " +
        "storage_placement=user-space-driver system_storage_placement=system-driver network_placement=user-space-driver " +
        "storage_namespace=non-secure-resource-namespace network_namespace=non-secure-resource-namespace " +
        "storage_grant=" + storage_grant + " network_grant=" + network_grant + " common_driver_logic=shared"

fn real_device_q35_pure_simple_perf_marker_from_measurements(
    simple_read_iops: u64,
    simple_write_iops: u64,
    simple_read_p99_us: u64,
    simple_write_p99_us: u64,
    c_read_iops: u64,
    c_write_iops: u64,
    c_read_p99_us: u64,
    c_write_p99_us: u64,
    queue_depth: u16,
    warm_runs: u32,
    max_rss_kib: u64,
    allocation_per_io: bool
) -> text:
    """Build the guest serial perf marker consumed by q35 pure-Simple acceptance."""
    nvme_production_perf_report_line_from_measurements(
        simple_read_iops,
        simple_write_iops,
        simple_read_p99_us,
        simple_write_p99_us,
        c_read_iops,
        c_write_iops,
        c_read_p99_us,
        c_write_p99_us,
        queue_depth,
        warm_runs,
        max_rss_kib,
        allocation_per_io
    )

fn real_device_physical_nvme_perf_marker_from_measurements(
    simple_read_iops: u64,
    simple_write_iops: u64,
    simple_read_p99_us: u64,
    simple_write_p99_us: u64,
    c_read_iops: u64,
    c_write_iops: u64,
    c_read_p99_us: u64,
    c_write_p99_us: u64,
    queue_depth: u16,
    warm_runs: u32,
    max_rss_kib: u64,
    allocation_per_io: bool,
    device_model: text,
    device_serial: text,
    namespace_nsid: u32
) -> text:
    """Build the physical-NVMe serial perf marker consumed by release gates."""
    nvme_real_hardware_perf_report_line_from_measurements(
        simple_read_iops,
        simple_write_iops,
        simple_read_p99_us,
        simple_write_p99_us,
        c_read_iops,
        c_write_iops,
        c_read_p99_us,
        c_write_p99_us,
        queue_depth,
        warm_runs,
        max_rss_kib,
        allocation_per_io,
        device_model,
        device_serial,
        namespace_nsid
    )

fn real_device_q35_pure_simple_serial_acceptance_reason(serial_output: text) -> text:
    if serial_output.contains("storage_provider=c-boot-bridge"):
        return "storage-not-pure-simple:c-boot-bridge"
    if serial_output.contains("network_provider=c-boot-bridge"):
        return "network-not-pure-simple:c-boot-bridge"
    for marker in real_device_q35_pure_simple_boot_markers():
        if not _real_device_serial_marker_present(serial_output, marker):
            return "missing-pure-simple-marker:" + marker
    val perf_reason = nvme_production_perf_serial_acceptance_reason(serial_output)
    if perf_reason != "ready":
        return "nvme-production-perf:" + perf_reason
    "ready"

fn real_device_q35_pure_simple_serial_accepts_completion(serial_output: text) -> bool:
    real_device_q35_pure_simple_serial_acceptance_reason(serial_output) == "ready"

fn real_device_physical_nvme_boot_markers() -> [text]:
    [
        "storage_provider=simple-driver",
        "storage_placement=user-space-driver",
        "system_storage_placement=system-driver",
        "storage_namespace=non-secure-resource-namespace",
        "storage_grant=resource-grant-set:tok=",
        "common_driver_logic=shared",
        "nvme_perf reason=ready",
        "direct_io_path=nvme-lease-shared-dma-4k",
        "fs_consumers=fat32,nvfs,dbfs",
        "fat32_direct_io=read-write",
        "nvfs_direct_io=read-write",
        "dbfs_direct_io=read-write",
        "fat32_extent_source=freestanding-fat32-extents",
        "nvfs_extent_source=freestanding-dbfs-arena",
        "dbfs_extent_source=freestanding-dbfs-arena",
        "c_bridge_used=false",
        "c_baseline_device=same-nvme",
        "c_baseline_scope=in-guest",
        "c_baseline_cache=direct",
        "allocation_per_io=false",
        "hardware_target=real-nvme",
        "qemu=false",
        "device_model=",
        "device_serial=",
        "namespace_nsid=",
        "measured_on=real-device",
        "user_namespace_assignment=hardware-data-queue",
        "user_namespace_mode=user-assigned",
        "user_namespace_nsid=",
        "user_namespace_queue_id=",
        "user_namespace_active_lease_count=",
        "user_namespace_direct_io=read-write",
        "user_namespace_shared_interface=fat32,nvfs,dbfs",
        "user_namespace_conflict_policy=active-lease-checked",
        "TEST PASSED"
    ]

fn _real_device_serial_marker_present(serial_output: text, marker: text) -> bool:
    if marker.contains(" "):
        return serial_output.contains(marker)
    if not marker.contains("="):
        return serial_output.contains(marker)
    var normalized = serial_output.replace("\n", " ")
    normalized = normalized.replace("\r", " ")
    normalized = normalized.replace("\t", " ")
    for part in normalized.split(" "):
        val token = part.trim()
        if marker.ends_with("="):
            if token.starts_with(marker) and token.len() > marker.len():
                return true
        else:
            if token == marker:
                return true
    false

fn _real_device_serial_text_field(serial_output: text, prefix: text) -> text:
    var normalized = serial_output.replace("\n", " ")
    normalized = normalized.replace("\r", " ")
    normalized = normalized.replace("\t", " ")
    for part in normalized.split(" "):
        val token = part.trim()
        if token.starts_with(prefix):
            return token.substring(prefix.len(), token.len()).trim()
    ""

fn _real_device_serial_u16_field(serial_output: text, prefix: text) -> Result<u16, text>:
    val value_text = _real_device_serial_text_field(serial_output, prefix)
    if value_text.len() == 0:
        return Err("missing")
    for ch in value_text:
        if ch < "0" or ch > "9":
            return Err("invalid")
    var value: u64 = 0u64
    for ch in value_text:
        val digit = ch.to_i32() - "0".to_i32()
        value = value * 10u64 + digit.to_u64()
    if value > 65535u64:
        return Err("invalid")
    Ok(value as u16)

fn _real_device_serial_u32_field(serial_output: text, prefix: text) -> Result<u32, text>:
    val value_text = _real_device_serial_text_field(serial_output, prefix)
    if value_text.len() == 0:
        return Err("missing")
    for ch in value_text:
        if ch < "0" or ch > "9":
            return Err("invalid")
    var value: u64 = 0u64
    for ch in value_text:
        val digit = ch.to_i32() - "0".to_i32()
        value = value * 10u64 + digit.to_u64()
    if value > 4294967295u64:
        return Err("invalid")
    Ok(value as u32)

fn real_device_physical_nvme_serial_acceptance_reason(serial_output: text) -> text:
    if serial_output.contains("storage_provider=c-boot-bridge"):
        return "storage-not-pure-simple:c-boot-bridge"
    for marker in real_device_physical_nvme_boot_markers():
        if not _real_device_serial_marker_present(serial_output, marker):
            return "missing-physical-nvme-marker:" + marker
    val system_nsid = _real_device_serial_u32_field(serial_output, "namespace_nsid=")
    if system_nsid.is_err():
        return "physical-nvme-system-nsid-invalid"
    val user_nsid = _real_device_serial_u32_field(serial_output, "user_namespace_nsid=")
    if user_nsid.is_err():
        return "physical-nvme-user-nsid-invalid"
    if user_nsid.unwrap() == system_nsid.unwrap():
        return "physical-nvme-user-namespace-conflicts-system"
    val user_queue = _real_device_serial_u16_field(serial_output, "user_namespace_queue_id=")
    if user_queue.is_err():
        return "physical-nvme-user-queue-invalid"
    if user_queue.unwrap() < SIMPLEOS_NVME_FIRST_DATA_QUEUE_ID:
        return "physical-nvme-user-queue-not-data"
    val active_lease_count = _real_device_serial_u16_field(serial_output, "user_namespace_active_lease_count=")
    if active_lease_count.is_err():
        return "physical-nvme-active-lease-count-invalid"
    if active_lease_count.unwrap() == 0u16:
        return "physical-nvme-active-lease-check-empty"
    val perf_reason = nvme_real_hardware_perf_serial_acceptance_reason(serial_output)
    if perf_reason != "ready":
        return "nvme-real-hardware-perf:" + perf_reason
    "ready"

fn real_device_physical_nvme_serial_accepts_completion(serial_output: text) -> bool:
    real_device_physical_nvme_serial_acceptance_reason(serial_output) == "ready"

fn real_device_physical_nvme_serial_check_command(serial_log_path: text) -> [text]:
    [
        "bin/release/x86_64-unknown-linux-gnu/simple",
        "run",
        "src/app/simpleos_nvme_serial_check/main.spl",
        "--serial-log", serial_log_path
    ]

fn real_device_physical_nvme_validation_script() -> text:
    "scripts/run_simpleos_physical_nvme_perf.shs"

fn real_device_physical_nvme_validation_command(serial_log_path: text) -> [text]:
    [
        "sh",
        real_device_physical_nvme_validation_script(),
        "--serial-log", serial_log_path,
        "--validate-log-only"
    ]

fn real_device_physical_nvme_production_validation_command(serial_log_path: text, preflight_report_path: text, report_out_path: text) -> [text]:
    [
        "sh",
        real_device_physical_nvme_validation_script(),
        "--production",
        "--serial-log", serial_log_path,
        "--preflight-report", preflight_report_path,
        "--report-out", report_out_path,
        "--validate-log-only"
    ]

fn real_device_physical_nvme_live_production_validation_command(serial_port: text, serial_log_path: text, preflight_out_path: text, report_out_path: text) -> [text]:
    [
        "env",
        "SERIAL_PORT=" + serial_port,
        "sh",
        real_device_physical_nvme_validation_script(),
        "--production",
        "--serial-log", serial_log_path,
        "--preflight-out", preflight_out_path,
        "--report-out", report_out_path
    ]
