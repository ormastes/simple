// x86_64 Desktop Driver: Display Mode Reporting + Network Contract
// Covers: DisplayModeReport, InputAcceptance, VirtioNetContract,
//         NetSmokeResult, NetCapabilityReport, DisplayNetworkAcceptance

class DisplayModeReport:
    mode: text
    width: i64
    height: i64
    bpp: i64
    accelerated: bool
    accel_verified: bool
    vsync: bool
    double_buffered: bool

    static fn framebuffer(w: i64, h: i64, bits: i64) -> DisplayModeReport:
        return DisplayModeReport(
            mode: "framebuffer",
            width: w,
            height: h,
            bpp: bits,
            accelerated: false,
            accel_verified: false,
            vsync: false,
            double_buffered: false
        )

    static fn bga(w: i64, h: i64, bits: i64) -> DisplayModeReport:
        return DisplayModeReport(
            mode: "bga",
            width: w,
            height: h,
            bpp: bits,
            accelerated: true,
            accel_verified: false,
            vsync: false,
            double_buffered: true
        )

    static fn virtio_gpu(w: i64, h: i64, accel_verified: bool) -> DisplayModeReport:
        return DisplayModeReport(
            mode: "virtio_gpu",
            width: w,
            height: h,
            bpp: 32,
            accelerated: true,
            accel_verified: accel_verified,
            vsync: true,
            double_buffered: true
        )

    me is_accelerated() -> bool:
        return self.accelerated == true && self.accel_verified == true

    me pixel_count() -> i64:
        return self.width * self.height

    me summary() -> text:
        val accel_str = if self.is_accelerated() { "accel=yes" } else { "accel=no" }
        return "display[" + self.mode + " " + self.width.to_text() + "x" + self.height.to_text() + "@" + self.bpp.to_text() + "bpp " + accel_str + "]"


class InputAcceptance:
    ps2_keyboard_ok: bool
    ps2_mouse_ok: bool
    xhci_enumerated: bool
    xhci_device_count: i64
    xhci_blocking: bool

    static fn create() -> InputAcceptance:
        return InputAcceptance(
            ps2_keyboard_ok: false,
            ps2_mouse_ok: false,
            xhci_enumerated: false,
            xhci_device_count: 0,
            xhci_blocking: false
        )

    me ps2_passes() -> bool:
        return self.ps2_keyboard_ok == true && self.ps2_mouse_ok == true

    me xhci_diagnostic() -> text:
        val enum_str = if self.xhci_enumerated { "enumerated" } else { "not-enumerated" }
        val block_str = if self.xhci_blocking { " BLOCKING" } else { "" }
        return "xhci[" + enum_str + " devices=" + self.xhci_device_count.to_text() + block_str + "]"

    me passes_desktop() -> bool:
        return self.ps2_passes() == true && self.xhci_blocking == false

    me summary() -> text:
        val ps2_str = if self.ps2_passes() { "ps2=ok" } else { "ps2=fail" }
        return "input[" + ps2_str + " " + self.xhci_diagnostic() + "]"


class VirtioNetContract:
    initialized: bool
    mac_addr: text
    rx_queue_ready: bool
    tx_queue_ready: bool
    link_up: bool
    speed_mbps: i64

    static fn create() -> VirtioNetContract:
        return VirtioNetContract(
            initialized: false,
            mac_addr: "",
            rx_queue_ready: false,
            tx_queue_ready: false,
            link_up: false,
            speed_mbps: 0
        )

    me set_mac(mac: text) -> text:
        self.mac_addr = mac
        self.initialized = true
        return "mac=" + mac

    me set_queues(rx: bool, tx: bool) -> text:
        self.rx_queue_ready = rx
        self.tx_queue_ready = tx
        val rx_str = if rx { "rx=ok" } else { "rx=fail" }
        val tx_str = if tx { "tx=ok" } else { "tx=fail" }
        return rx_str + " " + tx_str

    me set_link(up: bool, speed: i64) -> text:
        self.link_up = up
        self.speed_mbps = speed
        val up_str = if up { "up" } else { "down" }
        return "link=" + up_str + " speed=" + speed.to_text() + "mbps"

    me is_ready() -> bool:
        val mac_ok = self.mac_addr == "" == false
        return self.initialized == true && mac_ok == true && self.rx_queue_ready == true && self.tx_queue_ready == true && self.link_up == true

    me summary() -> text:
        val ready_str = if self.is_ready() { "ready" } else { "not-ready" }
        return "virtio_net[" + ready_str + " mac=" + self.mac_addr + " speed=" + self.speed_mbps.to_text() + "mbps]"


class NetSmokeResult:
    packets_sent: i64
    packets_received: i64
    tcp_connect_ok: bool
    tcp_transfer_ok: bool
    latency_ms: i64
    throughput_kbps: i64

    static fn create() -> NetSmokeResult:
        return NetSmokeResult(
            packets_sent: 0,
            packets_received: 0,
            tcp_connect_ok: false,
            tcp_transfer_ok: false,
            latency_ms: 0,
            throughput_kbps: 0
        )

    me record_packet(sent: bool) -> i64:
        if sent == true:
            self.packets_sent = self.packets_sent + 1
        else:
            self.packets_received = self.packets_received + 1
        return self.packets_received

    me set_tcp(connect: bool, transfer: bool) -> text:
        self.tcp_connect_ok = connect
        self.tcp_transfer_ok = transfer
        val conn_str = if connect { "connect=ok" } else { "connect=fail" }
        val xfer_str = if transfer { "transfer=ok" } else { "transfer=fail" }
        return conn_str + " " + xfer_str

    me passes() -> bool:
        return self.packets_received > 0 && self.tcp_connect_ok == true

    me summary() -> text:
        val pass_str = if self.passes() { "PASS" } else { "FAIL" }
        return "net_smoke[" + pass_str + " sent=" + self.packets_sent.to_text() + " recv=" + self.packets_received.to_text() + " latency=" + self.latency_ms.to_text() + "ms]"


class NetCapabilityReport:
    backend: text
    rdma_enabled: bool
    sriov_enabled: bool
    packet_io_enabled: bool
    checksum_offload: bool
    tso_enabled: bool
    gso_enabled: bool

    static fn virtio_net_default() -> NetCapabilityReport:
        return NetCapabilityReport(
            backend: "virtio_net",
            rdma_enabled: false,
            sriov_enabled: false,
            packet_io_enabled: false,
            checksum_offload: true,
            tso_enabled: true,
            gso_enabled: false
        )

    me has_advanced() -> bool:
        return self.rdma_enabled == true || self.sriov_enabled == true || self.packet_io_enabled == true

    me validate_no_implicit_advanced() -> text:
        if self.has_advanced() == true:
            var flags = ""
            if self.rdma_enabled == true:
                flags = flags + "rdma "
            if self.sriov_enabled == true:
                flags = flags + "sriov "
            if self.packet_io_enabled == true:
                flags = flags + "packet_io "
            return "REJECT: advanced features enabled without explicit request: " + flags
        return ""

    me summary() -> text:
        val adv_str = if self.has_advanced() { "advanced=yes" } else { "advanced=no" }
        val csum_str = if self.checksum_offload { "csum=on" } else { "csum=off" }
        val tso_str = if self.tso_enabled { "tso=on" } else { "tso=off" }
        return "net_caps[" + self.backend + " " + adv_str + " " + csum_str + " " + tso_str + "]"


class DisplayNetworkAcceptance:
    display: DisplayModeReport
    input: InputAcceptance
    net_contract: VirtioNetContract
    net_smoke: NetSmokeResult
    net_caps: NetCapabilityReport

    static fn create() -> DisplayNetworkAcceptance:
        val disp = DisplayModeReport(
            mode: "none",
            width: 0,
            height: 0,
            bpp: 0,
            accelerated: false,
            accel_verified: false,
            vsync: false,
            double_buffered: false
        )
        return DisplayNetworkAcceptance(
            display: disp,
            input: InputAcceptance.create(),
            net_contract: VirtioNetContract.create(),
            net_smoke: NetSmokeResult.create(),
            net_caps: NetCapabilityReport.virtio_net_default()
        )

    me passes_display() -> bool:
        val mode_ok = self.display.mode == "none" == false
        return mode_ok == true && self.input.passes_desktop() == true

    me passes_network() -> bool:
        val adv_check = self.net_caps.validate_no_implicit_advanced()
        val adv_ok = adv_check == ""
        return self.net_contract.is_ready() == true && self.net_smoke.passes() == true && adv_ok == true

    me passes_all() -> bool:
        return self.passes_display() == true && self.passes_network() == true

    me report() -> text:
        val overall = if self.passes_all() { "PASS" } else { "FAIL" }
        return "x86_64_desktop[" + overall + "] " + self.display.summary() + " " + self.input.summary() + " " + self.net_contract.summary() + " " + self.net_smoke.summary() + " " + self.net_caps.summary()
