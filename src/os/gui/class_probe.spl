# Baremetal Imported-Class Probe Module
#
# Minimal shared module used by
# examples/09_embedded/simple_os/arch/x86_64/class_fault_probe_entry.spl to
# isolate the --entry-closure imported-class instantiation FAULT
# (doc/08_tracking/bug/baremetal_entry_closure_class_instantiation_fault_2026-07-06.md).
#
# Deliberately models the two module-global shapes involved:
#   - scalar module global read by a static constructor
#     (like _gpu_compositor_next_id in os.compositor.display_backend)
#   - heap-typed module global mutated by a method
#     (like _gpu_compositor_override_pixels) — stays ZERO unless
#     module initializers run before spl_start.

var _probe_next_id: u64 = 41
var _probe_events: [u64] = []

class ProbeCounter:
    count: u64
    label: text

impl ProbeCounter:
    static fn new() -> ProbeCounter:
        val id = _probe_next_id
        _probe_next_id = _probe_next_id + 1
        ProbeCounter(count: id, label: "probe")

    me bump(v: u64) -> u64:
        _probe_events.push(v)
        self.count = self.count + v
        self.count

fn probe_events_len() -> u64:
    _probe_events.len() as u64
