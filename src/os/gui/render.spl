#![allow(unnamed_duplicate_typed_args)]
# Pure Simple Rendering Library — Cross-Platform WM Rendering Primitives
#
# Replaces C glass_render.c with pure Simple code so the WM can run on
# ANY architecture (x86_64, ARM64, RISC-V, ARM32, x86_32).
#
# Architecture:
#   Shadow buffer (normal RAM) for fast pixel read/write, then bulk-copy
#   to the real MMIO framebuffer on present(). All pixel operations go
#   through px_read/px_write on the shadow buffer.
#
# Extern dependencies (arch-independent, available in all baremetal stubs):
#   rt_alloc          — heap allocation
#   rt_mmio_read_u32  — volatile 32-bit read (works on RAM and MMIO)
#   rt_mmio_write_u32 — volatile 32-bit write (works on RAM and MMIO)

# Architecture-independent runtime externs
extern fn rt_alloc(size: u64) -> u64
extern fn rt_mmio_read_u32(addr: u64) -> u32
extern fn rt_mmio_write_u32(addr: u64, value: u32)

# ============================================================================
# Global State
# ============================================================================

var g_shadow_buf: u64 = 0       # Shadow buffer base address (RAM)
var g_fb_addr: u64 = 0          # Real MMIO framebuffer address
var g_width: u64 = 0            # Framebuffer width in pixels
var g_height: u64 = 0           # Framebuffer height in pixels
var g_ready: u64 = 0            # 1 when shadow buffer is allocated
var g_dirty_valid: u64 = 0
var g_dirty_x1: u64 = 0
var g_dirty_y1: u64 = 0
var g_dirty_x2: u64 = 0
var g_dirty_y2: u64 = 0

# ============================================================================
# Frame Lifecycle
# ============================================================================

fn render_init(fb_addr: u64, width: u64, height: u64):
    """Initialize renderer with framebuffer address and dimensions.

    Allocates a shadow buffer in RAM for fast pixel operations.
    Must be called before any drawing functions.
    """
    g_fb_addr = fb_addr
    g_width = width
    g_height = height
    g_shadow_buf = rt_alloc(width * height * 4)
    if g_shadow_buf != 0:
        g_ready = 1
        # Clear shadow buffer to black
        var i: u64 = 0
        val total = width * height
        while i < total:
            rt_mmio_write_u32(g_shadow_buf + i * 4, 0xFF000000)
            i = i + 1
        render_mark_dirty_rect(0, 0, width, height)

fn render_present():
    """Copy tracked damage from the shadow buffer to the MMIO framebuffer.

    Call after all drawing for the current frame is complete.
    """
    if g_ready == 0:
        return
    if g_dirty_valid != 0:
        render_present_rect(g_dirty_x1, g_dirty_y1, g_dirty_x2 - g_dirty_x1, g_dirty_y2 - g_dirty_y1)
        render_clear_dirty()
        return
    render_present_full()

fn render_present_full():
    """Copy entire shadow buffer to real MMIO framebuffer."""
    if g_ready == 0:
        return
    var i: u64 = 0
    val total = g_width * g_height
    while i < total:
        val offset = i * 4
        val pixel = rt_mmio_read_u32(g_shadow_buf + offset)
        rt_mmio_write_u32(g_fb_addr + offset, pixel)
        i = i + 1
    render_clear_dirty()

fn render_present_rect(rx: u64, ry: u64, rw: u64, rh: u64):
    """Copy a rectangular region from shadow buffer to MMIO framebuffer.

    More efficient than full present() when only a small area changed.
    """
    if g_ready == 0:
        return
    var row: u64 = 0
    while row < rh:
        val py = ry + row
        if py >= g_height:
            return
        var col: u64 = 0
        while col < rw:
            val px = rx + col
            if px < g_width:
                val offset = (py * g_width + px) * 4
                val pixel = rt_mmio_read_u32(g_shadow_buf + offset)
                rt_mmio_write_u32(g_fb_addr + offset, pixel)
            col = col + 1
        row = row + 1

fn render_mark_dirty_rect(x: u64, y: u64, w: u64, h: u64):
    """Record shadow-buffer damage using exclusive-end coordinates."""
    if w == 0 or h == 0 or g_width == 0 or g_height == 0:
        return
    if x >= g_width or y >= g_height:
        return
    var x2 = x + w
    var y2 = y + h
    if x2 > g_width:
        x2 = g_width
    if y2 > g_height:
        y2 = g_height
    if x2 <= x or y2 <= y:
        return
    if g_dirty_valid == 0:
        g_dirty_x1 = x
        g_dirty_y1 = y
        g_dirty_x2 = x2
        g_dirty_y2 = y2
        g_dirty_valid = 1
        return
    if x < g_dirty_x1:
        g_dirty_x1 = x
    if y < g_dirty_y1:
        g_dirty_y1 = y
    if x2 > g_dirty_x2:
        g_dirty_x2 = x2
    if y2 > g_dirty_y2:
        g_dirty_y2 = y2

fn render_clear_dirty():
    g_dirty_valid = 0
    g_dirty_x1 = 0
    g_dirty_y1 = 0
    g_dirty_x2 = 0
    g_dirty_y2 = 0

fn render_dirty_valid() -> u64:
    g_dirty_valid

fn render_dirty_x1() -> u64:
    g_dirty_x1

fn render_dirty_y1() -> u64:
    g_dirty_y1

fn render_dirty_x2() -> u64:
    g_dirty_x2

fn render_dirty_y2() -> u64:
    g_dirty_y2

fn render_width() -> u64:
    """Return framebuffer width."""
    g_width

fn render_height() -> u64:
    """Return framebuffer height."""
    g_height

# ============================================================================
# Pixel Operations (on shadow buffer)
# ============================================================================

fn px_read(x: u64, y: u64) -> u64:
    """Read a pixel from the shadow buffer. Returns 0xAARRGGBB."""
    if g_ready == 0:
        return 0
    if x >= g_width:
        return 0
    if y >= g_height:
        return 0
    val offset = (y * g_width + x) * 4
    rt_mmio_read_u32(g_shadow_buf + offset).to_u64()

fn px_write(x: u64, y: u64, color: u64):
    """Write a pixel to the shadow buffer. Color is 0xAARRGGBB."""
    if g_ready == 0:
        return
    if x >= g_width:
        return
    if y >= g_height:
        return
    val offset = (y * g_width + x) * 4
    rt_mmio_write_u32(g_shadow_buf + offset, (color & 0xFFFFFFFF).to_u32())
    render_mark_dirty_rect(x, y, 1, 1)

# ============================================================================
# Color Math
# ============================================================================

fn alpha_blend(dst: u64, src: u64, alpha: u64) -> u64:
    """Blend src over dst with alpha (0-255).

    Uses (x + 128) >> 8 approximation matching the C glass_render.c.
    Returns 0xFFRRGGBB (fully opaque result).
    """
    if alpha >= 255:
        return 0xFF000000 | (src & 0x00FFFFFF)
    if alpha == 0:
        return dst
    val inv = 255 - alpha
    val sr = (src >> 16) & 0xFF
    val sg = (src >> 8) & 0xFF
    val sb = src & 0xFF
    val dr = (dst >> 16) & 0xFF
    val dg = (dst >> 8) & 0xFF
    val db = dst & 0xFF
    val rr = (sr * alpha + dr * inv + 128) >> 8
    val rg = (sg * alpha + dg * inv + 128) >> 8
    val rb = (sb * alpha + db * inv + 128) >> 8
    0xFF000000 | (rr << 16) | (rg << 8) | rb

fn lerp_color(c1: u64, c2: u64, t: u64, max: u64) -> u64:
    """Linearly interpolate between two colors.

    Uses signed math internally to handle cases where c2 channel < c1 channel
    (prevents unsigned underflow). t ranges from 0 to max.
    Returns 0xFFRRGGBB.
    """
    if max == 0:
        return 0xFF000000 | (c1 & 0x00FFFFFF)
    val r1 = (c1 >> 16) & 0xFF
    val g1 = (c1 >> 8) & 0xFF
    val b1 = c1 & 0xFF
    val r2 = (c2 >> 16) & 0xFF
    val g2 = (c2 >> 8) & 0xFF
    val b2 = c2 & 0xFF
    # Signed arithmetic: r = r1 + (r2 - r1) * t / max
    # To avoid underflow when r2 < r1, compute as:
    #   if r2 >= r1: r1 + (r2 - r1) * t / max
    #   else:        r1 - (r1 - r2) * t / max
    val r = _lerp_channel(r1, r2, t, max)
    val g = _lerp_channel(g1, g2, t, max)
    val b = _lerp_channel(b1, b2, t, max)
    0xFF000000 | (r << 16) | (g << 8) | b

fn _lerp_channel(a: u64, b: u64, t: u64, max: u64) -> u64:
    """Interpolate a single color channel (0-255) without underflow."""
    if b >= a:
        val diff = b - a
        val result = a + (diff * t) / max
        if result > 255:
            return 255
        return result
    # b < a: interpolate downward
    val diff = a - b
    val sub = (diff * t) / max
    if sub > a:
        return 0
    a - sub

fn color_rgb(r: u64, g: u64, b: u64) -> u64:
    """Pack r, g, b (each 0-255) into 0x00RRGGBB."""
    (r << 16) | (g << 8) | b

fn color_argb(a: u64, r: u64, g: u64, b: u64) -> u64:
    """Pack a, r, g, b (each 0-255) into 0xAARRGGBB."""
    (a << 24) | (r << 16) | (g << 8) | b

# ============================================================================
# Rectangle Operations
# ============================================================================

fn solid_fill(x: u64, y: u64, w: u64, h: u64, color: u64):
    """Fill a rectangle with a solid color (no blending).

    Color is 0x00RRGGBB — alpha is forced to 0xFF.
    """
    val c = 0xFF000000 | (color & 0x00FFFFFF)
    var row: u64 = 0
    while row < h:
        val py = y + row
        if py >= g_height:
            return
        var col: u64 = 0
        while col < w:
            val px = x + col
            if px < g_width:
                px_write(px, py, c)
            col = col + 1
        row = row + 1

fn blend_fill(x: u64, y: u64, w: u64, h: u64, color: u64, alpha: u64):
    """Alpha-blended rectangle fill.

    Reads each destination pixel, blends with color at given alpha,
    writes result back. Color is 0x00RRGGBB, alpha is 0-255.
    """
    if alpha == 0:
        return
    if alpha >= 255:
        solid_fill(x, y, w, h, color)
        return
    var row: u64 = 0
    while row < h:
        val py = y + row
        if py >= g_height:
            return
        var col: u64 = 0
        while col < w:
            val px = x + col
            if px < g_width:
                val dst = px_read(px, py)
                px_write(px, py, alpha_blend(dst, color, alpha))
            col = col + 1
        row = row + 1

# ============================================================================
# Gradients
# ============================================================================

fn gradient_v(x: u64, y: u64, w: u64, h: u64, c1: u64, c2: u64):
    """Vertical gradient from c1 (top) to c2 (bottom).

    Colors are 0x00RRGGBB. Output pixels are fully opaque.
    """
    if h == 0 or w == 0:
        return
    val max = if h > 1: h - 1 else: 1
    var row: u64 = 0
    while row < h:
        val py = y + row
        if py >= g_height:
            return
        val color = lerp_color(c1, c2, row, max)
        var col: u64 = 0
        while col < w:
            val px = x + col
            if px < g_width:
                px_write(px, py, color)
            col = col + 1
        row = row + 1

fn gradient_h(x: u64, y: u64, w: u64, h: u64, c1: u64, c2: u64):
    """Horizontal gradient from c1 (left) to c2 (right).

    Colors are 0x00RRGGBB. Output pixels are fully opaque.
    """
    if h == 0 or w == 0:
        return
    val max = if w > 1: w - 1 else: 1
    var col: u64 = 0
    while col < w:
        val px = x + col
        if px >= g_width:
            col = col + 1
            continue
        val color = lerp_color(c1, c2, col, max)
        var row: u64 = 0
        while row < h:
            val py = y + row
            if py < g_height:
                px_write(px, py, color)
            row = row + 1
        col = col + 1

fn gradient_blend_v(x: u64, y: u64, w: u64, h: u64, c1: u64, a1: u64, c2: u64, a2: u64):
    """Vertical gradient with varying alpha.

    Blends gradient color onto existing framebuffer content.
    c1/c2 are 0x00RRGGBB, a1/a2 are alpha values (0-255).
    """
    if h == 0 or w == 0:
        return
    val max = if h > 1: h - 1 else: 1
    var row: u64 = 0
    while row < h:
        val py = y + row
        if py >= g_height:
            return
        val color = lerp_color(c1, c2, row, max)
        val alpha = _lerp_channel(a1, a2, row, max)
        var col: u64 = 0
        while col < w:
            val px = x + col
            if px < g_width:
                val dst = px_read(px, py)
                px_write(px, py, alpha_blend(dst, color, alpha))
            col = col + 1
        row = row + 1

# ============================================================================
# Box Blur (3-pass or 5-pass approximation of Gaussian)
# ============================================================================

fn box_blur(x: u64, y: u64, w: u64, h: u64, radius: u64):
    """Multi-pass box blur approximating Gaussian blur.

    Uses 5 passes (H-V-H-V-H) matching glass_render.c for quality.
    Radius is clamped to 30 to prevent artifacts.
    """
    if w == 0 or h == 0:
        return
    var r = radius
    if r > 30:
        r = 30
    if r == 0:
        return
    # Clamp region to screen bounds
    var bw = w
    var bh = h
    if x + bw > g_width:
        bw = g_width - x
    if y + bh > g_height:
        bh = g_height - y
    # 5-pass: H -> V -> H -> V -> H
    _blur_h(x, y, bw, bh, r)
    _blur_v(x, y, bw, bh, r)
    _blur_h(x, y, bw, bh, r)
    _blur_v(x, y, bw, bh, r)
    _blur_h(x, y, bw, bh, r)

fn _blur_h(x0: u64, y0: u64, w: u64, h: u64, r: u64):
    """Horizontal blur pass using sliding window accumulator.

    For each row, maintains running sums of R/G/B channels across
    a window of size (2*r + 1). Slides the window left-to-right,
    writing averaged values, then adding/removing edge pixels.
    """
    if r == 0 or w == 0:
        return
    val d = 2 * r + 1
    var row: u64 = 0
    while row < h:
        val py = y0 + row
        if py >= g_height:
            row = row + 1
            continue
        # Build initial accumulator
        var acc_r: u64 = 0
        var acc_g: u64 = 0
        var acc_b: u64 = 0
        var i: u64 = 0
        while i < d and i < w:
            var sx = x0 + i
            if i < r:
                sx = x0
            else:
                sx = x0 + i - r
            if sx >= g_width:
                sx = g_width - 1
            val c = px_read(sx, py)
            acc_r = acc_r + ((c >> 16) & 0xFF)
            acc_g = acc_g + ((c >> 8) & 0xFF)
            acc_b = acc_b + (c & 0xFF)
            i = i + 1

        # Allocate temporary row buffer for blurred values
        # We write to a temp buffer first, then copy back,
        # to avoid reading already-blurred pixels in the sliding window.
        val tmp_buf = rt_alloc(w * 4)

        # Slide window across row, writing to temp buffer
        var col: u64 = 0
        while col < w:
            val avg_r = acc_r / d
            val avg_g = acc_g / d
            val avg_b = acc_b / d
            val blurred = 0xFF000000 | (avg_r << 16) | (avg_g << 8) | avg_b
            # Write to temp buffer
            if tmp_buf != 0:
                rt_mmio_write_u32(tmp_buf + col * 4, (blurred & 0xFFFFFFFF).to_u32())
            else:
                # Fallback: write directly (less accurate but no alloc needed)
                val px_out = x0 + col
                if px_out < g_width:
                    px_write(px_out, py, blurred)

            # Remove leftmost pixel from window
            var rm_x = x0 + col
            if col >= r:
                rm_x = x0 + col - r
            else:
                rm_x = x0
            if rm_x >= g_width:
                rm_x = g_width - 1
            val rm_c = px_read(rm_x, py)
            acc_r = acc_r - ((rm_c >> 16) & 0xFF)
            acc_g = acc_g - ((rm_c >> 8) & 0xFF)
            acc_b = acc_b - (rm_c & 0xFF)

            # Add rightmost pixel to window
            var add_x = x0 + col + r + 1
            if add_x >= x0 + w:
                add_x = x0 + w - 1
            if add_x >= g_width:
                add_x = g_width - 1
            val add_c = px_read(add_x, py)
            acc_r = acc_r + ((add_c >> 16) & 0xFF)
            acc_g = acc_g + ((add_c >> 8) & 0xFF)
            acc_b = acc_b + (add_c & 0xFF)

            col = col + 1

        # Copy temp buffer back to shadow buffer
        if tmp_buf != 0:
            var c2: u64 = 0
            while c2 < w:
                val px_out = x0 + c2
                if px_out < g_width:
                    val v = rt_mmio_read_u32(tmp_buf + c2 * 4).to_u64()
                    px_write(px_out, py, v)
                c2 = c2 + 1

        row = row + 1

fn _blur_v(x0: u64, y0: u64, w: u64, h: u64, r: u64):
    """Vertical blur pass using sliding window accumulator.

    Same algorithm as _blur_h but operates column-by-column.
    """
    if r == 0 or h == 0:
        return
    val d = 2 * r + 1
    var col: u64 = 0
    while col < w:
        val px = x0 + col
        if px >= g_width:
            col = col + 1
            continue
        # Build initial accumulator
        var acc_r: u64 = 0
        var acc_g: u64 = 0
        var acc_b: u64 = 0
        var i: u64 = 0
        while i < d and i < h:
            var sy = y0 + i
            if i < r:
                sy = y0
            else:
                sy = y0 + i - r
            if sy >= g_height:
                sy = g_height - 1
            val c = px_read(px, sy)
            acc_r = acc_r + ((c >> 16) & 0xFF)
            acc_g = acc_g + ((c >> 8) & 0xFF)
            acc_b = acc_b + (c & 0xFF)
            i = i + 1

        # Allocate temporary column buffer
        val tmp_buf = rt_alloc(h * 4)

        # Slide window down column
        var row: u64 = 0
        while row < h:
            val avg_r = acc_r / d
            val avg_g = acc_g / d
            val avg_b = acc_b / d
            val blurred = 0xFF000000 | (avg_r << 16) | (avg_g << 8) | avg_b
            # Write to temp buffer
            if tmp_buf != 0:
                rt_mmio_write_u32(tmp_buf + row * 4, (blurred & 0xFFFFFFFF).to_u32())
            else:
                val py = y0 + row
                if py < g_height:
                    px_write(px, py, blurred)

            # Remove top pixel from window
            var rm_y = y0 + row
            if row >= r:
                rm_y = y0 + row - r
            else:
                rm_y = y0
            if rm_y >= g_height:
                rm_y = g_height - 1
            val rm_c = px_read(px, rm_y)
            acc_r = acc_r - ((rm_c >> 16) & 0xFF)
            acc_g = acc_g - ((rm_c >> 8) & 0xFF)
            acc_b = acc_b - (rm_c & 0xFF)

            # Add bottom pixel to window
            var add_y = y0 + row + r + 1
            if add_y >= y0 + h:
                add_y = y0 + h - 1
            if add_y >= g_height:
                add_y = g_height - 1
            val add_c = px_read(px, add_y)
            acc_r = acc_r + ((add_c >> 16) & 0xFF)
            acc_g = acc_g + ((add_c >> 8) & 0xFF)
            acc_b = acc_b + (add_c & 0xFF)

            row = row + 1

        # Copy temp buffer back to shadow buffer
        if tmp_buf != 0:
            var r2: u64 = 0
            while r2 < h:
                val py = y0 + r2
                if py < g_height:
                    val v = rt_mmio_read_u32(tmp_buf + r2 * 4).to_u64()
                    px_write(px, py, v)
                r2 = r2 + 1

        col = col + 1

# ============================================================================
# Rounded Rectangle with Anti-Aliasing
# ============================================================================

fn rounded_rect_aa(x: u64, y: u64, w: u64, h: u64, color: u64, radius: u64, alpha: u64):
    """Draw a rounded rectangle (squircle) with anti-aliased corners.

    Uses circle-quarter masks at each corner. Pixels partially inside
    the circle boundary get proportional alpha for smooth edges.
    Color is 0x00RRGGBB, alpha is overall opacity (0-255).
    """
    if w == 0 or h == 0:
        return
    var r = radius
    if r > w / 2:
        r = w / 2
    if r > h / 2:
        r = h / 2
    val r2 = r * r

    var row: u64 = 0
    while row < h:
        val py = y + row
        if py >= g_height:
            return

        # Determine horizontal span based on corner rounding
        var x_start: u64 = 0
        var x_end: u64 = w

        # Check if we are in a corner region (top or bottom r rows)
        var in_corner = 0
        var dy: u64 = 0
        if row < r:
            in_corner = 1
            dy = r - row
        if row >= h - r:
            in_corner = 1
            dy = row - (h - 1 - r)

        if in_corner == 1:
            # Find the x offset where the circle boundary is
            var dx: u64 = 0
            while (dx + 1) * (dx + 1) + dy * dy <= r2:
                dx = dx + 1
            x_start = r - dx
            x_end = w - (r - dx)

            # Draw corner AA pixels (the fractional edge pixels)
            # Left corner edge pixel
            if x_start > 0:
                val edge_px = x + x_start - 1
                if edge_px < g_width:
                    # Compute sub-pixel coverage
                    val dist2 = (x_start) * (x_start) + dy * dy
                    var coverage = alpha
                    if dist2 > r2:
                        coverage = 0
                    else:
                        # Approximate AA: fraction of pixel inside circle
                        coverage = alpha * (r2 - dist2) / r2
                    if coverage > 0:
                        val dst = px_read(edge_px, py)
                        px_write(edge_px, py, alpha_blend(dst, color, coverage))

            # Right corner edge pixel
            if x_end < w:
                val edge_px = x + x_end
                if edge_px < g_width:
                    val dist2 = (x_start) * (x_start) + dy * dy
                    var coverage = alpha
                    if dist2 > r2:
                        coverage = 0
                    else:
                        coverage = alpha * (r2 - dist2) / r2
                    if coverage > 0:
                        val dst = px_read(edge_px, py)
                        px_write(edge_px, py, alpha_blend(dst, color, coverage))

        # Fill the main body of this scanline
        var col = x_start
        while col < x_end:
            val px = x + col
            if px >= g_width:
                col = col + 1
                continue
            if alpha >= 255:
                px_write(px, py, 0xFF000000 | (color & 0x00FFFFFF))
            else:
                val dst = px_read(px, py)
                px_write(px, py, alpha_blend(dst, color, alpha))
            col = col + 1
        row = row + 1

fn rounded_rect_top(x: u64, y: u64, w: u64, h: u64, color: u64, radius: u64, alpha: u64):
    """Rounded rectangle with only top corners rounded (for title bars).

    Bottom edge is flat/square.
    """
    if w == 0 or h == 0:
        return
    var r = radius
    if r > w / 2:
        r = w / 2
    if r > h:
        r = h
    val r2 = r * r

    var row: u64 = 0
    while row < h:
        val py = y + row
        if py >= g_height:
            return

        var x_start: u64 = 0
        var x_end: u64 = w

        if row < r:
            # Top corners only
            val dy = r - row
            var dx: u64 = 0
            while (dx + 1) * (dx + 1) + dy * dy <= r2:
                dx = dx + 1
            x_start = r - dx
            x_end = w - (r - dx)

        var col = x_start
        while col < x_end:
            val px = x + col
            if px >= g_width:
                col = col + 1
                continue
            if alpha >= 255:
                px_write(px, py, 0xFF000000 | (color & 0x00FFFFFF))
            else:
                val dst = px_read(px, py)
                px_write(px, py, alpha_blend(dst, color, alpha))
            col = col + 1
        row = row + 1

# ============================================================================
# Circle
# ============================================================================

fn filled_circle(cx: u64, cy: u64, diameter: u64, color: u64, alpha: u64):
    """Draw a filled circle using scanline rasterization.

    (cx, cy) is the top-left of the bounding box, not the center.
    Diameter is in pixels. Color is 0x00RRGGBB.
    """
    if diameter == 0:
        return
    val r = diameter / 2
    val ox = cx + r       # Center x
    val oy = cy + r       # Center y
    val r2 = r * r

    var row: u64 = 0
    while row < diameter:
        val py = cy + row
        if py >= g_height:
            row = row + 1
            continue

        # Compute dy from center
        var dy_abs: u64 = 0
        if row >= r:
            dy_abs = row - r
        else:
            dy_abs = r - row
        val dy2 = dy_abs * dy_abs
        if dy2 > r2:
            row = row + 1
            continue

        # Compute horizontal span: x^2 + y^2 <= r^2 => x = sqrt(r^2 - y^2)
        var dx: u64 = 0
        while (dx + 1) * (dx + 1) <= r2 - dy2:
            dx = dx + 1

        var x_left: u64 = 0
        if ox > dx:
            x_left = ox - dx
        var x_right = ox + dx
        if x_right >= g_width:
            x_right = g_width - 1

        var px = x_left
        while px <= x_right:
            if alpha >= 255:
                px_write(px, py, 0xFF000000 | (color & 0x00FFFFFF))
            else:
                val dst = px_read(px, py)
                px_write(px, py, alpha_blend(dst, color, alpha))
            px = px + 1
        row = row + 1

# ============================================================================
# Ring (Hollow Circle)
# ============================================================================

fn ring(cx: u64, cy: u64, outer_diameter: u64, thickness: u64, color: u64, alpha: u64):
    """Draw a ring (hollow circle).

    (cx, cy) is the top-left of the bounding box.
    Renders pixels between inner and outer radius.
    """
    if outer_diameter == 0 or thickness == 0:
        return
    val outer_r = outer_diameter / 2
    val inner_r = if outer_r > thickness: outer_r - thickness else: 0
    val outer_r2 = outer_r * outer_r
    val inner_r2 = inner_r * inner_r
    val center_x = cx + outer_r
    val center_y = cy + outer_r

    var row: u64 = 0
    while row < outer_diameter:
        val py = cy + row
        if py >= g_height:
            row = row + 1
            continue

        var dy_abs: u64 = 0
        if row >= outer_r:
            dy_abs = row - outer_r
        else:
            dy_abs = outer_r - row
        val dy2 = dy_abs * dy_abs
        if dy2 > outer_r2:
            row = row + 1
            continue

        # Outer span
        var outer_dx: u64 = 0
        while (outer_dx + 1) * (outer_dx + 1) <= outer_r2 - dy2:
            outer_dx = outer_dx + 1

        # Inner span
        var inner_dx: u64 = 0
        if dy2 < inner_r2:
            while (inner_dx + 1) * (inner_dx + 1) <= inner_r2 - dy2:
                inner_dx = inner_dx + 1

        # Draw left arc segment
        var lx = center_x - outer_dx
        val lx_end = if dy2 < inner_r2: center_x - inner_dx else: center_x + 1
        while lx < lx_end:
            if lx < g_width:
                if alpha >= 255:
                    px_write(lx, py, 0xFF000000 | (color & 0x00FFFFFF))
                else:
                    val dst = px_read(lx, py)
                    px_write(lx, py, alpha_blend(dst, color, alpha))
            lx = lx + 1

        # Draw right arc segment
        var rx = if dy2 < inner_r2: center_x + inner_dx else: center_x
        val rx_end = center_x + outer_dx + 1
        while rx < rx_end:
            if rx < g_width:
                if alpha >= 255:
                    px_write(rx, py, 0xFF000000 | (color & 0x00FFFFFF))
                else:
                    val dst = px_read(rx, py)
                    px_write(rx, py, alpha_blend(dst, color, alpha))
            rx = rx + 1

        row = row + 1

# ============================================================================
# Line (Bresenham)
# ============================================================================

fn line(x0: u64, y0: u64, x1: u64, y1: u64, color: u64, alpha: u64):
    """Draw a line using Bresenham's algorithm.

    Handles all octants. Coordinates are absolute pixel positions.
    Color is 0x00RRGGBB.
    """
    # Compute absolute deltas and direction
    var dx: u64 = 0
    var dy: u64 = 0
    var sx: u64 = 1     # Step x: 1 = right
    var sy: u64 = 1     # Step y: 1 = down
    var x_neg: u64 = 0  # 1 if stepping left
    var y_neg: u64 = 0  # 1 if stepping up

    if x1 >= x0:
        dx = x1 - x0
    else:
        dx = x0 - x1
        x_neg = 1

    if y1 >= y0:
        dy = y1 - y0
    else:
        dy = y0 - y1
        y_neg = 1

    var cx = x0
    var cy = y0

    if dx >= dy:
        # Mostly horizontal
        var err: u64 = dx / 2
        var steps: u64 = 0
        while steps <= dx:
            if cx < g_width and cy < g_height:
                if alpha >= 255:
                    px_write(cx, cy, 0xFF000000 | (color & 0x00FFFFFF))
                else:
                    val dst = px_read(cx, cy)
                    px_write(cx, cy, alpha_blend(dst, color, alpha))

            # Step in x
            if x_neg == 1:
                if cx == 0:
                    return
                cx = cx - 1
            else:
                cx = cx + 1

            # Accumulate error for y
            if dy > err:
                err = err + dx - dy
                if y_neg == 1:
                    if cy == 0:
                        return
                    cy = cy - 1
                else:
                    cy = cy + 1
            else:
                err = err - dy

            steps = steps + 1
    else:
        # Mostly vertical
        var err: u64 = dy / 2
        var steps: u64 = 0
        while steps <= dy:
            if cx < g_width and cy < g_height:
                if alpha >= 255:
                    px_write(cx, cy, 0xFF000000 | (color & 0x00FFFFFF))
                else:
                    val dst = px_read(cx, cy)
                    px_write(cx, cy, alpha_blend(dst, color, alpha))

            # Step in y
            if y_neg == 1:
                if cy == 0:
                    return
                cy = cy - 1
            else:
                cy = cy + 1

            # Accumulate error for x
            if dx > err:
                err = err + dy - dx
                if x_neg == 1:
                    if cx == 0:
                        return
                    cx = cx - 1
                else:
                    cx = cx + 1
            else:
                err = err - dx

            steps = steps + 1

# ============================================================================
# Shadow (Blur + Offset)
# ============================================================================

fn shadow(x: u64, y: u64, w: u64, h: u64, blur_radius: u64, alpha: u64, offset: u64):
    """Draw a drop shadow below/right of a rectangle.

    Renders a dark rectangle offset from the given position, then blurs it.
    Matches the glass_render.c shadow implementation.
    """
    if w == 0 or h == 0:
        return

    # 1.5x stronger shadow alpha (matching C code)
    var sa = alpha * 3 / 2
    if sa > 255:
        sa = 255
    var br = blur_radius
    if br > 45:
        br = 45
    var off = offset
    if off == 0:
        off = 6

    # Shadow position: offset down and right, slightly larger
    val sx = x + off
    val sy = y + off
    var sw = w + off
    var sh = h + off

    # Clamp to screen
    if sx >= g_width or sy >= g_height:
        return
    if sx + sw > g_width:
        sw = g_width - sx
    if sy + sh > g_height:
        sh = g_height - sy

    # Draw dark rectangle
    blend_fill(sx, sy, sw, sh, 0x000000, sa)

    # Blur the shadow
    if br > 0:
        _blur_h(sx, sy, sw, sh, br)
        _blur_v(sx, sy, sw, sh, br)

    # Extra soft outer glow for large blur radii
    if br > 4:
        var ex = sx
        if ex >= 2:
            ex = sx - 2
        else:
            ex = 0
        var ey = sy
        if ey >= 2:
            ey = sy - 2
        else:
            ey = 0
        val ew = sw + 4
        val eh = sh + 4
        val glow_alpha = sa / 4
        if ex + ew <= g_width and ey + eh <= g_height:
            # Top edge glow
            blend_fill(ex, ey, ew, 1, 0x000000, glow_alpha)
            # Bottom edge glow
            val bot = ey + eh - 1
            if bot < g_height:
                blend_fill(ex, bot, ew, 1, 0x000000, glow_alpha)

# ============================================================================
# Noise Texture Blend
# ============================================================================

fn noise_blend(x: u64, y: u64, w: u64, h: u64, intensity: u64):
    """Add subtle noise pattern to glass surfaces (frosted glass grain).

    Uses a pseudo-random hash function applied to ~30% of pixels for
    a subtle effect matching macOS frosted glass.
    """
    if w == 0 or h == 0 or intensity == 0:
        return
    var row: u64 = 0
    while row < h:
        val py = y + row
        if py >= g_height:
            return
        var col: u64 = 0
        while col < w:
            val px = x + col
            if px >= g_width:
                col = col + 1
                continue
            # Simple hash for pseudo-random noise
            var hash = (px * 2654435761) ^ (py * 2246822519)
            hash = ((hash >> 16) ^ hash) * 0x45d9f3b
            hash = (hash >> 16) ^ hash
            # Only apply to ~30% of pixels
            if (hash & 7) < 3:
                val dst = px_read(px, py)
                val noise_color = if (hash >> 8) & 1 == 1: 0x00FFFFFF else: 0x00000000
                px_write(px, py, alpha_blend(dst, noise_color, intensity))
            col = col + 1
        row = row + 1

# ============================================================================
# Border Drawing
# ============================================================================

fn draw_border(x: u64, y: u64, w: u64, h: u64, color: u64, alpha: u64):
    """Draw a 1px semi-transparent border around a rectangle."""
    # Top edge
    blend_fill(x, y, w, 1, color, alpha)
    # Bottom edge
    if h > 1:
        blend_fill(x, y + h - 1, w, 1, color, alpha)
    # Left edge
    blend_fill(x, y, 1, h, color, alpha)
    # Right edge
    if w > 1:
        blend_fill(x + w - 1, y, 1, h, color, alpha)

# ============================================================================
# Convenience: Clear
# ============================================================================

fn render_clear(color: u64):
    """Clear entire shadow buffer to a solid color."""
    val c = 0xFF000000 | (color & 0x00FFFFFF)
    var i: u64 = 0
    val total = g_width * g_height
    while i < total:
        rt_mmio_write_u32(g_shadow_buf + i * 4, (c & 0xFFFFFFFF).to_u32())
        i = i + 1

# ============================================================================
# Blend Pixel (single pixel alpha blend)
# ============================================================================

fn blend_pixel(x: u64, y: u64, color: u64, alpha: u64):
    """Alpha-blend a single pixel."""
    if x >= g_width or y >= g_height:
        return
    val dst = px_read(x, y)
    px_write(x, y, alpha_blend(dst, color, alpha))
