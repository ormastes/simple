# GUI Module — Cross-platform rendering, input, and shortcut handling
#
# Modules:
#   - render.spl      — Pure Simple rendering primitives (shadow buffer, blend, blur, shapes)
#   - input_event.spl — Unified input event types (Key, KeyEvent, MouseEvent, WmAction)
#   - shortcut.spl    — Shared shortcut handler (keyboard → WmAction mapping)

use os.gui.render.{render_init, render_present, blend_fill, solid_fill, gradient_v, gradient_h, box_blur, rounded_rect_aa, filled_circle, ring, line, shadow, alpha_blend, lerp_color}
use os.gui.input_event.{WmAction}
use os.gui.shortcut.{ShortcutHandler, uart_char_to_action}
