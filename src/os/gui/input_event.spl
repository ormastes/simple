# Shared Input Event Types for GUI/WM
#
# Standalone module — no dependencies on platform-specific drivers.
# Defines WmAction enum for shortcut mapping.

# Window manager actions — high-level commands triggered by shortcuts
enum WmAction:
    CycleFocus         # Tab or Alt+Tab
    FocusWindow(idx: u64)   # 1/2/3 or direct focus
    ToggleTheme        # T key
    Minimize           # M or Alt+F5
    Close              # W or Alt+F4
    Restore            # R key
    Quit               # Q key
    None               # No action matched
