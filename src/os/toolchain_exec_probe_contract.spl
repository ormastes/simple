# Serial completion contract for the x64 toolchain EXEC probe.
#
# This lane is distinct from `x64-toolchain-vfs-probe`. The VFS probe proves
# only that Clang/Rust app fixtures are readable and parse as SMF envelopes and
# that a task is *prepared* (spawn:image / spawn:prepared markers). It does NOT
# prove a compiler process actually ran.
#
# The exec probe proves in-guest compiler *operation*: bytes loaded from the
# guest FS, the launched process IS the compiler (not a host shim), it consumes
# an input source file, and it produces a deterministic compile artifact or
# diagnostic. Success is gated on that post-exec observable output — NEVER on a
# returned pid or a `spawn:image` marker (those exist today with no live
# handoff and are exactly the confusion this lane must avoid).
#
# Three terminal states, mutually exclusive:
#   ok      -> `[toolchain-exec] compiler-ran app=clang status=ok ...` + TEST PASSED
#   fail    -> `[toolchain-exec] compiler-ran app=clang status=fail ...` + TEST FAILED
#   blocked -> `[toolchain-exec] blocked: in-guest exec (Phase 1)` (no TEST PASSED)
#
# `blocked` is the honest until-Phase-1 state: it is NOT a pass and NOT a skip.

pub fn toolchain_exec_probe_ok_marker_fragments() -> [text]:
    [
        "[toolchain-exec] storage-ready",
        "[toolchain-exec] clang-present path=/sys/apps/clang bytes=",
        "[toolchain-exec] input-source path=/usr/share/simpleos/toolchain/clang/hello.c bytes=",
        "[toolchain-exec] compile-artifact path=/TMP/HELLO.O bytes=",
        "[toolchain-exec] compiler-ran app=clang status=ok",
        "TEST PASSED"
    ]

pub fn toolchain_exec_probe_blocked_marker_fragments() -> [text]:
    [
        "[toolchain-exec] storage-ready",
        "[toolchain-exec] blocked: in-guest exec (Phase 1)",
        "[toolchain-exec] compiler-ran app=clang status=blocked reason=in-guest-exec-phase1"
    ]

# A lane only PASSES on the ok state. Blocked and fail both return false here.
pub fn toolchain_exec_probe_serial_accepts_completion(serial_output: text) -> bool:
    if serial_output.contains("[toolchain-exec] compiler-ran app=clang status=blocked"):
        return false
    if serial_output.contains("[toolchain-exec] compiler-ran app=clang status=fail"):
        return false
    for marker in toolchain_exec_probe_ok_marker_fragments():
        if not serial_output.contains(marker):
            return false
    true

# Lets the orchestrator tell "blocked on Phase 1" apart from "broken".
pub fn toolchain_exec_probe_serial_is_blocked(serial_output: text) -> bool:
    for marker in toolchain_exec_probe_blocked_marker_fragments():
        if not serial_output.contains(marker):
            return false
    not serial_output.contains("TEST PASSED")

pub fn print_toolchain_exec_probe_missing_markers(serial_output: text):
    if toolchain_exec_probe_serial_is_blocked(serial_output):
        print "[test] toolchain-exec lane is BLOCKED on in-guest exec (Phase 1); not a pass, not a skip"
        return
    for marker in toolchain_exec_probe_ok_marker_fragments():
        if not serial_output.contains(marker):
            print "[test] missing marker fragment: {marker}"
