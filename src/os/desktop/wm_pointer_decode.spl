# WM Pointer Step — Button/Kind Code Decode
#
# Pure decode helpers for the raw PS/2-derived pointer codes that flow from
# `compositor.spl`'s `_handle_input_ps2` / `_ps2_wm_pointer_button_code`
# (bits 0/1/2 of the PS/2 status byte) into the text labels the rest of the
# WM understands. Kept in a standalone module — with no dependency on the
# compositor/launcher/VFS module graph that `shell.spl` pulls in — so this
# pure decode contract can be unit-tested in isolation.
#
# Consumed by:
#   * src/os/desktop/shell.spl — handle_pending_wm_pointer_step

fn wm_pointer_button_from_code(button_code: i32) -> text:
    """Decode a Compositor.pending_wm_pointer_button_code into the button
    label consumed by shared_wm_dispatch_pointer / UIEvent.MouseEvent-style
    callers. Producer: compositor.spl's _handle_input_ps2 via
    _ps2_wm_pointer_button_code (PS/2 status byte bits 0/1/2). Keep this
    mapping in sync with that function: 0 = none, 1 = left, 2 = middle,
    3 = right. Any other code decodes to "none" (unknown-button case)."""
    if button_code == 1:
        return "left"
    if button_code == 2:
        return "middle"
    if button_code == 3:
        return "right"
    return "none"

fn wm_pointer_kind_from_code(kind_code: i32) -> text:
    """Decode a Compositor.pending_wm_pointer_kind_code into the pointer
    event kind. Producer: compositor.spl's _handle_input_ps2. Keep this
    mapping in sync with that function: 0 = none, 1 = down, 2 = up,
    3 = move. Any other code decodes to "none" (unknown-kind case)."""
    if kind_code == 1:
        return "down"
    if kind_code == 2:
        return "up"
    if kind_code == 3:
        return "move"
    return "none"
