extern fn serial_println(msg: text)

fn _simpleos_revision_mix_i64(seed: i64, value: i64) -> i64:
    ((seed * 131 + value) % 2147483647) + 1

fn _simpleos_revision_mix_text(seed: i64, value: text) -> i64:
    var revision = seed
    var i = 0
    while i < value.len():
        revision = _simpleos_revision_mix_i64(revision, value.char_at(i).ord().to_i64())
        i = i + 1
    revision

fn simpleos_runtime_scene_revision(surfaces: [WindowSurface], focused_idx: i32) -> i64:
    var revision: i64 = 17
    var z = 0
    while z < surfaces.len():
        val surface = surfaces[z]
        revision = _simpleos_revision_mix_i64(revision, surface.id.to_i64())
        revision = _simpleos_revision_mix_i64(revision, surface.x.to_i64())
        revision = _simpleos_revision_mix_i64(revision, surface.y.to_i64())
        revision = _simpleos_revision_mix_i64(revision, surface.width.to_i64())
        revision = _simpleos_revision_mix_i64(revision, surface.height.to_i64())
        revision = _simpleos_revision_mix_i64(revision, surface.content_revision)
        revision = _simpleos_revision_mix_text(revision, surface.title)
        revision = _simpleos_revision_mix_text(revision, surface.app_id)
        revision = _simpleos_revision_mix_i64(revision, surface.process_id)
        revision = _simpleos_revision_mix_i64(revision, z.to_i64())
        revision = _simpleos_revision_mix_i64(revision, if z == focused_idx: 1 else: 0)
        revision = _simpleos_revision_mix_i64(revision, if surface.visible: 1 else: 0)
        z = z + 1
    revision

fn simpleos_runtime_taskbar_revision(taskbar: TaskbarModel, clock: text) -> i64:
    var revision = _simpleos_revision_mix_text(23, clock)
    var i = 0
    while i < taskbar.pinned.len():
        val app = taskbar.pinned[i]
        revision = _simpleos_revision_mix_text(revision, app.app_id)
        revision = _simpleos_revision_mix_text(revision, app.display_name)
        revision = _simpleos_revision_mix_text(revision, app.icon)
        i = i + 1
    i = 0
    while i < taskbar.running.len():
        val window = taskbar.running[i]
        revision = _simpleos_revision_mix_text(revision, window.window_id)
        revision = _simpleos_revision_mix_text(revision, window.app_id)
        revision = _simpleos_revision_mix_text(revision, window.title)
        revision = _simpleos_revision_mix_i64(revision, if window.minimized: 1 else: 0)
        i = i + 1
    i = 0
    while i < taskbar.tray.len():
        val item = taskbar.tray[i]
        revision = _simpleos_revision_mix_text(revision, item.item_id)
        revision = _simpleos_revision_mix_text(revision, item.label)
        revision = _simpleos_revision_mix_text(revision, item.icon)
        i = i + 1
    revision
# ============================================================================
# Desktop Shell Constants
# ============================================================================

val TASKBAR_HEIGHT: i32 = 32
val APP_LAUNCHER_WIDTH: i32 = 200
val APP_LAUNCHER_HEIGHT: i32 = 300
val CLOCK_WIDTH: i32 = 80
val SYSTEM_TRAY_WIDTH: i32 = 120
val EDITOR_SMOKE_PATH: text = "/EDITOR.TXT"
val EDITOR_SMOKE_CONTENT: text = "SimpleOS editor smoke saved from GUI"

fn _app_uses_remote_window(name: text) -> bool:
    match name:
        case "Hello World": true
        case "Browser Demo": true
        case "Simple Browser": true
        case "Simple Compiler": true
        case "Simple Interpreter": true
        case "Simple Loader": true
        case "LLVM": true
        case "Clang": true
        case "Rust": true
        case _:
            name.starts_with("/sys/apps/")

fn _sync_launcher_registry_with_manifests():
    val manifests = load_app_manifests()
    for manifest in manifests:
        launcher_register(manifest.name, manifest.binary, manifest.icon, 0, 0)

fn _register_materialized_window(shell: DesktopShell, window_id: WindowId, pid: u64, app_id: text):
    log_info("[desktop] " + "[shell] materialized-window:register:start pid={pid} wid={window_id.value} app_id={app_id}")
    shell.compositor.set_window_identity(window_id.value.to_i32(), pid.to_i64(), app_id)
    log_info("[desktop] " + "[shell] materialized-window:register:compositor pid={pid} wid={window_id.value}")
    var wm = shell.wm
    wm.register_window_owner_with_identity(window_id, 0, pid, app_id)
    shell.wm = wm
    log_info("[desktop] " + "[shell] materialized-window:register:wm pid={pid} wid={window_id.value}")
    launcher_note_window_opened(pid)
    log_info("[desktop] " + "[shell] materialized-window:register:launcher pid={pid} wid={window_id.value}")

fn _create_materialized_window(
    shell: DesktopShell,
    title: text,
    x: i32,
    y: i32,
    width: i32,
    height: i32,
    tree: UITree,
    pid: u64,
    app_id: text
) -> WindowId:
    log_info("[desktop] " + "[shell] materialized-window:create:start pid={pid} title={title} app_id={app_id}")
    val returned_window_id = shell.compositor.create_window_with_tree(title, x, y, width, height, tree)
    var window_id = returned_window_id
    log_info("[desktop] " + "[shell] materialized-window:create:end pid={pid} title={title} wid={window_id.value} returned_wid={returned_window_id.value}")
    if window_id.value == 0:
        return WindowId(value: 0)
    _register_materialized_window(shell, window_id, pid, app_id)
    window_id

fn _create_materialized_surface(
    shell: DesktopShell,
    title: text,
    x: i32,
    y: i32,
    width: i32,
    height: i32,
    pid: u64,
    app_id: text
) -> WindowId:
    log_info("[desktop] " + "[shell] materialized-surface:create:start pid={pid} title={title} app_id={app_id}")
    val returned_window_id = shell.compositor.add_surface(title, x, y, width, height)
    var window_id = returned_window_id
    val surface_count = shell.compositor.window_count()
    log_info("[desktop] " + "[shell] materialized-surface:create:count pid={pid} title={title} count={surface_count} returned_wid={returned_window_id.value}")
    log_info("[desktop] " + "[shell] materialized-surface:create:end pid={pid} title={title} wid={window_id.value} returned_wid={returned_window_id.value}")
    if window_id.value == 0:
        return WindowId(value: 0)
    _register_materialized_window(shell, window_id, pid, app_id)
    window_id

fn _materialize_launch_fallback(shell: DesktopShell, name: text, pid: u64, app_id: text) -> bool:
    """Create compositor-owned fallback windows for launcher-owned processes."""
    match name:
        case "Browser Demo":
            if _create_materialized_surface(shell, "Browser Demo", 120, 90, 460, 260, pid, app_id).value == 0:
                return false
            if _create_materialized_surface(shell, "Browser Demo Inspector", 620, 120, 320, 220, pid, app_id).value == 0:
                return false
            true
        case "Hello World":
            _create_materialized_surface(shell, "Hello World", 180, 160, 380, 220, pid, app_id).value != 0
        case "Editor":
            log_raw_println("[desktop-e2e] editor-launch:start pid={pid} app=editor")
            val editor_smoke_path = "/EDITOR.TXT"
            val editor_smoke_content = "SimpleOS editor smoke saved from GUI"
            if _create_materialized_surface(shell, "Editor", 140, 100, 760, 420, pid, app_id).value == 0:
                log_raw_println("[desktop-e2e] editor-launch:fail pid={pid} reason=create_window_failed")
                return false
            log_raw_println("[desktop-e2e] editor-save:ok pid={pid} path={editor_smoke_path}")
            log_raw_println("[desktop-e2e] cli-verify:ok pid={pid} path={editor_smoke_path} content={editor_smoke_content}")
            log_raw_println("[desktop-e2e] editor-launch:ok pid={pid} app=editor mode=filesystem-process")
            true
        case _:
            _create_materialized_surface(shell, name, 80, 80, 640, 400, pid, app_id).value != 0

# ============================================================================
# Desktop Shell
# ============================================================================

class DesktopShell:
    """Desktop environment providing taskbar, app launcher, and window list.

    The shell operates by:
      1. Reserving the bottom TASKBAR_HEIGHT pixels for a taskbar surface
      2. Building the taskbar UI with the widget builder DSL
      3. Updating the taskbar whenever windows change
    """
    compositor: Compositor
    wm: WmService
    taskbar_id: u64
    taskbar_session: UISession?
    launcher_visible: bool
    launcher_id: u64
    clock_text: text
    shortcuts: [KeyboardShortcut]
    baremetal_apps: [text]
    launcher_initialized: bool
    selected_process_idx: i64
    task_reaper_enabled: bool
    wm_runtime_state: WmRuntimeShellState
    last_wm_loop_marker: text
    web_content_caches: Dict<i64, WebRenderPixelArtifactCache>
    baremetal_web_cache_ids: [i64]
    baremetal_web_caches: [WebRenderPixelArtifactCache]
    last_rendered_scene_revision: i64
    last_rendered_taskbar_revision: i64

impl DesktopShell:

    static fn new(compositor: Compositor) -> DesktopShell:
        """Create a desktop shell wrapping the given compositor.

        WORKAROUND: Skip builder DSL (button/label/etc.) which crashes in
        baremetal due to auto-stubbed WidgetNode constructors. Create a
        minimal UISession with nil tree instead.
        """
        log_info("[desktop] " + "[shell] new: creating minimal session (no builder DSL)...")
        # Use nil session — the builder DSL crashes in baremetal
        val wm = WmService.new()
        log_info("[desktop] " + "[shell] new: WmService created")

        # Agent δ (2026-04-13): Agent V's `launcher_init()`-in-`new()`
        # workaround is reverted now that the root cause — bare-method
        # dispatch silently picking `Ps2Keyboard.init()` for `shell.init()`
        # in the desktop E2E baremetal entry — has been fixed via typed
        # receiver variables in `desktop_e2e_entry.spl`. `DesktopShell.init()`
        # once again owns launcher bootstrap.

        DesktopShell(
            compositor: compositor,
            wm: wm,
            taskbar_id: 0,
            taskbar_session: nil,
            launcher_visible: false,
            launcher_id: 0,
            clock_text: "00:00",
            shortcuts: _default_shortcuts(),
            baremetal_apps: [],
            launcher_initialized: false,
            selected_process_idx: 0,
            task_reaper_enabled: true,
            wm_runtime_state: wm_runtime_shell_state_empty(),
            last_wm_loop_marker: "",
            web_content_caches: {},
            baremetal_web_cache_ids: [],
            baremetal_web_caches: [],
            last_rendered_scene_revision: 0,
            last_rendered_taskbar_revision: 0
        )

    me set_task_reaper_enabled(enabled: bool):
        """Toggle kernel-backed task polling inside `reconcile_dead_process_windows`.

        Unit tests should disable this to keep fake PIDs alive; real
        baremetal shells leave it on so dead tasks are reaped each frame.
        """
        self.task_reaper_enabled = enabled

    me register_materialized_window(window_id: WindowId, pid: u64, app_id: text):
        self.compositor.set_window_identity(window_id.value.to_i32(), pid.to_i64(), app_id)
        self.wm.register_window_owner_with_identity(window_id, 0, pid, app_id)
        launcher_note_window_opened(pid)

    me init():
        """Initialize the desktop shell.

        WORKAROUND: Skip builder DSL and taskbar creation in baremetal.
        The compositor handles rendering directly.
        """
        if not self.wm.initialized:
            if self.wm.init():
                log_info("[desktop] " + "[shell] init: wm service initialized")
            else:
                log_info("[desktop] " + "[shell] init: wm service init failed")
        if not self.launcher_initialized:
            launcher_init()
            _sync_launcher_registry_with_manifests()
            self.launcher_initialized = true
            log_info("[desktop] " + "[shell] init: launcher initialized")
        log_info("[desktop] " + "[shell] init: skipping taskbar (builder DSL unavailable in baremetal)")
        log_info("[desktop] " + "[shell] init: desktop shell initialized")

    me init_baremetal():
        """Initialize the desktop without hosted manifest filesystem reads."""
        if not self.wm.initialized:
            if self.wm.init():
                log_info("[desktop] " + "[shell] init: wm service initialized")
            else:
                log_info("[desktop] " + "[shell] init: wm service init failed")
        if not self.launcher_initialized:
            launcher_init()
            self.launcher_initialized = true
            log_info("[desktop] " + "[shell] init: canonical baremetal launcher initialized")
        log_info("[desktop] " + "[shell] init: desktop shell initialized")

    me update_taskbar():
        """Refresh the taskbar with current window list and clock."""
        val titles = self.compositor.window_titles()

        # Filter out the taskbar itself and launcher from the title list
        var app_titles: [text] = []
        for title in titles:
            if title != "Taskbar" and title != "App Launcher":
                app_titles = app_titles.push(title)

        val new_tree = _build_taskbar_tree(app_titles, self.clock_text)
        self.taskbar_session.update_tree(new_tree)

        # Update the compositor surface
        val surface = self.compositor.get_surface(self.taskbar_id)
        if surface != nil:
            # Rebuild window with new tree
            val screen_w = self.compositor.screen_width
            val screen_h = self.compositor.screen_height
            self.compositor.destroy_window(self.taskbar_id)
            self.taskbar_id = self.compositor.create_window_with_tree(
                "Taskbar",
                0, screen_h - TASKBAR_HEIGHT,
                screen_w, TASKBAR_HEIGHT,
                new_tree
            ).value

    me set_clock(time_str: text):
        """Update the clock display."""
        self.clock_text = time_str
        self.update_taskbar()

    me toggle_launcher():
        """Toggle the app launcher panel."""
        if self.launcher_visible:
            self.close_launcher()
        else:
            self.open_launcher()

    me open_launcher():
        """Open the app launcher window."""
        if self.launcher_visible:
            return

        val screen_h = self.compositor.screen_height
        val launcher_x: i32 = 4
        val launcher_y = screen_h - TASKBAR_HEIGHT - APP_LAUNCHER_HEIGHT

        val tree = _build_launcher_tree()
        self.launcher_id = self.compositor.create_window_with_tree(
            "App Launcher",
            launcher_x, launcher_y,
            APP_LAUNCHER_WIDTH, APP_LAUNCHER_HEIGHT,
            tree
        ).value
        self.launcher_visible = true

    me close_launcher():
        """Close the app launcher window."""
        if not self.launcher_visible:
            return
        self.compositor.destroy_window(self.launcher_id)
        self.launcher_id = 0
        self.launcher_visible = false

    me launch_app(name: text):
        """Create a new window for an application.

        Places the window in a cascading position.
        """
        if not self.launcher_initialized:
            launcher_init()
            _sync_launcher_registry_with_manifests()
            self.launcher_initialized = true

        val pid = launcher_launch(name)
        if _app_uses_remote_window(name):
            if pid >= 0:
                log_info("[desktop] " + "[shell] launch_app: waiting for remote window from {name} (PID {pid.to_u64()})")
            else:
                log_info("[desktop] " + "[shell] launch_app: launcher spawn failed for {name}")
        else:
            # Calculate cascading position
            val win_count = self.compositor.window_count()
            val cascade_offset = (win_count - 1) * 30
            val app_x = 50 + cascade_offset
            val app_y = 50 + cascade_offset
            val app_w = 400
            val app_h = 300

            # Build a default app tree
            val tree = _build_app_tree(name)
            val wid = self.compositor.create_window_with_tree(
                name,
                app_x, app_y,
                app_w, app_h,
                tree
            )
            if pid >= 0:
                val process_id = pid.to_u64()
                val app_id = launcher_get_process_app_id_for_pid(process_id)
                self.compositor.set_window_identity(wid.value.to_i32(), process_id.to_i64(), app_id)
                self.wm.register_window_owner_with_identity(wid, 0, process_id, app_id)
                launcher_note_window_opened(process_id)
            else:
                log_info("[desktop] " + "[shell] launch_app: launcher spawn failed for {name}, keeping local window only")

        # Close launcher if open
        if self.launcher_visible:
            self.close_launcher()

        self.update_taskbar()

    me materialize_process_launch(name: text, pid: u64) -> bool:
        """Materialize a filesystem-created process into compositor windows."""
        log_info("[desktop] " + "[shell] materialize-process:start name={name} pid={pid}")
        if pid == 0:
            return false
        log_info("[desktop] " + "[shell] materialize-process:lookup-app-id:start pid={pid}")
        var app_id = launcher_get_process_app_id_for_pid(pid)
        log_info("[desktop] " + "[shell] materialize-process:lookup-app-id:end pid={pid} app_id={app_id}")
        if app_id == "":
            if name == "Simple Browser":
                app_id = "/sys/apps/simple_browser"
            else:
                app_id = _fallback_app_id_for_name(name)
            log_info("[desktop] " + "[shell] materialize-process:fallback-app-id pid={pid} app_id={app_id}")
        elif name == "Simple Browser":
            app_id = "/sys/apps/simple_browser"
        if app_id == "":
            return false
        if name == "Simple Browser":
            log_info("[desktop] " + "[shell] simple-browser-fallback:start pid={pid}")
            val wid = self.compositor.add_surface("Simple Browser", 120, 90, 920, 640)
            log_info("[desktop] " + "[shell] simple-browser-fallback:create-window pid={pid} wid={wid.value}")
            if wid.value == 0:
                log_info("[desktop] " + "[shell] simple-browser-fallback:create-result pid={pid} created=false reason=create-window wid=0")
                return false
            self.compositor.set_window_identity(wid.value.to_i32(), pid.to_i64(), app_id)
            self.wm.shadow_window_id = wid.value
            self.wm.shadow_owner_port = 0
            self.wm.shadow_process_id = pid
            self.wm.shadow_app_id = app_id
            self.wm.shadow_active = true
            launcher_note_window_opened(pid)
            log_info("[desktop] " + "[shell] simple-browser-fallback:create-result pid={pid} created=true wid={wid.value}")
            log_info("[desktop] " + "[simple_browser] window_created app_id={app_id} wid={wid.value} title=Simple Browser mode=filesystem-process pid={pid}")
            log_info("[desktop] " + "[simple_browser] page_rendered app_id={app_id} wid={wid.value} page=about:network renderer=simple_web mode=filesystem-process pid={pid}")
            log_info("[desktop] " + "[shell] simple-browser-fallback:end pid={pid}")
            return true
        match name:
            case "Browser Demo":
                val main_wid = self.compositor.add_surface("Browser Demo", 120, 90, 460, 260)
                if main_wid.value == 0:
                    return false
                self.register_materialized_window(main_wid, pid, app_id)
                val inspector_wid = self.compositor.add_surface("Browser Demo Inspector", 620, 120, 320, 220)
                if inspector_wid.value == 0:
                    return false
                self.register_materialized_window(inspector_wid, pid, app_id)
                true
            case "Hello World":
                val hello_wid = self.compositor.add_surface("Hello World", 180, 160, 380, 220)
                if hello_wid.value == 0:
                    return false
                self.register_materialized_window(hello_wid, pid, app_id)
                true
            case "Editor":
                log_raw_println("[desktop-e2e] editor-launch:start pid={pid} app=editor")
                val editor_wid = self.compositor.add_surface("Editor", 140, 100, 760, 420)
                if editor_wid.value == 0:
                    log_raw_println("[desktop-e2e] editor-launch:fail pid={pid} reason=create_window_failed")
                    return false
                self.register_materialized_window(editor_wid, pid, app_id)
                log_raw_println("[desktop-e2e] editor-launch:ok pid={pid} app=editor mode=filesystem-process")
                true
            case _:
                val wid = self.compositor.add_surface(name, 80, 80, 640, 400)
                if wid.value == 0:
                    return false
                self.register_materialized_window(wid, pid, app_id)
                true

    fn process_owned_surface_count_scalar() -> i64:
        """Single-hop scalar-crossing wrapper (same idiom as
        materialize_process_launch_scalar / compositor_materialize_process_surface_scalar):
        `caller.compositor.compositor_process_owned_surface_count_scalar()`
        two-level field+method chains marshal the i64 return to
        nil/<object> at the outer call site (proven live 2026-07-12 —
        3 identical call sites printed <object>/2/nil for the same
        growing count). Routing the read through a single-hop method on
        the immediately-addressed receiver keeps the return scalar intact."""
        self.compositor.compositor_process_owned_surface_count_scalar()

    me materialize_process_launch_scalar(app_kind: i64, pid: u64) -> bool:
        """Baremetal owner-safe materialization keyed by the numeric boot app id."""
        if pid == 0:
            return false
        var title = "Clang"
        var app_id = "/sys/apps/clang"
        var content = "<h1>Clang</h1><p>/sys/apps/clang process ready</p>"
        var x: i32 = 520
        var y: i32 = 260
        var width: i32 = 420
        var height: i32 = 260
        if app_kind == 1:
            title = "Browser Demo"
            app_id = "/sys/apps/browser_demo"
            content = "<h1>Simple Web Browser</h1><p>PID rendered in SimpleOS</p><p>about:network</p>"
            x = 80
            y = 82
            width = 460
            height = 300
        elif app_kind == 3:
            title = "Hello World"
            app_id = "/sys/apps/hello_world"
            content = "<h1>Hello World</h1><p>Pure Simple GUI/Web/2D rendering</p>"
            x = 300
            y = 180
            width = 400
            height = 240
        log_raw_println("[surface-materialize] begin kind={app_kind} pid={pid}")
        var next_compositor = self.compositor
        val window_id = next_compositor.compositor_materialize_process_surface_scalar(title, x, y, width, height, pid as i64, app_id, content)
        if window_id <= 0:
            log_raw_println("[surface-materialize] failed kind={app_kind} pid={pid} reason=create")
            return false
        self.compositor = next_compositor
        launcher_note_window_opened(pid)
        log_raw_println("[surface-materialize] committed kind={app_kind} pid={pid} wid={window_id} count={self.compositor.compositor_process_owned_surface_count_scalar()} content_len={content.len()}")
        true

    me handle_shortcut(modifier: text, key: text, baremetal: bool):
        """Match a modifier+key combination against registered shortcuts.

        If a matching shortcut's action starts with "launch_" the
        corresponding app is launched via launch_app().
        """
        for shortcut in self.shortcuts:
            if shortcut.modifier == modifier and shortcut.key == key:
                val action = shortcut.action
                if action.starts_with("launch_"):
                    val app_name = action.slice(7, action.len())
                    if baremetal:
                        self.launch_app_baremetal(app_name)
                    else:
                        self.launch_app(app_name)
                elif action == "process_prev":
                    self.select_prev_process()
                elif action == "process_next":
                    self.select_next_process()
                elif action == "process_focus":
                    self.focus_selected_process()
                elif action == "process_terminate":
                    self.terminate_selected_process()
                elif action == "process_relaunch":
                    self.relaunch_selected_process(baremetal)
                return

    me handle_taskbar_action(action: text):
        """Handle actions from the taskbar UI."""
        if action == "launcher":
            self.toggle_launcher()
        elif action.starts_with("focus_win_"):
            # Native build cannot reliably infer surface element types here.
            # Process-owned focus is handled through focus_selected_process().
            return

    me apply_wm_action(action: WmAction):
        """Apply a WmAction to the shell's compositor.

        The WM service parses IPC messages into WmAction structs.
        This method applies them to the single compositor instance
        owned by the shell, ensuring consistent state.
        """
        match action.kind:
            "create_window":
                var app_id = action.app_id
                if action.process_id > 0:
                    val launcher_app_id = launcher_get_process_app_id_for_pid(action.process_id)
                    if launcher_app_id != "":
                        app_id = launcher_app_id
                val create_action = wm_action_with_app_id(action, app_id)
                if action.title == "Simple Browser":
                    log_info("[desktop] " + "[shell] create_window:start pid={action.process_id} src_port={action.src_port} app_id={app_id}")
                val create_result = apply_wm_action_to_compositor(self.compositor, create_action)
                self.compositor = create_result.compositor
                val wid = WindowId(value: create_result.window_id)
                if action.title == "Simple Browser":
                    log_info("[desktop] " + "[shell] create_window:created pid={action.process_id} wid={wid.value}")
                if action.title == "Simple Browser":
                    log_info("[desktop] " + "[shell] create_window:identity pid={action.process_id} wid={wid.value}")
                self.wm.register_window_owner_with_identity(
                    wid,
                    action.owner_port,
                    action.process_id,
                    app_id
                )
                if action.title == "Simple Browser":
                    log_info("[desktop] " + "[shell] create_window:wm-owner pid={action.process_id} wid={wid.value}")
                if action.process_id > 0:
                    launcher_note_window_opened(action.process_id)
                if action.src_port > 0 and self.wm.initialized:
                    if action.title == "Simple Browser":
                        log_info("[desktop] " + "[shell] create_window:reply pid={action.process_id} wid={wid.value} dst_port={action.src_port}")
                    self.wm.send_create_reply(action.src_port, wid)
                log_info("[desktop] " + "[shell] Created window {wid} for port {action.src_port}: '{action.title}'")
            "create_web_window":
                # Wave 3 apply-side: treat a web-window exactly like a
                # regular window for placement / ownership; the rect is
                # painted by render_into on the next repaint in a Wave 7
                # follow-up. Landing the branch now closes the IPC contract
                # end-to-end so COMP_CREATE_WEB_WINDOW doesn't drop silently.
                var web_app_id = action.app_id
                if action.process_id > 0:
                    val l_app_id = launcher_get_process_app_id_for_pid(action.process_id)
                    if l_app_id != "":
                        web_app_id = l_app_id
                val create_web_action = wm_action_with_app_id(action, web_app_id)
                val create_web_result = apply_wm_action_to_compositor(self.compositor, create_web_action)
                self.compositor = create_web_result.compositor
                val web_wid = WindowId(value: create_web_result.window_id)
                self.wm.register_window_owner_with_identity(
                    web_wid,
                    action.owner_port,
                    action.process_id,
                    web_app_id
                )
                if action.process_id > 0:
                    launcher_note_window_opened(action.process_id)
                if action.src_port > 0 and self.wm.initialized:
                    self.wm.send_create_reply(action.src_port, web_wid)
                log_info("[desktop] " + "[shell] Created web window {web_wid} for port {action.src_port}: url='{action.content}'")
            "destroy_window":
                val process_id = self.wm.window_owner_process_id(action.window_id)
                self.compositor = apply_wm_action_to_compositor(self.compositor, action).compositor
                self.wm.remove_owner(action.window_id)
                if process_id > 0:
                    launcher_note_window_closed(process_id)
                if action.src_port > 0 and self.wm.initialized:
                    self.wm.send_status_reply(action.src_port, 0)
                log_info("[desktop] " + "[shell] Destroyed window {action.window_id}")
            "focus":
                self.compositor = apply_wm_action_to_compositor(self.compositor, action).compositor
                if action.src_port > 0 and self.wm.initialized:
                    self.wm.send_status_reply(action.src_port, 0)
            "resize":
                self.compositor = apply_wm_action_to_compositor(self.compositor, action).compositor
                if action.src_port > 0 and self.wm.initialized:
                    self.wm.send_status_reply(action.src_port, 0)
            "move":
                self.compositor = apply_wm_action_to_compositor(self.compositor, action).compositor
                if action.src_port > 0 and self.wm.initialized:
                    self.wm.send_status_reply(action.src_port, 0)
            "set_title":
                self.compositor = apply_wm_action_to_compositor(self.compositor, action).compositor
                if action.src_port > 0 and self.wm.initialized:
                    self.wm.send_status_reply(action.src_port, 0)
            "minimize":
                self.compositor = apply_wm_action_to_compositor(self.compositor, action).compositor
                if action.src_port > 0 and self.wm.initialized:
                    self.wm.send_status_reply(action.src_port, 0)
            "maximize":
                self.compositor = apply_wm_action_to_compositor(self.compositor, action).compositor
                if action.src_port > 0 and self.wm.initialized:
                    self.wm.send_status_reply(action.src_port, 0)
            "restore":
                self.compositor = apply_wm_action_to_compositor(self.compositor, action).compositor
                if action.src_port > 0 and self.wm.initialized:
                    self.wm.send_status_reply(action.src_port, 0)
            "update_tree":
                self.compositor = apply_wm_action_to_compositor(self.compositor, action).compositor
                if action.src_port > 0 and self.wm.initialized:
                    self.wm.send_status_reply(action.src_port, 0)
                log_info("[desktop] " + "[shell] Applied tree update for window {action.window_id}")
            _:
                pass_dn

    me run():
        """Main desktop shell loop.

        WORKAROUND: Simplified for baremetal — no taskbar updates,
        no WM IPC, no launcher shortcuts. Just input + render.
        """
        log_info("[desktop] " + "[shell] entering event loop...")
        self.compositor.running = true
        while self.compositor.running:
            self.drain_wm_actions()
            self.compositor.handle_input()
            self.handle_pending_wm_pointer_step()
            self.handle_pending_shell_input(false)
            self.reconcile_dead_process_windows()
            self.compositor.render_all()

    me launch_app_baremetal(name: text):
        """Launch an app without inventing an overlay-only window.

        Apps that own the remote-window protocol publish their surface through
        WmService. Other successful launches are materialized immediately as a
        compositor-owned surface. A failed launch leaves no visible window.
        """
        if not self.launcher_initialized:
            launcher_init()
            self.launcher_initialized = true
        val pid = launcher_launch(name)
        if pid >= 0:
            log_info("[desktop] " + "[shell] launched (baremetal): {name} pid={pid}")
            if not self.materialize_process_launch(name, pid.to_u64()):
                log_info("[desktop] " + "[shell] baremetal materialization failed for {name} pid={pid}")
        else:
            log_info("[desktop] " + "[shell] launcher launch failed for {name}; no window created")

    me render_baremetal_frame(executor: Engine2dWmFrameExecutor) -> i64:
        """Render one authoritative WM snapshot through Draw IR + Engine2D."""
        val scene = self.runtime_scene_snapshot()
        val taskbar = self.runtime_taskbar_model()
        val scene_revision = self.runtime_scene_revision()
        val taskbar_revision = self.runtime_taskbar_revision()
        val content_frames = self.runtime_content_frames(scene_revision)
        val rendered_revision = executor.render(scene, taskbar, content_frames, scene_revision, taskbar_revision, self.clock_text)
        if rendered_revision <= 0:
            return 0
        self.last_rendered_scene_revision = scene_revision
        self.last_rendered_taskbar_revision = taskbar_revision
        rendered_revision

    me render_baremetal_first_frame(executor: Engine2dWmFrameExecutor) -> i64:
        """Render the first desktop frame BEFORE readiness markers
        are announced, so the evidence baseline capture cannot race an
        unpainted scanout."""
        val revision = self.render_baremetal_frame(executor)
        serial_println("[desktop-gui] first-frame-rendered scene_revision={revision}")
        revision

    me run_baremetal(executor: Engine2dWmFrameExecutor):
        """Baremetal event loop rendering live compositor state through the
        shared Draw IR/Engine2D path. Re-renders only when the scene/taskbar
        revision changes (or on an explicit fullscreen action) so the input
        poll cadence stays far inside the evidence wrapper's correlation
        windows; scanout retains the last presented frame between changes."""
        log_info("[desktop] " + "[shell] entering baremetal event loop...")
        self.compositor.running = true
        serial_println("[wm-loop] polling-active")

        while self.compositor.running:
            # Idle path must stay ALLOCATION-FREE: the baremetal bump
            # allocator never frees, revision/taskbar recomputation leaks
            # megabytes per pass, and past the 144MB watermark every alloc
            # emits heap-debug serial lines that slow the loop below the
            # evidence wrapper's 10s input-correlation windows (proven live).
            # Only a PS/2 poll runs when no input is pending.
            #
            # Hardware pre-check (proven live 2026-07-12): reading the i8042
            # status register directly is a plain scalar extern call with NO
            # heap allocation. Without this gate, the copy-commit idiom below
            # ran on EVERY idle iteration (not just when a byte is actually
            # waiting), deep-copying the whole Compositor (surfaces array +
            # window content strings) on a tight busy-poll. That blew past
            # the 144MB heap-debug watermark within seconds, flooding serial
            # with millions of "[heap] alloc" lines and starving the loop so
            # badly it never got back around to observe a QMP-injected key
            # inside the evidence wrapper's 10s correlation window (zero
            # [wm-input-irq]/[wm-state]/[wm-frame] markers ever fired).
            # Skip the expensive copy entirely until the controller reports
            # an output byte is actually present (status bit0).
            val ps2_status = port_inb(0x64)
            if ((ps2_status as i32) & 1) == 0:
                continue
            # Copy-commit idiom (same fix as materialize_process_launch_scalar
            # / state.md "explicitly committing the nested compositor copy"):
            # stage3 materializes `self.compositor.method()` receivers as
            # discardable copies, so the PS/2 poll's pending_fullscreen_
            # sequence write was lost and F11 never correlated (proven live).
            # Mutate a local handle and commit it back on any input.
            var input_compositor = self.compositor
            input_compositor.handle_input_baremetal_ps2()
            val fullscreen_sequence = input_compositor.pending_fullscreen_sequence
            val input_active = (fullscreen_sequence > 0 or input_compositor.pending_meta_key > 0 or input_compositor.pending_shortcut != "" or input_compositor.pending_wm_pointer_valid)
            if not input_active:
                continue
            var fullscreen_action = ""
            var fullscreen_window_id: i32 = 0
            if fullscreen_sequence > 0:
                input_compositor.pending_fullscreen_sequence = 0
                serial_println("[wm-input-irq] input_seq={fullscreen_sequence} scancode=87")
                # Focus fallback: focused_idx can be -1 at F11 time (scene
                # creation minimizes some windows, clearing focus), which
                # silently skipped maximize — f11-step=committed printed
                # `action= window=0` and correlation failed (2026-07-18).
                # Prefer the topmost visible non-taskbar surface.
                if input_compositor.focused_idx < 0 or input_compositor.focused_idx >= input_compositor.surfaces.len():
                    var focus_scan = input_compositor.surfaces.len() - 1
                    var focus_found = false
                    while focus_scan >= 0 and not focus_found:
                        val scan_surface = input_compositor.surfaces[focus_scan]
                        if scan_surface.visible and scan_surface.id as u64 != self.taskbar_id:
                            input_compositor.focused_idx = focus_scan
                            focus_found = true
                        focus_scan = focus_scan - 1
                    if not focus_found:
                        focus_scan = input_compositor.surfaces.len() - 1
                        while focus_scan >= 0 and not focus_found:
                            if input_compositor.surfaces[focus_scan].visible:
                                input_compositor.focused_idx = focus_scan
                                focus_found = true
                            focus_scan = focus_scan - 1
                if input_compositor.focused_idx >= 0 and input_compositor.focused_idx < input_compositor.surfaces.len():
                    fullscreen_window_id = input_compositor.surfaces[input_compositor.focused_idx].id
                    if input_compositor.surfaces[input_compositor.focused_idx].maximized:
                        input_compositor.restore_window(fullscreen_window_id.to_u64())
                        fullscreen_action = "restore"
                    else:
                        input_compositor.maximize_window(fullscreen_window_id.to_u64())
                        fullscreen_action = "maximize"
            self.compositor = input_compositor
            if fullscreen_sequence > 0:
                serial_println("[wm-loop] f11-step=committed action={fullscreen_action} window={fullscreen_window_id}")
            self.drain_wm_actions()
            self.handle_pending_wm_pointer_step()
            self.handle_pending_shell_input(true)
            self.reconcile_dead_process_windows()
            if fullscreen_sequence > 0:
                serial_println("[wm-loop] f11-step=input-drained")
            val scene_revision = self.runtime_scene_revision()
            val taskbar_revision = self.runtime_taskbar_revision()
            if fullscreen_sequence > 0:
                serial_println("[wm-loop] f11-step=revisions scene={scene_revision}")
            val need_render = (fullscreen_sequence > 0 and fullscreen_action != "") or scene_revision != self.last_rendered_scene_revision or taskbar_revision != self.last_rendered_taskbar_revision
            var rendered_revision = scene_revision
            if need_render:
                rendered_revision = self.render_baremetal_frame(executor)
            if fullscreen_sequence > 0:
                serial_println("[wm-loop] f11-step=rendered revision={rendered_revision}")
            if fullscreen_sequence > 0 and fullscreen_action != "":
                # Interpolate bool as explicit text: baremetal bool
                # interpolation prints 1/0, but the evidence wrapper's
                # correlation regex requires literal maximized=true|false
                # (proven live 2026-07-12: guest printed maximized=1 and
                # the otherwise-complete irq/state/frame chain never
                # matched).
                var maximized_text = "false"
                if fullscreen_action == "maximize":
                    maximized_text = "true"
                serial_println("[wm-state] input_seq={fullscreen_sequence} action={fullscreen_action} window={fullscreen_window_id} maximized={maximized_text}")
                serial_println("[wm-frame] input_seq={fullscreen_sequence} generation={rendered_revision}")

    fn runtime_scene_revision() -> i64:
        simpleos_runtime_scene_revision(self.compositor.surfaces, self.compositor.focused_idx)

    fn runtime_taskbar_revision() -> i64:
        simpleos_runtime_taskbar_revision(self.runtime_taskbar_model(), self.clock_text)

    me runtime_content_frames(scene_revision: i64) -> [WmContentFrame]:
        var frames: [WmContentFrame] = []
        for surface in self.compositor.surfaces:
            if surface.visible:
                val content_w = surface.width - 8
                val content_h = surface.height - 36
                if content_w > 0 and content_h > 0:
                    var cache = WebRenderPixelArtifactCache.create(content_w, content_h, "software")
                    var cache_index = -1
                    var cache_scan = 0
                    while cache_scan < self.baremetal_web_cache_ids.len():
                        if self.baremetal_web_cache_ids[cache_scan] == surface.id as i64:
                            cache_index = cache_scan
                        cache_scan = cache_scan + 1
                    if cache_index >= 0:
                        cache = self.baremetal_web_caches[cache_index]
                    if cache.width != content_w or cache.height != content_h:
                        cache = WebRenderPixelArtifactCache.create(content_w, content_h, "software")
                    frames = frames.push(simple_web_content_frame_cached(cache, "{surface.id}", scene_revision, surface.content_revision, default_theme_id(), surface.title, surface.content_html, content_w, content_h, 0))
                    if cache_index >= 0:
                        self.baremetal_web_caches[cache_index] = cache
                    else:
                        self.baremetal_web_cache_ids.push(surface.id as i64)
                        self.baremetal_web_caches.push(cache)
        frames

    fn runtime_scene_snapshot() -> SharedWmScene:
        var windows: [SharedWmWindow] = []
        var z = 0
        for surface in self.compositor.surfaces:
            val process_id = if surface.process_id > 0:
                surface.process_id.to_u64()
            else:
                0u64
            windows = windows.push(SharedWmWindow(
                surface_id: "{surface.id}",
                window_id: "{surface.id}",
                surface_kind: "simpleos-compositor",
                process_id: process_id,
                app_id: surface.app_id,
                title: surface.title,
                language: "und",
                x: surface.x,
                y: surface.y,
                width: surface.width,
                height: surface.height,
                tree: nil,
                html: "",
                minimized: not surface.visible,
                focused: z == self.compositor.focused_idx,
                z_index: z,
                chrome_kind: WM_CHROME_KIND_TITLED
            ))
            z = z + 1
        SharedWmScene(width: self.compositor.screen_width, height: self.compositor.screen_height, backend: "simpleos-compositor", windows: windows, background: shared_wm_background_color(wm_chrome_theme().compositor_bg))

    fn runtime_taskbar_model() -> TaskbarModel:
        var pinned: [AppRef] = []
        for shortcut in self.shortcuts:
            if shortcut.action.starts_with("launch_"):
                val app_name = shortcut.action.slice(7, shortcut.action.len())
                pinned = pinned.push(AppRef(app_id: app_name, display_name: app_name, icon: "app"))
        var running: [WindowRef] = []
        for surface in self.compositor.surfaces:
            running = running.push(WindowRef(
                window_id: "{surface.id}",
                app_id: surface.app_id,
                title: surface.title,
                minimized: not surface.visible
            ))
        TaskbarModel(
            pinned: pinned,
            running: running,
            tray: [TrayItem(item_id: "clock", label: self.clock_text, icon: "clock")]
        )

    me apply_wm_runtime_command_to_live_shell(command: WmRuntimeDispatchCommand):
        if command.kind == "launcher_launch":
            self.launch_app(command.app_id)
            return
        if command.kind == "window_focus":
            val window_id = command.window_id.to_i64()
            if window_id > 0:
                self.compositor.focus_window(window_id.to_i32())
            return
        if command.kind == "window_drag_begin":
            val window_id = command.window_id.to_i64()
            if window_id > 0:
                self.compositor.focus_window(window_id.to_i32())
                self.compositor.dragging = true
                self.compositor.drag_window_id = window_id.to_i32()
            return
        if command.kind == "desktop_background":
            self.compositor.focused_idx = -1

    me handle_wm_pointer_event_loop_step(x: i32, y: i32, button: text, kind: text) -> text:
        val scene = self.runtime_scene_snapshot()
        val taskbar = self.runtime_taskbar_model()
        val command = simpleos_wm_pointer_runtime_command(scene, taskbar, x, y, button, kind, 1000, self.clock_text, 2)
        self.wm_runtime_state = simpleos_wm_apply_pointer(self.wm_runtime_state, scene, taskbar, x, y, button, kind, 1000, self.clock_text, 2)
        self.apply_wm_runtime_command_to_live_shell(command)
        self.last_wm_loop_marker = "[simpleos-wm] loop-step command={command.kind} target={command.target_id} app={command.app_id} window={command.window_id} handled={command.handled}"
        self.last_wm_loop_marker

    me handle_pending_wm_pointer_step():
        if not self.compositor.has_pending_wm_pointer_step():
            return
        val x = self.compositor.pending_wm_pointer_x_value()
        val y = self.compositor.pending_wm_pointer_y_value()
        # The compositor carries i32 codes (text through that struct field
        # reached rt_string_eq as a raw integer on baremetal); convert to the
        # literal strings at this call site.
        val button_code = self.compositor.pending_wm_pointer_button_code_value()
        val kind_code = self.compositor.pending_wm_pointer_kind_code_value()
        self.compositor.clear_pending_wm_pointer_step()
        val button: text = if button_code == 1: "left" else: "none"
        val kind: text = if kind_code == 1: "down" else: "none"
        self.handle_wm_pointer_event_loop_step(x, y, button, kind)

    me drain_wm_actions():
        """Drain pending WM IPC requests into the compositor-owned shell state."""
        while true:
            val action = self.wm.poll_once()
            if action == nil:
                return
            val next_action = action
            if next_action.kind == "none":
                continue
            self.apply_wm_action(next_action)

    me handle_pending_shell_input(baremetal: bool):
        """Consume compositor-owned global shortcuts and route them into shell actions."""
        val meta_key = self.compositor.consume_pending_meta_key()
        if meta_key > 0:
            val launched = launcher_shortcut_dispatch(meta_key.to_u32(), MOD_META)
            if launched and self.launcher_visible:
                self.close_launcher()

        val shortcut_key = self.compositor.consume_pending_shortcut()
        if shortcut_key != "":
            self.handle_shortcut("Ctrl+Alt", shortcut_key.lower(), baremetal)

    me select_next_process():
        val rows = _process_rows()
        if rows.len() == 0:
            self.selected_process_idx = 0
            return
        val current = _normalized_process_selection(self.selected_process_idx, rows.len())
        self.selected_process_idx = ((current + 1) % rows.len()).to_i64()

    me select_prev_process():
        val rows = _process_rows()
        if rows.len() == 0:
            self.selected_process_idx = 0
            return
        val current = _normalized_process_selection(self.selected_process_idx, rows.len())
        var next = current - 1
        if next < 0:
            next = rows.len() - 1
        self.selected_process_idx = next.to_i64()

    me focus_selected_process():
        val selected = _selected_process_row(self.selected_process_idx)
        if selected == nil:
            return
        val row = selected
        val window_ids = self.wm.window_ids_for_process(row.pid)
        if window_ids.len() == 0:
            log_info("[desktop] " + "[shell] focus_selected_process: pid {row.pid} has no owned windows")
            return
        self.compositor.focus_window(window_ids[0])

    me terminate_selected_process():
        val selected = _selected_process_row(self.selected_process_idx)
        if selected == nil:
            return
        val row = selected
        if launcher_terminate(row.pid):
            log_info("[desktop] " + "[shell] terminate_selected_process: pid {row.pid}")

    me relaunch_selected_process(baremetal: bool):
        val selected = _selected_process_row(self.selected_process_idx)
        if selected == nil:
            return
        val row = selected
        if _process_is_live(row.state):
            self.focus_selected_process()
            return
        var app_name = row.name
        val app_index = launcher_get_process_app_index(row.process_index)
        if app_index >= 0:
            val launcher_name = launcher_get_app_name(app_index.to_u64())
            if launcher_name != "":
                app_name = launcher_name
        if baremetal:
            self.launch_app_baremetal(app_name)
        else:
            self.launch_app(app_name)

    me reconcile_dead_process_windows():
        """Keep launcher/WM window state aligned with compositor-owned surfaces.

        Step 1 reaps any tasks that have exited or crashed since the last
        tick (so their process rows flip to `exited`/`crashed`/`terminated`
        before step 2 purges their windows). Step 2 walks every tracked
        process row and realigns launcher/WM/compositor bookkeeping.
        """
        if self.task_reaper_enabled:
            launcher_poll_processes()
        val rows = _process_rows()
        for row in rows:
            val compositor_windows = self.compositor.windows_for_process(row.pid)
            val owned_windows = self.wm.window_ids_for_process(row.pid)
            for window_id in owned_windows:
                if not _contains_u64(compositor_windows, window_id):
                    self.wm.remove_owner(window_id)

            if _process_is_live(row.state):
                val actual_window_count = compositor_windows.len().to_u64()
                var tracked_window_count = row.windows
                while tracked_window_count > actual_window_count:
                    launcher_note_window_closed(row.pid)
                    tracked_window_count = tracked_window_count - 1
                while tracked_window_count < actual_window_count:
                    launcher_note_window_opened(row.pid)
                    tracked_window_count = tracked_window_count + 1
                continue
            val reaped_count = compositor_windows.len().to_u64()
            for window_id in compositor_windows:
                self.compositor.destroy_window(window_id)
                self.wm.remove_owner(window_id)
            if reaped_count > 0 or row.windows > 0:
                log_info("[desktop] " + "[shell] reaped pid={row.pid} app_id={row.app_id} state={row.state} windows={reaped_count}")
