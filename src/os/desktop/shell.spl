# Desktop Shell
#
# The SimpleOS desktop environment built on the existing widget builder DSL.
# Provides a taskbar (window list, clock, system tray), an app launcher,
# and integration with the compositor for window management.
#
# The taskbar is itself a special compositor surface pinned to the bottom
# of the screen.

use common.ui.widget.{WidgetNode, UITree, UIState, UIEvent}
use common.ui.session.{UISession, new_session}
use common.ui.builder.{
    column, row, panel, text_widget, button, label, statusbar,
    build_tree, build_tree_with_title, with_height, with_width, with_flex
}
use os.compositor.compositor.{Compositor, WindowSurface}
use os.drivers.framebuffer.fb_driver.{Color}
use os.desktop.app_manifest.{AppManifest, load_app_manifests, search_apps}
use os.services.wm.wm_service.{WmService, WmAction}
use os.services.launcher.launcher.{launcher_shortcut_dispatch}

extern fn serial_println(msg: text)

use os.apps.calculator.calculator.{Calculator}
use os.apps.clock.clock.{ClockApp}
use os.apps.terminal.terminal.{Terminal}
use os.apps.hello_world.hello_world.{HelloWorldApp}
use os.apps.browser_demo.browser_demo.{BrowserDemoApp}
use os.apps.editor.editor.{TextEditor}
use os.apps.memo.memo.{MemoApp}
use os.apps.paint.paint.{PaintApp}
use os.apps.file_manager.file_manager.{FileManager}
use os.apps.file_explorer.file_explorer.{FileExplorer}
use os.apps.image_viewer.image_viewer.{ImageViewer}
use os.apps.calendar.calendar.{CalendarApp}
use os.apps.system_monitor.system_monitor.{SystemMonitor}
use os.apps.disk_manager.disk_manager.{DiskManager}
use os.apps.screenshot.screenshot.{ScreenshotApp}
