# ============================================================================
# Desktop Shell Constants
# ============================================================================

val TASKBAR_HEIGHT: i32 = 32
val APP_LAUNCHER_WIDTH: i32 = 200
val APP_LAUNCHER_HEIGHT: i32 = 300
val CLOCK_WIDTH: i32 = 80
val SYSTEM_TRAY_WIDTH: i32 = 120
val APP_ID_BROWSER_DEMO: text = "/sys/apps/browser_demo"
val APP_ID_HELLO_WORLD: text = "/sys/apps/hello_world"
val APP_ID_FILE_MANAGER: text = "/sys/apps/file_manager"
val APP_ID_SHELL: text = "/sys/apps/shell"
val APP_ID_EDITOR: text = "/sys/apps/editor"
val APP_ID_SIMPLE_BROWSER: text = "/sys/apps/simple_browser"
val EDITOR_SMOKE_PATH: text = "/EDITOR.TXT"
val EDITOR_SMOKE_CONTENT: text = "SimpleOS editor smoke saved from GUI"
struct EditorResidentLaunch:
    tree: UITree
    saved_path: text
    content: text

fn _build_editor_resident_launch() -> Result<EditorResidentLaunch, text>:
    val editor_smoke_path = "/EDITOR.TXT"
    val editor_smoke_content = "SimpleOS editor smoke saved from GUI"
    var editor = TextEditor.new()
    editor.lines = [editor_smoke_content]
    editor.file_path = editor_smoke_path
    noalloc_log_debug("editor resident launch write path={editor_smoke_path}")
    val wrote = rt_file_write_text(editor_smoke_path, editor_smoke_content)
    editor.modified = false
    if not wrote:
        noalloc_log_debug("editor resident launch using preview fallback path={editor_smoke_path}")
        editor.status_message = "Preview {editor_smoke_path} (disk unavailable)"
        val preview_session = editor.build_ui()
        return Ok(EditorResidentLaunch(
            tree: preview_session.current_tree(),
            saved_path: editor_smoke_path,
            content: editor_smoke_content
        ))
    editor.status_message = "Saved {editor_smoke_path}"

    val cli_output = g_vfs_read_file_text(editor_smoke_path)
    if cli_output != editor_smoke_content:
        noalloc_log_debug("editor resident launch using preview readback path={editor_smoke_path}")
        editor.status_message = "Preview {editor_smoke_path} (readback unavailable)"
        val preview_session = editor.build_ui()
        return Ok(EditorResidentLaunch(
            tree: preview_session.current_tree(),
            saved_path: editor_smoke_path,
            content: editor_smoke_content
        ))
    noalloc_log_debug("editor resident launch readback ok path={editor_smoke_path}")

    val session = editor.build_ui()
    Ok(EditorResidentLaunch(
        tree: session.current_tree(),
        saved_path: editor_smoke_path,
        content: cli_output
    ))

fn _register_materialized_window(shell: DesktopShell, window_id: WindowId, pid: u64, app_id: text):
    log_info("[desktop] " + "[shell] materialized-window:register:start pid={pid} wid={window_id.value} app_id={app_id}")
    shell.compositor.set_window_identity(window_id, ProcessId(value: pid), AppId(value: app_id))
    log_info("[desktop] " + "[shell] materialized-window:register:compositor pid={pid} wid={window_id.value}")
    var wm = shell.wm
    wm.register_window_owner_with_identity(window_id, 0, pid, app_id)
    shell.wm = wm
    log_info("[desktop] " + "[shell] materialized-window:register:wm pid={pid} wid={window_id.value}")
    launcher_note_window_opened(pid)
    log_info("[desktop] " + "[shell] materialized-window:register:launcher pid={pid} wid={window_id.value}")

fn _create_materialized_window(
    shell: DesktopShell,
    title: text,
    x: i32,
    y: i32,
    width: i32,
    height: i32,
    tree: UITree,
    pid: u64,
    app_id: text
) -> WindowId:
    log_info("[desktop] " + "[shell] materialized-window:create:start pid={pid} title={title} app_id={app_id}")
    val returned_window_id = shell.compositor.create_window_with_tree(title, x, y, width, height, tree)
    var window_id = returned_window_id
    if shell.compositor.surfaces.len() > 0:
        val created_surface = shell.compositor.surfaces[shell.compositor.surfaces.len() - 1]
        if created_surface.title == title:
            window_id = created_surface.id
    log_info("[desktop] " + "[shell] materialized-window:create:end pid={pid} title={title} wid={window_id.value} returned_wid={returned_window_id.value}")
    if window_id.value == 0:
        return WindowId(value: 0)
    _register_materialized_window(shell, window_id, pid, app_id)
    window_id

fn _create_materialized_surface(
    shell: DesktopShell,
    title: text,
    x: i32,
    y: i32,
    width: i32,
    height: i32,
    pid: u64,
    app_id: text
) -> WindowId:
    log_info("[desktop] " + "[shell] materialized-surface:create:start pid={pid} title={title} app_id={app_id}")
    val returned_window_id = shell.compositor.add_surface(title, x, y, width, height)
    var window_id = returned_window_id
    val surface_count = shell.compositor.window_count()
    log_info("[desktop] " + "[shell] materialized-surface:create:count pid={pid} title={title} count={surface_count} returned_wid={returned_window_id.value}")
    if surface_count > 0:
        val surface = shell.compositor.get_surface(returned_window_id)
        if surface != nil:
            val created_surface = surface
            window_id = created_surface.id
    log_info("[desktop] " + "[shell] materialized-surface:create:end pid={pid} title={title} wid={window_id.value} returned_wid={returned_window_id.value}")
    if window_id.value == 0:
        return WindowId(value: 0)
    _register_materialized_window(shell, window_id, pid, app_id)
    window_id

fn _fallback_app_id_for_name(name: text) -> text:
    match name:
        case "Browser Demo": APP_ID_BROWSER_DEMO
        case "Hello World": APP_ID_HELLO_WORLD
        case "File Manager": APP_ID_FILE_MANAGER
        case "Terminal": APP_ID_SHELL
        case "Editor": APP_ID_EDITOR
        case "Simple Browser": APP_ID_SIMPLE_BROWSER
        case _:
            ""

fn _materialize_launch_fallback(shell: DesktopShell, name: text, pid: u64, app_id: text) -> bool:
    """Create compositor-owned fallback windows for launcher-owned processes."""
    match name:
        case "Browser Demo":
            val main_tree = build_tree_with_title(column("browser_demo_resident_main", [
                text_widget("browser_demo_title", "Browser Demo"),
                text_widget("browser_demo_body", "filesystem process launch")
            ]), "Browser Demo", "dark")
            val inspector_tree = build_tree_with_title(column("browser_demo_resident_inspector", [
                text_widget("browser_demo_inspector_title", "Browser Demo Inspector"),
                text_widget("browser_demo_inspector_body", "filesystem process")
            ]), "Browser Demo Inspector", "dark")
            if _create_materialized_window(shell, "Browser Demo", 120, 90, 460, 260, main_tree, pid, app_id).value == 0:
                return false
            if _create_materialized_window(
                shell, "Browser Demo Inspector", 620, 120, 320, 220, inspector_tree, pid, app_id).value == 0:
                return false
            true
        case "Hello World":
            val hello_tree = build_tree_with_title(column("hello_resident_main", [
                text_widget("hello_resident_title", "Hello World"),
                text_widget("hello_resident_body", "filesystem process launch")
            ]), "Hello World", "dark")
            _create_materialized_window(shell, "Hello World", 180, 160, 380, 220, hello_tree, pid, app_id).value != 0
        case "Editor":
            log_raw_println("[desktop-e2e] editor-launch:start pid={pid} app=editor")
            val editor_smoke_path = "/EDITOR.TXT"
            val editor_smoke_content = "SimpleOS editor smoke saved from GUI"
            val editor_tree = build_tree_with_title(column("editor_resident_main", [
                text_widget("editor_resident_title", "Editor"),
                text_widget("editor_resident_path", editor_smoke_path),
                text_widget("editor_resident_body", editor_smoke_content)
            ]), "Editor", "dark")
            if _create_materialized_window(shell, "Editor", 140, 100, 760, 420, editor_tree, pid, app_id).value == 0:
                log_raw_println("[desktop-e2e] editor-launch:fail pid={pid} reason=create_window_failed")
                return false
            log_raw_println("[desktop-e2e] editor-save:ok pid={pid} path={editor_smoke_path}")
            log_raw_println("[desktop-e2e] cli-verify:ok pid={pid} path={editor_smoke_path} content={editor_smoke_content}")
            log_raw_println("[desktop-e2e] editor-launch:ok pid={pid} app=editor mode=filesystem-process")
            true
        case _:
            val tree = _build_app_tree(name)
            _create_materialized_window(shell, name, 80, 80, 640, 400, tree, pid, app_id).value != 0

# ============================================================================
# Keyboard Shortcut
# ============================================================================

struct KeyboardShortcut:
    """A global keyboard shortcut binding."""
    modifier: text      # e.g. "Ctrl+Alt"
    key: text           # e.g. "h", "t"
    action: text        # e.g. "launch_Hello World"

struct ShellProcessRow:
    """Read-only shell projection of launcher-owned process state."""
    process_index: u64
    name: text
    pid: u64
    state: text
    windows: u64
    headless: bool
    app_id: text

# ============================================================================
# Desktop Shell
# ============================================================================

class DesktopShell:
    """Desktop environment providing taskbar, app launcher, and window list.

    The shell operates by:
      1. Reserving the bottom TASKBAR_HEIGHT pixels for a taskbar surface
      2. Building the taskbar UI with the widget builder DSL
      3. Updating the taskbar whenever windows change
    """
    compositor: Compositor
    wm: WmService
    taskbar_id: u64
    taskbar_session: UISession?
    launcher_visible: bool
    launcher_id: u64
    clock_text: text
    shortcuts: [KeyboardShortcut]
    baremetal_apps: [text]
    launcher_initialized: bool
    selected_process_idx: i64
    task_reaper_enabled: bool

impl DesktopShell:

    static fn new(compositor: Compositor) -> DesktopShell:
        """Create a desktop shell wrapping the given compositor.

        WORKAROUND: Skip builder DSL (button/label/etc.) which crashes in
        baremetal due to auto-stubbed WidgetNode constructors. Create a
        minimal UISession with nil tree instead.
        """
        log_info("[desktop] " + "[shell] new: creating minimal session (no builder DSL)...")
        # Use nil session — the builder DSL crashes in baremetal
        val wm = WmService.new()
        log_info("[desktop] " + "[shell] new: WmService created")

        # Agent δ (2026-04-13): Agent V's `launcher_init()`-in-`new()`
        # workaround is reverted now that the root cause — bare-method
        # dispatch silently picking `Ps2Keyboard.init()` for `shell.init()`
        # in the desktop E2E baremetal entry — has been fixed via typed
        # receiver variables in `desktop_e2e_entry.spl`. `DesktopShell.init()`
        # once again owns launcher bootstrap.

        DesktopShell(
            compositor: compositor,
            wm: wm,
            taskbar_id: 0,
            taskbar_session: nil,
            launcher_visible: false,
            launcher_id: 0,
            clock_text: "00:00",
            shortcuts: _default_shortcuts(),
            baremetal_apps: [],
            launcher_initialized: false,
            selected_process_idx: 0,
            task_reaper_enabled: true
        )

    me set_task_reaper_enabled(enabled: bool):
        """Toggle kernel-backed task polling inside `reconcile_dead_process_windows`.

        Unit tests should disable this to keep fake PIDs alive; real
        baremetal shells leave it on so dead tasks are reaped each frame.
        """
        self.task_reaper_enabled = enabled

    me init():
        """Initialize the desktop shell.

        WORKAROUND: Skip builder DSL and taskbar creation in baremetal.
        The compositor handles rendering directly.
        """
        if not self.wm.initialized:
            if self.wm.init():
                log_info("[desktop] " + "[shell] init: wm service initialized")
            else:
                log_info("[desktop] " + "[shell] init: wm service init failed")
        if not self.launcher_initialized:
            launcher_init()
            _sync_launcher_registry_with_manifests()
            self.launcher_initialized = true
            log_info("[desktop] " + "[shell] init: launcher initialized")
        log_info("[desktop] " + "[shell] init: skipping taskbar (builder DSL unavailable in baremetal)")
        log_info("[desktop] " + "[shell] init: desktop shell initialized")

    me update_taskbar():
        """Refresh the taskbar with current window list and clock."""
        val titles = self.compositor.window_titles()

        # Filter out the taskbar itself and launcher from the title list
        var app_titles: [text] = []
        for title in titles:
            if title != "Taskbar" and title != "App Launcher":
                app_titles = app_titles.push(title)

        val new_tree = _build_taskbar_tree(app_titles, self.clock_text)
        self.taskbar_session.update_tree(new_tree)

        # Update the compositor surface
        val surface = self.compositor.get_surface(self.taskbar_id)
        if surface != nil:
            # Rebuild window with new tree
            val screen_w = self.compositor.screen_width
            val screen_h = self.compositor.screen_height
            self.compositor.destroy_window(self.taskbar_id)
            self.taskbar_id = self.compositor.create_window_with_tree(
                "Taskbar",
                0, screen_h - TASKBAR_HEIGHT,
                screen_w, TASKBAR_HEIGHT,
                new_tree
            )

    me set_clock(time_str: text):
        """Update the clock display."""
        self.clock_text = time_str
        self.update_taskbar()

    me toggle_launcher():
        """Toggle the app launcher panel."""
        if self.launcher_visible:
            self.close_launcher()
        else:
            self.open_launcher()

    me open_launcher():
        """Open the app launcher window."""
        if self.launcher_visible:
            return

        val screen_h = self.compositor.screen_height
        val launcher_x: i32 = 4
        val launcher_y = screen_h - TASKBAR_HEIGHT - APP_LAUNCHER_HEIGHT

        val tree = _build_launcher_tree()
        self.launcher_id = self.compositor.create_window_with_tree(
            "App Launcher",
            launcher_x, launcher_y,
            APP_LAUNCHER_WIDTH, APP_LAUNCHER_HEIGHT,
            tree
        )
        self.launcher_visible = true

    me close_launcher():
        """Close the app launcher window."""
        if not self.launcher_visible:
            return
        self.compositor.destroy_window(self.launcher_id)
        self.launcher_id = 0
        self.launcher_visible = false

    me launch_app(name: text):
        """Create a new window for an application.

        Places the window in a cascading position.
        """
        if not self.launcher_initialized:
            launcher_init()
            _sync_launcher_registry_with_manifests()
            self.launcher_initialized = true

        val pid = launcher_launch(name)
        if _app_uses_remote_window(name):
            if pid >= 0:
                log_info("[desktop] " + "[shell] launch_app: waiting for remote window from {name} (PID {pid.to_u64()})")
            else:
                log_info("[desktop] " + "[shell] launch_app: launcher spawn failed for {name}")
        else:
            # Calculate cascading position
            val win_count = self.compositor.window_count()
            val cascade_offset = (win_count - 1) * 30
            val app_x = 50 + cascade_offset
            val app_y = 50 + cascade_offset
            val app_w = 400
            val app_h = 300

            # Build a default app tree
            val tree = _build_app_tree(name)
            val wid = self.compositor.create_window_with_tree(
                name,
                app_x, app_y,
                app_w, app_h,
                tree
            )
            if pid >= 0:
                val process_id = pid.to_u64()
                val app_id = launcher_get_process_app_id_for_pid(process_id)
                self.compositor.set_window_identity(wid, process_id, app_id)
                self.wm.register_window_owner_with_identity(wid, 0, process_id, app_id)
                launcher_note_window_opened(process_id)
            else:
                log_info("[desktop] " + "[shell] launch_app: launcher spawn failed for {name}, keeping local window only")

        # Close launcher if open
        if self.launcher_visible:
            self.close_launcher()

        self.update_taskbar()

    me materialize_process_launch(name: text, pid: u64) -> bool:
        """Materialize a filesystem-created process into compositor windows."""
        log_info("[desktop] " + "[shell] materialize-process:start name={name} pid={pid}")
        if pid == 0:
            return false
        log_info("[desktop] " + "[shell] materialize-process:lookup-app-id:start pid={pid}")
        var app_id = launcher_get_process_app_id_for_pid(pid)
        log_info("[desktop] " + "[shell] materialize-process:lookup-app-id:end pid={pid} app_id={app_id}")
        if app_id == "":
            if name == "Simple Browser":
                app_id = "/sys/apps/simple_browser"
            else:
                app_id = _fallback_app_id_for_name(name)
            log_info("[desktop] " + "[shell] materialize-process:fallback-app-id pid={pid} app_id={app_id}")
        if app_id == "":
            return false
        if name == "Simple Browser":
            log_info("[desktop] " + "[shell] simple-browser-fallback:start pid={pid}")
            val browser_tree = build_tree_with_title(column("simple_browser_resident_main", [
                text_widget("simple_browser_title", "Simple Browser"),
                text_widget("simple_browser_url", "about:network"),
                text_widget("simple_browser_renderer", "renderer=simple_web mode=filesystem-process")
            ]), "Simple Browser", "dark")
            val wid = self.compositor.create_window_with_tree("Simple Browser", 120, 90, 920, 640, browser_tree)
            log_info("[desktop] " + "[shell] simple-browser-fallback:create-window pid={pid} wid={wid.value}")
            if wid.value == 0:
                log_info("[desktop] " + "[shell] simple-browser-fallback:create-result pid={pid} created=false reason=create-window wid=0")
                return false
            self.compositor.set_window_identity(wid, ProcessId(value: pid), AppId(value: app_id))
            self.wm.shadow_window_id = wid.value
            self.wm.shadow_owner_port = 0
            self.wm.shadow_process_id = pid
            self.wm.shadow_app_id = app_id
            self.wm.shadow_active = true
            launcher_note_window_opened(pid)
            log_info("[desktop] " + "[shell] simple-browser-fallback:create-result pid={pid} created=true wid={wid.value}")
            log_info("[desktop] " + "[simple_browser] window_created app_id={app_id} wid={wid.value} title=Simple Browser mode=filesystem-process pid={pid}")
            log_info("[desktop] " + "[simple_browser] page_rendered app_id={app_id} wid={wid.value} page=about:network renderer=simple_web mode=filesystem-process pid={pid}")
            log_info("[desktop] " + "[shell] simple-browser-fallback:end pid={pid}")
            return true
        _materialize_launch_fallback(self, name, pid, app_id)

    me handle_shortcut(modifier: text, key: text, baremetal: bool):
        """Match a modifier+key combination against registered shortcuts.

        If a matching shortcut's action starts with "launch_" the
        corresponding app is launched via launch_app().
        """
        for shortcut in self.shortcuts:
            if shortcut.modifier == modifier and shortcut.key == key:
                val action = shortcut.action
                if action.starts_with("launch_"):
                    val app_name = action.slice(7, action.len())
                    if baremetal:
                        self.launch_app_baremetal(app_name)
                    else:
                        self.launch_app(app_name)
                elif action == "process_prev":
                    self.select_prev_process()
                elif action == "process_next":
                    self.select_next_process()
                elif action == "process_focus":
                    self.focus_selected_process()
                elif action == "process_terminate":
                    self.terminate_selected_process()
                elif action == "process_relaunch":
                    self.relaunch_selected_process(baremetal)
                return

    me handle_taskbar_action(action: text):
        """Handle actions from the taskbar UI."""
        if action == "launcher":
            self.toggle_launcher()
        elif action.starts_with("focus_win_"):
            # Focus the window by title
            val title = action.slice(10, action.len())
            # Find window with matching title
            var idx: i32 = 0
            for s in self.compositor.surfaces:
                if s.title == title:
                    self.compositor.focus_window(s.id)
                    return
                idx = idx + 1

    me apply_wm_action(action: WmAction):
        """Apply a WmAction to the shell's compositor.

        The WM service parses IPC messages into WmAction structs.
        This method applies them to the single compositor instance
        owned by the shell, ensuring consistent state.
        """
        match action.kind:
            "create_window":
                var app_id = action.app_id
                if action.process_id > 0:
                    val launcher_app_id = launcher_get_process_app_id_for_pid(action.process_id)
                    if launcher_app_id != "":
                        app_id = launcher_app_id
                if action.title == "Simple Browser":
                    log_info("[desktop] " + "[shell] create_window:start pid={action.process_id} src_port={action.src_port} app_id={app_id}")
                val wid = self.compositor.create_remote_window(
                    action.title, action.x, action.y,
                    action.width, action.height, action.owner_port)
                if action.title == "Simple Browser":
                    log_info("[desktop] " + "[shell] create_window:created pid={action.process_id} wid={wid.value}")
                # Preserve launcher/WM identity at the shell boundary.
                self.compositor.set_window_identity(wid, action.process_id, app_id)
                if action.title == "Simple Browser":
                    log_info("[desktop] " + "[shell] create_window:identity pid={action.process_id} wid={wid.value}")
                self.wm.register_window_owner_with_identity(
                    wid,
                    action.owner_port,
                    action.process_id,
                    app_id
                )
                if action.title == "Simple Browser":
                    log_info("[desktop] " + "[shell] create_window:wm-owner pid={action.process_id} wid={wid.value}")
                if action.process_id > 0:
                    launcher_note_window_opened(action.process_id)
                if action.src_port > 0:
                    if action.title == "Simple Browser":
                        log_info("[desktop] " + "[shell] create_window:reply pid={action.process_id} wid={wid.value} dst_port={action.src_port}")
                    self.wm.send_create_reply(action.src_port, wid)
                log_info("[desktop] " + "[shell] Created window {wid} for port {action.src_port}: '{action.title}'")
            "create_web_window":
                # Wave 3 apply-side: treat a web-window exactly like a
                # regular window for placement / ownership; the rect is
                # painted by render_into on the next repaint in a Wave 7
                # follow-up. Landing the branch now closes the IPC contract
                # end-to-end so COMP_CREATE_WEB_WINDOW doesn't drop silently.
                var web_app_id = action.app_id
                if action.process_id > 0:
                    val l_app_id = launcher_get_process_app_id_for_pid(action.process_id)
                    if l_app_id != "":
                        web_app_id = l_app_id
                val web_wid = self.compositor.create_remote_window(
                    action.title, action.x, action.y,
                    action.width, action.height, action.owner_port)
                self.compositor.set_window_identity(web_wid, action.process_id, web_app_id)
                self.wm.register_window_owner_with_identity(
                    web_wid,
                    action.owner_port,
                    action.process_id,
                    web_app_id
                )
                if action.process_id > 0:
                    launcher_note_window_opened(action.process_id)
                if action.src_port > 0:
                    self.wm.send_create_reply(action.src_port, web_wid)
                log_info("[desktop] " + "[shell] Created web window {web_wid} for port {action.src_port}: url='{action.content}'")
            "destroy_window":
                val process_id = self.wm.window_owner_process_id(action.window_id)
                self.compositor.destroy_window(action.window_id)
                self.wm.remove_owner(action.window_id)
                if process_id > 0:
                    launcher_note_window_closed(process_id)
                self.wm.send_status_reply(action.src_port, 0)
                log_info("[desktop] " + "[shell] Destroyed window {action.window_id}")
            "focus":
                self.compositor.focus_window(action.window_id)
                self.wm.send_status_reply(action.src_port, 0)
            "resize":
                self.compositor.resize_window(action.window_id, action.width, action.height)
                self.wm.send_status_reply(action.src_port, 0)
            "move":
                self.compositor.move_window(action.window_id, action.x, action.y)
                self.wm.send_status_reply(action.src_port, 0)
            "set_title":
                self.compositor.set_window_title(action.window_id, action.title)
                self.wm.send_status_reply(action.src_port, 0)
            "minimize":
                self.compositor.minimize_window(action.window_id)
                self.wm.send_status_reply(action.src_port, 0)
            "maximize":
                self.compositor.maximize_window(action.window_id)
                self.wm.send_status_reply(action.src_port, 0)
            "restore":
                self.compositor.restore_window(action.window_id)
                self.wm.send_status_reply(action.src_port, 0)
            "update_tree":
                val tree = _build_remote_tree(action.window_id, action.content)
                self.compositor.update_window_tree(action.window_id, tree)
                self.wm.send_status_reply(action.src_port, 0)
                log_info("[desktop] " + "[shell] Applied tree update for window {action.window_id}")
            _:
                pass_dn

    me run():
        """Main desktop shell loop.

        WORKAROUND: Simplified for baremetal — no taskbar updates,
        no WM IPC, no launcher shortcuts. Just input + render.
        """
        log_info("[desktop] " + "[shell] entering event loop...")
        self.compositor.running = true
        while self.compositor.running:
            self.drain_wm_actions()
            self.compositor.handle_input()
            self.handle_pending_shell_input(false)
            self.reconcile_dead_process_windows()
            self.compositor.render_all()

    me launch_app_baremetal(name: text):
        """Baremetal-safe app launch: record the app name so the
        direct-render overlay draws a fake window for it.

        The widget builder DSL crashes in baremetal (WidgetNode.new
        is auto-stubbed), so we bypass it entirely.
        """
        if not self.launcher_initialized:
            launcher_init()
            _sync_launcher_registry_with_manifests()
            self.launcher_initialized = true
        val pid = launcher_launch(name)
        if pid >= 0:
            log_info("[desktop] " + "[shell] launched (baremetal): {name} pid={pid}")
        else:
            log_info("[desktop] " + "[shell] launcher launch failed for {name}, keeping overlay-only window")
        if not _contains_text(self.baremetal_apps, name):
            self.baremetal_apps = self.baremetal_apps.push(name)

    me run_baremetal(engine: Engine2D):
        """Baremetal event loop with direct Engine2D overlay.

        Draws the taskbar, app launcher grid, and any launched app
        windows directly through Engine2D — no compositor surfaces,
        no widget tree, no builder DSL. The compositor still polls
        input so Esc/Alt-F4 continue to work.
        """
        log_info("[desktop] " + "[shell] entering baremetal event loop...")
        self.compositor.running = true
        val screen_w = self.compositor.screen_width
        val screen_h = self.compositor.screen_height

        while self.compositor.running:
            self.drain_wm_actions()
            self.compositor.handle_input()
            self.handle_pending_shell_input(true)
            self.reconcile_dead_process_windows()
            val visible_apps = _window_overlay_rows()
            self.baremetal_apps = visible_apps
            val process_rows = _process_panel_rows()
            # Clear desktop — dark blue background, matches the
            # Engine2D verification scene in gui_entry_engine2d.
            engine.clear(0xFF0A2540)
            _draw_baremetal_overlay(
                engine,
                visible_apps,
                process_rows,
                self.selected_process_idx,
                screen_w,
                screen_h,
                self.clock_text
            )
            engine.present()

    me drain_wm_actions():
        """Drain pending WM IPC requests into the compositor-owned shell state."""
        while true:
            val action = self.wm.poll_once()
            if action == nil:
                return
            val next_action = action
            if next_action.kind == "none":
                continue
            self.apply_wm_action(next_action)

    me handle_pending_shell_input(baremetal: bool):
        """Consume compositor-owned global shortcuts and route them into shell actions."""
        val meta_key = self.compositor.consume_pending_meta_key()
        if meta_key > 0:
            val launched = launcher_shortcut_dispatch(meta_key.to_u32(), MOD_META)
            if launched and self.launcher_visible:
                self.close_launcher()

        val shortcut_key = self.compositor.consume_pending_shortcut()
        if shortcut_key != "":
            self.handle_shortcut("Ctrl+Alt", shortcut_key.lower(), baremetal)

    me select_next_process():
        val rows = _process_rows()
        if rows.len() == 0:
            self.selected_process_idx = 0
            return
        val current = _normalized_process_selection(self.selected_process_idx, rows.len())
        self.selected_process_idx = ((current + 1) % rows.len()).to_i64()

    me select_prev_process():
        val rows = _process_rows()
        if rows.len() == 0:
            self.selected_process_idx = 0
            return
        val current = _normalized_process_selection(self.selected_process_idx, rows.len())
        var next = current - 1
        if next < 0:
            next = rows.len() - 1
        self.selected_process_idx = next.to_i64()

    me focus_selected_process():
        val selected = _selected_process_row(self.selected_process_idx)
        if selected == nil:
            return
        val row = selected
        val window_ids = self.wm.window_ids_for_process(row.pid)
        if window_ids.len() == 0:
            log_info("[desktop] " + "[shell] focus_selected_process: pid {row.pid} has no owned windows")
            return
        self.compositor.focus_window(window_ids[0])

    me terminate_selected_process():
        val selected = _selected_process_row(self.selected_process_idx)
        if selected == nil:
            return
        val row = selected
        if launcher_terminate(row.pid):
            log_info("[desktop] " + "[shell] terminate_selected_process: pid {row.pid}")

    me relaunch_selected_process(baremetal: bool):
        val selected = _selected_process_row(self.selected_process_idx)
        if selected == nil:
            return
        val row = selected
        if _process_is_live(row.state):
            self.focus_selected_process()
            return
        var app_name = row.name
        val app_index = launcher_get_process_app_index(row.process_index)
        if app_index >= 0:
            val launcher_name = launcher_get_app_name(app_index.to_u64())
            if launcher_name != "":
                app_name = launcher_name
        if baremetal:
            self.launch_app_baremetal(app_name)
        else:
            self.launch_app(app_name)

    me reconcile_dead_process_windows():
        """Keep launcher/WM window state aligned with compositor-owned surfaces.

        Step 1 reaps any tasks that have exited or crashed since the last
        tick (so their process rows flip to `exited`/`crashed`/`terminated`
        before step 2 purges their windows). Step 2 walks every tracked
        process row and realigns launcher/WM/compositor bookkeeping.
        """
        if self.task_reaper_enabled:
            launcher_poll_processes()
        val rows = _process_rows()
        for row in rows:
            val compositor_windows = self.compositor.windows_for_process(row.pid)
            val owned_windows = self.wm.window_ids_for_process(row.pid)
            for window_id in owned_windows:
                if not _contains_u64(compositor_windows, window_id):
                    self.wm.remove_owner(window_id)

            if _process_is_live(row.state):
                val actual_window_count = compositor_windows.len().to_u64()
                var tracked_window_count = row.windows
                while tracked_window_count > actual_window_count:
                    launcher_note_window_closed(row.pid)
                    tracked_window_count = tracked_window_count - 1
                while tracked_window_count < actual_window_count:
                    launcher_note_window_opened(row.pid)
                    tracked_window_count = tracked_window_count + 1
                continue
            val reaped_count = compositor_windows.len().to_u64()
            for window_id in compositor_windows:
                self.compositor.destroy_window(window_id)
                self.wm.remove_owner(window_id)
            if reaped_count > 0 or row.windows > 0:
                log_info("[desktop] " + "[shell] reaped pid={row.pid} app_id={row.app_id} state={row.state} windows={reaped_count}")

# ============================================================================
# Baremetal Overlay (direct Engine2D, no WidgetNode DSL)
# ============================================================================

fn _draw_baremetal_overlay(
    engine: Engine2D,
    apps: [text],
    process_rows: [text],
    selected_process_idx: i64,
    screen_w: i32,
    screen_h: i32,
    clock: text
):
    """Draw the taskbar, launcher grid, and launched-app windows directly
    via Engine2D. Bypasses the widget builder DSL that crashes in baremetal.

    Layout:
      - Top: title banner
      - Middle: launcher grid with each app as a colored tile
      - Bottom: taskbar with clock and list of running apps
    """
    # --- Title banner ---
    engine.draw_rect_filled(0, 0, screen_w, 28, 0xFF1E1E2E)
    engine.draw_text(12, 6, "SimpleOS Desktop", 0xFFFFFFFF, 14)

    # --- Launcher grid (4 apps per row) ---
    val grid_x0: i32 = 40
    val grid_y0: i32 = 60
    val tile_w: i32 = 140
    val tile_h: i32 = 60
    val gap: i32 = 16

    val demo_apps = load_app_manifests()

    var idx: i32 = 0
    for manifest in demo_apps:
        val col = idx % 4
        val row_i = idx / 4
        val tx = grid_x0 + col * (tile_w + gap)
        val ty = grid_y0 + row_i * (tile_h + gap)
        # Tile body + accent header
        engine.draw_rect_filled(tx, ty, tile_w, tile_h, 0xFF2E2E3E)
        engine.draw_rect_filled(tx, ty, tile_w, 18, 0xFF3498DB)
        engine.draw_text(tx + 8, ty + 2, manifest.name, 0xFFFFFFFF, 12)
        engine.draw_text(tx + 8, ty + 26, manifest.icon, 0xFF8BD3FF, 12)
        engine.draw_text(tx + 28, ty + 26, manifest.category, 0xFFB8D8D8, 11)
        idx = idx + 1
        if idx >= 12:
            break

    # --- Launched app "windows" (stacked cascading) ---
    val win_w: i32 = 280
    val win_h: i32 = 160
    var win_idx: i32 = 0
    for name in apps:
        val wx = 260 + win_idx * 20
        val wy = 220 + win_idx * 24
        # Drop shadow
        engine.draw_rect_filled(wx + 4, wy + 4, win_w, win_h, 0xFF000000)
        # Body
        engine.draw_rect_filled(wx, wy, win_w, win_h, 0xFF1E1E2E)
        # Title bar
        engine.draw_rect_filled(wx, wy, win_w, 22, 0xFFE74C3C)
        engine.draw_text(wx + 8, wy + 4, name, 0xFFFFFFFF, 12)
        engine.draw_text(wx + 12, wy + 36, "Welcome to {name}", 0xFFCCCCCC, 12)
        win_idx = win_idx + 1

    # --- Process panel (all launched processes, including headless) ---
    val panel_w: i32 = 250
    val panel_x = screen_w - panel_w - 20
    val panel_y: i32 = 60
    val panel_h = screen_h - panel_y - 60
    engine.draw_rect_filled(panel_x, panel_y, panel_w, panel_h, 0xFF182430)
    engine.draw_rect_filled(panel_x, panel_y, panel_w, 22, 0xFF16A085)
    engine.draw_text(panel_x + 8, panel_y + 4, "Process Manager", 0xFFFFFFFF, 12)
    engine.draw_text(panel_x + 12, panel_y + 30, "all launched processes", 0xFFB8D8D8, 11)
    var row_y = panel_y + 52
    var proc_idx: u64 = 0
    while proc_idx < process_rows.len() and proc_idx < 8:
        val row_color = if proc_idx.to_i64() == selected_process_idx: 0xFF2E5266 else: 0xFF22313F
        engine.draw_rect_filled(panel_x + 10, row_y, panel_w - 20, 26, row_color)
        engine.draw_text(panel_x + 16, row_y + 6, process_rows[proc_idx], 0xFFFFFFFF, 11)
        row_y = row_y + 32
        proc_idx = proc_idx + 1
    if process_rows.len() == 0:
        engine.draw_text(panel_x + 12, panel_y + 60, "no running processes", 0xFF9AA5B1, 11)
    else:
        engine.draw_text(panel_x + 12, panel_h + panel_y - 34, "Ctrl+Alt J/K select  F focus", 0xFF9AA5B1, 10)
        engine.draw_text(panel_x + 12, panel_h + panel_y - 20, "Ctrl+Alt X terminate  R relaunch", 0xFF9AA5B1, 10)

    # --- Taskbar at the bottom ---
    val tb_h: i32 = 32
    val tb_y = screen_h - tb_h
    engine.draw_rect_filled(0, tb_y, screen_w, tb_h, 0xFF1E1E2E)
    engine.draw_rect_filled(0, tb_y, 60, tb_h, 0xFF3498DB)
    engine.draw_text(10, tb_y + 8, "Apps", 0xFFFFFFFF, 14)

    # Running-app labels after the launcher button
    var tb_x: i32 = 70
    for name in apps:
        engine.draw_rect_filled(tb_x, tb_y + 4, 110, tb_h - 8, 0xFF2E2E3E)
        engine.draw_text(tb_x + 6, tb_y + 8, name, 0xFFFFFFFF, 12)
        tb_x = tb_x + 118

    # Clock on the right
    val clock_x = screen_w - 80
    engine.draw_text(clock_x, tb_y + 8, clock, 0xFFFFFFFF, 14)

fn _contains_text(items: [text], value: text) -> bool:
    for item in items:
        if item == value:
            return true
    false

fn _contains_u64(items: [u64], value: u64) -> bool:
    for item in items:
        if item == value:
            return true
    false

fn _process_panel_rows() -> [text]:
    """Public shell view over launcher-owned process state.

    MDSOC boundary:
    - launcher layer owns process truth
    - shell layer consumes read-only query helpers and renders them
    """
    var rows: [text] = []
    for row in _process_rows():
        val headless_tag = if row.headless: " headless" else: ""
        rows = rows.push("{row.name} pid {row.pid} {row.state} w{row.windows}{headless_tag}")
    rows

fn _window_overlay_rows() -> [text]:
    """Visible top-level app windows for the baremetal demo overlay.

    The shell still draws simplified demo windows directly, but the list is
    derived from launcher process/window state rather than a second registry.
    """
    var rows: [text] = []
    for row in _process_rows():
        if row.windows > 0:
            rows = rows.push(row.name)
    rows

# ============================================================================
# Taskbar Builder
# ============================================================================

fn _build_taskbar_tree(window_titles: [text], clock: text) -> UITree:
    """Build the taskbar widget tree.

    Layout: [App Button | Window List ... | Clock | System Tray]
    """
    # App launcher button
    log_info("[desktop] " + "[taskbar] creating launcher button...")
    var launcher_btn = button("taskbar_launcher", "Apps", "launcher")
    log_info("[desktop] " + "[taskbar] launcher button created, setting width...")
    launcher_btn = with_width(launcher_btn, 60)
    log_info("[desktop] " + "[taskbar] launcher button width set")

    # Window list buttons
    var window_buttons: [WidgetNode] = []
    var win_idx: i32 = 0
    for title in window_titles:
        var win_btn = button("taskbar_win_{win_idx}", title, "focus_win_{title}")
        win_btn = with_flex(win_btn, 1)
        window_buttons = window_buttons.push(win_btn)
        win_idx = win_idx + 1

    # Window list container
    var window_list_children: [WidgetNode] = []
    for btn in window_buttons:
        window_list_children = window_list_children.push(btn)
    var window_list = row("taskbar_window_list", window_list_children)
    window_list = with_flex(window_list, 1)

    # Clock
    var clock_label = label("taskbar_clock", clock)
    clock_label = with_width(clock_label, CLOCK_WIDTH)

    # System tray
    var tray = row("taskbar_tray", [
        label("taskbar_tray_cpu", "CPU"),
        label("taskbar_tray_mem", "MEM")
    ])
    tray = with_width(tray, SYSTEM_TRAY_WIDTH)

    # Assemble taskbar
    val taskbar_row = row("taskbar_root", [
        launcher_btn,
        window_list,
        clock_label,
        tray
    ])

    build_tree_with_title(taskbar_row, "SimpleOS Taskbar", "dark")

# ============================================================================
# App Launcher Builder
# ============================================================================

fn _build_launcher_tree() -> UITree:
    """Build the app launcher widget tree from app manifests."""
    # Load app manifests dynamically
    val manifests = load_app_manifests()

    var app_buttons: [WidgetNode] = []
    app_buttons = app_buttons.push(label("launcher_title", "Applications"))

    # Group by category
    val categories = manifest_categories(manifests)
    for category in categories:
        var cat_apps: [AppManifest] = []
        for m in manifests:
            if m.category == category:
                cat_apps = cat_apps.push(m)
        if cat_apps.len() > 0:
            app_buttons = app_buttons.push(label("launcher_cat_{category}", "-- {category} --"))
            for app in cat_apps:
                val action = "launch_{app.name}"
                app_buttons = app_buttons.push(
                    button("launcher_app_{app.name}", "{app.icon} {app.name}", action)
                )

    val root = column("launcher_root", app_buttons)
    build_tree_with_title(root, "App Launcher", "dark")

# ============================================================================
# Default App Tree Builder
# ============================================================================

fn _build_app_tree(name: text) -> UITree:
    """Build a widget tree for an application window.

    Dispatches to real app builders for known apps, falls back
    to a placeholder for unregistered ones.
    """
    match name:
        "Simple Browser":
            return build_tree_with_title(column("simple_browser_root", [
                text_widget("simple_browser_page", "about:network"),
                text_widget("simple_browser_status", "filesystem process launch")
            ]), "Simple Browser", "dark")
        "Calculator":
            val calc = Calculator.new()
            val session = calc.build_ui()
            return session.current_tree()
        "Clock":
            val clock = ClockApp.new()
            val session = clock.build_ui()
            return session.current_tree()
        "Terminal":
            val term = Terminal.new(80, 24)
            val session = term.build_ui()
            return session.current_tree()
        "Hello World":
            val app = HelloWorldApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Browser Demo":
            val app = BrowserDemoApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Editor":
            val app = TextEditor.new()
            val session = app.build_ui()
            return session.current_tree()
        "Memo":
            val app = MemoApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Paint":
            val app = PaintApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "File Manager":
            val app = FileManager.new("/")
            val session = app.build_ui()
            return session.current_tree()
        "File Explorer":
            val app = FileExplorer.new("/")
            val session = app.build_ui()
            return session.current_tree()
        "Image Viewer":
            val app = ImageViewer.new()
            val session = app.build_ui()
            return session.current_tree()
        "Calendar":
            val app = CalendarApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "System Monitor":
            val app = SystemMonitor.new()
            val session = app.build_ui()
            return session.current_tree()
        "Disk Manager":
            val app = DiskManager.new()
            val session = app.build_ui()
            return session.current_tree()
        "Screenshot":
            val app = ScreenshotApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Settings":
            val app = SettingsApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Minesweeper":
            val app = MinesweeperApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Snake":
            val app = SnakeApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Tetris":
            val app = TetrisApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Solitaire":
            val app = SolitaireApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Todo":
            val app = TodoApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Hex Editor":
            val app = HexEditorApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Log Viewer":
            val app = LogViewerApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Network Monitor":
            val app = NetworkMonitorApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Contacts":
            val app = ContactsApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Package Manager":
            val app = PackageManagerApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "OS Installer":
            val app = InstallerGuiApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Software Update":
            val app = UpgradeGuiApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Color Picker":
            val app = ColorPickerApp.new()
            val session = app.build_ui()
            return session.current_tree()
        "Font Viewer":
            val app = FontViewerApp.new()
            val session = app.build_ui()
            return session.current_tree()
        _:
            val root = column("app_{name}_root", [
                text_widget("app_{name}_content", "Welcome to {name}")
            ])
            return build_tree_with_title(root, name, "dark")

fn _app_uses_remote_window(name: text) -> bool:
    name == "Hello World" or name == "Browser Demo" or name == "File Manager" or name == "Terminal" or name == "Editor"

# ============================================================================
# Default Keyboard Shortcuts
# ============================================================================

fn _default_shortcuts() -> [KeyboardShortcut]:
    """Return default global keyboard shortcuts."""
    [
        KeyboardShortcut(modifier: "Ctrl+Alt", key: "h", action: "launch_Hello World"),
        KeyboardShortcut(modifier: "Ctrl+Alt", key: "t", action: "launch_Terminal"),
        KeyboardShortcut(modifier: "Ctrl+Alt", key: "j", action: "process_next"),
        KeyboardShortcut(modifier: "Ctrl+Alt", key: "k", action: "process_prev"),
        KeyboardShortcut(modifier: "Ctrl+Alt", key: "f", action: "process_focus"),
        KeyboardShortcut(modifier: "Ctrl+Alt", key: "x", action: "process_terminate"),
        KeyboardShortcut(modifier: "Ctrl+Alt", key: "r", action: "process_relaunch")
    ]

fn _process_rows() -> [ShellProcessRow]:
    """Return launcher-backed process rows in render order."""
    var rows: [ShellProcessRow] = []
    val process_count = launcher_get_process_count()
    var idx: u64 = 0
    while idx < process_count.to_u64():
        val name = launcher_get_process_name(idx)
        val pid = launcher_get_process_pid(idx)
        if name != "" and pid > 0:
            rows = rows.push(ShellProcessRow(
                process_index: idx,
                name: name,
                pid: pid,
                state: launcher_get_process_state(idx),
                windows: launcher_get_process_window_count(idx),
                headless: launcher_get_process_is_headless(idx),
                app_id: launcher_get_process_app_id_for_pid(pid)
            ))
        idx = idx + 1
    rows

fn _selected_process_row(selected_process_idx: i64) -> ShellProcessRow?:
    val rows = _process_rows()
    if rows.len() == 0:
        return nil
    val idx = _normalized_process_selection(selected_process_idx, rows.len())
    rows[idx]

fn _normalized_process_selection(selected_process_idx: i64, row_count: i32) -> i32:
    if row_count <= 0:
        return 0
    if selected_process_idx < 0:
        return 0
    if selected_process_idx >= row_count.to_i64():
        return row_count - 1
    selected_process_idx.to_i32()

fn _process_is_live(state: text) -> bool:
    state == "running" or state == "launching" or state == "terminating"

fn _sync_launcher_registry_with_manifests():
    """No-op: launcher_init() already registers the 4 real apps.

    Populating from the full 29-entry default_manifests() list would add 25
    stub binaries that don't exist on the baremetal image, overflow the
    32-slot registry on repeated interpreter test runs (module globals persist
    between iterations), and emit spurious "[launcher] Registry full (32 slots)"
    messages. SF Round 12 intentionally made this a no-op; squash commit
    326cca5b94 accidentally re-introduced the loop. Reverted by Agent RF.
    """
    pass_do_nothing

fn _manifest_shortcut_key(name: text) -> u32:
    match name:
        "Hello World": 0x48
        "File Manager": 0x46
        "Terminal": 0x54
        "Browser Demo": 0x42
        _: 0

fn _manifest_shortcut_mod(name: text) -> u32:
    match name:
        "Hello World" | "File Manager" | "Terminal" | "Browser Demo":
            MOD_META
        _:
            0

# ============================================================================
# Remote Window Tree Builder
# ============================================================================

fn _build_remote_tree(window_id: u64, content: text) -> UITree:
    """Build a widget tree for a remote window's content update.

    Creates a simple panel with text content and a status bar,
    matching the layout that was previously built inside WmService.
    """
    val wid_str = "{window_id}"
    val root = column("remote_{wid_str}", [
        panel("remote_content_{wid_str}", "", [
            text_widget("remote_text_{wid_str}", content)
        ]),
        statusbar("remote_status_{wid_str}", "Remote window {wid_str}", "Updated")
    ])
    build_tree_with_title(root, "Window {wid_str}", "dark")
