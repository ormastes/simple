# App Manifest — Application Metadata for Launcher
#
# Defines application entries for the desktop app launcher.
# Manifests can be loaded from /usr/share/apps/*.sdn or
# returned as built-in defaults.
#
# MDSOC: feature dimension, desktop layer

use os.crash_policy.{AppClass, AppFaultDomain, SupervisorPolicy, default_fault_domain, default_supervisor_policy}
use os.services.vfs.vfs_init.{g_vfs_readdir, g_vfs_read_file_text}
use os.kernel.types.fs_types.{DirEntry, FsNodeKind}

# =========================================================================
# UI Backend Selection
# =========================================================================
#
# Per-app choice of rendering backend for an app's native window content.
# Resolved at spawn time by resolve_backend() given the current host's caps.
# SimpleOS rejects Electron at manifest-load time — no Node / no Chromium
# in kernel.

enum UiBackendKind:
    Electron
    SimpleWeb
    Auto

struct HostCaps:
    """Runtime-detected capabilities relevant to backend selection."""
    is_simpleos: bool
    electron_available: bool

enum ManifestError:
    ElectronNotAvailable

fn resolve_backend(requested: UiBackendKind, host: HostCaps) -> Result<UiBackendKind, ManifestError>:
    """Resolve a requested backend against the host's capabilities.

    * Auto       -> SimpleWeb on SimpleOS / hosts without Electron,
                    else Electron.
    * Electron   -> Err(ElectronNotAvailable) on SimpleOS or hosts
                    without Electron; Ok(Electron) otherwise.
    * SimpleWeb  -> Ok(SimpleWeb) everywhere.
    """
    match requested:
        UiBackendKind.Auto:
            if host.is_simpleos or not host.electron_available:
                Ok(UiBackendKind.SimpleWeb)
            else:
                Ok(UiBackendKind.Electron)
        UiBackendKind.Electron:
            if host.is_simpleos or not host.electron_available:
                Err(ManifestError.ElectronNotAvailable)
            else:
                Ok(UiBackendKind.Electron)
        UiBackendKind.SimpleWeb:
            Ok(UiBackendKind.SimpleWeb)

fn host_caps_simpleos() -> HostCaps:
    """Default host caps for SimpleOS — Electron is never available."""
    HostCaps(is_simpleos: true, electron_available: false)

fn host_caps_host(electron_available: bool) -> HostCaps:
    """Default host caps for a non-SimpleOS host."""
    HostCaps(is_simpleos: false, electron_available: electron_available)

# =========================================================================
# App Manifest
# =========================================================================

struct AppManifest:
    """Application manifest for the desktop launcher."""
    name: text
    description: text
    category: text          # "System", "Utilities", "Development", "Settings"
    binary: text            # Path to binary
    capabilities: [text]    # Required capabilities
    icon: text              # Icon identifier (text label for now)
    app_class: AppClass
    fault_domain: AppFaultDomain
    supervisor_policy: SupervisorPolicy

struct AppHostContent:
    """Host-rendered content supplied by an app manifest."""
    title: text
    body: text
    status: text

# =========================================================================
# Manifest Loading
# =========================================================================

fn load_app_manifests() -> [AppManifest]:
    """Load application manifests.

    Returns built-in defaults plus any found in /usr/share/apps/.
    """
    # Built-in applications
    var manifests = default_manifests()

    # In a full OS, we would also scan /usr/share/apps/*.sdn
    # and parse each file into an AppManifest.
    # For now, return built-in defaults only.
    manifests

