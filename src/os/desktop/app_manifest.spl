# =========================================================================
# Search
# =========================================================================

fn search_apps(manifests: [AppManifest], query: text) -> [AppManifest]:
    """Search manifests by name or description."""
    if query == "":
        return manifests
    var results: [AppManifest] = []
    val q_lower = query.lower()
    for m in manifests:
        if m.name.lower().contains(q_lower) or m.description.lower().contains(q_lower):
            results = results.push(m)
    results

fn manifest_categories(manifests: [AppManifest]) -> [text]:
    """Return category names in first-seen order."""
    var categories: [text] = []
    for manifest in manifests:
        var exists = false
        for category in categories:
            if category == manifest.category:
                exists = true
        if not exists:
            categories = categories.push(manifest.category)
    categories

fn find_manifest_by_name(manifests: [AppManifest], name: text) -> AppManifest?:
    """Return a manifest by display name, or nil if no match exists."""
    for manifest in manifests:
        if manifest.name == name:
            return manifest
    nil

fn host_content_for_manifest(manifest: AppManifest) -> AppHostContent?:
    """Return app-specific host content when a built-in app supplies it."""
    if manifest.binary == "/sys/apps/terminal":
        return Some(AppHostContent(
            title: "Terminal",
            body: "Host terminal surface ready for shell attachment.",
            status: "/sys/apps/terminal"
        ))
    if manifest.binary == "/sys/apps/shell":
        return Some(AppHostContent(
            title: "Shell",
            body: "Interactive command shell host surface.",
            status: "/sys/apps/shell"
        ))
    if manifest.binary == "/sys/apps/settings":
        return Some(AppHostContent(
            title: "Settings",
            body: "System settings host panel placeholder.",
            status: "/sys/apps/settings"
        ))
    return nil

# =========================================================================
# Removable Media Manifest Scanning
# =========================================================================

fn sdn_extract_field(content: text, key: text) -> text:
    val terminated = "{content}\n"
    var current = ""
    val search = "{key} = "
    for ch in terminated:
        if ch == "\n":
            val line = current.trim()
            if line.starts_with(search):
                var raw = line.slice(search.len(), line.len()).trim()
                if raw.starts_with("\"") and raw.ends_with("\""):
                    raw = raw.slice(1, raw.len() - 1)
                return raw
            current = ""
        else:
            current = "{current}{ch}"
    ""

fn parse_removable_manifest(content: text, binary_base: text) -> AppManifest:
    val user_app = AppClass.UserApp
    val user_domain = default_fault_domain(user_app)
    val user_policy = default_supervisor_policy(user_app)
    var name_val = sdn_extract_field(content, "name")
    if name_val == "":
        name_val = binary_base
    var binary_val = sdn_extract_field(content, "binary")
    if binary_val == "":
        binary_val = binary_base
    var category_val = sdn_extract_field(content, "category")
    if category_val == "":
        category_val = "Utilities"
    var icon_val = sdn_extract_field(content, "icon")
    if icon_val == "":
        icon_val = "app"
    var desc_val = sdn_extract_field(content, "description")
    if desc_val == "":
        desc_val = name_val
    AppManifest(
        name: name_val,
        description: desc_val,
        category: category_val,
        binary: binary_val,
        capabilities: [],
        icon: icon_val,
        app_class: user_app,
        fault_domain: user_domain,
        supervisor_policy: user_policy
    )

pub fn scan_removable_manifests(mount_path: text) -> [AppManifest]:
    """Scan {mount_path}/APPS/ for .sdn manifest files and parse each into AppManifest."""
    var results: [AppManifest] = []
    val apps_dir = "{mount_path}/APPS"
    val entries = g_vfs_readdir(apps_dir)
    for entry in entries:
        if entry.node.kind == FsNodeKind.File and entry.name.ends_with(".sdn"):
            val file_path = "{apps_dir}/{entry.name}"
            val content = g_vfs_read_file_text(file_path)
            if content != "":
                val manifest = parse_removable_manifest(content, file_path)
                results = results.push(manifest)
    results
