# Shared SimpleOS desktop font registration.

use std.common.encoding.font_registry.{simpleos_default_font_asset_candidate, simpleos_font_asset_guest_path, simpleos_font_asset_short_guest_path}
use std.nogc_sync_mut.text_layout.font_renderer.{font_renderer_register_selected_bytes, font_renderer_use_registered_selected_bytes_only}
use os.services.vfs.vfs_init.{g_vfs_read_file_bytes, vfs_is_ready}

fn simpleos_desktop_register_default_font_from_vfs() -> bool:
    """Register the pinned desktop face from its staged VFS bytes."""
    font_renderer_use_registered_selected_bytes_only()
    if not vfs_is_ready():
        return false
    val candidate = simpleos_default_font_asset_candidate()
    var blob = g_vfs_read_file_bytes(simpleos_font_asset_guest_path(candidate))
    if blob.len() == 0:
        blob = g_vfs_read_file_bytes(simpleos_font_asset_short_guest_path(candidate))
    if blob.len() == 0:
        return false
    font_renderer_register_selected_bytes(candidate.local_path, blob)
