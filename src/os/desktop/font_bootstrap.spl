# Shared SimpleOS desktop font registration.

use std.common.encoding.font_registry.{selected_font_asset_candidates, simpleos_font_asset_guest_path, simpleos_font_asset_short_guest_path}
use std.nogc_sync_mut.text_layout.font_renderer.{font_renderer_register_selected_bytes, font_renderer_use_registered_selected_bytes_only}
use os.services.vfs.vfs_init.{g_vfs_read_file_bytes}

fn simpleos_desktop_register_selected_fonts_from_vfs() -> bool:
    """Register every pinned desktop face from its staged VFS bytes."""
    font_renderer_use_registered_selected_bytes_only()
    val candidates = selected_font_asset_candidates()
    var registered = 0
    for candidate in candidates:
        val canonical_blob = g_vfs_read_file_bytes(simpleos_font_asset_guest_path(candidate))
        var registered_candidate = canonical_blob.len() > 0 and font_renderer_register_selected_bytes(candidate.local_path, canonical_blob)
        if not registered_candidate:
            val short_blob = g_vfs_read_file_bytes(simpleos_font_asset_short_guest_path(candidate))
            registered_candidate = short_blob.len() > 0 and font_renderer_register_selected_bytes(candidate.local_path, short_blob)
        if registered_candidate:
            registered = registered + 1
    registered == candidates.len()
