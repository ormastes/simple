# Z-Order Store — In-Memory Stacking + Minimize State + Durable Persistence
#
# Tracks per-window (z_index, minimized) for the desktop shell's taskbar
# + focus/raise handling. The in-memory API is unchanged; persistence across
# WM restart is now wired:
#   * serialize()/load(blob) round-trip the stacking list to a compact binary
#     blob (device-free — the blob is the injectable backend, so tests never
#     touch a real device).
#   * save(path)/load_path(path) route that blob through the VFS byte file API
#     so the order survives a WmService restart on a real filesystem.
#
# Consumed by:
#   * src/os/services/wm/wm_service.spl    — COMP_MINIMIZE / COMP_RESTORE / COMP_FOCUS
#   * src/os/desktop/shell.spl             — TaskbarShell running-apps section

use common.window_protocol.geometry.{WindowId}
use os.services.vfs.vfs_write_ops.{g_vfs_write_file_bytes}
use os.services.vfs.vfs_init.{g_vfs_read_file_bytes}

# Binary blob format: version(u32) | next_z(i64 as u64) | count(u32)
# followed by `count` records of window_id(u64) | z_index(i64 as u64) | minimized(u8).
val ZO_FORMAT_VERSION: u32 = 1
val ZO_HEADER_LEN: i32 = 16
val ZO_RECORD_LEN: i32 = 17
# Default on-disk location for the stacking order (VFS path).
val ZO_DEFAULT_PATH: text = "/var/wm/z_order.bin"

struct ZOrderEntry:
    window_id: u64
    z_index: i64
    minimized: bool

class ZOrderStore:
    entries: [ZOrderEntry]
    next_z: i64

impl ZOrderStore:
    static fn new() -> ZOrderStore:
        ZOrderStore(entries: [], next_z: 1)

    me touch(window_id: u64):
        """Insert or refresh a window at the top of the stack."""
        var filtered: [ZOrderEntry] = []
        var was_minimized = false
        for e in self.entries:
            if e.window_id == window_id:
                was_minimized = e.minimized
            else:
                filtered = filtered.push(e)
        val top = self.next_z
        self.next_z = top + 1
        filtered = filtered.push(ZOrderEntry(
            window_id: window_id,
            z_index: top,
            minimized: was_minimized
        ))
        self.entries = filtered

    me focus(window_id: u64):
        """Raise window_id to the top (unminimize if needed)."""
        var filtered: [ZOrderEntry] = []
        for e in self.entries:
            if e.window_id == window_id:
                pass_dn
            else:
                filtered = filtered.push(e)
        val top = self.next_z
        self.next_z = top + 1
        filtered = filtered.push(ZOrderEntry(
            window_id: window_id,
            z_index: top,
            minimized: false
        ))
        self.entries = filtered

    me set_minimized(window_id: u64, minimized: bool):
        var updated: [ZOrderEntry] = []
        for e in self.entries:
            if e.window_id == window_id:
                updated = updated.push(ZOrderEntry(
                    window_id: e.window_id,
                    z_index: e.z_index,
                    minimized: minimized
                ))
            else:
                updated = updated.push(e)
        self.entries = updated

    me remove(window_id: u64):
        var filtered: [ZOrderEntry] = []
        for e in self.entries:
            if e.window_id == window_id:
                pass_dn
            else:
                filtered = filtered.push(e)
        self.entries = filtered

    fn get(window_id: u64) -> ZOrderEntry?:
        for e in self.entries:
            if e.window_id == window_id:
                return e
        return nil

    fn is_minimized(window_id: u64) -> bool:
        val e = self.get(window_id)
        if e == nil:
            return false
        e.minimized

    fn top_window() -> u64:
        """Window with the highest z_index among non-minimized entries. 0 if none."""
        var best_z: i64 = -1
        var best_id: u64 = 0
        for e in self.entries:
            if not e.minimized and e.z_index > best_z:
                best_z = e.z_index
                best_id = e.window_id
        best_id

    fn len() -> i32:
        self.entries.len()

    # -- Durable persistence -------------------------------------------------

    fn zo_serialize() -> [u8]:
        """Serialize the stacking list + next_z to a compact binary blob.

        This is the injectable backend seam: callers route the blob to a real
        device (save) or hold it in memory (tests) without the store touching
        any filesystem."""
        # Arrays are value types: the _zo_push_* helpers must RETURN the grown
        # buffer and be reassigned — pushing through a bare function arg does
        # not mutate the caller's array.
        var buf: [u8] = []
        buf = _zo_push_u32(buf, ZO_FORMAT_VERSION)
        buf = _zo_push_u64(buf, self.next_z.to_u64())
        buf = _zo_push_u32(buf, self.entries.len().to_u32())
        for e in self.entries:
            buf = _zo_push_u64(buf, e.window_id)
            buf = _zo_push_u64(buf, e.z_index.to_u64())
            val mbyte: u8 = if e.minimized: 1 else: 0
            buf = buf.push(mbyte)
        buf

    me zo_load(blob: [u8]):
        """Restore stacking order + next_z from a blob produced by serialize().

        Malformed or version-mismatched blobs leave the store untouched.
        Written without a bare `return`: the interpreter mis-handles an early
        `return` in a `me` method invoked from a spec `it` block, silently
        skipping the field writes below it."""
        var valid = blob.len() >= ZO_HEADER_LEN
        if valid:
            valid = _zo_read_u32(blob, 0) == ZO_FORMAT_VERSION
        if valid:
            val restored_next_z = _zo_read_u64(blob, 4).to_i64()
            val count = _zo_read_u32(blob, 12).to_i32()
            var rebuilt: [ZOrderEntry] = []
            var off: i32 = ZO_HEADER_LEN
            var i: i32 = 0
            var truncated = false
            while i < count and not truncated:
                if off + ZO_RECORD_LEN > blob.len():
                    truncated = true
                else:
                    val wid = _zo_read_u64(blob, off)
                    val z = _zo_read_u64(blob, off + 8).to_i64()
                    val minimized = blob[off + 16] != 0
                    rebuilt = rebuilt.push(ZOrderEntry(window_id: wid, z_index: z, minimized: minimized))
                    off = off + ZO_RECORD_LEN
                    i = i + 1
            if not truncated:
                self.entries = rebuilt
                self.next_z = restored_next_z

    fn save(path: text) -> bool:
        """Persist the stacking order to `path` via the VFS byte-file API."""
        g_vfs_write_file_bytes(path, self.zo_serialize())

    fn save_default() -> bool:
        """Persist to the canonical ZO_DEFAULT_PATH location."""
        self.save(ZO_DEFAULT_PATH)

    me load_from(path: text):
        """Reload the stacking order from `path` (no-op if the file is absent)."""
        val blob = g_vfs_read_file_bytes(path)
        self.zo_load(blob)

    me load_from_default():
        """Reload from the canonical ZO_DEFAULT_PATH location."""
        self.load_from(ZO_DEFAULT_PATH)

fn new_z_order_store() -> ZOrderStore:
    ZOrderStore.new()

# -- Little-endian byte helpers ----------------------------------------------

fn _zo_push_u32(buf: [u8], value: u32) -> [u8]:
    var out = buf
    out = out.push((value & 0xFF).to_u8())
    out = out.push(((value >> 8) & 0xFF).to_u8())
    out = out.push(((value >> 16) & 0xFF).to_u8())
    out = out.push(((value >> 24) & 0xFF).to_u8())
    out

fn _zo_push_u64(buf: [u8], value: u64) -> [u8]:
    var out = buf
    var i: i32 = 0
    while i < 8:
        out = out.push(((value >> (i * 8)) & 0xFF).to_u8())
        i = i + 1
    out

fn _zo_read_u32(buf: [u8], off: i32) -> u32:
    var v: u32 = 0
    var i: i32 = 0
    while i < 4:
        v = v | (buf[off + i].to_u32() << (i * 8))
        i = i + 1
    v

fn _zo_read_u64(buf: [u8], off: i32) -> u64:
    var v: u64 = 0
    var i: i32 = 0
    while i < 8:
        v = v | (buf[off + i].to_u64() << (i * 8))
        i = i + 1
    v
