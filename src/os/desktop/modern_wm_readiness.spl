    os_render_titlebar_input_ready: bool
    os_render_traffic_controls_ready: bool
    os_render_animated_background_ready: bool
    os_render_window_interaction_ready: bool
    os_render_command_palette_ready: bool
    os_render_command_palette_max_width_px: i32
    os_render_theme_accent_controls_ready: bool
    os_render_focus_depth_ready: bool
    os_render_lifecycle_animation_ready: bool
    os_render_taskbar_interaction_ready: bool
    os_render_dock_magnification_ready: bool
    os_render_notification_feedback_ready: bool
    os_render_notification_max_width_px: i32
    os_render_workspace_switcher_ready: bool
    os_render_workspace_switcher_max_width_px: i32
    os_render_keyboard_shortcut_overlay_ready: bool
    os_render_shortcut_overlay_max_width_px: i32
    os_render_app_launcher_ready: bool
    os_render_app_launcher_max_width_px: i32
    os_render_context_menu_ready: bool
    os_render_context_menu_max_width_px: i32
    os_render_hot_corners_ready: bool
    os_render_hot_corner_max_size_px: i32
    os_render_resize_hud_ready: bool
    os_render_resize_hud_max_width_px: i32
    os_render_gesture_hints_ready: bool
    os_render_gesture_hints_max_width_px: i32
    os_render_taskbar_preview_ready: bool
    os_render_taskbar_preview_max_width_px: i32
    os_render_stage_rail_ready: bool
    os_render_stage_rail_max_width_px: i32
    os_render_contrast_ratio_x100: i64
    os_render_bounded_layout: bool
    os_render_touch_target_min_height_px: i32
