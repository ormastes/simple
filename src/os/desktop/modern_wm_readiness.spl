fn _os_dock_ready() -> bool:
    val metrics = modern_dock_metrics()
    val dock = Dock.create(Px(value: 1024), Px(value: 768))
    val expected_width = 7 * metrics.icon_size_px + 6 * metrics.item_spacing_px + metrics.padding_px * 2
    val image = DockItem(app_name: "Browser", icon_char: "https://simple.local/icon.png", is_pinned: true, is_running: false, window_id: nil)
    metrics.translucent and metrics.round_icon_converter and metrics.motion_can_disable and metrics.icon_size_px == 48 and metrics.height_px == 64 and dock.width.value == expected_width and dock.height.value == metrics.height_px and dock_item_modern_icon_kind(image) == "square-to-round"

fn _os_taskbar_ready() -> bool:
    val contract = modern_taskbar_shell_contract()
    val root = build_taskbar_shell_tree(_readiness_taskbar_model())
    val sections = root.children()
    if sections.len() != 3:
        return false
    val pinned = sections[0].children()
    if pinned.len() < 2:
        return false
    contract.translucent and contract.rounded_taskbar and contract.rounded_icons and contract.motion_can_disable and root.get_prop("modern_shell") == "true" and root.get_prop("modern_taskbar_height_px") == "{contract.height_px}" and pinned[1].get_prop("modern_icon_kind") == "square-to-round"

fn _os_affordances_ready() -> bool:
    val contract = modern_desktop_affordance_contract()
    val root = build_taskbar_shell_tree(_readiness_taskbar_model())
    contract.command_palette and contract.control_center and contract.window_overview and contract.desktop_widgets and contract.snap_assist and contract.motion_verbosity_controls and contract.can_disable_motion and contract.translucent_panels and contract.rounded_controls and contract.reduced_motion_ms == 80 and root.get_prop("modern_command_palette") == "true" and root.get_prop("modern_control_center") == "true" and root.get_prop("modern_window_overview") == "true" and root.get_prop("modern_desktop_widgets") == "true" and root.get_prop("modern_snap_assist") == "true" and root.get_prop("modern_motion_controls") == "true" and root.get_prop("modern_affordance_reduced_motion_ms") == "80"

fn _os_interactions_ready() -> bool:
    val contract = modern_wm_interaction_contract()
    contract.command_count == 12 and contract.shortcut_count == 12 and contract.snap_layout_count == 3 and contract.motion_mode_count == 3 and contract.widget_command_count == 1 and contract.overview_command_count == 2 and contract.all_server_authoritative and contract.local_preview_only

fn _lifecycle_motion_ready() -> bool:
    val window = _readiness_window(false)
    val minimized = _readiness_window(true)
    val open = wm_lifecycle_motion_contract("create_window", window)
    val close = wm_lifecycle_motion_contract("destroy_window", window)
    val minimize = wm_lifecycle_motion_contract("minimize", window)
    val restore = wm_lifecycle_motion_contract("restore", minimized)
    open.class_name == "wm-window-opening" and close.phase == "closing" and minimize.duration_ms == 180 and minimize.transform_origin == "dock" and minimize.dock_origin_y > window.y and restore.duration_ms == 240 and restore.reduced_duration_ms == 80 and restore.can_disable and restore.easing == "cubic-bezier(.2,.8,.2,1)" and restore.transform_origin == "dock"

fn _rendered_motion_ready() -> bool:
    val windows = [_readiness_window(false), _readiness_window(true)]
    val html = scene_to_html(lifecycle_windows_to_motion_wm_scene(windows, "restore", 640, 480))
    html.contains("motion-window") and html.contains("data-motion-phase='restoring'") and html.contains("data-motion-class='wm-window-restoring'") and html.contains("data-motion-can-disable='true'") and html.contains("data-motion-easing='cubic-bezier(.2,.8,.2,1)'") and html.contains("data-motion-transform-origin='dock'") and html.contains("data-dock-origin-x='") and html.contains("data-dock-origin-y='") and html.contains("--dock-origin-x:") and html.contains("--dock-origin-y:") and html.contains("@keyframes wm-window-open") and html.contains("@keyframes wm-window-close") and html.contains("@keyframes wm-window-minimize") and html.contains("@keyframes wm-window-restore") and html.contains("body[data-motion-mode='off'] .motion-window")

fn _rendered_icon_policy() -> RenderedIconPolicy:
    val scene = shared_wm_scene_to_chromed_wm_scene(_readiness_shared_scene(), _readiness_taskbar_model(), 1000, "09:41", 2)
    val html = scene_to_html(scene)
    val ready = html.contains("data-icon-inner-padding-px='3'") and html.contains("data-icon-mask-shape='circle'") and html.contains("data-icon-image-fit='cover'") and html.contains("data-icon-mask='circle'") and html.contains("data-icon-fit='cover'") and html.contains("data-icon-fit='glyph'") and html.contains("data-icon-fallback='") and html.contains("aria-label='Normalized round icon") and html.contains("aria-label='Round glyph icon") and html.contains(".round-icon.icon-normalized-square{{padding:3px") and html.contains("object-position:center") and html.contains("aspect-ratio:1 / 1")
    RenderedIconPolicy(ready: ready, inner_padding_px: 3, mask_shape: "circle", image_fit: "cover")

fn _rendered_affordances_ready() -> bool:
