    notes: [text]

fn modern_wm_readiness_report(theme: text) -> ModernWmReadinessReport:
    val web = wm_theme_quality_report(theme)
    val dock_ready = _os_dock_ready()
    val taskbar_ready = _os_taskbar_ready()
    val affordances_ready = _os_affordances_ready()
    val lifecycle_ready = _lifecycle_motion_ready()
    val rendered_ready = _rendered_motion_ready()
    val rendered_affordances_ready = _rendered_affordances_ready()
    val os_render_quality = _os_render_quality_report()
    val passed = web.passed and dock_ready and taskbar_ready and affordances_ready and lifecycle_ready and rendered_ready and rendered_affordances_ready and os_render_quality.passed
    ModernWmReadinessReport(
        theme: theme,
        passed: passed,
        web_quality_ready: web.passed,
        os_dock_ready: dock_ready,
        os_taskbar_ready: taskbar_ready,
        os_affordances_ready: affordances_ready,
        lifecycle_motion_ready: lifecycle_ready,
        rendered_motion_ready: rendered_ready,
        rendered_affordances_ready: rendered_affordances_ready,
        os_render_quality_ready: os_render_quality.passed,
        os_render_theme_configured: os_render_quality.theme_configured,
        os_render_round_scrollbars: os_render_quality.round_scrollbars,
        os_render_round_icon_converter: os_render_quality.round_icon_converter,
        os_render_titlebar_input_ready: os_render_quality.titlebar_input_ready,
        os_render_traffic_controls_ready: os_render_quality.traffic_controls_ready,
        os_render_animated_background_ready: os_render_quality.animated_background_ready,
        os_render_window_interaction_ready: os_render_quality.window_interaction_ready,
        os_render_command_palette_ready: os_render_quality.command_palette_ready,
        os_render_command_palette_max_width_px: os_render_quality.max_command_palette_width_px,
        os_render_theme_accent_controls_ready: os_render_quality.theme_accent_controls_ready,
        os_render_focus_depth_ready: os_render_quality.focus_depth_ready,
        os_render_lifecycle_animation_ready: os_render_quality.lifecycle_animation_ready,
        os_render_taskbar_interaction_ready: os_render_quality.taskbar_interaction_ready,
        os_render_dock_magnification_ready: os_render_quality.dock_magnification_ready,
        os_render_notification_feedback_ready: os_render_quality.notification_feedback_ready,
        os_render_notification_max_width_px: os_render_quality.max_notification_width_px,
        os_render_workspace_switcher_ready: os_render_quality.workspace_switcher_ready,
        os_render_workspace_switcher_max_width_px: os_render_quality.max_workspace_switcher_width_px,
        os_render_keyboard_shortcut_overlay_ready: os_render_quality.keyboard_shortcut_overlay_ready,
        os_render_shortcut_overlay_max_width_px: os_render_quality.max_shortcut_overlay_width_px,
        os_render_app_launcher_ready: os_render_quality.app_launcher_ready,
        os_render_app_launcher_max_width_px: os_render_quality.max_app_launcher_width_px,
        os_render_context_menu_ready: os_render_quality.context_menu_ready,
        os_render_context_menu_max_width_px: os_render_quality.max_context_menu_width_px,
        os_render_hot_corners_ready: os_render_quality.hot_corners_ready,
        os_render_hot_corner_max_size_px: os_render_quality.max_hot_corner_size_px,
        os_render_resize_hud_ready: os_render_quality.resize_hud_ready,
        os_render_resize_hud_max_width_px: os_render_quality.max_resize_hud_width_px,
        os_render_gesture_hints_ready: os_render_quality.gesture_hints_ready,
        os_render_gesture_hints_max_width_px: os_render_quality.max_gesture_hint_width_px,
        os_render_taskbar_preview_ready: os_render_quality.taskbar_preview_ready,
        os_render_taskbar_preview_max_width_px: os_render_quality.max_taskbar_preview_width_px,
        os_render_stage_rail_ready: os_render_quality.stage_rail_ready,
        os_render_stage_rail_max_width_px: os_render_quality.max_stage_rail_width_px,
        os_render_contrast_ratio_x100: os_render_quality.contrast_ratio_x100,
        os_render_bounded_layout: os_render_quality.bounded_layout,
        os_render_touch_target_min_height_px: os_render_quality.min_touch_target_height_px,
        color_checked: web.color_checked,
        contrast_ratio_x100: web.contrast_ratio_x100,
        size_layout_configured: web.size_layout_configured,
        titlebar_height_px: web.titlebar_height_px,
        window_min_width_px: web.window_min_width_px,
        window_min_height_px: web.window_min_height_px,
        title_input_min_width_px: web.title_input_min_width_px,
        taskbar_icon_size_px: web.taskbar_icon_size_px,
        command_palette_max_width_px: web.command_palette_max_width_px,
        control_center_max_width_px: web.control_center_max_width_px,
        desktop_widget_max_width_px: web.desktop_widget_max_width_px,
        overview_card_min_width_px: web.overview_card_min_width_px,
        touch_target_min_height_px: web.touch_target_min_height_px,
        responsive_layout_ready: web.responsive_layout_ready,
        command_palette_ready: web.command_palette_ready,
        title_input_ready: web.title_input_ready,
        visual_layering_ready: web.visual_layering_ready,
        motion_verbosity_control: web.motion_verbosity_control,
        round_icon_converter: web.round_icon_converter,
        round_scrollbars: web.round_scrollbars,
        translucent_shell: web.translucent_shell,
        accessible_controls_ready: web.accessible_controls_ready,
        snap_assist_ready: web.snap_assist_ready,
        desktop_widgets_ready: web.desktop_widgets_ready,
        window_overview_ready: web.window_overview_ready,
        control_center_ready: web.control_center_ready,
        notes: _modern_wm_notes(passed, web.contrast_ratio_x100)
    )

fn modern_wm_readiness_summary(theme: text) -> text:
    val r = modern_wm_readiness_report(theme)
    val status = if r.passed: "pass" else: "fail"
    "modern_wm_readiness theme={r.theme} status={status} web={r.web_quality_ready} dock={r.os_dock_ready} taskbar={r.os_taskbar_ready} os_affordances={r.os_affordances_ready} lifecycle={r.lifecycle_motion_ready} rendered_motion={r.rendered_motion_ready} rendered_affordances={r.rendered_affordances_ready} os_render_quality={r.os_render_quality_ready} os_render_theme_configured={r.os_render_theme_configured} os_render_round_scrollbars={r.os_render_round_scrollbars} os_render_round_icon_converter={r.os_render_round_icon_converter} os_render_titlebar_input={r.os_render_titlebar_input_ready} os_render_traffic_controls={r.os_render_traffic_controls_ready} os_render_animated_background={r.os_render_animated_background_ready} os_render_window_interaction={r.os_render_window_interaction_ready} os_render_command_palette={r.os_render_command_palette_ready} os_render_command_palette_max={r.os_render_command_palette_max_width_px}px os_render_theme_accent_controls={r.os_render_theme_accent_controls_ready} os_render_focus_depth={r.os_render_focus_depth_ready} os_render_lifecycle_animation={r.os_render_lifecycle_animation_ready} os_render_taskbar_interaction={r.os_render_taskbar_interaction_ready} os_render_dock_magnification={r.os_render_dock_magnification_ready} os_render_notification_feedback={r.os_render_notification_feedback_ready} os_render_notification_max={r.os_render_notification_max_width_px}px os_render_workspace_switcher={r.os_render_workspace_switcher_ready} os_render_workspace_switcher_max={r.os_render_workspace_switcher_max_width_px}px os_render_keyboard_shortcuts={r.os_render_keyboard_shortcut_overlay_ready} os_render_shortcuts_max={r.os_render_shortcut_overlay_max_width_px}px os_render_app_launcher={r.os_render_app_launcher_ready} os_render_app_launcher_max={r.os_render_app_launcher_max_width_px}px os_render_context_menu={r.os_render_context_menu_ready} os_render_context_menu_max={r.os_render_context_menu_max_width_px}px os_render_hot_corners={r.os_render_hot_corners_ready} os_render_hot_corner_max={r.os_render_hot_corner_max_size_px}px os_render_resize_hud={r.os_render_resize_hud_ready} os_render_resize_hud_max={r.os_render_resize_hud_max_width_px}px os_render_gesture_hints={r.os_render_gesture_hints_ready} os_render_gesture_hints_max={r.os_render_gesture_hints_max_width_px}px os_render_taskbar_preview={r.os_render_taskbar_preview_ready} os_render_taskbar_preview_max={r.os_render_taskbar_preview_max_width_px}px os_render_stage_rail={r.os_render_stage_rail_ready} os_render_stage_rail_max={r.os_render_stage_rail_max_width_px}px os_render_contrast_ratio_x100={r.os_render_contrast_ratio_x100} os_render_bounded_layout={r.os_render_bounded_layout} os_render_touch_target_min={r.os_render_touch_target_min_height_px}px color_checked={r.color_checked} contrast_ratio_x100={r.contrast_ratio_x100} size_layout={r.size_layout_configured} responsive_layout={r.responsive_layout_ready} titlebar={r.titlebar_height_px}px window_min={r.window_min_width_px}x{r.window_min_height_px} title_input={r.title_input_min_width_px}px taskbar_icon={r.taskbar_icon_size_px}px command_palette_max={r.command_palette_max_width_px}px control_center_max={r.control_center_max_width_px}px desktop_widget_max={r.desktop_widget_max_width_px}px overview_card_min={r.overview_card_min_width_px}px touch_target_min={r.touch_target_min_height_px}px command_palette={r.command_palette_ready} title_input_ready={r.title_input_ready} visual_layering={r.visual_layering_ready} motion_control={r.motion_verbosity_control} round_icons={r.round_icon_converter} round_scrollbars={r.round_scrollbars} translucent={r.translucent_shell} accessible_controls={r.accessible_controls_ready} snap_assist={r.snap_assist_ready} desktop_widgets={r.desktop_widgets_ready} window_overview={r.window_overview_ready} control_center={r.control_center_ready}"

fn _os_dock_ready() -> bool:
    val metrics = modern_dock_metrics()
    val dock = Dock.create(Px(value: 1024), Px(value: 768))
    val expected_width = 7 * metrics.icon_size_px + 6 * metrics.item_spacing_px + metrics.padding_px * 2
    val image = DockItem(app_name: "Browser", icon_char: "https://simple.local/icon.png", is_pinned: true, is_running: false, window_id: nil)
    metrics.translucent and metrics.round_icon_converter and metrics.motion_can_disable and metrics.icon_size_px == 48 and metrics.height_px == 64 and dock.width.value == expected_width and dock.height.value == metrics.height_px and dock_item_modern_icon_kind(image) == "square-to-round"

fn _os_taskbar_ready() -> bool:
    val contract = modern_taskbar_shell_contract()
    val root = build_taskbar_shell_tree(_readiness_taskbar_model())
    val sections = root.children()
    if sections.len() != 3:
        return false
    val pinned = sections[0].children()
    if pinned.len() < 2:
        return false
    contract.translucent and contract.rounded_taskbar and contract.rounded_icons and contract.motion_can_disable and root.get_prop("modern_shell") == "true" and root.get_prop("modern_taskbar_height_px") == "{contract.height_px}" and pinned[1].get_prop("modern_icon_kind") == "square-to-round"

fn _os_affordances_ready() -> bool:
    val contract = modern_desktop_affordance_contract()
    val root = build_taskbar_shell_tree(_readiness_taskbar_model())
    contract.command_palette and contract.control_center and contract.window_overview and contract.desktop_widgets and contract.snap_assist and contract.motion_verbosity_controls and contract.can_disable_motion and contract.translucent_panels and contract.rounded_controls and contract.reduced_motion_ms == 80 and root.get_prop("modern_command_palette") == "true" and root.get_prop("modern_control_center") == "true" and root.get_prop("modern_window_overview") == "true" and root.get_prop("modern_desktop_widgets") == "true" and root.get_prop("modern_snap_assist") == "true" and root.get_prop("modern_motion_controls") == "true" and root.get_prop("modern_affordance_reduced_motion_ms") == "80"

fn _lifecycle_motion_ready() -> bool:
    val window = _readiness_window(false)
    val minimized = _readiness_window(true)
    val open = wm_lifecycle_motion_contract("create_window", window)
    val close = wm_lifecycle_motion_contract("destroy_window", window)
    val minimize = wm_lifecycle_motion_contract("minimize", window)
    val restore = wm_lifecycle_motion_contract("restore", minimized)
    open.class_name == "wm-window-opening" and close.phase == "closing" and minimize.duration_ms == 180 and restore.duration_ms == 240 and restore.reduced_duration_ms == 80 and restore.can_disable

fn _rendered_motion_ready() -> bool:
    val windows = [_readiness_window(false), _readiness_window(true)]
    val html = scene_to_html(lifecycle_windows_to_motion_wm_scene(windows, "restore", 640, 480))
    html.contains("motion-window") and html.contains("data-motion-phase='restoring'") and html.contains("data-motion-class='wm-window-restoring'") and html.contains("data-motion-can-disable='true'") and html.contains("@keyframes wm-window-open") and html.contains("@keyframes wm-window-close") and html.contains("@keyframes wm-window-minimize") and html.contains("@keyframes wm-window-restore") and html.contains("body[data-motion-mode='off'] .motion-window")

fn _rendered_affordances_ready() -> bool:
    val scene = shared_wm_scene_to_chromed_wm_scene(_readiness_shared_scene(), _readiness_taskbar_model(), 1000, "09:41", 2)
    val html = scene_to_html(scene)
    html.contains("aria-label='Desktop widgets'") and html.contains("class='desktop-widget'") and html.contains("role='dialog' aria-label='Simple command palette'") and html.contains("class='command-palette-input'") and html.contains("class='command-palette-item active'") and html.contains("@keyframes wm-command-in") and html.contains("data-window-focus='focused'") and html.contains("data-elevation-layer='active-window'") and html.contains("class='bar focused'") and html.contains("class='glass focused'") and html.contains(".bar.focused") and html.contains(".glass.focused") and html.contains("@keyframes wm-window-open") and html.contains("@keyframes wm-window-close") and html.contains("@keyframes wm-window-minimize") and html.contains("@keyframes wm-window-restore") and html.contains("data-taskbar-motion='dock-hover'") and html.contains("data-dock-magnification='1.18'") and html.contains("data-dock-neighbor-magnification='1.07'") and html.contains("data-taskbar-state='running'") and html.contains("class='taskbar-running-indicator'") and html.contains(".taskbar-launcher:hover,.taskbar-running:hover") and html.contains("scale(1.18)") and html.contains("scale(1.07)") and html.contains("@keyframes wm-taskbar-indicator") and html.contains("class='notification-toast toast-enter'") and html.contains("role='status' aria-live='polite'") and html.contains("@keyframes wm-toast-in") and html.contains("@keyframes wm-toast-out") and html.contains("class='toast-progress'") and html.contains("class='workspace-switcher'") and html.contains("role='tablist' aria-label='Workspaces'") and html.contains("@keyframes wm-workspace-in") and html.contains("@keyframes wm-workspace-slide") and html.contains("class='shortcut-overlay'") and html.contains("role='dialog' aria-label='Keyboard shortcuts'") and html.contains("@keyframes wm-shortcut-in") and html.contains("class='app-launcher'") and html.contains("role='dialog' aria-label='App launcher'") and html.contains("class='app-launcher-search'") and html.contains("class='app-launcher-tile active'") and html.contains("@keyframes wm-launcher-in") and html.contains("class='context-menu'") and html.contains("role='menu' aria-label='Window context menu'") and html.contains("class='context-menu-item active'") and html.contains("@keyframes wm-menu-in") and html.contains("class='hot-corner-zone hot-corner-overview'") and html.contains("class='hot-corner-zone hot-corner-launcher'") and html.contains("class='hot-corner-zone hot-corner-desktop'") and html.contains("class='hot-corner-zone hot-corner-control-center'") and html.contains("@keyframes wm-hot-corner-pulse") and html.contains("class='resize-hud'") and html.contains("role='status' aria-live='polite'") and html.contains("@keyframes wm-resize-hud-in") and html.contains("class='gesture-hints'") and html.contains("aria-label='Trackpad gesture hints'") and html.contains("@keyframes wm-gesture-hints-in") and html.contains("class='taskbar-preview'") and html.contains("role='tooltip' aria-label='Taskbar window preview'") and html.contains("@keyframes wm-taskbar-preview-in") and html.contains("class='stage-rail'") and html.contains("aria-label='Window stage rail'") and html.contains("@keyframes wm-stage-rail-in") and html.contains("aria-label='WM control center'") and html.contains("Standard motion") and html.contains("Motion off") and html.contains("class='accent-controls'") and html.contains("aria-label='Theme accent color'") and html.contains("data-accent-choice='blue'") and html.contains("data-accent-choice='teal'") and html.contains("data-accent-choice='rose'") and html.contains("aria-label='Window overview'") and html.contains("class='overview-card active'") and html.contains("class='snap-preview active'") and html.contains("data-snap-zone='right'") and html.contains("repeat(auto-fit,minmax(180px,1fr))") and html.contains("repeat(auto-fit,minmax(96px,1fr))") and html.contains("data-icon-normalized='square-to-round'") and html.contains("data-icon-normalized='glyph-to-round'") and html.contains("<input class='bar-command-input'") and html.contains("aria-label='Window command or location'") and html.contains("data-window-control='close'") and html.contains("data-window-control='minimize'") and html.contains("data-window-control='maximize'") and html.contains("data-drag-region='titlebar'") and html.contains("data-resize-surface='window'") and html.contains("class='resize-handle resize-south-east'") and html.contains("data-hit-size-px='44'") and html.contains("data-motion-scope='desktop-background'") and html.contains(".desktop::before") and html.contains("@keyframes wm-bg-drift") and html.contains("data-motion-mode='standard'") and html.contains("data-motion-can-disable='true'") and html.contains("data-reduced-motion-duration-ms='80'") and html.contains("@keyframes wm-control-in") and html.contains("@keyframes wm-overview-in") and html.contains("@keyframes wm-snap-pulse") and html.contains("@media (prefers-reduced-motion: reduce)") and html.contains("body[data-motion-mode='reduced'] .desktop::before") and html.contains("body[data-motion-mode='reduced'] .motion-window") and html.contains("body[data-motion-mode='reduced'] .command-palette") and html.contains("body[data-motion-mode='reduced'] .taskbar-running-indicator") and html.contains("body[data-motion-mode='reduced'] .notification-toast") and html.contains("body[data-motion-mode='reduced'] .workspace-switcher") and html.contains("body[data-motion-mode='reduced'] .shortcut-overlay") and html.contains("body[data-motion-mode='reduced'] .app-launcher") and html.contains("body[data-motion-mode='reduced'] .context-menu") and html.contains("body[data-motion-mode='reduced'] .hot-corner-ring") and html.contains("body[data-motion-mode='reduced'] .resize-hud") and html.contains("body[data-motion-mode='reduced'] .gesture-hints") and html.contains("body[data-motion-mode='reduced'] .taskbar-preview") and html.contains("body[data-motion-mode='reduced'] .stage-rail") and html.contains("body[data-motion-mode='off'] .desktop::before") and html.contains("body[data-motion-mode='off'] .motion-window") and html.contains("body[data-motion-mode='off'] .command-palette") and html.contains("body[data-motion-mode='off'] .taskbar-running-indicator") and html.contains("body[data-motion-mode='off'] .notification-toast") and html.contains("body[data-motion-mode='off'] .workspace-switcher") and html.contains("body[data-motion-mode='off'] .shortcut-overlay") and html.contains("body[data-motion-mode='off'] .app-launcher") and html.contains("body[data-motion-mode='off'] .context-menu") and html.contains("body[data-motion-mode='off'] .hot-corner-ring") and html.contains("body[data-motion-mode='off'] .resize-hud") and html.contains("body[data-motion-mode='off'] .gesture-hints") and html.contains("body[data-motion-mode='off'] .taskbar-preview") and html.contains("body[data-motion-mode='off'] .stage-rail") and html.contains("animation:none!important")

fn _os_render_quality_report():
    wm_scene_visual_quality_report(shared_wm_scene_to_chromed_wm_scene(_readiness_shared_scene(), _readiness_taskbar_model(), 1000, "09:41", 2))

fn _readiness_taskbar_model() -> TaskbarModel:
    TaskbarModel(
        pinned: [
            AppRef(app_id: "terminal", display_name: "Terminal", icon: ">"),
            AppRef(app_id: "browser", display_name: "Browser", icon: "https://simple.local/icon.png")
        ],
        running: [
            WindowRef(window_id: "win1", app_id: "terminal", title: "Terminal", minimized: false)
        ],
        tray: [
            TrayItem(item_id: "clock", label: "09:41", icon: "clock")
        ]
    )

fn _readiness_window(minimized: bool) -> WmLifecycleWindowState:
    WmLifecycleWindowState(id: if minimized: 2 else: 1, owner_port: 11, title: if minimized: "Hidden" else: "Active", x: 20, y: 60, w: 220, h: 160, content: "", process_id: 1, app_id: "/readiness", minimized: minimized, focused: not minimized)

fn _readiness_shared_scene() -> SharedWmScene:
    SharedWmScene(
        width: 800,
        height: 600,
        backend: "simpleos",
        windows: [
            SharedWmWindow(surface_id: "surf1", window_id: "win1", surface_kind: "simple_web", process_id: 1u64, app_id: "terminal", title: "Terminal", x: 20, y: 40, width: 300, height: 200, tree: nil, html: "", minimized: false, focused: true, z_index: 1)
        ]
    )

fn _modern_wm_notes(passed: bool, contrast_ratio_x100: i64) -> [text]:
    var notes: [text] = []
    if passed:
        notes = notes.push("modern WM readiness passed")
    else:
        notes = notes.push("modern WM readiness failed")
    notes.push("contrast_ratio_x100={contrast_ratio_x100}")
    notes
