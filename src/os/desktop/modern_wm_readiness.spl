struct RenderedIconPolicy:
    ready: bool
    inner_padding_px: i32
    mask_shape: text
    image_fit: text

fn modern_wm_readiness_report(theme: text) -> ModernWmReadinessReport:
    val web = wm_theme_quality_report(theme)
    val dock_ready = _os_dock_ready()
    val taskbar_ready = _os_taskbar_ready()
    val affordances_ready = _os_affordances_ready()
    val interaction_contract = modern_wm_interaction_contract()
    val interactions_ready = _os_interactions_ready()
    val lifecycle_ready = _lifecycle_motion_ready()
    val rendered_ready = _rendered_motion_ready()
    val rendered_icon_policy = _rendered_icon_policy()
    val rendered_affordances_ready = _rendered_affordances_ready() and _rendered_live_activity_ready() and _rendered_screen_capture_ready() and _rendered_clipboard_history_ready() and _rendered_privacy_indicator_ready() and _rendered_system_hud_ready() and _rendered_wallpaper_picker_ready() and _rendered_dock_stack_ready() and _rendered_widget_gallery_ready()
    val os_render_quality = _os_render_quality_report()
    val passed = web.passed and dock_ready and taskbar_ready and affordances_ready and interactions_ready and lifecycle_ready and rendered_ready and rendered_icon_policy.ready and rendered_affordances_ready and os_render_quality.passed
    ModernWmReadinessReport(
        theme: theme,
        passed: passed,
        web_quality_ready: web.passed,
        os_dock_ready: dock_ready,
        os_taskbar_ready: taskbar_ready,
        os_affordances_ready: affordances_ready,
        os_interactions_ready: interactions_ready,
        os_interaction_command_count: interaction_contract.command_count,
        os_interaction_shortcut_count: interaction_contract.shortcut_count,
        os_interaction_snap_layout_count: interaction_contract.snap_layout_count,
        os_interaction_motion_mode_count: interaction_contract.motion_mode_count,
        os_interaction_widget_command_count: interaction_contract.widget_command_count,
        os_interaction_overview_command_count: interaction_contract.overview_command_count,
        os_interaction_server_authoritative: interaction_contract.all_server_authoritative,
        os_interaction_local_preview_only: interaction_contract.local_preview_only,
        lifecycle_motion_ready: lifecycle_ready,
        rendered_motion_ready: rendered_ready,
        rendered_affordances_ready: rendered_affordances_ready,
        os_render_quality_ready: os_render_quality.passed,
        os_render_theme_configured: os_render_quality.theme_configured,
        os_render_round_scrollbars: os_render_quality.round_scrollbars,
        os_render_round_icon_converter: os_render_quality.round_icon_converter,
        os_render_icon_policy_ready: rendered_icon_policy.ready,
        os_render_icon_inner_padding_px: rendered_icon_policy.inner_padding_px,
        os_render_icon_mask_shape: rendered_icon_policy.mask_shape,
        os_render_icon_image_fit: rendered_icon_policy.image_fit,
        os_render_titlebar_input_ready: os_render_quality.titlebar_input_ready,
        os_render_traffic_controls_ready: os_render_quality.traffic_controls_ready,
        os_render_animated_background_ready: os_render_quality.animated_background_ready,
        os_render_window_interaction_ready: os_render_quality.window_interaction_ready,
        os_render_command_palette_ready: os_render_quality.command_palette_ready,
        os_render_command_palette_max_width_px: os_render_quality.max_command_palette_width_px,
        os_render_theme_accent_controls_ready: os_render_quality.theme_accent_controls_ready,
        os_render_focus_depth_ready: os_render_quality.focus_depth_ready,
        os_render_lifecycle_animation_ready: os_render_quality.lifecycle_animation_ready,
        os_render_taskbar_interaction_ready: os_render_quality.taskbar_interaction_ready,
        os_render_dock_magnification_ready: os_render_quality.dock_magnification_ready,
        os_render_notification_feedback_ready: os_render_quality.notification_feedback_ready,
        os_render_notification_max_width_px: os_render_quality.max_notification_width_px,
        os_render_notification_center_ready: os_render_quality.notification_center_ready,
        os_render_notification_center_max_width_px: os_render_quality.max_notification_center_width_px,
        os_render_live_activity_ready: os_render_quality.live_activity_ready,
