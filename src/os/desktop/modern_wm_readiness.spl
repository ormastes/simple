# Combined modern WM readiness audit for Web WM plus SimpleOS shell/compositor.

use app.ui.web.wm_quality_contract.{wm_theme_quality_report}
use os.compositor.wm_action_applier.{WmLifecycleWindowState, wm_lifecycle_motion_contract}
use os.compositor.wm_scene.{lifecycle_windows_to_motion_wm_scene, scene_to_html, shared_wm_scene_to_chromed_wm_scene, wm_scene_visual_quality_report}
