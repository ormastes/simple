"""SimpleOS guest adapter for the QEMU ivshmem host-GPU service."""

use common.gpu.simpleos_host_gpu_protocol.*
use common.gpu.simpleos_host_gpu_draw_ir.{
    SimpleOsHostGpuImageResource,
    simpleos_host_gpu_draw_ir_encode,
    simpleos_host_gpu_image_resource_coverage_reason,
    simpleos_host_gpu_image_resources_encode
}
use common.ui.draw_ir.{DrawIrComposition}
use os.kernel.boot.mmio_hardware.{mmio_read64, mmio_write64, mmio_write8, mmio_memory_barrier}
use os.kernel.boot.monotonic_hardware.{boot_monotonic_now_us}

val HOST_GPU_IVSHMEM_DEFAULT_TIMEOUT_POLLS: i64 = 50000000
val _HOST_GPU_IVSHMEM_MAX_GENERATION: i64 = 9223372036854775807

struct HostGpuIvshmemReceipt:
    completed: bool
    status: i64
    reason: i64
    generation: i64
    native_handle: i64
    output_addr: u64
    output_bytes: i64
    output_checksum: i64
    elapsed_us: i64
    readback_source: i64
    device_identity: i64
    run_id_hash: i64
    frame_id: i64
    backend_code: i64

struct HostGpuIvshmemHelloReceipt:
    published: bool
    completed: bool
    status: i64
    reason: i64
    generation: i64
    render_mask: i64
    processing_mask: i64
    max_payload_bytes: i64
    max_readback_bytes: i64
    version: i64
    elapsed_us: i64

fn _host_gpu_error_receipt(status: i64, reason: i64, generation: i64) -> HostGpuIvshmemReceipt:
    HostGpuIvshmemReceipt(completed: false, status: status, reason: reason, generation: generation, native_handle: 0, output_addr: 0u64, output_bytes: 0, output_checksum: 0, elapsed_us: 0, readback_source: 0, device_identity: 0, run_id_hash: 0, frame_id: 0, backend_code: 0)

fn host_gpu_ivshmem_device_receipt_valid(receipt: HostGpuIvshmemReceipt, expected_generation: i64, expected_run_id_hash: i64, expected_frame_id: i64, expected_backend: i64, expected_bytes: i64) -> bool:
    simpleos_host_gpu_wire_correlation_valid(expected_run_id_hash, expected_frame_id) and
        receipt.completed and receipt.generation == expected_generation and
        receipt.status == SIMPLEOS_HOST_GPU_STATUS_PASS and receipt.reason == 0 and
        receipt.native_handle > 0 and receipt.device_identity > 0 and receipt.output_addr > 0u64 and
        receipt.output_bytes == expected_bytes and receipt.output_checksum > 0 and receipt.elapsed_us > 0 and
        receipt.readback_source == SIMPLEOS_HOST_GPU_READBACK_DEVICE and
        receipt.run_id_hash == expected_run_id_hash and receipt.frame_id == expected_frame_id and
        receipt.backend_code == expected_backend

fn _host_gpu_write(base: u64, offset: i64, value: i64):
    mmio_write64(base + (offset as u64), value as u64)

fn _host_gpu_read(base: u64, offset: i64) -> i64:
    mmio_read64(base + (offset as u64)) as i64

fn _host_gpu_slot_is_idle(base: u64, completion: i64) -> bool:
    _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_REQUEST_GENERATION) == completion

fn host_gpu_ivshmem_next_generation(base: u64) -> i64:
    if base == 0u64:
        return 0
    val completion = _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_GENERATION)
    if completion < 0 or completion >= _HOST_GPU_IVSHMEM_MAX_GENERATION or not _host_gpu_slot_is_idle(base, completion):
        return 0
    completion + 1

fn _host_gpu_write_commands(base: u64, commands: [SimpleOsHostGpuWireCommand]) -> i64:
    var words: [i64] = []
    for command in commands:
        words.push(command.op)
        words.push(command.x)
        words.push(command.y)
        words.push(command.width)
        words.push(command.height)
        words.push(command.value)
    var i: i64 = 0
    while i < words.len():
        _host_gpu_write(base, simpleos_host_gpu_wire_payload_offset() + i * 8, words[i])
        i = i + 1
    simpleos_host_gpu_wire_checksum_words(words)

fn _host_gpu_write_bytes_at(base: u64, wire_offset: i64, bytes: [u8]):
    var i: i64 = 0
    while i < bytes.len():
        mmio_write8(base + (wire_offset as u64) + (i as u64), bytes[i])
        i = i + 1

fn _host_gpu_publish_payload(base: u64, generation: i64, completion: i64, run_id_hash: i64, frame_id: i64, kind: i64, backend_code: i64, width: i64, height: i64, element_count: i64, payload_bytes: i64, checksum: i64, image_resource_count: i64, image_resource_bytes: i64, image_resource_checksum: i64, timeout_polls: i64) -> HostGpuIvshmemReceipt:
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_MAGIC, SIMPLEOS_HOST_GPU_PROTOCOL_MAGIC)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_VERSION, SIMPLEOS_HOST_GPU_PROTOCOL_VERSION)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_KIND, kind)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_BACKEND, backend_code)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_WIDTH, width)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_HEIGHT, height)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_ELEMENT_COUNT, element_count)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_PAYLOAD_BYTES, payload_bytes)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_PAYLOAD_CHECKSUM, checksum)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_FRAME_ID, frame_id)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_RUN_ID_HASH, run_id_hash)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_STATUS, SIMPLEOS_HOST_GPU_STATUS_IDLE)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_COUNT, image_resource_count)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_BYTES, image_resource_bytes)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_CHECKSUM, image_resource_checksum)
    mmio_memory_barrier()
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_REQUEST_GENERATION, generation)

    var polls: i64 = 0
    var observed = completion
    while polls < timeout_polls and observed < generation:
        polls = polls + 1
        observed = _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_GENERATION)
    if observed != generation:
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_FAIL, if observed > generation: SIMPLEOS_HOST_GPU_REASON_STALE_GENERATION else: SIMPLEOS_HOST_GPU_REASON_TIMEOUT, generation)
    mmio_memory_barrier()
    val receipt = HostGpuIvshmemReceipt(
        completed: true,
        status: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_STATUS),
        reason: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_REASON),
        generation: generation,
        native_handle: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_NATIVE_HANDLE),
        output_addr: base + (simpleos_host_gpu_wire_readback_offset() as u64),
        output_bytes: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_OUTPUT_BYTES),
        output_checksum: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_OUTPUT_CHECKSUM),
        elapsed_us: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_ELAPSED_US),
        readback_source: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_READBACK_SOURCE),
        device_identity: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_DEVICE_IDENTITY),
        run_id_hash: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_RUN_ID_HASH),
        frame_id: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_FRAME_ID),
        backend_code: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_BACKEND)
    )
    if receipt.run_id_hash != run_id_hash or receipt.frame_id != frame_id or receipt.backend_code != backend_code:
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_CORRELATION_MISMATCH, generation)
    receipt

fn host_gpu_ivshmem_negotiate(base: u64, generation: i64, guest_isa: text, render_backend: text, processing_mask: i64, timeout_polls: i64, deadline_us: i64) -> HostGpuIvshmemHelloReceipt:
    val started_now = boot_monotonic_now_us()
    if deadline_us <= 0 or started_now <= 0 or started_now >= deadline_us:
        return HostGpuIvshmemHelloReceipt(published: false, completed: false, status: SIMPLEOS_HOST_GPU_STATUS_FAIL, reason: SIMPLEOS_HOST_GPU_REASON_TIMEOUT, generation: generation, render_mask: 0, processing_mask: 0, max_payload_bytes: 0, max_readback_bytes: 0, version: 0, elapsed_us: 0)
    val completion = if base == 0u64: generation else: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_GENERATION)
    if base == 0u64 or not simpleos_host_gpu_generation_is_fresh(generation, completion) or not _host_gpu_slot_is_idle(base, completion):
        return HostGpuIvshmemHelloReceipt(published: false, completed: false, status: SIMPLEOS_HOST_GPU_STATUS_FAIL, reason: SIMPLEOS_HOST_GPU_REASON_STALE_GENERATION, generation: generation, render_mask: 0, processing_mask: 0, max_payload_bytes: 0, max_readback_bytes: 0, version: 0, elapsed_us: 0)
    val backend_code = simpleos_host_gpu_backend_code(render_backend)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_MAGIC, SIMPLEOS_HOST_GPU_PROTOCOL_MAGIC)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_VERSION, SIMPLEOS_HOST_GPU_PROTOCOL_VERSION)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_KIND, SIMPLEOS_HOST_GPU_KIND_HELLO)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_BACKEND, backend_code)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_GUEST_ISA, simpleos_host_gpu_guest_isa_code(guest_isa))
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_REQUESTED_RENDER_MASK, simpleos_host_gpu_backend_mask(backend_code))
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_REQUESTED_PROCESSING_MASK, processing_mask)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_COUNT, 0)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_BYTES, 0)
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_IMAGE_RESOURCE_CHECKSUM, 0)
    mmio_memory_barrier()
    _host_gpu_write(base, SIMPLEOS_HOST_GPU_WIRE_REQUEST_GENERATION, generation)
    var polls: i64 = 0
    var observed = completion
    var now_us = started_now
    while polls < timeout_polls and observed < generation and now_us > 0 and now_us <= deadline_us:
        polls = polls + 1
        observed = _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_GENERATION)
        now_us = boot_monotonic_now_us()
    if observed != generation or now_us <= 0 or now_us > deadline_us:
        return HostGpuIvshmemHelloReceipt(published: true, completed: false, status: SIMPLEOS_HOST_GPU_STATUS_FAIL, reason: if observed > generation: SIMPLEOS_HOST_GPU_REASON_STALE_GENERATION else: SIMPLEOS_HOST_GPU_REASON_TIMEOUT, generation: generation, render_mask: 0, processing_mask: 0, max_payload_bytes: 0, max_readback_bytes: 0, version: 0, elapsed_us: 0)
    mmio_memory_barrier()
    HostGpuIvshmemHelloReceipt(published: true, completed: true, status: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_STATUS), reason: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_REASON), generation: generation, render_mask: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_RENDER_MASK), processing_mask: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_PROCESSING_MASK), max_payload_bytes: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_MAX_PAYLOAD), max_readback_bytes: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_MAX_READBACK), version: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_VERSION), elapsed_us: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_ELAPSED_US))

fn host_gpu_ivshmem_submit(
    base: u64,
    generation: i64,
    run_id_hash: i64,
    frame_id: i64,
    kind: i64,
    backend: text,
    width: i64,
    height: i64,
    element_count: i64,
    commands: [SimpleOsHostGpuWireCommand],
    timeout_polls: i64
) -> HostGpuIvshmemReceipt:
    val payload_bytes = commands.len().to_i64() * SIMPLEOS_HOST_GPU_WIRE_COMMAND_BYTES
    val completion = if base == 0u64: generation else: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_GENERATION)
    if base == 0u64 or not simpleos_host_gpu_generation_is_fresh(generation, completion) or not _host_gpu_slot_is_idle(base, completion):
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_STALE_GENERATION, generation)
    if not simpleos_host_gpu_wire_correlation_valid(run_id_hash, frame_id) or payload_bytes <= 0:
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, generation)
    if _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_VERSION) != SIMPLEOS_HOST_GPU_PROTOCOL_VERSION:
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_HELLO_REQUIRED, generation)
    val negotiated_max_payload = _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_MAX_PAYLOAD)
    if negotiated_max_payload <= 0 or negotiated_max_payload > SIMPLEOS_HOST_GPU_MAX_PAYLOAD_BYTES or payload_bytes > negotiated_max_payload:
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, generation)
    val backend_code = simpleos_host_gpu_backend_code(backend)
    if backend_code == 0:
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_UNSUPPORTED_BACKEND, generation)

    val checksum = _host_gpu_write_commands(base, commands)
    _host_gpu_publish_payload(base, generation, completion, run_id_hash, frame_id, kind, backend_code, width, height, element_count, payload_bytes, checksum, 0, 0, 0, timeout_polls)

fn host_gpu_ivshmem_submit_draw_ir(base: u64, generation: i64, run_id_hash: i64, frame_id: i64, backend: text, width: i64, height: i64, composition: DrawIrComposition, image_resources: [SimpleOsHostGpuImageResource], timeout_polls: i64) -> HostGpuIvshmemReceipt:
    val completion = if base == 0u64: generation else: _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_COMPLETION_GENERATION)
    if base == 0u64 or not simpleos_host_gpu_generation_is_fresh(generation, completion) or not _host_gpu_slot_is_idle(base, completion):
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_STALE_GENERATION, generation)
    if not simpleos_host_gpu_wire_correlation_valid(run_id_hash, frame_id):
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, generation)
    if _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_VERSION) != SIMPLEOS_HOST_GPU_PROTOCOL_VERSION:
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_HELLO_REQUIRED, generation)
    val negotiated_max_payload = _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_MAX_PAYLOAD)
    if negotiated_max_payload <= 0 or negotiated_max_payload > SIMPLEOS_HOST_GPU_MAX_PAYLOAD_BYTES:
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, generation)
    val backend_code = simpleos_host_gpu_backend_code(backend)
    if backend_code == 0:
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_UNSUPPORTED_BACKEND, generation)
    val negotiated_max_readback = _host_gpu_read(base, SIMPLEOS_HOST_GPU_WIRE_NEGOTIATED_MAX_READBACK)
    if negotiated_max_readback <= 0 or negotiated_max_readback > simpleos_host_gpu_max_readback_bytes():
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, generation)
    val payload = simpleos_host_gpu_draw_ir_encode(composition, negotiated_max_payload, SIMPLEOS_HOST_GPU_MAX_DRAW_IR_COMMANDS)
    if not payload.ok:
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, generation)
    if simpleos_host_gpu_image_resource_coverage_reason(composition, image_resources) != "":
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_UNSUPPORTED, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, generation)
    val resources = simpleos_host_gpu_image_resources_encode(image_resources, negotiated_max_readback, SIMPLEOS_HOST_GPU_MAX_DRAW_IR_COMMANDS)
    if not resources.ok:
        return _host_gpu_error_receipt(SIMPLEOS_HOST_GPU_STATUS_FAIL, SIMPLEOS_HOST_GPU_REASON_INVALID_REQUEST, generation)
    val payload_bytes = payload.bytes.len().to_i64()
    val command_count = payload.command_count
    val checksum = payload.checksum
    _host_gpu_write_bytes_at(base, simpleos_host_gpu_wire_readback_offset(), resources.bytes)
    _host_gpu_write_bytes_at(base, simpleos_host_gpu_wire_payload_offset(), payload.bytes)
    _host_gpu_publish_payload(base, generation, completion, run_id_hash, frame_id, SIMPLEOS_HOST_GPU_KIND_DRAW_IR, backend_code, width, height, command_count, payload_bytes, checksum, resources.resource_count, resources.bytes.len().to_i64(), resources.checksum, timeout_polls)

fn host_gpu_ivshmem_fill_u32(base: u64, generation: i64, run_id_hash: i64, frame_id: i64, backend: text, element_count: i64, value: u32, timeout_polls: i64) -> HostGpuIvshmemReceipt:
    val command = SimpleOsHostGpuWireCommand(op: SIMPLEOS_HOST_GPU_COMMAND_FILL_U32, x: 0, y: 0, width: 0, height: 0, value: value.to_i64())
    host_gpu_ivshmem_submit(base, generation, run_id_hash, frame_id, SIMPLEOS_HOST_GPU_KIND_PROCESSING, backend, 0, 0, element_count, [command], timeout_polls)

export HostGpuIvshmemReceipt, HostGpuIvshmemHelloReceipt, host_gpu_ivshmem_device_receipt_valid
export HOST_GPU_IVSHMEM_DEFAULT_TIMEOUT_POLLS, host_gpu_ivshmem_next_generation
export host_gpu_ivshmem_negotiate, host_gpu_ivshmem_submit, host_gpu_ivshmem_submit_draw_ir, host_gpu_ivshmem_fill_u32
