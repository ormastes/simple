# Driver Runtime — shared async runtime for SimpleOS user-space drivers
#
# Provides event loop, lifecycle management, and IPC helpers.
# All user-space drivers (NVMe, VirtIO-net, VirtIO-GPU) share this runtime.

use os.lib.driver_runtime.event_loop.{DriverEventLoop, DriverEvent, EVENT_IRQ, EVENT_IPC, EVENT_TIMER, EVENT_SHUTDOWN, EVENT_NONE}
use os.lib.driver_runtime.lifecycle.{DriverLifecycle, STATE_CREATED, STATE_PROBING, STATE_CLAIMED, STATE_INITIALIZING, STATE_PUBLISHING, STATE_SERVING, STATE_QUIESCING, STATE_STOPPED, STATE_FAILED}
use os.lib.driver_runtime.ipc_service.{ServiceEndpoint, service_health_respond, service_error_respond}
