use os.kernel.log.klog_api.{log_init, log_info, log_warn, log_error, log_raw, log_raw_println}
# Driver Lifecycle State Machine
#
# Standard lifecycle: Probe -> Claim -> Init -> Publish -> Serve -> Quiesce -> Restart
# Tracks state transitions and provides hooks for each phase.
#
# Valid transitions:
#   created -> probing -> claimed -> initializing -> publishing -> serving
#   serving -> quiescing -> stopped
#   any -> failed
#   failed -> created (restart)


# Lifecycle states
val STATE_CREATED: u8 = 0
val STATE_PROBING: u8 = 1
val STATE_CLAIMED: u8 = 2
val STATE_INITIALIZING: u8 = 3
val STATE_PUBLISHING: u8 = 4
val STATE_SERVING: u8 = 5
val STATE_QUIESCING: u8 = 6
val STATE_STOPPED: u8 = 7
val STATE_FAILED: u8 = 8

struct DriverLifecycle:
    """Tracks the lifecycle state of a user-space driver.

    Enforces valid state transitions and provides restart-safety
    with a configurable maximum restart count.
    """
    state: u8
    driver_name: text
    restart_count: u32
    max_restarts: u32
    last_error: text

impl DriverLifecycle:
    static fn new(name: text) -> DriverLifecycle:
        """Create a new lifecycle tracker in the 'created' state."""
        DriverLifecycle(
            state: STATE_CREATED,
            driver_name: name,
            restart_count: 0,
            max_restarts: 5,
            last_error: ""
        )

    fn state_name() -> text:
        """Return a human-readable name for the current state."""
        _state_name(self.state)

    fn is_serving() -> bool:
        """True if the driver is in the serving state."""
        self.state == STATE_SERVING

    fn is_failed() -> bool:
        """True if the driver is in the failed state."""
        self.state == STATE_FAILED

    me transition(new_state: u8) -> bool:
        """Attempt a state transition. Returns false if invalid."""
        val valid = _is_valid_transition(self.state, new_state)
        if valid:
            val from_name = self.state_name()
            val to_name = _state_name(new_state)
            log_info("[drvrt] " + "[{self.driver_name}] {from_name} -> {to_name}")
            self.state = new_state
        else:
            val from_name = self.state_name()
            val to_name = _state_name(new_state)
            log_info("[drvrt] " + "[{self.driver_name}] Invalid transition: {from_name} -> {to_name}")
        valid

    me fail(error: text):
        """Force the driver into the failed state with an error message."""
        self.last_error = error
        self.state = STATE_FAILED
        log_info("[drvrt] " + "[{self.driver_name}] FAILED: {error}")

    me can_restart() -> bool:
        """True if restart count has not exceeded the maximum."""
        self.restart_count < self.max_restarts

    me restart():
        """Reset state to 'created' and increment the restart counter."""
        self.restart_count = self.restart_count + 1
        self.state = STATE_CREATED
        self.last_error = ""
        log_info("[drvrt] " + "[{self.driver_name}] Restart #{self.restart_count}")

    me set_max_restarts(max: u32):
        """Override the default maximum restart count."""
        self.max_restarts = max

# ============================================================================
# Internal helpers
# ============================================================================

fn _is_valid_transition(from: u8, to: u8) -> bool:
    """Check whether a state transition is valid.

    Any state can transition to FAILED.
    FAILED can transition to CREATED (restart).
    Otherwise, only forward transitions along the happy path are valid.
    """
    if to == STATE_FAILED:
        return true
    if from == STATE_FAILED and to == STATE_CREATED:
        return true
    match from:
        case 0: to == STATE_PROBING
        case 1: to == STATE_CLAIMED
        case 2: to == STATE_INITIALIZING
        case 3: to == STATE_PUBLISHING
        case 4: to == STATE_SERVING
        case 5: to == STATE_QUIESCING
        case 6: to == STATE_STOPPED
        case _: false

fn _state_name(s: u8) -> text:
    """Return a human-readable name for a state constant."""
    match s:
        case 0: "created"
        case 1: "probing"
        case 2: "claimed"
        case 3: "initializing"
        case 4: "publishing"
        case 5: "serving"
        case 6: "quiescing"
        case 7: "stopped"
        case 8: "failed"
        case _: "unknown"
