# IPC Service Helpers — common patterns for driver/service IPC endpoints
#
# Wraps the raw IPC syscalls with typed service patterns.
# Each driver creates a ServiceEndpoint to receive requests and send replies.

use os.userlib.syscall_raw.{syscall}

extern fn serial_println(msg: text)

# Syscall numbers (must match kernel definitions)
val SYS_IPC_SEND: u64 = 20
val SYS_IPC_RECV: u64 = 21
val SYS_IPC_CREATE_PORT: u64 = 22

struct ServiceEndpoint:
    """An IPC service endpoint for receiving requests and sending replies.

    Wraps a kernel IPC port handle and tracks request count
    for health-check / diagnostics reporting.
    """
    port_handle: u64
    service_name: text
    request_count: u64

impl ServiceEndpoint:
    static fn create(name: text) -> ServiceEndpoint:
        """Create a new IPC service endpoint.

        Calls the kernel to allocate an IPC port. If allocation fails,
        port_handle is set to 0 (invalid).
        """
        val port = syscall(SYS_IPC_CREATE_PORT, 0, 0, 0, 0, 0)
        if port < 0:
            serial_println("[ipc-svc] Failed to create port for {name}")
            return ServiceEndpoint(port_handle: 0, service_name: name, request_count: 0)
        serial_println("[ipc-svc] Port created for {name}: handle={port}")
        ServiceEndpoint(port_handle: port as u64, service_name: name, request_count: 0)

    fn is_valid() -> bool:
        """True if the endpoint holds a valid port handle."""
        self.port_handle > 0

    fn get_request_count() -> u64:
        """Return the total number of requests received on this endpoint."""
        self.request_count

    me recv_blocking() -> i64:
        """Block until a message arrives. Returns message handle or -1."""
        if self.port_handle == 0:
            return -1
        val result = syscall(SYS_IPC_RECV, self.port_handle, 0, 0, 0, 0)
        if result >= 0:
            self.request_count = self.request_count + 1
        result

    me recv_poll() -> i64:
        """Non-blocking receive. Returns message handle, or -1 if nothing available."""
        if self.port_handle == 0:
            return -1
        # Non-blocking variant: arg1 = 1 signals non-blocking mode
        syscall(SYS_IPC_RECV, self.port_handle, 1, 0, 0, 0)

    me send_reply(dest: u64, method: u32, value: u64) -> bool:
        """Send a reply to a request.

        dest:   destination task / port handle
        method: reply method ID
        value:  reply payload value

        Returns true if the send succeeded.
        """
        val result = syscall(SYS_IPC_SEND, dest, method as u64, value, 0, 0)
        result >= 0

# ============================================================================
# Convenience helpers
# ============================================================================

fn service_health_respond(endpoint: ServiceEndpoint, sender: u64) -> bool:
    """Respond to a health-check ping from the driver supervisor.

    Sends a reply with value 1 (= healthy) to the given sender.
    """
    endpoint.send_reply(sender, 0, 1)

fn service_error_respond(endpoint: ServiceEndpoint, sender: u64, error_code: u64) -> bool:
    """Respond with an error code to a failed request.

    Convention: method 0xFFFF signals an error reply, value = error code.
    """
    endpoint.send_reply(sender, 0xFFFF, error_code)
