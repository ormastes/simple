# HTTP/3 Frame Layer — RFC 9114 §7.2
#
# Implements the HTTP/3 wire frame format:
#   - Variable-length integer encoding (RFC 9000 §16)
#   - Frame emit: varint(type) || varint(length) || payload
#   - Frame parse: decode type + length varints, slice payload
#
# Frame types (RFC 9114 §7.2):
#   DATA(0x00), HEADERS(0x01), CANCEL_PUSH(0x03), SETTINGS(0x04),
#   PUSH_PROMISE(0x05), GOAWAY(0x07), MAX_PUSH_ID(0x0d)
#
# No QUIC transport — frame layer only. Reserved-range/QPACK deferred.
#
# Reference: RFC 9114 §7.2, RFC 9000 §16

# ============================================================================
# Constants — frame type identifiers (RFC 9114 §7.2)
# ============================================================================

val H3_FRAME_DATA: u64        = 0x00u64
val H3_FRAME_HEADERS: u64     = 0x01u64
val H3_FRAME_CANCEL_PUSH: u64 = 0x03u64
val H3_FRAME_SETTINGS: u64    = 0x04u64
val H3_FRAME_PUSH_PROMISE: u64 = 0x05u64
val H3_FRAME_GOAWAY: u64      = 0x07u64
val H3_FRAME_MAX_PUSH_ID: u64 = 0x0du64

# ============================================================================
# Error type
# ============================================================================

enum H3Error:
    InvalidVarint(msg: text)
    TruncatedFrame(msg: text)
    InvalidLength(msg: text)

# ============================================================================
# Result types
# ============================================================================

enum H3VarintResult:
    Ok(value: u64, consumed: u64)
    Err(e: H3Error)

enum H3FrameResult:
    Ok(frame_type: u64, payload: [u8], new_offset: u64)
    Err(e: H3Error)

# ============================================================================
# Internal helpers
# ============================================================================

fn _h3_u8_at(buf: [u8], idx: u64) -> u8:
    buf[idx]

fn _h3_append(dst: [u8], src: [u8]) -> [u8]:
    """Append src onto dst without relying on array concatenation."""
    var out: [u8] = dst
    var i: u64 = 0
    while i < src.len():
        out.push(src[i])
        i = i + 1u64
    out

# ============================================================================
# Variable-length integer encoding — RFC 9000 §16
#
# Two bits of the first byte give the encoded length:
#   00 → 1 byte  (value fits in 6 bits,  0..63)
#   01 → 2 bytes (value fits in 14 bits, 0..16383)
#   10 → 4 bytes (value fits in 30 bits, 0..1073741823)
#   11 → 8 bytes (value fits in 62 bits, 0..2^62-1)
#
# The value bits are big-endian and share the first byte with the prefix.
# ============================================================================

pub fn h3_varint_encode(u: u64) -> [u8]:
    """Encode a u64 as an RFC 9000 variable-length integer."""
    var out: [u8] = []
    if u <= 63u64:
        # 1-byte form: 0b00xxxxxx
        out.push(u.to_u8())
    elif u <= 16383u64:
        # 2-byte form: 0b01xxxxxx xxxxxxxx
        val hi = (0x4000u64 | u)
        out.push(((hi >> 8) & 0xffu64).to_u8())
        out.push((hi & 0xffu64).to_u8())
    elif u <= 1073741823u64:
        # 4-byte form: 0b10xxxxxx xxxxxxxx xxxxxxxx xxxxxxxx
        val v = 0x80000000u64 | u
        out.push(((v >> 24) & 0xffu64).to_u8())
        out.push(((v >> 16) & 0xffu64).to_u8())
        out.push(((v >> 8) & 0xffu64).to_u8())
        out.push((v & 0xffu64).to_u8())
    else:
        # 8-byte form: 0b11xxxxxx ... (62-bit value)
        val v = 0xc000000000000000u64 | u
        out.push(((v >> 56) & 0xffu64).to_u8())
        out.push(((v >> 48) & 0xffu64).to_u8())
        out.push(((v >> 40) & 0xffu64).to_u8())
        out.push(((v >> 32) & 0xffu64).to_u8())
        out.push(((v >> 24) & 0xffu64).to_u8())
        out.push(((v >> 16) & 0xffu64).to_u8())
        out.push(((v >> 8) & 0xffu64).to_u8())
        out.push((v & 0xffu64).to_u8())
    out

pub fn h3_varint_decode(bytes: [u8], offset: u64) -> H3VarintResult:
    """Decode an RFC 9000 variable-length integer from bytes at offset.

    Returns Ok(value, consumed_bytes) on success, Err on truncation or
    invalid input. consumed_bytes is 1, 2, 4, or 8.
    """
    if offset >= bytes.len():
        return H3VarintResult.Err(H3Error.InvalidVarint("offset past end of buffer"))
    val first = _h3_u8_at(bytes, offset).to_u64()
    val prefix = first >> 6
    if prefix == 0u64:
        # 1-byte form
        return H3VarintResult.Ok(value: first & 0x3fu64, consumed: 1u64)
    elif prefix == 1u64:
        # 2-byte form
        if offset + 2u64 > bytes.len():
            return H3VarintResult.Err(H3Error.InvalidVarint("2-byte varint truncated"))
        val b1 = _h3_u8_at(bytes, offset + 1u64).to_u64()
        val v = ((first & 0x3fu64) << 8) | b1
        return H3VarintResult.Ok(value: v, consumed: 2u64)
    elif prefix == 2u64:
        # 4-byte form
        if offset + 4u64 > bytes.len():
            return H3VarintResult.Err(H3Error.InvalidVarint("4-byte varint truncated"))
        val b1 = _h3_u8_at(bytes, offset + 1u64).to_u64()
        val b2 = _h3_u8_at(bytes, offset + 2u64).to_u64()
        val b3 = _h3_u8_at(bytes, offset + 3u64).to_u64()
        val v = ((first & 0x3fu64) << 24) | (b1 << 16) | (b2 << 8) | b3
        return H3VarintResult.Ok(value: v, consumed: 4u64)
    else:
        # 8-byte form (prefix == 3)
        if offset + 8u64 > bytes.len():
            return H3VarintResult.Err(H3Error.InvalidVarint("8-byte varint truncated"))
        val b1 = _h3_u8_at(bytes, offset + 1u64).to_u64()
        val b2 = _h3_u8_at(bytes, offset + 2u64).to_u64()
        val b3 = _h3_u8_at(bytes, offset + 3u64).to_u64()
        val b4 = _h3_u8_at(bytes, offset + 4u64).to_u64()
        val b5 = _h3_u8_at(bytes, offset + 5u64).to_u64()
        val b6 = _h3_u8_at(bytes, offset + 6u64).to_u64()
        val b7 = _h3_u8_at(bytes, offset + 7u64).to_u64()
        val v = ((first & 0x3fu64) << 56) | (b1 << 48) | (b2 << 40) | (b3 << 32) | (b4 << 24) | (b5 << 16) | (b6 << 8) | b7
        return H3VarintResult.Ok(value: v, consumed: 8u64)
    H3VarintResult.Err(H3Error.InvalidVarint("unreachable"))

# ============================================================================
# Frame emit — RFC 9114 §7.2
#
# Wire format: varint(type) || varint(length) || payload
# ============================================================================

pub fn h3_frame_emit(frame_type: u64, payload: [u8]) -> [u8]:
    """Encode an HTTP/3 frame: varint(type) || varint(len) || payload."""
    val type_bytes = h3_varint_encode(frame_type)
    val len_bytes = h3_varint_encode(payload.len())
    var out: [u8] = []
    var i: u64 = 0
    while i < type_bytes.len():
        out.push(type_bytes[i])
        i = i + 1u64
    i = 0u64
    while i < len_bytes.len():
        out.push(len_bytes[i])
        i = i + 1u64
    i = 0u64
    while i < payload.len():
        out.push(payload[i])
        i = i + 1u64
    out

# ============================================================================
# Frame parse — RFC 9114 §7.2
# ============================================================================

pub fn h3_frame_parse(bytes: [u8], offset: u64) -> H3FrameResult:
    """Parse one HTTP/3 frame from bytes starting at offset.

    Returns Ok(frame_type, payload, new_offset) where new_offset points
    past the end of this frame. Returns Err on truncation or bad varint.
    """
    # Decode frame type varint
    val type_r = h3_varint_decode(bytes, offset)
    match type_r:
        H3VarintResult.Err(e):
            return H3FrameResult.Err(e)
        H3VarintResult.Ok(value: ftype, consumed: type_len):
            val after_type = offset + type_len
            # Decode payload length varint
            val len_r = h3_varint_decode(bytes, after_type)
            match len_r:
                H3VarintResult.Err(e):
                    return H3FrameResult.Err(e)
                H3VarintResult.Ok(value: payload_len, consumed: len_len):
                    val payload_start = after_type + len_len
                    val payload_end = payload_start + payload_len
                    if payload_end > bytes.len():
                        return H3FrameResult.Err(H3Error.TruncatedFrame("frame payload truncated"))
                    var payload: [u8] = []
                    var j: u64 = payload_start
                    while j < payload_end:
                        payload.push(bytes[j])
                        j = j + 1u64
                    return H3FrameResult.Ok(frame_type: ftype, payload: payload, new_offset: payload_end)
    H3FrameResult.Err(H3Error.TruncatedFrame("unreachable"))
