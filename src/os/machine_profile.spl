# SimpleOS Shared Machine Profiles
#
# This module defines the small shared board/profile slice used by:
# - `simple os` for the existing QEMU-backed OS boot path
# - `simple sim` for profile inspection and simulator-oracle routing
#
# The repo-native simulator is not implemented yet. These profiles cover the
# shared baremetal QEMU contracts currently reused by `simple os` and
# `simple sim`.

use os.kernel.arch.arch_context.{Architecture}
use os.port.simpleos_multiplatform_build.{simpleos_platform_target_by_name}

struct MachineProfile:
    name: text
    arch: Architecture
    xlen: i64
    isa: text
    abi: text
    boot_protocol: text
    entry: text
    linker_script: text
    target_triple: text
    output: text
    qemu_system: text
    qemu_machine: text
    qemu_cpu: text
    qemu_memory: text
    qemu_bios: text
    qemu_extra: [text]
    qemu_serial_kind: text
    qemu_serial_base: u64
    console: text
    oracle_path: text
    notes: text

fn machine_arch_name(arch: Architecture) -> text:
    match arch:
        Architecture.Riscv64: "riscv64"
        Architecture.Riscv32: "riscv32"
        Architecture.X86_64: "x86_64"
        Architecture.X86: "x86"
        Architecture.Arm64: "arm64"
        Architecture.Arm32: "arm32"

fn machine_profile_name(profile: MachineProfile) -> text:
    profile.name

fn _shared_machine_profile(
    platform_name: text,
    profile_name: text,
    isa_display: text,
    boot_protocol: text,
    qemu_memory: text,
    qemu_bios: text,
    notes: text
) -> MachineProfile:
    if val platform = simpleos_platform_target_by_name(platform_name):
        return MachineProfile(
            name: profile_name,
            arch: platform.arch,
            xlen: platform.bits,
            isa: isa_display,
            abi: platform.abi,
            boot_protocol: boot_protocol,
            entry: platform.default_entry,
            linker_script: platform.linker_script,
            target_triple: platform.native_target,
            output: platform.kernel_output,
            qemu_system: platform.qemu_system,
            qemu_machine: platform.qemu_machine,
            qemu_cpu: platform.qemu_cpu,
            qemu_memory: qemu_memory,
            qemu_bios: qemu_bios,
            qemu_extra: [],
            qemu_serial_kind: platform.qemu_serial_kind,
            qemu_serial_base: platform.qemu_serial_base,
            console: "serial",
            oracle_path: "simple os run --arch={platform.platform_slug}",
            notes: notes
        )

    val fallback_arch = if platform_name == "riscv32": Architecture.Riscv32
        elif platform_name == "arm64": Architecture.Arm64
        elif platform_name == "arm32": Architecture.Arm32
        else: Architecture.Riscv64
    val fallback_bits: i64 = if fallback_arch == Architecture.Riscv32 or fallback_arch == Architecture.Arm32: 32 else: 64
    val fallback_qemu_system = if fallback_arch == Architecture.Riscv32: "qemu-system-riscv32"
        elif fallback_arch == Architecture.Riscv64: "qemu-system-riscv64"
        elif fallback_arch == Architecture.Arm64: "qemu-system-aarch64"
        else: "qemu-system-arm"
    val fallback_qemu_cpu = if fallback_arch == Architecture.Riscv32: "rv32"
        elif fallback_arch == Architecture.Riscv64: "rv64"
        elif fallback_arch == Architecture.Arm64: "cortex-a72"
        else: "cortex-a15"
    val fallback_serial_kind = if fallback_arch == Architecture.Riscv32 or fallback_arch == Architecture.Riscv64: "ns16550" else: "pl011"
    val fallback_serial_base = if fallback_arch == Architecture.Riscv32 or fallback_arch == Architecture.Riscv64: 0x10000000u64 else: 0x09000000u64

    MachineProfile(
        name: profile_name,
        arch: fallback_arch,
        xlen: fallback_bits,
        isa: isa_display,
        abi: if fallback_arch == Architecture.Riscv64: "lp64d"
            elif fallback_arch == Architecture.Riscv32: "ilp32"
            elif fallback_arch == Architecture.Arm64: "aapcs64"
            else: "eabihf",
        boot_protocol: boot_protocol,
        entry: "src/os/kernel/arch/{platform_name}/boot.spl",
        linker_script: "src/os/kernel/arch/{platform_name}/linker.ld",
        target_triple: "{platform_name}-unknown-none",
        output: "build/os/simpleos_{platform_name}.elf",
        qemu_system: fallback_qemu_system,
        qemu_machine: "virt",
        qemu_cpu: fallback_qemu_cpu,
        qemu_memory: qemu_memory,
        qemu_bios: qemu_bios,
        qemu_extra: [],
        qemu_serial_kind: fallback_serial_kind,
        qemu_serial_base: fallback_serial_base,
        console: "serial",
        oracle_path: "simple os run --arch={platform_name}",
        notes: notes
    )

fn riscv_machine_profile(platform_name: text, profile_name: text, isa_display: text) -> MachineProfile:
    val is_rv32 = platform_name == "riscv32"
    _shared_machine_profile(
        platform_name,
        profile_name,
        isa_display,
        if is_rv32: "dtb" else: "opensbi",
        "128M",
        if is_rv32: "none" else: "default",
        "Shared baremetal RISC-V profile; repo-native simulator remains pending."
    )

fn arm_machine_profile(platform_name: text, profile_name: text, isa_display: text) -> MachineProfile:
    _shared_machine_profile(
        platform_name,
        profile_name,
        isa_display,
        "raw-loader",
        "128M",
        "",
        "Shared baremetal ARM virt profile; repo-native simulator remains pending."
    )

fn riscv64_machine_profile() -> MachineProfile:
    riscv_machine_profile("riscv64", "simple-rv64", "RV64GC")

fn riscv32_machine_profile() -> MachineProfile:
    riscv_machine_profile("riscv32", "simple-rv32", "RV32IMAC")

fn arm64_machine_profile() -> MachineProfile:
    arm_machine_profile("arm64", "simple-arm64", "ARMv8-A")

fn arm32_machine_profile() -> MachineProfile:
    arm_machine_profile("arm32", "simple-arm32", "ARMv7-A")

fn get_riscv_machine_profiles() -> [MachineProfile]:
    [
        riscv64_machine_profile(),
        riscv32_machine_profile()
    ]

fn get_riscv_machine_profile(arch_name: text) -> MachineProfile?:
    if arch_name == "riscv64" or arch_name == "simple-rv64":
        Some(riscv64_machine_profile())
    elif arch_name == "riscv32" or arch_name == "simple-rv32":
        Some(riscv32_machine_profile())
    else:
        nil

fn get_arm_machine_profiles() -> [MachineProfile]:
    [
        arm64_machine_profile(),
        arm32_machine_profile()
    ]

fn get_arm_machine_profile(arch_name: text) -> MachineProfile?:
    if arch_name == "arm64" or arch_name == "aarch64" or arch_name == "simple-arm64":
        Some(arm64_machine_profile())
    elif arch_name == "arm32" or arch_name == "armv7" or arch_name == "simple-arm32":
        Some(arm32_machine_profile())
    else:
        nil

fn get_machine_profile(arch: Architecture) -> MachineProfile?:
    match arch:
        Architecture.Riscv64:
            Some(riscv64_machine_profile())
        Architecture.Riscv32:
            Some(riscv32_machine_profile())
        Architecture.Arm64:
            Some(arm64_machine_profile())
        Architecture.Arm32:
            Some(arm32_machine_profile())
        _:
            nil
