use os.drivers.input.ps2_keyboard.{KeyEvent, Key}
use os.drivers.input.ps2_mouse.{MouseEvent}

trait InputBackend:
    me poll_key() -> KeyEvent?
    me poll_mouse() -> MouseEvent?
    fn alt_held() -> bool
    fn shift_held() -> bool
    fn ctrl_held() -> bool
    fn key_to_char(key: Key) -> text?
