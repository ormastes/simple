# Compositor Input Backend — trait abstracting keyboard + mouse input sources
#
# The compositor reads input through this trait instead of directly calling
# PS/2 drivers, allowing transparent switching between PS/2, USB HID,
# VirtIO input, or other input sources.
#
# One implementation:
#   - Ps2InputBackend: wraps Ps2Keyboard + Ps2Mouse (legacy PS/2 port I/O)

use os.drivers.input.ps2_keyboard.{Ps2Keyboard, KeyEvent, Key}
use os.drivers.input.ps2_mouse.{Ps2Mouse, MouseEvent}

# ============================================================================
# Input Backend Trait
# ============================================================================

trait InputBackend:
    """Abstract input interface for the window compositor.

    Implementations wrap platform-specific keyboard and mouse drivers,
    exposing a uniform polling API for the compositor's event loop.
    """
    me poll_key() -> KeyEvent?
    me poll_mouse() -> MouseEvent?
    fn alt_held() -> bool
    fn shift_held() -> bool
    fn ctrl_held() -> bool
    fn key_to_char(key: Key) -> text?

# ============================================================================
# PS/2 Input Backend
# ============================================================================

class Ps2InputBackend:
    """InputBackend wrapping PS/2 keyboard and mouse drivers.

    Delegates all input polling and modifier queries to the underlying
    Ps2Keyboard and Ps2Mouse instances. Suitable for x86 platforms
    with standard PS/2 controller at ports 0x60/0x64.
    """
    keyboard: Ps2Keyboard
    mouse: Ps2Mouse

impl InputBackend for Ps2InputBackend:

    me poll_key() -> KeyEvent?:
        self.keyboard.poll()

    me poll_mouse() -> MouseEvent?:
        self.mouse.poll()

    fn alt_held() -> bool:
        self.keyboard.alt_held

    fn shift_held() -> bool:
        self.keyboard.shift_held

    fn ctrl_held() -> bool:
        self.keyboard.ctrl_held

    fn key_to_char(key: Key) -> text?:
        self.keyboard.key_to_char(key)

impl Ps2InputBackend:

    static fn create(keyboard: Ps2Keyboard, mouse: Ps2Mouse) -> Ps2InputBackend:
        """Create a PS/2 input backend from initialized keyboard and mouse drivers."""
        Ps2InputBackend(keyboard: keyboard, mouse: mouse)
