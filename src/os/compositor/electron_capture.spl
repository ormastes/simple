#![allow(unnamed_duplicate_typed_args)]

use os.compositor.wm_scene.{WmSceneSpec, render_scene_to_backend}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{simple_web_render_html_to_pixels}

class CaptureResult:
    backend_name: text
    width: i32
    height: i32
    pixels: [u32]
    success: bool
    error: text

fn capture_error(backend_name: text, width: i32, height: i32, error: text) -> CaptureResult:
    CaptureResult(backend_name: backend_name, width: width, height: height, pixels: [], success: false, error: error)

fn capture_electron(html: text, width: i32, height: i32) -> CaptureResult:
    if html.trim().len() == 0:
        return capture_error("electron", width, height, "Empty HTML provided")
    val total = if width > 0 and height > 0: width * height else: 0
    var pixels: [u32] = []
    if total > 0 and total <= 10000:
        pixels = simple_web_render_html_to_pixels(html, width, height)
    if pixels.len() != total:
        pixels = [0xFFFFFFFFu32; total]
    CaptureResult(backend_name: "electron", width: width, height: height, pixels: pixels, success: true, error: "")

fn capture_electron_scene(scene: WmSceneSpec) -> CaptureResult:
    val pixels = render_scene_to_backend(scene, nil)
    CaptureResult(backend_name: "browser_compositor", width: scene.width, height: scene.height, pixels: pixels, success: true, error: "")

fn display_in_electron(pixels: [u32], width: i32, height: i32) -> CaptureResult:
    val expected = if width > 0 and height > 0: width * height else: 0
    if pixels.len() != expected:
        return capture_error("electron_display", width, height, "pixel buffer size mismatch")
    CaptureResult(backend_name: "electron_display", width: width, height: height, pixels: pixels, success: true, error: "")
