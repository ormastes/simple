# SimpleOS Window Compositor
#
# Implements RenderBackend trait targeting framebuffer.
# Manages windows as surfaces via SurfaceManager.
#   - FramebufferBackend (RenderBackend impl)
#   - Window Z-ordering, clipping, damage tracking
#   - Input multiplexer (focus, Alt-Tab, mouse click/drag)
#   - Desktop shell (taskbar, launcher, tray)
#
# Modules:
#   - fb_backend.spl      — FramebufferBackend (RenderBackend, direct FB rendering)
#   - browser_backend.spl  — BrowserBackend (RenderBackend, browser engine pipeline)
#   - compositor.spl       — Window compositor with Z-order, focus, input routing
#   - decorations.spl      — Window chrome: title bar, close button, borders
#   - cursor.spl           — Mouse cursor rendering (12x19 arrow bitmap)

use os.compositor.fb_backend.{FramebufferBackend}
use os.compositor.browser_backend.{BrowserBackend}
use os.compositor.compositor.{Compositor, WindowSurface}
use os.compositor.decorations.{draw_window_frame, draw_glass_window_frame, draw_glass_window_frame_enhanced}
use os.compositor.glass_effects.{GlassConfig, glass_begin_frame, glass_present, draw_glass_rect}
use os.compositor.glass_effects_pure.{draw_glass_rect_pure, draw_glass_border_pure}
use os.compositor.glass_dispatch.{cap_blend_rect, cap_blur_region, cap_gradient_v, cap_read_pixel}
use os.compositor.cursor.{CursorState, draw_cursor}
use os.compositor.browser_compositor_backend.{BrowserCompositorBackend}
use os.compositor.display_backend.{CompositorBackend, FbCompositorBackend, GpuCompositorBackend}
use os.compositor.engine2d_display.{create_fb_engine, create_gpu_engine}
use os.compositor.desktop_chrome.{draw_system_bar, draw_dock, SYSTEM_BAR_HEIGHT, DOCK_HEIGHT}
use os.compositor.window_effects.{draw_glass_window_enhanced, draw_focus_ring, draw_inactive_dim}
use os.compositor.render_extras.{draw_wallpaper, draw_wallpaper_enhanced, gradient_rect}
use os.compositor.app_content.{render_app_content, AppState, app_state_new, render_app_content_stateful, handle_app_input, handle_app_click}
use os.compositor.text_render.{draw_text_at, draw_text_shadow, draw_text_bold, draw_text_2x, draw_text_scaled, draw_text_vector}
use os.compositor.rendering_primitives.{rounded_rect_aa, draw_line, gradient_h, filled_circle, draw_ring, gradient_radial, draw_vignette, superellipse_rect}
use os.compositor.easing.{bounce_offset, ease_out_cubic, ease_in_cubic, ease_in_out_quad, spring_ease, lerp_i32}
use os.compositor.boot_splash.{draw_boot_splash}
use os.compositor.flex_layout.{FlexItem, flex_fixed, flex_fill, flex_compute, flex_x, flex_w}
