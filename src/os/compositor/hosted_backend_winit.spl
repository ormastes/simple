use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}

extern fn rt_winit_buffer_create(w: i64, h: i64, fill_color: i64) -> i64
extern fn rt_winit_buffer_fill_rect(buf: i64, x: i32, y: i32, w: i32, h: i32, color: i64) -> bool
extern fn rt_winit_buffer_draw_text(buf: i64, x: i32, y: i32, text_str: text, fg: i64, bg: i64) -> bool
extern fn rt_winit_buffer_present(win: i64, buf: i64) -> bool
extern fn rt_winit_buffer_free(buf: i64) -> bool

class HostedWinitBufferBackend:
    window_id: i64
    buffer_id: i64
    w: i32
    h: i32
    present_count: i64

    static fn new(window_id: i64, buffer_id: i64, w: i32, h: i32) -> HostedWinitBufferBackend:
        HostedWinitBufferBackend(window_id: window_id, buffer_id: buffer_id, w: w, h: h, present_count: 0)

    static fn create(window_id: i64, w: i32, h: i32, clear_color: u32) -> HostedWinitBufferBackend?:
        if window_id <= 0 or w <= 0 or h <= 0:
            return nil
        val buffer = rt_winit_buffer_create(w.to_i64(), h.to_i64(), clear_color.to_i64())
        if buffer <= 0:
            return nil
        HostedWinitBufferBackend.new(window_id, buffer, w, h)

    static fn implementation_name() -> text:
        "winit-buffer-simple-web"

    me free():
        if self.buffer_id > 0:
            rt_winit_buffer_free(self.buffer_id)
            self.buffer_id = 0

impl CompositorBackend for HostedWinitBufferBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        if self.buffer_id > 0:
            rt_winit_buffer_fill_rect(self.buffer_id, 0, 0, self.w, self.h, color.to_i64())

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        if self.buffer_id > 0:
            rt_winit_buffer_fill_rect(self.buffer_id, x, y, w, h, color.to_i64())

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        if self.buffer_id > 0:
            rt_winit_buffer_draw_text(self.buffer_id, x, y, text_str, fg.to_i64(), bg.to_i64())

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        self.draw_text(x, y, "{ch}", fg, bg)

    me put_pixel(x: i32, y: i32, color: u32):
        self.fill_rect(x, y, 1, 1, color)

    me present():
        if self.window_id > 0 and self.buffer_id > 0:
            rt_winit_buffer_present(self.window_id, self.buffer_id)
            self.present_count = self.present_count + 1

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        self.present()

    fn as_glass_capable() -> CompositorGlassCapable?:
        nil
