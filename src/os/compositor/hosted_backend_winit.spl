use os.compositor.display_backend_core.{CompositorBackend, CompositorGlassCapable}
use os.drivers.framebuffer.fb_font.{get_glyph_8x16}

extern fn rt_winit_window_staging_ptr(win: i64, w: i64, h: i64) -> i64
extern fn rt_winit_window_stage_clear(win: i64, w: i64, h: i64, color: i64) -> i64
extern fn rt_winit_window_present_staged(win: i64, w: i64, h: i64) -> i64
extern fn rt_ptr_write_i32(addr: i64, offset: i64, value: i32)

class HostedWinitBufferBackend:
    window_id: i64
    buffer_id: i64
    w: i32
    h: i32
    present_count: i64
    pixels: [u32]

    static fn new(window_id: i64, buffer_id: i64, w: i32, h: i32) -> HostedWinitBufferBackend:
        HostedWinitBufferBackend(window_id: window_id, buffer_id: buffer_id, w: w, h: h, present_count: 0, pixels: [0u32; w * h])

    static fn create(window_id: i64, w: i32, h: i32, clear_color: u32) -> HostedWinitBufferBackend?:
        if window_id <= 0 or w <= 0 or h <= 0:
            return nil
        if rt_winit_window_stage_clear(window_id, w.to_i64(), h.to_i64(), clear_color.to_i64()) == 0:
            return nil
        val backend = HostedWinitBufferBackend.new(window_id, window_id, w, h)
        backend.pixels = [clear_color; w * h]
        backend

    static fn implementation_name() -> text:
        "simple-2d-winit-buffer"

    fn get_pixel_buffer() -> [u32]:
        self.pixels

    me free():
        self.buffer_id = 0

fn hosted_winit_present_pure_simple_pixels(backend: HostedWinitBufferBackend, pixels: [u32], width: i32, height: i32) -> bool:
    if backend.window_id <= 0 or width <= 0 or height <= 0 or pixels.len() != width * height:
        return false
    backend.w = width
    backend.h = height
    backend.pixels = pixels
    val ptr = rt_winit_window_staging_ptr(backend.window_id, width as i64, height as i64)
    if ptr <= 0:
        return false
    var i = 0
    while i < pixels.len():
        rt_ptr_write_i32(ptr, i as i64 * 4, pixels[i] as i32)
        i = i + 1
    if rt_winit_window_present_staged(backend.window_id, width as i64, height as i64) == 0:
        return false
    backend.present_count = backend.present_count + 1
    true

impl CompositorBackend for HostedWinitBufferBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        if self.window_id > 0:
            self.pixels = [color; self.w * self.h]

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        if self.window_id > 0:
            var row = 0
            while row < h:
                var col = 0
                while col < w:
                    val px = x + col
                    val py = y + row
                    if px >= 0 and py >= 0 and px < self.w and py < self.h:
                        self.pixels[py * self.w + px] = color
                    col = col + 1
                row = row + 1

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        if self.window_id > 0:
            var cx = x
            for ch in text_str:
                val glyph = get_glyph_8x16(ch.char_code_at(0).to_u8())
                var row = 0
                while row < 16:
                    val bits = glyph[row]
                    var col = 0
                    while col < 8:
                        val px = cx + col
                        val py = y + row
                        if px >= 0 and py >= 0 and px < self.w and py < self.h:
                            val mask = (0x80 >> col).to_u8()
                            self.pixels[py * self.w + px] = if (bits & mask) != 0u8: fg else: bg
                        col = col + 1
                    row = row + 1
                cx = cx + 8

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        self.draw_text(x, y, "{ch}", fg, bg)

    me put_pixel(x: i32, y: i32, color: u32):
        self.fill_rect(x, y, 1, 1, color)

    me blit_pixels(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        if self.window_id > 0:
            var row = 0
            while row < h:
                var col = 0
                while col < w:
                    val src = row * w + col
                    val px = x + col
                    val py = y + row
                    if src >= 0 and src < pixels.len() and px >= 0 and py >= 0 and px < self.w and py < self.h:
                        self.pixels[py * self.w + px] = pixels[src]
                    col = col + 1
                row = row + 1

    me present():
        if self.window_id > 0:
            val ptr = rt_winit_window_staging_ptr(self.window_id, self.w.to_i64(), self.h.to_i64())
            if ptr > 0:
                var i = 0
                while i < self.pixels.len():
                    rt_ptr_write_i32(ptr, i.to_i64() * 4, self.pixels[i].to_i32())
                    i = i + 1
                if rt_winit_window_present_staged(self.window_id, self.w.to_i64(), self.h.to_i64()) != 0:
                    self.present_count = self.present_count + 1

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        self.present()

    fn as_glass_capable() -> CompositorGlassCapable?:
        nil
