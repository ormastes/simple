# Window Compositor
#
# Manages windows as surfaces in Z-order, routes input to the focused
# window, and orchestrates rendering of all visible windows plus
# their decorations onto the framebuffer.
#
# Each window owns a UISession, reusing the existing UI system.
# The compositor itself is NOT a RenderBackend — it uses the
# FramebufferDriver directly for compositing, and delegates
# per-window rendering to FramebufferBackend.

use common.ui.widget.{WidgetNode, UITree, UIState, UIEvent, UIMode}
use common.ui.session.{UISession, new_session}
use common.ui.layout.{compute_layout}
use common.ui.builder.{column, text_widget}
use os.drivers.framebuffer.fb_driver.{FramebufferDriver, Color}
use os.drivers.input.ps2_keyboard.{Ps2Keyboard, KeyEvent, Key}
use os.drivers.input.ps2_mouse.{Ps2Mouse, MouseEvent}
use os.compositor.decorations.{draw_window_frame, draw_glass_window_frame, draw_glass_window_frame_enhanced, TITLE_BAR_HEIGHT, BORDER_WIDTH, client_area_x, client_area_y, client_area_width, client_area_height, is_in_title_bar, is_in_close_button}
use os.compositor.glass_effects.{GlassConfig, glass_begin_frame, glass_present, glass_gradient_v, draw_glass_rect}
# glass_effects_pure.GlassConfig not imported — we use GlassPortConfig for pure Simple path
use os.compositor.glass_port.{GlassPort, GlassPortConfig, glass_port_name, register_pure_glass, gp_begin_frame, gp_present, gp_gradient_v, gp_draw_rect, gp_draw_text, gp_fill}
use os.compositor.cursor.{CursorState, default_cursor_state, draw_cursor}
use os.compositor.fb_backend.{_render_tree, resolve_theme, CHAR_W, CHAR_H}
use os.compositor.desktop_chrome.{draw_system_bar, draw_dock, SYSTEM_BAR_HEIGHT, DOCK_HEIGHT}
use os.compositor.window_effects.{draw_glass_window_enhanced}
use os.compositor.render_extras.{draw_wallpaper_enhanced}
use os.compositor.app_content.{render_app_content, render_app_content_stateful, AppState, app_state_new, handle_app_input, handle_app_click}
use os.compositor.easing.{bounce_offset, ease_out_cubic, ease_in_cubic}
use common.window_protocol.window_protocol.{WmInputEvent, wm_input_event, WM_EVENT_KEY_PRESS, WM_EVENT_MOUSE_CLICK, WM_EVENT_MOUSE_MOVE, WM_EVENT_MOUSE_RELEASE}
use os.compositor.display_backend.{CompositorBackend, FbCompositorBackend}
use os.compositor.input_backend.{InputBackend, Ps2InputBackend}
# NOTE: Shared shortcut table lives in os.gui.shortcut (ShortcutHandler,
# uart_char_to_action).  The compositor keeps its own Alt+key handling below
# because non-shortcut keys must route to focused windows -- importing
# ShortcutHandler would intercept bare keys (T, Q, M, W, R) that should
# reach in-process text editors and remote apps.

# ============================================================================
# Edge Resize Detection
# ============================================================================

fn _detect_resize_edge(mx: i32, my: i32, wx: i32, wy: i32, ww: i32, wh: i32) -> i32:
    """Detect which resize edge the cursor is on (6px hit zone). Returns 0-8."""
    val edge: i32 = 6
    val on_left = mx >= wx - edge and mx < wx + edge
    val on_right = mx >= wx + ww - edge and mx < wx + ww + edge
    val on_top = my >= wy - edge and my < wy + edge
    val on_bottom = my >= wy + wh - edge and my < wy + wh + edge
    val in_x = mx >= wx - edge and mx < wx + ww + edge
    val in_y = my >= wy - edge and my < wy + wh + edge
    # Corners first
    if on_left and on_top and in_x and in_y: return 5   # TL
    if on_right and on_top and in_x and in_y: return 6  # TR
    if on_left and on_bottom and in_x and in_y: return 7  # BL
    if on_right and on_bottom and in_x and in_y: return 8  # BR
    # Edges
    if on_left and in_y: return 1   # left
    if on_right and in_y: return 2  # right
    if on_top and in_x: return 3    # top
    if on_bottom and in_x: return 4 # bottom
    0  # none

# ============================================================================
# Window Surface
# ============================================================================

struct WindowSurface:
    """A managed window in the compositor.

    Each surface has its own UISession containing the widget tree,
    plus position/size and rendering state.

    owner_port: IPC port of the owning application.
      0 = local in-process window (UI dispatched directly to UISession)
      >0 = remote app's IPC port (input queued for IPC delivery)
    """
    id: u64
    title: text
    x: i32
    y: i32
    width: i32
    height: i32
    visible: bool
    session: UISession?
    dirty: bool
    owner_port: u64

# ============================================================================
# Pre-maximize saved geometry — for restore after maximize
# ============================================================================

struct SavedGeometry:
    """Saved window geometry before maximize, used to restore."""
    window_id: u64
    x: i32
    y: i32
    width: i32
    height: i32

# ============================================================================
# Compositor
# ============================================================================

class Compositor:
    """Window compositor managing multiple surfaces.

    Surfaces are stored in Z-order: index 0 is the backmost window,
    last index is the frontmost. The focused window is always rendered
    on top.
    """
    surfaces: [WindowSurface]
    focused_idx: i32
    backend: CompositorBackend
    input: InputBackend
    cursor: CursorState
    app_states: [AppState]
    desktop_bg: u32
    next_id: u64
    screen_width: i32
    screen_height: i32
    running: bool
    dragging: bool
    drag_window_id: u64
    drag_offset_x: i32
    drag_offset_y: i32
    pending_shortcut_key: text
    pending_meta_key: i32
    pending_remote_events: [WmInputEvent]
    saved_geometries: [SavedGeometry]
    taskbar_height: i32
    glass_theme_active: bool
    glass_config: GlassConfig
    # Animation state (integer easing, QEMU-compatible)
    anim_progress: i32
    anim_active: bool
    minimize_active: bool
    minimize_progress: i32
    minimize_win: i32
    close_active: bool
    close_progress: i32
    close_win: i32
    # Snap state
    snap_zone: i32          # 0=none, 1=left, 2=right, 3=full, 4=topL, 5=topR, 6=botL, 7=botR
    snap_preview_active: bool
    # Alt+Tab switcher overlay
    switcher_active: bool
    switcher_timer: i32     # frames to show overlay (counts down)
    # Theme transition
    theme_transitioning: bool
    theme_progress: i32     # 0-100
    theme_target_dark: bool
    # Edge resize state
    resizing: bool
    resize_window_id: u64
    resize_edge: i32        # 0=none, 1=left, 2=right, 3=top, 4=bottom, 5=TL, 6=TR, 7=BL, 8=BR
    resize_start_mx: i32    # mouse x at resize start
    resize_start_my: i32    # mouse y at resize start
    resize_orig_x: i32     # window x at resize start
    resize_orig_y: i32     # window y at resize start
    resize_orig_w: i32     # window width at resize start
    resize_orig_h: i32     # window height at resize start
    # Dock bounce animation
    dock_bounce_active: bool
    dock_bounce_progress: i32
    dock_bounce_icon: i32   # dock icon index to bounce (-1 = none)
    # Double-click state
    last_click_x: i32
    last_click_y: i32
    last_click_frame: i32
    frame_count: i32
    # Desktop right-click context menu
    context_menu_active: bool
    context_menu_x: i32
    context_menu_y: i32
    context_menu_sel: i32   # selected item: 0, 1, or 2
    # Window open animation
    open_anim_active: bool
    open_anim_progress: i32
    open_anim_win: i32      # surface index of opening window
    # Spotlight search overlay
    spotlight_active: bool

impl Compositor:

    static fn new(fb: FramebufferDriver, keyboard: Ps2Keyboard, mouse: Ps2Mouse) -> Compositor:
        """Create a compositor with baremetal framebuffer and PS/2 input.

        Wraps the concrete drivers in CompositorBackend + InputBackend
        traits so the compositor uses a single rendering/input path.
        """
        val sw = fb.width.to_i32()
        val sh = fb.height.to_i32()
        val cb = FbCompositorBackend.new(fb)
        val ib = Ps2InputBackend.create(keyboard, mouse)
        Compositor.with_backends(cb, ib, sw, sh)

    static fn with_backends(b: CompositorBackend, i: InputBackend, sw: i32, sh: i32) -> Compositor:
        """Create a compositor using abstract backend and input traits.

        Works on all platforms: baremetal (FB/GPU), hosted (winit).
        """
        val initial_cursor = CursorState(
            x: sw / 2,
            y: sh / 2,
            visible: true,
            shape: 0,
            hotspot_x: 1,
            hotspot_y: 1
        )
        Compositor(
            surfaces: [],
            focused_idx: -1,
            backend: b,
            input: i,
            cursor: initial_cursor,
            app_states: [],
            desktop_bg: 0xFF003060,
            next_id: 1,
            screen_width: sw,
            screen_height: sh,
            running: false,
            dragging: false,
            drag_window_id: 0,
            drag_offset_x: 0,
            drag_offset_y: 0,
            pending_shortcut_key: "",
            pending_meta_key: 0,
            pending_remote_events: [],
            saved_geometries: [],
            taskbar_height: 32,
            glass_theme_active: false,
            glass_config: GlassConfig.dark(),
            anim_progress: 100,
            anim_active: false,
            minimize_active: false,
            minimize_progress: 0,
            minimize_win: -1,
            close_active: false,
            close_progress: 0,
            close_win: -1,
            snap_zone: 0,
            snap_preview_active: false,
            switcher_active: false,
            switcher_timer: 0,
            theme_transitioning: false,
            theme_progress: 0,
            theme_target_dark: true,
            resizing: false,
            resize_window_id: 0,
            resize_edge: 0,
            resize_start_mx: 0,
            resize_start_my: 0,
            resize_orig_x: 0,
            resize_orig_y: 0,
            resize_orig_w: 0,
            resize_orig_h: 0,
            dock_bounce_active: false,
            dock_bounce_progress: 0,
            dock_bounce_icon: -1,
            last_click_x: 0,
            last_click_y: 0,
            last_click_frame: 0,
            frame_count: 0,
            context_menu_active: false,
            context_menu_x: 0,
            context_menu_y: 0,
            context_menu_sel: 0,
            open_anim_active: false,
            open_anim_progress: 0,
            open_anim_win: -1,
            spotlight_active: false
        )

    # -- Window Management ---------------------------------------------------

    me create_window(title: text, x: i32, y: i32, w: i32, h: i32) -> u64:
        """Create a new window surface and return its ID.

        The window gets a default widget tree (empty column).
        """
        val id = self.next_id
        self.next_id = self.next_id + 1

        val root = column("win_{id}_root", [
            text_widget("win_{id}_content", "")
        ])
        val tree = UITree.new(root)
        val session = new_session(tree)

        val surface = WindowSurface(
            id: id,
            title: title,
            x: x,
            y: y,
            width: w,
            height: h,
            visible: true,
            session: session,
            dirty: true,
            owner_port: 0
        )

        self.surfaces = self.surfaces.push(surface)
        self.app_states = self.app_states.push(app_state_new())
        self.focused_idx = self.surfaces.len() - 1

        # Trigger dock bounce for the new window's icon
        self.dock_bounce_active = true
        self.dock_bounce_progress = 0
        if title == "Terminal": self.dock_bounce_icon = 0
        else if title == "File Manager" or title == "Finder": self.dock_bounce_icon = 1
        else if title == "Calculator": self.dock_bounce_icon = 2
        else if title == "Browser": self.dock_bounce_icon = 5
        else if title == "Editor": self.dock_bounce_icon = 6
        else: self.dock_bounce_icon = -1

        self.open_anim_active = true
        self.open_anim_progress = 0
        self.open_anim_win = self.surfaces.len() - 1

        return id

    me add_surface(title: text, x: i32, y: i32, w: i32, h: i32) -> u64:
        """Create a lightweight window surface without a UISession widget tree.

        For baremetal use where the UI builder DSL is auto-stubbed.
        Windows are rendered as solid rectangles with title bars.
        """
        val id = self.next_id
        self.next_id = self.next_id + 1

        val surface = WindowSurface(
            id: id,
            title: title,
            x: x,
            y: y,
            width: w,
            height: h,
            visible: true,
            session: nil,
            dirty: true,
            owner_port: 0
        )

        self.surfaces = self.surfaces.push(surface)
        self.app_states = self.app_states.push(app_state_new())
        self.focused_idx = self.surfaces.len() - 1
        return id

    me create_window_with_tree(title: text, x: i32, y: i32, w: i32, h: i32, tree: UITree) -> u64:
        """Create a new window with a pre-built widget tree."""
        val id = self.next_id
        self.next_id = self.next_id + 1

        val session = new_session(tree)

        val surface = WindowSurface(
            id: id,
            title: title,
            x: x,
            y: y,
            width: w,
            height: h,
            visible: true,
            session: session,
            dirty: true,
            owner_port: 0
        )

        self.surfaces = self.surfaces.push(surface)
        self.focused_idx = self.surfaces.len() - 1
        return id

    me destroy_window(id: u64):
        """Remove a window by ID."""
        var updated: [WindowSurface] = []
        var updated_states: [AppState] = []
        var i: i32 = 0
        while i < self.surfaces.len():
            if self.surfaces[i].id != id:
                updated = updated.push(self.surfaces[i])
                if i < self.app_states.len():
                    updated_states = updated_states.push(self.app_states[i])
            i = i + 1
        self.surfaces = updated
        self.app_states = updated_states

        # Fix focused index
        if self.surfaces.len() == 0:
            self.focused_idx = -1
        elif self.focused_idx >= self.surfaces.len():
            self.focused_idx = self.surfaces.len() - 1

    me focus_window(id: u64):
        """Bring a window to focus (front of Z-order)."""
        var target_idx: i32 = -1
        var idx: i32 = 0
        for s in self.surfaces:
            if s.id == id:
                target_idx = idx
            idx = idx + 1

        if target_idx < 0:
            return

        # Move target to end of list (topmost Z-order), keeping app_states aligned
        val target = self.surfaces[target_idx]
        val target_state = if target_idx < self.app_states.len(): self.app_states[target_idx] else: app_state_new()
        var reordered: [WindowSurface] = []
        var reordered_states: [AppState] = []
        var j: i32 = 0
        while j < self.surfaces.len():
            if self.surfaces[j].id != id:
                reordered = reordered.push(self.surfaces[j])
                if j < self.app_states.len():
                    reordered_states = reordered_states.push(self.app_states[j])
            j = j + 1
        reordered = reordered.push(target)
        reordered_states = reordered_states.push(target_state)
        self.surfaces = reordered
        self.app_states = reordered_states
        self.focused_idx = self.surfaces.len() - 1

    me move_window(id: u64, new_x: i32, new_y: i32):
        """Move a window to a new position."""
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id == id:
                updated = updated.push(WindowSurface(
                    id: s.id, title: s.title,
                    x: new_x, y: new_y,
                    width: s.width, height: s.height,
                    visible: s.visible, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
        self.surfaces = updated

    me resize_window(id: u64, new_w: i32, new_h: i32):
        """Resize a window."""
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id == id:
                updated = updated.push(WindowSurface(
                    id: s.id, title: s.title,
                    x: s.x, y: s.y,
                    width: new_w, height: new_h,
                    visible: s.visible, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
        self.surfaces = updated

    me create_remote_window(title: text, x: i32, y: i32, w: i32, h: i32, owner_port: u64) -> u64:
        """Create a new window surface owned by a remote app process.

        The owner_port identifies the IPC port of the owning application.
        Input events for this window will be queued in pending_remote_events
        instead of dispatched directly to the UISession.
        """
        val id = self.next_id
        self.next_id = self.next_id + 1

        val root = column("win_{id}_root", [
            text_widget("win_{id}_content", "")
        ])
        val tree = UITree.new(root)
        val session = new_session(tree)

        val surface = WindowSurface(
            id: id,
            title: title,
            x: x,
            y: y,
            width: w,
            height: h,
            visible: true,
            session: session,
            dirty: true,
            owner_port: owner_port
        )

        self.surfaces = self.surfaces.push(surface)
        self.focused_idx = self.surfaces.len() - 1
        return id

    me mark_window_dirty(id: u64):
        """Mark a window as needing re-render.

        Sets the dirty flag on the WindowSurface so the compositor
        repaints it on the next frame.
        """
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id == id:
                updated = updated.push(WindowSurface(
                    id: s.id, title: s.title,
                    x: s.x, y: s.y,
                    width: s.width, height: s.height,
                    visible: s.visible, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
        self.surfaces = updated

    me update_window_tree(id: u64, new_tree: UITree):
        """Replace the widget tree of a window and mark it dirty.

        Used by the WM service to apply remote tree updates received
        via IPC from app processes.
        """
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id == id:
                s.session.update_tree(new_tree)
                updated = updated.push(WindowSurface(
                    id: s.id, title: s.title,
                    x: s.x, y: s.y,
                    width: s.width, height: s.height,
                    visible: s.visible, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
        self.surfaces = updated

    me lower_window(id: u64):
        """Send a window to the back of the Z-order.

        The window becomes the backmost surface but remains visible.
        """
        var target_idx: i32 = -1
        var idx: i32 = 0
        for s in self.surfaces:
            if s.id == id:
                target_idx = idx
            idx = idx + 1

        if target_idx < 0:
            return

        # Move target to index 0 (backmost Z-order)
        val target = self.surfaces[target_idx]
        var reordered: [WindowSurface] = [target]
        for s in self.surfaces:
            if s.id != id:
                reordered = reordered.push(s)
        self.surfaces = reordered

        # Adjust focused index
        if self.focused_idx == target_idx:
            # Lowered the focused window — focus the new topmost
            if self.surfaces.len() > 1:
                self.focused_idx = self.surfaces.len() - 1
            else:
                self.focused_idx = 0
        elif self.focused_idx > target_idx:
            # Focused window moved down one slot
            self.focused_idx = self.focused_idx - 1

    me minimize_window(id: u64):
        """Minimize a window (hide it).

        Sets visible=false. The window remains in the surface list
        and can be restored later.
        """
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id == id:
                updated = updated.push(WindowSurface(
                    id: s.id, title: s.title,
                    x: s.x, y: s.y,
                    width: s.width, height: s.height,
                    visible: false, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
        self.surfaces = updated

    me maximize_window(id: u64):
        """Maximize a window to fill the screen (minus taskbar).

        Saves the current geometry so it can be restored later.
        """
        # Find current geometry and save it
        for s in self.surfaces:
            if s.id == id:
                # Save geometry before maximizing
                val saved = SavedGeometry(
                    window_id: id,
                    x: s.x,
                    y: s.y,
                    width: s.width,
                    height: s.height
                )
                # Replace existing saved geometry for this window
                var new_saved: [SavedGeometry] = []
                for g in self.saved_geometries:
                    if g.window_id != id:
                        new_saved = new_saved.push(g)
                new_saved = new_saved.push(saved)
                self.saved_geometries = new_saved

        # Resize to full screen minus taskbar
        val max_w = self.screen_width
        val max_h = self.screen_height - self.taskbar_height
        val zero: i32 = 0
        self.move_window(id, zero, zero)
        self.resize_window(id, max_w, max_h)

    me restore_window(id: u64):
        """Restore a window from minimized or maximized state.

        If the window was maximized, restores to its pre-maximize geometry.
        If the window was minimized (hidden), makes it visible again.
        """
        # Check if we have saved geometry (was maximized)
        var found_geo: SavedGeometry? = nil
        for g in self.saved_geometries:
            if g.window_id == id:
                found_geo = g

        if found_geo != nil:
            val geo = found_geo
            val gx = geo.x
            val gy = geo.y
            val gw = geo.width
            val gh = geo.height
            self.move_window(id, gx, gy)
            self.resize_window(id, gw, gh)
            # Remove saved geometry
            var remaining: [SavedGeometry] = []
            for g in self.saved_geometries:
                if g.window_id != id:
                    remaining = remaining.push(g)
            self.saved_geometries = remaining
        else:
            # Was minimized — just make visible
            var updated: [WindowSurface] = []
            for s in self.surfaces:
                if s.id == id:
                    updated = updated.push(WindowSurface(
                        id: s.id, title: s.title,
                        x: s.x, y: s.y,
                        width: s.width, height: s.height,
                        visible: true, session: s.session,
                        dirty: true,
                        owner_port: s.owner_port
                    ))
                else:
                    updated = updated.push(s)
            self.surfaces = updated

    me set_window_title(id: u64, new_title: text):
        """Change the title of a window."""
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id == id:
                updated = updated.push(WindowSurface(
                    id: s.id, title: new_title,
                    x: s.x, y: s.y,
                    width: s.width, height: s.height,
                    visible: s.visible, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
        self.surfaces = updated

    me consume_remote_events() -> [WmInputEvent]:
        """Drain and return all pending remote input events.

        Called by the WM service to collect events that need to be
        delivered to remote app processes via IPC.
        """
        val events = self.pending_remote_events
        self.pending_remote_events = []
        events

    me queue_remote_event(event: WmInputEvent):
        """Queue an input event for a remote window.

        Used internally when input is directed at a window with
        owner_port > 0.
        """
        self.pending_remote_events = self.pending_remote_events.push(event)

    # -- Queries -------------------------------------------------------------

    fn window_count() -> i32:
        var count: i32 = 0
        for s in self.surfaces:
            count = count + 1
        return count

    fn focused_window_id() -> u64:
        if self.focused_idx >= 0 and self.focused_idx < self.surfaces.len():
            return self.surfaces[self.focused_idx].id
        return 0

    fn get_surface(id: u64) -> WindowSurface?:
        for s in self.surfaces:
            if s.id == id:
                return s
        return nil

    fn window_titles() -> [text]:
        """Get titles of all windows in Z-order."""
        var titles: [text] = []
        for s in self.surfaces:
            titles = titles.push(s.title)
        return titles

    # -- Rendering -----------------------------------------------------------

    me render_all():
        """Composite all windows via CompositorBackend.

        Single rendering path for all platforms (baremetal + hosted).
        Draws desktop background, windows back-to-front, cursor on top.
        When glass_theme_active is true, uses glassmorphism rendering path.

        Glass rendering has two backends (auto-selected via DI glass port):
          - C FFI (baremetal QEMU): uses rt_gui_* extern calls
          - Pure Simple (hosted/browser): uses CompositorBackend trait methods
        """
        if self.glass_theme_active:
            if glass_port_name() == "pure_simple":
                # Pure Simple glass path — uses CompositorBackend trait via DI port
                self._render_glass_pure()
            else:
                # C FFI glass path (baremetal QEMU)
                val sw = self.screen_width.to_u64()
                val sh = self.screen_height.to_u64()
                glass_begin_frame(sw, sh)
                glass_gradient_v(0, 0, sw, sh, self.glass_config.bg_top, self.glass_config.bg_bottom)

                var idx: i32 = 0
                for surface in self.surfaces:
                    if surface.visible:
                        val is_focused = idx == self.focused_idx
                        _render_glass_window(self.backend, surface, is_focused, self.glass_config)
                    idx = idx + 1

                draw_cursor(self.backend, self.screen_width, self.screen_height, self.cursor)
                glass_present()
        else:
            # Standard compositing path
            self.backend.clear(self.desktop_bg)

            var idx: i32 = 0
            for surface in self.surfaces:
                if surface.visible:
                    val is_focused = idx == self.focused_idx
                    _render_window(self.backend, surface, is_focused)
                idx = idx + 1

            draw_cursor(self.backend, self.screen_width, self.screen_height, self.cursor)
            self.backend.present()

    me _render_glass_pure():
        """Glass rendering via pure Simple — full desktop chrome.

        Uses shared modules for cross-platform rendering:
        - render_extras: enhanced wallpaper with stars/vignette/tech grid
        - window_effects: multi-layer shadows, frosted glass, focus ring, noise
        - desktop_chrome: system bar (top) + dock (bottom)
        - app_content: shared Terminal/Editor/FileManager/Calculator content
        All via CompositorBackend trait — works on hosted + baremetal.
        """
        val gc = self.glass_config
        # Convert u64 GlassConfig to u32/u8/i32 GlassPortConfig for pure Simple path
        val sc: u32 = gc.surface_color
        val sa: u8 = gc.surface_alpha
        val br: u32 = gc.blur_radius
        val bc: u32 = gc.border_color
        val ba: u8 = gc.border_alpha
        val so: i32 = gc.shadow_offset
        val sb: u32 = gc.shadow_blur
        val sha: u8 = gc.shadow_alpha
        val ac: u32 = gc.accent_color
        val ac2: u32 = gc.accent2_color
        val bgt: u32 = gc.bg_top
        val bgb: u32 = gc.bg_bottom
        val cfg = GlassPortConfig(
            surface_color: sc, surface_alpha: sa,
            blur_radius: br, border_color: bc, border_alpha: ba,
            shadow_offset: so, shadow_blur: sb, shadow_alpha: sha,
            accent_color: ac, accent2_color: ac2,
            bg_top: bgt, bg_bottom: bgb
        )

        # 1. Enhanced wallpaper with stars, vignette, tech grid
        self.backend.clear(0xFF000000)
        val is_dark = gc.bg_top < 0x00808080
        draw_wallpaper_enhanced(self.backend, is_dark, gc.accent_color, gc.accent2_color, self.frame_count)

        # Snap zone preview overlay (blue=left, purple=right, green=fullscreen)
        if self.snap_preview_active and self.snap_zone > 0:
            val bar_h = SYSTEM_BAR_HEIGHT
            val dock_h: i32 = 68
            val usable_h = self.screen_height - bar_h - dock_h
            val half_w = self.screen_width / 2
            if self.snap_zone == 1:
                self.backend.blend_rect(0, bar_h, half_w, usable_h, gc.accent_color, 30)
                # Left edge highlight
                self.backend.blend_rect(0, bar_h, 3, usable_h, gc.accent_color, 80)
            else if self.snap_zone == 2:
                self.backend.blend_rect(half_w, bar_h, half_w, usable_h, gc.accent2_color, 30)
                # Right edge highlight
                self.backend.blend_rect(self.screen_width - 3, bar_h, 3, usable_h, gc.accent2_color, 80)
            else if self.snap_zone == 3:
                self.backend.blend_rect(0, bar_h, self.screen_width, usable_h, 0x0030D158, 20)
                # Top edge highlight
                self.backend.blend_rect(0, bar_h, self.screen_width, 3, 0x0030D158, 80)

        # 2. Windows (back-to-front Z-order) with animation
        val active_idx = self.focused_idx
        val boff = bounce_offset(self.anim_progress)
        var idx: i32 = 0
        for surface in self.surfaces:
            if surface.visible:
                val is_focused = idx == self.focused_idx

                # Apply animation offsets
                var wy = surface.y
                var wx = surface.x
                var ww = surface.width
                var wh = surface.height
                var skip_render = false

                # Focused window gets bounce offset
                if is_focused and self.anim_active:
                    wy = wy - boff

                # Minimize animation: shrink toward dock icon
                if self.minimize_active and idx == self.minimize_win:
                    val prog = ease_out_cubic(self.minimize_progress)
                    val dock_y = self.screen_height - 58
                    # Target specific dock icon based on window title
                    var icon_idx: i32 = 0
                    if surface.title == "Terminal":
                        icon_idx = 0
                    else if surface.title == "File Manager" or surface.title == "Finder":
                        icon_idx = 1
                    else if surface.title == "Calculator":
                        icon_idx = 2
                    else if surface.title == "Browser":
                        icon_idx = 5
                    else if surface.title == "Editor":
                        icon_idx = 6
                    val dock_total_w: i32 = 520
                    val dock_start = (self.screen_width - dock_total_w) / 2 + 16
                    val dock_pill: i32 = 48
                    val dock_gap: i32 = 16
                    val dock_x = dock_start + icon_idx * (dock_pill + dock_gap) + dock_pill / 2
                    wx = surface.x + (dock_x - surface.x) * prog / 100
                    wy = surface.y + (dock_y - surface.y) * prog / 100
                    ww = surface.width - surface.width * prog / 120
                    wh = surface.height - surface.height * prog / 120
                    if ww < 10 or wh < 10:
                        skip_render = true

                # Close animation: shrink inward
                if self.close_active and idx == self.close_win:
                    val prog = ease_in_cubic(self.close_progress)
                    val shrink = prog * 15 / 100
                    wx = surface.x + shrink
                    wy = surface.y + shrink
                    ww = surface.width - shrink * 2
                    wh = surface.height - shrink * 2
                    if ww < 10 or wh < 10:
                        skip_render = true

                # Open animation: scale up from center
                if self.open_anim_active and idx == self.open_anim_win:
                    val open_prog = ease_out_cubic(self.open_anim_progress)
                    val scale = 30 + open_prog * 70 / 100  # 30% -> 100%
                    val orig_w = ww
                    val orig_h = wh
                    ww = orig_w * scale / 100
                    wh = orig_h * scale / 100
                    wx = wx + (orig_w - ww) / 2
                    wy = wy + (orig_h - wh) / 2
                    if ww < 20 or wh < 20:
                        skip_render = true

                if not skip_render:
                    # Enhanced glass window frame (shared window_effects)
                    val is_dragging = self.dragging and self.drag_window_id == surface.id
                    draw_glass_window_enhanced(self.backend, wx, wy,
                        ww, wh, surface.title, is_focused, cfg, 28, is_dragging)

                    # App content (shared app_content)
                    val cx = client_area_x(wx)
                    val cy = client_area_y(wy)
                    val cw = client_area_width(ww)
                    val ch_val = client_area_height(wh)
                    if cw > 0 and ch_val > 0:
                        if idx < self.app_states.len():
                            render_app_content_stateful(self.backend, surface.title, cx, cy, cw, ch_val, self.app_states[idx])
                        else:
                            render_app_content(self.backend, surface.title, cx, cy, cw, ch_val)
            idx = idx + 1

        # 3. System bar (top) + Dock (bottom) — shared desktop chrome
        draw_system_bar(self.backend, cfg, active_idx, self.frame_count)
        val bounce_icon = if self.dock_bounce_active: self.dock_bounce_icon else: -1
        val bounce_prog = if self.dock_bounce_active: self.dock_bounce_progress else: 0
        draw_dock(self.backend, cfg, active_idx, self.cursor.x, self.cursor.y, bounce_icon, bounce_prog)

        # 4. Global accent tint + bottom edge line
        self.backend.blend_rect(0, self.screen_height - 2, self.screen_width, 2, 0x00000000, 20)
        self.backend.blend_rect(0, 0, self.screen_width, self.screen_height, gc.accent_color, 2)

        # Alt+Tab switcher overlay
        if self.switcher_active and self.focused_idx >= 0:
            val ow: i32 = 300
            val oh: i32 = 60
            val ox = (self.screen_width - ow) / 2
            val oy = (self.screen_height - oh) / 2
            # Glass background
            self.backend.blur_region(ox, oy, ow, oh, 16)
            self.backend.blend_rect(ox, oy, ow, oh, gc.surface_color, gc.surface_alpha)
            # Border
            self.backend.blend_rect(ox, oy, ow, 1, gc.border_color, gc.border_alpha)
            self.backend.blend_rect(ox, oy + oh - 1, ow, 1, gc.border_color, gc.border_alpha)
            self.backend.blend_rect(ox, oy, 1, oh, gc.border_color, gc.border_alpha)
            self.backend.blend_rect(ox + ow - 1, oy, 1, oh, gc.border_color, gc.border_alpha)
            # Window title
            if self.focused_idx < self.surfaces.len():
                val title = self.surfaces[self.focused_idx].title
                self.backend.draw_text(ox + ow / 2 - 32, oy + 8, title, 0xFFFFFFFF, 0x00000000)
            # Window index indicator
            var wi: i32 = 0
            val dot_y = oy + oh - 16
            val dot_start = ox + ow / 2 - self.surfaces.len() * 8
            while wi < self.surfaces.len():
                val dot_x = dot_start + wi * 16
                if wi == self.focused_idx:
                    self.backend.blend_rect(dot_x, dot_y, 8, 8, gc.accent_color, 200)
                else:
                    self.backend.blend_rect(dot_x, dot_y, 8, 8, 0x00FFFFFF, 60)
                wi = wi + 1

        # Desktop right-click context menu
        if self.context_menu_active:
            val cm_w: i32 = 160
            val cm_h: i32 = 80
            val cm_x = self.context_menu_x
            val cm_y = self.context_menu_y
            # Glass background
            self.backend.blur_region(cm_x, cm_y, cm_w, cm_h, 16)
            self.backend.blend_rect(cm_x, cm_y, cm_w, cm_h, gc.surface_color, gc.surface_alpha)
            # Border
            self.backend.blend_rect(cm_x, cm_y, cm_w, 1, gc.border_color, gc.border_alpha)
            self.backend.blend_rect(cm_x, cm_y + cm_h - 1, cm_w, 1, gc.border_color, gc.border_alpha)
            self.backend.blend_rect(cm_x, cm_y, 1, cm_h, gc.border_color, gc.border_alpha)
            self.backend.blend_rect(cm_x + cm_w - 1, cm_y, 1, cm_h, gc.border_color, gc.border_alpha)
            # Highlight selected item
            val sel_y = cm_y + 4 + self.context_menu_sel * 26
            self.backend.blend_rect(cm_x + 2, sel_y, cm_w - 4, 22, gc.accent_color, 40)
            # Menu items
            self.backend.draw_text(cm_x + 12, cm_y + 8, "New Window", 0xFFE0E0F0, 0x00000000)
            self.backend.blend_rect(cm_x + 4, cm_y + 28, cm_w - 8, 1, gc.border_color, gc.border_alpha)
            self.backend.draw_text(cm_x + 12, cm_y + 34, "Theme", 0xFFE0E0F0, 0x00000000)
            self.backend.blend_rect(cm_x + 4, cm_y + 54, cm_w - 8, 1, gc.border_color, gc.border_alpha)
            self.backend.draw_text(cm_x + 12, cm_y + 60, "About", 0xFFA0A0B0, 0x00000000)

        # Spotlight search overlay
        if self.spotlight_active:
            val sp_w: i32 = 400
            val sp_h: i32 = 44
            val sp_x = (self.screen_width - sp_w) / 2
            val sp_y = self.screen_height / 4
            self.backend.blur_region(sp_x, sp_y, sp_w, sp_h, 16)
            self.backend.blend_rect(sp_x, sp_y, sp_w, sp_h, gc.surface_color, gc.surface_alpha)
            # Border
            self.backend.blend_rect(sp_x, sp_y, sp_w, 1, gc.accent_color, 120)
            self.backend.blend_rect(sp_x, sp_y + sp_h - 1, sp_w, 1, gc.accent_color, 120)
            self.backend.blend_rect(sp_x, sp_y, 1, sp_h, gc.accent_color, 120)
            self.backend.blend_rect(sp_x + sp_w - 1, sp_y, 1, sp_h, gc.accent_color, 120)
            # Search icon + text
            self.backend.draw_text(sp_x + 12, sp_y + 14, "Search...", 0xFF808090, 0x00000000)
            # Accent underline
            self.backend.blend_rect(sp_x + 8, sp_y + sp_h - 4, sp_w - 16, 2, gc.accent_color, 80)

        # 5. Cursor + present
        draw_cursor(self.backend, self.screen_width, self.screen_height, self.cursor)

        # Theme transition fade
        if self.theme_transitioning:
            val fade_alpha: u8 = if self.theme_progress < 50: self.theme_progress * 5 else: (100 - self.theme_progress) * 5
            if self.theme_target_dark:
                self.backend.blend_rect(0, 0, self.screen_width, self.screen_height, 0x00000000, fade_alpha)
            else:
                self.backend.blend_rect(0, 0, self.screen_width, self.screen_height, 0x00FFFFFF, fade_alpha)
            # Switch theme at midpoint
            if self.theme_progress >= 50 and self.theme_progress < 60:
                if self.theme_target_dark:
                    self.glass_config = GlassConfig.dark()
                else:
                    self.glass_config = GlassConfig.light()

        self.backend.present()

    me set_glass_theme(active: bool):
        """Enable or disable glassmorphism rendering."""
        self.glass_theme_active = active

    me set_glass_theme_pure(active: bool):
        """Enable glass theme with pure Simple rendering (for hosted backends).

        Registers a pure Simple glass port via DI, using the current backend.
        """
        self.glass_theme_active = active
        if active:
            register_pure_glass(self.backend)

    me set_glass_config(config: GlassConfig):
        """Set the glass configuration for the compositor."""
        self.glass_config = config

    # -- Input Handling ------------------------------------------------------

    me handle_input():
        """Poll keyboard and mouse, route events.

        Keyboard shortcuts:
          Alt+Tab  — cycle focus to next window
          Alt+F4   — close focused window
          Alt+F5   — minimize focused window (toggle visibility)

        Mouse actions:
          Left click on close button — close that window
          Left click on title bar — start dragging
          Left click on window body — focus that window
          Mouse move while dragging — move window
          Left release — stop dragging
        """
        val key_event = self.input.poll_key()
        if key_event != nil:
            self._handle_key_event(key_event)

        val mouse_event = self.input.poll_mouse()
        if mouse_event != nil:
            self._handle_mouse_event(mouse_event)

    me _handle_key_event(key_event: KeyEvent):
        """Process a keyboard event."""
        match key_event:
            KeyEvent.Release(key):
                return
            KeyEvent.Press(key):
                pass_dn

        val key = key_event.key

        # Spotlight dismiss on Escape
        if self.spotlight_active:
            match key:
                Key.Escape:
                    self.spotlight_active = false
                    return
                _: pass_dn

        # Context menu keyboard navigation
        if self.context_menu_active:
            match key:
                Key.Up:
                    self.context_menu_sel = if self.context_menu_sel > 0: self.context_menu_sel - 1 else: 2
                    return
                Key.Down:
                    self.context_menu_sel = if self.context_menu_sel < 2: self.context_menu_sel + 1 else: 0
                    return
                Key.Enter:
                    if self.context_menu_sel == 0:
                        self.create_window("Terminal", self.context_menu_x - 200, self.context_menu_y, 400, 280)
                    else if self.context_menu_sel == 1:
                        if not self.theme_transitioning:
                            self.theme_transitioning = true
                            self.theme_progress = 0
                            self.theme_target_dark = self.glass_config.bg_top >= 0x00808080
                    self.context_menu_active = false
                    return
                Key.Escape:
                    self.context_menu_active = false
                    return
                _: pass_dn

        # Escape: cancel drag/resize first, then quit glass theme
        match key:
            Key.Escape:
                if self.dragging:
                    self.dragging = false
                    self.drag_window_id = 0
                    return
                if self.resizing:
                    # Restore original geometry
                    self.move_window(self.resize_window_id, self.resize_orig_x, self.resize_orig_y)
                    self.resize_window(self.resize_window_id, self.resize_orig_w, self.resize_orig_h)
                    self.resizing = false
                    self.resize_window_id = 0
                    self.resize_edge = 0
                    return
                if self.glass_theme_active:
                    self.stop()
                    return
            _: pass_dn

        # Enter/Backspace for terminal
        if self.glass_theme_active and self.focused_idx >= 0 and self.focused_idx < self.app_states.len():
            if self.surfaces[self.focused_idx].title == "Terminal":
                match key:
                    Key.Enter:
                        val new_state = handle_app_input(self.app_states[self.focused_idx], "Terminal", 13)
                        self._update_app_state(self.focused_idx, new_state)
                        return
                    Key.Backspace:
                        val new_state = handle_app_input(self.app_states[self.focused_idx], "Terminal", 8)
                        self._update_app_state(self.focused_idx, new_state)
                        return
                    _: pass_dn

        # Glass theme shortcuts (like QEMU WM)
        val ch_val = self.input.key_to_char(key)
        if ch_val != nil:
            if self.glass_theme_active:
                # Forward ALL printable keys to Terminal BEFORE WM shortcuts
                # (t/m/w/r would be intercepted by theme/minimize/close/restore otherwise)
                if self.focused_idx >= 0 and self.focused_idx < self.app_states.len():
                    val focused_title = self.surfaces[self.focused_idx].title
                    if focused_title == "Terminal":
                        val key_code: i32 = 0
                        if ch_val == " ": key_code = 32
                        else if ch_val == "a": key_code = 97
                        else if ch_val == "b": key_code = 98
                        else if ch_val == "c": key_code = 99
                        else if ch_val == "d": key_code = 100
                        else if ch_val == "e": key_code = 101
                        else if ch_val == "f": key_code = 102
                        else if ch_val == "g": key_code = 103
                        else if ch_val == "h": key_code = 104
                        else if ch_val == "i": key_code = 105
                        else if ch_val == "j": key_code = 106
                        else if ch_val == "k": key_code = 107
                        else if ch_val == "l": key_code = 108
                        else if ch_val == "m": key_code = 109
                        else if ch_val == "n": key_code = 110
                        else if ch_val == "o": key_code = 111
                        else if ch_val == "p": key_code = 112
                        else if ch_val == "q": key_code = 113
                        else if ch_val == "r": key_code = 114
                        else if ch_val == "s": key_code = 115
                        else if ch_val == "t": key_code = 116
                        else if ch_val == "u": key_code = 117
                        else if ch_val == "v": key_code = 118
                        else if ch_val == "w": key_code = 119
                        else if ch_val == "x": key_code = 120
                        else if ch_val == "y": key_code = 121
                        else if ch_val == "z": key_code = 122
                        if key_code > 0:
                            val new_state = handle_app_input(self.app_states[self.focused_idx], focused_title, key_code)
                            self._update_app_state(self.focused_idx, new_state)
                            return

                # T = toggle dark/light theme (with transition animation)
                if ch_val == "t" or ch_val == "T":
                    # Start theme transition animation
                    if not self.theme_transitioning:
                        self.theme_transitioning = true
                        self.theme_progress = 0
                        if self.glass_config.bg_top < 0x00808080:
                            self.theme_target_dark = false  # currently dark -> go light
                        else:
                            self.theme_target_dark = true   # currently light -> go dark
                    return
                # 1/2/3/4 = focus window by index
                if ch_val == "1":
                    self._focus_by_index(0)
                    return
                if ch_val == "2":
                    self._focus_by_index(1)
                    return
                if ch_val == "3":
                    self._focus_by_index(2)
                    return
                if ch_val == "4":
                    self._focus_by_index(3)
                    return
                # M = minimize active window
                if ch_val == "m" or ch_val == "M":
                    if self.focused_idx >= 0 and not self.minimize_active:
                        self.minimize_active = true
                        self.minimize_progress = 0
                        self.minimize_win = self.focused_idx
                    return
                # W = close active window (with animation)
                if ch_val == "w" or ch_val == "W":
                    if self.focused_idx >= 0 and not self.close_active:
                        self.close_active = true
                        self.close_progress = 0
                        self.close_win = self.focused_idx
                    return
                # R = restore all minimized windows
                if ch_val == "r" or ch_val == "R":
                    var restored: [WindowSurface] = []
                    for s in self.surfaces:
                        if not s.visible:
                            restored = restored.push(WindowSurface(
                                id: s.id, title: s.title,
                                x: s.x, y: s.y,
                                width: s.width, height: s.height,
                                visible: true, session: s.session,
                                dirty: true, owner_port: s.owner_port
                            ))
                        else:
                            restored = restored.push(s)
                    self.surfaces = restored
                    return

        # Compositor-level shortcuts (Alt held)
        if self.input.alt_held():
            match key:
                Key.Tab:
                    self.cycle_focus()
                    return
                Key.F4:
                    self.close_focused_window()
                    return
                Key.F5:
                    self.toggle_focused_visibility()
                    return
                _:
                    pass_dn

        # Global shortcuts (Ctrl+Alt held) — dispatched to desktop shell
        if self.input.ctrl_held() and self.input.alt_held():
            val ch = self.input.key_to_char(key)
            if ch != nil:
                self.pending_shortcut_key = ch
                return

        # Route to focused window
        if self.focused_idx >= 0 and self.focused_idx < self.surfaces.len():
            val focused = self.surfaces[self.focused_idx]

            # Remote window: queue event for IPC delivery
            if focused.owner_port > 0:
                val key_char = self.input.key_to_char(key)
                var key_code: u32 = 0
                if key_char != nil:
                    key_code = key_char.to_u32()
                val remote_event = wm_input_event(focused.id, WM_EVENT_KEY_PRESS, key_code, 0, 0)
                self.queue_remote_event(remote_event)
                return

            # Local window: dispatch to UISession directly
            val ui_event = _key_to_ui_event(self.input, key)
            if ui_event != nil:
                self.surfaces[self.focused_idx].session.dispatch(ui_event)
                # Mark dirty
                var updated: [WindowSurface] = []
                var i: i32 = 0
                for s in self.surfaces:
                    if i == self.focused_idx:
                        updated = updated.push(WindowSurface(
                            id: s.id, title: s.title,
                            x: s.x, y: s.y,
                            width: s.width, height: s.height,
                            visible: s.visible, session: s.session,
                            dirty: true,
                            owner_port: s.owner_port
                        ))
                    else:
                        updated = updated.push(s)
                    i = i + 1
                self.surfaces = updated

    me _handle_mouse_event(event: MouseEvent):
        """Process a mouse event: update cursor, handle clicks, dragging."""
        val mx = event.x.to_i32()
        val my = event.y.to_i32()

        # Update cursor shape based on position
        var new_shape: i32 = 0  # default arrow
        var shape_idx = self.surfaces.len() - 1
        while shape_idx >= 0:
            val ss = self.surfaces[shape_idx]
            if ss.visible:
                val edge = _detect_resize_edge(mx, my, ss.x, ss.y, ss.width, ss.height)
                if edge > 0:
                    new_shape = 2  # hand/pointer for resize
                    shape_idx = -1  # break
                else:
                    # Check if over content area (for I-beam on text apps)
                    val in_content = mx > ss.x + 10 and mx < ss.x + ss.width - 10 and my > ss.y + 44 and my < ss.y + ss.height - 10
                    if in_content and (ss.title == "Terminal" or ss.title == "Editor"):
                        new_shape = 1  # I-beam for text
                        shape_idx = -1
            shape_idx = shape_idx - 1

        # Update cursor position and shape
        self.cursor = CursorState(
            x: mx,
            y: my,
            visible: self.cursor.visible,
            shape: new_shape,
            hotspot_x: self.cursor.hotspot_x,
            hotspot_y: self.cursor.hotspot_y
        )

        # Handle resize release
        if event.left_just_released:
            if self.resizing:
                self.resizing = false
                self.resize_window_id = 0
                self.resize_edge = 0
                return

        # Handle drag release
        if event.left_just_released:
            # Apply snap if active
            if self.snap_preview_active and self.snap_zone > 0:
                val bar_h = SYSTEM_BAR_HEIGHT
                val dock_h: i32 = 68   # dock height + margin
                val usable_h = self.screen_height - bar_h - dock_h
                val half_w = self.screen_width / 2
                val drag_id = self.drag_window_id
                if self.snap_zone == 1:
                    # Left half
                    self.move_window(drag_id, 0, bar_h)
                    self.resize_window(drag_id, half_w, usable_h)
                else if self.snap_zone == 2:
                    # Right half
                    self.move_window(drag_id, half_w, bar_h)
                    self.resize_window(drag_id, half_w, usable_h)
                else if self.snap_zone == 3:
                    # Full screen
                    self.move_window(drag_id, 0, bar_h)
                    self.resize_window(drag_id, self.screen_width, usable_h)
                self.snap_preview_active = false
                self.snap_zone = 0
            self.dragging = false
            self.drag_window_id = 0
            return

        # Handle ongoing drag
        if self.dragging and event.left_pressed:
            val new_x = mx - self.drag_offset_x
            val new_y = my - self.drag_offset_y
            val drag_id = self.drag_window_id
            self.move_window(drag_id, new_x, new_y)
            # Detect snap zone during drag
            val edge: i32 = 20
            if mx < edge:
                self.snap_zone = 1  # left half
            else if mx > self.screen_width - edge:
                self.snap_zone = 2  # right half
            else if my < edge:
                self.snap_zone = 3  # full screen
            else:
                self.snap_zone = 0  # no snap
            self.snap_preview_active = self.snap_zone > 0
            return

        # Handle ongoing edge resize
        if self.resizing and event.left_pressed:
            val dx = mx - self.resize_start_mx
            val dy = my - self.resize_start_my
            var nx = self.resize_orig_x
            var ny = self.resize_orig_y
            var nw = self.resize_orig_w
            var nh = self.resize_orig_h
            val e = self.resize_edge
            if e == 2 or e == 6 or e == 8: nw = nw + dx
            if e == 4 or e == 7 or e == 8: nh = nh + dy
            if e == 1 or e == 5 or e == 7:
                nw = nw - dx
                nx = nx + dx
            if e == 3 or e == 5 or e == 6:
                nh = nh - dy
                ny = ny + dy
            if nw < 100: nw = 100
            if nh < 80: nh = 80
            self.move_window(self.resize_window_id, nx, ny)
            self.resize_window(self.resize_window_id, nw, nh)
            return

        # Handle new left click — hit test windows back-to-front (topmost first)
        if event.left_just_pressed:
            # Dismiss context menu on any left click
            if self.context_menu_active:
                self.context_menu_active = false
                # If click was ON the menu, handle the menu item
                val cm_x = self.context_menu_x
                val cm_y = self.context_menu_y
                val cm_w: i32 = 160
                val cm_h: i32 = 80
                if mx >= cm_x and mx < cm_x + cm_w and my >= cm_y and my < cm_y + cm_h:
                    if my < cm_y + 28:
                        # "New Window" clicked
                        self.create_window("Terminal", cm_x, cm_y, 400, 280)
                    else if my < cm_y + 54:
                        # "Theme" clicked — toggle dark/light
                        if not self.theme_transitioning:
                            self.theme_transitioning = true
                            self.theme_progress = 0
                            val is_dark = self.glass_config.bg_top < 0x00808080
                            if is_dark:
                                self.theme_target_dark = false
                            else:
                                self.theme_target_dark = true
                return  # consume click whether on menu or not

            # Spotlight: dismiss on click outside, consume click inside
            if self.spotlight_active:
                val sp_x = (self.screen_width - 400) / 2
                val sp_y = self.screen_height / 4
                if not (mx >= sp_x and mx < sp_x + 400 and my >= sp_y and my < sp_y + 44):
                    self.spotlight_active = false
                return

            # Search icon click in system bar (top-right area, ~28px tall)
            if my < 28 and mx > self.screen_width - 210 and mx < self.screen_width - 180:
                self.spotlight_active = not self.spotlight_active
                return

            # Dock icon click — launch or focus window
            val dock_h_click: i32 = 52
            val dock_margin: i32 = 6
            val dock_y_click = self.screen_height - dock_h_click - dock_margin
            if my >= dock_y_click and my < dock_y_click + dock_h_click:
                val dock_pill: i32 = 48
                val dock_gap: i32 = 16
                val dock_pad: i32 = 16
                val num_icons: i32 = 9
                val dock_w = 7 * (dock_pill + dock_gap) + 2 + 10 * 2 + 2 * (dock_pill + dock_gap) - dock_gap + dock_pad * 2
                val dock_x_start = (self.screen_width - dock_w) / 2 + dock_pad
                # Determine which icon was clicked
                val rel_x = mx - dock_x_start
                if rel_x >= 0:
                    val icon_idx = rel_x / (dock_pill + dock_gap)
                    if icon_idx >= 0 and icon_idx < 7:
                        # Map dock icon to window title
                        var target_title: text = ""
                        if icon_idx == 0: target_title = "Terminal"
                        else if icon_idx == 1: target_title = "File Manager"
                        else if icon_idx == 2: target_title = "Calculator"
                        else if icon_idx == 5: target_title = "Browser"
                        else if icon_idx == 6: target_title = "Editor"
                        if target_title != "":
                            # Try to find and focus existing window
                            var found = false
                            var fi: i32 = 0
                            while fi < self.surfaces.len():
                                if self.surfaces[fi].title == target_title and self.surfaces[fi].visible:
                                    self.focus_window(self.surfaces[fi].id)
                                    self.anim_active = true
                                    self.anim_progress = 0
                                    found = true
                                    fi = self.surfaces.len()  # break
                                fi = fi + 1
                            if not found:
                                # Create new window
                                self.create_window(target_title, 100 + icon_idx * 40, 100 + icon_idx * 30, 400, 280)
                            return

            # Check for edge resize on any visible window
            var ridx = self.surfaces.len() - 1
            while ridx >= 0:
                val rs = self.surfaces[ridx]
                if rs.visible:
                    val edge = _detect_resize_edge(mx, my, rs.x, rs.y, rs.width, rs.height)
                    if edge > 0:
                        self.focus_window(rs.id)
                        self.resizing = true
                        self.resize_window_id = rs.id
                        self.resize_edge = edge
                        self.resize_start_mx = mx
                        self.resize_start_my = my
                        self.resize_orig_x = rs.x
                        self.resize_orig_y = rs.y
                        self.resize_orig_w = rs.width
                        self.resize_orig_h = rs.height
                        return
                ridx = ridx - 1

            # Iterate in reverse Z-order to find topmost hit
            var idx = self.surfaces.len() - 1
            while idx >= 0:
                val s = self.surfaces[idx]
                if s.visible:
                    # Check if click is within the window frame
                    val in_x = mx >= s.x and mx < s.x + s.width
                    val in_y = my >= s.y and my < s.y + s.height
                    if in_x and in_y:
                        val sid = s.id
                        # Check close button first
                        if is_in_close_button(s.x, s.y, s.width, mx, my):
                            self.destroy_window(sid)
                            return

                        # Check minimize button (yellow, second traffic light)
                        val min_btn_x = s.x + 32
                        val min_btn_y = s.y + 8
                        if mx >= min_btn_x and mx < min_btn_x + 12 and my >= min_btn_y and my < min_btn_y + 12:
                            if not self.minimize_active:
                                self.minimize_active = true
                                self.minimize_progress = 0
                                self.minimize_win = idx
                            return

                        # Check maximize button (green, third traffic light)
                        val max_btn_x = s.x + 52
                        val max_btn_y = s.y + 8
                        if mx >= max_btn_x and mx < max_btn_x + 12 and my >= max_btn_y and my < max_btn_y + 12:
                            # Maximize: fill usable area
                            val bar_h = SYSTEM_BAR_HEIGHT
                            val dock_h_val: i32 = 68
                            self.move_window(sid, 0, bar_h)
                            self.resize_window(sid, self.screen_width, self.screen_height - bar_h - dock_h_val)
                            return

                        # Check title bar for drag (with double-click detection)
                        if is_in_title_bar(s.x, s.y, s.width, mx, my):
                            # Double-click detection
                            val frame_diff = self.frame_count - self.last_click_frame
                            val dx_click = mx - self.last_click_x
                            val dy_click = my - self.last_click_y
                            val abs_dx = if dx_click < 0: 0 - dx_click else: dx_click
                            val abs_dy = if dy_click < 0: 0 - dy_click else: dy_click
                            self.last_click_frame = self.frame_count
                            self.last_click_x = mx
                            self.last_click_y = my
                            if frame_diff < 15 and abs_dx < 10 and abs_dy < 10:
                                # Toggle maximize
                                val bar_h = SYSTEM_BAR_HEIGHT
                                val dock_h_val: i32 = 68
                                val usable = self.screen_height - bar_h - dock_h_val
                                if s.width >= self.screen_width - 10 and s.height >= usable - 10:
                                    self.move_window(sid, 60 + idx * 80, 80 + idx * 60)
                                    self.resize_window(sid, 400, 280)
                                else:
                                    self.move_window(sid, 0, bar_h)
                                    self.resize_window(sid, self.screen_width, usable)
                                return
                            # Single click: start drag
                            self.focus_window(sid)
                            self.dragging = true
                            self.drag_window_id = sid
                            self.drag_offset_x = mx - s.x
                            self.drag_offset_y = my - s.y
                            return

                        # Click on window body — just focus
                        self.focus_window(sid)

                        # Forward click to app content
                        if self.focused_idx >= 0 and self.focused_idx < self.app_states.len():
                            val local_x = mx - client_area_x(s.x)
                            val local_y = my - client_area_y(s.y)
                            if local_x >= 0 and local_y >= 0:
                                val new_state = handle_app_click(self.app_states[self.focused_idx], s.title, local_x, local_y)
                                self._update_app_state(self.focused_idx, new_state)
                        return
                idx = idx - 1

            # No window hit — click on desktop background
            if self.focused_idx >= 0:
                self.focused_idx = -1

        # Right-click context menu on empty desktop
        if event.right_just_pressed:
            self.context_menu_active = false
            # Check if click is on empty desktop (no window hit)
            var on_desktop = true
            var ri = self.surfaces.len() - 1
            while ri >= 0:
                val rs = self.surfaces[ri]
                if rs.visible and mx >= rs.x and mx < rs.x + rs.width and my >= rs.y and my < rs.y + rs.height:
                    on_desktop = false
                    ri = -1  # break
                ri = ri - 1
            if on_desktop:
                self.context_menu_x = mx
                self.context_menu_y = my
                self.context_menu_active = true
                self.context_menu_sel = 0

    me cycle_focus():
        """Cycle focus to the next window (Alt+Tab behavior)."""
        if self.surfaces.len() <= 1:
            return
        var next = self.focused_idx + 1
        if next >= self.surfaces.len():
            next = 0
        val target = self.surfaces[next]
        val target_id = target.id
        self.focus_window(target_id)
        # Start bounce animation
        self.anim_active = true
        self.anim_progress = 0
        self.switcher_active = true
        self.switcher_timer = 30  # show for ~30 frames (~500ms)

    me _focus_by_index(idx: i32):
        """Focus a window by surface index (0, 1, 2). Starts bounce animation."""
        if idx >= 0 and idx < self.surfaces.len():
            val target = self.surfaces[idx]
            self.focus_window(target.id)
            self.anim_active = true
            self.anim_progress = 0
            self.switcher_active = true
            self.switcher_timer = 20

    me close_focused_window():
        """Close the currently focused window."""
        if self.focused_idx >= 0 and self.focused_idx < self.surfaces.len():
            val id = self.surfaces[self.focused_idx].id
            self.destroy_window(id)

    me toggle_focused_visibility():
        """Toggle visibility of the focused window."""
        if self.focused_idx < 0:
            return
        var updated: [WindowSurface] = []
        var i: i32 = 0
        for s in self.surfaces:
            if i == self.focused_idx:
                updated = updated.push(WindowSurface(
                    id: s.id, title: s.title,
                    x: s.x, y: s.y,
                    width: s.width, height: s.height,
                    visible: not s.visible, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
            i = i + 1
        self.surfaces = updated

    # -- Main Loop -----------------------------------------------------------

    me run_loop():
        """Main compositor loop: handle input, render, repeat.

        Includes animation ticking for focus bounce, minimize, and close.
        """
        self.running = true
        while self.running:
            self.handle_input()
            self._tick_animations()
            self.render_all()

    me _tick_animations():
        """Update all active animations by one frame step."""
        self.frame_count = self.frame_count + 1
        # Focus bounce animation (12 frames, 0-100 progress)
        if self.anim_active:
            self.anim_progress = self.anim_progress + 8
            if self.anim_progress >= 100:
                self.anim_progress = 100
                self.anim_active = false

        # Minimize animation (shrink toward dock)
        if self.minimize_active:
            self.minimize_progress = self.minimize_progress + 12
            if self.minimize_progress >= 100:
                self.minimize_progress = 100
                self.minimize_active = false
                # Actually minimize the window
                if self.minimize_win >= 0 and self.minimize_win < self.surfaces.len():
                    val min_id = self.surfaces[self.minimize_win].id
                    self.minimize_window(min_id)
                    # Focus next visible window
                    self.cycle_focus()
                self.minimize_win = -1

        # Close animation (shrink and fade)
        if self.close_active:
            self.close_progress = self.close_progress + 16
            if self.close_progress >= 100:
                self.close_progress = 100
                self.close_active = false
                # Actually close the window
                if self.close_win >= 0 and self.close_win < self.surfaces.len():
                    val close_id = self.surfaces[self.close_win].id
                    self.destroy_window(close_id)
                self.close_win = -1

        # Open animation (scale up from center)
        if self.open_anim_active:
            self.open_anim_progress = self.open_anim_progress + 12
            if self.open_anim_progress >= 100:
                self.open_anim_active = false
                self.open_anim_progress = 100

        # Switcher overlay countdown
        if self.switcher_active:
            self.switcher_timer = self.switcher_timer - 1
            if self.switcher_timer <= 0:
                self.switcher_active = false

        # Dock bounce animation
        if self.dock_bounce_active:
            self.dock_bounce_progress = self.dock_bounce_progress + 8
            if self.dock_bounce_progress >= 100:
                self.dock_bounce_active = false
                self.dock_bounce_progress = 0
                self.dock_bounce_icon = -1

        # Theme transition animation
        if self.theme_transitioning:
            self.theme_progress = self.theme_progress + 10  # ~10 frames = 170ms
            if self.theme_progress >= 100:
                self.theme_transitioning = false
                self.theme_progress = 0
                if self.theme_target_dark:
                    self.glass_config = GlassConfig.dark()
                else:
                    self.glass_config = GlassConfig.light()

    me consume_pending_shortcut() -> text:
        """Return and clear any pending Ctrl+Alt shortcut key.

        Returns "" if no shortcut is pending.
        """
        val key = self.pending_shortcut_key
        self.pending_shortcut_key = ""
        key

    me consume_pending_meta_key() -> i32:
        """Return and clear any pending Meta key press.

        Returns 0 if no meta key is pending.
        """
        val key = self.pending_meta_key
        self.pending_meta_key = 0
        key

    me consume_remote_events() -> [WmInputEvent]:
        """Return and clear pending remote window input events."""
        val events = self.pending_remote_events
        self.pending_remote_events = []
        events

    me stop():
        """Signal the compositor loop to exit."""
        self.running = false

    me _update_app_state(idx: i32, new_state: AppState):
        """Update app state at index, rebuilding the array."""
        var new_states: [AppState] = []
        var i: i32 = 0
        while i < self.app_states.len():
            if i == idx:
                new_states = new_states.push(new_state)
            else:
                new_states = new_states.push(self.app_states[i])
            i = i + 1
        self.app_states = new_states

# ============================================================================
# Internal: Render a Single Window (via CompositorBackend)
# ============================================================================

fn _render_window(backend: CompositorBackend, surface: WindowSurface, focused: bool):
    """Render a single window: decorations + client area content.

    Uses CompositorBackend for all rendering — works on all platforms.
    """
    draw_window_frame(backend, surface.x, surface.y, surface.width, surface.height, surface.title, focused)

    val cx = client_area_x(surface.x)
    val cy = client_area_y(surface.y)
    val cw = client_area_width(surface.width)
    val ch = client_area_height(surface.height)

    if cw <= 0 or ch <= 0:
        return

    val state = surface.session.current_state()
    val tree_theme = state.tree.theme()
    val theme = resolve_theme(tree_theme)
    val root = state.tree.root_node()
    val rects = compute_layout(root, cx, cy, cw, ch)

    backend.fill_rect(cx, cy, cw, ch, theme.bg)
    _render_tree(backend, root, rects, state.focused_id, theme)

# ============================================================================
# Internal: Render a Single Window with Glass Theme
# ============================================================================

fn _render_glass_window(backend: CompositorBackend, surface: WindowSurface, focused: bool, config: GlassConfig):
    """Render a single window with glassmorphism decorations + client area.

    Uses glass_effects for the window frame, then renders client content
    on top of the glass surface.
    """
    draw_glass_window_frame(backend, surface.x, surface.y, surface.width, surface.height, surface.title, focused, config)

    val cx = client_area_x(surface.x)
    val cy = client_area_y(surface.y)
    val cw = client_area_width(surface.width)
    val ch = client_area_height(surface.height)

    if cw <= 0 or ch <= 0:
        return

    val state = surface.session.current_state()
    val tree_theme = state.tree.theme()
    val theme = resolve_theme(tree_theme)
    val root = state.tree.root_node()
    val rects = compute_layout(root, cx, cy, cw, ch)

    backend.fill_rect(cx, cy, cw, ch, theme.bg)
    _render_tree(backend, root, rects, state.focused_id, theme)

# ============================================================================
# Internal: Key to UIEvent Translation (via InputBackend)
# ============================================================================

fn _key_to_ui_event(input: InputBackend, key: Key) -> UIEvent?:
    """Convert a Key press to a UIEvent for window dispatch."""
    match key:
        Key.Escape: return UIEvent.Quit
        Key.Tab:
            if input.shift_held():
                return UIEvent.FocusPrev
            return UIEvent.FocusNext
        Key.Up: return UIEvent.KeyPress(key: "up")
        Key.Down: return UIEvent.KeyPress(key: "down")
        Key.Left: return UIEvent.KeyPress(key: "left")
        Key.Right: return UIEvent.KeyPress(key: "right")
        Key.Enter: return UIEvent.KeyPress(key: "enter")
        Key.Backspace: return UIEvent.KeyPress(key: "backspace")
        Key.Delete: return UIEvent.KeyPress(key: "delete")
        Key.Home: return UIEvent.KeyPress(key: "home")
        Key.End: return UIEvent.KeyPress(key: "end")
        Key.PageUp: return UIEvent.KeyPress(key: "pageup")
        Key.PageDown: return UIEvent.KeyPress(key: "pagedown")
        _: pass_dn

    val ch = input.key_to_char(key)
    if ch != nil:
        return UIEvent.KeyPress(key: ch)
    return nil
