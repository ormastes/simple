use os.compositor.cursor.{CursorState}
use os.compositor.display_backend_core.{CompositorBackend}
use os.compositor.input_backend.{InputBackend}
use os.drivers.framebuffer.fb_driver.{Color}
use os.kernel.boot.cpu.{port_inb, port_outb}
use common.window_protocol.geometry.{WindowId}
use common.ui.window_scene.{SharedWmScene}
use common.ui.wm_chrome_theme.{wm_chrome_theme}
use os.compositor.shared_mdi_framebuffer_scene.{
    SharedMdiRenderWindow,
    shared_mdi_render_window,
    render_shared_mdi_desktop_chrome,
    draw_shared_mdi_window_chrome,
    draw_shared_mdi_taskbar
}
use os.compositor.simple_web_window_renderer.{render_simple_web_content}

fn _ps2_wm_pointer_button_code(left_btn: bool, right_btn: bool, middle_btn: bool) -> i32:
    """Map PS/2 mouse status-byte button bits (status byte bits 0/1/2) to
    the pending_wm_pointer_button_code contract shared with shell.spl's
    decode (see Compositor.pending_wm_pointer_button_code doc comment):
    0 = none, 1 = left, 2 = middle, 3 = right. At most one code is
    reported per packet; when multiple bits are set simultaneously, left
    takes priority, then right, then middle (left already took priority
    over any simultaneous button before this decode was widened)."""
    if left_btn:
        return 1
    if right_btn:
        return 3
    if middle_btn:
        return 2
    return 0

class WindowSurface:
    id: i32
    title: text
    x: i32
    y: i32
    width: i32
    height: i32
    visible: bool
    session: any
    # Runtime-owned client content. `session` may hold a typed UI tree or
    # render request and must never be stringified to recover this value.
    content_html: text
    content_revision: i64
    dirty: bool
    owner_port: i64
    process_id: i64
    app_id: text
    maximized: bool = false
    restore_x: i32 = 0
    restore_y: i32 = 0
    restore_width: i32 = 0
    restore_height: i32 = 0

class Compositor:
    surfaces: [WindowSurface]
    focused_idx: i32
    backend: CompositorBackend
    input: InputBackend?
    cursor: CursorState
    desktop_bg: Color
    next_id: i32
    screen_width: i32
    screen_height: i32
    running: bool
    dragging: bool
    drag_window_id: i32
    drag_offset_x: i32
    drag_offset_y: i32
    pending_meta_key: i32
    pending_shortcut: text
    pending_wm_pointer_valid: bool
    pending_wm_pointer_x: i32
    pending_wm_pointer_y: i32
    # i32 codes, not text: text stored through this struct field arrived at
    # rt_string_eq as a raw integer on baremetal (cr2=-114 fault class,
    # 2026-07-18 input-correlation lane).
    # button_code: 0=none, 1=left, 2=middle, 3=right (see
    # _ps2_wm_pointer_button_code). kind_code: 0=none, 1=down, 2=up,
    # 3=move. Decoded back to text in shell.spl's
    # wm_pointer_button_from_code / wm_pointer_kind_from_code (see
    # handle_pending_wm_pointer_step) — keep both ends in sync.
    pending_wm_pointer_button_code: i32
    pending_wm_pointer_kind_code: i32
    # Button code held as of the previous PS/2 packet, used only to detect
    # the release (down -> none) edge and report which button went up.
    prev_wm_pointer_button_code: i32
    input_sequence: i64
    pending_fullscreen_sequence: i64

    static fn with_backends(backend: CompositorBackend, input: InputBackend?, width: i32, height: i32) -> Compositor:
        Compositor(
            surfaces: [],
            focused_idx: -1,
            backend: backend,
            input: input,
            cursor: CursorState(x: width / 2, y: height / 2, visible: true, hotspot_x: 1, hotspot_y: 1),
            desktop_bg: Color.rgb(0, 48, 96),
            next_id: 1,
            screen_width: width,
            screen_height: height,
            running: false,
            dragging: false,
            drag_window_id: 0,
            drag_offset_x: 0,
            drag_offset_y: 0,
            pending_meta_key: 0,
            pending_shortcut: "",
            pending_wm_pointer_valid: false,
            pending_wm_pointer_x: 0,
            pending_wm_pointer_y: 0,
            pending_wm_pointer_button_code: 0,
            pending_wm_pointer_kind_code: 0,
            prev_wm_pointer_button_code: 0,
            input_sequence: 0,
            pending_fullscreen_sequence: 0
        )

    me create_window(title: text, x: i32, y: i32, width: i32, height: i32) -> i32:
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.surfaces.push(WindowSurface(
            id: id,
            title: title,
            x: x,
            y: y,
            width: width,
            height: height,
            visible: true,
            session: nil,
            content_html: "",
            content_revision: 1,
            dirty: true,
            owner_port: 0,
            process_id: 0,
            app_id: "",
            # Explicit, not defaulted: defaulted struct fields are NOT
            # zero-initialized on the freestanding lane — a fresh window read
            # maximized=true and F11's first press dispatched action=restore
            # instead of maximize (proven live 2026-07-18).
            maximized: false,
            restore_x: 0,
            restore_y: 0,
            restore_width: 0,
            restore_height: 0
        ))
        self.focused_idx = self.surfaces.len() - 1
        id

    me add_surface(title: text, x: i32, y: i32, width: i32, height: i32) -> WindowId:
        WindowId(value: self.create_window(title, x, y, width, height).to_u64())

    me create_window_with_tree(title: text, x: i32, y: i32, width: i32, height: i32, tree: any) -> WindowId:
        val id = self.create_window(title, x, y, width, height)
        self.update_window_tree(id.to_u64(), tree)
        WindowId(value: id.to_u64())

    me create_windows_from_shared_scene(scene: SharedWmScene) -> [WindowId]:
        var ids: [WindowId] = []
        for window in scene.windows:
            var wid = WindowId(value: 0u64)
            if val tree = window.tree:
                wid = self.create_window_with_tree(window.title, window.x, window.y, window.width, window.height, tree)
            else:
                wid = self.add_surface(window.title, window.x, window.y, window.width, window.height)
                val surface = self.get_surface(wid.value)
                if surface != nil and window.html != "":
                    self.update_window_tree(wid.value, window.html)
                    self.update_window_content(wid.value, window.html)
            if window.process_id > 0u64 or window.app_id != "":
                self.set_window_identity(wid.value.to_i32(), window.process_id.to_i64(), window.app_id)
            if window.minimized:
                self.minimize_window(wid.value)
            ids = ids.push(wid)
        ids

    me create_remote_window(title: text, x: i32, y: i32, width: i32, height: i32, owner_port: u64) -> WindowId:
        val id = self.create_window(title, x, y, width, height)
        val i = self.surface_index(id.to_u64())
        if i >= 0:
            var surface = self.surfaces[i]
            surface.owner_port = owner_port.to_i64()
            self.surfaces[i] = surface
        WindowId(value: id.to_u64())

    me destroy_window(id: i32):
        var out: [WindowSurface] = []
        var i = 0
        while i < self.surfaces.len():
            if self.surfaces[i].id != id:
                out.push(self.surfaces[i])
            i = i + 1
        self.surfaces = out
        if self.surfaces.len() == 0:
            self.focused_idx = -1
        elif self.focused_idx >= self.surfaces.len():
            self.focused_idx = self.surfaces.len() - 1

    me focus_window(id: i32):
        val found = self.surface_index(id.to_u64())
        if found < 0:
            return
        val chosen = self.surfaces[found]
        var out: [WindowSurface] = []
        var i = 0
        while i < self.surfaces.len():
            if i != found:
                out.push(self.surfaces[i])
            i = i + 1
        out.push(chosen)
        self.surfaces = out
        self.focused_idx = self.surfaces.len() - 1

    me cycle_focus():
        if self.surfaces.len() <= 1:
            if self.surfaces.len() == 0:
                self.focused_idx = -1
            return
        var idx = self.focused_idx + 1
        if idx >= self.surfaces.len():
            idx = 0
        self.focus_window(self.surfaces[idx].id)

    me move_window(id: i32, x: i32, y: i32):
        val i = self.surface_index(id.to_u64())
        if i >= 0:
            var surface = self.surfaces[i]
            surface.x = x
            surface.y = y
            surface.dirty = true
            self.surfaces[i] = surface

    me resize_window(id: u64, width: i32, height: i32):
        val i = self.surface_index(id)
        if i >= 0:
            var surface = self.surfaces[i]
            surface.width = width
            surface.height = height
            surface.dirty = true
            self.surfaces[i] = surface

    me set_window_title(id: u64, title: text):
        val i = self.surface_index(id)
        if i >= 0:
            var surface = self.surfaces[i]
            surface.title = title
            surface.dirty = true
            self.surfaces[i] = surface

    me minimize_window(id: u64):
        val i = self.surface_index(id)
        if i >= 0:
            var surface = self.surfaces[i]
            surface.visible = false
            self.surfaces[i] = surface

    me maximize_window(id: u64):
        val i = self.surface_index(id)
        if i >= 0:
            var surface = self.surfaces[i]
            if not surface.maximized:
                surface.restore_x = surface.x
                surface.restore_y = surface.y
                surface.restore_width = surface.width
                surface.restore_height = surface.height
            surface.x = 0
            surface.y = 44
            surface.width = self.screen_width
            surface.height = self.screen_height - 100
            surface.visible = true
            surface.maximized = true
            surface.dirty = true
            self.surfaces[i] = surface

    me restore_window(id: u64):
        val i = self.surface_index(id)
        if i >= 0:
            var surface = self.surfaces[i]
            if surface.maximized and surface.restore_width > 0 and surface.restore_height > 0:
                surface.x = surface.restore_x
                surface.y = surface.restore_y
                surface.width = surface.restore_width
                surface.height = surface.restore_height
            surface.visible = true
            surface.maximized = false
            surface.dirty = true
            self.surfaces[i] = surface

    me update_window_tree(id: u64, tree: any):
        val i = self.surface_index(id)
        if i >= 0:
            var surface = self.surfaces[i]
            surface.session = tree
            surface.dirty = true
            self.surfaces[i] = surface

    me update_window_content(id: u64, content_html: text):
        """Retain authoritative text/HTML without coercing an opaque tree."""
        val i = self.surface_index(id)
        if i >= 0:
            var surface = self.surfaces[i]
            if surface.content_html != content_html:
                surface.content_html = content_html
                surface.content_revision = surface.content_revision + 1
                surface.dirty = true
                self.surfaces[i] = surface

    me set_window_identity(id: i32, process_id: i64, app_id: text):
        val i = self.surface_index(id.to_u64())
        if i >= 0:
            var surface = self.surfaces[i]
            surface.process_id = process_id
            surface.app_id = app_id
            self.surfaces[i] = surface

    me compositor_materialize_process_surface_scalar(title: text, x: i32, y: i32, width: i32, height: i32, process_id: i64, app_id: text, content_html: text) -> i64:
        val id = self.create_window(title, x, y, width, height)
        if id <= 0:
            return 0
        val i = self.surface_index(id.to_u64())
        if i >= 0:
            var surface = self.surfaces[i]
            surface.process_id = process_id
            surface.app_id = app_id
            surface.content_html = content_html
            surface.content_revision = surface.content_revision + 1
            surface.dirty = true
            self.surfaces[i] = surface
        id

    fn compositor_process_owned_surface_count_scalar() -> i64:
        var count: i64 = 0
        # cpu-lane-loop-ok: bounded startup/readiness ownership count, not a frame or pixel path
        for surface in self.surfaces:
            if surface.process_id > 0 and surface.app_id != "":
                count = count + 1
        count

    fn window_count() -> i32:
        self.surfaces.len()

    fn window_titles() -> [text]:
        var titles: [text] = []
        for surface in self.surfaces:
            titles = titles.push(surface.title)
        titles

    fn surface_index(id: u64) -> i32:
        var i = 0
        # cpu-lane-loop-ok: bounded compositor window-table identity lookup
        while i < self.surfaces.len():
            if self.surfaces[i].id.to_u64() == id:
                return i
            i = i + 1
        -1

    fn get_surface(id: u64) -> WindowSurface?:
        val i = self.surface_index(id)
        if i >= 0:
            return self.surfaces[i]
        nil

    fn window_title(id: u64) -> text:
        val i = self.surface_index(id)
        if i >= 0:
            return self.surfaces[i].title
        ""

    fn window_owner_port(id: u64) -> u64:
        val i = self.surface_index(id)
        if i >= 0:
            return self.surfaces[i].owner_port.to_u64()
        0

    fn window_process_id(id: i32) -> i64:
        val i = self.surface_index(id.to_u64())
        if i >= 0:
            return self.surfaces[i].process_id
        0

    fn window_app_id(id: i32) -> text:
        val i = self.surface_index(id.to_u64())
        if i >= 0:
            return self.surfaces[i].app_id
        ""

    fn window_count_for_app(app_id: text) -> i32:
        var count = 0
        var i = 0
        while i < self.surfaces.len():
            if self.surfaces[i].app_id == app_id:
                count = count + 1
            i = i + 1
        count

    fn window_count_for_process(process_id: i64) -> i32:
        var count = 0
        var i = 0
        while i < self.surfaces.len():
            if self.surfaces[i].process_id == process_id:
                count = count + 1
            i = i + 1
        count

    fn windows_for_process(process_id: i64) -> [u64]:
        var out: [u64] = []
        var i = 0
        while i < self.surfaces.len():
            if self.surfaces[i].process_id == process_id:
                out = out.push(self.surfaces[i].id.to_u64())
            i = i + 1
        out

    fn windows_for_app(app_id: text) -> [u64]:
        var out: [u64] = []
        var i = 0
        while i < self.surfaces.len():
            if self.surfaces[i].app_id == app_id:
                out = out.push(self.surfaces[i].id.to_u64())
            i = i + 1
        out

    me handle_input():
        if self.input != nil:
            self._handle_input_backend()
            return
        self._handle_input_ps2()

    me handle_input_baremetal_ps2():
        self._handle_input_ps2()

    me _handle_input_backend():
        val inp = self.input
        if inp == nil:
            return
        val key_event = inp.poll_key()
        if key_event != nil:
            if inp.alt_held():
                self.pending_meta_key = 1
            # KeyEvent is an enum (Press/Release with a key payload) — it has
            # no `.key` property; extract the key by pattern match. Only
            # presses produce shortcut characters.
            if val Press(pressed_key) = key_event:
                # key_to_char returns text? — unwrap so pending_shortcut holds
                # the bare character, not an Option wrapper.
                if val Some(shortcut_char) = inp.key_to_char(pressed_key):
                    self.pending_shortcut = shortcut_char
        # Drain the mouse poll each frame so the backend event queue does not
        # back up. Cursor-move + click-to-focus are handled via _handle_input_ps2
        # (the direct 0x60 PS/2 path below), NOT through this trait poll:
        # inp.poll_mouse() is an InputBackend TRAIT method, and the bootstrap
        # native-build HIR erases its MouseEvent? return to ANY, then rejects
        # struct field access on ANY (a cluster of native-build MIR/HIR gaps —
        # field-result type not propagated, method calls lowered to const-0;
        # see doc/08_tracking/bug/simpleos_wm_4k_footprint_exceeds_heap_window_2026-07-14.md).
        # Reading mouse_event.x/y/left through this ANY receiver made the whole
        # compositor module fail native-build and get skipped/weak-stubbed, which
        # null-derefed the desktop render. Draining without field access keeps the
        # module compiling; the concrete PS/2 path keeps cursor/click working.
        val _drained_mouse = inp.poll_mouse()

    me _handle_input_ps2():
        var alt_held = false
        var status = port_inb(0x64)
        while ((status as i32) & 1) != 0:
            # AUX bytes belong to the mouse packet decoder below. Consuming
            # them as keyboard scancodes made QMP pointer input disappear
            # before it could reach the shared WM event path.
            if ((status as i32) & 0x20) != 0:
                break
            var scancode = port_inb(0x60)
            var sc = scancode as i32
            if sc == 0x38:
                alt_held = true
                self.pending_meta_key = 1
            elif sc == 0xB8:
                alt_held = false
            elif alt_held and sc == 0x0F:
                self.cycle_focus()
            elif alt_held and sc == 0x3E:
                if self.focused_idx >= 0 and self.focused_idx < self.surfaces.len():
                    val focused_id = self.surfaces[self.focused_idx].id
                    self.destroy_window(focused_id)
            elif sc == 0x57:
                self.input_sequence = self.input_sequence + 1
                self.pending_fullscreen_sequence = self.input_sequence
            var next_status = port_inb(0x64)
            status = next_status

        var mstatus = port_inb(0x64)
        if ((mstatus as i32) & 0x21) == 0x21:
            var b0 = port_inb(0x60)
            var ms1 = port_inb(0x64)
            if ((ms1 as i32) & 1) != 0:
                var b1 = port_inb(0x60)
                var ms2 = port_inb(0x64)
                if ((ms2 as i32) & 1) != 0:
                    var b2 = port_inb(0x60)
                    var dx = b1 as i32
                    var dy = b2 as i32
                    if ((b0 as i32) & 0x10) != 0:
                        dx = dx - 256
                    if ((b0 as i32) & 0x20) != 0:
                        dy = dy - 256
                    var new_x = self.cursor.x + dx
                    var new_y = self.cursor.y - dy
                    if new_x < 0:
                        new_x = 0
                    if new_x >= self.screen_width:
                        new_x = self.screen_width - 1
                    if new_y < 0:
                        new_y = 0
                    if new_y >= self.screen_height:
                        new_y = self.screen_height - 1
                    var cursor_ref = self.cursor
                    cursor_ref.x = new_x
                    cursor_ref.y = new_y
                    self.cursor = cursor_ref
                    val left_btn = ((b0 as i32) & 0x01) != 0
                    val right_btn = ((b0 as i32) & 0x02) != 0
                    val middle_btn = ((b0 as i32) & 0x04) != 0
                    self.input_sequence = self.input_sequence + 1
                    val cur_wm_pointer_button_code = _ps2_wm_pointer_button_code(left_btn, right_btn, middle_btn)
                    val prev_wm_pointer_button_code = self.prev_wm_pointer_button_code
                    if cur_wm_pointer_button_code != 0:
                        self.note_pending_wm_pointer_step(new_x, new_y, cur_wm_pointer_button_code, 1)
                    elif prev_wm_pointer_button_code != 0:
                        self.note_pending_wm_pointer_step(new_x, new_y, prev_wm_pointer_button_code, 2)
                    else:
                        self.note_pending_wm_pointer_step(new_x, new_y, 0, 3)
                    self.prev_wm_pointer_button_code = cur_wm_pointer_button_code
                    if left_btn:
                        if self.dragging:
                            val new_win_x = new_x - self.drag_offset_x
                            val new_win_y = new_y - self.drag_offset_y
                            self.move_window(self.drag_window_id, new_win_x, new_win_y)
                        else:
                            var hit_idx = -1
                            var wi = 0
                            while wi < self.surfaces.len():
                                val s = self.surfaces[wi]
                                if (new_x >= s.x and new_x < s.x + s.width and
                                    new_y >= s.y and new_y < s.y + s.height):
                                    hit_idx = wi
                                wi = wi + 1
                            if hit_idx >= 0:
                                val hit = self.surfaces[hit_idx]
                                if new_y < hit.y + 24:
                                    self.dragging = true
                                    self.drag_window_id = hit.id
                                    self.drag_offset_x = new_x - hit.x
                                    self.drag_offset_y = new_y - hit.y
                                    self.focus_window(hit.id)
                                else:
                                    self.focus_window(hit.id)
                    else:
                        self.dragging = false

    me render_all():
        # Project the live SimpleOS compositor into the same shared-MDI model
        # used by the hosted WM. Chrome/taskbar are executed by the common
        # Draw-IR renderer and every visible body is rasterized by the same
        # pure-Simple Web pixel pipeline as the host; only the final backend
        # differs (framebuffer here, winit pixel buffer on the host).
        val theme = wm_chrome_theme()
        render_shared_mdi_desktop_chrome(self.backend, self.screen_width, self.screen_height, theme)
        var shared_windows: [SharedMdiRenderWindow] = []
        var i = 0
        while i < self.surfaces.len():
            val s = self.surfaces[i]
            val shared = shared_mdi_render_window(
                s.id.to_i64(),
                s.title,
                s.app_id,
                s.content_html,
                s.x,
                s.y,
                s.width,
                s.height,
                s.process_id,
                not s.visible,
                i == self.focused_idx,
                0
            )
            shared_windows.push(shared)
            if s.visible:
                draw_shared_mdi_window_chrome(self.backend, shared, theme)
                val content_w = s.width - 8
                val content_h = s.height - 36
                if content_w > 0 and content_h > 0:
                    render_simple_web_content(
                        self.backend,
                        s.title,
                        s.x + 4,
                        s.y + 32,
                        content_w,
                        content_h,
                        s.content_html
                    )
            i = i + 1
        draw_shared_mdi_taskbar(self.backend, shared_windows, self.screen_width, self.screen_height, theme)
        val cx = self.cursor.x
        val cy = self.cursor.y
        self.backend.fill_rect(cx, cy, 8, 8, 0xFFFFFFFF)

    me consume_pending_meta_key() -> i32:
        val k = self.pending_meta_key
        self.pending_meta_key = 0
        k

    me consume_pending_shortcut() -> text:
        val s = self.pending_shortcut
        self.pending_shortcut = ""
        s

    me note_pending_wm_pointer_step(x: i32, y: i32, button_code: i32, kind_code: i32):
        self.pending_wm_pointer_valid = true
        self.pending_wm_pointer_x = x
        self.pending_wm_pointer_y = y
        self.pending_wm_pointer_button_code = button_code
        self.pending_wm_pointer_kind_code = kind_code

    fn has_pending_wm_pointer_step() -> bool:
        self.pending_wm_pointer_valid

    fn pending_wm_pointer_x_value() -> i32:
        self.pending_wm_pointer_x

    fn pending_wm_pointer_y_value() -> i32:
        self.pending_wm_pointer_y

    fn pending_wm_pointer_button_code_value() -> i32:
        self.pending_wm_pointer_button_code

    fn pending_wm_pointer_kind_code_value() -> i32:
        self.pending_wm_pointer_kind_code

    me clear_pending_wm_pointer_step():
        self.pending_wm_pointer_valid = false
        self.pending_wm_pointer_x = 0
        self.pending_wm_pointer_y = 0
        self.pending_wm_pointer_button_code = 0
        self.pending_wm_pointer_kind_code = 0

    me render_frame():
        self.render_all()
        self.backend.present()

    me run_loop():
        self.running = true
        while self.running:
            self.handle_input()
            self.render_all()
            self.backend.present()
            self.running = false
