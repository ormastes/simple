# Window Compositor
#
# Manages windows as surfaces in Z-order, routes input to the focused
# window, and orchestrates rendering of all visible windows plus
# their decorations onto the framebuffer.
#
# Each window owns a UISession, reusing the existing UI system.
# The compositor itself is NOT a RenderBackend — it uses the
# FramebufferDriver directly for compositing, and delegates
# per-window rendering to FramebufferBackend.

use common.ui.widget.{WidgetNode, UITree, UIState, UIEvent, UIMode}
use common.ui.session.{UISession, new_session}
use common.ui.layout.{compute_layout}
use common.ui.builder.{column, text_widget}
use os.drivers.framebuffer.fb_driver.{FramebufferDriver, Color}
use os.drivers.input.ps2_keyboard.{Ps2Keyboard, KeyEvent, Key}
use os.drivers.input.ps2_mouse.{Ps2Mouse, MouseEvent}
use os.compositor.decorations.{draw_window_frame, draw_glass_window_frame, draw_glass_window_frame_enhanced, TITLE_BAR_HEIGHT, BORDER_WIDTH, client_area_x, client_area_y, client_area_width, client_area_height, is_in_title_bar, is_in_close_button}
use os.compositor.glass_effects.{GlassConfig, glass_begin_frame, glass_present, glass_gradient_v, draw_glass_rect}
# glass_effects_pure.GlassConfig not imported — we use GlassPortConfig for pure Simple path
use os.compositor.glass_port.{GlassPort, GlassPortConfig, glass_port_name, register_pure_glass, gp_begin_frame, gp_present, gp_gradient_v, gp_draw_rect, gp_draw_text, gp_fill}
use os.compositor.cursor.{CursorState, default_cursor_state, draw_cursor}
use os.compositor.fb_backend.{_render_tree, resolve_theme, CHAR_W, CHAR_H}
use os.compositor.desktop_chrome.{draw_system_bar, draw_dock, SYSTEM_BAR_HEIGHT, DOCK_HEIGHT}
use os.compositor.window_effects.{draw_glass_window_enhanced}
use os.compositor.render_extras.{draw_wallpaper_enhanced}
use os.compositor.app_content.{render_app_content}
use os.compositor.easing.{bounce_offset, ease_out_cubic, ease_in_cubic}
use common.window_protocol.window_protocol.{WmInputEvent, wm_input_event, WM_EVENT_KEY_PRESS, WM_EVENT_MOUSE_CLICK, WM_EVENT_MOUSE_MOVE, WM_EVENT_MOUSE_RELEASE}
use os.compositor.display_backend.{CompositorBackend, FbCompositorBackend}
use os.compositor.input_backend.{InputBackend, Ps2InputBackend}
# NOTE: Shared shortcut table lives in os.gui.shortcut (ShortcutHandler,
# uart_char_to_action).  The compositor keeps its own Alt+key handling below
# because non-shortcut keys must route to focused windows -- importing
# ShortcutHandler would intercept bare keys (T, Q, M, W, R) that should
# reach in-process text editors and remote apps.

# ============================================================================
# Window Surface
# ============================================================================

struct WindowSurface:
    """A managed window in the compositor.

    Each surface has its own UISession containing the widget tree,
    plus position/size and rendering state.

    owner_port: IPC port of the owning application.
      0 = local in-process window (UI dispatched directly to UISession)
      >0 = remote app's IPC port (input queued for IPC delivery)
    """
    id: u64
    title: text
    x: i32
    y: i32
    width: i32
    height: i32
    visible: bool
    session: UISession?
    dirty: bool
    owner_port: u64

# ============================================================================
# Pre-maximize saved geometry — for restore after maximize
# ============================================================================

struct SavedGeometry:
    """Saved window geometry before maximize, used to restore."""
    window_id: u64
    x: i32
    y: i32
    width: i32
    height: i32

# ============================================================================
# Compositor
# ============================================================================

class Compositor:
    """Window compositor managing multiple surfaces.

    Surfaces are stored in Z-order: index 0 is the backmost window,
    last index is the frontmost. The focused window is always rendered
    on top.
    """
    surfaces: [WindowSurface]
    focused_idx: i32
    backend: CompositorBackend
    input: InputBackend
    cursor: CursorState
    desktop_bg: u32
    next_id: u64
    screen_width: i32
    screen_height: i32
    running: bool
    dragging: bool
    drag_window_id: u64
    drag_offset_x: i32
    drag_offset_y: i32
    pending_shortcut_key: text
    pending_meta_key: i32
    pending_remote_events: [WmInputEvent]
    saved_geometries: [SavedGeometry]
    taskbar_height: i32
    glass_theme_active: bool
    glass_config: GlassConfig
    # Animation state (integer easing, QEMU-compatible)
    anim_progress: i32
    anim_active: bool
    minimize_active: bool
    minimize_progress: i32
    minimize_win: i32
    close_active: bool
    close_progress: i32
    close_win: i32

impl Compositor:

    static fn new(fb: FramebufferDriver, keyboard: Ps2Keyboard, mouse: Ps2Mouse) -> Compositor:
        """Create a compositor with baremetal framebuffer and PS/2 input.

        Wraps the concrete drivers in CompositorBackend + InputBackend
        traits so the compositor uses a single rendering/input path.
        """
        val sw = fb.width.to_i32()
        val sh = fb.height.to_i32()
        val cb = FbCompositorBackend.new(fb)
        val ib = Ps2InputBackend.create(keyboard, mouse)
        Compositor.with_backends(cb, ib, sw, sh)

    static fn with_backends(b: CompositorBackend, i: InputBackend, sw: i32, sh: i32) -> Compositor:
        """Create a compositor using abstract backend and input traits.

        Works on all platforms: baremetal (FB/GPU), hosted (winit).
        """
        val initial_cursor = CursorState(
            x: sw / 2,
            y: sh / 2,
            visible: true,
            hotspot_x: 1,
            hotspot_y: 1
        )
        Compositor(
            surfaces: [],
            focused_idx: -1,
            backend: b,
            input: i,
            cursor: initial_cursor,
            desktop_bg: 0xFF003060,
            next_id: 1,
            screen_width: sw,
            screen_height: sh,
            running: false,
            dragging: false,
            drag_window_id: 0,
            drag_offset_x: 0,
            drag_offset_y: 0,
            pending_shortcut_key: "",
            pending_meta_key: 0,
            pending_remote_events: [],
            saved_geometries: [],
            taskbar_height: 32,
            glass_theme_active: false,
            glass_config: GlassConfig.dark(),
            anim_progress: 100,
            anim_active: false,
            minimize_active: false,
            minimize_progress: 0,
            minimize_win: -1,
            close_active: false,
            close_progress: 0,
            close_win: -1
        )

    # -- Window Management ---------------------------------------------------

    me create_window(title: text, x: i32, y: i32, w: i32, h: i32) -> u64:
        """Create a new window surface and return its ID.

        The window gets a default widget tree (empty column).
        """
        val id = self.next_id
        self.next_id = self.next_id + 1

        val root = column("win_{id}_root", [
            text_widget("win_{id}_content", "")
        ])
        val tree = UITree.new(root)
        val session = new_session(tree)

        val surface = WindowSurface(
            id: id,
            title: title,
            x: x,
            y: y,
            width: w,
            height: h,
            visible: true,
            session: session,
            dirty: true,
            owner_port: 0
        )

        self.surfaces = self.surfaces.push(surface)
        self.focused_idx = self.surfaces.len() - 1
        return id

    me add_surface(title: text, x: i32, y: i32, w: i32, h: i32) -> u64:
        """Create a lightweight window surface without a UISession widget tree.

        For baremetal use where the UI builder DSL is auto-stubbed.
        Windows are rendered as solid rectangles with title bars.
        """
        val id = self.next_id
        self.next_id = self.next_id + 1

        val surface = WindowSurface(
            id: id,
            title: title,
            x: x,
            y: y,
            width: w,
            height: h,
            visible: true,
            session: nil,
            dirty: true,
            owner_port: 0
        )

        self.surfaces = self.surfaces.push(surface)
        self.focused_idx = self.surfaces.len() - 1
        return id

    me create_window_with_tree(title: text, x: i32, y: i32, w: i32, h: i32, tree: UITree) -> u64:
        """Create a new window with a pre-built widget tree."""
        val id = self.next_id
        self.next_id = self.next_id + 1

        val session = new_session(tree)

        val surface = WindowSurface(
            id: id,
            title: title,
            x: x,
            y: y,
            width: w,
            height: h,
            visible: true,
            session: session,
            dirty: true,
            owner_port: 0
        )

        self.surfaces = self.surfaces.push(surface)
        self.focused_idx = self.surfaces.len() - 1
        return id

    me destroy_window(id: u64):
        """Remove a window by ID."""
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id != id:
                updated = updated.push(s)
        self.surfaces = updated

        # Fix focused index
        if self.surfaces.len() == 0:
            self.focused_idx = -1
        elif self.focused_idx >= self.surfaces.len():
            self.focused_idx = self.surfaces.len() - 1

    me focus_window(id: u64):
        """Bring a window to focus (front of Z-order)."""
        var target_idx: i32 = -1
        var idx: i32 = 0
        for s in self.surfaces:
            if s.id == id:
                target_idx = idx
            idx = idx + 1

        if target_idx < 0:
            return

        # Move target to end of list (topmost Z-order)
        val target = self.surfaces[target_idx]
        var reordered: [WindowSurface] = []
        for s in self.surfaces:
            if s.id != id:
                reordered = reordered.push(s)
        reordered = reordered.push(target)
        self.surfaces = reordered
        self.focused_idx = self.surfaces.len() - 1

    me move_window(id: u64, new_x: i32, new_y: i32):
        """Move a window to a new position."""
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id == id:
                updated = updated.push(WindowSurface(
                    id: s.id, title: s.title,
                    x: new_x, y: new_y,
                    width: s.width, height: s.height,
                    visible: s.visible, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
        self.surfaces = updated

    me resize_window(id: u64, new_w: i32, new_h: i32):
        """Resize a window."""
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id == id:
                updated = updated.push(WindowSurface(
                    id: s.id, title: s.title,
                    x: s.x, y: s.y,
                    width: new_w, height: new_h,
                    visible: s.visible, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
        self.surfaces = updated

    me create_remote_window(title: text, x: i32, y: i32, w: i32, h: i32, owner_port: u64) -> u64:
        """Create a new window surface owned by a remote app process.

        The owner_port identifies the IPC port of the owning application.
        Input events for this window will be queued in pending_remote_events
        instead of dispatched directly to the UISession.
        """
        val id = self.next_id
        self.next_id = self.next_id + 1

        val root = column("win_{id}_root", [
            text_widget("win_{id}_content", "")
        ])
        val tree = UITree.new(root)
        val session = new_session(tree)

        val surface = WindowSurface(
            id: id,
            title: title,
            x: x,
            y: y,
            width: w,
            height: h,
            visible: true,
            session: session,
            dirty: true,
            owner_port: owner_port
        )

        self.surfaces = self.surfaces.push(surface)
        self.focused_idx = self.surfaces.len() - 1
        return id

    me mark_window_dirty(id: u64):
        """Mark a window as needing re-render.

        Sets the dirty flag on the WindowSurface so the compositor
        repaints it on the next frame.
        """
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id == id:
                updated = updated.push(WindowSurface(
                    id: s.id, title: s.title,
                    x: s.x, y: s.y,
                    width: s.width, height: s.height,
                    visible: s.visible, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
        self.surfaces = updated

    me update_window_tree(id: u64, new_tree: UITree):
        """Replace the widget tree of a window and mark it dirty.

        Used by the WM service to apply remote tree updates received
        via IPC from app processes.
        """
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id == id:
                s.session.update_tree(new_tree)
                updated = updated.push(WindowSurface(
                    id: s.id, title: s.title,
                    x: s.x, y: s.y,
                    width: s.width, height: s.height,
                    visible: s.visible, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
        self.surfaces = updated

    me lower_window(id: u64):
        """Send a window to the back of the Z-order.

        The window becomes the backmost surface but remains visible.
        """
        var target_idx: i32 = -1
        var idx: i32 = 0
        for s in self.surfaces:
            if s.id == id:
                target_idx = idx
            idx = idx + 1

        if target_idx < 0:
            return

        # Move target to index 0 (backmost Z-order)
        val target = self.surfaces[target_idx]
        var reordered: [WindowSurface] = [target]
        for s in self.surfaces:
            if s.id != id:
                reordered = reordered.push(s)
        self.surfaces = reordered

        # Adjust focused index
        if self.focused_idx == target_idx:
            # Lowered the focused window — focus the new topmost
            if self.surfaces.len() > 1:
                self.focused_idx = self.surfaces.len() - 1
            else:
                self.focused_idx = 0
        elif self.focused_idx > target_idx:
            # Focused window moved down one slot
            self.focused_idx = self.focused_idx - 1

    me minimize_window(id: u64):
        """Minimize a window (hide it).

        Sets visible=false. The window remains in the surface list
        and can be restored later.
        """
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id == id:
                updated = updated.push(WindowSurface(
                    id: s.id, title: s.title,
                    x: s.x, y: s.y,
                    width: s.width, height: s.height,
                    visible: false, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
        self.surfaces = updated

    me maximize_window(id: u64):
        """Maximize a window to fill the screen (minus taskbar).

        Saves the current geometry so it can be restored later.
        """
        # Find current geometry and save it
        for s in self.surfaces:
            if s.id == id:
                # Save geometry before maximizing
                val saved = SavedGeometry(
                    window_id: id,
                    x: s.x,
                    y: s.y,
                    width: s.width,
                    height: s.height
                )
                # Replace existing saved geometry for this window
                var new_saved: [SavedGeometry] = []
                for g in self.saved_geometries:
                    if g.window_id != id:
                        new_saved = new_saved.push(g)
                new_saved = new_saved.push(saved)
                self.saved_geometries = new_saved

        # Resize to full screen minus taskbar
        val max_w = self.screen_width
        val max_h = self.screen_height - self.taskbar_height
        val zero: i32 = 0
        self.move_window(id, zero, zero)
        self.resize_window(id, max_w, max_h)

    me restore_window(id: u64):
        """Restore a window from minimized or maximized state.

        If the window was maximized, restores to its pre-maximize geometry.
        If the window was minimized (hidden), makes it visible again.
        """
        # Check if we have saved geometry (was maximized)
        var found_geo: SavedGeometry? = nil
        for g in self.saved_geometries:
            if g.window_id == id:
                found_geo = g

        if found_geo != nil:
            val geo = found_geo
            val gx = geo.x
            val gy = geo.y
            val gw = geo.width
            val gh = geo.height
            self.move_window(id, gx, gy)
            self.resize_window(id, gw, gh)
            # Remove saved geometry
            var remaining: [SavedGeometry] = []
            for g in self.saved_geometries:
                if g.window_id != id:
                    remaining = remaining.push(g)
            self.saved_geometries = remaining
        else:
            # Was minimized — just make visible
            var updated: [WindowSurface] = []
            for s in self.surfaces:
                if s.id == id:
                    updated = updated.push(WindowSurface(
                        id: s.id, title: s.title,
                        x: s.x, y: s.y,
                        width: s.width, height: s.height,
                        visible: true, session: s.session,
                        dirty: true,
                        owner_port: s.owner_port
                    ))
                else:
                    updated = updated.push(s)
            self.surfaces = updated

    me set_window_title(id: u64, new_title: text):
        """Change the title of a window."""
        var updated: [WindowSurface] = []
        for s in self.surfaces:
            if s.id == id:
                updated = updated.push(WindowSurface(
                    id: s.id, title: new_title,
                    x: s.x, y: s.y,
                    width: s.width, height: s.height,
                    visible: s.visible, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
        self.surfaces = updated

    me consume_remote_events() -> [WmInputEvent]:
        """Drain and return all pending remote input events.

        Called by the WM service to collect events that need to be
        delivered to remote app processes via IPC.
        """
        val events = self.pending_remote_events
        self.pending_remote_events = []
        events

    me queue_remote_event(event: WmInputEvent):
        """Queue an input event for a remote window.

        Used internally when input is directed at a window with
        owner_port > 0.
        """
        self.pending_remote_events = self.pending_remote_events.push(event)

    # -- Queries -------------------------------------------------------------

    fn window_count() -> i32:
        var count: i32 = 0
        for s in self.surfaces:
            count = count + 1
        return count

    fn focused_window_id() -> u64:
        if self.focused_idx >= 0 and self.focused_idx < self.surfaces.len():
            return self.surfaces[self.focused_idx].id
        return 0

    fn get_surface(id: u64) -> WindowSurface?:
        for s in self.surfaces:
            if s.id == id:
                return s
        return nil

    fn window_titles() -> [text]:
        """Get titles of all windows in Z-order."""
        var titles: [text] = []
        for s in self.surfaces:
            titles = titles.push(s.title)
        return titles

    # -- Rendering -----------------------------------------------------------

    me render_all():
        """Composite all windows via CompositorBackend.

        Single rendering path for all platforms (baremetal + hosted).
        Draws desktop background, windows back-to-front, cursor on top.
        When glass_theme_active is true, uses glassmorphism rendering path.

        Glass rendering has two backends (auto-selected via DI glass port):
          - C FFI (baremetal QEMU): uses rt_gui_* extern calls
          - Pure Simple (hosted/browser): uses CompositorBackend trait methods
        """
        if self.glass_theme_active:
            if glass_port_name() == "pure_simple":
                # Pure Simple glass path — uses CompositorBackend trait via DI port
                self._render_glass_pure()
            else:
                # C FFI glass path (baremetal QEMU)
                val sw = self.screen_width.to_u64()
                val sh = self.screen_height.to_u64()
                glass_begin_frame(sw, sh)
                glass_gradient_v(0, 0, sw, sh, self.glass_config.bg_top, self.glass_config.bg_bottom)

                var idx: i32 = 0
                for surface in self.surfaces:
                    if surface.visible:
                        val is_focused = idx == self.focused_idx
                        _render_glass_window(self.backend, surface, is_focused, self.glass_config)
                    idx = idx + 1

                draw_cursor(self.backend, self.screen_width, self.screen_height, self.cursor)
                glass_present()
        else:
            # Standard compositing path
            self.backend.clear(self.desktop_bg)

            var idx: i32 = 0
            for surface in self.surfaces:
                if surface.visible:
                    val is_focused = idx == self.focused_idx
                    _render_window(self.backend, surface, is_focused)
                idx = idx + 1

            draw_cursor(self.backend, self.screen_width, self.screen_height, self.cursor)
            self.backend.present()

    me _render_glass_pure():
        """Glass rendering via pure Simple — full desktop chrome.

        Uses shared modules for cross-platform rendering:
        - render_extras: enhanced wallpaper with stars/vignette/tech grid
        - window_effects: multi-layer shadows, frosted glass, focus ring, noise
        - desktop_chrome: system bar (top) + dock (bottom)
        - app_content: shared Terminal/Editor/FileManager/Calculator content
        All via CompositorBackend trait — works on hosted + baremetal.
        """
        val gc = self.glass_config
        # Convert u64 GlassConfig to u32/u8/i32 GlassPortConfig for pure Simple path
        val sc: u32 = gc.surface_color
        val sa: u8 = gc.surface_alpha
        val br: u32 = gc.blur_radius
        val bc: u32 = gc.border_color
        val ba: u8 = gc.border_alpha
        val so: i32 = gc.shadow_offset
        val sb: u32 = gc.shadow_blur
        val sha: u8 = gc.shadow_alpha
        val ac: u32 = gc.accent_color
        val ac2: u32 = gc.accent2_color
        val bgt: u32 = gc.bg_top
        val bgb: u32 = gc.bg_bottom
        val cfg = GlassPortConfig(
            surface_color: sc, surface_alpha: sa,
            blur_radius: br, border_color: bc, border_alpha: ba,
            shadow_offset: so, shadow_blur: sb, shadow_alpha: sha,
            accent_color: ac, accent2_color: ac2,
            bg_top: bgt, bg_bottom: bgb
        )

        # 1. Enhanced wallpaper with stars, vignette, tech grid
        self.backend.clear(0xFF000000)
        val is_dark = gc.bg_top < 0x00808080
        draw_wallpaper_enhanced(self.backend, is_dark, gc.accent_color, gc.accent2_color)

        # 2. Windows (back-to-front Z-order) with animation
        val active_idx = self.focused_idx
        val boff = bounce_offset(self.anim_progress)
        var idx: i32 = 0
        for surface in self.surfaces:
            if surface.visible:
                val is_focused = idx == self.focused_idx

                # Apply animation offsets
                var wy = surface.y
                var wx = surface.x
                var ww = surface.width
                var wh = surface.height
                var skip_render = false

                # Focused window gets bounce offset
                if is_focused and self.anim_active:
                    wy = wy - boff

                # Minimize animation: shrink toward dock
                if self.minimize_active and idx == self.minimize_win:
                    val prog = ease_out_cubic(self.minimize_progress)
                    val dock_y = self.screen_height - 58
                    val dock_x = self.screen_width / 2
                    wx = surface.x + (dock_x - surface.x) * prog / 100
                    wy = surface.y + (dock_y - surface.y) * prog / 100
                    ww = surface.width - surface.width * prog / 120
                    wh = surface.height - surface.height * prog / 120
                    if ww < 10 or wh < 10:
                        skip_render = true

                # Close animation: shrink inward
                if self.close_active and idx == self.close_win:
                    val prog = ease_in_cubic(self.close_progress)
                    val shrink = prog * 15 / 100
                    wx = surface.x + shrink
                    wy = surface.y + shrink
                    ww = surface.width - shrink * 2
                    wh = surface.height - shrink * 2
                    if ww < 10 or wh < 10:
                        skip_render = true

                if not skip_render:
                    # Enhanced glass window frame (shared window_effects)
                    draw_glass_window_enhanced(self.backend, wx, wy,
                        ww, wh, surface.title, is_focused, cfg, 28)

                    # App content (shared app_content)
                    val cx = client_area_x(wx)
                    val cy = client_area_y(wy)
                    val cw = client_area_width(ww)
                    val ch_val = client_area_height(wh)
                    if cw > 0 and ch_val > 0:
                        render_app_content(self.backend, surface.title, cx, cy, cw, ch_val)
            idx = idx + 1

        # 3. System bar (top) + Dock (bottom) — shared desktop chrome
        draw_system_bar(self.backend, cfg, active_idx)
        draw_dock(self.backend, cfg, active_idx)

        # 4. Global accent tint + bottom edge line
        self.backend.blend_rect(0, self.screen_height - 2, self.screen_width, 2, 0x00000000, 20)
        self.backend.blend_rect(0, 0, self.screen_width, self.screen_height, gc.accent_color, 2)

        # 5. Cursor + present
        draw_cursor(self.backend, self.screen_width, self.screen_height, self.cursor)
        self.backend.present()

    me set_glass_theme(active: bool):
        """Enable or disable glassmorphism rendering."""
        self.glass_theme_active = active

    me set_glass_theme_pure(active: bool):
        """Enable glass theme with pure Simple rendering (for hosted backends).

        Registers a pure Simple glass port via DI, using the current backend.
        """
        self.glass_theme_active = active
        if active:
            register_pure_glass(self.backend)

    me set_glass_config(config: GlassConfig):
        """Set the glass configuration for the compositor."""
        self.glass_config = config

    # -- Input Handling ------------------------------------------------------

    me handle_input():
        """Poll keyboard and mouse, route events.

        Keyboard shortcuts:
          Alt+Tab  — cycle focus to next window
          Alt+F4   — close focused window
          Alt+F5   — minimize focused window (toggle visibility)

        Mouse actions:
          Left click on close button — close that window
          Left click on title bar — start dragging
          Left click on window body — focus that window
          Mouse move while dragging — move window
          Left release — stop dragging
        """
        val key_event = self.input.poll_key()
        if key_event != nil:
            self._handle_key_event(key_event)

        val mouse_event = self.input.poll_mouse()
        if mouse_event != nil:
            self._handle_mouse_event(mouse_event)

    me _handle_key_event(key_event: KeyEvent):
        """Process a keyboard event."""
        match key_event:
            KeyEvent.Release(key):
                return
            KeyEvent.Press(key):
                pass_dn

        val key = key_event.key

        # Escape quits in glass theme mode (like QEMU WM)
        match key:
            Key.Escape:
                if self.glass_theme_active:
                    self.stop()
                    return
            _: pass_dn

        # Glass theme shortcuts (like QEMU WM)
        val ch_val = self.input.key_to_char(key)
        if ch_val != nil:
            if self.glass_theme_active:
                # T = toggle dark/light theme
                if ch_val == "t" or ch_val == "T":
                    if self.glass_config.bg_top < 0x00808080:
                        self.glass_config = GlassConfig.light()
                    else:
                        self.glass_config = GlassConfig.dark()
                    return
                # 1/2/3 = focus window by index
                if ch_val == "1":
                    self._focus_by_index(0)
                    return
                if ch_val == "2":
                    self._focus_by_index(1)
                    return
                if ch_val == "3":
                    self._focus_by_index(2)
                    return
                # M = minimize active window
                if ch_val == "m" or ch_val == "M":
                    if self.focused_idx >= 0 and not self.minimize_active:
                        self.minimize_active = true
                        self.minimize_progress = 0
                        self.minimize_win = self.focused_idx
                    return
                # W = close active window (with animation)
                if ch_val == "w" or ch_val == "W":
                    if self.focused_idx >= 0 and not self.close_active:
                        self.close_active = true
                        self.close_progress = 0
                        self.close_win = self.focused_idx
                    return
                # R = restore all minimized windows
                if ch_val == "r" or ch_val == "R":
                    var restored: [WindowSurface] = []
                    for s in self.surfaces:
                        if not s.visible:
                            restored = restored.push(WindowSurface(
                                id: s.id, title: s.title,
                                x: s.x, y: s.y,
                                width: s.width, height: s.height,
                                visible: true, session: s.session,
                                dirty: true, owner_port: s.owner_port
                            ))
                        else:
                            restored = restored.push(s)
                    self.surfaces = restored
                    return

        # Compositor-level shortcuts (Alt held)
        if self.input.alt_held():
            match key:
                Key.Tab:
                    self.cycle_focus()
                    return
                Key.F4:
                    self.close_focused_window()
                    return
                Key.F5:
                    self.toggle_focused_visibility()
                    return
                _:
                    pass_dn

        # Global shortcuts (Ctrl+Alt held) — dispatched to desktop shell
        if self.input.ctrl_held() and self.input.alt_held():
            val ch = self.input.key_to_char(key)
            if ch != nil:
                self.pending_shortcut_key = ch
                return

        # Route to focused window
        if self.focused_idx >= 0 and self.focused_idx < self.surfaces.len():
            val focused = self.surfaces[self.focused_idx]

            # Remote window: queue event for IPC delivery
            if focused.owner_port > 0:
                val key_char = self.input.key_to_char(key)
                var key_code: u32 = 0
                if key_char != nil:
                    key_code = key_char.to_u32()
                val remote_event = wm_input_event(focused.id, WM_EVENT_KEY_PRESS, key_code, 0, 0)
                self.queue_remote_event(remote_event)
                return

            # Local window: dispatch to UISession directly
            val ui_event = _key_to_ui_event(self.input, key)
            if ui_event != nil:
                self.surfaces[self.focused_idx].session.dispatch(ui_event)
                # Mark dirty
                var updated: [WindowSurface] = []
                var i: i32 = 0
                for s in self.surfaces:
                    if i == self.focused_idx:
                        updated = updated.push(WindowSurface(
                            id: s.id, title: s.title,
                            x: s.x, y: s.y,
                            width: s.width, height: s.height,
                            visible: s.visible, session: s.session,
                            dirty: true,
                            owner_port: s.owner_port
                        ))
                    else:
                        updated = updated.push(s)
                    i = i + 1
                self.surfaces = updated

    me _handle_mouse_event(event: MouseEvent):
        """Process a mouse event: update cursor, handle clicks, dragging."""
        # Update cursor position
        self.cursor = CursorState(
            x: event.x.to_i32(),
            y: event.y.to_i32(),
            visible: self.cursor.visible,
            hotspot_x: self.cursor.hotspot_x,
            hotspot_y: self.cursor.hotspot_y
        )

        val mx = event.x.to_i32()
        val my = event.y.to_i32()

        # Handle drag release
        if event.left_just_released:
            self.dragging = false
            self.drag_window_id = 0
            return

        # Handle ongoing drag
        if self.dragging and event.left_pressed:
            val new_x = mx - self.drag_offset_x
            val new_y = my - self.drag_offset_y
            val drag_id = self.drag_window_id
            self.move_window(drag_id, new_x, new_y)
            return

        # Handle new left click — hit test windows back-to-front (topmost first)
        if event.left_just_pressed:
            # Iterate in reverse Z-order to find topmost hit
            var idx = self.surfaces.len() - 1
            while idx >= 0:
                val s = self.surfaces[idx]
                if s.visible:
                    # Check if click is within the window frame
                    val in_x = mx >= s.x and mx < s.x + s.width
                    val in_y = my >= s.y and my < s.y + s.height
                    if in_x and in_y:
                        val sid = s.id
                        # Check close button first
                        if is_in_close_button(s.x, s.y, s.width, mx, my):
                            self.destroy_window(sid)
                            return

                        # Check title bar for drag
                        if is_in_title_bar(s.x, s.y, s.width, mx, my):
                            self.focus_window(sid)
                            self.dragging = true
                            self.drag_window_id = sid
                            self.drag_offset_x = mx - s.x
                            self.drag_offset_y = my - s.y
                            return

                        # Click on window body — just focus
                        self.focus_window(sid)
                        return
                idx = idx - 1

    me cycle_focus():
        """Cycle focus to the next window (Alt+Tab behavior)."""
        if self.surfaces.len() <= 1:
            return
        var next = self.focused_idx + 1
        if next >= self.surfaces.len():
            next = 0
        val target = self.surfaces[next]
        val target_id = target.id
        self.focus_window(target_id)
        # Start bounce animation
        self.anim_active = true
        self.anim_progress = 0

    me _focus_by_index(idx: i32):
        """Focus a window by surface index (0, 1, 2). Starts bounce animation."""
        if idx >= 0 and idx < self.surfaces.len():
            val target = self.surfaces[idx]
            self.focus_window(target.id)
            self.anim_active = true
            self.anim_progress = 0

    me close_focused_window():
        """Close the currently focused window."""
        if self.focused_idx >= 0 and self.focused_idx < self.surfaces.len():
            val id = self.surfaces[self.focused_idx].id
            self.destroy_window(id)

    me toggle_focused_visibility():
        """Toggle visibility of the focused window."""
        if self.focused_idx < 0:
            return
        var updated: [WindowSurface] = []
        var i: i32 = 0
        for s in self.surfaces:
            if i == self.focused_idx:
                updated = updated.push(WindowSurface(
                    id: s.id, title: s.title,
                    x: s.x, y: s.y,
                    width: s.width, height: s.height,
                    visible: not s.visible, session: s.session,
                    dirty: true,
                    owner_port: s.owner_port
                ))
            else:
                updated = updated.push(s)
            i = i + 1
        self.surfaces = updated

    # -- Main Loop -----------------------------------------------------------

    me run_loop():
        """Main compositor loop: handle input, render, repeat.

        Includes animation ticking for focus bounce, minimize, and close.
        """
        self.running = true
        while self.running:
            self.handle_input()
            self._tick_animations()
            self.render_all()

    me _tick_animations():
        """Update all active animations by one frame step."""
        # Focus bounce animation (12 frames, 0-100 progress)
        if self.anim_active:
            self.anim_progress = self.anim_progress + 8
            if self.anim_progress >= 100:
                self.anim_progress = 100
                self.anim_active = false

        # Minimize animation (shrink toward dock)
        if self.minimize_active:
            self.minimize_progress = self.minimize_progress + 12
            if self.minimize_progress >= 100:
                self.minimize_progress = 100
                self.minimize_active = false
                # Actually minimize the window
                if self.minimize_win >= 0 and self.minimize_win < self.surfaces.len():
                    val min_id = self.surfaces[self.minimize_win].id
                    self.minimize_window(min_id)
                    # Focus next visible window
                    self.cycle_focus()
                self.minimize_win = -1

        # Close animation (shrink and fade)
        if self.close_active:
            self.close_progress = self.close_progress + 16
            if self.close_progress >= 100:
                self.close_progress = 100
                self.close_active = false
                # Actually close the window
                if self.close_win >= 0 and self.close_win < self.surfaces.len():
                    val close_id = self.surfaces[self.close_win].id
                    self.destroy_window(close_id)
                self.close_win = -1

    me consume_pending_shortcut() -> text:
        """Return and clear any pending Ctrl+Alt shortcut key.

        Returns "" if no shortcut is pending.
        """
        val key = self.pending_shortcut_key
        self.pending_shortcut_key = ""
        key

    me consume_pending_meta_key() -> i32:
        """Return and clear any pending Meta key press.

        Returns 0 if no meta key is pending.
        """
        val key = self.pending_meta_key
        self.pending_meta_key = 0
        key

    me consume_remote_events() -> [WmInputEvent]:
        """Return and clear pending remote window input events."""
        val events = self.pending_remote_events
        self.pending_remote_events = []
        events

    me stop():
        """Signal the compositor loop to exit."""
        self.running = false

# ============================================================================
# Internal: Render a Single Window (via CompositorBackend)
# ============================================================================

fn _render_window(backend: CompositorBackend, surface: WindowSurface, focused: bool):
    """Render a single window: decorations + client area content.

    Uses CompositorBackend for all rendering — works on all platforms.
    """
    draw_window_frame(backend, surface.x, surface.y, surface.width, surface.height, surface.title, focused)

    val cx = client_area_x(surface.x)
    val cy = client_area_y(surface.y)
    val cw = client_area_width(surface.width)
    val ch = client_area_height(surface.height)

    if cw <= 0 or ch <= 0:
        return

    val state = surface.session.current_state()
    val tree_theme = state.tree.theme()
    val theme = resolve_theme(tree_theme)
    val root = state.tree.root_node()
    val rects = compute_layout(root, cx, cy, cw, ch)

    backend.fill_rect(cx, cy, cw, ch, theme.bg)
    _render_tree(backend, root, rects, state.focused_id, theme)

# ============================================================================
# Internal: Render a Single Window with Glass Theme
# ============================================================================

fn _render_glass_window(backend: CompositorBackend, surface: WindowSurface, focused: bool, config: GlassConfig):
    """Render a single window with glassmorphism decorations + client area.

    Uses glass_effects for the window frame, then renders client content
    on top of the glass surface.
    """
    draw_glass_window_frame(backend, surface.x, surface.y, surface.width, surface.height, surface.title, focused, config)

    val cx = client_area_x(surface.x)
    val cy = client_area_y(surface.y)
    val cw = client_area_width(surface.width)
    val ch = client_area_height(surface.height)

    if cw <= 0 or ch <= 0:
        return

    val state = surface.session.current_state()
    val tree_theme = state.tree.theme()
    val theme = resolve_theme(tree_theme)
    val root = state.tree.root_node()
    val rects = compute_layout(root, cx, cy, cw, ch)

    backend.fill_rect(cx, cy, cw, ch, theme.bg)
    _render_tree(backend, root, rects, state.focused_id, theme)

# ============================================================================
# Internal: Key to UIEvent Translation (via InputBackend)
# ============================================================================

fn _key_to_ui_event(input: InputBackend, key: Key) -> UIEvent?:
    """Convert a Key press to a UIEvent for window dispatch."""
    match key:
        Key.Escape: return UIEvent.Quit
        Key.Tab:
            if input.shift_held():
                return UIEvent.FocusPrev
            return UIEvent.FocusNext
        Key.Up: return UIEvent.KeyPress(key: "up")
        Key.Down: return UIEvent.KeyPress(key: "down")
        Key.Left: return UIEvent.KeyPress(key: "left")
        Key.Right: return UIEvent.KeyPress(key: "right")
        Key.Enter: return UIEvent.KeyPress(key: "enter")
        Key.Backspace: return UIEvent.KeyPress(key: "backspace")
        Key.Delete: return UIEvent.KeyPress(key: "delete")
        Key.Home: return UIEvent.KeyPress(key: "home")
        Key.End: return UIEvent.KeyPress(key: "end")
        Key.PageUp: return UIEvent.KeyPress(key: "pageup")
        Key.PageDown: return UIEvent.KeyPress(key: "pagedown")
        _: pass_dn

    val ch = input.key_to_char(key)
    if ch != nil:
        return UIEvent.KeyPress(key: ch)
    return nil
