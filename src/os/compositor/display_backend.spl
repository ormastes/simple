# Compositor Display Backend — trait abstracting framebuffer vs GPU rendering
#
# The compositor renders through this trait instead of directly calling
# FramebufferDriver, allowing transparent switching between software
# framebuffer and GPU-accelerated rendering paths.
#
# Two implementations:
#   - FbCompositorBackend:  wraps FramebufferDriver (software double-buffer)
#   - GpuCompositorBackend: wraps VirtioGpuDriver (DMA framebuffer + GPU flush)

use os.drivers.framebuffer.fb_driver.{FramebufferDriver, Color, get_glyph_8x16}
use os.drivers.virtio.virtio_gpu.{VirtioGpuDriver}
use os.kernel.boot.mmio.{mmio_write32}

# ============================================================================
# Compositor Backend Trait
# ============================================================================

trait CompositorBackend:
    """Abstract rendering interface for the window compositor.

    All drawing operations use u32 ARGB (0xAARRGGBB) colors.
    Implementations convert to the underlying driver's color format.
    """
    fn width() -> i32
    fn height() -> i32
    fn clear(color: u32)
    # Paints columns [x, x+w) and rows [y, y+h). Right/bottom edge EXCLUSIVE.
    # A zero-width or zero-height rect is a no-op. Negative w/h is undefined
    # (implementations may silently no-op, wrap, or overrun — do not rely).
    # See doc/03_plan/sys_gui/d1_fill_rect_contract_doctest.md.
    fn fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32)
    fn draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32)
    fn draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32)
    fn put_pixel(x: i32, y: i32, color: u32)
    fn present()
    fn present_rect(x: i32, y: i32, w: i32, h: i32)
    fn blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8)
    fn blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32)
    fn gradient_v(x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32)
    fn read_pixel(x: i32, y: i32) -> u32

# ============================================================================
# Glass Rendering Extern Helpers
# ============================================================================

extern fn rt_gui_blend_fill(xy: u64, wh: u64, color: u64, alpha: u64)
extern fn rt_gui_box_blur(xy: u64, wh: u64, radius: u64, unused: u64)
extern fn rt_gui_gradient_v(xy: u64, wh: u64, c1: u64, c2: u64)
extern fn rt_gui_read_pixel(x_y: u64, unused1: u64, unused2: u64, unused3: u64) -> u64

fn pack(hi: u64, lo: u64) -> u64:
    (hi << 32) | (lo & 0xFFFFFFFF)

fn clamp_u64(v: i32) -> u64:
    """Clamp i32 to non-negative and convert to u64."""
    if v < 0:
        return 0
    v.to_u64()

# ============================================================================
# Color Conversion Helper
# ============================================================================

fn u32_to_color(argb: u32) -> Color:
    """Convert packed u32 ARGB (0xAARRGGBB) to Color struct."""
    val a = ((argb >> 24) & 0xFF).to_u8()
    val r = ((argb >> 16) & 0xFF).to_u8()
    val g = ((argb >> 8) & 0xFF).to_u8()
    val b = (argb & 0xFF).to_u8()
    Color(r: r, g: g, b: b, a: a)

# ============================================================================
# Framebuffer Compositor Backend
# ============================================================================

class FbCompositorBackend:
    """CompositorBackend wrapping FramebufferDriver.

    Delegates all drawing to the framebuffer's double-buffered software
    rendering. Colors are converted from u32 ARGB to the Color struct.
    present() calls swap_buffers() to copy the back buffer to hardware.
    """
    fb: FramebufferDriver

impl CompositorBackend for FbCompositorBackend:

    fn width() -> i32:
        self.fb.width.to_i32()

    fn height() -> i32:
        self.fb.height.to_i32()

    me clear(color: u32):
        val c = u32_to_color(color)
        self.fb.clear(c)

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        val c = u32_to_color(color)
        self.fb.fill_rect(x.to_u32(), y.to_u32(), w.to_u32(), h.to_u32(), c)

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        val fg_c = u32_to_color(fg)
        val bg_c = u32_to_color(bg)
        self.fb.draw_text(x.to_u32(), y.to_u32(), text_str, fg_c, bg_c)

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        val fg_c = u32_to_color(fg)
        val bg_c = u32_to_color(bg)
        self.fb.draw_char_8x16(x.to_u32(), y.to_u32(), ch, fg_c, bg_c)

    me put_pixel(x: i32, y: i32, color: u32):
        val c = u32_to_color(color)
        self.fb.put_pixel(x.to_u32(), y.to_u32(), c)

    me present():
        self.fb.swap_buffers()

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        # FramebufferDriver only has full-frame swap_buffers, so
        # present_rect degrades to a full present.
        self.fb.swap_buffers()

    me blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8):
        val xy = pack(clamp_u64(x), clamp_u64(y))
        val wh = pack(clamp_u64(w), clamp_u64(h))
        rt_gui_blend_fill(xy, wh, color.to_u64(), alpha.to_u64())

    me blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32):
        val xy = pack(clamp_u64(x), clamp_u64(y))
        val wh = pack(clamp_u64(w), clamp_u64(h))
        rt_gui_box_blur(xy, wh, radius.to_u64(), 0)

    me gradient_v(x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32):
        val xy = pack(clamp_u64(x), clamp_u64(y))
        val wh = pack(clamp_u64(w), clamp_u64(h))
        rt_gui_gradient_v(xy, wh, color1.to_u64(), color2.to_u64())

    fn read_pixel(x: i32, y: i32) -> u32:
        val xy = pack(clamp_u64(x), clamp_u64(y))
        val result = rt_gui_read_pixel(xy, 0, 0, 0)
        result.to_u32()

impl FbCompositorBackend:

    static fn new(fb: FramebufferDriver) -> FbCompositorBackend:
        """Create a framebuffer compositor backend."""
        FbCompositorBackend(fb: fb)

# ============================================================================
# GPU Compositor Backend
# ============================================================================

class GpuCompositorBackend:
    """CompositorBackend wrapping VirtioGpuDriver.

    Writes pixels directly to the GPU's DMA framebuffer via mmio_write32.
    present() calls gpu.flush() to transfer + flush the entire display.
    present_rect() calls gpu.flush_rect() for partial updates.
    """
    gpu: VirtioGpuDriver
    w: i32
    h: i32

impl CompositorBackend for GpuCompositorBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        """Write every pixel in the GPU framebuffer to the given color."""
        self.gpu.clear(color)

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        """Fill a rectangle in the GPU framebuffer."""
        self.gpu.fill_rect(x.to_u32(), y.to_u32(), w.to_u32(), h.to_u32(), color)

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        """Draw text by rendering each character glyph into the GPU framebuffer.

        Uses 8x16 bitmap font. Each character is rendered pixel-by-pixel
        via put_pixel into the GPU's DMA buffer.
        """
        var cx = x
        for ch in text_str:
            val ch_byte = ch.to_u8()
            self.draw_char_8x16(cx, y, ch_byte, fg, bg)
            cx = cx + 8

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        """Draw a single 8x16 character glyph into the GPU framebuffer.

        Uses the VGA 8x16 bitmap font from fb_driver. Each glyph row is
        a byte where MSB = leftmost pixel. Set bits draw fg, clear bits draw bg.
        """
        val glyph = get_glyph_8x16(ch)
        var row: i32 = 0
        while row < 16:
            val bits = glyph[row]
            var col: i32 = 0
            while col < 8:
                val mask = 0x80 >> col
                val color = if (bits & mask) != 0: fg else: bg
                val px = x + col
                val py = y + row
                self.put_pixel(px, py, color)
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        """Write a single pixel to the GPU DMA framebuffer."""
        self.gpu.put_pixel(x.to_u32(), y.to_u32(), color)

    me present():
        """Flush the entire GPU framebuffer to the display."""
        self.gpu.flush()

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        """Flush a rectangular region of the GPU framebuffer."""
        self.gpu.flush_rect(x.to_u32(), y.to_u32(), w.to_u32(), h.to_u32())

    me blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8):
        val xy = pack(clamp_u64(x), clamp_u64(y))
        val wh = pack(clamp_u64(w), clamp_u64(h))
        rt_gui_blend_fill(xy, wh, color.to_u64(), alpha.to_u64())

    me blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32):
        val xy = pack(clamp_u64(x), clamp_u64(y))
        val wh = pack(clamp_u64(w), clamp_u64(h))
        rt_gui_box_blur(xy, wh, radius.to_u64(), 0)

    me gradient_v(x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32):
        val xy = pack(clamp_u64(x), clamp_u64(y))
        val wh = pack(clamp_u64(w), clamp_u64(h))
        rt_gui_gradient_v(xy, wh, color1.to_u64(), color2.to_u64())

    fn read_pixel(x: i32, y: i32) -> u32:
        val xy = pack(clamp_u64(x), clamp_u64(y))
        val result = rt_gui_read_pixel(xy, 0, 0, 0)
        result.to_u32()

impl GpuCompositorBackend:

    static fn new(gpu: VirtioGpuDriver) -> GpuCompositorBackend:
        """Create a GPU compositor backend from an initialized VirtIO-GPU driver."""
        val gw = gpu.width.to_i32()
        val gh = gpu.height.to_i32()
        GpuCompositorBackend(gpu: gpu, w: gw, h: gh)
