# Compositor Display Backend — trait abstracting framebuffer vs GPU rendering
#
# The compositor renders through this trait instead of directly calling
# FramebufferDriver, allowing transparent switching between software
# framebuffer and GPU-accelerated rendering paths.
#
# Two implementations:
#   - FbCompositorBackend:  wraps FramebufferDriver (software double-buffer)
#   - GpuCompositorBackend: wraps VirtioGpuDriver (DMA framebuffer + GPU flush)
#
# Trait split (D2 Phase 1 — 2026-04-14): the glass effect methods
# (blend_rect / blur_region / gradient_v / read_pixel) live on an optional
# subtrait `CompositorGlassCapable`. Backends implement it when their
# per-surface pixel path can safely do alpha/blur/gradient; backends whose
# only available path is `rt_gui_*` against the raw framebuffer opt out
# and callers must feature-detect via `as_glass_capable()`.
# See doc/03_plan/sys_gui/d2_glass_subtrait_migration.md.

use os.drivers.framebuffer.fb_driver.{FramebufferDriver, Color, get_glyph_8x16}
use os.drivers.virtio.virtio_gpu.{VirtioGpuDriver}
use os.kernel.boot.mmio.{mmio_write32, mmio_read32}

# ============================================================================
# Platform Capability Probe
# ============================================================================

class PlatformCaps:
    """Minimal capability record produced by the OS platform probe."""
    has_gpu: bool

# ============================================================================
# Backend Factory Functions (used by select_backend)
# ============================================================================

fn make_fb_compositor_backend(fb: FramebufferDriver) -> FbCompositorBackend:
    """Construct the software framebuffer compositor backend."""
    FbCompositorBackend.new(fb)

fn make_gpu_compositor_backend(gpu: VirtioGpuDriver) -> GpuCompositorBackend:
    """Construct the VirtIO-GPU compositor backend."""
    GpuCompositorBackend.new(gpu)

# ============================================================================
# Compositor Backend Trait
# ============================================================================

trait CompositorBackend:
    """Abstract rendering interface for the window compositor.

    All drawing operations use u32 ARGB (0xAARRGGBB) colors.
    Implementations convert to the underlying driver's color format.
    """
    fn width() -> i32
    fn height() -> i32
    fn clear(color: u32)
    # Paints columns [x, x+w) and rows [y, y+h). Right/bottom edge EXCLUSIVE.
    # A zero-width or zero-height rect is a no-op. Negative w/h is undefined
    # (implementations may silently no-op, wrap, or overrun — do not rely).
    # See doc/03_plan/sys_gui/d1_fill_rect_contract_doctest.md.
    fn fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32)
    fn draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32)
    fn draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32)
    fn put_pixel(x: i32, y: i32, color: u32)
    fn present()
    fn present_rect(x: i32, y: i32, w: i32, h: i32)
    # Optional glass-capable view onto this backend. Returns `nil` on
    # backends that cannot safely paint alpha/blur/gradient into their
    # own surface; callers must degrade to opaque fill.
    fn as_glass_capable() -> CompositorGlassCapable?

trait CompositorGlassCapable:
    """Optional subtrait for backends that can paint glass effects into
    their own surface. Backends that can't (or don't yet) omit the impl;
    callers must degrade to opaque fill via
    `os.compositor.glass_dispatch.cap_blend_rect` (and siblings).

    See doc/03_plan/sys_gui/d2_glass_subtrait_migration.md and
    doc/06_spec/runtime/rt_gui_glass_contract.md.
    """
    fn blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8)
    fn blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32)
    fn gradient_v(x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32)
    fn read_pixel(x: i32, y: i32) -> u32

# ============================================================================
# Glass Rendering Extern Helpers
# ============================================================================

extern fn rt_gui_blend_fill(xy: u64, wh: u64, color: u64, alpha: u64)
extern fn rt_gui_box_blur(xy: u64, wh: u64, radius: u64, unused: u64)
extern fn rt_gui_gradient_v(xy: u64, wh: u64, c1: u64, c2: u64)
extern fn rt_gui_read_pixel(x_y: u64, unused1: u64, unused2: u64, unused3: u64) -> u64

fn pack(hi: u64, lo: u64) -> u64:
    (hi << 32) | (lo & 0xFFFFFFFF)

fn clamp_u64(v: i32) -> u64:
    """Clamp i32 to non-negative and convert to u64."""
    if v < 0:
        return 0
    v.to_u64()

# ============================================================================
# Color Conversion Helper
# ============================================================================

fn u32_to_color(argb: u32) -> Color:
    """Convert packed u32 ARGB (0xAARRGGBB) to Color struct."""
    val a = ((argb >> 24) & 0xFF).to_u8()
    val r = ((argb >> 16) & 0xFF).to_u8()
    val g = ((argb >> 8) & 0xFF).to_u8()
    val b = (argb & 0xFF).to_u8()
    Color(r: r, g: g, b: b, a: a)

# ============================================================================
# Framebuffer Compositor Backend
# ============================================================================

class FbCompositorBackend:
    """CompositorBackend wrapping FramebufferDriver.

    Delegates all drawing to the framebuffer's double-buffered software
    rendering. Colors are converted from u32 ARGB to the Color struct.
    present() calls swap_buffers() to copy the back buffer to hardware.
    """
    fb: FramebufferDriver

impl CompositorBackend for FbCompositorBackend:

    fn width() -> i32:
        self.fb.width.to_i32()

    fn height() -> i32:
        self.fb.height.to_i32()

    me clear(color: u32):
        val c = u32_to_color(color)
        self.fb.clear(c)

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        val c = u32_to_color(color)
        self.fb.fill_rect(x.to_u32(), y.to_u32(), w.to_u32(), h.to_u32(), c)

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        val fg_c = u32_to_color(fg)
        val bg_c = u32_to_color(bg)
        self.fb.draw_text(x.to_u32(), y.to_u32(), text_str, fg_c, bg_c)

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        val fg_c = u32_to_color(fg)
        val bg_c = u32_to_color(bg)
        self.fb.draw_char_8x16(x.to_u32(), y.to_u32(), ch, fg_c, bg_c)

    me put_pixel(x: i32, y: i32, color: u32):
        val c = u32_to_color(color)
        self.fb.put_pixel(x.to_u32(), y.to_u32(), c)

    me present():
        self.fb.swap_buffers()

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        self.fb.present_rect(x.to_u32(), y.to_u32(), w.to_u32(), h.to_u32())

    fn as_glass_capable() -> CompositorGlassCapable?:
        # Fb backend opts IN to CompositorGlassCapable; the rt_gui_* externs
        # paint the baremetal framebuffer which IS the surface we own.
        self

impl CompositorGlassCapable for FbCompositorBackend:

    me blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8):
        val xy = pack(clamp_u64(x), clamp_u64(y))
        val wh = pack(clamp_u64(w), clamp_u64(h))
        rt_gui_blend_fill(xy, wh, color.to_u64(), alpha.to_u64())

    me blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32):
        val xy = pack(clamp_u64(x), clamp_u64(y))
        val wh = pack(clamp_u64(w), clamp_u64(h))
        rt_gui_box_blur(xy, wh, radius.to_u64(), 0)

    me gradient_v(x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32):
        val xy = pack(clamp_u64(x), clamp_u64(y))
        val wh = pack(clamp_u64(w), clamp_u64(h))
        rt_gui_gradient_v(xy, wh, color1.to_u64(), color2.to_u64())

    fn read_pixel(x: i32, y: i32) -> u32:
        val xy = pack(clamp_u64(x), clamp_u64(y))
        val result = rt_gui_read_pixel(xy, 0, 0, 0)
        result.to_u32()

impl FbCompositorBackend:

    static fn new(fb: FramebufferDriver) -> FbCompositorBackend:
        """Create a framebuffer compositor backend."""
        FbCompositorBackend(fb: fb)

# ============================================================================
# GPU Compositor Backend
# ============================================================================

class GpuCompositorBackend:
    """CompositorBackend wrapping VirtioGpuDriver.

    Writes pixels directly to the GPU's DMA framebuffer via mmio_write32.
    present() calls gpu.flush() to transfer + flush the entire display.
    present_rect() calls gpu.flush_rect() for partial updates.
    """
    gpu: VirtioGpuDriver
    w: i32
    h: i32

impl CompositorBackend for GpuCompositorBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        """Write every pixel in the GPU framebuffer to the given color."""
        self.gpu.clear(color)

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        """Fill a rectangle in the GPU framebuffer."""
        self.gpu.fill_rect(x.to_u32(), y.to_u32(), w.to_u32(), h.to_u32(), color)

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        """Draw text by rendering each character glyph into the GPU framebuffer.

        Uses 8x16 bitmap font. Each character is rendered pixel-by-pixel
        via put_pixel into the GPU's DMA buffer.
        """
        var cx = x
        for ch in text_str:
            val ch_byte = ch.to_u8()
            self.draw_char_8x16(cx, y, ch_byte, fg, bg)
            cx = cx + 8

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        """Draw a single 8x16 character glyph into the GPU framebuffer.

        Uses the VGA 8x16 bitmap font from fb_driver. Each glyph row is
        a byte where MSB = leftmost pixel. Set bits draw fg, clear bits draw bg.
        """
        val glyph = get_glyph_8x16(ch)
        var row: i32 = 0
        while row < 16:
            val bits = glyph[row]
            var col: i32 = 0
            while col < 8:
                val mask = 0x80 >> col
                val color = if (bits & mask) != 0: fg else: bg
                val px = x + col
                val py = y + row
                self.put_pixel(px, py, color)
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        """Write a single pixel to the GPU DMA framebuffer."""
        self.gpu.put_pixel(x.to_u32(), y.to_u32(), color)

    me present():
        """Flush the entire GPU framebuffer to the display."""
        self.gpu.flush()

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        """Flush a rectangular region of the GPU framebuffer."""
        self.gpu.flush_rect(x.to_u32(), y.to_u32(), w.to_u32(), h.to_u32())

    # D2 Phase 2 Gpu re-adoption (2026-04-14): glass ops land natively on
    # the VirtIO-GPU DMA framebuffer. `VirtioGpuDriver` owns a guest-visible
    # DMA region at `fb_virt`; `flush` / `flush_rect` emit the cmd-stream
    # TRANSFER_TO_HOST_2D + RESOURCE_FLUSH pair that ships those pixels to
    # the host. We do blend / blur / gradient / read as guest-side pixel
    # work on the DMA buffer BEFORE the next flush, so the result rides the
    # existing cmd-stream path and there is no surface-mismatch hazard from
    # Phase 1. No `rt_gui_*` — every pixel write goes through the same
    # `mmio_write32` on `fb_virt` that `put_pixel` / `fill_rect` use.
    fn as_glass_capable() -> CompositorGlassCapable?:
        self

impl CompositorGlassCapable for GpuCompositorBackend:

    me blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8):
        """Alpha-blend a solid ARGB source over the DMA framebuffer rect.

        Reads each destination pixel straight out of `gpu.fb_virt` via
        `mmio_read32`, runs Porter-Duff source-over with the caller's RGB
        and the explicit `alpha` factor, and writes the result back with
        `mmio_write32`. No flush is issued — `present` / `present_rect`
        still ships the pixels to the host as part of the next frame.
        """
        if w <= 0 or h <= 0:
            return
        val fb_w = self.w
        val fb_h = self.h
        var rx = x
        var ry = y
        var rw = w
        var rh = h
        if rx < 0:
            rw = rw + rx
            rx = 0
        if ry < 0:
            rh = rh + ry
            ry = 0
        if rx + rw > fb_w:
            rw = fb_w - rx
        if ry + rh > fb_h:
            rh = fb_h - ry
        if rw <= 0 or rh <= 0:
            return

        val sr = ((color >> 16) & 0xFF).to_i32()
        val sg = ((color >> 8) & 0xFF).to_i32()
        val sb = (color & 0xFF).to_i32()
        val a = alpha.to_i32()
        val inv_a = 255 - a
        val stride = self.gpu.width.to_u64()
        val base = self.gpu.fb_virt
        var row: i32 = 0
        while row < rh:
            var col: i32 = 0
            while col < rw:
                val px = (rx + col).to_u64()
                val py = (ry + row).to_u64()
                val offset = (py * stride + px) * 4
                val dst = mmio_read32(base + offset)
                val dr = ((dst >> 16) & 0xFF).to_i32()
                val dg = ((dst >> 8) & 0xFF).to_i32()
                val db = (dst & 0xFF).to_i32()
                val mr = (sr * a + dr * inv_a) / 255
                val mg = (sg * a + dg * inv_a) / 255
                val mb = (sb * a + db * inv_a) / 255
                val out = (0xFFu32 << 24)
                    | (mr.to_u32() << 16)
                    | (mg.to_u32() << 8)
                    | mb.to_u32()
                mmio_write32(base + offset, out)
                col = col + 1
            row = row + 1

    me blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32):
        """Native 3x3 box blur passes on the VirtIO-GPU DMA framebuffer.

        TRADEOFF: mirrors the Engine2d Phase 2 strategy — `radius` is
        honoured as a pass count (1 for <2, 2 for <4, else 3), not as a
        kernel width. A full separable Gaussian would need a scratch DMA
        buffer per frame; the box-blur pass is strictly better than the
        Phase 1 opaque-fill fallback and ships pixels through the same
        cmd-stream flush as every other paint on this backend.
        """
        if w <= 0 or h <= 0:
            return
        val fb_w = self.w
        val fb_h = self.h
        var rx = x
        var ry = y
        var rw = w
        var rh = h
        if rx < 0:
            rw = rw + rx
            rx = 0
        if ry < 0:
            rh = rh + ry
            ry = 0
        if rx + rw > fb_w:
            rw = fb_w - rx
        if ry + rh > fb_h:
            rh = fb_h - ry
        if rw <= 0 or rh <= 0:
            return

        var passes: i32 = 1
        if radius >= 2u32:
            passes = 2
        if radius >= 4u32:
            passes = 3

        val stride = self.gpu.width.to_u64()
        val base = self.gpu.fb_virt
        var pass_i: i32 = 0
        while pass_i < passes:
            # Snapshot the region into a local scratch buffer so the blur
            # kernel samples the pre-pass state.
            var src: [u32] = [0u32; rw * rh]
            var row: i32 = 0
            while row < rh:
                var col: i32 = 0
                while col < rw:
                    val sx = (rx + col).to_u64()
                    val sy = (ry + row).to_u64()
                    val off = (sy * stride + sx) * 4
                    src[row * rw + col] = mmio_read32(base + off)
                    col = col + 1
                row = row + 1
            var row2: i32 = 0
            while row2 < rh:
                var col2: i32 = 0
                while col2 < rw:
                    var sumR: i32 = 0
                    var sumG: i32 = 0
                    var sumB: i32 = 0
                    var n: i32 = 0
                    var dy: i32 = -1
                    while dy <= 1:
                        var dx: i32 = -1
                        while dx <= 1:
                            val nx = col2 + dx
                            val ny = row2 + dy
                            if nx >= 0 and nx < rw and ny >= 0 and ny < rh:
                                val p = src[ny * rw + nx]
                                sumR = sumR + ((p >> 16) & 0xFF).to_i32()
                                sumG = sumG + ((p >> 8) & 0xFF).to_i32()
                                sumB = sumB + (p & 0xFF).to_i32()
                                n = n + 1
                            dx = dx + 1
                        dy = dy + 1
                    if n > 0:
                        val avgR = (sumR / n).to_u32() & 0xFF
                        val avgG = (sumG / n).to_u32() & 0xFF
                        val avgB = (sumB / n).to_u32() & 0xFF
                        val out = (0xFFu32 << 24) | (avgR << 16) | (avgG << 8) | avgB
                        val px = (rx + col2).to_u64()
                        val py = (ry + row2).to_u64()
                        mmio_write32(base + (py * stride + px) * 4, out)
                    col2 = col2 + 1
                row2 = row2 + 1
            pass_i = pass_i + 1

    me gradient_v(x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32):
        """Vertical gradient — linear interpolate color1..color2 along Y.

        Issues per-pixel writes directly on the VirtIO-GPU DMA framebuffer.
        An alternative implementation could emit one `fill_rect` command
        per scanline, but the guest-side path is simpler and uses the same
        primitive (`mmio_write32` on `fb_virt`) as every other draw op.
        """
        if w <= 0 or h <= 0:
            return
        val fb_w = self.w
        val fb_h = self.h
        var rx = x
        var ry = y
        var rw = w
        var rh = h
        if rx < 0:
            rw = rw + rx
            rx = 0
        if ry < 0:
            rh = rh + ry
            ry = 0
        if rx + rw > fb_w:
            rw = fb_w - rx
        if ry + rh > fb_h:
            rh = fb_h - ry
        if rw <= 0 or rh <= 0:
            return

        val r1 = ((color1 >> 16) & 0xFF).to_i32()
        val g1 = ((color1 >> 8) & 0xFF).to_i32()
        val b1 = (color1 & 0xFF).to_i32()
        val a1 = ((color1 >> 24) & 0xFF).to_i32()
        val r2 = ((color2 >> 16) & 0xFF).to_i32()
        val g2 = ((color2 >> 8) & 0xFF).to_i32()
        val b2 = (color2 & 0xFF).to_i32()
        val a2 = ((color2 >> 24) & 0xFF).to_i32()
        val stride = self.gpu.width.to_u64()
        val base = self.gpu.fb_virt
        var row: i32 = 0
        val span = if rh > 1: rh - 1 else: 1
        while row < rh:
            val r = r1 + ((r2 - r1) * row) / span
            val g = g1 + ((g2 - g1) * row) / span
            val b = b1 + ((b2 - b1) * row) / span
            val a = a1 + ((a2 - a1) * row) / span
            val line = (a.to_u32() << 24) | (r.to_u32() << 16) | (g.to_u32() << 8) | b.to_u32()
            var col: i32 = 0
            while col < rw:
                val px = (rx + col).to_u64()
                val py = (ry + row).to_u64()
                mmio_write32(base + (py * stride + px) * 4, line)
                col = col + 1
            row = row + 1

    fn read_pixel(x: i32, y: i32) -> u32:
        """Single-pixel read from the VirtIO-GPU DMA framebuffer.

        Direct `mmio_read32` on `fb_virt`; the guest-visible DMA region is
        the live staging buffer for the next cmd-stream flush, so the
        result matches whatever the host will see on the next present.
        """
        if x < 0 or y < 0:
            return 0u32
        if x >= self.w or y >= self.h:
            return 0u32
        val stride = self.gpu.width.to_u64()
        val px = x.to_u64()
        val py = y.to_u64()
        mmio_read32(self.gpu.fb_virt + (py * stride + px) * 4)

impl GpuCompositorBackend:

    static fn new(gpu: VirtioGpuDriver) -> GpuCompositorBackend:
        """Create a GPU compositor backend from an initialized VirtIO-GPU driver."""
        val gw = gpu.width.to_i32()
        val gh = gpu.height.to_i32()
        GpuCompositorBackend(gpu: gpu, w: gw, h: gh)

# ============================================================================
# OS-Tier Backend Selector
# ============================================================================

fn select_backend(caps: PlatformCaps, fb: FramebufferDriver, gpu: VirtioGpuDriver) -> CompositorBackend:
    """Select the compositor backend based on platform capability.

    Routes to the GPU path (Engine2D via compositor_engine2d adapter) when
    caps.has_gpu is true, or falls back to the software framebuffer path.
    """
    if caps.has_gpu:
        # GPU path — delegates to Engine2D via compositor_engine2d adapter
        return make_gpu_compositor_backend(gpu)
    # Software fallback — framebuffer + lib rasterizer
    make_fb_compositor_backend(fb)
