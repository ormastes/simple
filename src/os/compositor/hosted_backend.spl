# Hosted Compositor Backend — winit native pixel buffer rendering
#
# Implements CompositorBackend trait using Rust FFI functions that manage
# a native-side pixel buffer via winit. This allows the SimpleOS window
# manager to render on macOS/Linux/Windows host desktops without a
# bare-metal framebuffer or GPU driver.
#
# The pixel buffer lives in Rust memory (not Simple arrays), so all
# drawing operations are fast FFI calls — critical for interpreter mode
# where array-based pixel manipulation would be too slow.

use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}
use os.compositor.hosted_backend_cocoa.{HostedCocoaBackend}
use os.compositor.hosted_backend_win32.{HostedWin32Backend}
use os.drivers.framebuffer.fb_driver.{get_glyph_8x16}

# ============================================================================
# Platform Routing (Row 3 / Phase C)
# ============================================================================
#
# `select_hosted_backend()` is the single dispatch site that picks
# between the cross-platform winit path (this file's
# `HostedCompositorBackend`), the macOS Cocoa shim
# (`hosted_backend_cocoa.spl::HostedCocoaBackend`), and the Windows
# Win32 shim (`hosted_backend_win32.spl::HostedWin32Backend`).
#
# Selection precedence:
#   1. `SIMPLE_HOSTED_SURFACE` env var: `winit` | `cocoa` | `win32` | `auto`
#   2. Host triple from the runtime (when env is `auto` or unset):
#        - `*-apple-darwin*` -> `cocoa`
#        - `*-pc-windows-*`  -> `win32`
#        - everything else   -> `winit`
#
# Host-triple detection lives in `src/runtime/hosted/select.rs` (called
# from `rt_hosted_select_surface`). Falls through to winit on unknown hosts.

# ============================================================================
# Winit Buffer FFI Declarations
# ============================================================================

extern fn rt_winit_buffer_create(w: i64, h: i64, fill_color: i64) -> i64
extern fn rt_winit_buffer_fill_rect(buf: i64, x: i64, y: i64, w: i64, h: i64, color: i64) -> bool
extern fn rt_winit_buffer_present(win: i64, buf: i64) -> bool
extern fn rt_winit_buffer_free(buf: i64) -> bool
extern fn rt_winit_buffer_read_pixel(buf: i64, x: i64, y: i64) -> i64
extern fn rt_winit_buffer_blend_rect(buf: i64, x: i64, y: i64, w: i64, h: i64, color: i64, alpha: i64) -> bool
extern fn rt_winit_buffer_blur(buf: i64, x: i64, y: i64, w: i64, h: i64, radius: i64) -> bool
extern fn rt_winit_buffer_gradient_v(buf: i64, x: i64, y: i64, w: i64, h: i64, c1: i64, c2: i64) -> bool
extern fn rt_winit_buffer_get_pixels(buf: i64) -> [i64]
extern fn rt_winit_buffer_save_bmp(buf: i64, path: text) -> bool

# Module-level state (interpreter-safe — struct fields can be nil through trait dispatch)
var _hosted_window_id: i64 = 0
var _hosted_buffer_id: i64 = 0
var _hosted_w: i32 = 0
var _hosted_h: i32 = 0

# ============================================================================
# HostedCompositorBackend
# ============================================================================

class HostedCompositorBackend:
    """CompositorBackend that renders through a winit native pixel buffer.

    All drawing is delegated to Rust-side FFI functions that operate on
    an opaque pixel buffer identified by buffer_id. The buffer is presented
    to a winit window identified by window_id.

    Colors are u32 ARGB (0xAARRGGBB), matching the CompositorBackend contract.
    The FFI layer accepts i64 for all numeric arguments.
    """
    window_id: i64
    buffer_id: i64
    w: i32
    h: i32

# ============================================================================
# CompositorBackend Trait Implementation
# ============================================================================

impl CompositorBackend for HostedCompositorBackend:

    fn width() -> i32:
        _hosted_w

    fn height() -> i32:
        _hosted_h

    me clear(color: u32):
        """Fill the entire buffer with a solid color."""
        val w_i: i64 = _hosted_w
        val h_i: i64 = _hosted_h
        val c: i64 = color
        rt_winit_buffer_fill_rect(_hosted_buffer_id, 0, 0, w_i, h_i, c)

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        """Fill a rectangle in the pixel buffer."""
        val xi: i64 = x
        val yi: i64 = y
        val wi: i64 = w
        val hi: i64 = h
        val c: i64 = color
        rt_winit_buffer_fill_rect(_hosted_buffer_id, xi, yi, wi, hi, c)

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        """Draw text using 8x16 bitmap font via native buffer.

        Each character is 8 pixels wide, 16 pixels tall.
        Iterates text as single-char strings and converts to ASCII code.
        """
        var cx = x
        for ch in text_str:
            val code = ch.ord()
            val ch_byte: u8 = code
            self.draw_char_8x16(cx, y, ch_byte, fg, bg)
            cx = cx + 8

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        """Draw a single 8x16 character glyph into the pixel buffer."""
        val glyph = get_glyph_8x16(ch)
        val fg_i: i64 = fg
        val bg_i: i64 = bg
        var row: i64 = 0
        while row < 16:
            val bits: i64 = glyph[row]
            var col: i64 = 0
            while col < 8:
                val mask: i64 = 0x80 >> col
                val color = if (bits & mask) != 0: fg_i else: bg_i
                val px: i64 = x + col
                val py: i64 = y + row
                rt_winit_buffer_fill_rect(_hosted_buffer_id, px, py, 1, 1, color)
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        """Write a single pixel using a 1x1 fill_rect call."""
        val xi: i64 = x
        val yi: i64 = y
        val c: i64 = color
        rt_winit_buffer_fill_rect(_hosted_buffer_id, xi, yi, 1, 1, c)

    me present():
        """Present the pixel buffer to the winit window (full frame)."""
        rt_winit_buffer_present(_hosted_window_id, _hosted_buffer_id)

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        """Present a rectangular region."""
        rt_winit_buffer_present(_hosted_window_id, _hosted_buffer_id)

    fn as_glass_capable() -> CompositorGlassCapable?:
        # Hosted backend opts IN: the winit buffer IS the active surface and
        # rt_winit_buffer_* primitives are per-surface safe. See D2 Phase 1.
        self

# ============================================================================
# CompositorGlassCapable Trait Implementation (D2 Phase 1 — opt-in)
# ============================================================================

impl CompositorGlassCapable for HostedCompositorBackend:

    me blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8):
        """Alpha-blend a rectangle over existing content."""
        val xi: i64 = x
        val yi: i64 = y
        val wi: i64 = w
        val hi: i64 = h
        val c: i64 = color
        val a: i64 = alpha
        rt_winit_buffer_blend_rect(_hosted_buffer_id, xi, yi, wi, hi, c, a)

    me blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32):
        """Apply box blur to a rectangular region."""
        val xi: i64 = x
        val yi: i64 = y
        val wi: i64 = w
        val hi: i64 = h
        val ri: i64 = radius
        rt_winit_buffer_blur(_hosted_buffer_id, xi, yi, wi, hi, ri)

    me gradient_v(x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32):
        """Fill a rectangle with a vertical gradient."""
        val xi: i64 = x
        val yi: i64 = y
        val wi: i64 = w
        val hi: i64 = h
        val c1: i64 = color1
        val c2: i64 = color2
        rt_winit_buffer_gradient_v(_hosted_buffer_id, xi, yi, wi, hi, c1, c2)

    fn read_pixel(x: i32, y: i32) -> u32:
        """Read a single pixel from the buffer."""
        val xi: i64 = x
        val yi: i64 = y
        val result = rt_winit_buffer_read_pixel(_hosted_buffer_id, xi, yi)
        result.to_u32()

# ============================================================================
# Static Constructor
# ============================================================================

impl HostedCompositorBackend:

    static fn new(window_id: i64, buffer_id: i64, w: i32, h: i32) -> HostedCompositorBackend:
        """Create a hosted compositor backend from existing winit handles.

        Args:
            window_id: Opaque handle from rt_winit_window_new
            buffer_id: Opaque handle from rt_winit_buffer_create
            w: Buffer width in pixels
            h: Buffer height in pixels
        """
        HostedCompositorBackend(window_id: window_id, buffer_id: buffer_id, w: w, h: h)

    static fn create(window_id: i64, w: i32, h: i32, fill_color: u32) -> HostedCompositorBackend:
        """Create a hosted compositor backend, allocating a new pixel buffer."""
        val w64: i64 = w
        val h64: i64 = h
        val fc64: i64 = fill_color
        val buf = rt_winit_buffer_create(w64, h64, fc64)
        # Store in module-level vars (interpreter trait dispatch loses struct fields)
        _hosted_window_id = window_id
        _hosted_buffer_id = buf
        _hosted_w = w
        _hosted_h = h
        HostedCompositorBackend(window_id: window_id, buffer_id: buf, w: w, h: h)

    me free():
        """Release the native pixel buffer.

        Should be called when the backend is no longer needed to avoid
        leaking the Rust-side buffer allocation.
        """
        rt_winit_buffer_free(self.buffer_id)

    fn get_pixels() -> [i64]:
        """Get all pixels from the buffer for comparison."""
        rt_winit_buffer_get_pixels(_hosted_buffer_id)

    fn save_bmp(path: text) -> bool:
        """Save the current pixel buffer to disk as a BMP file.

        Wraps rt_winit_buffer_save_bmp using the module-level buffer id so the
        backend remains the sole site that touches the raw winit FFI.
        """
        rt_winit_buffer_save_bmp(_hosted_buffer_id, path)

# ============================================================================
# Platform-routed hosted backend constructor (Row 3 / Phase C)
# ============================================================================

extern fn rt_hosted_select_surface() -> i64
extern fn rt_hosted_set_surface_override(sel: i64)

fn select_hosted_backend(window_id: i64, w: i32, h: i32, fill_color: u32) -> CompositorBackend:
    """Return the right `CompositorBackend` for this host.

    Reads the runtime's `rt_hosted_select_surface()` selector:
      0 = winit (default / fallback / Linux / BSD / unknown)
      1 = cocoa (macOS — see `hosted_backend_cocoa.spl`)
      2 = win32 (Windows — see `hosted_backend_win32.spl`)

    The runtime is responsible for honouring `SIMPLE_HOSTED_SURFACE` and
    falling back to the winit path on probe failure. See the comment at
    the top of this file for the full precedence rules.
    """
    val sel = rt_hosted_select_surface()
    if sel == 1:
        return HostedCocoaBackend.create(window_id, w, h, fill_color)
    if sel == 2:
        return HostedWin32Backend.create(window_id, w, h, fill_color)
    HostedCompositorBackend.create(window_id, w, h, fill_color)
