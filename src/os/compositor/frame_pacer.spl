# frame_pacer.spl — frame budget management and budget-paced present
#
# FramePacer tracks when each frame started and whether the frame
# budget has elapsed, preventing busy-wait present loops.
#
# Honesty note: this is a monotonic-clock budget sleep, NOT a real
# vsync/vblank-aligned present — there is no IRQ or hardware scanout
# signal involved, so a present can still land mid-refresh on real
# hardware. Upgrading to true vsync alignment requires wiring a vblank
# IRQ (or virtio-gpu/GPU vendor scanout-complete signal) into
# mark_frame_start()/should_present() in place of the monotonic clock
# read; that hardware hookup is out of scope here.
#
# ponytail: checked virtio_gpu_ops.spl/virtio_gpu.spl — this driver only
# implements the synchronous controlq (GET_DISPLAY_INFO/RESOURCE_CREATE_2D/
# SET_SCANOUT/TRANSFER_TO_HOST_2D/RESOURCE_FLUSH all block on the ctrl
# virtqueue's used-ring index via rt_wait_u16_change); no cursorq/eventq and
# no VIRTIO_GPU_FLAG_FENCE fence_id is ever set. So there is no scanout-flip
# / vblank completion signal exposed at this tier to hook here — do not
# fake one. The upgrade path is real vblank IRQ wiring (bare-metal) or a
# fenced RESOURCE_FLUSH + VIRTIO_GPU_CMD_GET_EDID/cursorq addition
# (virtio-gpu), whichever lands first; keep the monotonic-clock budget as
# the fallback bound either way.
#
# Usage pattern:
#   pacer.mark_frame_start()
#   ... do work ...
#   if pacer.should_present():
#       compositor.present(dirty.bounding_box())
#       dirty.clear()
#       pacer.mark_frame_end()
#   else:
#       pacer.sleep_remaining()

extern fn rt_time_now_monotonic_ms() -> i64
extern fn rt_sleep_ms(ms: i64)

val FRAME_BUDGET_60HZ_MS: i64 = 16   # 16.666... ms → floor to 16
val FRAME_BUDGET_30HZ_MS: i64 = 33
val FRAME_BUDGET_24HZ_MS: i64 = 41

struct FramePacerContract:
    """Snapshot of FramePacer's pacing state (same fields report_contract prints).

    Returned as data so callers/specs can assert on values directly instead
    of scraping stdout. `warm_startup_ms` is only meaningful when
    `warm_startup_available` is true (mirrors the prior "unavailable" print
    for the zero-frames case).
    """
    target_fps: i32
    frame_budget_ms: i64
    frame_count: i64
    warm_startup_ms: i64
    warm_startup_available: bool

class FramePacer:
    target_fps: i32
    frame_budget_ms: i64
    frame_start_ms: i64
    frame_end_ms: i64
    frame_count: i64
    last_present_ms: i64
    # minimum sleep granularity — avoid sleeping < 1 ms
    min_sleep_ms: i64

    static fn for_fps(fps: i32) -> FramePacer:
        val budget: i64 = if fps <= 0:
            FRAME_BUDGET_60HZ_MS
        else:
            1000 / fps.to_i64()
        FramePacer(
            target_fps: fps,
            frame_budget_ms: budget,
            frame_start_ms: 0,
            frame_end_ms: 0,
            frame_count: 0,
            last_present_ms: 0,
            min_sleep_ms: 1
        )

    static fn for_60hz() -> FramePacer:
        FramePacer.for_fps(60)

    static fn for_30hz() -> FramePacer:
        FramePacer.for_fps(30)

    # Call at the very beginning of each iteration of the main loop.
    me mark_frame_start():
        self.frame_start_ms = rt_time_now_monotonic_ms()

    # Call after the present is done.
    me mark_frame_end():
        self.frame_end_ms = rt_time_now_monotonic_ms()
        self.last_present_ms = self.frame_end_ms
        self.frame_count = self.frame_count + 1

    # Returns true when the frame budget has elapsed since frame_start.
    # Use this to gate presents: only present when the budget is met.
    me should_present() -> bool:
        val now = rt_time_now_monotonic_ms()
        val elapsed = now - self.frame_start_ms
        elapsed >= self.frame_budget_ms

    # How many ms remain until the frame budget expires.
    # Returns 0 if the budget has already been consumed.
    me remaining_budget_ms() -> i64:
        val now = rt_time_now_monotonic_ms()
        val elapsed = now - self.frame_start_ms
        val remaining = self.frame_budget_ms - elapsed
        if remaining < 0: 0 else: remaining

    # Elapsed ms since mark_frame_start.
    me elapsed_ms() -> i64:
        rt_time_now_monotonic_ms() - self.frame_start_ms

    # Sleep for the remaining budget (avoids busy-wait).
    # Clamps to min_sleep_ms to avoid sub-millisecond spins.
    me sleep_remaining():
        val rem = self.remaining_budget_ms()
        if rem >= self.min_sleep_ms:
            rt_sleep_ms(rem)

    # Total frames presented since creation.
    me total_frames() -> i64:
        self.frame_count

    # Actual FPS over the last frame (instantaneous).
    # Returns 0 if no frames have been presented yet.
    me instant_fps() -> i64:
        val dur = self.frame_end_ms - self.frame_start_ms
        if dur <= 0: 0 else: 1000 / dur

    me warm_startup_ms() -> i64:
        if self.frame_count == 0: return 0
        self.frame_end_ms - self.frame_start_ms

    # Build the pacing snapshot as data (no I/O) — see report_contract() below
    # for the print wrapper consumed by gate scripts/specs.
    me contract() -> FramePacerContract:
        FramePacerContract(
            target_fps: self.target_fps,
            frame_budget_ms: self.frame_budget_ms,
            frame_count: self.frame_count,
            warm_startup_ms: if self.frame_count > 0: self.warm_startup_ms() else: 0,
            warm_startup_available: self.frame_count > 0
        )

    # Thin print wrapper: keeps the exact prior stdout line format for any
    # existing gate/log scrapers while `contract()` is now the source of truth.
    me report_contract():
        val c = self.contract()
        print("frame_pacer_target_fps={c.target_fps}")
        print("frame_pacer_frame_budget_ms={c.frame_budget_ms}")
        print("frame_pacer_frame_count={c.frame_count}")
        if c.warm_startup_available:
            print("frame_pacer_warm_startup_ms={c.warm_startup_ms}")
        else:
            print("frame_pacer_warm_startup_ms=unavailable")
