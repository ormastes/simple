use os.compositor.display_backend_core.{CompositorBackend, CompositorGlassCapable}
use nogc_sync_mut.ui.gui_renderer.{GuiRenderer}
use common.ui.glyph_bitmap_5x7.{glyph_index_for_char_code, glyph_row_bits}

class HostedGuiRendererBackend:
    renderer: GuiRenderer
    w: i32
    h: i32
    pixels: [u32]
    present_count: i64

    static fn new(renderer: GuiRenderer, w: i32, h: i32, pixels: [u32]) -> HostedGuiRendererBackend:
        HostedGuiRendererBackend(renderer: renderer, w: w, h: h, pixels: pixels, present_count: 0)

    static fn create(renderer: GuiRenderer, w: i32, h: i32, clear_color: u32) -> HostedGuiRendererBackend?:
        if not renderer.is_open() or w <= 0 or h <= 0:
            return nil
        val pixels: [u32] = []
        renderer.stage_clear(w.to_i64(), h.to_i64(), clear_color)
        HostedGuiRendererBackend.new(renderer, w, h, pixels)

    static fn implementation_name() -> text:
        "gui-renderer-framebuffer"

    me free():
        self.pixels = []

impl CompositorBackend for HostedGuiRendererBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        self.renderer.stage_clear(self.w.to_i64(), self.h.to_i64(), color)

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        self.renderer.stage_fill_rect(x.to_i64(), y.to_i64(), w.to_i64(), h.to_i64(), color)

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        var cx = x
        var i = 0
        val n = text_str.len()
        while i < n:
            self.draw_char_8x16(cx, y, text_str.char_at(i).ord().to_u8(), fg, bg)
            cx = cx + 12
            i = i + 1

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        self.fill_rect(x, y, 12, 16, bg)
        val gi = glyph_index_for_char_code(ch.to_i32())
        var row: i32 = 0
        while row < 7:
            val bits = glyph_row_bits(gi, row)
            var col: i32 = 0
            while col < 5:
                val mask = 1 << (4 - col)
                if (bits & mask) != 0:
                    self.fill_rect(x + col * 2, y + row * 2 + 1, 2, 2, fg)
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        self.fill_rect(x, y, 1, 1, color)

    me blit_pixels(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        self.renderer.stage_blit_argb_u32(x.to_i64(), y.to_i64(), w.to_i64(), h.to_i64(), self.w.to_i64(), self.h.to_i64(), pixels)

    me present():
        if self.renderer.present_staged(self.w.to_i64(), self.h.to_i64()):
            self.present_count = self.present_count + 1

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        self.present()

    fn as_glass_capable() -> CompositorGlassCapable?:
        nil
