# Bounded Simple Web panel renderer for freestanding QEMU WM lanes.
#
# The hosted compositor uses simple_web_window_renderer, which depends on the
# normal web-render artifact stack. The x86_64 baremetal QEMU entry cannot pull
# that stack into an entry-closure build, so this module owns the equivalent
# deterministic Simple Web panel contract used by that lane.

pub fn qemu_simple_web_demo_html() -> text:
    "<html><body style='margin:0; background-color:#101820; color:#f3f4f6;'><div style='height:30px; background-color:#2050a0; color:#ffffff;'>about:engine2d-wm</div><div style='height:86px; background-color:#182230; color:#44ff44;'>Simple Web Renderer</div><div style='height:86px; background-color:#1f2937; color:#e0e0f0;'>HTML -> layout -> paint -> pixels -> Engine2D</div></body></html>"

pub fn qemu_simple_web_panel_pixel_count(width: i32, height: i32) -> i64:
    if width <= 0 or height <= 0:
        return 0
    (width * height).to_i64()

pub fn qemu_simple_web_panel_color_at(local_x: i32, local_y: i32) -> u32:
    if local_x >= 6 and local_x < 30 and local_y >= 6 and local_y < 9:
        return 0xFFFFFFFFu32
    if local_y < 30:
        return 0xFF2050A0u32
    if local_y < 116:
        return 0xFF182230u32
    if local_y < 202:
        return 0xFF1F2937u32
    0xFF101820u32

pub fn qemu_simple_web_panel_checksum(width: i32, height: i32) -> i64:
    if width <= 0 or height <= 0:
        return 0
    var checksum: i64 = 0
    var y: i32 = 0
    while y < height:
        var x: i32 = 0
        while x < width:
            val color = qemu_simple_web_panel_color_at(x, y)
            checksum = checksum + ((color & 0x00FFFFFFu32) as i64) + ((x + 1) * (y + 1)).to_i64()
            x = x + 1
        y = y + 1
    checksum
