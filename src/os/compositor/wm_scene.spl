    if has_control_center:
        min_touch_target_height_px = _scene_touch_target_height_px(html)
    val translucent_surfaces = html.contains("backdrop-filter:blur") and html.contains("rgba(") and html.contains("linear-gradient")
    val has_all_motion_affordances = has_command_palette and has_control_center and has_desktop_widgets and has_window_overview and has_snap_preview and has_notification_toast and has_notification_center and has_live_activity and has_workspace_switcher and has_shortcut_overlay and has_app_launcher and has_context_menu and has_snap_layouts and has_window_switcher and has_quick_settings and hot_corner_count == 4 and has_resize_hud and has_gesture_hints and has_taskbar_preview and has_stage_rail and has_screen_capture and has_clipboard_history and has_privacy_indicator and has_system_hud
    val motion_can_disable = has_all_motion_affordances and html.contains("data-motion-can-disable='true'") and html.contains("body[data-motion-mode='off']") and html.contains("animation:none!important")
    val reduced_motion_duration_ms = if has_all_motion_affordances and html.contains("data-reduced-motion-duration-ms='80'") and html.contains("animation-duration:80ms"): 80 else: 0
    val passed = theme_configured and round_scrollbars and round_icon_converter and titlebar_input_ready and traffic_controls_ready and animated_background_ready and window_interaction_ready and command_palette_ready and theme_accent_controls_ready and focus_depth_ready and lifecycle_animation_ready and taskbar_interaction_ready and dock_magnification_ready and notification_feedback_ready and notification_center_ready and live_activity_ready and workspace_switcher_ready and keyboard_shortcut_overlay_ready and app_launcher_ready and context_menu_ready and snap_layouts_ready and window_switcher_ready and quick_settings_ready and hot_corners_ready and resize_hud_ready and gesture_hints_ready and taskbar_preview_ready and stage_rail_ready and screen_capture_ready and clipboard_history_ready and privacy_indicator_ready and system_hud_ready and color_checked and bounded_layout and translucent_surfaces and rounded_surface_count >= 15 and max_command_palette_width_px <= 680 and max_control_center_width_px <= 320 and max_desktop_widget_width_px <= 260 and max_notification_width_px <= 360 and max_notification_center_width_px <= 340 and max_live_activity_width_px <= 420 and max_workspace_switcher_width_px <= 360 and max_shortcut_overlay_width_px <= 420 and max_app_launcher_width_px <= 520 and max_context_menu_width_px <= 280 and max_snap_layouts_width_px <= 360 and max_window_switcher_width_px <= 460 and max_quick_settings_width_px <= 300 and max_hot_corner_size_px <= 44 and max_resize_hud_width_px <= 240 and max_gesture_hint_width_px <= 360 and max_taskbar_preview_width_px <= 320 and max_stage_rail_width_px <= 88 and max_screen_capture_width_px <= 560 and max_clipboard_history_width_px <= 360 and max_privacy_indicator_width_px <= 300 and max_system_hud_width_px <= 280 and min_overview_card_width_px >= 180 and min_touch_target_height_px >= 44 and motion_can_disable and reduced_motion_duration_ms == 80
    WmSceneVisualQualityReport(
