    ".screen-capture-overlay{{position:absolute;display:grid;grid-template-rows:1fr auto;gap:12px;max-width:560px;border-radius:24px;background:linear-gradient(180deg,rgba(2,6,23,.54),rgba(15,23,42,.34));border:1px solid rgba(255,255,255,.18);box-shadow:0 30px 90px rgba(0,0,0,.38);backdrop-filter:blur(18px) saturate(160%);padding:14px;box-sizing:border-box;color:white;animation:wm-capture-in 170ms cubic-bezier(.2,.8,.2,1) both}}.capture-selection{{position:relative;border:2px dashed rgba(96,165,250,.86);border-radius:18px;background:rgba(96,165,250,.10);box-shadow:inset 0 0 0 1px rgba(255,255,255,.14),0 0 0 999px rgba(2,6,23,.34);min-height:132px}}.capture-handle{{position:absolute;width:14px;height:14px;border-radius:999px;background:#bfdbfe;border:2px solid rgba(15,23,42,.92);box-shadow:0 4px 12px rgba(0,0,0,.36)}}.capture-handle.nw{{left:-8px;top:-8px}}.capture-handle.ne{{right:-8px;top:-8px}}.capture-handle.sw{{left:-8px;bottom:-8px}}.capture-handle.se{{right:-8px;bottom:-8px}}.capture-dimensions{{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);border-radius:999px;background:rgba(15,23,42,.84);border:1px solid rgba(255,255,255,.16);padding:6px 10px;font:800 12px system-ui;color:#dbeafe;white-space:nowrap}}.capture-toolbar{{min-height:44px;display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:8px;align-items:center;border-radius:18px;background:rgba(2,6,23,.76);border:1px solid rgba(255,255,255,.14);padding:8px;box-sizing:border-box}}.capture-mode,.capture-action{{min-height:34px;border-radius:999px;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.07);color:white;font:800 11px system-ui;padding:0 12px;white-space:nowrap}}.capture-mode.active{{background:rgba(37,99,235,.62);box-shadow:0 0 0 2px rgba(96,165,250,.26)}}.capture-action{{background:#dbeafe;color:#0f172a}}.capture-mode:focus-visible,.capture-action:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:2px}}" +
    ".clipboard-history{{position:absolute;display:grid;grid-template-rows:auto 1fr auto;gap:10px;max-width:360px;border-radius:22px;background:linear-gradient(180deg,rgba(2,6,23,.92),rgba(15,23,42,.72));border:1px solid rgba(255,255,255,.16);box-shadow:0 26px 78px rgba(0,0,0,.42);backdrop-filter:blur(26px) saturate(170%);padding:12px;box-sizing:border-box;color:white;animation:wm-clipboard-in 160ms cubic-bezier(.2,.8,.2,1) both}}.clipboard-history-header{{display:flex;align-items:center;justify-content:space-between;gap:10px;font:800 13px system-ui}}.clipboard-clear,.clipboard-pin{{min-height:34px;border-radius:999px;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.08);color:white;font:800 11px system-ui;padding:0 12px;white-space:nowrap}}.clipboard-list{{display:grid;gap:8px;min-height:0;overflow:hidden}}.clipboard-item{{min-height:44px;border-radius:14px;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.07);color:white;display:grid;grid-template-columns:30px minmax(0,1fr) auto;align-items:center;gap:8px;padding:7px 8px;text-align:left;font:700 11px system-ui}}.clipboard-item span{{overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}.clipboard-item.active{{background:rgba(37,99,235,.46);box-shadow:0 0 0 2px rgba(96,165,250,.28)}}.clipboard-item.pinned{{border-color:rgba(20,184,166,.48)}}.clipboard-item kbd{{border-radius:7px;background:rgba(255,255,255,.10);padding:2px 6px;color:#cbd5e1;font:800 10px system-ui;white-space:nowrap}}.clipboard-item-icon{{width:28px;height:28px;font-size:10px}}.clipboard-clear:focus-visible,.clipboard-pin:focus-visible,.clipboard-item:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:2px}}" +
    ".privacy-indicator{{position:absolute;display:grid;grid-template-rows:auto 1fr auto;gap:8px;max-width:300px;border-radius:22px;background:linear-gradient(180deg,rgba(2,6,23,.92),rgba(15,23,42,.72));border:1px solid rgba(255,255,255,.16);box-shadow:0 24px 72px rgba(0,0,0,.40);backdrop-filter:blur(26px) saturate(170%);padding:12px;box-sizing:border-box;color:white;animation:wm-privacy-in 150ms cubic-bezier(.2,.8,.2,1) both}}.privacy-header{{display:flex;align-items:center;gap:8px;font:800 12px system-ui}}.privacy-dot{{width:10px;height:10px;border-radius:999px;background:#22c55e;box-shadow:0 0 0 4px rgba(34,197,94,.16);animation:wm-privacy-pulse 1400ms ease-in-out infinite}}.privacy-list{{display:grid;gap:5px}}.privacy-list span{{min-height:26px;border-radius:999px;background:rgba(255,255,255,.07);display:flex;align-items:center;gap:8px;padding:4px 8px;font:700 11px system-ui}}.privacy-icon{{width:22px;height:22px;font-size:9px}}.privacy-actions{{display:grid;grid-template-columns:1fr 1fr;gap:8px}}.privacy-action{{min-height:34px;border-radius:999px;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.08);color:white;font:800 11px system-ui}}.privacy-action.danger{{background:rgba(225,29,72,.46)}}.privacy-action:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:2px}}" +
    ".system-hud{{position:absolute;display:grid;grid-template-columns:42px 1fr;grid-template-rows:auto auto auto;gap:8px 10px;max-width:280px;border-radius:24px;background:linear-gradient(180deg,rgba(2,6,23,.90),rgba(15,23,42,.70));border:1px solid rgba(255,255,255,.16);box-shadow:0 26px 78px rgba(0,0,0,.40);backdrop-filter:blur(26px) saturate(170%);padding:14px;box-sizing:border-box;color:white;animation:wm-system-hud-in 130ms cubic-bezier(.2,.8,.2,1) both}}.system-hud-icon{{grid-row:1 / 3;width:42px;height:42px;font-size:12px}}.system-hud-copy{{display:flex;align-items:center;justify-content:space-between;gap:10px;font:800 12px system-ui}}.system-hud-copy span{{color:#dbeafe}}.system-hud-meter{{grid-column:2;height:8px;border-radius:999px;background:rgba(255,255,255,.12);overflow:hidden}}.system-hud-meter span{{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,#60a5fa,#14b8a6)}}.system-hud-actions{{grid-column:1 / -1;display:grid;grid-template-columns:1fr 1fr;gap:8px}}.system-hud-action{{min-height:34px;border-radius:999px;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.08);color:white;font:800 11px system-ui}}.system-hud-action.active{{background:rgba(37,99,235,.46)}}.system-hud-action:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:2px}}" +
    "@keyframes wm-bg-drift{{from{{transform:translate3d(-1.5%,-1%,0) scale(1)}}to{{transform:translate3d(1.5%,1%,0) scale(1.03)}}}}@keyframes wm-window-open{{from{{opacity:0;transform:translateY(10px) scale(.96)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-window-restore{{from{{opacity:.72;transform:translateY(28px) scale(.92)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-window-close{{from{{opacity:1;transform:translateY(0) scale(1)}}to{{opacity:0;transform:translateY(8px) scale(.94)}}}}@keyframes wm-window-minimize{{from{{opacity:1;transform:translateY(0) scale(1)}}to{{opacity:.24;transform:translateY(54px) scale(.72)}}}}@keyframes wm-command-in{{from{{opacity:0;transform:translateY(-8px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-widget-float{{from{{opacity:0;transform:translateY(10px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-control-in{{from{{opacity:0;transform:translateY(-8px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-overview-in{{from{{opacity:0;transform:scale(.98)}}to{{opacity:1;transform:scale(1)}}}}@keyframes wm-snap-pulse{{0%,100%{{opacity:.76}}50%{{opacity:1}}}}@keyframes wm-snap-layouts-in{{from{{opacity:0;transform:translateY(6px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-switcher-in{{from{{opacity:0;transform:translateY(8px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-quick-settings-in{{from{{opacity:0;transform:translateY(-6px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-notification-center-in{{from{{opacity:0;transform:translateX(14px) scale(.98)}}to{{opacity:1;transform:translateX(0) scale(1)}}}}@keyframes wm-live-activity-in{{from{{opacity:0;transform:translateY(-6px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-live-activity-progress{{0%,100%{{filter:brightness(1)}}50%{{filter:brightness(1.25)}}}}@keyframes wm-taskbar-indicator{{0%,100%{{opacity:.72;transform:translateX(-50%) scaleX(.82)}}50%{{opacity:1;transform:translateX(-50%) scaleX(1)}}}}@keyframes wm-toast-in{{from{{opacity:0;transform:translateX(18px) scale(.98)}}to{{opacity:1;transform:translateX(0) scale(1)}}}}@keyframes wm-toast-out{{from{{opacity:1;transform:translateX(0) scale(1)}}to{{opacity:0;transform:translateX(18px) scale(.98)}}}}@keyframes wm-toast-progress{{from{{transform:scaleX(1)}}to{{transform:scaleX(0)}}}}@keyframes wm-workspace-in{{from{{opacity:0;transform:translateY(10px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-workspace-slide{{from{{transform:translateX(8px) scaleX(.92)}}to{{transform:translateX(0) scaleX(1)}}}}@keyframes wm-shortcut-in{{from{{opacity:0;transform:translateY(8px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-launcher-in{{from{{opacity:0;transform:translateY(12px) scale(.97)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-menu-in{{from{{opacity:0;transform:translateY(4px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-hot-corner-pulse{{0%,100%{{opacity:.44;transform:scale(.72)}}50%{{opacity:1;transform:scale(1)}}}}@keyframes wm-resize-hud-in{{from{{opacity:0;transform:translateY(6px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-gesture-hints-in{{from{{opacity:0;transform:translateX(10px) scale(.98)}}to{{opacity:1;transform:translateX(0) scale(1)}}}}@keyframes wm-taskbar-preview-in{{from{{opacity:0;transform:translateY(8px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-stage-rail-in{{from{{opacity:0;transform:translateX(-10px) scale(.98)}}to{{opacity:1;transform:translateX(0) scale(1)}}}}@keyframes wm-capture-in{{from{{opacity:0;transform:translateY(8px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-clipboard-in{{from{{opacity:0;transform:translateY(8px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-privacy-in{{from{{opacity:0;transform:translateY(-6px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-privacy-pulse{{0%,100%{{opacity:.72;transform:scale(.86)}}50%{{opacity:1;transform:scale(1)}}}}@keyframes wm-system-hud-in{{from{{opacity:0;transform:translateY(8px) scale(.96)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}" +
    "@media (prefers-reduced-motion: reduce){{.desktop::before,.motion-window,.command-palette,.desktop-widgets,.control-center,.window-overview,.snap-preview,.snap-layouts,.window-switcher,.quick-settings,.notification-center,.live-activity,.live-activity-progress span,.taskbar-running-indicator,.notification-toast,.toast-progress,.workspace-switcher,.workspace-active-pill,.shortcut-overlay,.app-launcher,.context-menu,.hot-corner-ring,.resize-hud,.gesture-hints,.taskbar-preview,.stage-rail,.screen-capture-overlay,.clipboard-history,.privacy-indicator,.privacy-dot,.system-hud{{animation-duration:80ms;animation-iteration-count:1}}}}" +
    "body[data-motion-mode='reduced'] .desktop::before,body[data-motion-mode='reduced'] .motion-window,body[data-motion-mode='reduced'] .command-palette,body[data-motion-mode='reduced'] .desktop-widgets,body[data-motion-mode='reduced'] .control-center,body[data-motion-mode='reduced'] .window-overview,body[data-motion-mode='reduced'] .snap-preview,body[data-motion-mode='reduced'] .snap-layouts,body[data-motion-mode='reduced'] .window-switcher,body[data-motion-mode='reduced'] .quick-settings,body[data-motion-mode='reduced'] .notification-center,body[data-motion-mode='reduced'] .live-activity,body[data-motion-mode='reduced'] .live-activity-progress span,body[data-motion-mode='reduced'] .taskbar-running-indicator,body[data-motion-mode='reduced'] .notification-toast,body[data-motion-mode='reduced'] .toast-progress,body[data-motion-mode='reduced'] .workspace-switcher,body[data-motion-mode='reduced'] .workspace-active-pill,body[data-motion-mode='reduced'] .shortcut-overlay,body[data-motion-mode='reduced'] .app-launcher,body[data-motion-mode='reduced'] .context-menu,body[data-motion-mode='reduced'] .hot-corner-ring,body[data-motion-mode='reduced'] .resize-hud,body[data-motion-mode='reduced'] .gesture-hints,body[data-motion-mode='reduced'] .taskbar-preview,body[data-motion-mode='reduced'] .stage-rail,body[data-motion-mode='reduced'] .screen-capture-overlay,body[data-motion-mode='reduced'] .clipboard-history,body[data-motion-mode='reduced'] .privacy-indicator,body[data-motion-mode='reduced'] .privacy-dot,body[data-motion-mode='reduced'] .system-hud{{animation-duration:80ms;animation-iteration-count:1}}body[data-motion-mode='off'] .desktop::before,body[data-motion-mode='off'] .motion-window,body[data-motion-mode='off'] .command-palette,body[data-motion-mode='off'] .desktop-widgets,body[data-motion-mode='off'] .control-center,body[data-motion-mode='off'] .window-overview,body[data-motion-mode='off'] .snap-preview,body[data-motion-mode='off'] .snap-layouts,body[data-motion-mode='off'] .window-switcher,body[data-motion-mode='off'] .quick-settings,body[data-motion-mode='off'] .notification-center,body[data-motion-mode='off'] .live-activity,body[data-motion-mode='off'] .live-activity-progress span,body[data-motion-mode='off'] .taskbar-running-indicator,body[data-motion-mode='off'] .notification-toast,body[data-motion-mode='off'] .toast-progress,body[data-motion-mode='off'] .workspace-switcher,body[data-motion-mode='off'] .workspace-active-pill,body[data-motion-mode='off'] .shortcut-overlay,body[data-motion-mode='off'] .app-launcher,body[data-motion-mode='off'] .context-menu,body[data-motion-mode='off'] .hot-corner-ring,body[data-motion-mode='off'] .resize-hud,body[data-motion-mode='off'] .gesture-hints,body[data-motion-mode='off'] .taskbar-preview,body[data-motion-mode='off'] .stage-rail,body[data-motion-mode='off'] .screen-capture-overlay,body[data-motion-mode='off'] .clipboard-history,body[data-motion-mode='off'] .privacy-indicator,body[data-motion-mode='off'] .privacy-dot,body[data-motion-mode='off'] .system-hud{{animation:none!important;transition:none!important}}" +
    "</style></head><body data-modern-wm='true' data-theme-configured='true' data-window-radius-px='{config.window_radius_px}' data-widget-radius-px='{config.widget_radius_px}' data-taskbar-radius-px='{config.taskbar_radius_px}' data-control-radius-px='{config.control_radius_px}' data-icon-radius-px='{config.icon_radius_px}' data-scrollbar-width-px='{config.scrollbar_width_px}' data-scrollbar-thumb-radius-px='{config.scrollbar_thumb_radius_px}' data-scrollbar-thumb-border-px='{config.scrollbar_thumb_border_px}' data-blur-px='{config.blur_px}' data-titlebar-height-px='{config.titlebar_height_px}' data-command-lane-height-px='{config.command_lane_height_px}' data-taskbar-height-px='{config.taskbar_height_px}' data-desktop-layer-z='{config.desktop_layer_z}' data-snap-layer-z='{config.snap_layer_z}' data-window-layer-z='{config.window_layer_z}' data-overlay-layer-z='{config.overlay_layer_z}' data-standard-motion-ms='{config.standard_motion_ms}' data-reduced-motion-ms='{config.reduced_motion_ms}' data-motion-mode='standard' data-motion-can-disable='{config.can_disable_motion}' data-width='" + w + "' data-height='" + h + "'>" +
    body + "</body></html>"

class _SceneMotionData:
    title: text
    phase: text
    class_name: text
    duration_ms: text
    reduced_duration_ms: text
    can_disable: text

class _SceneIconData:
    id: text
    source: text
    kind: text

class _SceneToastData:
    title: text
    message: text
    action: text

fn _scene_icon_data(blob: text) -> _SceneIconData:
    val parts = blob.split("|")
    var id = blob
    var source = blob
    if parts.len() > 0:
        id = parts[0]
    if parts.len() > 1:
        source = parts[1]
    _SceneIconData(id: id, source: source, kind: wm_scene_icon_kind(source))

fn _scene_toast_data(blob: text) -> _SceneToastData:
    val parts = blob.split("|")
    var title = blob
    var message = ""
    var action = "Dismiss"
    if parts.len() > 0:
        title = parts[0]
    if parts.len() > 1:
        message = parts[1]
    if parts.len() > 2:
        action = parts[2]
    _SceneToastData(title: title, message: message, action: action)

fn _scene_round_icon_html(class_name: text, source: text) -> text:
    val kind = wm_scene_icon_kind(source)
    val glyph = if source.len() > 0: source.substring(0, 1) else: "S"
    if kind == "square-to-round":
        return "<span class='round-icon {class_name} icon-normalized-square' data-icon-normalized='square-to-round' data-icon-source='{source}'><span class='icon-image-placeholder'></span></span>"
    "<span class='round-icon {class_name} icon-glyph-to-round' data-icon-normalized='glyph-to-round' data-icon-source='{source}'><span class='icon-glyph'>{glyph}</span></span>"

fn _scene_motion_data(blob: text) -> _SceneMotionData:
    val parts = blob.split("|")
    var title = ""
    var phase = "idle"
    var class_name = "wm-window-idle"
    var duration_ms = "0"
    var reduced_duration_ms = "0"
    var can_disable = "true"
    if parts.len() > 0:
        title = parts[0]
    if parts.len() > 1:
        phase = parts[1]
    if parts.len() > 2:
        class_name = parts[2]
    if parts.len() > 3:
        duration_ms = parts[3]
    if parts.len() > 4:
        reduced_duration_ms = parts[4]
    if parts.len() > 5:
        can_disable = parts[5]
    _SceneMotionData(title: title, phase: phase, class_name: class_name, duration_ms: duration_ms, reduced_duration_ms: reduced_duration_ms, can_disable: can_disable)

fn _scene_window_title(blob: text) -> text:
    val parts = blob.split("|")
    if parts.len() > 0:
        return parts[0]
    blob

fn _scene_window_focus(blob: text) -> text:
    if blob.contains("|focused"):
        return "focused"
    "idle"

fn _scene_window_focus_class(blob: text) -> text:
    if blob.contains("|focused"):
        return " focused"
    ""

fn _scene_background_color(scene: WmSceneSpec) -> u32:
    for elem in scene.elements:
        if elem.kind == "desktop_chrome":
            return elem.color
    0xFF0F172Au32

fn _scene_touch_target_height_px(html: text) -> i32:
    if html.contains(".control-center button{{min-height:44px"):
        return 44
    0

fn _scene_theme_configured(html: text, config: WmSceneModernThemeConfig) -> bool:
    html.contains("data-theme-configured='true'") and
    html.contains("data-window-radius-px='{config.window_radius_px}'") and
    html.contains("data-widget-radius-px='{config.widget_radius_px}'") and
    html.contains("data-taskbar-radius-px='{config.taskbar_radius_px}'") and
    html.contains("data-control-radius-px='{config.control_radius_px}'") and
    html.contains("data-icon-radius-px='{config.icon_radius_px}'") and
    html.contains("data-scrollbar-width-px='{config.scrollbar_width_px}'") and
    html.contains("data-scrollbar-thumb-radius-px='{config.scrollbar_thumb_radius_px}'") and
    html.contains("data-scrollbar-thumb-border-px='{config.scrollbar_thumb_border_px}'") and
    html.contains("data-blur-px='{config.blur_px}'") and
    html.contains("data-titlebar-height-px='{config.titlebar_height_px}'") and
    html.contains("data-command-lane-height-px='{config.command_lane_height_px}'") and
    html.contains("data-taskbar-height-px='{config.taskbar_height_px}'") and
    html.contains("data-desktop-layer-z='{config.desktop_layer_z}'") and
    html.contains("data-snap-layer-z='{config.snap_layer_z}'") and
    html.contains("data-window-layer-z='{config.window_layer_z}'") and
    html.contains("data-overlay-layer-z='{config.overlay_layer_z}'") and
    html.contains("data-standard-motion-ms='{config.standard_motion_ms}'") and
    html.contains("data-reduced-motion-ms='{config.reduced_motion_ms}'") and
    html.contains("data-motion-can-disable='{config.can_disable_motion}'")

fn _scene_round_scrollbars_configured(html: text, config: WmSceneModernThemeConfig) -> bool:
    html.contains("data-scrollbar-width-px='{config.scrollbar_width_px}'") and
    html.contains("data-scrollbar-thumb-radius-px='{config.scrollbar_thumb_radius_px}'") and
    html.contains("data-scrollbar-thumb-border-px='{config.scrollbar_thumb_border_px}'") and
    html.contains("scrollbar-width:thin") and
    html.contains("scrollbar-color:rgba(96,165,250,.58) transparent") and
    html.contains("::-webkit-scrollbar") and
    html.contains("width:10px;height:10px") and
    html.contains("::-webkit-scrollbar-thumb") and
    html.contains("background-clip:padding-box") and
    html.contains("border-radius:999px")

fn _scene_round_icon_converter_configured(html: text) -> bool:
    html.contains("class='round-icon") and
    html.contains("data-icon-normalized='square-to-round'") and
    html.contains("data-icon-normalized='glyph-to-round'") and
    html.contains("icon-normalized-square") and
    html.contains("icon-glyph-to-round") and
    html.contains("icon-image-placeholder") and
    html.contains("icon-glyph") and
    html.contains("clip-path:circle(50% at 50% 50%)")

fn _scene_titlebar_input_configured(html: text) -> bool:
    html.contains("role='toolbar' aria-label='Window titlebar'") and
    html.contains("<input class='bar-command-input'") and
    html.contains("aria-label='Window command or location'") and
    html.contains(".bar-command-input{{min-width:140px") and
    html.contains("height:22px") and
    html.contains(".bar-command-input:focus") and
    html.contains("box-shadow:0 0 0 3px")

fn _scene_traffic_controls_configured(html: text) -> bool:
    html.contains("<button class='traffic traffic-close'") and
    html.contains("data-window-control='close'") and
    html.contains("aria-label='Close window'") and
    html.contains("<button class='traffic traffic-min'") and
    html.contains("data-window-control='minimize'") and
    html.contains("aria-label='Minimize window'") and
    html.contains("<button class='traffic traffic-max'") and
    html.contains("data-window-control='maximize'") and
    html.contains("aria-label='Maximize window'") and
    html.contains(".traffic::before{{content:'';position:absolute;inset:-8px") and
    html.contains(".traffic:focus-visible") and
    html.contains(".traffic:hover{{transform:scale(1.08)")

fn _scene_animated_background_configured(html: text) -> bool:
    html.contains("data-motion-scope='desktop-background'") and
    html.contains(".desktop::before") and
    html.contains("@keyframes wm-bg-drift") and
    html.contains("animation:wm-bg-drift") and
    html.contains("body[data-motion-mode='reduced'] .desktop::before") and
    html.contains("body[data-motion-mode='off'] .desktop::before") and
    html.contains("animation:none!important")

fn _scene_window_interaction_configured(html: text) -> bool:
    html.contains("data-drag-region='titlebar'") and
    html.contains("data-drag-hit-size-px='44'") and
    html.contains("cursor:grab") and
    html.contains("data-resize-surface='window'") and
    html.contains("class='resize-handle resize-east'") and
    html.contains("class='resize-handle resize-south'") and
    html.contains("class='resize-handle resize-west'") and
    html.contains("class='resize-handle resize-south-east'") and
    html.contains("data-resize-edge='south-east'") and
    html.contains("data-hit-size-px='44'") and
    html.contains(".resize-handle::before") and
    html.contains(".resize-handle:focus-visible")

fn _scene_command_palette_configured(html: text) -> bool:
    html.contains("class='command-palette'") and
    html.contains("role='dialog' aria-label='Simple command palette'") and
    html.contains("data-motion-scope='command-palette'") and
    html.contains("class='command-palette-input'") and
    html.contains("aria-label='Global command'") and
    html.contains("class='command-palette-list' role='listbox'") and
    html.contains("class='command-palette-item active' role='option' aria-selected='true'") and
    html.contains("Open Simple IDE") and
    html.contains("Show window overview") and
    html.contains(".command-palette{{position:absolute") and
    html.contains("max-width:680px") and
    html.contains(".command-palette-input{{width:100%;height:44px") and
    html.contains(".command-palette-item{{min-height:44px") and
    html.contains("@keyframes wm-command-in") and
    html.contains("body[data-motion-mode='reduced'] .command-palette") and
    html.contains("body[data-motion-mode='off'] .command-palette")

fn _scene_theme_accent_controls_configured(html: text) -> bool:
    html.contains("class='accent-controls' role='group' aria-label='Theme accent color'") and
    html.contains("class='accent-swatch active' data-accent-choice='blue'") and
    html.contains("data-accent-choice='teal'") and
