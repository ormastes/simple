fn scene_to_html(scene: WmSceneSpec) -> text:
    val w = "{scene.width}"
    val h = "{scene.height}"
    val config = modern_wm_scene_theme_config()
    var body = ""
    for elem in scene.elements:
        if elem.kind == "desktop_chrome":
            body = body + "<div class='desktop' data-motion-scope='desktop-background' data-motion-mode='standard' data-reduced-motion-duration-ms='80' data-motion-can-disable='true' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'></div>"
        elif elem.kind == "decoration":
            val title = _scene_window_title(elem.text)
            val focus = _scene_window_focus(elem.text)
            val focus_class = _scene_window_focus_class(elem.text)
            body = body + "<div class='bar{focus_class}' role='toolbar' aria-label='Window titlebar' data-window-focus='{focus}' data-elevation-layer='active-window' data-drag-region='titlebar' data-drag-hit-size-px='44' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'><button class='traffic traffic-close' data-window-control='close' aria-label='Close window'></button><button class='traffic traffic-min' data-window-control='minimize' aria-label='Minimize window'></button><button class='traffic traffic-max' data-window-control='maximize' aria-label='Maximize window'></button>" + _scene_round_icon_html("bar-icon", title) + "<span class='bar-title'>{title}</span><input class='bar-command-input' aria-label='Window command or location' value='{title}'><span class='bar-context'>workspace</span></div>"
        elif elem.kind == "glass_panel":
            val focus = _scene_window_focus(elem.text)
            val focus_class = _scene_window_focus_class(elem.text)
