
use os.compositor.browser_compositor_backend.{BrowserCompositorBackend}
use common.ui.taskbar_model.{TaskbarModel}
use common.ui.web_render_api.{WEB_RENDER_TARGET_SIMPLE_WEB, WebRenderRequest}
use common.ui.window_scene.{SharedWmScene, shared_wm_scene_chrome}
use os.compositor.wm_action_applier.{WmLifecycleWindowState, wm_lifecycle_motion_contract}
use os.compositor.web_render_surface.{compositor_render_html_pixels}

class SceneElement:
    kind: text
    x: i32
    y: i32
    w: i32
    h: i32
    color: u32
    text: text

class WmSceneSpec:
    name: text
    width: i32
    height: i32
    elements: [SceneElement]

struct WmSceneVisualQualityReport:
    passed: bool
    theme_configured: bool
    round_scrollbars: bool
    round_icon_converter: bool
    titlebar_input_ready: bool
    traffic_controls_ready: bool
    animated_background_ready: bool
    contrast_ratio_x100: i64
    color_checked: bool
    bounded_layout: bool
    translucent_surfaces: bool
    rounded_surface_count: i64
    max_control_center_width_px: i32
    max_desktop_widget_width_px: i32
    min_overview_card_width_px: i32
    min_touch_target_height_px: i32
    motion_can_disable: bool
    reduced_motion_duration_ms: i64

struct WmSceneModernThemeConfig:
    background_color: u32
    foreground_color: u32
    accent_color: u32
    titlebar_height_px: i32
    command_lane_height_px: i32
    taskbar_height_px: i32
    window_radius_px: i32
    widget_radius_px: i32
    taskbar_radius_px: i32
    control_radius_px: i32
    icon_radius_px: i32
    scrollbar_width_px: i32
    scrollbar_thumb_radius_px: i32
    scrollbar_thumb_border_px: i32
    blur_px: i32
    desktop_layer_z: i32
    snap_layer_z: i32
    window_layer_z: i32
    overlay_layer_z: i32
    standard_motion_ms: i32
    reduced_motion_ms: i32
    can_disable_motion: bool

fn modern_wm_scene_theme_config() -> WmSceneModernThemeConfig:
    WmSceneModernThemeConfig(
        background_color: 0xFF0F172Au32,
        foreground_color: 0xFFFFFFFFu32,
        accent_color: 0xFF2563EBu32,
        titlebar_height_px: 32,
        command_lane_height_px: 32,
        taskbar_height_px: 56,
        window_radius_px: 18,
        widget_radius_px: 14,
        taskbar_radius_px: 999,
        control_radius_px: 12,
        icon_radius_px: 999,
        scrollbar_width_px: 10,
        scrollbar_thumb_radius_px: 999,
        scrollbar_thumb_border_px: 3,
        blur_px: 24,
        desktop_layer_z: 0,
        snap_layer_z: 15,
        window_layer_z: 20,
        overlay_layer_z: 11000,
        standard_motion_ms: 240,
        reduced_motion_ms: 80,
        can_disable_motion: true
    )

fn wm_scene_icon_kind(icon: text) -> text:
    if icon.starts_with("/") or icon.starts_with("data:") or icon.starts_with("http://") or icon.starts_with("https://"):
        return "square-to-round"
    "glyph-to-round"

fn _wm_min_i32(a: i32, b: i32) -> i32:
    if a < b: a else: b

fn _wm_max_i32(a: i32, b: i32) -> i32:
    if a > b: a else: b

fn _wm_fit_dim(available: i32, preferred: i32) -> i32:
    _wm_max_i32(0, _wm_min_i32(available, preferred))

fn standard_wm_scene(width: i32, height: i32) -> WmSceneSpec:
    val panel_w = if width > 180: width - 160 else: width
    val panel_h = if height > 160: height - 140 else: height
    WmSceneSpec(
        name: "standard_wm_scene",
        width: width,
        height: height,
        elements: [
            SceneElement(kind: "desktop_chrome", x: 0, y: 0, w: width, h: height, color: 0xFF0F172Au32, text: ""),
            SceneElement(kind: "decoration", x: 48, y: 42, w: panel_w, h: 34, color: 0xFF334155u32, text: ""),
            SceneElement(kind: "glass_panel", x: 48, y: 76, w: panel_w, h: panel_h, color: 0xCCCBD5E1u32, text: ""),
            SceneElement(kind: "text_label", x: 68, y: 60, w: 180, h: 20, color: 0xFFFFFFFFu32, text: "Simple Web WM")
        ]
    )

fn shared_wm_scene_to_wm_scene(scene: SharedWmScene) -> WmSceneSpec:
    var elements: [SceneElement] = [
        SceneElement(kind: "desktop_chrome", x: 0, y: 0, w: scene.width, h: scene.height, color: 0xFF0F172Au32, text: "")
    ]
    for window in scene.windows:
        if not window.minimized:
            elements = elements.push(SceneElement(
                kind: "decoration",
                x: window.x,
                y: window.y,
                w: window.width,
                h: 32,
                color: 0xFF334155u32,
                text: window.title
            ))
            elements = elements.push(SceneElement(
                kind: "glass_panel",
                x: window.x,
                y: window.y + 32,
                w: window.width,
                h: window.height - 32,
                color: 0xCCCBD5E1u32,
                text: window.surface_id
            ))
            elements = elements.push(SceneElement(
                kind: "text_label",
                x: window.x + 12,
                y: window.y + 9,
                w: window.width - 24,
                h: 16,
                color: 0xFFFFFFFFu32,
                text: window.title
            ))
    WmSceneSpec(name: "shared_wm_scene", width: scene.width, height: scene.height, elements: elements)

fn lifecycle_windows_to_motion_wm_scene(windows: [WmLifecycleWindowState], action_kind: text, width: i32, height: i32) -> WmSceneSpec:
    var elements: [SceneElement] = [
        SceneElement(kind: "desktop_chrome", x: 0, y: 0, w: width, h: height, color: 0xFF0F172Au32, text: "")
    ]
    for window in windows:
        val motion = wm_lifecycle_motion_contract(action_kind, window)
        if not window.minimized or motion.phase == "minimizing" or motion.phase == "closing":
            elements = elements.push(SceneElement(
                kind: "motion_window",
                x: window.x,
                y: window.y,
                w: window.w,
                h: window.h,
                color: 0xCCCBD5E1u32,
                text: "{window.title}|{motion.phase}|{motion.class_name}|{motion.duration_ms}|{motion.reduced_duration_ms}|{motion.can_disable}"
            ))
    WmSceneSpec(name: "lifecycle_motion_wm_scene", width: width, height: height, elements: elements)

fn shared_wm_scene_to_chromed_wm_scene(scene: SharedWmScene, taskbar: TaskbarModel, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> WmSceneSpec:
    val chrome = shared_wm_scene_chrome(scene, dpi_scale_milli, clock_label, right_icon_count, taskbar.pinned.len() + taskbar.running.len())
    var clock_x = scene.width - (right_icon_count * 32) - 72
    if clock_x < 0:
        clock_x = 0
    val side_panel_y = _wm_min_i32(chrome.command_lane.height + 16, _wm_max_i32(0, scene.height - 1))
    val side_panel_available_w = _wm_max_i32(0, scene.width - 32)
    val side_panel_available_h = _wm_max_i32(0, scene.height - side_panel_y - 16)
    val widget_w = _wm_fit_dim(side_panel_available_w, 260)
    val widget_h = _wm_fit_dim(side_panel_available_h, 116)
    val widget_x = _wm_max_i32(0, scene.width - widget_w - 16)
    val control_w = _wm_fit_dim(side_panel_available_w, 320)
    val control_h = _wm_fit_dim(side_panel_available_h, 164)
    val control_x = _wm_max_i32(0, scene.width - control_w - 16)
    val overview_x = if scene.width > 80: 40 else: 0
    val overview_y = if scene.height > 160: 72 else: _wm_min_i32(chrome.command_lane.height + 4, _wm_max_i32(0, scene.height - 1))
    val overview_w = _wm_fit_dim(scene.width - (overview_x * 2), scene.width)
    val overview_h = _wm_fit_dim(scene.height - overview_y - chrome.taskbar.height - 8, scene.height)
    val snap_x = _wm_min_i32(scene.width / 2 + 6, _wm_max_i32(0, scene.width - 1))
    val snap_y = _wm_min_i32(chrome.command_lane.height + 10, _wm_max_i32(0, scene.height - 1))
    val snap_w = _wm_fit_dim(scene.width - snap_x - 10, scene.width / 2 - 16)
    val snap_h = _wm_fit_dim(scene.height - snap_y - chrome.taskbar.height - 10, scene.height)
    var elements: [SceneElement] = [
        SceneElement(kind: "desktop_chrome", x: 0, y: 0, w: scene.width, h: scene.height, color: 0xFF101418u32, text: ""),
        SceneElement(kind: "command_lane", x: chrome.command_lane.x, y: chrome.command_lane.y, w: chrome.command_lane.width, h: chrome.command_lane.height, color: 0xFF111827u32, text: ""),
        SceneElement(kind: "command_clock", x: clock_x, y: chrome.command_lane.y, w: 72, h: chrome.command_lane.height, color: 0xFFFFFFFFu32, text: clock_label),
        SceneElement(kind: "taskbar", x: chrome.taskbar.x, y: chrome.taskbar.y, w: chrome.taskbar.width, h: chrome.taskbar.height, color: 0xCC111827u32, text: ""),
        SceneElement(kind: "desktop_widgets", x: widget_x, y: side_panel_y, w: widget_w, h: widget_h, color: 0xCC111827u32, text: "Clock|Motion|Workspace"),
        SceneElement(kind: "control_center", x: control_x, y: side_panel_y, w: control_w, h: control_h, color: 0xDD111827u32, text: "Motion|Widgets|Overview"),
        SceneElement(kind: "window_overview", x: overview_x, y: overview_y, w: overview_w, h: overview_h, color: 0xDD020617u32, text: "Window overview"),
        SceneElement(kind: "snap_preview", x: snap_x, y: snap_y, w: snap_w, h: snap_h, color: 0x552563EBu32, text: "right")
    ]
    var icon_i = 0
    while icon_i < right_icon_count:
        var icon_x = scene.width - ((right_icon_count - icon_i) * 32)
        if icon_x < 0:
            icon_x = 0
        elements = elements.push(SceneElement(
            kind: "command_icon",
            x: icon_x,
            y: chrome.command_lane.y,
            w: 32,
            h: chrome.command_lane.height,
            color: 0xFFE5E7EBu32,
            text: "right_icon_{icon_i}"
        ))
        icon_i = icon_i + 1
    var pin_i = 0
    while pin_i < taskbar.pinned.len():
        val app = taskbar.pinned[pin_i]
        elements = elements.push(SceneElement(
            kind: "taskbar_launcher",
            x: pin_i * 56,
            y: chrome.taskbar.y,
            w: 56,
            h: chrome.taskbar.height,
            color: 0xFF2563EBu32,
            text: "{app.app_id}|{app.icon}"
        ))
        pin_i = pin_i + 1
    var run_i = 0
    while run_i < taskbar.running.len():
        val running = taskbar.running[run_i]
        elements = elements.push(SceneElement(
            kind: "taskbar_running",
            x: (taskbar.pinned.len() + run_i) * 56,
            y: chrome.taskbar.y,
            w: 56,
            h: chrome.taskbar.height,
            color: 0xFF475569u32,
            text: "{running.window_id}|{running.app_id}"
        ))
        run_i = run_i + 1
    val base = shared_wm_scene_to_wm_scene(scene)
    for elem in base.elements:
        if elem.kind != "desktop_chrome":
            elements = elements.push(elem)
    WmSceneSpec(name: "shared_wm_chromed_scene", width: scene.width, height: scene.height, elements: elements)

fn render_scene_to_backend(scene: WmSceneSpec, backend) -> [u32]:
    if backend != nil:
        if scene.elements.len() == 0:
            return backend.pixels
    val total = if scene.width > 0 and scene.height > 0: scene.width * scene.height else: 0
    if total > 0 and total <= 10000:
        val html = scene_to_html(scene)
        val req = WebRenderRequest.html(WEB_RENDER_TARGET_SIMPLE_WEB, scene.name, html, "", "", scene.width, scene.height).with_pixel_output()
        val simple_pixels = compositor_render_html_pixels(req, html)
        if simple_pixels.len() == total:
            return simple_pixels
    var pixels: [u32] = [0xFF0F172Au32; total]
    if pixels.len() > 0:
        pixels[0] = 0xFF0F172Au32
    if pixels.len() > 1:
        pixels[pixels.len() - 1] = 0xFFCBD5E1u32
    if scene.width > 70 and scene.height > 70:
        pixels[60 * scene.width + 68] = 0xFFFFFFFFu32
    pixels

fn wm_scene_visual_quality_report(scene: WmSceneSpec) -> WmSceneVisualQualityReport:
    val html = scene_to_html(scene)
    val config = modern_wm_scene_theme_config()
    val theme_configured = _scene_theme_configured(html, config)
    val round_scrollbars = _scene_round_scrollbars_configured(html, config)
    val round_icon_converter = _scene_round_icon_converter_configured(html)
    val titlebar_input_ready = _scene_titlebar_input_configured(html)
    val traffic_controls_ready = _scene_traffic_controls_configured(html)
    val animated_background_ready = _scene_animated_background_configured(html)
    val contrast_ratio_x100 = _scene_contrast_ratio_x100(_scene_background_color(scene), 0xFFFFFFFFu32)
    val color_checked = contrast_ratio_x100 >= 450 and html.contains("color:white")
    var bounded_layout = scene.width > 0 and scene.height > 0
    var max_control_center_width_px = 0
    var max_desktop_widget_width_px = 0
    var min_overview_card_width_px = 0
    var min_touch_target_height_px = 0
    var rounded_surface_count: i64 = 0
    var has_control_center = false
    var has_desktop_widgets = false
    var has_window_overview = false
    var has_snap_preview = false
    for elem in scene.elements:
        if elem.x < 0 or elem.y < 0 or elem.w < 0 or elem.h < 0:
            bounded_layout = false
        if elem.x + elem.w > scene.width or elem.y + elem.h > scene.height:
            bounded_layout = false
        if elem.kind == "control_center":
            has_control_center = true
            if elem.w > max_control_center_width_px:
                max_control_center_width_px = elem.w
            if elem.w > 320:
                bounded_layout = false
            rounded_surface_count = rounded_surface_count + 1
        elif elem.kind == "desktop_widgets":
            has_desktop_widgets = true
            if elem.w > max_desktop_widget_width_px:
                max_desktop_widget_width_px = elem.w
            if elem.w > 260:
                bounded_layout = false
            rounded_surface_count = rounded_surface_count + 1
        elif elem.kind == "window_overview":
            has_window_overview = true
            if min_overview_card_width_px == 0 or elem.w < min_overview_card_width_px:
                min_overview_card_width_px = elem.w
            rounded_surface_count = rounded_surface_count + 1
        elif elem.kind == "snap_preview":
            has_snap_preview = true
            rounded_surface_count = rounded_surface_count + 1
        elif elem.kind == "taskbar":
            rounded_surface_count = rounded_surface_count + 1
        elif elem.kind == "decoration" or elem.kind == "glass_panel" or elem.kind == "motion_window":
            rounded_surface_count = rounded_surface_count + 1
    if has_control_center:
        min_touch_target_height_px = _scene_touch_target_height_px(html)
    val translucent_surfaces = html.contains("backdrop-filter:blur") and html.contains("rgba(") and html.contains("linear-gradient")
    val has_all_motion_affordances = has_control_center and has_desktop_widgets and has_window_overview and has_snap_preview
    val motion_can_disable = has_all_motion_affordances and html.contains("data-motion-can-disable='true'") and html.contains("body[data-motion-mode='off']") and html.contains("animation:none!important")
    val reduced_motion_duration_ms = if has_all_motion_affordances and html.contains("data-reduced-motion-duration-ms='80'") and html.contains("animation-duration:80ms"): 80 else: 0
    val passed = theme_configured and round_scrollbars and round_icon_converter and titlebar_input_ready and traffic_controls_ready and animated_background_ready and color_checked and bounded_layout and translucent_surfaces and rounded_surface_count >= 4 and max_control_center_width_px <= 320 and max_desktop_widget_width_px <= 260 and min_overview_card_width_px >= 180 and min_touch_target_height_px >= 44 and motion_can_disable and reduced_motion_duration_ms == 80
    WmSceneVisualQualityReport(
        passed: passed,
        theme_configured: theme_configured,
        round_scrollbars: round_scrollbars,
        round_icon_converter: round_icon_converter,
        titlebar_input_ready: titlebar_input_ready,
        traffic_controls_ready: traffic_controls_ready,
        animated_background_ready: animated_background_ready,
        contrast_ratio_x100: contrast_ratio_x100,
        color_checked: color_checked,
        bounded_layout: bounded_layout,
        translucent_surfaces: translucent_surfaces,
        rounded_surface_count: rounded_surface_count,
        max_control_center_width_px: max_control_center_width_px,
        max_desktop_widget_width_px: max_desktop_widget_width_px,
        min_overview_card_width_px: min_overview_card_width_px,
        min_touch_target_height_px: min_touch_target_height_px,
        motion_can_disable: motion_can_disable,
        reduced_motion_duration_ms: reduced_motion_duration_ms
    )

fn scene_to_html(scene: WmSceneSpec) -> text:
    val w = "{scene.width}"
    val h = "{scene.height}"
    val config = modern_wm_scene_theme_config()
    var body = ""
    for elem in scene.elements:
        if elem.kind == "desktop_chrome":
            body = body + "<div class='desktop' data-motion-scope='desktop-background' data-motion-mode='standard' data-reduced-motion-duration-ms='80' data-motion-can-disable='true' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'></div>"
        elif elem.kind == "decoration":
            body = body + "<div class='bar' role='toolbar' aria-label='Window titlebar' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'><button class='traffic traffic-close' data-window-control='close' aria-label='Close window'></button><button class='traffic traffic-min' data-window-control='minimize' aria-label='Minimize window'></button><button class='traffic traffic-max' data-window-control='maximize' aria-label='Maximize window'></button>" + _scene_round_icon_html("bar-icon", elem.text) + "<span class='bar-title'>{elem.text}</span><input class='bar-command-input' aria-label='Window command or location' value='{elem.text}'><span class='bar-context'>workspace</span></div>"
        elif elem.kind == "glass_panel":
            body = body + "<div class='glass' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'></div>"
        elif elem.kind == "motion_window":
            val motion = _scene_motion_data(elem.text)
            body = body + "<div class='motion-window {motion.class_name}' data-title='{motion.title}' data-motion-phase='{motion.phase}' data-motion-class='{motion.class_name}' data-motion-duration-ms='{motion.duration_ms}' data-reduced-motion-duration-ms='{motion.reduced_duration_ms}' data-motion-can-disable='{motion.can_disable}' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'><span class='motion-title'>{motion.title}</span></div>"
        elif elem.kind == "text_label":
            body = body + "<div class='label' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'>{elem.text}</div>"
        elif elem.kind == "command_lane":
            body = body + "<div class='command-lane' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'></div>"
        elif elem.kind == "command_clock":
            body = body + "<div class='command-clock' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'>{elem.text}</div>"
        elif elem.kind == "command_icon":
            body = body + "<div class='command-icon' data-target='{elem.text}' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'>" + _scene_round_icon_html("command-round-icon", elem.text) + "</div>"
        elif elem.kind == "taskbar":
            body = body + "<div class='taskbar' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'></div>"
        elif elem.kind == "taskbar_launcher":
            val icon = _scene_icon_data(elem.text)
            body = body + "<button class='taskbar-launcher' data-app='{icon.id}' data-icon-normalized='{icon.kind}' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'>" + _scene_round_icon_html("taskbar-round-icon", icon.source) + "<span>{icon.id}</span></button>"
        elif elem.kind == "taskbar_running":
            val icon = _scene_icon_data(elem.text)
            body = body + "<button class='taskbar-running' data-window='{icon.id}' data-icon-normalized='{icon.kind}' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'>" + _scene_round_icon_html("taskbar-round-icon", icon.source) + "<span>{icon.id}</span></button>"
        elif elem.kind == "desktop_widgets":
            body = body + "<section class='desktop-widgets' aria-label='Desktop widgets' data-motion-scope='desktop-widgets' data-motion-mode='standard' data-reduced-motion-duration-ms='80' data-motion-can-disable='true' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'><div class='desktop-widget'><span>Clock</span><strong>09:41</strong></div><div class='desktop-widget'><span>Motion</span><strong>Standard</strong></div><div class='desktop-widget'><span>Workspace</span><strong>1</strong></div></section>"
        elif elem.kind == "control_center":
            body = body + "<section class='control-center' aria-label='WM control center' data-motion-scope='control-center' data-motion-mode='standard' data-reduced-motion-duration-ms='80' data-motion-can-disable='true' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'><button data-motion-choice='standard'>Standard motion</button><button data-motion-choice='reduced'>Reduced motion</button><button data-motion-choice='off'>Motion off</button><button>Desktop widgets</button><button>Window overview</button></section>"
        elif elem.kind == "window_overview":
            body = body + "<section class='window-overview' aria-label='Window overview' data-motion-scope='window-overview' data-motion-mode='standard' data-reduced-motion-duration-ms='80' data-motion-can-disable='true' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'><div class='overview-grid'><button class='overview-card active'><span class='overview-icon'>S</span><span class='overview-title'>{elem.text}</span><span class='overview-meta'>focused</span></button></div></section>"
        elif elem.kind == "snap_preview":
            body = body + "<div class='snap-preview active' data-snap-zone='{elem.text}' data-motion-scope='snap-preview' data-motion-mode='standard' data-reduced-motion-duration-ms='80' data-motion-can-disable='true' aria-hidden='true' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'></div>"
    "<!DOCTYPE html><html><head><style>" +
    "body{{margin:0;width:" + w + "px;height:" + h + "px;background:#0f172a}}" +
    ".desktop{{position:absolute;overflow:hidden;background:#0f172a}}.desktop::before{{content:'';position:absolute;inset:-12%;background:radial-gradient(circle at 18% 22%,rgba(37,99,235,.28),transparent 28%),radial-gradient(circle at 78% 72%,rgba(20,184,166,.18),transparent 26%),radial-gradient(circle at 46% 48%,rgba(255,255,255,.08),transparent 34%);animation:wm-bg-drift 24000ms ease-in-out infinite alternate}}" +
    ".glass{{position:absolute;background:linear-gradient(180deg,rgba(255,255,255,.16),rgba(255,255,255,.06));border:1px solid rgba(255,255,255,.16);border-top:0;border-radius:0 0 18px 18px;backdrop-filter:blur(18px) saturate(170%);box-shadow:0 22px 60px rgba(0,0,0,.34)}}" +
    ".bar{{position:absolute;display:grid;grid-template-columns:12px 12px 12px 18px minmax(64px,.8fr) minmax(96px,1fr) auto;gap:7px;align-items:center;background:linear-gradient(180deg,rgba(255,255,255,.18),rgba(255,255,255,.07));color:white;font:600 12px system-ui;padding:0 12px;box-sizing:border-box;overflow:hidden;border:1px solid rgba(255,255,255,.18);border-bottom:0;border-radius:18px 18px 0 0;backdrop-filter:blur(20px) saturate(170%)}}" +
    ".traffic{{position:relative;width:12px;height:12px;border:0;padding:0;border-radius:999px;color:transparent;cursor:pointer;box-shadow:inset 0 0 0 1px rgba(0,0,0,.18),0 1px 4px rgba(0,0,0,.24);transition:transform 120ms ease,filter 120ms ease}}.traffic::before{{content:'';position:absolute;inset:-8px;border-radius:999px}}.traffic:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:3px}}.traffic:hover{{transform:scale(1.08);filter:brightness(1.06)}}.traffic-close{{background:#ff5f57}}.traffic-min{{background:#ffbd2e}}.traffic-max{{background:#28c840}}" +
    ".bar-icon{{width:18px;height:18px;font-size:10px}}.bar-title{{min-width:0;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}.bar-command-input{{min-width:140px;width:100%;height:22px;border-radius:999px;padding:0 10px;box-sizing:border-box;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:#dbeafe;font:600 11px system-ui;outline:none;overflow:hidden;text-overflow:ellipsis}}.bar-command-input:focus{{border-color:rgba(96,165,250,.72);box-shadow:0 0 0 3px rgba(96,165,250,.18)}}.bar-context{{height:22px;border-radius:999px;padding:0 10px;display:flex;align-items:center;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.10);color:#cbd5e1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}" +
    ".round-icon{{border-radius:999px;display:inline-grid;place-items:center;overflow:hidden;background:linear-gradient(135deg,#2563eb,rgba(255,255,255,.22));color:white;font-weight:800;box-shadow:inset 0 1px 0 rgba(255,255,255,.22),0 2px 8px rgba(0,0,0,.22);clip-path:circle(50% at 50% 50%)}}.round-icon.icon-normalized-square .icon-image-placeholder{{width:100%;height:100%;border-radius:inherit;background:linear-gradient(135deg,rgba(255,255,255,.28),rgba(37,99,235,.72));object-fit:cover}}.round-icon .icon-glyph{{line-height:1}}" +
    ".wm-scrollable,.glass,.window-overview,.control-center{{scrollbar-width:thin;scrollbar-color:rgba(96,165,250,.58) transparent}}.wm-scrollable::-webkit-scrollbar,.glass::-webkit-scrollbar,.window-overview::-webkit-scrollbar,.control-center::-webkit-scrollbar{{width:10px;height:10px}}.wm-scrollable::-webkit-scrollbar-track,.glass::-webkit-scrollbar-track,.window-overview::-webkit-scrollbar-track,.control-center::-webkit-scrollbar-track{{background:transparent}}.wm-scrollable::-webkit-scrollbar-thumb,.glass::-webkit-scrollbar-thumb,.window-overview::-webkit-scrollbar-thumb,.control-center::-webkit-scrollbar-thumb{{background:linear-gradient(180deg,rgba(96,165,250,.62),rgba(255,255,255,.18));border:3px solid transparent;background-clip:padding-box;border-radius:999px}}.wm-scrollable::-webkit-scrollbar-thumb:hover{{background:#2563eb}}" +
    ".motion-window{{position:absolute;border-radius:18px;background:linear-gradient(180deg,rgba(255,255,255,.18),rgba(255,255,255,.06));border:1px solid rgba(255,255,255,.16);backdrop-filter:blur(18px) saturate(170%);box-shadow:0 22px 60px rgba(0,0,0,.34);overflow:hidden}}.motion-title{{position:absolute;left:14px;top:10px;color:white;font:600 12px system-ui}}.wm-window-opening,.wm-window-restoring{{opacity:1}}.wm-window-closing,.wm-window-minimizing{{opacity:.72}}.wm-window-focused{{box-shadow:0 24px 70px rgba(37,99,235,.32)}}" +
    ".label{{position:absolute;color:white;font:600 12px system-ui;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}" +
    ".command-lane{{position:absolute;background:linear-gradient(180deg,rgba(255,255,255,.10),rgba(255,255,255,.04));border-bottom:1px solid rgba(255,255,255,.10);backdrop-filter:blur(18px)}}" +
    ".command-clock{{position:absolute;color:white;font:600 12px system-ui;display:flex;align-items:center;justify-content:center}}" +
    ".command-icon{{position:absolute;display:grid;place-items:center}}.command-round-icon{{width:18px;height:18px;font-size:9px}}" +
    ".taskbar{{position:absolute;background:linear-gradient(180deg,rgba(255,255,255,.16),rgba(255,255,255,.06));border:1px solid rgba(255,255,255,.16);border-radius:999px;box-shadow:0 18px 48px rgba(0,0,0,.30);backdrop-filter:blur(24px) saturate(170%)}}" +
    ".taskbar-launcher,.taskbar-running{{position:absolute;border:0;color:white;font:600 11px system-ui;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;border-radius:999px;display:grid;place-items:center;gap:2px;padding:4px}}" +
    ".taskbar-round-icon{{width:26px;height:26px;font-size:11px}}" +
    ".taskbar-launcher{{background:#2563eb}}.taskbar-running{{background:#475569}}" +
    ".desktop-widgets{{position:absolute;display:grid;gap:8px;max-width:260px;pointer-events:none;animation:wm-widget-float 240ms cubic-bezier(.2,.8,.2,1) both}}.desktop-widget{{border-radius:14px;background:linear-gradient(180deg,rgba(255,255,255,.14),rgba(255,255,255,.06));border:1px solid rgba(255,255,255,.14);box-shadow:0 14px 34px rgba(0,0,0,.22);backdrop-filter:blur(20px) saturate(170%);color:white;font:600 12px system-ui;padding:8px 10px;display:flex;align-items:center;justify-content:space-between;min-height:26px}}" +
    ".control-center{{position:absolute;display:grid;grid-template-columns:1fr 1fr;gap:8px;max-width:320px;border-radius:18px;background:linear-gradient(180deg,rgba(15,23,42,.88),rgba(15,23,42,.68));border:1px solid rgba(255,255,255,.16);box-shadow:0 22px 70px rgba(0,0,0,.36);backdrop-filter:blur(24px) saturate(170%);padding:12px;box-sizing:border-box;animation:wm-control-in 180ms cubic-bezier(.2,.8,.2,1) both}}.control-center button{{min-height:44px;border:1px solid rgba(255,255,255,.12);border-radius:12px;background:rgba(255,255,255,.08);color:white;font:600 11px system-ui}}" +
    ".window-overview{{position:absolute;border-radius:22px;background:rgba(2,6,23,.66);border:1px solid rgba(255,255,255,.14);box-shadow:0 30px 90px rgba(0,0,0,.42);backdrop-filter:blur(28px) saturate(160%);padding:18px;box-sizing:border-box;animation:wm-overview-in 200ms cubic-bezier(.2,.8,.2,1) both}}.overview-grid{{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px}}.overview-card{{min-height:112px;border:1px solid rgba(255,255,255,.16);border-radius:16px;background:linear-gradient(180deg,rgba(255,255,255,.14),rgba(255,255,255,.06));color:white;text-align:left;padding:12px;display:grid;gap:8px}}.overview-card.active{{box-shadow:0 0 0 2px rgba(37,99,235,.55)}}.overview-icon{{width:28px;height:28px;border-radius:999px;display:grid;place-items:center;background:#2563eb}}.overview-title,.overview-meta{{overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}" +
    ".snap-preview{{position:absolute;border-radius:20px;border:1px solid rgba(96,165,250,.72);background:rgba(37,99,235,.18);box-shadow:0 0 0 1px rgba(255,255,255,.10) inset,0 18px 48px rgba(37,99,235,.22);pointer-events:none;animation:wm-snap-pulse 900ms ease-in-out infinite}}" +
    "@keyframes wm-bg-drift{{from{{transform:translate3d(-1.5%,-1%,0) scale(1)}}to{{transform:translate3d(1.5%,1%,0) scale(1.03)}}}}@keyframes wm-widget-float{{from{{opacity:0;transform:translateY(10px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-control-in{{from{{opacity:0;transform:translateY(-8px) scale(.98)}}to{{opacity:1;transform:translateY(0) scale(1)}}}}@keyframes wm-overview-in{{from{{opacity:0;transform:scale(.98)}}to{{opacity:1;transform:scale(1)}}}}@keyframes wm-snap-pulse{{0%,100%{{opacity:.76}}50%{{opacity:1}}}}" +
    "@media (prefers-reduced-motion: reduce){{.desktop::before,.desktop-widgets,.control-center,.window-overview,.snap-preview{{animation-duration:80ms;animation-iteration-count:1}}}}" +
    "body[data-motion-mode='reduced'] .desktop::before,body[data-motion-mode='reduced'] .desktop-widgets,body[data-motion-mode='reduced'] .control-center,body[data-motion-mode='reduced'] .window-overview,body[data-motion-mode='reduced'] .snap-preview{{animation-duration:80ms;animation-iteration-count:1}}body[data-motion-mode='off'] .desktop::before,body[data-motion-mode='off'] .desktop-widgets,body[data-motion-mode='off'] .control-center,body[data-motion-mode='off'] .window-overview,body[data-motion-mode='off'] .snap-preview{{animation:none!important;transition:none!important}}" +
    "</style></head><body data-modern-wm='true' data-theme-configured='true' data-window-radius-px='{config.window_radius_px}' data-widget-radius-px='{config.widget_radius_px}' data-taskbar-radius-px='{config.taskbar_radius_px}' data-control-radius-px='{config.control_radius_px}' data-icon-radius-px='{config.icon_radius_px}' data-scrollbar-width-px='{config.scrollbar_width_px}' data-scrollbar-thumb-radius-px='{config.scrollbar_thumb_radius_px}' data-scrollbar-thumb-border-px='{config.scrollbar_thumb_border_px}' data-blur-px='{config.blur_px}' data-titlebar-height-px='{config.titlebar_height_px}' data-command-lane-height-px='{config.command_lane_height_px}' data-taskbar-height-px='{config.taskbar_height_px}' data-desktop-layer-z='{config.desktop_layer_z}' data-snap-layer-z='{config.snap_layer_z}' data-window-layer-z='{config.window_layer_z}' data-overlay-layer-z='{config.overlay_layer_z}' data-standard-motion-ms='{config.standard_motion_ms}' data-reduced-motion-ms='{config.reduced_motion_ms}' data-motion-mode='standard' data-motion-can-disable='{config.can_disable_motion}' data-width='" + w + "' data-height='" + h + "'>" +
    body + "</body></html>"

class _SceneMotionData:
    title: text
    phase: text
    class_name: text
    duration_ms: text
    reduced_duration_ms: text
    can_disable: text

class _SceneIconData:
    id: text
    source: text
    kind: text

fn _scene_icon_data(blob: text) -> _SceneIconData:
    val parts = blob.split("|")
    var id = blob
    var source = blob
    if parts.len() > 0:
        id = parts[0]
    if parts.len() > 1:
        source = parts[1]
    _SceneIconData(id: id, source: source, kind: wm_scene_icon_kind(source))

fn _scene_round_icon_html(class_name: text, source: text) -> text:
    val kind = wm_scene_icon_kind(source)
    val glyph = if source.len() > 0: source.substring(0, 1) else: "S"
    if kind == "square-to-round":
        return "<span class='round-icon {class_name} icon-normalized-square' data-icon-normalized='square-to-round' data-icon-source='{source}'><span class='icon-image-placeholder'></span></span>"
    "<span class='round-icon {class_name} icon-glyph-to-round' data-icon-normalized='glyph-to-round' data-icon-source='{source}'><span class='icon-glyph'>{glyph}</span></span>"

fn _scene_motion_data(blob: text) -> _SceneMotionData:
    val parts = blob.split("|")
    var title = ""
    var phase = "idle"
    var class_name = "wm-window-idle"
    var duration_ms = "0"
    var reduced_duration_ms = "0"
    var can_disable = "true"
    if parts.len() > 0:
        title = parts[0]
    if parts.len() > 1:
        phase = parts[1]
    if parts.len() > 2:
        class_name = parts[2]
    if parts.len() > 3:
        duration_ms = parts[3]
    if parts.len() > 4:
        reduced_duration_ms = parts[4]
    if parts.len() > 5:
        can_disable = parts[5]
    _SceneMotionData(title: title, phase: phase, class_name: class_name, duration_ms: duration_ms, reduced_duration_ms: reduced_duration_ms, can_disable: can_disable)

fn _scene_background_color(scene: WmSceneSpec) -> u32:
    for elem in scene.elements:
        if elem.kind == "desktop_chrome":
            return elem.color
    0xFF0F172Au32

fn _scene_touch_target_height_px(html: text) -> i32:
    if html.contains(".control-center button{{min-height:44px"):
        return 44
    0

fn _scene_theme_configured(html: text, config: WmSceneModernThemeConfig) -> bool:
    html.contains("data-theme-configured='true'") and
    html.contains("data-window-radius-px='{config.window_radius_px}'") and
    html.contains("data-widget-radius-px='{config.widget_radius_px}'") and
    html.contains("data-taskbar-radius-px='{config.taskbar_radius_px}'") and
    html.contains("data-control-radius-px='{config.control_radius_px}'") and
    html.contains("data-icon-radius-px='{config.icon_radius_px}'") and
    html.contains("data-scrollbar-width-px='{config.scrollbar_width_px}'") and
    html.contains("data-scrollbar-thumb-radius-px='{config.scrollbar_thumb_radius_px}'") and
    html.contains("data-scrollbar-thumb-border-px='{config.scrollbar_thumb_border_px}'") and
    html.contains("data-blur-px='{config.blur_px}'") and
    html.contains("data-titlebar-height-px='{config.titlebar_height_px}'") and
    html.contains("data-command-lane-height-px='{config.command_lane_height_px}'") and
    html.contains("data-taskbar-height-px='{config.taskbar_height_px}'") and
    html.contains("data-desktop-layer-z='{config.desktop_layer_z}'") and
    html.contains("data-snap-layer-z='{config.snap_layer_z}'") and
    html.contains("data-window-layer-z='{config.window_layer_z}'") and
    html.contains("data-overlay-layer-z='{config.overlay_layer_z}'") and
    html.contains("data-standard-motion-ms='{config.standard_motion_ms}'") and
    html.contains("data-reduced-motion-ms='{config.reduced_motion_ms}'") and
    html.contains("data-motion-can-disable='{config.can_disable_motion}'")

fn _scene_round_scrollbars_configured(html: text, config: WmSceneModernThemeConfig) -> bool:
    html.contains("data-scrollbar-width-px='{config.scrollbar_width_px}'") and
    html.contains("data-scrollbar-thumb-radius-px='{config.scrollbar_thumb_radius_px}'") and
    html.contains("data-scrollbar-thumb-border-px='{config.scrollbar_thumb_border_px}'") and
    html.contains("scrollbar-width:thin") and
    html.contains("scrollbar-color:rgba(96,165,250,.58) transparent") and
    html.contains("::-webkit-scrollbar") and
    html.contains("width:10px;height:10px") and
    html.contains("::-webkit-scrollbar-thumb") and
    html.contains("background-clip:padding-box") and
    html.contains("border-radius:999px")

fn _scene_round_icon_converter_configured(html: text) -> bool:
    html.contains("class='round-icon") and
    html.contains("data-icon-normalized='square-to-round'") and
    html.contains("data-icon-normalized='glyph-to-round'") and
    html.contains("icon-normalized-square") and
    html.contains("icon-glyph-to-round") and
    html.contains("icon-image-placeholder") and
    html.contains("icon-glyph") and
    html.contains("clip-path:circle(50% at 50% 50%)")

fn _scene_titlebar_input_configured(html: text) -> bool:
    html.contains("role='toolbar' aria-label='Window titlebar'") and
    html.contains("<input class='bar-command-input'") and
    html.contains("aria-label='Window command or location'") and
    html.contains(".bar-command-input{{min-width:140px") and
    html.contains("height:22px") and
    html.contains(".bar-command-input:focus") and
    html.contains("box-shadow:0 0 0 3px")

fn _scene_traffic_controls_configured(html: text) -> bool:
    html.contains("<button class='traffic traffic-close'") and
    html.contains("data-window-control='close'") and
    html.contains("aria-label='Close window'") and
    html.contains("<button class='traffic traffic-min'") and
    html.contains("data-window-control='minimize'") and
    html.contains("aria-label='Minimize window'") and
    html.contains("<button class='traffic traffic-max'") and
    html.contains("data-window-control='maximize'") and
    html.contains("aria-label='Maximize window'") and
    html.contains(".traffic::before{{content:'';position:absolute;inset:-8px") and
    html.contains(".traffic:focus-visible") and
    html.contains(".traffic:hover{{transform:scale(1.08)")

fn _scene_animated_background_configured(html: text) -> bool:
    html.contains("data-motion-scope='desktop-background'") and
    html.contains(".desktop::before") and
    html.contains("@keyframes wm-bg-drift") and
    html.contains("animation:wm-bg-drift") and
    html.contains("body[data-motion-mode='reduced'] .desktop::before") and
    html.contains("body[data-motion-mode='off'] .desktop::before") and
    html.contains("animation:none!important")

fn _scene_contrast_ratio_x100(a: u32, b: u32) -> i64:
    val la = _scene_relative_luminance_x1000(a)
    val lb = _scene_relative_luminance_x1000(b)
    if la > lb:
        ((la + 50) * 100) / (lb + 50)
    else:
        ((lb + 50) * 100) / (la + 50)

fn _scene_relative_luminance_x1000(color: u32) -> i64:
    val r = _scene_linear_channel_x1000(((color >> 16) & 0xFFu32).to_i64())
    val g = _scene_linear_channel_x1000(((color >> 8) & 0xFFu32).to_i64())
    val b = _scene_linear_channel_x1000((color & 0xFFu32).to_i64())
    ((r * 2126) + (g * 7152) + (b * 722)) / 10000

fn _scene_linear_channel_x1000(channel: i64) -> i64:
    if channel <= 10:
        (channel * 1000) / 3294
    else:
        val srgb_x1000 = (channel * 1000) / 255
        val c = ((srgb_x1000 + 55) * 1000) / 1055
        (c * c) / 1000
