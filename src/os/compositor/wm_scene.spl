            body = body + "<section class='clipboard-history' role='dialog' aria-label='Clipboard history' data-motion-scope='clipboard-history' data-motion-mode='standard' data-reduced-motion-duration-ms='80' data-motion-can-disable='true' data-clipboard-source='system' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'><header class='clipboard-history-header'><strong>Clipboard</strong><button class='clipboard-clear' data-clipboard-action='clear' aria-label='Clear clipboard history'>Clear</button></header><div class='clipboard-list' role='listbox' aria-label='Recent clipboard items'><button class='clipboard-item active' role='option' aria-selected='true' data-clipboard-kind='command' data-clipboard-action='paste'>" + _scene_round_icon_html("clipboard-item-icon", "Command") + "<span>simple check src/os</span><kbd>Paste</kbd></button><button class='clipboard-item' role='option' aria-selected='false' data-clipboard-kind='code' data-clipboard-action='paste'>" + _scene_round_icon_html("clipboard-item-icon", "Code") + "<span>SceneElement(...)</span><kbd>Paste</kbd></button><button class='clipboard-item pinned' role='option' aria-selected='false' data-clipboard-kind='link' data-clipboard-action='paste'>" + _scene_round_icon_html("clipboard-item-icon", "Link") + "<span>https://simple.local</span><kbd>Pin</kbd></button></div><button class='clipboard-pin' data-clipboard-action='pin' aria-label='Pin selected clipboard item'>Pin</button></section>"
        elif elem.kind == "privacy_indicator":
            body = body + "<section class='privacy-indicator' role='status' aria-live='polite' aria-label='Privacy activity' data-motion-scope='privacy-indicator' data-motion-mode='standard' data-reduced-motion-duration-ms='80' data-motion-can-disable='true' data-privacy-source='system-services' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'><header class='privacy-header'><span class='privacy-dot camera' aria-hidden='true'></span><strong>Camera and mic</strong></header><div class='privacy-list' role='list'><span role='listitem'>" + _scene_round_icon_html("privacy-icon", "Camera") + "Camera active</span><span role='listitem'>" + _scene_round_icon_html("privacy-icon", "Mic") + "Mic active</span><span role='listitem'>" + _scene_round_icon_html("privacy-icon", "Screen") + "Screen sharing</span></div><div class='privacy-actions' role='group' aria-label='Privacy controls'><button class='privacy-action' data-privacy-action='allow'>Allow</button><button class='privacy-action danger' data-privacy-action='block'>Block</button></div></section>"
        elif elem.kind == "system_hud":
            body = body + "<section class='system-hud' role='status' aria-live='polite' aria-label='System volume and brightness' data-motion-scope='system-hud' data-motion-mode='standard' data-reduced-motion-duration-ms='80' data-motion-can-disable='true' data-hud-source='hardware-keys' style='left:{elem.x}px;top:{elem.y}px;width:{elem.w}px;height:{elem.h}px'>" + _scene_round_icon_html("system-hud-icon", "Volume") + "<div class='system-hud-copy'><strong>Volume</strong><span>68%</span></div><div class='system-hud-meter' role='meter' aria-label='Volume level' aria-valuemin='0' aria-valuemax='100' aria-valuenow='68'><span style='width:68%'></span></div><div class='system-hud-actions' role='group' aria-label='System HUD actions'><button class='system-hud-action' data-hud-action='mute' aria-label='Mute audio'>Mute</button><button class='system-hud-action active' data-hud-action='brightness' aria-label='Show brightness level'>Brightness</button></div></section>"
    "<!DOCTYPE html><html><head><style>" +
    "body{{margin:0;width:" + w + "px;height:" + h + "px;background:#0f172a}}" +
    ".desktop{{position:absolute;overflow:hidden;background:#0f172a}}.desktop::before{{content:'';position:absolute;inset:-12%;background:radial-gradient(circle at 18% 22%,rgba(37,99,235,.28),transparent 28%),radial-gradient(circle at 78% 72%,rgba(20,184,166,.18),transparent 26%),radial-gradient(circle at 46% 48%,rgba(255,255,255,.08),transparent 34%);animation:wm-bg-drift 24000ms ease-in-out infinite alternate}}" +
    ".glass{{position:absolute;background:linear-gradient(180deg,rgba(255,255,255,.16),rgba(255,255,255,.06));border:1px solid rgba(255,255,255,.16);border-top:0;border-radius:0 0 18px 18px;backdrop-filter:blur(18px) saturate(170%);box-shadow:0 22px 60px rgba(0,0,0,.34)}}" +
    ".bar{{position:absolute;display:grid;grid-template-columns:12px 12px 12px 18px minmax(64px,.8fr) minmax(96px,1fr) auto;gap:7px;align-items:center;background:linear-gradient(180deg,rgba(255,255,255,.18),rgba(255,255,255,.07));color:white;font:600 12px system-ui;padding:0 12px;box-sizing:border-box;overflow:hidden;border:1px solid rgba(255,255,255,.18);border-bottom:0;border-radius:18px 18px 0 0;backdrop-filter:blur(20px) saturate(170%);cursor:grab}}.bar:active{{cursor:grabbing}}.bar.focused{{box-shadow:0 0 0 1px rgba(96,165,250,.34),0 18px 46px rgba(37,99,235,.24);transform:translateY(-1px)}}.glass.focused{{box-shadow:0 0 0 1px rgba(96,165,250,.28),0 30px 90px rgba(37,99,235,.22),0 22px 60px rgba(0,0,0,.34)}}" +
    ".traffic{{position:relative;width:12px;height:12px;border:0;padding:0;border-radius:999px;color:transparent;cursor:pointer;box-shadow:inset 0 0 0 1px rgba(0,0,0,.18),0 1px 4px rgba(0,0,0,.24);transition:transform 120ms ease,filter 120ms ease}}.traffic::before{{content:'';position:absolute;inset:-8px;border-radius:999px}}.traffic:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:3px}}.traffic:hover{{transform:scale(1.08);filter:brightness(1.06)}}.traffic-close{{background:#ff5f57}}.traffic-min{{background:#ffbd2e}}.traffic-max{{background:#28c840}}" +
    ".bar-icon{{width:18px;height:18px;font-size:10px}}.bar-title{{min-width:0;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}.bar-command-input{{min-width:140px;width:100%;height:22px;border-radius:999px;padding:0 10px;box-sizing:border-box;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:#dbeafe;font:600 11px system-ui;outline:none;overflow:hidden;text-overflow:ellipsis}}.bar-command-input:focus{{border-color:rgba(96,165,250,.72);box-shadow:0 0 0 3px rgba(96,165,250,.18)}}.bar-context{{height:22px;border-radius:999px;padding:0 10px;display:flex;align-items:center;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.10);color:#cbd5e1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}" +
    ".resize-handle{{position:absolute;border:0;padding:0;background:transparent;color:transparent;z-index:3}}.resize-handle::before{{content:'';position:absolute;inset:-16px;border-radius:999px}}.resize-handle:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:3px}}.resize-east{{right:-4px;top:18px;width:8px;height:calc(100% - 36px);cursor:ew-resize}}.resize-west{{left:-4px;top:18px;width:8px;height:calc(100% - 36px);cursor:ew-resize}}.resize-south{{left:18px;right:18px;bottom:-4px;height:8px;cursor:ns-resize}}.resize-south-east{{right:2px;bottom:2px;width:16px;height:16px;border-radius:999px;background:rgba(96,165,250,.42);box-shadow:0 0 0 1px rgba(255,255,255,.26) inset;cursor:nwse-resize}}" +
    ".round-icon{{border-radius:999px;display:inline-grid;place-items:center;overflow:hidden;background:linear-gradient(135deg,#2563eb,rgba(255,255,255,.22));color:white;font-weight:800;box-shadow:inset 0 1px 0 rgba(255,255,255,.22),0 2px 8px rgba(0,0,0,.22);clip-path:circle(50% at 50% 50%)}}.round-icon.icon-normalized-square .icon-image-placeholder{{width:100%;height:100%;border-radius:inherit;background:linear-gradient(135deg,rgba(255,255,255,.28),rgba(37,99,235,.72));object-fit:cover}}.round-icon .icon-glyph{{line-height:1}}" +
    ".wm-scrollable,.glass,.window-overview,.control-center,.command-palette,.app-launcher{{scrollbar-width:thin;scrollbar-color:rgba(96,165,250,.58) transparent}}.wm-scrollable::-webkit-scrollbar,.glass::-webkit-scrollbar,.window-overview::-webkit-scrollbar,.control-center::-webkit-scrollbar,.command-palette::-webkit-scrollbar,.app-launcher::-webkit-scrollbar{{width:10px;height:10px}}.wm-scrollable::-webkit-scrollbar-track,.glass::-webkit-scrollbar-track,.window-overview::-webkit-scrollbar-track,.control-center::-webkit-scrollbar-track,.command-palette::-webkit-scrollbar-track,.app-launcher::-webkit-scrollbar-track{{background:transparent}}.wm-scrollable::-webkit-scrollbar-thumb,.glass::-webkit-scrollbar-thumb,.window-overview::-webkit-scrollbar-thumb,.control-center::-webkit-scrollbar-thumb,.command-palette::-webkit-scrollbar-thumb,.app-launcher::-webkit-scrollbar-thumb{{background:linear-gradient(180deg,rgba(96,165,250,.62),rgba(255,255,255,.18));border:3px solid transparent;background-clip:padding-box;border-radius:999px}}.wm-scrollable::-webkit-scrollbar-thumb:hover{{background:#2563eb}}" +
    ".motion-window{{position:absolute;border-radius:18px;background:linear-gradient(180deg,rgba(255,255,255,.18),rgba(255,255,255,.06));border:1px solid rgba(255,255,255,.16);backdrop-filter:blur(18px) saturate(170%);box-shadow:0 22px 60px rgba(0,0,0,.34);overflow:hidden;transform-origin:center bottom}}.motion-title{{position:absolute;left:14px;top:10px;color:white;font:600 12px system-ui}}.wm-window-opening{{animation:wm-window-open 240ms cubic-bezier(.2,.8,.2,1) both}}.wm-window-restoring{{animation:wm-window-restore 240ms cubic-bezier(.2,.8,.2,1) both}}.wm-window-closing{{animation:wm-window-close 180ms cubic-bezier(.4,0,.2,1) both}}.wm-window-minimizing{{animation:wm-window-minimize 180ms cubic-bezier(.4,0,.2,1) both}}.wm-window-focused{{box-shadow:0 24px 70px rgba(37,99,235,.32)}}" +
    ".label{{position:absolute;color:white;font:600 12px system-ui;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}" +
    ".command-lane{{position:absolute;background:linear-gradient(180deg,rgba(255,255,255,.10),rgba(255,255,255,.04));border-bottom:1px solid rgba(255,255,255,.10);backdrop-filter:blur(18px)}}" +
    ".command-clock{{position:absolute;color:white;font:600 12px system-ui;display:flex;align-items:center;justify-content:center}}" +
    ".command-icon{{position:absolute;display:grid;place-items:center}}.command-round-icon{{width:18px;height:18px;font-size:9px}}" +
    ".taskbar{{position:absolute;background:linear-gradient(180deg,rgba(255,255,255,.16),rgba(255,255,255,.06));border:1px solid rgba(255,255,255,.16);border-radius:999px;box-shadow:0 18px 48px rgba(0,0,0,.30);backdrop-filter:blur(24px) saturate(170%)}}" +
    ".taskbar-launcher,.taskbar-running{{position:absolute;border:0;color:white;font:600 11px system-ui;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;border-radius:999px;display:grid;place-items:center;gap:2px;padding:4px;transition:transform 160ms ease,filter 160ms ease,box-shadow 160ms ease}}" +
    ".taskbar-round-icon{{width:26px;height:26px;font-size:11px}}" +
    ".taskbar-launcher{{background:#2563eb}}.taskbar-running{{background:#475569}}.taskbar-launcher:hover,.taskbar-running:hover{{transform:translateY(-6px) scale(1.18);filter:brightness(1.12);box-shadow:0 16px 34px rgba(37,99,235,.32)}}.taskbar-launcher:hover + .taskbar-launcher,.taskbar-launcher:hover + .taskbar-running,.taskbar-running:hover + .taskbar-launcher,.taskbar-running:hover + .taskbar-running{{transform:translateY(-2px) scale(1.07)}}.taskbar-launcher:focus-visible,.taskbar-running:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:3px;transform:translateY(-6px) scale(1.18)}}.taskbar-running-indicator{{position:absolute;left:50%;bottom:4px;width:18px;height:3px;border-radius:999px;background:#60a5fa;transform:translateX(-50%);animation:wm-taskbar-indicator 1200ms ease-in-out infinite}}" +
    ".desktop-widgets{{position:absolute;display:grid;gap:8px;max-width:260px;pointer-events:none;animation:wm-widget-float 240ms cubic-bezier(.2,.8,.2,1) both}}.desktop-widget{{border-radius:14px;background:linear-gradient(180deg,rgba(255,255,255,.14),rgba(255,255,255,.06));border:1px solid rgba(255,255,255,.14);box-shadow:0 14px 34px rgba(0,0,0,.22);backdrop-filter:blur(20px) saturate(170%);color:white;font:600 12px system-ui;padding:8px 10px;display:flex;align-items:center;justify-content:space-between;min-height:26px}}" +
    ".command-palette{{position:absolute;display:grid;gap:10px;max-width:680px;border-radius:22px;background:linear-gradient(180deg,rgba(2,6,23,.92),rgba(15,23,42,.74));border:1px solid rgba(255,255,255,.16);box-shadow:0 30px 90px rgba(0,0,0,.44);backdrop-filter:blur(28px) saturate(170%);padding:14px;box-sizing:border-box;animation:wm-command-in 160ms cubic-bezier(.2,.8,.2,1) both}}.command-palette-input{{width:100%;height:44px;border-radius:14px;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.08);color:white;font:600 13px system-ui;padding:0 12px;box-sizing:border-box}}.command-palette-list{{display:grid;gap:8px;overflow:auto}}.command-palette-item{{min-height:44px;border:1px solid rgba(255,255,255,.12);border-radius:14px;background:rgba(255,255,255,.07);color:white;font:600 12px system-ui;display:grid;grid-template-columns:28px 1fr auto;align-items:center;gap:10px;padding:8px 10px;text-align:left}}.command-palette-item.active{{box-shadow:0 0 0 2px rgba(37,99,235,.56)}}.command-palette-icon{{width:28px;height:28px;font-size:11px}}.command-palette-item kbd{{border-radius:8px;background:rgba(255,255,255,.10);padding:3px 7px;color:#cbd5e1}}" +
    ".control-center{{position:absolute;display:grid;grid-template-columns:1fr 1fr;gap:8px;max-width:320px;border-radius:18px;background:linear-gradient(180deg,rgba(15,23,42,.88),rgba(15,23,42,.68));border:1px solid rgba(255,255,255,.16);box-shadow:0 22px 70px rgba(0,0,0,.36);backdrop-filter:blur(24px) saturate(170%);padding:12px;box-sizing:border-box;animation:wm-control-in 180ms cubic-bezier(.2,.8,.2,1) both}}.control-center button{{min-height:44px;border:1px solid rgba(255,255,255,.12);border-radius:12px;background:rgba(255,255,255,.08);color:white;font:600 11px system-ui}}.accent-controls{{grid-column:1 / -1;min-height:44px;border-radius:14px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;padding:7px;box-sizing:border-box}}.accent-swatch{{min-height:30px;border-radius:999px;border:1px solid rgba(255,255,255,.20);box-shadow:inset 0 1px 0 rgba(255,255,255,.24);padding:0}}.accent-swatch[data-accent-choice='blue']{{background:#2563eb}}.accent-swatch[data-accent-choice='teal']{{background:#14b8a6}}.accent-swatch[data-accent-choice='rose']{{background:#e11d48}}.accent-swatch.active{{outline:2px solid rgba(255,255,255,.72);outline-offset:2px}}.accent-swatch:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:3px}}" +
    ".window-overview{{position:absolute;border-radius:22px;background:rgba(2,6,23,.66);border:1px solid rgba(255,255,255,.14);box-shadow:0 30px 90px rgba(0,0,0,.42);backdrop-filter:blur(28px) saturate(160%);padding:18px;box-sizing:border-box;animation:wm-overview-in 200ms cubic-bezier(.2,.8,.2,1) both}}.overview-grid{{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px}}.overview-card{{min-height:112px;border:1px solid rgba(255,255,255,.16);border-radius:16px;background:linear-gradient(180deg,rgba(255,255,255,.14),rgba(255,255,255,.06));color:white;text-align:left;padding:12px;display:grid;gap:8px}}.overview-card.active{{box-shadow:0 0 0 2px rgba(37,99,235,.55)}}.overview-icon{{width:28px;height:28px;border-radius:999px;display:grid;place-items:center;background:#2563eb}}.overview-title,.overview-meta{{overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}" +
    ".snap-preview{{position:absolute;border-radius:20px;border:1px solid rgba(96,165,250,.72);background:rgba(37,99,235,.18);box-shadow:0 0 0 1px rgba(255,255,255,.10) inset,0 18px 48px rgba(37,99,235,.22);pointer-events:none;animation:wm-snap-pulse 900ms ease-in-out infinite}}" +
    ".snap-layouts{{position:absolute;display:grid;grid-template-rows:auto 1fr;gap:10px;max-width:360px;border-radius:18px;background:linear-gradient(180deg,rgba(2,6,23,.92),rgba(15,23,42,.72));border:1px solid rgba(255,255,255,.16);box-shadow:0 24px 72px rgba(0,0,0,.40);backdrop-filter:blur(24px) saturate(170%);padding:12px;box-sizing:border-box;color:white;animation:wm-snap-layouts-in 150ms cubic-bezier(.2,.8,.2,1) both}}.snap-layouts-header{{display:flex;align-items:center;justify-content:space-between;gap:10px;font:800 12px system-ui}}.snap-layouts-header span{{border-radius:999px;background:rgba(96,165,250,.18);border:1px solid rgba(96,165,250,.24);padding:3px 8px;color:#dbeafe;font:700 10px system-ui;white-space:nowrap}}.snap-layout-grid{{display:grid;grid-template-columns:1fr 1fr;gap:8px}}.snap-layout-option{{min-height:50px;border:1px solid rgba(255,255,255,.12);border-radius:14px;background:rgba(255,255,255,.07);color:white;font:700 11px system-ui;display:grid;grid-template-columns:42px 1fr;align-items:center;gap:8px;padding:7px;text-align:left}}.snap-layout-option.active{{box-shadow:0 0 0 2px rgba(37,99,235,.56);background:rgba(37,99,235,.24)}}.snap-layout-option:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:2px}}.snap-layout-diagram{{height:30px;border-radius:8px;border:1px solid rgba(255,255,255,.18);background:rgba(15,23,42,.78);box-shadow:inset 0 0 0 1px rgba(96,165,250,.12)}}.snap-layout-diagram.split-left{{background:linear-gradient(90deg,rgba(96,165,250,.82) 0 48%,rgba(255,255,255,.10) 48% 100%)}}.snap-layout-diagram.split-right{{background:linear-gradient(90deg,rgba(255,255,255,.10) 0 52%,rgba(96,165,250,.82) 52% 100%)}}.snap-layout-diagram.fullscreen{{background:rgba(96,165,250,.82)}}.snap-layout-diagram.quarter-grid{{background:linear-gradient(90deg,rgba(96,165,250,.82) 0 48%,rgba(255,255,255,.10) 48% 52%,rgba(96,165,250,.46) 52% 100%)}}" +
    ".window-switcher{{position:absolute;display:grid;grid-template-rows:auto 1fr;gap:10px;max-width:460px;border-radius:20px;background:linear-gradient(180deg,rgba(2,6,23,.92),rgba(15,23,42,.72));border:1px solid rgba(255,255,255,.16);box-shadow:0 28px 82px rgba(0,0,0,.44);backdrop-filter:blur(28px) saturate(170%);padding:12px;box-sizing:border-box;color:white;animation:wm-switcher-in 150ms cubic-bezier(.2,.8,.2,1) both}}.window-switcher-header{{display:flex;align-items:center;justify-content:space-between;gap:10px;font:800 12px system-ui}}.window-switcher-header kbd,.window-switcher-item kbd{{border-radius:999px;background:rgba(96,165,250,.18);border:1px solid rgba(96,165,250,.24);padding:3px 8px;color:#dbeafe;font:700 10px system-ui;white-space:nowrap}}.window-switcher-list{{display:grid;grid-template-columns:repeat(3,1fr);gap:9px}}.window-switcher-item{{min-height:66px;border:1px solid rgba(255,255,255,.12);border-radius:16px;background:rgba(255,255,255,.07);color:white;font:700 11px system-ui;display:grid;grid-template-rows:32px auto auto;place-items:center;gap:4px;padding:8px;overflow:hidden}}.window-switcher-item span{{max-width:100%;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}.window-switcher-item.active{{box-shadow:0 0 0 2px rgba(96,165,250,.58);background:rgba(37,99,235,.28)}}.window-switcher-item:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:2px}}.window-switcher-icon{{width:32px;height:32px;font-size:12px}}" +
    ".quick-settings{{position:absolute;display:grid;grid-template-rows:auto 1fr;gap:10px;max-width:300px;border-radius:20px;background:linear-gradient(180deg,rgba(2,6,23,.92),rgba(15,23,42,.70));border:1px solid rgba(255,255,255,.16);box-shadow:0 26px 76px rgba(0,0,0,.42);backdrop-filter:blur(28px) saturate(170%);padding:12px;box-sizing:border-box;color:white;animation:wm-quick-settings-in 150ms cubic-bezier(.2,.8,.2,1) both}}.quick-settings-header{{display:flex;align-items:center;justify-content:space-between;gap:10px;font:800 12px system-ui}}.quick-settings-header span{{border-radius:999px;background:rgba(255,255,255,.09);padding:3px 8px;color:#cbd5e1;font:700 10px system-ui}}.quick-settings-grid{{display:grid;grid-template-columns:1fr 1fr;gap:8px}}.quick-setting-tile{{min-height:58px;border:1px solid rgba(255,255,255,.12);border-radius:16px;background:rgba(255,255,255,.07);color:white;font:700 11px system-ui;display:grid;grid-template-columns:30px 1fr;grid-template-rows:auto auto;align-items:center;column-gap:8px;padding:8px;text-align:left;overflow:hidden}}.quick-setting-tile .quick-setting-icon{{grid-row:1 / 3;width:30px;height:30px;font-size:11px}}.quick-setting-tile span,.quick-setting-tile em{{overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}.quick-setting-tile em{{font-style:normal;color:#cbd5e1;font:700 10px system-ui}}.quick-setting-tile.active{{background:rgba(37,99,235,.26);box-shadow:0 0 0 2px rgba(96,165,250,.42)}}.quick-setting-tile:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:2px}}" +
    ".notification-center{{position:absolute;display:grid;grid-template-rows:auto 1fr;gap:10px;max-width:340px;border-radius:22px;background:linear-gradient(180deg,rgba(2,6,23,.92),rgba(15,23,42,.70));border:1px solid rgba(255,255,255,.16);box-shadow:0 28px 84px rgba(0,0,0,.44);backdrop-filter:blur(28px) saturate(170%);padding:12px;box-sizing:border-box;color:white;animation:wm-notification-center-in 170ms cubic-bezier(.2,.8,.2,1) both}}.notification-center-header{{display:flex;align-items:center;justify-content:space-between;gap:10px;font:800 12px system-ui}}.notification-clear{{min-height:30px;border-radius:999px;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.08);color:white;font:800 10px system-ui;padding:0 10px}}.notification-list{{display:grid;gap:8px;overflow:auto}}.notification-card{{min-height:48px;border:1px solid rgba(255,255,255,.12);border-radius:16px;background:rgba(255,255,255,.07);display:grid;grid-template-columns:32px 1fr auto;align-items:center;gap:8px;padding:8px;box-sizing:border-box}}.notification-card.unread{{background:rgba(37,99,235,.24);box-shadow:inset 3px 0 0 rgba(96,165,250,.78)}}.notification-card-icon{{width:32px;height:32px;font-size:11px}}.notification-card div{{min-width:0;display:grid;gap:2px}}.notification-card strong,.notification-card span{{overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}.notification-card strong{{font:800 11px system-ui}}.notification-card span,.notification-card time{{color:#cbd5e1;font:700 10px system-ui}}.notification-clear:focus-visible,.notification-card:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:2px}}" +
    ".live-activity{{position:absolute;display:grid;grid-template-columns:34px 1fr auto auto;align-items:center;gap:9px;max-width:420px;border-radius:999px;background:linear-gradient(180deg,rgba(2,6,23,.92),rgba(15,23,42,.72));border:1px solid rgba(255,255,255,.16);box-shadow:0 22px 64px rgba(0,0,0,.38);backdrop-filter:blur(24px) saturate(170%);padding:7px 9px;box-sizing:border-box;color:white;animation:wm-live-activity-in 150ms cubic-bezier(.2,.8,.2,1) both}}.live-activity-icon{{width:34px;height:34px;font-size:11px}}.live-activity-copy{{min-width:0;display:grid;gap:2px}}.live-activity-copy strong,.live-activity-copy span{{overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}.live-activity-copy strong{{font:800 11px system-ui}}.live-activity-copy span{{color:#cbd5e1;font:700 10px system-ui}}.live-activity-progress{{height:4px;border-radius:999px;background:rgba(255,255,255,.10);overflow:hidden}}.live-activity-progress span{{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,#60a5fa,#14b8a6);animation:wm-live-activity-progress 1400ms ease-in-out infinite}}.live-activity-action{{min-height:32px;border-radius:999px;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.08);color:white;font:800 10px system-ui;padding:0 10px}}.live-activity-action.danger{{color:#fecaca;background:rgba(244,63,94,.14)}}.live-activity-action:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:2px}}" +
    ".notification-toast{{position:absolute;display:grid;grid-template-columns:32px 1fr auto;align-items:center;gap:10px;max-width:360px;min-height:72px;border-radius:18px;background:linear-gradient(180deg,rgba(15,23,42,.92),rgba(15,23,42,.72));border:1px solid rgba(255,255,255,.16);box-shadow:0 24px 70px rgba(0,0,0,.38);backdrop-filter:blur(24px) saturate(170%);padding:10px 12px;box-sizing:border-box;color:white;overflow:hidden;animation:wm-toast-in 180ms cubic-bezier(.2,.8,.2,1) both}}.toast-enter{{will-change:transform,opacity}}.toast-exit{{animation:wm-toast-out 140ms cubic-bezier(.4,0,.2,1) both}}.toast-round-icon{{width:32px;height:32px;font-size:12px}}.toast-copy{{min-width:0;display:grid;gap:2px;font:600 12px system-ui}}.toast-copy strong,.toast-copy span{{overflow:hidden;white-space:nowrap;text-overflow:ellipsis}}.toast-copy span{{color:#cbd5e1;font-weight:500}}.toast-action{{min-height:36px;border:1px solid rgba(255,255,255,.14);border-radius:12px;background:rgba(255,255,255,.08);color:white;font:700 11px system-ui;padding:0 10px}}.toast-action:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:3px}}.toast-progress{{position:absolute;left:12px;right:12px;bottom:7px;height:3px;border-radius:999px;background:linear-gradient(90deg,#60a5fa,rgba(96,165,250,.16));transform-origin:left center;animation:wm-toast-progress 4200ms linear both}}" +
    ".workspace-switcher{{position:absolute;display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;max-width:360px;border-radius:999px;background:linear-gradient(180deg,rgba(15,23,42,.84),rgba(15,23,42,.62));border:1px solid rgba(255,255,255,.16);box-shadow:0 18px 48px rgba(0,0,0,.32);backdrop-filter:blur(24px) saturate(170%);padding:6px;box-sizing:border-box;animation:wm-workspace-in 180ms cubic-bezier(.2,.8,.2,1) both}}.workspace-active-pill{{position:absolute;left:6px;top:6px;width:calc((100% - 24px) / 3);height:calc(100% - 12px);border-radius:999px;background:rgba(37,99,235,.72);box-shadow:0 8px 22px rgba(37,99,235,.28);animation:wm-workspace-slide 220ms cubic-bezier(.2,.8,.2,1) both}}.workspace-tab{{position:relative;z-index:1;min-height:40px;border:0;border-radius:999px;background:transparent;color:white;font:700 12px system-ui;display:grid;place-items:center;gap:1px}}.workspace-tab kbd{{font:600 9px system-ui;color:#cbd5e1}}.workspace-tab:focus-visible{{outline:2px solid rgba(96,165,250,.82);outline-offset:3px}}.workspace-tab.active kbd{{color:#dbeafe}}" +
