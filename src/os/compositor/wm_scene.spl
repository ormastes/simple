fn modern_wm_scene_theme_config() -> WmSceneModernThemeConfig:
    WmSceneModernThemeConfig(
        background_color: 0xFF0F172Au32,
        foreground_color: 0xFFFFFFFFu32,
        accent_color: 0xFF2563EBu32,
        titlebar_height_px: 32,
        command_lane_height_px: 32,
        taskbar_height_px: 56,
        window_radius_px: 18,
        widget_radius_px: 14,
        taskbar_radius_px: 999,
        control_radius_px: 12,
        icon_radius_px: 999,
        scrollbar_width_px: 10,
        scrollbar_thumb_radius_px: 999,
        scrollbar_thumb_border_px: 3,
        blur_px: 24,
        desktop_layer_z: 0,
        snap_layer_z: 15,
        window_layer_z: 20,
        overlay_layer_z: 11000,
        standard_motion_ms: 240,
        reduced_motion_ms: 80,
        can_disable_motion: true
    )

fn wm_scene_icon_kind(icon: text) -> text:
    if icon.starts_with("/") or icon.starts_with("data:") or icon.starts_with("http://") or icon.starts_with("https://"):
        return "square-to-round"
    "glyph-to-round"

fn _wm_min_i32(a: i32, b: i32) -> i32:
    if a < b: a else: b

fn _wm_max_i32(a: i32, b: i32) -> i32:
    if a > b: a else: b

fn _wm_fit_dim(available: i32, preferred: i32) -> i32:
    _wm_max_i32(0, _wm_min_i32(available, preferred))

fn standard_wm_scene(width: i32, height: i32) -> WmSceneSpec:
    val panel_w = if width > 180: width - 160 else: width
    val panel_h = if height > 160: height - 140 else: height
    WmSceneSpec(
        name: "standard_wm_scene",
        width: width,
        height: height,
        elements: [
            SceneElement(kind: "desktop_chrome", x: 0, y: 0, w: width, h: height, color: 0xFF0F172Au32, text: ""),
            SceneElement(kind: "decoration", x: 48, y: 42, w: panel_w, h: 34, color: 0xFF334155u32, text: ""),
            SceneElement(kind: "glass_panel", x: 48, y: 76, w: panel_w, h: panel_h, color: 0xCCCBD5E1u32, text: ""),
            SceneElement(kind: "text_label", x: 68, y: 60, w: 180, h: 20, color: 0xFFFFFFFFu32, text: "Simple Web WM")
        ]
    )

fn shared_wm_scene_to_wm_scene(scene: SharedWmScene) -> WmSceneSpec:
    var elements: [SceneElement] = [
        SceneElement(kind: "desktop_chrome", x: 0, y: 0, w: scene.width, h: scene.height, color: 0xFF0F172Au32, text: "")
    ]
    for window in scene.windows:
        if not window.minimized:
            elements = elements.push(SceneElement(
                kind: "decoration",
                x: window.x,
                y: window.y,
                w: window.width,
                h: 32,
                color: 0xFF334155u32,
                text: if window.focused: "{window.title}|focused" else: "{window.title}|idle"
            ))
            elements = elements.push(SceneElement(
                kind: "glass_panel",
                x: window.x,
                y: window.y + 32,
                w: window.width,
                h: window.height - 32,
                color: 0xCCCBD5E1u32,
                text: if window.focused: "{window.surface_id}|focused" else: "{window.surface_id}|idle"
            ))
            elements = elements.push(SceneElement(
                kind: "text_label",
                x: window.x + 12,
                y: window.y + 9,
                w: window.width - 24,
                h: 16,
                color: 0xFFFFFFFFu32,
                text: window.title
            ))
    WmSceneSpec(name: "shared_wm_scene", width: scene.width, height: scene.height, elements: elements)

fn lifecycle_windows_to_motion_wm_scene(windows: [WmLifecycleWindowState], action_kind: text, width: i32, height: i32) -> WmSceneSpec:
    var elements: [SceneElement] = [
        SceneElement(kind: "desktop_chrome", x: 0, y: 0, w: width, h: height, color: 0xFF0F172Au32, text: "")
    ]
    for window in windows:
        val motion = wm_lifecycle_motion_contract(action_kind, window)
        if not window.minimized or motion.phase == "minimizing" or motion.phase == "closing":
            elements = elements.push(SceneElement(
                kind: "motion_window",
                x: window.x,
                y: window.y,
                w: window.w,
                h: window.h,
                color: 0xCCCBD5E1u32,
                text: "{window.title}|{motion.phase}|{motion.class_name}|{motion.duration_ms}|{motion.reduced_duration_ms}|{motion.can_disable}"
            ))
    WmSceneSpec(name: "lifecycle_motion_wm_scene", width: width, height: height, elements: elements)

fn shared_wm_scene_to_chromed_wm_scene(scene: SharedWmScene, taskbar: TaskbarModel, dpi_scale_milli: i32, clock_label: text, right_icon_count: i32) -> WmSceneSpec:
    val chrome = shared_wm_scene_chrome(scene, dpi_scale_milli, clock_label, right_icon_count, taskbar.pinned.len() + taskbar.running.len())
    var clock_x = scene.width - (right_icon_count * 32) - 72
    if clock_x < 0:
        clock_x = 0
    val side_panel_y = _wm_min_i32(chrome.command_lane.height + 16, _wm_max_i32(0, scene.height - 1))
    val side_panel_available_w = _wm_max_i32(0, scene.width - 32)
    val side_panel_available_h = _wm_max_i32(0, scene.height - side_panel_y - 16)
    val widget_w = _wm_fit_dim(side_panel_available_w, 260)
    val widget_h = _wm_fit_dim(side_panel_available_h, 116)
    val widget_x = _wm_max_i32(0, scene.width - widget_w - 16)
    val control_w = _wm_fit_dim(side_panel_available_w, 320)
    val control_h = _wm_fit_dim(side_panel_available_h, 164)
    val control_x = _wm_max_i32(0, scene.width - control_w - 16)
    val palette_w = _wm_fit_dim(side_panel_available_w, 680)
    val palette_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 220)
    val palette_x = _wm_max_i32(0, (scene.width - palette_w) / 2)
    val palette_y = _wm_min_i32(chrome.command_lane.height + 12, _wm_max_i32(0, scene.height - 1))
    val overview_x = if scene.width > 80: 40 else: 0
    val overview_y = if scene.height > 160: 72 else: _wm_min_i32(chrome.command_lane.height + 4, _wm_max_i32(0, scene.height - 1))
    val overview_w = _wm_fit_dim(scene.width - (overview_x * 2), scene.width)
    val overview_h = _wm_fit_dim(scene.height - overview_y - chrome.taskbar.height - 8, scene.height)
    val snap_x = _wm_min_i32(scene.width / 2 + 6, _wm_max_i32(0, scene.width - 1))
    val snap_y = _wm_min_i32(chrome.command_lane.height + 10, _wm_max_i32(0, scene.height - 1))
    val snap_w = _wm_fit_dim(scene.width - snap_x - 10, scene.width / 2 - 16)
    val snap_h = _wm_fit_dim(scene.height - snap_y - chrome.taskbar.height - 10, scene.height)
    val snap_layouts_w = _wm_fit_dim(side_panel_available_w, 360)
    val snap_layouts_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 148)
    val snap_layouts_x = _wm_min_i32(_wm_max_i32(16, scene.width / 2 - 92), _wm_max_i32(0, scene.width - snap_layouts_w - 16))
    val snap_layouts_y = _wm_min_i32(chrome.command_lane.height + 42, _wm_max_i32(0, chrome.taskbar.y - snap_layouts_h - 12))
    val switcher_w = _wm_fit_dim(side_panel_available_w, 460)
    val switcher_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 118)
    val switcher_x = _wm_max_i32(0, (scene.width - switcher_w) / 2)
    val switcher_y = _wm_min_i32(chrome.command_lane.height + 96, _wm_max_i32(0, chrome.taskbar.y - switcher_h - 12))
    val quick_settings_w = _wm_fit_dim(side_panel_available_w, 300)
    val quick_settings_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 168)
    val quick_settings_x = _wm_max_i32(0, scene.width - quick_settings_w - 12)
    val quick_settings_y = _wm_min_i32(chrome.command_lane.height + 8, _wm_max_i32(0, chrome.taskbar.y - quick_settings_h - 12))
    val notification_center_w = _wm_fit_dim(side_panel_available_w, 340)
    val notification_center_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 220)
    val notification_center_x = _wm_max_i32(0, scene.width - notification_center_w - 16)
    val notification_center_y = _wm_min_i32(quick_settings_y + quick_settings_h + 12, _wm_max_i32(0, chrome.taskbar.y - notification_center_h - 12))
    val live_activity_w = _wm_fit_dim(side_panel_available_w, 420)
    val live_activity_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 58)
    val live_activity_x = _wm_max_i32(0, (scene.width - live_activity_w) / 2)
    val live_activity_y = chrome.command_lane.height + 8
    val toast_w = _wm_fit_dim(side_panel_available_w, 360)
    val toast_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 32), 88)
    val toast_x = _wm_max_i32(0, scene.width - toast_w - 16)
    val toast_y = _wm_min_i32(side_panel_y + control_h + 12, _wm_max_i32(0, scene.height - toast_h - chrome.taskbar.height - 8))
    val workspace_w = _wm_fit_dim(side_panel_available_w, 360)
    val workspace_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 16), 52)
    val workspace_x = _wm_max_i32(0, (scene.width - workspace_w) / 2)
    val workspace_y = _wm_max_i32(chrome.command_lane.height + 8, chrome.taskbar.y - workspace_h - 12)
    val shortcut_w = _wm_fit_dim(side_panel_available_w, 420)
    val shortcut_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 188)
    val shortcut_x = _wm_max_i32(0, (scene.width - shortcut_w) / 2)
    val shortcut_y = _wm_min_i32(palette_y + palette_h + 12, _wm_max_i32(0, chrome.taskbar.y - shortcut_h - 8))
    val launcher_w = _wm_fit_dim(side_panel_available_w, 520)
    val launcher_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 260)
    val launcher_x = _wm_max_i32(0, (scene.width - launcher_w) / 2)
    val launcher_y = _wm_min_i32(chrome.command_lane.height + 44, _wm_max_i32(0, chrome.taskbar.y - launcher_h - 16))
    val context_w = _wm_fit_dim(side_panel_available_w, 280)
    val context_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 172)
    val context_x = _wm_min_i32(_wm_max_i32(16, scene.width / 2 - 120), _wm_max_i32(0, scene.width - context_w - 16))
    val context_y = _wm_min_i32(chrome.command_lane.height + 74, _wm_max_i32(0, chrome.taskbar.y - context_h - 12))
    val resize_hud_w = _wm_fit_dim(side_panel_available_w, 240)
    val resize_hud_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 64)
    val resize_hud_x = _wm_max_i32(0, (scene.width - resize_hud_w) / 2)
    val resize_hud_y = _wm_max_i32(chrome.command_lane.height + 8, chrome.taskbar.y - resize_hud_h - 76)
    val gesture_w = _wm_fit_dim(side_panel_available_w, 360)
    val gesture_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 118)
    val gesture_x = _wm_max_i32(0, scene.width - gesture_w - 16)
    val gesture_y = _wm_min_i32(side_panel_y + widget_h + 12, _wm_max_i32(0, chrome.taskbar.y - gesture_h - 16))
    val preview_w = _wm_fit_dim(side_panel_available_w, 320)
    val preview_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 132)
    val preview_x = _wm_max_i32(0, (scene.width - preview_w) / 2)
    val preview_y = _wm_max_i32(chrome.command_lane.height + 8, chrome.taskbar.y - preview_h - 12)
    val stage_rail_w = _wm_fit_dim(side_panel_available_w, 88)
    val stage_rail_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 220)
    val stage_rail_x = 16
    val stage_rail_y = _wm_min_i32(chrome.command_lane.height + 76, _wm_max_i32(chrome.command_lane.height + 8, chrome.taskbar.y - stage_rail_h - 16))
    val capture_w = _wm_fit_dim(side_panel_available_w, 560)
    val capture_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 240)
    val capture_x = _wm_max_i32(0, (scene.width - capture_w) / 2)
    val capture_y = _wm_min_i32(chrome.command_lane.height + 110, _wm_max_i32(0, chrome.taskbar.y - capture_h - 20))
    val clipboard_w = _wm_fit_dim(side_panel_available_w, 360)
    val clipboard_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 236)
    val clipboard_x = _wm_max_i32(0, scene.width - clipboard_w - 20)
    val clipboard_y = _wm_min_i32(chrome.command_lane.height + 62, _wm_max_i32(0, chrome.taskbar.y - clipboard_h - 20))
    val privacy_w = _wm_fit_dim(side_panel_available_w, 300)
    val privacy_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 112)
    val privacy_x = _wm_max_i32(0, scene.width - privacy_w - 56)
    val privacy_y = chrome.command_lane.height + 8
    val system_hud_w = _wm_fit_dim(side_panel_available_w, 280)
    val system_hud_h = _wm_fit_dim(_wm_max_i32(0, scene.height - chrome.command_lane.height - chrome.taskbar.height - 24), 132)
    val system_hud_x = _wm_max_i32(0, (scene.width - system_hud_w) / 2)
    val system_hud_y = _wm_min_i32(chrome.command_lane.height + 128, _wm_max_i32(0, chrome.taskbar.y - system_hud_h - 96))
    var elements: [SceneElement] = [
        SceneElement(kind: "desktop_chrome", x: 0, y: 0, w: scene.width, h: scene.height, color: 0xFF101418u32, text: ""),
        SceneElement(kind: "command_lane", x: chrome.command_lane.x, y: chrome.command_lane.y, w: chrome.command_lane.width, h: chrome.command_lane.height, color: 0xFF111827u32, text: ""),
        SceneElement(kind: "command_clock", x: clock_x, y: chrome.command_lane.y, w: 72, h: chrome.command_lane.height, color: 0xFFFFFFFFu32, text: clock_label),
        SceneElement(kind: "taskbar", x: chrome.taskbar.x, y: chrome.taskbar.y, w: chrome.taskbar.width, h: chrome.taskbar.height, color: 0xCC111827u32, text: ""),
        SceneElement(kind: "command_palette", x: palette_x, y: palette_y, w: palette_w, h: palette_h, color: 0xEE020617u32, text: "Run command|Open Simple IDE|Show window overview"),
        SceneElement(kind: "desktop_widgets", x: widget_x, y: side_panel_y, w: widget_w, h: widget_h, color: 0xCC111827u32, text: "Clock|Motion|Workspace"),
        SceneElement(kind: "control_center", x: control_x, y: side_panel_y, w: control_w, h: control_h, color: 0xDD111827u32, text: "Motion|Widgets|Overview"),
        SceneElement(kind: "window_overview", x: overview_x, y: overview_y, w: overview_w, h: overview_h, color: 0xDD020617u32, text: "Window overview"),
        SceneElement(kind: "snap_preview", x: snap_x, y: snap_y, w: snap_w, h: snap_h, color: 0x552563EBu32, text: "right"),
        SceneElement(kind: "snap_layouts", x: snap_layouts_x, y: snap_layouts_y, w: snap_layouts_w, h: snap_layouts_h, color: 0xEE020617u32, text: "Left half|Right half|Fullscreen|Quarter grid"),
        SceneElement(kind: "window_switcher", x: switcher_x, y: switcher_y, w: switcher_w, h: switcher_h, color: 0xEE020617u32, text: "Terminal|Browser|Settings"),
        SceneElement(kind: "quick_settings", x: quick_settings_x, y: quick_settings_y, w: quick_settings_w, h: quick_settings_h, color: 0xEE020617u32, text: "Wi-Fi|Audio|Battery|Brightness"),
        SceneElement(kind: "notification_center", x: notification_center_x, y: notification_center_y, w: notification_center_w, h: notification_center_h, color: 0xEE020617u32, text: "Window snapped|Build finished|Calendar"),
        SceneElement(kind: "live_activity", x: live_activity_x, y: live_activity_y, w: live_activity_w, h: live_activity_h, color: 0xEE020617u32, text: "Build indexing|72|Pause|Cancel"),
        SceneElement(kind: "notification_toast", x: toast_x, y: toast_y, w: toast_w, h: toast_h, color: 0xEE0F172Au32, text: "Window snapped|Right half|Undo"),
        SceneElement(kind: "workspace_switcher", x: workspace_x, y: workspace_y, w: workspace_w, h: workspace_h, color: 0xDD0F172Au32, text: "1|2|3"),
        SceneElement(kind: "shortcut_overlay", x: shortcut_x, y: shortcut_y, w: shortcut_w, h: shortcut_h, color: 0xEE020617u32, text: "Keyboard shortcuts"),
        SceneElement(kind: "app_launcher", x: launcher_x, y: launcher_y, w: launcher_w, h: launcher_h, color: 0xEE020617u32, text: "Terminal|Browser|Simple IDE|Settings"),
        SceneElement(kind: "context_menu", x: context_x, y: context_y, w: context_w, h: context_h, color: 0xEE020617u32, text: "Open|Pin to taskbar|Move to workspace|Close"),
        SceneElement(kind: "hot_corner_zone", x: 0, y: chrome.command_lane.height, w: 44, h: 44, color: 0x552563EBu32, text: "overview"),
        SceneElement(kind: "hot_corner_zone", x: _wm_max_i32(0, scene.width - 44), y: chrome.command_lane.height, w: 44, h: 44, color: 0x552563EBu32, text: "launcher"),
        SceneElement(kind: "hot_corner_zone", x: 0, y: _wm_max_i32(0, chrome.taskbar.y - 44), w: 44, h: 44, color: 0x552563EBu32, text: "desktop"),
        SceneElement(kind: "hot_corner_zone", x: _wm_max_i32(0, scene.width - 44), y: _wm_max_i32(0, chrome.taskbar.y - 44), w: 44, h: 44, color: 0x552563EBu32, text: "control-center"),
        SceneElement(kind: "resize_hud", x: resize_hud_x, y: resize_hud_y, w: resize_hud_w, h: resize_hud_h, color: 0xEE020617u32, text: "300 x 200|20,40|Snap ready"),
        SceneElement(kind: "gesture_hints", x: gesture_x, y: gesture_y, w: gesture_w, h: gesture_h, color: 0xDD0F172Au32, text: "Swipe up|Pinch out|Swipe left"),
        SceneElement(kind: "taskbar_preview", x: preview_x, y: preview_y, w: preview_w, h: preview_h, color: 0xEE020617u32, text: "Terminal|simple.terminal|win1"),
        SceneElement(kind: "stage_rail", x: stage_rail_x, y: stage_rail_y, w: stage_rail_w, h: stage_rail_h, color: 0xDD020617u32, text: "Terminal|Browser|Settings"),
        SceneElement(kind: "screen_capture_overlay", x: capture_x, y: capture_y, w: capture_w, h: capture_h, color: 0x99020617u32, text: "Selection|Window|Screen|Capture"),
        SceneElement(kind: "clipboard_history", x: clipboard_x, y: clipboard_y, w: clipboard_w, h: clipboard_h, color: 0xEE020617u32, text: "Command|Code|Link|Paste|Pin|Clear"),
        SceneElement(kind: "privacy_indicator", x: privacy_x, y: privacy_y, w: privacy_w, h: privacy_h, color: 0xEE020617u32, text: "Camera|Mic|Screen|Allow|Block"),
        SceneElement(kind: "system_hud", x: system_hud_x, y: system_hud_y, w: system_hud_w, h: system_hud_h, color: 0xEE020617u32, text: "Volume|Brightness|68|Mute")
    ]
    var icon_i = 0
    while icon_i < right_icon_count:
        var icon_x = scene.width - ((right_icon_count - icon_i) * 32)
        if icon_x < 0:
            icon_x = 0
        elements = elements.push(SceneElement(
            kind: "command_icon",
            x: icon_x,
            y: chrome.command_lane.y,
            w: 32,
            h: chrome.command_lane.height,
            color: 0xFFE5E7EBu32,
            text: "right_icon_{icon_i}"
        ))
        icon_i = icon_i + 1
    var pin_i = 0
    while pin_i < taskbar.pinned.len():
        val app = taskbar.pinned[pin_i]
        elements = elements.push(SceneElement(
            kind: "taskbar_launcher",
            x: pin_i * 56,
            y: chrome.taskbar.y,
            w: 56,
            h: chrome.taskbar.height,
            color: 0xFF2563EBu32,
            text: "{app.app_id}|{app.icon}"
        ))
        pin_i = pin_i + 1
    var run_i = 0
    while run_i < taskbar.running.len():
        val running = taskbar.running[run_i]
        elements = elements.push(SceneElement(
            kind: "taskbar_running",
            x: (taskbar.pinned.len() + run_i) * 56,
            y: chrome.taskbar.y,
            w: 56,
            h: chrome.taskbar.height,
            color: 0xFF475569u32,
            text: "{running.window_id}|{running.app_id}"
        ))
        run_i = run_i + 1
    val base = shared_wm_scene_to_wm_scene(scene)
    for elem in base.elements:
        if elem.kind != "desktop_chrome":
            elements = elements.push(elem)
    WmSceneSpec(name: "shared_wm_chromed_scene", width: scene.width, height: scene.height, elements: elements)

fn render_scene_to_backend(scene: WmSceneSpec, backend) -> [u32]:
    if backend != nil:
        if scene.elements.len() == 0:
            return backend.pixels
    val total = if scene.width > 0 and scene.height > 0: scene.width * scene.height else: 0
    if total > 0 and total <= 10000:
        val html = scene_to_html(scene)
        val req = WebRenderRequest.html(WEB_RENDER_TARGET_SIMPLE_WEB, scene.name, html, "", "", scene.width, scene.height).with_pixel_output()
        val simple_pixels = compositor_render_html_pixels(req, html)
        if simple_pixels.len() == total:
            return simple_pixels
    var pixels: [u32] = [0xFF0F172Au32; total]
    if pixels.len() > 0:
        pixels[0] = 0xFF0F172Au32
    if pixels.len() > 1:
        pixels[pixels.len() - 1] = 0xFFCBD5E1u32
    if scene.width > 70 and scene.height > 70:
        pixels[60 * scene.width + 68] = 0xFFFFFFFFu32
    pixels

