# Glass Dispatch — D2 Phase 1 feature-detecting helpers
#
# Callers that want to paint glass (alpha blend / box blur / vertical
# gradient / single-pixel read) MUST go through these helpers instead of
# calling `.blend_rect` / `.blur_region` / `.gradient_v` / `.read_pixel`
# directly on a `CompositorBackend`. The four methods no longer live on
# the core trait — they are on the optional `CompositorGlassCapable`
# subtrait, which some backends (Engine2dCompositorBackend,
# GpuCompositorBackend in Phase 1) do not implement.
#
# Each helper performs `backend.as_glass_capable()`; if the backend is
# glass-capable it forwards to the subtrait method, otherwise it
# degrades to an opaque `fill_rect` (the intended regression per the
# D2 plan). `cap_read_pixel` degrades to `0` when the backend cannot
# read its own surface.
#
# See doc/03_plan/sys_gui/d2_glass_subtrait_migration.md
# and doc/06_spec/runtime/rt_gui_glass_contract.md.

use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}
use std.common.window_protocol.geometry.{Rect, Point, Argb32, Alpha, BlurRadius}

fn cap_blend_rect(backend: CompositorBackend, x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8):
    """Alpha-blend a rect if the backend is glass-capable; otherwise
    degrade to an opaque `fill_rect` with the source color (alpha is
    discarded — the intended Phase-1 regression)."""
    val gc = backend.as_glass_capable()
    if gc != nil:
        gc.blend_rect(Rect.xywh(x, y, w, h), Argb32(value: color), Alpha(value: alpha))
        return
    # Degrade: opaque fill. Force alpha channel to 0xFF so downstream
    # compositors do not accidentally keep a transparent pixel.
    val opaque = color | 0xFF000000
    backend.fill_rect(Rect.xywh(x, y, w, h), Argb32(value: opaque))

fn cap_blur_region(backend: CompositorBackend, x: i32, y: i32, w: i32, h: i32, radius: u32):
    """Box-blur a region if glass-capable; otherwise no-op (cannot read
    pixels to blur them)."""
    val gc = backend.as_glass_capable()
    if gc != nil:
        gc.blur_region(Rect.xywh(x, y, w, h), BlurRadius(value: radius))

fn cap_gradient_v(backend: CompositorBackend, x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32):
    """Vertical gradient if glass-capable; otherwise degrade to an opaque
    fill using color1 (top colour) — matches the top edge of the
    gradient."""
    val gc = backend.as_glass_capable()
    if gc != nil:
        gc.gradient_v(Rect.xywh(x, y, w, h), Argb32(value: color1), Argb32(value: color2))
        return
    val opaque = color1 | 0xFF000000
    backend.fill_rect(Rect.xywh(x, y, w, h), Argb32(value: opaque))

fn cap_read_pixel(backend: CompositorBackend, x: i32, y: i32) -> u32:
    """Read a single pixel if glass-capable; otherwise return `0`.
    Callers that need a meaningful pixel value MUST either gate on
    `backend.as_glass_capable() != nil` or tolerate the degraded result."""
    val gc = backend.as_glass_capable()
    if gc != nil:
        return gc.read_pixel(Point.xy(x, y)).to_u32()
    0
