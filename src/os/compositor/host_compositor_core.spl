val HOST_WM_IDLE_SLEEP_MS: i32 = 16

# When true, render_frame_engine2d() rejects the canonical Draw IR lane so the
# caller can select the historical byte-identical direct compatibility renderer.
var _host_chrome_force_direct: bool = false

fn host_wm_force_direct_chrome(enabled: bool):
    """Pin (or release) the direct-draw chrome path for render_frame()."""
    _host_chrome_force_direct = enabled

fn host_wm_chrome_force_direct() -> bool:
    """True when render_frame() is pinned to the direct-draw chrome path."""
    _host_chrome_force_direct

enum HostBackendKind:
    Browser
    WebCanvas
    Electron
    Tauri
    Tui
    Sdl2
    Cocoa
    Win32
    Headless

enum HostDisplayMode:
    Windowed
    BorderlessFullscreen

enum HostDisplayTransitionPhase:
    Idle
    Requested
    AwaitingResize
    Applied
    Failed

struct HostSurfaceGeometry:
    x: i32
    y: i32
    width: i32
    height: i32
    scale_milli: i32

struct HostSurfaceState:
    mode: HostDisplayMode
    phase: HostDisplayTransitionPhase
    requested_mode: HostDisplayMode
    geometry: HostSurfaceGeometry
    saved_windowed_geometry: HostSurfaceGeometry
    rollback_geometry: HostSurfaceGeometry
    request_nonce: i64
    transition_revision: i64
    deadline_micros: i64
    resize_acknowledged: bool
    scale_acknowledged: bool
    failure_reason: text

struct HostDisplayTransition:
    state: HostSurfaceState
    accepted: bool
    mode_request_required: bool
    rolled_back: bool

val HOST_DISPLAY_TRANSITION_TIMEOUT_MICROS: i64 = 2000000

fn host_surface_geometry(x: i32, y: i32, width: i32, height: i32, scale_milli: i32) -> HostSurfaceGeometry:
    HostSurfaceGeometry(x: x, y: y, width: width, height: height, scale_milli: scale_milli)

fn host_surface_state(initial_geometry: HostSurfaceGeometry) -> HostSurfaceState:
    HostSurfaceState(
        mode: HostDisplayMode.Windowed,
        phase: HostDisplayTransitionPhase.Idle,
        requested_mode: HostDisplayMode.Windowed,
        geometry: initial_geometry,
        saved_windowed_geometry: initial_geometry,
        rollback_geometry: initial_geometry,
        request_nonce: 0,
        transition_revision: 0,
        deadline_micros: 0,
        resize_acknowledged: false,
        scale_acknowledged: false,
        failure_reason: ""
    )

fn _host_display_transition(state: HostSurfaceState, accepted: bool, mode_request_required: bool, rolled_back: bool) -> HostDisplayTransition:
    HostDisplayTransition(state: state, accepted: accepted, mode_request_required: mode_request_required, rolled_back: rolled_back)

fn request_display_mode(state: HostSurfaceState, mode: HostDisplayMode, nonce: i64, now_micros: i64) -> HostDisplayTransition:
    if nonce <= 0:
        return _host_display_transition(state, false, false, false)
    if state.phase == HostDisplayTransitionPhase.Requested or state.phase == HostDisplayTransitionPhase.AwaitingResize:
        val coalesced = state.request_nonce == nonce and state.requested_mode == mode
        return _host_display_transition(state, coalesced, false, false)
    if nonce <= state.request_nonce or mode == state.mode:
        return _host_display_transition(state, false, false, false)
    var out = state
    out.requested_mode = mode
    out.rollback_geometry = state.geometry
    if state.mode == HostDisplayMode.Windowed:
        out.saved_windowed_geometry = state.geometry
    out.phase = HostDisplayTransitionPhase.Requested
    out.request_nonce = nonce
    out.transition_revision = state.transition_revision + 1
    out.deadline_micros = now_micros + HOST_DISPLAY_TRANSITION_TIMEOUT_MICROS
    out.resize_acknowledged = false
    out.scale_acknowledged = false
    out.failure_reason = ""
    _host_display_transition(out, true, true, false)

fn _ack_surface_parts(state: HostSurfaceState, nonce: i64, geometry: HostSurfaceGeometry, resize_acknowledged: bool, scale_acknowledged: bool, now_micros: i64) -> HostDisplayTransition:
    if nonce != state.request_nonce or (state.phase != HostDisplayTransitionPhase.Requested and state.phase != HostDisplayTransitionPhase.AwaitingResize):
        return _host_display_transition(state, false, false, false)
    if now_micros > state.deadline_micros:
        return fail_or_timeout_display_transition(state, nonce, "display transition timed out", now_micros)
    var out = state
    if resize_acknowledged:
        if geometry.width <= 0 or geometry.height <= 0:
            return _host_display_transition(state, false, false, false)
        out.geometry.x = geometry.x
        out.geometry.y = geometry.y
        out.geometry.width = geometry.width
        out.geometry.height = geometry.height
        out.resize_acknowledged = true
    if scale_acknowledged:
        if geometry.scale_milli <= 0:
            return _host_display_transition(state, false, false, false)
        out.geometry.scale_milli = geometry.scale_milli
        out.scale_acknowledged = true
    if out.resize_acknowledged and out.scale_acknowledged:
        out.mode = out.requested_mode
        out.phase = HostDisplayTransitionPhase.Applied
        out.deadline_micros = 0
    else:
        out.phase = HostDisplayTransitionPhase.AwaitingResize
    out.transition_revision = state.transition_revision + 1
    _host_display_transition(out, true, false, false)

fn ack_surface_resize(state: HostSurfaceState, nonce: i64, geometry: HostSurfaceGeometry, now_micros: i64) -> HostDisplayTransition:
    _ack_surface_parts(state, nonce, geometry, true, false, now_micros)

fn ack_surface_scale(state: HostSurfaceState, nonce: i64, scale_milli: i32, now_micros: i64) -> HostDisplayTransition:
    val geometry = host_surface_geometry(state.geometry.x, state.geometry.y, state.geometry.width, state.geometry.height, scale_milli)
    _ack_surface_parts(state, nonce, geometry, false, true, now_micros)

fn ack_surface_event(state: HostSurfaceState, nonce: i64, geometry: HostSurfaceGeometry, now_micros: i64) -> HostDisplayTransition:
    _ack_surface_parts(state, nonce, geometry, true, true, now_micros)

fn fail_or_timeout_display_transition(state: HostSurfaceState, nonce: i64, reason: text, now_micros: i64) -> HostDisplayTransition:
    if nonce != state.request_nonce or (state.phase != HostDisplayTransitionPhase.Requested and state.phase != HostDisplayTransitionPhase.AwaitingResize):
        return _host_display_transition(state, false, false, false)
    if reason.len() == 0 and now_micros <= state.deadline_micros:
        return _host_display_transition(state, false, false, false)
    var out = state
    out.geometry = state.rollback_geometry
    out.requested_mode = state.mode
    out.phase = HostDisplayTransitionPhase.Failed
    out.deadline_micros = 0
    out.resize_acknowledged = false
    out.scale_acknowledged = false
    out.failure_reason = if reason.len() > 0: reason else: "display transition timed out"
    out.transition_revision = state.transition_revision + 1
    _host_display_transition(out, true, false, true)

class HostWmConfig:
    backend: HostBackendKind
    initial_size: Size
    title: text

class HostWmAppProcess:
    title: text
    app_id: text
    source_path: text
    pid: i64
    failed: bool

class HostedWindow:
    id: i64
    owner_port: i64
    title: text
    x: i32
    y: i32
    w: i32
    h: i32
    content: text
    process_id: i64
    app_id: text
    minimized: bool
    focused: bool
    maximized: bool = false
    restore_x: i32 = 0
    restore_y: i32 = 0
    restore_w: i32 = 0
    restore_h: i32 = 0

fn host_taskbar_clock_label(now_micros: i64) -> text:
    """Return a stable UTC HH:MM label from the host wall clock."""
    val seconds = (now_micros / 1000000) % 86400
    val hour = seconds / 3600
    val minute = (seconds % 3600) / 60
    val hour_text = if hour < 10: "0{hour}" else: "{hour}"
    val minute_text = if minute < 10: "0{minute}" else: "{minute}"
    "{hour_text}:{minute_text}"

fn _host_evidence_json_text(value: text) -> text:
    # Hoisted local is REQUIRED: stage3 native builds emit an interpolation
    # containing escaped string literals as literal source text (see
    # hosted_wm_evidence._json_text for the live-proven failure).
    val escaped = value.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n")
    "\"{escaped}\""

fn host_compositor_taskbar_model(comp: HostCompositor) -> TaskbarModel:
    """Project authoritative host process and window state into shell objects.

    Thin delegating wrapper kept for existing import sites; the body lives in
    HostCompositor.taskbar_model() because stage3 native codegen corrupts the
    windows array elements when the full HostCompositor aggregate crosses this
    free-function boundary by value (nil-receiver trap on window.focused)."""
    comp.taskbar_model()

fn host_window_to_shared_mdi_render_window(win: HostedWindow, scroll_y: i32) -> SharedMdiRenderWindow:
    shared_mdi_render_window(
        win.id,
        win.title,
        win.app_id,
        win.content,
        win.x,
        win.y,
        win.w,
        win.h,
        win.process_id,
        win.minimized,
        win.focused,
        scroll_y
    )

class HeadlessHostCompositorBackend:
    w: i32
    h: i32
    pixels: [u32]
    present_count: i64

    static fn new(width: i32, height: i32) -> HeadlessHostCompositorBackend:
        val total = if width > 0 and height > 0: width * height else: 0
        var pixels: [u32] = []
        var i = 0
        while i < total:
            pixels.push(0u32)
            i = i + 1
        HeadlessHostCompositorBackend(
            w: width,
            h: height,
            pixels: pixels,
            present_count: 0
        )

fn headless_host_compositor_pixels(backend: HeadlessHostCompositorBackend) -> [u32]:
    backend.pixels

fn headless_host_compositor_resize(backend: HeadlessHostCompositorBackend, width: i32, height: i32):
    if width <= 0 or height <= 0 or (backend.w == width and backend.h == height):
        return
    backend.w = width
    backend.h = height
    backend.pixels = [0u32; width * height]

impl CompositorBackend for HeadlessHostCompositorBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        var i = 0
        while i < self.pixels.len():
            self.pixels[i] = color
            i = i + 1

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        # Writes stay inline in this leaf method: delegating per pixel to
        # self.put_pixel (a me->me call) deep-clones the whole framebuffer on
        # EVERY write under the interpreter (~28ms/px at 1024x768) — see
        # doc/08_tracking/bug/interp_compositor_backend_put_pixel_clones_framebuffer_2026-07-03.md.
        # Bounds are clamped once up front instead of per pixel.
        var x0 = if x < 0: 0 else: x
        var y0 = if y < 0: 0 else: y
        var x1 = x + w
        var y1 = y + h
        if x1 > self.w:
            x1 = self.w
        if y1 > self.h:
            y1 = self.h
        var yy = y0
        while yy < y1:
            var idx = yy * self.w + x0
            var xx = x0
            while xx < x1:
                self.pixels[idx] = color
                idx = idx + 1
                xx = xx + 1
            yy = yy + 1

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        var cx = x
        for ch in text_str:
            val glyph = get_glyph_8x16(ch.char_code_at(0).to_u8())
            var row = 0
            while row < 16:
                val bits = glyph[row]
                var col = 0
                while col < 8:
                    val px = cx + col
                    val py = y + row
                    if px >= 0 and py >= 0 and px < self.w and py < self.h:
                        val mask = (0x80 >> col).to_u8()
                        self.pixels[py * self.w + px] = if (bits & mask) != 0u8: fg else: bg
                    col = col + 1
                row = row + 1
            cx = cx + 8

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        val glyph = get_glyph_8x16(ch)
        var row = 0
        while row < 16:
            val bits = glyph[row]
            var col = 0
            while col < 8:
                val px = x + col
                val py = y + row
                if px >= 0 and py >= 0 and px < self.w and py < self.h:
                    val mask = (0x80 >> col).to_u8()
                    self.pixels[py * self.w + px] = if (bits & mask) != 0u8: fg else: bg
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        if x < 0 or y < 0 or x >= self.w or y >= self.h:
            return
        val idx = y * self.w + x
        if idx >= 0 and idx < self.pixels.len():
            self.pixels[idx] = color

    me blit_pixels(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        # Inline writes with once-up-front clamping — same me->me put_pixel
        # framebuffer-clone hazard as fill_rect (see comment there).
        val src_len = pixels.len() as i32
        var row: i32 = 0
        while row < h:
            val dy = y + row
            if dy >= 0 and dy < self.h:
                var col0 = if x < 0: 0 - x else: 0
                var col1 = w
                if x + col1 > self.w:
                    col1 = self.w - x
                var col = col0
                var src_idx = row * w + col0
                var dst_idx = dy * self.w + x + col0
                while col < col1:
                    if src_idx >= 0 and src_idx < src_len:
                        self.pixels[dst_idx] = pixels[src_idx]
                    src_idx = src_idx + 1
                    dst_idx = dst_idx + 1
                    col = col + 1
            row = row + 1

    me present():
        self.present_count = self.present_count + 1

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        self.present_count = self.present_count + 1

    fn as_glass_capable() -> CompositorGlassCapable?:
        nil

class HostCompositor:
    backend: CompositorBackend
    headless_backend: HeadlessHostCompositorBackend?
    # NON-Optional on purpose: stage3 native codegen returns a NIL payload
    # from Optional-class-field unwrap (LLDB-proven: self==0 entering
    # _px_clear via self.pixel_backend.unwrap()), which also fabricated the
    # null trait vtable seen one slice earlier. The field is always
    # constructed (0x0 when unused) and gated by native_pixel_lane.
    pixel_backend: SharedWmPixelBufferBackend
    native_pixel_lane: bool
    native_cache_window_ids: [i64]
    native_content_caches: [WebRenderPixelArtifactCache]
    width: i32
    height: i32
    windows: [HostedWindow]
    next_window_id: i64
    app_processes: [HostWmAppProcess]
    dragging: bool
    drag_window_id: i64
    drag_offset_x: i32
    drag_offset_y: i32
    resizing: bool
    resize_window_id: i64
    resize_start_x: i32
    resize_start_y: i32
    resize_start_w: i32
    resize_start_h: i32
    pointer_x: i32
    pointer_y: i32
    # Last raw button code/state routed through handle_mouse_button (0=left,
    # 1=middle, 2=right). Left keeps its full chrome semantics via
    # handle_left_button; middle/right have no chrome action yet, so this is
    # the observable evidence that the event reached the compositor instead of
    # being silently dropped at the winit-dispatch layer.
    last_button: i64
    last_button_down: bool
    # Wheel-delta accumulator per hosted window id, keyed by whichever window
    # is under the pointer when a wheel event arrives. render_frame() reads
    # this back via scroll_offset_for(window.id) and threads it into
    # simple_web_content_frame_cached(), which translates the content
    # layer by that many pixels at paint time (renders `scroll_y` extra rows
    # of the same document, then windows the visible slice — see
    # os.compositor.simple_web_window_renderer._window_scrolled_pixels).
    scroll_offsets: Dict<i64, f64>
    # Chrome-action arming for release-inside click semantics (FIX 2): a
    # mouse-down over a chrome affordance (close button / taskbar item) arms
    # a target instead of firing immediately; the action only fires on
    # mouse-up if the release hit-test still resolves to the same target.
    armed_chrome_target: text
    armed_chrome_window_id: i64
    # Cache for the CSS/GUI-web chrome render lane (see render_frame). The key
    # is host_chrome_scene_fingerprint(); the pixels are the last full-scene
    # chrome rasterization. Empty key means "no cached chrome yet".
    _chrome_cache_key: text
    _chrome_cache_pixels: [u32]
    # Task #15 remainder item 4 (S1 perf): per-window content pixel cache.
    # Keyed by hosted window id so each window's cache tracks its own
    # (width, height, backend) identity independently — see
    # _content_cache_for, which replaces a window's cache whenever that
    # identity changes (resize/rescroll/backend change) and otherwise reuses
    # it so WebRenderPixelArtifactCache's own content-hash (HTML-equality)
    # check can skip re-rendering unchanged window content every frame.
    content_caches: Dict<i64, WebRenderPixelArtifactCache>
    # Scene background this compositor resolves at render time (color/image/
    # motion, see common.ui.window_scene.BackgroundSpec). Defaults to a plain
    # color matching the historical hardcoded compositor_bg fill so a
    # compositor that never calls set_background renders byte-identically to
    # before this field existed; see _resolve_background, which re-reads the
    # LIVE theme.compositor_bg for the color kind on every call instead of
    # trusting this stored default (the theme can change after construction).
    background: BackgroundSpec
    render_revision: i64
    # I-item-4 damage tracking: accumulates dirty rects across window
    # create/destroy/move/resize/content-update/focus-change so render_frame
    # can skip a full recomposite when nothing changed since the last
    # present. ponytail: full recomposite on any damage; partial/rect-level
    # recomposition is deferred until profiling demands it (see render_frame).
    dirty: DirtyRegion
    skipped_frame_count: i64

    static fn new(backend: CompositorBackend, size: Size) -> HostCompositor:
        var comp = HostCompositor(
            backend: backend,
            headless_backend: nil,
            pixel_backend: SharedWmPixelBufferBackend.new(0, 0),
            native_pixel_lane: false,
            native_cache_window_ids: [],
            native_content_caches: [],
            width: size.width as i32,
            height: size.height as i32,
            windows: [],
            next_window_id: 1,
            app_processes: [],
            dragging: false,
            drag_window_id: 0,
            drag_offset_x: 0,
            drag_offset_y: 0,
            resizing: false,
            resize_window_id: 0,
            resize_start_x: 0,
            resize_start_y: 0,
            resize_start_w: 0,
            resize_start_h: 0,
            pointer_x: 0,
            pointer_y: 0,
            last_button: -1,
            last_button_down: false,
            scroll_offsets: {},
            armed_chrome_target: "",
            armed_chrome_window_id: 0,
            _chrome_cache_key: "",
            _chrome_cache_pixels: [],
            content_caches: {},
            background: shared_wm_background_color(0xFF0F172Au32),
            render_revision: 0,
            dirty: DirtyRegion.new(),
            skipped_frame_count: 0
        )
        # Seed full-screen damage so the very first render_frame() call always
        # renders even though nothing has "changed" from an empty prior state.
        comp.dirty.add_full_screen(comp.width, comp.height)
        comp

    static fn new_headless(size: Size) -> HostCompositor:
        val concrete = HeadlessHostCompositorBackend.new(size.width as i32, size.height as i32)
        val compositor = HostCompositor.new(concrete, size)
        compositor.headless_backend = concrete
        compositor.pixel_backend = SharedWmPixelBufferBackend.new(size.width as i32, size.height as i32)
        compositor.native_pixel_lane = true
        compositor

    # Returns the WebRenderPixelArtifactCache for `window_id`, creating (or
    # replacing) it when there is none yet or its (width, height,
    # backend_name) identity no longer matches what this frame needs. A
    # replacement starts with an empty last-rendered-HTML slot, so the very
    # next content render after a resize/rescroll/backend change is
    # correctly a miss+store, not a stale hit.
    me _content_cache_for(window_id: i64, cw: i32, full_h: i32, backend_name: text) -> WebRenderPixelArtifactCache:
        if self.native_pixel_lane:
            var native_idx = 0
            while native_idx < self.native_cache_window_ids.len():
                if self.native_cache_window_ids[native_idx] == window_id:
                    val native_cache = self.native_content_caches[native_idx]
                    if native_cache.width == cw and native_cache.height == full_h and native_cache.backend_name == backend_name:
                        return native_cache
                    val replacement = web_render_pixel_artifact_cache(cw, full_h, backend_name)
                    self.native_content_caches[native_idx] = replacement
                    return replacement
                native_idx = native_idx + 1
            val native_fresh = web_render_pixel_artifact_cache(cw, full_h, backend_name)
            self.native_cache_window_ids.push(window_id)
            self.native_content_caches.push(native_fresh)
            return native_fresh
        val existing = self.content_caches.get(window_id)
        if existing != nil and existing.width == cw and existing.height == full_h and existing.backend_name == backend_name:
            return existing
        val fresh = web_render_pixel_artifact_cache(cw, full_h, backend_name)
        self.content_caches.set(window_id, fresh)
        fresh

    # Receiver-based taskbar projection. Stage3 native codegen yields nil
    # window elements when HostCompositor is passed by value into a free
    # function and its windows are iterated with for-in; indexed access on
    # the method receiver (the exact pattern render_frame uses) is proven
    # sound, so the authoritative body lives here.
    fn taskbar_model() -> TaskbarModel:
        var active_process_count = 0
        var pi = 0
        while pi < self.app_processes.len():
            if not self.app_processes[pi].failed:
                active_process_count = active_process_count + 1
            pi = pi + 1

        # Focus is part of the source state even though WindowRef intentionally
        # has no focus field: place the focused object last, matching host z-order.
        var running: [WindowRef] = []
        var wi = 0
        while wi < self.windows.len():
            val window = self.windows[wi]
            if not window.focused:
                running.push(WindowRef(window_id: window.id.to_text(), app_id: window.app_id, title: window.title, minimized: window.minimized))
            wi = wi + 1
        wi = 0
        while wi < self.windows.len():
            val window = self.windows[wi]
            if window.focused:
                running.push(WindowRef(window_id: window.id.to_text(), app_id: window.app_id, title: window.title, minimized: window.minimized))
            wi = wi + 1

        val process_label = "{active_process_count}/{self.app_processes.len()} active"
        TaskbarModel(
            # HostCompositor has no pinned-launcher registry. Processes are not
            # launchers, so presenting them as pinned would synthesize authority.
            pinned: [],
            running: running,
            tray: [TrayItem(item_id: "host-processes", label: process_label, icon: "process")]
        )

    # Receiver-built production evidence JSON for the compositor sub-object.
    # The evidence writer previously received the whole HostCompositor by
    # value; stage3 corrupts window elements at that free-function boundary
    # (LLDB: nil receiver inside host_wm_evidence_snapshot's element loop),
    # so the compositor fragment is built here on the receiver and crosses
    # the evidence boundary as a plain text scalar.
    fn evidence_compositor_json() -> text:
        var windows = ""
        var i = 0
        while i < self.windows.len():
            val w = self.windows[i]
            if i > 0: windows = windows + ","
            windows = windows + "{\"id\":{w.id},\"owner_port\":{w.owner_port},\"title\":{_host_evidence_json_text(w.title)},\"app_id\":{_host_evidence_json_text(w.app_id)},\"process_id\":{w.process_id},\"x\":{w.x},\"y\":{w.y},\"width\":{w.w},\"height\":{w.h},\"minimized\":{w.minimized},\"focused\":{w.focused},\"maximized\":{w.maximized},\"content\":{_host_evidence_json_text(w.content)}}"
            i = i + 1
        val model = self.taskbar_model()
        var running = ""
        i = 0
        while i < model.running.len():
            val item = model.running[i]
            if i > 0: running = running + ","
            running = running + "{\"window_id\":{_host_evidence_json_text(item.window_id)},\"app_id\":{_host_evidence_json_text(item.app_id)},\"title\":{_host_evidence_json_text(item.title)},\"minimized\":{item.minimized}}"
            i = i + 1
        "{\"width\":{self.width},\"height\":{self.height},\"render_revision\":{self.render_revision},\"pointer_x\":{self.pointer_x},\"pointer_y\":{self.pointer_y},\"dragging\":{self.dragging},\"resizing\":{self.resizing},\"windows\":[{windows}],\"taskbar\":{\"running\":[{running}],\"tray_count\":{model.tray.len()}}}"

    me resize(width: i32, height: i32):
        self.width = width
        self.height = height
        self.dirty.add_full_screen(width, height)
        if self.native_pixel_lane:
            # Native lane: the pixel mirror is authoritative; the headless
            # trait mirror is unused and its Optional unwrap is a stage3
            # nil-payload trap, so it is not touched here.
            shared_wm_pixel_buffer_resize(self.pixel_backend, width, height)
            return
        if self.headless_backend != nil:
            headless_host_compositor_resize(self.headless_backend.unwrap(), width, height)

    fn pure_simple_pixel_buffer() -> [u32]:
        if self.native_pixel_lane:
            return shared_wm_pixel_buffer_pixels(self.pixel_backend)
        if self.headless_backend == nil:
            return []
        headless_host_compositor_pixels(self.headless_backend.unwrap())

    me set_background(spec: BackgroundSpec):
        """Configure the scene background (color/image/motion) this
        compositor resolves at render time. init_host_wm calls this once at
        startup when ensure_host_motion_background_source_registered
        succeeded (SIMPLE_WM_MOTION_MANIFEST configured); specs may also call
        it directly to exercise a background without going through env-var
        wiring."""
        self.background = spec

    # Resolves self.background against the LIVE theme: a kind:"color"
    # background always tracks the current theme.compositor_bg (byte-identical
    # to the historical hardcoded fill when no image/motion background has
    # been configured — see the `background` field doc above), so a runtime
    # theme change is still honored exactly like before this field existed.
    # kind:"image"/"motion" pass straight to the one shared resolution point
    # (shared_wm_scene_resolve_background) the shared-MDI production lane
    # already uses. `wall_clock_micros` is only read by a kind:"motion"
    # background (see shared_wm_scene_resolve_background's t_micros doc).
    me _resolve_background(theme: WmChromeColors, wall_clock_micros: i64) -> SharedWmBackgroundResolution:
        val effective = if self.background.kind == WM_BACKGROUND_KIND_COLOR:
            shared_wm_background_color(theme.compositor_bg)
        else:
            self.background
        val t_micros = if effective.kind == WM_BACKGROUND_KIND_MOTION: wall_clock_micros else: 0
        shared_wm_scene_resolve_background(effective, self.width, self.height, t_micros)

    # I8 region-dirty: presents a due background advance WITHOUT re-rastering
    # windows or chrome. Only the desktop sub-rects NOT covered by a
    # currently-visible (non-minimized) window are touched, so window/chrome
    # pixels drawn by the last full render_frame() are left byte-exact — this
    # is the literal invariant I8 asks for ("background-only advance does NOT
    # re-raster windows/chrome"), not just a perf shortcut: blindly
    # re-blitting the full desktop rect here would stomp window pixels drawn
    # on top of it by the previous full render. Correctness fallback: if the
    # exact non-overlapping region can't be computed cheaply
    # (host_background_visible_rects hits its rect-count safety cap), this
    # returns false and the caller (hosted_entry.spl's present loop) falls
    # back to a full render_frame() instead of risking an incorrect partial
    # paint.
    me render_background_only(t_micros: i64) -> bool:
        val theme = wm_chrome_theme()
        val region = host_background_visible_rects(self.windows, self.width, self.height)
        if not region.computed:
            return false
        val resolved = self._resolve_background(theme, t_micros)
        for rect in region.rects:
            if val surface = resolved.surface:
                self.backend.blit_pixels(rect.x, rect.y, rect.width, rect.height, host_background_crop_surface(surface, rect, self.width))
            else:
                self.backend.fill_rect(rect.x, rect.y, rect.width, rect.height, resolved.color)
        if region.rects.len() > 0:
            val bounds = host_background_bounding_rect(region.rects)
            self.backend.present_rect(bounds.x, bounds.y, bounds.width, bounds.height)
        true

    me _taskbar_render_input(theme: WmChromeColors, frame_time: i64) -> SharedWmTaskbarRenderInput:
        var shared_windows: [SharedMdiRenderWindow] = []
        val window_count = self.windows.len()
        var i = 0
        while i < window_count:
            val win = self.windows[i]
            val scroll = self.scroll_offset_for(win.id) as i32
            shared_windows.push(host_window_to_shared_mdi_render_window(win, scroll))
            i = i + 1
        var scene = shared_mdi_scene_from_render_windows(self.width, self.height, "host-compositor", shared_windows)
        scene.background = if self.background.kind == WM_BACKGROUND_KIND_COLOR: shared_wm_background_color(theme.compositor_bg) else: self.background
        var content_frames: [WmContentFrame] = []
        i = 0
        while i < window_count:
            val win = self.windows[i]
            if not win.minimized:
                val cw = win.w - 8
                val ch = win.h - 36
                val scroll = self.scroll_offset_for(win.id) as i32
                val full_h = content_paint_full_height(ch, scroll)
                val cache = self._content_cache_for(win.id, cw, full_h, "auto")
                val content_revision = simple_web_content_revision(win.title, win.content, cw, ch, scroll)
                content_frames.push(simple_web_content_frame_cached(cache, win.id.to_text(), self.render_revision, content_revision, HOST_WM_CORE_DEFAULT_THEME_ID, win.title, win.content, cw, ch, scroll))
                if not self.native_pixel_lane:
                    self.content_caches.set(win.id, cache)
            i = i + 1
        val revision = WmSceneRevision(scene_revision: self.render_revision, input_revision: self.render_revision, taskbar_revision: self.render_revision)
        val metrics = WmRenderMetrics(scale_milli: 1000, top_lane_height: 44, titlebar_height: 28, taskbar_height: 56, min_hit_target: 44)
        val render_input = SharedWmRenderInput(scene: scene, revision: revision, content_frames: content_frames, metrics: metrics, t_micros: frame_time)
        SharedWmTaskbarRenderInput(render: render_input, taskbar: self.taskbar_model(), clock_label: host_taskbar_clock_label(frame_time))

    me _reject_engine2d_frame() -> bool:
        self.render_revision = self.render_revision - 1
        false

    me render_frame_engine2d(executor: Engine2dCompositorBackend) -> bool:
        if not self.native_pixel_lane or host_wm_chrome_force_direct() or self.background.kind != WM_BACKGROUND_KIND_COLOR or executor.w != self.width or executor.h != self.height:
            return false
        self.render_revision = self.render_revision + 1
        val had_damage = not self.dirty.is_empty()
        val taskbar_input = self._taskbar_render_input(wm_chrome_theme(), rt_time_now_unix_micros())
        if not had_damage:
            self.skipped_frame_count = self.skipped_frame_count + 1
            return true

        val scene = taskbar_input.render.scene
        val frames = taskbar_input.render.content_frames
        var images: [Engine2dResolvedDrawIrImage] = []
        var expected_images = 0
        var wi = 0
        while wi < scene.windows.len():
            val window = scene.windows[wi]
            val content = shared_wm_scene_window_content_rect_with_titlebar(window, 28)
            if not window.minimized and content.width > 0 and content.height > 0:
                expected_images = expected_images + 1
                val frame_index = shared_wm_top_content_frame_index(frames, self.render_revision, window.window_id, content.width, content.height)
                if frame_index >= 0:
                    val frame = frames[frame_index]
                    val image_uri = shared_wm_content_frame_image_uri(frame)
                    var duplicate_uri = image_uri == ""
                    var ii = 0
                    while ii < images.len():
                        if images[ii].image_uri == image_uri:
                            duplicate_uri = true
                        ii = ii + 1
                    if duplicate_uri:
                        return self._reject_engine2d_frame()
                    images.push(engine2d_resolved_draw_ir_image(image_uri, frame.width, frame.height, frame.pixels))
                else:
                    return self._reject_engine2d_frame()
            wi = wi + 1
        if images.len() != expected_images or frames.len() != expected_images:
            return self._reject_engine2d_frame()

        val composition = shared_wm_scene_draw_ir_composition_with_content(scene, taskbar_input.taskbar, frames, DRAW_IR_BACKEND_AUTO, 1000, taskbar_input.clock_label, 0)
        val result = executor.render_draw_ir_composition(composition, images)
        if result.fallback_required or result.skipped_command_count != 0 or result.rendered_command_count <= 0 or result.pixels.len() != self.width * self.height:
            return self._reject_engine2d_frame()
        self.pixel_backend.blit_pixels(0, 0, self.width, self.height, result.pixels)
        self.pixel_backend.present()
        self.dirty.clear()
        true

    me render_frame():
        val theme = wm_chrome_theme()
        self.render_revision = self.render_revision + 1
        # Compatibility renderer for explicit direct mode, image/motion
        # backgrounds, and same-frame fallback from render_frame_engine2d.
        val resolved_bg = self._resolve_background(theme, rt_time_now_unix_micros())
        # I-item-4 fast no-op path: only the chrome paint + final scene
        # composite + present are gated on accumulated damage (ponytail:
        # full recomposite on any damage; partial/rect-scoped recomposition
        # is deferred until profiling demands it). The content-frame
        # building loop below keeps running every call regardless of
        # `had_damage` -- it owns its own per-window cache hit/miss
        # bookkeeping (task #15's WebRenderPixelArtifactCache) which must
        # stay live independent of whether this frame actually presents.
        val had_damage = not self.dirty.is_empty()
        if had_damage and not self.native_pixel_lane:
            shared_wm_scene_render_desktop_chrome(self.backend, self.width, self.height, theme, resolved_bg.color, resolved_bg.surface)
        val frame_time = rt_time_now_unix_micros()
        val taskbar_input = self._taskbar_render_input(theme, frame_time)
        if had_damage:
            if self.native_pixel_lane:
                shared_wm_scene_render_taskbar_context_to_pixel_buffer(self.pixel_backend, taskbar_input)
            else:
                shared_wm_scene_render_taskbar_context_to_backend(self.backend, taskbar_input)
                self.backend.present()
            self.dirty.clear()
        else:
            self.skipped_frame_count = self.skipped_frame_count + 1

    me apply_bridge_request(seq: i64, owner_port: i64, method: i64, window_id: i64, title: text, x: i32, y: i32, w: i32, h: i32, content: text, process_id: i64, app_id: text):
        if method == COMP_MAXIMIZE.to_i64():
            self.maximize_window(window_id)
            return
        if method == COMP_RESTORE.to_i64():
            self.restore_window(window_id)
            return
        val action = wm_action_from_bridge_request(owner_port, method, window_id, title, x, y, w, h, content, process_id, app_id)
        self.apply_wm_action(action)

    me maximize_window(window_id: i64):
        val i = self._find_window_index(window_id)
        if i < 0:
            return
        val prior_windows = self.windows
        var win = self.windows[i]
        if not win.maximized:
            win.restore_x = win.x
            win.restore_y = win.y
            win.restore_w = win.w
            win.restore_h = win.h
        win.x = 0
        win.y = 48
        win.w = self.width
        win.h = self.height - 96
        win.minimized = false
        win.maximized = true
        self.windows[i] = win
        var j = 0
        while j < self.windows.len():
            var jw = self.windows[j]
            jw.focused = jw.id == window_id
            self.windows[j] = jw
            j = j + 1
        self._mark_geometry_damage(prior_windows)

    me restore_window(window_id: i64):
        val i = self._find_window_index(window_id)
        if i < 0:
            return
        val prior_windows = self.windows
        var win = self.windows[i]
        if win.maximized and win.restore_w > 0 and win.restore_h > 0:
            win.x = win.restore_x
            win.y = win.restore_y
            win.w = win.restore_w
            win.h = win.restore_h
        win.minimized = false
        win.maximized = false
        win.focused = true
        self.windows[i] = win
        self._mark_geometry_damage(prior_windows)

    me apply_wm_action(action: WmAction):
        val prior_windows = self.windows
        val out = host_compositor_apply_lifecycle_action(self, action)
        self.windows = out.windows
        self.next_window_id = out.next_window_id
        var i = 0
        while i < self.windows.len():
            var j = 0
            while j < prior_windows.len():
                if self.windows[i].id == prior_windows[j].id:
                    var iw = self.windows[i]
                    iw.maximized = prior_windows[j].maximized
                    iw.restore_x = prior_windows[j].restore_x
                    iw.restore_y = prior_windows[j].restore_y
                    iw.restore_w = prior_windows[j].restore_w
                    iw.restore_h = prior_windows[j].restore_h
                    self.windows[i] = iw
                j = j + 1
            i = i + 1
        self._mark_geometry_damage(prior_windows)

    fn _find_window_index(window_id: i64) -> i32:
        var i = 0
        while i < self.windows.len():
            if self.windows[i].id == window_id:
                return i
            i = i + 1
        -1

    # I-item-4 damage tracking: diffs `prior_windows` (a snapshot taken
    # before a mutation) against self.windows (the post-mutation state) and
    # adds the old + new rect for every window that was added, removed, or
    # whose visible bounds/state (position, size, minimized, focused,
    # content, title) changed. Content-only changes (e.g. COMP_UPDATE_TREE)
    # have no geometry delta but still damage the window's current rect,
    # since its rendered pixels differ even though x/y/w/h don't.
    me _mark_geometry_damage(prior_windows: [HostedWindow]):
        var i = 0
        while i < self.windows.len():
            val win = self.windows[i]
            val prior_idx = _host_find_window_by_id(prior_windows, win.id)
            if prior_idx < 0:
                self.dirty.add_rect(win.x, win.y, win.w, win.h)
            else:
                val prior = prior_windows[prior_idx]
                if prior.x != win.x or prior.y != win.y or prior.w != win.w or prior.h != win.h or prior.minimized != win.minimized or prior.focused != win.focused or prior.content != win.content or prior.title != win.title:
                    self.dirty.add_rect(prior.x, prior.y, prior.w, prior.h)
                    self.dirty.add_rect(win.x, win.y, win.w, win.h)
            i = i + 1
        var j = 0
        while j < prior_windows.len():
            if _host_find_window_by_id(self.windows, prior_windows[j].id) < 0:
                val gone = prior_windows[j]
                self.dirty.add_rect(gone.x, gone.y, gone.w, gone.h)
            j = j + 1

    me destroy_window(window_id: i64):
        self.apply_wm_action(wm_destroy_action(window_id))

    me focus_window(window_id: i64):
        self.apply_wm_action(wm_focus_action(window_id))

    fn hit_taskbar(x: i32, y: i32) -> i64:
        wm_lifecycle_hit_taskbar(host_windows_to_lifecycle_state(self.windows), self.width, self.height, x, y)

    me pointer_move(x: i32, y: i32):
        self.pointer_x = x
        self.pointer_y = y
        val prior_windows = self.windows
        val out = host_compositor_pointer_move(self, x, y)
        self.windows = out.windows
        self.next_window_id = out.next_window_id
        self.dragging = out.dragging
        self.drag_window_id = out.drag_window_id
        self.drag_offset_x = out.drag_offset_x
        self.drag_offset_y = out.drag_offset_y
        self.resizing = out.resizing
        self.resize_window_id = out.resize_window_id
        self.resize_start_x = out.resize_start_x
        self.resize_start_y = out.resize_start_y
        self.resize_start_w = out.resize_start_w
        self.resize_start_h = out.resize_start_h
        # Interactive drag/resize moves window geometry directly through
        # host_compositor_pointer_move rather than through apply_wm_action,
        # so it needs its own damage diff — otherwise a dragged window would
        # freeze on screen once render_frame()'s no-damage skip is live.
        self._mark_geometry_damage(prior_windows)

    me handle_mouse_move(x: i32, y: i32):
        self.pointer_move(x, y)

    me handle_left_button(down: bool):
        val prior_windows = self.windows
        val out = host_compositor_left_button_at(self, down, self.pointer_x, self.pointer_y)
        self.windows = out.windows
        self.next_window_id = out.next_window_id
        self.dragging = out.dragging
        self.drag_window_id = out.drag_window_id
        self.drag_offset_x = out.drag_offset_x
        self.drag_offset_y = out.drag_offset_y
        self.resizing = out.resizing
        self.resize_window_id = out.resize_window_id
        self.resize_start_x = out.resize_start_x
        self.resize_start_y = out.resize_start_y
        self.resize_start_w = out.resize_start_w
        self.resize_start_h = out.resize_start_h
        self.armed_chrome_target = out.armed_chrome_target
        self.armed_chrome_window_id = out.armed_chrome_window_id
        # host_compositor_left_button_at runs focus/destroy on a byval copy
        # of `self` (see class doc above re: stage3 free-function-by-value
        # codegen), so any damage it marked internally lives on that copy's
        # `dirty` and is never copied back here. Recompute the diff fresh
        # against the true receiver instead of trying to propagate it.
        self._mark_geometry_damage(prior_windows)

    # Generic pointer-button entry point (0=left, 1=middle, 2=right). Left
    # keeps its full chrome semantics (drag/resize/close/taskbar/focus);
    # middle/right have no WM chrome action defined yet, so they are recorded
    # on last_button/last_button_down instead of being silently dropped.
    me handle_mouse_button(button: i64, down: bool):
        self.last_button = button
        self.last_button_down = down
        if button == 0:
            self.handle_left_button(down)

    # Route a wheel delta to whichever hosted window the pointer currently
    # hovers, accumulating a per-window offset. See scroll_offsets doc above
    # for what this does and does not (yet) drive.
    me handle_mouse_wheel(dx: f64, dy: f64):
        var hit_idx = -1
        var i = 0
        while i < self.windows.len():
            val win = self.windows[i]
            if not win.minimized and self.pointer_x >= win.x and self.pointer_x < win.x + win.w and self.pointer_y >= win.y and self.pointer_y < win.y + win.h:
                hit_idx = i
            i = i + 1
        if hit_idx >= 0:
            val wid = self.windows[hit_idx].id
            val current = self.scroll_offsets.get(wid) ?? 0.0
            self.scroll_offsets[wid] = current + dy
            # Scroll changes rendered content without touching self.windows,
            # so the geometry diff in _mark_geometry_damage would miss it —
            # mark the scrolled window's own rect dirty directly.
            val scrolled = self.windows[hit_idx]
            self.dirty.add_rect(scrolled.x, scrolled.y, scrolled.w, scrolled.h)

    me scroll_offset_for(window_id: i64) -> f64:
        self.scroll_offsets.get(window_id) ?? 0.0

    me record_launch_failure(index: i32):
        if index < 0 or index >= self.app_processes.len():
            return
        var proc = self.app_processes[index]
        proc.failed = true
        self.app_processes[index] = proc
        val id = self.next_window_id
        self.next_window_id = self.next_window_id + 1
        self.windows.push(HostedWindow(id: id, owner_port: 0, title: proc.title + " failed", x: 40, y: 80, w: 360, h: 180, content: "failed to create a window for " + proc.app_id, process_id: proc.pid, app_id: proc.app_id, minimized: false, focused: true))
        self.dirty.add_rect(40, 80, 360, 180)

# ============================================================================
# I8 region-dirty background math (plan item B follow-up 1,
# doc/03_plan/os/desktop/wm_window_render_api_hardening_plan.md). Pure
# rectangle arithmetic — no backend/FFI calls — computing exactly which
# desktop sub-rects a background-only redraw is allowed to touch without
# corrupting window content a prior full render_frame() drew on top of it.
# ============================================================================

# Safety cap on the rect-subtraction fan-out (each window can split an
# existing rect into up to 4 pieces). Real hosted-WM window counts are small
# (single digits); this cap only guards a pathological layout from doing
# unbounded work — see host_background_visible_rects' `computed: false`
# escape hatch.
val HOST_BACKGROUND_REGION_DIRTY_MAX_RECTS: i32 = 256

struct HostBackgroundRegion:
    rects: [SharedWmRect]
    computed: bool

# Splits `a` into the axis-aligned pieces NOT covered by `b` (0-4 pieces):
# top/bottom strips spanning the full width of `a`, then left/right strips
# spanning only the vertical span where `a` and `b` actually overlap. No
# overlap -> `a` is returned unchanged.
fn _host_rect_subtract_one(a: SharedWmRect, b: SharedWmRect) -> [SharedWmRect]:
    val ax0 = a.x
    val ay0 = a.y
    val ax1 = a.x + a.width
    val ay1 = a.y + a.height
    val bx0 = b.x
    val by0 = b.y
    val bx1 = b.x + b.width
    val by1 = b.y + b.height
    if bx1 <= ax0 or bx0 >= ax1 or by1 <= ay0 or by0 >= ay1:
        return [a]
    var out: [SharedWmRect] = []
    if by0 > ay0:
        out.push(SharedWmRect(x: ax0, y: ay0, width: ax1 - ax0, height: by0 - ay0))
    if by1 < ay1:
        out.push(SharedWmRect(x: ax0, y: by1, width: ax1 - ax0, height: ay1 - by1))
    var my0 = ay0
    if by0 > ay0:
        my0 = by0
    var my1 = ay1
    if by1 < ay1:
        my1 = by1
    if bx0 > ax0:
        out.push(SharedWmRect(x: ax0, y: my0, width: bx0 - ax0, height: my1 - my0))
    if bx1 < ax1:
        out.push(SharedWmRect(x: bx1, y: my0, width: ax1 - bx1, height: my1 - my0))
    out

# Desktop rect minus the union of every visible (non-minimized) window rect —
# the exact set of pixels a background-only redraw may touch. `computed:
# false` is the correctness escape hatch: a pathological window layout that
# blows the rect-count safety cap aborts the computation rather than
# returning a partial (and therefore wrong) region — render_background_only
# treats that as "region can't be cheaply computed" and its caller falls back
# to a full render_frame().
fn host_background_visible_rects(windows: [HostedWindow], width: i32, height: i32) -> HostBackgroundRegion:
    if width <= 0 or height <= 0:
        return HostBackgroundRegion(rects: [], computed: true)
    var rects: [SharedWmRect] = [SharedWmRect(x: 0, y: 0, width: width, height: height)]
    for win in windows:
        if not win.minimized and win.w > 0 and win.h > 0:
            val hole = SharedWmRect(x: win.x, y: win.y, width: win.w, height: win.h)
            var next_rects: [SharedWmRect] = []
            for r in rects:
                for piece in _host_rect_subtract_one(r, hole):
                    if piece.width > 0 and piece.height > 0:
                        next_rects.push(piece)
            if next_rects.len() > HOST_BACKGROUND_REGION_DIRTY_MAX_RECTS:
                return HostBackgroundRegion(rects: [], computed: false)
            rects = next_rects
    HostBackgroundRegion(rects: rects, computed: true)

# Smallest rect containing every rect in `rects` — used to give
# backend.present_rect a single bounding invalidation rect for a
# background-only frame instead of one call per sub-rect.
fn host_background_bounding_rect(rects: [SharedWmRect]) -> SharedWmRect:
    var min_x = rects[0].x
    var min_y = rects[0].y
    var max_x = rects[0].x + rects[0].width
    var max_y = rects[0].y + rects[0].height
    for r in rects:
        if r.x < min_x:
            min_x = r.x
        if r.y < min_y:
            min_y = r.y
        val rx1 = r.x + r.width
        val ry1 = r.y + r.height
        if rx1 > max_x:
            max_x = rx1
        if ry1 > max_y:
            max_y = ry1
    SharedWmRect(x: min_x, y: min_y, width: max_x - min_x, height: max_y - min_y)

# Crops the (full-desktop-sized) resolved background surface down to `rect`'s
# sub-window so blit_pixels only writes the region host_background_visible_rects
# said is safe. Out-of-range reads (should not happen — the surface is sized
# to the same width/height the resolver was called with) degrade to opaque
# black rather than indexing out of bounds.
fn host_background_crop_surface(surface: BackgroundSurface, rect: SharedWmRect, full_width: i32) -> [u32]:
    # Pre-size once + index-store per pixel — NOT per-pixel `out.push`. Index
    # assignment hits the interpreter's strong_count==1 in-place fast path
    # (O(1)/element), whereas `arr.push` clones the whole growing array on
    # every call (O(N^2) — the measured CPU-lane anti-pattern). This runs on
    # the background-only motion path over the (large) desktop-minus-windows
    # region, so the quadratic form would dominate an animated frame. Default
    # fill is opaque black for the (should-not-happen) out-of-range reads.
    val n = rect.width * rect.height
    if n <= 0:
        return []
    var out: [u32] = [0xFF000000u32; n]
    val total = surface.pixels.len()
    var row = 0
    while row < rect.height:
        val row_start = (rect.y + row) * full_width + rect.x
        val out_row = row * rect.width
        var col = 0
        while col < rect.width:
            val idx = row_start + col
            if idx >= 0 and idx < total:
                out[out_row + col] = surface.pixels[idx]
            col = col + 1
        row = row + 1
    out

class HostWmLoopState:
    running: bool

class HostWmHandle:
    compositor: HostCompositor
    wm: HostWmLoopState
    event_loop_id: i64
    window_id: i64
    backend: HostBackendKind

    fn pump_host_events() -> i64:
        if self.event_loop_id == 0:
            return 0
        0

    me run_once():
        if not self.wm.running:
            return
        self.compositor.render_frame()

    me tick_forever():
        while self.wm.running:
            self.pump_host_events()
            self.run_once()
            rt_sleep_ms(HOST_WM_IDLE_SLEEP_MS.to_i64())

# Minimal headless-only WM init (item 5 of the WM hardening plan: "WM core
# must be VERY SMALL"). Builds a HostWmHandle the same way the Headless arm
# of host_compositor_bootstrap.init_host_wm's _create_backend_for_kind does
# (HeadlessHostCompositorBackend as the CompositorBackend, plain
# HostCompositor.new -- deliberately NOT new_headless's native_pixel_lane
# variant, to keep this byte-identical to the path the daemon already
# exercised), just reached without going through that file's
# _create_backend_for_kind/background-provider wiring. A caller that imports
# ONLY host_compositor_core (not host_compositor_entry, which re-exports
# host_compositor_bootstrap.*) never pulls hosted_backend_sdl2 /
# hosted_backend_cocoa / hosted_backend_win32 / background_image_provider /
# background_motion_provider into its module graph, so the resident daemon
# process (which only ever needs Headless -- see wm_daemon.wm_daemon_build_handle)
# can stay on this lean entry instead. No compositor refactor: HostCompositor
# itself is untouched, this is purely an alternate top-level constructor.
fn init_headless_host_wm(cfg: HostWmConfig) -> HostWmHandle:
    val w = cfg.initial_size.width.to_i32()
    val h = cfg.initial_size.height.to_i32()
    val backend = HeadlessHostCompositorBackend.new(w, h)
    val comp = HostCompositor.new(backend, cfg.initial_size)
    val wm = HostWmLoopState(running: true)
    HostWmHandle(compositor: comp, wm: wm, event_loop_id: 1, window_id: 1, backend: HostBackendKind.Headless)

class SimpleOsGuiAdapter:
    compositor: HostCompositor
    delivered_input_events: i64
    delivered_bridge_events: i64
    presented_frames: i64

    static fn new(backend: CompositorBackend, size: Size) -> SimpleOsGuiAdapter:
        SimpleOsGuiAdapter(
            compositor: HostCompositor.new(backend, size),
            delivered_input_events: 0,
            delivered_bridge_events: 0,
            presented_frames: 0
        )

    me deliver_bridge_request(seq: i64, owner_port: i64, method: i64, window_id: i64, title: text, x: i32, y: i32, w: i32, h: i32, content: text, process_id: i64, app_id: text):
        self.delivered_bridge_events = self.delivered_bridge_events + 1
        self.compositor.apply_bridge_request(seq, owner_port, method, window_id, title, x, y, w, h, content, process_id, app_id)

    me deliver_pointer_move(x: i32, y: i32):
        self.delivered_input_events = self.delivered_input_events + 1
        self.compositor = host_compositor_pointer_move(self.compositor, x, y)

    me deliver_left_button(down: bool):
        self.delivered_input_events = self.delivered_input_events + 1
        self.compositor = host_compositor_left_button(self.compositor, down)

    me render_framebuffer_frame():
        self.compositor.render_frame()
        self.presented_frames = self.presented_frames + 1

fn simpleos_gui_adapter_display_path_name(adapter: SimpleOsGuiAdapter) -> text:
    if adapter.compositor.width <= 0 or adapter.compositor.height <= 0:
        return "invalid"
    "simpleos-framebuffer"

fn simpleos_gui_adapter_content_renderer_name(adapter: SimpleOsGuiAdapter) -> text:
    if simpleos_gui_adapter_display_path_name(adapter) == "invalid":
        return "unsupported"
    WEB_RENDER_TARGET_SIMPLE_WEB

fn host_wm_surface_failure_reason(cfg: HostWmConfig, event_loop_id: i64, window_id: i64) -> text?:
    if cfg.backend == HostBackendKind.Tui:
        return "tui host compositor bootstrap is not implemented"
    if (cfg.initial_size.width as i32) <= 0 or (cfg.initial_size.height as i32) <= 0:
        return "host compositor size must be nonzero"
    if event_loop_id == 0 or window_id == 0:
        return "host compositor surface must be nonzero"
    nil

fn host_wm_content_renderer_name(handle: HostWmHandle) -> text:
    if handle.backend == HostBackendKind.Tui:
        return "unsupported"
    WEB_RENDER_TARGET_SIMPLE_WEB

fn _host_find_window_by_id(windows: [HostedWindow], window_id: i64) -> i32:
    var i = 0
    while i < windows.len():
        if windows[i].id == window_id:
            return i
        i = i + 1
    -1

fn host_compositor_find_window_index(comp: HostCompositor, window_id: i64) -> i32:
    var i = 0
    while i < comp.windows.len():
        if comp.windows[i].id == window_id:
            return i
        i = i + 1
    -1

fn host_window_to_lifecycle_state(win: HostedWindow) -> WmLifecycleWindowState:
    WmLifecycleWindowState(id: win.id, owner_port: win.owner_port, title: win.title, x: win.x, y: win.y, w: win.w, h: win.h, content: win.content, process_id: win.process_id, app_id: win.app_id, minimized: win.minimized, focused: win.focused)

fn host_window_from_lifecycle_state(win: WmLifecycleWindowState) -> HostedWindow:
    HostedWindow(id: win.id, owner_port: win.owner_port, title: win.title, x: win.x, y: win.y, w: win.w, h: win.h, content: win.content, process_id: win.process_id, app_id: win.app_id, minimized: win.minimized, focused: win.focused)

fn host_windows_to_lifecycle_state(windows: [HostedWindow]) -> [WmLifecycleWindowState]:
    var out: [WmLifecycleWindowState] = []
    var i = 0
    while i < windows.len():
        out.push(host_window_to_lifecycle_state(windows[i]))
        i = i + 1
    out

fn host_windows_from_lifecycle_state(windows: [WmLifecycleWindowState]) -> [HostedWindow]:
    var out: [HostedWindow] = []
    var i = 0
    while i < windows.len():
        out.push(host_window_from_lifecycle_state(windows[i]))
        i = i + 1
    out

fn host_compositor_apply_lifecycle_action(comp: HostCompositor, action: WmAction) -> HostCompositor:
    var out = comp
    val result = apply_wm_action_to_lifecycle_windows(host_windows_to_lifecycle_state(out.windows), out.next_window_id, out.width, out.height, action)
    out.windows = host_windows_from_lifecycle_state(result.windows)
    out.next_window_id = result.next_window_id
    out

fn host_compositor_pointer_move(comp: HostCompositor, x: i32, y: i32) -> HostCompositor:
    var out = comp
    val interaction = WmPointerInteractionState(dragging: out.dragging, drag_window_id: out.drag_window_id, drag_offset_x: out.drag_offset_x, drag_offset_y: out.drag_offset_y, resizing: out.resizing, resize_window_id: out.resize_window_id, resize_start_x: out.resize_start_x, resize_start_y: out.resize_start_y, resize_start_w: out.resize_start_w, resize_start_h: out.resize_start_h)
    val result = wm_lifecycle_pointer_move(host_windows_to_lifecycle_state(out.windows), out.next_window_id, out.width, out.height, interaction, x, y)
    out.windows = host_windows_from_lifecycle_state(result.windows)
    out.next_window_id = result.next_window_id
    out.dragging = result.interaction.dragging
    out.drag_window_id = result.interaction.drag_window_id
    out.drag_offset_x = result.interaction.drag_offset_x
    out.drag_offset_y = result.interaction.drag_offset_y
    out.resizing = result.interaction.resizing
    out.resize_window_id = result.interaction.resize_window_id
    out.resize_start_x = result.interaction.resize_start_x
    out.resize_start_y = result.interaction.resize_start_y
    out.resize_start_w = result.interaction.resize_start_w
    out.resize_start_h = result.interaction.resize_start_h
    out

fn host_compositor_left_button(comp: HostCompositor, down: bool) -> HostCompositor:
    host_compositor_left_button_at(comp, down, comp.pointer_x, comp.pointer_y)

fn host_compositor_left_button_at(comp: HostCompositor, down: bool, x: i32, y: i32) -> HostCompositor:
    var out = comp
    out.pointer_x = x
    out.pointer_y = y
    if down:
        # Clear any stale arming from a previous down whose matching up was
        # missed (defensive; the release path below always clears its own arm).
        out.armed_chrome_target = ""
        out.armed_chrome_window_id = 0
        # Taskbar click: a press inside the bottom dock band that lands on a
        # window's taskbar item is a chrome ACTION (focus + restore-if-
        # minimized). Arm it on down; it fires only on a release whose
        # hit-test still resolves to the same taskbar item (release-inside).
        # A drag-away before release cancels it (see the `else` branch below).
        # Checked before the window hit-test because the dock band can
        # overlap a window that extends to the bottom of the desktop.
        val tb_id = out.hit_taskbar(x, y)
        if tb_id > 0:
            out.armed_chrome_target = "taskbar"
            out.armed_chrome_window_id = tb_id
            return out
        var hit_idx = -1
        var i = 0
        while i < out.windows.len():
            val win = out.windows[i]
            if not win.minimized and x >= win.x and x < win.x + win.w and y >= win.y and y < win.y + win.h:
                hit_idx = i
            i = i + 1
        if hit_idx >= 0:
            val hit = out.windows[hit_idx]
            if x >= hit.x + hit.w - 24 and y >= hit.y and y < hit.y + 24:
                # Close button is a chrome ACTION: arm, fire on release-inside.
                out.armed_chrome_target = "close"
                out.armed_chrome_window_id = hit.id
                return out
            # Window-body focus and titlebar drag-arming are unchanged
            # (not converted to release-based semantics).
            out.focus_window(hit.id)
            if y >= hit.y and y < hit.y + 24:
                out.dragging = true
                out.drag_window_id = hit.id
                out.drag_offset_x = x - hit.x
                out.drag_offset_y = y - hit.y
                return out
    else:
        # Release: fire the armed chrome action only if the release hit-test
        # still resolves to the same target (release-inside). Moving away
        # before release (a different taskbar item / off the close button /
        # a different window entirely) cancels the action; the armed state is
        # cleared unconditionally below either way.
        if out.armed_chrome_target == "taskbar":
            val tb_id2 = out.hit_taskbar(x, y)
            if tb_id2 == out.armed_chrome_window_id:
                out.focus_window(tb_id2)
        elif out.armed_chrome_target == "close":
            var close_target_idx = -1
            var j = 0
            while j < out.windows.len():
                if out.windows[j].id == out.armed_chrome_window_id:
                    close_target_idx = j
                j = j + 1
            if close_target_idx >= 0:
                val win = out.windows[close_target_idx]
                if not win.minimized and x >= win.x + win.w - 24 and x < win.x + win.w and y >= win.y and y < win.y + 24:
                    out.destroy_window(win.id)
        out.armed_chrome_target = ""
        out.armed_chrome_window_id = 0
    val interaction = wm_lifecycle_left_button(WmPointerInteractionState(dragging: out.dragging, drag_window_id: out.drag_window_id, drag_offset_x: out.drag_offset_x, drag_offset_y: out.drag_offset_y, resizing: out.resizing, resize_window_id: out.resize_window_id, resize_start_x: out.resize_start_x, resize_start_y: out.resize_start_y, resize_start_w: out.resize_start_w, resize_start_h: out.resize_start_h), down)
    out.dragging = interaction.dragging
    out.drag_window_id = interaction.drag_window_id
    out.drag_offset_x = interaction.drag_offset_x
    out.drag_offset_y = interaction.drag_offset_y
    out.resizing = interaction.resizing
    out.resize_window_id = interaction.resize_window_id
    out.resize_start_x = interaction.resize_start_x
    out.resize_start_y = interaction.resize_start_y
    out.resize_start_w = interaction.resize_start_w
    out.resize_start_h = interaction.resize_start_h
    out

fn host_compositor_cycle_focus(comp: HostCompositor) -> HostCompositor:
    var out = comp
    if out.windows.len() == 0:
        return out
    var focused_idx = -1
    var i = 0
    while i < out.windows.len():
        if out.windows[i].focused:
            focused_idx = i
        i = i + 1
    var next_idx = focused_idx + 1
    if next_idx >= out.windows.len():
        next_idx = 0
    out.focus_window(out.windows[next_idx].id)
    out

fn host_compositor_focused_window_id(comp: HostCompositor) -> i64:
    var i = 0
    while i < comp.windows.len():
        if comp.windows[i].focused:
            return comp.windows[i].id
        i = i + 1
    if comp.windows.len() > 0:
        return comp.windows[comp.windows.len() - 1].id
    0

fn host_compositor_minimize_focused(comp: HostCompositor) -> HostCompositor:
    val id = host_compositor_focused_window_id(comp)
    if id <= 0:
        return comp
    var out = comp
    out.apply_bridge_request(0, 0, COMP_MINIMIZE.to_i64(), id, "", 0, 0, 0, 0, "", 0, "")
    out

fn host_compositor_maximize_focused(comp: HostCompositor) -> HostCompositor:
    val id = host_compositor_focused_window_id(comp)
    if id <= 0:
        return comp
    var out = comp
    out.apply_bridge_request(0, 0, COMP_MAXIMIZE.to_i64(), id, "", 0, 0, 0, 0, "", 0, "")
    out

fn host_compositor_restore_all(comp: HostCompositor) -> HostCompositor:
    var out = comp
    var i = 0
    while i < out.windows.len():
        out.apply_bridge_request(0, 0, COMP_RESTORE.to_i64(), out.windows[i].id, "", 0, 0, 0, 0, "", 0, "")
        i = i + 1
    out

fn host_taskbar_item_width(screen_width: i32, count: i32) -> i32:
    wm_taskbar_item_width(screen_width, count)

fn host_taskbar_dock_width(screen_width: i32, count: i32) -> i32:
    wm_taskbar_dock_width(screen_width, count)

fn host_taskbar_item_x(screen_width: i32, count: i32, index: i32) -> i32:
    wm_taskbar_item_x(screen_width, count, index)

fn host_compositor_draw_taskbar(backend: CompositorBackend, windows: [HostedWindow], width: i32, height: i32, theme: WmChromeColors):
    """Draw the taskbar dock with one item per window (minimized included —
    that is how restore works). Geometry mirrors wm_lifecycle_hit_taskbar
    EXACTLY (band at height-62, 44 tall; centered items) so what the user
    clicks is what they see. Item colors come from the shared theme:
    focused window -> title_focused, minimized -> window body, else
    unfocused titlebar color."""
    val count = windows.len() as i32
    if count <= 0:
        return
    val dock_w = wm_taskbar_dock_width(width, count)
    val dock_x = (width - dock_w) / 2
    val dock_y = height - 62
    backend.fill_rect(dock_x, dock_y, dock_w, 44, theme.taskbar)
    val item_w = wm_taskbar_item_width(width, count)
    var i: i32 = 0
    while i < count:
        val win = windows[i]
        val ix = wm_taskbar_item_x(width, count, i)
        var item_color = theme.title_unfocused
        if win.focused and not win.minimized:
            item_color = theme.title_focused
        elif win.minimized:
            item_color = theme.host_window_body
        backend.fill_rect(ix + 2, dock_y + 4, item_w - 4, 36, item_color)
        backend.draw_text(ix + 8, dock_y + 14, win.title, theme.text_primary, item_color)
        i = i + 1

# Convert an opaque ARGB u32 (as stored in WmChromeColors) to a CSS "#RRGGBB"
# hex string. The alpha byte is dropped: the host chrome colors are all opaque
# (0xFF..) and the CSS engine rasterizes #RRGGBB back to the same 0xFF ARGB u32,
# so the fast-lane chrome pixels are byte-identical to the direct-draw colors.
fn _argb_to_css_hex(color: u32) -> text:
    val r = ((color / 65536u32) % 256u32).to_i64()
    val g = ((color / 256u32) % 256u32).to_i64()
    val b = (color % 256u32).to_i64()
    "#" + int_to_hex(r) + int_to_hex(g) + int_to_hex(b)

# Build the host WM chrome as a single HTML/CSS document. Element geometry and
# colors mirror the direct-draw chrome in render_frame() exactly (desktop
# backdrop = compositor_bg, window body = host_window_body, titlebar =
# title_focused, close button = close_button, title/close glyph text =
# text_primary). title_focused (not accent) fills the titlebar so
# text_primary's dark glyphs stay legible on it — accent is reserved for
# thin stripes that never carry text directly. Colors flow from
# wm_chrome_theme() — the single source of truth — so an installed theme
# reskins the chrome automatically.
fn host_chrome_scene_html(windows: [HostedWindow], width: i32, height: i32) -> text:
    val theme = wm_chrome_theme()
    val bg_hex = _argb_to_css_hex(theme.compositor_bg)
    val body_hex = _argb_to_css_hex(theme.host_window_body)
    val title_focused_hex = _argb_to_css_hex(theme.title_focused)
    val close_hex = _argb_to_css_hex(theme.close_button)
    val text_hex = _argb_to_css_hex(theme.text_primary)
    var body = ""
    for win in windows:
        if not win.minimized:
            val close_x = win.x + win.w - 24
            val title_x = win.x + 8
            val title_y = win.y + 4
            val close_text_x = win.x + win.w - 17
            val title_w = if win.w - 40 > 0: win.w - 40 else: 0
            body = body + "<div style='position:absolute;left:{win.x}px;top:{win.y}px;width:{win.w}px;height:{win.h}px;background:{body_hex}'></div>"
            body = body + "<div style='position:absolute;left:{win.x}px;top:{win.y}px;width:{win.w}px;height:24px;background:{title_focused_hex}'></div>"
            body = body + "<div style='position:absolute;left:{title_x}px;top:{title_y}px;width:{title_w}px;height:16px;color:{text_hex};font:12px monospace;overflow:hidden;white-space:nowrap'>{win.title}</div>"
            body = body + "<div style='position:absolute;left:{close_x}px;top:{win.y}px;width:24px;height:24px;background:{close_hex}'></div>"
            body = body + "<div style='position:absolute;left:{close_text_x}px;top:{title_y}px;width:16px;height:16px;color:{text_hex};font:12px monospace'>X</div>"
    # Taskbar dock: one item per window (minimized included — restore works
    # through its item). Geometry mirrors wm_lifecycle_hit_taskbar exactly
    # (band at height-62, 44 tall; centered items) so what the user clicks
    # is what they see.
    val tb_count = windows.len() as i32
    if tb_count > 0:
        val taskbar_hex = _argb_to_css_hex(theme.taskbar)
        val unfocused_hex = _argb_to_css_hex(theme.title_unfocused)
        val dock_w = wm_taskbar_dock_width(width, tb_count)
        val dock_x = (width - dock_w) / 2
        val dock_y = height - 62
        val item_w = wm_taskbar_item_width(width, tb_count)
        body = body + "<div style='position:absolute;left:{dock_x}px;top:{dock_y}px;width:{dock_w}px;height:44px;background:{taskbar_hex}'></div>"
        var ti = 0
        while ti < tb_count:
            val twin = windows[ti]
            val tix = wm_taskbar_item_x(width, tb_count, ti)
            var item_hex = unfocused_hex
            if twin.focused and not twin.minimized:
                item_hex = title_focused_hex
            elif twin.minimized:
                item_hex = body_hex
            val item_inner_w = item_w - 4
            val label_w = item_w - 16
            val label_y = dock_y + 14
            body = body + "<div style='position:absolute;left:{tix + 2}px;top:{dock_y + 4}px;width:{item_inner_w}px;height:36px;background:{item_hex}'></div>"
            body = body + "<div style='position:absolute;left:{tix + 8}px;top:{label_y}px;width:{label_w}px;height:16px;color:{text_hex};font:12px monospace;overflow:hidden;white-space:nowrap'>{twin.title}</div>"
            ti = ti + 1
    "<!DOCTYPE html><html><head><style>body{{margin:0;width:{width}px;height:{height}px;background:{bg_hex}}}</style></head><body>" + body + "</body></html>"

# Fingerprint the chrome-relevant scene state so render_frame() can reuse the
# cached CSS chrome pixels on unchanged scenes. Deliberately excludes window
# content (redrawn every frame) but includes size, theme colors, and every
# window's id/geometry/minimized/focused/title.
fn host_chrome_scene_fingerprint(windows: [HostedWindow], width: i32, height: i32) -> text:
    val theme = wm_chrome_theme()
    var fp = "{width}x{height}|{theme.compositor_bg}|{theme.host_window_body}|{theme.title_focused}|{theme.close_button}|{theme.text_primary}|{theme.taskbar}|{theme.title_unfocused}#"
    for win in windows:
        val minf = if win.minimized: 1 else: 0
        val focf = if win.focused: 1 else: 0
        fp = fp + "{win.id}:{win.x},{win.y},{win.w},{win.h},{minf},{focf},{win.title};"
    fp
