# Hosted WM theme bootstrap owner.
#
# Resolve the registered package and install its immutable render snapshot
# before any backend, compositor, or visible frame is created.

use nogc_sync_mut.ui.theme_package.{load_default_theme_package}
use common.ui.theme_render_snapshot.{ThemeRenderSnapshot}
use common.ui.wm_chrome_theme.{apply_theme_render_snapshot_to_wm_chrome}

fn install_default_host_wm_theme() -> ThemeRenderSnapshot:
    val snapshot = load_default_theme_package().snapshot
    apply_theme_render_snapshot_to_wm_chrome(snapshot)
    snapshot
