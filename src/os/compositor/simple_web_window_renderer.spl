# Simple Web Window Renderer Adapter
#
# SimpleOS compositor adapter for rendering app client areas through the
# canonical Simple Web renderer and then blitting pixels to CompositorBackend.

use os.compositor.display_backend.{CompositorBackend}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{simple_web_render_html_to_pixels, simple_web_default_page_html}
use app.ui.web.html.{generate_css}
use common.ui.theme_package.{default_theme_id}

fn _is_simple_browser_title(title: text) -> bool:
    title == "Browser" or title == "Simple Browser"

fn themed_simple_web_html_with_theme(theme: text, title: text, body_html: text) -> text:
    val css = generate_css(theme)
    return "<html><head><style>" + css + "body { margin: 0; overflow: hidden; } #app { min-height: 100vh; padding: 0; } .simple-web-line { height: 22px; padding: 0 10px; } .simple-web-accent { color: var(--glass-accent); } .simple-web-success { color: var(--glass-success); } .simple-web-warning { color: var(--glass-warning); } .simple-web-muted { color: var(--glass-text-secondary); }</style></head><body><div id='app'><div class='wm-app-container'><div class='wm-app-titlebar'>" + title + "</div><div class='wm-app-content'>" + body_html + "</div></div></div></body></html>"

fn themed_simple_web_html(title: text, body_html: text) -> text:
    themed_simple_web_html_with_theme(default_theme_id(), title, body_html)

fn simple_web_app_html_with_theme(theme: text, title: text, state_text: text) -> text:
    if title == "Terminal":
        return themed_simple_web_html_with_theme(theme, title, "<div class='simple-web-line simple-web-success'>$ " + state_text + "</div><div class='simple-web-line simple-web-accent'>src/ test/ main.spl</div><div class='simple-web-line simple-web-success'>SimpleOS shell via Simple Web</div>")
    if title == "Editor" or title == "Hello World":
        return themed_simple_web_html_with_theme(theme, title, "<div class='simple-web-line simple-web-muted'>main.spl</div><div class='simple-web-line simple-web-warning'>fn main():</div><div class='simple-web-line simple-web-accent'>    print \"Hello SimpleOS\"</div><div class='simple-web-line simple-web-success'># rendered by Simple Web</div>")
    if title == "File Manager" or title == "Finder":
        return themed_simple_web_html_with_theme(theme, title, "<div class='simple-web-line simple-web-muted'>Files</div><div class='simple-web-line simple-web-accent'>boot/</div><div class='simple-web-line simple-web-accent'>home/</div><div class='simple-web-line'>kernel.elf</div>")
    if title == "Calculator":
        return themed_simple_web_html_with_theme(theme, title, "<div class='simple-web-line simple-web-accent'>0</div><div class='simple-web-line'>7 8 9 /</div><div class='simple-web-line'>4 5 6 *</div><div class='simple-web-line'>1 2 3 -</div>")
    if _is_simple_browser_title(title):
        return simple_web_default_page_html("about:network")
    themed_simple_web_html_with_theme(theme, title, "<div class='simple-web-line'>Simple Web app surface</div>")

fn simple_web_app_html(title: text, state_text: text) -> text:
    simple_web_app_html_with_theme(default_theme_id(), title, state_text)

fn render_simple_web_html_content(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch: i32, html: text):
    if cw <= 0 or ch <= 0:
        return
    val pixels = simple_web_render_html_to_pixels(html, cw, ch)
    blit_simple_web_pixels(backend, cx, cy, cw, ch, pixels)

fn render_simple_web_app_content(backend: CompositorBackend, title: text, cx: i32, cy: i32, cw: i32, ch: i32, state_text: text):
    render_simple_web_html_content(backend, cx, cy, cw, ch, simple_web_app_html(title, state_text))

fn render_simple_web_app_content_with_theme(backend: CompositorBackend, theme: text, title: text, cx: i32, cy: i32, cw: i32, ch: i32, state_text: text):
    render_simple_web_html_content(backend, cx, cy, cw, ch, simple_web_app_html_with_theme(theme, title, state_text))

fn blit_simple_web_pixels(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch: i32, pixels: [u32]):
    var y: i32 = 0
    while y < ch:
        var x: i32 = 0
        while x < cw:
            val idx = y * cw + x
            if idx < pixels.len():
                backend.put_pixel(cx + x, cy + y, pixels[idx])
            x = x + 1
        y = y + 1
