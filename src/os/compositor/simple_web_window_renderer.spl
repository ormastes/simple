# Simple Web Window Renderer Adapter
#
# SimpleOS compositor adapter for rendering app client areas through the
# canonical Simple Web renderer and then blitting pixels to CompositorBackend.

use os.compositor.display_backend.{CompositorBackend}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{simple_web_render_html_to_pixels, simple_web_default_page_html}

fn simple_web_app_html(title: text, state_text: text) -> text:
    if title == "Terminal":
        return "<html><body style='margin:0; background-color:#0a0a14; color:#e0e0f0;'><div style='height:22px; background-color:#101820; color:#44ff44;'>$ {state_text}</div><div style='height:22px; color:#6699ff;'>src/ test/ main.spl</div><div style='height:22px; color:#44ff44;'>SimpleOS shell via Simple Web</div></body></html>"
    if title == "Editor" or title == "Hello World":
        return "<html><body style='margin:0; background-color:#0d0d14; color:#cccccc;'><div style='height:24px; background-color:#2c2c32; color:#e0e0f0;'>main.spl</div><div style='height:22px; color:#cc7832;'>fn main():</div><div style='height:22px; color:#ffc66d;'>    print \"Hello SimpleOS\"</div><div style='height:22px; color:#629755;'># rendered by Simple Web</div></body></html>"
    if title == "File Manager" or title == "Finder":
        return "<html><body style='margin:0; background-color:#111827; color:#e5e7eb;'><div style='height:24px; background-color:#1f2937; color:#ffffff;'>Files</div><div style='height:22px; color:#6699ff;'>boot/</div><div style='height:22px; color:#6699ff;'>home/</div><div style='height:22px;'>kernel.elf</div></body></html>"
    if title == "Calculator":
        return "<html><body style='margin:0; background-color:#1a1a24; color:#f3f4f6;'><div style='height:34px; background-color:#0d0d14; color:#ffffff;'>0</div><div style='height:28px; background-color:#2c2c32;'>7 8 9 /</div><div style='height:28px; background-color:#2c2c32;'>4 5 6 *</div><div style='height:28px; background-color:#2c2c32;'>1 2 3 -</div></body></html>"
    if title == "Browser":
        return simple_web_default_page_html("about:network")
    "<html><body style='margin:0; background-color:#182230; color:#f3f4f6;'><div style='height:28px; background-color:#2050a0; color:#ffffff;'> {title}</div><div style='height:80px;'>Simple Web app surface</div></body></html>"

fn render_simple_web_html_content(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch: i32, html: text):
    if cw <= 0 or ch <= 0:
        return
    val pixels = simple_web_render_html_to_pixels(html, cw, ch)
    blit_simple_web_pixels(backend, cx, cy, cw, ch, pixels)

fn render_simple_web_app_content(backend: CompositorBackend, title: text, cx: i32, cy: i32, cw: i32, ch: i32, state_text: text):
    render_simple_web_html_content(backend, cx, cy, cw, ch, simple_web_app_html(title, state_text))

fn blit_simple_web_pixels(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch: i32, pixels: [u32]):
    var y: i32 = 0
    while y < ch:
        var x: i32 = 0
        while x < cw:
            val idx = y * cw + x
            if idx < pixels.len():
                backend.put_pixel(cx + x, cy + y, pixels[idx])
            x = x + 1
        y = y + 1
