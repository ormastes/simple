#![allow(unnamed_duplicate_typed_args)]

use os.compositor.browser_compositor_backend.{BrowserCompositorBackend, set_backend_pixel_buffer_override}
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{simple_web_render_html_to_pixels}

fn simple_web_app_html(title: text, url: text) -> text:
    val effective_url = if url.trim().len() > 0: url else: "about:network"
    "<html><body style='margin:0; background-color:#101820; color:#f3f4f6;'>" +
    "<div style='height:28px; background-color:#2050a0; color:#ffffff;'> " + title + "</div>" +
    "<div style='height:96px; background-color:#182230; color:#44ff44;'> Simple Web</div>" +
    "<div style='height:96px; background-color:#1f2937; color:#e0e0f0;'> " + effective_url + "</div>" +
    "</body></html>"

fn render_simple_web_app_content(backend: BrowserCompositorBackend, title: text, x: i32, y: i32, w: i32, h: i32, url: text):
    val html = simple_web_app_html(title, url)
    val pixels = simple_web_render_html_to_pixels(html, w, h)
    var composed = backend.get_pixel_buffer()
    var row: i32 = 0
    while row < h:
        var col: i32 = 0
        while col < w:
            val src_idx = row * w + col
            val dst_x = x + col
            val dst_y = y + row
            if src_idx >= 0 and src_idx < pixels.len() and dst_x >= 0 and dst_y >= 0 and dst_x < backend.width and dst_y < backend.height:
                composed[dst_y * backend.width + dst_x] = pixels[src_idx]
            col = col + 1
        row = row + 1
    set_backend_pixel_buffer_override(backend, composed)
