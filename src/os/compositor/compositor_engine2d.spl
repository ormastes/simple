# Engine2D-backed Compositor
#
# CompositorEngine2D is the "Engine2D actually drives the compositor"
# variant of the window compositor. Instead of handing a raw
# FramebufferDriver to `Compositor.new`, this module builds a
# `Compositor` whose `CompositorBackend` delegates every paint-leaf call
# (clear / fill_rect / draw_text / put_pixel / present / ...) to an
# `Engine2D`.
#
# Design (wrapper approach):
#
#   CompositorEngine2D
#     ├── engine:  Engine2D                    (Engine2D facade)
#     ├── backend: Engine2dCompositorBackend   (implements CompositorBackend)
#     └── inner:   Compositor                  (built via with_backends)
#
# The standard `Compositor` class (src/os/compositor/compositor.spl) is
# untouched — legacy boot entries (e.g. gui_entry.spl) keep calling
# `Compositor.new(fb, ...)` with the FramebufferDriver path. This file is
# additive.
#
# Because `DesktopShell` hard-types `compositor: Compositor`, the boot
# entry continues to hand DesktopShell a real `Compositor` instance —
# specifically `ce2d.inner` — so no shell-side change is needed.
#
# Deltas from FbCompositorBackend:
#   - clear / fill_rect / draw_text / gradient_v / draw_rect delegate
#     to the Engine2D facade (engine.clear, engine.draw_rect_filled,
#     engine.draw_text, engine.draw_gradient_rect).
#   - put_pixel / draw_char_8x16 synthesize per-pixel output via
#     Engine2D.draw_rect_filled(x, y, 1, 1, color). This matches how
#     GpuCompositorBackend implements the same calls.
#   - present / present_rect call engine.present().
#   - blend_rect / blur_region / gradient_v / read_pixel: OPT OUT in
#     D2 Phase 1 (2026-04-14). Glass is disabled for this backend because
#     the `rt_gui_*` externs paint the raw baremetal framebuffer; when the
#     underlying RenderBackend is not baremetal (Vulkan, Metal, non-identity
#     virtio-GPU), those writes hit the wrong surface. Re-enable via a
#     native `CompositorGlassCapable` impl once Engine2D's `RenderBackend`
#     grows blend/blur primitives — see
#     doc/03_plan/sys_gui/d2_glass_subtrait_migration.md (Phase 2).
#
# Milestone unlocked: the compositor's render loop now runs through
# Engine2D. Every surface fill, title bar, text glyph, and cursor blit
# issued by `Compositor.render_all()` is routed through the Engine2D
# facade before hitting the framebuffer.

use os.drivers.framebuffer.fb_driver.{get_glyph_8x16}
use os.drivers.input.ps2_keyboard.{Ps2Keyboard}
use os.drivers.input.ps2_mouse.{Ps2Mouse}
use os.compositor.compositor.{Compositor}
use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}
use os.compositor.input_backend.{InputBackend, Ps2InputBackend}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}

# ============================================================================
# Engine2D Compositor Backend
# ============================================================================

class Engine2dCompositorBackend:
    """CompositorBackend that routes every paint call through Engine2D.

    The backing Engine2D is expected to be created via
    `create_fb_engine(fb)` (or any other Engine2D factory that ultimately
    paints the same framebuffer the glass rt_gui_* helpers target).
    """
    engine: Engine2D
    w: i32
    h: i32

impl CompositorBackend for Engine2dCompositorBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        self.engine.clear(color)

    # Edge semantics: [x, x+w) x [y, y+h). See CompositorBackend.fill_rect contract.
    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        self.engine.draw_rect_filled(x, y, w, h, color)

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        # D3 (2026-04-14): delegate to Engine2D's `draw_text_bg`, which
        # hands off to the backend's `Engine2DExtended` impl. The previous
        # pre-paint-rect-then-overlay hack destroyed antialiased glyph
        # edges and forced a fixed 8x16 cell pitch; the new path lets the
        # backend render glyphs with `bg` as the per-pixel background.
        self.engine.draw_text_bg(x, y, text_str, fg, bg, 16)

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        """Draw a single 8x16 glyph pixel-by-pixel through Engine2D.

        Matches the GpuCompositorBackend strategy: decode the VGA 8x16
        bitmap font row-by-row and emit a 1x1 filled rect per pixel.
        """
        val glyph = get_glyph_8x16(ch)
        var row: i32 = 0
        while row < 16:
            val bits = glyph[row]
            var col: i32 = 0
            while col < 8:
                val mask = 0x80 >> col
                val color = if (bits & mask) != 0: fg else: bg
                self.engine.draw_rect_filled(x + col, y + row, 1, 1, color)
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        self.engine.draw_rect_filled(x, y, 1, 1, color)

    me present():
        self.engine.present()

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        # Engine2D has no partial-present API; degrade to a full present
        # (same as FbCompositorBackend).
        self.engine.present()

    # D2 Phase 1 opt-out: no `impl CompositorGlassCapable for
    # Engine2dCompositorBackend` exists. `rt_gui_*` writes would paint the
    # wrong surface when the underlying RenderBackend is not baremetal.
    # Callers degrade to opaque `fill_rect` via
    # `os.compositor.glass_dispatch` helpers.
    fn as_glass_capable() -> CompositorGlassCapable?:
        nil

impl Engine2dCompositorBackend:

    static fn create(engine: Engine2D) -> Engine2dCompositorBackend:
        """Wrap an Engine2D as a CompositorBackend."""
        val w = engine.width()
        val h = engine.height()
        Engine2dCompositorBackend(engine: engine, w: w, h: h)

# ============================================================================
# CompositorEngine2D — Engine2D-driven compositor facade
# ============================================================================

class CompositorEngine2D:
    """Engine2D-backed window compositor facade.

    Composition (not inheritance):
      - `engine`  is the Engine2D the compositor paints through.
      - `backend` adapts that Engine2D to the `CompositorBackend` trait.
      - `inner`   is the standard `Compositor` built via
                  `Compositor.with_backends(backend, input, w, h)`.

    For callers that take a `Compositor` directly (e.g. `DesktopShell`),
    pass `ce2d.inner` — it is a real `Compositor`, just one whose
    render path goes through Engine2D.
    """
    engine: Engine2D
    backend: Engine2dCompositorBackend
    inner: Compositor

impl CompositorEngine2D:

    static fn new(engine: Engine2D, kb: Ps2Keyboard, mouse: Ps2Mouse) -> CompositorEngine2D:
        """Create a compositor whose paint path runs through Engine2D.

        Args:
            engine: Engine2D (typically from `create_fb_engine(fb)`)
            kb:     PS/2 keyboard for input events
            mouse:  PS/2 mouse for input events

        Returns:
            CompositorEngine2D whose `.inner` Compositor is ready to
            hand to DesktopShell.
        """
        val w = engine.width()
        val h = engine.height()
        val backend = Engine2dCompositorBackend.create(engine)
        val input = Ps2InputBackend.create(kb, mouse)
        val compositor = Compositor.with_backends(backend, input, w, h)
        CompositorEngine2D(
            engine: engine,
            backend: backend,
            inner: compositor
        )

    me run():
        """Run the compositor event loop (delegates to inner.run via the
        standard shell flow). Callers that already drive the event loop
        through DesktopShell.run() do not need this — it is provided for
        parity with the legacy `Compositor.run()` entry point."""
        self.inner.running = true
        while self.inner.running:
            self.inner.handle_input()
            self.inner.render_all()

    me as_compositor() -> Compositor:
        """Return the underlying `Compositor` for code that is typed
        against it (e.g. `DesktopShell.new`)."""
        self.inner
