# Engine2D-backed Compositor
#
# CompositorEngine2D is the "Engine2D actually drives the compositor"
# variant of the window compositor. Instead of handing a raw
# FramebufferDriver to `Compositor.new`, this module builds a
# `Compositor` whose `CompositorBackend` delegates every paint-leaf call
# (clear / fill_rect / draw_text / put_pixel / present / ...) to an
# `Engine2D`.
#
# Design (wrapper approach):
#
#   CompositorEngine2D
#     ├── engine:  Engine2D                    (Engine2D facade)
#     ├── backend: Engine2dCompositorBackend   (implements CompositorBackend)
#     └── inner:   Compositor                  (built via with_backends)
#
# The standard `Compositor` class (src/os/compositor/compositor.spl) is
# untouched — legacy boot entries (e.g. gui_entry.spl) keep calling
# `Compositor.new(fb, ...)` with the FramebufferDriver path. This file is
# additive.
#
# Because `DesktopShell` hard-types `compositor: Compositor`, the boot
# entry continues to hand DesktopShell a real `Compositor` instance —
# specifically `ce2d.inner` — so no shell-side change is needed.
#
# Deltas from FbCompositorBackend:
#   - clear / fill_rect / draw_text / gradient_v / draw_rect delegate
#     to the Engine2D facade (engine.clear, engine.draw_rect_filled,
#     engine.draw_text, engine.draw_gradient_rect).
#   - put_pixel / draw_char_8x16 synthesize per-pixel output via
#     Engine2D.draw_rect_filled(x, y, 1, 1, color). This matches how
#     GpuCompositorBackend implements the same calls.
#   - present / present_rect call engine.present().
#   - blend_rect / blur_region / gradient_v / read_pixel: NATIVE Engine2D
#     in D2 Phase 2 (2026-04-14). The backend implements
#     `CompositorGlassCapable` directly and routes every glass op through
#     existing Engine2D primitives (`draw_gradient_rect`, `read_pixels`,
#     `draw_image`) — there are NO `rt_gui_*` calls on this path, so the
#     Phase 1 surface-mismatch hazard is gone. The blur path uses a simple
#     1–3 pass 3x3 box kernel (radius collapsed to pass count) — a
#     deliberate tradeoff documented inline; a faithful Gaussian would
#     require adding a scratch buffer to every Engine2D backend.
#     Gpu (virtio_gpu) is still opt-out — that path lands later with
#     command-stream work. See doc/03_plan/sys_gui/d2_glass_subtrait_migration.md.
#
# Milestone unlocked: the compositor's render loop now runs through
# Engine2D. Every surface fill, title bar, text glyph, and cursor blit
# issued by `Compositor.render_all()` is routed through the Engine2D
# facade before hitting the framebuffer.

use os.drivers.framebuffer.fb_driver.{get_glyph_8x16}
use os.drivers.input.ps2_keyboard.{Ps2Keyboard}
use os.drivers.input.ps2_mouse.{Ps2Mouse}
use os.compositor.compositor.{Compositor}
use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}
use os.compositor.input_backend.{InputBackend, Ps2InputBackend}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.color.{rgba, blend, color_r, color_g, color_b, color_a}

# ============================================================================
# Engine2D Compositor Backend
# ============================================================================

class Engine2dCompositorBackend:
    """CompositorBackend that routes every paint call through Engine2D.

    The backing Engine2D is expected to be created via
    `create_fb_engine(fb)` (or any other Engine2D factory). In Phase 2
    the glass ops also paint through this Engine2D — no separate
    `rt_gui_*` write path is taken.
    """
    engine: Engine2D
    w: i32
    h: i32

impl CompositorBackend for Engine2dCompositorBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        self.engine.clear(color)

    # Edge semantics: [x, x+w) x [y, y+h). See CompositorBackend.fill_rect contract.
    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        self.engine.draw_rect_filled(x, y, w, h, color)

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        # D3 (2026-04-14): delegate to Engine2D's `draw_text_bg`, which
        # hands off to the backend's `Engine2DExtended` impl. The previous
        # pre-paint-rect-then-overlay hack destroyed antialiased glyph
        # edges and forced a fixed 8x16 cell pitch; the new path lets the
        # backend render glyphs with `bg` as the per-pixel background.
        self.engine.draw_text_bg(x, y, text_str, fg, bg, 16)

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        """Draw a single 8x16 glyph pixel-by-pixel through Engine2D.

        Matches the GpuCompositorBackend strategy: decode the VGA 8x16
        bitmap font row-by-row and emit a 1x1 filled rect per pixel.
        """
        val glyph = get_glyph_8x16(ch)
        var row: i32 = 0
        while row < 16:
            val bits = glyph[row]
            var col: i32 = 0
            while col < 8:
                val mask = 0x80 >> col
                val color = if (bits & mask) != 0: fg else: bg
                self.engine.draw_rect_filled(x + col, y + row, 1, 1, color)
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        self.engine.draw_rect_filled(x, y, 1, 1, color)

    me present():
        self.engine.present()

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        # Engine2D has no partial-present API; degrade to a full present
        # (same as FbCompositorBackend).
        self.engine.present()

    # D2 Phase 2 opt-in: Engine2D has the primitives we need
    # (`draw_gradient_rect`, `read_pixels`, `draw_image`) so we paint glass
    # natively through the backing Engine2D — NO `rt_gui_*` calls. Glass
    # writes hit the same surface every other Engine2D draw goes to, so
    # the surface-mismatch hazard from Phase 1 is eliminated.
    fn as_glass_capable() -> CompositorGlassCapable?:
        self

impl CompositorGlassCapable for Engine2dCompositorBackend:

    me blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8):
        """Alpha-blend a solid colour over the rect.

        Reads the affected region from Engine2D, runs Porter-Duff source-over
        per pixel using `std.gpu.engine2d.color.blend`, then writes the result
        back via `draw_image`. Pure Engine2D primitives — no rt_gui_*.
        """
        if w <= 0 or h <= 0:
            return
        # Build the source colour with the requested alpha applied to the
        # caller's RGB. The incoming `color` is treated as an opaque triple;
        # `alpha` is the over factor.
        val sr = color_r(color)
        val sg = color_g(color)
        val sb = color_b(color)
        val src = rgba(sr, sg, sb, alpha.to_i32())

        val full = self.engine.read_pixels()
        val fb_w = self.engine.width()
        val fb_h = self.engine.height()
        # Clip to framebuffer.
        var rx = x
        var ry = y
        var rw = w
        var rh = h
        if rx < 0:
            rw = rw + rx
            rx = 0
        if ry < 0:
            rh = rh + ry
            ry = 0
        if rx + rw > fb_w:
            rw = fb_w - rx
        if ry + rh > fb_h:
            rh = fb_h - ry
        if rw <= 0 or rh <= 0:
            return

        var region: [u32] = [0u32; rw * rh]
        var row: i32 = 0
        while row < rh:
            var col: i32 = 0
            while col < rw:
                val dst = full[(ry + row) * fb_w + (rx + col)]
                # Force result alpha to 255 so draw_image's own blend path
                # treats it as an opaque overwrite.
                val mixed = blend(src, dst)
                val mr = color_r(mixed)
                val mg = color_g(mixed)
                val mb = color_b(mixed)
                region[row * rw + col] = rgba(mr, mg, mb, 255)
                col = col + 1
            row = row + 1
        self.engine.draw_image(rx, ry, rw, rh, region)

    me blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32):
        """Native blur via a simple 3x3 box kernel.

        TRADEOFF: the `radius` parameter is honoured as "box-blur passes"
        with a hard cap of 3 (1 pass for radius 0/1, 2 for radius 2/3,
        3 otherwise). A faithful separable Gaussian would mean adding a
        scratch buffer to every Engine2D backend, which is over-engineering
        for the Phase 2 step. The render result is still strictly nicer
        than the Phase 1 opaque fill fallback.
        """
        if w <= 0 or h <= 0:
            return
        val fb_w = self.engine.width()
        val fb_h = self.engine.height()
        var rx = x
        var ry = y
        var rw = w
        var rh = h
        if rx < 0:
            rw = rw + rx
            rx = 0
        if ry < 0:
            rh = rh + ry
            ry = 0
        if rx + rw > fb_w:
            rw = fb_w - rx
        if ry + rh > fb_h:
            rh = fb_h - ry
        if rw <= 0 or rh <= 0:
            return

        var passes: i32 = 1
        if radius >= 2u32:
            passes = 2
        if radius >= 4u32:
            passes = 3

        var src_full = self.engine.read_pixels()
        var pass_i: i32 = 0
        while pass_i < passes:
            var out: [u32] = [0u32; rw * rh]
            var row: i32 = 0
            while row < rh:
                var col: i32 = 0
                while col < rw:
                    var sumR: i32 = 0
                    var sumG: i32 = 0
                    var sumB: i32 = 0
                    var n: i32 = 0
                    var dy: i32 = -1
                    while dy <= 1:
                        var dx: i32 = -1
                        while dx <= 1:
                            val sx = rx + col + dx
                            val sy = ry + row + dy
                            if sx >= 0 and sx < fb_w and sy >= 0 and sy < fb_h:
                                val p = src_full[sy * fb_w + sx]
                                sumR = sumR + color_r(p)
                                sumG = sumG + color_g(p)
                                sumB = sumB + color_b(p)
                                n = n + 1
                            dx = dx + 1
                        dy = dy + 1
                    if n > 0:
                        out[row * rw + col] = rgba(sumR / n, sumG / n, sumB / n, 255)
                    else:
                        out[row * rw + col] = src_full[(ry + row) * fb_w + (rx + col)]
                    col = col + 1
                row = row + 1
            self.engine.draw_image(rx, ry, rw, rh, out)
            # Re-read for the next pass (cheap and guarantees correctness
            # even on backends where draw_image has its own quirks).
            if pass_i + 1 < passes:
                src_full = self.engine.read_pixels()
            pass_i = pass_i + 1

    me gradient_v(x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32):
        """Vertical gradient via the Engine2D facade primitive."""
        self.engine.draw_gradient_rect(x, y, w, h, color1, color2)

    fn read_pixel(x: i32, y: i32) -> u32:
        """Single-pixel read via Engine2D.read_pixels.

        `read_pixels` returns a full-frame copy; for hot read paths a
        per-pixel backend method would be cheaper, but for the compositor's
        glass overlay use case (a handful of probes per frame) the extra
        copy is acceptable and avoids touching the RenderBackend trait.
        """
        if x < 0 or y < 0:
            return 0u32
        val w = self.engine.width()
        val h = self.engine.height()
        if x >= w or y >= h:
            return 0u32
        val pixels = self.engine.read_pixels()
        pixels[y * w + x]

impl Engine2dCompositorBackend:

    static fn create(engine: Engine2D) -> Engine2dCompositorBackend:
        """Wrap an Engine2D as a CompositorBackend."""
        val w = engine.width()
        val h = engine.height()
        Engine2dCompositorBackend(engine: engine, w: w, h: h)

# ============================================================================
# CompositorEngine2D — Engine2D-driven compositor facade
# ============================================================================

class CompositorEngine2D:
    """Engine2D-backed window compositor facade.

    Composition (not inheritance):
      - `engine`  is the Engine2D the compositor paints through.
      - `backend` adapts that Engine2D to the `CompositorBackend` trait.
      - `inner`   is the standard `Compositor` built via
                  `Compositor.with_backends(backend, input, w, h)`.

    For callers that take a `Compositor` directly (e.g. `DesktopShell`),
    pass `ce2d.inner` — it is a real `Compositor`, just one whose
    render path goes through Engine2D.
    """
    engine: Engine2D
    backend: Engine2dCompositorBackend
    inner: Compositor

impl CompositorEngine2D:

    static fn new(engine: Engine2D, kb: Ps2Keyboard, mouse: Ps2Mouse) -> CompositorEngine2D:
        """Create a compositor whose paint path runs through Engine2D.

        Args:
            engine: Engine2D (typically from `create_fb_engine(fb)`)
            kb:     PS/2 keyboard for input events
            mouse:  PS/2 mouse for input events

        Returns:
            CompositorEngine2D whose `.inner` Compositor is ready to
            hand to DesktopShell.
        """
        val w = engine.width()
        val h = engine.height()
        val backend = Engine2dCompositorBackend.create(engine)
        val input = Ps2InputBackend.create(kb, mouse)
        val compositor = Compositor.with_backends(backend, input, w, h)
        CompositorEngine2D(
            engine: engine,
            backend: backend,
            inner: compositor
        )

    me run():
        """Run the compositor event loop (delegates to inner.run via the
        standard shell flow). Callers that already drive the event loop
        through DesktopShell.run() do not need this — it is provided for
        parity with the legacy `Compositor.run()` entry point."""
        self.inner.running = true
        while self.inner.running:
            self.inner.handle_input()
            self.inner.render_all()

    me as_compositor() -> Compositor:
        """Return the underlying `Compositor` for code that is typed
        against it (e.g. `DesktopShell.new`)."""
        self.inner
