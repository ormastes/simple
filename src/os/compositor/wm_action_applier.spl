# Shared WM action application helpers.
#
# Host and SimpleOS adapters should translate platform/wire requests into
# WmAction, then apply the common compositor mutations here.

use os.compositor.compositor.{Compositor}
use os.services.wm.wm_world.{WmAction, wm_action_none}
use os.userlib.ipc_protocol.{COMP_CREATE_WINDOW, COMP_CREATE_WEB_WINDOW, COMP_DESTROY_WINDOW, COMP_UPDATE_TREE, COMP_FOCUS, COMP_RESIZE, COMP_MOVE, COMP_SET_TITLE, COMP_MINIMIZE, COMP_MAXIMIZE, COMP_RESTORE}

class WmActionApplyResult:
    compositor: Compositor
    window_id: u64
    applied: bool

fn apply_wm_action_to_compositor(compositor: Compositor, action: WmAction) -> WmActionApplyResult:
    var next = compositor
    match action.kind:
        "create_window":
            val wid = next.create_remote_window(action.title, action.x, action.y, action.width, action.height, action.owner_port)
            next.set_window_identity(wid.value.to_i32(), action.process_id.to_i64(), action.app_id)
            return WmActionApplyResult(compositor: next, window_id: wid.value, applied: true)
        "create_web_window":
            val web_wid = next.create_remote_window(action.title, action.x, action.y, action.width, action.height, action.owner_port)
            next.set_window_identity(web_wid.value.to_i32(), action.process_id.to_i64(), action.app_id)
            return WmActionApplyResult(compositor: next, window_id: web_wid.value, applied: true)
        "destroy_window":
            next.destroy_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "focus":
            next.focus_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "resize":
            next.resize_window(action.window_id, action.width, action.height)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "move":
            next.move_window(action.window_id, action.x, action.y)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "set_title":
            next.set_window_title(action.window_id, action.title)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "minimize":
            next.minimize_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "maximize":
            next.maximize_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "restore":
            next.restore_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "update_tree":
            next.update_window_tree(action.window_id, action.content)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        _:
            return WmActionApplyResult(compositor: next, window_id: 0, applied: false)

fn wm_action_is_shared_lifecycle(kind: text) -> bool:
    kind == "create_window" or kind == "create_web_window" or kind == "destroy_window" or kind == "focus" or kind == "resize" or kind == "move" or kind == "set_title" or kind == "minimize" or kind == "maximize" or kind == "restore" or kind == "update_tree"

fn wm_action_from_bridge_request(owner_port: i64, method: i64, window_id: i64, title: text, x: i32, y: i32, w: i32, h: i32, content: text, process_id: i64, app_id: text) -> WmAction:
    var src_port: u64 = 0
    if owner_port > 0:
        src_port = owner_port.to_u64()
    var pid: u64 = src_port
    if process_id > 0:
        pid = process_id.to_u64()
    val wid = if window_id > 0: window_id.to_u64() else: 0
    if method == COMP_CREATE_WEB_WINDOW.to_i64():
        return WmAction(kind: "create_web_window", window_id: 0, title: title, x: x, y: y, width: w, height: h, content: content, process_id: pid, app_id: app_id, owner_port: src_port, src_port: src_port)
    if method == COMP_CREATE_WINDOW.to_i64() or (window_id == 0 and title.len() > 0 and w > 0 and h > 0):
        return WmAction(kind: "create_window", window_id: 0, title: title, x: x, y: y, width: w, height: h, content: content, process_id: pid, app_id: app_id, owner_port: src_port, src_port: src_port)
    if method == COMP_DESTROY_WINDOW.to_i64():
        return WmAction(kind: "destroy_window", window_id: wid, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_UPDATE_TREE.to_i64():
        return WmAction(kind: "update_tree", window_id: wid, title: "", x: 0, y: 0, width: 0, height: 0, content: content, process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_FOCUS.to_i64():
        return WmAction(kind: "focus", window_id: wid, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_RESIZE.to_i64():
        return WmAction(kind: "resize", window_id: wid, title: "", x: 0, y: 0, width: w, height: h, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_MOVE.to_i64():
        return WmAction(kind: "move", window_id: wid, title: "", x: x, y: y, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_SET_TITLE.to_i64():
        return WmAction(kind: "set_title", window_id: wid, title: title, x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_MINIMIZE.to_i64():
        return WmAction(kind: "minimize", window_id: wid, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_MAXIMIZE.to_i64():
        return WmAction(kind: "maximize", window_id: wid, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    if method == COMP_RESTORE.to_i64():
        return WmAction(kind: "restore", window_id: wid, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)
    wm_action_none()
