# Shared WM action application helpers.
#
# Host and SimpleOS adapters should translate platform/wire requests into
# WmAction, then apply the common compositor mutations here.

use common.ui.builder.{column, panel, statusbar, text_widget, build_tree_with_title}
use common.ui.widget.{UITree}
use common.ui.web_render_api.{WebRenderRequest, WEB_RENDER_TARGET_SIMPLE_WEB}
use os.compositor.compositor.{Compositor}
use os.compositor.web_render_surface.{compositor_default_web_page_html}
use os.services.wm.wm_action.{WmAction, wm_action_none}
use common.window_protocol.compositor_methods.{COMP_CREATE_WINDOW, COMP_CREATE_WEB_WINDOW, COMP_DESTROY_WINDOW, COMP_UPDATE_TREE, COMP_FOCUS, COMP_RESIZE, COMP_MOVE, COMP_SET_TITLE, COMP_MINIMIZE, COMP_MAXIMIZE, COMP_RESTORE}
# Taskbar item geometry moved to common.ui.window_scene_draw_ir (pure math,
# reused by the SharedWmScene->CompositorBackend executor); re-exported here
# under the same names so existing callers are unaffected.
export use common.ui.window_scene_draw_ir.{wm_taskbar_item_width, wm_taskbar_dock_width, wm_taskbar_item_x}

class WmActionApplyResult:
    compositor: Compositor
    window_id: u64
    applied: bool
export use os.compositor.wm_action_lifecycle.*

fn wm_action_remote_tree(window_id: u64, content: text) -> UITree:
    val wid_str = "{window_id}"
    val root = column("remote_{wid_str}", [
        panel("remote_content_{wid_str}", "", [
            text_widget("remote_text_{wid_str}", content)
        ]),
        statusbar("remote_status_{wid_str}", "Remote window {wid_str}", "Updated")
    ])
    build_tree_with_title(root, "Window {wid_str}", "dark")

fn wm_action_web_window_request(window_id: u64, title: text, url: text, width: i32, height: i32) -> WebRenderRequest:
    val surface_id = "web_window_{window_id}"
    val body = compositor_default_web_page_html(url)
    WebRenderRequest.html(WEB_RENDER_TARGET_SIMPLE_WEB, title, body, "", "", width, height).with_surface(surface_id).with_pixel_output()

fn apply_wm_action_to_compositor(compositor: Compositor, action: WmAction) -> WmActionApplyResult:
    var next = compositor
    match action.kind:
        "create_window":
            val wid = next.create_remote_window(action.title, action.x, action.y, action.width, action.height, action.owner_port)
            next.update_window_content(wid.value, action.content)
            next.set_window_identity(wid.value.to_i32(), action.process_id.to_i64(), action.app_id)
            return WmActionApplyResult(compositor: next, window_id: wid.value, applied: true)
        "create_web_window":
            val web_wid = next.create_remote_window(action.title, action.x, action.y, action.width, action.height, action.owner_port)
            next.update_window_tree(web_wid.value, wm_action_web_window_request(web_wid.value, action.title, action.content, action.width, action.height))
            next.update_window_content(web_wid.value, compositor_default_web_page_html(action.content))
            next.set_window_identity(web_wid.value.to_i32(), action.process_id.to_i64(), action.app_id)
            return WmActionApplyResult(compositor: next, window_id: web_wid.value, applied: true)
        "destroy_window":
            next.destroy_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "focus":
            next.focus_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "resize":
            next.resize_window(action.window_id, action.width, action.height)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "move":
            next.move_window(action.window_id, action.x, action.y)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "set_title":
            next.set_window_title(action.window_id, action.title)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "minimize":
            next.minimize_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "maximize":
            next.maximize_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "restore":
            next.restore_window(action.window_id)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        "update_tree":
            next.update_window_tree(action.window_id, wm_action_remote_tree(action.window_id, action.content))
            next.update_window_content(action.window_id, action.content)
            return WmActionApplyResult(compositor: next, window_id: action.window_id, applied: true)
        _:
            return WmActionApplyResult(compositor: next, window_id: 0, applied: false)

