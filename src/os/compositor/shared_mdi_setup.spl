# Shared Simple Web MDI surface definitions for hosted and QEMU WM lanes.

class SharedMdiSurface:
    title: text
    app_id: text
    content: text
    x: i32
    y: i32
    w: i32
    h: i32
    process_id: i64

fn shared_mdi_surfaces() -> [SharedMdiSurface]:
    [
        SharedMdiSurface(title: "Terminal", app_id: "terminal", content: "simple$ build check --live", x: 58, y: 76, w: 236, h: 142, process_id: 101),
        SharedMdiSurface(title: "Editor", app_id: "editor", content: "src/main.spl   real Simple Web text", x: 276, y: 120, w: 256, h: 154, process_id: 102),
        SharedMdiSurface(title: "Browser", app_id: "browser", content: "about:network", x: 150, y: 256, w: 278, h: 150, process_id: 103),
        SharedMdiSurface(title: "File Manager", app_id: "file-manager", content: "home", x: 486, y: 250, w: 238, h: 142, process_id: 104),
        SharedMdiSurface(title: "Calculator", app_id: "calculator", content: "0", x: 642, y: 82, w: 202, h: 138, process_id: 105)
    ]
