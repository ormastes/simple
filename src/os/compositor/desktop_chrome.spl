#![allow(unnamed_duplicate_typed_args)]
# Desktop Chrome — Shared system bar + dock rendering
#
# Pure Simple implementation using CompositorBackend trait.
# Shared between hosted (winit) and baremetal (QEMU) window managers.
# Ported from QEMU ARM64 wm_entry.spl glass system bar + dock.

use os.compositor.display_backend.{CompositorBackend}
use os.compositor.glass_port.{GlassPortConfig}
use os.compositor.rendering_primitives.{rounded_rect_aa, gradient_h, filled_circle, superellipse_rect}
use os.compositor.flex_layout.{FlexItem, flex_fixed, flex_fill, flex_compute, flex_x, flex_w}
use os.compositor.easing.{bounce_offset}
use os.compositor.glass_dispatch.{cap_blend_rect, cap_blur_region, cap_gradient_v, cap_read_pixel}
use common.ui.glass_numeric_tokens.{GLASS_ICON_TERM, GLASS_ICON_FILES, GLASS_ICON_CALC, GLASS_ICON_CLOCK, GLASS_ICON_SETTINGS, GLASS_ICON_BROWSER, GLASS_ICON_EDITOR, GLASS_DARK_ELEVATED, GLASS_DARK_SURFACE}

# ============================================================================
# Chrome Configuration
# ============================================================================

val SYSTEM_BAR_HEIGHT: i32 = 28
val DOCK_HEIGHT: i32 = 58
val DOCK_ICON_SIZE: i32 = 40
val DOCK_PILL_SIZE: i32 = 48
val DOCK_ICON_GAP: i32 = 16
val DOCK_ICON_PAD: i32 = 4
val DOCK_CORNER_RADIUS: i32 = 26
val DOCK_MARGIN_BOTTOM: i32 = 6

# Icon colors — sourced from common.ui.glass_numeric_tokens (Stitch-aligned).
# See doc/07_guide/theme/stitch_simple_os_theme.md for the token registry.
val ICON_TERM: u32     = GLASS_ICON_TERM
val ICON_FILES: u32    = GLASS_ICON_FILES
val ICON_CALC: u32     = GLASS_ICON_CALC
val ICON_CLOCK: u32    = GLASS_ICON_CLOCK
val ICON_SETTINGS: u32 = GLASS_ICON_SETTINGS
val ICON_BROWSER: u32  = GLASS_ICON_BROWSER
val ICON_EDITOR: u32   = GLASS_ICON_EDITOR

# ============================================================================
# System Bar (top 28px)
# ============================================================================

fn draw_system_bar(backend: CompositorBackend, config: GlassPortConfig, active_win: i32, frame: i32):
    """Draw the macOS-style system bar at the top of the screen.

    Includes: logo, active app name, menu items (File, Edit, View, Go, Window),
    search icon, control center, Wi-Fi, battery, volume, clock.
    All rendered via CompositorBackend for cross-platform use.
    """
    val sw = backend.width()
    val h = SYSTEM_BAR_HEIGHT

    # Glass blur + tint
    cap_blur_region(backend, 0, 0, sw, h, 24)
    cap_blur_region(backend, 0, 0, sw, h, 10)
    cap_blend_rect(backend, 0, 0, sw, h, config.accent_color, 5)
    cap_blend_rect(backend, 0, 0, sw, h, 0x004080FF, 12)
    # Rose undertone tint
    cap_blend_rect(backend, 0, 0, sw, h, 0x00FF6B8A, 3)

    # Gradient overlay: elevated → surface (sourced from glass_numeric_tokens)
    val elevated: u32 = GLASS_DARK_ELEVATED
    val surface: u32 = GLASS_DARK_SURFACE
    cap_gradient_v(backend, 0, 0, sw, h, elevated, surface)
    cap_blend_rect(backend, 0, 0, sw, h / 2, 0x00FFFFFF, 8)
    cap_blend_rect(backend, 0, h / 2, sw, h / 2, 0x00000000, 8)
    cap_blend_rect(backend, 0, 1, sw, 1, 0x00FFFFFF, 35)
    cap_blend_rect(backend, 0, 0, sw, 1, 0x00FFFFFF, 30)

    # Bottom separator
    cap_blend_rect(backend, 0, h - 1, sw, 1, config.border_color, 38)
    cap_blend_rect(backend, 0, h - 2, sw, 1, config.accent_color, 15)

    # Edge accents
    cap_blend_rect(backend, 4, 4, 2, h - 8, config.accent_color, 30)
    cap_blend_rect(backend, sw - 6, 4, 2, h - 8, config.accent2_color, 30)

    # Top-left light catch
    cap_blend_rect(backend, 4, 2, 20, 15, 0x00FFFFFF, 5)

    # Flex layout for system bar items
    var items: [FlexItem] = []
    items = items.push(flex_fixed(28))    # 0: logo
    items = items.push(flex_fixed(68))    # 1: app name
    items = items.push(flex_fixed(210))   # 2: menu items
    items = items.push(flex_fill(1))      # 3: spacer
    items = items.push(flex_fixed(24))    # 4: search
    items = items.push(flex_fixed(20))    # 5: control center
    items = items.push(flex_fixed(32))    # 6: wifi
    items = items.push(flex_fixed(20))    # 7: volume
    items = items.push(flex_fixed(60))    # 8: battery
    items = items.push(flex_fixed(20))    # 9: avatar
    items = items.push(flex_fixed(80))    # 10: clock
    items = flex_compute(items, sw - 20, 8)
    val base_x: i32 = 10

    # Logo at flex_x(items, 0)
    val logo_x = base_x + flex_x(items, 0)
    cap_blend_rect(backend, logo_x, 4, 28, 20, config.accent_color, 200)
    cap_blend_rect(backend, logo_x + 2, 5, 24, 9, 0x00FFFFFF, 40)
    backend.fill_rect(logo_x + 22, 6, 3, 3, 0x00FFFFFF)

    # Active app name at flex_x(items, 1)
    val name_x = base_x + flex_x(items, 1)
    val app_name = if active_win == 0: "Terminal"
                   else if active_win == 1: "Editor"
                   else: "Finder"
    backend.draw_text(name_x, 6, app_name, 0xFFE0E0F0, 0x00000000)

    # Green running dot
    _draw_filled_circle(backend, name_x + 68, 10, 4, 0xFF30D158)

    # Menu items at flex_x(items, 2)
    val menu_x = base_x + flex_x(items, 2)
    cap_blend_rect(backend, menu_x - 2, 5, 38, 18, 0x00FFFFFF, 25)
    cap_blend_rect(backend, menu_x - 2, 5, 38, 18, config.accent_color, 8)
    backend.draw_text(menu_x, 6, "File", 0xFFE0E0F0, 0x00000000)
    cap_blend_rect(backend, menu_x, 19, 34, 1, config.accent_color, 120)
    cap_blend_rect(backend, menu_x, 20, 34, 1, config.accent_color, 40)
    backend.draw_text(menu_x + 46, 6, "Edit", 0xFFC8C8D0, 0x00000000)
    backend.draw_text(menu_x + 90, 6, "View", 0xFFC8C8D0, 0x00000000)
    backend.draw_text(menu_x + 134, 6, "Go", 0xFFC8C8D0, 0x00000000)
    backend.draw_text(menu_x + 162, 6, "Window", 0xFFC8C8D0, 0x00000000)

    # Search icon at flex_x(items, 4)
    val search_x = base_x + flex_x(items, 4)
    _draw_ring(backend, search_x, 5, 12, 2, 0xFFE0E0F0, 150)
    cap_blend_rect(backend, search_x + 10, 15, 4, 2, 0x00E0E0F0, 150)

    # Control center (2×2 grid of small circles)
    val cc_x = base_x + flex_x(items, 5)
    _draw_filled_circle(backend, cc_x + 4, 8, 3, 0xFFE0E0F0)
    _draw_filled_circle(backend, cc_x + 12, 8, 3, 0xFFE0E0F0)
    _draw_filled_circle(backend, cc_x + 4, 16, 3, 0xFFE0E0F0)
    _draw_filled_circle(backend, cc_x + 12, 16, 3, 0xFFE0E0F0)

    # Wi-Fi icon at flex_x(items, 6)
    val wifi_x = base_x + flex_x(items, 6)
    _draw_ring(backend, wifi_x, 4, 16, 2, 0xFFE0E0F0, 140)
    _draw_ring(backend, wifi_x + 3, 7, 10, 2, 0xFFE0E0F0, 160)
    _draw_filled_circle(backend, wifi_x + 7, 13, 4, 0xFFE0E0F0)

    # Volume icon (speaker rect + 2 lines)
    val vol_x = base_x + flex_x(items, 7)
    backend.fill_rect(vol_x + 2, 10, 4, 8, 0xFFE0E0F0)
    backend.fill_rect(vol_x + 6, 8, 2, 12, 0xFFE0E0F0)
    cap_blend_rect(backend, vol_x + 10, 10, 1, 8, 0x00E0E0F0, 120)
    cap_blend_rect(backend, vol_x + 13, 8, 1, 12, 0x00E0E0F0, 100)

    # Battery at flex_x(items, 8)
    val bx = base_x + flex_x(items, 8)
    cap_blend_rect(backend, bx, 8, 24, 12, 0x00E0E0F0, 160)
    cap_blend_rect(backend, bx + 1, 9, 22, 10, 0x00000000, 200)
    cap_blend_rect(backend, bx + 2, 10, 16, 8, 0x0030D158, 200)
    cap_blend_rect(backend, bx + 24, 11, 3, 6, 0x00E0E0F0, 100)
    backend.draw_text(bx + 30, 6, "85%", 0xFFA0A0B0, 0x00000000)

    # User avatar circle
    val av_x = base_x + flex_x(items, 9)
    _draw_filled_circle(backend, av_x + 4, 6, 8, config.accent2_color)
    cap_blend_rect(backend, av_x + 5, 7, 6, 6, 0x00FFFFFF, 200)

    # Clock at flex_x(items, 10) — computed from frame count (~10 fps)
    val clx = base_x + flex_x(items, 10)
    val clock_bg: u32 = GLASS_DARK_ELEVATED
    cap_blend_rect(backend, clx, 4, 72, 20, clock_bg, 100)
    cap_blend_rect(backend, clx - 2, 3, 76, 22, config.accent_color, 8)
    val total_sec = frame / 10
    val hours = (12 + total_sec / 3600) % 12
    val mins = (total_sec / 60) % 60
    val h_str = if hours == 0: "12" else if hours < 10: " {hours}" else: "{hours}"
    val m_str = if mins < 10: "0{mins}" else: "{mins}"
    val time_str = "{h_str}:{m_str} PM"
    backend.draw_text(clx + 4, 6, time_str, 0xFFE0E0F0, 0x00000000)

    # Notification dot
    _draw_filled_circle(backend, clx + 66, 2, 5, 0xFFFF3B30)

# ============================================================================
# Dock (bottom)
# ============================================================================

fn _dock_icon_scale(pill: i32, cursor_x: i32, cursor_y: i32, icon_cx: i32, dock_y: i32, dock_h: i32) -> i32:
    """Compute magnified pill size based on cursor distance to icon center."""
    val in_zone = cursor_y > dock_y - 30 and cursor_y < dock_y + dock_h + 30
    if not in_zone:
        return pill
    val dx = cursor_x - icon_cx
    val dist = if dx < 0: 0 - dx else: dx
    if dist < 40:
        return pill + 12
    if dist < 80:
        return pill + 6
    pill

fn draw_dock(backend: CompositorBackend, config: GlassPortConfig, active_win: i32, cursor_x: i32, cursor_y: i32, bounce_icon: i32, bounce_progress: i32):
    """Draw the macOS-style dock at the bottom of the screen.

    Includes: 7 app icons + separator + 2 utility icons + running indicators.
    Uses pill-shaped icon containers with gradient reflections.
    bounce_icon: dock icon index to bounce (-1 = none).
    bounce_progress: 0-100 animation progress.
    """
    val sw = backend.width()
    val sh = backend.height()

    val num_icons: i32 = 9
    val pill = DOCK_PILL_SIZE
    val gap = DOCK_ICON_GAP
    val sep_w: i32 = 2
    val sep_gap: i32 = 10
    val pad: i32 = 16

    val dock_w = 7 * (pill + gap) + sep_w + sep_gap * 2 + 2 * (pill + gap) - gap + pad * 2
    val dock_h: i32 = 52
    val dock_x = (sw - dock_w) / 2
    val dock_y = sh - dock_h - DOCK_MARGIN_BOTTOM

    # Glass background
    cap_blur_region(backend, dock_x, dock_y, dock_w, dock_h, 24)
    cap_blur_region(backend, dock_x, dock_y, dock_w, dock_h, 12)
    cap_blend_rect(backend, dock_x, dock_y, dock_w, dock_h, config.accent_color, 6)
    cap_blend_rect(backend, dock_x, dock_y, dock_w, dock_h, 0x00FFFFFF, 12)
    cap_blend_rect(backend, dock_x, dock_y, dock_w, dock_h, 0x004080FF, 12)

    # Rounded surface fill
    rounded_rect_aa(backend, dock_x, dock_y, dock_w, dock_h, config.surface_color, DOCK_CORNER_RADIUS, config.surface_alpha)

    # Inner white ring (1px inset from surface)
    rounded_rect_aa(backend, dock_x + 1, dock_y + 1, dock_w - 2, dock_h - 2, 0x00FFFFFF, DOCK_CORNER_RADIUS - 1, 10)
    # Light wash (2px inset)
    cap_blend_rect(backend, dock_x + 2, dock_y + 2, dock_w - 4, dock_h - 4, 0x00FFFFFF, 15)
    # Pink accent (4px inset)
    cap_blend_rect(backend, dock_x + 4, dock_y + 4, dock_w - 8, dock_h - 8, 0x00FF6B8A, 3)
    # Side highlights (3px white strips on left and right)
    cap_blend_rect(backend, dock_x + 1, dock_y + 8, 3, dock_h - 16, 0x00FFFFFF, 8)
    cap_blend_rect(backend, dock_x + dock_w - 4, dock_y + 8, 3, dock_h - 16, 0x00FFFFFF, 8)
    # Fresnel edge glow (brighter at top/bottom edges)
    cap_blend_rect(backend, dock_x + 8, dock_y + 1, dock_w - 16, 2, 0x00FFFFFF, 12)
    cap_blend_rect(backend, dock_x + 8, dock_y + dock_h - 3, dock_w - 16, 2, 0x00FFFFFF, 6)

    # Top/bottom highlights
    cap_blend_rect(backend, dock_x + 8, dock_y + 1, dock_w - 16, 1, 0x00FFFFFF, 35)
    cap_blend_rect(backend, dock_x + 2, dock_y + 2, dock_w - 4, 1, 0x00FFFFFF, 15)

    # Border
    cap_blend_rect(backend, dock_x, dock_y, dock_w, 1, config.border_color, config.border_alpha)
    cap_blend_rect(backend, dock_x, dock_y + dock_h - 1, dock_w, 1, config.border_color, config.border_alpha)
    cap_blend_rect(backend, dock_x, dock_y, 1, dock_h, config.border_color, config.border_alpha)
    cap_blend_rect(backend, dock_x + dock_w - 1, dock_y, 1, dock_h, config.border_color, config.border_alpha)

    # Dock bottom shadow
    cap_blend_rect(backend, dock_x + 8, dock_y + dock_h, dock_w - 16, 3, 0x00000000, 25)

    # Top accent gradient stripe (accent -> accent2)
    gradient_h(backend, dock_x + 20, dock_y + 1, dock_w - 40, 2, config.accent_color, config.accent2_color)
    # Bottom accent gradient stripe (accent2 -> accent)
    gradient_h(backend, dock_x + 20, dock_y + dock_h - 3, dock_w - 40, 2, config.accent2_color, config.accent_color)

    # Dynamic Island notch
    val notch_w: i32 = 80
    val notch_h: i32 = 6
    val notch_x = dock_x + (dock_w - notch_w) / 2
    val notch_y = dock_y - notch_h + 2
    cap_blend_rect(backend, notch_x + 4, notch_y + 2, notch_w - 8, notch_h, config.surface_color, config.surface_alpha + 30)
    cap_blend_rect(backend, notch_x + 2, notch_y + 4, notch_w - 4, notch_h - 4, config.surface_color, config.surface_alpha + 30)
    _draw_filled_circle(backend, notch_x + notch_w / 2 - 14, notch_y + 5, 3, 0xFF0A84FF)
    _draw_filled_circle(backend, notch_x + notch_w / 2 - 2, notch_y + 5, 3, 0xFF30D158)
    _draw_filled_circle(backend, notch_x + notch_w / 2 + 10, notch_y + 5, 3, 0xFFBB86FC)

    # Bounce offset for dock icon animation
    val b_off = if bounce_icon >= 0: bounce_offset(bounce_progress) else: 0

    # Draw icons (with hover magnification + bounce)
    val icon_y = dock_y + 4
    var ix: i32 = dock_x + pad

    # 1. Terminal (icon index 0)
    var by = if bounce_icon == 0: 0 - b_off else: 0
    var mag = _dock_icon_scale(pill, cursor_x, cursor_y, ix + pill / 2, dock_y, dock_h)
    var mo = (pill - mag) / 2
    _draw_dock_icon(backend, ix + mo, icon_y + mo + by, mag, ICON_TERM, config)
    _draw_icon_terminal(backend, ix + mo + DOCK_ICON_PAD, icon_y + mo + by + DOCK_ICON_PAD, mag - DOCK_ICON_PAD * 2)
    ix = ix + pill + gap

    # 2. Files (icon index 1)
    by = if bounce_icon == 1: 0 - b_off else: 0
    mag = _dock_icon_scale(pill, cursor_x, cursor_y, ix + pill / 2, dock_y, dock_h)
    mo = (pill - mag) / 2
    _draw_dock_icon(backend, ix + mo, icon_y + mo + by, mag, ICON_FILES, config)
    _draw_icon_files(backend, ix + mo + DOCK_ICON_PAD, icon_y + mo + by + DOCK_ICON_PAD, mag - DOCK_ICON_PAD * 2)
    ix = ix + pill + gap

    # 3. Calculator (icon index 2)
    by = if bounce_icon == 2: 0 - b_off else: 0
    mag = _dock_icon_scale(pill, cursor_x, cursor_y, ix + pill / 2, dock_y, dock_h)
    mo = (pill - mag) / 2
    _draw_dock_icon(backend, ix + mo, icon_y + mo + by, mag, ICON_CALC, config)
    _draw_icon_calc(backend, ix + mo + DOCK_ICON_PAD, icon_y + mo + by + DOCK_ICON_PAD, mag - DOCK_ICON_PAD * 2)
    ix = ix + pill + gap

    # 4. Clock (icon index 3)
    by = if bounce_icon == 3: 0 - b_off else: 0
    mag = _dock_icon_scale(pill, cursor_x, cursor_y, ix + pill / 2, dock_y, dock_h)
    mo = (pill - mag) / 2
    _draw_dock_icon(backend, ix + mo, icon_y + mo + by, mag, ICON_CLOCK, config)
    _draw_icon_clock(backend, ix + mo + DOCK_ICON_PAD, icon_y + mo + by + DOCK_ICON_PAD, mag - DOCK_ICON_PAD * 2)
    ix = ix + pill + gap

    # 5. Settings (icon index 4)
    by = if bounce_icon == 4: 0 - b_off else: 0
    mag = _dock_icon_scale(pill, cursor_x, cursor_y, ix + pill / 2, dock_y, dock_h)
    mo = (pill - mag) / 2
    _draw_dock_icon(backend, ix + mo, icon_y + mo + by, mag, ICON_SETTINGS, config)
    _draw_icon_settings(backend, ix + mo + DOCK_ICON_PAD, icon_y + mo + by + DOCK_ICON_PAD, mag - DOCK_ICON_PAD * 2)
    ix = ix + pill + gap

    # 6. Browser (icon index 5)
    by = if bounce_icon == 5: 0 - b_off else: 0
    mag = _dock_icon_scale(pill, cursor_x, cursor_y, ix + pill / 2, dock_y, dock_h)
    mo = (pill - mag) / 2
    _draw_dock_icon(backend, ix + mo, icon_y + mo + by, mag, ICON_BROWSER, config)
    _draw_icon_browser(backend, ix + mo + DOCK_ICON_PAD, icon_y + mo + by + DOCK_ICON_PAD, mag - DOCK_ICON_PAD * 2)
    ix = ix + pill + gap

    # 7. Editor (icon index 6)
    by = if bounce_icon == 6: 0 - b_off else: 0
    mag = _dock_icon_scale(pill, cursor_x, cursor_y, ix + pill / 2, dock_y, dock_h)
    mo = (pill - mag) / 2
    _draw_dock_icon(backend, ix + mo, icon_y + mo + by, mag, ICON_EDITOR, config)
    _draw_icon_editor(backend, ix + mo + DOCK_ICON_PAD, icon_y + mo + by + DOCK_ICON_PAD, mag - DOCK_ICON_PAD * 2)

    # Notification badge on Editor icon
    val badge_x = ix + mo + mag - 8
    val badge_y = icon_y + mo + by + 2
    _draw_filled_circle(backend, badge_x, badge_y, 6, 0xFFFF3B30)
    _draw_filled_circle(backend, badge_x + 2, badge_y + 2, 2, 0xFFFFFFFF)

    # Separator
    val sep_x = ix + pill + sep_gap
    cap_blend_rect(backend, sep_x, dock_y + 8, sep_w, dock_h - 16, config.border_color, config.border_alpha)
    ix = sep_x + sep_w + sep_gap

    # 8. Finder (icon index 7)
    by = if bounce_icon == 7: 0 - b_off else: 0
    mag = _dock_icon_scale(pill, cursor_x, cursor_y, ix + pill / 2, dock_y, dock_h)
    mo = (pill - mag) / 2
    _draw_dock_icon(backend, ix + mo, icon_y + mo + by, mag, 0x004A90D9, config)
    _draw_icon_finder(backend, ix + mo + DOCK_ICON_PAD, icon_y + mo + by + DOCK_ICON_PAD, mag - DOCK_ICON_PAD * 2)
    ix = ix + pill + gap

    # 9. Trash (icon index 8)
    by = if bounce_icon == 8: 0 - b_off else: 0
    mag = _dock_icon_scale(pill, cursor_x, cursor_y, ix + pill / 2, dock_y, dock_h)
    mo = (pill - mag) / 2
    _draw_dock_icon(backend, ix + mo, icon_y + mo + by, mag, 0x00808080, config)
    _draw_icon_trash(backend, ix + mo + DOCK_ICON_PAD, icon_y + mo + by + DOCK_ICON_PAD, mag - DOCK_ICON_PAD * 2)

    # Running indicators (dots)
    val dot_y = dock_y + dock_h - 6
    val first_dot = dock_x + pad + pill / 2 - 2

    # Running indicators for open apps (Terminal=0, Files=1, Browser=5, Editor=6)
    _draw_running_dot(backend, first_dot, dot_y, config.accent_color)
    _draw_running_dot(backend, first_dot + (pill + gap), dot_y, config.accent_color)
    _draw_running_dot(backend, first_dot + 5 * (pill + gap), dot_y, config.accent_color)
    _draw_running_dot(backend, first_dot + 6 * (pill + gap), dot_y, config.accent_color)

    # Active window highlight dot (white)
    val active_dot_x = first_dot + active_win * (pill + gap)
    _draw_filled_circle(backend, active_dot_x, dot_y, 3, 0xFFFFFFFF)

    # Active app icon glow halo
    val glow_ix = dock_x + pad + active_win * (pill + gap)
    cap_blend_rect(backend, glow_ix, icon_y, pill, pill, config.accent_color, 15)

    # Reflection below dock
    cap_blend_rect(backend, dock_x + 10, dock_y + dock_h + 2, dock_w - 20, 1, config.surface_color, 20)
    cap_blend_rect(backend, dock_x + 16, dock_y + dock_h + 3, dock_w - 32, 1, config.surface_color, 12)
    cap_blend_rect(backend, dock_x + 24, dock_y + dock_h + 4, dock_w - 48, 1, config.surface_color, 6)

    # Dock icon tooltips (show app name above hovered icon)
    val tip_y = dock_y - 24
    var tip_ix: i32 = dock_x + pad
    var ti: i32 = 0
    while ti < 7:
        val tip_cx = tip_ix + pill / 2
        val in_zone = cursor_y > dock_y - 30 and cursor_y < dock_y + dock_h + 30
        val tip_dx = cursor_x - tip_cx
        val tip_dist = if tip_dx < 0: 0 - tip_dx else: tip_dx
        if in_zone and tip_dist < 30:
            var tip_name: text = ""
            var tip_w: i32 = 80
            if ti == 0:
                tip_name = "Terminal"
                tip_w = 76
            else if ti == 1:
                tip_name = "Files"
                tip_w = 52
            else if ti == 2:
                tip_name = "Calculator"
                tip_w = 92
            else if ti == 3:
                tip_name = "Clock"
                tip_w = 52
            else if ti == 4:
                tip_name = "Settings"
                tip_w = 76
            else if ti == 5:
                tip_name = "Browser"
                tip_w = 68
            else if ti == 6:
                tip_name = "Editor"
                tip_w = 60
            if tip_w > 0:
                val tip_x = tip_cx - tip_w / 2
                # Glass tooltip background
                cap_blur_region(backend, tip_x, tip_y, tip_w, 20, 8)
                cap_blend_rect(backend, tip_x, tip_y, tip_w, 20, config.surface_color, config.surface_alpha)
                # Border
                cap_blend_rect(backend, tip_x, tip_y, tip_w, 1, config.border_color, config.border_alpha)
                cap_blend_rect(backend, tip_x, tip_y + 19, tip_w, 1, config.border_color, config.border_alpha)
                cap_blend_rect(backend, tip_x, tip_y, 1, 20, config.border_color, config.border_alpha)
                cap_blend_rect(backend, tip_x + tip_w - 1, tip_y, 1, 20, config.border_color, config.border_alpha)
                # Tooltip text
                backend.draw_text(tip_x + 6, tip_y + 2, tip_name, 0xFFE0E0F0, 0x00000000)
        tip_ix = tip_ix + pill + gap
        ti = ti + 1

# ============================================================================
# Dock Icon Helpers
# ============================================================================

fn _draw_dock_icon(backend: CompositorBackend, x: i32, y: i32, size: i32, color: u32, config: GlassPortConfig):
    """Draw a pill-shaped dock icon container with rounded corners."""
    # Pill background (superellipse, radius=14)
    superellipse_rect(backend, x, y, size, size, config.surface_color, 14, 60)
    # Pill border
    superellipse_rect(backend, x, y, size, size, 0x00FFFFFF, 14, 20)
    # Top highlight
    cap_blend_rect(backend, x + 4, y + 1, size - 8, 1, 0x00FFFFFF, 25)
    # Icon color fill (content area)
    superellipse_rect(backend, x + 2, y + 2, size - 4, size - 4, color, 12, 200)
    # Lighter top (3D gradient)
    cap_blend_rect(backend, x + 4, y + 4, size - 8, size / 3, 0x00FFFFFF, 25)
    # Darker bottom
    cap_blend_rect(backend, x + 4, y + size * 2 / 3, size - 8, size / 3 - 4, 0x00000000, 20)
    # Wallpaper color reflection on icon tops
    cap_blend_rect(backend, x + 4, y + 4, size - 8, 14, 0x00304060, 8)
    # Reflection top (white shimmer)
    cap_blend_rect(backend, x + 4, y + 4, size - 8, 4, 0x00FFFFFF, 10)
    # Dark shadow below icon
    cap_blend_rect(backend, x + 4, y + size + 1, size - 8, 3, 0x00000000, 20)
    # Color reflection below
    cap_blend_rect(backend, x + 4, y + size + 2, size - 8, 4, color, 22)

fn _draw_icon_terminal(backend: CompositorBackend, x: i32, y: i32, s: i32):
    """Draw terminal icon content."""
    cap_blend_rect(backend, x + 2, y + 2, s - 4, s - 4, 0x001A1A2E, 200)
    cap_blend_rect(backend, x + 6, y + s / 2, 8, 2, 0x0044FF44, 255)
    backend.fill_rect(x + 14, y + s / 2 - 2, 2, 6, 0xFF44FF44)

fn _draw_icon_files(backend: CompositorBackend, x: i32, y: i32, s: i32):
    """Draw files/folder icon content."""
    cap_blend_rect(backend, x + 2, y + 6, s - 4, s - 8, 0x001E8449, 220)
    backend.fill_rect(x + 6, y + 12, s - 12, 2, 0xFFFFFFFF)
    backend.fill_rect(x + 6, y + 16, s - 16, 2, 0xFFFFFFFF)

fn _draw_icon_calc(backend: CompositorBackend, x: i32, y: i32, s: i32):
    """Draw calculator icon content."""
    cap_blend_rect(backend, x + 2, y + 2, s - 4, 8, 0x00FFFFFF, 120)
    val bsz: i32 = 7
    cap_blend_rect(backend, x + 3, y + 13, bsz, bsz, 0x00FFFFFF, 200)
    cap_blend_rect(backend, x + 11, y + 13, bsz, bsz, 0x00FFFFFF, 200)
    cap_blend_rect(backend, x + 19, y + 13, bsz, bsz, 0x00FFFFFF, 200)

fn _draw_icon_clock(backend: CompositorBackend, x: i32, y: i32, s: i32):
    """Draw clock icon content."""
    _draw_ring(backend, x + 2, y + 2, s - 4, 2, 0xFFFFFFFF, 180)
    cap_blend_rect(backend, x + s / 2, y + s / 2, 2, 0 - s / 4, 0x00FFFFFF, 200)
    cap_blend_rect(backend, x + s / 2, y + s / 2, s / 4, 2, 0x00FFFFFF, 200)

fn _draw_icon_settings(backend: CompositorBackend, x: i32, y: i32, s: i32):
    """Draw settings gear icon content."""
    _draw_ring(backend, x + 4, y + 4, s - 8, 3, 0xFFFFFFFF, 160)
    _draw_filled_circle(backend, x + s / 2 - 3, y + s / 2 - 3, 4, 0xFFFFFFFF)
    backend.fill_rect(x + s / 2 - 1, y, 2, 4, 0xFFFFFFFF)
    backend.fill_rect(x + s / 2 - 1, y + s - 4, 2, 4, 0xFFFFFFFF)
    backend.fill_rect(x, y + s / 2 - 1, 4, 2, 0xFFFFFFFF)
    backend.fill_rect(x + s - 4, y + s / 2 - 1, 4, 2, 0xFFFFFFFF)

fn _draw_icon_browser(backend: CompositorBackend, x: i32, y: i32, s: i32):
    """Draw browser globe icon content."""
    _draw_ring(backend, x + 2, y + 2, s - 4, 2, 0xFFFFFFFF, 180)
    cap_blend_rect(backend, x + s / 3, y + 2, 1, s - 4, 0x00FFFFFF, 120)
    cap_blend_rect(backend, x + s * 2 / 3, y + 2, 1, s - 4, 0x00FFFFFF, 120)

fn _draw_icon_editor(backend: CompositorBackend, x: i32, y: i32, s: i32):
    """Draw editor icon content."""
    cap_blend_rect(backend, x + 4, y + 2, s - 8, s - 4, 0x00FFFFFF, 140)
    backend.fill_rect(x + 8, y + 7, s - 16, 2, 0xFF148F77)
    backend.fill_rect(x + 8, y + 12, s - 18, 2, 0xFF148F77)
    backend.fill_rect(x + 8, y + 17, s - 14, 2, 0xFF148F77)

fn _draw_icon_finder(backend: CompositorBackend, x: i32, y: i32, s: i32):
    """Draw Finder icon (face with eyes)."""
    cap_blend_rect(backend, x + s / 2, y, s / 2, s, 0x00357ABD, 120)
    _draw_filled_circle(backend, x + 6, y + 8, 3, 0xFFFFFFFF)
    _draw_filled_circle(backend, x + 18, y + 8, 3, 0xFFFFFFFF)
    _draw_filled_circle(backend, x + 7, y + 8, 2, 0xFF000000)
    _draw_filled_circle(backend, x + 19, y + 8, 2, 0xFF000000)
    cap_blend_rect(backend, x + 6, y + 18, 18, 6, 0x00FFFFFF, 200)

fn _draw_icon_trash(backend: CompositorBackend, x: i32, y: i32, s: i32):
    """Draw trash can icon."""
    cap_blend_rect(backend, x + 4, y + 2, s - 8, 4, 0x00C0C0C0, 255)
    cap_blend_rect(backend, x + 6, y + 8, s - 12, s - 12, 0x00A0A0A0, 220)
    cap_blend_rect(backend, x + 10, y + 11, 2, s - 18, 0x00808080, 180)
    cap_blend_rect(backend, x + 14, y + 11, 2, s - 18, 0x00808080, 180)
    cap_blend_rect(backend, x + 18, y + 11, 2, s - 18, 0x00808080, 180)

fn _draw_running_dot(backend: CompositorBackend, x: i32, y: i32, color: u32):
    """Draw a running app indicator dot with outer glow."""
    # Outer glow
    filled_circle(backend, x, y, 4, color, 40)
    # Main dot
    filled_circle(backend, x, y, 3, color, 220)

# ============================================================================
# Geometry Primitives (shared)
# ============================================================================

fn _draw_filled_circle(backend: CompositorBackend, cx: i32, cy: i32, r: i32, color: u32):
    """Draw a filled circle at center (cx+r, cy+r) with radius r."""
    var dy: i32 = 0
    while dy < r * 2:
        val dist_y = dy - r
        val abs_dy = if dist_y < 0: 0 - dist_y else: dist_y
        val hw = r - abs_dy
        if hw > 0:
            backend.fill_rect(cx + r - hw, cy + dy, hw * 2, 1, color)
        dy = dy + 1

fn _draw_ring(backend: CompositorBackend, x: i32, y: i32, size: i32, thickness: i32, color: u32, alpha: u8):
    """Draw a circle outline (ring)."""
    val r = size / 2
    var dy: i32 = 0
    while dy < size:
        val dist_y = dy - r
        val abs_dy = if dist_y < 0: 0 - dist_y else: dist_y
        val hw_outer = r - abs_dy
        val inner_r = r - thickness
        val hw_inner = if abs_dy < inner_r: inner_r - abs_dy else: 0
        if hw_outer > 0:
            val left_w = hw_outer - hw_inner
            if left_w > 0:
                cap_blend_rect(backend, x + r - hw_outer, y + dy, left_w, 1, color, alpha)
                cap_blend_rect(backend, x + r + hw_inner, y + dy, left_w, 1, color, alpha)
        dy = dy + 1
