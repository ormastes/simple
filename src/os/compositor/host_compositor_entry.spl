use common.window_protocol.geometry.{Size}
use common.ui.web_render_api.{WEB_RENDER_TARGET_SIMPLE_WEB}
use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}
use os.compositor.hosted_backend_sdl2.{HostedSdl2Backend}
use os.compositor.hosted_backend_cocoa.{HostedCocoaBackend}
use os.compositor.hosted_backend_win32.{HostedWin32Backend}
use os.compositor.simple_gui_window_renderer.{render_simple_gui_app_content}
use os.compositor.wm_action_applier.{WmLifecycleWindowState, WmPointerInteractionState, apply_wm_action_to_lifecycle_windows, wm_action_from_bridge_request, wm_destroy_action, wm_focus_action, wm_lifecycle_hit_taskbar, wm_lifecycle_left_button, wm_lifecycle_pointer_move, wm_taskbar_dock_width, wm_taskbar_item_width, wm_taskbar_item_x}
use os.services.wm.wm_service.{WmService}
use os.services.wm.wm_world.{WmAction}
use os.userlib.ipc_protocol.{COMP_MINIMIZE, COMP_RESTORE}

extern fn rt_sleep_ms(ms: i64)

val HOST_WM_IDLE_SLEEP_MS: i32 = 16

enum HostBackendKind:
    Browser
    WebCanvas
    Electron
    Tauri
    Tui
    Sdl2
    Cocoa
    Win32
    Headless

class HostWmConfig:
    backend: HostBackendKind
    initial_size: Size
    title: text

class HostWmAppProcess:
    title: text
    app_id: text
    source_path: text
    pid: i64
    failed: bool

class HostedWindow:
    id: i64
    owner_port: i64
    title: text
    x: i32
    y: i32
    w: i32
    h: i32
    content: text
    process_id: i64
    app_id: text
    minimized: bool
    focused: bool

class HeadlessHostCompositorBackend:
    w: i32
    h: i32
    pixels: [u32]
    present_count: i64

    static fn new(width: i32, height: i32) -> HeadlessHostCompositorBackend:
        val total = if width > 0 and height > 0: width * height else: 0
        HeadlessHostCompositorBackend(
            w: width,
            h: height,
            pixels: [0u32; total],
            present_count: 0
        )

impl CompositorBackend for HeadlessHostCompositorBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        var i = 0
        while i < self.pixels.len():
            self.pixels[i] = color
            i = i + 1

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        var yy = y
        while yy < y + h:
            var xx = x
            while xx < x + w:
                self.put_pixel(xx, yy, color)
                xx = xx + 1
            yy = yy + 1

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        if text_str.len() > 0:
            self.fill_rect(x, y, text_str.len().to_i32() * 8, 16, bg)
            self.put_pixel(x, y, fg)

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        self.fill_rect(x, y, 8, 16, bg)
        self.put_pixel(x, y, fg)

    me put_pixel(x: i32, y: i32, color: u32):
        if x < 0 or y < 0 or x >= self.w or y >= self.h:
            return
        val idx = y * self.w + x
        if idx >= 0 and idx < self.pixels.len():
            self.pixels[idx] = color

    me blit_pixels(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        var row: i32 = 0
        while row < h:
            var col: i32 = 0
            while col < w:
                val src_idx = row * w + col
                if src_idx >= 0 and src_idx < pixels.len():
                    self.put_pixel(x + col, y + row, pixels[src_idx])
                col = col + 1
            row = row + 1

    me present():
        self.present_count = self.present_count + 1

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        self.present_count = self.present_count + 1

    fn as_glass_capable() -> CompositorGlassCapable?:
        nil

class HostCompositor:
    backend: CompositorBackend
    width: i32
    height: i32
    windows: [HostedWindow]
    next_window_id: i64
    app_processes: [HostWmAppProcess]
    dragging: bool
    drag_window_id: i64
    drag_offset_x: i32
    drag_offset_y: i32
    resizing: bool
    resize_window_id: i64
    resize_start_x: i32
    resize_start_y: i32
    resize_start_w: i32
    resize_start_h: i32
    pointer_x: i32
    pointer_y: i32

    static fn new(backend: CompositorBackend, size: Size) -> HostCompositor:
        HostCompositor(
            backend: backend,
            width: size.width.to_i32(),
            height: size.height.to_i32(),
            windows: [],
            next_window_id: 1,
            app_processes: [],
            dragging: false,
            drag_window_id: 0,
            drag_offset_x: 0,
            drag_offset_y: 0,
            resizing: false,
            resize_window_id: 0,
            resize_start_x: 0,
            resize_start_y: 0,
            resize_start_w: 0,
            resize_start_h: 0,
            pointer_x: 0,
            pointer_y: 0
        )

    me resize(width: i32, height: i32):
        self.width = width
        self.height = height

    me render_frame():
        self.backend.clear(0xFF0F172Au32)
        var i = 0
        while i < self.windows.len():
            val win = self.windows[i]
            if not win.minimized:
                self.backend.fill_rect(win.x, win.y, win.w, win.h, 0xFF1E293Bu32)
                self.backend.fill_rect(win.x, win.y, win.w, 24, 0xFF2563EBu32)
                self.backend.draw_text(win.x + 8, win.y + 4, win.title, 0xFFFFFFFFu32, 0xFF2563EBu32)
                self.backend.fill_rect(win.x + win.w - 24, win.y, 24, 24, 0xFFCC3333u32)
                self.backend.draw_text(win.x + win.w - 17, win.y + 4, "X", 0xFFFFFFFFu32, 0xFFCC3333u32)
                val cx = win.x + 4
                val cy = win.y + 28
                val cw = win.w - 8
                val ch = win.h - 32
                render_simple_gui_app_content(self.backend, win.title, cx, cy, cw, ch, win.content)
            i = i + 1
        self.backend.present()

    me apply_bridge_request(seq: i64, owner_port: i64, method: i64, window_id: i64, title: text, x: i32, y: i32, w: i32, h: i32, content: text, process_id: i64, app_id: text):
        val action = wm_action_from_bridge_request(owner_port, method, window_id, title, x, y, w, h, content, process_id, app_id)
        self.apply_wm_action(action)

    me apply_wm_action(action: WmAction):
        val out = host_compositor_apply_lifecycle_action(self, action)
        self.windows = out.windows
        self.next_window_id = out.next_window_id

    fn _find_window_index(window_id: i64) -> i32:
        var i = 0
        while i < self.windows.len():
            if self.windows[i].id == window_id:
                return i
            i = i + 1
        -1

    me destroy_window(window_id: i64):
        self.apply_wm_action(wm_destroy_action(window_id))

    me focus_window(window_id: i64):
        self.apply_wm_action(wm_focus_action(window_id))

    fn hit_taskbar(x: i32, y: i32) -> i64:
        wm_lifecycle_hit_taskbar(host_windows_to_lifecycle_state(self.windows), self.width, self.height, x, y)

    me pointer_move(x: i32, y: i32):
        self.pointer_x = x
        self.pointer_y = y
        val out = host_compositor_pointer_move(self, x, y)
        self.windows = out.windows
        self.next_window_id = out.next_window_id
        self.dragging = out.dragging
        self.drag_window_id = out.drag_window_id
        self.drag_offset_x = out.drag_offset_x
        self.drag_offset_y = out.drag_offset_y
        self.resizing = out.resizing
        self.resize_window_id = out.resize_window_id
        self.resize_start_x = out.resize_start_x
        self.resize_start_y = out.resize_start_y
        self.resize_start_w = out.resize_start_w
        self.resize_start_h = out.resize_start_h

    me handle_mouse_move(x: i32, y: i32):
        self.pointer_move(x, y)

    me handle_left_button(down: bool):
        val out = host_compositor_left_button_at(self, down, self.pointer_x, self.pointer_y)
        self.windows = out.windows
        self.next_window_id = out.next_window_id
        self.dragging = out.dragging
        self.drag_window_id = out.drag_window_id
        self.drag_offset_x = out.drag_offset_x
        self.drag_offset_y = out.drag_offset_y
        self.resizing = out.resizing
        self.resize_window_id = out.resize_window_id
        self.resize_start_x = out.resize_start_x
        self.resize_start_y = out.resize_start_y
        self.resize_start_w = out.resize_start_w
        self.resize_start_h = out.resize_start_h

    me record_launch_failure(index: i32):
        if index < 0 or index >= self.app_processes.len():
            return
        var proc = self.app_processes[index]
        proc.failed = true
        self.app_processes[index] = proc
        val id = self.next_window_id
        self.next_window_id = self.next_window_id + 1
        self.windows.push(HostedWindow(id: id, owner_port: 0, title: proc.title + " failed", x: 40, y: 80, w: 360, h: 180, content: "failed to create a window for " + proc.app_id, process_id: proc.pid, app_id: proc.app_id, minimized: false, focused: true))

class HostWmHandle:
    compositor: HostCompositor
    wm: WmService
    event_loop_id: i64
    window_id: i64
    backend: HostBackendKind

    fn pump_host_events() -> i64:
        if self.event_loop_id == 0:
            return 0
        0

    me run_once():
        if not self.wm.running:
            return
        self.compositor.render_frame()

    me tick_forever():
        while self.wm.running:
            self.pump_host_events()
            self.run_once()
            rt_sleep_ms(HOST_WM_IDLE_SLEEP_MS.to_i64())

class SimpleOsGuiAdapter:
    compositor: HostCompositor
    delivered_input_events: i64
    delivered_bridge_events: i64
    presented_frames: i64

    static fn new(backend: CompositorBackend, size: Size) -> SimpleOsGuiAdapter:
        SimpleOsGuiAdapter(
            compositor: HostCompositor.new(backend, size),
            delivered_input_events: 0,
            delivered_bridge_events: 0,
            presented_frames: 0
        )

    me deliver_bridge_request(seq: i64, owner_port: i64, method: i64, window_id: i64, title: text, x: i32, y: i32, w: i32, h: i32, content: text, process_id: i64, app_id: text):
        self.delivered_bridge_events = self.delivered_bridge_events + 1
        self.compositor.apply_bridge_request(seq, owner_port, method, window_id, title, x, y, w, h, content, process_id, app_id)

    me deliver_pointer_move(x: i32, y: i32):
        self.delivered_input_events = self.delivered_input_events + 1
        self.compositor = host_compositor_pointer_move(self.compositor, x, y)

    me deliver_left_button(down: bool):
        self.delivered_input_events = self.delivered_input_events + 1
        self.compositor = host_compositor_left_button(self.compositor, down)

    me render_framebuffer_frame():
        self.compositor.render_frame()
        self.presented_frames = self.presented_frames + 1

fn simpleos_gui_adapter_display_path_name(adapter: SimpleOsGuiAdapter) -> text:
    if adapter.compositor.width <= 0 or adapter.compositor.height <= 0:
        return "invalid"
    "simpleos-framebuffer"

fn simpleos_gui_adapter_content_renderer_name(adapter: SimpleOsGuiAdapter) -> text:
    if simpleos_gui_adapter_display_path_name(adapter) == "invalid":
        return "unsupported"
    WEB_RENDER_TARGET_SIMPLE_WEB

fn host_wm_surface_failure_reason(cfg: HostWmConfig, event_loop_id: i64, window_id: i64) -> text?:
    if cfg.backend == HostBackendKind.Tui:
        return "tui host compositor bootstrap is not implemented"
    if cfg.initial_size.width.to_i32() <= 0 or cfg.initial_size.height.to_i32() <= 0:
        return "host compositor size must be nonzero"
    if event_loop_id == 0 or window_id == 0:
        return "host compositor surface must be nonzero"
    nil

fn _create_backend_for_kind(kind: HostBackendKind, w: i32, h: i32, title: text) -> CompositorBackend?:
    if kind == HostBackendKind.Sdl2:
        val sdl = HostedSdl2Backend.try_create(w, h, title)
        if sdl != nil:
            return sdl
        return nil
    if kind == HostBackendKind.Cocoa:
        val cocoa = HostedCocoaBackend.try_create(0, w, h, 0xFF0F172Au32)
        if cocoa != nil:
            return cocoa
        return nil
    if kind == HostBackendKind.Win32:
        val win32 = HostedWin32Backend.try_create(0, w, h, 0xFF0F172Au32)
        if win32 != nil:
            return win32
        return nil
    if kind == HostBackendKind.Tui:
        return nil
    HeadlessHostCompositorBackend.new(w, h)

fn init_host_wm(cfg: HostWmConfig) -> HostWmHandle?:
    if cfg.backend == HostBackendKind.Tui:
        return nil
    val event_loop_id = 1
    val window_id = 1
    val reason = host_wm_surface_failure_reason(cfg, event_loop_id, window_id)
    if reason != nil:
        return nil
    val w = cfg.initial_size.width.to_i32()
    val h = cfg.initial_size.height.to_i32()
    val backend = _create_backend_for_kind(cfg.backend, w, h, cfg.title)
    if backend == nil:
        return nil
    val comp = HostCompositor.new(backend, cfg.initial_size)
    val wm = WmService.new()
    wm.running = true
    HostWmHandle(
        compositor: comp,
        wm: wm,
        event_loop_id: event_loop_id,
        window_id: window_id,
        backend: cfg.backend
    )

fn host_wm_content_renderer_name(handle: HostWmHandle) -> text:
    if handle.backend == HostBackendKind.Tui:
        return "unsupported"
    WEB_RENDER_TARGET_SIMPLE_WEB

fn host_compositor_find_window_index(comp: HostCompositor, window_id: i64) -> i32:
    var i = 0
    while i < comp.windows.len():
        if comp.windows[i].id == window_id:
            return i
        i = i + 1
    -1

fn host_window_to_lifecycle_state(win: HostedWindow) -> WmLifecycleWindowState:
    WmLifecycleWindowState(id: win.id, owner_port: win.owner_port, title: win.title, x: win.x, y: win.y, w: win.w, h: win.h, content: win.content, process_id: win.process_id, app_id: win.app_id, minimized: win.minimized, focused: win.focused)

fn host_window_from_lifecycle_state(win: WmLifecycleWindowState) -> HostedWindow:
    HostedWindow(id: win.id, owner_port: win.owner_port, title: win.title, x: win.x, y: win.y, w: win.w, h: win.h, content: win.content, process_id: win.process_id, app_id: win.app_id, minimized: win.minimized, focused: win.focused)

fn host_windows_to_lifecycle_state(windows: [HostedWindow]) -> [WmLifecycleWindowState]:
    var out: [WmLifecycleWindowState] = []
    var i = 0
    while i < windows.len():
        out.push(host_window_to_lifecycle_state(windows[i]))
        i = i + 1
    out

fn host_windows_from_lifecycle_state(windows: [WmLifecycleWindowState]) -> [HostedWindow]:
    var out: [HostedWindow] = []
    var i = 0
    while i < windows.len():
        out.push(host_window_from_lifecycle_state(windows[i]))
        i = i + 1
    out

fn host_compositor_apply_lifecycle_action(comp: HostCompositor, action: WmAction) -> HostCompositor:
    var out = comp
    val result = apply_wm_action_to_lifecycle_windows(host_windows_to_lifecycle_state(out.windows), out.next_window_id, out.width, out.height, action)
    out.windows = host_windows_from_lifecycle_state(result.windows)
    out.next_window_id = result.next_window_id
    out

fn host_compositor_pointer_move(comp: HostCompositor, x: i32, y: i32) -> HostCompositor:
    var out = comp
    val interaction = WmPointerInteractionState(dragging: out.dragging, drag_window_id: out.drag_window_id, drag_offset_x: out.drag_offset_x, drag_offset_y: out.drag_offset_y, resizing: out.resizing, resize_window_id: out.resize_window_id, resize_start_x: out.resize_start_x, resize_start_y: out.resize_start_y, resize_start_w: out.resize_start_w, resize_start_h: out.resize_start_h)
    val result = wm_lifecycle_pointer_move(host_windows_to_lifecycle_state(out.windows), out.next_window_id, out.width, out.height, interaction, x, y)
    out.windows = host_windows_from_lifecycle_state(result.windows)
    out.next_window_id = result.next_window_id
    out.dragging = result.interaction.dragging
    out.drag_window_id = result.interaction.drag_window_id
    out.drag_offset_x = result.interaction.drag_offset_x
    out.drag_offset_y = result.interaction.drag_offset_y
    out.resizing = result.interaction.resizing
    out.resize_window_id = result.interaction.resize_window_id
    out.resize_start_x = result.interaction.resize_start_x
    out.resize_start_y = result.interaction.resize_start_y
    out.resize_start_w = result.interaction.resize_start_w
    out.resize_start_h = result.interaction.resize_start_h
    out

fn host_compositor_left_button(comp: HostCompositor, down: bool) -> HostCompositor:
    host_compositor_left_button_at(comp, down, comp.pointer_x, comp.pointer_y)

fn host_compositor_left_button_at(comp: HostCompositor, down: bool, x: i32, y: i32) -> HostCompositor:
    var out = comp
    out.pointer_x = x
    out.pointer_y = y
    if down:
        var hit_idx = -1
        var i = 0
        while i < out.windows.len():
            val win = out.windows[i]
            if not win.minimized and x >= win.x and x < win.x + win.w and y >= win.y and y < win.y + win.h:
                hit_idx = i
            i = i + 1
        if hit_idx >= 0:
            val hit = out.windows[hit_idx]
            if x >= hit.x + hit.w - 24 and y >= hit.y and y < hit.y + 24:
                out.destroy_window(hit.id)
                return out
            out.focus_window(hit.id)
            if y >= hit.y and y < hit.y + 24:
                out.dragging = true
                out.drag_window_id = hit.id
                out.drag_offset_x = x - hit.x
                out.drag_offset_y = y - hit.y
                return out
    val interaction = wm_lifecycle_left_button(WmPointerInteractionState(dragging: out.dragging, drag_window_id: out.drag_window_id, drag_offset_x: out.drag_offset_x, drag_offset_y: out.drag_offset_y, resizing: out.resizing, resize_window_id: out.resize_window_id, resize_start_x: out.resize_start_x, resize_start_y: out.resize_start_y, resize_start_w: out.resize_start_w, resize_start_h: out.resize_start_h), down)
    out.dragging = interaction.dragging
    out.drag_window_id = interaction.drag_window_id
    out.drag_offset_x = interaction.drag_offset_x
    out.drag_offset_y = interaction.drag_offset_y
    out.resizing = interaction.resizing
    out.resize_window_id = interaction.resize_window_id
    out.resize_start_x = interaction.resize_start_x
    out.resize_start_y = interaction.resize_start_y
    out.resize_start_w = interaction.resize_start_w
    out.resize_start_h = interaction.resize_start_h
    out

fn host_compositor_cycle_focus(comp: HostCompositor) -> HostCompositor:
    var out = comp
    if out.windows.len() == 0:
        return out
    var focused_idx = -1
    var i = 0
    while i < out.windows.len():
        if out.windows[i].focused:
            focused_idx = i
        i = i + 1
    var next_idx = focused_idx + 1
    if next_idx >= out.windows.len():
        next_idx = 0
    out.focus_window(out.windows[next_idx].id)
    out

fn host_compositor_focused_window_id(comp: HostCompositor) -> i64:
    var i = 0
    while i < comp.windows.len():
        if comp.windows[i].focused:
            return comp.windows[i].id
        i = i + 1
    if comp.windows.len() > 0:
        return comp.windows[comp.windows.len() - 1].id
    0

fn host_compositor_minimize_focused(comp: HostCompositor) -> HostCompositor:
    val id = host_compositor_focused_window_id(comp)
    if id <= 0:
        return comp
    var out = comp
    out.apply_bridge_request(0, 0, COMP_MINIMIZE.to_i64(), id, "", 0, 0, 0, 0, "", 0, "")
    out

fn host_compositor_restore_all(comp: HostCompositor) -> HostCompositor:
    var out = comp
    var i = 0
    while i < out.windows.len():
        out.apply_bridge_request(0, 0, COMP_RESTORE.to_i64(), out.windows[i].id, "", 0, 0, 0, 0, "", 0, "")
        i = i + 1
    out

fn host_taskbar_item_width(screen_width: i32, count: i32) -> i32:
    wm_taskbar_item_width(screen_width, count)

fn host_taskbar_dock_width(screen_width: i32, count: i32) -> i32:
    wm_taskbar_dock_width(screen_width, count)

fn host_taskbar_item_x(screen_width: i32, count: i32, index: i32) -> i32:
    wm_taskbar_item_x(screen_width, count, index)
