use os.compositor.wm_action_applier.{WmLifecycleWindowState, WmPointerInteractionState, apply_wm_action_to_lifecycle_windows, wm_action_from_bridge_request, wm_destroy_action, wm_focus_action, wm_lifecycle_hit_taskbar, wm_lifecycle_left_button, wm_lifecycle_pointer_move, wm_taskbar_dock_width, wm_taskbar_item_width, wm_taskbar_item_x}
use os.services.wm.wm_service.{WmService}
use os.services.wm.wm_world.{WmAction}
use os.userlib.ipc_protocol.{COMP_MINIMIZE, COMP_RESTORE}

extern fn rt_sleep_ms(ms: i64)

val HOST_WM_IDLE_SLEEP_MS: i32 = 16

# When true, render_frame() always uses the direct-draw chrome path and never
# the fast CSS/GUI-web lane, regardless of Metal availability. Lets callers pin
# the historical byte-identical direct chrome contract (e.g. deterministic unit
# tests on Metal-capable hosts, or a config that disables GPU chrome).
var _host_chrome_force_direct: bool = false

fn host_wm_force_direct_chrome(enabled: bool):
    """Pin (or release) the direct-draw chrome path for render_frame()."""
    _host_chrome_force_direct = enabled

fn host_wm_chrome_force_direct() -> bool:
    """True when render_frame() is pinned to the direct-draw chrome path."""
    _host_chrome_force_direct

enum HostBackendKind:
    Browser
    WebCanvas
    Electron
    Tauri
    Tui
    Sdl2
    Cocoa
    Win32
    Headless

class HostWmConfig:
    backend: HostBackendKind
    initial_size: Size
    title: text

class HostWmAppProcess:
    title: text
    app_id: text
    source_path: text
    pid: i64
    failed: bool

class HostedWindow:
    id: i64
    owner_port: i64
    title: text
    x: i32
    y: i32
    w: i32
    h: i32
    content: text
    process_id: i64
    app_id: text
    minimized: bool
    focused: bool

fn host_window_to_shared_mdi_render_window(win: HostedWindow, scroll_y: i32) -> SharedMdiRenderWindow:
    shared_mdi_render_window(
        win.id,
        win.title,
        win.app_id,
        win.content,
        win.x,
        win.y,
        win.w,
        win.h,
        win.process_id,
        win.minimized,
        win.focused,
        scroll_y
    )

class HeadlessHostCompositorBackend:
    w: i32
    h: i32
    pixels: [u32]
    present_count: i64

    static fn new(width: i32, height: i32) -> HeadlessHostCompositorBackend:
        val total = if width > 0 and height > 0: width * height else: 0
        var pixels: [u32] = []
        var i = 0
        while i < total:
            pixels.push(0u32)
            i = i + 1
        HeadlessHostCompositorBackend(
            w: width,
            h: height,
            pixels: pixels,
            present_count: 0
        )

impl CompositorBackend for HeadlessHostCompositorBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        var i = 0
        while i < self.pixels.len():
            self.pixels[i] = color
            i = i + 1

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        # Writes stay inline in this leaf method: delegating per pixel to
        # self.put_pixel (a me->me call) deep-clones the whole framebuffer on
        # EVERY write under the interpreter (~28ms/px at 1024x768) — see
        # doc/08_tracking/bug/interp_compositor_backend_put_pixel_clones_framebuffer_2026-07-03.md.
        # Bounds are clamped once up front instead of per pixel.
        var x0 = if x < 0: 0 else: x
        var y0 = if y < 0: 0 else: y
        var x1 = x + w
        var y1 = y + h
        if x1 > self.w:
            x1 = self.w
        if y1 > self.h:
            y1 = self.h
        var yy = y0
        while yy < y1:
            var idx = yy * self.w + x0
            var xx = x0
            while xx < x1:
                self.pixels[idx] = color
                idx = idx + 1
                xx = xx + 1
            yy = yy + 1

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        if text_str.len() > 0:
            self.fill_rect(x, y, text_str.len().to_i32() * 8, 16, bg)
            self.put_pixel(x, y, fg)

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        self.fill_rect(x, y, 8, 16, bg)
        self.put_pixel(x, y, fg)

    me put_pixel(x: i32, y: i32, color: u32):
        if x < 0 or y < 0 or x >= self.w or y >= self.h:
            return
        val idx = y * self.w + x
        if idx >= 0 and idx < self.pixels.len():
            self.pixels[idx] = color

    me blit_pixels(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        # Inline writes with once-up-front clamping — same me->me put_pixel
        # framebuffer-clone hazard as fill_rect (see comment there).
        val src_len = pixels.len().to_i32()
        var row: i32 = 0
        while row < h:
            val dy = y + row
            if dy >= 0 and dy < self.h:
                var col0 = if x < 0: 0 - x else: 0
                var col1 = w
                if x + col1 > self.w:
                    col1 = self.w - x
                var col = col0
                var src_idx = row * w + col0
                var dst_idx = dy * self.w + x + col0
                while col < col1:
                    if src_idx >= 0 and src_idx < src_len:
                        self.pixels[dst_idx] = pixels[src_idx]
                    src_idx = src_idx + 1
                    dst_idx = dst_idx + 1
                    col = col + 1
            row = row + 1

    me present():
        self.present_count = self.present_count + 1

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        self.present_count = self.present_count + 1

    fn as_glass_capable() -> CompositorGlassCapable?:
        nil

class HostCompositor:
    backend: CompositorBackend
    width: i32
    height: i32
    windows: [HostedWindow]
    next_window_id: i64
    app_processes: [HostWmAppProcess]
    dragging: bool
    drag_window_id: i64
    drag_offset_x: i32
    drag_offset_y: i32
    resizing: bool
    resize_window_id: i64
    resize_start_x: i32
    resize_start_y: i32
    resize_start_w: i32
    resize_start_h: i32
    pointer_x: i32
    pointer_y: i32
    # Last raw button code/state routed through handle_mouse_button (0=left,
    # 1=middle, 2=right). Left keeps its full chrome semantics via
    # handle_left_button; middle/right have no chrome action yet, so this is
    # the observable evidence that the event reached the compositor instead of
    # being silently dropped at the winit-dispatch layer.
    last_button: i64
    last_button_down: bool
    # Wheel-delta accumulator per hosted window id, keyed by whichever window
    # is under the pointer when a wheel event arrives. render_frame() reads
    # this back via scroll_offset_for(window.id) and threads it into
    # render_simple_web_app_content_cached(), which translates the content
    # layer by that many pixels at paint time (renders `scroll_y` extra rows
    # of the same document, then windows the visible slice — see
    # os.compositor.simple_web_window_renderer._window_scrolled_pixels).
    scroll_offsets: Dict<i64, f64>
    # Chrome-action arming for release-inside click semantics (FIX 2): a
    # mouse-down over a chrome affordance (close button / taskbar item) arms
    # a target instead of firing immediately; the action only fires on
    # mouse-up if the release hit-test still resolves to the same target.
    armed_chrome_target: text
    armed_chrome_window_id: i64
    # Cache for the CSS/GUI-web chrome render lane (see render_frame). The key
    # is host_chrome_scene_fingerprint(); the pixels are the last full-scene
    # chrome rasterization. Empty key means "no cached chrome yet".
    _chrome_cache_key: text
    _chrome_cache_pixels: [u32]
    # Task #15 remainder item 4 (S1 perf): per-window content pixel cache.
    # Keyed by hosted window id so each window's cache tracks its own
    # (width, height, backend) identity independently — see
    # _content_cache_for, which replaces a window's cache whenever that
    # identity changes (resize/rescroll/backend change) and otherwise reuses
    # it so WebRenderPixelArtifactCache's own content-hash (HTML-equality)
    # check can skip re-rendering unchanged window content every frame.
    content_caches: Dict<i64, WebRenderPixelArtifactCache>

    static fn new(backend: CompositorBackend, size: Size) -> HostCompositor:
        HostCompositor(
            backend: backend,
            width: size.width.to_i32(),
            height: size.height.to_i32(),
            windows: [],
            next_window_id: 1,
            app_processes: [],
            dragging: false,
            drag_window_id: 0,
            drag_offset_x: 0,
            drag_offset_y: 0,
            resizing: false,
            resize_window_id: 0,
            resize_start_x: 0,
            resize_start_y: 0,
            resize_start_w: 0,
            resize_start_h: 0,
            pointer_x: 0,
            pointer_y: 0,
            last_button: -1,
            last_button_down: false,
            scroll_offsets: {},
            armed_chrome_target: "",
            armed_chrome_window_id: 0,
            _chrome_cache_key: "",
            _chrome_cache_pixels: [],
            content_caches: {}
        )

    # Returns the WebRenderPixelArtifactCache for `window_id`, creating (or
    # replacing) it when there is none yet or its (width, height,
    # backend_name) identity no longer matches what this frame needs. A
    # replacement starts with an empty last-rendered-HTML slot, so the very
    # next content render after a resize/rescroll/backend change is
    # correctly a miss+store, not a stale hit.
    me _content_cache_for(window_id: i64, cw: i32, full_h: i32, backend_name: text) -> WebRenderPixelArtifactCache:
        val existing = self.content_caches.get(window_id)
        if existing != nil and existing.width == cw and existing.height == full_h and existing.backend_name == backend_name:
            return existing
        val fresh = web_render_pixel_artifact_cache(cw, full_h, backend_name)
        self.content_caches.set(window_id, fresh)
        fresh

    me resize(width: i32, height: i32):
        self.width = width
        self.height = height

    me render_frame():
        val theme = wm_chrome_theme()
        val total = if self.width > 0 and self.height > 0: self.width * self.height else: 0
        # Fast CSS/GUI-web chrome lane: express the WM chrome (desktop backdrop,
        # window bodies, titlebars, close buttons, titles) as ONE HTML/CSS
        # document whose element colors come from wm_chrome_theme(), rasterize it
        # on the native Engine2D fast path (Metal -> one-shot readback), blit the
        # chrome pixels, then compose each window's HTML content on top exactly as
        # before. This routes the chrome through the same web render lane as the
        # window content — the "single HTML/CSS representation for WM UI".
        #
        # Caching contract: the CSS chrome pixels are re-rendered ONLY when the
        # chrome-relevant scene state changes — window list / geometry / focus /
        # minimized / desktop size / theme colors, hashed by
        # host_chrome_scene_fingerprint(). On an unchanged fingerprint the cached
        # buffer is reused (a cheap full-frame blit), so a settled desktop costs
        # one blit per present instead of a full ~1.4s CSS render. Window content
        # is NOT part of the fingerprint (it is redrawn every frame regardless),
        # so content updates never invalidate the chrome cache.
        #
        # Incremental-frame policy: during an active drag/resize every frame's
        # geometry differs, which would force a full ~1.4s CSS re-render per frame
        # (unusably slow for a 60fps interaction). While self.dragging /
        # self.resizing is set we therefore skip the fast lane and direct-draw the
        # chrome; the CSS chrome re-renders once on the next settled frame.
        if total > 0 and not _host_chrome_force_direct and not self.dragging and not self.resizing and engine2d_fast_metal_available():
            val fp = host_chrome_scene_fingerprint(self.windows, self.width, self.height)
            if fp != self._chrome_cache_key or self._chrome_cache_pixels.len() != total:
                val html = host_chrome_scene_html(self.windows, self.width, self.height)
                val chrome_px = simple_web_layout_render_html_pixels_engine2d(html, self.width, self.height, "metal")
                if chrome_px.len() == total:
                    self._chrome_cache_pixels = chrome_px
                    self._chrome_cache_key = fp
            if self._chrome_cache_key == fp and self._chrome_cache_pixels.len() == total:
                self.backend.blit_pixels(0, 0, self.width, self.height, self._chrome_cache_pixels)
                var fi = 0
                while fi < self.windows.len():
                    val fwin = self.windows[fi]
                    if not fwin.minimized:
                        val fcx = fwin.x + 4
                        val fcy = fwin.y + 28
                        val fcw = fwin.w - 8
                        val fch = fwin.h - 32
                        val fscroll = self.scroll_offset_for(fwin.id).to_i32()
                        val ffull_h = content_paint_full_height(fch, fscroll)
                        val fcache = self._content_cache_for(fwin.id, fcw, ffull_h, "auto")
                        render_simple_web_app_content_cached(fcache, self.backend, fwin.title, fcx, fcy, fcw, fch, fwin.content, fscroll)
                        # Dict.get()/.set() copy class values in this interpreter (no
                        # shared-reference semantics for dict-stored class instances),
                        # so the mutations request_to_pixel_artifact() just made inside
                        # fcache (hit/store counters, last-rendered HTML) live only on
                        # this local copy until explicitly written back — otherwise the
                        # very next frame's _content_cache_for() lookup would see a
                        # stale, still-empty cache and never observe a hit.
                        self.content_caches.set(fwin.id, fcache)
                    fi = fi + 1
                self.backend.present()
                return
        # Fallback (Metal unavailable, or active drag/resize): direct-draw the
        # chrome. BYTE-IDENTICAL to the historical host compositor chrome contract
        # (plus the taskbar dock, which the hit-test always honored but no
        # render path ever drew).
        render_shared_mdi_desktop_chrome(self.backend, self.width, self.height, theme)
        var shared_windows: [SharedMdiRenderWindow] = []
        val window_count = self.windows.len()
        var i = 0
        while i < window_count:
            val win = self.windows[i]
            val scroll = self.scroll_offset_for(win.id).to_i32()
            shared_windows.push(host_window_to_shared_mdi_render_window(win, scroll))
            i = i + 1
        # Route host WM chrome/taskbar through the shared Simple GUI internal-
        # window scene projection. Host-only content composition below keeps
        # its scroll/cache state, but chrome/taskbar geometry and metadata come
        # from the same SharedWmScene boundary used by SimpleOS framebuffer
        # rendering.
        val simple_gui_scene = shared_mdi_scene_from_render_windows(self.width, self.height, "host-compositor", shared_windows)
        val simple_gui_windows = shared_mdi_render_windows_from_simple_gui_scene(simple_gui_scene)
        i = 0
        while i < window_count:
            val win = self.windows[i]
            if not win.minimized:
                val scene_win = if i < simple_gui_windows.len(): simple_gui_windows[i] else: shared_windows[i]
                draw_shared_mdi_window_chrome(self.backend, scene_win, theme)
                val cx = win.x + 4
                val cy = win.y + 32
                val cw = win.w - 8
                val ch = win.h - 36
                val scroll = self.scroll_offset_for(win.id).to_i32()
                val full_h = content_paint_full_height(ch, scroll)
                val cache = self._content_cache_for(win.id, cw, full_h, "auto")
                render_simple_web_app_content_cached(cache, self.backend, win.title, cx, cy, cw, ch, win.content, scroll)
                # See the matching write-back comment in the fast chrome lane above.
                self.content_caches.set(win.id, cache)
            i = i + 1
        draw_shared_mdi_taskbar(self.backend, simple_gui_windows, self.width, self.height, theme)
        self.backend.present()

    me apply_bridge_request(seq: i64, owner_port: i64, method: i64, window_id: i64, title: text, x: i32, y: i32, w: i32, h: i32, content: text, process_id: i64, app_id: text):
        val action = wm_action_from_bridge_request(owner_port, method, window_id, title, x, y, w, h, content, process_id, app_id)
        self.apply_wm_action(action)

    me apply_wm_action(action: WmAction):
        val out = host_compositor_apply_lifecycle_action(self, action)
        self.windows = out.windows
        self.next_window_id = out.next_window_id

    fn _find_window_index(window_id: i64) -> i32:
        var i = 0
        while i < self.windows.len():
            if self.windows[i].id == window_id:
                return i
            i = i + 1
        -1

    me destroy_window(window_id: i64):
        self.apply_wm_action(wm_destroy_action(window_id))

    me focus_window(window_id: i64):
        self.apply_wm_action(wm_focus_action(window_id))

    fn hit_taskbar(x: i32, y: i32) -> i64:
        wm_lifecycle_hit_taskbar(host_windows_to_lifecycle_state(self.windows), self.width, self.height, x, y)

    me pointer_move(x: i32, y: i32):
        self.pointer_x = x
        self.pointer_y = y
        val out = host_compositor_pointer_move(self, x, y)
        self.windows = out.windows
        self.next_window_id = out.next_window_id
        self.dragging = out.dragging
        self.drag_window_id = out.drag_window_id
        self.drag_offset_x = out.drag_offset_x
        self.drag_offset_y = out.drag_offset_y
        self.resizing = out.resizing
        self.resize_window_id = out.resize_window_id
        self.resize_start_x = out.resize_start_x
        self.resize_start_y = out.resize_start_y
        self.resize_start_w = out.resize_start_w
        self.resize_start_h = out.resize_start_h

    me handle_mouse_move(x: i32, y: i32):
        self.pointer_move(x, y)

    me handle_left_button(down: bool):
        val out = host_compositor_left_button_at(self, down, self.pointer_x, self.pointer_y)
        self.windows = out.windows
        self.next_window_id = out.next_window_id
        self.dragging = out.dragging
        self.drag_window_id = out.drag_window_id
        self.drag_offset_x = out.drag_offset_x
        self.drag_offset_y = out.drag_offset_y
        self.resizing = out.resizing
        self.resize_window_id = out.resize_window_id
        self.resize_start_x = out.resize_start_x
        self.resize_start_y = out.resize_start_y
        self.resize_start_w = out.resize_start_w
        self.resize_start_h = out.resize_start_h
        self.armed_chrome_target = out.armed_chrome_target
        self.armed_chrome_window_id = out.armed_chrome_window_id

    # Generic pointer-button entry point (0=left, 1=middle, 2=right). Left
    # keeps its full chrome semantics (drag/resize/close/taskbar/focus);
    # middle/right have no WM chrome action defined yet, so they are recorded
    # on last_button/last_button_down instead of being silently dropped.
    me handle_mouse_button(button: i64, down: bool):
        self.last_button = button
        self.last_button_down = down
        if button == 0:
            self.handle_left_button(down)

    # Route a wheel delta to whichever hosted window the pointer currently
    # hovers, accumulating a per-window offset. See scroll_offsets doc above
    # for what this does and does not (yet) drive.
    me handle_mouse_wheel(dx: f64, dy: f64):
        var hit_idx = -1
        var i = 0
        while i < self.windows.len():
            val win = self.windows[i]
            if not win.minimized and self.pointer_x >= win.x and self.pointer_x < win.x + win.w and self.pointer_y >= win.y and self.pointer_y < win.y + win.h:
                hit_idx = i
            i = i + 1
        if hit_idx >= 0:
            val wid = self.windows[hit_idx].id
            val current = self.scroll_offsets.get(wid) ?? 0.0
            self.scroll_offsets[wid] = current + dy

    me scroll_offset_for(window_id: i64) -> f64:
        self.scroll_offsets.get(window_id) ?? 0.0

    me record_launch_failure(index: i32):
        if index < 0 or index >= self.app_processes.len():
            return
        var proc = self.app_processes[index]
        proc.failed = true
        self.app_processes[index] = proc
        val id = self.next_window_id
        self.next_window_id = self.next_window_id + 1
        self.windows.push(HostedWindow(id: id, owner_port: 0, title: proc.title + " failed", x: 40, y: 80, w: 360, h: 180, content: "failed to create a window for " + proc.app_id, process_id: proc.pid, app_id: proc.app_id, minimized: false, focused: true))

class HostWmHandle:
    compositor: HostCompositor
    wm: WmService
    event_loop_id: i64
    window_id: i64
    backend: HostBackendKind

    fn pump_host_events() -> i64:
        if self.event_loop_id == 0:
            return 0
        0

    me run_once():
        if not self.wm.running:
            return
        self.compositor.render_frame()

    me tick_forever():
        while self.wm.running:
            self.pump_host_events()
            self.run_once()
            rt_sleep_ms(HOST_WM_IDLE_SLEEP_MS.to_i64())

class SimpleOsGuiAdapter:
    compositor: HostCompositor
    delivered_input_events: i64
    delivered_bridge_events: i64
    presented_frames: i64

    static fn new(backend: CompositorBackend, size: Size) -> SimpleOsGuiAdapter:
        SimpleOsGuiAdapter(
            compositor: HostCompositor.new(backend, size),
            delivered_input_events: 0,
            delivered_bridge_events: 0,
            presented_frames: 0
        )

    me deliver_bridge_request(seq: i64, owner_port: i64, method: i64, window_id: i64, title: text, x: i32, y: i32, w: i32, h: i32, content: text, process_id: i64, app_id: text):
        self.delivered_bridge_events = self.delivered_bridge_events + 1
        self.compositor.apply_bridge_request(seq, owner_port, method, window_id, title, x, y, w, h, content, process_id, app_id)

    me deliver_pointer_move(x: i32, y: i32):
        self.delivered_input_events = self.delivered_input_events + 1
        self.compositor = host_compositor_pointer_move(self.compositor, x, y)

    me deliver_left_button(down: bool):
        self.delivered_input_events = self.delivered_input_events + 1
        self.compositor = host_compositor_left_button(self.compositor, down)

    me render_framebuffer_frame():
        self.compositor.render_frame()
        self.presented_frames = self.presented_frames + 1

fn simpleos_gui_adapter_display_path_name(adapter: SimpleOsGuiAdapter) -> text:
    if adapter.compositor.width <= 0 or adapter.compositor.height <= 0:
        return "invalid"
    "simpleos-framebuffer"

fn simpleos_gui_adapter_content_renderer_name(adapter: SimpleOsGuiAdapter) -> text:
    if simpleos_gui_adapter_display_path_name(adapter) == "invalid":
        return "unsupported"
    WEB_RENDER_TARGET_SIMPLE_WEB

fn host_wm_surface_failure_reason(cfg: HostWmConfig, event_loop_id: i64, window_id: i64) -> text?:
    if cfg.backend == HostBackendKind.Tui:
        return "tui host compositor bootstrap is not implemented"
    if cfg.initial_size.width.to_i32() <= 0 or cfg.initial_size.height.to_i32() <= 0:
        return "host compositor size must be nonzero"
    if event_loop_id == 0 or window_id == 0:
        return "host compositor surface must be nonzero"
    nil

fn _create_backend_for_kind(kind: HostBackendKind, w: i32, h: i32, title: text) -> CompositorBackend?:
    if kind == HostBackendKind.Sdl2:
        val sdl = HostedSdl2Backend.try_create(w, h, title)
        if sdl != nil:
            return sdl
        return nil
    if kind == HostBackendKind.Cocoa:
        val cocoa = HostedCocoaBackend.try_create(0, w, h, 0xFF0F172Au32)
        if cocoa != nil:
            return cocoa
        return nil
    if kind == HostBackendKind.Win32:
        val win32 = HostedWin32Backend.try_create(0, w, h, 0xFF0F172Au32)
        if win32 != nil:
            return win32
        return nil
    if kind == HostBackendKind.Tui:
        return nil
    HeadlessHostCompositorBackend.new(w, h)

fn init_host_wm(cfg: HostWmConfig) -> HostWmHandle?:
    if cfg.backend == HostBackendKind.Tui:
        return nil
    val event_loop_id = 1
    val window_id = 1
    val reason = host_wm_surface_failure_reason(cfg, event_loop_id, window_id)
    if reason != nil:
        return nil
    val w = cfg.initial_size.width.to_i32()
    val h = cfg.initial_size.height.to_i32()
    val backend = _create_backend_for_kind(cfg.backend, w, h, cfg.title)
    if backend == nil:
        return nil
    val comp = HostCompositor.new(backend, cfg.initial_size)
    val wm = WmService.new()
    wm.running = true
    HostWmHandle(
        compositor: comp,
        wm: wm,
        event_loop_id: event_loop_id,
        window_id: window_id,
        backend: cfg.backend
    )

fn host_wm_content_renderer_name(handle: HostWmHandle) -> text:
    if handle.backend == HostBackendKind.Tui:
        return "unsupported"
    WEB_RENDER_TARGET_SIMPLE_WEB

fn host_compositor_find_window_index(comp: HostCompositor, window_id: i64) -> i32:
    var i = 0
    while i < comp.windows.len():
        if comp.windows[i].id == window_id:
            return i
        i = i + 1
    -1

fn host_window_to_lifecycle_state(win: HostedWindow) -> WmLifecycleWindowState:
    WmLifecycleWindowState(id: win.id, owner_port: win.owner_port, title: win.title, x: win.x, y: win.y, w: win.w, h: win.h, content: win.content, process_id: win.process_id, app_id: win.app_id, minimized: win.minimized, focused: win.focused)

fn host_window_from_lifecycle_state(win: WmLifecycleWindowState) -> HostedWindow:
    HostedWindow(id: win.id, owner_port: win.owner_port, title: win.title, x: win.x, y: win.y, w: win.w, h: win.h, content: win.content, process_id: win.process_id, app_id: win.app_id, minimized: win.minimized, focused: win.focused)

fn host_windows_to_lifecycle_state(windows: [HostedWindow]) -> [WmLifecycleWindowState]:
    var out: [WmLifecycleWindowState] = []
    var i = 0
    while i < windows.len():
        out.push(host_window_to_lifecycle_state(windows[i]))
        i = i + 1
    out

fn host_windows_from_lifecycle_state(windows: [WmLifecycleWindowState]) -> [HostedWindow]:
    var out: [HostedWindow] = []
    var i = 0
    while i < windows.len():
        out.push(host_window_from_lifecycle_state(windows[i]))
        i = i + 1
    out

fn host_compositor_apply_lifecycle_action(comp: HostCompositor, action: WmAction) -> HostCompositor:
    var out = comp
    val result = apply_wm_action_to_lifecycle_windows(host_windows_to_lifecycle_state(out.windows), out.next_window_id, out.width, out.height, action)
    out.windows = host_windows_from_lifecycle_state(result.windows)
    out.next_window_id = result.next_window_id
    out

fn host_compositor_pointer_move(comp: HostCompositor, x: i32, y: i32) -> HostCompositor:
    var out = comp
    val interaction = WmPointerInteractionState(dragging: out.dragging, drag_window_id: out.drag_window_id, drag_offset_x: out.drag_offset_x, drag_offset_y: out.drag_offset_y, resizing: out.resizing, resize_window_id: out.resize_window_id, resize_start_x: out.resize_start_x, resize_start_y: out.resize_start_y, resize_start_w: out.resize_start_w, resize_start_h: out.resize_start_h)
    val result = wm_lifecycle_pointer_move(host_windows_to_lifecycle_state(out.windows), out.next_window_id, out.width, out.height, interaction, x, y)
    out.windows = host_windows_from_lifecycle_state(result.windows)
    out.next_window_id = result.next_window_id
    out.dragging = result.interaction.dragging
    out.drag_window_id = result.interaction.drag_window_id
    out.drag_offset_x = result.interaction.drag_offset_x
    out.drag_offset_y = result.interaction.drag_offset_y
    out.resizing = result.interaction.resizing
    out.resize_window_id = result.interaction.resize_window_id
    out.resize_start_x = result.interaction.resize_start_x
    out.resize_start_y = result.interaction.resize_start_y
    out.resize_start_w = result.interaction.resize_start_w
    out.resize_start_h = result.interaction.resize_start_h
    out

fn host_compositor_left_button(comp: HostCompositor, down: bool) -> HostCompositor:
    host_compositor_left_button_at(comp, down, comp.pointer_x, comp.pointer_y)

fn host_compositor_left_button_at(comp: HostCompositor, down: bool, x: i32, y: i32) -> HostCompositor:
    var out = comp
    out.pointer_x = x
    out.pointer_y = y
    if down:
        # Clear any stale arming from a previous down whose matching up was
        # missed (defensive; the release path below always clears its own arm).
        out.armed_chrome_target = ""
        out.armed_chrome_window_id = 0
        # Taskbar click: a press inside the bottom dock band that lands on a
        # window's taskbar item is a chrome ACTION (focus + restore-if-
        # minimized). Arm it on down; it fires only on a release whose
        # hit-test still resolves to the same taskbar item (release-inside).
        # A drag-away before release cancels it (see the `else` branch below).
        # Checked before the window hit-test because the dock band can
        # overlap a window that extends to the bottom of the desktop.
        val tb_id = out.hit_taskbar(x, y)
        if tb_id > 0:
            out.armed_chrome_target = "taskbar"
            out.armed_chrome_window_id = tb_id
            return out
        var hit_idx = -1
        var i = 0
        while i < out.windows.len():
            val win = out.windows[i]
            if not win.minimized and x >= win.x and x < win.x + win.w and y >= win.y and y < win.y + win.h:
                hit_idx = i
            i = i + 1
        if hit_idx >= 0:
            val hit = out.windows[hit_idx]
            if x >= hit.x + hit.w - 24 and y >= hit.y and y < hit.y + 24:
                # Close button is a chrome ACTION: arm, fire on release-inside.
                out.armed_chrome_target = "close"
                out.armed_chrome_window_id = hit.id
                return out
            # Window-body focus and titlebar drag-arming are unchanged
            # (not converted to release-based semantics).
            out.focus_window(hit.id)
            if y >= hit.y and y < hit.y + 24:
                out.dragging = true
                out.drag_window_id = hit.id
                out.drag_offset_x = x - hit.x
                out.drag_offset_y = y - hit.y
                return out
    else:
        # Release: fire the armed chrome action only if the release hit-test
        # still resolves to the same target (release-inside). Moving away
        # before release (a different taskbar item / off the close button /
        # a different window entirely) cancels the action; the armed state is
        # cleared unconditionally below either way.
        if out.armed_chrome_target == "taskbar":
            val tb_id2 = out.hit_taskbar(x, y)
            if tb_id2 == out.armed_chrome_window_id:
                out.focus_window(tb_id2)
        elif out.armed_chrome_target == "close":
            var close_target_idx = -1
            var j = 0
            while j < out.windows.len():
                if out.windows[j].id == out.armed_chrome_window_id:
                    close_target_idx = j
                j = j + 1
            if close_target_idx >= 0:
                val win = out.windows[close_target_idx]
                if not win.minimized and x >= win.x + win.w - 24 and x < win.x + win.w and y >= win.y and y < win.y + 24:
                    out.destroy_window(win.id)
        out.armed_chrome_target = ""
        out.armed_chrome_window_id = 0
    val interaction = wm_lifecycle_left_button(WmPointerInteractionState(dragging: out.dragging, drag_window_id: out.drag_window_id, drag_offset_x: out.drag_offset_x, drag_offset_y: out.drag_offset_y, resizing: out.resizing, resize_window_id: out.resize_window_id, resize_start_x: out.resize_start_x, resize_start_y: out.resize_start_y, resize_start_w: out.resize_start_w, resize_start_h: out.resize_start_h), down)
    out.dragging = interaction.dragging
    out.drag_window_id = interaction.drag_window_id
    out.drag_offset_x = interaction.drag_offset_x
    out.drag_offset_y = interaction.drag_offset_y
    out.resizing = interaction.resizing
    out.resize_window_id = interaction.resize_window_id
    out.resize_start_x = interaction.resize_start_x
    out.resize_start_y = interaction.resize_start_y
    out.resize_start_w = interaction.resize_start_w
    out.resize_start_h = interaction.resize_start_h
    out

fn host_compositor_cycle_focus(comp: HostCompositor) -> HostCompositor:
    var out = comp
    if out.windows.len() == 0:
        return out
    var focused_idx = -1
    var i = 0
    while i < out.windows.len():
        if out.windows[i].focused:
            focused_idx = i
        i = i + 1
    var next_idx = focused_idx + 1
    if next_idx >= out.windows.len():
        next_idx = 0
    out.focus_window(out.windows[next_idx].id)
    out

fn host_compositor_focused_window_id(comp: HostCompositor) -> i64:
    var i = 0
    while i < comp.windows.len():
        if comp.windows[i].focused:
            return comp.windows[i].id
        i = i + 1
    if comp.windows.len() > 0:
        return comp.windows[comp.windows.len() - 1].id
    0

fn host_compositor_minimize_focused(comp: HostCompositor) -> HostCompositor:
    val id = host_compositor_focused_window_id(comp)
    if id <= 0:
        return comp
    var out = comp
    out.apply_bridge_request(0, 0, COMP_MINIMIZE.to_i64(), id, "", 0, 0, 0, 0, "", 0, "")
    out

fn host_compositor_restore_all(comp: HostCompositor) -> HostCompositor:
    var out = comp
    var i = 0
    while i < out.windows.len():
        out.apply_bridge_request(0, 0, COMP_RESTORE.to_i64(), out.windows[i].id, "", 0, 0, 0, 0, "", 0, "")
        i = i + 1
    out

fn host_taskbar_item_width(screen_width: i32, count: i32) -> i32:
    wm_taskbar_item_width(screen_width, count)

fn host_taskbar_dock_width(screen_width: i32, count: i32) -> i32:
    wm_taskbar_dock_width(screen_width, count)

fn host_taskbar_item_x(screen_width: i32, count: i32, index: i32) -> i32:
    wm_taskbar_item_x(screen_width, count, index)

fn host_compositor_draw_taskbar(backend: CompositorBackend, windows: [HostedWindow], width: i32, height: i32, theme: WmChromeColors):
    """Draw the taskbar dock with one item per window (minimized included —
    that is how restore works). Geometry mirrors wm_lifecycle_hit_taskbar
    EXACTLY (band at height-62, 44 tall; centered items) so what the user
    clicks is what they see. Item colors come from the shared theme:
    focused window -> accent, minimized -> window body, else unfocused
    titlebar color."""
    val count = windows.len().to_i32()
    if count <= 0:
        return
    val dock_w = wm_taskbar_dock_width(width, count)
    val dock_x = (width - dock_w) / 2
    val dock_y = height - 62
    backend.fill_rect(dock_x, dock_y, dock_w, 44, theme.taskbar)
    val item_w = wm_taskbar_item_width(width, count)
    var i: i32 = 0
    while i < count:
        val win = windows[i]
        val ix = wm_taskbar_item_x(width, count, i)
        var item_color = theme.title_unfocused
        if win.focused and not win.minimized:
            item_color = theme.accent
        elif win.minimized:
            item_color = theme.host_window_body
        backend.fill_rect(ix + 2, dock_y + 4, item_w - 4, 36, item_color)
        backend.draw_text(ix + 8, dock_y + 14, win.title, theme.text_primary, item_color)
        i = i + 1

# Convert an opaque ARGB u32 (as stored in WmChromeColors) to a CSS "#RRGGBB"
# hex string. The alpha byte is dropped: the host chrome colors are all opaque
# (0xFF..) and the CSS engine rasterizes #RRGGBB back to the same 0xFF ARGB u32,
# so the fast-lane chrome pixels are byte-identical to the direct-draw colors.
fn _argb_to_css_hex(color: u32) -> text:
    val r = ((color / 65536u32) % 256u32).to_i64()
    val g = ((color / 256u32) % 256u32).to_i64()
    val b = (color % 256u32).to_i64()
    "#" + int_to_hex(r) + int_to_hex(g) + int_to_hex(b)

# Build the host WM chrome as a single HTML/CSS document. Element geometry and
# colors mirror the direct-draw chrome in render_frame() exactly (desktop
# backdrop = compositor_bg, window body = host_window_body, titlebar = accent,
# close button = close_button, title/close glyph text = text_primary), so the
# CSS-rasterized chrome is visually identical to the historical direct output
# for the default theme. Colors flow from wm_chrome_theme() — the single source
# of truth — so an installed theme reskins the chrome automatically.
fn host_chrome_scene_html(windows: [HostedWindow], width: i32, height: i32) -> text:
    val theme = wm_chrome_theme()
    val bg_hex = _argb_to_css_hex(theme.compositor_bg)
    val body_hex = _argb_to_css_hex(theme.host_window_body)
    val accent_hex = _argb_to_css_hex(theme.accent)
    val close_hex = _argb_to_css_hex(theme.close_button)
    val text_hex = _argb_to_css_hex(theme.text_primary)
    var body = ""
    for win in windows:
        if not win.minimized:
            val close_x = win.x + win.w - 24
            val title_x = win.x + 8
            val title_y = win.y + 4
            val close_text_x = win.x + win.w - 17
            val title_w = if win.w - 40 > 0: win.w - 40 else: 0
            body = body + "<div style='position:absolute;left:{win.x}px;top:{win.y}px;width:{win.w}px;height:{win.h}px;background:{body_hex}'></div>"
            body = body + "<div style='position:absolute;left:{win.x}px;top:{win.y}px;width:{win.w}px;height:24px;background:{accent_hex}'></div>"
            body = body + "<div style='position:absolute;left:{title_x}px;top:{title_y}px;width:{title_w}px;height:16px;color:{text_hex};font:12px monospace;overflow:hidden;white-space:nowrap'>{win.title}</div>"
            body = body + "<div style='position:absolute;left:{close_x}px;top:{win.y}px;width:24px;height:24px;background:{close_hex}'></div>"
            body = body + "<div style='position:absolute;left:{close_text_x}px;top:{title_y}px;width:16px;height:16px;color:{text_hex};font:12px monospace'>X</div>"
    # Taskbar dock: one item per window (minimized included — restore works
    # through its item). Geometry mirrors wm_lifecycle_hit_taskbar exactly
    # (band at height-62, 44 tall; centered items) so what the user clicks
    # is what they see.
    val tb_count = windows.len().to_i32()
    if tb_count > 0:
        val taskbar_hex = _argb_to_css_hex(theme.taskbar)
        val unfocused_hex = _argb_to_css_hex(theme.title_unfocused)
        val dock_w = wm_taskbar_dock_width(width, tb_count)
        val dock_x = (width - dock_w) / 2
        val dock_y = height - 62
        val item_w = wm_taskbar_item_width(width, tb_count)
        body = body + "<div style='position:absolute;left:{dock_x}px;top:{dock_y}px;width:{dock_w}px;height:44px;background:{taskbar_hex}'></div>"
        var ti = 0
        while ti < tb_count:
            val twin = windows[ti]
            val tix = wm_taskbar_item_x(width, tb_count, ti)
            var item_hex = unfocused_hex
            if twin.focused and not twin.minimized:
                item_hex = accent_hex
            elif twin.minimized:
                item_hex = body_hex
            val item_inner_w = item_w - 4
            val label_w = item_w - 16
            val label_y = dock_y + 14
            body = body + "<div style='position:absolute;left:{tix + 2}px;top:{dock_y + 4}px;width:{item_inner_w}px;height:36px;background:{item_hex}'></div>"
            body = body + "<div style='position:absolute;left:{tix + 8}px;top:{label_y}px;width:{label_w}px;height:16px;color:{text_hex};font:12px monospace;overflow:hidden;white-space:nowrap'>{twin.title}</div>"
            ti = ti + 1
    "<!DOCTYPE html><html><head><style>body{{margin:0;width:{width}px;height:{height}px;background:{bg_hex}}}</style></head><body>" + body + "</body></html>"

# Fingerprint the chrome-relevant scene state so render_frame() can reuse the
# cached CSS chrome pixels on unchanged scenes. Deliberately excludes window
# content (redrawn every frame) but includes size, theme colors, and every
# window's id/geometry/minimized/focused/title.
fn host_chrome_scene_fingerprint(windows: [HostedWindow], width: i32, height: i32) -> text:
    val theme = wm_chrome_theme()
    var fp = "{width}x{height}|{theme.compositor_bg}|{theme.host_window_body}|{theme.accent}|{theme.close_button}|{theme.text_primary}|{theme.taskbar}|{theme.title_unfocused}#"
    for win in windows:
        val minf = if win.minimized: 1 else: 0
        val focf = if win.focused: 1 else: 0
        fp = fp + "{win.id}:{win.x},{win.y},{win.w},{win.h},{minf},{focf},{win.title};"
    fp
