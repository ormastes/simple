# Deterministic first-frame capture for the shared hosted WM renderer.

use os.compositor.backend_evidence.{GuiBackendEvidence, make_gui_backend_evidence}
use os.compositor.browser_compositor_backend.{BrowserCompositorBackend}
use os.compositor.shared_mdi_setup.{shared_mdi_surfaces}
use os.compositor.simple_web_window_renderer.{render_simple_web_app_content}

extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_env_get(key: text) -> text?
extern fn rt_time_now_unix_micros() -> i64

val HOSTED_WM_CAPTURE_WIDTH: i32 = 340
val HOSTED_WM_CAPTURE_HEIGHT: i32 = 240
val HOSTED_WM_CROP_X: i32 = 48
val HOSTED_WM_CROP_Y: i32 = 68
val HOSTED_WM_CROP_WIDTH: i32 = 270
val HOSTED_WM_CROP_HEIGHT: i32 = 150

class HostedWmCaptureMetrics:
    width: i32
    height: i32
    pixels: i32
    non_background_pixels: i32
    bright_pixels: i32
    accent_pixels: i32
    sample_checksum: u64
    render_us: i64
    backend_evidence: GuiBackendEvidence
    write_ok: bool

fn _push_ascii(out: [u8], text_value: text) -> [u8]:
    var bytes = out
    for ch in text_value:
        bytes.push(ch.char_code_at(0).to_u8())
    bytes

fn write_argb_crop_ppm(path: text, source_width: i32, x: i32, y: i32, width: i32, height: i32, pixels: [u32]) -> bool:
    var out: [u8] = []
    out = _push_ascii(out, "P6\n{width} {height}\n255\n")
    var row: i32 = 0
    while row < height:
        var col: i32 = 0
        while col < width:
            val idx = (y + row) * source_width + x + col
            val p = if idx >= 0 and idx < pixels.len(): pixels[idx] else: 0xFF000000u32
            out.push(((p >> 16u32) & 0xFFu32).to_u8())
            out.push(((p >> 8u32) & 0xFFu32).to_u8())
            out.push((p & 0xFFu32).to_u8())
            col = col + 1
        row = row + 1
    rt_file_write_bytes(path, out)

fn render_shared_mdi_frame(backend: BrowserCompositorBackend):
    backend.clear(0xFF0F172Au32)
    val surfaces = shared_mdi_surfaces()
    val surface = surfaces[0]
    backend.fill_rect(surface.x, surface.y, surface.w, surface.h, 0xFF1E293Bu32)
    backend.fill_rect(surface.x, surface.y, surface.w, 24, 0xFF2563EBu32)
    backend.draw_text(surface.x + 8, surface.y + 4, surface.title, 0xFFFFFFFFu32, 0xFF2563EBu32)
    backend.fill_rect(surface.x + surface.w - 24, surface.y, 24, 24, 0xFFCC3333u32)
    backend.draw_text(surface.x + surface.w - 17, surface.y + 4, "X", 0xFFFFFFFFu32, 0xFFCC3333u32)
    render_simple_web_app_content(
        backend,
        surface.title,
        surface.x + 4,
        surface.y + 28,
        surface.w - 8,
        surface.h - 32,
        surface.content
    )
    backend.present()

fn capture_shared_hosted_wm_frame(path: text) -> HostedWmCaptureMetrics:
    val backend = BrowserCompositorBackend.with_color(HOSTED_WM_CAPTURE_WIDTH, HOSTED_WM_CAPTURE_HEIGHT, 0xFF0F172Au32)
    val start = rt_time_now_unix_micros()
    render_shared_mdi_frame(backend)
    val elapsed = rt_time_now_unix_micros() - start
    val pixels = backend.get_pixel_buffer()
    var non_bg = 0
    var bright = 0
    var accent = 0
    var checksum = 1469598103934665603u64
    var row: i32 = 0
    while row < HOSTED_WM_CROP_HEIGHT:
        var col: i32 = 0
        while col < HOSTED_WM_CROP_WIDTH:
            val i = (HOSTED_WM_CROP_Y + row) * HOSTED_WM_CAPTURE_WIDTH + HOSTED_WM_CROP_X + col
            val p = if i >= 0 and i < pixels.len(): pixels[i] else: 0xFF000000u32
            val r = (p >> 16u32) & 0xFFu32
            val g = (p >> 8u32) & 0xFFu32
            val b = p & 0xFFu32
            if p != 0xFF0F172Au32:
                non_bg = non_bg + 1
            if r > 210u32 and g > 210u32 and b > 210u32:
                bright = bright + 1
            val max1 = if r > g: r else: g
            val maxc = if max1 > b: max1 else: b
            val min1 = if r < g: r else: g
            val minc = if min1 < b: min1 else: b
            if maxc - minc > 65u32:
                accent = accent + 1
            if (row * HOSTED_WM_CROP_WIDTH + col) % 97 == 0:
                checksum = (checksum ^ p.to_u64()) * 1099511628211u64
            col = col + 1
        row = row + 1
    val ok = if path != "": write_argb_crop_ppm(path, HOSTED_WM_CAPTURE_WIDTH, HOSTED_WM_CROP_X, HOSTED_WM_CROP_Y, HOSTED_WM_CROP_WIDTH, HOSTED_WM_CROP_HEIGHT, pixels) else: true
    val evidence = make_gui_backend_evidence(
        "macos_metal",
        "browser_compositor_cpu_readback",
        "Metal submit/readback is not wired for this hosted evidence path; using verified BrowserCompositor CPU readback",
        elapsed,
        "verified:browser-compositor-pixel-buffer"
    )
    HostedWmCaptureMetrics(
        width: HOSTED_WM_CROP_WIDTH,
        height: HOSTED_WM_CROP_HEIGHT,
        pixels: HOSTED_WM_CROP_WIDTH * HOSTED_WM_CROP_HEIGHT,
        non_background_pixels: non_bg,
        bright_pixels: bright,
        accent_pixels: accent,
        sample_checksum: checksum,
        render_us: elapsed,
        backend_evidence: evidence,
        write_ok: ok
    )

fn main() -> i64:
    val path = rt_env_get("SIMPLE_HOSTED_WM_CAPTURE_PPM") ?? "build/hosted-wm-capture-evidence/hosted_wm_first_frame.ppm"
    val metrics = capture_shared_hosted_wm_frame(path)
    print "hosted_wm_capture_status=" + (if metrics.write_ok: "pass" else: "fail")
    print "hosted_wm_capture_path=" + path
    print "hosted_wm_capture_width=" + metrics.width.to_text()
    print "hosted_wm_capture_height=" + metrics.height.to_text()
    print "hosted_wm_capture_pixels=" + metrics.pixels.to_text()
    print "hosted_wm_capture_non_background_pixels=" + metrics.non_background_pixels.to_text()
    print "hosted_wm_capture_bright_pixels=" + metrics.bright_pixels.to_text()
    print "hosted_wm_capture_accent_pixels=" + metrics.accent_pixels.to_text()
    print "hosted_wm_capture_sample_checksum=" + metrics.sample_checksum.to_text()
    print "hosted_wm_capture_render_us=" + metrics.render_us.to_text()
    print "hosted_wm_backend_selected=" + metrics.backend_evidence.selected_backend
    print "hosted_wm_backend_fallback_reason=" + metrics.backend_evidence.fallback_reason
    print "hosted_wm_backend_frame_time_us=" + metrics.backend_evidence.frame_time_us.to_text()
    print "hosted_wm_backend_readback_status=" + metrics.backend_evidence.readback_status
    print "hosted_wm_backend_status=" + (if metrics.backend_evidence.ok: "pass" else: "fail")
    print "hosted_wm_backend_error=" + metrics.backend_evidence.error
    if metrics.write_ok and metrics.backend_evidence.ok:
        return 0
    1
