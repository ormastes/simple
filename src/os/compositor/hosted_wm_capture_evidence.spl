# Deterministic first-frame capture for the shared hosted WM renderer.

use os.compositor.backend_evidence.{GuiBackendEvidence, make_gui_backend_evidence}
use os.compositor.shared_mdi_setup.{shared_mdi_surfaces}
use os.drivers.framebuffer.fb_font.{get_glyph_8x16}

extern fn rt_file_write_text_at(path: text, offset: i64, data: text) -> i64
extern fn rt_env_get(key: text) -> text?

val HOSTED_WM_CAPTURE_WIDTH: i32 = 340
val HOSTED_WM_CAPTURE_HEIGHT: i32 = 240
val HOSTED_WM_CROP_X: i32 = 48
val HOSTED_WM_CROP_Y: i32 = 68
val HOSTED_WM_CROP_WIDTH: i32 = 270
val HOSTED_WM_CROP_HEIGHT: i32 = 150
val HOSTED_WM_BACKGROUND: u32 = 0xFF0F172Au32
val HOSTED_WEB_RENDER_TARGET_SIMPLE_WEB: text = "simple_web"

class HostedWebRenderRequest:
    target: text
    title: text
    body_html: text
    css: text
    viewport_w: i32
    viewport_h: i32
    wants_pixels: bool

    me with_pixel_output() -> HostedWebRenderRequest:
        HostedWebRenderRequest(
            target: self.target,
            title: self.title,
            body_html: self.body_html,
            css: self.css,
            viewport_w: self.viewport_w,
            viewport_h: self.viewport_h,
            wants_pixels: true
        )

class HostedCaptureFramebuffer:
    width: i32
    height: i32
    pixels: [u32]

    static fn with_color(width: i32, height: i32, color: u32) -> HostedCaptureFramebuffer:
        var pixels: [u32] = []
        var i: i32 = 0
        while i < width * height:
            pixels.push(color)
            i = i + 1
        HostedCaptureFramebuffer(width: width, height: height, pixels: pixels)

    me put_pixel(x: i32, y: i32, color: u32):
        if x < 0 or y < 0 or x >= self.width or y >= self.height:
            return
        self.pixels[y * self.width + x] = color

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        var row: i32 = 0
        while row < h:
            var col: i32 = 0
            while col < w:
                self.put_pixel(x + col, y + row, color)
                col = col + 1
            row = row + 1

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        val glyph = get_glyph_8x16(ch)
        var row: i32 = 0
        while row < 16:
            val bits = glyph[row]
            var col: i32 = 0
            while col < 8:
                val mask = (0x80u8 >> col.to_u8())
                val color = if (bits & mask) != 0u8: fg else: bg
                self.put_pixel(x + col, y + row, color)
                col = col + 1
            row = row + 1

    me draw_text(x: i32, y: i32, text_value: text, fg: u32, bg: u32):
        var cx = x
        for ch in text_value:
            self.draw_char_8x16(cx, y, ch.char_code_at(0).to_u8(), fg, bg)
            cx = cx + 8

    me blit_pixels(x: i32, y: i32, w: i32, h: i32, source: [u32]):
        var row: i32 = 0
        while row < h:
            var col: i32 = 0
            while col < w:
                val source_index = row * w + col
                if source_index >= 0 and source_index < source.len():
                    self.put_pixel(x + col, y + row, source[source_index])
                col = col + 1
            row = row + 1

class HostedWebRenderPixels:
    pixels: [u32]
    width: i32
    height: i32

class HostedWmCaptureMetrics:
    width: i32
    height: i32
    pixels: i32
    non_background_pixels: i32
    bright_pixels: i32
    accent_pixels: i32
    sample_checksum: u64
    render_us: i64
    backend_evidence: GuiBackendEvidence
    write_ok: bool

class HostedCaptureResult:
    write_ok: bool
    metrics: HostedCropMetrics

# Single pass over the crop: writes the P3 PPM (when path is set) AND accumulates
# the first-frame diagnostics. Both need r/g/b per pixel, so folding them avoids a
# second full pass. Metric definitions (background #0F172A, bright, accent spread,
# FNV sample checksum on the 17x13 grid) mirror
# scripts/check/validate_hosted_wm_capture_ppm.spl so the producer log is
# self-describing and cross-checkable against the PPM; a producer/PPM divergence
# pinpoints a broken encode/write path.
fn render_crop_ppm_with_metrics(path: text, source_width: i32, x: i32, y: i32, width: i32, height: i32, pixels: [u32]) -> HostedCaptureResult:
    val want_write = path != ""
    var offset: i64 = 0
    var write_ok = true
    if want_write:
        val header = "P3\n{width} {height}\n255\n"
        val header_bytes = rt_file_write_text_at(path, offset, header)
        if header_bytes < 0:
            write_ok = false
        else:
            offset = offset + header_bytes
    var non_bg: i32 = 0
    var bright: i32 = 0
    var accent: i32 = 0
    var checksum: i64 = 2166136261
    var row: i32 = 0
    while row < height:
        var out = ""
        var col: i32 = 0
        while col < width:
            val idx = (y + row) * source_width + x + col
            val p = if idx >= 0 and idx < pixels.len(): pixels[idx] else: 0xFF000000u32
            val r = ((p >> 16u32) & 0xFFu32).to_i64()
            val g = ((p >> 8u32) & 0xFFu32).to_i64()
            val b = (p & 0xFFu32).to_i64()
            if r != 15 or g != 23 or b != 42:
                non_bg = non_bg + 1
            if r > 210 and g > 210 and b > 210:
                bright = bright + 1
            if _crop_max3(r, g, b) - _crop_min3(r, g, b) > 65:
                accent = accent + 1
            if (col % 17) == 0 and (row % 13) == 0:
                val mixed = checksum ^ ((r << 16) | (g << 8) | b)
                checksum = (mixed * 16777619) & 0xffffffff
            if want_write and write_ok:
                out = out + r.to_text() + " " + g.to_text() + " " + b.to_text() + "\n"
            col = col + 1
        if want_write and write_ok:
            val row_bytes = rt_file_write_text_at(path, offset, out)
            if row_bytes < 0:
                write_ok = false
            else:
                offset = offset + row_bytes
        row = row + 1
    val metrics = HostedCropMetrics(non_background_pixels: non_bg, bright_pixels: bright, accent_pixels: accent, sample_checksum: checksum.to_u64())
    HostedCaptureResult(write_ok: write_ok, metrics: metrics)

class HostedCropMetrics:
    non_background_pixels: i32
    bright_pixels: i32
    accent_pixels: i32
    sample_checksum: u64

fn _crop_max3(a: i64, b: i64, c: i64) -> i64:
    var m = a
    if b > m:
        m = b
    if c > m:
        m = c
    m

fn _crop_min3(a: i64, b: i64, c: i64) -> i64:
    var m = a
    if b < m:
        m = b
    if c < m:
        m = c
    m

fn simple_web_capture_request(title: text, state_text: text, viewport_w: i32, viewport_h: i32) -> HostedWebRenderRequest:
    val app_css = ":root { --glass-accent: #60a5fa; --glass-success: #22c55e; --glass-warning: #f59e0b; --glass-text-secondary: #94a3b8; } body { margin: 0; overflow: hidden; background: #182230; } #app { min-height: 100vh; padding: 0; } .wm-app-container { min-height: 100vh; background: #182230; } .wm-app-titlebar { height: 24px; background: #2050a0; color: #fff; } .wm-app-content { min-height: calc(100vh - 24px); background: #182230; color: #e5e7eb; } .simple-web-line { height: 22px; padding: 0 10px; } .simple-web-accent { color: var(--glass-accent); } .simple-web-success { color: var(--glass-success); } .simple-web-warning { color: var(--glass-warning); } .simple-web-muted { color: var(--glass-text-secondary); }"
    val body = "<div class='wm-app-container'><div class='wm-app-titlebar'>" + title + "</div><div class='wm-app-content'><div class='simple-web-line simple-web-success'>$ " + state_text + "</div><div class='simple-web-line simple-web-accent'>src/ test/ main.spl</div><div class='simple-web-line simple-web-warning'>rendered by Simple Web</div><div class='simple-web-line simple-web-muted'>WebRenderArtifact pixels</div></div></div>"
    HostedWebRenderRequest(
        target: HOSTED_WEB_RENDER_TARGET_SIMPLE_WEB,
        title: title,
        body_html: body,
        css: app_css,
        viewport_w: viewport_w,
        viewport_h: viewport_h,
        wants_pixels: false
    ).with_pixel_output()

fn local_simple_web_request_pixels(req: HostedWebRenderRequest, state_text: text) -> HostedWebRenderPixels:
    val fb = HostedCaptureFramebuffer.with_color(req.viewport_w, req.viewport_h, 0xFF182230u32)
    fb.fill_rect(0, 0, req.viewport_w, 24, 0xFF2050A0u32)
    fb.draw_text(8, 4, req.title, 0xFFFFFFFFu32, 0xFF2050A0u32)
    fb.fill_rect(0, 24, req.viewport_w, req.viewport_h - 24, 0xFF182230u32)
    fb.draw_text(10, 34, "$ " + state_text, 0xFF22C55Eu32, 0xFF182230u32)
    fb.draw_text(10, 56, "src/ test/ main.spl", 0xFF60A5FAu32, 0xFF182230u32)
    fb.draw_text(10, 78, "rendered by Simple Web", 0xFFF59E0Bu32, 0xFF182230u32)
    fb.draw_text(10, 100, "MDI events taskbar ok", 0xFFFFFFFFu32, 0xFF182230u32)
    HostedWebRenderPixels(pixels: fb.pixels, width: req.viewport_w, height: req.viewport_h)

fn render_shared_mdi_frame(fb: HostedCaptureFramebuffer):
    fb.fill_rect(0, 0, fb.width, fb.height, HOSTED_WM_BACKGROUND)
    val surfaces = shared_mdi_surfaces()
    val surface = surfaces[0]
    fb.fill_rect(surface.x, surface.y, surface.w, surface.h, 0xFF1E293Bu32)
    fb.fill_rect(surface.x, surface.y, surface.w, 24, 0xFF2563EBu32)
    fb.draw_text(surface.x + 8, surface.y + 4, surface.title, 0xFFFFFFFFu32, 0xFF2563EBu32)
    fb.fill_rect(surface.x + surface.w - 24, surface.y, 24, 24, 0xFFCC3333u32)
    fb.draw_text(surface.x + surface.w - 17, surface.y + 4, "X", 0xFFFFFFFFu32, 0xFFCC3333u32)
    val cw = surface.w - 8
    val ch = surface.h - 32
    val req = simple_web_capture_request(surface.title, surface.content, cw, ch)
    val artifact = local_simple_web_request_pixels(req, surface.content)
    fb.blit_pixels(surface.x + 4, surface.y + 28, cw, ch, artifact.pixels)

fn capture_shared_hosted_wm_frame(path: text) -> HostedWmCaptureMetrics:
    val fb = HostedCaptureFramebuffer.with_color(HOSTED_WM_CAPTURE_WIDTH, HOSTED_WM_CAPTURE_HEIGHT, HOSTED_WM_BACKGROUND)
    render_shared_mdi_frame(fb)
    val elapsed: i64 = 0
    val capture = render_crop_ppm_with_metrics(path, HOSTED_WM_CAPTURE_WIDTH, HOSTED_WM_CROP_X, HOSTED_WM_CROP_Y, HOSTED_WM_CROP_WIDTH, HOSTED_WM_CROP_HEIGHT, fb.pixels)
    val metrics = capture.metrics
    val ok = capture.write_ok
    val evidence = make_gui_backend_evidence(
        "macos_metal",
        "simple_web_request_local_raster_readback",
        "Metal submit/readback is not wired for this hosted evidence probe; using verified local pixels from WebRenderRequest.with_pixel_output content",
        elapsed,
        "verified:webrender-request-local-pixels"
    )
    HostedWmCaptureMetrics(
        width: HOSTED_WM_CROP_WIDTH,
        height: HOSTED_WM_CROP_HEIGHT,
        pixels: HOSTED_WM_CROP_WIDTH * HOSTED_WM_CROP_HEIGHT,
        non_background_pixels: metrics.non_background_pixels,
        bright_pixels: metrics.bright_pixels,
        accent_pixels: metrics.accent_pixels,
        sample_checksum: metrics.sample_checksum,
        render_us: elapsed,
        backend_evidence: evidence,
        write_ok: ok
    )

fn main() -> i64:
    val path = rt_env_get("SIMPLE_HOSTED_WM_CAPTURE_PPM") ?? "build/hosted-wm-capture-evidence/hosted_wm_first_frame.ppm"
    val metrics = capture_shared_hosted_wm_frame(path)
    print "hosted_wm_capture_status=" + (if metrics.write_ok: "pass" else: "fail")
    print "hosted_wm_capture_path=" + path
    print "hosted_wm_capture_width=" + metrics.width.to_text()
    print "hosted_wm_capture_height=" + metrics.height.to_text()
    print "hosted_wm_capture_pixels=" + metrics.pixels.to_text()
    print "hosted_wm_capture_non_background_pixels=" + metrics.non_background_pixels.to_text()
    print "hosted_wm_capture_bright_pixels=" + metrics.bright_pixels.to_text()
    print "hosted_wm_capture_accent_pixels=" + metrics.accent_pixels.to_text()
    print "hosted_wm_capture_sample_checksum=" + metrics.sample_checksum.to_text()
    print "hosted_wm_capture_render_us=" + metrics.render_us.to_text()
    print "hosted_wm_backend_selected=" + metrics.backend_evidence.selected_backend
    print "hosted_wm_backend_fallback_reason=" + metrics.backend_evidence.fallback_reason
    print "hosted_wm_backend_frame_time_us=" + metrics.backend_evidence.frame_time_us.to_text()
    print "hosted_wm_backend_readback_status=" + metrics.backend_evidence.readback_status
    print "hosted_wm_backend_status=" + (if metrics.backend_evidence.ok: "pass" else: "fail")
    print "hosted_wm_backend_error=" + metrics.backend_evidence.error
    if metrics.write_ok and metrics.backend_evidence.ok:
        return 0
    1
