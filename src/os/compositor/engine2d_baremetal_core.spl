# Freestanding Engine2D-shaped core for Simple OS QEMU entries.
#
# This module intentionally avoids the full std.gpu.engine2d facade in
# --entry-closure baremetal builds. It exposes the narrow drawing surface used
# by QEMU system entries and writes through the x86_64 runtime framebuffer fill
# primitive.

extern fn rt_gui_fill4(xy: u64, wh: u64, color: u64, unused: u64) -> u64

var _fb_width: i32 = 0
var _fb_height: i32 = 0
var _fb_addr: u64 = 0

class Engine2DBaremetalCore:
    fb_addr: u64
    width: i32
    height: i32

fn _pack(hi: i32, lo: i32) -> u64:
    (hi.to_u64() << 32) | (lo.to_u64() & 0xFFFFFFFF)

fn _fill(x: i32, y: i32, w: i32, h: i32, color: u32):
    if w <= 0 or h <= 0:
        return
    rt_gui_fill4(_pack(x, y), _pack(w, h), color.to_u64(), 0)

fn _clamp_start(v: i32) -> i32:
    if v < 0:
        return 0
    v

fn _pixel_at(pixels: [u32], width: i32, x: i32, y: i32, fallback: u32) -> u32:
    if x < 0 or y < 0 or width <= 0:
        return fallback
    val idx = (y * width + x).to_u64()
    if idx >= pixels.len():
        return fallback
    pixels[idx]

fn create_fb_engine_core(fb_addr: u64, width: i32, height: i32) -> Engine2DBaremetalCore:
    _fb_addr = fb_addr
    _fb_width = width
    _fb_height = height
    Engine2DBaremetalCore(fb_addr: fb_addr, width: width, height: height)

impl Engine2DBaremetalCore:
    me clear(color: u32):
        _fill(0, 0, _fb_width, _fb_height, color)

    me present():
        return

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        var x0 = _clamp_start(x)
        var y0 = _clamp_start(y)
        var x1 = x + w
        var y1 = y + h
        if x1 > _fb_width:
            x1 = _fb_width
        if y1 > _fb_height:
            y1 = _fb_height
        _fill(x0, y0, x1 - x0, y1 - y0, color)

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        self.draw_rect_stroked(x, y, w, h, color)

    me draw_rect_stroked(x: i32, y: i32, w: i32, h: i32, color: u32):
        if w <= 0 or h <= 0:
            return
        self.draw_rect_filled(x, y, w, 1, color)
        self.draw_rect_filled(x, y + h - 1, w, 1, color)
        self.draw_rect_filled(x, y, 1, h, color)
        self.draw_rect_filled(x + w - 1, y, 1, h, color)

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        var dx = x2 - x1
        if dx < 0:
            dx = 0 - dx
        var dy = y2 - y1
        if dy < 0:
            dy = 0 - dy
        val sx = if x1 < x2: 1 else: -1
        val sy = if y1 < y2: 1 else: -1
        var err = dx - dy
        var x = x1
        var y = y1
        val t = if thickness <= 0: 1 else: thickness
        while true:
            self.draw_rect_filled(x, y, t, t, color)
            if x == x2 and y == y2:
                return
            var e2 = err * 2
            if e2 > (0 - dy):
                err = err - dy
                x = x + sx
            if e2 < dx:
                err = err + dx
                y = y + sy

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        if r <= 0:
            return
        var x = r
        var y = 0
        var err = 1 - x
        while x >= y:
            self.draw_rect_filled(cx - x, cy + y, x * 2 + 1, 1, color)
            self.draw_rect_filled(cx - x, cy - y, x * 2 + 1, 1, color)
            self.draw_rect_filled(cx - y, cy + x, y * 2 + 1, 1, color)
            self.draw_rect_filled(cx - y, cy - x, y * 2 + 1, 1, color)
            y = y + 1
            if err < 0:
                err = err + 2 * y + 1
            else:
                x = x - 1
                err = err + 2 * (y - x + 1)

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        self.draw_circle_stroked(cx, cy, r, color)

    me draw_circle_stroked(cx: i32, cy: i32, r: i32, color: u32):
        if r <= 0:
            return
        var x = r
        var y = 0
        var err = 1 - x
        while x >= y:
            self.draw_rect_filled(cx + x, cy + y, 1, 1, color)
            self.draw_rect_filled(cx - x, cy + y, 1, 1, color)
            self.draw_rect_filled(cx + x, cy - y, 1, 1, color)
            self.draw_rect_filled(cx - x, cy - y, 1, 1, color)
            self.draw_rect_filled(cx + y, cy + x, 1, 1, color)
            self.draw_rect_filled(cx - y, cy + x, 1, 1, color)
            self.draw_rect_filled(cx + y, cy - x, 1, 1, color)
            self.draw_rect_filled(cx - y, cy - x, 1, 1, color)
            y = y + 1
            if err < 0:
                err = err + 2 * y + 1
            else:
                x = x - 1
                err = err + 2 * (y - x + 1)

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        if w <= 0 or h <= 0:
            return
        var row = 0
        while row < h:
            var col = 0
            while col < w:
                val color = _pixel_at(pixels, w, col, row, 0xFF000000)
                var run = 1
                while col + run < w and _pixel_at(pixels, w, col + run, row, color) == color:
                    run = run + 1
                self.draw_rect_filled(x + col, y + row, run, 1, color)
                col = col + run
            row = row + 1

    me draw_codes12_block(x: i32, y: i32, c0: i32, c1: i32, c2: i32, c3: i32, c4: i32, c5: i32, c6: i32, c7: i32, c8: i32, c9: i32, c10: i32, c11: i32, color: u32, scale: i32):
        val cell_w = if scale <= 0: 6 else: scale * 3
        val cell_h = if scale <= 0: 8 else: scale * 5
        var i = 0
        while i < 12:
            val code = if i == 0: c0 elif i == 1: c1 elif i == 2: c2 elif i == 3: c3 elif i == 4: c4 elif i == 5: c5 elif i == 6: c6 elif i == 7: c7 elif i == 8: c8 elif i == 9: c9 elif i == 10: c10 else: c11
            if code != 0 and code != 32:
                self.draw_rect_filled(x + i * (cell_w + 1), y, cell_w, cell_h, color)
            i = i + 1
