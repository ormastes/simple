# Engine2D Baremetal Core — freestanding Engine2D facade for QEMU boot fixtures
#
# This internal facade keeps the Simple OS verification entries on Engine2D
# primitive calls while avoiding the full host/GPU backend selection surface in
# freestanding x86_64 kernels.

extern fn rt_mmio_write_u32_real(addr: u64, value: u64) -> u64

class Engine2DBaremetalCore:
    front_addr: u64
    w: i32
    h: i32

    static fn create(front_addr: u64, width: i32, height: i32) -> Engine2DBaremetalCore:
        Engine2DBaremetalCore(front_addr: front_addr, w: width, h: height)

    me clear(color: u32):
        self.draw_rect_filled(0, 0, self.w, self.h, color)

    me put_pixel(x: i32, y: i32, color: u32):
        if x < 0 or y < 0 or x >= self.w or y >= self.h:
            return
        val base_addr: u64 = self.front_addr
        val stride: i32 = self.w
        val raw_color: u64 = color.to_u64()
        val pixel_index: i32 = y * stride + x
        val offset: u64 = (pixel_index * 4).to_u64()
        val addr: u64 = base_addr + offset
        rt_mmio_write_u32_real(addr, raw_color)

    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        if w <= 0 or h <= 0:
            return
        var x0: i32 = x
        var y0: i32 = y
        var x1: i32 = x + w
        var y1: i32 = y + h
        if x0 < 0:
            x0 = 0
        if y0 < 0:
            y0 = 0
        if x1 > self.w:
            x1 = self.w
        if y1 > self.h:
            y1 = self.h
        if x0 >= x1 or y0 >= y1:
            return
        val base_addr: u64 = self.front_addr
        val stride: i32 = self.w
        val raw_color: u64 = color.to_u64()
        var py: i32 = y0
        while py < y1:
            var px: i32 = x0
            while px < x1:
                val pixel_index: i32 = py * stride + px
                val offset: u64 = (pixel_index * 4).to_u64()
                val addr: u64 = base_addr + offset
                rt_mmio_write_u32_real(addr, raw_color)
                px = px + 1
            py = py + 1

    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        if w <= 0 or h <= 0:
            return
        self.draw_rect_filled(x, y, w, 1, color)
        self.draw_rect_filled(x, y + h - 1, w, 1, color)
        self.draw_rect_filled(x, y, 1, h, color)
        self.draw_rect_filled(x + w - 1, y, 1, h, color)

    me draw_rect_stroked(x: i32, y: i32, w: i32, h: i32, color: u32):
        self.draw_rect(x, y, w, h, color)

    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        var dx = x2 - x1
        var dy = y2 - y1
        var sx: i32 = 1
        var sy: i32 = 1
        if dx < 0:
            dx = -dx
            sx = -1
        if dy < 0:
            dy = -dy
            sy = -1
        var err = dx - dy
        var cx = x1
        var cy = y1
        while true:
            self.put_pixel(cx, cy, color)
            if cx == x2 and cy == y2:
                return
            val e2 = 2 * err
            if e2 > -dy:
                err = err - dy
                cx = cx + sx
            if e2 < dx:
                err = err + dx
                cy = cy + sy

    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        if r < 0:
            return
        val rr: i32 = r * r
        var yy: i32 = -r
        while yy <= r:
            var xx: i32 = -r
            while xx <= r:
                if xx * xx + yy * yy <= rr:
                    self.put_pixel(cx + xx, cy + yy, color)
                xx = xx + 1
            yy = yy + 1

    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        if r < 0:
            return
        var x: i32 = r
        var y: i32 = 0
        var err: i32 = 0
        while x >= y:
            self.put_pixel(cx + x, cy + y, color)
            self.put_pixel(cx + y, cy + x, color)
            self.put_pixel(cx - y, cy + x, color)
            self.put_pixel(cx - x, cy + y, color)
            self.put_pixel(cx - x, cy - y, color)
            self.put_pixel(cx - y, cy - x, color)
            self.put_pixel(cx + y, cy - x, color)
            self.put_pixel(cx + x, cy - y, color)
            y = y + 1
            if err <= 0:
                err = err + 2 * y + 1
            if err > 0:
                x = x - 1
                err = err - 2 * x + 1

    me draw_circle_stroked(cx: i32, cy: i32, r: i32, color: u32):
        self.draw_circle(cx, cy, r, color)

    me present():
        pass_dn

fn create_fb_engine_core(front_addr: u64, width: i32, height: i32) -> Engine2DBaremetalCore:
    Engine2DBaremetalCore.create(front_addr, width, height)
