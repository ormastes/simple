# Hosted Compositor Backend — Cocoa / macOS winit-alias shim
#
# Routes through the cross-platform winit pixel-buffer backend
# (`rt_winit_buffer_*`) instead of native NSWindow / CAMetalLayer symbols.
# The window is owned by the caller (created via `rt_winit_window_new`);
# this backend only manages the pixel buffer and drawing operations.
#
# Naming boundary: `HostedCocoaBackend` is retained as the selector-facing
# macOS backend name, but this Simple-side class is a documented alias over
# the winit buffer implementation. It does not call `rt_cocoa_*` symbols.
#
# Selection: routed by `hosted_backend.spl::select_hosted_backend()`
# at construct time based on `rt_hosted_select_surface()` returning 1
# (macOS). See that file for the dispatch site.

use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}
use os.drivers.framebuffer.fb_driver.{get_glyph_8x16}

# ============================================================================
# Winit Buffer FFI Declarations (shared symbols with hosted_backend.spl)
# ============================================================================

extern fn rt_winit_buffer_create(w: i64, h: i64, fill_color: i64) -> i64
extern fn rt_winit_buffer_fill_rect(buf: i64, x: i64, y: i64, w: i64, h: i64, color: i64) -> bool
extern fn rt_winit_buffer_draw_text(buf: i64, x: i64, y: i64, text_str: text, fg: i64, bg: i64) -> bool
extern fn rt_winit_buffer_present(win: i64, buf: i64) -> bool
extern fn rt_winit_buffer_free(buf: i64) -> bool
extern fn rt_winit_buffer_read_pixel(buf: i64, x: i64, y: i64) -> i64
extern fn rt_winit_buffer_blend_rect(buf: i64, x: i64, y: i64, w: i64, h: i64, color: i64, alpha: i64) -> bool
extern fn rt_winit_buffer_blur(buf: i64, x: i64, y: i64, w: i64, h: i64, radius: i64) -> bool
extern fn rt_winit_buffer_gradient_v(buf: i64, x: i64, y: i64, w: i64, h: i64, c1: i64, c2: i64) -> bool

# Module-level state — same idiom as `hosted_backend.spl` (interpreter
# trait dispatch loses struct fields, so we mirror them here).
var _cocoa_window_id: i64 = 0
var _cocoa_buffer_id: i64 = 0
var _cocoa_w: i32 = 0
var _cocoa_h: i32 = 0

# ============================================================================
# HostedCocoaBackend
# ============================================================================

class HostedCocoaBackend:
    """macOS selector alias that renders through the winit pixel buffer.

    Drawing is delegated to `rt_winit_buffer_*` SFFI symbols. The window
    is owned by the host entrypoint; this backend manages the pixel buffer only.
    Native `rt_cocoa_*` wrappers are not bound here yet.

    Colors are u32 ARGB (0xAARRGGBB), matching `CompositorBackend`.
    """
    window_id: i64
    buffer_id: i64
    w: i32
    h: i32

# ============================================================================
# CompositorBackend Trait Implementation
# ============================================================================

impl CompositorBackend for HostedCocoaBackend:

    fn width() -> i32:
        _cocoa_w

    fn height() -> i32:
        _cocoa_h

    me clear(color: u32):
        val w_i: i64 = _cocoa_w
        val h_i: i64 = _cocoa_h
        val c: i64 = color
        rt_winit_buffer_fill_rect(_cocoa_buffer_id, 0, 0, w_i, h_i, c)

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        val xi: i64 = x
        val yi: i64 = y
        val wi: i64 = w
        val hi: i64 = h
        val c: i64 = color
        rt_winit_buffer_fill_rect(_cocoa_buffer_id, xi, yi, wi, hi, c)

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        val fg_i: i64 = fg
        val bg_i: i64 = bg
        rt_winit_buffer_draw_text(_cocoa_buffer_id, x, y, text_str, fg_i, bg_i)

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        val glyph = get_glyph_8x16(ch)
        val fg_i: i64 = fg
        val bg_i: i64 = bg
        var row: i64 = 0
        while row < 16:
            val bits: i64 = glyph[row]
            var col: i64 = 0
            while col < 8:
                val mask: i64 = 0x80 >> col
                val color = if (bits & mask) != 0: fg_i else: bg_i
                val px: i64 = x + col
                val py: i64 = y + row
                rt_winit_buffer_fill_rect(_cocoa_buffer_id, px, py, 1, 1, color)
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        val xi: i64 = x
        val yi: i64 = y
        val c: i64 = color
        rt_winit_buffer_fill_rect(_cocoa_buffer_id, xi, yi, 1, 1, c)

    me present():
        rt_winit_buffer_present(_cocoa_window_id, _cocoa_buffer_id)

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        # winit presents the full buffer; degrade to full present.
        rt_winit_buffer_present(_cocoa_window_id, _cocoa_buffer_id)

    fn as_glass_capable() -> CompositorGlassCapable?:
        # The winit buffer is a per-surface bitmap we own end-to-end.
        self

# ============================================================================
# CompositorGlassCapable Trait Implementation
# ============================================================================

impl CompositorGlassCapable for HostedCocoaBackend:

    me blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8):
        val xi: i64 = x
        val yi: i64 = y
        val wi: i64 = w
        val hi: i64 = h
        val c: i64 = color
        val a: i64 = alpha
        rt_winit_buffer_blend_rect(_cocoa_buffer_id, xi, yi, wi, hi, c, a)

    me blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32):
        val xi: i64 = x
        val yi: i64 = y
        val wi: i64 = w
        val hi: i64 = h
        val ri: i64 = radius
        rt_winit_buffer_blur(_cocoa_buffer_id, xi, yi, wi, hi, ri)

    me gradient_v(x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32):
        val xi: i64 = x
        val yi: i64 = y
        val wi: i64 = w
        val hi: i64 = h
        val c1: i64 = color1
        val c2: i64 = color2
        rt_winit_buffer_gradient_v(_cocoa_buffer_id, xi, yi, wi, hi, c1, c2)

    fn read_pixel(x: i32, y: i32) -> u32:
        val xi: i64 = x
        val yi: i64 = y
        val result = rt_winit_buffer_read_pixel(_cocoa_buffer_id, xi, yi)
        result.to_u32()

# ============================================================================
# Lifecycle — create / resize / pump / free
# ============================================================================

impl HostedCocoaBackend:

    static fn implementation_name() -> text:
        "cocoa-winit-alias"

    static fn uses_native_cocoa_symbols() -> bool:
        false

    static fn new(window_id: i64, buffer_id: i64, w: i32, h: i32) -> HostedCocoaBackend:
        """Wrap pre-existing winit handles (test seam)."""
        HostedCocoaBackend(window_id: window_id, buffer_id: buffer_id, w: w, h: h)

    static fn try_create(window_id: i64, w: i32, h: i32, fill_color: u32) -> HostedCocoaBackend?:
        """Allocate a winit pixel buffer sized w/h for the given window."""
        val w64: i64 = w
        val h64: i64 = h
        val fc64: i64 = fill_color
        val buf = rt_winit_buffer_create(w64, h64, fc64)
        if buf == 0:
            return nil
        _cocoa_window_id = window_id
        _cocoa_buffer_id = buf
        _cocoa_w = w
        _cocoa_h = h
        HostedCocoaBackend(window_id: window_id, buffer_id: buf, w: w, h: h)

    static fn create(window_id: i64, w: i32, h: i32, fill_color: u32) -> HostedCocoaBackend:
        """Allocate a winit pixel buffer sized w/h for the given window."""
        val backend = HostedCocoaBackend.try_create(window_id, w, h, fill_color)
        if val b = backend:
            return b
        HostedCocoaBackend(window_id: window_id, buffer_id: 0, w: w, h: h)

    me resize(new_w: i32, new_h: i32) -> bool:
        """React to a window resize. Frees the old buffer and allocates a new one."""
        val w64: i64 = new_w
        val h64: i64 = new_h
        rt_winit_buffer_free(_cocoa_buffer_id)
        val buf = rt_winit_buffer_create(w64, h64, 0)
        _cocoa_buffer_id = buf
        _cocoa_w = new_w
        _cocoa_h = new_h
        true

    me free():
        """Release the winit pixel buffer. Idempotent."""
        rt_winit_buffer_free(self.buffer_id)
