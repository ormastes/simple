# Compositor web-render surface facade.
#
# Keeps compositor and WM modules on the common WebRenderRequest/WebRenderArtifact
# boundary instead of importing the concrete Simple Web renderer bridge directly.

use common.ui.web_render_api.{WebRenderArtifact, WebRenderRequest}
use std.gc_async_mut.ui.web_render_pixel_backend.{
    web_render_default_page_html,
    web_render_html_request_to_pixel_artifact,
    web_render_html_request_to_pixel_artifact_with_backend,
    web_render_html_request_to_pixels,
    web_render_html_request_to_pixels_with_backend,
    web_render_request_to_pixel_artifact
}

fn compositor_default_web_page_html(url: text) -> text:
    web_render_default_page_html(url)

fn compositor_render_html_pixels(req: WebRenderRequest, full_html: text) -> [u32]:
    web_render_html_request_to_pixels(req, full_html)

fn compositor_render_html_pixels_with_backend(req: WebRenderRequest, full_html: text, backend_name: text) -> [u32]:
    web_render_html_request_to_pixels_with_backend(req, full_html, backend_name)

fn compositor_render_html_artifact(req: WebRenderRequest, full_html: text) -> WebRenderArtifact:
    web_render_html_request_to_pixel_artifact(req, full_html)

fn compositor_render_html_artifact_with_backend(req: WebRenderRequest, full_html: text, backend_name: text) -> WebRenderArtifact:
    web_render_html_request_to_pixel_artifact_with_backend(req, full_html, backend_name)

fn compositor_render_request_artifact(req: WebRenderRequest) -> WebRenderArtifact:
    web_render_request_to_pixel_artifact(req)
