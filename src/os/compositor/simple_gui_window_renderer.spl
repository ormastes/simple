# Simple GUI app content renderer for hosted WM first-frame display.
#
# This uses the existing Simple GUI UITree builders from app modules and renders
# a compact text view into a CompositorBackend. It is intentionally lightweight
# enough for the interpreter-hosted macOS inspection path.

use common.ui.widget.{UITree, WidgetNode}
use common.ui.builder.{column, panel, text_widget, button, statusbar, build_tree_with_title}
use os.compositor.display_backend.{CompositorBackend}

fn _simple_gui_tree_for_app(title: text, state_text: text) -> UITree:
    if title == "Terminal":
        val root = column("terminal_root", [
            text_widget("term_1", "SimpleOS Terminal"),
            text_widget("term_2", "$ " + state_text),
            text_widget("term_3", "src/ test/ main.spl")
        ])
        return build_tree_with_title(root, "Terminal", "dark")
    if title == "Editor":
        val root = column("editor_root", [
            button("save", "Save", "editor.save"),
            text_widget("line_1", "fn main():"),
            text_widget("line_2", "    print \"Hello SimpleOS\"")
        ])
        return build_tree_with_title(root, "Editor", "dark")
    if title == "Calculator":
        val root = column("calculator_root", [
            panel("display", "Calculator", [text_widget("value", "0")]),
            button("clear", "C", "calc.clear"),
            button("equals", "=", "calc.equals")
        ])
        return build_tree_with_title(root, "Calculator", "dark")
    if title == "Browser" or title == "Simple Browser":
        val root = column("simple_browser_root", [
            text_widget("url", "about:network"),
            text_widget("mode", "Simple GUI lib surface"),
            text_widget("status", "ready")
        ])
        return build_tree_with_title(root, "Browser", "dark")
    if title == "File Manager":
        val root = column("file_manager_root", [
            button("home", "Home", "file.home"),
            button("documents", "Documents", "file.documents"),
            button("downloads", "Downloads", "file.downloads"),
            statusbar("file_status", "Simple GUI lib surface", state_text)
        ])
        return build_tree_with_title(root, "File Manager", "dark")
    val root = panel("generic_app", title, [
        text_widget("state", state_text),
        text_widget("renderer", "Simple GUI lib surface")
    ])
    build_tree_with_title(root, title, "dark")

fn _node_display_line(node: WidgetNode) -> text:
    val title = node.get_prop("title")
    if title != "":
        return title
    val content = node.get_prop("content")
    if content != "":
        return content
    val label = node.get_prop("label")
    if label != "":
        return label
    val left = node.get_prop("left")
    val right = node.get_prop("right")
    if left != "" or right != "":
        return left + " " + right
    val value = node.get_prop("value")
    if value != "":
        return value
    ""

fn _collect_gui_lines(node: WidgetNode, limit: i32) -> [text]:
    var lines: [text] = []
    val line = _node_display_line(node)
    if line != "":
        lines.push(line)
    for child in node.children():
        if lines.len() >= limit:
            return lines
        val child_lines = _collect_gui_lines(child, limit - lines.len())
        for child_line in child_lines:
            if lines.len() < limit:
                lines.push(child_line)
    lines

fn render_simple_gui_app_content(backend: CompositorBackend, title: text, cx: i32, cy: i32, cw: i32, ch: i32, state_text: text):
    if cw <= 0 or ch <= 0:
        return
    val tree = _simple_gui_tree_for_app(title, state_text)
    val lines = _collect_gui_lines(tree.root_node(), 8)
    backend.fill_rect(cx, cy, cw, ch, 0xFF111827u32)
    backend.draw_text(cx + 8, cy + 6, "Simple GUI: " + tree.title_text(), 0xFFFFFFFFu32, 0xFF111827u32)
    var i = 0
    while i < lines.len():
        val y = cy + 28 + (i * 18)
        if y + 16 < cy + ch:
            backend.draw_text(cx + 10, y, lines[i], 0xFFE5E7EBu32, 0xFF111827u32)
        i = i + 1
