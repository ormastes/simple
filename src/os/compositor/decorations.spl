use os.drivers.framebuffer.fb_driver.{Color}

val TITLE_BAR_HEIGHT: i32 = 24
val BORDER_WIDTH: i32 = 1
val CLOSE_BUTTON_SIZE: i32 = 18
val CLOSE_BUTTON_MARGIN: i32 = 3
val TITLE_TEXT_X_OFFSET: i32 = 8
val TITLE_TEXT_Y_OFFSET: i32 = 4

fn total_decoration_top() -> i32:
    TITLE_BAR_HEIGHT + BORDER_WIDTH

fn total_decoration_left() -> i32:
    BORDER_WIDTH

fn total_decoration_right() -> i32:
    BORDER_WIDTH

fn total_decoration_bottom() -> i32:
    BORDER_WIDTH

fn client_area_x(window_x: i32) -> i32:
    window_x + total_decoration_left()

fn client_area_y(window_y: i32) -> i32:
    window_y + total_decoration_top()

fn client_area_width(window_width: i32) -> i32:
    val w = window_width - total_decoration_left() - total_decoration_right()
    if w > 0: w else: 0

fn client_area_height(window_height: i32) -> i32:
    val h = window_height - total_decoration_top() - total_decoration_bottom()
    if h > 0: h else: 0

fn is_in_title_bar(window_x: i32, window_y: i32, window_width: i32, x: i32, y: i32) -> bool:
    val bar_x = window_x + BORDER_WIDTH
    val bar_y = window_y + BORDER_WIDTH
    val bar_w = client_area_width(window_width)
    x >= bar_x and x < bar_x + bar_w and y >= bar_y and y < bar_y + TITLE_BAR_HEIGHT

fn is_in_close_button(window_x: i32, window_y: i32, window_width: i32, x: i32, y: i32) -> bool:
    val bar_x = window_x + BORDER_WIDTH
    val bar_y = window_y + BORDER_WIDTH
    val bar_w = client_area_width(window_width)
    val btn_x = bar_x + bar_w - CLOSE_BUTTON_SIZE - CLOSE_BUTTON_MARGIN
    val btn_y = bar_y + CLOSE_BUTTON_MARGIN
    x >= btn_x and x < btn_x + CLOSE_BUTTON_SIZE and y >= btn_y and y < btn_y + CLOSE_BUTTON_SIZE

fn title_bar_color_focused() -> Color:
    Color.rgb(50, 50, 50)

fn title_bar_color_unfocused() -> Color:
    Color.rgb(100, 100, 100)

fn close_button_bg() -> Color:
    Color.rgb(200, 50, 50)

fn close_button_x_color() -> Color:
    Color.white()

fn border_color_focused() -> Color:
    Color.rgb(100, 149, 237)

fn border_color_unfocused() -> Color:
    Color.rgb(80, 80, 80)
