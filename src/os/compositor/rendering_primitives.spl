#![allow(unnamed_duplicate_typed_args)]
# Rendering Primitives — Pure Simple implementations via CompositorBackend
#
# Anti-aliased rounded rectangles, line drawing, horizontal gradients,
# and filled circles. Shared between hosted and QEMU window managers.
# All rendering through CompositorBackend trait — works on all backends.

use os.compositor.display_backend.{CompositorBackend}
use os.compositor.glass_dispatch.{cap_blend_rect, cap_blur_region, cap_gradient_v, cap_read_pixel}

# ============================================================================
# Integer Square Root (for corner calculations)
# ============================================================================

fn _isqrt(n: i32) -> i32:
    """Integer square root via Newton's method."""
    if n <= 0: return 0
    if n == 1: return 1
    var x = n
    var y = (x + 1) / 2
    while y < x:
        x = y
        y = (x + n / x) / 2
    x

# ============================================================================
# Anti-Aliased Rounded Rectangle
# ============================================================================

fn rounded_rect_aa(backend: CompositorBackend, x: i32, y: i32, w: i32, h: i32,
                   color: u32, radius: i32, alpha: u8):
    """Draw a filled rounded rectangle with anti-aliased edges.

    Uses superellipse (x⁴+y⁴≤r⁴) for radii ≤ 200, matching the QEMU C
    backend's rt_gui_rounded_rect_aa. Falls back to circular (x²+y²≤r²)
    for larger radii where i32 would overflow.
    """
    if w <= 0 or h <= 0:
        return
    val r = if radius > w / 2: w / 2 else: if radius > h / 2: h / 2 else: radius
    if r <= 0:
        cap_blend_rect(backend, x, y, w, h, color, alpha)
        return

    # Delegate to superellipse for radii that fit i32 (r⁴ ≤ 2.1B → r ≤ 215)
    # Use 200 as safe limit. Covers all practical cases: dock r=14, windows r=22, splash r=28.
    if r <= 200:
        superellipse_rect(backend, x, y, w, h, color, r, alpha)
        return

    # Circular fallback for large radii (r > 200)
    var row: i32 = 0
    while row < h:
        var inset: i32 = 0
        var edge_alpha: u8 = alpha

        if row < r:
            # Top corners
            val dy = r - row
            val full_hw = _isqrt(r * r - dy * dy)
            inset = r - full_hw
            # Edge softening: reduce alpha on the outermost pixel
            if inset > 0:
                val edge_dy = r - (row + 1)
                val edge_hw = if edge_dy >= 0: _isqrt(r * r - edge_dy * edge_dy) else: r
                if edge_hw != full_hw:
                    # Fractional pixel — soften the edge
                    edge_alpha = alpha / 2
        else if row >= h - r:
            # Bottom corners
            val dy = row - (h - r - 1)
            val full_hw = _isqrt(r * r - dy * dy)
            inset = r - full_hw
            if inset > 0:
                edge_alpha = alpha / 2

        val rx = x + inset
        val rw = w - inset * 2
        if rw > 0:
            # Draw main row
            cap_blend_rect(backend, rx, y + row, rw, 1, color, alpha)
            # Soften edges (1px on each side at reduced alpha)
            if inset > 0 and edge_alpha < alpha:
                cap_blend_rect(backend, rx - 1, y + row, 1, 1, color, edge_alpha)
                cap_blend_rect(backend, rx + rw, y + row, 1, 1, color, edge_alpha)
        row = row + 1

# ============================================================================
# Bresenham Line Drawing
# ============================================================================

fn draw_line(backend: CompositorBackend, x1: i32, y1: i32, x2: i32, y2: i32,
             color: u32, thickness: i32, alpha: u8):
    """Draw a line from (x1,y1) to (x2,y2) with given thickness and alpha.

    Uses Bresenham-like stepping. For thick lines, draws a filled rect at each step.
    """
    var dx = x2 - x1
    var dy = y2 - y1
    val abs_dx = if dx < 0: 0 - dx else: dx
    val abs_dy = if dy < 0: 0 - dy else: dy
    val steps = if abs_dx > abs_dy: abs_dx else: abs_dy
    if steps <= 0:
        cap_blend_rect(backend, x1, y1, thickness, thickness, color, alpha)
        return

    var i: i32 = 0
    while i <= steps:
        val px = x1 + dx * i / steps
        val py = y1 + dy * i / steps
        cap_blend_rect(backend, px, py, thickness, thickness, color, alpha)
        i = i + 1

# ============================================================================
# Horizontal Gradient
# ============================================================================

fn gradient_h(backend: CompositorBackend, x: i32, y: i32, w: i32, h: i32,
              color1: u32, color2: u32):
    """Draw a horizontal gradient from color1 (left) to color2 (right).

    Uses 32-segment approximation with alpha blending. Produces smooth
    gradients matching C per-pixel quality for typical dock/title bar widths.
    """
    if w <= 0 or h <= 0:
        return

    val segs: i32 = if w < 32: w else: 32
    val seg_w = w / segs
    if seg_w <= 0:
        backend.fill_rect(x, y, w, h, color1)
        return
    val max_seg = segs - 1
    var s: i32 = 0
    while s < segs:
        val sx = x + seg_w * s
        val sw = if s == max_seg: w - seg_w * s else: seg_w
        if sw > 0:
            val t: u8 = if max_seg > 0: 255 * s / max_seg else: 0
            backend.fill_rect(sx, y, sw, h, color1)
            if t > 0:
                cap_blend_rect(backend, sx, y, sw, h, color2, t)
        s = s + 1

# ============================================================================
# Filled Circle
# ============================================================================

fn filled_circle(backend: CompositorBackend, cx: i32, cy: i32, r: i32, color: u32, alpha: u8):
    """Draw a filled circle centered at (cx, cy) with radius r.

    Uses concentric horizontal lines for circle approximation.
    Canonical implementation — replaces duplicates in desktop_chrome.spl.
    """
    var dy: i32 = 0 - r
    while dy <= r:
        val abs_dy = if dy < 0: 0 - dy else: dy
        val hw = _isqrt(r * r - abs_dy * abs_dy)
        if hw > 0:
            cap_blend_rect(backend, cx - hw, cy + dy, hw * 2, 1, color, alpha)
        dy = dy + 1

# ============================================================================
# Circle Outline (Ring)
# ============================================================================

fn draw_ring(backend: CompositorBackend, cx: i32, cy: i32, r: i32,
             thickness: i32, color: u32, alpha: u8):
    """Draw a circle outline (ring) centered at (cx, cy).

    Renders the difference between outer and inner circles.
    """
    val inner_r = r - thickness
    var dy: i32 = 0 - r
    while dy <= r:
        val abs_dy = if dy < 0: 0 - dy else: dy
        val hw_outer = _isqrt(r * r - abs_dy * abs_dy)
        val hw_inner = if abs_dy < inner_r: _isqrt(inner_r * inner_r - abs_dy * abs_dy) else: 0
        val left_w = hw_outer - hw_inner
        if left_w > 0:
            # Left arc
            cap_blend_rect(backend, cx - hw_outer, cy + dy, left_w, 1, color, alpha)
            # Right arc
            cap_blend_rect(backend, cx + hw_inner, cy + dy, left_w, 1, color, alpha)
        dy = dy + 1

# ============================================================================
# Radial Gradient
# ============================================================================

fn gradient_radial(backend: CompositorBackend, cx: i32, cy: i32, radius: i32,
                   color: u32, max_alpha: u8):
    """Draw a radial gradient from transparent (outer) to max_alpha (inner).
    Uses 8 concentric filled_circle rings for smooth falloff.
    """
    if radius <= 0:
        return
    var ring: i32 = 0
    while ring < 8:
        val r = radius - radius * ring / 8
        val a: u8 = max_alpha * (ring + 1) / 8
        if r > 0:
            filled_circle(backend, cx, cy, r, color, a)
        ring = ring + 1

# ============================================================================
# Vignette (Edge Darkening)
# ============================================================================

fn draw_vignette(backend: CompositorBackend, x: i32, y: i32, w: i32, h: i32, max_alpha: u8):
    """Draw edge vignette (darkening in outer 40% of region).
    Uses 8 concentric rectangular bands with decreasing alpha inward.
    """
    val band_w = w * 2 / 5
    val band_h = h * 2 / 5
    var step: i32 = 0
    while step < 8:
        val a: u8 = max_alpha * (8 - step) / 8
        val dx = band_w * step / 8
        val dy = band_h * step / 8
        val rw = w - dx * 2
        val rh = h - dy * 2
        if rw > 0 and rh > 0:
            # Top edge
            cap_blend_rect(backend, x + dx, y + dy, rw, 1, 0x00000000, a)
            # Bottom edge
            cap_blend_rect(backend, x + dx, y + h - 1 - dy, rw, 1, 0x00000000, a)
            # Left edge
            cap_blend_rect(backend, x + dx, y + dy, 1, rh, 0x00000000, a)
            # Right edge
            cap_blend_rect(backend, x + w - 1 - dx, y + dy, 1, rh, 0x00000000, a)
        step = step + 1

# ============================================================================
# Superellipse Rounded Rect (Squircle)
# ============================================================================

fn superellipse_rect(backend: CompositorBackend, x: i32, y: i32, w: i32, h: i32,
                     color: u32, radius: i32, alpha: u8):
    """Draw a filled superellipse (squircle) rounded rect.
    Uses x⁴+y⁴≤r⁴ for smoother continuous-curvature corners (macOS/iPadOS style).
    Radius limited to 200 for i32 overflow safety (200⁴ = 1.6B, fits signed i32).
    """
    if w <= 0 or h <= 0:
        return
    val r = if radius > 200: 200 else: if radius > w / 2: w / 2 else: if radius > h / 2: h / 2 else: radius
    if r <= 0:
        cap_blend_rect(backend, x, y, w, h, color, alpha)
        return

    val r2 = r * r
    val r4 = r2 * r2

    var row: i32 = 0
    while row < h:
        var inset: i32 = 0
        if row < r:
            val dy = r - row
            val dy2 = dy * dy
            val dy4 = dy2 * dy2
            val rem = r4 - dy4
            if rem > 0:
                val hw = _fourth_root_i32(rem)
                inset = r - hw
            else:
                inset = r
        else if row >= h - r:
            val dy = row - (h - r - 1)
            val dy2 = dy * dy
            val dy4 = dy2 * dy2
            val rem = r4 - dy4
            if rem > 0:
                val hw = _fourth_root_i32(rem)
                inset = r - hw
            else:
                inset = r

        val rx = x + inset
        val rw = w - inset * 2
        if rw > 0:
            cap_blend_rect(backend, rx, y + row, rw, 1, color, alpha)
            # Anti-alias: soften outer pixels on corner rows
            if inset > 0:
                cap_blend_rect(backend, rx - 1, y + row, 1, 1, color, alpha / 3)
                cap_blend_rect(backend, rx + rw, y + row, 1, 1, color, alpha / 3)
        row = row + 1

fn _fourth_root_i32(n: i32) -> i32:
    """Integer fourth root via nested square root: ⁴√n = √(√n)."""
    if n <= 0: return 0
    if n == 1: return 1
    val sq = _isqrt(n)
    _isqrt(sq)
