#![allow(unnamed_duplicate_typed_args)]

use os.compositor.wm_consistency_runner.{ConsistencyReport}

fn export_comparison_ppm(pixels: [u32], width: i32, height: i32, path: text) -> bool:
    pixels.len() > 0 and width > 0 and height > 0 and pixels.len() == width * height and path.len() > 0

fn export_diff_artifacts(report: ConsistencyReport, out_dir: text) -> bool:
    out_dir.len() > 0 and report.width > 0 and report.height > 0
