#![allow(unnamed_duplicate_typed_args)]
# Diff Export — Diff visualization artifact export
#
# Exports diff visualization artifacts: diff image as PPM, per-channel
# diffs, and annotated region overlay. Generated only on comparison
# failure or explicit request, not on every run.
#
# Depends on:
#   - os.compositor.screenshot_compare (generate_diff_image, generate_channel_diff_image)

use os.compositor.screenshot_compare.{generate_diff_image, generate_channel_diff_image}
use os.compositor.wm_consistency_runner.{ConsistencyReport}
use std.nogc_sync_mut.ffi.io.{file_write_bytes, dir_create_all}

# ============================================================================
# Single Image Export
# ============================================================================

fn export_comparison_ppm(pixels: [u32], width: i32, height: i32, path: text) -> bool:
    """Export a pixel buffer as PPM P6 (binary) file.

    Args:
        pixels: ARGB u32 pixel buffer
        width: Image width
        height: Image height
        path: Output file path

    Returns:
        true on success, false on error (e.g. empty buffer)
    """
    if pixels.len() == 0 or width <= 0 or height <= 0:
        return false

    # Build PPM header
    val header = "P6\n{width} {height}\n255\n"

    # Build pixel data as raw bytes (RGB, no alpha)
    var data: [u8] = []
    for pixel in pixels:
        val r = ((pixel >> 16) & 0xFF).to_u8()
        val g = ((pixel >> 8) & 0xFF).to_u8()
        val b = (pixel & 0xFF).to_u8()
        data = data + [r, g, b]

    # Combine header bytes + pixel data
    var full_data: [u8] = []
    for ch in header:
        full_data = full_data + [ch.to_u8()]
    for b in data:
        full_data = full_data + [b]

    # Write file
    file_write_bytes(path, full_data)
    true

# ============================================================================
# Full Diff Artifact Export
# ============================================================================

fn export_diff_artifacts(report: ConsistencyReport, output_dir: text) -> bool:
    """Export diff visualization artifacts from a ConsistencyReport.

    Creates:
    - diff.ppm: Visual diff image (green=match, red=diff)
    - diff_R.ppm: Red channel diff
    - diff_G.ppm: Green channel diff
    - diff_B.ppm: Blue channel diff
    - electron.ppm: Electron capture
    - qemu.ppm: QEMU capture

    Args:
        report: ConsistencyReport with electron_capture, qemu_capture, overall
        output_dir: Directory to write artifacts to

    Returns:
        true if at least some artifacts were exported
    """
    # Ensure output directory exists
    dir_create_all(output_dir)

    val e_pixels = report.electron_capture.pixels
    val q_pixels = report.qemu_capture.pixels
    val width = report.electron_capture.width
    val height = report.electron_capture.height

    # Use qemu dimensions if electron is empty
    val w = if width > 0: width else: report.qemu_capture.width
    val h = if height > 0: height else: report.qemu_capture.height

    if w <= 0 or h <= 0:
        return false

    var exported_any = false

    # Export source images
    if e_pixels.len() > 0:
        val ok = export_comparison_ppm(e_pixels, w, h, "{output_dir}/electron.ppm")
        if ok:
            exported_any = true

    if q_pixels.len() > 0:
        val ok = export_comparison_ppm(q_pixels, w, h, "{output_dir}/qemu.ppm")
        if ok:
            exported_any = true

    # Generate and export diff image
    if e_pixels.len() > 0 and q_pixels.len() > 0:
        val diff = generate_diff_image(e_pixels, q_pixels, w, h)
        val ok = export_comparison_ppm(diff, w, h, "{output_dir}/diff.ppm")
        if ok:
            exported_any = true

        # Per-channel diffs
        val diff_r = generate_channel_diff_image(e_pixels, q_pixels, w, h, "R")
        export_comparison_ppm(diff_r, w, h, "{output_dir}/diff_R.ppm")

        val diff_g = generate_channel_diff_image(e_pixels, q_pixels, w, h, "G")
        export_comparison_ppm(diff_g, w, h, "{output_dir}/diff_G.ppm")

        val diff_b = generate_channel_diff_image(e_pixels, q_pixels, w, h, "B")
        export_comparison_ppm(diff_b, w, h, "{output_dir}/diff_B.ppm")

    # If only qemu pixels available, still export them
    if e_pixels.len() == 0 and q_pixels.len() > 0:
        exported_any = true

    exported_any
