# App Content — Shared application content rendering
#
# Renders window content for demo apps: Terminal, Editor, File Manager, Calculator.
# Uses CompositorBackend trait for cross-platform rendering.
# Shared between hosted (winit) and QEMU window managers.
# Ported from QEMU ARM64 wm_entry.spl content functions + hosted compositor.

use os.compositor.display_backend.{CompositorBackend}

# ============================================================================
# App State
# ============================================================================

struct AppState:
    """Mutable state for interactive app windows."""
    term_cmd: text
    term_output: i32
    term_history: i32
    edit_cx: i32
    edit_cy: i32
    edit_buf: text
    fm_folder: i32
    fm_file: i32

fn app_state_new() -> AppState:
    """Create default app state."""
    AppState(term_cmd: "", term_output: 0, term_history: 0,
             edit_cx: 0, edit_cy: 3, edit_buf: "",
             fm_folder: 0, fm_file: -1)

# ============================================================================
# Main Dispatcher
# ============================================================================

fn render_app_content(backend: CompositorBackend, title: text, cx: i32, cy: i32, cw: i32, ch: i32):
    """Render app content based on window title.

    Dispatches to the appropriate content renderer.
    Shared by both hosted and QEMU window managers.
    """
    if title == "Terminal":
        render_terminal(backend, cx, cy, cw, ch)
    else if title == "Editor" or title == "Hello World":
        render_editor(backend, cx, cy, cw, ch)
    else if title == "File Manager" or title == "Finder":
        render_file_manager(backend, cx, cy, cw, ch)
    else if title == "Calculator":
        render_calculator(backend, cx, cy, cw, ch)
    else:
        # Default: show title text
        backend.draw_text(cx + 8, cy + 8, title, 0xFFE0E0F0, 0x00000000)

# ============================================================================
# Stateful Dispatcher
# ============================================================================

fn render_app_content_stateful(backend: CompositorBackend, title: text, cx: i32, cy: i32, cw: i32, ch: i32, state: AppState):
    """Render app content with interactive state."""
    if title == "Terminal":
        render_terminal_interactive(backend, cx, cy, cw, ch, state)
    else if title == "Editor" or title == "Hello World":
        render_editor_interactive(backend, cx, cy, cw, ch, state)
    else if title == "File Manager" or title == "Finder":
        render_file_manager_interactive(backend, cx, cy, cw, ch, state)
    else if title == "Browser":
        render_browser(backend, cx, cy, cw, ch)
    else if title == "Calculator":
        render_calculator(backend, cx, cy, cw, ch)
    else:
        backend.draw_text(cx + 8, cy + 8, title, 0xFFE0E0F0, 0x00000000)

# ============================================================================
# Terminal
# ============================================================================

fn render_terminal(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch: i32):
    """Render terminal emulator content.

    Shows a simulated shell session with colored output.
    Green prompt, white/gray text, blue paths, orange cursor.
    """
    val bg: u32 = 0xFF0A0A14
    val green: u32 = 0xFF44FF44
    val gray: u32 = 0xFF888888
    val blue: u32 = 0xFF5588CC
    val white: u32 = 0xFFE0E0F0
    val orange: u32 = 0xFFFF8844

    # Terminal background
    backend.fill_rect(cx, cy, cw, ch, bg)

    # Cursor block at prompt
    backend.blend_rect(cx + 12, cy + 10, 8, 16, green, 255)

    # Shell session lines
    backend.draw_text(cx + 24, cy + 10, "$ ls -la", green, 0x00000000)
    backend.draw_text(cx + 12, cy + 28, "total 42", gray, 0x00000000)
    backend.draw_text(cx + 12, cy + 46, "drwxr-xr-x  src/", blue, 0x00000000)
    backend.draw_text(cx + 12, cy + 64, "drwxr-xr-x  test/", blue, 0x00000000)
    backend.draw_text(cx + 12, cy + 82, "-rw-r--r--  main.spl", white, 0x00000000)
    backend.draw_text(cx + 12, cy + 100, "-rw-r--r--  mod.spl", gray, 0x00000000)
    backend.draw_text(cx + 12, cy + 118, "-rw-r--r--  readme.md", gray, 0x00000000)

    # Second prompt with colored output
    if ch > 150:
        backend.draw_text(cx + 12, cy + 144, "$ cargo build", green, 0x00000000)
        backend.draw_text(cx + 12, cy + 162, "Compiling simple v0.1.0", blue, 0x00000000)
        backend.draw_text(cx + 12, cy + 180, "Finished in 2.3s", green, 0x00000000)

    # Active cursor
    if ch > 200:
        backend.blend_rect(cx + 12, cy + 206, 8, 16, green, 180)
        backend.draw_text(cx + 24, cy + 206, "$ _", green, 0x00000000)

# ============================================================================
# Interactive Terminal (P13)
# ============================================================================

fn render_terminal_interactive(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch: i32, state: AppState):
    """Interactive terminal with command input and output."""
    # Dark background
    backend.fill_rect(cx, cy, cw, ch, 0xFF0A0A14)

    var line_y = cy + 4

    # Show previous command output if any
    if state.term_output == 1:
        # help output
        backend.draw_text(cx + 8, line_y, "Commands:", 0xFF44FF44, 0x00000000)
        line_y = line_y + 18
        backend.draw_text(cx + 8, line_y, " help ls pwd ps", 0xFFA0A0B0, 0x00000000)
        line_y = line_y + 18
        backend.draw_text(cx + 8, line_y, " free date uptime", 0xFFA0A0B0, 0x00000000)
        line_y = line_y + 18
        backend.draw_text(cx + 8, line_y, " hostname echo uname", 0xFFA0A0B0, 0x00000000)
        line_y = line_y + 18
        backend.draw_text(cx + 8, line_y, " clear whoami", 0xFFA0A0B0, 0x00000000)
        line_y = line_y + 18
    else if state.term_output == 2:
        # ls output
        backend.draw_text(cx + 8, line_y, "bin/  etc/  home/", 0xFF6699FF, 0x00000000)
        line_y = line_y + 18
        backend.draw_text(cx + 8, line_y, "boot/ kernel.elf", 0xFF6699FF, 0x00000000)
        line_y = line_y + 18
    else if state.term_output == 3:
        # pwd
        backend.draw_text(cx + 8, line_y, "/home/root", 0xFFE0E0F0, 0x00000000)
        line_y = line_y + 18
    else if state.term_output == 4:
        # ps
        backend.draw_text(cx + 8, line_y, "PID  CMD", 0xFF44FF44, 0x00000000)
        line_y = line_y + 18
        backend.draw_text(cx + 8, line_y, "  1  init", 0xFFE0E0F0, 0x00000000)
        line_y = line_y + 18
        backend.draw_text(cx + 8, line_y, "  2  wm", 0xFFE0E0F0, 0x00000000)
        line_y = line_y + 18
        backend.draw_text(cx + 8, line_y, "  3  shell", 0xFFE0E0F0, 0x00000000)
        line_y = line_y + 18
    else if state.term_output == 5:
        # free
        backend.draw_text(cx + 8, line_y, "Total: 256MB", 0xFFE0E0F0, 0x00000000)
        line_y = line_y + 18
        backend.draw_text(cx + 8, line_y, "Used:   67MB", 0xFFE0E0F0, 0x00000000)
        line_y = line_y + 18
        backend.draw_text(cx + 8, line_y, "Free:  189MB", 0xFFE0E0F0, 0x00000000)
        line_y = line_y + 18
    else if state.term_output == 6:
        backend.draw_text(cx + 8, line_y, "2026-04-07 12:00:00", 0xFFE0E0F0, 0x00000000)
        line_y = line_y + 18
    else if state.term_output == 7:
        backend.draw_text(cx + 8, line_y, "up 0:05:23", 0xFFE0E0F0, 0x00000000)
        line_y = line_y + 18
    else if state.term_output == 8:
        backend.draw_text(cx + 8, line_y, "simpleos", 0xFFE0E0F0, 0x00000000)
        line_y = line_y + 18
    else if state.term_output == 9:
        backend.draw_text(cx + 8, line_y, "SimpleOS 1.0 aarch64", 0xFFE0E0F0, 0x00000000)
        line_y = line_y + 18
    else if state.term_output == 10:
        backend.draw_text(cx + 8, line_y, "root", 0xFFE0E0F0, 0x00000000)
        line_y = line_y + 18

    # Current prompt with input
    backend.draw_text(cx + 8, line_y, "$ ", 0xFF44FF44, 0x00000000)
    backend.draw_text(cx + 24, line_y, state.term_cmd, 0xFFE0E0F0, 0x00000000)
    # Cursor block
    val cursor_x = cx + 24 + state.term_cmd.len() * 8
    backend.fill_rect(cursor_x, line_y, 8, 16, 0xFF44FF44)

# ============================================================================
# Editor (Code Editor with syntax highlighting)
# ============================================================================

fn render_editor(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch: i32):
    """Render a code editor with syntax-highlighted Simple language code.

    Includes tab bar, file tree sidebar, line numbers, and colored syntax.
    Ported from QEMU's draw_hello_content.
    """
    val sidebar_w: i32 = 70
    val tab_h: i32 = 24
    val status_h: i32 = 20
    val line_h: i32 = 16

    # Colors
    val bg_dark: u32 = 0xFF0D0D14
    val bg_sidebar: u32 = 0xFF181820
    val text_main: u32 = 0xFFCCCCCC
    val text_dim: u32 = 0xFF666688
    val kw_orange: u32 = 0xFFCC7832
    val fn_yellow: u32 = 0xFFFFC66D
    val num_blue: u32 = 0xFF6897BB
    val comment_green: u32 = 0xFF629755
    val accent: u32 = 0xFF0A84FF

    # Tab bar
    backend.blend_rect(cx, cy, cw, tab_h, 0x001E1E23, 180)
    backend.blend_rect(cx, cy + tab_h - 1, cw, 1, 0x40FFFFFF, 80)

    # Active tab
    backend.blend_rect(cx + sidebar_w + 2, cy + 2, 80, tab_h - 3, 0x002C2C32, 200)
    backend.blend_rect(cx + sidebar_w + 2, cy + tab_h - 2, 80, 2, accent, 200)
    backend.draw_text(cx + sidebar_w + 10, cy + 4, "main.spl", 0xFFE0E0F0, 0x00000000)

    # Second tab
    backend.draw_text(cx + sidebar_w + 92, cy + 4, "mod.spl", 0xFF808890, 0x00000000)

    # File tree sidebar
    val sb_y = cy + tab_h
    val sb_h = ch - tab_h - status_h
    backend.fill_rect(cx, sb_y, sidebar_w, sb_h, bg_sidebar)
    backend.blend_rect(cx + sidebar_w, sb_y, 1, sb_h, 0x40FFFFFF, 40)

    backend.draw_text(cx + 4, sb_y + 4, "EXPLORER", text_dim, 0x00000000)
    backend.draw_text(cx + 4, sb_y + 20, "> src/", text_main, 0x00000000)
    backend.draw_text(cx + 14, sb_y + 36, "main.spl", accent, 0x00000000)
    backend.draw_text(cx + 14, sb_y + 52, "mod.spl", text_main, 0x00000000)
    backend.draw_text(cx + 4, sb_y + 72, "> test/", text_main, 0x00000000)
    backend.draw_text(cx + 14, sb_y + 88, "spec.spl", text_main, 0x00000000)

    # Editor area
    val ed_x = cx + sidebar_w + 1
    val ed_y = sb_y
    val ed_w = cw - sidebar_w - 1
    val ed_h = sb_h
    backend.fill_rect(ed_x, ed_y, ed_w, ed_h, bg_dark)

    # Line number gutter
    val gutter_w: i32 = 30
    backend.blend_rect(ed_x, ed_y, gutter_w, ed_h, 0x00FFFFFF, 8)
    backend.blend_rect(ed_x + gutter_w, ed_y, 1, ed_h, 0x00FFFFFF, 20)

    # Line numbers
    var ln: i32 = 0
    while ln < 8 and (ln * line_h + 4) < ed_h:
        val ly = ed_y + 4 + ln * line_h
        val num_str = "{ln + 1}"
        backend.draw_text(ed_x + 16, ly, num_str, text_dim, 0x00000000)
        ln = ln + 1

    # Syntax-highlighted code
    val code_x = ed_x + gutter_w + 8
    # Line 1: fn main():
    backend.draw_text(code_x, ed_y + 4, "fn", kw_orange, 0x00000000)
    backend.draw_text(code_x + 24, ed_y + 4, "main", fn_yellow, 0x00000000)
    backend.draw_text(code_x + 56, ed_y + 4, "():", text_main, 0x00000000)

    # Line 2:     val x = 42
    backend.draw_text(code_x + 32, ed_y + 20, "val", kw_orange, 0x00000000)
    backend.draw_text(code_x + 56, ed_y + 20, "x = ", text_main, 0x00000000)
    backend.draw_text(code_x + 88, ed_y + 20, "42", num_blue, 0x00000000)

    # Line 3:     print x
    backend.draw_text(code_x + 32, ed_y + 36, "print", fn_yellow, 0x00000000)
    backend.draw_text(code_x + 72, ed_y + 36, "x", text_main, 0x00000000)

    # Line 4: (empty)

    # Line 5: # Comment
    backend.draw_text(code_x, ed_y + 68, "# Comment", comment_green, 0x00000000)

    # Line 6: fn square(n):
    backend.draw_text(code_x, ed_y + 84, "fn", kw_orange, 0x00000000)
    backend.draw_text(code_x + 24, ed_y + 84, "square", fn_yellow, 0x00000000)
    backend.draw_text(code_x + 72, ed_y + 84, "(n):", text_main, 0x00000000)

    # Line 7:     n * n
    backend.draw_text(code_x + 32, ed_y + 100, "n * n", text_main, 0x00000000)

    # Cursor blink line
    backend.blend_rect(code_x + 80, ed_y + 36, 2, 14, accent, 255)

    # Current line highlight
    backend.blend_rect(ed_x + gutter_w + 1, ed_y + 34, ed_w - gutter_w - 2, line_h, 0x00FFFFFF, 8)

    # Status bar
    val st_y = cy + ch - status_h
    backend.blend_rect(cx, st_y, cw, status_h, accent, 200)
    backend.draw_text(cx + 8, st_y + 3, "Ln 3, Col 1", 0xFFFFFFFF, 0x00000000)
    backend.draw_text(cx + cw - 56, st_y + 3, "Simple", 0xFFFFFFFF, 0x00000000)

# ============================================================================
# Interactive Editor (P14)
# ============================================================================

fn render_editor_interactive(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch_val: i32, state: AppState):
    """Editor with movable cursor and editable line."""
    # Base: use existing render_editor for the static content
    render_editor(backend, cx, cy, cw, ch_val)
    # Overlay: cursor at state position
    val cursor_px = cx + 78 + state.edit_cx * 8
    val cursor_py = cy + 24 + state.edit_cy * 18
    # Cursor line (accent blue)
    backend.blend_rect(cursor_px, cursor_py, 2, 16, 0x000A84FF, 200)
    # Current line highlight
    backend.blend_rect(cx + 78, cursor_py, cw - 86, 16, 0x00FFFFFF, 8)
    # Edit buffer overlay if non-empty
    if state.edit_buf.len() > 0:
        backend.draw_text(cursor_px + 4, cursor_py, state.edit_buf, 0xFFE0E0F0, 0x00000000)

# ============================================================================
# File Manager
# ============================================================================

fn render_file_manager(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch: i32):
    """Render File Manager / Finder with toolbar, sidebar, and file grid.

    Includes navigation arrows, favorites sidebar, folder icons.
    Ported from QEMU's draw_files_content + hosted compositor.
    """
    val sidebar_w: i32 = 110
    val toolbar_h: i32 = 28
    val pathbar_h: i32 = 20

    # Toolbar
    backend.blend_rect(cx, cy, cw, toolbar_h, 0x001E1E23, 180)
    backend.blend_rect(cx, cy + toolbar_h - 1, cw, 1, 0x40FFFFFF, 80)

    # Navigation arrows (back/forward)
    backend.blend_rect(cx + 10, cy + 12, 8, 2, 0x00FFFFFF, 140)
    backend.blend_rect(cx + 10, cy + 10, 2, 6, 0x00FFFFFF, 140)
    backend.blend_rect(cx + 26, cy + 12, 8, 2, 0x00FFFFFF, 140)
    backend.blend_rect(cx + 32, cy + 10, 2, 6, 0x00FFFFFF, 140)

    # Sidebar
    val sb_y = cy + toolbar_h
    val sb_h = ch - toolbar_h - pathbar_h
    backend.blend_rect(cx, sb_y, sidebar_w, sb_h, 0x001E1E23, 80)
    backend.blend_rect(cx + sidebar_w, sb_y, 1, sb_h, 0x40FFFFFF, 40)

    backend.draw_text(cx + 10, sb_y + 6, "Favorites", 0xFF808890, 0x00000000)
    # Active item (Desktop)
    backend.blend_rect(cx + 4, sb_y + 22, sidebar_w - 8, 18, 0x000A84FF, 80)
    backend.draw_text(cx + 24, sb_y + 24, "Desktop", 0xFFE0E0F0, 0x00000000)
    backend.draw_text(cx + 24, sb_y + 44, "Documents", 0xFFC0C0D0, 0x00000000)
    backend.draw_text(cx + 24, sb_y + 62, "Downloads", 0xFFC0C0D0, 0x00000000)

    # Content area — file list or folder icons
    val content_x = cx + sidebar_w + 8
    val content_y = sb_y + 8

    # File list header
    backend.draw_text(content_x, content_y, "Name          Type  Size", 0xFF808890, 0x00000000)
    backend.blend_rect(content_x, content_y + 16, cw - sidebar_w - 16, 1, 0x40FFFFFF, 40)

    # Files
    backend.draw_text(content_x, content_y + 22, "[D] Documents  Dir  4 KB", 0xFFE0E0F0, 0x00000000)
    backend.draw_text(content_x, content_y + 40, "[D] Downloads  Dir  4 KB", 0xFFE0E0F0, 0x00000000)
    backend.draw_text(content_x, content_y + 58, "[D] Pictures   Dir  4 KB", 0xFFE0E0F0, 0x00000000)
    backend.draw_text(content_x, content_y + 76, "    readme.md  File 2 KB", 0xFF808890, 0x00000000)
    backend.draw_text(content_x, content_y + 94, "    hello.spl  File 512B", 0xFF808890, 0x00000000)

    # Path bar
    val pb_y = cy + ch - pathbar_h
    backend.blend_rect(cx, pb_y, cw, pathbar_h, 0x001E1E23, 80)
    backend.blend_rect(cx, pb_y, cw, 1, 0x40FFFFFF, 40)
    backend.draw_text(cx + 8, pb_y + 3, "SimpleHD > Desktop", 0xFF808890, 0x00000000)

# ============================================================================
# Interactive File Manager (P15)
# ============================================================================

fn render_file_manager_interactive(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch_val: i32, state: AppState):
    """File manager with selectable sidebar."""
    # Base static content
    render_file_manager(backend, cx, cy, cw, ch_val)
    # Highlight selected sidebar folder
    val sel_y = cy + 50 + state.fm_folder * 20
    backend.blend_rect(cx + 2, sel_y, 108, 18, 0x000A84FF, 40)

# ============================================================================
# Calculator
# ============================================================================

fn render_calculator(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch: i32):
    """Render a calculator with display and button grid.

    Shows numeric display and 4x4 button grid + clear button.
    Shared between all platforms.
    """
    val fg: u32 = 0xFFE0E0F0
    val dim: u32 = 0xFF808890

    # Display
    backend.blend_rect(cx + 8, cy + 8, cw - 16, 32, 0x00FFFFFF, 30)
    backend.draw_text(cx + cw - 24, cy + 16, "0", fg, 0x00000000)

    # Button grid 4x4
    val bw: i32 = (cw - 40) / 4
    val bh: i32 = 28
    val labels = ["7", "8", "9", "/", "4", "5", "6", "*", "1", "2", "3", "-", "0", ".", "=", "+"]
    var bi: i32 = 0
    while bi < 16:
        val bx = cx + 8 + (bi % 4) * (bw + 4)
        val by = cy + 52 + (bi / 4) * (bh + 4)
        backend.blend_rect(bx, by, bw, bh, 0x00FFFFFF, 40)
        backend.draw_text(bx + bw / 2 - 4, by + 6, labels[bi], fg, 0x00000000)
        bi = bi + 1

    # Clear button (red tint)
    backend.blend_rect(cx + 8, cy + 52 + 4 * (bh + 4), bw, bh, 0x00FF6666, 60)
    backend.draw_text(cx + 8 + bw / 2 - 4, cy + 52 + 4 * (bh + 4) + 6, "C", fg, 0x00000000)

    # Operator column accent
    val op_x = cx + 8 + 3 * (bw + 4)
    backend.blend_rect(op_x, cy + 52, bw, 4 * (bh + 4) - 4, 0x000A84FF, 20)

# ============================================================================
# Browser (P16)
# ============================================================================

fn render_browser(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, ch_val: i32):
    """Browser window with URL bar and about:network page."""
    # URL bar
    backend.fill_rect(cx, cy, cw, 28, 0xFF2C2C32)
    backend.blend_rect(cx + 4, cy + 4, cw - 8, 20, 0x00FFFFFF, 15)
    backend.draw_text(cx + 8, cy + 6, "about:network", 0xFFE0E0F0, 0x00000000)
    # Separator
    backend.fill_rect(cx, cy + 28, cw, 1, 0xFF404050)
    # Page content
    val py = cy + 36
    backend.fill_rect(cx, py, cw, ch_val - 36, 0xFF1A1A24)
    backend.draw_text(cx + 8, py + 4, "Network Status", 0xFF44FF44, 0x00000000)
    backend.draw_text(cx + 8, py + 24, "VirtIO-net: OK", 0xFFE0E0F0, 0x00000000)
    backend.draw_text(cx + 8, py + 42, "MAC: 52:54:00:12:34:56", 0xFFA0A0B0, 0x00000000)
    backend.draw_text(cx + 8, py + 60, "TX: 0 packets", 0xFFA0A0B0, 0x00000000)
    backend.draw_text(cx + 8, py + 78, "RX: 0 packets", 0xFFA0A0B0, 0x00000000)
    backend.draw_text(cx + 8, py + 100, "QEMU user network", 0xFF6699FF, 0x00000000)

# ============================================================================
# Input Handling
# ============================================================================

fn handle_app_input(state: AppState, title: text, key: i32) -> AppState:
    """Handle keyboard input for interactive apps. Returns updated state."""
    if title == "Terminal":
        if key == 13:
            # Enter — parse command
            var output: i32 = 0
            if state.term_cmd == "help":
                output = 1
            else if state.term_cmd == "ls":
                output = 2
            else if state.term_cmd == "pwd":
                output = 3
            else if state.term_cmd == "ps":
                output = 4
            else if state.term_cmd == "free":
                output = 5
            else if state.term_cmd == "date":
                output = 6
            else if state.term_cmd == "uptime":
                output = 7
            else if state.term_cmd == "hostname":
                output = 8
            else if state.term_cmd == "uname":
                output = 9
            else if state.term_cmd == "whoami":
                output = 10
            else if state.term_cmd == "clear":
                output = 0
            return AppState(term_cmd: "", term_output: output, term_history: state.term_history + 1,
                           edit_cx: state.edit_cx, edit_cy: state.edit_cy, edit_buf: state.edit_buf,
                           fm_folder: state.fm_folder, fm_file: state.fm_file)
        else if key == 8:
            # Backspace — clear command
            if state.term_cmd.len() > 0:
                return AppState(term_cmd: "", term_output: state.term_output, term_history: state.term_history,
                               edit_cx: state.edit_cx, edit_cy: state.edit_cy, edit_buf: state.edit_buf,
                               fm_folder: state.fm_folder, fm_file: state.fm_file)
            return state
        else if key >= 32 and key <= 126:
            # Append printable character
            val ch = _key_to_char(key)
            return AppState(term_cmd: state.term_cmd + ch, term_output: state.term_output, term_history: state.term_history,
                           edit_cx: state.edit_cx, edit_cy: state.edit_cy, edit_buf: state.edit_buf,
                           fm_folder: state.fm_folder, fm_file: state.fm_file)
    state

fn _key_to_char(key: i32) -> text:
    """Convert ASCII key code to single-char text."""
    if key == 32: return " "
    if key == 97: return "a"
    if key == 98: return "b"
    if key == 99: return "c"
    if key == 100: return "d"
    if key == 101: return "e"
    if key == 102: return "f"
    if key == 103: return "g"
    if key == 104: return "h"
    if key == 105: return "i"
    if key == 106: return "j"
    if key == 107: return "k"
    if key == 108: return "l"
    if key == 109: return "m"
    if key == 110: return "n"
    if key == 111: return "o"
    if key == 112: return "p"
    if key == 113: return "q"
    if key == 114: return "r"
    if key == 115: return "s"
    if key == 116: return "t"
    if key == 117: return "u"
    if key == 118: return "v"
    if key == 119: return "w"
    if key == 120: return "x"
    if key == 121: return "y"
    if key == 122: return "z"
    ""

# ============================================================================
# Click Handling
# ============================================================================

fn handle_app_click(state: AppState, title: text, local_x: i32, local_y: i32) -> AppState:
    """Handle mouse click for interactive apps."""
    if title == "File Manager" or title == "Finder":
        # Sidebar click (x < 110)
        if local_x < 110:
            val folder = (local_y - 50) / 20
            if folder >= 0 and folder < 5:
                return AppState(term_cmd: state.term_cmd, term_output: state.term_output,
                               term_history: state.term_history,
                               edit_cx: state.edit_cx, edit_cy: state.edit_cy,
                               edit_buf: state.edit_buf,
                               fm_folder: folder, fm_file: state.fm_file)
    else if title == "Editor" or title == "Hello World":
        # Map click to cursor position
        val col = (local_x - 78) / 8
        val row = (local_y - 24) / 18
        if col >= 0 and row >= 0:
            return AppState(term_cmd: state.term_cmd, term_output: state.term_output,
                           term_history: state.term_history,
                           edit_cx: col, edit_cy: row, edit_buf: state.edit_buf,
                           fm_folder: state.fm_folder, fm_file: state.fm_file)
    state
