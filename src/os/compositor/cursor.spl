@allow(primitive_api)
# Mouse Cursor Renderer
#
# Renders a 12x19 arrow cursor bitmap onto the framebuffer.
# Uses mask for black outline and bitmap for white fill.

use os.compositor.display_backend.{CompositorBackend}
use os.compositor.glass_dispatch.{cap_blend_rect, cap_blur_region, cap_gradient_v, cap_read_pixel}

# ============================================================================
# Cursor Constants
# ============================================================================

val CURSOR_WIDTH: i32 = 12
val CURSOR_HEIGHT: i32 = 19

# ============================================================================
# Cursor State
# ============================================================================

struct CursorState:
    """Tracks cursor position, visibility, and hotspot offset."""
    x: i32
    y: i32
    visible: bool
    shape: i32        # 0=arrow, 1=ibeam, 2=hand
    hotspot_x: i32   # Click point offset from top-left
    hotspot_y: i32

fn default_cursor_state() -> CursorState:
    """Create a default cursor state at (0, 0) with standard arrow hotspot."""
    CursorState(
        x: 0,
        y: 0,
        visible: true,
        shape: 0,
        hotspot_x: 1,
        hotspot_y: 1
    )

# ============================================================================
# Cursor Bitmap — 12x19 Arrow
# ============================================================================

fn get_cursor_bitmap() -> [i64]:
    """Get the white fill bitmap for the arrow cursor.

    Each row is a 12-bit bitmask. MSB (bit 11) = leftmost pixel.
    1 = white fill pixel.
    """
    [
        0b100000000000,
        0b110000000000,
        0b111000000000,
        0b111100000000,
        0b111110000000,
        0b111111000000,
        0b111111100000,
        0b111111110000,
        0b111111111000,
        0b111111111100,
        0b111111000000,
        0b110111000000,
        0b100011100000,
        0b000011100000,
        0b000001110000,
        0b000001110000,
        0b000000111000,
        0b000000111000,
        0b000000000000
    ]

fn get_cursor_mask() -> [i64]:
    """Get the outline mask for the arrow cursor.

    Slightly larger than the bitmap to produce a 1px black border.
    Pixels in mask but NOT in bitmap are drawn as black outline.
    """
    [
        0b110000000000,
        0b111000000000,
        0b111100000000,
        0b111110000000,
        0b111111000000,
        0b111111100000,
        0b111111110000,
        0b111111111000,
        0b111111111100,
        0b111111111110,
        0b111111111110,
        0b111111100000,
        0b111011110000,
        0b110011110000,
        0b000001111000,
        0b000001111000,
        0b000000111100,
        0b000000111100,
        0b000000111100
    ]

# ============================================================================
# Cursor Drawing
# ============================================================================

fn draw_cursor(backend: CompositorBackend, screen_width: i32, screen_height: i32, cursor: CursorState):
    """Draw mouse cursor with shape-aware rendering.

    Supports arrow (0), I-beam (1), and hand (2) cursor shapes.
    Uses mask for black outline, bitmap for white fill (arrow).
    Clips to screen bounds. Drawn after all windows for topmost visibility.
    """
    if not cursor.visible:
        return

    val cx = cursor.x - cursor.hotspot_x
    val cy = cursor.y - cursor.hotspot_y

    if cursor.shape == 1:
        # I-beam cursor (text editing)
        # Top serif
        backend.fill_rect(cx - 2, cy, 5, 1, 0xFFFFFFFF)
        # Vertical bar
        backend.fill_rect(cx, cy + 1, 1, 17, 0xFFFFFFFF)
        # Bottom serif
        backend.fill_rect(cx - 2, cy + 18, 5, 1, 0xFFFFFFFF)
        # Shadow
        cap_blend_rect(backend, cx + 1, cy + 1, 1, 17, 0x00000000, 80)
        return

    if cursor.shape == 2:
        # Hand/pointer cursor
        # Index finger (vertical line at top)
        backend.fill_rect(cx + 4, cy, 3, 8, 0xFFFFFFFF)
        cap_blend_rect(backend, cx + 3, cy, 1, 8, 0x00000000, 120)
        cap_blend_rect(backend, cx + 7, cy, 1, 8, 0x00000000, 120)
        # Palm (wider rectangle below)
        backend.fill_rect(cx, cy + 8, 11, 8, 0xFFFFFFFF)
        cap_blend_rect(backend, cx - 1, cy + 8, 1, 8, 0x00000000, 120)
        cap_blend_rect(backend, cx + 11, cy + 8, 1, 8, 0x00000000, 120)
        # Bottom edge
        backend.fill_rect(cx + 1, cy + 16, 9, 2, 0xFFFFFFFF)
        cap_blend_rect(backend, cx, cy + 16, 1, 2, 0x00000000, 80)
        cap_blend_rect(backend, cx + 10, cy + 16, 1, 2, 0x00000000, 80)
        # Shadow
        cap_blend_rect(backend, cx + 1, cy + 18, 9, 1, 0x00000000, 60)
        return

    # Shape 0 (default): Arrow cursor
    val bitmap = get_cursor_bitmap()
    val mask = get_cursor_mask()

    var row: i32 = 0
    while row < CURSOR_HEIGHT:
        val py = cy + row
        if py >= 0 and py < screen_height:
            var col: i32 = 0
            while col < CURSOR_WIDTH:
                val px = cx + col
                if px >= 0 and px < screen_width:
                    val bit_shift: i64 = 11 - col
                    val bit: i64 = 1 << bit_shift
                    val row_idx: i64 = row
                    val mask_row = mask[row_idx]
                    val bitmap_row = bitmap[row_idx]
                    val mask_hit = (mask_row & bit) != 0
                    if mask_hit:
                        val bitmap_hit = (bitmap_row & bit) != 0
                        if bitmap_hit:
                            # White fill
                            backend.put_pixel(px, py, 0xFFFFFFFF)
                        else:
                            # Black outline
                            backend.put_pixel(px, py, 0xFF000000)
                col = col + 1
        row = row + 1
