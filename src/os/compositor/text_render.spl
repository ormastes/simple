#![allow(unnamed_duplicate_typed_args)]

use os.compositor.browser_compositor_backend.{set_backend_pixel_buffer_override}

fn text_width(content: text) -> i32:
    content.len().to_i32() * 8

fn text_width_2x(content: text) -> i32:
    text_width(content) * 2

fn draw_text_at(backend, x: i32, y: i32, content: text, color: u32):
    draw_text_scaled(backend, x, y, content, color, 1)

fn draw_text_scaled(backend, x: i32, y: i32, content: text, color: u32, scale: i32):
    val s = if scale > 0: scale else: 1
    var pixels = backend.get_pixel_buffer()
    var idx = 0
    while idx < content.len():
        val ox = x + idx * 6 * s
        var row = 0
        while row < 7 * s:
            var col = 0
            while col < 5 * s:
                val px = ox + col
                val py = y + row
                if px >= 0 and py >= 0 and px < backend.width and py < backend.height:
                    pixels[py * backend.width + px] = color
                col = col + 1
            row = row + 1
        idx = idx + 1
    set_backend_pixel_buffer_override(backend, pixels)
