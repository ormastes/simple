# Smoke-only lightweight hosted WM for Simple GUI lib inspection.
#
# The release/acceptance hosted WM path is src/os/hosted/hosted_entry.spl,
# which routes through HostCompositor and Simple Web/WebRenderer pixels.

use common.window_protocol.geometry.{Size}
use os.compositor.display_backend.{CompositorBackend}
use os.compositor.shared_mdi_setup.{shared_mdi_surfaces}
use os.compositor.simple_gui_window_renderer.{render_simple_gui_app_content}

class SimpleGuiHostedWindow:
    id: i64
    title: text
    app_id: text
    content: text
    x: i32
    y: i32
    w: i32
    h: i32
    minimized: bool
    focused: bool
    tab_group_id: i64

class TabGroup:
    id: i64
    active_tab_id: i64
    tab_ids: [i64]

class SimpleGuiHostedWm:
    backend: CompositorBackend
    width: i32
    height: i32
    windows: [SimpleGuiHostedWindow]
    tab_groups: [TabGroup]
    next_tab_group_id: i64
    pointer_x: i32
    pointer_y: i32
    dragging: bool
    drag_window_id: i64
    drag_offset_x: i32
    drag_offset_y: i32

    static fn create(backend: CompositorBackend, size: Size) -> SimpleGuiHostedWm:
        var windows: [SimpleGuiHostedWindow] = []
        var id: i64 = 1
        val surfaces = shared_mdi_surfaces()
        var i = 0
        while i < surfaces.len():
            val surface = surfaces[i]
            windows.push(SimpleGuiHostedWindow(
                id: id,
                title: surface.title,
                app_id: surface.app_id,
                content: surface.content,
                x: surface.x,
                y: surface.y,
                w: surface.w,
                h: surface.h,
                minimized: false,
                focused: i == surfaces.len() - 1,
                tab_group_id: 0
            ))
            id = id + 1
            i = i + 1
        SimpleGuiHostedWm(
            backend: backend,
            width: size.width.to_i32(),
            height: size.height.to_i32(),
            windows: windows,
            tab_groups: [],
            next_tab_group_id: 1,
            pointer_x: 0,
            pointer_y: 0,
            dragging: false,
            drag_window_id: 0,
            drag_offset_x: 0,
            drag_offset_y: 0
        )

    me render_frame():
        self.backend.clear(0xFF0F172Au32)
        var i = 0
        while i < self.windows.len():
            val win = self.windows[i]
            if win.minimized:
                i = i + 1
                continue
            if win.tab_group_id > 0:
                val grp = self.find_tab_group(win.tab_group_id)
                if grp != nil and grp.active_tab_id != win.id:
                    i = i + 1
                    continue
            val title_color = if win.focused: 0xFF2563EBu32 else: 0xFF334155u32
            val tab_bar_h = if win.tab_group_id > 0: 20 else: 0
            self.backend.fill_rect(win.x + 5, win.y + 6, win.w, win.h + tab_bar_h, 0x66000000u32)
            self.backend.fill_rect(win.x, win.y, win.w, win.h + tab_bar_h, 0xFF1E293Bu32)
            if win.tab_group_id > 0:
                self.render_tab_bar(win)
            self.backend.fill_rect(win.x, win.y + tab_bar_h, win.w, 24, title_color)
            self.backend.draw_text(win.x + 8, win.y + tab_bar_h + 4, win.title, 0xFFFFFFFFu32, title_color)
            self.backend.fill_rect(win.x + win.w - 24, win.y + tab_bar_h, 24, 24, 0xFFCC3333u32)
            self.backend.draw_text(win.x + win.w - 17, win.y + tab_bar_h + 4, "X", 0xFFFFFFFFu32, 0xFFCC3333u32)
            render_simple_gui_app_content(self.backend, win.title, win.x + 4, win.y + tab_bar_h + 28, win.w - 8, win.h - 32, win.content)
            i = i + 1
        self.backend.present()

    fn focused_window_id() -> i64:
        var i = 0
        while i < self.windows.len():
            if self.windows[i].focused and not self.windows[i].minimized:
                return self.windows[i].id
            i = i + 1
        0

    fn hit_window(x: i32, y: i32) -> i64:
        var i = self.windows.len() - 1
        while i >= 0:
            val win = self.windows[i]
            if not win.minimized and x >= win.x and y >= win.y and x < win.x + win.w and y < win.y + win.h:
                return win.id
            i = i - 1
        0

    me focus_window(window_id: i64):
        var focused: [SimpleGuiHostedWindow] = []
        var selected: SimpleGuiHostedWindow? = nil
        var i = 0
        while i < self.windows.len():
            var win = self.windows[i]
            win.focused = false
            if win.id == window_id:
                selected = win
            else:
                focused.push(win)
            i = i + 1
        if selected != nil:
            selected.focused = true
            focused.push(selected)
        self.windows = focused

    me pointer_move(x: i32, y: i32):
        self.pointer_x = x
        self.pointer_y = y
        if self.dragging:
            var i = 0
            while i < self.windows.len():
                var win = self.windows[i]
                if win.id == self.drag_window_id:
                    win.x = x - self.drag_offset_x
                    win.y = y - self.drag_offset_y
                    self.windows[i] = win
                i = i + 1

    me handle_left_button(down: bool):
        if not down:
            self.dragging = false
            self.drag_window_id = 0
            return
        val hit = self.hit_window(self.pointer_x, self.pointer_y)
        if hit == 0:
            return
        self.focus_window(hit)
        var i = 0
        while i < self.windows.len():
            val win = self.windows[i]
            if win.id == hit:
                val tab_bar_h = if win.tab_group_id > 0: 20 else: 0
                if win.tab_group_id > 0 and self.pointer_y < win.y + 20:
                    self.handle_tab_click(win)
                    return
                if self.pointer_y < win.y + tab_bar_h + 24:
                    if self.pointer_x >= win.x + win.w - 24:
                        self.close_focused()
                        return
                    self.dragging = true
                    self.drag_window_id = hit
                    self.drag_offset_x = self.pointer_x - win.x
                    self.drag_offset_y = self.pointer_y - win.y
                return
            i = i + 1

    me cycle_focus():
        if self.windows.len() == 0:
            return
        var current = -1
        var i = 0
        while i < self.windows.len():
            if self.windows[i].focused:
                current = i
            self.windows[i].focused = false
            i = i + 1
        var next = current + 1
        if next >= self.windows.len():
            next = 0
        self.windows[next].focused = true

    me cycle_tab():
        val fid = self.focused_window_id()
        if fid == 0:
            return
        var gid: i64 = 0
        var i = 0
        while i < self.windows.len():
            if self.windows[i].id == fid:
                gid = self.windows[i].tab_group_id
            i = i + 1
        if gid == 0:
            self.cycle_focus()
            return
        val grp = self.find_tab_group(gid)
        if grp == nil:
            self.cycle_focus()
            return
        var idx = -1
        i = 0
        while i < grp.tab_ids.len():
            if grp.tab_ids[i] == fid:
                idx = i
            i = i + 1
        var next = idx + 1
        if next >= grp.tab_ids.len():
            next = 0
        self.switch_tab(gid, grp.tab_ids[next])

    me cycle_tab_reverse():
        val fid = self.focused_window_id()
        if fid == 0:
            return
        var gid: i64 = 0
        var i = 0
        while i < self.windows.len():
            if self.windows[i].id == fid:
                gid = self.windows[i].tab_group_id
            i = i + 1
        if gid == 0:
            self.cycle_focus()
            return
        val grp = self.find_tab_group(gid)
        if grp == nil:
            self.cycle_focus()
            return
        var idx = -1
        i = 0
        while i < grp.tab_ids.len():
            if grp.tab_ids[i] == fid:
                idx = i
            i = i + 1
        var prev = idx - 1
        if prev < 0:
            prev = grp.tab_ids.len() - 1
        self.switch_tab(gid, grp.tab_ids[prev])

    me close_focused():
        val focused = self.focused_window_id()
        if focused == 0:
            return
        var next_windows: [SimpleGuiHostedWindow] = []
        var i = 0
        while i < self.windows.len():
            if self.windows[i].id != focused:
                next_windows.push(self.windows[i])
            i = i + 1
        self.windows = next_windows
        if self.windows.len() > 0:
            self.windows[self.windows.len() - 1].focused = true

    me minimize_focused():
        val focused = self.focused_window_id()
        var i = 0
        while i < self.windows.len():
            if self.windows[i].id == focused:
                self.windows[i].minimized = true
                self.windows[i].focused = false
            i = i + 1
        if self.windows.len() > 0:
            self.windows[self.windows.len() - 1].focused = true

    me handle_tab_click(win: SimpleGuiHostedWindow):
        val grp = self.find_tab_group(win.tab_group_id)
        if grp == nil:
            return
        val tab_w = win.w / grp.tab_ids.len()
        val rel_x = self.pointer_x - win.x
        var idx = rel_x / tab_w
        if idx >= grp.tab_ids.len():
            idx = grp.tab_ids.len() - 1
        if idx < 0:
            idx = 0
        self.switch_tab(win.tab_group_id, grp.tab_ids[idx])

    me restore_all():
        var i = 0
        while i < self.windows.len():
            self.windows[i].minimized = false
            self.windows[i].focused = i == self.windows.len() - 1
            i = i + 1

    fn find_tab_group(group_id: i64) -> TabGroup?:
        var i = 0
        while i < self.tab_groups.len():
            if self.tab_groups[i].id == group_id:
                return self.tab_groups[i]
            i = i + 1
        nil

    me group_windows(win_a_id: i64, win_b_id: i64):
        var a_idx = -1
        var b_idx = -1
        var i = 0
        while i < self.windows.len():
            if self.windows[i].id == win_a_id:
                a_idx = i
            if self.windows[i].id == win_b_id:
                b_idx = i
            i = i + 1
        if a_idx < 0 or b_idx < 0:
            return
        val existing_group = self.windows[a_idx].tab_group_id
        if existing_group > 0:
            self.windows[b_idx].tab_group_id = existing_group
            i = 0
            while i < self.tab_groups.len():
                if self.tab_groups[i].id == existing_group:
                    self.tab_groups[i].tab_ids.push(win_b_id)
                i = i + 1
            return
        val gid = self.next_tab_group_id
        self.next_tab_group_id = gid + 1
        self.windows[a_idx].tab_group_id = gid
        self.windows[b_idx].tab_group_id = gid
        self.windows[b_idx].x = self.windows[a_idx].x
        self.windows[b_idx].y = self.windows[a_idx].y
        self.windows[b_idx].w = self.windows[a_idx].w
        self.windows[b_idx].h = self.windows[a_idx].h
        self.tab_groups.push(TabGroup(id: gid, active_tab_id: win_a_id, tab_ids: [win_a_id, win_b_id]))

    me switch_tab(group_id: i64, tab_id: i64):
        var i = 0
        while i < self.tab_groups.len():
            if self.tab_groups[i].id == group_id:
                self.tab_groups[i].active_tab_id = tab_id
            i = i + 1
        self.focus_window(tab_id)

    me ungroup_window(win_id: i64):
        var i = 0
        while i < self.windows.len():
            if self.windows[i].id == win_id:
                val gid = self.windows[i].tab_group_id
                self.windows[i].tab_group_id = 0
                self.windows[i].x = self.windows[i].x + 30
                self.windows[i].y = self.windows[i].y + 30
                var g = 0
                while g < self.tab_groups.len():
                    if self.tab_groups[g].id == gid:
                        var new_ids: [i64] = []
                        var t = 0
                        while t < self.tab_groups[g].tab_ids.len():
                            if self.tab_groups[g].tab_ids[t] != win_id:
                                new_ids.push(self.tab_groups[g].tab_ids[t])
                            t = t + 1
                        self.tab_groups[g].tab_ids = new_ids
                        if new_ids.len() <= 1:
                            if new_ids.len() == 1:
                                var j = 0
                                while j < self.windows.len():
                                    if self.windows[j].id == new_ids[0]:
                                        self.windows[j].tab_group_id = 0
                                    j = j + 1
                            var keep: [TabGroup] = []
                            var k = 0
                            while k < self.tab_groups.len():
                                if self.tab_groups[k].id != gid:
                                    keep.push(self.tab_groups[k])
                                k = k + 1
                            self.tab_groups = keep
                        elif self.tab_groups[g].active_tab_id == win_id:
                            self.tab_groups[g].active_tab_id = new_ids[0]
                    g = g + 1
                return
            i = i + 1

    me render_tab_bar(win: SimpleGuiHostedWindow):
        val grp = self.find_tab_group(win.tab_group_id)
        if grp == nil:
            return
        val tab_w = win.w / grp.tab_ids.len()
        var tx = win.x
        var t = 0
        while t < grp.tab_ids.len():
            val tid = grp.tab_ids[t]
            val active = tid == grp.active_tab_id
            val bg = if active: 0xFF1E293Bu32 else: 0xFF0F172Au32
            self.backend.fill_rect(tx, win.y, tab_w, 20, bg)
            var label = ""
            var j = 0
            while j < self.windows.len():
                if self.windows[j].id == tid:
                    label = self.windows[j].title
                j = j + 1
            if label.len() > 12:
                label = label.substring(0, 12)
            self.backend.draw_text(tx + 4, win.y + 2, label, 0xFFE2E8F0u32, bg)
            tx = tx + tab_w
            t = t + 1
