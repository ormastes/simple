# Shared MDI framebuffer scene renderer for hosted/QEMU evidence paths.

use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}
use os.compositor.shared_mdi_setup.{shared_mdi_surfaces}
use common.ui.window_scene.{SharedWmScene, SharedWmWindow, simple_gui_internal_window, simple_gui_internal_window_scene}
use common.ui.wm_chrome_theme.{wm_chrome_theme, WmChromeColors}
use common.ui.glyph_bitmap_5x7.{glyph_index_for_char_code, glyph_row_bits}
use os.compositor.wm_action_applier.{WmLifecycleWindowState, wm_taskbar_dock_width, wm_taskbar_item_width, wm_taskbar_item_x}

class SharedMdiFramebufferScene:
    width: i32
    height: i32
    pixels: [u32]
    surface_count: i32
    web_pixel_count: i64
    backend_kind: text
    fallback_reason: text
    readback_status: text

class SharedMdiRenderWindow:
    id: i64
    title: text
    app_id: text
    content: text
    x: i32
    y: i32
    w: i32
    h: i32
    process_id: i64
    minimized: bool
    focused: bool
    scroll_y: i32

class SharedMdiFramebufferBackend:
    w: i32
    h: i32
    pixels: [u32]
    web_pixel_count: i64

    static fn create(width: i32, height: i32, fill: u32) -> SharedMdiFramebufferBackend:
        val total = if width > 0 and height > 0: width * height else: 0
        var pixels: [u32] = []
        var i = 0
        while i < total:
            pixels.push(fill)
            i = i + 1
        SharedMdiFramebufferBackend(w: width, h: height, pixels: pixels, web_pixel_count: 0)

impl CompositorBackend for SharedMdiFramebufferBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        val total = self.pixels.len()
        var i = 0
        while i < total:
            self.pixels[i] = color
            i = i + 1

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        var x0 = if x < 0: 0 else: x
        var y0 = if y < 0: 0 else: y
        var x1 = x + w
        var y1 = y + h
        if x1 > self.w:
            x1 = self.w
        if y1 > self.h:
            y1 = self.h
        if x1 <= x0 or y1 <= y0:
            return
        var yy = y0
        while yy < y1:
            var idx = yy * self.w + x0
            var xx = x0
            while xx < x1:
                self.pixels[idx] = color
                idx = idx + 1
                xx = xx + 1
            yy = yy + 1

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        var cx = x
        var i = 0
        val n = text_str.len()
        while i < n:
            self.draw_char_8x16(cx, y, text_str.char_at(i).ord().to_u8(), fg, bg)
            cx = cx + 8
            i = i + 1

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        if x >= self.w or y >= self.h or x + 12 <= 0 or y + 16 <= 0:
            return
        self.fill_rect(x, y, 12, 16, bg)
        val gi = glyph_index_for_char_code(ch.to_i32())
        var row: i32 = 0
        while row < 7:
            val bits = glyph_row_bits(gi, row)
            var col: i32 = 0
            while col < 5:
                val mask = 1 << (4 - col)
                if (bits & mask) != 0:
                    self.fill_rect(x + col * 2, y + row * 2 + 1, 2, 2, fg)
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        if x < 0 or y < 0 or x >= self.w or y >= self.h:
            return
        val idx = y * self.w + x
        if idx >= 0 and idx < self.pixels.len():
            self.pixels[idx] = color

    me blit_pixels(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        if w <= 0 or h <= 0:
            return
        self.web_pixel_count = self.web_pixel_count + pixels.len().to_i64()
        val src_len = pixels.len()
        if src_len <= 0:
            return
        var row0 = if y < 0: 0 - y else: 0
        var row1 = h
        if y + row1 > self.h:
            row1 = self.h - y
        val available_rows = src_len / w
        if row1 > available_rows:
            row1 = available_rows
        var col0 = if x < 0: 0 - x else: 0
        var col1 = w
        if x + col1 > self.w:
            col1 = self.w - x
        if row1 <= row0 or col1 <= col0:
            return
        var row = row0
        while row < row1:
            val dy = y + row
            var col = col0
            var src = row * w + col0
            var dst = dy * self.w + x + col0
            while col < col1:
                self.pixels[dst] = pixels[src]
                src = src + 1
                dst = dst + 1
                col = col + 1
            row = row + 1

    me present():
        self.w = self.w

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        self.w = self.w

    fn as_glass_capable() -> CompositorGlassCapable?:
        nil

fn shared_mdi_render_window(id: i64, title: text, app_id: text, content: text, x: i32, y: i32, w: i32, h: i32, process_id: i64, minimized: bool, focused: bool, scroll_y: i32) -> SharedMdiRenderWindow:
    SharedMdiRenderWindow(id: id, title: title, app_id: app_id, content: content, x: x, y: y, w: w, h: h, process_id: process_id, minimized: minimized, focused: focused, scroll_y: scroll_y)

fn _shared_mdi_simple_gui_window_id(id: i64) -> text:
    id.to_text()

fn _shared_mdi_to_simple_gui_window(win: SharedMdiRenderWindow, z_index: i32) -> SharedWmWindow:
    simple_gui_internal_window(
        "mdi-{win.id}",
        _shared_mdi_simple_gui_window_id(win.id),
        win.process_id as u64,
        win.app_id,
        win.title,
        win.x,
        win.y,
        win.w,
        win.h,
        win.content,
        win.minimized,
        win.focused,
        z_index
    )

fn _shared_mdi_from_simple_gui_window(id: i64, win: SharedWmWindow, scroll_y: i32) -> SharedMdiRenderWindow:
    shared_mdi_render_window(
        id,
        win.title,
        win.app_id,
        win.html,
        win.x,
        win.y,
        win.width,
        win.height,
        win.process_id as i64,
        win.minimized,
        win.focused,
        scroll_y
    )

fn _shared_mdi_scene_from_render_windows(width: i32, height: i32, backend_kind: text, windows: [SharedMdiRenderWindow]) -> SharedWmScene:
    var gui_windows: [SharedWmWindow] = []
    var i = 0
    val count = windows.len()
    while i < count:
        gui_windows.push(_shared_mdi_to_simple_gui_window(windows[i], i))
        i = i + 1
    simple_gui_internal_window_scene(width, height, backend_kind, gui_windows)

fn shared_mdi_scene_from_render_windows(width: i32, height: i32, backend_kind: text, windows: [SharedMdiRenderWindow]) -> SharedWmScene:
    _shared_mdi_scene_from_render_windows(width, height, backend_kind, windows)

fn _shared_mdi_render_windows_from_scene(scene: SharedWmScene) -> [SharedMdiRenderWindow]:
    var out: [SharedMdiRenderWindow] = []
    var i = 0
    val count = scene.windows.len()
    while i < count:
        val win = scene.windows[i]
        val parsed_id = win.window_id.to_i64() ?? (i + 1).to_i64()
        out.push(_shared_mdi_from_simple_gui_window(parsed_id, win, 0))
        i = i + 1
    out

fn shared_mdi_render_windows_from_simple_gui_scene(scene: SharedWmScene) -> [SharedMdiRenderWindow]:
    _shared_mdi_render_windows_from_scene(scene)

fn shared_mdi_seed_windows() -> [SharedMdiRenderWindow]:
    val surfaces = shared_mdi_surfaces()
    val count = surfaces.len()
    var windows: [SharedMdiRenderWindow] = []
    var i = 0
    while i < count:
        val surface = surfaces[i]
        val id = (i + 1).to_i64()
        val gui_window = simple_gui_internal_window(
            "mdi-{id}",
            id.to_text(),
            surface.process_id as u64,
            surface.app_id,
            surface.title,
            surface.x,
            surface.y,
            surface.w,
            surface.h,
            surface.content,
            false,
            i == count - 1,
            i
        )
        windows.push(_shared_mdi_from_simple_gui_window(id, gui_window, 0))
        i = i + 1
    windows

fn shared_mdi_lifecycle_seed_windows() -> [WmLifecycleWindowState]:
    val render_windows = shared_mdi_seed_windows()
    var windows: [WmLifecycleWindowState] = []
    var i = 0
    val count = render_windows.len()
    while i < count:
        val win = render_windows[i]
        windows.push(WmLifecycleWindowState(
            id: win.id,
            owner_port: 0,
            title: win.title,
            x: win.x,
            y: win.y,
            w: win.w,
            h: win.h,
            content: win.content,
            process_id: win.process_id,
            app_id: win.app_id,
            minimized: win.minimized,
            focused: win.focused
        ))
        i = i + 1
    windows

fn shared_mdi_render_windows_from_lifecycle(windows: [WmLifecycleWindowState]) -> [SharedMdiRenderWindow]:
    var out: [SharedMdiRenderWindow] = []
    var i = 0
    val count = windows.len()
    while i < count:
        val win = windows[i]
        out.push(shared_mdi_render_window(
            win.id,
            win.title,
            win.app_id,
            win.content,
            win.x,
            win.y,
            win.w,
            win.h,
            win.process_id,
            win.minimized,
            win.focused,
            0
        ))
        i = i + 1
    out

fn _shared_text_fit(content: text, max_chars: i32) -> text:
    if max_chars <= 0:
        return ""
    if content.len().to_i32() > max_chars:
        return content.substring(0, max_chars)
    content

fn _shared_ascii_codes(value: text) -> [i32]:
    if value == "Terminal": return [84, 101, 114, 109, 105, 110, 97, 108]
    if value == "Editor": return [69, 100, 105, 116, 111, 114]
    if value == "Browser": return [66, 114, 111, 119, 115, 101, 114]
    if value == "File Manager": return [70, 105, 108, 101, 32, 77, 97, 110, 97, 103, 101, 114]
    if value == "Calculator": return [67, 97, 108, 99, 117, 108, 97, 116, 111, 114]
    if value == "X": return [88]
    if value == "$ simple$ build check --live": return [36, 32, 115, 105, 109, 112, 108, 101, 36, 32, 98, 117, 105, 108, 100, 32, 99, 104, 101, 99, 107, 32, 45, 45, 108, 105, 118, 101]
    if value == "src/ test/ main.spl": return [115, 114, 99, 47, 32, 116, 101, 115, 116, 47, 32, 109, 97, 105, 110, 46, 115, 112, 108]
    if value == "SimpleOS shell via Simple Web": return [83, 105, 109, 112, 108, 101, 79, 83, 32, 115, 104, 101, 108, 108, 32, 118, 105, 97, 32, 83, 105, 109, 112, 108, 101, 32, 87, 101, 98]
    if value == "main.spl": return [109, 97, 105, 110, 46, 115, 112, 108]
    if value == "fn main():": return [102, 110, 32, 109, 97, 105, 110, 40, 41, 58]
    if value == "    print Hello SimpleOS": return [32, 32, 32, 32, 112, 114, 105, 110, 116, 32, 72, 101, 108, 108, 111, 32, 83, 105, 109, 112, 108, 101, 79, 83]
    if value == "# rendered by Simple Web": return [35, 32, 114, 101, 110, 100, 101, 114, 101, 100, 32, 98, 121, 32, 83, 105, 109, 112, 108, 101, 32, 87, 101, 98]
    if value == "/home/simple": return [47, 104, 111, 109, 101, 47, 115, 105, 109, 112, 108, 101]
    if value == "Desktop": return [68, 101, 115, 107, 116, 111, 112]
    if value == "Documents": return [68, 111, 99, 117, 109, 101, 110, 116, 115]
    if value == "Downloads": return [68, 111, 119, 110, 108, 111, 97, 100, 115]
    if value == "state: home": return [115, 116, 97, 116, 101, 58, 32, 104, 111, 109, 101]
    if value == "0": return [48]
    if value == "7 8 9 /": return [55, 32, 56, 32, 57, 32, 47]
    if value == "4 5 6 *": return [52, 32, 53, 32, 54, 32, 42]
    if value == "1 2 3 -": return [49, 32, 50, 32, 51, 32, 45]
    if value == "about:network": return [97, 98, 111, 117, 116, 58, 110, 101, 116, 119, 111, 114, 107]
    if value == "Simple Web": return [83, 105, 109, 112, 108, 101, 32, 87, 101, 98]
    if value == "GET /status 200": return [71, 69, 84, 32, 47, 115, 116, 97, 116, 117, 115, 32, 50, 48, 48]
    if value == "Simple Web app surface": return [83, 105, 109, 112, 108, 101, 32, 87, 101, 98, 32, 97, 112, 112, 32, 115, 117, 114, 102, 97, 99, 101]
    []

fn _draw_shared_text_fit(backend: CompositorBackend, x: i32, y: i32, text_value: text, fg: u32, bg: u32, max_chars: i32):
    val codes = _shared_ascii_codes(text_value)
    var count = codes.len()
    if max_chars > 0 and count > max_chars:
        count = max_chars
    var i = 0
    var cx = x
    while i < count:
        backend.draw_char_8x16(cx, y, codes[i].to_u8(), fg, bg)
        cx = cx + 12
        i = i + 1

fn _render_shared_mdi_desktop_chrome(backend: CompositorBackend, width: i32, height: i32, theme: WmChromeColors, clear_first: bool):
    if clear_first:
        backend.clear(theme.compositor_bg)
    backend.fill_rect(0, 0, width, 44, theme.command_lane)
    backend.fill_rect(0, 42, width, 2, theme.accent)
    backend.fill_rect(0, height - 56, width, 56, theme.taskbar)
    backend.fill_rect(0, height - 56, width, 2, theme.accent)

fn render_shared_mdi_desktop_chrome(backend: CompositorBackend, width: i32, height: i32, theme: WmChromeColors):
    _render_shared_mdi_desktop_chrome(backend, width, height, theme, true)

fn draw_shared_mdi_window_chrome(backend: CompositorBackend, win: SharedMdiRenderWindow, theme: WmChromeColors):
    if win.minimized:
        return
    val title_color = if win.focused: theme.accent else: theme.title_unfocused
    backend.fill_rect(win.x + 5, win.y + 6, win.w, win.h, theme.window_shadow)
    backend.fill_rect(win.x, win.y, win.w, win.h, theme.host_window_body)
    backend.fill_rect(win.x, win.y, win.w, 28, title_color)
    backend.fill_rect(win.x + 12, win.y + 9, 10, 10, 0xFFE74C3Cu32)
    backend.fill_rect(win.x + 30, win.y + 9, 10, 10, 0xFFF1C40Fu32)
    backend.fill_rect(win.x + 48, win.y + 9, 10, 10, 0xFF27AE60u32)
    _draw_shared_text_fit(backend, win.x + 66, win.y + 6, win.title, theme.text_primary, title_color, if win.w > 92: (win.w - 92) / 12 else: 0)
    backend.fill_rect(win.x + win.w - 24, win.y + 2, 20, 20, theme.close_button)
    _draw_shared_text_fit(backend, win.x + win.w - 18, win.y + 4, "X", theme.text_primary, theme.close_button, 1)

fn draw_shared_mdi_taskbar(backend: CompositorBackend, windows: [SharedMdiRenderWindow], width: i32, height: i32, theme: WmChromeColors):
    val count = windows.len()
    if count <= 0:
        return
    val dock_w = wm_taskbar_dock_width(width, count)
    val dock_x = (width - dock_w) / 2
    val dock_y = height - 62
    val item_w = wm_taskbar_item_width(width, count)
    backend.fill_rect(dock_x, dock_y, dock_w, 44, theme.taskbar)
    var i = 0
    while i < count:
        val win = windows[i]
        val ix = wm_taskbar_item_x(width, count, i)
        var item_color = theme.title_unfocused
        if win.focused and not win.minimized:
            item_color = theme.accent
        elif win.minimized:
            item_color = theme.host_window_body
        backend.fill_rect(ix + 2, dock_y + 4, item_w - 4, 36, item_color)
        _draw_shared_text_fit(backend, ix + 8, dock_y + 14, win.title, theme.text_primary, item_color, if item_w > 16: (item_w - 16) / 12 else: 0)
        i = i + 1

fn _shared_mdi_content_line(backend: CompositorBackend, cx: i32, cy: i32, cw: i32, line_index: i32, text_value: text, fg: u32, bg: u32):
    val y = cy + 34 + line_index * 22
    _draw_shared_text_fit(backend, cx + 10, y, text_value, fg, bg, if cw > 20: (cw - 20) / 12 else: 0)

fn render_shared_mdi_app_content(backend: CompositorBackend, title: text, cx: i32, cy: i32, cw: i32, ch: i32, state_text: text):
    if cw <= 0 or ch <= 0:
        return
    val bg = 0xFF182230u32
    val header = 0xFF2050A0u32
    val text_primary = 0xFFE5E7EBu32
    val accent = 0xFF2563EBu32
    val success = 0xFF22C55Eu32
    val warning = 0xFFF59E0Bu32
    val muted = 0xFF94A3B8u32
    backend.fill_rect(cx, cy, cw, ch, bg)
    backend.fill_rect(cx, cy, cw, 24, header)
    _draw_shared_text_fit(backend, cx + 8, cy + 4, title, text_primary, header, if cw > 16: (cw - 16) / 12 else: 0)
    if title == "Terminal":
        _shared_mdi_content_line(backend, cx, cy, cw, 0, "$ " + state_text, success, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 1, "src/ test/ main.spl", accent, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 2, "SimpleOS shell via Simple Web", success, bg)
        return
    if title == "Editor" or title == "Hello World":
        _shared_mdi_content_line(backend, cx, cy, cw, 0, "main.spl", muted, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 1, "fn main():", warning, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 2, "    print Hello SimpleOS", accent, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 3, "# rendered by Simple Web", success, bg)
        return
    if title == "File Manager" or title == "Finder":
        _shared_mdi_content_line(backend, cx, cy, cw, 0, "/home/simple", accent, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 1, "Desktop", text_primary, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 2, "Documents", text_primary, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 3, "Downloads", text_primary, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 4, "state: " + state_text, muted, bg)
        return
    if title == "Calculator":
        _shared_mdi_content_line(backend, cx, cy, cw, 0, "0", accent, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 1, "7 8 9 /", text_primary, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 2, "4 5 6 *", text_primary, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 3, "1 2 3 -", text_primary, bg)
        return
    if title == "Browser" or title == "Simple Browser":
        _shared_mdi_content_line(backend, cx, cy, cw, 0, "about:network", accent, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 1, "Simple Web", success, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 2, "GET /status 200", text_primary, bg)
        _shared_mdi_content_line(backend, cx, cy, cw, 3, state_text, muted, bg)
        return
    _shared_mdi_content_line(backend, cx, cy, cw, 0, "Simple Web app surface", text_primary, bg)

fn _shared_mdi_content_pixel_count(windows: [SharedMdiRenderWindow]) -> i64:
    var count: i64 = 0
    val window_count = windows.len()
    var i = 0
    while i < window_count:
        val win = windows[i]
        if not win.minimized:
            val cw = win.w - 8
            val ch = win.h - 36
            if cw > 0 and ch > 0:
                count = count + (cw.to_i64() * ch.to_i64())
        i = i + 1
    count

fn _render_shared_mdi_windows_to_backend(backend: CompositorBackend, windows: [SharedMdiRenderWindow], width: i32, height: i32, theme: WmChromeColors, clear_first: bool):
    _render_shared_mdi_desktop_chrome(backend, width, height, theme, clear_first)
    val count = windows.len()
    var i = 0
    while i < count:
        val win = windows[i]
        if not win.minimized:
            draw_shared_mdi_window_chrome(backend, win, theme)
            val cx = win.x + 4
            val cy = win.y + 32
            val cw = win.w - 8
            val ch = win.h - 36
            render_shared_mdi_app_content(backend, win.title, cx, cy, cw, ch, win.content)
        i = i + 1
    draw_shared_mdi_taskbar(backend, windows, width, height, theme)

fn render_shared_mdi_windows_to_backend(backend: CompositorBackend, windows: [SharedMdiRenderWindow], width: i32, height: i32):
    _render_shared_mdi_windows_to_backend(backend, windows, width, height, wm_chrome_theme(), true)

fn render_shared_mdi_framebuffer_scene(width: i32, height: i32, backend_kind: text) -> SharedMdiFramebufferScene:
    render_shared_mdi_framebuffer_scene_limited(width, height, backend_kind, 0, 0)

fn render_shared_mdi_framebuffer_scene_for_windows(width: i32, height: i32, backend_kind: text, windows: [SharedMdiRenderWindow]) -> SharedMdiFramebufferScene:
    render_shared_mdi_framebuffer_scene_for_simple_gui_scene(_shared_mdi_scene_from_render_windows(width, height, backend_kind, windows))

fn render_shared_mdi_framebuffer_scene_for_simple_gui_scene(scene: SharedWmScene) -> SharedMdiFramebufferScene:
    val theme = wm_chrome_theme()
    val backend = SharedMdiFramebufferBackend.create(scene.width, scene.height, theme.compositor_bg)
    val windows = _shared_mdi_render_windows_from_scene(scene)
    _render_shared_mdi_windows_to_backend(backend, windows, scene.width, scene.height, theme, false)
    backend.web_pixel_count = _shared_mdi_content_pixel_count(windows)
    SharedMdiFramebufferScene(
        width: scene.width,
        height: scene.height,
        pixels: backend.pixels,
        surface_count: windows.len(),
        web_pixel_count: backend.web_pixel_count,
        backend_kind: scene.backend,
        fallback_reason: "",
        readback_status: "unavailable:qemu-framebuffer-write-only"
    )

fn render_shared_mdi_framebuffer_scene_for_lifecycle_windows(width: i32, height: i32, backend_kind: text, windows: [WmLifecycleWindowState]) -> SharedMdiFramebufferScene:
    render_shared_mdi_framebuffer_scene_for_windows(width, height, backend_kind, shared_mdi_render_windows_from_lifecycle(windows))

fn render_shared_mdi_framebuffer_scene_limited(width: i32, height: i32, backend_kind: text, max_surface_w: i32, max_surface_h: i32) -> SharedMdiFramebufferScene:
    var windows = shared_mdi_seed_windows()
    val count = windows.len()
    var i = 0
    while i < count:
        var win = windows[i]
        if max_surface_w > 0 and win.w > max_surface_w:
            win.w = max_surface_w
        if max_surface_h > 0 and win.h > max_surface_h:
            win.h = max_surface_h
        windows[i] = win
        i = i + 1
    render_shared_mdi_framebuffer_scene_for_windows(width, height, backend_kind, windows)
