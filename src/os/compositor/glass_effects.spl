#![allow(unnamed_duplicate_typed_args)]
# Glass Effects -- Glassmorphism rendering helpers for compositor
#
# Wraps C glass_render.c helpers for use by compositor and decorations.
# Uses glass_numeric_tokens.spl constants for theme-driven config.

use common.ui.glass_numeric_tokens.{GLASS_DARK_SURFACE, GLASS_DARK_SURFACE_A, GLASS_DARK_BORDER, GLASS_DARK_BORDER_A, GLASS_DARK_SHADOW_A, GLASS_DARK_ACCENT, GLASS_DARK_ACCENT2, GLASS_DARK_BG_TOP, GLASS_DARK_BG_BOT, GLASS_LIGHT_SURFACE, GLASS_LIGHT_SURFACE_A, GLASS_LIGHT_BORDER, GLASS_LIGHT_BORDER_A, GLASS_LIGHT_SHADOW_A, GLASS_LIGHT_ACCENT, GLASS_LIGHT_ACCENT2, GLASS_LIGHT_BG_TOP, GLASS_LIGHT_BG_BOT, GLASS_BLUR_SURFACE, GLASS_SHADOW_OFFSET, GLASS_SHADOW_BLUR, GLASS_OBSIDIAN_SURFACE, GLASS_OBSIDIAN_SURFACE_A, GLASS_OBSIDIAN_BORDER, GLASS_OBSIDIAN_BORDER_A, GLASS_OBSIDIAN_ACCENT, GLASS_OBSIDIAN_ACCENT2, GLASS_OBSIDIAN_SHADOW_A, GLASS_OBSIDIAN_BG_TOP, GLASS_OBSIDIAN_BG_BOT, GLASS_SURFACE_0_A, GLASS_SURFACE_1_A, GLASS_SURFACE_2_A, GLASS_SURFACE_3_A, GLASS_SURFACE_4_A, GLASS_SURFACE_BLUR_0, GLASS_SURFACE_BLUR_1, GLASS_SURFACE_BLUR_2, GLASS_SURFACE_BLUR_3, GLASS_SURFACE_BLUR_4}

extern fn rt_gui_begin_frame(width: u64, height: u64, unused1: u64, unused2: u64)
extern fn rt_gui_present(unused1: u64, unused2: u64, unused3: u64, unused4: u64)
extern fn rt_gui_blend_fill(xy: u64, wh: u64, color: u64, alpha: u64)
extern fn rt_gui_box_blur(xy: u64, wh: u64, radius: u64, unused: u64)
extern fn rt_gui_gradient_v(xy: u64, wh: u64, c1: u64, c2: u64)
extern fn rt_gui_gradient_h(xy: u64, wh: u64, c1: u64, c2: u64)
extern fn rt_gui_shadow(xy: u64, wh: u64, blur_alpha: u64, offset: u64)
extern fn rt_gui_shadow_fill(xy: u64, wh: u64, color: u64, unused: u64)

fn pack(hi: u64, lo: u64) -> u64:
    (hi << 32) | (lo & 0xFFFFFFFF)

struct GlassConfig:
    surface_color: u64
    surface_alpha: u64
    blur_radius: u64
    border_color: u64
    border_alpha: u64
    shadow_offset: u64
    shadow_blur: u64
    shadow_alpha: u64
    accent_color: u64
    accent2_color: u64
    bg_top: u64
    bg_bottom: u64

impl GlassConfig:
    static fn dark() -> GlassConfig:
        GlassConfig(
            surface_color: GLASS_DARK_SURFACE,
            surface_alpha: GLASS_DARK_SURFACE_A,
            blur_radius: GLASS_BLUR_SURFACE,
            border_color: GLASS_DARK_BORDER,
            border_alpha: GLASS_DARK_BORDER_A,
            shadow_offset: GLASS_SHADOW_OFFSET,
            shadow_blur: GLASS_SHADOW_BLUR,
            shadow_alpha: GLASS_DARK_SHADOW_A,
            accent_color: GLASS_DARK_ACCENT,
            accent2_color: GLASS_DARK_ACCENT2,
            bg_top: GLASS_DARK_BG_TOP,
            bg_bottom: GLASS_DARK_BG_BOT
        )

    static fn light() -> GlassConfig:
        GlassConfig(
            surface_color: GLASS_LIGHT_SURFACE,
            surface_alpha: GLASS_LIGHT_SURFACE_A,
            blur_radius: GLASS_BLUR_SURFACE,
            border_color: GLASS_LIGHT_BORDER,
            border_alpha: GLASS_LIGHT_BORDER_A,
            shadow_offset: GLASS_SHADOW_OFFSET,
            shadow_blur: GLASS_SHADOW_BLUR,
            shadow_alpha: GLASS_LIGHT_SHADOW_A,
            accent_color: GLASS_LIGHT_ACCENT,
            accent2_color: GLASS_LIGHT_ACCENT2,
            bg_top: GLASS_LIGHT_BG_TOP,
            bg_bottom: GLASS_LIGHT_BG_BOT
        )

    static fn obsidian_dark() -> GlassConfig:
        GlassConfig(
            surface_color: GLASS_OBSIDIAN_SURFACE,
            surface_alpha: GLASS_OBSIDIAN_SURFACE_A,
            blur_radius: GLASS_BLUR_SURFACE,
            border_color: GLASS_OBSIDIAN_BORDER,
            border_alpha: GLASS_OBSIDIAN_BORDER_A,
            shadow_offset: GLASS_SHADOW_OFFSET,
            shadow_blur: GLASS_SHADOW_BLUR,
            shadow_alpha: GLASS_OBSIDIAN_SHADOW_A,
            accent_color: GLASS_OBSIDIAN_ACCENT,
            accent2_color: GLASS_OBSIDIAN_ACCENT2,
            bg_top: GLASS_OBSIDIAN_BG_TOP,
            bg_bottom: GLASS_OBSIDIAN_BG_BOT
        )

# ============================================================================
# Wrapper Functions
# ============================================================================

fn glass_fill(x: u64, y: u64, w: u64, h: u64, color: u64, alpha: u64):
    """Blend-fill a rectangle with the given color and alpha."""
    val xy = pack(x, y)
    val wh = pack(w, h)
    rt_gui_blend_fill(xy, wh, color, alpha)

fn glass_blur(x: u64, y: u64, w: u64, h: u64, radius: u64):
    """Apply a box blur to the rectangle region."""
    val xy = pack(x, y)
    val wh = pack(w, h)
    rt_gui_box_blur(xy, wh, radius, 0)

fn glass_gradient_v(x: u64, y: u64, w: u64, h: u64, c1: u64, c2: u64):
    """Draw a vertical gradient from c1 (top) to c2 (bottom)."""
    val xy = pack(x, y)
    val wh = pack(w, h)
    rt_gui_gradient_v(xy, wh, c1, c2)

fn glass_shadow(x: u64, y: u64, w: u64, h: u64, config: GlassConfig):
    """Draw a drop shadow below the rectangle using config parameters."""
    val xy = pack(x, y)
    val wh = pack(w, h)
    val blur_alpha = pack(config.shadow_blur, config.shadow_alpha)
    val offset = pack(config.shadow_offset, config.shadow_offset)
    rt_gui_shadow(xy, wh, blur_alpha, offset)

fn glass_solid_fill(x: u64, y: u64, w: u64, h: u64, color: u64):
    """Shadow-buffer-aware solid fill for a rectangle."""
    val xy = pack(x, y)
    val wh = pack(w, h)
    rt_gui_shadow_fill(xy, wh, color, 0)

fn draw_glass_rect(x: u64, y: u64, w: u64, h: u64, config: GlassConfig):
    """Draw a full glass rectangle: shadow + blur + blend + border.

    Renders the complete glassmorphism effect in the correct order:
    1. Drop shadow behind the rect
    2. Box blur of the background content
    3. Semi-transparent surface fill
    4. 1px semi-transparent border
    """
    # 1. Drop shadow
    glass_shadow(x, y, w, h, config)
    # 2. Blur background behind the glass surface
    glass_blur(x, y, w, h, config.blur_radius)
    # 3. Semi-transparent surface fill
    glass_fill(x, y, w, h, config.surface_color, config.surface_alpha)
    # 4. Border
    draw_glass_border(x, y, w, h, config)

fn draw_glass_border(x: u64, y: u64, w: u64, h: u64, config: GlassConfig):
    """Draw a 1px semi-transparent border around the rectangle."""
    val bcolor = config.border_color
    val balpha = config.border_alpha
    # Top edge
    glass_fill(x, y, w, 1, bcolor, balpha)
    # Bottom edge
    if h > 1:
        glass_fill(x, y + h - 1, w, 1, bcolor, balpha)
    # Left edge
    glass_fill(x, y, 1, h, bcolor, balpha)
    # Right edge
    if w > 1:
        glass_fill(x + w - 1, y, 1, h, bcolor, balpha)

fn glass_begin_frame(w: u64, h: u64):
    """Begin a new glass compositing frame."""
    rt_gui_begin_frame(w, h, 0, 0)

fn glass_present():
    """Present the completed glass frame to the display."""
    rt_gui_present(0, 0, 0, 0)

# ============================================================================
# Surface Level Support
# ============================================================================

fn surface_alpha_for_level(level: i32) -> u64:
    """Return the surface alpha (0-255) for a compositor surface level (0-4)."""
    if level == 0:
        return GLASS_SURFACE_0_A
    if level == 1:
        return GLASS_SURFACE_1_A
    if level == 2:
        return GLASS_SURFACE_2_A
    if level == 3:
        return GLASS_SURFACE_3_A
    if level == 4:
        return GLASS_SURFACE_4_A
    return GLASS_SURFACE_0_A

fn surface_blur_for_level(level: i32) -> u64:
    """Return the blur radius for a compositor surface level (0-4)."""
    if level == 0:
        return GLASS_SURFACE_BLUR_0
    if level == 1:
        return GLASS_SURFACE_BLUR_1
    if level == 2:
        return GLASS_SURFACE_BLUR_2
    if level == 3:
        return GLASS_SURFACE_BLUR_3
    if level == 4:
        return GLASS_SURFACE_BLUR_4
    return GLASS_SURFACE_BLUR_0

fn glass_config_for_level(base: GlassConfig, level: i32) -> GlassConfig:
    """Adjust a base GlassConfig for a specific surface level (0-4).

    Level 0 = opaque background, no blur.
    Level 4 = maximum translucency + maximum blur.
    Intermediate levels interpolate between these extremes.
    """
    GlassConfig(
        surface_color: base.surface_color,
        surface_alpha: surface_alpha_for_level(level),
        blur_radius: surface_blur_for_level(level),
        border_color: base.border_color,
        border_alpha: base.border_alpha,
        shadow_offset: base.shadow_offset,
        shadow_blur: base.shadow_blur,
        shadow_alpha: base.shadow_alpha,
        accent_color: base.accent_color,
        accent2_color: base.accent2_color,
        bg_top: base.bg_top,
        bg_bottom: base.bg_bottom
    )
