# Browser Render Backend
#
# Implements the common.ui.backend.RenderBackend trait by routing the
# widget tree through the browser engine rendering pipeline:
#
#   1. Convert UITree -> browser DOM   (widget_to_dom)
#   2. Apply theme as CSS inline styles on the DOM root
#   3. Lay out via CSS box model       (layout_tree)
#   4. Generate paint commands          (generate_paint_list)
#   5. Convert to RenderScene           (paint_commands_to_scene)
#   6. Execute via software rasterizer  (execute_scene_to_buffer)
#
# This unifies the widget system and browser engine through the shared
# render_scene layer, as required by the SimpleOS master plan Phase 8-9.

use common.ui.backend.{RenderBackend}
use common.ui.widget.{UITree, UIState, UIEvent}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.css.{StyleProps, CssValue, BoxEdges,
    BorderProps, default_style}
use std.gc_async_mut.gpu.browser_engine.layout.{BeLayoutBox, layout_tree}
use std.gc_async_mut.gpu.browser_engine.paint.{PaintCommand,
    generate_paint_list, paint_commands_to_scene}
use std.gc_async_mut.gpu.browser_engine.widget_to_dom.{ui_tree_to_dom}
use common.render_scene.scene.{RenderScene}
use common.render_scene.executor.{execute_scene_to_buffer}
use common.render_scene.engine2d_executor.{execute_scene_to_engine2d_pixels}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use os.drivers.framebuffer.fb_driver.{FramebufferDriver}
use os.drivers.virtio.virtio_gpu.{VirtioGpuDriver}
use os.compositor.engine2d_display.{create_fb_engine, create_gpu_engine}

# ============================================================================
# Theme Color Constants (ARGB packed u32)
# ============================================================================

# Dark theme
val DARK_BG: u32 = 0xFF1E1E1E
val DARK_FG: u32 = 0xFFFFFFFF
val DARK_ACCENT: u32 = 0xFF007ACC
val DARK_PANEL: u32 = 0xFF2D2D2D
val DARK_BORDER: u32 = 0xFF3E3E3E
val DARK_BUTTON: u32 = 0xFF3E3E3E
val DARK_BUTTON_HOVER: u32 = 0xFF505050
val DARK_STATUS: u32 = 0xFF007ACC

# Light theme
val LIGHT_BG: u32 = 0xFFFFFFFF
val LIGHT_FG: u32 = 0xFF000000
val LIGHT_ACCENT: u32 = 0xFF0066CC
val LIGHT_PANEL: u32 = 0xFFF0F0F0
val LIGHT_BORDER: u32 = 0xFFCCCCCC
val LIGHT_BUTTON: u32 = 0xFFE0E0E0
val LIGHT_BUTTON_HOVER: u32 = 0xFFD0D0D0
val LIGHT_STATUS: u32 = 0xFF0066CC

# Stitch/Claude Obsidian theme
val OBSIDIAN_BG: u32 = 0xFF12121F
val OBSIDIAN_FG: u32 = 0xFFE3E0F3
val OBSIDIAN_ACCENT: u32 = 0xFFC6C6C8
val OBSIDIAN_PANEL: u32 = 0xFF1E1E2C
val OBSIDIAN_BORDER: u32 = 0xFF958E98
val OBSIDIAN_BUTTON: u32 = 0xFF292937
val OBSIDIAN_BUTTON_HOVER: u32 = 0xFF343342
val OBSIDIAN_STATUS: u32 = 0xFF292937

# ============================================================================
# Theme Helpers
# ============================================================================

fn theme_bg(name: text) -> u32:
    if name == "light": return LIGHT_BG
    if name == "glass_obsidian_dark" or name == "obsidian": return OBSIDIAN_BG
    return DARK_BG

fn theme_fg(name: text) -> u32:
    if name == "light": return LIGHT_FG
    if name == "glass_obsidian_dark" or name == "obsidian": return OBSIDIAN_FG
    return DARK_FG

fn theme_accent(name: text) -> u32:
    if name == "light": return LIGHT_ACCENT
    if name == "glass_obsidian_dark" or name == "obsidian": return OBSIDIAN_ACCENT
    return DARK_ACCENT

fn theme_panel(name: text) -> u32:
    if name == "light": return LIGHT_PANEL
    if name == "glass_obsidian_dark" or name == "obsidian": return OBSIDIAN_PANEL
    return DARK_PANEL

fn theme_border(name: text) -> u32:
    if name == "light": return LIGHT_BORDER
    if name == "glass_obsidian_dark" or name == "obsidian": return OBSIDIAN_BORDER
    return DARK_BORDER

fn theme_button(name: text) -> u32:
    if name == "light": return LIGHT_BUTTON
    if name == "glass_obsidian_dark" or name == "obsidian": return OBSIDIAN_BUTTON
    return DARK_BUTTON

fn theme_status(name: text) -> u32:
    if name == "light": return LIGHT_STATUS
    if name == "glass_obsidian_dark" or name == "obsidian": return OBSIDIAN_STATUS
    return DARK_STATUS

# ============================================================================
# ARGB -> CSS hex helper
# ============================================================================

fn argb_to_css_hex(color: u32) -> text:
    """Convert an ARGB packed u32 to a CSS hex color string '#RRGGBB'."""
    val r = (color >> 16) & 0xFF
    val g = (color >> 8) & 0xFF
    val b = color & 0xFF
    val rh = hex_byte(r)
    val gh = hex_byte(g)
    val bh = hex_byte(b)
    return "#{rh}{gh}{bh}"

fn hex_byte(v: u32) -> text:
    """Convert a byte value (0-255) to a 2-digit hex string."""
    val hi = v / 16
    val lo = v % 16
    val h = hex_digit(hi)
    val l = hex_digit(lo)
    return "{h}{l}"

fn hex_digit(v: u32) -> text:
    if v == 0: return "0"
    if v == 1: return "1"
    if v == 2: return "2"
    if v == 3: return "3"
    if v == 4: return "4"
    if v == 5: return "5"
    if v == 6: return "6"
    if v == 7: return "7"
    if v == 8: return "8"
    if v == 9: return "9"
    if v == 10: return "a"
    if v == 11: return "b"
    if v == 12: return "c"
    if v == 13: return "d"
    if v == 14: return "e"
    if v == 15: return "f"
    return "0"

# ============================================================================
# Apply Theme to DOM
# ============================================================================

fn apply_theme_to_dom(dom: BeDomNode, theme_name: text):
    """Apply theme colors as CSS inline styles on the DOM root.

    Sets background-color, color (foreground), and a border-color
    on the root element so that all descendants inherit the base
    palette. Individual widget converters in widget_to_dom may
    override these on specific nodes.

    Supported themes:
      - "dark":  bg=#1e1e1e, fg=#ffffff, accent=#007acc
      - "light": bg=#ffffff, fg=#000000, accent=#0066cc
    """
    val bg = theme_bg(theme_name)
    val fg = theme_fg(theme_name)
    val accent = theme_accent(theme_name)
    val panel = theme_panel(theme_name)
    val border = theme_border(theme_name)

    # Apply root background and text color
    dom.set_style("background-color", argb_to_css_hex(bg))
    dom.set_style("color", argb_to_css_hex(fg))

    # Apply accent as border-color for focusable children
    # The theme is propagated to child nodes via CSS inheritance
    # so child widgets pick up the base colors automatically.
    var s = dom.style
    s.background_color = bg
    s.color = fg
    dom.style = s

# ============================================================================
# Browser Backend
# ============================================================================

class BrowserBackend:
    """RenderBackend implementation that renders through the browser engine.

    Converts UI widget trees to browser DOM, runs CSS layout, generates
    paint commands, and rasterizes to an ARGB pixel buffer via the
    shared render_scene software executor.

    When an Engine2D is attached (via with_engine/from_fb/from_gpu
    constructors), the render pipeline routes through the Engine2D
    backend for GPU-accelerated or framebuffer-direct rendering.
    """
    width: i32
    height: i32
    pixel_buffer: [u32]
    theme_name: text
    initialized: bool
    engine: Engine2D?

impl BrowserBackend:

    static fn new(width: i32, height: i32, theme_name: text) -> BrowserBackend:
        """Create a browser backend with the given viewport size and theme.
        Uses the software rasterizer (no Engine2D).
        """
        val buf_size = width * height
        var buf: [u32] = []
        var i = 0
        while i < buf_size:
            buf = buf + [0xFF000000]
            i = i + 1
        BrowserBackend(
            width: width,
            height: height,
            pixel_buffer: buf,
            theme_name: theme_name,
            initialized: false,
            engine: nil
        )

    static fn with_engine(width: i32, height: i32, theme_name: text, engine: Engine2D) -> BrowserBackend:
        """Create a browser backend backed by an Engine2D instance.

        When an Engine2D is present, render_tree() routes through the
        Engine2D backend (GPU or optimized software) instead of the
        default software rasterizer.

        Args:
            width: Viewport width in pixels
            height: Viewport height in pixels
            theme_name: Theme name ("dark" or "light")
            engine: Initialized Engine2D instance
        """
        val buf_size = width * height
        var buf: [u32] = []
        var i = 0
        while i < buf_size:
            buf = buf + [0xFF000000]
            i = i + 1
        BrowserBackend(
            width: width,
            height: height,
            pixel_buffer: buf,
            theme_name: theme_name,
            initialized: false,
            engine: engine
        )

    static fn from_fb(width: i32, height: i32, theme_name: text, fb: FramebufferDriver) -> BrowserBackend:
        """Create a browser backend backed by a FramebufferDriver.

        Wraps the framebuffer in an Engine2D via the compositor bridge,
        then uses Engine2D for rendering.

        Args:
            width: Viewport width in pixels
            height: Viewport height in pixels
            theme_name: Theme name ("dark" or "light")
            fb: Initialized FramebufferDriver
        """
        val engine = create_fb_engine(fb)
        BrowserBackend.with_engine(width, height, theme_name, engine)

    static fn from_gpu(width: i32, height: i32, theme_name: text, gpu: VirtioGpuDriver) -> BrowserBackend:
        """Create a browser backend backed by a VirtIO-GPU driver.

        Wraps the GPU driver in an Engine2D via the compositor bridge,
        then uses Engine2D for rendering.

        Args:
            width: Viewport width in pixels
            height: Viewport height in pixels
            theme_name: Theme name ("dark" or "light")
            gpu: Initialized VirtioGpuDriver
        """
        val engine = create_gpu_engine(gpu)
        BrowserBackend.with_engine(width, height, theme_name, engine)

    me render_tree(tree: UITree, state: UIState) -> [u32]:
        """Render a widget tree through the full browser engine pipeline.

        Pipeline:
          UITree -> DOM -> themed DOM -> layout -> paint -> scene -> pixels

        When an Engine2D is attached, step 7 routes through Engine2D
        (execute_scene_to_engine2d_pixels) for GPU or framebuffer
        rendering.  Otherwise falls back to the software rasterizer.

        Returns the ARGB pixel buffer.
        """
        # 1. Convert widget tree to browser DOM
        val dom = ui_tree_to_dom(tree, state)

        # 2. Apply theme styles to the DOM root
        apply_theme_to_dom(dom, self.theme_name)

        # 3. Lay out via browser engine CSS box model
        val layout = layout_tree(dom, self.width, self.height)

        # 4. Generate paint commands from layout tree
        val commands = generate_paint_list(layout)

        # 5. Convert paint commands to RenderScene
        val scene = paint_commands_to_scene(commands, self.width, self.height)

        # 6 + 7. Execute scene — Engine2D path or software rasterizer
        if val Some(e) = self.engine:
            self.pixel_buffer = execute_scene_to_engine2d_pixels(scene, e)
        else:
            # Clear pixel buffer to theme background
            val bg = theme_bg(self.theme_name)
            var i = 0
            while i < self.pixel_buffer.len():
                self.pixel_buffer[i] = bg
                i = i + 1
            # Execute scene into pixel buffer via software rasterizer
            execute_scene_to_buffer(scene, self.pixel_buffer, self.width, self.height)

        return self.pixel_buffer

    me resize(new_w: i32, new_h: i32):
        """Resize the viewport and reallocate the pixel buffer."""
        self.width = new_w
        self.height = new_h
        val buf_size = new_w * new_h
        var buf: [u32] = []
        var i = 0
        while i < buf_size:
            buf = buf + [0xFF000000]
            i = i + 1
        self.pixel_buffer = buf

    fn get_pixels() -> [u32]:
        """Return the current pixel buffer."""
        return self.pixel_buffer

# ============================================================================
# RenderBackend Trait Implementation
# ============================================================================

impl RenderBackend for BrowserBackend:

    fn init() -> Result<bool, text>:
        self.initialized = true
        Ok(true)

    fn shutdown():
        self.initialized = false

    fn render(state: UIState) -> Result<bool, text>:
        """Render the UI state through the browser engine pipeline."""
        val tree = state.tree
        self.render_tree(tree, state)
        Ok(true)

    fn render_html(state: UIState) -> text:
        """HTML rendering is not supported by this pixel-based backend."""
        ""

    fn poll_event(timeout_ms: i32) -> UIEvent?:
        """BrowserBackend does not handle input directly.

        Input events should be provided by a separate input driver
        (e.g., PS/2 keyboard, VirtIO input) and routed through the
        compositor or window manager.
        """
        nil

    fn supports_mouse() -> bool: false
    fn supports_color() -> bool: true
    fn supports_images() -> bool: true
    fn supports_touch() -> bool: false

    fn viewport_width() -> i32: self.width
    fn viewport_height() -> i32: self.height

    fn backend_name() -> text: "browser"
