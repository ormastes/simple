# Browser Compositor Backend — software pixel buffer implementation
#
# Implements CompositorBackend using a Simple-side [u32] pixel buffer.
# All rendering operations are done in pure Simple code — no FFI required.
#
# This backend enables the compositor to render through the browser engine
# pipeline for visual comparison against the native winit backend.
#
# The pixel buffer is directly accessible for screenshot comparison.

use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}
use os.drivers.framebuffer.fb_driver.{get_glyph_8x16}
use std.common.window_protocol.geometry.{Px, Point, Rect, Argb32, Alpha, BlurRadius}

# ============================================================================
# BrowserCompositorBackend
# ============================================================================

class BrowserCompositorBackend:
    """CompositorBackend with in-memory pixel buffer and software rendering.

    All drawing operations write to a Simple [u32] array in ARGB format.
    present() is a no-op by default — the pixel buffer is read directly
    for comparison or can be saved to BMP.
    """
    pixel_buffer: [u32]
    w: i32
    h: i32
    present_count: i32

# ============================================================================
# CompositorBackend Trait Implementation
# ============================================================================

impl CompositorBackend for BrowserCompositorBackend:

    fn width() -> Px:
        Px(value: self.w)

    fn height() -> Px:
        Px(value: self.h)

    me clear(color: Argb32):
        val c = color.to_u32()
        var i = 0
        val total = self.w * self.h
        while i < total:
            self.pixel_buffer[i] = c
            i = i + 1

    me fill_rect(rect: Rect, color: Argb32):
        val x = rect.origin.x.to_i32()
        val y = rect.origin.y.to_i32()
        val w = rect.size.width.to_i32()
        val h = rect.size.height.to_i32()
        val c = color.to_u32()
        var row: i32 = 0
        while row < h:
            val py = y + row
            if py >= 0 and py < self.h:
                var col: i32 = 0
                while col < w:
                    val px = x + col
                    if px >= 0 and px < self.w:
                        self.pixel_buffer[py * self.w + px] = c
                    col = col + 1
            row = row + 1

    me draw_text(origin: Point, text_str: text, fg: Argb32, bg: Argb32):
        var cx = origin.x.to_i32()
        val y = origin.y.to_i32()
        for ch in text_str:
            val ch_byte = ch as u8
            self.draw_char_8x16(Point.xy(cx, y), ch_byte, fg, bg)
            cx = cx + 8

    me draw_char_8x16(origin: Point, ch: u8, fg: Argb32, bg: Argb32):
        val x = origin.x.to_i32()
        val y = origin.y.to_i32()
        val fg_u = fg.to_u32()
        val bg_u = bg.to_u32()
        val glyph = get_glyph_8x16(ch)
        var row: i32 = 0
        while row < 16:
            val bits = glyph[row]
            var col: i32 = 0
            while col < 8:
                val mask = 0x80 >> col
                val color = if (bits & mask) != 0: fg_u else: bg_u
                val px = x + col
                val py = y + row
                if px >= 0 and px < self.w and py >= 0 and py < self.h:
                    self.pixel_buffer[py * self.w + px] = color
                col = col + 1
            row = row + 1

    me put_pixel(p: Point, color: Argb32):
        val x = p.x.to_i32()
        val y = p.y.to_i32()
        if x >= 0 and x < self.w and y >= 0 and y < self.h:
            self.pixel_buffer[y * self.w + x] = color.to_u32()

    me present():
        self.present_count = self.present_count + 1

    me present_rect(rect: Rect):
        self.present_count = self.present_count + 1

    fn as_glass_capable() -> CompositorGlassCapable?:
        # Browser backend opts IN: per-pixel blend/blur on the owned
        # `[u32]` pixel buffer is trivially per-surface correct.
        self

# ============================================================================
# CompositorGlassCapable Trait Implementation (D2 Phase 1 — opt-in)
# ============================================================================

impl CompositorGlassCapable for BrowserCompositorBackend:

    me blend_rect(rect: Rect, color: Argb32, alpha: Alpha):
        val x = rect.origin.x.to_i32()
        val y = rect.origin.y.to_i32()
        val w = rect.size.width.to_i32()
        val h = rect.size.height.to_i32()
        val c = color.to_u32()
        val sa: i32 = alpha.to_u8().to_i32()
        val inv_a: i32 = 255 - sa
        val sr: i32 = ((c >> 16) & 0xFF).to_i32()
        val sg: i32 = ((c >> 8) & 0xFF).to_i32()
        val sb: i32 = (c & 0xFF).to_i32()
        var row: i32 = 0
        while row < h:
            val py = y + row
            if py >= 0 and py < self.h:
                var col: i32 = 0
                while col < w:
                    val px = x + col
                    if px >= 0 and px < self.w:
                        val pixel_idx = py * self.w + px
                        val alpha_u8 = alpha.to_u8()
                        if alpha_u8 == 255u8:
                            # Opaque: write directly
                            self.pixel_buffer[pixel_idx] = c | 0xFF000000
                            col = col + 1
                            continue
                        if alpha_u8 == 0u8:
                            col = col + 1
                            continue
                        val dst = self.pixel_buffer[pixel_idx]
                        val dr: i32 = ((dst >> 16) & 0xFF).to_i32()
                        val dg: i32 = ((dst >> 8) & 0xFF).to_i32()
                        val db: i32 = (dst & 0xFF).to_i32()
                        val r = (sr * sa + dr * inv_a + 128) / 256
                        val g = (sg * sa + dg * inv_a + 128) / 256
                        val b = (sb * sa + db * inv_a + 128) / 256
                        self.pixel_buffer[pixel_idx] = 0xFF000000 | (r.to_u32() << 16) | (g.to_u32() << 8) | b.to_u32()
                    col = col + 1
            row = row + 1

    me blur_region(rect: Rect, radius: BlurRadius):
        """5-pass box blur approximation of Gaussian blur (HVHVH)."""
        val x = rect.origin.x.to_i32()
        val y = rect.origin.y.to_i32()
        val w = rect.size.width.to_i32()
        val h = rect.size.height.to_i32()
        val clamped_radius = if radius.value > 30u32: 30 else: radius.value.to_i32()
        val rad: i32 = clamped_radius
        if rad <= 0: return
        # Clamp region
        val x0 = if x < 0: 0 else: x
        val y0 = if y < 0: 0 else: y
        val x1 = if x + w > self.w: self.w else: x + w
        val y1 = if y + h > self.h: self.h else: y + h
        val rw = x1 - x0
        val rh = y1 - y0
        if rw <= 0 or rh <= 0: return

        # 5-pass HVHVH blur
        var pass_idx: i32 = 0
        while pass_idx < 5:
            if pass_idx % 2 == 0:
                # Horizontal pass
                var row: i32 = 0
                while row < rh:
                    var temp_row: [u32] = []
                    var col: i32 = 0
                    while col < rw:
                        var r_sum: i32 = 0
                        var g_sum: i32 = 0
                        var b_sum: i32 = 0
                        var count: i32 = 0
                        val c_min = if col - rad < 0: 0 else: col - rad
                        val c_max = if col + rad + 1 > rw: rw else: col + rad + 1
                        var kc = c_min
                        while kc < c_max:
                            val px = self.pixel_buffer[(y0 + row) * self.w + (x0 + kc)]
                            r_sum = r_sum + ((px >> 16) & 0xFF).to_i32()
                            g_sum = g_sum + ((px >> 8) & 0xFF).to_i32()
                            b_sum = b_sum + (px & 0xFF).to_i32()
                            count = count + 1
                            kc = kc + 1
                        if count == 0: count = 1
                        val r = (r_sum / count).to_u32()
                        val g = (g_sum / count).to_u32()
                        val b = (b_sum / count).to_u32()
                        temp_row = temp_row + [0xFF000000 | (r << 16) | (g << 8) | b]
                        col = col + 1
                    col = 0
                    while col < rw:
                        self.pixel_buffer[(y0 + row) * self.w + (x0 + col)] = temp_row[col]
                        col = col + 1
                    row = row + 1
            else:
                # Vertical pass
                var col: i32 = 0
                while col < rw:
                    var temp_col: [u32] = []
                    var row: i32 = 0
                    while row < rh:
                        var r_sum: i32 = 0
                        var g_sum: i32 = 0
                        var b_sum: i32 = 0
                        var count: i32 = 0
                        val r_min = if row - rad < 0: 0 else: row - rad
                        val r_max = if row + rad + 1 > rh: rh else: row + rad + 1
                        var kr = r_min
                        while kr < r_max:
                            val px = self.pixel_buffer[(y0 + kr) * self.w + (x0 + col)]
                            r_sum = r_sum + ((px >> 16) & 0xFF).to_i32()
                            g_sum = g_sum + ((px >> 8) & 0xFF).to_i32()
                            b_sum = b_sum + (px & 0xFF).to_i32()
                            count = count + 1
                            kr = kr + 1
                        if count == 0: count = 1
                        val r = (r_sum / count).to_u32()
                        val g = (g_sum / count).to_u32()
                        val b = (b_sum / count).to_u32()
                        temp_col = temp_col + [0xFF000000 | (r << 16) | (g << 8) | b]
                        row = row + 1
                    row = 0
                    while row < rh:
                        self.pixel_buffer[(y0 + row) * self.w + (x0 + col)] = temp_col[row]
                        row = row + 1
                    col = col + 1
            pass_idx = pass_idx + 1

    me gradient_v(rect: Rect, color1: Argb32, color2: Argb32):
        val x = rect.origin.x.to_i32()
        val y = rect.origin.y.to_i32()
        val w = rect.size.width.to_i32()
        val h = rect.size.height.to_i32()
        val c1 = color1.to_u32()
        val c2 = color2.to_u32()
        val r1: i32 = ((c1 >> 16) & 0xFF).to_i32()
        val g1: i32 = ((c1 >> 8) & 0xFF).to_i32()
        val b1: i32 = (c1 & 0xFF).to_i32()
        val r2: i32 = ((c2 >> 16) & 0xFF).to_i32()
        val g2: i32 = ((c2 >> 8) & 0xFF).to_i32()
        val b2: i32 = (c2 & 0xFF).to_i32()
        val denom = if h > 1: h - 1 else: 1
        var row: i32 = 0
        while row < h:
            val py = y + row
            if py >= 0 and py < self.h:
                val r = (r1 + (r2 - r1) * row / denom).to_u32()
                val g = (g1 + (g2 - g1) * row / denom).to_u32()
                val b = (b1 + (b2 - b1) * row / denom).to_u32()
                val color = 0xFF000000 | (r << 16) | (g << 8) | b
                var col: i32 = 0
                while col < w:
                    val px = x + col
                    if px >= 0 and px < self.w:
                        self.pixel_buffer[py * self.w + px] = color
                    col = col + 1
            row = row + 1

    fn read_pixel(p: Point) -> Argb32:
        val x = p.x.to_i32()
        val y = p.y.to_i32()
        if x >= 0 and x < self.w and y >= 0 and y < self.h:
            return Argb32(value: self.pixel_buffer[y * self.w + x])
        return Argb32(value: 0u32)

# ============================================================================
# Constructors and Helpers
# ============================================================================

impl BrowserCompositorBackend:

    static fn new(width: i32, height: i32) -> BrowserCompositorBackend:
        """Create a new browser compositor backend with black pixel buffer."""
        val total = width * height
        var buf: [u32] = []
        var i: i32 = 0
        while i < total:
            buf = buf + [0xFF000000]
            i = i + 1
        BrowserCompositorBackend(
            pixel_buffer: buf,
            w: width,
            h: height,
            present_count: 0
        )

    static fn with_color(width: i32, height: i32, fill_color: u32) -> BrowserCompositorBackend:
        """Create a new browser compositor backend with a specific fill color."""
        val total = width * height
        var buf: [u32] = []
        var i: i32 = 0
        while i < total:
            buf = buf + [fill_color]
            i = i + 1
        BrowserCompositorBackend(
            pixel_buffer: buf,
            w: width,
            h: height,
            present_count: 0
        )

    fn get_pixel_buffer() -> [u32]:
        """Return the pixel buffer for screenshot comparison."""
        self.pixel_buffer

    fn get_present_count() -> i32:
        """Return the number of times present() has been called."""
        self.present_count
