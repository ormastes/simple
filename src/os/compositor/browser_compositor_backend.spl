# Browser Compositor Backend — software pixel buffer implementation
#
# Implements CompositorBackend using a Simple-side [u32] pixel buffer.
# All rendering operations are done in pure Simple code — no FFI required.
#
# This backend enables the compositor to render through the browser engine
# pipeline for visual comparison against the native winit backend.
#
# The pixel buffer is directly accessible for screenshot comparison.

use os.compositor.display_backend.{CompositorBackend}
use os.drivers.framebuffer.fb_driver.{get_glyph_8x16}

# ============================================================================
# BrowserCompositorBackend
# ============================================================================

class BrowserCompositorBackend:
    """CompositorBackend with in-memory pixel buffer and software rendering.

    All drawing operations write to a Simple [u32] array in ARGB format.
    present() is a no-op by default — the pixel buffer is read directly
    for comparison or can be saved to BMP.
    """
    pixel_buffer: [u32]
    w: i32
    h: i32
    present_count: i32

# ============================================================================
# CompositorBackend Trait Implementation
# ============================================================================

impl CompositorBackend for BrowserCompositorBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        var i = 0
        val total = self.w * self.h
        while i < total:
            self.pixel_buffer[i] = color
            i = i + 1

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        var row: i32 = 0
        while row < h:
            val py = y + row
            if py >= 0 and py < self.h:
                var col: i32 = 0
                while col < w:
                    val px = x + col
                    if px >= 0 and px < self.w:
                        self.pixel_buffer[py * self.w + px] = color
                    col = col + 1
            row = row + 1

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        var cx = x
        for ch in text_str:
            val ch_byte = ch.to_u8()
            self.draw_char_8x16(cx, y, ch_byte, fg, bg)
            cx = cx + 8

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        val glyph = get_glyph_8x16(ch)
        var row: i32 = 0
        while row < 16:
            val bits = glyph[row]
            var col: i32 = 0
            while col < 8:
                val mask = 0x80 >> col
                val color = if (bits & mask) != 0: fg else: bg
                val px = x + col
                val py = y + row
                if px >= 0 and px < self.w and py >= 0 and py < self.h:
                    self.pixel_buffer[py * self.w + px] = color
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        if x >= 0 and x < self.w and y >= 0 and y < self.h:
            self.pixel_buffer[y * self.w + x] = color

    me present():
        self.present_count = self.present_count + 1

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        self.present_count = self.present_count + 1

    me blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8):
        val sa: i32 = alpha.to_i32()
        val inv_a: i32 = 255 - sa
        val sr: i32 = ((color >> 16) & 0xFF).to_i32()
        val sg: i32 = ((color >> 8) & 0xFF).to_i32()
        val sb: i32 = (color & 0xFF).to_i32()
        var row: i32 = 0
        while row < h:
            val py = y + row
            if py >= 0 and py < self.h:
                var col: i32 = 0
                while col < w:
                    val px = x + col
                    if px >= 0 and px < self.w:
                        val idx = py * self.w + px
                        val dst = self.pixel_buffer[idx]
                        val dr: i32 = ((dst >> 16) & 0xFF).to_i32()
                        val dg: i32 = ((dst >> 8) & 0xFF).to_i32()
                        val db: i32 = (dst & 0xFF).to_i32()
                        val r = (sr * sa + dr * inv_a) / 255
                        val g = (sg * sa + dg * inv_a) / 255
                        val b = (sb * sa + db * inv_a) / 255
                        self.pixel_buffer[idx] = 0xFF000000 | (r.to_u32() << 16) | (g.to_u32() << 8) | b.to_u32()
                    col = col + 1
            row = row + 1

    me blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32):
        """3-pass box blur approximation of Gaussian blur."""
        val rad: i32 = radius.to_i32()
        if rad <= 0: return
        # Clamp region
        val x0 = if x < 0: 0 else: x
        val y0 = if y < 0: 0 else: y
        val x1 = if x + w > self.w: self.w else: x + w
        val y1 = if y + h > self.h: self.h else: y + h
        val rw = x1 - x0
        val rh = y1 - y0
        if rw <= 0 or rh <= 0: return

        var pass: i32 = 0
        while pass < 3:
            # Horizontal pass — use a temporary row buffer
            var row: i32 = 0
            while row < rh:
                # Build averaged row
                var temp_row: [u32] = []
                var col: i32 = 0
                while col < rw:
                    var r_sum: i32 = 0
                    var g_sum: i32 = 0
                    var b_sum: i32 = 0
                    var count: i32 = 0
                    val c_min = if col - rad < 0: 0 else: col - rad
                    val c_max = if col + rad + 1 > rw: rw else: col + rad + 1
                    var kc = c_min
                    while kc < c_max:
                        val px = self.pixel_buffer[(y0 + row) * self.w + (x0 + kc)]
                        r_sum = r_sum + ((px >> 16) & 0xFF).to_i32()
                        g_sum = g_sum + ((px >> 8) & 0xFF).to_i32()
                        b_sum = b_sum + (px & 0xFF).to_i32()
                        count = count + 1
                        kc = kc + 1
                    if count == 0: count = 1
                    val r = (r_sum / count).to_u32()
                    val g = (g_sum / count).to_u32()
                    val b = (b_sum / count).to_u32()
                    temp_row = temp_row + [0xFF000000 | (r << 16) | (g << 8) | b]
                    col = col + 1
                # Write back
                col = 0
                while col < rw:
                    self.pixel_buffer[(y0 + row) * self.w + (x0 + col)] = temp_row[col]
                    col = col + 1
                row = row + 1

            # Vertical pass — use a temporary column buffer
            col = 0
            while col < rw:
                var temp_col: [u32] = []
                row = 0
                while row < rh:
                    var r_sum: i32 = 0
                    var g_sum: i32 = 0
                    var b_sum: i32 = 0
                    var count: i32 = 0
                    val r_min = if row - rad < 0: 0 else: row - rad
                    val r_max = if row + rad + 1 > rh: rh else: row + rad + 1
                    var kr = r_min
                    while kr < r_max:
                        val px = self.pixel_buffer[(y0 + kr) * self.w + (x0 + col)]
                        r_sum = r_sum + ((px >> 16) & 0xFF).to_i32()
                        g_sum = g_sum + ((px >> 8) & 0xFF).to_i32()
                        b_sum = b_sum + (px & 0xFF).to_i32()
                        count = count + 1
                        kr = kr + 1
                    if count == 0: count = 1
                    val r = (r_sum / count).to_u32()
                    val g = (g_sum / count).to_u32()
                    val b = (b_sum / count).to_u32()
                    temp_col = temp_col + [0xFF000000 | (r << 16) | (g << 8) | b]
                    row = row + 1
                # Write back
                row = 0
                while row < rh:
                    self.pixel_buffer[(y0 + row) * self.w + (x0 + col)] = temp_col[row]
                    row = row + 1
                col = col + 1
            pass = pass + 1

    me gradient_v(x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32):
        val r1: i32 = ((color1 >> 16) & 0xFF).to_i32()
        val g1: i32 = ((color1 >> 8) & 0xFF).to_i32()
        val b1: i32 = (color1 & 0xFF).to_i32()
        val r2: i32 = ((color2 >> 16) & 0xFF).to_i32()
        val g2: i32 = ((color2 >> 8) & 0xFF).to_i32()
        val b2: i32 = (color2 & 0xFF).to_i32()
        val denom = if h > 1: h - 1 else: 1
        var row: i32 = 0
        while row < h:
            val py = y + row
            if py >= 0 and py < self.h:
                val r = (r1 + (r2 - r1) * row / denom).to_u32()
                val g = (g1 + (g2 - g1) * row / denom).to_u32()
                val b = (b1 + (b2 - b1) * row / denom).to_u32()
                val color = 0xFF000000 | (r << 16) | (g << 8) | b
                var col: i32 = 0
                while col < w:
                    val px = x + col
                    if px >= 0 and px < self.w:
                        self.pixel_buffer[py * self.w + px] = color
                    col = col + 1
            row = row + 1

    fn read_pixel(x: i32, y: i32) -> u32:
        if x >= 0 and x < self.w and y >= 0 and y < self.h:
            return self.pixel_buffer[y * self.w + x]
        return 0

# ============================================================================
# Constructors and Helpers
# ============================================================================

impl BrowserCompositorBackend:

    static fn new(width: i32, height: i32) -> BrowserCompositorBackend:
        """Create a new browser compositor backend with black pixel buffer."""
        val total = width * height
        var buf: [u32] = []
        var i: i32 = 0
        while i < total:
            buf = buf + [0xFF000000]
            i = i + 1
        BrowserCompositorBackend(
            pixel_buffer: buf,
            w: width,
            h: height,
            present_count: 0
        )

    static fn with_color(width: i32, height: i32, fill_color: u32) -> BrowserCompositorBackend:
        """Create a new browser compositor backend with a specific fill color."""
        val total = width * height
        var buf: [u32] = []
        var i: i32 = 0
        while i < total:
            buf = buf + [fill_color]
            i = i + 1
        BrowserCompositorBackend(
            pixel_buffer: buf,
            w: width,
            h: height,
            present_count: 0
        )

    fn get_pixel_buffer() -> [u32]:
        """Return the pixel buffer for screenshot comparison."""
        self.pixel_buffer

    fn get_present_count() -> i32:
        """Return the number of times present() has been called."""
        self.present_count
