#![allow(unnamed_duplicate_typed_args)]
# Deterministic software compositor backend used by WM capture tests.

var _browser_compositor_override_enabled: bool = false
var _browser_compositor_next_id: i32 = 1
var _browser_compositor_override_id: i32 = 0
var _browser_compositor_override_width: i32 = 0
var _browser_compositor_override_height: i32 = 0
var _browser_compositor_override_pixels: [u32] = []

class BrowserCompositorBackend:
    id: i32
    width: i32
    height: i32
    pixels: [u32]

    static fn with_color(width: i32, height: i32, color: u32) -> BrowserCompositorBackend:
        val total = if width > 0 and height > 0: width * height else: 0
        val id = _browser_compositor_next_id
        _browser_compositor_next_id = _browser_compositor_next_id + 1
        BrowserCompositorBackend(id: id, width: width, height: height, pixels: [color; total])

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        var row: i32 = 0
        while row < h:
            var col: i32 = 0
            while col < w:
                val px = x + col
                val py = y + row
                if px >= 0 and py >= 0 and px < self.width and py < self.height:
                    self.pixels[py * self.width + px] = color
                col = col + 1
            row = row + 1

    fn get_pixel_buffer() -> [u32]:
        if _browser_compositor_override_enabled and _browser_compositor_override_id == self.id and _browser_compositor_override_width == self.width and _browser_compositor_override_height == self.height:
            _browser_compositor_override_enabled = false
            return _browser_compositor_override_pixels
        self.pixels

    fn set_pixel_buffer_override(pixels: [u32]):
        set_backend_pixel_buffer_override(self, pixels)

fn browser_compositor_backend(width: i32, height: i32) -> BrowserCompositorBackend:
    BrowserCompositorBackend.with_color(width, height, 0xFF1E293Bu32)

fn set_backend_pixel_buffer_override(backend: BrowserCompositorBackend, pixels: [u32]):
    _browser_compositor_override_id = backend.id
    _browser_compositor_override_width = backend.width
    _browser_compositor_override_height = backend.height
    _browser_compositor_override_pixels = pixels
    _browser_compositor_override_enabled = true
