# Deterministic software compositor backend used by WM capture tests.

use os.compositor.display_backend_core.{CompositorBackend, CompositorGlassCapable}
use os.drivers.framebuffer.fb_font.{get_glyph_8x16}

var _browser_compositor_override_enabled: bool = false
var _browser_compositor_next_id: i32 = 1
var _browser_compositor_override_id: i32 = 0
var _browser_compositor_override_width: i32 = 0
var _browser_compositor_override_height: i32 = 0
var _browser_compositor_override_pixels: [u32] = []

class BrowserCompositorBackend:
    id: i32
    width: i32
    height: i32
    pixels: [u32]

    static fn new(width: i32, height: i32) -> BrowserCompositorBackend:
        # Aqua window_body (see common.ui.wm_chrome_theme.wm_chrome_theme_defaults)
        BrowserCompositorBackend.with_color(width, height, 0xfff2f2f2u32)

    static fn with_color(width: i32, height: i32, color: u32) -> BrowserCompositorBackend:
        val total = if width > 0 and height > 0: width * height else: 0
        val id = _browser_compositor_next_id
        _browser_compositor_next_id = _browser_compositor_next_id + 1
        BrowserCompositorBackend(id: id, width: width, height: height, pixels: [color; total])

    fn get_pixel_buffer() -> [u32]:
        if _browser_compositor_override_enabled and _browser_compositor_override_id == self.id and _browser_compositor_override_width == self.width and _browser_compositor_override_height == self.height:
            return _browser_compositor_override_pixels
        self.pixels

    fn set_pixel_buffer_override(pixels: [u32]):
        set_backend_pixel_buffer_override(self, pixels)

fn browser_compositor_backend(width: i32, height: i32) -> BrowserCompositorBackend:
    # Aqua window_body (see common.ui.wm_chrome_theme.wm_chrome_theme_defaults)
    BrowserCompositorBackend.with_color(width, height, 0xfff2f2f2u32)

fn set_backend_pixel_buffer_override(backend: BrowserCompositorBackend, pixels: [u32]):
    _browser_compositor_override_id = backend.id
    _browser_compositor_override_width = backend.width
    _browser_compositor_override_height = backend.height
    _browser_compositor_override_pixels = pixels
    _browser_compositor_override_enabled = true

impl CompositorBackend for BrowserCompositorBackend:

    fn width() -> i32:
        self.width

    fn height() -> i32:
        self.height

    me clear(color: u32):
        var i = 0
        while i < self.pixels.len():
            self.pixels[i] = color
            i = i + 1

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        var row: i32 = 0
        while row < h:
            var col: i32 = 0
            while col < w:
                val px = x + col
                val py = y + row
                if px >= 0 and py >= 0 and px < self.width and py < self.height:
                    self.pixels[py * self.width + px] = color
                col = col + 1
            row = row + 1

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        if text_str.len() > 0:
            var cx = x
            for ch in text_str:
                self.draw_char_8x16(cx, y, ch.char_code_at(0).to_u8(), fg, bg)
                cx = cx + 8

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        val glyph = get_glyph_8x16(ch)
        var row: i32 = 0
        while row < 16:
            val bits = glyph[row]
            var col: i32 = 0
            while col < 8:
                val mask = 0x80 >> col
                val color = if (bits & mask.to_u8()) != 0u8: fg else: bg
                self.put_pixel(x + col, y + row, color)
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        if x >= 0 and y >= 0 and x < self.width and y < self.height:
            self.pixels[y * self.width + x] = color

    me blit_pixels(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        var row: i32 = 0
        while row < h:
            var col: i32 = 0
            while col < w:
                val dst_x = x + col
                val dst_y = y + row
                val src_idx = row * w + col
                if dst_x >= 0 and dst_y >= 0 and dst_x < self.width and dst_y < self.height and src_idx >= 0 and src_idx < pixels.len():
                    self.pixels[dst_y * self.width + dst_x] = pixels[src_idx]
                col = col + 1
            row = row + 1

    me present():
        self.id = self.id

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        self.id = self.id

    fn as_glass_capable() -> CompositorGlassCapable?:
        self

impl CompositorGlassCapable for BrowserCompositorBackend:

    me blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8):
        """Alpha-blend a rectangle using the same per-channel formula as
        the backend parity software blend: `(src*a + dst*(255-a) + 128) >> 8`.  Color is
        packed ARGB8888; alpha is the blend factor (0=transparent,
        255=opaque).  Result pixels have full-opaque alpha."""
        val sr = (color >> 16u32) & 0xFFu32
        val sg = (color >> 8u32) & 0xFFu32
        val sb = color & 0xFFu32
        val inv = 255u32 - alpha.to_u32()
        var row: i32 = 0
        while row < h:
            var col: i32 = 0
            while col < w:
                val px = x + col
                val py = y + row
                if px >= 0 and py >= 0 and px < self.width and py < self.height:
                    val idx = py * self.width + px
                    val dst = self.pixels[idx]
                    val dr = (dst >> 16u32) & 0xFFu32
                    val dg = (dst >> 8u32) & 0xFFu32
                    val db = dst & 0xFFu32
                    val rr = (sr * alpha.to_u32() + dr * inv + 128u32) >> 8u32
                    val rg = (sg * alpha.to_u32() + dg * inv + 128u32) >> 8u32
                    val rb = (sb * alpha.to_u32() + db * inv + 128u32) >> 8u32
                    self.pixels[idx] = 0xFF000000u32 | (rr << 16u32) | (rg << 8u32) | rb
                col = col + 1
            row = row + 1

    me blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32):
        # No-op: blur is not used by any parity scene.
        self.id = self.id

    me gradient_v(x: i32, y: i32, w: i32, h: i32, color_top: u32, color_bottom: u32):
        # No-op: gradient is not used by any parity scene.
        self.id = self.id

    fn read_pixel(x: i32, y: i32) -> u32:
        if x < 0 or y < 0 or x >= self.width or y >= self.height:
            return 0u32
        val idx = y * self.width + x
        self.pixels[idx]
