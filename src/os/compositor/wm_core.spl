use common.window_protocol.geometry.{Rect, Point, Size}

val EDGE_NONE: i32 = 0
val EDGE_LEFT: i32 = 1
val EDGE_RIGHT: i32 = 2
val EDGE_TOP: i32 = 4
val EDGE_BOTTOM: i32 = 8

fn detect_resize_edge(bounds: Rect, pt: Point, threshold) -> i32:
    val x = pt.x.to_i32()
    val y = pt.y.to_i32()
    val left = bounds.origin.x.to_i32()
    val top = bounds.origin.y.to_i32()
    val right = left + bounds.size.width.to_i32()
    val bottom = top + bounds.size.height.to_i32()
    val t = threshold.to_i32()
    if x < left - t or x > right + t or y < top - t or y > bottom + t:
        return EDGE_NONE
    var edge = EDGE_NONE
    if x >= left - t and x <= left + t:
        edge = edge | EDGE_LEFT
    if x >= right - t and x <= right + t:
        edge = edge | EDGE_RIGHT
    if y >= top - t and y <= top + t:
        edge = edge | EDGE_TOP
    if y >= bottom - t and y <= bottom + t:
        edge = edge | EDGE_BOTTOM
    edge

fn raise_to_top(items: [i32], idx: i32) -> [i32]:
    if idx < 0 or idx >= items.len() or idx == items.len() - 1:
        return items
    var out: [i32] = []
    var i = 0
    val chosen = items[idx]
    while i < items.len():
        if i != idx:
            out.push(items[i])
        i = i + 1
    out.push(chosen)
    out

fn _max_i32(a: i32, b: i32) -> i32:
    if a > b: a else: b

fn apply_resize(bounds: Rect, edge: i32, delta: Point, min_size: Size) -> Rect:
    var x = bounds.origin.x.to_i32()
    var y = bounds.origin.y.to_i32()
    var w = bounds.size.width.to_i32()
    var h = bounds.size.height.to_i32()
    val dx = delta.x.to_i32()
    val dy = delta.y.to_i32()
    val min_w = min_size.width.to_i32()
    val min_h = min_size.height.to_i32()

    if (edge & EDGE_RIGHT) != 0:
        w = _max_i32(min_w, w + dx)
    if (edge & EDGE_BOTTOM) != 0:
        h = _max_i32(min_h, h + dy)
    if (edge & EDGE_LEFT) != 0:
        val old_right = x + w
        x = x + dx
        w = old_right - x
        if w < min_w:
            w = min_w
            x = old_right - min_w
    if (edge & EDGE_TOP) != 0:
        val old_bottom = y + h
        h = _max_i32(min_h, h + dy)
        y = old_bottom - h
    Rect.xywh(x, y, w, h)
