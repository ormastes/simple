# WM Core — pure helpers for hit-test, z-order, drag, resize-edge detection.
#
# Lifted out of `compositor.spl` so the host adapter and SimpleOS compositor
# share one implementation, and so each piece can be unit-tested without
# building a full Compositor instance. Every function here is pure — no
# compositor self-reference, no external side effects.

use common.window_protocol.geometry.{Px, Point, Size, Rect}

# ============================================================================
# Resize edge bitmask
# ============================================================================
#
# Bits:
#   0x1  left
#   0x2  right
#   0x4  top
#   0x8  bottom
# Corners are combinations (e.g. top-left = 0x5). Zero = no edge.

val EDGE_NONE: i32 = 0
val EDGE_LEFT: i32 = 1
val EDGE_RIGHT: i32 = 2
val EDGE_TOP: i32 = 4
val EDGE_BOTTOM: i32 = 8

fn detect_resize_edge(surface_bounds: Rect, point: Point, edge_width: Px) -> i32:
    """Return an EDGE_* bitmask describing which edge(s) of `surface_bounds`
    the `point` is near, with tolerance `edge_width`. Returns EDGE_NONE if
    the point is outside the surface or inside the interior."""
    val px = point.x.value
    val py = point.y.value
    val left = surface_bounds.origin.x.value
    val top = surface_bounds.origin.y.value
    val right = left + surface_bounds.size.width.value
    val bottom = top + surface_bounds.size.height.value
    val ew = edge_width.value

    if (px < left - ew) or (px > right + ew) or (py < top - ew) or (py > bottom + ew):
        return EDGE_NONE

    var mask: i32 = 0
    if px >= left - ew and px <= left + ew:
        mask = mask | EDGE_LEFT
    if px >= right - ew and px <= right + ew:
        mask = mask | EDGE_RIGHT
    if py >= top - ew and py <= top + ew:
        mask = mask | EDGE_TOP
    if py >= bottom - ew and py <= bottom + ew:
        mask = mask | EDGE_BOTTOM
    mask

# ============================================================================
# Hit-test
# ============================================================================

fn hit_test(windows: [Rect], point: Point) -> i32:
    """Return the index of the topmost window containing `point`, or -1.
    `windows` is in z-order with the last entry on top."""
    var i: i32 = (windows.len() - 1).to_i32()
    while i >= 0:
        val w = windows[i.to_i64()]
        if w.contains(point):
            return i
        i = i - 1
    -1

# ============================================================================
# Z-order raise
# ============================================================================

fn raise_to_top<T>(list: [T], idx: i32) -> [T]:
    """Return a new list with the element at `idx` moved to the end (top).
    Out-of-range `idx` returns the list unchanged."""
    val n = list.len().to_i32()
    if idx < 0 or idx >= n:
        return list
    var out: [T] = []
    var i: i32 = 0
    while i < n:
        if i != idx:
            out = out.push(list[i.to_i64()])
        i = i + 1
    out = out.push(list[idx.to_i64()])
    out

# ============================================================================
# Drag
# ============================================================================

fn apply_drag(bounds: Rect, delta: Point) -> Rect:
    """Translate `bounds` by `delta`; size unchanged."""
    Rect.xywh(
        bounds.origin.x.value + delta.x.value,
        bounds.origin.y.value + delta.y.value,
        bounds.size.width.value,
        bounds.size.height.value
    )

# ============================================================================
# Resize from edge
# ============================================================================

fn apply_resize(bounds: Rect, edge: i32, delta: Point, min_size: Size) -> Rect:
    """Resize `bounds` by `delta` in the direction implied by the EDGE_* `edge`
    bitmask. Enforces `min_size`: width/height will never drop below it, and
    the origin is clamped to preserve the opposite edge."""
    var x = bounds.origin.x.value
    var y = bounds.origin.y.value
    var w = bounds.size.width.value
    var h = bounds.size.height.value
    val dx = delta.x.value
    val dy = delta.y.value
    val min_w = min_size.width.value
    val min_h = min_size.height.value

    if (edge & EDGE_LEFT) != 0:
        val new_w = w - dx
        if new_w >= min_w:
            x = x + dx
            w = new_w
        else:
            x = x + (w - min_w)
            w = min_w
    if (edge & EDGE_RIGHT) != 0:
        val new_w = w + dx
        if new_w >= min_w:
            w = new_w
        else:
            w = min_w
    if (edge & EDGE_TOP) != 0:
        val new_h = h - dy
        if new_h >= min_h:
            y = y + dy
            h = new_h
        else:
            y = y + (h - min_h)
            h = min_h
    if (edge & EDGE_BOTTOM) != 0:
        val new_h = h + dy
        if new_h >= min_h:
            h = new_h
        else:
            h = min_h

    Rect.xywh(x, y, w, h)
