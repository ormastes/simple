# Hosted Compositor Backend — Win32 / Windows surface shim
#
# Routes through the cross-platform winit pixel-buffer backend
# (`rt_winit_buffer_*`) instead of native HWND / DIB-section symbols.
# The window is owned by the caller (created via `rt_winit_window_new`);
# this backend only manages the pixel buffer and drawing operations.
#
# Selection: routed by `hosted_backend.spl::select_hosted_backend()`
# at construct time based on `rt_hosted_select_surface()` returning 2
# (Windows). See that file for the dispatch site.

use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}
use os.drivers.framebuffer.fb_driver.{get_glyph_8x16}

# ============================================================================
# Winit Buffer FFI Declarations (shared symbols with hosted_backend.spl)
# ============================================================================

extern fn rt_winit_buffer_create(w: i64, h: i64, fill_color: i64) -> i64
extern fn rt_winit_buffer_fill_rect(buf: i64, x: i64, y: i64, w: i64, h: i64, color: i64) -> bool
extern fn rt_winit_buffer_present(win: i64, buf: i64) -> bool
extern fn rt_winit_buffer_free(buf: i64) -> bool
extern fn rt_winit_buffer_read_pixel(buf: i64, x: i64, y: i64) -> i64
extern fn rt_winit_buffer_blend_rect(buf: i64, x: i64, y: i64, w: i64, h: i64, color: i64, alpha: i64) -> bool
extern fn rt_winit_buffer_blur(buf: i64, x: i64, y: i64, w: i64, h: i64, radius: i64) -> bool
extern fn rt_winit_buffer_gradient_v(buf: i64, x: i64, y: i64, w: i64, h: i64, c1: i64, c2: i64) -> bool

# Module-level state (interpreter-safe — same pattern as `hosted_backend.spl`).
var _win32_window_id: i64 = 0
var _win32_buffer_id: i64 = 0
var _win32_w: i32 = 0
var _win32_h: i32 = 0

# ============================================================================
# HostedWin32Backend
# ============================================================================

class HostedWin32Backend:
    """CompositorBackend for Windows that renders through the winit pixel buffer.

    Drawing is delegated to `rt_winit_buffer_*` SFFI symbols. The window
    is owned by the caller; this backend manages the pixel buffer only.

    Colors are Argb32 (0xAARRGGBB), matching the CompositorBackend contract.
    """
    window_id: i64
    buffer_id: i64
    w: i32
    h: i32

# ============================================================================
# CompositorBackend Trait Implementation
# ============================================================================

impl CompositorBackend for HostedWin32Backend:

    fn width() -> i32:
        _win32_w

    fn height() -> i32:
        _win32_h

    me clear(color: u32):
        val w_i: i64 = _win32_w
        val h_i: i64 = _win32_h
        val c: i64 = color
        rt_winit_buffer_fill_rect(_win32_buffer_id, 0, 0, w_i, h_i, c)

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        val xi: i64 = x
        val yi: i64 = y
        val wi: i64 = w
        val hi: i64 = h
        val c: i64 = color
        rt_winit_buffer_fill_rect(_win32_buffer_id, xi, yi, wi, hi, c)

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        var cx = x
        for ch in text_str:
            val code = ch.ord()
            val ch_byte: u8 = code
            self.draw_char_8x16(cx, y, ch_byte, fg, bg)
            cx = cx + 8

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        val glyph = get_glyph_8x16(ch)
        val fg_i: i64 = fg
        val bg_i: i64 = bg
        var row: i64 = 0
        while row < 16:
            val bits: i64 = glyph[row]
            var col: i64 = 0
            while col < 8:
                val mask: i64 = 0x80 >> col
                val color = if (bits & mask) != 0: fg_i else: bg_i
                val px: i64 = x + col
                val py: i64 = y + row
                rt_winit_buffer_fill_rect(_win32_buffer_id, px, py, 1, 1, color)
                col = col + 1
            row = row + 1

    me put_pixel(x: i32, y: i32, color: u32):
        val xi: i64 = x
        val yi: i64 = y
        val c: i64 = color
        rt_winit_buffer_fill_rect(_win32_buffer_id, xi, yi, 1, 1, c)

    me present():
        rt_winit_buffer_present(_win32_window_id, _win32_buffer_id)

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        # winit presents the full buffer; degrade to full present.
        rt_winit_buffer_present(_win32_window_id, _win32_buffer_id)

    fn as_glass_capable() -> CompositorGlassCapable?:
        # The winit buffer is our own pixel buffer, safe for blend/blur/gradient.
        self

# ============================================================================
# CompositorGlassCapable Trait Implementation
# ============================================================================

impl CompositorGlassCapable for HostedWin32Backend:

    me blend_rect(x: i32, y: i32, w: i32, h: i32, color: u32, alpha: u8):
        val xi: i64 = x
        val yi: i64 = y
        val wi: i64 = w
        val hi: i64 = h
        val c: i64 = color
        val a: i64 = alpha
        rt_winit_buffer_blend_rect(_win32_buffer_id, xi, yi, wi, hi, c, a)

    me blur_region(x: i32, y: i32, w: i32, h: i32, radius: u32):
        val xi: i64 = x
        val yi: i64 = y
        val wi: i64 = w
        val hi: i64 = h
        val ri: i64 = radius
        rt_winit_buffer_blur(_win32_buffer_id, xi, yi, wi, hi, ri)

    me gradient_v(x: i32, y: i32, w: i32, h: i32, color1: u32, color2: u32):
        val xi: i64 = x
        val yi: i64 = y
        val wi: i64 = w
        val hi: i64 = h
        val c1: i64 = color1
        val c2: i64 = color2
        rt_winit_buffer_gradient_v(_win32_buffer_id, xi, yi, wi, hi, c1, c2)

    fn read_pixel(x: i32, y: i32) -> u32:
        val xi: i64 = x
        val yi: i64 = y
        val result = rt_winit_buffer_read_pixel(_win32_buffer_id, xi, yi)
        result.to_u32()

# ============================================================================
# Lifecycle — create / resize / free
# ============================================================================

impl HostedWin32Backend:

    static fn new(window_id: i64, buffer_id: i64, w: i32, h: i32) -> HostedWin32Backend:
        """Wrap pre-existing winit handles (test seam)."""
        HostedWin32Backend(window_id: window_id, buffer_id: buffer_id, w: w, h: h)

    static fn create(window_id: i64, w: i32, h: i32, fill_color: u32) -> HostedWin32Backend:
        """Allocate a winit pixel buffer sized w×h for the given window."""
        val w64: i64 = w
        val h64: i64 = h
        val fc64: i64 = fill_color
        val buf = rt_winit_buffer_create(w64, h64, fc64)
        _win32_window_id = window_id
        _win32_buffer_id = buf
        _win32_w = w
        _win32_h = h
        HostedWin32Backend(window_id: window_id, buffer_id: buf, w: w, h: h)

    me resize(new_w: i32, new_h: i32) -> bool:
        """React to a WM_SIZE event. Frees the old buffer and allocates a new one."""
        val w64: i64 = new_w
        val h64: i64 = new_h
        rt_winit_buffer_free(_win32_buffer_id)
        val buf = rt_winit_buffer_create(w64, h64, 0)
        _win32_buffer_id = buf
        _win32_w = new_w
        _win32_h = new_h
        true

    me free():
        """Release the winit pixel buffer. Idempotent."""
        rt_winit_buffer_free(self.buffer_id)
