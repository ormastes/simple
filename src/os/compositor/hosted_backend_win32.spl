# Hosted Compositor Backend — Win32 / Windows surface shim
#
# Row 3 of the GUI drawing-layer work matrix (2026-04-14).
# Phase C of `doc/03_plan/v2_hosted_engine2d_rewiring.md`.
#
# Plumbs `CompositorBackend` through to a Win32 HWND + DIB-section
# (BitBlt) backbuffer. Direct2D / D3D11 are an optional future swap
# behind the same trait — see TODO at the bottom. The SFFI bodies are
# placeholder declarations against `rt_win32_*` runtime symbols that the
# next agent will fill in.
#
# TODO(next-agent): implement these in `src/runtime/hosted/win32.rs`
# (windows-rs crate). Until then the externs link to runtime stubs that
# return -1 / false.

use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}
use os.drivers.framebuffer.fb_driver.{get_glyph_8x16}
use std.common.window_protocol.geometry.{Px, Point, Rect, Argb32, Alpha, BlurRadius}

# ============================================================================
# Win32 Surface SFFI Declarations (placeholders — see TODO above)
# ============================================================================

extern fn rt_win32_window_new(w: i64, h: i64, title: text) -> i64
extern fn rt_win32_window_resize(hwnd: i64, w: i64, h: i64) -> bool
extern fn rt_win32_window_close(hwnd: i64) -> bool
extern fn rt_win32_dib_create(hwnd: i64, w: i64, h: i64, fill_color: i64) -> i64
extern fn rt_win32_dib_fill_rect(dib: i64, x: i64, y: i64, w: i64, h: i64, color: i64) -> bool
extern fn rt_win32_dib_present(hwnd: i64, dib: i64) -> bool
extern fn rt_win32_dib_present_rect(hwnd: i64, dib: i64, x: i64, y: i64, w: i64, h: i64) -> bool
extern fn rt_win32_dib_free(dib: i64) -> bool
extern fn rt_win32_dib_resize(dib: i64, w: i64, h: i64) -> bool
extern fn rt_win32_dib_read_pixel(dib: i64, x: i64, y: i64) -> i64
extern fn rt_win32_dib_blend_rect(dib: i64, x: i64, y: i64, w: i64, h: i64, color: i64, alpha: i64) -> bool
extern fn rt_win32_dib_blur(dib: i64, x: i64, y: i64, w: i64, h: i64, radius: i64) -> bool
extern fn rt_win32_dib_gradient_v(dib: i64, x: i64, y: i64, w: i64, h: i64, c1: i64, c2: i64) -> bool
extern fn rt_win32_message_pump(hwnd: i64) -> i64

# Module-level state (interpreter-safe — same pattern as `hosted_backend.spl`).
var _win32_hwnd: i64 = 0
var _win32_dib_id: i64 = 0
var _win32_w: i32 = 0
var _win32_h: i32 = 0

# ============================================================================
# HostedWin32Backend
# ============================================================================

class HostedWin32Backend:
    """CompositorBackend that targets a Win32 HWND with a DIB-section backbuffer.

    The DIB section is a top-down BGRA8 bitmap (negative biHeight) so
    the runtime can blit it straight to the window DC with `StretchDIBits`.
    `present()` is a single BitBlt; `present_rect()` blits a sub-region.

    Colors are Argb32 (0xAARRGGBB); the runtime swizzles to BGRA on
    write so callers don't have to think about it.
    """
    hwnd: i64
    dib_id: i64
    w: i32
    h: i32

# ============================================================================
# CompositorBackend Trait Implementation
# ============================================================================

impl CompositorBackend for HostedWin32Backend:

    fn width() -> Px:
        Px(value: _win32_w)

    fn height() -> Px:
        Px(value: _win32_h)

    me clear(color: Argb32):
        val w_i: i64 = _win32_w
        val h_i: i64 = _win32_h
        val c: i64 = color.to_u32()
        rt_win32_dib_fill_rect(_win32_dib_id, 0, 0, w_i, h_i, c)

    me fill_rect(rect: Rect, color: Argb32):
        val xi: i64 = rect.origin.x.to_i32()
        val yi: i64 = rect.origin.y.to_i32()
        val wi: i64 = rect.size.width.to_i32()
        val hi: i64 = rect.size.height.to_i32()
        val c: i64 = color.to_u32()
        rt_win32_dib_fill_rect(_win32_dib_id, xi, yi, wi, hi, c)

    me draw_text(origin: Point, text_str: text, fg: Argb32, bg: Argb32):
        var cx = origin.x.to_i32()
        val y = origin.y.to_i32()
        for ch in text_str:
            val code = ch.ord()
            val ch_byte: u8 = code
            self.draw_char_8x16(Point.xy(cx, y), ch_byte, fg, bg)
            cx = cx + 8

    me draw_char_8x16(origin: Point, ch: u8, fg: Argb32, bg: Argb32):
        val x = origin.x.to_i32()
        val y = origin.y.to_i32()
        val glyph = get_glyph_8x16(ch)
        val fg_i: i64 = fg.to_u32()
        val bg_i: i64 = bg.to_u32()
        var row: i64 = 0
        while row < 16:
            val bits: i64 = glyph[row]
            var col: i64 = 0
            while col < 8:
                val mask: i64 = 0x80 >> col
                val color = if (bits & mask) != 0: fg_i else: bg_i
                val px: i64 = x + col
                val py: i64 = y + row
                rt_win32_dib_fill_rect(_win32_dib_id, px, py, 1, 1, color)
                col = col + 1
            row = row + 1

    me put_pixel(p: Point, color: Argb32):
        val xi: i64 = p.x.to_i32()
        val yi: i64 = p.y.to_i32()
        val c: i64 = color.to_u32()
        rt_win32_dib_fill_rect(_win32_dib_id, xi, yi, 1, 1, c)

    me present():
        rt_win32_dib_present(_win32_hwnd, _win32_dib_id)

    me present_rect(rect: Rect):
        val xi: i64 = rect.origin.x.to_i32()
        val yi: i64 = rect.origin.y.to_i32()
        val wi: i64 = rect.size.width.to_i32()
        val hi: i64 = rect.size.height.to_i32()
        rt_win32_dib_present_rect(_win32_hwnd, _win32_dib_id, xi, yi, wi, hi)

    fn as_glass_capable() -> CompositorGlassCapable?:
        # The DIB section is our own pixel buffer, safe for blend/blur/gradient.
        self

# ============================================================================
# CompositorGlassCapable Trait Implementation
# ============================================================================

impl CompositorGlassCapable for HostedWin32Backend:

    me blend_rect(rect: Rect, color: Argb32, alpha: Alpha):
        val xi: i64 = rect.origin.x.to_i32()
        val yi: i64 = rect.origin.y.to_i32()
        val wi: i64 = rect.size.width.to_i32()
        val hi: i64 = rect.size.height.to_i32()
        val c: i64 = color.to_u32()
        val a: i64 = alpha.to_u8()
        rt_win32_dib_blend_rect(_win32_dib_id, xi, yi, wi, hi, c, a)

    me blur_region(rect: Rect, radius: BlurRadius):
        val xi: i64 = rect.origin.x.to_i32()
        val yi: i64 = rect.origin.y.to_i32()
        val wi: i64 = rect.size.width.to_i32()
        val hi: i64 = rect.size.height.to_i32()
        val ri: i64 = radius.value
        rt_win32_dib_blur(_win32_dib_id, xi, yi, wi, hi, ri)

    me gradient_v(rect: Rect, color1: Argb32, color2: Argb32):
        val xi: i64 = rect.origin.x.to_i32()
        val yi: i64 = rect.origin.y.to_i32()
        val wi: i64 = rect.size.width.to_i32()
        val hi: i64 = rect.size.height.to_i32()
        val c1: i64 = color1.to_u32()
        val c2: i64 = color2.to_u32()
        rt_win32_dib_gradient_v(_win32_dib_id, xi, yi, wi, hi, c1, c2)

    fn read_pixel(p: Point) -> Argb32:
        val xi: i64 = p.x.to_i32()
        val yi: i64 = p.y.to_i32()
        val result = rt_win32_dib_read_pixel(_win32_dib_id, xi, yi)
        Argb32(value: result.to_u32())

# ============================================================================
# Lifecycle — create / resize / pump / free
# ============================================================================

impl HostedWin32Backend:

    static fn new(hwnd: i64, dib_id: i64, w: i32, h: i32) -> HostedWin32Backend:
        """Wrap pre-existing Win32 handles (test seam)."""
        HostedWin32Backend(hwnd: hwnd, dib_id: dib_id, w: w, h: h)

    static fn create(w: i32, h: i32, title: text, fill_color: u32) -> HostedWin32Backend:
        """Allocate an HWND + DIB-section pair sized w×h."""
        val w64: i64 = w
        val h64: i64 = h
        val fc64: i64 = fill_color
        val hwnd = rt_win32_window_new(w64, h64, title)
        val dib = rt_win32_dib_create(hwnd, w64, h64, fc64)
        _win32_hwnd = hwnd
        _win32_dib_id = dib
        _win32_w = w
        _win32_h = h
        HostedWin32Backend(hwnd: hwnd, dib_id: dib, w: w, h: h)

    me resize(new_w: i32, new_h: i32) -> bool:
        """React to a WM_SIZE event."""
        val w64: i64 = new_w
        val h64: i64 = new_h
        val ok_win = rt_win32_window_resize(_win32_hwnd, w64, h64)
        val ok_dib = rt_win32_dib_resize(_win32_dib_id, w64, h64)
        if ok_win and ok_dib:
            _win32_w = new_w
            _win32_h = new_h
        ok_win and ok_dib

    me pump() -> i64:
        """Drain queued window messages. Non-blocking."""
        rt_win32_message_pump(_win32_hwnd)

    me free():
        """Release the DIB section and destroy the window. Idempotent."""
        rt_win32_dib_free(self.dib_id)
        rt_win32_window_close(self.hwnd)
