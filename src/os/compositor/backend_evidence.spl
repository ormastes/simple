# Backend evidence contract for GUI capture and renderer reports.

class GuiBackendEvidence:
    requested_backend: text
    selected_backend: text
    fallback_reason: text
    frame_time_us: i64
    readback_status: text
    ok: bool
    error: text

    fn diagnostic_text(self) -> text:
        "requested={self.requested_backend};selected={self.selected_backend};fallback={self.fallback_reason};frame_time_us={self.frame_time_us};readback={self.readback_status};ok={self.ok};error={self.error}"

fn backend_readback_verified(readback_status: text) -> bool:
    readback_status == "verified" or readback_status.starts_with("verified:")

fn backend_claim_requires_verified_readback(selected_backend: text) -> bool:
    if selected_backend == "metal" or selected_backend == "gpu":
        return true
    if selected_backend.contains("metal") or selected_backend.contains("gpu"):
        return true
    selected_backend.contains("qemu") and selected_backend.contains("simd")

fn _backend_evidence_error(requested_backend: text, selected_backend: text, fallback_reason: text, frame_time_us: i64, readback_status: text) -> text:
    if selected_backend == "":
        return "missing-selected-backend"
    if frame_time_us < 0:
        return "negative-frame-time"
    if readback_status == "":
        return "missing-readback-status"
    if requested_backend != "" and requested_backend != selected_backend and fallback_reason == "":
        return "fallback-without-reason"
    if backend_claim_requires_verified_readback(selected_backend) and not backend_readback_verified(readback_status):
        return "verified-readback-required-for-" + selected_backend
    ""

fn make_gui_backend_evidence(requested_backend: text, selected_backend: text, fallback_reason: text, frame_time_us: i64, readback_status: text) -> GuiBackendEvidence:
    val err = _backend_evidence_error(requested_backend, selected_backend, fallback_reason, frame_time_us, readback_status)
    GuiBackendEvidence(
        requested_backend: requested_backend,
        selected_backend: selected_backend,
        fallback_reason: fallback_reason,
        frame_time_us: frame_time_us,
        readback_status: readback_status,
        ok: err == "",
        error: err
    )

fn make_verified_gui_backend_evidence(requested_backend: text, selected_backend: text, frame_time_us: i64) -> GuiBackendEvidence:
    make_gui_backend_evidence(requested_backend, selected_backend, "", frame_time_us, "verified")
