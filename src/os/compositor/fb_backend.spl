#![allow(unnamed_duplicate_typed_args)]
# Framebuffer Render Backend
#
# Implements RenderBackend trait targeting the framebuffer driver.
# Walks the widget tree, computes layout via the standard layout engine,
# and renders each widget type to pixels using FramebufferDriver methods.
#
# Usage:
#   val fb = FramebufferDriver.from_boot_info(info)
#   val kb = Ps2Keyboard.new()
#   val backend = FramebufferBackend(fb: fb, keyboard: kb,
#       width: fb.width.to_i32(), height: fb.height.to_i32())
#   impl backend as RenderBackend

use common.ui.backend.{RenderBackend}
use common.ui.widget.{UIState, UIEvent, UITree, WidgetNode, WidgetRect}
use common.ui.layout.{compute_layout, find_rect}
use os.drivers.framebuffer.fb_driver.{FramebufferDriver, Color}
use os.drivers.input.ps2_keyboard.{Ps2Keyboard, KeyEvent, Key}
use os.compositor.display_backend.{CompositorBackend, FbCompositorBackend}
use os.compositor.rendering_primitives.{draw_icon_rle}
use common.ui.icon_registry.{get_icon_definition}

# ============================================================================
# Theme Colors
# ============================================================================

struct ThemeColors:
    """Theme colors as packed u32 ARGB (0xFFRRGGBB)."""
    bg: u32
    fg: u32
    panel_bg: u32
    panel_border: u32
    focused_border: u32
    button_bg: u32
    button_fg: u32
    button_focused_bg: u32
    input_bg: u32
    input_fg: u32
    input_border: u32
    menubar_bg: u32
    menubar_fg: u32
    statusbar_bg: u32
    statusbar_fg: u32
    progress_bg: u32
    progress_fill: u32
    divider_color: u32
    selection_bg: u32

fn _argb(r: u32, g: u32, b: u32) -> u32:
    0xFF000000 | (r << 16) | (g << 8) | b

fn dark_theme() -> ThemeColors:
    """Standard dark theme colors."""
    ThemeColors(
        bg: _argb(32, 32, 32),
        fg: 0xFFFFFFFF,
        panel_bg: _argb(40, 40, 40),
        panel_border: _argb(80, 80, 80),
        focused_border: _argb(100, 149, 237),
        button_bg: _argb(60, 60, 60),
        button_fg: 0xFFFFFFFF,
        button_focused_bg: _argb(80, 120, 200),
        input_bg: _argb(50, 50, 50),
        input_fg: 0xFFFFFFFF,
        input_border: _argb(100, 100, 100),
        menubar_bg: _argb(48, 48, 48),
        menubar_fg: _argb(200, 200, 200),
        statusbar_bg: _argb(0, 122, 204),
        statusbar_fg: 0xFFFFFFFF,
        progress_bg: _argb(60, 60, 60),
        progress_fill: _argb(0, 122, 204),
        divider_color: _argb(80, 80, 80),
        selection_bg: _argb(44, 93, 142)
    )

fn light_theme() -> ThemeColors:
    """Standard light theme colors."""
    ThemeColors(
        bg: _argb(240, 240, 240),
        fg: _argb(30, 30, 30),
        panel_bg: 0xFFFFFFFF,
        panel_border: _argb(200, 200, 200),
        focused_border: _argb(0, 120, 215),
        button_bg: _argb(225, 225, 225),
        button_fg: _argb(30, 30, 30),
        button_focused_bg: _argb(0, 120, 215),
        input_bg: 0xFFFFFFFF,
        input_fg: _argb(30, 30, 30),
        input_border: _argb(180, 180, 180),
        menubar_bg: _argb(230, 230, 230),
        menubar_fg: _argb(30, 30, 30),
        statusbar_bg: _argb(0, 122, 204),
        statusbar_fg: 0xFFFFFFFF,
        progress_bg: _argb(220, 220, 220),
        progress_fill: _argb(0, 122, 204),
        divider_color: _argb(200, 200, 200),
        selection_bg: _argb(0, 120, 215)
    )

fn resolve_theme(name: text) -> ThemeColors:
    if name == "light":
        return light_theme()
    return dark_theme()

# ============================================================================
# Framebuffer Backend
# ============================================================================

class FramebufferBackend:
    """RenderBackend implementation that draws to a framebuffer.

    Translates the abstract widget tree into pixel rendering commands
    via FramebufferDriver (fill_rect, draw_text, swap_buffers).
    """
    fb: FramebufferDriver
    keyboard: Ps2Keyboard
    width: i32
    height: i32

impl FramebufferBackend:

    static fn create(fb: FramebufferDriver, keyboard: Ps2Keyboard) -> FramebufferBackend:
        FramebufferBackend(
            fb: fb,
            keyboard: keyboard,
            width: fb.width.to_i32(),
            height: fb.height.to_i32()
        )

# ============================================================================
# RenderBackend Trait Implementation
# ============================================================================

impl RenderBackend for FramebufferBackend:

    fn init() -> Result<bool, text>:
        self.keyboard.init()
        self.fb.clear(Color.black())
        self.fb.swap_buffers()
        Ok(true)

    fn shutdown():
        self.fb.clear(Color.black())
        self.fb.swap_buffers()

    fn render(state: UIState) -> Result<bool, text>:
        val theme = resolve_theme(state.tree.theme())
        # Create compositor backend wrapper
        var cb = FbCompositorBackend.new(self.fb)
        # Clear background
        cb.clear(theme.bg)
        # Compute layout for the full viewport
        val root = state.tree.root_node()
        val rects = compute_layout(root, 0, 0, self.width, self.height)
        # Render each widget
        _render_tree(cb, root, rects, state.focused_id, theme)
        # Flip to screen
        cb.present()
        Ok(true)

    fn render_html(state: UIState) -> text:
        ""

    fn poll_event(timeout_ms: i32) -> UIEvent?:
        val key_event = self.keyboard.poll()
        if key_event == nil:
            return nil
        return _translate_key_event(self.keyboard, key_event)

    fn supports_mouse() -> bool: false
    fn supports_color() -> bool: true
    fn supports_images() -> bool: false
    fn supports_touch() -> bool: false

    fn viewport_width() -> i32: self.width
    fn viewport_height() -> i32: self.height

    fn backend_name() -> text: "framebuffer"

# ============================================================================
# Widget Tree Rendering
# ============================================================================

fn _render_tree(backend: CompositorBackend, node: WidgetNode, rects: [WidgetRect], focused_id: text, theme: ThemeColors):
    """Recursively render each widget in the tree via CompositorBackend."""
    if not node.is_visible():
        return

    val rect = find_rect(rects, node.id)
    if rect == nil:
        return
    val r = rect

    val is_focused = node.id == focused_id
    val kind = node.kind_name()

    if kind == "panel":
        _render_panel(backend, node, r, is_focused, theme)
    elif kind == "text" or kind == "label" or kind == "heading":
        _render_text(backend, node, r, is_focused, theme)
    elif kind == "button":
        _render_button(backend, node, r, is_focused, theme)
    elif kind == "input" or kind == "textfield":
        _render_input(backend, node, r, is_focused, theme)
    elif kind == "menubar":
        _render_menubar(backend, node, r, theme)
    elif kind == "statusbar":
        _render_statusbar(backend, node, r, theme)
    elif kind == "progress":
        _render_progress(backend, node, r, theme)
    elif kind == "divider":
        _render_divider(backend, r, theme)
    elif kind == "list":
        _render_list(backend, node, r, is_focused, theme)
    elif kind == "checkbox":
        _render_checkbox(backend, node, r, is_focused, theme)
    elif kind == "textarea":
        _render_textarea(backend, node, r, is_focused, theme)
    else:
        pass_dn

    # Render children recursively
    for child in node.children():
        _render_tree(backend, child, rects, focused_id, theme)

# ============================================================================
# Widget Renderers
# ============================================================================

# Pixel sizes for 8x16 font
val CHAR_W: i32 = 8
val CHAR_H: i32 = 16

fn _render_panel(backend: CompositorBackend, node: WidgetNode, r: WidgetRect, focused: bool, theme: ThemeColors):
    """Render a panel: background fill + border + optional title."""
    val x = r.x
    val y = r.y
    val w = r.w
    val h = r.h

    # Background
    backend.fill_rect(x, y, w, h, theme.panel_bg)

    # Border
    val border_color = if focused: theme.focused_border else: theme.panel_border
    # Top edge
    backend.fill_rect(x, y, w, 1, border_color)
    # Bottom edge
    if h > 1:
        backend.fill_rect(x, y + h - 1, w, 1, border_color)
    # Left edge
    backend.fill_rect(x, y, 1, h, border_color)
    # Right edge
    if w > 1:
        backend.fill_rect(x + w - 1, y, 1, h, border_color)

    # Title text (if set)
    val title = node.get_prop("title")
    if title != "":
        val title_x = x + CHAR_W
        val title_y = y + 2
        backend.draw_text(title_x, title_y, title, theme.fg, theme.panel_bg)

fn _render_text(backend: CompositorBackend, node: WidgetNode, r: WidgetRect, focused: bool, theme: ThemeColors):
    """Render a text/label widget."""
    val x = r.x
    val y = r.y

    val content = node.get_prop("content")
    val label_text = node.get_prop("label")
    val display = if content != "": content else: label_text

    if display != "":
        val fg = if focused: theme.selection_bg else: theme.fg
        backend.draw_text(x, y, display, fg, theme.bg)

fn _render_button(backend: CompositorBackend, node: WidgetNode, r: WidgetRect, focused: bool, theme: ThemeColors):
    """Render a button: filled rectangle + centered label + optional icon."""
    val x = r.x
    val y = r.y
    val w = r.w
    val h = r.h

    val bg = if focused: theme.button_focused_bg else: theme.button_bg
    backend.fill_rect(x, y, w, h, bg)

    val label_text = node.get_prop("label")
    val icon_id = node.get_prop("icon-id")
    
    var text_offset_x = 0
    if icon_id != "":
        if val def = get_icon_definition(icon_id):
            # Render icon on the left of text
            val scale = 1
            val icon_x = x + 4
            val icon_y = y + (h - def.height) / 2
            draw_icon_rle(backend, icon_x, icon_y, def, scale)
            text_offset_x = def.width + 4

    if label_text != "":
        val text_w = label_text.len().to_i32() * CHAR_W
        val text_x = x + (w - text_w + text_offset_x) / 2
        val text_y = y + (h - CHAR_H) / 2
        backend.draw_text(text_x, text_y, label_text, theme.button_fg, bg)

fn _render_input(backend: CompositorBackend, node: WidgetNode, r: WidgetRect, focused: bool, theme: ThemeColors):
    """Render a text input field."""
    val x = r.x
    val y = r.y
    val w = r.w
    val h = r.h

    # Background
    backend.fill_rect(x, y, w, h, theme.input_bg)

    # Border
    val border = if focused: theme.focused_border else: theme.input_border
    backend.fill_rect(x, y, w, 1, border)
    if h > 1:
        backend.fill_rect(x, y + h - 1, w, 1, border)
    backend.fill_rect(x, y, 1, h, border)
    if w > 1:
        backend.fill_rect(x + w - 1, y, 1, h, border)

    # Value or placeholder
    val value = node.get_prop("value")
    val placeholder = node.get_prop("placeholder")
    val display = if value != "": value else: placeholder
    val fg = if value != "": theme.input_fg else: 0xFF808080

    if display != "":
        backend.draw_text(x + 4, y + 2, display, fg, theme.input_bg)

    # Cursor when focused
    if focused:
        val cursor_x = x + 4 + value.len().to_i32() * CHAR_W
        backend.fill_rect(cursor_x, y + 2, 2, CHAR_H, theme.fg)

fn _render_menubar(backend: CompositorBackend, node: WidgetNode, r: WidgetRect, theme: ThemeColors):
    """Render a menu bar: horizontal strip with menu items."""
    backend.fill_rect(r.x, r.y, r.w, r.h, theme.menubar_bg)

    var item_x = r.x + 8
    for child in node.children():
        val label_text = child.get_prop("label")
        if label_text != "":
            backend.draw_text(item_x, r.y + 2, label_text, theme.menubar_fg, theme.menubar_bg)
            item_x = item_x + label_text.len().to_i32() * CHAR_W + 16

fn _render_statusbar(backend: CompositorBackend, node: WidgetNode, r: WidgetRect, theme: ThemeColors):
    """Render a status bar: horizontal strip at bottom."""
    backend.fill_rect(r.x, r.y, r.w, r.h, theme.statusbar_bg)

    val left = node.get_prop("left")
    if left != "":
        backend.draw_text(r.x + 4, r.y + 2, left, theme.statusbar_fg, theme.statusbar_bg)

    val right = node.get_prop("right")
    if right != "":
        val right_w = right.len().to_i32() * CHAR_W
        val right_x = r.x + r.w - right_w - 4
        backend.draw_text(right_x, r.y + 2, right, theme.statusbar_fg, theme.statusbar_bg)

fn _render_progress(backend: CompositorBackend, node: WidgetNode, r: WidgetRect, theme: ThemeColors):
    """Render a progress bar."""
    backend.fill_rect(r.x, r.y, r.w, r.h, theme.progress_bg)

    val value_str = node.get_prop("value")
    if value_str != "":
        val value = value_str.to_int()
        if value > 0:
            val clamped = if value > 100: 100 else: value
            val fill_w = r.w * clamped / 100
            backend.fill_rect(r.x, r.y, fill_w, r.h, theme.progress_fill)

fn _render_divider(backend: CompositorBackend, r: WidgetRect, theme: ThemeColors):
    """Render a horizontal divider line."""
    val mid_y = r.y + r.h / 2
    backend.fill_rect(r.x, mid_y, r.w, 1, theme.divider_color)

fn _render_list(backend: CompositorBackend, node: WidgetNode, r: WidgetRect, focused: bool, theme: ThemeColors):
    """Render a list widget with selectable items."""
    backend.fill_rect(r.x, r.y, r.w, r.h, theme.panel_bg)

    val selected_str = node.get_prop("selected_index")
    var selected_idx: i32 = -1
    if selected_str != "":
        selected_idx = selected_str.to_int()

    var item_y = r.y
    var idx: i32 = 0
    for child in node.children():
        val label_text = child.get_prop("label")
        if label_text != "":
            val is_selected = idx == selected_idx
            val item_bg = if is_selected: theme.selection_bg else: theme.panel_bg
            val item_fg = if is_selected: 0xFFFFFFFF else: theme.fg
            backend.fill_rect(r.x, item_y, r.w, CHAR_H, item_bg)
            backend.draw_text(r.x + 4, item_y, label_text, item_fg, item_bg)
        item_y = item_y + CHAR_H
        idx = idx + 1

fn _render_checkbox(backend: CompositorBackend, node: WidgetNode, r: WidgetRect, focused: bool, theme: ThemeColors):
    """Render a checkbox: box + label text."""
    val x = r.x
    val y = r.y
    val checked = node.get_prop("checked") == "true"
    val label_text = node.get_prop("label")

    val box_size: i32 = 12
    val box_y = y + 2
    val border: u32 = if focused: theme.focused_border else: theme.panel_border
    backend.fill_rect(x, box_y, box_size, box_size, theme.input_bg)
    backend.fill_rect(x, box_y, box_size, 1, border)
    backend.fill_rect(x, box_y + box_size - 1, box_size, 1, border)
    backend.fill_rect(x, box_y, 1, box_size, border)
    backend.fill_rect(x + box_size - 1, box_y, 1, box_size, border)

    if checked:
        backend.fill_rect(x + 2, box_y + 2, box_size - 4, box_size - 4, theme.focused_border)

    if label_text != "":
        backend.draw_text(x + box_size + 6, y, label_text, theme.fg, theme.bg)

fn _render_textarea(backend: CompositorBackend, node: WidgetNode, r: WidgetRect, focused: bool, theme: ThemeColors):
    """Render a multi-line text area."""
    backend.fill_rect(r.x, r.y, r.w, r.h, theme.input_bg)
    val border: u32 = if focused: theme.focused_border else: theme.input_border
    backend.fill_rect(r.x, r.y, r.w, 1, border)
    backend.fill_rect(r.x, r.y + r.h - 1, r.w, 1, border)
    backend.fill_rect(r.x, r.y, 1, r.h, border)
    backend.fill_rect(r.x + r.w - 1, r.y, 1, r.h, border)

    val value = node.get_prop("value")
    if value != "":
        backend.draw_text(r.x + 4, r.y + 2, value, theme.input_fg, theme.input_bg)

# ============================================================================
# Input Translation
# ============================================================================

fn _translate_key_event(keyboard: Ps2Keyboard, event: KeyEvent) -> UIEvent?:
    """Convert a PS/2 KeyEvent into a UIEvent."""
    match event:
        KeyEvent.Release(key):
            return nil
        KeyEvent.Press(key):
            return _translate_key_press(keyboard, key)

fn _translate_key_press(keyboard: Ps2Keyboard, key: Key) -> UIEvent?:
    """Convert a key press into a UIEvent."""
    # Special keys
    match key:
        Key.Escape:
            return UIEvent.Quit
        Key.Tab:
            if keyboard.shift_held:
                return UIEvent.FocusPrev
            return UIEvent.FocusNext
        Key.F1:
            return UIEvent.Action(name: "help")
        Key.F2:
            return UIEvent.Action(name: "rename")
        Key.Up:
            return UIEvent.KeyPress(key: "up")
        Key.Down:
            return UIEvent.KeyPress(key: "down")
        Key.Left:
            return UIEvent.KeyPress(key: "left")
        Key.Right:
            return UIEvent.KeyPress(key: "right")
        Key.Enter:
            return UIEvent.KeyPress(key: "enter")
        Key.Backspace:
            return UIEvent.KeyPress(key: "backspace")
        Key.Delete:
            return UIEvent.KeyPress(key: "delete")
        Key.Home:
            return UIEvent.KeyPress(key: "home")
        Key.End:
            return UIEvent.KeyPress(key: "end")
        Key.PageUp:
            return UIEvent.KeyPress(key: "pageup")
        Key.PageDown:
            return UIEvent.KeyPress(key: "pagedown")
        _:
            pass_dn

    # Character keys
    val ch = keyboard.key_to_char(key)
    if ch != nil:
        return UIEvent.KeyPress(key: ch)

    return nil
