#![allow(unnamed_duplicate_typed_args)]

class RegionTolerance:
    region_type: text
    threshold: i32
    min_match_pct: i32
    yiq_threshold: f64

class ToleranceProfile:
    name: text
    default_threshold: i32
    default_yiq_threshold: f64
    min_match_pct: i32
    regions: [RegionTolerance]

fn profile_strict() -> ToleranceProfile:
    ToleranceProfile(name: "strict", default_threshold: 0, default_yiq_threshold: 0.0, min_match_pct: 10000, regions: [])

fn profile_text_tolerant() -> ToleranceProfile:
    ToleranceProfile(
        name: "text_tolerant",
        default_threshold: 16,
        default_yiq_threshold: 0.05,
        min_match_pct: 9800,
        regions: [RegionTolerance(region_type: "text", threshold: 32, min_match_pct: 9600, yiq_threshold: 0.08)]
    )

fn profile_glass_blur() -> ToleranceProfile:
    ToleranceProfile(
        name: "glass_blur",
        default_threshold: 16,
        default_yiq_threshold: 0.07,
        min_match_pct: 9700,
        regions: [RegionTolerance(region_type: "glass", threshold: 48, min_match_pct: 9400, yiq_threshold: 0.12)]
    )

fn profile_wm_default() -> ToleranceProfile:
    ToleranceProfile(
        name: "wm_default",
        default_threshold: 12,
        default_yiq_threshold: 0.04,
        min_match_pct: 9850,
        regions: [
            RegionTolerance(region_type: "text", threshold: 28, min_match_pct: 9600, yiq_threshold: 0.08),
            RegionTolerance(region_type: "glass", threshold: 40, min_match_pct: 9500, yiq_threshold: 0.10)
        ]
    )

fn merge_profiles(base: ToleranceProfile, overlay: ToleranceProfile) -> ToleranceProfile:
    var regions = base.regions
    for region in overlay.regions:
        regions.push(region)
    ToleranceProfile(
        name: overlay.name,
        default_threshold: overlay.default_threshold,
        default_yiq_threshold: overlay.default_yiq_threshold,
        min_match_pct: overlay.min_match_pct,
        regions: regions
    )
