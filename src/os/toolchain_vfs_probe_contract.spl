# Serial completion contract for the x64 toolchain VFS probe.

pub fn toolchain_vfs_probe_required_marker_fragments() -> [text]:
    [
        "[toolchain-vfs] storage-ready",
        "[toolchain-vfs] ok read-exec path=/sys/apps/clang bytes=",
        "[toolchain-vfs] ok read-exec path=/sys/apps/rust bytes=",
        "[toolchain-vfs] ok smf-exec path=/sys/apps/clang marker=SIMPLEOS_X86_64_CLANG_ELF stub_bytes=",
        "[toolchain-vfs] ok smf-exec path=/sys/apps/rust marker=SIMPLEOS_X86_64_RUST_ELF stub_bytes=",
        "[toolchain-vfs] ok read-text path=/SYS/CLANGMAN.TXT contains=mode=native-filesystem-app bytes=",
        "[toolchain-vfs] ok read-text path=/SYS/CLANGMAN.TXT contains=status=standalone-required bytes=",
        "[toolchain-vfs] ok read-text path=/SYS/CLANGMAN.TXT contains=proof_pipeline=/usr/share/simpleos/toolchain/clang/pipeline.step bytes=",
        "[toolchain-vfs] ok read-text path=/SYS/RUSTMAN.TXT contains=mode=native-filesystem-app bytes=",
        "[toolchain-vfs] ok read-text path=/SYS/RUSTMAN.TXT contains=status=standalone-required bytes=",
        "[toolchain-vfs] ok read-text path=/SYS/RUSTMAN.TXT contains=proof_pipeline=/usr/share/simpleos/toolchain/rust/pipeline.step bytes=",
        "[toolchain-vfs] ok read-text path=/SYS/CLANGHEL.C contains=hello from simpleos clang bytes=",
        "[toolchain-vfs] ok read-text path=/SYS/CLANGFLG.RSP contains=-target x86_64-unknown-simpleos bytes=",
        "[toolchain-vfs] ok read-text path=/SYS/CLANGPLN.STP contains=pipeline=compile-pipeline-step bytes=",
        "[toolchain-vfs] ok read-text path=/SYS/RUSTHELO.RS contains=fn main bytes=",
        "[toolchain-vfs] ok read-text path=/SYS/RUSTCARG.TOM contains=simpleos-hello bytes=",
        "[toolchain-vfs] ok read-text path=/SYS/RUSTPIPE.STP contains=pipeline=build-pipeline-step bytes=",
        "[fs-exec] spawn:image path=/sys/apps/clang entry=0 segments=1 stub_bytes=",
        "argv_count=2 env_count=0 pid=1",
        "[toolchain-vfs] ok spawn app=clang path=/sys/apps/clang pid=1",
        "argv0=/usr/share/simpleos/toolchain/clang/hello.c",
        "[fs-exec] spawn:image path=/sys/apps/rust entry=0 segments=1 stub_bytes=",
        "argv_count=2 env_count=0 pid=2",
        "[toolchain-vfs] ok spawn app=rust path=/sys/apps/rust pid=2",
        "argv0=/usr/share/simpleos/toolchain/rust/Cargo.toml",
        "[toolchain-vfs] compiler-operation-deferred status=standalone-required reason=frontend-runtime-not-yet-ported",
        "[toolchain-vfs] all checks passed",
        "TEST PASSED"
    ]

pub fn toolchain_vfs_probe_serial_accepts_completion(serial_output: text) -> bool:
    for marker in toolchain_vfs_probe_required_marker_fragments():
        if not serial_output.contains(marker):
            return false
    true

pub fn print_toolchain_vfs_probe_missing_markers(serial_output: text):
    for marker in toolchain_vfs_probe_required_marker_fragments():
        if not serial_output.contains(marker):
            print "[test] missing marker fragment: {marker}"
