val _MULTIARCH_RESULT_ROOT: text = "build/multiarch"

# Default native-build timeout for `os build` lane.
# Rationale: a cold full-tree native-build on current CI hardware routinely
# lands in the 5–10 minute range (see simpleos_process_shell_followup_plan_2026-04-13.md
# item #1). The previous hardcoded 60s ceiling reported a generic "Process timed out"
# before the compiler had meaningfully started its LLVM/Cranelift backend, hiding the
# real phase. 900_000 ms (15 min) gives enough headroom for the slowest target
# (x86_64 desktop wrapper) while still bounding stuck subprocesses. Override with
# SIMPLE_OS_BUILD_TIMEOUT_MS at runtime when tracing regressions.
val _OS_BUILD_DEFAULT_TIMEOUT_MS: i64 = 900000
val _OS_BUILD_DEFAULT_LOG_MODE: text = "on"

fn _parse_timeout_ms(raw: text, default_ms: i64) -> i64:
    """Parse a positive integer ms value from env, falling back to default on empty/bad input."""
    if raw == "":
        return default_ms
    var result: i64 = 0
    var found_digit = false
    for ch in raw:
        if ch >= "0" and ch <= "9":
            val digit = (ch.to_i32() - "0".to_i32()) as i64
            result = result * 10 + digit
            found_digit = true
        else:
            return default_ms
    if not found_digit:
        return default_ms
    if result <= 0:
        return default_ms
    result

fn _os_build_timeout_ms() -> i64:
    """Resolve the active native-build timeout, honoring SIMPLE_OS_BUILD_TIMEOUT_MS.

    env_get returns NIL when the variable is unset; coerce to empty string so
    the parser takes the empty/default branch instead of failing to iterate NIL.
    """
    val raw = env_get("SIMPLE_OS_BUILD_TIMEOUT_MS") ?? ""
    _parse_timeout_ms(raw, _OS_BUILD_DEFAULT_TIMEOUT_MS)

fn _normalize_os_log_mode(raw: text) -> text:
    if raw == "off":
        return "off"
    if raw == "on":
        return "on"
    _OS_BUILD_DEFAULT_LOG_MODE

fn _os_build_log_mode() -> text:
    val raw = env_get("SIMPLE_OS_LOG_MODE") ?? ""
    _normalize_os_log_mode(raw)

fn _os_build_backend_for_target(target: OsTarget) -> text:
    """Resolve native-build backend for a concrete OS target.

    Cranelift in this toolchain does not provide i686 or RISC-V freestanding
    object targets, so those OS lanes default to LLVM. The environment
    override still wins for diagnostics and experiments.
    """
    val raw = env_get("SIMPLE_OS_BUILD_BACKEND") ?? ""
    if raw == "llvm":
        return "llvm"
    if raw == "cranelift":
        return "cranelift"
    if target.entry == "examples/09_embedded/simple_os/arch/riscv64/ssh_live_entry.spl":
        return "cranelift"
    if target.entry == "examples/09_embedded/simple_os/arch/riscv64/x25519_probe_entry.spl":
        return "cranelift"
    match target.arch:
        Architecture.X86: "llvm"
        Architecture.Arm64: "llvm"
        Architecture.Arm32: "llvm"
        Architecture.Riscv64: "llvm"
        Architecture.Riscv32: "llvm"
        _: "cranelift"

fn default_os_build_backend_for_target(target: OsTarget) -> text:
    """Return the default native-build backend for an OS target."""
    _os_build_backend_for_target(target)

fn _now_ms() -> i64:
    current_time_ms()

fn _result_arch_slug(arch: Architecture) -> text:
    match arch:
        Architecture.X86_64: "x86_64"
        Architecture.X86: "i686"
        Architecture.Arm64: "aarch64"
        Architecture.Arm32: "armv7"
        Architecture.Riscv64: "riscv64"
        Architecture.Riscv32: "riscv32"

fn _result_arch_dir(arch: Architecture) -> text:
    "{_MULTIARCH_RESULT_ROOT}/{_result_arch_slug(arch)}"

fn _smoke_result_path(arch: Architecture) -> text:
    "{_result_arch_dir(arch)}/smoke_result.json"

fn _smoke_serial_log_path(arch: Architecture) -> text:
    "{_result_arch_dir(arch)}/smoke_serial.log"

fn _smoke_serial_sample_path(arch: Architecture) -> text:
    "{_result_arch_dir(arch)}/smoke_serial_{_now_ms()}.log"

fn _bootstrap_result_path(arch: Architecture) -> text:
    "{_result_arch_dir(arch)}/bootstrap_result.json"

fn _native_build_failure_log_path(arch: Architecture) -> text:
    "{_result_arch_dir(arch)}/native_build_failure.log"

fn _json_bool(v: bool) -> text:
    if v:
        return "true"
    "false"

fn _escape_json(s: text) -> text:
    var out = ""
    for ch in s:
        if ch == "\\":
            out = out + "\\\\"
        elif ch == "\"":
            out = out + "\\\""
        elif ch == "\n":
            out = out + "\\n"
        elif ch == "\r":
            out = out + "\\r"
        else:
            out = out + ch
    out

fn _status_text(ok: bool) -> text:
    if ok:
        return "pass"
    "fail"

fn _loader_name_for_arch(arch: Architecture) -> text:
    match arch:
        Architecture.X86_64: "limine"
        Architecture.X86: "limine"
        Architecture.Arm64: "u-boot"
        Architecture.Arm32: "u-boot"
        Architecture.Riscv64: "opensbi"
        Architecture.Riscv32: "opensbi"

fn _backend_title_case(raw: text) -> text:
    if raw == "llvm":
        return "Llvm"
    if raw == "cranelift":
        return "Cranelift"
    raw

fn _platform_name_for_arch(arch: Architecture) -> text:
    arch_display_name(arch)

fn _image_path_for_target(target: OsTarget) -> text:
    simpleos_platform_disk_image_output(_platform_name_for_arch(target.arch))

fn _ensure_result_dir(arch: Architecture) -> bool:
    dir_create_all(_result_arch_dir(arch))

fn _smoke_result_body(target: OsTarget, success: bool, has_banner: bool, nvfs_mounted: bool, serial_output: text, exit_code: i32, baseline_match: bool) -> text:
    "{\n" +
        "  \"arch\": \"" + _result_arch_slug(target.arch) + "\",\n" +
        "  \"status\": \"" + _status_text(success) + "\",\n" +
        "  \"banner\": " + _json_bool(has_banner) + ",\n" +
        "  \"nvfs_mounted\": " + _json_bool(nvfs_mounted) + ",\n" +
        "  \"baseline_match\": " + _json_bool(baseline_match) + ",\n" +
        "  \"exit_code\": " + (exit_code as i64).to_text() + ",\n" +
        "  \"serial_tail\": \"" + _escape_json(_tail_lines(serial_output, 20)) + "\"\n" +
        "}\n"

fn _bootstrap_result_body(target: OsTarget, build_ok: bool, smoke_ok: bool, backend: text) -> text:
    val loader = _loader_name_for_arch(target.arch)
    val image_path = _image_path_for_target(target)
    val backend_name = _backend_title_case(backend)
    val dtb_field = if target.arch == Architecture.Arm64 or target.arch == Architecture.Arm32:
        ",\n  \"dtb\": true"
    else:
        ""
    "{\n" +
        "  \"arch\": \"" + _result_arch_slug(target.arch) + "\",\n" +
        "  \"exit_code\": " + (if build_ok: "0" else: "1") + ",\n" +
        "  \"image_path\": \"" + _escape_json(image_path) + "\",\n" +
        "  \"smoke_status\": \"" + _status_text(smoke_ok) + "\",\n" +
        "  \"loader\": \"" + loader + "\",\n" +
        "  \"backend\": \"" + backend_name + "\"" +
        dtb_field + "\n" +
        "}\n"

fn _write_smoke_result(target: OsTarget, success: bool, has_banner: bool, serial_output: text, exit_code: i32):
    if not _ensure_result_dir(target.arch):
        print "[test] WARNING: could not create multiarch result dir for {arch_display_name(target.arch)}"
        return
    val baseline_path = "{_result_arch_dir(target.arch)}/baseline_smoke.json"
    val baseline_match = target.arch != Architecture.X86_64 or file_exists(baseline_path)
    # Do not infer storage readiness from a generic boot PASS.  This field is
    # evidence for a filesystem marker, not an alias for "QEMU exited OK".
    val nvfs_mounted = serial_output.contains("nvfs") or serial_output.contains("NVFS") or serial_output.contains("[vfs] mounted")
    val body = _smoke_result_body(target, success, has_banner, nvfs_mounted, serial_output, exit_code, baseline_match)
    if not file_write_text(_smoke_result_path(target.arch), body):
        print "[test] WARNING: could not write smoke result for {arch_display_name(target.arch)}"
    if serial_output != "":
        val _latest_ok = file_write_text(_smoke_serial_log_path(target.arch), serial_output)
        val _sample_ok = file_write_text(_smoke_serial_sample_path(target.arch), serial_output)
    if target.arch == Architecture.X86_64 and success:
        var refresh_baseline = not file_exists(baseline_path)
        if not refresh_baseline:
            val baseline = file_read(baseline_path)
            refresh_baseline = not baseline.contains("\"status\": \"pass\"")
        if refresh_baseline:
            val _ = file_write_text(baseline_path, body)

fn _write_bootstrap_result(target: OsTarget, build_ok: bool, smoke_ok: bool, backend: text):
    if not _ensure_result_dir(target.arch):
        print "[build] WARNING: could not create multiarch result dir for {arch_display_name(target.arch)}"
        return
    val body = _bootstrap_result_body(target, build_ok, smoke_ok, backend)
    if not file_write_text(_bootstrap_result_path(target.arch), body):
        print "[build] WARNING: could not write bootstrap result for {arch_display_name(target.arch)}"

fn _write_native_build_failure_log(target: OsTarget, backend: text, args: [text], stdout: text, stderr: text, exit_code: i32, elapsed_ms: i64):
    if not _ensure_result_dir(target.arch):
        return
    val body =
        "arch={arch_display_name(target.arch)}\n" +
        "backend={backend}\n" +
        "entry={target.entry}\n" +
        "target={target.target_triple}\n" +
        "output={target.output}\n" +
        "exit_code={(exit_code as i64).to_text()}\n" +
        "elapsed_ms={elapsed_ms}\n" +
        "args={args.join(\" \")}\n" +
        "\n[stdout]\n{stdout}\n[stderr]\n{stderr}\n"
    val _ = file_write_text(_native_build_failure_log_path(target.arch), body)

fn _tail_lines(s: text, n: i64) -> text:
    """Return the last n newline-delimited lines of s, for compact diagnostic prints."""
    if s == "":
        return ""
    val lines = s.split("\n")
    val total = lines.len() as i64
    if total <= n:
        return s
    var out: text = ""
    var i: i64 = total - n
    while i < total:
        out = out + lines[i as i32] + "\n"
        i = i + 1
    out

fn native_build_prerequisite_hint(backend: text, stderr: text) -> text:
    """Return a concise prerequisite hint for known native-build backend failures."""
    if backend == "llvm" and stderr.contains("LLVM backend requested but 'llvm' feature not enabled"):
        return "LLVM backend unavailable: rebuild the selected Simple compiler with the Rust `llvm` feature and make LLVM 18 discoverable, for example with LLVM_SYS_180_PREFIX."
    if backend == "llvm" and stderr.contains("native backend 'llvm' is not available"):
        return "LLVM backend unavailable: rebuild the selected Simple compiler with the Rust `llvm` feature and make LLVM 18 discoverable, for example with LLVM_SYS_180_PREFIX."
    if backend == "llvm" and stderr.contains("No suitable version of LLVM was found"):
        return "LLVM 18 is not discoverable: set LLVM_SYS_180_PREFIX or install a system LLVM 18 before building the LLVM-enabled Simple compiler."
    if backend == "cranelift" and stderr.contains("Support for this target has not been implemented yet"):
        return "Cranelift cannot build this freestanding target; use an LLVM-enabled Simple compiler or unset SIMPLE_OS_BUILD_BACKEND for targets that default to LLVM."
    if backend == "cranelift" and stderr.contains("Cranelift native builds do not support hosted riscv32 yet"):
        return "Cranelift cannot build this freestanding target; use an LLVM-enabled Simple compiler or unset SIMPLE_OS_BUILD_BACKEND for targets that default to LLVM."
    ""

fn _print_native_build_failure_hint(arch_label: text, backend_name: text, stderr: text):
    val hint = native_build_prerequisite_hint(backend_name, stderr)
    if hint != "":
        print "[build][{arch_label}] prerequisite: {hint}"

pub fn is_qemu_success(target: OsTarget, exit_code: i32) -> bool:
    """Interpret QEMU exit code based on architecture.

    x86/x86_64 with isa-debug-exit: guest writes 0 -> QEMU exits with (0 << 1) | 1 = 1
    Non-x86 lanes do not attach isa-debug-exit in this runner, so only exit 0
    is accepted.  Accepting exit 1 globally hid real guest failures.
    """
    match target.arch:
        Architecture.X86_64: exit_code == 1
        Architecture.X86: exit_code == 1
        Architecture.Arm64: exit_code == 0
        Architecture.Arm32: exit_code == 0
        _: exit_code == 0

# ===========================================================================
# OS Target Configuration
# ===========================================================================

class OsTarget:
    """Build and QEMU configuration for a single OS architecture target."""
    arch: Architecture
    entry: text
    linker_script: text
    target_triple: text
    output: text
    qemu_system: text
    qemu_machine: text
    qemu_cpu: text
    qemu_memory: text
    qemu_bios: text
    qemu_extra: [text]
    gui_mode: bool

class QemuRunOptions:
    """Run-time launch knobs that do not change the compiled target."""
    debug_gui_serial: bool
    headless: bool

fn qemu_run_options_default() -> QemuRunOptions:
    QemuRunOptions(debug_gui_serial: false, headless: false)

fn qemu_run_options_debug_gui() -> QemuRunOptions:
    QemuRunOptions(debug_gui_serial: true, headless: false)

fn qemu_run_options_headless() -> QemuRunOptions:
    QemuRunOptions(debug_gui_serial: false, headless: true)

fn _qemu_command_binary(target: OsTarget) -> text:
    """Resolve the host QEMU frontend used to launch a built target.

    Current QEMU releases reject the x86_32 Multiboot-style ELF under
    `qemu-system-i386 -kernel` with a PVH-note error, while the same kernel
    boots correctly through `qemu-system-x86_64` when paired with the 32-bit
    `pc`/`qemu32` machine tuple. Keep the catalog metadata unchanged and only
    swap the executable used for the kernel-only x86_32 launch path.
    """
    if target.arch == Architecture.X86 and target.qemu_system == "qemu-system-i386":
        return "qemu-system-x86_64"
    target.qemu_system

fn _lane_to_target(platform_name: text, lane: SimpleOsLaneContract) -> OsTarget:
    OsTarget(
        arch: simpleos_platform_arch(platform_name),
        entry: lane.entry,
        linker_script: lane.linker_script,
        target_triple: simpleos_platform_native_target(platform_name),
        output: lane.output,
        qemu_system: simpleos_platform_qemu_system(platform_name),
        qemu_machine: simpleos_platform_qemu_machine(platform_name),
        qemu_cpu: simpleos_platform_qemu_cpu(platform_name),
        qemu_memory: lane.qemu_memory,
        qemu_bios: lane.qemu_bios,
        qemu_extra: lane.qemu_extra,
        gui_mode: false
    )

fn catalog_os_target(platform_name: text, memory: text, qemu_extra: [text], gui_mode: bool) -> OsTarget:
    """Build a QEMU target from the shared SimpleOS platform catalog."""
    OsTarget(
        arch: simpleos_platform_arch(platform_name),
        entry: simpleos_platform_default_entry(platform_name),
        linker_script: simpleos_platform_linker_script(platform_name),
        target_triple: simpleos_platform_native_target(platform_name),
        output: simpleos_platform_kernel_output(platform_name),
        qemu_system: simpleos_platform_qemu_system(platform_name),
        qemu_machine: simpleos_platform_qemu_machine(platform_name),
        qemu_cpu: simpleos_platform_qemu_cpu(platform_name),
        qemu_memory: memory,
        qemu_bios: "",
        qemu_extra: qemu_extra,
        gui_mode: gui_mode
    )

fn simpleos_platform_arch(platform_name: text) -> Architecture:
    # Workaround: avoid Option<large-struct> across function boundary (interpreter crash).
    # Use index-based lookup via simpleos_platform_arch_name instead.
    # arch_name values from catalog: "x86_64","x86","aarch64","arm","riscv64","riscv32"
    val aname = simpleos_platform_arch_name(platform_name)
    if aname == "x86_64":
        return Architecture.X86_64
    if aname == "x86" or aname == "x86_32":
        return Architecture.X86
    if aname == "riscv64":
        return Architecture.Riscv64
    if aname == "riscv32":
        return Architecture.Riscv32
    if aname == "aarch64" or aname == "arm64":
        return Architecture.Arm64
    if aname == "arm" or aname == "arm32" or aname == "armv7":
        return Architecture.Arm32
    Architecture.X86_64

# ===========================================================================
# Hardcoded Target Definitions
# ===========================================================================

fn get_target(arch: Architecture) -> OsTarget:
    """Returns hardcoded target config for the given architecture."""
    val platform_name = arch_display_name(arch)
    _lane_to_target(platform_name, simpleos_platform_qemu_smoke_lane(platform_name))

fn get_qemu_target(arch: Architecture) -> OsTarget:
    """Return the default QEMU/run target for an architecture.

    ARM and RISC-V default to filesystem-backed acceptance lanes so
    `simple os run/test` exercises the staged userland payloads
    (llvm/clang/rust) rather than the bare kernel-only boot target.
    Other architectures keep their existing direct boot targets unless the
    caller requests a named scenario.
    """
    if arch == Architecture.Arm64:
        return _lane_to_target("arm64", simpleos_platform_qemu_acceptance_lane("arm64"))
    if arch == Architecture.Arm32:
        return _lane_to_target("arm32", simpleos_platform_qemu_acceptance_lane("arm32"))
    if arch == Architecture.Riscv64:
        # Workaround: avoid if val Option<large-struct> (interpreter crash).
        if simpleos_platform_has_qemu_lane("riscv64", "riscv64-virtio-fat32-smf"):
            return _lane_to_target("riscv64", simpleos_platform_qemu_lane_or_smoke("riscv64", "riscv64-virtio-fat32-smf"))
        return _lane_to_target("riscv64", simpleos_platform_qemu_acceptance_lane("riscv64"))
    if arch == Architecture.Riscv32:
        return _lane_to_target("riscv32", simpleos_platform_qemu_acceptance_lane("riscv32"))
    get_target(arch)

# ===========================================================================
# Target Enumeration & Name Parsing
# ===========================================================================

fn get_gui_target() -> OsTarget:
    """Returns the x86_64 GUI target with BGA framebuffer and display enabled."""
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/09_embedded/simple_os/arch/x86_64/gui_entry.spl",
        linker_script: "examples/09_embedded/simple_os/arch/x86_64/linker.ld",
        target_triple: "x86_64-unknown-none",
        output: "build/os/simpleos_gui_x86_64.elf",
        qemu_system: "qemu-system-x86_64",
        qemu_machine: "q35",
        qemu_cpu: "qemu64",
        qemu_memory: "2G",
        qemu_bios: "",
        qemu_extra: _x64_nvme_fs_test_disk_args() + ["-vga", "std", "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"],
        gui_mode: true
    )

fn arm64_wm_qemu_cpu_for_host(host_os: text, host_arch: text) -> text:
    if host_os == "macos" and host_arch == "aarch64": return "host"
    "cortex-a57"

fn arm64_wm_qemu_extra_for_host(host_os: text, host_arch: text) -> [text]:
    if host_os == "macos" and host_arch == "aarch64":
        return ["-accel", "hvf", "-device", "ramfb"]
    ["-accel", "tcg", "-device", "ramfb"]

fn get_arm64_wm_qemu_target() -> OsTarget:
    """Returns the ARM64 canonical Engine2D WM ramfb target used by the host QEMU contract lane."""
    OsTarget(
        arch: Architecture.Arm64,
        entry: "examples/09_embedded/simple_os/arch/arm64/gui_entry_desktop.spl",
        linker_script: "examples/09_embedded/simple_os/arch/arm64/linker.ld",
        target_triple: "aarch64-unknown-none",
        output: "build/os/simpleos_arm64_wm.elf",
        qemu_system: "qemu-system-aarch64",
        qemu_machine: "virt",
        qemu_cpu: arm64_wm_qemu_cpu_for_host(detect_os(), detect_arch()),
        qemu_memory: "384M",
        qemu_bios: "",
        qemu_extra: arm64_wm_qemu_extra_for_host(detect_os(), detect_arch()),
        gui_mode: false
    )

fn get_arm64_desktop_engine2d_target() -> OsTarget:
    """Canonical ARM64 RAMFB/Engine2D desktop target."""
    OsTarget(
        arch: Architecture.Arm64,
        entry: "examples/09_embedded/simple_os/arch/arm64/gui_entry_desktop.spl",
        linker_script: "examples/09_embedded/simple_os/arch/arm64/linker.ld",
        target_triple: "aarch64-unknown-none",
        output: "build/os/simpleos_arm64_desktop_engine2d.elf",
        qemu_system: "qemu-system-aarch64",
        qemu_machine: "virt",
        qemu_cpu: "cortex-a72",
        qemu_memory: "512M",
        qemu_bios: "",
        qemu_extra: ["-device", "ramfb"],
        gui_mode: false
    )

fn get_host_gpu_probe_target(arch: Architecture) -> OsTarget:
    """Canonical build target for the architecture-neutral host-GPU probe."""
    val isa = match arch:
        Architecture.Arm64: "arm64"
        Architecture.Riscv64: "riscv64"
        _: "x86_64"
    val triple = match arch:
        Architecture.Arm64: "aarch64-unknown-none"
        Architecture.Riscv64: "riscv64-unknown-none"
        _: "x86_64-unknown-none"
    val qemu = match arch:
        Architecture.Arm64: "qemu-system-aarch64"
        Architecture.Riscv64: "qemu-system-riscv64"
        _: "qemu-system-x86_64"
    OsTarget(
        arch: arch,
        entry: "examples/09_embedded/simple_os/arch/{isa}/host_gpu_smoke_entry.spl",
        linker_script: "examples/09_embedded/simple_os/arch/{isa}/linker.ld",
        target_triple: triple,
        output: "build/os/simpleos_{isa}_host_gpu_probe.elf",
        qemu_system: qemu,
        qemu_machine: if arch == Architecture.X86_64: "q35" else: "virt",
        qemu_cpu: if arch == Architecture.Arm64: "cortex-a72" elif arch == Architecture.Riscv64: "rv64" else: "qemu64",
        qemu_memory: "512M",
        qemu_bios: "",
        qemu_extra: [],
        gui_mode: false
    )

fn get_gpu_test_target() -> OsTarget:
    """Returns the x86_64 GPU test target with VirtIO-GPU in legacy PCI mode."""
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/09_embedded/simple_os/arch/x86_64/gpu_test_entry.spl",
        linker_script: "examples/09_embedded/simple_os/arch/x86_64/linker.ld",
        target_triple: "x86_64-unknown-none",
        output: "build/os/simpleos_gpu_test_x86_64.elf",
        qemu_system: "qemu-system-x86_64",
        qemu_machine: "q35",
        qemu_cpu: "qemu64",
        qemu_memory: "512M",
        qemu_bios: "",
        qemu_extra: ["-device", "virtio-gpu,disable-modern=on,disable-legacy=off", "-vga", "none", "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"],
        gui_mode: true
    )

fn get_tools_test_target() -> OsTarget:
    """Returns x86_64 tools test target with release-first NVMe + FAT32 media."""
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/09_embedded/simple_os/arch/x86_64/tools_test_entry.spl",
