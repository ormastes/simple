        gui_mode: false
    )

fn get_fs_test_target() -> OsTarget:
    """Returns x86_64 filesystem contract target with NVMe + FAT32 media.

    The target entry is filesystem-specific and the disk image is supplied by
    the x64-nvme-fat32 scenario. Keeping the entry target separate lets SPipe
    reuse the same named-scenario machinery as other QEMU lanes while binding
    the FAT32 contract to the dedicated fs test program.
    """
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/09_embedded/simple_os/arch/x86_64/fs_test_entry.spl",
        linker_script: "examples/09_embedded/simple_os/arch/x86_64/linker.ld",
        target_triple: "x86_64-unknown-none",
        output: "build/os/simpleos_fs_test_32.elf",
        qemu_system: "qemu-system-x86_64",
        qemu_machine: "q35",
        qemu_cpu: "qemu64",
        qemu_memory: "384M",
        qemu_bios: "",
        qemu_extra: ["-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"],
        gui_mode: false
    )

fn get_browser_soft_target() -> OsTarget:
    """Returns the x86_64 wrapper target for the browser software smoke test.

    The x86_64 baremetal build is post-processed to ELF32 so QEMU -kernel
    can boot the multiboot image.
    """
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/09_embedded/simple_os/arch/x86_64/browser_soft_entry.spl",
        linker_script: "examples/09_embedded/simple_os/arch/x86_64/linker.ld",
