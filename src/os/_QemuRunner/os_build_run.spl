# SimpleOS QEMU runner — target enumeration, OS native build pipeline, QEMU
# command construction, and run_os entry points.
use os.qemu_runner.*
# SimpleOS QEMU Runner — Multi-Architecture Boot & Test
#
# Provides build + run + test functionality for all 6 architectures.
# Usage:
#   bin/simple os build --arch=x86_64
#   bin/simple os run --arch=riscv64
#   bin/simple os test --arch=all

use os.kernel.arch.arch_context.{Architecture}
use os.packages.os_packages.{os_version}
use os.port.simpleos_multiplatform_build.{
    SimpleOsLaneContract,
    SimpleOsLaneKind,
    simpleos_platform_default_entry,
    simpleos_platform_disk_image_output,
    simpleos_platform_linker_script,
    simpleos_platform_native_target,
    simpleos_platform_qemu_acceptance_lane,
    simpleos_platform_qemu_cpu,
    simpleos_platform_qemu_lane,
    simpleos_platform_qemu_machine,
    simpleos_platform_qemu_smoke_lane,
    simpleos_platform_qemu_system,
    simpleos_platform_kernel_output,
    simpleos_platform_target_by_name
}
use os.desktop_qemu_contract.{
    clear_qemu_serial_log,
    desktop_container_marker_fragments,
    desktop_disk_serial_accepts_completion,
    desktop_disk_serial_log_path,
    desktop_uefi_serial_accepts_completion,
    desktop_uefi_serial_log_path,
    desktop_wine_exec_env_marker_contract_accepts,
    desktop_wine_exec_env_required_marker_fragments,
    print_desktop_disk_missing_markers,
    print_desktop_uefi_missing_markers,
    qemu_serial_log_contains,
    read_qemu_serial_log,
    run_x64_desktop_disk_probe,
    run_x64_wm_simple_web_probe,
    wm_simple_web_serial_log_path
}
use os.toolchain_vfs_probe_contract.{
    print_toolchain_vfs_probe_missing_markers,
    toolchain_vfs_probe_serial_accepts_completion
}
use os.ssh_qemu_contract.{run_x64_ssh_probe}
use hardware.riscv_common.core.riscv_formal.{verify_rv64_qemu_user_proof_contract}
use std.nogc_sync_mut.io.process_ops.{process_run_timeout}
use std.nogc_sync_mut.io.dir_ops.{dir_create_all, dir_remove_all}
use std.nogc_sync_mut.io.env_ops.{env_get, env_set, cwd}
use std.nogc_sync_mut.io.file_ops.{file_delete, file_exists, file_read}
use std.nogc_sync_mut.ffi.io.{file_write_text, path_absolute}

fn get_all_targets() -> [OsTarget]:
    """Returns all 6 architecture targets."""
    [
        get_qemu_target(Architecture.X86_64),
        get_qemu_target(Architecture.X86),
        get_qemu_target(Architecture.Riscv64),
        get_qemu_target(Architecture.Riscv32),
        get_qemu_target(Architecture.Arm64),
        get_qemu_target(Architecture.Arm32)
    ]

fn arch_from_name(name: text) -> Architecture?:
    """Parse architecture name string to Architecture enum.

    Accepts: x86_64, x86_32, x86, i386, i686, riscv64, riscv32, arm64, aarch64, arm32, armv7.
    Returns nil for unrecognized names.
    """
    if name == "x86_64":
        Some(Architecture.X86_64)
    elif name == "x86_32" or name == "x86" or name == "i386" or name == "i686":
        Some(Architecture.X86)
    elif name == "riscv64":
        Some(Architecture.Riscv64)
    elif name == "riscv32":
        Some(Architecture.Riscv32)
    elif name == "arm64" or name == "aarch64":
        Some(Architecture.Arm64)
    elif name == "arm32" or name == "armv7":
        Some(Architecture.Arm32)
    else:
        nil

fn arch_display_name(arch: Architecture) -> text:
    """Human-readable name for an architecture."""
    match arch:
        Architecture.X86_64: "x86_64"
        Architecture.X86: "x86_32"
        Architecture.Riscv64: "riscv64"
        Architecture.Riscv32: "riscv32"
        Architecture.Arm64: "arm64"
        Architecture.Arm32: "arm32"

# ===========================================================================
# Build
# ===========================================================================

var _last_successful_build_entry: text = ""
var _last_successful_build_output: text = ""
var _last_successful_build_backend: text = ""
var _last_successful_build_target: text = ""

fn build_os(target: OsTarget) -> bool:
    build_os_with_backend(target, _os_build_backend_for_target(target))

pub fn os_native_build_sources(target: OsTarget) -> [text]:
    """Return the source roots passed to `simple native-build` for an OS target."""
    _build_sources(target)

pub fn os_native_build_env_prefix(target: OsTarget, objcopy_prefix: text) -> text:
    """Return the build environment prefix for an OS target."""
    _build_env_prefix(target, objcopy_prefix)

fn os_native_build_args(target: OsTarget, backend: text) -> [text]:
    """Build the argv passed to `simple native-build` for an OS target."""
    val backend_name = if backend == "llvm": "llvm" else: "cranelift"
    val log_mode = _os_build_log_mode()
    var args: [text] = ["native-build"]
    for source in _build_sources(target):
        args.push("--source")
        args.push(source)
    args.push("--backend")
    args.push(backend_name)
    if target.arch == Architecture.X86_64 and target.target_triple == "x86_64-unknown-none":
        # QEMU's portable x86_64 CPU profile does not guarantee BMI/AVX.
        # Build freestanding kernels for the baseline ISA unless a target
        # explicitly opts into a richer CPU model.
        args.push("--cpu")
        args.push("x86-64-v1")
    if _is_wm_simple_web_check_target(target):
        args.push("--opt-level=none")
    elif _is_riscv32_smoke_target(target):
        args.push("--opt-level=standard")
    else:
        args.push("--opt-level=aggressive")
    args.push("--log")
    args.push(log_mode)
    if _is_riscv32_smoke_target(target):
        args.push("--timeout")
        args.push("840")
    elif _is_wm_simple_web_check_target(target):
        # Keep the worker timeout below the OS runner's 900s outer timeout so
        # timed-out wm-simple-web builds do not leave orphaned workers.
        args.push("--timeout")
        args.push("870")
    elif _is_arm64_desktop_engine2d_target(target):
        args.push("--timeout")
        args.push("870")
    elif _is_arm64_wm_qemu_target(target) or _is_arm_fs_exec_target(target) or _is_riscv_fs_exec_target(target) or _is_riscv64_display_smoke_target(target) or _is_riscv64_hosted_target(target):
        args.push("--timeout")
        args.push("180")
    elif _is_riscv64_live_helper_target(target):
        args.push("--timeout")
        args.push("180")
    elif _is_ssh_live_target(target):
        # The SSH live image pulls in the full network/storage/userland slice,
        # and several reachable modules routinely exceed short worker budgets
        # on cold builds even when the lane is healthy.
        val outer_timeout_secs = _os_build_timeout_ms() / 1000
        var worker_timeout_secs = 180
        if outer_timeout_secs > 210:
            worker_timeout_secs = outer_timeout_secs - 30
        elif outer_timeout_secs > 1:
            worker_timeout_secs = outer_timeout_secs - 1
        args.push("--timeout")
        args.push(worker_timeout_secs.to_text())
    args.push("--entry-closure")
    args.push("--entry")
    args.push(target.entry)
    args.push("--target")
    args.push(target.target_triple)
    args.push("-o")
    args.push(target.output)
    args.push("--linker-script")
    args.push(target.linker_script)
    args

fn build_os_with_backend(target: OsTarget, backend: text) -> bool:
    """Builds the OS kernel for the given target.

    Runs the native-build command through the process facade. Returns true on success.

    Phase-level diagnostics are printed so a stalled build identifies which phase
    ran long rather than surfacing as a generic 'Process timed out'. The timeout
    defaults to 15 minutes and can be overridden with SIMPLE_OS_BUILD_TIMEOUT_MS.
    """
    val arch_label = arch_display_name(target.arch)
    val backend_name = if backend == "llvm": "llvm" else: "cranelift"
    val cached_build_matches = _last_successful_build_entry == target.entry and _last_successful_build_output == target.output and _last_successful_build_backend == backend_name and _last_successful_build_target == target.target_triple
    if cached_build_matches and file_exists(target.output):
        print "[build][{arch_label}] phase=native-build cached output={target.output}"
        return true
    val build_marker = if _is_riscv64_live_helper_target(target): _ssh_live_build_marker_value(backend) else: ""
    val log_mode = _os_build_log_mode()
    val timeout_ms = _os_build_timeout_ms()
    val args = os_native_build_args(target, backend_name)
    val objcopy_prefix = _objcopy_path_prefix()
    val simple_bin = _find_simple_binary_for_target(target, backend_name)
    if simple_bin == "":
        _remove_stale_build_output(target)
        print "[build][{arch_label}] phase=tooling FAILED: no runnable pure-Simple compiler"
        return false
    val stamp_content = _native_build_stamp_content(target, backend_name, args, simple_bin, log_mode)
    if build_marker == "" and _native_build_cache_hit(target, stamp_content, simple_bin):
        print "[build][{arch_label}] phase=native-build persistent-cache output={target.output}"
        _last_successful_build_entry = target.entry
        _last_successful_build_output = target.output
        _last_successful_build_backend = backend_name
        _last_successful_build_target = target.target_triple
        return true
    val old_bootstrap = env_get("SIMPLE_BOOTSTRAP") ?? ""
    val old_lib = env_get("SIMPLE_LIB") ?? ""
    val old_boot_minimal = env_get("SIMPLE_BOOT_MINIMAL") ?? ""
    val old_stub_env = env_get("SIMPLE_ALLOW_FREESTANDING_STUBS") ?? ""
    val old_log_mode = env_get("SIMPLE_OS_LOG_MODE") ?? ""
    val old_path = env_get("PATH") ?? ""
    val old_build_marker = env_get("SIMPLE_SSH_LIVE_BUILD_MARKER") ?? ""
    if not _prepare_build_output(target, build_marker):
        _cleanup_generated_build_helpers(build_marker)
        _restore_build_env(old_bootstrap, old_lib, old_boot_minimal, old_stub_env, old_log_mode, old_path, old_build_marker)
        print "[build][{arch_label}] phase=prepare FAILED output={target.output}"
        return false

    print "[build][{arch_label}] phase=plan entry={target.entry} target={target.target_triple} backend={backend_name} log={log_mode}"
    if _needs_elf32_wrap(target) and objcopy_prefix == "":
        print "[build][{arch_label}] phase=tooling FAILED: llvm-objcopy not found for {target.entry}"
        _cleanup_generated_build_helpers(build_marker)
        _restore_build_env(old_bootstrap, old_lib, old_boot_minimal, old_stub_env, old_log_mode, old_path, old_build_marker)
        return false

    val env_prefix = _build_env_prefix(target, objcopy_prefix)
    if not _apply_build_env(target, objcopy_prefix):
        print "[build][{arch_label}] phase=env FAILED could not export build environment"
        _cleanup_generated_build_helpers(build_marker)
        _restore_build_env(old_bootstrap, old_lib, old_boot_minimal, old_stub_env, old_log_mode, old_path, old_build_marker)
        return false
    val started_ms = _now_ms()
    print "[build][{arch_label}] phase=spawn timeout_ms={timeout_ms}"
    if env_prefix != "":
        print "[build][{arch_label}] env: {env_prefix}"
    print "[build][{arch_label}] cmd: {simple_bin} {args.join(" ")}"
    val (stdout, stderr, exit_code) = _run_candidate_pinned(simple_bin, args, timeout_ms)
    val elapsed_ms = _now_ms() - started_ms
    if exit_code != 0:
        _write_bootstrap_result(target, false, false, backend_name)
        _write_native_build_failure_log(target, backend_name, args, stdout, stderr, exit_code, elapsed_ms)
        print "[build][{arch_label}] phase=native-build FAILED exit={exit_code} elapsed_ms={elapsed_ms} timeout_ms={timeout_ms}"
        _print_native_build_failure_hint(arch_label, backend_name, stderr)
        if stdout != "":
            print "[build][{arch_label}] stdout tail:\n{_tail_lines(stdout, 20)}"
        if stderr != "":
            print "[build][{arch_label}] stderr tail:\n{_tail_lines(stderr, 40)}"
        _cleanup_generated_build_helpers(build_marker)
        _restore_build_env(old_bootstrap, old_lib, old_boot_minimal, old_stub_env, old_log_mode, old_path, old_build_marker)
        return false
    print "[build][{arch_label}] phase=native-build OK elapsed_ms={elapsed_ms}"
    if not file_exists(target.output):
        _write_bootstrap_result(target, false, false, backend_name)
        print "[build][{arch_label}] phase=artifact FAILED output missing: {target.output}"
        _cleanup_generated_build_helpers(build_marker)
        _restore_build_env(old_bootstrap, old_lib, old_boot_minimal, old_stub_env, old_log_mode, old_path, old_build_marker)
        return false
    if build_marker != "":
        print "[build][{arch_label}] phase=artifact OK marker={build_marker}"
    _write_bootstrap_result(target, true, false, backend_name)
    _last_successful_build_entry = target.entry
    _last_successful_build_output = target.output
    _last_successful_build_backend = backend_name
    _last_successful_build_target = target.target_triple
    if build_marker == "":
        _write_native_build_stamp(target, stamp_content)
    _restore_build_env(old_bootstrap, old_lib, old_boot_minimal, old_stub_env, old_log_mode, old_path, old_build_marker)
    true

fn _native_build_stamp_path(target: OsTarget) -> text:
    target.output + ".build_stamp"

fn _native_build_stamp_content(target: OsTarget, backend_name: text, args: [text], simple_bin: text, log_mode: text) -> text:
    "entry=" + target.entry + "\n" +
        "output=" + target.output + "\n" +
        "target=" + target.target_triple + "\n" +
        "linker=" + target.linker_script + "\n" +
        "backend=" + backend_name + "\n" +
        "log=" + log_mode + "\n" +
        "simple_bin=" + simple_bin + "\n" +
        "sources=" + _build_sources(target).join("|") + "\n" +
        "args=" + args.join("|") + "\n"

fn _write_native_build_stamp(target: OsTarget, content: text):
    val stamp_path = _native_build_stamp_path(target)
    if not file_write_text(stamp_path, content):
        print "[build] warning: could not write native-build stamp: {stamp_path}"

fn _path_newer_than_output(path: text, output: text) -> bool:
    if not file_exists(path):
        return false
    val (stdout, _stderr, exit_code) = process_run_timeout("find", [path, "-newer", output, "-print", "-quit"], 10000)
    exit_code != 0 or stdout != ""

fn _native_build_inputs_newer_than_output(target: OsTarget, simple_bin: text) -> bool:
    if _path_newer_than_output(target.linker_script, target.output):
        return true
    if _path_newer_than_output(simple_bin, target.output):
        return true
    for source in _build_sources(target):
        if _path_newer_than_output(source, target.output):
            return true
    false

fn _native_build_cache_hit(target: OsTarget, expected_stamp: text, simple_bin: text) -> bool:
    if not file_exists(target.output):
        return false
    val stamp_path = _native_build_stamp_path(target)
    if not file_exists(stamp_path):
        return false
    if file_read(stamp_path) != expected_stamp:
        return false
    not _native_build_inputs_newer_than_output(target, simple_bin)

fn _objcopy_path_prefix() -> text:
    # macOS Homebrew locations
    if file_exists("/opt/homebrew/opt/llvm/bin/llvm-objcopy"):
        return "/opt/homebrew/opt/llvm/bin"
    if file_exists("/usr/local/opt/llvm/bin/llvm-objcopy"):
        return "/usr/local/opt/llvm/bin"
    # Linux system locations (Debian/Ubuntu packaged LLVM)
    if file_exists("/usr/bin/llvm-objcopy"):
        return "/usr/bin"
    if file_exists("/usr/lib/llvm-20/bin/llvm-objcopy"):
        return "/usr/lib/llvm-20/bin"
    if file_exists("/usr/lib/llvm-19/bin/llvm-objcopy"):
        return "/usr/lib/llvm-19/bin"
    if file_exists("/usr/lib/llvm-18/bin/llvm-objcopy"):
        return "/usr/lib/llvm-18/bin"
    if file_exists("/usr/lib/llvm-17/bin/llvm-objcopy"):
        return "/usr/lib/llvm-17/bin"
    ""

fn _candidate_identity_env_args(candidate: text) -> [text]:
    var pinned_candidate = path_absolute(candidate)
    if pinned_candidate == "":
        pinned_candidate = candidate
    [
        "SIMPLE_BINARY={pinned_candidate}",
        "SIMPLE_BIN={pinned_candidate}",
        "SIMPLE_BOOTSTRAP_DRIVER={pinned_candidate}",
        "SIMPLE_FRONTEND_DELEGATE={pinned_candidate}",
        "SIMPLE_FRONTEND_DELEGATED=1",
        "SIMPLE_NO_STUB_FALLBACK=1",
    ]

fn _candidate_admission_env_args(candidate: text) -> [text]:
    var env_args = _candidate_identity_env_args(candidate)
    env_args.push("SIMPLE_EXECUTION_MODE=")
    env_args.push("SIMPLE_NATIVE_BUILD_FORCE_WORKER=0")
    env_args.push("SIMPLE_BOOTSTRAP=0")
    env_args.push("SIMPLE_LIB={cwd()}/src")
    env_args

fn _run_candidate_with_env(candidate: text, args: [text], timeout_ms: i64, env_args: [text]) -> (text, text, i32):
    var command_args = env_args
    command_args.push(candidate)
    for arg in args:
        command_args.push(arg)
    process_run_timeout("env", command_args, timeout_ms)

fn _run_candidate_pinned(candidate: text, args: [text], timeout_ms: i64) -> (text, text, i32):
    _run_candidate_with_env(candidate, args, timeout_ms, _candidate_identity_env_args(candidate))

fn _run_candidate_admission_pinned(candidate: text, args: [text], timeout_ms: i64) -> (text, text, i32):
    _run_candidate_with_env(candidate, args, timeout_ms, _candidate_admission_env_args(candidate))

fn _candidate_exact_five(stdout: text) -> bool:
    stdout == "5" or stdout == "5\n" or stdout == "5\r\n"

fn _candidate_frontend_smoke(candidate: text) -> bool:
    var temp_root = env_get("TMPDIR") ?? ""
    if temp_root == "":
        temp_root = "/tmp"
    while temp_root.len() > 1 and temp_root.ends_with("/"):
        temp_root = temp_root[0:temp_root.len() - 1]
    val probe_prefix = "{temp_root}/simpleos-qemu-admission."
    val (probe_dir_stdout, _, probe_dir_exit) = process_run_timeout(
        "mktemp", ["-d", probe_prefix + "XXXXXX"], 5000
    )
    if probe_dir_exit != 0:
        return false
    val probe_dir = probe_dir_stdout.trim()
    if not probe_dir.starts_with(probe_prefix) or not file_exists(probe_dir):
        return false

    val probe_output = probe_dir + "/p2_add"
    val probe_log = probe_dir + "/build.log"
    val build_args = [
        "native-build",
        "--backend", "cranelift",
        "--runtime-bundle", "core-c-bootstrap",
        "--entry-closure",
        "--entry", "scripts/check/cert/redeploy_gate/fixtures/p2_add.spl",
        "--cache-dir", probe_dir + "/cache",
        "--mode", "one-binary",
        "--output", probe_output,
    ]
    val (build_stdout, build_stderr, build_exit) = _run_candidate_admission_pinned(
        candidate, build_args, 60000
    )
    val log_ok = file_write_text(probe_log, build_stdout + "\n" + build_stderr)
    var accepted = false
    if build_exit == 0 and log_ok and file_exists(probe_output):
        val (run_stdout, _, run_exit) = process_run_timeout(probe_output, [], 5000)
        accepted = run_exit == 0 and _candidate_exact_five(run_stdout)
    val cleanup_ok = dir_remove_all(probe_dir) == 0
    accepted and cleanup_ok

fn _simple_binary_is_valid(candidate: text) -> bool:
    """Validate a candidate with version and bounded frontend checks.

    Guards against seed, stale-ABI, and corrupt binaries before any QEMU build.
    """
    if not file_exists(candidate):
        return false
    val (stdout, stderr, exit_code) = process_run_timeout(candidate, ["--version"], 5000)
    val version = stdout + "\n" + stderr
    if exit_code != 0 or version.trim() == "" or version.contains("bootstrap seed only"):
        return false
    _candidate_frontend_smoke(candidate)

fn _simple_binary_has_native_build_contract(candidate: text, backend_name: text) -> bool:
    # This is a bounded CLI liveness/command-surface probe. The real build is
    # still authoritative for backend runtime/toolchain availability.
    if not _simple_binary_is_valid(candidate):
        return false
    val probe_args = [
        "native-build",
        "--backend", backend_name,
        "--entry", "src/app/cli/main.spl",
        "--mode", "definitely-invalid-mode"
    ]
    val (stdout, stderr, exit_code) = _run_candidate_admission_pinned(candidate, probe_args, 5000)
    val diagnostic = "Error: invalid --mode 'definitely-invalid-mode' (expected dynload or one-binary)"
    exit_code == 1 and (stdout + "\n" + stderr).contains(diagnostic)

fn _find_simple_binary() -> text:
    val env_bin = env_get("SIMPLE_BINARY") ?? ""
    if env_bin != "" and _simple_binary_is_valid(env_bin):
        return env_bin
    val env_simple_bin = env_get("SIMPLE_BIN") ?? ""
    if env_simple_bin != "" and _simple_binary_is_valid(env_simple_bin):
        return env_simple_bin
    # Probe in priority order. Prefer freshly built local binaries first so
    # QEMU/native-build lanes see the current source tree instead of an older
    # release artifact that merely still passes `--version`.
    # Each candidate must pass version and a bounded checked-in frontend smoke,
    # so stale or segfaulting binaries fall through.
    val candidates: [text] = [
        "release/x86_64-unknown-linux-gnu/simple",
        "bin/simple",
        "bin/release/aarch64-apple-darwin-macho/simple",
        "bin/release/macos-arm64/simple",
        "bin/release/darwin-aarch64/simple",
        "bin/release/macos-x86_64/simple",
        "bin/release/linux-x86_64/simple",
    ]
    for cand in candidates:
        if _simple_binary_is_valid(cand):
            return cand
    ""

fn _find_simple_binary_for_target(target: OsTarget, backend_name: text) -> text:
    val env_bin = env_get("SIMPLE_BINARY") ?? ""
    if env_bin != "" and _simple_binary_has_native_build_contract(env_bin, backend_name):
        return env_bin
    val env_simple_bin = env_get("SIMPLE_BIN") ?? ""
    if env_simple_bin != "" and _simple_binary_has_native_build_contract(env_simple_bin, backend_name):
        return env_simple_bin
    val candidates: [text] = [
        "release/x86_64-unknown-linux-gnu/simple",
        "bin/simple",
        "bin/release/aarch64-apple-darwin-macho/simple",
        "bin/release/macos-arm64/simple",
        "bin/release/darwin-aarch64/simple",
        "bin/release/macos-x86_64/simple",
        "bin/release/linux-x86_64/simple",
    ]
    for cand in candidates:
        if _simple_binary_has_native_build_contract(cand, backend_name):
            return cand
    ""

fn _build_sources(target: OsTarget) -> [text]:
    if _is_arm64_wm_qemu_target(target) or _is_arm64_desktop_engine2d_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/09_embedded/simple_os"]
    if _is_host_gpu_probe_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/09_embedded/simple_os"]
    if _is_riscv64_live_helper_target(target):
        return ["build/os/generated", "src", "examples"]
    if _is_riscv64_smoke_target(target):
        return ["build/os/generated", "src/os", "src/lib"]
    if _is_riscv32_smoke_target(target):
        return ["build/os/generated", "src/os", "src/lib"]
    if _is_ssh_live_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/09_embedded/simple_os"]
    if _is_x86_32_probe_target(target):
        return ["build/os/generated", "examples/09_embedded/simple_os/arch/x86_32"]
    if _is_x86_64_kernel_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/09_embedded/simple_os"]
    if _is_browser_wrapper_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/09_embedded/simple_os"]
    if _is_desktop_wrapper_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/09_embedded/simple_os"]
    if _is_wm_simple_web_check_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/09_embedded/simple_os"]
    if _is_gui_engine2d_wrapper_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/09_embedded/simple_os"]
    if _is_js_browser_runtime_probe_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/09_embedded/simple_os"]
    if _is_fs_wrapper_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/09_embedded/simple_os"]
    if _is_arm_fs_exec_target(target):
        return ["build/os/generated", "src/os", "examples/09_embedded/simple_os"]
    if _is_riscv64_fs_exec_target(target):
        return ["build/os/generated", "examples/09_embedded/simple_os/arch/riscv64"]
    if _is_riscv64_display_smoke_target(target):
        return ["build/os/generated", "src/os", "src/lib", "examples/09_embedded/simple_os"]
    if _is_riscv64_hosted_target(target):
        return ["build/os/generated", "src", "examples"]
    if _is_riscv32_fs_exec_target(target):
        return ["build/os/generated", "examples/09_embedded/simple_os/arch/riscv32"]
    ["build/os/generated", "src", "examples"]

fn _build_env_prefix(target: OsTarget, objcopy_prefix: text) -> text:
    var envs: [text] = []
    if _is_x86_64_kernel_target(target) or _is_x86_32_probe_target(target) or _uses_baremetal_wrapper_profile(target):
        envs.push("SIMPLE_BOOTSTRAP=1")
        envs.push("SIMPLE_LIB=\"$(pwd)/src\"")
    if _is_arm64_wm_qemu_target(target) or _is_arm64_desktop_engine2d_target(target):
        envs.push("SIMPLE_BOOTSTRAP=1")
        envs.push("SIMPLE_LIB=\"$(pwd)/src\"")
        envs.push("SIMPLE_ALLOW_FREESTANDING_STUBS=1")
    if _is_arm_fs_exec_target(target):
        envs.push("SIMPLE_BOOT_MINIMAL=1")
    if _needs_arm_freestanding_stub_env(target):
        envs.push("SIMPLE_ALLOW_FREESTANDING_STUBS=1")
    if _is_riscv64_display_smoke_target(target):
        envs.push("SIMPLE_BOOTSTRAP=1")
        envs.push("SIMPLE_LIB=\"$(pwd)/src\"")
    if _is_riscv_fs_exec_target(target) or _is_riscv64_display_smoke_target(target) or _is_riscv64_hosted_target(target) or _is_riscv64_live_helper_target(target) or _is_host_gpu_probe_target(target):
        envs.push("SIMPLE_BOOT_MINIMAL=1")
    if _needs_freestanding_stub_env(target):
        envs.push("SIMPLE_ALLOW_FREESTANDING_STUBS=1")
    envs.push("SIMPLE_OS_LOG_MODE={_os_build_log_mode()}")
    if objcopy_prefix != "":
        envs.push("PATH=\"{objcopy_prefix}:$PATH\"")
    envs.join(" ")

fn _is_ssh_live_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/x86_64/ssh_live_entry.spl" or _is_riscv64_ssh_live_target(target)

fn _is_riscv64_live_helper_target(target: OsTarget) -> bool:
    _is_riscv64_ssh_live_target(target) or _is_riscv64_x25519_probe_target(target)

fn _is_riscv64_ssh_live_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/riscv64/ssh_live_entry.spl" and
        target.output == "build/os/simpleos_riscv64_ssh_live.elf"

fn _is_riscv64_x25519_probe_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/riscv64/x25519_probe_entry.spl" and
        target.output == "build/os/simpleos_riscv64_x25519_probe.elf"

fn _ssh_live_build_marker_value(backend: text) -> text:
    "ssh-live-build:{backend}:{_now_ms()}"

fn _ssh_live_build_marker_path() -> text:
    "build/os/generated/ssh_live_build_marker.spl"

fn _ssh_live_build_marker_source(marker: text) -> text:
    "pub fn ssh_live_build_marker() -> text:\n" +
        "    \"" + marker + "\"\n"

fn _simpleos_log_config_path() -> text:
    "build/os/generated/generated/simpleos_log_config.spl"

fn _legacy_simpleos_log_config_path() -> text:
    "build/os/generated/lib/simpleos_log_config.spl"

fn _simpleos_log_config_source(enabled: bool) -> text:
    val default_value = if enabled: "true" else: "false"
    "val SIMPLEOS_LOG_COMPILED: bool = {default_value}\n" +
        "\n" +
        "fn simpleos_log_compile_enabled() -> bool:\n" +
        "    SIMPLEOS_LOG_COMPILED\n" +
        "\n" +
        "fn simpleos_log_compile_mode_name() -> text:\n" +
        "    if SIMPLEOS_LOG_COMPILED:\n" +
        "        return \"on\"\n" +
        "    \"off\"\n"

fn _remove_stale_build_output(target: OsTarget) -> bool:
    if file_exists(target.output):
        if not file_delete(target.output):
            print "[build] could not remove stale artifact: {target.output}"
            return false
    true

fn _prepare_build_output(target: OsTarget, build_marker: text) -> bool:
    if not _remove_stale_build_output(target):
        return false
    if file_exists(_legacy_simpleos_log_config_path()):
        file_delete(_legacy_simpleos_log_config_path())
    if not dir_create_all("build/os/generated/generated"):
        print "[build] could not create build/os/generated/generated"
        return false
    if not file_write_text(_simpleos_log_config_path(), _simpleos_log_config_source(_os_build_log_mode() == "on")):
        print "[build] could not write SimpleOS log compile config"
        return false
    if build_marker != "":
        if not file_write_text(_ssh_live_build_marker_path(), _ssh_live_build_marker_source(build_marker)):
            print "[build] could not write SSH live build marker"
            return false
        if not env_set("SIMPLE_SSH_LIVE_BUILD_MARKER", build_marker):
            print "[build] could not export SIMPLE_SSH_LIVE_BUILD_MARKER"
            return false
    true

fn _cleanup_generated_build_helpers(build_marker: text):
    if file_exists(_simpleos_log_config_path()):
        file_delete(_simpleos_log_config_path())
    if build_marker != "" and file_exists(_ssh_live_build_marker_path()):
        file_delete(_ssh_live_build_marker_path())
    if build_marker != "":
        env_set("SIMPLE_SSH_LIVE_BUILD_MARKER", "")

fn _restore_build_env(old_bootstrap: text, old_lib: text, old_boot_minimal: text, old_stub_env: text, old_log_mode: text, old_path: text, old_build_marker: text):
    env_set("SIMPLE_BOOTSTRAP", old_bootstrap)
    env_set("SIMPLE_LIB", old_lib)
    env_set("SIMPLE_BOOT_MINIMAL", old_boot_minimal)
    env_set("SIMPLE_ALLOW_FREESTANDING_STUBS", old_stub_env)
    env_set("SIMPLE_OS_LOG_MODE", old_log_mode)
    env_set("PATH", old_path)
    env_set("SIMPLE_SSH_LIVE_BUILD_MARKER", old_build_marker)

fn _apply_build_env(target: OsTarget, objcopy_prefix: text) -> bool:
    val cwd = cwd()
    if _is_x86_64_kernel_target(target) or _is_x86_32_probe_target(target) or _uses_baremetal_wrapper_profile(target):
        if not env_set("SIMPLE_BOOTSTRAP", "1"):
            return false
        if not env_set("SIMPLE_LIB", "{cwd}/src"):
            return false
    if _is_arm64_desktop_engine2d_target(target):
        if not env_set("SIMPLE_BOOTSTRAP", "1"):
            return false
        if not env_set("SIMPLE_LIB", "{cwd}/src"):
            return false
        if not env_set("SIMPLE_ALLOW_FREESTANDING_STUBS", "1"):
            return false
    if _is_arm_fs_exec_target(target):
        if not env_set("SIMPLE_BOOT_MINIMAL", "1"):
            return false
        if not env_set("SIMPLE_LIB", "{cwd}/src"):
            return false
    if _needs_arm_freestanding_stub_env(target):
        if not env_set("SIMPLE_ALLOW_FREESTANDING_STUBS", "1"):
            return false
    if _is_riscv64_display_smoke_target(target):
        if not env_set("SIMPLE_BOOTSTRAP", "1"):
            return false
        if not env_set("SIMPLE_LIB", "{cwd}/src"):
            return false
    if _is_riscv_fs_exec_target(target) or _is_riscv64_display_smoke_target(target) or _is_riscv64_hosted_target(target) or _is_riscv64_live_helper_target(target) or _is_host_gpu_probe_target(target):
        if not env_set("SIMPLE_BOOT_MINIMAL", "1"):
            return false
    if _needs_freestanding_stub_env(target):
        if not env_set("SIMPLE_ALLOW_FREESTANDING_STUBS", "1"):
            return false
    if not env_set("SIMPLE_OS_LOG_MODE", _os_build_log_mode()):
        return false
    if objcopy_prefix != "":
        val old_path = env_get("PATH") ?? ""
        if old_path == "":
            if not env_set("PATH", objcopy_prefix):
                return false
        else:
            if not env_set("PATH", "{objcopy_prefix}:{old_path}"):
                return false
    true

fn _needs_elf32_wrap(target: OsTarget) -> bool:
    _uses_baremetal_wrapper_profile(target)

fn _uses_baremetal_wrapper_profile(target: OsTarget) -> bool:
    _is_browser_wrapper_target(target) or _is_desktop_wrapper_target(target) or _is_gui_engine2d_wrapper_target(target) or _is_js_browser_runtime_probe_target(target) or _is_fs_wrapper_target(target)

fn _needs_freestanding_stub_env(target: OsTarget) -> bool:
    _is_x86_64_kernel_target(target) or _is_desktop_wrapper_target(target) or _is_gui_engine2d_wrapper_target(target) or _is_js_browser_runtime_probe_target(target) or _is_fs_wrapper_target(target)

fn _is_x86_64_kernel_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/x86_64/os_entry.spl"

fn _is_host_gpu_probe_target(target: OsTarget) -> bool:
    target.entry.ends_with("/host_gpu_smoke_entry.spl")

fn _is_x86_32_browser_probe_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/x86_32/browser_probe_entry.spl"

fn _is_x86_32_probe_target(target: OsTarget) -> bool:
    target.entry.starts_with("examples/09_embedded/simple_os/arch/x86_32/")

fn _is_browser_wrapper_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/x86_64/browser_soft_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/browser_probe_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/gui_entry_browser.spl"

fn _is_desktop_wrapper_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/x86_64/desktop_e2e_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/gui_entry_desktop.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/desktop_probe_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/ssh_live_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/ssh_x25519_probe_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/sys_gui_008_entry.spl"

fn _is_gui_engine2d_wrapper_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/x86_64/gui_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/gui_entry_engine2d.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/gui_entry_engine2d_min.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/gui_engine2d_primitives_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/gui_entry_engine2d_virtio.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/gpu_test_entry.spl"

fn _is_wm_simple_web_check_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/x86_64/gui_entry_desktop.spl" and
        target.output == "build/os/simpleos_wm_simple_web_check_32.elf"

fn _is_js_browser_runtime_probe_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/x86_64/js_runtime_probe_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/browser_runtime_probe_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/js_env_stack_probe_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/js_object_store_probe_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/js_runtime_browser_state_probe_entry.spl"

fn _is_fs_wrapper_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/x86_64/fs_test_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/x86_64/toolchain_vfs_probe_entry.spl"

fn _is_arm64_wm_qemu_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/arm64/gui_entry_desktop.spl" and
        target.output == "build/os/simpleos_arm64_wm.elf"

fn _is_arm64_desktop_engine2d_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/arm64/gui_entry_desktop.spl" and
        target.output == "build/os/simpleos_arm64_desktop_engine2d.elf"

fn _is_arm_fs_exec_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/arm64/fs_exec_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/arm64/smoke_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/arm32/fs_exec_entry.spl" or
        target.entry == "examples/09_embedded/simple_os/arch/arm32/smoke_entry.spl"

fn _needs_arm_freestanding_stub_env(target: OsTarget) -> bool:
    _is_arm_fs_exec_target(target) and
        target.entry != "examples/09_embedded/simple_os/arch/arm64/fs_exec_entry.spl" and
        target.entry != "examples/09_embedded/simple_os/arch/arm64/smoke_entry.spl" and
        target.entry != "examples/09_embedded/simple_os/arch/arm32/fs_exec_entry.spl" and
        target.entry != "examples/09_embedded/simple_os/arch/arm32/smoke_entry.spl"

fn _is_riscv64_fs_exec_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/riscv64/smoke_entry.spl" and
        target.output == "build/os/simpleos_riscv64_smf_fs.elf"

fn _is_riscv32_fs_exec_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/riscv32/smoke_entry.spl" and
        target.output == "build/os/simpleos_riscv32_smf_fs.elf"

fn _is_riscv64_hosted_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/riscv64/hosted_entry.spl" and
        target.output == "build/os/simpleos_riscv64_hosted.elf"

fn _is_riscv64_smoke_target(target: OsTarget) -> bool:
    target.entry == "src/os/kernel/arch/riscv64/boot.spl" and
        target.output == "build/os/simpleos_riscv64.elf"

fn _is_riscv32_smoke_target(target: OsTarget) -> bool:
    target.entry == "src/os/kernel/arch/riscv32/boot.spl" and
        target.output == "build/os/simpleos_riscv32.elf"

fn _is_riscv64_display_smoke_target(target: OsTarget) -> bool:
    target.entry == "examples/09_embedded/simple_os/arch/riscv64/gui_entry_desktop.spl" and
        target.output == "build/os/simpleos_riscv64_display_smoke.elf"

fn _is_riscv_fs_exec_target(target: OsTarget) -> bool:
    _is_riscv64_fs_exec_target(target) or _is_riscv32_fs_exec_target(target)

# ===========================================================================
# QEMU Command Construction
# ===========================================================================

fn build_qemu_command(target: OsTarget) -> [text]:
    build_qemu_command_with_options(target, qemu_run_options_default())

fn verify_qemu_formal_output(arch: Architecture, output: text) -> Result<text, text>:
    match arch:
        Architecture.Riscv64:
            verify_rv64_qemu_user_proof_contract(output)
        _:
            Ok("no formal qemu contract for {arch_display_name(arch)}")

fn build_qemu_command_with_options(target: OsTarget, options: QemuRunOptions) -> [text]:
    """Returns QEMU command line as a list of strings.

    Includes machine, cpu, memory, serial routing, display mode, no reboot,
    optional BIOS flags, kernel path, and extra architecture-specific flags.
    """
    var args: [text] = []

    # QEMU system binary
    args.push(_qemu_command_binary(target))

    for hardening_arg in qemu_target_hardening_args(target):
        args.push(hardening_arg)

    # Machine and CPU
    args.push("-machine")
    args.push(target.qemu_machine)
    args.push("-cpu")
    args.push(target.qemu_cpu)

    # Memory
    args.push("-m")
    args.push(target.qemu_memory)

    # Serial routing:
    # - headless/test lanes keep serial on stdio
    # - GUI lanes hide boot logs for a macOS-style windowed startup
    args.push("-serial")
    if target.gui_mode and not options.debug_gui_serial:
        args.push("none")
    else:
        args.push("stdio")

    # Display mode: headless for text-mode or --headless override, show window for GUI
    if not target.gui_mode or options.headless:
        args.push("-display")
        args.push("none")

    # Don't reboot on crash
    args.push("-no-reboot")

    # BIOS/firmware (OpenSBI uses "default", empty means no -bios flag)
    if target.qemu_bios == "default":
        args.push("-bios")
        args.push("default")
    elif target.qemu_bios != "":
        args.push("-bios")
        args.push(target.qemu_bios)

    # Kernel ELF
    args.push("-kernel")
    args.push(target.output)

    # Extra architecture-specific flags
    for extra in target.qemu_extra:
        args.push(extra)

    args

fn qemu_target_hardening_args(target: OsTarget) -> [text]:
    """Return host-side QEMU hardening flags for a target launch.

    These flags avoid ambient host/user QEMU configuration and disable the
    interactive HMP monitor. x86_64 lanes that do not intentionally attach a
    netdev also disable networking explicitly so future QEMU defaults cannot
    add a host-facing device by accident.
    """
    var args: [text] = []
    if _target_uses_qemu_x86_64(target):
        args.push("-no-user-config")
        args.push("-monitor")
        args.push("none")
        if not _qemu_extra_enables_network(target.qemu_extra):
            args.push("-net")
            args.push("none")
    args

fn qemu_scenario_hardening_args(scenario: QemuScenario) -> [text]:
    """Return host-side QEMU hardening flags for a named scenario."""
    var args: [text] = []
    if scenario.arch == Architecture.X86_64:
        args.push("-no-user-config")
        args.push("-monitor")
        args.push("none")
        if not _qemu_extra_enables_network(scenario.qemu_extra):
            args.push("-net")
            args.push("none")
    args

fn _target_uses_qemu_x86_64(target: OsTarget) -> bool:
    target.arch == Architecture.X86_64 and target.qemu_system == "qemu-system-x86_64"

fn _qemu_extra_enables_network(qemu_extra: [text]) -> bool:
    for arg in qemu_extra:
        if arg == "-netdev" or arg == "-nic" or arg == "-net":
            return true
        if arg.contains("virtio-net") or arg.contains("e1000") or arg.contains("rtl8139"):
            return true
        if arg.contains("hostfwd="):
            return true
    false

# ===========================================================================
# Run
# ===========================================================================

fn run_os(target: OsTarget) -> bool:
    run_os_with_options(target, qemu_run_options_default())

fn run_os_debug_gui(target: OsTarget) -> bool:
    run_os_with_options(target, qemu_run_options_debug_gui())

fn run_os_headless(target: OsTarget) -> bool:
    run_os_with_options(target, qemu_run_options_headless())

fn run_os_with_options(target: OsTarget, options: QemuRunOptions) -> bool:
    """Runs QEMU with the built kernel for the given target.

    Checks that the binary exists, then spawns QEMU. Returns true on success.
    """
    if not file_exists(target.output):
        print "[run] ERROR: kernel binary not found: {target.output}"
        print "[run] Run 'bin/simple os build --arch={arch_display_name(target.arch)}' first"
        return false
    val cmd_parts = build_qemu_command_with_options(target, options)
    val qemu_bin = cmd_parts[0]
    val qemu_args = cmd_parts.slice(1)
    if target.gui_mode and options.debug_gui_serial:
        print "[run] GUI debug lane enabled: serial output is attached to stdio"
    print "[run] {arch_display_name(target.arch)}: {cmd_parts.join(" ")}"
    val timeout: i64 = if target.gui_mode: 600000 else: 30000
    val (stdout, stderr, exit_code) = process_run_timeout(qemu_bin, qemu_args, timeout)
    if stdout != "":
        print "[run] serial output:\n{stdout}"
    if stderr != "":
        print "[run] stderr:\n{stderr}"
    val success = is_qemu_success(target, exit_code)
    if not success:
        print "[run] FAILED (exit code {exit_code})"
    success

# ===========================================================================
# Test
# ===========================================================================
