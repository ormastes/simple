# Capability restriction and security syscalls.

use os.userlib.syscall_raw

fn pledge(capabilities: [text]) -> Result<bool, text>:
    val joined = capabilities.join(",")
    val result = syscall(40, &joined as u64, joined.len() as u64, 0, 0, 0)
    if result < 0:
        return Err("pledge failed with code {result}")
    Ok(true)

fn unveil(path: text, permissions: text) -> Result<bool, text>:
    val result = syscall(41, &path as u64, path.len() as u64, &permissions as u64, permissions.len() as u64, 0)
    if result < 0:
        return Err("unveil failed with code {result}")
    Ok(true)

fn cap_grant(target_pid: u64, capability: text) -> Result<bool, text>:
    val result = syscall(42, target_pid, &capability as u64, capability.len() as u64, 0, 0)
    if result < 0:
        return Err("cap_grant failed with code {result}")
    Ok(true)
