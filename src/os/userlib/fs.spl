# Filesystem operations via IPC to VFS service and raw syscalls.

use std.nogc_sync_mut.binary_io.{bytes_to_string}
use os.userlib.syscall_raw
use os.userlib.ipc_protocol(VFS_READ, VFS_WRITE, VFS_STAT, VFS_MKDIR, VFS_READDIR, VFS_REMOVE, VFS_RENAME, VFS_MOUNT_LIST)
use os.kernel.types.fs_types(DirEntry, FsNode, FsNodeKind)
use os.kernel.types.ipc_types(IpcPort, IpcMessage)

# Well-known VFS service port
val _VFS_PORT: u64 = 1

fn _vfs_request(method: u32, payload: text) -> Result<text, text>:
    # Connect to VFS service port
    val port_result = syscall(50, _VFS_PORT, 0, 0, 0, 0)
    if port_result < 0:
        return Err("failed to connect to VFS service")
    val conn = port_result as u64

    # Encode method + payload into message
    val msg = "{method}:{payload}"
    val send_result = syscall(51, conn, &msg as u64, msg.len() as u64, 0, 0)
    if send_result < 0:
        return Err("VFS send failed with code {send_result}")

    # Receive response
    var buf_size: u64 = 4096
    var response_buf: [u8] = [0; 4096]
    val recv_result = syscall(52, conn, &response_buf as u64, buf_size, 0, 0)
    if recv_result < 0:
        return Err("VFS recv failed with code {recv_result}")

    # Close connection
    syscall(53, conn, 0, 0, 0, 0)

    val response = bytes_to_string(response_buf.slice(0, recv_result as u64))
    if response.starts_with("ERR:"):
        return Err(response.slice(4, response.len()))
    Ok(response)

fn read_text(path: text) -> Result<text, text>:
    _vfs_request(VFS_READ, path)

fn write_text(path: text, content: text) -> Result<bool, text>:
    val payload = "{path}\0{content}"
    val resp = _vfs_request(VFS_WRITE, payload)?
    Ok(true)

fn stat(path: text) -> Result<FsNode, text>:
    val resp = _vfs_request(VFS_STAT, path)?
    # Parse response into FsNode
    # Response format: "kind:size:name"
    val parts = resp.split(":")
    if parts.len() < 3:
        return Err("malformed stat response")
    val kind_val = parts[0].parse_u8()
    val size_val = parts[1].parse_u64()
    val name_val = parts[2]
    Ok(FsNode(
        kind: FsNodeKind.from_u8(kind_val),
        size: size_val,
        name: name_val
    ))

fn mkdir(path: text) -> Result<bool, text>:
    val resp = _vfs_request(VFS_MKDIR, path)?
    Ok(true)

fn readdir(path: text) -> Result<[DirEntry], text>:
    val resp = _vfs_request(VFS_READDIR, path)?
    var entries: [DirEntry] = []
    if resp.len() == 0:
        return Ok(entries)
    val lines = resp.split("\n")
    var i: u64 = 0
    while i < lines.len() as u64:
        val line = lines[i as i64]
        if line.len() > 0:
            val parts = line.split(":")
            if parts.len() >= 2:
                val kind_val = parts[0].parse_u8()
                val name_val = parts[1]
                entries.push(DirEntry(
                    kind: FsNodeKind.from_u8(kind_val),
                    name: name_val
                ))
        i = i + 1
    Ok(entries)

fn remove(path: text) -> Result<bool, text>:
    val resp = _vfs_request(VFS_REMOVE, path)?
    Ok(true)

fn rename(old_path: text, new_path: text) -> Result<bool, text>:
    val payload = "{old_path}\0{new_path}"
    val resp = _vfs_request(VFS_RENAME, payload)?
    Ok(true)

fn mount(device: text, mount_path: text, fs_type: text) -> Result<bool, text>:
    val payload = "{device}\0{mount_path}\0{fs_type}"
    val result = syscall(37, &payload as u64, payload.len() as u64, 0, 0, 0)
    if result < 0:
        return Err("mount failed with code {result}")
    Ok(true)

fn unmount(path: text) -> Result<bool, text>:
    val result = syscall(38, &path as u64, path.len() as u64, 0, 0, 0)
    if result < 0:
        return Err("unmount failed with code {result}")
    Ok(true)

fn mount_list() -> Result<[text], text>:
    val resp = _vfs_request(VFS_MOUNT_LIST, "")?
    if resp.len() == 0:
        return Ok([])
    val entries = resp.split("\n")
    var result: [text] = []
    var i: u64 = 0
    while i < entries.len() as u64:
        val entry = entries[i as i64]
        if entry.len() > 0:
            result.push(entry)
        i = i + 1
    Ok(result)
