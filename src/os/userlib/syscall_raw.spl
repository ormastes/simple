# Raw syscall invocation for SimpleOS.
#
# Register convention:
# - x86_64: rax = id, rdi/rsi/rdx/r10/r8 = args, result in rax
# - riscv64: a7 = id, a0-a4 = args, result in a0
# - riscv32: a7 = id, a0-a4 = args, result in a0

@cfg(x86_64)
fn syscall(id: u64, arg0: u64, arg1: u64, arg2: u64, arg3: u64, arg4: u64) -> i64:
    var result: i64 = 0
    unsafe:
        asm volatile:
            "mov rax, {id}"
            "mov rdi, {arg0}"
            "mov rsi, {arg1}"
            "mov rdx, {arg2}"
            "mov r10, {arg3}"
            "mov r8,  {arg4}"
            "syscall"
            "mov {out}, rax"
            in(reg) id
            in(reg) arg0
            in(reg) arg1
            in(reg) arg2
            in(reg) arg3
            in(reg) arg4
            out(reg) result
    result

@cfg(riscv64)
fn syscall(id: u64, arg0: u64, arg1: u64, arg2: u64, arg3: u64, arg4: u64) -> i64:
    var result: i64 = 0
    unsafe:
        asm volatile:
            "mv a7, {id}"
            "mv a0, {arg0}"
            "mv a1, {arg1}"
            "mv a2, {arg2}"
            "mv a3, {arg3}"
            "mv a4, {arg4}"
            "ecall"
            "mv {out}, a0"
            in(reg) id
            in(reg) arg0
            in(reg) arg1
            in(reg) arg2
            in(reg) arg3
            in(reg) arg4
            out(reg) result
    result

@cfg(riscv32)
fn syscall(id: u64, arg0: u64, arg1: u64, arg2: u64, arg3: u64, arg4: u64) -> i64:
    val id32 = id as u32
    val arg032 = arg0 as u32
    val arg132 = arg1 as u32
    val arg232 = arg2 as u32
    val arg332 = arg3 as u32
    val arg432 = arg4 as u32
    var result32: u32 = 0
    unsafe:
        asm volatile:
            "mv a7, {id}"
            "mv a0, {arg0}"
            "mv a1, {arg1}"
            "mv a2, {arg2}"
            "mv a3, {arg3}"
            "mv a4, {arg4}"
            "ecall"
            "mv {out}, a0"
            in(reg) id32
            in(reg) arg032
            in(reg) arg132
            in(reg) arg232
            in(reg) arg332
            in(reg) arg432
            out(reg) result32
    result32 as i32 as i64
