# Raw syscall invocation for x86_64 SimpleOS.
#
# Uses the SYSCALL instruction with the standard register convention:
#   rax = syscall id
#   rdi = arg0, rsi = arg1, rdx = arg2, r10 = arg3, r8 = arg4
# Returns the value in rax.

fn syscall(id: u64, arg0: u64, arg1: u64, arg2: u64, arg3: u64, arg4: u64) -> i64:
    val result: i64 = 0
    asm:
        "mov rax, {id}"
        "mov rdi, {arg0}"
        "mov rsi, {arg1}"
        "mov rdx, {arg2}"
        "mov r10, {arg3}"
        "mov r8,  {arg4}"
        "syscall"
        "mov {result}, rax"
    result
