#![allow(unknown_attribute)]
# Raw syscall invocation for SimpleOS.
#
# Register convention:
# - x86_64: rax = id, rdi/rsi/rdx/r10/r8 = args, result in rax
# - riscv64: a7 = id, a0-a4 = args, result in a0
# - riscv32: a7 = id, a0-a4 = args, result in a0

@cfg(x86_64)
fn syscall(id: u64, arg0: u64, arg1: u64, arg2: u64, arg3: u64, arg4: u64) -> i64:
    var result: i64 = 0
    unsafe:
        asm volatile:
            "mov rax, {id}"
            "mov rdi, {arg0}"
            "mov rsi, {arg1}"
            "mov rdx, {arg2}"
            "mov r10, {arg3}"
            "mov r8,  {arg4}"
            "syscall"
            "mov {out}, rax"
            in(reg) id
            in(reg) arg0
            in(reg) arg1
            in(reg) arg2
            in(reg) arg3
            in(reg) arg4
            out(reg) result
    result

@cfg(riscv64)
fn syscall(id: u64, arg0: u64, arg1: u64, arg2: u64, arg3: u64, arg4: u64) -> i64:
    var result: i64 = 0
    unsafe:
        asm volatile:
            "mv a7, {id}"
            "mv a0, {arg0}"
            "mv a1, {arg1}"
            "mv a2, {arg2}"
            "mv a3, {arg3}"
            "mv a4, {arg4}"
            "ecall"
            "mv {out}, a0"
            in(reg) id
            in(reg) arg0
            in(reg) arg1
            in(reg) arg2
            in(reg) arg3
            in(reg) arg4
            out(reg) result
    result

@cfg(riscv32)
fn syscall(id: u64, arg0: u64, arg1: u64, arg2: u64, arg3: u64, arg4: u64) -> i64:
    val id32 = id as u32
    val arg032 = arg0 as u32
    val arg132 = arg1 as u32
    val arg232 = arg2 as u32
    val arg332 = arg3 as u32
    val arg432 = arg4 as u32
    var result32: u32 = 0
    unsafe:
        asm volatile:
            "mv a7, {id}"
            "mv a0, {arg0}"
            "mv a1, {arg1}"
            "mv a2, {arg2}"
            "mv a3, {arg3}"
            "mv a4, {arg4}"
            "ecall"
            "mv {out}, a0"
            in(reg) id32
            in(reg) arg032
            in(reg) arg132
            in(reg) arg232
            in(reg) arg332
            in(reg) arg432
            out(reg) result32
    # Zero-extend to avoid sign-extending heap pointers (bit 31 set)
    # Only sign-extend small negative values (error codes: -1..-255)
    if result32 > 0xFFFFFF00:
        (result32 as i32) as i64
    else:
        result32 as u64 as i64

# ============================================================================
# spm-winfs-llm-suite (AC-3 / AC-4) — privilege + SPM + window wrappers.
#
# The byte-slice arguments travel through the existing 5-arg syscall as a
# (ptr, len) pair in arg0 / arg1. A real raw-pointer helper is not yet
# exposed in userland; callers pass `0 as u64` for the ptr until the pipe
# is wired — this keeps dispatch exercisable in tests without crashing on
# a real kernel run (kernel returns EINVAL for a null ptr).
# ============================================================================

fn sys_priv_check(id_path_bytes: [u8]) -> bool:
    # TODO(spm-winfs-llm-suite): wire raw pointer from `id_path_bytes`.
    val rc = syscall(110 as u64, 0 as u64, id_path_bytes.len() as u64, 0 as u64, 0 as u64, 0 as u64)
    rc != 0 as i64

fn sys_win_register(record_bytes: [u8]) -> u64:
    # TODO(spm-winfs-llm-suite): wire raw pointer from `record_bytes`.
    val rc = syscall(111 as u64, 0 as u64, record_bytes.len() as u64, 0 as u64, 0 as u64, 0 as u64)
    if rc < 0 as i64:
        return 0 as u64
    rc as u64

fn sys_approval_request(intent_bytes: [u8]) -> [u8]:
    # TODO(spm-winfs-llm-suite): wire raw pointer + response buffer.
    val _ = syscall(112 as u64, 0 as u64, intent_bytes.len() as u64, 0 as u64, 0 as u64, 0 as u64)
    []

fn sys_spm_send(req_bytes: [u8]) -> [u8]:
    # TODO(spm-winfs-llm-suite): wire raw pointer + response buffer.
    val _ = syscall(113 as u64, 0 as u64, req_bytes.len() as u64, 0 as u64, 0 as u64, 0 as u64)
    []

fn sys_spm_listen() -> [u8]:
    # TODO(spm-winfs-llm-suite): wire response buffer.
    val _ = syscall(114 as u64, 0 as u64, 0 as u64, 0 as u64, 0 as u64, 0 as u64)
    []
