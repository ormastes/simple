#![allow(unnamed_duplicate_typed_args)]
# Device enumeration via raw syscalls.

use os.userlib.syscall_raw
use os.kernel.types.syscall_types.{new_device_info_buf}
use os.kernel.types.device_mem_types.{new_device_grant}

class DeviceEntry:
    bus: u8
    device: u8
    func: u8
    vendor_id: u16
    device_id: u16
    class_code: u8
    subclass: u8
    class_name: text

fn enumerate_devices() -> Result<[DeviceEntry], text>:
    val count_result = syscall(80, 0, 0, 0, 0, 0)
    if count_result < 0:
        return Err("enumerate_devices failed with code {count_result}")
    val count = count_result as u64
    var devices: [DeviceEntry] = []
    var i: u64 = 0
    while i < count:
        var buf = new_device_info_buf()
        val info_result = syscall(80, 1, i, &buf as u64, 0, 0)
        if info_result >= 0:
            devices.push(DeviceEntry(
                bus: buf.bus,
                device: buf.device,
                func: buf.func,
                vendor_id: buf.vendor_id,
                device_id: buf.device_id,
                class_code: buf.class_code,
                subclass: buf.subclass,
                class_name: device_class_name(buf.class_code, buf.subclass)
            ))
        i = i + 1
    Ok(devices)

fn get_device_info(bus: u8, dev: u8, func: u8) -> Result<DeviceEntry, text>:
    var buf = new_device_info_buf()
    val bdf = (bus as u64) << 16 | (dev as u64) << 8 | (func as u64)
    val result = syscall(81, bdf, &buf as u64, 0, 0, 0)
    if result < 0:
        return Err("get_device_info failed with code {result}")
    Ok(DeviceEntry(
        bus: buf.bus,
        device: buf.device,
        func: buf.func,
        vendor_id: buf.vendor_id,
        device_id: buf.device_id,
        class_code: buf.class_code,
        subclass: buf.subclass,
        class_name: device_class_name(buf.class_code, buf.subclass)
    ))

fn device_class_name(class_code: u8, subclass: u8) -> text:
    match class_code:
        0x00: "Unclassified"
        0x01: match subclass:
            0x00: "SCSI Bus Controller"
            0x01: "IDE Controller"
            0x06: "SATA Controller"
            0x08: "NVMe Controller"
            _: "Mass Storage Controller"
        0x02: match subclass:
            0x00: "Ethernet Controller"
            0x80: "Other Network Controller"
            _: "Network Controller"
        0x03: match subclass:
            0x00: "VGA Compatible Controller"
            _: "Display Controller"
        0x04: "Multimedia Controller"
        0x05: "Memory Controller"
        0x06: match subclass:
            0x00: "Host Bridge"
            0x01: "ISA Bridge"
            0x04: "PCI-to-PCI Bridge"
            _: "Bridge Device"
        0x07: "Simple Communication Controller"
        0x08: "Base System Peripheral"
        0x09: "Input Device Controller"
        0x0C: match subclass:
            0x03: "USB Controller"
            _: "Serial Bus Controller"
        _: "Unknown ({class_code:#x})"

# ===========================================================================
# Device Grant Wrappers (syscalls 82-85)
# ===========================================================================

# Helper struct for DMA allocation results.
#
# Contract:
# - `virt_addr` is owned by the caller and is safe for CPU reads/writes.
# - `phys_addr` is the device-visible DMA address for the same buffer.
# - Keep the allocation alive until `free_dma()` is called.
# - On identity-mapped no-IOMMU lanes, `virt_addr` and `phys_addr` may
#   numerically match, but callers should prefer the explicit field names
#   instead of relying on that implementation detail.
struct DmaAllocResult:
    virt_addr: u64    # Virtual address for CPU access
    phys_addr: u64    # Physical address for device DMA

val DMA_CACHE_COHERENT: u8 = 0
val DMA_CACHE_FLUSH_REQUIRED: u8 = 1
val DMA_CACHE_UNCACHED: u8 = 2
val DMA_CACHE_WRITE_COMBINING: u8 = 3

struct DeviceDmaDescriptor:
    """Canonical DMA descriptor shared by storage, network, and display drivers."""
    virt_addr: u64
    phys_addr: u64
    device_addr: u64
    size_bytes: u64
    cache_policy: u8
    owner_task: u64
    owner_device: u64
    allocation_id: u64

impl DeviceDmaDescriptor:
    fn cpu_addr() -> u64:
        self.virt_addr

    fn host_phys_addr() -> u64:
        self.phys_addr

    fn dma_addr() -> u64:
        self.device_addr

    fn len() -> u64:
        self.size_bytes

    fn is_valid() -> bool:
        self.virt_addr != 0 and self.phys_addr != 0 and self.device_addr != 0 and self.size_bytes > 0

    fn into_dma_result() -> DmaAllocResult:
        DmaAllocResult(
            virt_addr: self.virt_addr,
            phys_addr: self.phys_addr
        )

    fn owner_bus() -> u8:
        ((self.owner_device >> 16) & 0xFF).to_u8()

    fn owner_bdf_device() -> u8:
        ((self.owner_device >> 8) & 0xFF).to_u8()

    fn owner_function() -> u8:
        (self.owner_device & 0xFF).to_u8()

struct SharedDmaBuffer:
    """Caller-owned DMA buffer with explicit CPU/device address accessors.

    This is a small groundwork type for zero-copy driver paths: it keeps the
    buffer size alongside both addresses so later callers can pass one object
    around instead of separate raw integers. No hidden bounce buffer is added.
    """
    virt_addr: u64
    phys_addr: u64
    device_addr: u64
    size_bytes: u64
    cache_policy: u8
    owner_task: u64
    owner_device: u64
    allocation_id: u64

impl SharedDmaBuffer:
    fn cpu_addr() -> u64:
        self.virt_addr

    fn device_addr() -> u64:
        self.device_addr

    fn len() -> u64:
        self.size_bytes

    fn is_valid() -> bool:
        self.virt_addr != 0 and self.phys_addr != 0 and self.device_addr != 0 and self.size_bytes > 0

    fn into_dma_result() -> DmaAllocResult:
        DmaAllocResult(
            virt_addr: self.virt_addr,
            phys_addr: self.phys_addr
        )

    fn into_descriptor() -> DeviceDmaDescriptor:
        DeviceDmaDescriptor(
            virt_addr: self.virt_addr,
            phys_addr: self.phys_addr,
            device_addr: self.device_addr,
            size_bytes: self.size_bytes,
            cache_policy: self.cache_policy,
            owner_task: self.owner_task,
            owner_device: self.owner_device,
            allocation_id: self.allocation_id
        )

fn request_device_grant(bus: u8, dev: u8, func: u8) -> Result<DeviceGrant, text>:
    """Request a DeviceGrant for a PCI device.

    The kernel reads PCI config space, allocates an IRQ notification,
    and fills the DeviceGrant struct with BAR0 info, IRQ routing, and DMA caps.
    """
    val bdf = (bus as u64) << 16 | (dev as u64) << 8 | (func as u64)
    var grant = new_device_grant()
    val result = syscall(82, bdf, &grant as u64, 0, 0, 0)
    if result < 0:
        return Err("DeviceGrant failed: error {result}")
    Ok(grant)

fn map_bar(phys_addr: u64, size: u64) -> Result<u64, text>:
    """Map a PCI BAR into the caller's address space.

    Returns the virtual address where the BAR was mapped.
    The mapping uses cache-disable and no-execute flags.
    """
    val result = syscall(83, phys_addr, size, 0, 0, 0)
    if result <= 0:
        return Err("MapBar failed: error {result}")
    Ok(result as u64)

fn map_bar_at(phys_addr: u64, size: u64, vaddr_hint: u64) -> Result<u64, text>:
    """Map a PCI BAR at a specific virtual address hint."""
    val result = syscall(83, phys_addr, size, vaddr_hint, 0, 0)
    if result <= 0:
        return Err("MapBar failed: error {result}")
    Ok(result as u64)

fn alloc_dma(size: u64) -> Result<DmaAllocResult, text>:
    """Allocate a contiguous DMA buffer.

    Returns both the virtual address (for CPU access) and physical address
    (for device DMA). In a no-IOMMU system, device_addr == phys_addr.
    """
    var result_buf: [u64; 2] = [0, 0]
    val result = syscall(84, size, &result_buf as u64, 0, 0, 0)
    if result <= 0:
        return Err("AllocDma failed: error {result}")
    Ok(DmaAllocResult(
        virt_addr: result as u64,
        phys_addr: result_buf[0]
    ))

fn alloc_shared_dma(size: u64) -> Result<SharedDmaBuffer, text>:
    """Allocate a caller-owned DMA buffer with explicit zero-copy metadata.

    This is a thin wrapper over `alloc_dma()` intended for drivers that want
    to keep the CPU pointer, device pointer, and size together without
    changing their transport code yet.
    """
    val dma_result = alloc_dma(size)
    if val Err(msg) = dma_result:
        return Err("AllocSharedDma failed: {msg}")
    val dma = dma_result.unwrap()
    Ok(SharedDmaBuffer(
        virt_addr: dma.virt_addr,
        phys_addr: dma.phys_addr,
        device_addr: dma.phys_addr,
        size_bytes: size,
        cache_policy: DMA_CACHE_COHERENT,
        owner_task: 0,
        owner_device: 0,
        allocation_id: 0
    ))

fn alloc_device_dma(size: u64, cache_policy: u8, owner_device: u64) -> Result<DeviceDmaDescriptor, text>:
    """Allocate a canonical DMA descriptor for drivers that need metadata."""
    var result_buf: [u64; 2] = [0, 0]
    val result = syscall(84, size, &result_buf as u64, owner_device, cache_policy as u64, 0)
    if result <= 0:
        return Err("AllocDeviceDma failed: error {result}")
    Ok(DeviceDmaDescriptor(
        virt_addr: result as u64,
        phys_addr: result_buf[0],
        device_addr: result_buf[0],
        size_bytes: size,
        cache_policy: cache_policy,
        owner_task: 0,
        owner_device: owner_device,
        allocation_id: result_buf[1]
    ))

fn dma_sync_cpu_to_device(_desc: DeviceDmaDescriptor) -> Result<bool, text>:
    """Synchronize CPU writes before device DMA reads.

    Current no-IOMMU/coherent lanes do not require explicit cache maintenance,
    but keeping this helper in the API prevents drivers from baking in that
    assumption.
    """
    Ok(true)

fn dma_sync_device_to_cpu(_desc: DeviceDmaDescriptor) -> Result<bool, text>:
    """Synchronize device DMA writes before CPU reads."""
    Ok(true)

fn free_dma(virt_addr: u64, size: u64) -> Result<bool, text>:
    """Free a previously allocated DMA buffer."""
    val result = syscall(85, virt_addr, size, 0, 0, 0)
    if result < 0:
        return Err("FreeDma failed: error {result}")
    Ok(true)

fn free_dma_for_device(virt_addr: u64, size: u64, owner_device: u64) -> Result<bool, text>:
    """Free a DMA buffer while requiring the kernel owner-device record to match."""
    val result = syscall(85, virt_addr, size, owner_device, 0, 0)
    if result < 0:
        return Err("FreeDma failed: error {result}")
    Ok(true)

fn free_shared_dma(buf: SharedDmaBuffer) -> Result<bool, text>:
    """Free a shared DMA buffer allocated by `alloc_shared_dma()`."""
    if not buf.is_valid():
        return Err("FreeSharedDma failed: invalid buffer")
    free_dma(buf.virt_addr, buf.size_bytes)

fn free_device_dma(desc: DeviceDmaDescriptor) -> Result<bool, text>:
    """Free a DMA descriptor allocated by `alloc_device_dma()`."""
    if not desc.is_valid():
        return Err("FreeDeviceDma failed: invalid descriptor")
    free_dma_for_device(desc.virt_addr, desc.size_bytes, desc.owner_device)
