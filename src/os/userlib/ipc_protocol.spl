# IPC method constants per service.
# Each userspace service exposes a numbered method table.

# --- VFS service methods ---
val VFS_OPEN: u32 = 1
val VFS_READ: u32 = 2
val VFS_WRITE: u32 = 3
val VFS_CLOSE: u32 = 4
val VFS_STAT: u32 = 5
val VFS_MKDIR: u32 = 6
val VFS_READDIR: u32 = 7
val VFS_REMOVE: u32 = 8
val VFS_RENAME: u32 = 9
val VFS_MOUNT: u32 = 10
val VFS_UNMOUNT: u32 = 11
val VFS_MOUNT_LIST: u32 = 12

# --- Net service methods ---
val NET_SOCKET: u32 = 1
val NET_BIND: u32 = 2
val NET_LISTEN: u32 = 3
val NET_CONNECT: u32 = 4
val NET_ACCEPT: u32 = 5
val NET_SEND: u32 = 6
val NET_RECV: u32 = 7
val NET_CLOSE: u32 = 8
val NET_IF_LIST: u32 = 9
val NET_IF_CONFIG: u32 = 10

# --- Compositor service methods ---
val COMP_CREATE_WINDOW: u32 = 1
val COMP_DESTROY_WINDOW: u32 = 2
val COMP_UPDATE_TREE: u32 = 3
val COMP_FOCUS: u32 = 4

# --- Compositor service methods (extended) ---
val COMP_RESIZE: u32 = 5
val COMP_MOVE: u32 = 6
val COMP_SET_TITLE: u32 = 7
val COMP_MINIMIZE: u32 = 8
val COMP_MAXIMIZE: u32 = 9
val COMP_RESTORE: u32 = 10
val COMP_INPUT_EVENT: u32 = 11
val COMP_CLOSE_REQUEST: u32 = 12
val COMP_FOCUS_CHANGED: u32 = 13

# Create a window whose content is rendered by the Simple Web Engine.
# Payload: url_len(u32) | url(bytes) | x(i32) | y(i32) | w(i32) | h(i32)
# Response: status(i32) | window_id(u64)   — same shape as COMP_CREATE_WINDOW.
val COMP_CREATE_WEB_WINDOW: u32 = 14

# --- Display service methods ---
val DISPLAY_GET_MODE: u32 = 1
val DISPLAY_CREATE_SURFACE: u32 = 2
val DISPLAY_DESTROY_SURFACE: u32 = 3
val DISPLAY_PRESENT: u32 = 4
val DISPLAY_SET_SCANOUT: u32 = 5
val DISPLAY_GET_INFO: u32 = 6

# --- PCI Manager service methods ---
val PCIMGR_ENUMERATE: u32 = 1
val PCIMGR_REQUEST_DEVICE: u32 = 2
val PCIMGR_RELEASE_DEVICE: u32 = 3
val PCIMGR_GET_DEVICE_INFO: u32 = 4

# --- Init service methods ---
val INIT_SERVICE_LIST: u32 = 1
val INIT_SERVICE_START: u32 = 2
val INIT_SERVICE_STOP: u32 = 3
val INIT_SERVICE_STATUS: u32 = 5
