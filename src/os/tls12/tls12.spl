#![allow(unnamed_duplicate_typed_args)]
# TLS 1.2 module entry — RFC 5246 record layer + ClientHello/ServerHello seed.
#
# This wave (W16-A) only ships record framing + handshake-message
# parse/build.  Cipher suite negotiation, Finished MAC, record encryption,
# and extension-specific parsers are follow-up waves and live elsewhere
# once landed.
#
# Reference: RFC 5246 (TLS 1.2)

use os.tls12.tls12_record.{
    TlsRecord12, RecordResult,
    CT_CHANGE_CIPHER_SPEC, CT_ALERT, CT_HANDSHAKE, CT_APPLICATION_DATA,
    TLS12_VERSION_MAJOR, TLS12_VERSION_MINOR, TLS12_MAX_PLAINTEXT_FRAGMENT,
    encode_record, decode_record, make_plaintext_record
}
use os.tls12.tls12_extensions.{
    TlsExtension12, ExtensionResult, ExtensionListResult,
    EXT12_SNI, EXT12_MAX_FRAGMENT_LENGTH, EXT12_SUPPORTED_GROUPS,
    EXT12_EC_POINT_FORMATS, EXT12_SIG_ALGS, EXT12_ALPN, EXT12_RENEGOTIATION_INFO,
    encode_extension, encode_extension_list, decode_extension, decode_extension_list
}
use os.tls12.tls12_handshake.{
    HandshakeMessage12, HandshakeResult,
    ClientHello12, ClientHelloResult,
    ServerHello12, ServerHelloResult,
    HS12_HELLO_REQUEST, HS12_CLIENT_HELLO, HS12_SERVER_HELLO,
    HS12_CERTIFICATE, HS12_SERVER_KEY_EXCHANGE, HS12_CERTIFICATE_REQUEST,
    HS12_SERVER_HELLO_DONE, HS12_CERTIFICATE_VERIFY, HS12_CLIENT_KEY_EXCHANGE,
    HS12_FINISHED,
    encode_handshake, decode_handshake,
    build_client_hello_body, build_client_hello, parse_client_hello,
    build_server_hello_body, build_server_hello, parse_server_hello
}
