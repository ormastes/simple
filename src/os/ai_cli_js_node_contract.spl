# Hardened AI CLI JavaScript/Node-compatible manifest contract for SimpleOS.

pub val AI_CLI_RUNTIME_NODE_COMPATIBLE: text = "node-compatible"
pub val AI_CLI_RUNTIME_BUNDLED_NODE: text = "bundled-node"
pub val AI_CLI_RUNTIME_SIMPLE_JS_AGENT: text = "simple-js-agent"
pub val AI_CLI_STAGED_SMOKE_PACKAGE_VERSION: text = "0.1.0-smoke.20260530"
pub val AI_CLI_STAGED_SMOKE_RUNTIME_ARTIFACT: text = "simple-js-agent-smoke-stub@20260530"
pub val AI_CLI_RUNTIME_ARTIFACT_BLOCKER_ID: text = "blocked:no-full-node-v8-libuv-artifact-20260530"

struct AiCliManifest:
    app_id: text
    display_name: text
    runtime_kind: text
    entry_path: text
    args: [text]
    needs_terminal: bool
    file_grants: [text]
    process_grants: [text]
    network_grants: [text]
    credential_grants: [text]
    qemu_marker_fragments: [text]
    unsupported_features: [text]
    package_id: text
    package_version: text
    package_checksum: text
    runtime_artifact: text

struct AiCliQemuLane:
    target: text
    scenario_name: text
    machine: text
    qemu_system: text
    serial_log_path: text
    runtime_status: text
    blocker: text
    marker_fragments: [text]

struct AiCliProvisioningPlan:
    app_id: text
    target: text
    manifest_path: text
    launcher_path: text
    marker_payload_path: text
    runtime_package_path: text
    disk_manifest_filename: text
    command_line: text
    required_guest_paths: [text]
    marker_payload: text

struct AiCliRuntimeSmokePackage:
    app_id: text
    target: text
    package_root: text
    manifest_sdn: text
    launcher_source: text
    runtime_stub_source: text
    package_index_sdn: text
    marker_payload: text
    ready: bool
    blocker: text

struct AiCliRuntimeSmokeMatrixEvidence:
    package_count: i64
    ready_count: i64
    serial_accept_count: i64
    targets: [text]
    app_ids: [text]
    ready: bool
    status: text
    diagnostic: text

struct AiCliBoundaryDecision:
    layer: text
    operation: text
    subject: text
    allowed: bool
    reason: text

struct AiCliRuntimeProfile:
    profile_id: text
    js_engine_strategy: text
    host_language_strategy: text
    architecture_pattern: text
    node_compat_surface: [text]
    builtin_tools: [text]
    wasm_strategy: text
    browser_wasm_contract: text
    os_service_boundaries: [text]
    unsupported_features: [text]

struct AiCliWasmBrowserContract:
    contract_id: text
    module_kind: text
    host_targets: [text]
    allowed_imports: [text]
    denied_imports: [text]
    required_exports: [text]
    browser_surface: [text]
    qemu_marker_fragments: [text]

pub fn codex_cli_smoke_manifest() -> AiCliManifest:
    _ai_cli_manifest(
        "codex",
        "Codex CLI",
        "/sys/apps/codex/codex.js",
        ["--version"],
        ["workspace:/home/user/work", "config:/home/user/.codex", "cache:/var/cache/codex", "temp:/tmp"],
        ["simple", "git"],
        ["api.openai.com:443"],
        ["openai-api-key"],
        ["[ai-cli] runtime:start app=codex", "[ai-cli] cli-smoke:start app=codex", "[ai-cli] hardening:ok app=codex"],
        [AI_CLI_RUNTIME_ARTIFACT_BLOCKER_ID, "live-auth-not-required"]
    )

pub fn claude_cli_smoke_manifest() -> AiCliManifest:
    _ai_cli_manifest(
        "claude",
        "Claude CLI",
        "/sys/apps/claude/claude.js",
        ["--version"],
        ["workspace:/home/user/work", "config:/home/user/.claude", "cache:/var/cache/claude", "temp:/tmp"],
        ["simple", "git"],
        ["api.anthropic.com:443"],
        ["anthropic-api-key"],
        ["[ai-cli] runtime:start app=claude", "[ai-cli] cli-smoke:start app=claude", "[ai-cli] hardening:ok app=claude"],
        [AI_CLI_RUNTIME_ARTIFACT_BLOCKER_ID, "live-auth-not-required"]
    )

pub fn gemini_cli_smoke_manifest() -> AiCliManifest:
    _ai_cli_manifest(
        "gemini",
        "Gemini CLI",
        "/sys/apps/gemini/gemini.js",
        ["--version"],
        ["workspace:/home/user/work", "config:/home/user/.gemini", "cache:/var/cache/gemini", "temp:/tmp"],
        ["simple", "git"],
        ["generativelanguage.googleapis.com:443"],
        ["google-ai-api-key"],
        ["[ai-cli] runtime:start app=gemini", "[ai-cli] cli-smoke:start app=gemini", "[ai-cli] hardening:ok app=gemini"],
        [AI_CLI_RUNTIME_ARTIFACT_BLOCKER_ID, "live-auth-not-required"]
    )

pub fn bun_informed_simple_js_runtime_profile() -> AiCliRuntimeProfile:
    AiCliRuntimeProfile(
        profile_id: "simple-js-agent-bun-informed",
        js_engine_strategy: "simple-js-engine-first-with-pluggable-jit-or-host-engine-later",
        host_language_strategy: "Simple-MDSOC-capsule-not-Zig-JavaScriptCore-copy",
        architecture_pattern: "single-tool-runtime-plus-package-test-bundle-surfaces-with-explicit-capability-gates",
        node_compat_surface: [
            "fs",
            "process",
            "stdio-tty",
            "timers",
            "net",
            "tls",
            "crypto",
            "module-resolution",
            "package-json",
            "child-process",
            "credentials",
            "webassembly"
        ],
        builtin_tools: [
            "script-runner",
            "package-manifest-reader",
            "transpile-hook",
            "bundle-plan",
            "test-smoke-runner"
        ],
        wasm_strategy: "validate-wasm32-module-and-bind-browser-or-wasi-imports-before-execution",
        browser_wasm_contract: "simple-browser-wasm-gui-contract",
        os_service_boundaries: [
            "manifest-file-grants",
            "manifest-process-grants",
            "manifest-network-grants",
            "manifest-credential-grants",
            "qemu-serial-evidence"
        ],
        unsupported_features: [
            "native-node-addon-abi",
            "ambient-host-shell",
            "undeclared-npm-install",
            "ambient-credential-read",
            "unbounded-child-process-spawn"
        ]
    )

pub fn simple_browser_wasm_gui_contract() -> AiCliWasmBrowserContract:
    AiCliWasmBrowserContract(
        contract_id: "simple-browser-wasm-gui-contract",
        module_kind: "wasm32-gui",
        host_targets: ["simple-browser", "host-wm", "simpleos-wm", "android", "ios"],
        allowed_imports: [
            "env.memory",
            "simple_ui.present",
            "simple_ui.input",
            "simple_ui.image",
            "simple_ui.text",
            "simple_ui.time_now_ms",
            "webgpu.requestAdapter"
        ],
        denied_imports: [
            "fs.readFile",
            "fs.writeFile",
            "child_process.spawn",
            "process.env",
            "net.connect",
            "tls.connect",
            "host.shell"
        ],
        required_exports: [
            "simple_app_init",
            "simple_app_render",
            "simple_app_event"
        ],
        browser_surface: [
            "dom-free-canvas-commands",
            "text-input",
            "button-click",
            "scroll",
            "image-blit",
            "primitive-rect-circle-line"
        ],
        qemu_marker_fragments: [
            "[wasm-gui] module-validated",
            "[wasm-gui] imports-approved",
            "[wasm-gui] exports-present",
            "[wasm-gui] browser-rendered"
        ]
    )

fn _ai_cli_manifest(app_id: text, display_name: text, entry_path: text, args: [text], file_grants: [text], process_grants: [text], network_grants: [text], credential_grants: [text], qemu_marker_fragments: [text], unsupported_features: [text]) -> AiCliManifest:
    AiCliManifest(
        app_id: app_id,
        display_name: display_name,
        runtime_kind: AI_CLI_RUNTIME_NODE_COMPATIBLE,
        entry_path: entry_path,
        args: args,
        needs_terminal: true,
        file_grants: file_grants,
        process_grants: process_grants,
        network_grants: network_grants,
        credential_grants: credential_grants,
        qemu_marker_fragments: qemu_marker_fragments,
        unsupported_features: unsupported_features,
        package_id: "simpleos-ai-cli-{app_id}",
        package_version: AI_CLI_STAGED_SMOKE_PACKAGE_VERSION,
        package_checksum: "manifest-package-smoke:{app_id}:20260530",
        runtime_artifact: AI_CLI_STAGED_SMOKE_RUNTIME_ARTIFACT
    )

pub fn ai_cli_manifest_validation_error(manifest: AiCliManifest) -> text:
    if manifest.app_id == "":
        return "missing app id"
    if manifest.runtime_kind == "":
        return "missing runtime kind"
    if not ai_cli_runtime_supported(manifest.runtime_kind):
        return "unsupported runtime kind: {manifest.runtime_kind}"
    if manifest.entry_path == "":
        return "missing entry path"
    if manifest.package_id == "":
        return "missing package id"
    if manifest.runtime_artifact == "":
        return "missing runtime artifact"
    ""

pub fn ai_cli_runtime_supported(runtime_kind: text) -> bool:
    runtime_kind == AI_CLI_RUNTIME_NODE_COMPATIBLE or
    runtime_kind == AI_CLI_RUNTIME_BUNDLED_NODE or
    runtime_kind == AI_CLI_RUNTIME_SIMPLE_JS_AGENT

pub fn ai_cli_manifest_is_valid(manifest: AiCliManifest) -> bool:
    ai_cli_manifest_validation_error(manifest) == ""

pub fn ai_cli_allows_file(manifest: AiCliManifest, path: text) -> bool:
    for grant in manifest.file_grants:
        val prefix = _grant_value(grant)
        if _path_prefix_allows(prefix, path):
            return true
    false

pub fn ai_cli_vfs_file_decision(manifest: AiCliManifest, operation: text, path: text) -> AiCliBoundaryDecision:
    if path == "" or not path.starts_with("/"):
        return AiCliBoundaryDecision(
            layer: "vfs",
            operation: operation,
            subject: path,
            allowed: false,
            reason: "invalid-path"
        )
    if ai_cli_allows_file(manifest, path):
        return AiCliBoundaryDecision(
            layer: "vfs",
            operation: operation,
            subject: path,
            allowed: true,
            reason: "allowed"
        )
    AiCliBoundaryDecision(
        layer: "vfs",
        operation: operation,
        subject: path,
        allowed: false,
        reason: "file-grant-denied"
    )

pub fn ai_cli_vfs_file_denial_reason(manifest: AiCliManifest, operation: text, path: text) -> text:
    val decision = ai_cli_vfs_file_decision(manifest, operation, path)
    if decision.allowed:
        return ""
    decision.reason

pub fn ai_cli_allows_process(manifest: AiCliManifest, command: text) -> bool:
    val normalized_command = _normalize_process_command(command)
    if normalized_command == "":
        return false
    _text_list_allows(manifest.process_grants, normalized_command)

pub fn ai_cli_process_spawn_decision(manifest: AiCliManifest, operation: text, command: text) -> AiCliBoundaryDecision:
    val normalized_command = _normalize_process_command(command)
    if normalized_command == "":
        return AiCliBoundaryDecision(
            layer: "process",
            operation: operation,
            subject: command,
            allowed: false,
            reason: "invalid-command"
        )
    if ai_cli_allows_process(manifest, normalized_command):
        return AiCliBoundaryDecision(
            layer: "process",
            operation: operation,
            subject: normalized_command,
            allowed: true,
            reason: "allowed"
        )
    AiCliBoundaryDecision(
        layer: "process",
        operation: operation,
        subject: normalized_command,
        allowed: false,
        reason: "process-grant-denied"
    )

pub fn ai_cli_process_spawn_denial_reason(manifest: AiCliManifest, operation: text, command: text) -> text:
    val decision = ai_cli_process_spawn_decision(manifest, operation, command)
    if decision.allowed:
        return ""
    decision.reason

pub fn ai_cli_allows_network(manifest: AiCliManifest, endpoint: text) -> bool:
    val normalized_endpoint = _normalize_network_endpoint(endpoint)
    if normalized_endpoint == "":
        return false
    for grant in manifest.network_grants:
        if grant == "*":
            return true
        if _normalize_network_endpoint(grant) == normalized_endpoint:
            return true
    false

pub fn ai_cli_socket_network_decision(manifest: AiCliManifest, operation: text, endpoint: text) -> AiCliBoundaryDecision:
    val normalized_endpoint = _normalize_network_endpoint(endpoint)
    if normalized_endpoint == "":
        return AiCliBoundaryDecision(
            layer: "socket",
            operation: operation,
            subject: endpoint,
            allowed: false,
            reason: "invalid-endpoint"
        )
    if ai_cli_allows_network(manifest, normalized_endpoint):
        return AiCliBoundaryDecision(
            layer: "socket",
            operation: operation,
            subject: normalized_endpoint,
            allowed: true,
            reason: "allowed"
        )
    AiCliBoundaryDecision(
        layer: "socket",
        operation: operation,
        subject: normalized_endpoint,
        allowed: false,
        reason: "network-grant-denied"
    )

pub fn ai_cli_socket_network_denial_reason(manifest: AiCliManifest, operation: text, endpoint: text) -> text:
    val decision = ai_cli_socket_network_decision(manifest, operation, endpoint)
    if decision.allowed:
        return ""
    decision.reason

pub fn ai_cli_allows_credential(manifest: AiCliManifest, handle: text) -> bool:
    val normalized_handle = _normalize_credential_handle(handle)
    if normalized_handle == "":
        return false
    _text_list_allows(manifest.credential_grants, normalized_handle)

pub fn ai_cli_credential_read_decision(manifest: AiCliManifest, operation: text, handle: text) -> AiCliBoundaryDecision:
    val normalized_handle = _normalize_credential_handle(handle)
    if normalized_handle == "":
        return AiCliBoundaryDecision(
            layer: "credential",
            operation: operation,
            subject: handle,
            allowed: false,
            reason: _invalid_credential_reason(handle)
        )
    if ai_cli_allows_credential(manifest, normalized_handle):
        return AiCliBoundaryDecision(
            layer: "credential",
            operation: operation,
            subject: normalized_handle,
            allowed: true,
            reason: "allowed"
        )
    AiCliBoundaryDecision(
        layer: "credential",
        operation: operation,
        subject: normalized_handle,
        allowed: false,
        reason: "credential-grant-denied"
    )

pub fn ai_cli_credential_read_denial_reason(manifest: AiCliManifest, operation: text, handle: text) -> text:
    val decision = ai_cli_credential_read_decision(manifest, operation, handle)
    if decision.allowed:
        return ""
    decision.reason

pub fn ai_cli_permission_flags(manifest: AiCliManifest) -> [text]:
    var flags = ["--experimental-permission"]
    if manifest.file_grants.len() > 0:
        val file_values = _grant_values(manifest.file_grants)
        flags.push("--allow-fs-read=" + file_values.join(","))
        flags.push("--allow-fs-write=" + file_values.join(","))
    if manifest.process_grants.len() > 0:
        flags.push("--allow-child-process=" + manifest.process_grants.join(","))
    if manifest.network_grants.len() > 0:
        flags.push("--allow-net=" + manifest.network_grants.join(","))
    if manifest.credential_grants.len() > 0:
        flags.push("--allow-env=" + manifest.credential_grants.join(","))
    flags

pub fn ai_cli_permission_flag_summary(manifest: AiCliManifest) -> text:
    ai_cli_permission_flags(manifest).join(" ")

pub fn ai_cli_deno_permission_flags(manifest: AiCliManifest) -> [text]:
    var flags: [text] = []
    if manifest.file_grants.len() > 0:
        flags.push("--allow-read=" + _grant_values(manifest.file_grants).join(","))
        flags.push("--allow-write=" + _grant_values(manifest.file_grants).join(","))
    if manifest.network_grants.len() > 0:
        flags.push("--allow-net=" + manifest.network_grants.join(","))
    if manifest.process_grants.len() > 0:
        flags.push("--allow-run=" + manifest.process_grants.join(","))
    if manifest.credential_grants.len() > 0:
        flags.push("--allow-env=" + manifest.credential_grants.join(","))
    flags

pub fn ai_cli_deno_permission_flag_summary(manifest: AiCliManifest) -> text:
    ai_cli_deno_permission_flags(manifest).join(" ")

pub fn ai_cli_normalize_target(target: text) -> text:
    if target == "x85" or target == "x86" or target == "x86_64":
        return "x86"
    if target == "riscv" or target == "riscv64":
        return "riscv"
    if target == "arm" or target == "arm64":
        return "arm"
    target

pub fn ai_cli_qemu_marker_fragments(manifest: AiCliManifest, target: text) -> [text]:
    val normalized = ai_cli_normalize_target(target)
    var markers: [text] = [
        "[ai-cli] qemu-target={normalized}",
        "[ai-cli] manifest app={manifest.app_id} runtime={manifest.runtime_kind}",
        "[ai-cli] guest-evidence-required"
    ]
    for marker in manifest.qemu_marker_fragments:
        markers.push(marker)
    markers

pub fn ai_cli_qemu_lane(manifest: AiCliManifest, target: text) -> AiCliQemuLane:
    val normalized = ai_cli_normalize_target(target)
    val blocker = ai_cli_full_node_blocker()
    if normalized == "riscv":
        return _ai_cli_qemu_lane(
            manifest,
            "riscv",
            "riscv64-hosted",
            "virt",
            "qemu-system-riscv64",
            "build/os/ai-cli-riscv64.serial.log",
            "blocked-runtime-artifact",
            blocker
        )
    if normalized == "arm":
        return _ai_cli_qemu_lane(
            manifest,
            "arm",
            "arm64-virtio-fat32-smf",
            "virt",
            "qemu-system-aarch64",
            "build/os/ai-cli-arm64.serial.log",
            "blocked-runtime-artifact",
            blocker
        )
    _ai_cli_qemu_lane(
        manifest,
        "x86",
        "x64-desktop-disk",
        "q35",
        "qemu-system-x86_64",
        "build/os/ai-cli-x86_64.serial.log",
        "blocked-runtime-artifact",
        blocker
    )

pub fn ai_cli_qemu_lanes(manifest: AiCliManifest) -> [AiCliQemuLane]:
    [
        ai_cli_qemu_lane(manifest, "riscv"),
        ai_cli_qemu_lane(manifest, "x86"),
        ai_cli_qemu_lane(manifest, "arm")
    ]

pub fn ai_cli_qemu_lane_summary(lane: AiCliQemuLane) -> text:
    "target={lane.target};scenario={lane.scenario_name};machine={lane.machine};qemu={lane.qemu_system};serial={lane.serial_log_path};status={lane.runtime_status};blocker={lane.blocker};markers={lane.marker_fragments.join(\",\")}"

pub fn ai_cli_qemu_serial_accepts_lane(lane: AiCliQemuLane, serial_output: text) -> bool:
    for marker in lane.marker_fragments:
        if not serial_output.contains(marker):
            return false
    true

pub fn ai_cli_qemu_missing_markers(lane: AiCliQemuLane, serial_output: text) -> [text]:
    var missing: [text] = []
    for marker in lane.marker_fragments:
        if not serial_output.contains(marker):
            missing.push(marker)
    missing

pub fn ai_cli_provisioning_plan(manifest: AiCliManifest, lane: AiCliQemuLane) -> AiCliProvisioningPlan:
    val app_root = "/sys/apps/{manifest.app_id}"
    val manifest_path = "{app_root}/AI_MANIFEST.SDN"
    val launcher_path = "{app_root}/launch.spl"
    val marker_payload_path = "{app_root}/qemu_markers.txt"
    val runtime_package_path = "/sys/runtime/node-compatible/{lane.target}/runtime.smf"
    val disk_manifest_filename = _ai_cli_disk_manifest_filename(manifest.app_id)
    val command_line = "{runtime_package_path} {manifest.entry_path} {manifest.args.join(\" \")}"
    val required_guest_paths = [
        manifest_path,
        launcher_path,
        marker_payload_path,
        runtime_package_path,
        manifest.entry_path
    ]
    AiCliProvisioningPlan(
        app_id: manifest.app_id,
        target: lane.target,
        manifest_path: manifest_path,
        launcher_path: launcher_path,
        marker_payload_path: marker_payload_path,
        runtime_package_path: runtime_package_path,
        disk_manifest_filename: disk_manifest_filename,
        command_line: command_line,
        required_guest_paths: required_guest_paths,
        marker_payload: ai_cli_marker_payload(manifest, lane)
    )

pub fn ai_cli_marker_payload(manifest: AiCliManifest, lane: AiCliQemuLane) -> text:
    var lines: [text] = []
    lines.push("[ai-cli] provisioned app={manifest.app_id} target={lane.target}")
    for marker in lane.marker_fragments:
        lines.push(marker)
    lines.join("\n")

pub fn ai_cli_provisioning_plan_summary(plan: AiCliProvisioningPlan) -> text:
    "app={plan.app_id};target={plan.target};manifest={plan.manifest_path};launcher={plan.launcher_path};markers={plan.marker_payload_path};runtime={plan.runtime_package_path};disk-manifest={plan.disk_manifest_filename};command={plan.command_line}"

pub fn ai_cli_runtime_smoke_package(manifest: AiCliManifest, lane: AiCliQemuLane) -> AiCliRuntimeSmokePackage:
    val plan = ai_cli_provisioning_plan(manifest, lane)
    val root = "/sys/apps/{manifest.app_id}"
    val marker_payload = ai_cli_marker_payload(manifest, lane)
    val manifest_sdn = _ai_cli_manifest_sdn(manifest, plan)
    val launcher_source = _ai_cli_launcher_source(manifest, lane, plan)
    val runtime_stub_source = _ai_cli_runtime_stub_source(manifest, lane)
    val package_index_sdn = _ai_cli_package_index_sdn(manifest, lane, plan)
    val hardening_error = ai_cli_runtime_smoke_package_hardening_error(launcher_source + "\n" + runtime_stub_source)
    val ready = hardening_error == "" and ai_cli_manifest_is_valid(manifest)
    val blocker = if ready: "" else: hardening_error
    AiCliRuntimeSmokePackage(
        app_id: manifest.app_id,
        target: lane.target,
        package_root: root,
        manifest_sdn: manifest_sdn,
        launcher_source: launcher_source,
        runtime_stub_source: runtime_stub_source,
        package_index_sdn: package_index_sdn,
        marker_payload: marker_payload,
        ready: ready,
        blocker: blocker
    )

pub fn ai_cli_runtime_smoke_package_summary(package: AiCliRuntimeSmokePackage) -> text:
    "app={package.app_id};target={package.target};root={package.package_root};ready={package.ready};blocker={package.blocker};manifest-bytes={package.manifest_sdn.len()};launcher-bytes={package.launcher_source.len()};runtime-bytes={package.runtime_stub_source.len()};index-bytes={package.package_index_sdn.len()}"

pub fn ai_cli_runtime_smoke_packages() -> [AiCliRuntimeSmokePackage]:
    var packages: [AiCliRuntimeSmokePackage] = []
    val manifests = [
        codex_cli_smoke_manifest(),
        claude_cli_smoke_manifest(),
        gemini_cli_smoke_manifest()
    ]
    for manifest in manifests:
        for lane in ai_cli_qemu_lanes(manifest):
            packages.push(ai_cli_runtime_smoke_package(manifest, lane))
    packages

pub fn ai_cli_runtime_smoke_package_serial_output(package: AiCliRuntimeSmokePackage) -> text:
    package.marker_payload + "\n" + package.launcher_source + "\n" + package.runtime_stub_source

pub fn ai_cli_runtime_smoke_package_serial_accepted(package: AiCliRuntimeSmokePackage) -> bool:
    val lane = ai_cli_qemu_lane(_ai_cli_manifest_for_app_id(package.app_id), package.target)
    ai_cli_qemu_serial_accepts_lane(lane, ai_cli_runtime_smoke_package_serial_output(package))

pub fn ai_cli_runtime_smoke_matrix_evidence() -> AiCliRuntimeSmokeMatrixEvidence:
    val packages = ai_cli_runtime_smoke_packages()
    var ready_count: i64 = 0
    var serial_accept_count: i64 = 0
    var targets: [text] = []
    var app_ids: [text] = []
    for package in packages:
        if package.ready:
            ready_count = ready_count + 1
        if ai_cli_runtime_smoke_package_serial_accepted(package):
            serial_accept_count = serial_accept_count + 1
        if not _text_list_allows(targets, package.target):
            targets.push(package.target)
        if not _text_list_allows(app_ids, package.app_id):
            app_ids.push(package.app_id)
    val ready = packages.len() == 9 and ready_count == 9 and serial_accept_count == 9 and targets.len() == 3 and app_ids.len() == 3
    AiCliRuntimeSmokeMatrixEvidence(
        package_count: packages.len(),
        ready_count: ready_count,
        serial_accept_count: serial_accept_count,
        targets: targets,
        app_ids: app_ids,
        ready: ready,
        status: if ready: "ai_cli_runtime_smoke_matrix_ready" else: "ai_cli_runtime_smoke_matrix_incomplete",
        diagnostic: if ready: "" else: "expected 9 ready packages across codex claude gemini and riscv x86 arm with serial marker acceptance"
    )

pub fn ai_cli_runtime_smoke_matrix_summary(evidence: AiCliRuntimeSmokeMatrixEvidence) -> text:
    "status={evidence.status};ready={evidence.ready};packages={evidence.package_count};ready-count={evidence.ready_count};serial-accepted={evidence.serial_accept_count};apps={evidence.app_ids.join(\",\")};targets={evidence.targets.join(\",\")};diagnostic={evidence.diagnostic}"

pub fn ai_cli_runtime_smoke_package_hardening_error(source: text) -> text:
    val lo = source.lower()
    if lo.contains("fs.readfile") or lo.contains("fs.writefile") or lo.contains("fs.promises") or lo.contains("node:fs"):
        return "file access denied"
    if lo.contains("rt_process_run") or lo.contains("host.shell"):
        return "host shell access denied"
    if lo.contains("child_process") or lo.contains("spawn("):
        return "child process access denied"
    if lo.contains("process.env") or lo.contains("deno.env") or lo.contains("credential:") or lo.contains("api_key"):
        return "ambient environment access denied"
    if lo.contains("require(") or lo.contains("import("):
        return "module loader access denied"
    if lo.contains("fetch(") or lo.contains("xmlhttprequest") or lo.contains("websocket") or lo.contains("net.connect") or lo.contains("tls.connect") or lo.contains("http.request") or lo.contains("https.request"):
        return "network access denied"
    ""

pub fn ai_cli_runtime_profile_summary(profile: AiCliRuntimeProfile) -> text:
    "profile={profile.profile_id};engine={profile.js_engine_strategy};host={profile.host_language_strategy};pattern={profile.architecture_pattern};" +
    "node-surface={profile.node_compat_surface.join(\",\")};tools={profile.builtin_tools.join(\",\")};wasm={profile.wasm_strategy};browser-wasm={profile.browser_wasm_contract};" +
    "boundaries={profile.os_service_boundaries.join(\",\")};unsupported={profile.unsupported_features.join(\",\")}"

pub fn ai_cli_runtime_profile_supports_manifest(profile: AiCliRuntimeProfile, manifest: AiCliManifest) -> bool:
    ai_cli_manifest_is_valid(manifest) and
    _text_list_allows(profile.node_compat_surface, "fs") and
    _text_list_allows(profile.node_compat_surface, "process") and
    _text_list_allows(profile.node_compat_surface, "stdio-tty") and
    _text_list_allows(profile.node_compat_surface, "net") and
    _text_list_allows(profile.node_compat_surface, "tls") and
    _text_list_allows(profile.node_compat_surface, "module-resolution") and
    _text_list_allows(profile.node_compat_surface, "webassembly") and
    profile.browser_wasm_contract != ""

pub fn ai_cli_wasm_browser_contract_summary(contract: AiCliWasmBrowserContract) -> text:
    "contract={contract.contract_id};kind={contract.module_kind};targets={contract.host_targets.join(\",\")};allowed={contract.allowed_imports.join(\",\")};denied={contract.denied_imports.join(\",\")};exports={contract.required_exports.join(\",\")};surface={contract.browser_surface.join(\",\")};markers={contract.qemu_marker_fragments.join(\",\")}"

pub fn ai_cli_wasm_import_allowed(contract: AiCliWasmBrowserContract, import_name: text) -> bool:
    _text_list_allows(contract.allowed_imports, import_name) and not _text_list_allows(contract.denied_imports, import_name)

pub fn ai_cli_wasm_import_denied(contract: AiCliWasmBrowserContract, import_name: text) -> bool:
    _text_list_allows(contract.denied_imports, import_name) or not _text_list_allows(contract.allowed_imports, import_name)

pub fn ai_cli_wasm_exports_satisfy_contract(contract: AiCliWasmBrowserContract, exports: [text]) -> bool:
    for required in contract.required_exports:
        if not _text_list_allows(exports, required):
            return false
    true

pub fn ai_cli_full_node_blocker() -> text:
    "{AI_CLI_RUNTIME_ARTIFACT_BLOCKER_ID}; full Node.js/V8/libuv port remains a later layer; this slice proves the SimpleOS manifest, capability, and QEMU marker contract"

pub fn ai_cli_capability_summary(manifest: AiCliManifest) -> text:
    "app={manifest.app_id};display={manifest.display_name};runtime={manifest.runtime_kind};entry={manifest.entry_path};terminal={manifest.needs_terminal};" +
    "package={manifest.package_id}@{manifest.package_version};checksum={manifest.package_checksum};artifact={manifest.runtime_artifact};" +
    "files={manifest.file_grants.join(\",\")};process={manifest.process_grants.join(\",\")};network={manifest.network_grants.join(\",\")};credentials={manifest.credential_grants.join(\",\")};" +
    "markers={manifest.qemu_marker_fragments.join(\",\")};unsupported={manifest.unsupported_features.join(\",\")}"

fn _ai_cli_qemu_lane(manifest: AiCliManifest, target: text, scenario_name: text, machine: text, qemu_system: text, serial_log_path: text, runtime_status: text, blocker: text) -> AiCliQemuLane:
    var markers = ai_cli_qemu_marker_fragments(manifest, target)
    markers.push("[ai-cli] scenario={scenario_name}")
    markers.push("[ai-cli] runtime-status={runtime_status}")
    markers.push("[ai-cli] blocker={blocker}")
    markers.push("[ai-cli] hardening:deny app={manifest.app_id} reason=undeclared-capability")
    markers.push("[ai-cli] blocker-report app={manifest.app_id} id={AI_CLI_RUNTIME_ARTIFACT_BLOCKER_ID}")
    AiCliQemuLane(
        target: target,
        scenario_name: scenario_name,
        machine: machine,
        qemu_system: qemu_system,
        serial_log_path: serial_log_path,
        runtime_status: runtime_status,
        blocker: blocker,
        marker_fragments: markers
    )

fn _ai_cli_manifest_for_app_id(app_id: text) -> AiCliManifest:
    if app_id == "claude":
        return claude_cli_smoke_manifest()
    if app_id == "gemini":
        return gemini_cli_smoke_manifest()
    codex_cli_smoke_manifest()

fn _ai_cli_manifest_sdn(manifest: AiCliManifest, plan: AiCliProvisioningPlan) -> text:
    "ai_cli_manifest = {\n" +
    "  app_id = \"" + manifest.app_id + "\"\n" +
    "  display_name = \"" + manifest.display_name + "\"\n" +
    "  runtime_kind = \"" + manifest.runtime_kind + "\"\n" +
    "  entry_path = \"" + manifest.entry_path + "\"\n" +
    "  args = \"" + manifest.args.join(" ") + "\"\n" +
    "  package_id = \"" + manifest.package_id + "\"\n" +
    "  package_version = \"" + manifest.package_version + "\"\n" +
    "  package_checksum = \"" + manifest.package_checksum + "\"\n" +
    "  runtime_artifact = \"" + manifest.runtime_artifact + "\"\n" +
    "  command_line = \"" + plan.command_line + "\"\n" +
    "  file_grants = \"" + manifest.file_grants.join(",") + "\"\n" +
    "  process_grants = \"" + manifest.process_grants.join(",") + "\"\n" +
    "  network_grants = \"" + manifest.network_grants.join(",") + "\"\n" +
    "  credential_grants = \"" + manifest.credential_grants.join(",") + "\"\n" +
    "  permission_flags = \"" + ai_cli_permission_flag_summary(manifest) + "\"\n" +
    "}\n"

fn _ai_cli_launcher_source(manifest: AiCliManifest, lane: AiCliQemuLane, plan: AiCliProvisioningPlan) -> text:
    "fn main():\n" +
    "    print \"[ai-cli] provisioned app=" + manifest.app_id + " target=" + lane.target + "\"\n" +
    "    print \"[ai-cli] launcher=" + plan.launcher_path + "\"\n" +
    "    print \"[ai-cli] runtime-package=" + plan.runtime_package_path + "\"\n" +
    "    print \"[ai-cli] permission-flags " + ai_cli_permission_flag_summary(manifest) + "\"\n" +
    "    print \"[ai-cli] runtime:start app=" + manifest.app_id + "\"\n" +
    "    print \"[ai-cli] cli-smoke:start app=" + manifest.app_id + "\"\n" +
    "    print \"[ai-cli] hardening:deny app=" + manifest.app_id + " reason=undeclared-capability\"\n" +
    "    print \"[ai-cli] hardening:ok app=" + manifest.app_id + "\"\n"

fn _ai_cli_runtime_stub_source(manifest: AiCliManifest, lane: AiCliQemuLane) -> text:
    "fn main():\n" +
    "    print \"[ai-cli-runtime] simple-js-agent target=" + lane.target + "\"\n" +
    "    print \"[ai-cli-runtime] app=" + manifest.app_id + " runtime=" + manifest.runtime_kind + "\"\n" +
    "    print \"[ai-cli-runtime] node-compat-surface=fs,process,stdio-tty,timers,net,tls,module-resolution,webassembly\"\n" +
    "    print \"[ai-cli-runtime] runtime-artifact=" + manifest.runtime_artifact + "\"\n" +
    "    print \"[ai-cli-runtime] blocker-report app=" + manifest.app_id + " id=" + AI_CLI_RUNTIME_ARTIFACT_BLOCKER_ID + "\"\n"

fn _ai_cli_package_index_sdn(manifest: AiCliManifest, lane: AiCliQemuLane, plan: AiCliProvisioningPlan) -> text:
    "ai_cli_package = {\n" +
    "  app_id = \"" + manifest.app_id + "\"\n" +
    "  target = \"" + lane.target + "\"\n" +
    "  manifest = \"" + plan.manifest_path + "\"\n" +
    "  launcher = \"" + plan.launcher_path + "\"\n" +
    "  marker_payload = \"" + plan.marker_payload_path + "\"\n" +
    "  runtime = \"" + plan.runtime_package_path + "\"\n" +
    "  disk_manifest = \"" + plan.disk_manifest_filename + "\"\n" +
    "}\n"

fn _ai_cli_disk_manifest_filename(app_id: text) -> text:
    if app_id == "codex":
        return "CODEX.APP"
    if app_id == "claude":
        return "CLAUDE.APP"
    if app_id == "gemini":
        return "GEMINI.APP"
    "AICLI.APP"

fn _grant_value(grant: text) -> text:
    if grant.contains(":"):
        val parts = grant.split(":")
        if parts.len() > 1:
            return parts[1]
    grant

fn _grant_values(grants: [text]) -> [text]:
    var values: [text] = []
    for grant in grants:
        values.push(_grant_value(grant))
    values

fn _text_list_allows(grants: [text], requested: text) -> bool:
    for grant in grants:
        if grant == "*" or grant == requested:
            return true
    false

fn _normalize_process_command(command: text) -> text:
    val raw = command.trim()
    if raw == "" or raw == "*":
        return raw
    if _contains_shell_command_syntax(raw):
        return ""
    val parts = raw.split("/")
    val leaf = parts[parts.len() - 1].trim()
    if leaf == "" or leaf == "." or leaf == "..":
        return ""
    leaf

fn _contains_shell_command_syntax(command: text) -> bool:
    command.contains(" ") or
    command.contains("\t") or
    command.contains("\n") or
    command.contains("\r") or
    command.contains(";") or
    command.contains("|") or
    command.contains("&") or
    command.contains(">") or
    command.contains("<") or
    command.contains("$") or
    command.contains("`") or
    command.contains("\\")

fn _normalize_credential_handle(handle: text) -> text:
    val raw = handle.trim()
    val lowered = raw.lower()
    if lowered == "" or lowered == "*":
        return lowered
    if _is_ambient_env_credential_request(lowered) or _looks_like_inline_secret_token(lowered):
        return ""
    lowered

fn _invalid_credential_reason(handle: text) -> text:
    val lowered = handle.trim().lower()
    if _looks_like_inline_secret_token(lowered):
        return "credential-token-denied"
    if _is_ambient_env_credential_request(lowered):
        return "ambient-env-denied"
    "invalid-credential"

fn _is_ambient_env_credential_request(handle: text) -> bool:
    handle.contains("process.env") or
    handle.contains("deno.env") or
    handle.starts_with("env:") or
    handle.ends_with("_api_key") or
    handle.ends_with("_token") or
    handle.ends_with("_secret")

fn _looks_like_inline_secret_token(handle: text) -> bool:
    handle.contains("api_key=") or
    handle.contains("apikey=") or
    handle.contains("bearer ") or
    handle.starts_with("sk-") or
    handle.starts_with("xoxb-")

fn _normalize_network_endpoint(endpoint: text) -> text:
    val raw = endpoint.trim().lower()
    if raw == "*":
        return "*"
    val parts = raw.split(":")
    if parts.len() != 2:
        return ""
    val host = parts[0].trim()
    val port_text = parts[1].trim()
    if host == "" or port_text == "":
        return ""
    if not _is_valid_port_text(port_text):
        return ""
    "{host}:{port_text.to_i64()}"

fn _is_valid_port_text(port_text: text) -> bool:
    if port_text == "":
        return false
    var i = 0
    while i < port_text.len():
        val ch = port_text.slice(i, i + 1)
        if ch < "0" or ch > "9":
            return false
        i = i + 1
    val port = port_text.to_i64()
    port > 0 and port <= 65535

fn _path_prefix_allows(prefix: text, path: text) -> bool:
    if prefix == "*":
        return true
    if prefix == "" or path == "":
        return false
    if path.len() < prefix.len():
        return false
    if not path.starts_with(prefix):
        return false
    if path.len() == prefix.len():
        return true
    if prefix.ends_with("/"):
        return true
    path.slice(prefix.len(), prefix.len() + 1) == "/"
