# @platform: baremetal
#
# RTOS Replay Mode — lightweight version of kernel replay mode.
# 5 modes: Off (zero overhead), Record, Replay, Verify, ChaosRecord.
# ChaosRecord randomizes scheduler timing for fuzz testing.

val RTOS_REPLAY_OFF: i32 = 0
val RTOS_REPLAY_RECORD: i32 = 1
val RTOS_REPLAY_REPLAY: i32 = 2
val RTOS_REPLAY_VERIFY: i32 = 3
val RTOS_REPLAY_CHAOS: i32 = 4

var g_rtos_replay_mode: i32 = 0
var g_rtos_replay_event_seq: i64 = 0

fn rtos_replay_mode() -> i32:
    g_rtos_replay_mode

fn rtos_replay_set_mode(mode: i32):
    g_rtos_replay_mode = mode
    g_rtos_replay_event_seq = 0

fn rtos_replay_is_off() -> bool:
    g_rtos_replay_mode == 0

fn rtos_replay_is_recording() -> bool:
    g_rtos_replay_mode == RTOS_REPLAY_RECORD or g_rtos_replay_mode == RTOS_REPLAY_CHAOS

fn rtos_replay_is_replaying() -> bool:
    g_rtos_replay_mode == RTOS_REPLAY_REPLAY

fn rtos_replay_is_verifying() -> bool:
    g_rtos_replay_mode == RTOS_REPLAY_VERIFY

fn rtos_replay_is_chaos() -> bool:
    g_rtos_replay_mode == RTOS_REPLAY_CHAOS

fn rtos_replay_next_seq() -> i64:
    g_rtos_replay_event_seq = g_rtos_replay_event_seq + 1
    g_rtos_replay_event_seq

fn rtos_replay_mode_text() -> text:
    if g_rtos_replay_mode == RTOS_REPLAY_OFF:
        return "off"
    if g_rtos_replay_mode == RTOS_REPLAY_RECORD:
        return "record"
    if g_rtos_replay_mode == RTOS_REPLAY_REPLAY:
        return "replay"
    if g_rtos_replay_mode == RTOS_REPLAY_VERIFY:
        return "verify"
    if g_rtos_replay_mode == RTOS_REPLAY_CHAOS:
        return "chaos-record"
    "unknown"
