# @platform: baremetal
#
# ExternalIO trait — the only I/O boundary for the realtime OS.
# All external communication goes through this trait.

trait ExternalIO:
    fn write(buf_ptr: u64, len: i32) -> i32
    fn read(buf_ptr: u64, len: i32) -> i32
    fn available() -> i32
    fn flush()

fn io_write_byte(io: ExternalIO, byte: u8) -> bool:
    """Write a single byte. Returns true on success."""
    # Store byte at a known scratch location, pass pointer
    val written = io.write(byte.to_u64(), 1)
    written == 1

fn io_write_text(io: ExternalIO, msg: text) -> i32:
    """Write a text string. Returns bytes written."""
    val len = msg.length()
    if len == 0:
        return 0
    var written = 0
    var i = 0
    while i < len:
        val ch = msg.char_at(i)
        io.write(ch.to_u64(), 1)
        written = written + 1
        i = i + 1
    written
