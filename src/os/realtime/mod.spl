# @platform: baremetal
#
# Realtime Simple OS — Minimal deterministic RTOS
#
# Fixed-priority preemptive scheduler, bounded task count,
# no dynamic allocation, JTAG state save/restore.
# Targets: ARM Cortex-M, RISC-V RV32, x86_64.

val RTOS_VERSION_MAJOR: i32 = 0
val RTOS_VERSION_MINOR: i32 = 1
val MAX_TASKS: i32 = 16
val NUM_PRIORITIES: i32 = 8
