"""SimpleOS process-backed apps specification tests.

Self-contained: all classes defined inline.
Covers ProcessRecord, AppManifest, SyscallResult, and WmWindowHandle.
20 tests total.
"""

use std.spipe.*

# ---------------------------------------------------------------------------
# Inline: ProcessRecord
# ---------------------------------------------------------------------------

class ProcessRecord:
    pid: i64
    app_path: text
    run_status: text
    exit_code: i64
    has_window: bool

    static fn new(pid: i64, app_path: text) -> ProcessRecord:
        ProcessRecord(
            pid: pid,
            app_path: app_path,
            run_status: "running",
            exit_code: 0,
            has_window: false
        )

    me is_running() -> bool:
        self.run_status == "running"

    me is_zombie() -> bool:
        self.run_status == "zombie"

    me is_faulted() -> bool:
        self.run_status == "faulted"

    me mark_exited(code: i64) -> ProcessRecord:
        ProcessRecord(
            pid: self.pid,
            app_path: self.app_path,
            run_status: "exited",
            exit_code: code,
            has_window: self.has_window
        )

    me mark_zombie() -> ProcessRecord:
        ProcessRecord(
            pid: self.pid,
            app_path: self.app_path,
            run_status: "zombie",
            exit_code: self.exit_code,
            has_window: self.has_window
        )

    me mark_faulted(code: i64) -> ProcessRecord:
        ProcessRecord(
            pid: self.pid,
            app_path: self.app_path,
            run_status: "faulted",
            exit_code: code,
            has_window: self.has_window
        )

    me with_window() -> ProcessRecord:
        ProcessRecord(
            pid: self.pid,
            app_path: self.app_path,
            run_status: self.run_status,
            exit_code: self.exit_code,
            has_window: true
        )

# ---------------------------------------------------------------------------
# Inline: AppManifest
# ---------------------------------------------------------------------------

class AppManifest:
    app_id: text
    exec_path: text
    launch_mode: text
    needs_window: bool
    needs_net: bool

    static fn gui_app(app_id: text, exec_path: text) -> AppManifest:
        AppManifest(
            app_id: app_id,
            exec_path: exec_path,
            launch_mode: "gui",
            needs_window: true,
            needs_net: false
        )

    static fn cli_app(app_id: text, exec_path: text) -> AppManifest:
        AppManifest(
            app_id: app_id,
            exec_path: exec_path,
            launch_mode: "cli",
            needs_window: false,
            needs_net: false
        )

    me is_gui() -> bool:
        self.launch_mode == "gui"

    me is_cli() -> bool:
        self.launch_mode == "cli"

    me is_valid() -> bool:
        val has_id = self.app_id.len() > 0
        val has_path = self.exec_path.len() > 0
        has_id and has_path

    me with_net() -> AppManifest:
        AppManifest(
            app_id: self.app_id,
            exec_path: self.exec_path,
            launch_mode: self.launch_mode,
            needs_window: self.needs_window,
            needs_net: true
        )

# ---------------------------------------------------------------------------
# Inline: SyscallResult
# ---------------------------------------------------------------------------

val ENOSYS_CODE = 38
val EINVAL_CODE = 22
val ENOMEM_CODE = 12
val EFAULT_CODE = 14

class SyscallResult:
    is_ok: bool
    retval: i64
    errno_code: i64

    static fn ok(retval: i64) -> SyscallResult:
        SyscallResult(is_ok: true, retval: retval, errno_code: 0)

    static fn err(errno_code: i64) -> SyscallResult:
        SyscallResult(is_ok: false, retval: -1, errno_code: errno_code)

    static fn enosys() -> SyscallResult:
        SyscallResult(is_ok: false, retval: -1, errno_code: ENOSYS_CODE)

    static fn efault() -> SyscallResult:
        SyscallResult(is_ok: false, retval: -1, errno_code: EFAULT_CODE)

    me is_enosys() -> bool:
        val not_ok = self.is_ok == false
        not_ok and self.errno_code == ENOSYS_CODE

    me is_efault() -> bool:
        val not_ok = self.is_ok == false
        not_ok and self.errno_code == EFAULT_CODE

    me pid_val() -> i64:
        if self.is_ok:
            return self.retval
        return -1

# ---------------------------------------------------------------------------
# Inline: WmWindowHandle
# ---------------------------------------------------------------------------

class WmWindowHandle:
    window_id: i64
    owner_pid: i64
    title: text
    ipc_status: text
    width: i64
    height: i64

    static fn create(window_id: i64, owner_pid: i64, title: text) -> WmWindowHandle:
        WmWindowHandle(
            window_id: window_id,
            owner_pid: owner_pid,
            title: title,
            ipc_status: "pending",
            width: 0,
            height: 0
        )

    me is_active() -> bool:
        self.ipc_status == "active"

    me is_pending() -> bool:
        self.ipc_status == "pending"

    me is_closed() -> bool:
        self.ipc_status == "closed"

    me is_process_backed() -> bool:
        self.owner_pid > 0

    me activate(w: i64, h: i64) -> WmWindowHandle:
        WmWindowHandle(
            window_id: self.window_id,
            owner_pid: self.owner_pid,
            title: self.title,
            ipc_status: "active",
            width: w,
            height: h
        )

    me close() -> WmWindowHandle:
        WmWindowHandle(
            window_id: self.window_id,
            owner_pid: self.owner_pid,
            title: self.title,
            ipc_status: "closed",
            width: self.width,
            height: self.height
        )

    me matches_pid(pid: i64) -> bool:
        self.owner_pid == pid

# ---------------------------------------------------------------------------
# Tests: ProcessRecord (5 tests)
# ---------------------------------------------------------------------------

describe "ProcessRecord":
    it "new process starts as running":
        val p = ProcessRecord.new(101, "/sys/apps/browser")
        expect(p.is_running()).to_equal(true)

    it "new process pid is set":
        val p = ProcessRecord.new(42, "/sys/apps/editor")
        expect(p.pid).to_equal(42)

    it "new process app_path is set":
        val p = ProcessRecord.new(10, "/sys/apps/hello")
        expect(p.app_path).to_equal("/sys/apps/hello")

    it "mark_exited sets exit_code":
        val p = ProcessRecord.new(5, "/sys/apps/cli")
        val p2 = p.mark_exited(0)
        expect(p2.exit_code).to_equal(0)

    it "mark_zombie transitions status":
        val p = ProcessRecord.new(7, "/sys/apps/srv")
        val p2 = p.mark_zombie()
        expect(p2.is_zombie()).to_equal(true)

# ---------------------------------------------------------------------------
# Tests: AppManifest (5 tests)
# ---------------------------------------------------------------------------

describe "AppManifest":
    it "gui_app sets is_gui true":
        val m = AppManifest.gui_app("browser", "/sys/apps/browser/browser.elf")
        expect(m.is_gui()).to_equal(true)

    it "cli_app sets is_cli true":
        val m = AppManifest.cli_app("sh", "/bin/sh")
        expect(m.is_cli()).to_equal(true)

    it "is_valid returns true for non-empty fields":
        val m = AppManifest.gui_app("editor", "/sys/apps/editor/editor.elf")
        expect(m.is_valid()).to_equal(true)

    it "gui_app needs_window is true":
        val m = AppManifest.gui_app("calc", "/sys/apps/calc/calc.elf")
        expect(m.needs_window).to_equal(true)

    it "cli_app needs_window is false":
        val m = AppManifest.cli_app("cat", "/bin/cat")
        expect(m.needs_window == false).to_equal(true)

# ---------------------------------------------------------------------------
# Tests: SyscallResult (5 tests)
# ---------------------------------------------------------------------------

describe "SyscallResult":
    it "ok result is_ok true":
        val r = SyscallResult.ok(99)
        expect(r.is_ok).to_equal(true)

    it "ok result retval preserved":
        val r = SyscallResult.ok(1234)
        expect(r.retval).to_equal(1234)

    it "enosys is_enosys true":
        val r = SyscallResult.enosys()
        expect(r.is_enosys()).to_equal(true)

    it "efault is_efault true":
        val r = SyscallResult.efault()
        expect(r.is_efault()).to_equal(true)

    it "ok pid_val returns retval":
        val r = SyscallResult.ok(77)
        expect(r.pid_val()).to_equal(77)

# ---------------------------------------------------------------------------
# Tests: WmWindowHandle (5 tests)
# ---------------------------------------------------------------------------

describe "WmWindowHandle":
    it "create sets ipc_status to pending":
        val w = WmWindowHandle.create(1, 101, "Browser")
        expect(w.is_pending()).to_equal(true)

    it "is_process_backed true when pid > 0":
        val w = WmWindowHandle.create(2, 55, "Editor")
        expect(w.is_process_backed()).to_equal(true)

    it "activate sets ipc_status to active":
        val w = WmWindowHandle.create(3, 10, "Hello")
        val w2 = w.activate(800, 600)
        expect(w2.is_active()).to_equal(true)

    it "activate sets width and height":
        val w = WmWindowHandle.create(4, 12, "Calc")
        val w2 = w.activate(1024, 768)
        expect(w2.width).to_equal(1024)

    it "matches_pid returns true for owner":
        val w = WmWindowHandle.create(5, 99, "Terminal")
        expect(w.matches_pid(99)).to_equal(true)
