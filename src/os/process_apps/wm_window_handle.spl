"""WmWindowHandle — IPC-based window registration record for the WM/compositor.

When a process-backed GUI app creates a window it sends an IPC message
to the WM. The WM stores a WmWindowHandle associating the window with
the owning PID instead of a resident manifest entry.
"""

# Window IPC status: "pending" | "active" | "hidden" | "closed"

class WmWindowHandle:
    window_id: i64
    owner_pid: i64
    title: text
    ipc_status: text
    width: i64
    height: i64

    static fn create(window_id: i64, owner_pid: i64, title: text) -> WmWindowHandle:
        WmWindowHandle(
            window_id: window_id,
            owner_pid: owner_pid,
            title: title,
            ipc_status: "pending",
            width: 0,
            height: 0
        )

    me is_active() -> bool:
        self.ipc_status == "active"

    me is_pending() -> bool:
        self.ipc_status == "pending"

    me is_closed() -> bool:
        self.ipc_status == "closed"

    me is_process_backed() -> bool:
        self.owner_pid > 0

    me activate(w: i64, h: i64) -> WmWindowHandle:
        WmWindowHandle(
            window_id: self.window_id,
            owner_pid: self.owner_pid,
            title: self.title,
            ipc_status: "active",
            width: w,
            height: h
        )

    me close() -> WmWindowHandle:
        WmWindowHandle(
            window_id: self.window_id,
            owner_pid: self.owner_pid,
            title: self.title,
            ipc_status: "closed",
            width: self.width,
            height: self.height
        )

    me matches_pid(pid: i64) -> bool:
        self.owner_pid == pid
