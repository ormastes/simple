# Crash Policy — Default Failure Domains and Supervisor Limits
#
# Establishes the default containment model used by hosted apps, services,
# kernel-resident components, and baremetal app domains.

val SUPERVISOR_ONE_FOR_ONE = "one_for_one"

extern fn rt_thread_available_parallelism() -> i64

enum AppClass:
    UserApp
    SystemService
    KernelComponent
    BaremetalAppDomain

enum AppFaultDomain:
    Process
    SupervisedTask
    KernelResident
    BaremetalDomain

enum CrashReason:
    CleanExit
    Panic
    Trap
    Abort
    Signal(i32)
    WatchdogTimeout
    InvariantViolation
    ExitCode(i32)

enum AppExitDisposition:
    Restart
    Stop
    Escalate
    Reboot
    Halt
    Quarantine

struct SupervisorPolicy:
    strategy: text
    max_restarts: i32
    restart_window_micros: i64
    backoff_millis: i64
    quarantine_on_limit: bool

enum AppWorkloadProfile:
    InteractiveDefault
    DashboardSession
    LlmWorker
    CompilerHeavy
    TestRunnerHeavy
    BatchIndexerHeavy
    BaremetalDomain

struct RuntimeBudget:
    profile: AppWorkloadProfile
    memory_limit_mb: i64
    cpu_time_limit_ms: i64
    wall_timeout_ms: i64
    max_fds: i64
    max_procs: i64
    max_threads: i64
    recycle_jobs: i64
    recycle_after_micros: i64
    quarantine_millis: i64

fn default_fault_domain(app_class: AppClass) -> AppFaultDomain:
    match app_class:
        case AppClass.UserApp:
            AppFaultDomain.Process
        case AppClass.SystemService:
            AppFaultDomain.SupervisedTask
        case AppClass.KernelComponent:
            AppFaultDomain.KernelResident
        case AppClass.BaremetalAppDomain:
            AppFaultDomain.BaremetalDomain

fn default_supervisor_policy(app_class: AppClass) -> SupervisorPolicy:
    match app_class:
        case AppClass.UserApp:
            SupervisorPolicy(
                strategy: SUPERVISOR_ONE_FOR_ONE,
                max_restarts: 1,
                restart_window_micros: 30_000_000,
                backoff_millis: 250,
                quarantine_on_limit: true
            )
        case AppClass.SystemService:
            SupervisorPolicy(
                strategy: SUPERVISOR_ONE_FOR_ONE,
                max_restarts: 5,
                restart_window_micros: 60_000_000,
                backoff_millis: 0,
                quarantine_on_limit: true
            )
        case AppClass.KernelComponent:
            SupervisorPolicy(
                strategy: SUPERVISOR_ONE_FOR_ONE,
                max_restarts: 0,
                restart_window_micros: 0,
                backoff_millis: 0,
                quarantine_on_limit: false
            )
        case AppClass.BaremetalAppDomain:
            SupervisorPolicy(
                strategy: SUPERVISOR_ONE_FOR_ONE,
                max_restarts: 1,
                restart_window_micros: 10_000_000,
                backoff_millis: 0,
                quarantine_on_limit: false
            )

# ============================================================================
# Crash Record — structured crash metadata
# ============================================================================

class CrashRecord:
    """Structured crash metadata for a single crash event."""
    timestamp: text
    pid: i64
    reason: text
    domain: text
    exit_code: i64
    message: text
    source_location: text
    restart_attempt: i64

    fn is_fatal() -> bool:
        """Returns true if crash should not be retried."""
        self.reason == "trap" or self.reason == "abort" or self.reason == "invariant_violation"

    fn summary() -> text:
        """One-line summary for logging."""
        self.reason + " (pid=" + str(self.pid) + ", exit=" + str(self.exit_code) + ", attempt=" + str(self.restart_attempt) + ")"

class CrashLog:
    """Accumulates crash records for a supervised component."""
    component_id: text
    records: [CrashRecord]
    max_records: i64

    static fn create(component_id: text) -> CrashLog:
        CrashLog(component_id: component_id, records: [], max_records: 100)

    me add(record: CrashRecord):
        """Add a crash record, trimming oldest if over limit."""
        self.records = self.records + [record]
        if self.records.len() > self.max_records:
            self.records = self.records[self.records.len() - self.max_records..]

    fn count() -> i64:
        self.records.len()

    fn last() -> CrashRecord?:
        if self.records.len() == 0:
            return nil
        Some(self.records[self.records.len() - 1])

    fn recent(n: i64) -> [CrashRecord]:
        """Get the N most recent crash records."""
        if n >= self.records.len():
            return self.records
        self.records[self.records.len() - n..]

    fn has_fatal() -> bool:
        """Check if any crash record is fatal (should not retry)."""
        for r in self.records:
            if r.is_fatal():
                return true
        false

fn make_crash_record(reason: text, domain: text, exit_code: i64, message: text) -> CrashRecord:
    CrashRecord(
        timestamp: "",
        pid: 0,
        reason: reason,
        domain: domain,
        exit_code: exit_code,
        message: message,
        source_location: "",
        restart_attempt: 0
    )

fn default_invariant_violation_disposition(app_class: AppClass) -> AppExitDisposition:
    match app_class:
        case AppClass.UserApp:
            AppExitDisposition.Quarantine
        case AppClass.SystemService:
            AppExitDisposition.Escalate
        case AppClass.KernelComponent:
            AppExitDisposition.Halt
        case AppClass.BaremetalAppDomain:
            AppExitDisposition.Reboot

fn classify_exit_code(exit_code: i32) -> CrashReason:
    if exit_code == 0:
        return CrashReason.CleanExit
    if exit_code == 101:
        return CrashReason.Panic
    if exit_code == 132:
        return CrashReason.Trap
    if exit_code == 134:
        return CrashReason.Abort
    if exit_code >= 128:
        return CrashReason.Signal(exit_code - 128)
    CrashReason.ExitCode(exit_code)

fn crash_reason_text(reason: CrashReason) -> text:
    match reason:
        case CrashReason.CleanExit:
            "clean_exit"
        case CrashReason.Panic:
            "panic"
        case CrashReason.Trap:
            "trap"
        case CrashReason.Abort:
            "abort"
        case CrashReason.Signal(code):
            "signal({code})"
        case CrashReason.WatchdogTimeout:
            "watchdog_timeout"
        case CrashReason.InvariantViolation:
            "invariant_violation"
        case CrashReason.ExitCode(code):
            "exit_code({code})"

fn is_failure_reason(reason: CrashReason) -> bool:
    match reason:
        case CrashReason.CleanExit:
            false
        case _:
            true

fn supervisor_restart_limit_reached(policy: SupervisorPolicy, restart_count: i32) -> bool:
    restart_count >= policy.max_restarts

fn restart_limit_disposition(policy: SupervisorPolicy) -> AppExitDisposition:
    if policy.quarantine_on_limit:
        return AppExitDisposition.Quarantine
    AppExitDisposition.Stop

fn _half_available_threads(available: i64) -> i64:
    if available <= 1:
        return 1
    val half = available / 2
    if half <= 0:
        return 1
    half

fn half_available_threads() -> i64:
    _half_available_threads(rt_thread_available_parallelism())

fn is_heavy_workload_profile(profile: AppWorkloadProfile) -> bool:
    match profile:
        case AppWorkloadProfile.CompilerHeavy:
            true
        case AppWorkloadProfile.TestRunnerHeavy:
            true
        case AppWorkloadProfile.BatchIndexerHeavy:
            true
        case _:
            false

fn default_runtime_budget(profile: AppWorkloadProfile) -> RuntimeBudget:
    val half_threads = half_available_threads()
    val all_threads = rt_thread_available_parallelism()

    match profile:
        case AppWorkloadProfile.InteractiveDefault:
            RuntimeBudget(
                profile: profile,
                memory_limit_mb: 8192,
                cpu_time_limit_ms: 30000,
                wall_timeout_ms: 30000,
                max_fds: 256,
                max_procs: 32,
                max_threads: half_threads,
                recycle_jobs: 100,
                recycle_after_micros: 1_800_000_000,
                quarantine_millis: 900_000
            )
        case AppWorkloadProfile.DashboardSession:
            RuntimeBudget(
                profile: profile,
                memory_limit_mb: 8192,
                cpu_time_limit_ms: 30000,
                wall_timeout_ms: 30000,
                max_fds: 256,
                max_procs: 32,
                max_threads: half_threads,
                recycle_jobs: 100,
                recycle_after_micros: 1_800_000_000,
                quarantine_millis: 900_000
            )
        case AppWorkloadProfile.LlmWorker:
            RuntimeBudget(
                profile: profile,
                memory_limit_mb: 8192,
                cpu_time_limit_ms: 600000,
                wall_timeout_ms: 600000,
                max_fds: 256,
                max_procs: 32,
                max_threads: half_threads,
                recycle_jobs: 100,
                recycle_after_micros: 1_800_000_000,
                quarantine_millis: 900_000
            )
        case AppWorkloadProfile.CompilerHeavy:
            RuntimeBudget(
                profile: profile,
                memory_limit_mb: 16384,
                cpu_time_limit_ms: 3_600_000,
                wall_timeout_ms: 3_600_000,
                max_fds: 2048,
                max_procs: 256,
                max_threads: if all_threads <= 0: 1 else: all_threads,
                recycle_jobs: 20,
                recycle_after_micros: 3_600_000_000,
                quarantine_millis: 900_000
            )
        case AppWorkloadProfile.TestRunnerHeavy:
            RuntimeBudget(
                profile: profile,
                memory_limit_mb: 12288,
                cpu_time_limit_ms: 3_600_000,
                wall_timeout_ms: 3_600_000,
                max_fds: 1024,
                max_procs: 256,
                max_threads: if all_threads <= 0: 1 else: all_threads,
                recycle_jobs: 50,
                recycle_after_micros: 3_600_000_000,
                quarantine_millis: 900_000
            )
        case AppWorkloadProfile.BatchIndexerHeavy:
            val capped_threads = if all_threads <= 1:
                1
            elif all_threads == 2:
                2
            else:
                (all_threads * 3) / 4
            RuntimeBudget(
                profile: profile,
                memory_limit_mb: 12288,
                cpu_time_limit_ms: 1_800_000,
                wall_timeout_ms: 1_800_000,
                max_fds: 1024,
                max_procs: 128,
                max_threads: capped_threads,
                recycle_jobs: 25,
                recycle_after_micros: 3_600_000_000,
                quarantine_millis: 900_000
            )
        case AppWorkloadProfile.BaremetalDomain:
            RuntimeBudget(
                profile: profile,
                memory_limit_mb: 0,
                cpu_time_limit_ms: 0,
                wall_timeout_ms: 0,
                max_fds: 0,
                max_procs: 0,
                max_threads: 1,
                recycle_jobs: 0,
                recycle_after_micros: 0,
                quarantine_millis: 0
            )
