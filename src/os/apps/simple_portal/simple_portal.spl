# simple_portal filesystem app identity

val SIMPLE_PORTAL_APP_ID: text = "/sys/apps/simple_portal"
val SIMPLE_PORTAL_EXEC_PATH: text = "/sys/apps/simple_portal.smf"
val SIMPLE_PORTAL_CONTENT_ROOT: text = "/sys/apps/simple_portal"
val SIMPLE_PORTAL_DATA_ROOT: text = "/var/lib/simple_portal"

pub fn simple_portal_app_id() -> text:
    SIMPLE_PORTAL_APP_ID

pub fn simple_portal_exec_path() -> text:
    SIMPLE_PORTAL_EXEC_PATH

pub fn simple_portal_content_root() -> text:
    SIMPLE_PORTAL_CONTENT_ROOT

pub fn simple_portal_data_root() -> text:
    SIMPLE_PORTAL_DATA_ROOT
