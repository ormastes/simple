use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class FontViewerApp:

    static fn new() -> FontViewerApp:
        FontViewerApp()

    me build_ui() -> UISession:
        val font_list = panel("font_list", "Fonts", [
            button("btn_font_sans", "Sans Serif", "fontviewer.select.sans"),
            button("btn_font_serif", "Serif", "fontviewer.select.serif"),
            button("btn_font_mono", "Monospace", "fontviewer.select.mono"),
            button("btn_font_cursive", "Cursive", "fontviewer.select.cursive"),
            button("btn_font_fantasy", "Fantasy", "fontviewer.select.fantasy"),
            button("btn_font_roboto", "Roboto", "fontviewer.select.roboto"),
            button("btn_font_ubuntu", "Ubuntu", "fontviewer.select.ubuntu"),
            button("btn_font_noto", "Noto Sans", "fontviewer.select.noto")
        ])

        val preview_area = panel("font_preview", "Preview", [
            text_widget("preview_large", "The quick brown fox"),
            text_widget("preview_medium", "jumps over the lazy dog"),
            text_widget("preview_small", "ABCDEFGHIJKLMNOPQRSTUVWXYZ"),
            text_widget("preview_digits", "0123456789 !@#$%^&*()")
        ])

        val font_info = panel("font_info", "Font Info", [
            row("info_row1", [
                label("name_label", "Name:"),
                text_widget("font_name", "Sans Serif")
            ]),
            row("info_row2", [
                label("style_label", "Style:"),
                text_widget("font_style", "Regular")
            ]),
            row("info_row3", [
                label("glyphs_label", "Glyphs:"),
                text_widget("font_glyphs", "1024")
            ])
        ])

        val status = statusbar("fontviewer_status", "Sans Serif  Regular", "1024 glyphs")

        val root = row("fontviewer_root", [
            font_list,
            column("fontviewer_right", [
                preview_area,
                font_info,
                status
            ])
        ])

        val tree = build_tree_with_title(root, "Font Viewer", "dark")
        UISession.new(tree)
