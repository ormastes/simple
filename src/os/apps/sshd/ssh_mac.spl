#![allow(unnamed_duplicate_typed_args)]
# SSH MAC helpers for negotiated transport algorithms.

use os.crypto.sha256.{sha256, sha256_hmac}
use os.crypto.sha512.{sha512}

fn _u8_at(data: [u8], idx: u64) -> u8:
    data[idx]

fn _append_u32_be(buf: [u8], value: u32):
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push((value & 0xFF).to_u8())

fn _append_bytes(dst: [u8], src: [u8]):
    var i: u64 = 0
    while i < src.len():
        dst.push(_u8_at(src, i))
        i = i + 1

fn _normalize_sha512_hmac_key(key: [u8]) -> [u8]:
    var normalized: [u8] = []
    if key.len() > 128:
        normalized = sha512(key)
    else:
        _append_bytes(normalized, key)

    while normalized.len() < 128:
        normalized.push(0)
    normalized

fn _sha512_hmac_with_normalized_key(key_block: [u8], data: [u8]) -> [u8]:
    var ipad: [u8] = []
    var opad: [u8] = []
    var i: u64 = 0
    while i < key_block.len():
        ipad.push(_u8_at(key_block, i) ^ 0x36)
        opad.push(_u8_at(key_block, i) ^ 0x5C)
        i = i + 1

    var inner: [u8] = []
    _append_bytes(inner, ipad)
    _append_bytes(inner, data)
    val inner_hash = sha512(inner)

    var outer: [u8] = []
    _append_bytes(outer, opad)
    _append_bytes(outer, inner_hash)
    sha512(outer)

fn sha512_hmac(key: [u8], data: [u8]) -> [u8]:
    val normalized = _normalize_sha512_hmac_key(key)
    _sha512_hmac_with_normalized_key(normalized, data)

fn ssh_mac_is_none(mac_algorithm: text) -> bool:
    mac_algorithm == "" or mac_algorithm == "none"

fn ssh_mac_is_etm(mac_algorithm: text) -> bool:
    mac_algorithm.ends_with("-etm@openssh.com")

fn ssh_mac_len(mac_algorithm: text) -> u64:
    if ssh_mac_is_none(mac_algorithm):
        return 0
    if mac_algorithm == "hmac-sha2-256-etm@openssh.com":
        return 32
    if mac_algorithm == "hmac-sha2-512-etm@openssh.com":
        return 64
    0

fn _ssh_mac_message(sequence: u32, packet: [u8]) -> [u8]:
    var data: [u8] = []
    _append_u32_be(data, sequence)
    _append_bytes(data, packet)
    data

fn ssh_mac_compute(mac_algorithm: text, mac_key: [u8], sequence: u32, packet: [u8]) -> Result<[u8], text>:
    if ssh_mac_is_none(mac_algorithm):
        return Ok([])

    val mac_input = _ssh_mac_message(sequence, packet)
    if mac_algorithm == "hmac-sha2-256-etm@openssh.com":
        return Ok(sha256_hmac(mac_key, mac_input))
    if mac_algorithm == "hmac-sha2-512-etm@openssh.com":
        return Ok(sha512_hmac(mac_key, mac_input))

    Err("unsupported ssh mac algorithm: {mac_algorithm}")

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len():
        if _u8_at(a, i) != _u8_at(b, i):
            return false
        i = i + 1
    true

fn ssh_mac_verify(mac_algorithm: text, mac_key: [u8], sequence: u32, packet: [u8], expected_mac: [u8]) -> Result<bool, text>:
    val computed = ssh_mac_compute(mac_algorithm, mac_key, sequence, packet)?
    Ok(_bytes_equal(computed, expected_mac))
