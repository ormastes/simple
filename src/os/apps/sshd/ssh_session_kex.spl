fn _push_u32_be_live(buf: [u8], val_: u64) -> [u8]:
    var out = buf
    out = rt_push_byte(out, ((val_ >> 24) & 0xFF).to_i64())
    out = rt_push_byte(out, ((val_ >> 16) & 0xFF).to_i64())
    out = rt_push_byte(out, ((val_ >> 8) & 0xFF).to_i64())
    out = rt_push_byte(out, (val_ & 0xFF).to_i64())
    out

fn _push_bytes_live(buf: [u8], data: [u8]) -> [u8]:
    var out = buf
    var i: u64 = 0
    while i < data.len():
        out = rt_push_byte(out, _u8_at(data, i).to_i64())
        i = i + 1
    out

fn _push_string_live(buf: [u8], data: [u8]) -> [u8]:
    _push_bytes_live(_push_u32_be_live(buf, data.len()), data)

fn _build_live_ed25519_host_key_blob(public_key: [u8]) -> [u8]:
    var blob: [u8] = []
    blob = _push_u32_be_live(blob, 11)
    blob = rt_push_byte(blob, 0x73)
    blob = rt_push_byte(blob, 0x73)
    blob = rt_push_byte(blob, 0x68)
    blob = rt_push_byte(blob, 0x2D)
    blob = rt_push_byte(blob, 0x65)
    blob = rt_push_byte(blob, 0x64)
    blob = rt_push_byte(blob, 0x32)
    blob = rt_push_byte(blob, 0x35)
    blob = rt_push_byte(blob, 0x35)
    blob = rt_push_byte(blob, 0x31)
    blob = rt_push_byte(blob, 0x39)
    blob = _push_string_live(blob, public_key)
    blob

