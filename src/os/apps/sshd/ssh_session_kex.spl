extern fn rt_push_byte(arr: [u8], byte_val: i64) -> [u8]
extern fn serial_println(msg: text)

fn log_raw_println(msg: text):
    serial_println(msg)

fn _live_exchange_hash_debug(
    client_version: [u8],
    server_version: [u8],
    client_kexinit: [u8],
    server_kexinit: [u8],
    host_key_blob: [u8],
    client_public: [u8],
    server_public: [u8],
    shared_secret: [u8]
) -> [u8]:
    serial_println("[sshd-session] exchash: v_c")
    var hash_input: [u8] = []
    hash_input = _push_string_live(hash_input, client_version)
    serial_println("[sshd-session] exchash: v_s")
    hash_input = _push_string_live(hash_input, server_version)
    serial_println("[sshd-session] exchash: i_c")
    hash_input = _push_string_live(hash_input, client_kexinit)
    serial_println("[sshd-session] exchash: i_s")
    hash_input = _push_string_live(hash_input, server_kexinit)
    serial_println("[sshd-session] exchash: k_s")
    hash_input = _push_string_live(hash_input, host_key_blob)
    serial_println("[sshd-session] exchash: q_c")
    hash_input = _push_string_live(hash_input, client_public)
    serial_println("[sshd-session] exchash: q_s")
    hash_input = _push_string_live(hash_input, server_public)
    serial_println("[sshd-session] exchash: k")
    hash_input = _push_mpint_bytes(hash_input, curve25519_shared_secret_mpint_bytes(shared_secret))
    serial_println("[sshd-session] exchash: sha256 input len={hash_input.len()}")
    val digest = rt_tls13_sha256(hash_input)
    serial_println("[sshd-session] exchash: sha256 out len={digest.len()}")
    digest

fn _live_exchange_hash_fast(
    client_version: [u8],
    server_version: [u8],
    client_kexinit: [u8],
    server_kexinit: [u8],
    host_key_blob: [u8],
    client_public: [u8],
    server_public: [u8],
    shared_secret: [u8]
) -> [u8]:
    serial_println("[sshd-session] exchash lens vc={client_version.len()} vs={server_version.len()} ic={client_kexinit.len()} is={server_kexinit.len()} ks={host_key_blob.len()} qc={client_public.len()} qs={server_public.len()} k={shared_secret.len()}")
    serial_println("[sshd-session] exchash sha vc={_bytes_to_hex(rt_tls13_sha256(client_version))}")
    serial_println("[sshd-session] exchash sha vs={_bytes_to_hex(rt_tls13_sha256(server_version))}")
    serial_println("[sshd-session] exchash sha ic={_bytes_to_hex(rt_tls13_sha256(client_kexinit))}")
    serial_println("[sshd-session] exchash sha is={_bytes_to_hex(rt_tls13_sha256(server_kexinit))}")
    serial_println("[sshd-session] exchash sha ks={_bytes_to_hex(rt_tls13_sha256(host_key_blob))}")
    serial_println("[sshd-session] exchash sha qc={_bytes_to_hex(rt_tls13_sha256(client_public))}")
    serial_println("[sshd-session] exchash sha qs={_bytes_to_hex(rt_tls13_sha256(server_public))}")
    serial_println("[sshd-session] exchash sha k={_bytes_to_hex(rt_tls13_sha256(shared_secret))}")
    val shared_secret_mpint = curve25519_shared_secret_mpint_bytes(shared_secret)
    serial_println("[sshd-session] exchash sha k-mpint={_bytes_to_hex(rt_tls13_sha256(shared_secret_mpint))}")
    var hash_input: [u8] = []
    hash_input = _push_string_live(hash_input, client_version)
    hash_input = _push_string_live(hash_input, server_version)
    hash_input = _push_string_live(hash_input, client_kexinit)
    hash_input = _push_string_live(hash_input, server_kexinit)
    hash_input = _push_string_live(hash_input, host_key_blob)
    hash_input = _push_string_live(hash_input, client_public)
    hash_input = _push_string_live(hash_input, server_public)
    hash_input = _push_mpint_bytes(hash_input, shared_secret_mpint)
    rt_tls13_sha256(hash_input)

