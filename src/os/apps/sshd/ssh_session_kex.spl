# SSH Session — Key Exchange Phase (Phase 2)
#
# Extracted from ssh_session.spl.
# Contains: impl SshSession.do_kex()

use os.apps.sshd.ssh_packet.{ssh_put_u32, ssh_get_u32}
use os.apps.sshd.ssh_transport.{SshKexInit, SSH_MSG_KEXINIT, SSH_MSG_IGNORE, SSH_MSG_DEBUG, SSH_DISCONNECT_PROTOCOL_ERROR, ssh_build_kexinit, ssh_parse_kexinit, ssh_negotiate_algorithms, ssh_build_ext_info_server_sig_algs, ssh_kex_uses_strict_kex, ssh_build_disconnect}
use os.apps.sshd.ssh_kex.{HostKeySet, HostCertificateSet, SSH_MSG_KEX_ECDH_REPLY, ssh_kex_generate_private_key, ssh_kex_compute_exchange_hash, ssh_derive_keys, ssh_build_kex_ecdh_reply, ssh_parse_kex_ecdh_init, ssh_build_newkeys, ssh_build_kexinit_for_host_keys_and_certs, ssh_sign_exchange_hash, ssh_build_ed25519_host_key_blob, host_key_set_advertised_algorithms}
use os.apps.sshd.ssh_session.{SshSession, SessionState}
use os.apps.sshd.ssh_session_helpers.{_u8_at, _bytes_to_hex, _copy_bytes_stable, _copy_prefix_stable, _parse_kexinit_fast, _build_host_key_blob_for_algo, _ed25519_public_key_from_seed, _unwrap_ssh_signature, _extract_ed25519_pubkey}
use os.kernel.log.klog_api.{log_info, log_raw_println}
use os.crypto.ed25519.{ed25519_keypair_from_seed, ed25519_sign}
use std.format.{format_hex}

extern fn rt_tls13_x25519_public_key(scalar: [u8]) -> [u8]
extern fn rt_tls13_x25519_shared_secret(scalar: [u8], point: [u8]) -> [u8]
extern fn rt_ed25519_verify(message: [u8], pubkey: [u8], signature: [u8]) -> i64
extern fn rt_push_byte(arr: [u8], byte_val: i64) -> [u8]
extern fn serial_println(msg: text)

impl SshSession:

    # ========================================================================
    # Phase 2: Key Exchange
    # ========================================================================

    me do_kex() -> bool:
        """Perform key exchange (curve25519-sha256)."""
        log_info("[app.sshd] " + "[sshd-session] kex start")
        # Send our KEXINIT — advertise algorithms available in our host key set
        val server_kexinit = if self.host_keys.rsa_pkcs8 != nil:
            ssh_build_kexinit()
        else:
            ssh_build_kexinit_for_host_keys_and_certs(self.host_keys, self.host_certs)
        log_raw_println("[sshd-session] server kexinit len={server_kexinit.len()}")
        self.server_kexinit_payload = server_kexinit
        self.send_packet(server_kexinit)

        # Receive client KEXINIT
        val client_payload = self.recv_packet_payload()
        log_info("[app.sshd] " + "[sshd-session] client kexinit received")
        if client_payload.len() == 0:
            log_info("[app.sshd] " + "[sshd-session] client kexinit missing")
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "no KEXINIT received")
            return false
        if _u8_at(client_payload, 0) == SSH_MSG_IGNORE or _u8_at(client_payload, 0) == SSH_MSG_DEBUG:
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "unexpected pre-kex control message")
            return false
        self.client_kexinit_payload = client_payload

        # Parse client KEXINIT
        var r_client_kex = ssh_parse_kexinit(client_payload)
        if r_client_kex.is_err():
            log_raw_println("[sshd-session] client kexinit parse failed len={client_payload.len()} attempting fast parse")
            r_client_kex = _parse_kexinit_fast(client_payload)
        if r_client_kex.is_err():
            log_raw_println("[sshd-session] client kexinit fast parse err")
            log_info("[app.sshd] " + "[sshd-session] client kexinit parse err")
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "bad KEXINIT")
            return false
        val client_kex = r_client_kex.unwrap()
        log_info("[app.sshd] " + "[sshd-session] client kexinit parsed")
        log_raw_println("[sshd-session] client kex list={client_kex.kex_algorithms}")
        log_raw_println("[sshd-session] client hostkey list={client_kex.server_host_key_algorithms}")
        log_raw_println("[sshd-session] client enc c2s={client_kex.encryption_client_to_server}")
        log_raw_println("[sshd-session] client mac c2s={client_kex.mac_client_to_server}")

        # Parse our own KEXINIT (for negotiation)
        val r_server_kex = _parse_kexinit_fast(server_kexinit)
        val server_kex = r_server_kex.unwrap()
        log_info("[app.sshd] " + "[sshd-session] client kex list={client_kex.kex_algorithms}")
        log_info("[app.sshd] " + "[sshd-session] server kex list={server_kex.kex_algorithms}")
        log_raw_println("[sshd-session] server kex list={server_kex.kex_algorithms}")
        log_raw_println("[sshd-session] server hostkey list={server_kex.server_host_key_algorithms}")
        log_raw_println("[sshd-session] server enc c2s={server_kex.encryption_client_to_server}")
        log_raw_println("[sshd-session] server mac c2s={server_kex.mac_client_to_server}")
        serial_println("[sshd-session] client kex list={client_kex.kex_algorithms}")
        serial_println("[sshd-session] client hostkey list={client_kex.server_host_key_algorithms}")
        serial_println("[sshd-session] client enc c2s={client_kex.encryption_client_to_server}")
        serial_println("[sshd-session] client mac c2s={client_kex.mac_client_to_server}")
        serial_println("[sshd-session] server kex list={server_kex.kex_algorithms}")
        serial_println("[sshd-session] server hostkey list={server_kex.server_host_key_algorithms}")
        serial_println("[sshd-session] server enc c2s={server_kex.encryption_client_to_server}")
        serial_println("[sshd-session] server mac c2s={server_kex.mac_client_to_server}")

        # Negotiate algorithms
        val r_algos = ssh_negotiate_algorithms(client_kex, server_kex)
        if r_algos.is_err():
            match r_algos:
                case Err(msg):
                    serial_println("[sshd-session] algo negotiation err={msg}")
                case Ok(_):
                    pass_dn
            log_raw_println("[sshd-session] algo negotiation failed")
            log_info("[app.sshd] " + "[sshd-session] algo negotiation failed")
            self.disconnect(3, "algorithm negotiation failed")
            return false
        val algos_early = r_algos.unwrap()
        val strict_kex = ssh_kex_uses_strict_kex(client_kex.kex_algorithms, server_kex.kex_algorithms)
        log_info("[app.sshd] " + "[sshd-session] negotiated kex={algos_early.kex} hostkey={algos_early.host_key} c2s={algos_early.cipher_c2s} s2c={algos_early.cipher_s2c}")
        serial_println("[sshd-session] negotiated kex={algos_early.kex} hostkey={algos_early.host_key} c2s={algos_early.cipher_c2s} s2c={algos_early.cipher_s2c}")

        # Receive KEX_ECDH_INIT (client's ephemeral public key)
        val kex_init_payload = self.recv_packet_payload()
        log_raw_println("[sshd-session] client ecdh init received")
        if kex_init_payload.len() == 0:
            log_raw_println("[sshd-session] client ecdh init missing")
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "no KEX_ECDH_INIT")
            return false
        val r_client_pub = ssh_parse_kex_ecdh_init(kex_init_payload)
        if r_client_pub.is_err():
            log_raw_println("[sshd-session] client ecdh init parse err")
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "bad KEX_ECDH_INIT")
            return false
        val client_public = r_client_pub.unwrap()
        log_raw_println("[sshd-session] client ecdh pub len={client_public.len()}")
        log_raw_println("[sshd-session] client ecdh pub={_bytes_to_hex(client_public)}")
        serial_println("[sshd-session] client ecdh pub={_bytes_to_hex(client_public)}")

        # Generate our ephemeral keypair
        val server_private = ssh_kex_generate_private_key()
        val server_public = if server_private.len() == 32 {
            rt_tls13_x25519_public_key(server_private)
        } else {
            []
        }
        log_info("[app.sshd] " + "[sshd-session] server ecdh priv len={server_private.len()} pub len={server_public.len()}")
        serial_println("[sshd-session] server ecdh priv={_bytes_to_hex(server_private)}")
        if server_public.len() != 32:
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "server X25519 public failed")
            return false
        log_info("[app.sshd] " + "[sshd-session] server ecdh pub len={server_public.len()}")
        log_info("[app.sshd] " + "[sshd-session] server ecdh pub={_bytes_to_hex(server_public)}")

        # Compute shared secret
        val shared_secret = if server_private.len() == 32 and client_public.len() == 32 {
            rt_tls13_x25519_shared_secret(server_private, client_public)
        } else {
            []
        }
        if shared_secret.len() != 32:
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "server X25519 shared failed")
            return false
        log_info("[app.sshd] " + "[sshd-session] shared secret len={shared_secret.len()}")
        log_info("[app.sshd] " + "[sshd-session] shared secret={_bytes_to_hex(shared_secret)}")
        serial_println("[sshd-session] shared secret={_bytes_to_hex(shared_secret)}")

        # Resolve negotiated algorithms — needed now for host-key-blob type
        var negotiated_hk_algo = algos_early.host_key

        # Build host key blob for the negotiated algorithm
        var host_key_blob = _build_host_key_blob_for_algo(negotiated_hk_algo, self.host_keys, self.host_certs)
        if host_key_blob.len() == 0:
            if self.host_ed25519_public.len() == 32:
                negotiated_hk_algo = "ssh-ed25519"
                host_key_blob = ssh_build_ed25519_host_key_blob(self.host_ed25519_public)
            elif self.host_keys.ed25519_seed != nil:
                val fallback_pubkey = _ed25519_public_key_from_seed(self.host_keys.ed25519_seed)
                if fallback_pubkey.len() == 32:
                    negotiated_hk_algo = "ssh-ed25519"
                    host_key_blob = ssh_build_ed25519_host_key_blob(fallback_pubkey)
        log_info("[app.sshd] " + "[sshd-session] host key algo={negotiated_hk_algo} blob len={host_key_blob.len()}")
        log_info("[app.sshd] " + "[sshd-session] host key blob={_bytes_to_hex(host_key_blob)}")
        serial_println("[sshd-session] host key blob={_bytes_to_hex(host_key_blob)}")

        # Compute exchange hash
        val exchange_hash = ssh_kex_compute_exchange_hash(
            self.client_version_bytes,
            self.server_version_bytes,
            self.client_kexinit_payload,
            self.server_kexinit_payload,
            host_key_blob,
            client_public,
            server_public,
            shared_secret
        )
        log_info("[app.sshd] " + "[sshd-session] exchange hash len={exchange_hash.len()}")
        serial_println("[sshd-session] exchange hash={_bytes_to_hex(exchange_hash)}")

        # Session ID is the first exchange hash
        if self.session_id.len() == 0:
            self.session_id = exchange_hash

        # Sign the exchange hash with the appropriate host key.
        # For Ed25519 on the live lane, use the daemon's stored public key
        # directly so the signature is bound to the exact host key blob we
        # advertised, instead of re-deriving a public key mid-KEX.
        var sig_blob: [u8] = []
        if negotiated_hk_algo == "ssh-ed25519" and self.host_keys.ed25519_seed != nil and self.host_ed25519_public.len() == 32:
            val stable_seed = _copy_bytes_stable(self.host_keys.ed25519_seed)
            val stable_pub = _copy_bytes_stable(self.host_ed25519_public)
            val stable_hash = _copy_bytes_stable(exchange_hash)
            serial_println("[sshd-session] host ed25519 seed={_bytes_to_hex(stable_seed)}")
            serial_println("[sshd-session] host ed25519 pub={_bytes_to_hex(stable_pub)}")
            val sig_raw = ed25519_sign(stable_seed, stable_pub, stable_hash)
            if sig_raw.len() != 64:
                log_info("[app.sshd] " + "[sshd-session] host key signing err")
                self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "host key signing failed")
                return false
            sig_blob = ssh_put_u32(sig_blob, 11)
            sig_blob.push(0x73)
            sig_blob.push(0x73)
            sig_blob.push(0x68)
            sig_blob.push(0x2D)
            sig_blob.push(0x65)
            sig_blob.push(0x64)
            sig_blob.push(0x32)
            sig_blob.push(0x35)
            sig_blob.push(0x35)
            sig_blob.push(0x31)
            sig_blob.push(0x39)
            sig_blob.push(0x00)
            sig_blob.push(0x00)
            sig_blob.push(0x00)
            sig_blob.push(0x40)
            var sig_i: u64 = 0
            while sig_i < 64 and sig_i < sig_raw.len():
                sig_blob.push(_u8_at(sig_raw, sig_i))
                sig_i = sig_i + 1
        else:
            val r_sig = ssh_sign_exchange_hash(negotiated_hk_algo, self.host_keys, exchange_hash)
            if r_sig.is_err():
                log_info("[app.sshd] " + "[sshd-session] host key signing err")
                self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "host key signing failed")
                return false
            sig_blob = r_sig.unwrap()
        log_info("[app.sshd] " + "[sshd-session] sig blob len={sig_blob.len()}")
        serial_println("[sshd-session] sig blob={_bytes_to_hex(sig_blob)}")
        if negotiated_hk_algo == "ssh-ed25519":
            val sig_pubkey = _extract_ed25519_pubkey(host_key_blob)
            val sig_raw = _unwrap_ssh_signature(sig_blob)
            val sig_verify = rt_ed25519_verify(exchange_hash, sig_pubkey, sig_raw)
            log_info("[app.sshd] " + "[sshd-session] sig self-verify rc={sig_verify} pub len={sig_pubkey.len()} raw len={sig_raw.len()}")
            log_info("[app.sshd] " + "[sshd-session] sig self-verify pub={_bytes_to_hex(sig_pubkey)}")
            log_info("[app.sshd] " + "[sshd-session] sig self-verify hash={_bytes_to_hex(exchange_hash)}")
            log_info("[app.sshd] " + "[sshd-session] sig self-verify raw={_bytes_to_hex(sig_raw)}")
            serial_println("[sshd-session] sig self-verify raw={_bytes_to_hex(sig_raw)}")

        # Send KEX_ECDH_REPLY
        val reply = ssh_build_kex_ecdh_reply(host_key_blob, server_public, sig_blob)
        log_info("[app.sshd] " + "[sshd-session] kex reply len={reply.len()}")
        serial_println("[sshd-session] server ecdh pub={_bytes_to_hex(server_public)}")
        serial_println("[sshd-session] kex reply={_bytes_to_hex(reply)}")
        self.send_packet(reply)

        # Send NEWKEYS
        val newkeys = ssh_build_newkeys()
        self.send_packet(newkeys)
        serial_println("[sshd-session] session_id={_bytes_to_hex(self.session_id)}")
        val keys = ssh_derive_keys(shared_secret, exchange_hash, self.session_id)
        serial_println("[sshd-session] derived iv_s2c={_bytes_to_hex(keys.iv_s2c)}")
        serial_println("[sshd-session] derived key_s2c={_bytes_to_hex(keys.enc_key_s2c)}")
        self.iv_c2s = _copy_bytes_stable(keys.iv_c2s)
        self.iv_s2c = _copy_bytes_stable(keys.iv_s2c)
        var enc_key_len: u64 = 0
        self.negotiated_cipher_c2s = algos_early.cipher_c2s
        self.negotiated_cipher_s2c = algos_early.cipher_s2c
        self.negotiated_mac_c2s = algos_early.mac_c2s
        self.negotiated_mac_s2c = algos_early.mac_s2c
        if algos_early.cipher_c2s == "aes256-gcm@openssh.com" and algos_early.cipher_s2c == "aes256-gcm@openssh.com":
            enc_key_len = 32
        elif algos_early.cipher_c2s == "aes128-gcm@openssh.com" and algos_early.cipher_s2c == "aes128-gcm@openssh.com":
            enc_key_len = 16
        elif algos_early.cipher_c2s == "aes256-ctr" and algos_early.cipher_s2c == "aes256-ctr":
            enc_key_len = 32
        else:
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "unsupported cipher negotiation")
            return false
        self.enc_key_c2s = _copy_prefix_stable(keys.enc_key_c2s, enc_key_len)
        self.enc_key_s2c = _copy_prefix_stable(keys.enc_key_s2c, enc_key_len)
        self.mac_key_c2s = _copy_bytes_stable(keys.mac_key_c2s)
        self.mac_key_s2c = _copy_bytes_stable(keys.mac_key_s2c)
        self.ctr_counter_c2s = _copy_bytes_stable(self.iv_c2s)
        self.ctr_counter_s2c = _copy_bytes_stable(self.iv_s2c)
        serial_println("[sshd-session] stored iv_c2s={_bytes_to_hex(self.iv_c2s)}")
        serial_println("[sshd-session] stored iv_s2c={_bytes_to_hex(self.iv_s2c)}")
        serial_println("[sshd-session] stored key_c2s={_bytes_to_hex(self.enc_key_c2s)}")
        serial_println("[sshd-session] stored key_s2c={_bytes_to_hex(self.enc_key_s2c)}")
        # Receive client NEWKEYS under the pre-NEWKEYS plaintext framing.
        val client_newkeys = self.recv_packet_payload()
        var client_newkeys_len: u64 = client_newkeys.len()
        var client_newkeys_type: u8 = 0
        if client_newkeys_len > 0:
            client_newkeys_type = _u8_at(client_newkeys, 0)
        serial_println("[sshd-session] client NEWKEYS len={client_newkeys_len} type=0x{format_hex(client_newkeys_type.to_i64())}")
        if client_newkeys_len != 1 or client_newkeys_type != 21:
            log_raw_println("[sshd-session] invalid client NEWKEYS payload")
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "invalid NEWKEYS")
            return false

        # Subsequent encrypted packets start a fresh packet sequence space.
        self.cipher.activate(0, 0)
        serial_println("[sshd-session] cipher activated c2s_seq=0 s2c_seq=0")
        log_info("[app.sshd] " + "[sshd-session] cipher activated: c2s_seq=0 s2c_seq=0")

        val ext_info = ssh_build_ext_info_server_sig_algs(host_key_set_advertised_algorithms(self.host_keys))
        self.send_packet(ext_info)
        log_info("[app.sshd] " + "[sshd-session] kex ok")

        self.state = SessionState.Authentication
        true
