    """Deterministic live-QEMU bootstrap scalar used only while baremetal random_bytes is unstable."""
    var key: [u8] = []
    key = rt_push_byte(key, 0x48)
    key = rt_push_byte(key, 0x9c)
    key = rt_push_byte(key, 0x2a)
