fn _build_live_kex_ecdh_reply(host_key_blob: [u8], server_public: [u8], signature: [u8]) -> [u8]:
    var buf: [u8] = []
    buf = rt_push_byte(buf, 31)
    buf = _push_string_live(buf, host_key_blob)
    buf = _push_string_live(buf, server_public)
    buf = _push_string_live(buf, signature)
    buf

