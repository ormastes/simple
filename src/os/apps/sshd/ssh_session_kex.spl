fn _live_host_key_sig_algs() -> text:
    "ssh-ed25519"

fn _rv64_live_x25519_public_runtime_probe(server_private: [u8]) -> [u8]:
    val out = rt_tls13_x25519_public_key(server_private)
    serial_println("[sshd-session] x25519 public runtime len={out.len()}")
    out

fn _rv64_live_x25519_public_pure_probe(server_private: [u8]) -> [u8]:
    serial_println("[sshd-session] x25519 public pure start")
    val out = x25519_base(server_private)
    serial_println("[sshd-session] x25519 public pure len={out.len()}")
    out

fn _rv64_live_x25519_public_alpha(server_private: [u8]) -> [u8]:
    val runtime_out = _rv64_live_x25519_public_runtime_probe(server_private)
    val pure_out = _rv64_live_x25519_public_pure_probe(server_private)
    val selected = dual_backend_choose_bytes(
        "curve25519",
        "rv64_live_public",
        dual_backend_alpha_default_mode(),
        [
            "priv_len=" + server_private.len().to_text()
        ],
        runtime_out,
        pure_out
    )
    if not dual_backend_bytes_equal(runtime_out, pure_out):
        serial_println("[sshd-session] x25519 public alpha mismatch: refusing runtime output")
        return []
    selected

fn _rv64_live_x25519_shared_alpha(server_private: [u8], client_public: [u8]) -> [u8]:
    val runtime_out = rt_tls13_x25519_shared_secret(server_private, client_public)
    val pure_out = x25519(server_private, client_public)
    val selected = dual_backend_choose_bytes(
        "curve25519",
        "rv64_live_shared",
        dual_backend_alpha_default_mode(),
        [
            "priv_len=" + server_private.len().to_text(),
            "pub_len=" + client_public.len().to_text()
        ],
        runtime_out,
        pure_out
    )
    if not dual_backend_bytes_equal(runtime_out, pure_out):
        serial_println("[sshd-session] x25519 shared alpha mismatch: refusing runtime output")
        return []
    selected


fn _derive_session_x25519_private_key(host_seed: [u8]?, client_public: [u8], client_kexinit_payload: [u8]) -> [u8]:
    # Baremetal live lane: use the fixed bootstrap scalar until the full
    # exchange-hash-derived path is proven stable under RV64.
    if client_public.len() == 32:
        return _live_bootstrap_x25519_private_key()
    var seed_material: [u8] = []
    if host_seed != nil:
        seed_material = _copy_bytes_stable(host_seed)
    val stable_client_public = _copy_bytes_stable(client_public)
    var i: u64 = 0
    while i < stable_client_public.len():
        seed_material.push(_u8_at(stable_client_public, i))
        i = i + 1
    val stable_kex_prefix = _copy_prefix_stable(client_kexinit_payload, 64)
    i = 0
    while i < stable_kex_prefix.len():
        seed_material.push(_u8_at(stable_kex_prefix, i))
        i = i + 1
    val digest = ssh_kex_compute_exchange_hash(
        [],
        [],
        [],
        [],
        [],
        [],
        [],
        seed_material
    )
    if digest.len() != 32:
        return _live_bootstrap_x25519_private_key()
    _copy_bytes_stable(digest)

