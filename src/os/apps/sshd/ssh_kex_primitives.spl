fn _push_none(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x04)
    out = _append_byte(out, 0x6E)
    out = _append_byte(out, 0x6F)
    out = _append_byte(out, 0x6E)
    out = _append_byte(out, 0x65)
    out

fn _push_empty_string(buf: [u8]) -> [u8]:
    _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x00)

fn _push_bool_false(buf: [u8]) -> [u8]:
    _append_byte(buf, 0)

fn _push_zero_u32(buf: [u8]) -> [u8]:
    _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x00)

# ============================================================================
# Host key set helpers
# ============================================================================

fn _push_host_key_algorithms(buf: [u8], host_keys: HostKeySet) -> [u8]:
    if host_keys.ed25519_seed != nil:
        if host_keys.rsa_pkcs8 != nil:
            if host_keys.ecdsa_p256_pkcs8 != nil:
                return _push_all_host_key_algorithms(buf)
            return _push_ed25519_rsa_pair(buf)
        if host_keys.ecdsa_p256_pkcs8 != nil:
            return _push_ed25519_ecdsa(buf)
        return _push_ssh_ed25519(buf)

    if host_keys.rsa_pkcs8 != nil:
        if host_keys.ecdsa_p256_pkcs8 != nil:
            return _push_rsa_pair_ecdsa(buf)
        return _push_rsa_sha2_pair(buf)

    if host_keys.ecdsa_p256_pkcs8 != nil:
        return _push_ecdsa_p256(buf)

    _push_ssh_ed25519(buf)

fn host_key_set_advertised_algorithms(host_keys: HostKeySet) -> text:
    """Return comma-separated list of host key algorithms the server can offer.

    Priority order: ssh-ed25519, rsa-sha2-256, rsa-sha2-512, ecdsa-sha2-nistp256.
    RSA algorithms are both listed when an RSA key is present (same key, two hash choices).
    """
    var algos: text = ""
    if host_keys.ed25519_seed != nil:
        algos = "ssh-ed25519"
    if host_keys.rsa_pkcs8 != nil:
        if algos.len() > 0:
            algos = algos + ",rsa-sha2-256,rsa-sha2-512"
        else:
            algos = "rsa-sha2-256,rsa-sha2-512"
    if host_keys.ecdsa_p256_pkcs8 != nil:
        if algos.len() > 0:
            algos = algos + ",ecdsa-sha2-nistp256"
        else:
            algos = "ecdsa-sha2-nistp256"
    if algos.len() == 0:
        algos = "ssh-ed25519"
    algos

fn host_key_algorithms_with_certificates(host_keys: HostKeySet, host_certs: HostCertificateSet) -> text:
    """Return host key algorithms, preferring configured OpenSSH certificates."""
    var algos: text = ""
    if host_certs.ssh_ed25519_cert != nil:
        algos = "ssh-ed25519-cert-v01@openssh.com"
    if host_keys.ed25519_seed != nil:
        algos = if algos.len() > 0: algos + ",ssh-ed25519" else: "ssh-ed25519"

    if host_certs.rsa_sha2_256_cert != nil:
        algos = if algos.len() > 0: algos + ",rsa-sha2-256-cert-v01@openssh.com" else: "rsa-sha2-256-cert-v01@openssh.com"
    if host_certs.rsa_sha2_512_cert != nil:
        algos = if algos.len() > 0: algos + ",rsa-sha2-512-cert-v01@openssh.com" else: "rsa-sha2-512-cert-v01@openssh.com"
    if host_keys.rsa_pkcs8 != nil:
        algos = if algos.len() > 0: algos + ",rsa-sha2-256,rsa-sha2-512" else: "rsa-sha2-256,rsa-sha2-512"

    if host_keys.ecdsa_p256_pkcs8 != nil:
        algos = if algos.len() > 0: algos + ",ecdsa-sha2-nistp256" else: "ecdsa-sha2-nistp256"

    if algos.len() == 0:
        algos = "ssh-ed25519"
    algos

fn _host_certificates_empty(host_certs: HostCertificateSet) -> bool:
    host_certs.ssh_ed25519_cert == nil and
    host_certs.rsa_sha2_256_cert == nil and
    host_certs.rsa_sha2_512_cert == nil
