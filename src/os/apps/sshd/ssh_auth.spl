# SSH Authentication — RFC 4252
#
# Supports password and public key authentication.
# Uses SHA-256 hashed passwords (not plaintext storage).
#
# Authentication flow:
#   1. Client sends SSH_MSG_SERVICE_REQUEST for "ssh-userauth"
#   2. Server responds with SSH_MSG_SERVICE_ACCEPT
#   3. Client sends SSH_MSG_USERAUTH_REQUEST with method
#   4. Server responds SUCCESS or FAILURE

use os.crypto.sha256.{sha256}
use os.apps.sshd.ssh_packet.{ssh_put_u32, ssh_put_text, ssh_put_string, ssh_put_bool, ssh_put_byte, ssh_get_u32, ssh_get_string, ssh_get_text}

# ============================================================================
# Constants
# ============================================================================

val SSH_MSG_USERAUTH_REQUEST: u8 = 50
val SSH_MSG_USERAUTH_FAILURE: u8 = 51
val SSH_MSG_USERAUTH_SUCCESS: u8 = 52
val SSH_MSG_USERAUTH_BANNER: u8 = 53
val SSH_MSG_USERAUTH_PK_OK: u8 = 60

# Maximum authentication attempts before disconnect
val MAX_AUTH_ATTEMPTS: u32 = 6

# ============================================================================
# Types
# ============================================================================

struct SshAuthRequest:
    """Parsed authentication request."""
    username: text
    service: text       # "ssh-connection"
    method: text        # "password", "publickey", or "none"
    password: text      # For password auth (empty otherwise)
    key_algo: text      # For publickey auth
    key_blob: [u8]      # For publickey auth
    has_signature: bool  # For publickey: true means verify, false means probe
    signature: [u8]     # For publickey: client's signature over session data

struct SshUser:
    """A user entry in the authentication database."""
    username: text
    password_hash: [u8]     # SHA-256 of password
    authorized_keys: [[u8]] # List of public key blobs

class SshUserDb:
    """Simple user database for SSH authentication."""
    users: [SshUser]

impl SshUserDb:

    static fn new() -> SshUserDb:
        """Create an empty user database."""
        SshUserDb(users: [])

    me add_user(username: text, password: text):
        """Add a user with a password.

        The password is stored as SHA-256(password), not plaintext.
        """
        val pw_bytes = password.to_bytes()
        val hash = sha256(pw_bytes)
        self.users.push(SshUser(
            username: username,
            password_hash: hash,
            authorized_keys: []
        ))

    me add_user_key(username: text, key_blob: [u8]):
        """Add an authorized public key for an existing user."""
        var i: u64 = 0
        while i < self.users.len():
            if self.users[i].username == username:
                self.users[i].authorized_keys.push(key_blob)
                return
            i = i + 1

    fn find_user(username: text) -> SshUser?:
        """Look up a user by name. Returns nil if not found."""
        var i: u64 = 0
        while i < self.users.len():
            if self.users[i].username == username:
                return self.users[i]
            i = i + 1
        nil

    fn authenticate_password(username: text, password: text) -> bool:
        """Check password against stored hash.

        Returns true if username exists and SHA-256(password) matches.
        """
        val user = self.find_user(username)
        if user == nil:
            return false

        val pw_bytes = password.to_bytes()
        val hash = sha256(pw_bytes)

        # Constant-time comparison
        if hash.len() != user.password_hash.len():
            return false

        var diff: u8 = 0
        var i: u64 = 0
        while i < hash.len():
            diff = diff | (hash[i] ^ user.password_hash[i])
            i = i + 1

        diff == 0

    fn authenticate_key(username: text, key_blob: [u8]) -> bool:
        """Check if a public key is authorized for this user.

        Returns true if the key_blob matches one of the user's authorized keys.
        """
        val user = self.find_user(username)
        if user == nil:
            return false

        var ki: u64 = 0
        while ki < user.authorized_keys.len():
            val stored = user.authorized_keys[ki]
            if _blobs_equal(stored, key_blob):
                return true
            ki = ki + 1

        false

# ============================================================================
# Message Parsing
# ============================================================================

fn ssh_parse_auth_request(data: [u8]) -> Result<SshAuthRequest, text>:
    """Parse SSH_MSG_USERAUTH_REQUEST.

    Format:
      byte      SSH_MSG_USERAUTH_REQUEST (50)
      string    user name
      string    service name ("ssh-connection")
      string    method name ("password", "publickey", "none")
      ... method-specific fields ...
    """
    if data.len() < 2:
        return Err("USERAUTH_REQUEST too short")
    if data[0] != SSH_MSG_USERAUTH_REQUEST:
        return Err("not a USERAUTH_REQUEST")

    var off: u64 = 1

    # Username
    val r_user = ssh_get_text(data, off)
    if val user_pair = r_user.ok():
        off = user_pair.1
    else:
        return Err("USERAUTH: bad username")
    val username = r_user.ok_val().0

    # Service name
    val r_service = ssh_get_text(data, off)
    if val svc_pair = r_service.ok():
        off = svc_pair.1
    else:
        return Err("USERAUTH: bad service")
    val service = r_service.ok_val().0

    # Method name
    val r_method = ssh_get_text(data, off)
    if val meth_pair = r_method.ok():
        off = meth_pair.1
    else:
        return Err("USERAUTH: bad method")
    val method = r_method.ok_val().0

    var password: text = ""
    var key_algo: text = ""
    var key_blob: [u8] = []
    var has_signature: bool = false
    var signature: [u8] = []

    if method == "password":
        # bool    FALSE (no password change)
        # string  plaintext password
        if off < data.len():
            off = off + 1   # skip bool byte
        val r_pw = ssh_get_text(data, off)
        if val pw_pair = r_pw.ok():
            password = pw_pair.0
            off = pw_pair.1

    elif method == "publickey":
        # bool    has_signature
        # string  public key algorithm name
        # string  public key blob
        # [string signature]  — only present when has_signature is true
        if off < data.len():
            has_signature = data[off] != 0
            off = off + 1
        val r_algo = ssh_get_text(data, off)
        if val algo_pair = r_algo.ok():
            key_algo = algo_pair.0
            off = algo_pair.1
        val r_blob = ssh_get_string(data, off)
        if val blob_pair = r_blob.ok():
            key_blob = blob_pair.0
            off = blob_pair.1
        # Read signature if has_signature is true
        if has_signature and off < data.len():
            val r_sig = ssh_get_string(data, off)
            if val sig_pair = r_sig.ok():
                signature = sig_pair.0
                off = sig_pair.1

    # method == "none" has no additional fields

    Ok(SshAuthRequest(
        username: username,
        service: service,
        method: method,
        password: password,
        key_algo: key_algo,
        key_blob: key_blob,
        has_signature: has_signature,
        signature: signature
    ))

# ============================================================================
# Message Builders
# ============================================================================

fn ssh_build_auth_success() -> [u8]:
    """Build SSH_MSG_USERAUTH_SUCCESS message."""
    var buf: [u8] = []
    buf.push(SSH_MSG_USERAUTH_SUCCESS)
    buf

fn ssh_build_auth_failure(methods: [text], partial_success: bool) -> [u8]:
    """Build SSH_MSG_USERAUTH_FAILURE with available methods.

    Format:
      byte      SSH_MSG_USERAUTH_FAILURE (51)
      name-list authentications that can continue
      boolean   partial success
    """
    var buf: [u8] = []
    buf.push(SSH_MSG_USERAUTH_FAILURE)

    # Build comma-separated method list
    var method_str: text = ""
    var i: u64 = 0
    while i < methods.len():
        if i > 0:
            method_str = method_str + ","
        method_str = method_str + methods[i]
        i = i + 1

    ssh_put_text(buf, method_str)
    ssh_put_bool(buf, partial_success)
    buf

fn ssh_build_auth_banner(message: text) -> [u8]:
    """Build SSH_MSG_USERAUTH_BANNER message.

    Format:
      byte      SSH_MSG_USERAUTH_BANNER (53)
      string    message (UTF-8)
      string    language tag
    """
    var buf: [u8] = []
    buf.push(SSH_MSG_USERAUTH_BANNER)
    ssh_put_text(buf, message)
    ssh_put_text(buf, "")   # language tag
    buf

fn ssh_build_userauth_pk_ok(algo: text, key_blob: [u8]) -> [u8]:
    """Build SSH_MSG_USERAUTH_PK_OK response (RFC 4252 section 7).

    Sent when has_signature=false and the key is acceptable.
    Tells the client to retry with a real signature.

    Format:
      byte      SSH_MSG_USERAUTH_PK_OK (60)
      string    public key algorithm name
      string    public key blob
    """
    var buf: [u8] = []
    buf.push(SSH_MSG_USERAUTH_PK_OK)
    ssh_put_text(buf, algo)
    ssh_put_string(buf, key_blob)
    buf

# NOTE: Public key authentication is currently DISABLED in ssh_session.spl.
# To enable it, implement Ed25519 signature verification for userauth here.
# The Ed25519 verify primitive is available at os.crypto.ed25519.ed25519_verify.
# The signed data format is defined in RFC 4252 section 7.

# ============================================================================
# Internal Helpers
# ============================================================================

fn _blobs_equal(a: [u8], b: [u8]) -> bool:
    """Constant-time comparison of two byte arrays."""
    if a.len() != b.len():
        return false

    var diff: u8 = 0
    var i: u64 = 0
    while i < a.len():
        diff = diff | (a[i] ^ b[i])
        i = i + 1

    diff == 0
