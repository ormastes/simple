# SSH Cipher Layer — AES-256-GCM + ChaCha20-Poly1305
#
# Wraps crypto implementations for SSH packet encryption.
# Supports two cipher modes:
#   - aes256-gcm@openssh.com (RFC 5647)
#   - chacha20-poly1305@openssh.com (OpenSSH extension)
#
# GCM nonce construction:
#   RFC 5647 uses a 12-byte IV split into a 4-byte fixed field and an
#   8-byte invocation counter field. The invocation counter is incremented
#   for each packet; with the SSH KDF-derived IV this is equivalent to
#   adding the packet sequence number as a 64-bit offset.
#
# ChaCha20-Poly1305 for SSH:
#   Uses two separate ChaCha20 instances: one for packet length (K2)
#   and one for payload (K1). Nonce is the sequence number as 8-byte LE.

use os.crypto.aes_gcm.{aes256_gcm_encrypt, aes256_gcm_decrypt, AesGcmResult}
use os.crypto.chacha20.{chacha20_encrypt}
use os.crypto.chacha20_poly1305.{chacha20_poly1305_encrypt, chacha20_poly1305_decrypt, Chacha20Poly1305Result}
use os.crypto.random.{random_bytes}
use os.apps.sshd.ssh_kex.{SshSessionKeys}
use os.apps.sshd.ssh_packet.{ssh_put_u32, ssh_get_u32, ssh_packet_build, SSH_MIN_PADDING}
use std.format.{format_hex}

extern fn serial_println(msg: text)
extern fn rt_push_byte(arr: [u8], byte_val: i64) -> [u8]

# ============================================================================
# Constants
# ============================================================================

val GCM_TAG_LEN: u64 = 16       # AES-GCM authentication tag length
val GCM_NONCE_LEN: u64 = 12     # AES-GCM nonce length
val AES_BLOCK_SIZE: u64 = 16    # AES block size for padding calculation
val POLY1305_TAG_LEN: u64 = 16  # Poly1305 authentication tag length

# ============================================================================
# Cipher Mode
# ============================================================================

enum CipherMode:
    None_           # No encryption (pre-kex)
    Aes256Gcm       # aes256-gcm@openssh.com
    Chacha20Poly1305  # chacha20-poly1305@openssh.com

# ============================================================================
# Cipher State
# ============================================================================

class SshCipher:
    """Bidirectional SSH encryption state."""
    seq_c2s: u32          # Client-to-server sequence number
    seq_s2c: u32          # Server-to-client sequence number
    active: bool          # Encryption enabled (after NEWKEYS)
    mode: CipherMode      # Active cipher algorithm

impl SshCipher:

    static fn new() -> SshCipher:
        """Create an inactive cipher (pre-kex, no encryption)."""
        SshCipher(
            seq_c2s: 0,
            seq_s2c: 0,
            active: false,
            mode: CipherMode.None_
        )

    me activate(start_c2s_seq: u32, start_s2c_seq: u32):
        """Activate encryption with derived session keys (AES-256-GCM).

        SSH packet sequence numbers continue across NEWKEYS, so the AEAD
        invocation counters must start from the current packet counts rather
        than reset to zero.
        """
        self.seq_c2s = start_c2s_seq
        self.seq_s2c = start_s2c_seq
        self.active = true
        self.mode = CipherMode.Aes256Gcm
        serial_println("[ssh-cipher] activate seq_s2c={self.seq_s2c}")

    me activate_chacha20(start_c2s_seq: u32, start_s2c_seq: u32):
        """Activate encryption with derived session keys (ChaCha20-Poly1305)."""
        self.seq_c2s = start_c2s_seq
        self.seq_s2c = start_s2c_seq
        self.active = true
        self.mode = CipherMode.Chacha20Poly1305

    me encrypt_packet(payload: [u8], enc_key_s2c: [u8], iv_s2c: [u8]) -> [u8]:
        ssh_encrypt_packet_aes_gcm(payload, self.seq_s2c, enc_key_s2c, iv_s2c)

    me decrypt_packet(data: [u8], enc_key_c2s: [u8], iv_c2s: [u8]) -> Result<[u8], text>:
        ssh_decrypt_packet_aes_gcm(data, self.seq_c2s, enc_key_c2s, iv_c2s)

fn ssh_encrypt_packet_aes_gcm(payload: [u8], seq_s2c: u32, enc_key_s2c: [u8], iv_s2c: [u8]) -> [u8]:
    """Encrypt an outgoing SSH packet (server-to-client direction)."""
    serial_println("[ssh-cipher] encrypt enter seq={seq_s2c} payload_len={payload.len()} iv_len={iv_s2c.len()} key_len={enc_key_s2c.len()}")
    val plaintext_packet = ssh_packet_build(payload, seq_s2c)
    val packet_length = ssh_get_u32(plaintext_packet, 0)
    var aad: [u8] = []
    aad = rt_push_byte(aad, ((packet_length >> 24) & 0xFF).to_i64())
    aad = rt_push_byte(aad, ((packet_length >> 16) & 0xFF).to_i64())
    aad = rt_push_byte(aad, ((packet_length >> 8) & 0xFF).to_i64())
    aad = rt_push_byte(aad, (packet_length & 0xFF).to_i64())
    var body: [u8] = []
    var i: u64 = 4
    while i < plaintext_packet.len():
        body = rt_push_byte(body, _u8_at(plaintext_packet, i).to_i64())
        i = i + 1
    serial_println("[ssh-cipher] aes payload_len={payload.len()} packet_length={packet_length} aad={_u8s_hex(aad)} body_len={body.len()}")

    val nonce = _make_nonce(iv_s2c, seq_s2c)
    serial_println("[ssh-cipher] aes nonce={_u8s_hex(nonce)}")

    val encrypted_with_tag = aes256_gcm_encrypt(enc_key_s2c, nonce, body, aad)
    serial_println("[ssh-cipher] aes encrypted={_u8s_hex(encrypted_with_tag)}")

    var result: [u8] = []
    i = 0
    while i < aad.len():
        result = rt_push_byte(result, _u8_at(aad, i).to_i64())
        i = i + 1
    i = 0
    while i < encrypted_with_tag.len():
        result = rt_push_byte(result, _u8_at(encrypted_with_tag, i).to_i64())
        i = i + 1

    result

fn ssh_decrypt_packet_aes_gcm(data: [u8], seq_c2s: u32, enc_key_c2s: [u8], iv_c2s: [u8]) -> Result<[u8], text>:
    """Decrypt an incoming SSH packet (client-to-server direction)."""
    if data.len() < 4 + GCM_TAG_LEN:
        return Err("encrypted packet too short")

    # Extract AAD (4-byte packet_length)
    var aad: [u8] = []
    var i: u64 = 0
    while i < 4:
        aad.push(data[i])
        i = i + 1

    val packet_length = ssh_get_u32(data, 0).to_u64()

    # The rest is encrypted_body + tag
    val ct_with_tag_len = data.len() - 4
    if ct_with_tag_len < GCM_TAG_LEN:
        return Err("no ciphertext in encrypted packet")

    val ct_len = ct_with_tag_len - GCM_TAG_LEN

    # Extract ciphertext
    var ciphertext: [u8] = []
    i = 0
    while i < ct_len:
        ciphertext.push(data[4 + i])
        i = i + 1

    # Extract tag
    var tag: [u8] = []
    i = 0
    while i < GCM_TAG_LEN:
        tag.push(data[4 + ct_len + i])
        i = i + 1

    # Compute GCM nonce: fixed IV prefix || (counter XOR seq)
    val nonce = _make_nonce(iv_c2s, seq_c2s)

    # Decrypt
    val result = aes256_gcm_decrypt(enc_key_c2s, nonce, ciphertext, aad, tag)

    match result:
        AesGcmResult.Ok(plaintext):
            # Parse plaintext: padding_length(1) + payload + padding
            if plaintext.len() < 1:
                return Err("decrypted body empty")

            val padding_len = plaintext[0].to_u64()
            if 1 + padding_len > plaintext.len():
                return Err("invalid padding in decrypted packet")

            val payload_len = plaintext.len() - 1 - padding_len

            var payload: [u8] = []
            i = 0
            while i < payload_len:
                payload.push(plaintext[1 + i])
                i = i + 1

            Ok(payload)

        AesGcmResult.Err(msg):
            Err("GCM decryption failed: {msg}")

# ============================================================================
# Helpers
# ============================================================================

fn _u8s_hex(data: [u8]) -> text:
    var out = ""
    var i: u64 = 0
    while i < data.len():
        val piece = format_hex(data[i].to_i64())
        if piece.len() == 1:
            out = out + "0" + piece
        else:
            out = out + piece
        i = i + 1
    out

fn _make_nonce(base_iv: [u8], seq: u32) -> [u8]:
    """Construct the SSH AES-GCM nonce from the 12-byte IV.

    RFC 5647 splits the IV into:
      - a 4-byte fixed field
      - an 8-byte invocation counter field

    The invocation counter is treated as a 64-bit integer and incremented
    once per packet. The 32-bit SSH sequence number is added into that
    counter for the current packet.
    """
    var nonce: [u8] = []
    var i: u64 = 0

    # Copy the fixed 4-byte prefix unchanged.
    while i < 4:
        if i < base_iv.len():
            nonce.push(base_iv[i])
        else:
            nonce.push(0)
        i = i + 1

    # Read the 8-byte invocation counter and advance it by the packet
    # sequence number. RFC 5647 treats this field as a 64-bit integer that
    # increments after each AES-GCM invocation.
    var counter: u64 = 0
    while i < 12:
        val b = if i < base_iv.len(): base_iv[i] else: 0
        counter = (counter << 8) | b.to_u64()
        i = i + 1

    counter = counter + seq.to_u64()

    nonce.push(((counter >> 56) & 0xFF).to_u8())
    nonce.push(((counter >> 48) & 0xFF).to_u8())
    nonce.push(((counter >> 40) & 0xFF).to_u8())
    nonce.push(((counter >> 32) & 0xFF).to_u8())
    nonce.push(((counter >> 24) & 0xFF).to_u8())
    nonce.push(((counter >> 16) & 0xFF).to_u8())
    nonce.push(((counter >> 8) & 0xFF).to_u8())
    nonce.push((counter & 0xFF).to_u8())

    nonce

# ============================================================================
# ChaCha20-Poly1305 for SSH (chacha20-poly1305@openssh.com)
# ============================================================================
#
# SSH variant uses 12-byte nonce = 4 zero bytes || 8-byte sequence number (BE).
# The encryption key is the standard 32-byte key from key derivation.
# No separate length encryption key (simplified variant).

fn _make_chacha20_nonce(seq: u32) -> [u8]:
    """Construct 12-byte nonce for ChaCha20-Poly1305 SSH variant.

    Nonce = 0x00000000 || seq_as_big_endian_8_bytes
    """
    var nonce: [u8] = []
    # 4 zero bytes
    nonce.push(0)
    nonce.push(0)
    nonce.push(0)
    nonce.push(0)
    # 8-byte big-endian sequence number (upper 4 bytes zero)
    nonce.push(0)
    nonce.push(0)
    nonce.push(0)
    nonce.push(0)
    nonce.push(((seq >> 24) & 0xFF).to_u8())
    nonce.push(((seq >> 16) & 0xFF).to_u8())
    nonce.push(((seq >> 8) & 0xFF).to_u8())
    nonce.push((seq & 0xFF).to_u8())
    nonce

impl SshCipher:

    me _encrypt_chacha20(payload: [u8]) -> [u8]:
        """Encrypt with ChaCha20-Poly1305 for SSH.

        Format: length(4) || encrypted(padding_len(1) || payload || padding) || tag(16)
        The length field is NOT encrypted in this simplified variant.
        """
        val payload_len = payload.len()

        # Calculate padding (block size 8 for ChaCha20)
        var padding_len: u64 = 8 - ((1 + payload_len) % 8)
        if padding_len < SSH_MIN_PADDING.to_u64():
            padding_len = padding_len + 8

        val packet_length = 1 + payload_len + padding_len

        # Build plaintext body
        var body: [u8] = []
        body.push(padding_len.to_u8())

        var i: u64 = 0
        while i < payload_len:
            body.push(payload[i])
            i = i + 1

        # Random padding
        val pad = random_bytes(padding_len)
        i = 0
        while i < padding_len:
            body.push(pad[i])
            i = i + 1

        # Build AAD: the 4-byte packet_length
        var aad: [u8] = []
        var packet_length_be: u32 = packet_length.to_u32()
        aad.push(((packet_length_be >> 24) & 0xFF).to_u8())
        aad.push(((packet_length_be >> 16) & 0xFF).to_u8())
        aad.push(((packet_length_be >> 8) & 0xFF).to_u8())
        aad.push((packet_length_be & 0xFF).to_u8())
        serial_println("[ssh-cipher] encrypt payload_len={payload_len} packet_length={packet_length} aad={_u8s_hex(aad)}")

        # Nonce from sequence number
        val nonce = _make_chacha20_nonce(self.seq_s2c)

        # Encrypt body with ChaCha20-Poly1305
        val encrypted_with_tag = chacha20_poly1305_encrypt(
            self.enc_key_s2c, nonce, body, aad
        )

        # Increment sequence number
        self.seq_s2c = (self.seq_s2c + 1) & 0xFFFFFFFF

        # Result: AAD (length) || encrypted body || tag
        var result: [u8] = []
        i = 0
        while i < aad.len():
            result.push(aad[i])
            i = i + 1
        i = 0
        while i < encrypted_with_tag.len():
            result.push(encrypted_with_tag[i])
            i = i + 1

        result

    me _decrypt_chacha20(data: [u8]) -> Result<[u8], text>:
        """Decrypt with ChaCha20-Poly1305 for SSH."""
        if data.len() < 4 + POLY1305_TAG_LEN:
            return Err("chacha20 packet too short")

        # Extract AAD (4-byte packet_length)
        var aad: [u8] = []
        var i: u64 = 0
        while i < 4:
            aad.push(data[i])
            i = i + 1

        val packet_length = ssh_get_u32(data, 0).to_u64()

        val ct_with_tag_len = data.len() - 4
        if ct_with_tag_len < POLY1305_TAG_LEN:
            return Err("no ciphertext in chacha20 packet")

        val ct_len = ct_with_tag_len - POLY1305_TAG_LEN

        # Extract ciphertext
        var ciphertext: [u8] = []
        i = 0
        while i < ct_len:
            ciphertext.push(data[4 + i])
            i = i + 1

        # Extract tag
        var tag: [u8] = []
        i = 0
        while i < POLY1305_TAG_LEN:
            tag.push(data[4 + ct_len + i])
            i = i + 1

        # Nonce from sequence number
        val nonce = _make_chacha20_nonce(self.seq_c2s)

        # Decrypt
        val result = chacha20_poly1305_decrypt(self.enc_key_c2s, nonce, ciphertext, aad, tag)

        match result:
            Chacha20Poly1305Result.Ok(plaintext):
                self.seq_c2s = (self.seq_c2s + 1) & 0xFFFFFFFF

                if plaintext.len() < 1:
                    return Err("chacha20 decrypted body empty")

                val padding_len = plaintext[0].to_u64()
                if 1 + padding_len > plaintext.len():
                    return Err("invalid padding in chacha20 packet")

                val payload_len = plaintext.len() - 1 - padding_len

                var payload: [u8] = []
                i = 0
                while i < payload_len:
                    payload.push(plaintext[1 + i])
                    i = i + 1

                Ok(payload)

            Chacha20Poly1305Result.Err(msg):
                Err("ChaCha20-Poly1305 decryption failed: {msg}")
