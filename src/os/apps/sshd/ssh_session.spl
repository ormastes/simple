# SSH Session — Per-client connection handler
#
# Manages the lifecycle of one SSH connection:
#   version exchange -> key exchange -> authentication -> channel -> shell
#
# Each phase is implemented as a separate method called from run().
# The session reads/writes via socket FDs using the POSIX socket API.

use os.apps.sshd.ssh_packet.{SshPacket, SshTextResult, SshStringResult, ssh_packet_build, ssh_put_u32, ssh_put_string, ssh_put_text, ssh_put_byte, ssh_put_bool, ssh_get_u32, ssh_get_string, ssh_get_text}
use os.apps.sshd.ssh_transport.{SshKexInit, SshAlgorithms, SSH_MSG_KEXINIT, SSH_MSG_NEWKEYS, SSH_MSG_DISCONNECT, SSH_MSG_IGNORE, SSH_MSG_SERVICE_REQUEST, SSH_MSG_SERVICE_ACCEPT, SSH_DISCONNECT_PROTOCOL_ERROR, ssh_build_version_string, ssh_parse_kexinit, ssh_negotiate_algorithms, ssh_build_service_accept, ssh_parse_service_request, ssh_build_disconnect}
use os.apps.sshd.ssh_kex.{HostKeySet, SshKexState, SshSessionKeys, SSH_MSG_KEX_ECDH_INIT, SSH_MSG_KEX_ECDH_REPLY, ssh_kex_generate_private_key, ssh_kex_compute_exchange_hash, ssh_derive_keys, ssh_build_kex_ecdh_reply, ssh_parse_kex_ecdh_init, ssh_build_newkeys, ssh_build_kexinit_for_host_keys, ssh_sign_exchange_hash, ssh_build_ed25519_host_key_blob}
use os.apps.sshd.ssh_cipher.{SshCipher}
use os.apps.sshd.ssh_auth.{SshUserDb, SshAuthRequest, SSH_MSG_USERAUTH_REQUEST, SSH_MSG_USERAUTH_PK_OK, MAX_AUTH_ATTEMPTS, ssh_parse_auth_request, ssh_build_auth_success, ssh_build_auth_failure, ssh_build_auth_banner, ssh_build_userauth_pk_ok, ssh_build_userauth_info_request, ssh_parse_userauth_info_response}
use os.apps.sshd.ssh_channel.{ChannelTable, SshChannel, ChannelType, ChannelState, SSH_MSG_CHANNEL_OPEN, SSH_MSG_CHANNEL_DATA, SSH_MSG_CHANNEL_WINDOW_ADJUST, SSH_MSG_CHANNEL_EOF, SSH_MSG_CHANNEL_CLOSE, SSH_MSG_CHANNEL_REQUEST, DEFAULT_WINDOW_SIZE, DEFAULT_MAX_PACKET, ssh_parse_channel_open, ssh_parse_channel_data, ssh_parse_channel_request, ssh_parse_window_adjust, ssh_parse_channel_eof, ssh_parse_channel_close, ssh_build_channel_open_confirmation, ssh_build_channel_data, ssh_build_channel_window_adjust, ssh_build_channel_eof, ssh_build_channel_close, ssh_build_channel_success, ssh_build_channel_failure}
use os.apps.sshd.rsa_pubkey.{ssh_rsa_blob_to_spki_der}
use os.apps.sshd.ssh_pty.{SshPty}
use os.apps.shell.shell_app.{ShellApp}
use std.format.{format_hex}
use os.kernel.log.klog_api.{log_init, log_info, log_warn, log_error, log_raw, log_raw_println}

extern fn rt_ed25519_keypair_pk(seed: [u8]) -> [u8]
extern fn rt_rsa_sha256_verify(pubkey: [u8], message: [u8], signature: [u8]) -> i64
extern fn rt_ed25519_verify(message: [u8], pubkey: [u8], signature: [u8]) -> i64
extern fn rt_string_from_byte_array(arr: [u8]) -> text
extern fn rt_string_to_byte_array(s: text) -> [u8]
extern fn rt_net_send_bytes(sock_fd: i64, data: [u8]) -> i64
extern fn rt_net_recv_bytes(sock_fd: i64, max_len: i64) -> [u8]
extern fn rt_net_recv_ssh_plain_packet_payload(sock_fd: i64) -> [u8]
extern fn rt_net_recv_version_text(sock_fd: i64) -> text
extern fn rt_net_close(sock_fd: i64) -> i64
extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_bytes_concat(a: [u8], b: [u8]) -> [u8]
extern fn rt_bytes_slice(arr: [u8], start: i64, length: i64) -> [u8]
extern fn rt_tls13_x25519_public_key(scalar: [u8]) -> [u8]
extern fn rt_tls13_x25519_shared_secret(scalar: [u8], point: [u8]) -> [u8]

# ============================================================================
# Constants
# ============================================================================

val RECV_BUF_SIZE: u64 = 8192

fn _u8_at(data: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(data, idx.to_i64()).to_u8()

fn _slice_range(data: [u8], start: u64, end: u64) -> [u8]:
    if start >= data.len() or start >= end:
        return rt_bytes_slice(data, 0, 0)
    var capped_end = end
    if capped_end > data.len():
        capped_end = data.len()
    rt_bytes_slice(data, start.to_i64(), (capped_end - start).to_i64())

fn _zeroed_32_bytes() -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < 32:
        out.push(0)
        i = i + 1
    out

fn _bytes_to_hex(data: [u8]) -> text:
    var out = ""
    var i: u64 = 0
    while i < data.len():
        val piece = format_hex(_u8_at(data, i).to_i64())
        if piece.len() == 1:
            out = out + "0" + piece
        else:
            out = out + piece
        i = i + 1
    out

fn _ed25519_public_key_from_seed(seed: [u8]?) -> [u8]:
    if seed == nil:
        return []
    val pk = rt_ed25519_keypair_pk(seed)
    if pk.len() != 32:
        return []
    pk

# ============================================================================
# Types
# ============================================================================

enum SessionState:
    VersionExchange
    KexInit
    KexDh
    Authentication
    Interactive
    Closed

class SshSession:
    """Per-client SSH session.

    Manages the full lifecycle from TCP accept through interactive shell.
    """
    socket_fd: i32
    state: SessionState
    cipher: SshCipher
    channels: ChannelTable
    user_db: SshUserDb
    session_id: [u8]
    authenticated_user: text
    pty: SshPty?
    shell: ShellApp?
    recv_buf: [u8]           # Accumulated received data
    send_seq: u32
    recv_seq: u32
    client_version: text
    server_version: text
    client_version_bytes: [u8]
    server_version_bytes: [u8]
    server_kexinit_payload: [u8]
    client_kexinit_payload: [u8]
    host_keys: HostKeySet     # Server's long-term host keys (multi-algorithm)

impl SshSession:

    static fn new(socket_fd: i32, user_db: SshUserDb, host_private: [u8], host_public: [u8]) -> SshSession:
        """Create a new SSH session for an accepted TCP connection.

        Backward-compatible constructor: wraps an Ed25519 seed into a HostKeySet.
        host_private is the 32-byte Ed25519 private seed.
        host_public is unused here (derived from the seed at signing time).
        """
        val keys = HostKeySet(
            ed25519_seed: host_private,
            rsa_pkcs8: nil,
            rsa_public_blob: nil,
            ecdsa_p256_pkcs8: nil
        )
        SshSession.new_with_host_keys(socket_fd, user_db, keys)

    static fn new_with_host_keys(socket_fd: i32, user_db: SshUserDb, host_keys: HostKeySet) -> SshSession:
        """Create a new SSH session with a full HostKeySet."""
        SshSession(
            socket_fd: socket_fd,
            state: SessionState.VersionExchange,
            cipher: SshCipher.new(),
            channels: ChannelTable.new(),
            user_db: user_db,
            session_id: [],
            authenticated_user: "",
            pty: nil,
            shell: nil,
            recv_buf: [],
            send_seq: 0,
            recv_seq: 0,
            client_version: "",
            server_version: "",
            client_version_bytes: [],
            server_version_bytes: [],
            server_kexinit_payload: [],
            client_kexinit_payload: [],
            host_keys: host_keys
        )

    me run():
        """Main session loop. Drives the SSH protocol state machine."""
        log_info("[app.sshd] " + "[sshd-session] start")
        if not self.do_version_exchange():
            return

        if not self.do_kex():
            return

        if not self.do_service_request():
            return

        if not self.do_auth():
            return

        self.do_interactive()

    # ========================================================================
    # Phase 1: Version Exchange
    # ========================================================================

    me do_version_exchange() -> bool:
        """Exchange SSH version strings (RFC 4253 section 4.2)."""
        log_info("[app.sshd] " + "[sshd-session] version exchange")
        # Send our version string
        val our_version = ssh_build_version_string()
        self.server_version_bytes = rt_bytes_slice(our_version, 0, our_version.len().to_i64() - 2)
        self.server_version = rt_string_from_byte_array(self.server_version_bytes)
        self.raw_send(our_version)

        # Read the client banner via the C TCP ring directly. The byte-array
        # marshalling path is not reliable enough on this baremetal lane for
        # SSH version parsing.
        val client_version = rt_net_recv_version_text(self.socket_fd as i64)
        if client_version == "":
            self.state = SessionState.Closed
            return false

        if not client_version.starts_with("SSH-2.0-"):
            log_info("[app.sshd] " + "[sshd-session] invalid version text={client_version}")
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "invalid version string")
            return false

        self.client_version = client_version
        self.client_version_bytes = rt_string_to_byte_array(client_version)
        log_info("[app.sshd] " + "[sshd-session] version parsed text={self.client_version}")
        log_info("[app.sshd] " + "[sshd-session] version parsed len={self.client_version.len()}")
        log_info("[app.sshd] " + "[sshd-session] server version text={self.server_version}")
        log_info("[app.sshd] " + "[sshd-session] version exchange ok")
        self.state = SessionState.KexInit
        true

    # ========================================================================
    # Phase 2: Key Exchange
    # ========================================================================

    me do_kex() -> bool:
        """Perform key exchange (curve25519-sha256)."""
        log_info("[app.sshd] " + "[sshd-session] kex start")
        # Send our KEXINIT — advertise algorithms available in our host key set
        val server_kexinit = ssh_build_kexinit_for_host_keys(self.host_keys)
        self.server_kexinit_payload = server_kexinit
        self.send_packet(server_kexinit)

        # Receive client KEXINIT
        val client_payload = self.recv_packet_payload()
        log_info("[app.sshd] " + "[sshd-session] client kexinit received")
        if client_payload.len() == 0:
            log_info("[app.sshd] " + "[sshd-session] client kexinit missing")
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "no KEXINIT received")
            return false
        self.client_kexinit_payload = client_payload

        # Parse client KEXINIT
        val r_client_kex = ssh_parse_kexinit(client_payload)
        if r_client_kex.is_err():
            log_info("[app.sshd] " + "[sshd-session] client kexinit parse err")
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "bad KEXINIT")
            return false
        val client_kex = r_client_kex.unwrap()
        log_info("[app.sshd] " + "[sshd-session] client kexinit hex={_bytes_to_hex(client_payload)}")
        log_info("[app.sshd] " + "[sshd-session] client kexinit parsed")
        log_info("[app.sshd] " + "[sshd-session] client kexinit hex={_bytes_to_hex(client_payload)}")

        # Parse our own KEXINIT (for negotiation)
        val r_server_kex = ssh_parse_kexinit(server_kexinit)
        val server_kex = r_server_kex.unwrap()
        log_info("[app.sshd] " + "[sshd-session] client kex list={client_kex.kex_algorithms}")
        log_info("[app.sshd] " + "[sshd-session] server kex list={server_kex.kex_algorithms}")
        log_info("[app.sshd] " + "[sshd-session] server kexinit hex={_bytes_to_hex(server_kexinit)}")
        log_info("[app.sshd] " + "[sshd-session] server kexinit hex={_bytes_to_hex(server_kexinit)}")

        # Negotiate algorithms
        val r_algos = ssh_negotiate_algorithms(client_kex, server_kex)
        if r_algos.is_err():
            log_info("[app.sshd] " + "[sshd-session] algo negotiation failed")
            self.disconnect(3, "algorithm negotiation failed")
            return false
        val algos_early = r_algos.unwrap()
        log_info("[app.sshd] " + "[sshd-session] negotiated kex={algos_early.kex} hostkey={algos_early.host_key} c2s={algos_early.cipher_c2s} s2c={algos_early.cipher_s2c}")

        # Receive KEX_ECDH_INIT (client's ephemeral public key)
        val kex_init_payload = self.recv_packet_payload()
        log_info("[app.sshd] " + "[sshd-session] client ecdh init received")
        if kex_init_payload.len() == 0:
            log_info("[app.sshd] " + "[sshd-session] client ecdh init missing")
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "no KEX_ECDH_INIT")
            return false

        val r_client_pub = ssh_parse_kex_ecdh_init(kex_init_payload)
        if r_client_pub.is_err():
            log_info("[app.sshd] " + "[sshd-session] client ecdh init parse err")
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "bad KEX_ECDH_INIT")
            return false
        val client_public = r_client_pub.unwrap()
        log_info("[app.sshd] " + "[sshd-session] client ecdh pub len={client_public.len()}")
        log_info("[app.sshd] " + "[sshd-session] client ecdh pub={_bytes_to_hex(client_public)}")

        # Generate our ephemeral keypair
        val server_private = ssh_kex_generate_private_key()
        val server_public = if server_private.len() == 32 {
            rt_tls13_x25519_public_key(server_private)
        } else {
            []
        }
        log_info("[app.sshd] " + "[sshd-session] server ecdh priv len={server_private.len()} pub len={server_public.len()}")
        if server_public.len() != 32:
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "server X25519 public failed")
            return false
        log_info("[app.sshd] " + "[sshd-session] server ecdh pub len={server_public.len()}")
        log_info("[app.sshd] " + "[sshd-session] server ecdh pub={_bytes_to_hex(server_public)}")

        # Compute shared secret
        val shared_secret = if server_private.len() == 32 and client_public.len() == 32 {
            rt_tls13_x25519_shared_secret(server_private, client_public)
        } else {
            []
        }
        if shared_secret.len() != 32:
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "server X25519 shared failed")
            return false
        log_info("[app.sshd] " + "[sshd-session] shared secret len={shared_secret.len()}")
        log_info("[app.sshd] " + "[sshd-session] shared secret={_bytes_to_hex(shared_secret)}")

        # Resolve negotiated algorithms — needed now for host-key-blob type
        val negotiated_hk_algo = algos_early.host_key

        # Build host key blob for the negotiated algorithm
        val host_key_blob = _build_host_key_blob_for_algo(negotiated_hk_algo, self.host_keys)
        log_info("[app.sshd] " + "[sshd-session] host key algo={negotiated_hk_algo} blob len={host_key_blob.len()}")
        log_info("[app.sshd] " + "[sshd-session] host key blob={_bytes_to_hex(host_key_blob)}")

        # Compute exchange hash
        val exchange_hash = ssh_kex_compute_exchange_hash(
            self.client_version_bytes,
            self.server_version_bytes,
            self.client_kexinit_payload,
            self.server_kexinit_payload,
            host_key_blob,
            client_public,
            server_public,
            shared_secret
        )
        log_info("[app.sshd] " + "[sshd-session] exchange hash len={exchange_hash.len()}")

        # Session ID is the first exchange hash
        if self.session_id.len() == 0:
            self.session_id = exchange_hash

        # Sign the exchange hash with the appropriate host key
        val r_sig = ssh_sign_exchange_hash(negotiated_hk_algo, self.host_keys, exchange_hash)
        if r_sig.is_err():
            log_info("[app.sshd] " + "[sshd-session] host key signing err")
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "host key signing failed")
            return false
        val sig_blob = r_sig.unwrap()
        log_info("[app.sshd] " + "[sshd-session] sig blob len={sig_blob.len()}")
        if negotiated_hk_algo == "ssh-ed25519":
            val sig_pubkey = _extract_ed25519_pubkey(host_key_blob)
            val sig_raw = _unwrap_ssh_signature(sig_blob)
            val sig_verify = rt_ed25519_verify(exchange_hash, sig_pubkey, sig_raw)
            log_info("[app.sshd] " + "[sshd-session] sig self-verify rc={sig_verify} pub len={sig_pubkey.len()} raw len={sig_raw.len()}")
            log_info("[app.sshd] " + "[sshd-session] sig self-verify pub={_bytes_to_hex(sig_pubkey)}")
            log_info("[app.sshd] " + "[sshd-session] sig self-verify hash={_bytes_to_hex(exchange_hash)}")
            log_info("[app.sshd] " + "[sshd-session] sig self-verify raw={_bytes_to_hex(sig_raw)}")

        # Send KEX_ECDH_REPLY
        val reply = ssh_build_kex_ecdh_reply(host_key_blob, server_public, sig_blob)
        log_info("[app.sshd] " + "[sshd-session] kex reply len={reply.len()}")
        self.send_packet(reply)

        # Send NEWKEYS
        val newkeys = ssh_build_newkeys()
        self.send_packet(newkeys)

        # Receive client NEWKEYS
        val client_newkeys = self.recv_packet_payload()
        if client_newkeys.len() == 0 or _u8_at(client_newkeys, 0) != SSH_MSG_NEWKEYS:
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "expected NEWKEYS")
            return false

        # Derive session keys and activate cipher based on negotiated algorithm
        val keys = ssh_derive_keys(shared_secret, exchange_hash, self.session_id)
        if (algos_early.cipher_c2s != "aes256-gcm@openssh.com" or
            algos_early.cipher_s2c != "aes256-gcm@openssh.com"):
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "unsupported cipher negotiation")
            return false
        self.cipher.activate(keys, self.recv_seq, self.send_seq)
        log_info("[app.sshd] " + "[sshd-session] cipher activated: c2s_seq={self.recv_seq} s2c_seq={self.send_seq}")
        log_info("[app.sshd] " + "[sshd-session] kex ok")

        self.state = SessionState.Authentication
        true

    # ========================================================================
    # Phase 3: Service Request
    # ========================================================================

    me do_service_request() -> bool:
        """Handle SSH_MSG_SERVICE_REQUEST for 'ssh-userauth'."""
        log_info("[app.sshd] " + "[sshd-session] service request")
        val payload = self.recv_packet_payload()
        if payload.len() == 0:
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "no service request")
            return false

        if _u8_at(payload, 0) == SSH_MSG_SERVICE_REQUEST:
            val r = ssh_parse_service_request(payload)
            if r.is_ok():
                val service = r.unwrap()
                if service == "ssh-userauth":
                    val accept = ssh_build_service_accept("ssh-userauth")
                    self.send_packet(accept)
                    log_info("[app.sshd] " + "[sshd-session] service request ok")
                    return true

            self.disconnect(7, "service not available")
        else:
            self.disconnect(SSH_DISCONNECT_PROTOCOL_ERROR, "expected SERVICE_REQUEST")
        false

    # ========================================================================
    # Phase 4: Authentication
    # ========================================================================

    me do_auth() -> bool:
        """Handle authentication requests. Loops until success or max attempts."""
        log_info("[app.sshd] " + "[sshd-session] auth")
        var attempts: u32 = 0

        # Send banner
        val banner = ssh_build_auth_banner("Welcome to SimpleOS SSH\r\n")
        self.send_packet(banner)

        while attempts < MAX_AUTH_ATTEMPTS:
            val payload = self.recv_packet_payload()
            if payload.len() == 0:
                self.state = SessionState.Closed
                return false

            if _u8_at(payload, 0) != SSH_MSG_USERAUTH_REQUEST:
                # Ignore non-auth messages during auth phase
                attempts = attempts + 1
                continue

            val r = ssh_parse_auth_request(payload)
            if r.is_err():
                attempts = attempts + 1
                val fail = ssh_build_auth_failure(["publickey", "password", "keyboard-interactive"], false)
                self.send_packet(fail)
                continue

            val req = r.unwrap()

            if req.method == "none":
                # "none" method: always fail, but tell client which methods are available
                val fail = ssh_build_auth_failure(["publickey", "password", "keyboard-interactive"], false)
                self.send_packet(fail)
                attempts = attempts + 1

            elif req.method == "password":
                if self.user_db.authenticate_password(req.username, req.password):
                    self.authenticated_user = req.username
                    val success = ssh_build_auth_success()
                    self.send_packet(success)
                    log_info("[app.sshd] " + "[sshd-session] auth ok")
                    self.state = SessionState.Interactive
                    return true
                else:
                    attempts = attempts + 1
                    val fail = ssh_build_auth_failure(["publickey", "password", "keyboard-interactive"], false)
                    self.send_packet(fail)

            elif req.method == "keyboard-interactive":
                val info_req = ssh_build_userauth_info_request(
                    "SimpleOS SSH",
                    "Password authentication",
                    "Password: ",
                    false
                )
                self.send_packet(info_req)
                val response_payload = self.recv_packet_payload()
                val r_password = ssh_parse_userauth_info_response(response_payload)
                if r_password.is_ok() and self.user_db.authenticate_password(req.username, r_password.unwrap()):
                    self.authenticated_user = req.username
                    val success = ssh_build_auth_success()
                    self.send_packet(success)
                    log_info("[app.sshd] " + "[sshd-session] auth ok (keyboard-interactive)")
                    self.state = SessionState.Interactive
                    return true
                else:
                    attempts = attempts + 1
                    val fail = ssh_build_auth_failure(["publickey", "password", "keyboard-interactive"], false)
                    self.send_packet(fail)

            elif req.method == "publickey":
                if not req.has_signature:
                    # Probe: client asks if the key is acceptable — respond PK_OK
                    val pk_ok = ssh_build_userauth_pk_ok(req.key_algo, req.key_blob)
                    self.send_packet(pk_ok)
                    # Don't increment attempts — probe is not a failure
                else:
                    # Verify: build signed_data per RFC 4252 §7 and verify signature
                    val signed_data = _build_publickey_signed_data(
                        self.session_id, req.username, req.key_algo, req.key_blob
                    )
                    # Unwrap the SSH signature envelope: string algo_name + string raw_sig
                    val raw_sig = _unwrap_ssh_signature(req.signature)
                    var verified: bool = false
                    if req.key_algo == "rsa-sha2-256":
                        val spki_der = ssh_rsa_blob_to_spki_der(req.key_blob)
                        val vr = rt_rsa_sha256_verify(spki_der, signed_data, raw_sig)
                        verified = vr == 1
                    elif req.key_algo == "ssh-ed25519":
                        # Ed25519 blob: string "ssh-ed25519" + string raw_pubkey (32 bytes)
                        val raw_pubkey = _extract_ed25519_pubkey(req.key_blob)
                        val vr = rt_ed25519_verify(signed_data, raw_pubkey, raw_sig)
                        verified = vr == 1
                    else:
                        verified = false

                    if verified:
                        val user_exists = self.user_db.find_user(req.username)
                        if user_exists != nil:
                            self.authenticated_user = req.username
                            val success = ssh_build_auth_success()
                            self.send_packet(success)
                            log_info("[app.sshd] " + "[sshd-session] auth ok (publickey)")
                            self.state = SessionState.Interactive
                            return true
                        else:
                            attempts = attempts + 1
                            val fail = ssh_build_auth_failure(["publickey", "password", "keyboard-interactive"], false)
                            self.send_packet(fail)
                    else:
                        attempts = attempts + 1
                        val fail = ssh_build_auth_failure(["publickey", "password", "keyboard-interactive"], false)
                        self.send_packet(fail)

            else:
                # Unknown method
                attempts = attempts + 1
                val fail = ssh_build_auth_failure(["publickey", "password", "keyboard-interactive"], false)
                self.send_packet(fail)

        # Too many failed attempts
        self.disconnect(14, "too many authentication failures")
        false

    # ========================================================================
    # Phase 5: Interactive (Channel Management)
    # ========================================================================

    me do_interactive():
        """Handle channels and data transfer.

        Main loop: receive packets, dispatch by message type.
        Simultaneously forwards data between PTY and SSH channel.
        """
        log_info("[app.sshd] " + "[sshd-session] interactive")
        while self.state == SessionState.Interactive:
            # Check for data from the interactive shell before blocking on input.
            self._forward_shell_output()
            self._forward_pty_output()

            # Receive a packet from the client
            val payload = self.recv_packet_payload()
            if payload.len() == 0:
                self.state = SessionState.Closed
                return

            val msg_type = _u8_at(payload, 0)

            if msg_type == SSH_MSG_CHANNEL_OPEN:
                self._handle_channel_open(payload)

            elif msg_type == SSH_MSG_CHANNEL_DATA:
                self._handle_channel_data(payload)

            elif msg_type == SSH_MSG_CHANNEL_WINDOW_ADJUST:
                self._handle_window_adjust(payload)

            elif msg_type == SSH_MSG_CHANNEL_EOF:
                self._handle_channel_eof(payload)

            elif msg_type == SSH_MSG_CHANNEL_CLOSE:
                self._handle_channel_close(payload)

            elif msg_type == SSH_MSG_CHANNEL_REQUEST:
                self._handle_channel_request(payload)

            elif msg_type == SSH_MSG_DISCONNECT:
                self.state = SessionState.Closed
                return

            elif msg_type == SSH_MSG_IGNORE:
                pass_dn     # Silently ignore

            elif msg_type == SSH_MSG_KEXINIT:
                # Re-keying: handle inline
                self.client_kexinit_payload = payload
                self.do_kex()

            else:
                pass_dn     # Ignore unknown messages

    me _handle_channel_open(payload: [u8]):
        """Handle SSH_MSG_CHANNEL_OPEN."""
        val r = ssh_parse_channel_open(payload)
        if r.is_err():
            return

        val parsed = r.unwrap()
        val ch_type_str = parsed.0
        val remote_id = parsed.1
        val remote_window = parsed.2
        val remote_max_packet = parsed.3

        if ch_type_str == "session":
            val local_id = self.channels.open(
                ChannelType.Session, remote_id, remote_window, remote_max_packet
            )
            val confirm = ssh_build_channel_open_confirmation(
                remote_id, local_id, DEFAULT_WINDOW_SIZE, DEFAULT_MAX_PACKET
            )
            self.send_packet(confirm)
        else:
            val fail = ssh_build_channel_open_confirmation(remote_id, 0, 0, 0)
            self.send_packet(fail)

    me _handle_channel_data(payload: [u8]):
        """Handle SSH_MSG_CHANNEL_DATA — forward to PTY."""
        val r = ssh_parse_channel_data(payload)
        if r.is_err():
            return

        val parsed = r.unwrap()
        val recipient = parsed.0
        val data = parsed.1

        # Consume local window
        self.channels.consume_local_window(recipient, data.len().to_u32())

        # Forward data to PTY master_write (user input to shell)
        if val shell = self.shell:
            val text = rt_string_from_byte_array(data)
            if not shell.feed_remote_input(text):
                self.state = SessionState.Closed
            self._forward_shell_output()
        elif val pty = self.pty:
            pty.master_write(data)

        # Send window adjust if local window is getting low
        val ch = self.channels.find(recipient)
        if ch != nil:
            if ch.local_window < DEFAULT_WINDOW_SIZE / 2:
                val adjust_bytes = DEFAULT_WINDOW_SIZE - ch.local_window
                self.channels.adjust_window(recipient, adjust_bytes)
                val adjust = ssh_build_channel_window_adjust(ch.remote_id, adjust_bytes)
                self.send_packet(adjust)

    me _handle_window_adjust(payload: [u8]):
        """Handle SSH_MSG_CHANNEL_WINDOW_ADJUST."""
        val r = ssh_parse_window_adjust(payload)
        if r.is_err():
            return

        val parsed = r.unwrap()
        val recipient = parsed.0
        val bytes = parsed.1

        # Find the channel and increase our remote send window
        var i: u64 = 0
        while i < self.channels.channels.len():
            if self.channels.channels[i].local_id == recipient:
                self.channels.channels[i].remote_window = self.channels.channels[i].remote_window + bytes
                return
            i = i + 1

    me _handle_channel_eof(payload: [u8]):
        """Handle SSH_MSG_CHANNEL_EOF."""
        val r = ssh_parse_channel_eof(payload)
        if r.is_err():
            return
        # Client sent EOF — no more data from client
        # We don't need to do anything special; the shell can keep running

    me _handle_channel_close(payload: [u8]):
        """Handle SSH_MSG_CHANNEL_CLOSE."""
        val r = ssh_parse_channel_close(payload)
        if r.is_err():
            return

        val recipient = r.unwrap()
        val ch = self.channels.find(recipient)
        if ch != nil:
            # Send CHANNEL_CLOSE back
            val close = ssh_build_channel_close(ch.remote_id)
            self.send_packet(close)
            self.channels.close(recipient)

        # Close PTY if this was the last channel
        if val pty = self.pty:
            pty.close()
            self.pty = nil

        self.channels.remove_closed()

        # If no more channels, end session
        if self.channels.channels.len() == 0:
            self.state = SessionState.Closed

    me _handle_channel_request(payload: [u8]):
        """Handle SSH_MSG_CHANNEL_REQUEST (pty-req, shell, exec, env, window-change)."""
        val r = ssh_parse_channel_request(payload)
        if r.is_err():
            return

        val parsed = r.unwrap()
        val recipient = parsed.0
        val req_type = parsed.1
        val want_reply = parsed.2
        var off = parsed.3

        val ch = self.channels.find(recipient)
        if ch == nil:
            if want_reply:
                val fail = ssh_build_channel_failure(0)
                self.send_packet(fail)
            return

        if req_type == "pty-req":
            self._handle_pty_request(payload, off, recipient, ch.remote_id, want_reply)

        elif req_type == "shell":
            self._handle_shell_request(recipient, ch.remote_id, want_reply)

        elif req_type == "exec":
            self._handle_exec_request(payload, off, recipient, ch.remote_id, want_reply)

        elif req_type == "subsystem":
            if want_reply:
                val fail = ssh_build_channel_failure(ch.remote_id)
                self.send_packet(fail)

        elif req_type == "env":
            # Environment variable setting — parse but don't act on it
            if want_reply:
                val success = ssh_build_channel_success(ch.remote_id)
                self.send_packet(success)

        elif req_type == "window-change":
            # Terminal resize
            if off + 8 <= payload.len():
                val new_cols = ssh_get_u32(payload, off)
                val new_rows = ssh_get_u32(payload, off + 4)
                if val pty = self.pty:
                    pty.resize(new_cols, new_rows)
            # window-change never wants reply per RFC

        else:
            if want_reply:
                val fail = ssh_build_channel_failure(ch.remote_id)
                self.send_packet(fail)

    me _handle_pty_request(payload: [u8], off: u64, local_id: u32, remote_id: u32, want_reply: bool):
        """Handle pty-req channel request.

        Fields after the standard header:
          string    TERM environment variable (e.g. "xterm-256color")
          uint32    terminal width in characters
          uint32    terminal height in rows
          uint32    terminal width in pixels (ignored)
          uint32    terminal height in pixels (ignored)
          string    encoded terminal modes (ignored)
        """
        var pos = off

        # Parse TERM
        var term_type: text = "xterm"
        val r_term = ssh_get_text(payload, pos)
        if r_term.is_ok():
            val term_pair = r_term.unwrap()
            term_type = term_pair.value
            pos = term_pair.next_offset

        # Parse dimensions
        var cols: u32 = 80
        var rows: u32 = 24
        if pos + 16 <= payload.len():
            cols = ssh_get_u32(payload, pos)
            pos = pos + 4
            rows = ssh_get_u32(payload, pos)
            pos = pos + 4
            # Skip pixel width and height
            pos = pos + 8

        # Create PTY
        val r_pty = SshPty.create(term_type, cols, rows)
        if r_pty.is_ok():
            val pty = r_pty.unwrap()
            self.pty = pty

            # Mark channel as PTY-enabled
            var i: u64 = 0
            while i < self.channels.channels.len():
                if self.channels.channels[i].local_id == local_id:
                    self.channels.channels[i].pty_requested = true
                i = i + 1

            if want_reply:
                val success = ssh_build_channel_success(remote_id)
                self.send_packet(success)
        else:
            if want_reply:
                val fail = ssh_build_channel_failure(remote_id)
                self.send_packet(fail)

    me _handle_shell_request(local_id: u32, remote_id: u32, want_reply: bool):
        """Handle shell channel request — launch interactive shell."""
        # Mark channel as shell-enabled
        var i: u64 = 0
        while i < self.channels.channels.len():
            if self.channels.channels[i].local_id == local_id:
                self.channels.channels[i].shell_requested = true
            i = i + 1

        if want_reply:
            val success = ssh_build_channel_success(remote_id)
            self.send_packet(success)

        # If no PTY was requested, create a default one
        if self.pty == nil:
            val r_pty = SshPty.create("vt100", 80, 24)
            if r_pty.is_ok():
                val pty = r_pty.unwrap()
                self.pty = pty

        self._ensure_shell_started()
        self._forward_shell_output()

    me _handle_exec_request(payload: [u8], off: u64, local_id: u32, remote_id: u32, want_reply: bool):
        """Handle exec requests by running the command through the same shell REPL."""
        var pos = off
        val r_command = ssh_get_text(payload, pos)
        if r_command.is_err():
            if want_reply:
                val fail = ssh_build_channel_failure(remote_id)
                self.send_packet(fail)
            return

        var i: u64 = 0
        while i < self.channels.channels.len():
            if self.channels.channels[i].local_id == local_id:
                self.channels.channels[i].shell_requested = true
            i = i + 1

        if want_reply:
            val success = ssh_build_channel_success(remote_id)
            self.send_packet(success)

        self._ensure_shell_started()
        if val shell = self.shell:
            val command = r_command.unwrap().value
            if not shell.feed_remote_input("{command}\n"):
                self.state = SessionState.Closed
            self._forward_shell_output()

    me _ensure_shell_started():
        """Create the shared SSH shell instance once per authenticated session."""
        if self.shell != nil:
            return
        var shell = ShellApp.new()
        shell.show_prompt()
        self.shell = shell

    me _forward_shell_output():
        """Drain shell terminal output to the active SSH session channel."""
        if val shell = self.shell:
            val output = shell.take_remote_output()
            if output != "":
                self._send_shell_output(output.to_bytes())

    me _send_shell_output(output: [u8]):
        """Forward shell bytes to the first open shell-enabled session channel."""
        if output.len() == 0:
            return
        var i: u64 = 0
        while i < self.channels.channels.len():
            val ch = self.channels.channels[i]
            if ch.shell_requested:
                match ch.state:
                    ChannelState.Open:
                        val send_len = output.len().to_u32()
                        if self.channels.consume_remote_window(ch.local_id, send_len):
                            val data_msg = ssh_build_channel_data(ch.remote_id, output)
                            self.send_packet(data_msg)
                        return
                    _:
                        pass_dn
            i = i + 1

    me _forward_pty_output():
        """Check for shell output and forward it as CHANNEL_DATA."""
        if val pty = self.pty:
            if pty.master_has_data():
                val output = pty.master_read(4096)
                if output.len() > 0:
                    self._send_shell_output(output)

    # ========================================================================
    # Packet I/O
    # ========================================================================

    me send_packet(payload: [u8]):
        """Send an SSH packet. Encrypts if cipher is active."""
        if self.cipher.active:
            val encrypted = self.cipher.encrypt_packet(payload)
            self.raw_send(encrypted)
        else:
            val packet = ssh_packet_build(payload, self.send_seq)
            self.raw_send(packet)
        self.send_seq = (self.send_seq + 1) & 0xFFFFFFFF

    me recv_packet_payload() -> [u8]:
        """Receive and decode one SSH packet. Returns payload or empty on error.

        Accumulates data in recv_buf until a complete packet can be parsed.
        """
        if not self.cipher.active:
            # Plaintext mode on baremetal: frame one packet directly in the
            # runtime socket ring to avoid SPL-side buffering corruption.
            val payload = rt_net_recv_ssh_plain_packet_payload(self.socket_fd as i64)
            if payload.len() == 0:
                log_info("[app.sshd] " + "[sshd-session] plaintext incomplete")
                return []
            log_info("[app.sshd] " + "[sshd-session] plaintext packet ok")
            self.recv_seq = (self.recv_seq + 1) & 0xFFFFFFFF
            return payload

        var i: u64 = 0
        if self.recv_buf.len() == 0:
            val new_data = self.raw_recv(RECV_BUF_SIZE)
            if new_data.len() == 0:
                return []
            self.recv_buf = new_data

        if self.cipher.active:
            # Encrypted mode: need at least 4 bytes for length + 16 for tag
            if self.recv_buf.len() < 20:
                return []

            val packet_length = ssh_get_u32(self.recv_buf, 0).to_u64()
            val total_needed = 4 + packet_length + 16   # length + body + GCM tag

            # Read more if needed
            while self.recv_buf.len() < total_needed:
                val more = self.raw_recv(RECV_BUF_SIZE)
                if more.len() == 0:
                    return []
                if self.recv_buf.len() == 0:
                    self.recv_buf = more
                else:
                    self.recv_buf = rt_bytes_concat(self.recv_buf, more)

            # Extract the encrypted packet
            var enc_packet = rt_bytes_slice(self.recv_buf, 0, total_needed.to_i64())

            # Remove consumed bytes from recv_buf
            self.recv_buf = _slice_range(self.recv_buf, total_needed, self.recv_buf.len())

            # Decrypt
            val r = self.cipher.decrypt_packet(enc_packet)
            if r.is_ok():
                val payload = r.unwrap()
                self.recv_seq = (self.recv_seq + 1) & 0xFFFFFFFF
                return payload
            else:
                return []

        else:
            return []

    me disconnect(reason: u32, description: text):
        """Send SSH_MSG_DISCONNECT and close the session."""
        log_info("[app.sshd] " + "[sshd-session] disconnect reason={reason} description={description}")
        val msg = ssh_build_disconnect(reason, description)
        self.send_packet(msg)
        self.state = SessionState.Closed

    me raw_send(data: [u8]):
        """Send raw bytes over the TCP socket."""
        rt_net_send_bytes(self.socket_fd as i64, data)

    me raw_recv(max: u64) -> [u8]:
        """Receive raw bytes from the TCP socket."""
        rt_net_recv_bytes(self.socket_fd as i64, max as i64)

    me close():
        """Clean up session resources."""
        if val pty = self.pty:
            pty.close()
        rt_net_close(self.socket_fd as i64)
        self.state = SessionState.Closed

# ============================================================================
# Host Key Helpers
# ============================================================================

fn _build_host_key_blob_for_algo(algo: text, host_keys: HostKeySet) -> [u8]:
    """Build the SSH host key blob for the negotiated host key algorithm.

    For ssh-ed25519: derives the public key from the seed and builds the blob.
    For rsa-sha2-256 / rsa-sha2-512: uses the prebuilt SSH RSA public blob.
    For ecdsa-sha2-nistp256: not yet fully supported (returns empty blob).
    Callers pass the blob directly into the exchange hash computation.
    """
    if algo == "ssh-ed25519":
        val pubkey = _ed25519_public_key_from_seed(host_keys.ed25519_seed)
        if pubkey.len() != 32:
            return []
        return ssh_build_ed25519_host_key_blob(pubkey)
    if algo == "rsa-sha2-256" or algo == "rsa-sha2-512":
        if host_keys.rsa_public_blob != nil:
            return host_keys.rsa_public_blob
        return []
    # For ECDSA the server needs to supply the public key separately.
    []

# ============================================================================
# Public Key Auth Helpers (RFC 4252 §7)
# ============================================================================

fn _build_publickey_signed_data(session_id: [u8], username: text, algo: text, key_blob: [u8]) -> [u8]:
    """Build the signed_data blob for publickey auth per RFC 4252 §7.

    Format:
      string  session_id
      byte    SSH_MSG_USERAUTH_REQUEST (50)
      string  username
      string  "ssh-connection"
      string  "publickey"
      bool    true
      string  algorithm name
      string  public_key_blob
    """
    var data: [u8] = []
    ssh_put_string(data, session_id)
    ssh_put_byte(data, 50)
    ssh_put_text(data, username)
    ssh_put_text(data, "ssh-connection")
    ssh_put_text(data, "publickey")
    ssh_put_bool(data, true)
    ssh_put_text(data, algo)
    ssh_put_string(data, key_blob)
    data

fn _unwrap_ssh_signature(sig_envelope: [u8]) -> [u8]:
    """Unwrap the SSH signature envelope to extract the raw signature bytes.

    SSH signature field format:
      string  algorithm name (e.g. "rsa-sha2-256" or "ssh-ed25519")
      string  raw signature bytes

    Returns the raw signature bytes, or the envelope unchanged if parsing fails.
    """
    if sig_envelope.len() < 4:
        return sig_envelope
    # Skip the algorithm name string
    var r_algo = ssh_get_string(sig_envelope, 0)
    if r_algo.is_ok():
        var algo_pair = r_algo.unwrap()
        var off = algo_pair.next_offset
        # Read the raw signature bytes
        var r_raw = ssh_get_string(sig_envelope, off)
        if r_raw.is_ok():
            var raw_pair = r_raw.unwrap()
            return raw_pair.data
    sig_envelope

fn _extract_ed25519_pubkey(key_blob: [u8]) -> [u8]:
    """Extract the raw 32-byte Ed25519 public key from an SSH key blob.

    SSH ed25519 blob format:
      string  "ssh-ed25519"
      string  public key (32 bytes)

    Returns the 32-byte key, or empty array on failure.
    """
    if key_blob.len() < 4:
        return []
    # Skip the key type string ("ssh-ed25519")
    var r_type = ssh_get_string(key_blob, 0)
    if r_type.is_ok():
        var type_pair = r_type.unwrap()
        var off = type_pair.next_offset
        var r_key = ssh_get_string(key_blob, off)
        if r_key.is_ok():
            var key_pair = r_key.unwrap()
            return key_pair.data
    []

pub fn ssh_shell_boot_output_for_test() -> text:
    """Create a fresh SSH-backed shell and return its initial banner/prompt."""
    var shell = ShellApp.new()
    shell.show_prompt()
    shell.take_remote_output()

pub fn ssh_shell_roundtrip_output_for_test(input: text) -> text:
    """Run transport text through a fresh shell and return the emitted output."""
    var shell = ShellApp.new()
    shell.show_prompt()
    var output = shell.take_remote_output()
    val _running = shell.feed_remote_input(input)
    output = "{output}{shell.take_remote_output()}"
    output
