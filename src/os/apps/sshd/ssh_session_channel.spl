# SSH Session — Interactive Phase and Channel Management (Phase 5)
#
# Extracted from ssh_session.spl.
# Contains: impl SshSession.do_interactive() and all _handle_* channel methods,
#           plus shell/PTY forwarding helpers.

use os.apps.sshd.ssh_session.{SshSession, SessionState}
use os.apps.sshd.ssh_hex.{format_hex_width}
use os.apps.sshd.ssh_packet.{ssh_get_u32, ssh_get_text}
use os.apps.sshd.ssh_transport.{SSH_MSG_DISCONNECT, SSH_MSG_IGNORE, SSH_MSG_KEXINIT}
use os.apps.sshd.ssh_channel.{ChannelTable, SshChannel, ChannelType, ChannelState, SSH_MSG_CHANNEL_OPEN, SSH_MSG_CHANNEL_DATA, SSH_MSG_CHANNEL_WINDOW_ADJUST, SSH_MSG_CHANNEL_EOF, SSH_MSG_CHANNEL_CLOSE, SSH_MSG_CHANNEL_REQUEST, DEFAULT_WINDOW_SIZE, DEFAULT_MAX_PACKET, ssh_parse_channel_open, ssh_parse_channel_data, ssh_parse_channel_request, ssh_parse_window_adjust, ssh_parse_channel_eof, ssh_parse_channel_close, ssh_build_channel_open_failure, ssh_build_channel_data, ssh_build_channel_window_adjust}
use os.apps.sshd.ssh_remote_shell.{SshRemoteShell}
use os.apps.sshd.ssh_session_helpers.{_u8_at, _bytes_to_hex, _read_u32_stable, _read_text_field_fast, _text_equals_bytes, _build_channel_open_confirmation_stable, _build_channel_success_stable, _build_channel_failure_stable, _build_channel_eof_stable, _build_channel_close_stable, _build_channel_exit_status_stable}
use os.kernel.log.klog_api.{log_info}
extern fn rt_string_from_byte_array(arr: [u8]) -> text
extern fn serial_println(msg: text)

impl SshSession:

    # ========================================================================
    # Phase 5: Interactive (Channel Management)
    # ========================================================================

    me do_interactive():
        """Handle channels and data transfer.

        Main loop: receive packets, dispatch by message type.
        Simultaneously forwards data between PTY and SSH channel.
        """
        log_info("[app.sshd] " + "[sshd-session] interactive")
        self.state = SessionState.Interactive
        serial_println("[sshd-session] interactive enter state={self.state} recv_buf_len={self.recv_buf.len()} seq_c2s={self.cipher.seq_c2s}")
        while true:
            if self.state == SessionState.Closed:
                serial_println("[sshd-session] interactive break closed")
                return
            # Check for data from the interactive shell before blocking on input.
            self._forward_shell_output()
            self._forward_pty_output()

            # Receive a packet from the client
            val payload = self.recv_packet_payload()
            if payload.len() == 0:
                serial_println("[sshd-session] interactive empty payload closing recv_buf_len={self.recv_buf.len()} seq_c2s={self.cipher.seq_c2s} recv_seq={self.recv_seq}")
                self.state = SessionState.Closed
                return

            val msg_type = _u8_at(payload, 0)
            serial_println("[sshd-session] interactive msg_type=0x{format_hex_width(msg_type.to_u64(), 2)} len={payload.len()} seq_c2s={self.cipher.seq_c2s}")

            if msg_type == 90:
                serial_println("[sshd-session] dispatch channel_open")
                self._handle_channel_open(payload)

            elif msg_type == 94:
                serial_println("[sshd-session] dispatch channel_data")
                self._handle_channel_data(payload)

            elif msg_type == 93:
                serial_println("[sshd-session] dispatch channel_window_adjust")
                self._handle_window_adjust(payload)

            elif msg_type == 96:
                serial_println("[sshd-session] dispatch channel_eof")
                self._handle_channel_eof(payload)

            elif msg_type == 97:
                serial_println("[sshd-session] dispatch channel_close")
                self._handle_channel_close(payload)

            elif msg_type == 98:
                serial_println("[sshd-session] dispatch channel_request")
                self._handle_channel_request(payload)

            elif msg_type == SSH_MSG_DISCONNECT:
                self.state = SessionState.Closed
                return

            elif msg_type == SSH_MSG_IGNORE:
                pass_dn     # Silently ignore

            elif msg_type == SSH_MSG_KEXINIT:
                # Re-keying: handle inline
                self.client_kexinit_payload = payload
                self.do_kex()

            else:
                pass_dn     # Ignore unknown messages

    me _handle_channel_open(payload: [u8]):
        """Handle SSH_MSG_CHANNEL_OPEN."""
        serial_println("[sshd-session] handle_channel_open len={payload.len()}")
        if payload.len() >= 24 and _u8_at(payload, 0) == 90:
            val r_type = _read_text_field_fast(payload, 1)
            if r_type.is_ok():
                val ch_type = r_type.unwrap()
                if _text_equals_bytes(ch_type.value, [0x73, 0x65, 0x73, 0x73, 0x69, 0x6F, 0x6E]) and ch_type.next_offset + 12 <= payload.len():
                    val remote_id = _read_u32_stable(payload, ch_type.next_offset)
                    val remote_window = _read_u32_stable(payload, ch_type.next_offset + 4)
                    val remote_max_packet = _read_u32_stable(payload, ch_type.next_offset + 8)
                    serial_println("[sshd-session] channel open=session (live fast path)")
                    val local_id: u32 = 0
                    self.active_remote_channel_id = remote_id
                    self.channels.seed_open(local_id, ChannelType.Session, remote_id, remote_window, remote_max_packet)
                    val confirm = _build_channel_open_confirmation_stable(
                        remote_id, local_id, DEFAULT_WINDOW_SIZE, DEFAULT_MAX_PACKET
                    )
                    serial_println("[sshd-session] channel open confirm len={confirm.len()}")
                    self.send_packet(confirm)
                    return

        val r = ssh_parse_channel_open(payload)
        if r.is_err():
            return

        val parsed = r.unwrap()
        val ch_type_str = parsed.0
        val remote_id = parsed.1
        val remote_window = parsed.2
        val remote_max_packet = parsed.3

        if ch_type_str == "session":
            val local_id = self.channels.open(
                ChannelType.Session, remote_id, remote_window, remote_max_packet
            )
            if local_id == 0:
                self.active_remote_channel_id = remote_id
            val confirm = _build_channel_open_confirmation_stable(
                remote_id, local_id, DEFAULT_WINDOW_SIZE, DEFAULT_MAX_PACKET
            )
            self.send_packet(confirm)
        else:
            val fail = ssh_build_channel_open_failure(remote_id, 3, "unknown channel type")
            self.send_packet(fail)

    me _handle_channel_data(payload: [u8]):
        """Handle SSH_MSG_CHANNEL_DATA — forward to the headless remote shell."""
        val r = ssh_parse_channel_data(payload)
        if r.is_err():
            return

        val parsed = r.unwrap()
        val recipient = parsed.0
        val data = parsed.1

        # Consume local window
        self.channels.consume_local_window(recipient, data.len().to_u32())

        # Forward data to the built-in remote shell.
        if val shell = self.shell:
            val text = rt_string_from_byte_array(data)
            if not shell.feed_remote_input(text):
                self.state = SessionState.Closed
            self._forward_shell_output()

        # Send window adjust if local window is getting low
        val ch = self.channels.find(recipient)
        if ch != nil:
            if ch.local_window < DEFAULT_WINDOW_SIZE / 2:
                val adjust_bytes = DEFAULT_WINDOW_SIZE - ch.local_window
                self.channels.adjust_window(recipient, adjust_bytes)
                val remote_id = if recipient == 0: self.active_remote_channel_id else: ch.remote_id
                val adjust = ssh_build_channel_window_adjust(remote_id, adjust_bytes)
                self.send_packet(adjust)

    me _handle_window_adjust(payload: [u8]):
        """Handle SSH_MSG_CHANNEL_WINDOW_ADJUST."""
        val r = ssh_parse_window_adjust(payload)
        if r.is_err():
            return

        val parsed = r.unwrap()
        val recipient = parsed.0
        val bytes = parsed.1

        # Find the channel and increase our remote send window
        var i: u64 = 0
        while i < self.channels.channels.len():
            if self.channels.channels[i].local_id == recipient:
                self.channels.channels[i].remote_window = self.channels.channels[i].remote_window + bytes
                return
            i = i + 1

    me _handle_channel_eof(payload: [u8]):
        """Handle SSH_MSG_CHANNEL_EOF."""
        val r = ssh_parse_channel_eof(payload)
        if r.is_err():
            return
        # Client sent EOF — no more data from client
        # We don't need to do anything special; the shell can keep running

    me _handle_channel_close(payload: [u8]):
        """Handle SSH_MSG_CHANNEL_CLOSE."""
        val r = ssh_parse_channel_close(payload)
        if r.is_err():
            return

        val recipient = r.unwrap()
        val ch = self.channels.find(recipient)
        if ch != nil:
            # Send CHANNEL_CLOSE back
            val remote_id = if recipient == 0: self.active_remote_channel_id else: ch.remote_id
            val close = _build_channel_close_stable(remote_id)
            self.send_packet(close)
            self.channels.close(recipient)

        self.channels.remove_closed()

        # If no more channels, end session
        if self.channels.channels.len() == 0:
            self.state = SessionState.Closed

    me _handle_channel_request(payload: [u8]):
        """Handle SSH_MSG_CHANNEL_REQUEST (pty-req, shell, exec, env, window-change)."""
        if payload.len() < 11 or _u8_at(payload, 0) != 98:
            return
        val recipient = _read_u32_stable(payload, 1)
        val r_type = _read_text_field_fast(payload, 5)
        if r_type.is_err():
            return
        val req_type = r_type.unwrap()
        if req_type.next_offset >= payload.len():
            return
        val want_reply = _u8_at(payload, req_type.next_offset) != 0
        var off = req_type.next_offset + 1
        var request_code: u8 = 0
        if _text_equals_bytes(req_type.value, [0x70, 0x74, 0x79, 0x2D, 0x72, 0x65, 0x71]):
            request_code = 1
        elif _text_equals_bytes(req_type.value, [0x73, 0x68, 0x65, 0x6C, 0x6C]):
            request_code = 2
        elif _text_equals_bytes(req_type.value, [0x65, 0x78, 0x65, 0x63]):
            request_code = 3
        elif _text_equals_bytes(req_type.value, [0x73, 0x75, 0x62, 0x73, 0x79, 0x73, 0x74, 0x65, 0x6D]):
            request_code = 4
        elif _text_equals_bytes(req_type.value, [0x65, 0x6E, 0x76]):
            request_code = 5
        elif _text_equals_bytes(req_type.value, [0x77, 0x69, 0x6E, 0x64, 0x6F, 0x77, 0x2D, 0x63, 0x68, 0x61, 0x6E, 0x67, 0x65]):
            request_code = 6
        else:
            return

        val ch = self.channels.find(recipient)
        var reply_remote_id: u32 = 0
        if recipient == 0:
            reply_remote_id = self.active_remote_channel_id
        elif ch != nil:
            reply_remote_id = ch.remote_id
        if ch == nil:
            if want_reply:
                val fail = _build_channel_failure_stable(0)
                self.send_packet(fail)
            return

        if request_code == 1:
            self._handle_pty_request(payload, off, recipient, reply_remote_id, want_reply)

        elif request_code == 2:
            self._handle_shell_request(recipient, reply_remote_id, want_reply)

        elif request_code == 3:
            serial_println("[sshd-session] channel request=exec want_reply={want_reply}")
            self._handle_exec_request(payload, off, recipient, reply_remote_id, want_reply)

        elif request_code == 4:
            if want_reply:
                val fail = _build_channel_failure_stable(reply_remote_id)
                self.send_packet(fail)

        elif request_code == 5:
            # Environment variable setting — parse but don't act on it
            if want_reply:
                val success = _build_channel_success_stable(reply_remote_id)
                self.send_packet(success)

        elif request_code == 6:
            # Terminal resize
            if off + 8 <= payload.len():
                val new_cols = _read_u32_stable(payload, off)
                val new_rows = _read_u32_stable(payload, off + 4)
                pass_dn
            # window-change never wants reply per RFC

        else:
            if want_reply:
                val fail = _build_channel_failure_stable(reply_remote_id)
                self.send_packet(fail)

    me _handle_pty_request(payload: [u8], off: u64, local_id: u32, remote_id: u32, want_reply: bool):
        """Handle pty-req channel request.

        Fields after the standard header:
          string    TERM environment variable (e.g. "xterm-256color")
          uint32    terminal width in characters
          uint32    terminal height in rows
          uint32    terminal width in pixels (ignored)
          uint32    terminal height in pixels (ignored)
          string    encoded terminal modes (ignored)
        """
        var pos = off

        # Parse TERM
        var term_type: text = "xterm"
        val r_term = ssh_get_text(payload, pos)
        if r_term.is_ok():
            val term_pair = r_term.unwrap()
            term_type = term_pair.value
            pos = term_pair.next_offset

        # Parse dimensions
        var cols: u32 = 80
        var rows: u32 = 24
        if pos + 16 <= payload.len():
            cols = ssh_get_u32(payload, pos)
            pos = pos + 4
            rows = ssh_get_u32(payload, pos)
            pos = pos + 4
            # Skip pixel width and height
            pos = pos + 8

        # Headless live SSH keeps the PTY request state without creating a hosted PTY.
        var i: u64 = 0
        while i < self.channels.channels.len():
            if self.channels.channels[i].local_id == local_id:
                self.channels.channels[i].pty_requested = true
            i = i + 1

        if want_reply:
            val success = _build_channel_success_stable(remote_id)
            self.send_packet(success)

    me _handle_shell_request(local_id: u32, remote_id: u32, want_reply: bool):
        """Handle shell channel request — launch interactive shell."""
        # Mark channel as shell-enabled
        var i: u64 = 0
        while i < self.channels.channels.len():
            if self.channels.channels[i].local_id == local_id:
                self.channels.channels[i].shell_requested = true
            i = i + 1

        if want_reply:
            val success = _build_channel_success_stable(remote_id)
            self.send_packet(success)

        self._ensure_shell_started(true)
        self._forward_shell_output()

    me _handle_exec_request(payload: [u8], off: u64, local_id: u32, remote_id: u32, want_reply: bool):
        """Handle exec requests by running the command through the same shell REPL."""
        val r_command = _read_text_field_fast(payload, off)
        if r_command.is_err():
            if want_reply:
                val fail = _build_channel_failure_stable(remote_id)
                self.send_packet(fail)
            return

        val command = r_command.unwrap().value
        serial_println("[sshd-session] exec command={command}")

        var i: u64 = 0
        while i < self.channels.channels.len():
            if self.channels.channels[i].local_id == local_id:
                self.channels.channels[i].shell_requested = true
            i = i + 1

        if want_reply:
            val success = _build_channel_success_stable(remote_id)
            self.send_packet(success)

        if command.trim() == "true":
            self._finish_exec_request(local_id, remote_id, 0, [])
            return

        self._ensure_shell_started(false)
        if val shell = self.shell:
            if not shell.feed_remote_input("{command}\n"):
                self.state = SessionState.Closed
                return
            self._forward_shell_output()

    me _ensure_shell_started(show_prompt: bool):
        """Create the shared SSH shell instance once per authenticated session."""
        if self.shell != nil:
            return
        var shell = SshRemoteShell.new()
        if show_prompt:
            shell.show_prompt()
        self.shell = shell

    me _finish_exec_request(local_id: u32, remote_id: u32, exit_status: u32, output: [u8]):
        if output.len() > 0 and self.channels.consume_remote_window(local_id, output.len().to_u32()):
            val data_msg = ssh_build_channel_data(remote_id, output)
            self.send_packet(data_msg)
        self._send_channel_exit_status(remote_id, exit_status)
        self.send_packet(_build_channel_eof_stable(remote_id))
        self.send_packet(_build_channel_close_stable(remote_id))
        self.channels.close(local_id)
        self.channels.remove_closed()
        if self.channels.channels.len() == 0:
            self.state = SessionState.Closed

    me _send_channel_exit_status(remote_id: u32, exit_status: u32):
        val payload = _build_channel_exit_status_stable(remote_id, exit_status)
        self.send_packet(payload)

    me _forward_shell_output():
        """Drain shell terminal output to the active SSH session channel."""
        if val shell = self.shell:
            val output = shell.take_remote_output()
            if output != "":
                self._send_shell_output(output.to_bytes())

    me _send_shell_output(output: [u8]):
        """Forward shell bytes to the first open shell-enabled session channel."""
        if output.len() == 0:
            return
        var i: u64 = 0
        while i < self.channels.channels.len():
            val ch = self.channels.channels[i]
            if ch.shell_requested:
                match ch.state:
                    ChannelState.Open:
                        val send_len = output.len().to_u32()
                        if self.channels.consume_remote_window(ch.local_id, send_len):
                            val data_msg = ssh_build_channel_data(ch.remote_id, output)
                            self.send_packet(data_msg)
                        return
                    _:
                        pass_dn
            i = i + 1

    me _forward_pty_output():
        """Headless live SSH does not source output from a PTY."""
        pass_dn
