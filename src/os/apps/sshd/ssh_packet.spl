#![allow(unnamed_duplicate_typed_args)]
# SSH Binary Packet Protocol — RFC 4253 Section 6
#
# Wire format (plaintext):
#   uint32    packet_length       (not including MAC or packet_length itself)
#   byte      padding_length      (4..255)
#   byte[n1]  payload             (n1 = packet_length - padding_length - 1)
#   byte[n2]  random_padding      (n2 = padding_length)
#   byte[m]   mac                 (0 before key exchange)
#
# Block size is 8 bytes minimum (16 for AES-256-GCM).
# Total of (packet_length + 4) must be a multiple of the cipher block size.

# ============================================================================
# Constants
# ============================================================================

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_push_byte(arr: [u8], byte_val: i64) -> [u8]

val SSH_MAX_PACKET: u64 = 35000   # Max packet size per RFC 4253
val SSH_MIN_PADDING: u8 = 4       # Minimum 4 bytes of random padding
val SSH_ASCII_PRINTABLE: text = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"

# ============================================================================
# Types
# ============================================================================

struct SshPacket:
    """A decoded SSH packet."""
    payload: [u8]
    sequence: u32

struct SshPacketResult:
    """Workaround: tuples are broken in baremetal Cranelift. Use struct instead."""
    packet: SshPacket
    consumed: u64

struct SshStringResult:
    """Workaround for tuple return from ssh_get_string."""
    data: [u8]
    next_offset: u64

struct SshTextResult:
    """Workaround for tuple return from ssh_get_text."""
    value: text
    next_offset: u64

# ============================================================================
# Big-Endian Encoding Helpers
# ============================================================================

fn ssh_put_u32(buf: [u8], val_: u32):
    """Append a u32 in big-endian (network byte order)."""
    buf.push(((val_ >> 24) & 0xFF).to_u8())
    buf.push(((val_ >> 16) & 0xFF).to_u8())
    buf.push(((val_ >> 8) & 0xFF).to_u8())
    buf.push((val_ & 0xFF).to_u8())

fn ssh_get_u32(data: [u8], offset: u64) -> u32:
    """Read a big-endian u32 from data at offset.
    NOTE: Uses var locals to work around baremetal Cranelift codegen bug.
    """
    var b0: u32 = data[offset].to_u32()
    var b1: u32 = data[offset + 1].to_u32()
    var b2: u32 = data[offset + 2].to_u32()
    var b3: u32 = data[offset + 3].to_u32()
    (b0 << 24) | (b1 << 16) | (b2 << 8) | b3

fn ssh_put_string(buf: [u8], data: [u8]):
    """Append SSH string: uint32 length + bytes."""
    ssh_put_u32(buf, data.len().to_u32())
    var i: u64 = 0
    while i < data.len():
        buf.push(data[i])
        i = i + 1

fn ssh_put_text(buf: [u8], s: text):
    """Append SSH string from text: uint32 length + UTF-8 bytes."""
    var bytes: [u8] = ssh_ascii_text_to_bytes(s)
    ssh_put_string(buf, bytes)

fn ssh_ascii_byte_to_text(byte: u8) -> text:
    val idx = byte.to_i64() - 32
    if idx < 0 or idx >= SSH_ASCII_PRINTABLE.len():
        return ""
    SSH_ASCII_PRINTABLE[idx:idx + 1]

fn ssh_ascii_bytes_to_text(data: [u8]) -> text:
    var result = ""
    var i: u64 = 0
    while i < data.len():
        result = result + ssh_ascii_byte_to_text(data[i])
        i = i + 1
    result

fn ssh_ascii_text_to_bytes(s: text) -> [u8]:
    var result: [u8] = []
    val chars = s.split("")
    for ch in chars:
        if ch != "":
            var idx: i64 = 0
            var found = false
            while idx < SSH_ASCII_PRINTABLE.len() and not found:
                if SSH_ASCII_PRINTABLE[idx:idx + 1] == ch:
                    result.push((idx + 32).to_u8())
                    found = true
                idx = idx + 1
    result

fn ssh_get_string(data: [u8], offset: u64) -> Result<SshStringResult, text>:
    """Read SSH string at offset. Returns SshStringResult(data, next_offset).
    NOTE: Uses intermediate var for ssh_get_u32 result to avoid baremetal
    Cranelift codegen bug with chained .to_u64() on function returns.
    """
    if offset + 4 > data.len():
        return Err("ssh_get_string: truncated length")
    var str_len_u32: u32 = ssh_get_u32(data, offset)
    var str_len: u64 = str_len_u32.to_u64()
    var start: u64 = offset + 4
    if start + str_len > data.len():
        return Err("ssh_get_string: truncated data")
    var result: [u8] = []
    var i: u64 = 0
    while i < str_len:
        result.push(data[start + i])
        i = i + 1
    Ok(SshStringResult(data: result, next_offset: start + str_len))

fn ssh_get_text(data: [u8], offset: u64) -> Result<SshTextResult, text>:
    """Read SSH string as text at offset. Returns SshTextResult(value, next_offset).
    NOTE: Extracts next_offset into var BEFORE extern call to avoid
    baremetal Cranelift register-clobber after byte-array text conversion.
    """
    var r = ssh_get_string(data, offset)
    if r.is_ok():
        var sr = r.unwrap()
        var sr_data: [u8] = sr.data
        var sr_next: u64 = sr.next_offset
        var txt: text = ssh_ascii_bytes_to_text(sr_data)
        Ok(SshTextResult(value: txt, next_offset: sr_next))
    else:
        Err("ssh_get_text: string decode failed")

fn ssh_put_mpint(buf: [u8], val_bytes: [u8]):
    """Append SSH mpint: uint32 length + value (big-endian, two's complement).

    If the high bit of the first byte is set we prepend a 0x00 byte
    to keep the number positive.
    """
    # Strip leading zeros
    var start: u64 = 0
    while start < val_bytes.len() and val_bytes[start] == 0:
        start = start + 1

    if start >= val_bytes.len():
        # Value is zero
        ssh_put_u32(buf, 0)
        return

    var needs_pad: bool = (val_bytes[start] & 0x80) != 0
    var body_len: u64 = val_bytes.len() - start
    var total_len: u64 = body_len + (if needs_pad: 1 else: 0)
    ssh_put_u32(buf, total_len.to_u32())

    if needs_pad:
        buf.push(0x00)

    var i: u64 = start
    while i < val_bytes.len():
        buf.push(val_bytes[i])
        i = i + 1

fn ssh_put_bool(buf: [u8], val_: bool):
    """Append SSH boolean (1 byte: 0 or 1)."""
    if val_:
        buf.push(1)
    else:
        buf.push(0)

fn ssh_put_byte(buf: [u8], val_: u8):
    """Append a single byte."""
    buf.push(val_)

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

# ============================================================================
# Packet Read (plaintext)
# ============================================================================

fn ssh_packet_read(data: [u8], offset: u64) -> Result<SshPacketResult, text>:
    """Read one SSH packet from raw bytes. Returns (packet, bytes_consumed).

    Expects unencrypted data. For encrypted packets see ssh_cipher.spl.
    NOTE: Uses var (mutable) locals and ssh_get_u32 (bit-shift based) to
    work around baremetal codegen bugs: (1) val locals from function returns
    corrupt in arithmetic, (2) multiplication of byte values fails for
    larger payloads. The ssh_get_u32 approach is proven correct by B7 test.
    """
    var avail: u64 = data.len() - offset

    if avail < 5:
        return Err("ssh_packet_read: need at least 5 bytes")

    # Read packet_length via ssh_get_u32 (bit-shift based, proven by B7 test).
    # Previous manual multiplication approach broke for larger payloads due to
    # baremetal codegen bug with intermediate multiplication results.
    var pkt_len_u32: u32 = ssh_get_u32(data, offset)
    var packet_length: u64 = 0
    # Avoid .to_u64() on function return (val-from-return corruption).
    # Instead, store u32 in var first, then widen.
    var pkt_tmp: u32 = pkt_len_u32
    packet_length = pkt_tmp.to_u64()

    if packet_length < 2:
        return Err("ssh_packet_read: packet_length too small")
    if packet_length > 35000:
        return Err("ssh_packet_read: packet_length exceeds max")

    var total: u64 = 4 + packet_length
    if avail < total:
        return Err("ssh_packet_read: incomplete packet")

    # Read padding_length byte
    var padding_length: u64 = data[offset + 4].to_u64()

    if padding_length + 1 > packet_length:
        return Err("ssh_packet_read: padding exceeds packet")
    var payload_length: u64 = packet_length - padding_length - 1

    var payload: [u8] = []
    var i: u64 = 0
    while i < payload_length:
        payload.push(data[offset + 5 + i])
        i = i + 1

    Ok(SshPacketResult(packet: SshPacket(payload: payload, sequence: 0), consumed: total))

# ============================================================================
# Packet Build (plaintext)
# ============================================================================

fn ssh_packet_build(payload: [u8], sequence: u32) -> [u8]:
    """Build an SSH packet from payload. No encryption/MAC.

    Padding: total of (4 + 1 + payload_len + padding_len) must be
    a multiple of 8 (minimum block size). Padding >= 4 bytes.
    """
    var block_size: u64 = 8
    var payload_len: u64 = payload.len()

    # Calculate minimum padding
    # packet_length = 1 + payload_len + padding_len
    # (4 + packet_length) must be a multiple of block_size
    # i.e. (5 + payload_len + padding_len) % block_size == 0
    var padding_len: u64 = block_size - ((5 + payload_len) % block_size)
    if padding_len < 4:
        padding_len = padding_len + block_size

    var packet_length: u64 = 1 + payload_len + padding_len

    var buf: [u8] = []

    # 4-byte length (big-endian)
    ssh_put_u32(buf, packet_length.to_u32())

    # 1-byte padding_length
    buf = rt_push_byte(buf, padding_len.to_i64())

    # Payload
    var i: u64 = 0
    while i < payload_len:
        buf = rt_push_byte(buf, _u8_at(payload, i).to_u64().to_i64())
        i = i + 1

    # Zero-fill padding (deterministic — random_bytes may FAULT on baremetal)
    i = 0
    while i < padding_len:
        buf = rt_push_byte(buf, 0)
        i = i + 1

    buf

fn ssh_packet_build_encrypted(payload: [u8], sequence: u32, key: [u8], iv: [u8], mac_key: [u8]) -> [u8]:
    """Build encrypted SSH packet with AES-256-GCM.

    Delegates to SshCipher — this is a convenience stub.
    For real encrypted packets use SshCipher.encrypt_packet().
    """
    # Construct the plaintext packet first, then encrypt externally
    ssh_packet_build(payload, sequence)
