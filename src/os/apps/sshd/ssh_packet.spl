# SSH Binary Packet Protocol — RFC 4253 Section 6
#
# Wire format (plaintext):
#   uint32    packet_length       (not including MAC or packet_length itself)
#   byte      padding_length      (4..255)
#   byte[n1]  payload             (n1 = packet_length - padding_length - 1)
#   byte[n2]  random_padding      (n2 = padding_length)
#   byte[m]   mac                 (0 before key exchange)
#
# Block size is 8 bytes minimum (16 for AES-256-GCM).
# Total of (packet_length + 4) must be a multiple of the cipher block size.

# ============================================================================
# Constants
# ============================================================================

val SSH_MAX_PACKET: u64 = 35000   # Max packet size per RFC 4253
val SSH_MIN_PADDING: u8 = 4       # Minimum 4 bytes of random padding

# ============================================================================
# Types
# ============================================================================

struct SshPacket:
    """A decoded SSH packet."""
    payload: [u8]
    sequence: u32

# ============================================================================
# Big-Endian Encoding Helpers
# ============================================================================

fn ssh_put_u32(buf: [u8], val_: u32):
    """Append a u32 in big-endian (network byte order)."""
    buf.push(((val_ >> 24) & 0xFF).to_u8())
    buf.push(((val_ >> 16) & 0xFF).to_u8())
    buf.push(((val_ >> 8) & 0xFF).to_u8())
    buf.push((val_ & 0xFF).to_u8())

fn ssh_get_u32(data: [u8], offset: u64) -> u32:
    """Read a big-endian u32 from data at offset."""
    val b0 = data[offset].to_u32()
    val b1 = data[offset + 1].to_u32()
    val b2 = data[offset + 2].to_u32()
    val b3 = data[offset + 3].to_u32()
    (b0 << 24) | (b1 << 16) | (b2 << 8) | b3

fn ssh_put_string(buf: [u8], data: [u8]):
    """Append SSH string: uint32 length + bytes."""
    ssh_put_u32(buf, data.len().to_u32())
    var i: u64 = 0
    while i < data.len():
        buf.push(data[i])
        i = i + 1

fn ssh_put_text(buf: [u8], s: text):
    """Append SSH string from text: uint32 length + UTF-8 bytes."""
    val bytes = s.to_bytes()
    ssh_put_string(buf, bytes)

fn ssh_get_string(data: [u8], offset: u64) -> Result<([u8], u64), text>:
    """Read SSH string at offset. Returns (bytes, next_offset)."""
    if offset + 4 > data.len():
        return Err("ssh_get_string: truncated length")
    val str_len = ssh_get_u32(data, offset).to_u64()
    val start = offset + 4
    if start + str_len > data.len():
        return Err("ssh_get_string: truncated data")
    var result: [u8] = []
    var i: u64 = 0
    while i < str_len:
        result.push(data[start + i])
        i = i + 1
    Ok((result, start + str_len))

fn ssh_get_text(data: [u8], offset: u64) -> Result<(text, u64), text>:
    """Read SSH string as text at offset. Returns (text, next_offset)."""
    val r = ssh_get_string(data, offset)
    if r.is_ok():
        val pair = r.unwrap()
        Ok((text.from_bytes(pair.0), pair.1))
    else:
        Err("ssh_get_text: string decode failed")

fn ssh_put_mpint(buf: [u8], val_bytes: [u8]):
    """Append SSH mpint: uint32 length + value (big-endian, two's complement).

    If the high bit of the first byte is set we prepend a 0x00 byte
    to keep the number positive.
    """
    # Strip leading zeros
    var start: u64 = 0
    while start < val_bytes.len() and val_bytes[start] == 0:
        start = start + 1

    if start >= val_bytes.len():
        # Value is zero
        ssh_put_u32(buf, 0)
        return

    val needs_pad = (val_bytes[start] & 0x80) != 0
    val body_len = val_bytes.len() - start
    val total_len = body_len + (if needs_pad: 1 else: 0)
    ssh_put_u32(buf, total_len.to_u32())

    if needs_pad:
        buf.push(0x00)

    var i: u64 = start
    while i < val_bytes.len():
        buf.push(val_bytes[i])
        i = i + 1

fn ssh_put_bool(buf: [u8], val_: bool):
    """Append SSH boolean (1 byte: 0 or 1)."""
    if val_:
        buf.push(1)
    else:
        buf.push(0)

fn ssh_put_byte(buf: [u8], val_: u8):
    """Append a single byte."""
    buf.push(val_)

# ============================================================================
# Packet Read (plaintext)
# ============================================================================

fn ssh_packet_read(data: [u8], offset: u64) -> Result<(SshPacket, u64), text>:
    """Read one SSH packet from raw bytes. Returns (packet, bytes_consumed).

    Expects unencrypted data. For encrypted packets see ssh_cipher.spl.
    NOTE: Uses var (mutable) locals and manual byte reads instead of
    ssh_get_u32 to work around baremetal codegen bug where val locals
    from function returns corrupt in arithmetic/comparisons.
    """
    var avail: u64 = data.len() - offset

    if avail < 5:
        return Err("ssh_packet_read: need at least 5 bytes")

    # Read packet_length manually from 4 big-endian bytes
    var packet_length: u64 = 0
    var b0: u64 = data[offset].to_u64()
    var b1: u64 = data[offset + 1].to_u64()
    var b2: u64 = data[offset + 2].to_u64()
    var b3: u64 = data[offset + 3].to_u64()
    packet_length = (b0 * 16777216) + (b1 * 65536) + (b2 * 256) + b3

    if packet_length < 2:
        return Err("ssh_packet_read: packet_length too small")
    if packet_length > 35000:
        return Err("ssh_packet_read: packet_length exceeds max")

    var total: u64 = 4 + packet_length
    if avail < total:
        return Err("ssh_packet_read: incomplete packet")

    # Read padding_length byte
    var padding_length: u64 = data[offset + 4].to_u64()

    if padding_length + 1 > packet_length:
        return Err("ssh_packet_read: padding exceeds packet")
    var payload_length: u64 = packet_length - padding_length - 1

    # Extract payload
    var payload: [u8] = []
    var i: u64 = 0
    while i < payload_length:
        payload.push(data[offset + 5 + i])
        i = i + 1

    Ok((SshPacket(payload: payload, sequence: 0), total))

# ============================================================================
# Packet Build (plaintext)
# ============================================================================

fn ssh_packet_build(payload: [u8], sequence: u32) -> [u8]:
    """Build an SSH packet from payload. No encryption/MAC.

    Padding: total of (4 + 1 + payload_len + padding_len) must be
    a multiple of 8 (minimum block size). Padding >= 4 bytes.
    """
    val block_size: u64 = 8
    val payload_len = payload.len()

    # Calculate minimum padding
    # packet_length = 1 + payload_len + padding_len
    # (4 + packet_length) must be a multiple of block_size
    # i.e. (5 + payload_len + padding_len) % block_size == 0
    var padding_len: u64 = block_size - ((5 + payload_len) % block_size)
    if padding_len < SSH_MIN_PADDING.to_u64():
        padding_len = padding_len + block_size

    val packet_length = 1 + payload_len + padding_len

    var buf: [u8] = []

    # 4-byte length (big-endian)
    ssh_put_u32(buf, packet_length.to_u32())

    # 1-byte padding_length
    buf.push(padding_len.to_u8())

    # Payload
    var i: u64 = 0
    while i < payload_len:
        buf.push(payload[i])
        i = i + 1

    # Zero-fill padding (deterministic — random_bytes may FAULT on baremetal)
    i = 0
    while i < padding_len:
        buf.push(0)
        i = i + 1

    buf

fn ssh_packet_build_encrypted(payload: [u8], sequence: u32, key: [u8], iv: [u8], mac_key: [u8]) -> [u8]:
    """Build encrypted SSH packet with AES-256-GCM.

    Delegates to SshCipher — this is a convenience stub.
    For real encrypted packets use SshCipher.encrypt_packet().
    """
    # Construct the plaintext packet first, then encrypt externally
    ssh_packet_build(payload, sequence)
