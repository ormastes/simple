    out = _append_byte(out, 0x73)
    out = _append_byte(out, 0x73)
    out = _append_byte(out, 0x68)
    out = _append_byte(out, 0x2E)
    out = _append_byte(out, 0x63)
    out = _append_byte(out, 0x6F)
    out = _append_byte(out, 0x6D)
    out

fn _push_none(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x04)
    out = _append_byte(out, 0x6E)
    out = _append_byte(out, 0x6F)
    out = _append_byte(out, 0x6E)
    out = _append_byte(out, 0x65)
    out

fn _push_empty_string(buf: [u8]) -> [u8]:
    _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x00)

fn _push_bool_false(buf: [u8]) -> [u8]:
    _append_byte(buf, 0)

fn _push_zero_u32(buf: [u8]) -> [u8]:
    _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x00)

fn _push_host_key_algorithms(buf: [u8], host_keys: HostKeySet) -> [u8]:
    if host_keys.ed25519_seed != nil:
        if host_keys.rsa_pkcs8 != nil:
            if host_keys.ecdsa_p256_pkcs8 != nil:
                return _push_all_host_key_algorithms(buf)
            return _push_ed25519_rsa_pair(buf)
        if host_keys.ecdsa_p256_pkcs8 != nil:
            return _push_ed25519_ecdsa(buf)
        return _push_ssh_ed25519(buf)

    if host_keys.rsa_pkcs8 != nil:
        if host_keys.ecdsa_p256_pkcs8 != nil:
            return _push_rsa_pair_ecdsa(buf)
        return _push_rsa_sha2_pair(buf)

    if host_keys.ecdsa_p256_pkcs8 != nil:
        return _push_ecdsa_p256(buf)

    _push_ssh_ed25519(buf)

fn host_key_set_advertised_algorithms(host_keys: HostKeySet) -> text:
    """Return comma-separated list of host key algorithms the server can offer.

    Priority order: ssh-ed25519, rsa-sha2-256, rsa-sha2-512, ecdsa-sha2-nistp256.
    RSA algorithms are both listed when an RSA key is present (same key, two hash choices).
    """
    var algos: text = ""
    if host_keys.ed25519_seed != nil:
        algos = "ssh-ed25519"
    if host_keys.rsa_pkcs8 != nil:
        if algos.len() > 0:
            algos = algos + ",rsa-sha2-256,rsa-sha2-512"
        else:
            algos = "rsa-sha2-256,rsa-sha2-512"
    if host_keys.ecdsa_p256_pkcs8 != nil:
        if algos.len() > 0:
            algos = algos + ",ecdsa-sha2-nistp256"
        else:
            algos = "ecdsa-sha2-nistp256"
    if algos.len() == 0:
        algos = "ssh-ed25519"
    algos

fn host_key_algorithms_with_certificates(host_keys: HostKeySet, host_certs: HostCertificateSet) -> text:
    """Return host key algorithms, preferring configured OpenSSH certificates."""
    var algos: text = ""
    if host_certs.ssh_ed25519_cert != nil:
        algos = "ssh-ed25519-cert-v01@openssh.com"
    if host_keys.ed25519_seed != nil:
        algos = if algos.len() > 0: algos + ",ssh-ed25519" else: "ssh-ed25519"

    if host_certs.rsa_sha2_256_cert != nil:
        algos = if algos.len() > 0: algos + ",rsa-sha2-256-cert-v01@openssh.com" else: "rsa-sha2-256-cert-v01@openssh.com"
    if host_certs.rsa_sha2_512_cert != nil:
        algos = if algos.len() > 0: algos + ",rsa-sha2-512-cert-v01@openssh.com" else: "rsa-sha2-512-cert-v01@openssh.com"
    if host_keys.rsa_pkcs8 != nil:
        algos = if algos.len() > 0: algos + ",rsa-sha2-256,rsa-sha2-512" else: "rsa-sha2-256,rsa-sha2-512"

    if host_keys.ecdsa_p256_pkcs8 != nil:
        algos = if algos.len() > 0: algos + ",ecdsa-sha2-nistp256" else: "ecdsa-sha2-nistp256"

    if algos.len() == 0:
        algos = "ssh-ed25519"
    algos

fn _host_certificates_empty(host_certs: HostCertificateSet) -> bool:
    host_certs.ssh_ed25519_cert == nil and
    host_certs.rsa_sha2_256_cert == nil and
    host_certs.rsa_sha2_512_cert == nil

# ============================================================================
# Key Generation
# ============================================================================

fn ssh_kex_generate_private_key() -> [u8]:
    """Generate a 32-byte ephemeral Curve25519 private key."""
    val secret = random_bytes(32)
    _push_bytes([], secret)

fn ssh_kex_generate_keypair() -> ([u8], [u8]):
    """Generate a hosted-test-friendly Curve25519 keypair."""
    val private = _push_bytes([], random_bytes(32))
    (private, x25519_base(private))

fn ssh_kex_public_from_private(private: [u8]) -> [u8]:
    """Derive the Curve25519 public key from a private scalar."""
    if _is_handle_backed_private_key(private):
        return _push_bytes([], rt_dh_curve25519_public_key(_decode_handle_backed_private_key(private)))
    val stable_private = _push_bytes([], private)
    val runtime_public = rt_tls13_x25519_public_key(stable_private)
    val public = x25519_base(stable_private)
    if runtime_public.len() == 32:
        return _push_bytes([], runtime_public)
    if public.len() == 32:
        return _push_bytes([], public)
    []

fn ssh_kex_compute_shared(our_private: [u8], their_public: [u8]) -> [u8]:
    """Compute DH shared secret via X25519.

    Returns: 32-byte shared secret.
    """
    if _is_handle_backed_private_key(our_private):
        return _push_bytes([], rt_dh_curve25519_shared_secret(_decode_handle_backed_private_key(our_private), their_public))
    val stable_private = _push_bytes([], our_private)
    val stable_public = _push_bytes([], their_public)
    val shared = rt_tls13_x25519_shared_secret(stable_private, stable_public)
    val pure_shared = x25519(stable_private, stable_public)
    if shared.len() == 32:
        return _push_bytes([], shared)
    if pure_shared.len() == 32:
        return _push_bytes([], pure_shared)
    []

# ============================================================================
# Exchange Hash
# ============================================================================

fn ssh_kex_compute_exchange_hash(
    client_version: [u8],
    server_version: [u8],
    client_kexinit: [u8],
    server_kexinit: [u8],
    host_key_blob: [u8],
    client_public: [u8],
    server_public: [u8],
    shared_secret: [u8]
) -> [u8]:
    """Compute exchange hash H = SHA-256(V_C || V_S || I_C || I_S || K_S || Q_C || Q_S || K).

    Each field is encoded as an SSH string (uint32 length + data),
    except the shared secret K which is encoded as an SSH mpint.
    """
    var hash_input: [u8] = []
    # RFC 8731 says the X25519 output bytes are reinterpreted as a fixed-length
    # unsigned big-endian integer for SSH K, then encoded as an mpint. That is
    # a reinterpretation of the same byte string, not a byte reversal.
    val shared_secret_mpint = shared_secret

    # V_C: client version string (without CR LF)
    hash_input = rt_bytes_concat(hash_input, _concat_ssh_string_field(client_version))

    # V_S: server version string (without CR LF)
    hash_input = rt_bytes_concat(hash_input, _concat_ssh_string_field(server_version))

    # I_C: client KEXINIT payload (the full packet payload including msg type)
    hash_input = rt_bytes_concat(hash_input, _concat_ssh_string_field(client_kexinit))

    # I_S: server KEXINIT payload
    hash_input = rt_bytes_concat(hash_input, _concat_ssh_string_field(server_kexinit))

    # K_S: server host key blob
    hash_input = rt_bytes_concat(hash_input, _concat_ssh_string_field(host_key_blob))

    # Q_C: client ephemeral public key (as string, 32 bytes)
    hash_input = rt_bytes_concat(hash_input, _concat_ssh_string_field(client_public))

    # Q_S: server ephemeral public key (as string, 32 bytes)
    hash_input = rt_bytes_concat(hash_input, _concat_ssh_string_field(server_public))

    # K: shared secret (as mpint — big-endian with sign handling)
    hash_input = rt_bytes_concat(hash_input, _concat_mpint_field(shared_secret_mpint))
    serial_println("[ssh-kex] exchange hash input len={hash_input.len()}")
    serial_println("[ssh-kex] exchange hash input={_bytes_to_hex(hash_input)}")

    _sha256_stable(hash_input)

# ============================================================================
# Key Derivation (RFC 4253 Section 7.2)
# ============================================================================

fn _derive_key(shared_secret: [u8], exchange_hash: [u8], letter: u8, session_id: [u8], needed: u64) -> [u8]:
    """Derive a session key per RFC 4253 section 7.2.

    K1 = SHA-256(K || H || letter || session_id)
    K2 = SHA-256(K || H || K1)
    K3 = SHA-256(K || H || K1 || K2)
    ...
    Key = K1 || K2 || ... (truncated to needed bytes)

    K is encoded as mpint, H and session_id as raw bytes.
    """
    # Build the initial hash input: mpint(K) || H || letter || session_id
    var input: [u8] = []
    val shared_secret_mpint = shared_secret
    input = _push_mpint_bytes(input, shared_secret_mpint)
    input = _push_bytes(input, exchange_hash)
    input = _append_byte(input, letter)
    input = _push_bytes(input, session_id)

    val k1 = _sha256_stable(input)

    var key_material: [u8] = _push_bytes([], k1)

    # If we need more than 32 bytes, extend
    while key_material.len() < needed:
        # next = SHA-256(K || H || K1 || K2 || ...)
        var ext_input: [u8] = []
        ext_input = _push_mpint_bytes(ext_input, shared_secret_mpint)
        ext_input = _push_bytes(ext_input, exchange_hash)
        ext_input = _push_bytes(ext_input, key_material)

        val next = _sha256_stable(ext_input)
        key_material = _push_bytes(key_material, next)

    # Truncate to needed length
    var result: [u8] = []
    var i: u64 = 0
    while i < needed:
        result = _append_byte(result, _u8_at(key_material, i))
        i = i + 1
    result

fn ssh_derive_keys(shared_secret: [u8], exchange_hash: [u8], session_id: [u8]) -> SshSessionKeys:
    """Derive all session keys from shared secret per RFC 4253 section 7.2.

    Letters A-F correspond to:
      A = IV client->server         (12 bytes for GCM nonce)
      B = IV server->client         (12 bytes for GCM nonce)
      C = encryption key c->s       (32 bytes for AES-256)
      D = encryption key s->c       (32 bytes for AES-256)
      E = integrity key c->s        (32 bytes)
      F = integrity key s->c        (32 bytes)
    """
    val iv_c2s = _derive_key(shared_secret, exchange_hash, 0x41, session_id, 12)   # 'A'
    val iv_s2c = _derive_key(shared_secret, exchange_hash, 0x42, session_id, 12)   # 'B'
    val enc_key_c2s = _derive_key(shared_secret, exchange_hash, 0x43, session_id, 32) # 'C'
    val enc_key_s2c = _derive_key(shared_secret, exchange_hash, 0x44, session_id, 32) # 'D'
    val mac_key_c2s = _derive_key(shared_secret, exchange_hash, 0x45, session_id, 32) # 'E'
    val mac_key_s2c = _derive_key(shared_secret, exchange_hash, 0x46, session_id, 32) # 'F'

    SshSessionKeys(
        iv_c2s: iv_c2s,
        iv_s2c: iv_s2c,
        enc_key_c2s: enc_key_c2s,
        enc_key_s2c: enc_key_s2c,
        mac_key_c2s: mac_key_c2s,
        mac_key_s2c: mac_key_s2c
    )

# ============================================================================
# Host Key Blob Builders
# ============================================================================

fn ssh_build_ed25519_host_key_blob(public_key: [u8]) -> [u8]:
    """Build SSH host key blob for ssh-ed25519 (RFC 8709).

    Format: string "ssh-ed25519" + string public_key (32 bytes).
    """
    var blob = _push_ssh_ed25519([])
    blob = _push_string_32(blob, public_key)
    blob

fn ssh_build_rsa_host_key_blob(e_bytes: [u8], n_bytes: [u8]) -> [u8]:
    """Build SSH host key blob for ssh-rsa / rsa-sha2-256 / rsa-sha2-512.

    Format (RFC 4253 §6.6): string "ssh-rsa" + string e + string n.
    e and n are the big-endian public exponent and modulus respectively.
    """
    var blob: [u8] = []
    _push_ascii_text(blob, [0x73u8, 0x73, 0x68, 0x2D, 0x72, 0x73, 0x61])
    ssh_put_string(blob, e_bytes)
    ssh_put_string(blob, n_bytes)
    blob

fn ssh_build_ecdsa_p256_host_key_blob(q_bytes: [u8]) -> [u8]:
    """Build SSH host key blob for ecdsa-sha2-nistp256 (RFC 5656).

    Format: string "ecdsa-sha2-nistp256" + string "nistp256" + string Q.
    Q is the uncompressed EC point (0x04 || x || y, 65 bytes).
    """
    var blob: [u8] = []
    _push_ascii_text(blob, [0x65u8, 0x63, 0x64, 0x73, 0x61, 0x2D, 0x73, 0x68, 0x61, 0x32, 0x2D, 0x6E, 0x69, 0x73, 0x74, 0x70, 0x32, 0x35, 0x36])
    _push_ascii_text(blob, [0x6Eu8, 0x69, 0x73, 0x74, 0x70, 0x32, 0x35, 0x36])
    ssh_put_string(blob, q_bytes)
    blob

struct _DerTlv:
    value_offset: u64
    value_length: u64
    next_offset: u64

fn _read_der_tlv(data: [u8], offset: u64, expected_tag: u8) -> Result<_DerTlv, text>:
    if offset + 2 > data.len():
        return Err("der truncated")
    if data[offset] != expected_tag:
        return Err("der unexpected tag")
    val len0 = data[offset + 1]
    if (len0 & 0x80) == 0:
        val value_offset = offset + 2
        val value_length = len0.to_u64()
        val next_offset = value_offset + value_length
        if next_offset > data.len():
            return Err("der value past end")
        return Ok(_DerTlv(value_offset: value_offset, value_length: value_length, next_offset: next_offset))
    val count = (len0 & 0x7F).to_u64()
    if count == 0 or count > 4 or offset + 2 + count > data.len():
        return Err("der bad length")
    var value_length: u64 = 0
    var i: u64 = 0
    while i < count:
        value_length = (value_length << 8) | data[offset + 2 + i].to_u64()
        i = i + 1
    val value_offset = offset + 2 + count
    val next_offset = value_offset + value_length
    if next_offset > data.len():
        return Err("der value past end")
    Ok(_DerTlv(value_offset: value_offset, value_length: value_length, next_offset: next_offset))

fn _slice_bytes(data: [u8], start: u64, length: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < length and start + i < data.len():
        out.push(_u8_at(data, start + i))
        i = i + 1
    out

fn ecdsa_p256_public_point_from_pkcs8(pkcs8: [u8]) -> [u8]:
    """Extract 65-byte uncompressed public point Q from ECDSA P-256 PKCS#8."""
    val outer = _read_der_tlv(pkcs8, 0, 0x30)
    if outer.is_err():
        return []
    var pos = outer.unwrap().value_offset

    val version = _read_der_tlv(pkcs8, pos, 0x02)
    if version.is_err():
        return []
    pos = version.unwrap().next_offset

    val algorithm = _read_der_tlv(pkcs8, pos, 0x30)
    if algorithm.is_err():
        return []
    pos = algorithm.unwrap().next_offset

    val private_octets = _read_der_tlv(pkcs8, pos, 0x04)
    if private_octets.is_err():
        return []
    val ec_private = _slice_bytes(pkcs8, private_octets.unwrap().value_offset, private_octets.unwrap().value_length)
    if ec_private.len() == 0:
        return []

    val ec_seq = _read_der_tlv(ec_private, 0, 0x30)
    if ec_seq.is_err():
        return []
    var ec_pos = ec_seq.unwrap().value_offset

    val ec_version = _read_der_tlv(ec_private, ec_pos, 0x02)
    if ec_version.is_err():
        return []
    ec_pos = ec_version.unwrap().next_offset

    val ec_key = _read_der_tlv(ec_private, ec_pos, 0x04)
    if ec_key.is_err():
        return []
    ec_pos = ec_key.unwrap().next_offset

    while ec_pos < ec_private.len():
        val tag = ec_private[ec_pos]
        if tag == 0xA0:
            val parameters = _read_der_tlv(ec_private, ec_pos, 0xA0)
            if parameters.is_err():
                return []
            ec_pos = parameters.unwrap().next_offset
        elif tag == 0xA1:
            val public_key = _read_der_tlv(ec_private, ec_pos, 0xA1)
            if public_key.is_err():
                return []
            val bit_string = _read_der_tlv(ec_private, public_key.unwrap().value_offset, 0x03)
            if bit_string.is_err():
                return []
            val bit_bytes = _slice_bytes(ec_private, bit_string.unwrap().value_offset, bit_string.unwrap().value_length)
            if bit_bytes.len() != 66 or bit_bytes[0] != 0 or bit_bytes[1] != 0x04:
                return []
            return _slice_bytes(bit_bytes, 1, 65)
        else:
            return []
    []

# ============================================================================
# Multi-Algorithm Signing
# ============================================================================

fn ssh_sign_exchange_hash(algo: text, host_keys: HostKeySet, exchange_hash: [u8]) -> Result<[u8], text>:
    """Sign exchange_hash with the algorithm-appropriate host key.

    Returns the complete SSH signature blob:
      string <algo-name> + string <raw-signature-bytes>

    For ecdsa-sha2-nistp256 the inner raw-sig is the SSH wire-format
    mpint pair (mpint r + mpint s) wrapped as a string per RFC 5656 §3.

    Returns Err if the required host key is absent or signing produces
    an empty result (indicating a key/runtime error).
    """
    if algo == "ssh-ed25519" or algo == "ssh-ed25519-cert-v01@openssh.com":
        if host_keys.ed25519_seed == nil:
            return Err("ssh-ed25519: no ed25519 seed configured")
        val seed = _push_bytes([], host_keys.ed25519_seed)
        val stable_hash = _push_bytes([], exchange_hash)
        val pubkey = ed25519_keypair_from_seed(seed).1
        if pubkey.len() != 32:
            return Err("ssh-ed25519: keypair derive failed")
        val sig_raw = ed25519_sign(seed, pubkey, stable_hash)
        if sig_raw.len() != 64:
            return Err("ssh-ed25519: signing failed")
        var blob = _push_ssh_ed25519([])
        blob = _push_string_64(blob, sig_raw)
        return Ok(blob)

    elif algo == "rsa-sha2-256" or algo == "rsa-sha2-256-cert-v01@openssh.com":
        if host_keys.rsa_pkcs8 == nil:
            return Err("rsa-sha2-256: no RSA key configured")
        val sig_raw = rsa_sha256_sign_with_backend(host_keys.rsa_pkcs8, exchange_hash, RsaSignBackend.Auto)
        if sig_raw.len() == 0:
            return Err("rsa-sha2-256: signing failed")
        var blob: [u8] = []
        _push_ascii_text(blob, [0x72u8, 0x73, 0x61, 0x2D, 0x73, 0x68, 0x61, 0x32, 0x2D, 0x32, 0x35, 0x36])
        ssh_put_string(blob, sig_raw)
        return Ok(blob)

    elif algo == "rsa-sha2-512" or algo == "rsa-sha2-512-cert-v01@openssh.com":
        if host_keys.rsa_pkcs8 == nil:
            return Err("rsa-sha2-512: no RSA key configured")
        val sig_raw = rsa_sha512_sign_with_backend(host_keys.rsa_pkcs8, exchange_hash, RsaSignBackend.Auto)
        if sig_raw.len() == 0:
            return Err("rsa-sha2-512: signing failed")
        var blob: [u8] = []
        _push_ascii_text(blob, [0x72u8, 0x73, 0x61, 0x2D, 0x73, 0x68, 0x61, 0x32, 0x2D, 0x35, 0x31, 0x32])
        ssh_put_string(blob, sig_raw)
        return Ok(blob)

    elif algo == "ecdsa-sha2-nistp256":
        if host_keys.ecdsa_p256_pkcs8 == nil:
            return Err("ecdsa-sha2-nistp256: no ECDSA key configured")
        val sig_fixed = ecdsa_p256_sign_fixed(host_keys.ecdsa_p256_pkcs8, exchange_hash)
        if sig_fixed.len() == 0:
            return Err("ecdsa-sha2-nistp256: signing failed")
        val mpint_pair = fixed64_to_ssh_mpint_pair(sig_fixed)
        if mpint_pair.len() == 0:
            return Err("ecdsa-sha2-nistp256: mpint conversion failed")
        var blob: [u8] = []
        _push_ascii_text(blob, [0x65u8, 0x63, 0x64, 0x73, 0x61, 0x2D, 0x73, 0x68, 0x61, 0x32, 0x2D, 0x6E, 0x69, 0x73, 0x74, 0x70, 0x32, 0x35, 0x36])
        ssh_put_string(blob, mpint_pair)
        return Ok(blob)

    else:
        Err("unsupported host key algorithm: {algo}")

# ============================================================================
# KEXINIT Builder (host-key-set aware)
# ============================================================================

fn ssh_build_kexinit_for_host_keys(host_keys: HostKeySet) -> [u8]:
    ssh_build_kexinit_for_host_keys_and_certs(host_keys, HostCertificateSet(
        ssh_ed25519_cert: nil,
        rsa_sha2_256_cert: nil,
        rsa_sha2_512_cert: nil
    ))

fn ssh_build_kexinit_for_host_keys_and_certs(host_keys: HostKeySet, host_certs: HostCertificateSet) -> [u8]:
    """Build SSH_MSG_KEXINIT advertising host key algorithms present in host_keys.

    Wire format is identical to ssh_build_kexinit() in ssh_transport.spl
    except the server_host_key_algorithms field reflects the actual key set.
    Other algorithms are fixed: curve25519-sha256,ext-info-s,kex-strict-s-v00@openssh.com
    KEX, aes256-gcm then aes128-gcm, no MAC, no compression.
    """
    if _host_certificates_empty(host_certs):
        var buf: [u8] = []

        buf = _append_byte(buf, 20)

        var i: u64 = 0
        while i < 16:
            buf = _append_byte(buf, 0)
            i = i + 1

        buf = _push_server_kex_algorithms(buf)
        buf = _push_host_key_algorithms(buf, host_keys)
        buf = _push_gcm_cipher_pair(buf)
        buf = _push_gcm_cipher_pair(buf)
        buf = _push_none(buf)
        buf = _push_none(buf)
        buf = _push_none(buf)
        buf = _push_none(buf)

        # The first empty language list appends correctly through the normal
        # helper path. The remaining zero-only tail bytes are appended from a
        # stable zero buffer because literal/byte-at-a-time growth has proven
        # unreliable on the baremetal live lane.
        buf = _push_empty_string(buf)
        buf = rt_bytes_concat(buf, _slice_bytes(_zeroed_32_bytes(), 0, 9))
        return buf

    var buf: [u8] = []

    # SSH_MSG_KEXINIT = 20
    buf = _append_byte(buf, 20)

    # 16-byte cookie (zeros)
    var i: u64 = 0
    while i < 16:
        buf = _append_byte(buf, 0)
        i = i + 1

    ssh_put_text(buf, "curve25519-sha256,ext-info-s,kex-strict-s-v00@openssh.com")
    ssh_put_text(buf, host_key_algorithms_with_certificates(host_keys, host_certs))
    ssh_put_text(buf, "aes128-gcm@openssh.com")
    ssh_put_text(buf, "aes128-gcm@openssh.com")
    ssh_put_text(buf, "hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,none")
    ssh_put_text(buf, "hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,none")
    ssh_put_text(buf, "none")
    ssh_put_text(buf, "none")
    ssh_put_text(buf, "")
    ssh_put_text(buf, "")
    ssh_put_bool(buf, false)
    ssh_put_u32(buf, 0)

    buf

# ============================================================================
# KEX Message Builders
# ============================================================================

fn ssh_build_kex_ecdh_reply(host_key_blob: [u8], server_public: [u8], signature: [u8]) -> [u8]:
    """Build SSH_MSG_KEX_ECDH_REPLY payload.

    Fields:
      byte      SSH_MSG_KEX_ECDH_REPLY (31)
      string    K_S (server host key blob)
      string    Q_S (server ephemeral public key)
      string    signature of H
    """
    var buf: [u8] = []
    buf.push(SSH_MSG_KEX_ECDH_REPLY)
    buf = _push_string_bytes(buf, host_key_blob)
    buf = _push_string_32(buf, server_public)
    buf = _push_string_bytes(buf, signature)
    buf

fn ssh_parse_kex_ecdh_init(data: [u8]) -> Result<[u8], text>:
    """Parse SSH_MSG_KEX_ECDH_INIT. Returns client's ephemeral public key Q_C."""
    if data.len() < 2:
        return Err("KEX_ECDH_INIT too short")
    if _u8_at(data, 0) != SSH_MSG_KEX_ECDH_INIT:
        return Err("not a KEX_ECDH_INIT message")

    val r = ssh_get_string(data, 1)
    if r.is_ok():
        val pair = r.unwrap()
        Ok(pair.data)
    else:
        Err("KEX_ECDH_INIT: bad client public key")

fn ssh_build_newkeys() -> [u8]:
    """Build SSH_MSG_NEWKEYS payload (just the message type byte)."""
    var buf: [u8] = []
    buf.push(21)   # SSH_MSG_NEWKEYS
    buf
