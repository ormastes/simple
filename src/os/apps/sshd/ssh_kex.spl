fn _push_gcm_cipher_pair(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x16)
    out = _append_byte(out, 0x61)
    out = _append_byte(out, 0x65)
    out = _append_byte(out, 0x73)
    out = _append_byte(out, 0x31)
