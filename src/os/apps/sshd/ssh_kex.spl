#![allow(unnamed_duplicate_typed_args)]
# SSH Key Exchange — Curve25519-SHA256 (RFC 8731)
#
# Implements the curve25519-sha256 key exchange method.
# Uses the pure Simple Curve25519 and SHA-256 implementations.
#
# Exchange hash H is computed over:
#   string  V_C   (client version string, without CR LF)
#   string  V_S   (server version string, without CR LF)
#   string  I_C   (client KEXINIT payload)
#   string  I_S   (server KEXINIT payload)
#   string  K_S   (server host key blob)
#   string  Q_C   (client ephemeral public key, 32 bytes)
#   string  Q_S   (server ephemeral public key, 32 bytes)
#   mpint   K     (shared secret)
#
# Session keys are derived per RFC 4253 section 7.2.

use os.crypto.curve25519.{x25519, x25519_base}
use os.crypto.sha256.{sha256}
use os.crypto.random.{random_bytes}
use os.crypto.ed25519.{ed25519_keypair_from_seed, ed25519_sign}
use os.crypto.rsa.{rsa_sha256_sign, rsa_sha512_sign}
use os.crypto.ecdsa_p256.{ecdsa_p256_sign_fixed, fixed64_to_ssh_mpint_pair}
use os.apps.sshd.ssh_packet.{ssh_put_u32, ssh_put_string, ssh_put_text, ssh_put_bool, ssh_put_mpint, ssh_get_string, SshStringResult}

extern fn rt_push_byte(arr: [u8], byte_val: i64) -> [u8]

# ============================================================================
# Constants
# ============================================================================

val SSH_MSG_KEX_ECDH_INIT: u8 = 30
val SSH_MSG_KEX_ECDH_REPLY: u8 = 31

# ============================================================================
# Types
# ============================================================================

struct SshKexState:
    """State for Curve25519 key exchange."""
    server_private: [u8]    # 32-byte ephemeral private key
    server_public: [u8]     # 32-byte ephemeral public key
    client_public: [u8]     # Client's ephemeral public key
    shared_secret: [u8]     # 32-byte DH shared secret
    exchange_hash: [u8]     # H = SHA-256(...)
    session_id: [u8]        # First exchange hash (stays fixed)

struct SshSessionKeys:
    """Derived session keys for encryption and MAC."""
    iv_c2s: [u8]            # Initial IV, client-to-server (12 bytes for GCM)
    iv_s2c: [u8]            # Initial IV, server-to-client
    enc_key_c2s: [u8]       # Encryption key, client-to-server (32 bytes)
    enc_key_s2c: [u8]       # Encryption key, server-to-client
    mac_key_c2s: [u8]       # Integrity key, client-to-server (32 bytes)
    mac_key_s2c: [u8]       # Integrity key, server-to-client

struct HostKeySet:
    """Server host key material for all supported host key algorithms.

    Each field holds an optional private key in the format expected by the
    corresponding signing primitive:
      ed25519_seed       — 32-byte Ed25519 private seed (RFC 8709)
      rsa_pkcs8          — PKCS#8 v1 DER RSA private key (RFC 8332)
      ecdsa_p256_pkcs8   — PKCS#8 v1 DER ECDSA P-256 private key (RFC 5656)

    Algorithms are advertised in priority order by advertised_algorithms().
    """
    ed25519_seed: [u8]?
    rsa_pkcs8: [u8]?
    ecdsa_p256_pkcs8: [u8]?

fn _push_ascii_text(buf: [u8], bytes: [u8]):
    """Append a fixed ASCII SSH string without relying on text-to-bytes externs."""
    ssh_put_string(buf, bytes)

fn _push_u32_literal(buf: [u8], b0: u8, b1: u8, b2: u8, b3: u8) -> [u8]:
    var out = buf
    out = rt_push_byte(out, b0.to_i64())
    out = rt_push_byte(out, b1.to_i64())
    out = rt_push_byte(out, b2.to_i64())
    out = rt_push_byte(out, b3.to_i64())
    out

fn _push_curve25519_sha256(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x11)
    out = rt_push_byte(out, 0x63)
    out = rt_push_byte(out, 0x75)
    out = rt_push_byte(out, 0x72)
    out = rt_push_byte(out, 0x76)
    out = rt_push_byte(out, 0x65)
    out = rt_push_byte(out, 0x32)
    out = rt_push_byte(out, 0x35)
    out = rt_push_byte(out, 0x35)
    out = rt_push_byte(out, 0x31)
    out = rt_push_byte(out, 0x39)
    out = rt_push_byte(out, 0x2D)
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x68)
    out = rt_push_byte(out, 0x61)
    out = rt_push_byte(out, 0x32)
    out = rt_push_byte(out, 0x35)
    out = rt_push_byte(out, 0x36)
    out

fn _push_ssh_ed25519(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x0B)
    out = _push_ssh_ed25519_bytes(out)
    out

fn _push_rsa_sha2_pair(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x19)
    out = _push_rsa_sha2_pair_bytes(out)
    out

fn _push_ecdsa_p256(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x13)
    out = _push_ecdsa_p256_bytes(out)
    out

fn _push_ed25519_rsa_pair(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x25)
    out = _push_ssh_ed25519_bytes(out)
    out = rt_push_byte(out, 0x2C)
    out = _push_rsa_sha2_pair_bytes(out)
    out

fn _push_ed25519_ecdsa(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x1F)
    out = _push_ssh_ed25519_bytes(out)
    out = rt_push_byte(out, 0x2C)
    out = _push_ecdsa_p256_bytes(out)
    out

fn _push_rsa_pair_ecdsa(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x2D)
    out = _push_rsa_sha2_pair_bytes(out)
    out = rt_push_byte(out, 0x2C)
    out = _push_ecdsa_p256_bytes(out)
    out

fn _push_all_host_key_algorithms(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x39)
    out = _push_ssh_ed25519_bytes(out)
    out = rt_push_byte(out, 0x2C)
    out = _push_rsa_sha2_pair_bytes(out)
    out = rt_push_byte(out, 0x2C)
    out = _push_ecdsa_p256_bytes(out)
    out

fn _push_ssh_ed25519_bytes(buf: [u8]) -> [u8]:
    var out = buf
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x68)
    out = rt_push_byte(out, 0x2D)
    out = rt_push_byte(out, 0x65)
    out = rt_push_byte(out, 0x64)
    out = rt_push_byte(out, 0x32)
    out = rt_push_byte(out, 0x35)
    out = rt_push_byte(out, 0x35)
    out = rt_push_byte(out, 0x31)
    out = rt_push_byte(out, 0x39)
    out

fn _push_rsa_sha2_pair_bytes(buf: [u8]) -> [u8]:
    var out = buf
    out = rt_push_byte(out, 0x72)
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x61)
    out = rt_push_byte(out, 0x2D)
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x68)
    out = rt_push_byte(out, 0x61)
    out = rt_push_byte(out, 0x32)
    out = rt_push_byte(out, 0x2D)
    out = rt_push_byte(out, 0x32)
    out = rt_push_byte(out, 0x35)
    out = rt_push_byte(out, 0x36)
    out = rt_push_byte(out, 0x2C)
    out = rt_push_byte(out, 0x72)
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x61)
    out = rt_push_byte(out, 0x2D)
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x68)
    out = rt_push_byte(out, 0x61)
    out = rt_push_byte(out, 0x32)
    out = rt_push_byte(out, 0x2D)
    out = rt_push_byte(out, 0x35)
    out = rt_push_byte(out, 0x31)
    out = rt_push_byte(out, 0x32)
    out

fn _push_ecdsa_p256_bytes(buf: [u8]) -> [u8]:
    var out = buf
    out = rt_push_byte(out, 0x65)
    out = rt_push_byte(out, 0x63)
    out = rt_push_byte(out, 0x64)
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x61)
    out = rt_push_byte(out, 0x2D)
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x68)
    out = rt_push_byte(out, 0x61)
    out = rt_push_byte(out, 0x32)
    out = rt_push_byte(out, 0x2D)
    out = rt_push_byte(out, 0x6E)
    out = rt_push_byte(out, 0x69)
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x74)
    out = rt_push_byte(out, 0x70)
    out = rt_push_byte(out, 0x32)
    out = rt_push_byte(out, 0x35)
    out = rt_push_byte(out, 0x36)
    out

fn _push_aes256_gcm_openssh(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x16)
    out = rt_push_byte(out, 0x61)
    out = rt_push_byte(out, 0x65)
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x32)
    out = rt_push_byte(out, 0x35)
    out = rt_push_byte(out, 0x36)
    out = rt_push_byte(out, 0x2D)
    out = rt_push_byte(out, 0x67)
    out = rt_push_byte(out, 0x63)
    out = rt_push_byte(out, 0x6D)
    out = rt_push_byte(out, 0x40)
    out = rt_push_byte(out, 0x6F)
    out = rt_push_byte(out, 0x70)
    out = rt_push_byte(out, 0x65)
    out = rt_push_byte(out, 0x6E)
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x73)
    out = rt_push_byte(out, 0x68)
    out = rt_push_byte(out, 0x2E)
    out = rt_push_byte(out, 0x63)
    out = rt_push_byte(out, 0x6F)
    out = rt_push_byte(out, 0x6D)
    out

fn _push_none(buf: [u8]) -> [u8]:
    var out = _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x04)
    out = rt_push_byte(out, 0x6E)
    out = rt_push_byte(out, 0x6F)
    out = rt_push_byte(out, 0x6E)
    out = rt_push_byte(out, 0x65)
    out

fn _push_empty_string(buf: [u8]) -> [u8]:
    _push_u32_literal(buf, 0x00, 0x00, 0x00, 0x00)

fn host_key_set_advertised_algorithms(host_keys: HostKeySet) -> text:
    """Return comma-separated list of host key algorithms the server can offer.

    Priority order: ssh-ed25519, rsa-sha2-256, rsa-sha2-512, ecdsa-sha2-nistp256.
    RSA algorithms are both listed when an RSA key is present (same key, two hash choices).
    """
    var algos: text = ""
    if host_keys.ed25519_seed != nil:
        algos = "ssh-ed25519"
    if host_keys.rsa_pkcs8 != nil:
        if algos.len() > 0:
            algos = algos + ",rsa-sha2-256,rsa-sha2-512"
        else:
            algos = "rsa-sha2-256,rsa-sha2-512"
    if host_keys.ecdsa_p256_pkcs8 != nil:
        if algos.len() > 0:
            algos = algos + ",ecdsa-sha2-nistp256"
        else:
            algos = "ecdsa-sha2-nistp256"
    if algos.len() == 0:
        algos = "ssh-ed25519"
    algos

# ============================================================================
# Key Generation
# ============================================================================

fn ssh_kex_generate_keypair() -> ([u8], [u8]):
    """Generate ephemeral Curve25519 keypair.

    Returns: (private_key, public_key) each 32 bytes.
    """
    val private = random_bytes(32)
    val public = x25519_base(private)
    (private, public)

fn ssh_kex_compute_shared(our_private: [u8], their_public: [u8]) -> [u8]:
    """Compute DH shared secret via X25519.

    Returns: 32-byte shared secret.
    """
    x25519(our_private, their_public)

# ============================================================================
# Exchange Hash
# ============================================================================

fn ssh_kex_compute_exchange_hash(
    client_version: text,
    server_version: text,
    client_kexinit: [u8],
    server_kexinit: [u8],
    host_key_blob: [u8],
    client_public: [u8],
    server_public: [u8],
    shared_secret: [u8]
) -> [u8]:
    """Compute exchange hash H = SHA-256(V_C || V_S || I_C || I_S || K_S || Q_C || Q_S || K).

    Each field is encoded as an SSH string (uint32 length + data),
    except the shared secret K which is encoded as an SSH mpint.
    """
    var hash_input: [u8] = []

    # V_C: client version string (without CR LF)
    ssh_put_text(hash_input, client_version)

    # V_S: server version string (without CR LF)
    ssh_put_text(hash_input, server_version)

    # I_C: client KEXINIT payload (the full packet payload including msg type)
    ssh_put_string(hash_input, client_kexinit)

    # I_S: server KEXINIT payload
    ssh_put_string(hash_input, server_kexinit)

    # K_S: server host key blob
    ssh_put_string(hash_input, host_key_blob)

    # Q_C: client ephemeral public key (as string, 32 bytes)
    ssh_put_string(hash_input, client_public)

    # Q_S: server ephemeral public key (as string, 32 bytes)
    ssh_put_string(hash_input, server_public)

    # K: shared secret (as mpint — big-endian with sign handling)
    ssh_put_mpint(hash_input, shared_secret)

    sha256(hash_input)

# ============================================================================
# Key Derivation (RFC 4253 Section 7.2)
# ============================================================================

fn _derive_key(shared_secret: [u8], exchange_hash: [u8], letter: u8, session_id: [u8], needed: u64) -> [u8]:
    """Derive a session key per RFC 4253 section 7.2.

    K1 = SHA-256(K || H || letter || session_id)
    K2 = SHA-256(K || H || K1)
    K3 = SHA-256(K || H || K1 || K2)
    ...
    Key = K1 || K2 || ... (truncated to needed bytes)

    K is encoded as mpint, H and session_id as raw bytes.
    """
    # Build the initial hash input: mpint(K) || H || letter || session_id
    var input: [u8] = []
    ssh_put_mpint(input, shared_secret)

    var i: u64 = 0
    while i < exchange_hash.len():
        input.push(exchange_hash[i])
        i = i + 1

    input.push(letter)

    i = 0
    while i < session_id.len():
        input.push(session_id[i])
        i = i + 1

    val k1 = sha256(input)

    var key_material: [u8] = []
    i = 0
    while i < k1.len():
        key_material.push(k1[i])
        i = i + 1

    # If we need more than 32 bytes, extend
    var prev = k1
    while key_material.len() < needed:
        # next = SHA-256(K || H || K1 || K2 || ...)
        var ext_input: [u8] = []
        ssh_put_mpint(ext_input, shared_secret)

        i = 0
        while i < exchange_hash.len():
            ext_input.push(exchange_hash[i])
            i = i + 1

        i = 0
        while i < key_material.len():
            ext_input.push(key_material[i])
            i = i + 1

        val next = sha256(ext_input)
        i = 0
        while i < next.len():
            key_material.push(next[i])
            i = i + 1
        prev = next

    # Truncate to needed length
    var result: [u8] = []
    i = 0
    while i < needed:
        result.push(key_material[i])
        i = i + 1
    result

fn ssh_derive_keys(shared_secret: [u8], exchange_hash: [u8], session_id: [u8]) -> SshSessionKeys:
    """Derive all session keys from shared secret per RFC 4253 section 7.2.

    Letters A-F correspond to:
      A = IV client->server         (12 bytes for GCM nonce)
      B = IV server->client         (12 bytes for GCM nonce)
      C = encryption key c->s       (32 bytes for AES-256)
      D = encryption key s->c       (32 bytes for AES-256)
      E = integrity key c->s        (32 bytes)
      F = integrity key s->c        (32 bytes)
    """
    val iv_c2s = _derive_key(shared_secret, exchange_hash, 0x41, session_id, 12)   # 'A'
    val iv_s2c = _derive_key(shared_secret, exchange_hash, 0x42, session_id, 12)   # 'B'
    val enc_key_c2s = _derive_key(shared_secret, exchange_hash, 0x43, session_id, 32) # 'C'
    val enc_key_s2c = _derive_key(shared_secret, exchange_hash, 0x44, session_id, 32) # 'D'
    val mac_key_c2s = _derive_key(shared_secret, exchange_hash, 0x45, session_id, 32) # 'E'
    val mac_key_s2c = _derive_key(shared_secret, exchange_hash, 0x46, session_id, 32) # 'F'

    SshSessionKeys(
        iv_c2s: iv_c2s,
        iv_s2c: iv_s2c,
        enc_key_c2s: enc_key_c2s,
        enc_key_s2c: enc_key_s2c,
        mac_key_c2s: mac_key_c2s,
        mac_key_s2c: mac_key_s2c
    )

# ============================================================================
# Host Key Blob Builders
# ============================================================================

fn ssh_build_ed25519_host_key_blob(public_key: [u8]) -> [u8]:
    """Build SSH host key blob for ssh-ed25519 (RFC 8709).

    Format: string "ssh-ed25519" + string public_key (32 bytes).
    """
    var blob: [u8] = []
    _push_ascii_text(blob, [0x73u8, 0x73, 0x68, 0x2D, 0x65, 0x64, 0x32, 0x35, 0x35, 0x31, 0x39])
    ssh_put_string(blob, public_key)
    blob

fn ssh_build_rsa_host_key_blob(e_bytes: [u8], n_bytes: [u8]) -> [u8]:
    """Build SSH host key blob for ssh-rsa / rsa-sha2-256 / rsa-sha2-512.

    Format (RFC 4253 §6.6): string "ssh-rsa" + string e + string n.
    e and n are the big-endian public exponent and modulus respectively.
    """
    var blob: [u8] = []
    _push_ascii_text(blob, [0x73u8, 0x73, 0x68, 0x2D, 0x72, 0x73, 0x61])
    ssh_put_string(blob, e_bytes)
    ssh_put_string(blob, n_bytes)
    blob

fn ssh_build_ecdsa_p256_host_key_blob(q_bytes: [u8]) -> [u8]:
    """Build SSH host key blob for ecdsa-sha2-nistp256 (RFC 5656).

    Format: string "ecdsa-sha2-nistp256" + string "nistp256" + string Q.
    Q is the uncompressed EC point (0x04 || x || y, 65 bytes).
    """
    var blob: [u8] = []
    _push_ascii_text(blob, [0x65u8, 0x63, 0x64, 0x73, 0x61, 0x2D, 0x73, 0x68, 0x61, 0x32, 0x2D, 0x6E, 0x69, 0x73, 0x74, 0x70, 0x32, 0x35, 0x36])
    _push_ascii_text(blob, [0x6Eu8, 0x69, 0x73, 0x74, 0x70, 0x32, 0x35, 0x36])
    ssh_put_string(blob, q_bytes)
    blob

# ============================================================================
# Multi-Algorithm Signing
# ============================================================================

fn ssh_sign_exchange_hash(algo: text, host_keys: HostKeySet, exchange_hash: [u8]) -> Result<[u8], text>:
    """Sign exchange_hash with the algorithm-appropriate host key.

    Returns the complete SSH signature blob:
      string <algo-name> + string <raw-signature-bytes>

    For ecdsa-sha2-nistp256 the inner raw-sig is the SSH wire-format
    mpint pair (mpint r + mpint s) wrapped as a string per RFC 5656 §3.

    Returns Err if the required host key is absent or signing produces
    an empty result (indicating a key/runtime error).
    """
    if algo == "ssh-ed25519":
        if host_keys.ed25519_seed == nil:
            return Err("ssh-ed25519: no ed25519 seed configured")
        val seed = host_keys.ed25519_seed
        val keypair = ed25519_keypair_from_seed(seed)
        val pubkey = keypair.1
        val sig_raw = ed25519_sign(seed, pubkey, exchange_hash)
        if sig_raw.len() == 0:
            return Err("ssh-ed25519: signing failed")
        var blob: [u8] = []
        _push_ascii_text(blob, [0x73u8, 0x73, 0x68, 0x2D, 0x65, 0x64, 0x32, 0x35, 0x35, 0x31, 0x39])
        ssh_put_string(blob, sig_raw)
        return Ok(blob)

    elif algo == "rsa-sha2-256":
        if host_keys.rsa_pkcs8 == nil:
            return Err("rsa-sha2-256: no RSA key configured")
        val sig_raw = rsa_sha256_sign(host_keys.rsa_pkcs8, exchange_hash)
        if sig_raw.len() == 0:
            return Err("rsa-sha2-256: signing failed")
        var blob: [u8] = []
        _push_ascii_text(blob, [0x72u8, 0x73, 0x61, 0x2D, 0x73, 0x68, 0x61, 0x32, 0x2D, 0x32, 0x35, 0x36])
        ssh_put_string(blob, sig_raw)
        return Ok(blob)

    elif algo == "rsa-sha2-512":
        if host_keys.rsa_pkcs8 == nil:
            return Err("rsa-sha2-512: no RSA key configured")
        val sig_raw = rsa_sha512_sign(host_keys.rsa_pkcs8, exchange_hash)
        if sig_raw.len() == 0:
            return Err("rsa-sha2-512: signing failed")
        var blob: [u8] = []
        _push_ascii_text(blob, [0x72u8, 0x73, 0x61, 0x2D, 0x73, 0x68, 0x61, 0x32, 0x2D, 0x35, 0x31, 0x32])
        ssh_put_string(blob, sig_raw)
        return Ok(blob)

    elif algo == "ecdsa-sha2-nistp256":
        if host_keys.ecdsa_p256_pkcs8 == nil:
            return Err("ecdsa-sha2-nistp256: no ECDSA key configured")
        val sig_fixed = ecdsa_p256_sign_fixed(host_keys.ecdsa_p256_pkcs8, exchange_hash)
        if sig_fixed.len() == 0:
            return Err("ecdsa-sha2-nistp256: signing failed")
        val mpint_pair = fixed64_to_ssh_mpint_pair(sig_fixed)
        if mpint_pair.len() == 0:
            return Err("ecdsa-sha2-nistp256: mpint conversion failed")
        var blob: [u8] = []
        _push_ascii_text(blob, [0x65u8, 0x63, 0x64, 0x73, 0x61, 0x2D, 0x73, 0x68, 0x61, 0x32, 0x2D, 0x6E, 0x69, 0x73, 0x74, 0x70, 0x32, 0x35, 0x36])
        ssh_put_string(blob, mpint_pair)
        return Ok(blob)

    else:
        Err("unsupported host key algorithm: {algo}")

# ============================================================================
# KEXINIT Builder (host-key-set aware)
# ============================================================================

fn ssh_build_kexinit_for_host_keys(host_keys: HostKeySet) -> [u8]:
    """Build SSH_MSG_KEXINIT advertising host key algorithms present in host_keys.

    Wire format is identical to ssh_build_kexinit() in ssh_transport.spl
    except the server_host_key_algorithms field reflects the actual key set.
    Other algorithms are fixed: curve25519-sha256 KEX, aes256-gcm cipher, no MAC, no compression.
    """
    var buf: [u8] = []

    # SSH_MSG_KEXINIT = 20
    buf = rt_push_byte(buf, 20)

    # 16-byte cookie (zeros)
    var i: u64 = 0
    while i < 16:
        buf = rt_push_byte(buf, 0)
        i = i + 1

    buf = _push_curve25519_sha256(buf)
    if host_keys.ed25519_seed != nil:
        if host_keys.rsa_pkcs8 != nil and host_keys.ecdsa_p256_pkcs8 != nil:
            buf = _push_all_host_key_algorithms(buf)
        elif host_keys.rsa_pkcs8 != nil:
            buf = _push_ed25519_rsa_pair(buf)
        elif host_keys.ecdsa_p256_pkcs8 != nil:
            buf = _push_ed25519_ecdsa(buf)
        else:
            buf = _push_ssh_ed25519(buf)
    elif host_keys.rsa_pkcs8 != nil:
        if host_keys.ecdsa_p256_pkcs8 != nil:
            buf = _push_rsa_pair_ecdsa(buf)
        else:
            buf = _push_rsa_sha2_pair(buf)
    elif host_keys.ecdsa_p256_pkcs8 != nil:
        buf = _push_ecdsa_p256(buf)
    else:
        buf = _push_ssh_ed25519(buf)

    buf = _push_aes256_gcm_openssh(buf)
    buf = _push_aes256_gcm_openssh(buf)
    buf = _push_none(buf)
    buf = _push_none(buf)
    buf = _push_none(buf)
    buf = _push_none(buf)
    buf = _push_empty_string(buf)
    buf = _push_empty_string(buf)

    # first_kex_packet_follows = false
    ssh_put_bool(buf, false)

    # reserved uint32 = 0
    ssh_put_u32(buf, 0)

    buf

# ============================================================================
# KEX Message Builders
# ============================================================================

fn ssh_build_kex_ecdh_reply(host_key_blob: [u8], server_public: [u8], signature: [u8]) -> [u8]:
    """Build SSH_MSG_KEX_ECDH_REPLY payload.

    Fields:
      byte      SSH_MSG_KEX_ECDH_REPLY (31)
      string    K_S (server host key blob)
      string    Q_S (server ephemeral public key)
      string    signature of H
    """
    var buf: [u8] = []
    buf.push(SSH_MSG_KEX_ECDH_REPLY)
    ssh_put_string(buf, host_key_blob)
    ssh_put_string(buf, server_public)
    ssh_put_string(buf, signature)
    buf

fn ssh_parse_kex_ecdh_init(data: [u8]) -> Result<[u8], text>:
    """Parse SSH_MSG_KEX_ECDH_INIT. Returns client's ephemeral public key Q_C."""
    if data.len() < 2:
        return Err("KEX_ECDH_INIT too short")
    if data[0] != SSH_MSG_KEX_ECDH_INIT:
        return Err("not a KEX_ECDH_INIT message")

    val r = ssh_get_string(data, 1)
    if r.is_ok():
        val pair = r.unwrap()
        Ok(pair.data)
    else:
        Err("KEX_ECDH_INIT: bad client public key")

fn ssh_build_newkeys() -> [u8]:
    """Build SSH_MSG_NEWKEYS payload (just the message type byte)."""
    var buf: [u8] = []
    buf.push(21)   # SSH_MSG_NEWKEYS
    buf
