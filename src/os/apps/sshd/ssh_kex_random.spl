#![allow(unnamed_duplicate_typed_args)]
# SSH Key Exchange — hosted/test random key generation helpers.

use os.crypto.random.{random_bytes}
use os.crypto.curve25519.{x25519_base}
use os.apps.sshd.ssh_kex_primitives.{_push_bytes}

fn ssh_kex_generate_private_key() -> [u8]:
    val secret = random_bytes(32)
    _push_bytes([], secret)

fn ssh_kex_generate_keypair() -> ([u8], [u8]):
    val private = _push_bytes([], random_bytes(32))
    (private, x25519_base(private))

export ssh_kex_generate_private_key, ssh_kex_generate_keypair
