#![allow(unnamed_duplicate_typed_args)]
# SSH Cipher Layer — live-safe AES-256-GCM only.

use os.apps.sshd.ssh_packet.{ssh_get_u32}
use os.apps.sshd.ssh_session_helpers.{_bytes_to_hex}
use os.crypto.aes128_gcm.{aes128_gcm_encrypt, aes128_gcm_decrypt, Aes128GcmResult}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_tls13_aes256_gcm_encrypt(key: [u8], nonce: [u8], plaintext: [u8], aad: [u8]) -> [u8]
extern fn rt_tls13_aes256_gcm_decrypt(key: [u8], nonce: [u8], ciphertext: [u8], aad: [u8], tag: [u8]) -> [u8]
extern fn rt_ssh_aes256_gcm_decrypt_packet(key: [u8], iv: [u8], seq: i64, packet: [u8]) -> [u8]
extern fn rt_ssh_aes256_gcm_decrypt_packet_payload_len(key: [u8], iv: [u8], seq: i64, packet: [u8]) -> i64
extern fn serial_println(msg: text)

val GCM_TAG_LEN: u64 = 16

class SshCipher:
    seq_c2s: u32
    seq_s2c: u32
    active: bool

impl SshCipher:

    static fn new() -> SshCipher:
        SshCipher(
            seq_c2s: 0,
            seq_s2c: 0,
            active: false
        )

    me activate(start_c2s_seq: u32, start_s2c_seq: u32):
        self.seq_c2s = start_c2s_seq
        self.seq_s2c = start_s2c_seq
        self.active = true

fn _u8_at(data: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(data, idx.to_i64()).to_u8()

fn _push_byte(arr: [u8], byte_val: u8) -> [u8]:
    var out = arr
    out.push(byte_val)
    out

fn _make_nonce(iv: [u8], seq: u32) -> [u8]:
    # RFC 5647 increments the AES-GCM invocation counter after each packet, so
    # encrypted packet sequence 0 uses the KDF IV unchanged.
    var carry: u64 = seq.to_u64()
    val s11 = (if iv.len() > 11: _u8_at(iv, 11).to_u64() else: 0) + (carry & 0xFF)
    val b11 = (s11 & 0xFF).to_u8()
    carry = (carry >> 8) + (s11 >> 8)
    val s10 = (if iv.len() > 10: _u8_at(iv, 10).to_u64() else: 0) + (carry & 0xFF)
    val b10 = (s10 & 0xFF).to_u8()
    carry = (carry >> 8) + (s10 >> 8)
    val s9 = (if iv.len() > 9: _u8_at(iv, 9).to_u64() else: 0) + (carry & 0xFF)
    val b9 = (s9 & 0xFF).to_u8()
    carry = (carry >> 8) + (s9 >> 8)
    val s8 = (if iv.len() > 8: _u8_at(iv, 8).to_u64() else: 0) + (carry & 0xFF)
    val b8 = (s8 & 0xFF).to_u8()
    carry = (carry >> 8) + (s8 >> 8)
    val s7 = (if iv.len() > 7: _u8_at(iv, 7).to_u64() else: 0) + (carry & 0xFF)
    val b7 = (s7 & 0xFF).to_u8()
    carry = (carry >> 8) + (s7 >> 8)
    val s6 = (if iv.len() > 6: _u8_at(iv, 6).to_u64() else: 0) + (carry & 0xFF)
    val b6 = (s6 & 0xFF).to_u8()
    carry = (carry >> 8) + (s6 >> 8)
    val s5 = (if iv.len() > 5: _u8_at(iv, 5).to_u64() else: 0) + (carry & 0xFF)
    val b5 = (s5 & 0xFF).to_u8()
    carry = (carry >> 8) + (s5 >> 8)
    val s4 = (if iv.len() > 4: _u8_at(iv, 4).to_u64() else: 0) + (carry & 0xFF)
    val b4 = (s4 & 0xFF).to_u8()

    var nonce: [u8] = []
    nonce.push(if iv.len() > 0: _u8_at(iv, 0) else: 0)
    nonce.push(if iv.len() > 1: _u8_at(iv, 1) else: 0)
    nonce.push(if iv.len() > 2: _u8_at(iv, 2) else: 0)
    nonce.push(if iv.len() > 3: _u8_at(iv, 3) else: 0)
    nonce.push(b4)
    nonce.push(b5)
    nonce.push(b6)
    nonce.push(b7)
    nonce.push(b8)
    nonce.push(b9)
    nonce.push(b10)
    nonce.push(b11)
    nonce

fn ssh_encrypt_packet_aes_gcm(payload: [u8], seq_s2c: u32, enc_key_s2c: [u8], iv_s2c: [u8]) -> [u8]:
    var padding_len: u64 = 4
    while ((1 + payload.len() + padding_len) % 16) != 0:
        padding_len = padding_len + 1
    val packet_length: u64 = 1 + payload.len() + padding_len
    var aad: [u8] = []
    aad = _push_byte(aad, ((packet_length >> 24) & 0xFF).to_u8())
    aad = _push_byte(aad, ((packet_length >> 16) & 0xFF).to_u8())
    aad = _push_byte(aad, ((packet_length >> 8) & 0xFF).to_u8())
    aad = _push_byte(aad, (packet_length & 0xFF).to_u8())

    var body: [u8] = []
    body = _push_byte(body, padding_len.to_u8())
    var i: u64 = 0
    while i < payload.len():
        body = _push_byte(body, _u8_at(payload, i))
        i = i + 1
    i = 0
    while i < padding_len:
        body = _push_byte(body, 0)
        i = i + 1

    val nonce = _make_nonce(iv_s2c, seq_s2c)
    serial_println("[sshd-cipher] encrypt seq={seq_s2c} key_len={enc_key_s2c.len()} iv={_bytes_to_hex(iv_s2c)} nonce={_bytes_to_hex(nonce)} aad={_bytes_to_hex(aad)} body={_bytes_to_hex(body)}")
    val encrypted_with_tag = rt_tls13_aes256_gcm_encrypt(enc_key_s2c, nonce, body, aad)
    serial_println("[sshd-cipher] encrypt out={_bytes_to_hex(encrypted_with_tag)}")

    var result: [u8] = []
    i = 0
    while i < aad.len():
        result = _push_byte(result, _u8_at(aad, i))
        i = i + 1
    i = 0
    while i < encrypted_with_tag.len():
        result = _push_byte(result, _u8_at(encrypted_with_tag, i))
        i = i + 1
    result

fn ssh_encrypt_packet_aes128_gcm(payload: [u8], seq_s2c: u32, enc_key_s2c: [u8], iv_s2c: [u8]) -> [u8]:
    var padding_len: u64 = 4
    while ((1 + payload.len() + padding_len) % 16) != 0:
        padding_len = padding_len + 1
    val packet_length: u64 = 1 + payload.len() + padding_len
    var aad: [u8] = []
    aad = _push_byte(aad, ((packet_length >> 24) & 0xFF).to_u8())
    aad = _push_byte(aad, ((packet_length >> 16) & 0xFF).to_u8())
    aad = _push_byte(aad, ((packet_length >> 8) & 0xFF).to_u8())
    aad = _push_byte(aad, (packet_length & 0xFF).to_u8())

    var body: [u8] = []
    body = _push_byte(body, padding_len.to_u8())
    var i: u64 = 0
    while i < payload.len():
        body = _push_byte(body, _u8_at(payload, i))
        i = i + 1
    i = 0
    while i < padding_len:
        body = _push_byte(body, 0)
        i = i + 1

    val nonce = _make_nonce(iv_s2c, seq_s2c)
    serial_println("[sshd-cipher] encrypt128 seq={seq_s2c} key_len={enc_key_s2c.len()} iv={_bytes_to_hex(iv_s2c)} nonce={_bytes_to_hex(nonce)} aad={_bytes_to_hex(aad)} body={_bytes_to_hex(body)}")
    val encrypted_with_tag = aes128_gcm_encrypt(enc_key_s2c, nonce, body, aad)
    serial_println("[sshd-cipher] encrypt128 out_len={encrypted_with_tag.len()} out={_bytes_to_hex(encrypted_with_tag)}")

    var result: [u8] = []
    i = 0
    while i < aad.len():
        result = _push_byte(result, _u8_at(aad, i))
        i = i + 1
    i = 0
    while i < encrypted_with_tag.len():
        result = _push_byte(result, _u8_at(encrypted_with_tag, i))
        i = i + 1
    result

fn ssh_decrypt_packet_aes_gcm(data: [u8], seq_c2s: u32, enc_key_c2s: [u8], iv_c2s: [u8]) -> Result<[u8], text>:
    if data.len() < 4 + GCM_TAG_LEN:
        return Err("encrypted packet too short")

    var aad: [u8] = []
    var i: u64 = 0
    while i < 4:
        aad.push(_u8_at(data, i))
        i = i + 1

    val ct_with_tag_len = data.len() - 4
    if ct_with_tag_len < GCM_TAG_LEN:
        return Err("no ciphertext in encrypted packet")
    val ct_len = ct_with_tag_len - GCM_TAG_LEN

    var ciphertext: [u8] = []
    i = 0
    while i < ct_len:
        ciphertext.push(_u8_at(data, 4 + i))
        i = i + 1

    var tag: [u8] = []
    i = 0
    while i < GCM_TAG_LEN:
        tag.push(_u8_at(data, 4 + ct_len + i))
        i = i + 1

    val nonce = _make_nonce(iv_c2s, seq_c2s)
    serial_println("[sshd-cipher] decrypt256 seq={seq_c2s} key_len={enc_key_c2s.len()} iv={_bytes_to_hex(iv_c2s)} nonce={_bytes_to_hex(nonce)} aad={_bytes_to_hex(aad)} ct={_bytes_to_hex(ciphertext)} tag={_bytes_to_hex(tag)}")
    val result = rt_tls13_aes256_gcm_decrypt(enc_key_c2s, nonce, ciphertext, aad, tag)
    var status: u8 = 0x00
    if result.len() > 0:
        status = _u8_at(result, 0)
        serial_println("[sshd-cipher] decrypt256 result_len={result.len()} status=0x{_bytes_to_hex([status])}")
    else:
        serial_println("[sshd-cipher] decrypt256 result_len=0")
    if result.len() == 0:
        return Err("GCM decryption failed: invalid input")
    if status == 0x00:
        return Err("GCM decryption failed: authentication tag mismatch")

    if result.len() < 2:
        return Err("decrypted body empty")
    val padding_len = _u8_at(result, 1).to_u64()
    if 2 + padding_len > result.len():
        return Err("invalid padding in decrypted packet")
    val payload_len = result.len() - 2 - padding_len
    serial_println("[sshd-cipher] decrypt256 padding_len={padding_len} payload_len={payload_len}")
    var payload: [u8] = []
    i = 0
    while i < payload_len:
        payload.push(_u8_at(result, 2 + i))
        i = i + 1
    serial_println("[sshd-cipher] decrypt256 payload_ready len={payload.len()}")
    Ok(payload)

fn ssh_decrypt_packet_aes256_gcm_payload_direct(data: [u8], seq_c2s: u32, enc_key_c2s: [u8], iv_c2s: [u8]) -> Result<[u8], text>:
    val payload = rt_ssh_aes256_gcm_decrypt_packet(enc_key_c2s, iv_c2s, seq_c2s.to_i64(), data)
    serial_println("[sshd-cipher] decrypt256 direct payload_len={payload.len()} seq={seq_c2s}")
    if data.len() > 0 and payload.len() == 0:
        return Err("GCM packet decryption failed")
    Ok(payload)

fn ssh_decrypt_packet_aes256_gcm_payload_direct_raw(data: [u8], seq_c2s: u32, enc_key_c2s: [u8], iv_c2s: [u8]) -> [u8]:
    val payload = rt_ssh_aes256_gcm_decrypt_packet(enc_key_c2s, iv_c2s, seq_c2s.to_i64(), data)
    serial_println("[sshd-cipher] decrypt256 direct raw payload_len={payload.len()} seq={seq_c2s}")
    payload

fn ssh_decrypt_packet_aes256_gcm_payload_len(data: [u8], seq_c2s: u32, enc_key_c2s: [u8], iv_c2s: [u8]) -> i64:
    val payload_len = rt_ssh_aes256_gcm_decrypt_packet_payload_len(enc_key_c2s, iv_c2s, seq_c2s.to_i64(), data)
    serial_println("[sshd-cipher] decrypt256 direct payload_len_scalar={payload_len} seq={seq_c2s}")
    payload_len

fn ssh_decrypt_packet_aes128_gcm(data: [u8], seq_c2s: u32, enc_key_c2s: [u8], iv_c2s: [u8]) -> Result<[u8], text>:
    if data.len() < 4 + GCM_TAG_LEN:
        return Err("encrypted packet too short")

    var aad: [u8] = []
    var i: u64 = 0
    while i < 4:
        aad.push(_u8_at(data, i))
        i = i + 1

    val ct_with_tag_len = data.len() - 4
    if ct_with_tag_len < GCM_TAG_LEN:
        return Err("no ciphertext in encrypted packet")
    val ct_len = ct_with_tag_len - GCM_TAG_LEN

    var ciphertext: [u8] = []
    i = 0
    while i < ct_len:
        ciphertext.push(_u8_at(data, 4 + i))
        i = i + 1

    var tag: [u8] = []
    i = 0
    while i < GCM_TAG_LEN:
        tag.push(_u8_at(data, 4 + ct_len + i))
        i = i + 1

    val nonce = _make_nonce(iv_c2s, seq_c2s)
    serial_println("[sshd-cipher] decrypt128 seq={seq_c2s} key_len={enc_key_c2s.len()} iv={_bytes_to_hex(iv_c2s)} nonce={_bytes_to_hex(nonce)} aad={_bytes_to_hex(aad)} ct={_bytes_to_hex(ciphertext)} tag={_bytes_to_hex(tag)}")
    val result = aes128_gcm_decrypt(enc_key_c2s, nonce, ciphertext, aad, tag)
    match result:
        case Aes128GcmResult.Ok(data):
            if data.len() < 1:
                return Err("decrypted body empty")
            val padding_len = _u8_at(data, 0).to_u64()
            if 1 + padding_len > data.len():
                return Err("invalid padding in decrypted packet")
            val payload_len = data.len() - 1 - padding_len
            var payload: [u8] = []
            i = 0
            while i < payload_len:
                payload.push(_u8_at(data, 1 + i))
                i = i + 1
            Ok(payload)
        case Aes128GcmResult.Err(msg):
            Err("GCM decryption failed: " + msg)

export SshCipher
export ssh_encrypt_packet_aes_gcm, ssh_decrypt_packet_aes_gcm, ssh_decrypt_packet_aes256_gcm_payload_direct, ssh_decrypt_packet_aes256_gcm_payload_direct_raw, ssh_decrypt_packet_aes256_gcm_payload_len
export ssh_encrypt_packet_aes128_gcm, ssh_decrypt_packet_aes128_gcm
