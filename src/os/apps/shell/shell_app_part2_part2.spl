# =========================================================================
# Shell Application
# =========================================================================

impl ShellApp:
    me _execute_chain(cmd: text):
        """Execute a command chain: cmd1 && cmd2 (stop on failure) or cmd1 || cmd2 (stop on success)."""
        # Split into segments with their operators
        # We process left to right
        var remaining = cmd
        var last_op = "&&"  # Start assuming && (first segment always runs)
        var first = true
        while remaining.len() > 0:
            var segment = remaining
            var next_op = ""
            var next_remaining = ""
            val and_pos = _find_chain_op(remaining, " && ")
            val or_pos = _find_chain_op(remaining, " || ")
            if and_pos >= 0 and (or_pos < 0 or and_pos < or_pos):
                segment = remaining.slice(0, and_pos)
                next_op = "&&"
                next_remaining = remaining.slice(and_pos + 4, remaining.len())
            elif or_pos >= 0:
                segment = remaining.slice(0, or_pos)
                next_op = "||"
                next_remaining = remaining.slice(or_pos + 4, remaining.len())
            # else: segment = remaining, loop ends after

            val run = if first: true
                      elif last_op == "&&": self.last_exit_code == 0
                      else: self.last_exit_code != 0
            if run:
                self.execute(segment.trim())
            first = false
            last_op = next_op
            remaining = next_remaining

    me _try_external(command: text, args: [text]):
        """Try to run an external command synchronously."""
        val toolchain_shim = tool_try_staged_toolchain(
            self.vfs, self.cwd, self._get_env("PATH"), command, args, self.terminal)
        if toolchain_shim != nil:
            self.last_exit_code = toolchain_shim.unwrap()
            return

        val result = spawn_command_async(command, args, self.cwd, self._get_env("PATH"))
        match result:
            Ok(future):
                # Block until command completes
                val status = posix_waitpid(future.pid as i64, 0)
                self.last_exit_code = status as i32
            Err(msg):
                self._write_error("sosh: command not found: {command}")
                self.last_exit_code = 127

    fn parse_command(input: text) -> [text]:
        """Split command input into argv tokens.

        Handles single and double quotes, backslash escaping.
        """
        var tokens: [text] = []
        var current = ""
        var in_single_quote = false
        var in_double_quote = false
        var escaped = false

        for ch in input:
            if escaped:
                current = "{current}{ch}"
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == "'" and not in_double_quote:
                in_single_quote = not in_single_quote
            elif ch == "\"" and not in_single_quote:
                in_double_quote = not in_double_quote
            elif ch == " " and not in_single_quote and not in_double_quote:
                if current != "":
                    tokens = tokens.push(current)
                    current = ""
            else:
                current = "{current}{ch}"

        if current != "":
            tokens = tokens.push(current)
        return tokens

    # -- Built-in Commands ---------------------------------------------------

    me cmd_cd(args: [text]):
        """Change directory."""
        val target = if args.len() > 0: args[0] else: self._get_env("HOME")
        val resolved = self._resolve_path(target)
        # Verify directory exists via VFS if available
        if self.vfs != nil:
            val result = self.vfs.stat(resolved)
            if result.is_err():
                self._write_error("cd: no such directory: {resolved}")
                self.last_exit_code = 1
                return
        self.cwd = resolved
        self.last_exit_code = 0

    me cmd_ls(args: [text]):
        """List directory contents."""
        self.last_exit_code = tool_ls(self.vfs, self.cwd, args, self.terminal)

    me cmd_pwd():
        """Print working directory."""
        self._write_line(self.cwd)
        self.last_exit_code = 0

    me cmd_echo(args: [text]):
        """Echo arguments to terminal."""
        var output = ""
        var i = 0
        for arg in args:
            if i > 0:
                output = "{output} "
            # Expand environment variables ($VAR)
            output = "{output}{self._expand_vars(arg)}"
            i = i + 1
        self._write_line(output)
        self.last_exit_code = 0

    me cmd_cat(args: [text]):
        """Display file contents."""
        if args.len() == 0:
            self._write_error("cat: missing file operand")
            self.last_exit_code = 1
            return
        for filename in args:
            val path = self._resolve_path(filename)
            if self.vfs != nil:
                val result = self.vfs.read_text(path)
                if result.is_err():
                    self._write_error("cat: {path}: {result.unwrap_err()}")
                    self.last_exit_code = 1
                else:
                    self._write_line(result.unwrap())
            else:
                self._write_error("cat: no filesystem mounted")
                self.last_exit_code = 1

    me cmd_mkdir(args: [text]):
        """Create a directory."""
        if args.len() == 0:
            self._write_error("mkdir: missing operand")
            self.last_exit_code = 1
            return
        var create_parents = false
        var paths: [text] = []
        for arg in args:
            if arg == "-p":
                create_parents = true
            else:
                paths = paths.push(arg)
        if paths.len() == 0:
            self._write_error("mkdir: missing operand")
            self.last_exit_code = 1
            return
        self.last_exit_code = 0
        for dirname in paths:
            val path = self._resolve_path(dirname)
            if self.vfs != nil:
                val result = if create_parents: self._mkdir_with_parents(path) else: self.vfs.mkdir(path)
                if result.is_err():
                    self._write_error("mkdir: {result.unwrap_err()}")
                    self.last_exit_code = 1
            else:
                self._write_error("mkdir: no filesystem mounted")
                self.last_exit_code = 1

    me cmd_rm(args: [text]):
        """Remove files."""
        if args.len() == 0:
            self._write_error("rm: missing operand")
            self.last_exit_code = 1
            return
        var recursive = false
        var force = false
        var paths: [text] = []
        for arg in args:
            if arg == "-r" or arg == "-R":
                recursive = true
            elif arg == "-f":
                force = true
            elif arg == "-rf" or arg == "-fr":
                recursive = true
                force = true
            else:
                paths = paths.push(arg)
        if paths.len() == 0:
            self._write_error("rm: missing operand")
            self.last_exit_code = 1
            return
        self.last_exit_code = 0
        for filename in paths:
            val path = self._resolve_path(filename)
            if self.vfs != nil:
                val result = self._remove_path(path, recursive, force)
                if result.is_err():
                    self._write_error("rm: {result.unwrap_err()}")
                    self.last_exit_code = 1
            else:
                self._write_error("rm: no filesystem mounted")
                self.last_exit_code = 1

    me cmd_cp(args: [text]):
        """Copy files."""
        if args.len() < 2:
            self._write_error("cp: missing operand")
            self.last_exit_code = 1
            return
        var recursive = false
        var operands: [text] = []
        for arg in args:
            if arg == "-r" or arg == "-R":
                recursive = true
            else:
                operands = operands.push(arg)
        if operands.len() < 2:
            self._write_error("cp: missing operand")
            self.last_exit_code = 1
            return
        val src = self._resolve_path(operands[0])
        val dst = self._resolve_path(operands[1])
        if self.vfs != nil:
            val copy_result = self._copy_path(src, dst, recursive)
            if copy_result.is_err():
                self._write_error("cp: {copy_result.unwrap_err()}")
                self.last_exit_code = 1
            else:
                self.last_exit_code = 0
        else:
            self._write_error("cp: no filesystem mounted")
            self.last_exit_code = 1

    me cmd_mv(args: [text]):
        """Move/rename files."""
        if args.len() < 2:
            self._write_error("mv: missing operand")
            self.last_exit_code = 1
            return
        val src = self._resolve_path(args[0])
        val dst = self._resolve_path(args[1])
        if self.vfs != nil:
            val rename_result = self.vfs.rename(src, dst)
            if rename_result.is_err():
                self._write_error("mv: {rename_result.unwrap_err()}")
                self.last_exit_code = 1
        else:
            self._write_error("mv: no filesystem mounted")
            self.last_exit_code = 1

    me cmd_grep(args: [text]):
        """Search for pattern in files."""
        if args.len() < 2:
            self._write_error("grep: usage: grep PATTERN FILE...")
            self.last_exit_code = 1
            return
        val pattern = args[0]
        var i = 1
        while i < args.len():
            val path = self._resolve_path(args[i])
            if self.vfs != nil:
                val result = self.vfs.read_text(path)
                if result.is_ok():
                    val content = result.unwrap()
                    var line_num = 1
                    for line in split_lines(content):
                        if line.contains(pattern):
                            self._write_line("{args[i]}:{line_num}:{line}")
                        line_num = line_num + 1
                else:
                    self._write_error("grep: {path}: {result.unwrap_err()}")
            i = i + 1
        self.last_exit_code = 0

    me cmd_find(args: [text]):
        """Find files by name."""
        self.last_exit_code = tool_find(self.vfs, self.cwd, args, self.terminal)

    me cmd_ps():
        """List running processes from the scheduler."""
        val result = list_tasks()
        if result.is_err():
            self._write_error("ps: {result.unwrap_err()}")
            self.last_exit_code = 1
            return
        val tasks = result.unwrap()
        self._write_line("  PID  STATE     PRIORITY  NAME")
        for task in tasks:
            val state_str = match task.state:
                case 0: "Ready   "
                case 1: "Running "
                case 2: "Blocked "
                case 3: "Zombie  "
                case _: "Unknown "
            val prio_str = match task.priority:
                case 0: "RT    "
                case 1: "High  "
                case 2: "Normal"
                case 3: "Low   "
                case 4: "Idle  "
                case _: "?     "
            self._write_line("  {task.pid}  {state_str}  {prio_str}  {task.name}")
        self.last_exit_code = 0

    me cmd_kill(args: [text]):
        """Send signal to a process."""
        if args.len() == 0:
            self._write_error("kill: missing PID")
            self.last_exit_code = 1
            return
        # Parse optional signal flag
        var sig = SignalKind.Term
        var pid_str = args[0]
        if args[0].starts_with("-"):
            val flag = args[0].slice(1, args[0].len())
            sig = match flag:
                "TERM": SignalKind.Term
                "KILL": SignalKind.Kill
                "STOP": SignalKind.Stop
                "CONT": SignalKind.Cont
                "INT":  SignalKind.Int
                _:      SignalKind.Term
            if args.len() < 2:
                self._write_error("kill: missing PID")
                self.last_exit_code = 1
                return
            pid_str = args[1]
        val pid = _parse_u64(pid_str)
        if pid == 0:
            self._write_error("kill: invalid PID: {pid_str}")
            self.last_exit_code = 1
            return
        val result = signal(pid, sig)
        if result.is_err():
            self._write_error("kill: {result.unwrap_err()}")
            self.last_exit_code = 1
        else:
            self.last_exit_code = 0

    me cmd_run(args: [text]):
        """Run an external command through the launcher path."""
        if args.len() == 0:
            self._write_error("run: missing command")
            self.last_exit_code = 1
            return
        if args[0] == "--help":
            self._write_line("usage: run CMD [ARGS...]")
            self.last_exit_code = 0
            return

        val command = args[0]
        var cmd_args: [text] = []
        var i = 1
        while i < args.len():
            cmd_args = cmd_args.push(args[i])
            i = i + 1

        val result = spawn_command_async(command, cmd_args, self.cwd, self._get_env("PATH"))
        match result:
            Ok(future):
                val status = posix_waitpid(future.pid as i64, 0)
                self.last_exit_code = status as i32
            Err(msg):
                self._write_error("run: {msg}")
                self.last_exit_code = 1

    me cmd_mount(args: [text]):
        """Show or add mount points."""
        if args.len() == 0:
            # Show current mounts
            val result = mount_list()
            if result.is_err():
                self._write_error("mount: {result.unwrap_err()}")
                self.last_exit_code = 1
            else:
                val mounts = result.unwrap()
                for m in mounts:
                    self._write_line(m)
                self.last_exit_code = 0
            return
        if args.len() < 2:
            self._write_error("mount: usage: mount DEVICE MOUNTPOINT [FSTYPE]")
            self.last_exit_code = 1
            return
        val device = args[0]
        val mount_path = args[1]
        val fs_type = if args.len() > 2: args[2] else: "fat32"
        val result = mount(device, mount_path, fs_type)
        if result.is_err():
            self._write_error("mount: {result.unwrap_err()}")
            self.last_exit_code = 1
        else:
            self._write_line("mount: mounted {device} on {mount_path} (type {fs_type})")
            self.last_exit_code = 0

    me cmd_clear():
        """Clear the terminal screen."""
        self.terminal.clear()
        self.last_exit_code = 0
