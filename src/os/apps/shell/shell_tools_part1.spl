# Part 1 of src/os/apps/shell/shell_tools.spl
use os.apps.shell.shell_tools.*
#![allow(unnamed_duplicate_typed_args)]
# Shell Extended Tools
#
# Additional built-in commands for the SimpleOS shell.
# Each tool is a standalone function returning an i32 exit code.
#
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.kernel.types.fs_types.{FsNode, FsNodeKind}
use os.services.vfs.vfs.{VfsManager}
use os.tools.tool_registry.{ToolRegistry}

# =========================================================================
# Path Resolution (shared helper)
# =========================================================================

fn _resolve_tool_path(cwd: text, path: text) -> text:
    """Resolve a relative path against cwd for tool use."""
    if path.starts_with("/"):
        return _normalize(path)
    if path == "..":
        return _parent(cwd)
    if path == ".":
        return cwd
    val full = if cwd == "/": "/{path}" else: "{cwd}/{path}"
    return _normalize(full)

fn _normalize(path: text) -> text:
    """Normalize path by resolving . and .. components."""
    var parts: [text] = []
    var current = ""
    for ch in path:
        if ch == "/":
            if current == "..":
                if parts.len() > 0:
                    var new_parts: [text] = []
                    var j = 0
                    while j < parts.len() - 1:
                        new_parts = new_parts.push(parts[j])
                        j = j + 1
                    parts = new_parts
            elif current != "." and current != "":
                parts = parts.push(current)
            current = ""
        else:
            current = "{current}{ch}"
    if current == "..":
        if parts.len() > 0:
            var new_parts: [text] = []
            var j = 0
            while j < parts.len() - 1:
                new_parts = new_parts.push(parts[j])
                j = j + 1
            parts = new_parts
    elif current != "." and current != "":
        parts = parts.push(current)
    if parts.len() == 0:
        return "/"
    var result = ""
    for part in parts:
        result = "{result}/{part}"
    return result

fn _parent(path: text) -> text:
    """Get parent directory of a path."""
    if path == "/":
        return "/"
    var last_slash = 0
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash == 0:
        return "/"
    return path.slice(0, last_slash)

# =========================================================================
# Output Helpers
# =========================================================================

fn _write_line(terminal: Terminal, line: text):
    """Write a line with newline to terminal."""
    terminal.write_string("{line}\n")

fn _write_error(terminal: Terminal, msg: text):
    """Write an error message in red."""
    val esc = "\u{001b}"
    terminal.write_string("{esc}[31m{msg}{esc}[0m\n")

fn _parse_int(s: text) -> i32:
    """Parse an i32 from text, returning -1 on failure."""
    var result: i32 = 0
    var found_digit = false
    for ch in s:
        if ch >= "0" and ch <= "9":
            val digit = ch.to_i32() - "0".to_i32()
            result = result * 10 + digit
            found_digit = true
        else:
            return -1
    if not found_digit:
        return -1
    return result

fn _split_text_on(content: text, delimiter: text) -> [text]:
    """Split text on a single-character delimiter without relying on text.split."""
    var parts: [text] = []
    var current = ""
    val terminated = "{content}{delimiter}"
    for ch in terminated:
        if ch == delimiter:
            parts = parts.push(current)
            current = ""
        else:
            current = "{current}{ch}"
    return parts

fn _split_lines(content: text) -> [text]:
    return _split_text_on(content, "\n")

fn _split_spaces(content: text) -> [text]:
    return _split_text_on(content, " ")

fn _tool_env_value(env_pairs: [(text, text)], key: text, default_value: text) -> text:
    for pair in env_pairs:
        if pair.0 == key:
            return pair.1
    default_value

fn _tool_file_first_line(vfs: VfsManager?, path: text) -> text?:
    if vfs == nil:
        return nil
    val result = vfs.read_text(path)
    if result.is_err():
        return nil
    val content = result.unwrap()
    val newline = content.index_of("\n")
    if newline == nil:
        return Some(content.trim())
    Some(content.slice(0, newline.unwrap()).trim())

fn _tool_manifest_value(vfs: VfsManager?, path: text, key: text) -> text?:
    if vfs == nil:
        return nil
    val result = vfs.read_text(path)
    if result.is_err():
        return nil
    for raw_line in _split_lines(result.unwrap()):
        val line = raw_line.trim()
        if line.starts_with("{key}="):
            return Some(line.slice(key.len() + 1, line.len()).trim())
    nil

fn _tool_path_candidates(command: text, cwd: text, path_env: text) -> [text]:
    if command == "":
        return []
    if command.contains("/"):
        return [_resolve_tool_path(cwd, command)]
    var candidates: [text] = []
    for raw_dir in _split_text_on(path_env, ":"):
        val dir = raw_dir.trim()
        if dir == "":
            continue
        if dir == "/":
            candidates = candidates.push("/{command}")
        else:
            candidates = candidates.push(_normalize("{dir}/{command}"))
    candidates

fn _tool_path_exists(vfs: VfsManager?, cwd: text, path_env: text, command: text) -> bool:
    if vfs == nil:
        return false
    for candidate in _tool_path_candidates(command, cwd, path_env):
        if vfs.stat(candidate).is_ok():
            return true
    false

fn _toolchain_manifest_paths(command: text) -> (version_path: text, manifest_path: text, canonical_path: text):
    match command:
        "cmake":
            ("/SYS/CMAKEVER.TXT", "/SYS/CMAKEMAN.TXT", "/usr/bin/cmake")
        "clang":
            ("/SYS/CLANGVER.TXT", "/SYS/CLANGMAN.TXT", "/usr/bin/clang")
        "clang-20":
            ("/SYS/CLANGVER.TXT", "/SYS/CLANGMAN.TXT", "/usr/bin/clang-20")
        "lld":
            ("/SYS/LLVMVER.TXT", "/SYS/LLVMMAN.TXT", "/usr/bin/lld")
        "ld.lld":
            ("/SYS/LLVMVER.TXT", "/SYS/LLVMMAN.TXT", "/usr/bin/ld.lld")
        "llvm-ar":
            ("/SYS/LLVMVER.TXT", "/SYS/LLVMMAN.TXT", "/usr/bin/llvm-ar")
        "llvm-nm":
            ("/SYS/LLVMVER.TXT", "/SYS/LLVMMAN.TXT", "/usr/bin/llvm-nm")
        "llvm-ranlib":
            ("/SYS/LLVMVER.TXT", "/SYS/LLVMMAN.TXT", "/usr/bin/llvm-ranlib")
        "llvm-objdump":
            ("/SYS/LLVMVER.TXT", "/SYS/LLVMMAN.TXT", "/usr/bin/llvm-objdump")
        "llvm-objcopy":
            ("/SYS/LLVMVER.TXT", "/SYS/LLVMMAN.TXT", "/usr/bin/llvm-objcopy")
        "llvm-strip":
            ("/SYS/LLVMVER.TXT", "/SYS/LLVMMAN.TXT", "/usr/bin/llvm-strip")
        "rustc":
            ("/SYS/RUSTVER.TXT", "/SYS/RUSTMAN.TXT", "/usr/bin/rustc")
        "cargo":
            ("/SYS/CARGOVER.TXT", "/SYS/RUSTMAN.TXT", "/usr/bin/cargo")
        "cargo-simpleos":
            ("/SYS/CARGOVER.TXT", "/SYS/RUSTMAN.TXT", "/usr/bin/cargo-simpleos")
        "ninja":
            ("/SYS/NINJAVER.TXT", "/SYS/NINJAMAN.TXT", "/usr/bin/ninja")
        _:
            ("", "", "")

fn _toolchain_command_supported(command: text) -> bool:
    val paths = _toolchain_manifest_paths(command)
    paths.version_path != ""

fn _toolchain_help_lines(command: text) -> [text]:
    if command == "cmake":
        return [
            "cmake: SimpleOS native wrapper for the packaged configure lane",
            "supported: --version, --help, -E capabilities",
            "supported subset: cmake -S <src> -B <build> -G Ninja",
        ]
    if command == "clang" or command == "clang-20" or command == "lld" or
       command == "ld.lld" or command == "llvm-ar" or command == "llvm-nm" or
       command == "llvm-ranlib" or command == "llvm-objdump" or
       command == "llvm-objcopy" or command == "llvm-strip":
        return [
            "{command}: SimpleOS guest-exec wrapper for staged LLVM payloads",
            "supported: --version, --help, --print-target-triple",
            "lane executes the staged LLVM payloads for x86_64-simpleos",
        ]
    if command == "rustc":
        return [
            "rustc: SimpleOS report-and-gate wrapper for staged Rust payloads",
            "supported: --version, --help, --print target-list, --print sysroot",
            "compile/build operations fail explicitly with lane/status metadata",
        ]
    if command == "cargo":
        return [
            "cargo: SimpleOS report-and-gate wrapper for staged Rust payloads",
            "supported: --version, --help, --print target-list",
            "cargo build/check/test/run are intentionally gated on this lane",
        ]
    if command == "cargo-simpleos":
        return [
            "cargo-simpleos: SimpleOS report-and-gate bootstrap wrapper",
            "supported: --version, --help, --print target-list",
            "real guest cargo cutover is pending rustlib/std bring-up",
        ]
    if command == "ninja":
        return [
            "ninja: SimpleOS native wrapper for packaged Ninja execution",
            "supported: --version, --help",
            "guest execution uses the staged ninja payload",
        ]
    []

fn tool_try_staged_toolchain(vfs: VfsManager?, cwd: text, path_env: text,
                             command: text, args: [text], terminal: Terminal) -> i32?:
    """Execute a filesystem-backed native-wrapper surface for guest toolchain commands.

    The FAT image currently stages host-built LLVM/Rust/Ninja binaries under
    `/usr/bin`, and packages the promoted native build-tool entrypoints at the
    same stable paths. The wrappers are truthful about what works in-guest while
    the full native execution lanes are still landing.
    """
    if not _toolchain_command_supported(command):
        return nil
    if not _tool_path_exists(vfs, cwd, path_env, command):
        return nil

    val paths = _toolchain_manifest_paths(command)
    val version_path = paths.version_path
    val manifest_path = paths.manifest_path
    val canonical_path = paths.canonical_path
    val version = _tool_file_first_line(vfs, version_path) ?? "{command} staged payload"
    val primary = if args.len() > 0: args[0] else: "--version"

    if primary == "--version":
        _write_line(terminal, version)
        return 0

    if command == "cmake":
        if primary == "-E" and args.len() > 1 and args[1] == "capabilities":
            val lane = _tool_manifest_value(vfs, manifest_path, "lane") ?? "unknown"
            val mode = _tool_manifest_value(vfs, manifest_path, "mode") ?? "unknown"
            val status = _tool_manifest_value(vfs, manifest_path, "status") ?? "unknown"
            _write_line(terminal, "serverMode=false")
            _write_line(terminal, "generators=Ninja")
            _write_line(terminal, "tool=/usr/bin/cmake")
            _write_line(terminal, "lane={lane}")
            _write_line(terminal, "mode={mode}")
            _write_line(terminal, "status={status}")
            return 0

    if command == "clang" or command == "clang-20":
        if primary == "--print-target-triple":
            _write_line(terminal, "x86_64-simpleos")
            return 0
        if primary == "--print" and args.len() > 1 and args[1] == "simpleos-wrapper-status":
            val lane = _tool_manifest_value(vfs, manifest_path, "lane") ?? "unknown"
            val mode = _tool_manifest_value(vfs, manifest_path, "mode") ?? "unknown"
            val status = _tool_manifest_value(vfs, manifest_path, "status") ?? "unknown"
            _write_line(terminal, "lane={lane}")
            _write_line(terminal, "mode={mode}")
            _write_line(terminal, "status={status}")
            return 0
        return nil
    if command == "rustc":
        if primary == "--print" and args.len() > 1 and args[1] == "target-list":
            _write_line(terminal, "x86_64-unknown-simpleos")
            return 0
        if primary == "--print" and args.len() > 1 and args[1] == "sysroot":
            _write_line(terminal, "/usr")
            return 0
        if primary == "--print" and args.len() > 1 and args[1] == "target-libdir":
            _write_line(terminal, "/usr/lib/rustlib/x86_64-unknown-simpleos/lib")
            return 0
        if primary == "--print" and args.len() > 1 and args[1] == "simpleos-rustlib":
            _write_line(terminal, "/usr/lib/rustlib/x86_64-unknown-simpleos/lib")
            return 0
        if primary == "--print" and args.len() > 1 and args[1] == "simpleos-target-json":
            _write_line(terminal, "/usr/lib/rustlib/x86_64-unknown-simpleos/target.json")
            return 0
        if primary == "--print" and args.len() > 1 and args[1] == "simpleos-wrapper-status":
            val lane = _tool_manifest_value(vfs, manifest_path, "lane") ?? "unknown"
            val mode = _tool_manifest_value(vfs, manifest_path, "mode") ?? "unknown"
            val status = _tool_manifest_value(vfs, manifest_path, "status") ?? "unknown"
            _write_line(terminal, "lane={lane}")
            _write_line(terminal, "mode={mode}")
            _write_line(terminal, "status={status}")
            return 0
    if command == "cargo" or command == "cargo-simpleos":
        if primary == "--print" and args.len() > 1 and args[1] == "target-list":
            _write_line(terminal, "x86_64-unknown-simpleos")
            return 0
        if primary == "--print" and args.len() > 1 and args[1] == "sysroot":
            _write_line(terminal, "/usr")
            return 0
        if primary == "--print" and args.len() > 1 and args[1] == "simpleos-rustlib":
            _write_line(terminal, "/usr/lib/rustlib/x86_64-unknown-simpleos/lib")
            return 0
        if primary == "--print" and args.len() > 1 and args[1] == "simpleos-target-json":
            _write_line(terminal, "/usr/lib/rustlib/x86_64-unknown-simpleos/target.json")
            return 0
        if primary == "--print" and args.len() > 1 and args[1] == "simpleos-wrapper-status":
            val lane = _tool_manifest_value(vfs, manifest_path, "lane") ?? "unknown"
            val mode = _tool_manifest_value(vfs, manifest_path, "mode") ?? "unknown"
            val status = _tool_manifest_value(vfs, manifest_path, "status") ?? "unknown"
            _write_line(terminal, "lane={lane}")
            _write_line(terminal, "mode={mode}")
            _write_line(terminal, "status={status}")
            return 0

    if primary == "--help" or primary == "-h":
        for line in _toolchain_help_lines(command):
            _write_line(terminal, line)
        val manifest = _tool_file_first_line(vfs, manifest_path)
        val lane = _tool_manifest_value(vfs, manifest_path, "lane")
        val status = _tool_manifest_value(vfs, manifest_path, "status")
        if manifest != nil and manifest.unwrap() != "":
            _write_line(terminal, "manifest: {manifest.unwrap()}")
        if lane != nil:
            _write_line(terminal, "lane: {lane.unwrap()}")
        if status != nil:
            _write_line(terminal, "status: {status.unwrap()}")
        _write_line(terminal, "payload: {canonical_path}")
        return 0

    val lane = _tool_manifest_value(vfs, manifest_path, "lane") ?? "unknown"
    val mode = _tool_manifest_value(vfs, manifest_path, "mode") ?? "unknown"
    val status = _tool_manifest_value(vfs, manifest_path, "status") ?? "unknown"
    _write_error(terminal,
        "{command}: unsupported operation on lane={lane} mode={mode} status={status}")
    _write_error(terminal,
        "{command}: no host fallback is available from this guest wrapper")
    _write_error(terminal,
        "{command}: supported guest wrapper options are --version and --help")
    if command == "cmake":
        _write_error(terminal,
            "{command}: supported discovery option available: -E capabilities")
    if command == "clang" or command == "clang-20" or command == "rustc" or
       command == "cargo" or command == "cargo-simpleos":
        _write_error(terminal,
            "{command}: additional discovery option available: --print target metadata")
        _write_error(terminal,
            "{command}: wrapper status available via --print simpleos-wrapper-status")
    1

# =========================================================================
# touch — Create empty files or update timestamps
# =========================================================================

fn tool_touch(vfs: VfsManager?, cwd: text, args: [text]) -> i32:
    """Create empty files. If file exists, this is a no-op (no timestamp update in VFS yet)."""
    if args.len() == 0:
        return 1
    if vfs == nil:
        return 1
    var exit_code: i32 = 0
    for filename in args:
        val path = _resolve_tool_path(cwd, filename)
        # Check if file already exists
        val stat_result = vfs.stat(path)
        if stat_result.is_ok():
            # File exists — would update timestamp but VFS doesn't support it yet
            pass_dn
        else:
            # Create empty file by writing empty content
            val write_result = vfs.write_text(path, "")
            if write_result.is_err():
                exit_code = 1
    return exit_code

# =========================================================================
# head — Show first N lines of a file
# =========================================================================

fn tool_head(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Show first N lines of a file (default 10)."""
    if vfs == nil:
        _write_error(terminal, "head: no filesystem mounted")
        return 1
    var n: i32 = 10
    var file_path: text = ""

    # Parse args: [-n N] FILE
    var i = 0
    while i < args.len():
        if args[i] == "-n" and i + 1 < args.len():
            val parsed = _parse_int(args[i + 1])
            if parsed > 0:
                n = parsed
            i = i + 2
        else:
            file_path = args[i]
            i = i + 1

    if file_path == "":
        _write_error(terminal, "head: missing file operand")
        return 1

    val path = _resolve_tool_path(cwd, file_path)
    val result = vfs.read_text(path)
    if result.is_err():
        _write_error(terminal, "head: {path}: {result.unwrap_err()}")
        return 1

    val content = result.unwrap()
    val lines = _split_lines(content)
    var count: i32 = 0
    for line in lines:
        if count >= n:
            return 0
        _write_line(terminal, line)
        count = count + 1
    return 0

# =========================================================================
# tail — Show last N lines of a file
# =========================================================================

fn tool_tail(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Show last N lines of a file (default 10)."""
    if vfs == nil:
        _write_error(terminal, "tail: no filesystem mounted")
        return 1
    var n: i32 = 10
    var file_path: text = ""

    # Parse args: [-n N] FILE
    var i = 0
    while i < args.len():
        if args[i] == "-n" and i + 1 < args.len():
            val parsed = _parse_int(args[i + 1])
            if parsed > 0:
                n = parsed
            i = i + 2
        else:
            file_path = args[i]
            i = i + 1

    if file_path == "":
        _write_error(terminal, "tail: missing file operand")
        return 1

    val path = _resolve_tool_path(cwd, file_path)
    val result = vfs.read_text(path)
    if result.is_err():
        _write_error(terminal, "tail: {path}: {result.unwrap_err()}")
        return 1

    val content = result.unwrap()
    val lines = _split_lines(content)
    val total = lines.len() as i32
    val start = if total > n: total - n else: 0
    var idx: i32 = 0
    for line in lines:
        if idx >= start:
            _write_line(terminal, line)
        idx = idx + 1
    return 0

# =========================================================================
# wc — Word/line/char count
# =========================================================================

fn tool_wc(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Count lines, words, and characters in files."""
    if vfs == nil:
        _write_error(terminal, "wc: no filesystem mounted")
        return 1

    # Parse flags
    var count_lines = false
    var count_words = false
    var count_chars = false
    var files: [text] = []

    for arg in args:
        if arg == "-l":
            count_lines = true
        elif arg == "-w":
            count_words = true
        elif arg == "-c":
            count_chars = true
        else:
            files = files.push(arg)

    # Default: show all counts
    if not count_lines and not count_words and not count_chars:
        count_lines = true
        count_words = true
        count_chars = true

    if files.len() == 0:
        _write_error(terminal, "wc: missing file operand")
        return 1

    var exit_code: i32 = 0
    var total_lines: i32 = 0
    var total_words: i32 = 0
    var total_chars: i32 = 0

    for filename in files:
        val path = _resolve_tool_path(cwd, filename)
        val result = vfs.read_text(path)
        if result.is_err():
            _write_error(terminal, "wc: {path}: {result.unwrap_err()}")
            exit_code = 1
        else:
            val content = result.unwrap()
            val lines = _split_lines(content)
            val num_lines = lines.len() as i32
            var num_words: i32 = 0
            for line in lines:
                # Count words by splitting on spaces
                val words = _split_spaces(line)
                for w in words:
                    if w.trim() != "":
                        num_words = num_words + 1
            val num_chars = content.len() as i32

            total_lines = total_lines + num_lines
            total_words = total_words + num_words
            total_chars = total_chars + num_chars

            var output = ""
            if count_lines:
                output = "  {num_lines}"
            if count_words:
                output = "{output}  {num_words}"
            if count_chars:
                output = "{output}  {num_chars}"
            _write_line(terminal, "{output}  {filename}")

    # Print total if multiple files
    if files.len() > 1:
        var output = ""
        if count_lines:
            output = "  {total_lines}"
        if count_words:
            output = "{output}  {total_words}"
        if count_chars:
            output = "{output}  {total_chars}"
        _write_line(terminal, "{output}  total")

    return exit_code

# =========================================================================
# sort — Sort lines alphabetically
# =========================================================================

fn tool_sort(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Sort lines of a file alphabetically."""
    if vfs == nil:
        _write_error(terminal, "sort: no filesystem mounted")
        return 1
    if args.len() == 0:
        _write_error(terminal, "sort: missing file operand")
        return 1

    val path = _resolve_tool_path(cwd, args[0])
    val result = vfs.read_text(path)
    if result.is_err():
        _write_error(terminal, "sort: {path}: {result.unwrap_err()}")
        return 1

    val content = result.unwrap()
    val lines = _split_lines(content)

    # Simple insertion sort (adequate for shell use)
    var sorted: [text] = []
    for line in lines:
        sorted = _insert_sorted(sorted, line)
    for s in sorted:
        _write_line(terminal, s)
    return 0
