# Shell Pipeline Execution
#
# Executes command pipelines: cmd1 | cmd2 | cmd3
# Uses POSIX pipes to connect stdout of one command to stdin of the next.
# Each stage is spawned as a child process with redirected FDs.
#
# MDSOC: feature dimension, shell layer

use os.posix.pipe_compat.{posix_pipe, pipe_read, pipe_write, pipe_close_read, pipe_close_write}
use os.posix.process_compat.{posix_spawn_with_args, posix_waitpid}
use os.posix.fd_io.{posix_dup2, posix_close}
use os.posix.fd_table.{fd_alloc, fd_set, FD_TYPE_PIPE_READ, FD_TYPE_PIPE_WRITE, O_RDONLY, O_WRONLY}

extern fn unsafe_addr_of(ref: any) -> u64

# ============================================================================
# Pipeline Stage
# ============================================================================

struct PipelineStage:
    """One stage of a pipeline."""
    command: text
    args: [text]
    pid: i64
    stdin_fd: i32
    stdout_fd: i32

# ============================================================================
# Pipeline Parsing
# ============================================================================

fn parse_pipeline(input: text) -> [text]:
    """Split command line on '|' respecting quotes.

    Returns a list of individual command strings, each trimmed.
    Handles single quotes, double quotes, and backslash escaping.
    """
    var stages: [text] = []
    var current: text = ""
    var in_single_quote = false
    var in_double_quote = false
    var escaped = false

    for ch in input:
        if escaped:
            current = "{current}{ch}"
            escaped = false
        elif ch == "\\":
            escaped = true
            current = "{current}{ch}"
        elif ch == "'" and not in_double_quote:
            in_single_quote = not in_single_quote
            current = "{current}{ch}"
        elif ch == "\"" and not in_single_quote:
            in_double_quote = not in_double_quote
            current = "{current}{ch}"
        elif ch == "|" and not in_single_quote and not in_double_quote:
            val trimmed = current.trim()
            if trimmed != "":
                stages = stages.push(trimmed)
            current = ""
        else:
            current = "{current}{ch}"

    val trimmed = current.trim()
    if trimmed != "":
        stages = stages.push(trimmed)

    stages

fn has_pipeline(input: text) -> bool:
    """Check if an input line contains a pipeline operator.

    Returns true if the input contains an unquoted '|' character.
    """
    var in_single_quote = false
    var in_double_quote = false
    var escaped = false

    for ch in input:
        if escaped:
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "'" and not in_double_quote:
            in_single_quote = not in_single_quote
        elif ch == "\"" and not in_single_quote:
            in_double_quote = not in_double_quote
        elif ch == "|" and not in_single_quote and not in_double_quote:
            return true

    false

# ============================================================================
# Pipeline Execution
# ============================================================================

fn execute_pipeline(stages: [text]) -> i64:
    """Execute a pipeline of commands.

    For N stages, creates N-1 pipes:
      Stage 0: stdin=terminal, stdout=pipe[0].write
      Stage 1: stdin=pipe[0].read, stdout=pipe[1].write
      ...
      Stage N-1: stdin=pipe[N-2].read, stdout=terminal

    Each stage is spawned as a child process with the appropriate
    stdin/stdout redirections. Returns exit code of the last stage.
    """
    if stages.len() == 0:
        return 0

    if stages.len() == 1:
        # Single command, no pipes needed — caller handles this
        return -1

    # Create N-1 pipes
    # Each pipe is a (read_fd, write_fd) pair
    var pipe_read_fds: [i32] = []
    var pipe_write_fds: [i32] = []

    var i: u64 = 0
    while i < stages.len() - 1:
        # posix_pipe expects addresses to write i32 FDs
        var read_fd_buf: [i32] = [0]
        var write_fd_buf: [i32] = [0]
        val read_addr = unsafe_addr_of(read_fd_buf)
        val write_addr = unsafe_addr_of(write_fd_buf)
        val result = posix_pipe(read_addr, write_addr)
        if result < 0:
            # Clean up already-created pipes
            _close_pipe_fds(pipe_read_fds, pipe_write_fds)
            return -1
        pipe_read_fds = pipe_read_fds.push(read_fd_buf[0])
        pipe_write_fds = pipe_write_fds.push(write_fd_buf[0])
        i = i + 1

    # Spawn each stage with appropriate FD redirections
    var pids: [i64] = []
    i = 0
    while i < stages.len():
        val stage_cmd = stages[i]
        val argv = _split_simple(stage_cmd)
        if argv.len() == 0:
            i = i + 1
            pids = pids.push(-1)
            continue

        val cmd_path = argv[0]
        var cmd_args: [text] = []
        var ai: u64 = 1
        while ai < argv.len():
            cmd_args = cmd_args.push(argv[ai])
            ai = ai + 1

        # Set up stdin redirect: stage 0 uses terminal stdin,
        # all others use the read end of the previous pipe
        if i > 0:
            # Redirect stdin to pipe[i-1] read end
            posix_dup2(pipe_read_fds[i - 1], 0)

        # Set up stdout redirect: last stage uses terminal stdout,
        # all others use the write end of the current pipe
        if i < stages.len() - 1:
            # Redirect stdout to pipe[i] write end
            posix_dup2(pipe_write_fds[i], 1)

        # Spawn the process
        val pid = posix_spawn_with_args(cmd_path, cmd_args, 2)
        pids = pids.push(pid)

        # Restore stdin/stdout in parent after spawn
        # (The dup2 above modified our own FD table; for a real OS
        #  we would fork first. Here the child inherits via spawn.)

        i = i + 1

    # Close all pipe FDs in the parent — children have inherited them
    _close_pipe_fds(pipe_read_fds, pipe_write_fds)

    # Wait for all stages to complete
    var last_exit: i64 = 0
    i = 0
    while i < pids.len():
        val pid = pids[i]
        if pid >= 0:
            val status = posix_waitpid(pid, 0)
            if i == pids.len() - 1:
                last_exit = status
        i = i + 1

    last_exit

# ============================================================================
# Internal Helpers
# ============================================================================

fn _close_pipe_fds(read_fds: [i32], write_fds: [i32]):
    """Close all pipe file descriptors."""
    var i: u64 = 0
    while i < read_fds.len():
        pipe_close_read(read_fds[i])
        i = i + 1
    i = 0
    while i < write_fds.len():
        pipe_close_write(write_fds[i])
        i = i + 1

fn _split_simple(input: text) -> [text]:
    """Simple whitespace split for pipeline stage commands.

    Handles single and double quotes, backslash escaping.
    """
    var tokens: [text] = []
    var current = ""
    var in_single_quote = false
    var in_double_quote = false
    var escaped = false

    for ch in input:
        if escaped:
            current = "{current}{ch}"
            escaped = false
        elif ch == "\\":
            escaped = true
        elif ch == "'" and not in_double_quote:
            in_single_quote = not in_single_quote
        elif ch == "\"" and not in_single_quote:
            in_double_quote = not in_double_quote
        elif ch == " " and not in_single_quote and not in_double_quote:
            if current != "":
                tokens = tokens.push(current)
                current = ""
        else:
            current = "{current}{ch}"

    if current != "":
        tokens = tokens.push(current)
    tokens
