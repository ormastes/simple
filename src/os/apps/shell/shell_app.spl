# Shell Application — Interactive Command Shell
#
# Interactive shell with built-in commands, environment variables,
# command history, pipe-like command parsing, job control, pipeline
# execution, file redirection, and async command support.
#
# MDSOC: feature dimension, shell layer

use common.ui.builder.{column, menubar, statusbar, text_widget, scroll, build_tree, with_flex}
use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use os.apps.terminal.terminal.{Terminal}
use os.kernel.types.fs_types.{DirEntry, FsNode, FsNodeKind}
use os.services.vfs.vfs.{VfsManager}
use os.services.vfs.vfs_async.{AsyncFilesystem}
use os.tools.tool_registry.{ToolRegistry, ToolEntry}
use os.userlib.process.{ProcessEntry, list_tasks, signal, kill, exit_}
use os.userlib.fs.{mount, unmount, mount_list}
use os.userlib.window.{WindowClient}
use common.window_protocol.window_protocol.{WM_EVENT_CLOSE}

extern fn serial_println(msg: text)
use os.userlib.system.{sysinfo, uptime, hostname}
use os.userlib.log.{read_recent}
use os.kernel.types.syscall_types.{SignalKind}
use os.apps.shell.shell_job.{JobTable, JobState, Job}
use os.apps.shell.shell_pipe.{parse_pipeline, has_pipeline, execute_pipeline}
use os.apps.shell.shell_redirect.{parse_redirects, apply_redirects, restore_redirects, ParsedCommand, SavedFd}
use os.apps.shell.shell_async.{spawn_command_async, spawn_command_bg, read_file_posix, read_file_async}
use os.apps.shell.shell_tools.{tool_touch, tool_head, tool_tail, tool_wc, tool_sort, tool_uniq, tool_which, tool_date, tool_true, tool_false, tool_tee, tool_ln, tool_chmod, tool_stat}
use os.tools.shell.cat.cat_tool.{tool_cat}
use os.tools.shell.ls.ls_tool.{tool_ls}
use os.tools.shell.echo.echo_tool.{tool_echo}
use os.tools.shell.grep.grep_tool.{tool_grep}
use os.tools.shell.find.find_tool.{tool_find}
use os.tools.shell.cut.cut_tool.{tool_cut}
use os.tools.shell.tr.tr_tool.{tool_tr}
use os.tools.shell.sed.sed_tool.{tool_sed}
use os.tools.shell.basename.basename_tool.{tool_basename}
use os.tools.shell.dirname.dirname_tool.{tool_dirname}
use os.tools.shell.sleep.sleep_tool.{tool_sleep}
use os.tools.shell.seq.seq_tool.{tool_seq}
use os.tools.shell.expr.expr_tool.{tool_expr}
use os.tools.shell.test.test_tool.{tool_test}
use os.tools.shell.xargs.xargs_tool.{tool_xargs}
use os.tools.shell.yes.yes_tool.{tool_yes}
use os.tools.shell.env.env_tool.{tool_env, tool_printenv}
use os.tools.shell.readlink.readlink_tool.{tool_readlink}
use os.tools.shell.mktemp.mktemp_tool.{tool_mktemp}
use os.tools.shell.diff.diff_tool.{tool_diff}
use os.tools.shell.patch.patch_tool.{tool_patch}
