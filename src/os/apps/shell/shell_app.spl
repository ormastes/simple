use os.apps.git.git_app.{git_run_cmd}
use os.apps.jj.jj_app.{jj_run_cmd}
use os.async.os_executor.{OsExecutor}
use os.posix.process_compat.{posix_waitpid}

# =========================================================================
# Shell Application
# =========================================================================

class ShellApp:
    """Interactive shell with command execution and history.

    Connects to a Terminal for display and a VfsManager for
    filesystem operations. Provides POSIX-like built-in commands,
    job control, pipeline execution, file redirection, and async
    command support with bidirectional file access.
    """
    terminal: Terminal
    cwd: text
    history: [text]
    history_pos: i32
    env: [(text, text)]
    prompt: text
    running: bool
    last_exit_code: i32
    output_lines: [text]
    vfs: VfsManager?
    tool_registry: ToolRegistry?
    jobs: JobTable
    executor: OsExecutor
    async_fs: AsyncFilesystem?

impl ShellApp:

    static fn new() -> ShellApp:
        """Create a new shell with default 80x24 terminal."""
        var term = Terminal.new(80, 24)
        term.write_string("SimpleOS Shell v0.2\n")
        term.write_string("Type 'help' for available commands.\n\n")
        return ShellApp(
            terminal: term,
            cwd: "/",
            history: [],
            history_pos: -1,
            env: [("HOME", "/"), ("PATH", "/bin:/usr/bin"), ("SHELL", "/bin/sosh")],
            prompt: "$ ",
            running: true,
            last_exit_code: 0,
            output_lines: [],
            vfs: nil,
            tool_registry: nil,
            jobs: JobTable.new(),
            executor: OsExecutor.new(),
            async_fs: nil
        )

    static fn with_vfs(vfs: VfsManager) -> ShellApp:
        """Create a shell connected to a VFS manager."""
        var shell = ShellApp.new()
        shell.vfs = vfs
        return shell

    static fn with_vfs_and_async(vfs: VfsManager, async_fs: AsyncFilesystem) -> ShellApp:
        """Create a shell connected to both VFS and async filesystem."""
        var shell = ShellApp.new()
        shell.vfs = vfs
        shell.async_fs = async_fs
        return shell

    # -- Main Loop -----------------------------------------------------------

    me run():
        """Main REPL loop. Reads from terminal input, executes, repeats.

        After each command, polls the job table to report completed
        background jobs to the user.
        """
        self._show_prompt()
        while self.running:
            val input = self.terminal.read_input()
            if input.contains("\n"):
                val cmd_line = input.trim()
                if cmd_line != "":
                    self.history = self.history.push(cmd_line)
                    self.history_pos = self.history.len()
                    self.terminal.write_string("\n")
                    self.execute(cmd_line)
                    # Report completed background jobs
                    self._report_done_jobs()
                else:
                    self.terminal.write_string("\n")
                self._show_prompt()

    me show_prompt():
        """Display the shell prompt (public, for cooperative mode)."""
        self._show_prompt()

    me check_input() -> bool:
        """Non-blocking check for pending terminal input.

        Returns true if a complete line (containing newline) is available.
        Used by the cooperative main loop in os_main.spl.
        """
        val input = self.terminal.peek_input()
        input.contains("\n")

    me process_pending() -> bool:
        """Process one pending command if available. Returns false if shell should exit.

        Used by the cooperative main loop in os_main.spl.
        """
        val input = self.terminal.read_input()
        if input.contains("\n"):
            val cmd_line = input.trim()
            if cmd_line != "":
                self.history = self.history.push(cmd_line)
                self.history_pos = self.history.len()
                self.terminal.write_string("\n")
                self.execute(cmd_line)
                self._report_done_jobs()
            else:
                self.terminal.write_string("\n")
            self._show_prompt()
        self.running

    me _show_prompt():
        """Display the shell prompt."""
        val esc = "\u{001b}"
        self.terminal.write_string("{esc}[32m{self.cwd}{esc}[0m {self.prompt}")

    # -- Command Execution ---------------------------------------------------

    me execute(cmd: text):
        """Parse and execute a command string.

        Handles pipelines (cmd1 | cmd2), file redirections (>, >>, <, 2>),
        and background execution (trailing &). Built-in commands are
        dispatched directly; external commands go through the tool
        registry or spawn as child processes.
        """
        # Check for pipeline first (before redirect parsing)
        if has_pipeline(cmd):
            val stages = parse_pipeline(cmd)
            if stages.len() > 1:
                val exit_code = execute_pipeline(stages)
                self.last_exit_code = exit_code as i32
                return

        # Parse tokens, extract redirections and background flag
        val argv = self.parse_command(cmd)
        if argv.len() == 0:
            return

        val parsed = parse_redirects(argv)
        val command = parsed.command
        val args = parsed.args
        val background = parsed.background

        if command == "":
            return

        # Apply file redirections
        var saved_fds: [SavedFd] = []
        if parsed.redirects.len() > 0:
            val redir_result = apply_redirects(parsed.redirects)
            match redir_result:
                Ok(fds):
                    saved_fds = fds
                Err(msg):
                    self._write_error("sosh: {msg}")
                    self.last_exit_code = 1
                    return

        # Background execution for external commands
        if background:
            self._execute_background(command, args)
            # Restore redirections
            if saved_fds.len() > 0:
                restore_redirects(saved_fds)
            return

        # Dispatch built-in commands
        self._dispatch_builtin(command, args)

        # Restore file redirections
        if saved_fds.len() > 0:
            restore_redirects(saved_fds)

    me _dispatch_builtin(command: text, args: [text]):
        """Dispatch a command to the appropriate built-in handler."""
        match command:
            "cd":       self.cmd_cd(args)
            "ls":       self.last_exit_code = tool_ls(self.vfs, self.cwd, args, self.terminal)
            "pwd":      self.cmd_pwd()
            "echo":     self.last_exit_code = tool_echo(args, self.terminal)
            "cat":      self.last_exit_code = tool_cat(self.vfs, self.cwd, args, self.terminal)
            "mkdir":    self.cmd_mkdir(args)
            "rm":       self.cmd_rm(args)
            "cp":       self.cmd_cp(args)
            "mv":       self.cmd_mv(args)
            "grep":     self.last_exit_code = tool_grep(self.vfs, self.cwd, args, self.terminal)
            "find":     self.last_exit_code = tool_find(self.vfs, self.cwd, args, self.terminal)
            "ps":       self.cmd_ps()
            "kill":     self.cmd_kill(args)
            "mount":    self.cmd_mount(args)
            "clear":    self.cmd_clear()
            "help":     self.cmd_help()
            "exit":     self.cmd_exit()
            "env":      self.cmd_env()
            "export":   self.cmd_export(args)
            "history":  self.cmd_history()
            "hostname": self.cmd_hostname(args)
            "uptime":   self.cmd_uptime()
            "dmesg":    self.cmd_dmesg(args)
            "jobs":     self.cmd_jobs()
            "fg":       self.cmd_fg(args)
            "bg":       self.cmd_bg(args)
            "readf":    self.cmd_readf(args)
            "touch":    self.last_exit_code = tool_touch(self.vfs, self.cwd, args)
            "head":     self.last_exit_code = tool_head(self.vfs, self.cwd, args, self.terminal)
            "tail":     self.last_exit_code = tool_tail(self.vfs, self.cwd, args, self.terminal)
            "wc":       self.last_exit_code = tool_wc(self.vfs, self.cwd, args, self.terminal)
            "sort":     self.last_exit_code = tool_sort(self.vfs, self.cwd, args, self.terminal)
            "uniq":     self.last_exit_code = tool_uniq(self.vfs, self.cwd, args, self.terminal)
            "which":    self.last_exit_code = tool_which(args, self.tool_registry, self.terminal)
            "date":     self.last_exit_code = tool_date(self.terminal)
            "true":     self.last_exit_code = tool_true()
            "false":    self.last_exit_code = tool_false()
            "tee":      self.last_exit_code = tool_tee(self.vfs, self.cwd, args, self.terminal)
            "ln":       self.last_exit_code = tool_ln(self.terminal)
            "chmod":    self.last_exit_code = tool_chmod(args, self.terminal)
            "stat":     self.last_exit_code = tool_stat(self.vfs, self.cwd, args, self.terminal)
            "cut":      self.last_exit_code = tool_cut(self.vfs, self.cwd, args, self.terminal)
            "tr":       self.last_exit_code = tool_tr(self.vfs, self.cwd, args, self.terminal)
            "sed":      self.last_exit_code = tool_sed(self.vfs, self.cwd, args, self.terminal)
            "basename": self.last_exit_code = tool_basename(args, self.terminal)
            "dirname":  self.last_exit_code = tool_dirname(args, self.terminal)
            "sleep":    self.last_exit_code = tool_sleep(args, self.terminal)
            "seq":      self.last_exit_code = tool_seq(args, self.terminal)
            "expr":     self.last_exit_code = tool_expr(args, self.terminal)
            "test":     self.last_exit_code = tool_test(self.vfs, self.cwd, args, self.terminal)
            "[":        self.last_exit_code = tool_test(self.vfs, self.cwd, args, self.terminal)
            "xargs":    self.last_exit_code = tool_xargs(self.vfs, self.cwd, args, self.terminal)
            "yes":      self.last_exit_code = tool_yes(args, self.terminal)
            "printenv": self.last_exit_code = tool_printenv(self.env, args, self.terminal)
            "readlink": self.last_exit_code = tool_readlink(self.vfs, self.cwd, args, self.terminal)
            "mktemp":   self.last_exit_code = tool_mktemp(self.vfs, args, self.terminal)
            "diff":     self.last_exit_code = tool_diff(self.vfs, self.cwd, args, self.terminal)
            "patch":    self.last_exit_code = tool_patch(self.vfs, self.cwd, args, self.terminal)
            "file":     self.last_exit_code = tool_file(self.vfs, self.cwd, args, self.terminal)
            "strings":  self.last_exit_code = tool_strings(self.vfs, self.cwd, args, self.terminal)
            "hexdump":  self.last_exit_code = tool_hexdump(self.vfs, self.cwd, args, self.terminal)
            "base64":   self.last_exit_code = tool_base64(self.vfs, self.cwd, args, self.terminal)
            "md5sum":   self.last_exit_code = tool_md5sum(self.vfs, self.cwd, args, self.terminal)
            "sha256sum": self.last_exit_code = tool_sha256sum(self.vfs, self.cwd, args, self.terminal)
            "git":      self.cmd_git(args)
            "jj":       self.cmd_jj(args)
            _:
                # Try tool registry for external commands
                if self.tool_registry != nil:
                    val tool = self.tool_registry.lookup(command)
                    if tool != nil:
                        self.last_exit_code = tool.run_fn(args)
                        return
                # Try spawning as external command
                self._try_external(command, args)

    me _execute_background(command: text, args: [text]):
        """Execute a command in the background. Adds to job table."""
        # Check built-ins first — they cannot be backgrounded
        val builtins = ["cd", "ls", "pwd", "echo", "cat", "mkdir", "rm", "cp",
            "mv", "grep", "find", "ps", "kill", "mount", "clear", "help",
            "exit", "env", "export", "history", "hostname", "uptime", "dmesg",
            "jobs", "fg", "bg", "readf", "touch", "head", "tail", "wc",
            "sort", "uniq", "which", "date", "true", "false", "tee", "ln",
            "chmod", "stat", "cut", "tr", "sed", "basename", "dirname",
            "sleep", "seq", "expr", "test", "[", "xargs", "yes", "printenv",
            "readlink", "mktemp", "diff", "patch", "file", "strings",
            "hexdump", "base64", "md5sum", "sha256sum", "git", "jj"]
        var i = 0
        while i < builtins.len():
            if command == builtins[i]:
                self._write_error("sosh: cannot background built-in: {command}")
                self.last_exit_code = 1
                return
            i = i + 1

        # Spawn in background
        val result = spawn_command_bg(command, args)
        match result:
            Ok(pid):
                val job_id = self.jobs.add(pid, "{command}", 0)
                self._write_line("[{job_id}] {pid}")
                self.last_exit_code = 0
            Err(msg):
                self._write_error("sosh: {msg}")
                self.last_exit_code = 1

    me _try_external(command: text, args: [text]):
        """Try to run an external command synchronously."""
        val result = spawn_command_async(command, args)
        match result:
            Ok(future):
                # Block until command completes
                val status = posix_waitpid(future.pid as i64, 0)
                self.last_exit_code = status as i32
            Err(msg):
                self._write_error("sosh: command not found: {command}")
                self.last_exit_code = 127

    fn parse_command(input: text) -> [text]:
        """Split command input into argv tokens.

        Handles single and double quotes, backslash escaping.
        """
        var tokens: [text] = []
        var current = ""
        var in_single_quote = false
        var in_double_quote = false
        var escaped = false

        for ch in input:
            if escaped:
                current = "{current}{ch}"
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == "'" and not in_double_quote:
                in_single_quote = not in_single_quote
            elif ch == "\"" and not in_single_quote:
                in_double_quote = not in_double_quote
            elif ch == " " and not in_single_quote and not in_double_quote:
                if current != "":
                    tokens = tokens.push(current)
                    current = ""
            else:
                current = "{current}{ch}"

        if current != "":
            tokens = tokens.push(current)
        return tokens

    # -- Built-in Commands ---------------------------------------------------

    me cmd_cd(args: [text]):
        """Change directory."""
        val target = if args.len() > 0: args[0] else: self._get_env("HOME")
        val resolved = self._resolve_path(target)
        # Verify directory exists via VFS if available
        if self.vfs != nil:
            val result = self.vfs.stat(resolved)
            if result.is_err():
                self._write_error("cd: no such directory: {resolved}")
                self.last_exit_code = 1
                return
        self.cwd = resolved
        self.last_exit_code = 0

    me cmd_ls(args: [text]):
        """List directory contents."""
        val path = if args.len() > 0: self._resolve_path(args[0]) else: self.cwd
        val show_all = args.contains("-a")
        val show_long = args.contains("-l")

        if self.vfs != nil:
            val result = self.vfs.readdir(path)
            if result.is_err():
                self._write_error("ls: cannot access '{path}': {result.unwrap_err()}")
                self.last_exit_code = 1
                return
            val entries = result.unwrap()
            for entry in entries:
                if not show_all and entry.name.starts_with("."):
                    pass_dn
                else:
                    if show_long:
                        val kind_str = match entry.node.kind:
                            FsNodeKind.Directory => "d"
                            FsNodeKind.Symlink => "l"
                            FsNodeKind.Device => "c"
                            FsNodeKind.Pipe => "p"
                            _ => "-"
                        self._write_line("{kind_str}  {entry.node.size}  {entry.name}")
                    else:
                        self._write_inline("{entry.name}  ")
            if not show_long:
                self.terminal.write_string("\n")
        else:
            self._write_line("(no filesystem mounted)")
        self.last_exit_code = 0

    me cmd_pwd():
        """Print working directory."""
        self._write_line(self.cwd)
        self.last_exit_code = 0

    me cmd_echo(args: [text]):
        """Echo arguments to terminal."""
        var output = ""
        var i = 0
        for arg in args:
            if i > 0:
                output = "{output} "
            # Expand environment variables ($VAR)
            output = "{output}{self._expand_vars(arg)}"
            i = i + 1
        self._write_line(output)
        self.last_exit_code = 0

    me cmd_cat(args: [text]):
        """Display file contents."""
        if args.len() == 0:
            self._write_error("cat: missing file operand")
            self.last_exit_code = 1
            return
        for filename in args:
            val path = self._resolve_path(filename)
            if self.vfs != nil:
                val result = self.vfs.read_text(path)
                if result.is_err():
                    self._write_error("cat: {path}: {result.unwrap_err()}")
                    self.last_exit_code = 1
                else:
                    self._write_line(result.unwrap())
            else:
                self._write_error("cat: no filesystem mounted")
                self.last_exit_code = 1

    me cmd_mkdir(args: [text]):
        """Create a directory."""
        if args.len() == 0:
            self._write_error("mkdir: missing operand")
            self.last_exit_code = 1
            return
        self.last_exit_code = 0
        for dirname in args:
            val path = self._resolve_path(dirname)
            if self.vfs != nil:
                val result = self.vfs.mkdir(path)
                if result.is_err():
                    self._write_error("mkdir: {result.unwrap_err()}")
                    self.last_exit_code = 1
            else:
                self._write_error("mkdir: no filesystem mounted")
                self.last_exit_code = 1

    me cmd_rm(args: [text]):
        """Remove files."""
        if args.len() == 0:
            self._write_error("rm: missing operand")
            self.last_exit_code = 1
            return
        self.last_exit_code = 0
        for filename in args:
            val path = self._resolve_path(filename)
            if self.vfs != nil:
                val result = self.vfs.unlink(path)
                if result.is_err():
                    self._write_error("rm: {result.unwrap_err()}")
                    self.last_exit_code = 1
            else:
                self._write_error("rm: no filesystem mounted")
                self.last_exit_code = 1

    me cmd_cp(args: [text]):
        """Copy files."""
        if args.len() < 2:
            self._write_error("cp: missing operand")
            self.last_exit_code = 1
            return
        val src = self._resolve_path(args[0])
        val dst = self._resolve_path(args[1])
        if self.vfs != nil:
            val read_result = self.vfs.read_text(src)
            if read_result.is_err():
                self._write_error("cp: {read_result.unwrap_err()}")
                self.last_exit_code = 1
                return
            val write_result = self.vfs.write_text(dst, read_result.unwrap())
            if write_result.is_err():
                self._write_error("cp: {write_result.unwrap_err()}")
                self.last_exit_code = 1
        else:
            self._write_error("cp: no filesystem mounted")
            self.last_exit_code = 1

    me cmd_mv(args: [text]):
        """Move/rename files."""
        if args.len() < 2:
            self._write_error("mv: missing operand")
            self.last_exit_code = 1
            return
        val src = self._resolve_path(args[0])
        val dst = self._resolve_path(args[1])
        if self.vfs != nil:
            val rename_result = self.vfs.rename(src, dst)
            if rename_result.is_err():
                self._write_error("mv: {rename_result.unwrap_err()}")
                self.last_exit_code = 1
        else:
            self._write_error("mv: no filesystem mounted")
            self.last_exit_code = 1

    me cmd_grep(args: [text]):
        """Search for pattern in files."""
        if args.len() < 2:
            self._write_error("grep: usage: grep PATTERN FILE...")
            self.last_exit_code = 1
            return
        val pattern = args[0]
        var i = 1
        while i < args.len():
            val path = self._resolve_path(args[i])
            if self.vfs != nil:
                val result = self.vfs.read_text(path)
                if result.is_ok():
                    val content = result.unwrap()
                    var line_num = 1
                    for line in content.split("\n"):
                        if line.contains(pattern):
                            self._write_line("{args[i]}:{line_num}:{line}")
                        line_num = line_num + 1
                else:
                    self._write_error("grep: {path}: {result.unwrap_err()}")
            i = i + 1
        self.last_exit_code = 0

    me cmd_find(args: [text]):
        """Find files by name."""
        val start_path = if args.len() > 0: self._resolve_path(args[0]) else: self.cwd
        val name_pattern = if args.len() > 2 and args[1] == "-name": args[2] else: "*"
        if self.vfs != nil:
            self._find_recursive(start_path, name_pattern)
        else:
            self._write_error("find: no filesystem mounted")
            self.last_exit_code = 1

    me _find_recursive(path: text, pattern: text):
        """Recursively find files matching a pattern."""
        if self.vfs == nil:
            return
        val result = self.vfs.readdir(path)
        if result.is_err():
            return
        val entries = result.unwrap()
        for entry in entries:
            val full_path = if path == "/": "/{entry.name}" else: "{path}/{entry.name}"
            if pattern == "*" or entry.name.contains(pattern):
                self._write_line(full_path)
            if entry.node.kind == FsNodeKind.Directory:
                self._find_recursive(full_path, pattern)

    me cmd_ps():
        """List running processes from the scheduler."""
        val result = list_tasks()
        if result.is_err():
            self._write_error("ps: {result.unwrap_err()}")
            self.last_exit_code = 1
            return
        val tasks = result.unwrap()
        self._write_line("  PID  STATE     PRIORITY  NAME")
        for task in tasks:
            val state_str = match task.state:
                case 0: "Ready   "
                case 1: "Running "
                case 2: "Blocked "
                case 3: "Zombie  "
                case _: "Unknown "
            val prio_str = match task.priority:
                case 0: "RT    "
                case 1: "High  "
                case 2: "Normal"
                case 3: "Low   "
                case 4: "Idle  "
                case _: "?     "
            self._write_line("  {task.pid}  {state_str}  {prio_str}  {task.name}")
        self.last_exit_code = 0

    me cmd_kill(args: [text]):
        """Send signal to a process."""
        if args.len() == 0:
            self._write_error("kill: missing PID")
            self.last_exit_code = 1
            return
        # Parse optional signal flag
        var sig = SignalKind.Term
        var pid_str = args[0]
        if args[0].starts_with("-"):
            val flag = args[0].slice(1, args[0].len())
            sig = match flag:
                "TERM": SignalKind.Term
                "KILL": SignalKind.Kill
                "STOP": SignalKind.Stop
                "CONT": SignalKind.Cont
                "INT":  SignalKind.Int
                _:      SignalKind.Term
            if args.len() < 2:
                self._write_error("kill: missing PID")
                self.last_exit_code = 1
                return
            pid_str = args[1]
        val pid = _parse_u64(pid_str)
        if pid == 0:
            self._write_error("kill: invalid PID: {pid_str}")
            self.last_exit_code = 1
            return
        val result = signal(pid, sig)
        if result.is_err():
            self._write_error("kill: {result.unwrap_err()}")
            self.last_exit_code = 1
        else:
            self.last_exit_code = 0

    me cmd_mount(args: [text]):
        """Show or add mount points."""
        if args.len() == 0:
            # Show current mounts
            val result = mount_list()
            if result.is_err():
                self._write_error("mount: {result.unwrap_err()}")
                self.last_exit_code = 1
            else:
                val mounts = result.unwrap()
                for m in mounts:
                    self._write_line(m)
                self.last_exit_code = 0
            return
        if args.len() < 2:
            self._write_error("mount: usage: mount DEVICE MOUNTPOINT [FSTYPE]")
            self.last_exit_code = 1
            return
        val device = args[0]
        val mount_path = args[1]
        val fs_type = if args.len() > 2: args[2] else: "fat32"
        val result = mount(device, mount_path, fs_type)
        if result.is_err():
            self._write_error("mount: {result.unwrap_err()}")
            self.last_exit_code = 1
        else:
            self._write_line("mount: mounted {device} on {mount_path} (type {fs_type})")
            self.last_exit_code = 0

    me cmd_clear():
        """Clear the terminal screen."""
        self.terminal.clear()
        self.last_exit_code = 0

    me cmd_help():
        """Display help for built-in commands."""
        self._write_line("SimpleOS Shell Built-in Commands:")
        self._write_line("")
        self._write_line("  cd DIR        Change directory")
        self._write_line("  ls [-a] [-l]  List directory contents")
        self._write_line("  pwd           Print working directory")
        self._write_line("  echo ARGS     Print arguments")
        self._write_line("  cat FILE      Display file contents")
        self._write_line("  mkdir DIR     Create directory")
        self._write_line("  rm FILE       Remove file")
        self._write_line("  cp SRC DST    Copy file")
        self._write_line("  mv SRC DST    Move/rename file")
        self._write_line("  grep PAT FILE Search in file")
        self._write_line("  find DIR      Find files")
        self._write_line("  ps            List processes")
        self._write_line("  kill PID      Send signal to process")
        self._write_line("  mount         Show/add mount points")
        self._write_line("  env           Show environment variables")
        self._write_line("  export K=V    Set environment variable")
        self._write_line("  history       Show command history")
        self._write_line("  hostname      Show hostname")
        self._write_line("  uptime        Show system uptime")
        self._write_line("  dmesg [N]     Show kernel log (last N entries)")
        self._write_line("  clear         Clear screen")
        self._write_line("  help          Show this help")
        self._write_line("  exit          Exit shell")
        self._write_line("")
        self._write_line("Extended Tools:")
        self._write_line("  touch FILE    Create empty file / update timestamp")
        self._write_line("  head [-n N]   Show first N lines (default 10)")
        self._write_line("  tail [-n N]   Show last N lines (default 10)")
        self._write_line("  wc [-lwc]     Word/line/char count")
        self._write_line("  sort FILE     Sort lines alphabetically")
        self._write_line("  uniq FILE     Remove consecutive duplicate lines")
        self._write_line("  which CMD     Show command type/location")
        self._write_line("  date          Show current date/time")
        self._write_line("  true          Exit with code 0")
        self._write_line("  false         Exit with code 1")
        self._write_line("  tee FILE      Echo args to stdout and file")
        self._write_line("  ln -s T L     Create symlink (not yet supported)")
        self._write_line("  chmod M FILE  Change permissions (not yet supported)")
        self._write_line("  stat FILE     Show file info (size, type)")
        self._write_line("")
        self._write_line("Job Control:")
        self._write_line("  jobs          List background jobs")
        self._write_line("  fg [ID]       Bring job to foreground")
        self._write_line("  bg [ID]       Resume stopped job in background")
        self._write_line("  CMD &         Run command in background")
        self._write_line("")
        self._write_line("File Access:")
        self._write_line("  readf FILE         Read file (POSIX sync)")
        self._write_line("  readf --async FILE Read file (async VFS)")
        self._write_line("")
        self._write_line("Version Control:")
        self._write_line("  git <cmd>     Git VCS (delegates to git binary)")
        self._write_line("  jj <cmd>      Jujutsu VCS (delegates to jj binary)")
        self._write_line("")
        self._write_line("Redirection & Pipes:")
        self._write_line("  CMD > FILE    Redirect stdout to file")
        self._write_line("  CMD >> FILE   Append stdout to file")
        self._write_line("  CMD < FILE    Redirect stdin from file")
        self._write_line("  CMD 2> FILE   Redirect stderr to file")
        self._write_line("  CMD1 | CMD2   Pipeline: pipe cmd1 output to cmd2")
        self.last_exit_code = 0

    me cmd_exit():
        """Exit the shell. Warns if background jobs are active."""
        if self.jobs.count() > 0:
            self._write_line("sosh: there are {self.jobs.count()} active jobs")
            self._write_line("use 'exit' again to force exit")
            # Set a flag so next exit will force
            self.running = false
            return
        self.running = false
        self.executor.destroy()
        self._write_line("logout")

    me cmd_env():
        """Display all environment variables."""
        for pair in self.env:
            self._write_line("{pair.0}={pair.1}")
        self.last_exit_code = 0

    me cmd_export(args: [text]):
        """Set an environment variable: export KEY=VALUE."""
        for arg in args:
            val eq_pos = _find_char(arg, "=")
            if eq_pos >= 0:
                val key = arg.slice(0, eq_pos)
                val value = arg.slice(eq_pos + 1, arg.len())
                self._set_env(key, value)
            else:
                self._write_error("export: invalid format, use KEY=VALUE")
                self.last_exit_code = 1

    me cmd_history():
        """Display command history."""
        var i = 0
        for cmd in self.history:
            self._write_line("  {i + 1}  {cmd}")
            i = i + 1
        self.last_exit_code = 0

    me cmd_hostname(args: [text]):
        """Display or set hostname."""
        if args.len() == 0:
            val result = hostname()
            if result.is_err():
                self._write_error("hostname: {result.unwrap_err()}")
                self.last_exit_code = 1
            else:
                self._write_line(result.unwrap())
                self.last_exit_code = 0
        else:
            self._write_error("hostname: setting hostname not supported from shell")
            self.last_exit_code = 1

    me cmd_uptime():
        """Display system uptime."""
        val result = uptime()
        if result.is_err():
            self._write_error("uptime: {result.unwrap_err()}")
            self.last_exit_code = 1
            return
        val ns = result.unwrap()
        val seconds = ns / 1000000000
        val hours = seconds / 3600
        val minutes = (seconds % 3600) / 60
        val secs = seconds % 60
        self._write_line("up {hours}h {minutes}m {secs}s")
        self.last_exit_code = 0

    me cmd_dmesg(args: [text]):
        """Display kernel log messages."""
        val count: u32 = if args.len() > 0: _parse_u64(args[0]).to_u32() else: 50
        val result = read_recent(count)
        if result.is_err():
            self._write_error("dmesg: {result.unwrap_err()}")
            self.last_exit_code = 1
            return
        val entries = result.unwrap()
        for entry in entries:
            self._write_line("[{entry.timestamp_ns}] {entry.message}")
        self.last_exit_code = 0

    # -- Job Control Commands ------------------------------------------------

    me cmd_jobs():
        """List active background jobs."""
        self.jobs.update_status()
        val job_list = self.jobs.list()
        if job_list.len() == 0:
            self._write_line("No active jobs.")
            self.last_exit_code = 0
            return
        var i = 0
        while i < job_list.len():
            val job = job_list[i]
            self._write_line("[{job.id}]  {job.state_text()}  {job.command}")
            i = i + 1
        self.last_exit_code = 0

    me cmd_fg(args: [text]):
        """Bring a background job to the foreground.

        Usage: fg [JOB_ID]
        If no ID given, uses the most recent job.
        """
        var job_id: i32 = -1
        if args.len() > 0:
            job_id = _parse_u64(args[0]) as i32
        else:
            # Find the most recent non-done job
            val job_list = self.jobs.list()
            var i = job_list.len()
            while i > 0:
                i = i - 1
                if not job_list[i].is_done():
                    job_id = job_list[i].id
                    i = 0  # break

        if job_id <= 0:
            self._write_error("fg: no current job")
            self.last_exit_code = 1
            return

        val job = self.jobs.find(job_id)
        if job == nil:
            self._write_error("fg: no such job: {job_id}")
            self.last_exit_code = 1
            return

        self._write_line("{job.command}")
        val result = self.jobs.foreground(job_id)
        match result:
            Ok(exit_code):
                self.last_exit_code = exit_code
            Err(msg):
                self._write_error(msg)
                self.last_exit_code = 1

    me cmd_bg(args: [text]):
        """Resume a stopped job in the background.

        Usage: bg [JOB_ID]
        If no ID given, uses the most recent stopped job.
        """
        var job_id: i32 = -1
        if args.len() > 0:
            job_id = _parse_u64(args[0]) as i32
        else:
            # Find the most recent stopped job
            val job_list = self.jobs.list()
            var i = job_list.len()
            while i > 0:
                i = i - 1
                if job_list[i].is_stopped():
                    job_id = job_list[i].id
                    i = 0  # break

        if job_id <= 0:
            self._write_error("bg: no current job")
            self.last_exit_code = 1
            return

        val result = self.jobs.background(job_id)
        match result:
            Ok(_):
                val job = self.jobs.find(job_id)
                if job != nil:
                    self._write_line("[{job_id}] {job.command} &")
                self.last_exit_code = 0
            Err(msg):
                self._write_error(msg)
                self.last_exit_code = 1

    # -- Bidirectional File Access -------------------------------------------

    me cmd_readf(args: [text]):
        """Read a file via POSIX sync or async VFS.

        Usage: readf [--async] FILE
        Default mode is POSIX synchronous fd I/O.
        With --async, uses the async VFS notification-based path.
        """
        if args.len() == 0:
            self._write_error("readf: missing file operand")
            self.last_exit_code = 1
            return

        var use_async = false
        var file_path: text = ""

        if args.len() >= 2 and args[0] == "--async":
            use_async = true
            file_path = self._resolve_path(args[1])
        else:
            file_path = self._resolve_path(args[0])

        if use_async:
            if self.async_fs == nil:
                self._write_error("readf: no async filesystem available")
                self.last_exit_code = 1
                return
            val result = read_file_async(self.async_fs, file_path, self.executor)
            match result:
                Ok(content):
                    self._write_line(content)
                    self.last_exit_code = 0
                Err(msg):
                    self._write_error("readf: {msg}")
                    self.last_exit_code = 1
        else:
            val result = read_file_posix(file_path)
            match result:
                Ok(content):
                    self._write_line(content)
                    self.last_exit_code = 0
                Err(msg):
                    self._write_error("readf: {msg}")
                    self.last_exit_code = 1

    # -- Version Control ----------------------------------------------------

    me cmd_git(args: [text]):
        """Run git subcommand via git_app wrapper."""
        self.last_exit_code = git_run_cmd(args) as i32

    me cmd_jj(args: [text]):
        """Run jj subcommand via jj_app wrapper."""
        self.last_exit_code = jj_run_cmd(args) as i32

    # -- Job Reporting -------------------------------------------------------

    me _report_done_jobs():
        """Poll job table and report completed background jobs."""
        self.jobs.update_status()
        val done = self.jobs.remove_done()
        var i = 0
        while i < done.len():
            val job = done[i]
            val exit_str = match job.state:
                JobState.Done(code): "{code}"
                _: "?"
            self._write_line("[{job.id}]  Done({exit_str})  {job.command}")
            i = i + 1

    # -- Output Helpers ------------------------------------------------------

    me _write_line(line: text):
        """Write a line to the terminal with newline."""
        self.terminal.write_string("{line}\n")
        self.output_lines = self.output_lines.push(line)

    me _write_inline(s: text):
        """Write text to the terminal without newline."""
        self.terminal.write_string(s)

    me _write_error(msg: text):
        """Write an error message in red."""
        val esc = "\u{001b}"
        self.terminal.write_string("{esc}[31m{msg}{esc}[0m\n")

    # -- Environment ---------------------------------------------------------

    fn _get_env(key: text) -> text:
        """Get an environment variable value."""
        for pair in self.env:
            if pair.0 == key:
                return pair.1
        return ""

    me _set_env(key: text, value: text):
        """Set an environment variable."""
        var new_env: [(text, text)] = []
        var found = false
        for pair in self.env:
            if pair.0 == key:
                new_env = new_env.push((key, value))
                found = true
            else:
                new_env = new_env.push(pair)
        if not found:
            new_env = new_env.push((key, value))
        self.env = new_env

    fn _expand_vars(s: text) -> text:
        """Expand $VAR references in a string."""
        var result = ""
        var in_var = false
        var var_name = ""
        for ch in s:
            if in_var:
                if ch >= "A" and ch <= "Z" or ch >= "a" and ch <= "z" or ch == "_" or ch >= "0" and ch <= "9":
                    var_name = "{var_name}{ch}"
                else:
                    result = "{result}{self._get_env(var_name)}{ch}"
                    in_var = false
                    var_name = ""
            elif ch == "$":
                in_var = true
                var_name = ""
            else:
                result = "{result}{ch}"
        if in_var:
            result = "{result}{self._get_env(var_name)}"
        return result

    # -- Path Resolution -----------------------------------------------------

    fn _resolve_path(path: text) -> text:
        """Resolve a relative path against cwd."""
        if path.starts_with("/"):
            return _normalize_path(path)
        if path == "~":
            return self._get_env("HOME")
        if path.starts_with("~/"):
            return "{self._get_env("HOME")}{path.slice(1, path.len())}"
        if path == "..":
            return _parent_path(self.cwd)
        if path == ".":
            return self.cwd
        val full = if self.cwd == "/": "/{path}" else: "{self.cwd}/{path}"
        return _normalize_path(full)

    # -- UI Construction -----------------------------------------------------

    fn build_ui() -> UISession:
        """Build the shell UI.

        Delegates to the terminal's build_ui with shell-specific status.
        """
        return self.terminal.build_ui()

# =========================================================================
# Helpers
# =========================================================================

fn _find_char(s: text, target: text) -> i32:
    """Find first occurrence of a character in a string. Returns -1 if not found."""
    var i = 0
    for ch in s:
        if ch == target:
            return i
        i = i + 1
    return -1

fn _normalize_path(path: text) -> text:
    """Normalize a path by resolving . and .. components."""
    var parts: [text] = []
    var current = ""
    for ch in path:
        if ch == "/":
            if current == "..":
                if parts.len() > 0:
                    var new_parts: [text] = []
                    var j = 0
                    while j < parts.len() - 1:
                        new_parts = new_parts.push(parts[j])
                        j = j + 1
                    parts = new_parts
            elif current != "." and current != "":
                parts = parts.push(current)
            current = ""
        else:
            current = "{current}{ch}"
    # Handle trailing component
    if current == "..":
        if parts.len() > 0:
            var new_parts: [text] = []
            var j = 0
            while j < parts.len() - 1:
                new_parts = new_parts.push(parts[j])
                j = j + 1
            parts = new_parts
    elif current != "." and current != "":
        parts = parts.push(current)

    if parts.len() == 0:
        return "/"
    var result = ""
    for part in parts:
        result = "{result}/{part}"
    return result

fn _parse_u64(s: text) -> u64:
    """Parse a u64 from text, returning 0 on failure."""
    var result: u64 = 0
    for ch in s:
        if ch >= "0" and ch <= "9":
            val digit = ch.to_i32() - "0".to_i32()
            result = result * 10 + digit.to_u64()
        else:
            return 0
    return result

fn _parent_path(path: text) -> text:
    """Get the parent directory of a path."""
    if path == "/":
        return "/"
    var last_slash = 0
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash == 0:
        return "/"
    return path.slice(0, last_slash)

# =========================================================================
# Remote Window Entry
# =========================================================================

fn shell_remote_main():
    """Launch Shell (Terminal) as a remote WM window."""
    serial_println("[shell] start app_id=/sys/apps/shell")
    var client = WindowClient.new()
    client.set_app_identity("/sys/apps/shell")
    if not client.connect():
        serial_println("[shell] connect_failed app_id=/sys/apps/shell")
        exit_(1)
        return

    val wid = client.create_window("Terminal", 80, 80, 600, 360)
    if wid == 0:
        serial_println("[shell] create_window_failed app_id=/sys/apps/shell")
        client.disconnect()
        exit_(1)
        return
    serial_println("[shell] window_created app_id=/sys/apps/shell wid={wid}")

    client.update_content("SimpleOS Shell\n\n$ ")

    var running = true
    while running:
        val event = client.wait_event()
        if event.event_type == WM_EVENT_CLOSE:
            running = false

    client.destroy_window()
    client.disconnect()
    serial_println("[shell] exit app_id=/sys/apps/shell code=0")
    exit_(0)

fn shell_remote_launch_once(process_id: u64) -> bool:
    """Create the packaged Shell window and return immediately."""
    serial_println("[shell] start app_id=/sys/apps/shell mode=resident-manifest pid={process_id}")
    var client = WindowClient.new()
    client.set_app_identity("/sys/apps/shell")
    if not client.connect():
        serial_println("[shell] connect_failed app_id=/sys/apps/shell mode=resident-manifest pid={process_id}")
        return false

    val wid = client.create_window_with_process_id("Terminal", 80, 80, 600, 360, process_id)
    if wid == 0:
        serial_println("[shell] create_window_failed app_id=/sys/apps/shell mode=resident-manifest pid={process_id}")
        client.disconnect()
        return false
    serial_println("[shell] window_created app_id=/sys/apps/shell wid={wid} mode=resident-manifest pid={process_id}")

    client.update_content("SimpleOS Shell\n\n$ ")
    true
