# =========================================================================
# Shell Application
# =========================================================================

class ShellApp:
    """Interactive shell with command execution and history.

    Connects to a Terminal for display and a VfsManager for
    filesystem operations. Provides POSIX-like built-in commands,
    job control, pipeline execution, file redirection, and async
    command support with bidirectional file access.
    """
    terminal: Terminal
    cwd: text
    history: [text]
    history_pos: i32
    env: [(text, text)]
    prompt: text
    running: bool
    last_exit_code: i32
    output_lines: [text]
    vfs: VfsManager?
    tool_registry: ToolRegistry?
    jobs: JobTable
    executor: OsExecutor
    async_fs: AsyncFilesystem?
    variables: [(text, text)]
    aliases: [(text, text)]
    shell_functions: [(text, text)]
    capture_mode: bool
    capture_lines: [text]
    exit_on_error: bool

impl ShellApp:

    static fn new() -> ShellApp:
        """Create a new shell with default 80x24 terminal."""
        var term = Terminal.new(80, 24)
        term.write_string("SimpleOS Shell v0.2\n")
        term.write_string("Type 'help' for available commands.\n\n")
        return ShellApp(
            terminal: term,
            cwd: "/",
            history: [],
            history_pos: -1,
            env: [("HOME", "/"), ("PATH", "/bin:/usr/bin"), ("SHELL", "/bin/sosh")],
            prompt: "$ ",
            running: true,
            last_exit_code: 0,
            output_lines: [],
            vfs: nil,
            tool_registry: nil,
            jobs: JobTable.new(),
            executor: OsExecutor.new(),
            async_fs: nil,
            variables: [],
            aliases: [
                ("rg", "grep"),
                ("fd", "find"),
                ("fdfind", "find"),
                ("bat", "cat"),
                ("batcat", "cat"),
                ("eza", "ls"),
                ("ag", "grep"),
            ],
            shell_functions: [],
            capture_mode: false,
            capture_lines: [],
            exit_on_error: false,
        )

    static fn with_vfs(vfs: VfsManager) -> ShellApp:
        """Create a shell connected to a VFS manager."""
        var shell = ShellApp.new()
        shell.vfs = vfs
        return shell

    static fn with_vfs_and_async(vfs: VfsManager, async_fs: AsyncFilesystem) -> ShellApp:
        """Create a shell connected to both VFS and async filesystem."""
        var shell = ShellApp.new()
        shell.vfs = vfs
        shell.async_fs = async_fs
        return shell

    # -- Main Loop -----------------------------------------------------------

    me run():
        """Main REPL loop. Reads from terminal input, executes, repeats.

        After each command, polls the job table to report completed
        background jobs to the user.
        """
        self._show_prompt()
        while self.running:
            val input = self.terminal.read_input()
            if input.contains("\n"):
                val cmd_line = input.trim()
                if cmd_line != "":
                    self.history = self.history.push(cmd_line)
                    self.history_pos = self.history.len()
                    self.terminal.write_string("\n")
                    self.execute(cmd_line)
                    # Report completed background jobs
                    self._report_done_jobs()
                else:
                    self.terminal.write_string("\n")
                self._show_prompt()

    me show_prompt():
        """Display the shell prompt (public, for cooperative mode)."""
        self._show_prompt()

    me feed_remote_input(input: text) -> bool:
        """Feed transport text into the shell and process complete lines."""
        for ch in input:
            self.terminal.feed_remote_input(ch)
            if self.check_input():
                if not self.process_pending():
                    return false
        self.running

    fn take_remote_output() -> text:
        """Drain terminal output produced since the last call."""
        self.terminal.take_mirrored_output()

    me check_input() -> bool:
        """Non-blocking check for pending terminal input.

        Returns true if a complete line (containing newline) is available.
        Used by the cooperative main loop in os_main.spl.
        """
        val input = self.terminal.peek_input()
        input.contains("\n")

    me process_pending() -> bool:
        """Process one pending command if available. Returns false if shell should exit.

        Used by the cooperative main loop in os_main.spl.
        """
        val input = self.terminal.read_input()
        if input.contains("\n"):
            val cmd_line = input.trim()
            if cmd_line != "":
                self.history = self.history.push(cmd_line)
                self.history_pos = self.history.len()
                self.terminal.write_string("\n")
                self.execute(cmd_line)
                self._report_done_jobs()
            else:
                self.terminal.write_string("\n")
            self._show_prompt()
        self.running

    me _show_prompt():
        """Display the shell prompt."""
        val ctx = ShellContext.from_fields(self.cwd, self.last_exit_code, self.env, self.vfs, self.jobs.count())
        val prompt_str = StarshipPrompt.new().build_prompt(ctx, 0)
        self.terminal.write_string(prompt_str)

    # -- Command Execution ---------------------------------------------------

    me execute(cmd: text):
        """Parse and execute a command string.

        Handles pipelines (cmd1 | cmd2), file redirections (>, >>, <, 2>),
        and background execution (trailing &). Built-in commands are
        dispatched directly; external commands go through the tool
        registry or spawn as child processes.
        """
        # Handle && and || command chaining
        if cmd.contains(" && ") or cmd.contains(" || "):
            self._execute_chain(cmd)
            return

        # Check for pipeline first (before redirect parsing)
        if has_pipeline(cmd):
            val stages = parse_pipeline(cmd)
            if stages.len() > 1:
                val exit_code = execute_pipeline(stages)
                self.last_exit_code = exit_code as i32
                return

        # Parse tokens, extract redirections and background flag
        val argv = self.parse_command(cmd)
        if argv.len() == 0:
            return

        val parsed = parse_redirects(argv)
        val command = parsed.command
        val args = parsed.args
        val background = parsed.background

        if command == "":
            return

        # Apply file redirections
        var saved_fds: [SavedFd] = []
        if parsed.redirects.len() > 0:
            val redir_result = apply_redirects(parsed.redirects)
            match redir_result:
                Ok(fds):
                    saved_fds = fds
                Err(msg):
                    self._write_error("sosh: {msg}")
                    self.last_exit_code = 1
                    return

        # Background execution for external commands
        if background:
            self._execute_background(command, args)
            # Restore redirections
            if saved_fds.len() > 0:
                restore_redirects(saved_fds)
            return

        # Built-ins stay in-process; everything else routes through launcher.
        if self._is_builtin_command(command):
            self._dispatch_builtin(command, args)
        else:
            self._try_external(command, args)

        # Exit on error if set -e is active
        if self.exit_on_error and self.last_exit_code != 0:
            self.running = false

        # Restore file redirections
        if saved_fds.len() > 0:
            restore_redirects(saved_fds)

    me _dispatch_builtin(command: text, args: [text]):
        """Dispatch a command to the appropriate built-in handler."""
        match command:
            "cd":       self.cmd_cd(args)
            "ls":       self.last_exit_code = tool_ls(self.vfs, self.cwd, args, self.terminal)
            "list":     self.last_exit_code = tool_ls(self.vfs, self.cwd, args, self.terminal)
            "pwd":      self.cmd_pwd()
            "echo":     self.last_exit_code = tool_echo(args, self.terminal)
            "cat":      self.last_exit_code = tool_cat(self.vfs, self.cwd, args, self.terminal)
            "mkdir":    self.cmd_mkdir(args)
            "rm":       self.cmd_rm(args)
            "cp":       self.cmd_cp(args)
            "mv":       self.cmd_mv(args)
            "grep":     self.last_exit_code = tool_grep(self.vfs, self.cwd, args, self.terminal)
            "find":     self.last_exit_code = tool_find(self.vfs, self.cwd, args, self.terminal)
            "ps":       self.cmd_ps()
            "kill":     self.cmd_kill(args)
            "run":      self.cmd_run(args)
            "mount":    self.cmd_mount(args)
            "clear":    self.cmd_clear()
            "help":     self.cmd_help()
            "exit":     self.cmd_exit()
            "env":      self.cmd_env()
            "export":   self.cmd_export(args)
            "history":  self.cmd_history()
            "hostname": self.cmd_hostname(args)
            "uptime":   self.cmd_uptime()
            "dmesg":    self.cmd_dmesg(args)
            "mem":      self.cmd_mem(args)
            "reboot":   self.cmd_reboot(args)
            "jobs":     self.cmd_jobs()
            "fg":       self.cmd_fg(args)
            "bg":       self.cmd_bg(args)
            "readf":    self.cmd_readf(args)
            "touch":    self.last_exit_code = tool_touch(self.vfs, self.cwd, args)
            "head":     self.last_exit_code = tool_head(self.vfs, self.cwd, args, self.terminal)
            "tail":     self.last_exit_code = tool_tail(self.vfs, self.cwd, args, self.terminal)
            "wc":       self.last_exit_code = tool_wc(self.vfs, self.cwd, args, self.terminal)
            "sort":     self.last_exit_code = tool_sort(self.vfs, self.cwd, args, self.terminal)
            "uniq":     self.last_exit_code = tool_uniq(self.vfs, self.cwd, args, self.terminal)
            "which":    self.last_exit_code = tool_which(self.vfs, self.cwd, self._get_env("PATH"), args, self.tool_registry, self.terminal)
            "date":     self.last_exit_code = tool_date(self.terminal)
            "uname":    self.last_exit_code = tool_uname(args, self.terminal)
            "cmake":    self.last_exit_code = tool_cmake(self.vfs, self.cwd, self.env, args, self.terminal)
            "ninja":    self.last_exit_code = tool_ninja(self.vfs, self.cwd, self.env, args, self.terminal)
            "true":     self.last_exit_code = tool_true()
            "false":    self.last_exit_code = tool_false()
            "tee":      self.last_exit_code = tool_tee(self.vfs, self.cwd, args, self.terminal)
            "ln":       self.last_exit_code = tool_ln(self.vfs, self.cwd, args, self.terminal)
            "chmod":    self.last_exit_code = tool_chmod(self.vfs, self.cwd, args, self.terminal)
            "stat":     self.last_exit_code = tool_stat(self.vfs, self.cwd, args, self.terminal)
            "cut":      self.last_exit_code = tool_cut(self.vfs, self.cwd, args, self.terminal)
            "tr":       self.last_exit_code = tool_tr(self.vfs, self.cwd, args, self.terminal)
            "sed":      self.last_exit_code = tool_sed(self.vfs, self.cwd, args, self.terminal)
            "basename": self.last_exit_code = tool_basename(args, self.terminal)
            "dirname":  self.last_exit_code = tool_dirname(args, self.terminal)
            "sleep":    self.last_exit_code = tool_sleep(args, self.terminal)
            "seq":      self.last_exit_code = tool_seq(args, self.terminal)
            "expr":     self.last_exit_code = tool_expr(args, self.terminal)
            "test":     self.last_exit_code = tool_test(self.vfs, self.cwd, args, self.terminal)
            "[":        self.last_exit_code = tool_test(self.vfs, self.cwd, args, self.terminal)
            "xargs":    self.last_exit_code = tool_xargs(self.vfs, self.cwd, args, self.terminal)
            "yes":      self.last_exit_code = tool_yes(args, self.terminal)
            "printenv": self.last_exit_code = tool_printenv(self.env, args, self.terminal)
            "readlink": self.last_exit_code = tool_readlink(self.vfs, self.cwd, args, self.terminal)
            "mktemp":   self.last_exit_code = tool_mktemp(self.vfs, args, self.terminal)
            "diff":     self.last_exit_code = tool_diff(self.vfs, self.cwd, args, self.terminal)
            "patch":    self.last_exit_code = tool_patch(self.vfs, self.cwd, args, self.terminal)
            "file":     self.last_exit_code = tool_file(self.vfs, self.cwd, args, self.terminal)
            "strings":  self.last_exit_code = tool_strings(self.vfs, self.cwd, args, self.terminal)
            "hexdump":  self.last_exit_code = tool_hexdump(self.vfs, self.cwd, args, self.terminal)
            "base64":   self.last_exit_code = tool_base64(self.vfs, self.cwd, args, self.terminal)
            "md5sum":   self.last_exit_code = tool_md5sum(self.vfs, self.cwd, args, self.terminal)
            "sha256sum": self.last_exit_code = tool_sha256sum(self.vfs, self.cwd, args, self.terminal)
            "git":      self.cmd_git(args)
            "jj":       self.cmd_jj(args)
            "source":   self.cmd_source(args)
            ".":        self.cmd_source(args)
            "read":     self.cmd_read(args)
            "printf":   self.last_exit_code = builtin_printf(self.terminal, args)
            "alias":    self.cmd_alias(args)
            "unalias":  self.cmd_unalias(args)
            "shift":    self.cmd_shift(args)
            "trap":     self.cmd_trap(args)
            "wait":     self.cmd_wait(args)
            "break":    self.last_exit_code = -1
            "continue": self.last_exit_code = -2
            "return":   self.cmd_return(args)
            "set":      self.cmd_set(args)
            "mkfifo":   self.cmd_mkfifo(args)
            "awk":      self.last_exit_code = tool_awk(self.vfs, self.cwd, args, self.terminal)
            "tac":      self.last_exit_code = tool_tac(self.vfs, self.cwd, args, self.terminal)
            "rev":      self.last_exit_code = tool_rev(self.vfs, self.cwd, args, self.terminal)
            "nl":       self.last_exit_code = tool_nl(self.vfs, self.cwd, args, self.terminal)
            "fold":     self.last_exit_code = tool_fold(self.vfs, self.cwd, args, self.terminal)
            "column":   self.last_exit_code = tool_column(self.vfs, self.cwd, args, self.terminal)
            "paste":    self.last_exit_code = tool_paste(self.vfs, self.cwd, args, self.terminal)
            "comm":     self.last_exit_code = tool_comm(self.vfs, self.cwd, args, self.terminal)
            "join":     self.last_exit_code = tool_join(self.vfs, self.cwd, args, self.terminal)
            "od":       self.last_exit_code = tool_od(self.vfs, self.cwd, args, self.terminal)
            "bc":       self.last_exit_code = tool_bc(self.vfs, self.cwd, args, self.terminal)
            "factor":   self.last_exit_code = tool_factor(self.vfs, self.cwd, args, self.terminal)
            "shuf":     self.last_exit_code = tool_shuf(self.vfs, self.cwd, args, self.terminal)
            "numfmt":   self.last_exit_code = tool_numfmt(self.vfs, self.cwd, args, self.terminal)
            "tree":     self.last_exit_code = tool_tree(self.vfs, self.cwd, args, self.terminal)
            "less":     self.last_exit_code = tool_less(self.vfs, self.cwd, args, self.terminal)
            _:
                self.last_exit_code = 127

    fn _is_builtin_command(command: text) -> bool:
        """Return true when the shell should handle the command in-process."""
        match command:
            "cd": true
            "ls": true
            "list": true
            "pwd": true
            "echo": true
            "cat": true
            "mkdir": true
            "rm": true
            "cp": true
            "mv": true
            "grep": true
            "find": true
            "ps": true
            "kill": true
            "run": true
            "mount": true
            "clear": true
            "help": true
            "exit": true
            "env": true
            "export": true
            "history": true
            "hostname": true
            "uptime": true
            "dmesg": true
            "mem": true
            "reboot": true
            "jobs": true
            "fg": true
            "bg": true
            "readf": true
            "touch": true
            "head": true
            "tail": true
            "wc": true
            "sort": true
            "uniq": true
            "which": true
            "date": true
            "uname": true
            "cmake": true
            "ninja": true
            "true": true
            "false": true
            "tee": true
            "ln": true
            "chmod": true
            "stat": true
            "cut": true
            "tr": true
            "sed": true
            "basename": true
            "dirname": true
            "sleep": true
            "seq": true
            "expr": true
            "test": true
            "[": true
            "xargs": true
            "yes": true
            "printenv": true
            "readlink": true
            "mktemp": true
            "diff": true
            "patch": true
            "file": true
            "strings": true
            "hexdump": true
            "base64": true
            "md5sum": true
            "sha256sum": true
            "git": true
            "jj": true
            "source": true
            ".": true
            "read": true
            "printf": true
            "alias": true
            "unalias": true
            "shift": true
            "trap": true
            "wait": true
            "break": true
            "continue": true
            "return": true
            "set": true
            "mkfifo": true
            "awk": true
            "tac": true
            "rev": true
            "nl": true
            "fold": true
            "column": true
            "paste": true
            "comm": true
            "join": true
            "od": true
            "bc": true
            "factor": true
            "shuf": true
            "numfmt": true
            "tree": true
            "less": true
            _: false

    me _execute_background(command: text, args: [text]):
        """Execute a command in the background. Adds to job table."""
        # Built-ins cannot be backgrounded because they mutate shell state.
        if self._is_builtin_command(command):
            self._write_error("sosh: cannot background built-in: {command}")
            self.last_exit_code = 1
            return

        # Spawn in background
        val result = spawn_command_bg(command, args, self.cwd, self._get_env("PATH"))
        match result:
            Ok(pid):
                val job_id = self.jobs.add(pid, "{command}", 0)
                self._write_line("[{job_id}] {pid}")
                self.last_exit_code = 0
            Err(msg):
                self._write_error("sosh: {msg}")
                self.last_exit_code = 1

    me _execute_chain(cmd: text):
        """Execute a command chain: cmd1 && cmd2 (stop on failure) or cmd1 || cmd2 (stop on success)."""
        # Split into segments with their operators
        # We process left to right
        var remaining = cmd
        var last_op = "&&"  # Start assuming && (first segment always runs)
        var first = true
        while remaining.len() > 0:
            var segment = remaining
            var next_op = ""
            var next_remaining = ""
            val and_pos = _find_chain_op(remaining, " && ")
            val or_pos = _find_chain_op(remaining, " || ")
            if and_pos >= 0 and (or_pos < 0 or and_pos < or_pos):
                segment = remaining.slice(0, and_pos)
                next_op = "&&"
                next_remaining = remaining.slice(and_pos + 4, remaining.len())
            elif or_pos >= 0:
                segment = remaining.slice(0, or_pos)
                next_op = "||"
                next_remaining = remaining.slice(or_pos + 4, remaining.len())
            # else: segment = remaining, loop ends after

            val run = if first: true
                      elif last_op == "&&": self.last_exit_code == 0
                      else: self.last_exit_code != 0
            if run:
                self.execute(segment.trim())
            first = false
            last_op = next_op
            remaining = next_remaining

    me _try_external(command: text, args: [text]):
        """Try to run an external command synchronously."""
        val toolchain_shim = tool_try_staged_toolchain(
            self.vfs, self.cwd, self._get_env("PATH"), command, args, self.terminal)
        if toolchain_shim != nil:
            self.last_exit_code = toolchain_shim.unwrap()
            return

        val result = spawn_command_async(command, args, self.cwd, self._get_env("PATH"))
        match result:
            Ok(future):
                # Block until command completes
                val status = posix_waitpid(future.pid as i64, 0)
                self.last_exit_code = status as i32
            Err(msg):
                self._write_error("sosh: command not found: {command}")
                self.last_exit_code = 127

    fn parse_command(input: text) -> [text]:
        """Split command input into argv tokens.

        Handles single and double quotes, backslash escaping.
        """
        var tokens: [text] = []
        var current = ""
        var in_single_quote = false
        var in_double_quote = false
        var escaped = false

        for ch in input:
            if escaped:
                current = "{current}{ch}"
                escaped = false
            elif ch == "\\":
                escaped = true
            elif ch == "'" and not in_double_quote:
                in_single_quote = not in_single_quote
            elif ch == "\"" and not in_single_quote:
                in_double_quote = not in_double_quote
            elif ch == " " and not in_single_quote and not in_double_quote:
                if current != "":
                    tokens = tokens.push(current)
                    current = ""
            else:
                current = "{current}{ch}"

        if current != "":
            tokens = tokens.push(current)
        return tokens

    # -- Built-in Commands ---------------------------------------------------

    me cmd_cd(args: [text]):
        """Change directory."""
        val target = if args.len() > 0: args[0] else: self._get_env("HOME")
        val resolved = self._resolve_path(target)
        # Verify directory exists via VFS if available
        if self.vfs != nil:
            val result = self.vfs.stat(resolved)
            if result.is_err():
                self._write_error("cd: no such directory: {resolved}")
                self.last_exit_code = 1
                return
        self.cwd = resolved
        self.last_exit_code = 0

    me cmd_ls(args: [text]):
        """List directory contents."""
        self.last_exit_code = tool_ls(self.vfs, self.cwd, args, self.terminal)

    me cmd_pwd():
        """Print working directory."""
        self._write_line(self.cwd)
        self.last_exit_code = 0

    me cmd_echo(args: [text]):
        """Echo arguments to terminal."""
        var output = ""
        var i = 0
        for arg in args:
            if i > 0:
                output = "{output} "
            # Expand environment variables ($VAR)
            output = "{output}{self._expand_vars(arg)}"
            i = i + 1
        self._write_line(output)
        self.last_exit_code = 0

    me cmd_cat(args: [text]):
        """Display file contents."""
        if args.len() == 0:
            self._write_error("cat: missing file operand")
            self.last_exit_code = 1
            return
        for filename in args:
            val path = self._resolve_path(filename)
            if self.vfs != nil:
                val result = self.vfs.read_text(path)
                if result.is_err():
                    self._write_error("cat: {path}: {result.unwrap_err()}")
                    self.last_exit_code = 1
                else:
                    self._write_line(result.unwrap())
            else:
                self._write_error("cat: no filesystem mounted")
                self.last_exit_code = 1

    me cmd_mkdir(args: [text]):
        """Create a directory."""
        if args.len() == 0:
            self._write_error("mkdir: missing operand")
            self.last_exit_code = 1
            return
        var create_parents = false
        var paths: [text] = []
        for arg in args:
            if arg == "-p":
                create_parents = true
            else:
                paths = paths.push(arg)
        if paths.len() == 0:
            self._write_error("mkdir: missing operand")
            self.last_exit_code = 1
            return
        self.last_exit_code = 0
        for dirname in paths:
            val path = self._resolve_path(dirname)
            if self.vfs != nil:
                val result = if create_parents: self._mkdir_with_parents(path) else: self.vfs.mkdir(path)
                if result.is_err():
                    self._write_error("mkdir: {result.unwrap_err()}")
                    self.last_exit_code = 1
            else:
                self._write_error("mkdir: no filesystem mounted")
                self.last_exit_code = 1

    me cmd_rm(args: [text]):
        """Remove files."""
        if args.len() == 0:
            self._write_error("rm: missing operand")
            self.last_exit_code = 1
            return
        var recursive = false
        var force = false
        var paths: [text] = []
        for arg in args:
            if arg == "-r" or arg == "-R":
                recursive = true
            elif arg == "-f":
                force = true
            elif arg == "-rf" or arg == "-fr":
                recursive = true
                force = true
            else:
                paths = paths.push(arg)
        if paths.len() == 0:
            self._write_error("rm: missing operand")
            self.last_exit_code = 1
            return
        self.last_exit_code = 0
        for filename in paths:
            val path = self._resolve_path(filename)
            if self.vfs != nil:
                val result = self._remove_path(path, recursive, force)
                if result.is_err():
                    self._write_error("rm: {result.unwrap_err()}")
                    self.last_exit_code = 1
            else:
                self._write_error("rm: no filesystem mounted")
                self.last_exit_code = 1

    me cmd_cp(args: [text]):
        """Copy files."""
        if args.len() < 2:
            self._write_error("cp: missing operand")
            self.last_exit_code = 1
            return
        var recursive = false
        var operands: [text] = []
        for arg in args:
            if arg == "-r" or arg == "-R":
                recursive = true
            else:
                operands = operands.push(arg)
        if operands.len() < 2:
            self._write_error("cp: missing operand")
            self.last_exit_code = 1
            return
        val src = self._resolve_path(operands[0])
        val dst = self._resolve_path(operands[1])
        if self.vfs != nil:
            val copy_result = self._copy_path(src, dst, recursive)
            if copy_result.is_err():
                self._write_error("cp: {copy_result.unwrap_err()}")
                self.last_exit_code = 1
            else:
                self.last_exit_code = 0
        else:
            self._write_error("cp: no filesystem mounted")
            self.last_exit_code = 1

    me cmd_mv(args: [text]):
        """Move/rename files."""
        if args.len() < 2:
            self._write_error("mv: missing operand")
            self.last_exit_code = 1
            return
        val src = self._resolve_path(args[0])
        val dst = self._resolve_path(args[1])
        if self.vfs != nil:
            val rename_result = self.vfs.rename(src, dst)
            if rename_result.is_err():
                self._write_error("mv: {rename_result.unwrap_err()}")
                self.last_exit_code = 1
        else:
            self._write_error("mv: no filesystem mounted")
            self.last_exit_code = 1

    me cmd_grep(args: [text]):
        """Search for pattern in files."""
        if args.len() < 2:
            self._write_error("grep: usage: grep PATTERN FILE...")
            self.last_exit_code = 1
            return
        val pattern = args[0]
        var i = 1
        while i < args.len():
            val path = self._resolve_path(args[i])
            if self.vfs != nil:
                val result = self.vfs.read_text(path)
                if result.is_ok():
                    val content = result.unwrap()
                    var line_num = 1
                    for line in split_lines(content):
                        if line.contains(pattern):
                            self._write_line("{args[i]}:{line_num}:{line}")
                        line_num = line_num + 1
                else:
                    self._write_error("grep: {path}: {result.unwrap_err()}")
            i = i + 1
        self.last_exit_code = 0

    me cmd_find(args: [text]):
        """Find files by name."""
        self.last_exit_code = tool_find(self.vfs, self.cwd, args, self.terminal)

    me cmd_ps():
        """List running processes from the scheduler."""
        val result = list_tasks()
        if result.is_err():
            self._write_error("ps: {result.unwrap_err()}")
            self.last_exit_code = 1
            return
        val tasks = result.unwrap()
        self._write_line("  PID  STATE     PRIORITY  NAME")
        for task in tasks:
            val state_str = match task.state:
                case 0: "Ready   "
                case 1: "Running "
                case 2: "Blocked "
                case 3: "Zombie  "
                case _: "Unknown "
            val prio_str = match task.priority:
                case 0: "RT    "
                case 1: "High  "
                case 2: "Normal"
                case 3: "Low   "
                case 4: "Idle  "
                case _: "?     "
            self._write_line("  {task.pid}  {state_str}  {prio_str}  {task.name}")
        self.last_exit_code = 0

    me cmd_kill(args: [text]):
        """Send signal to a process."""
        if args.len() == 0:
            self._write_error("kill: missing PID")
            self.last_exit_code = 1
            return
        # Parse optional signal flag
        var sig = SignalKind.Term
        var pid_str = args[0]
        if args[0].starts_with("-"):
            val flag = args[0].slice(1, args[0].len())
            sig = match flag:
                "TERM": SignalKind.Term
                "KILL": SignalKind.Kill
                "STOP": SignalKind.Stop
                "CONT": SignalKind.Cont
                "INT":  SignalKind.Int
                _:      SignalKind.Term
            if args.len() < 2:
                self._write_error("kill: missing PID")
                self.last_exit_code = 1
                return
            pid_str = args[1]
        val pid = _parse_u64(pid_str)
        if pid == 0:
            self._write_error("kill: invalid PID: {pid_str}")
            self.last_exit_code = 1
            return
        val result = signal(pid, sig)
        if result.is_err():
            self._write_error("kill: {result.unwrap_err()}")
            self.last_exit_code = 1
        else:
            self.last_exit_code = 0

    me cmd_run(args: [text]):
        """Run an external command through the launcher path."""
        if args.len() == 0:
            self._write_error("run: missing command")
            self.last_exit_code = 1
            return
        if args[0] == "--help":
            self._write_line("usage: run CMD [ARGS...]")
            self.last_exit_code = 0
            return

        val command = args[0]
        var cmd_args: [text] = []
        var i = 1
        while i < args.len():
            cmd_args = cmd_args.push(args[i])
            i = i + 1

        val result = spawn_command_async(command, cmd_args, self.cwd, self._get_env("PATH"))
        match result:
            Ok(future):
                val status = posix_waitpid(future.pid as i64, 0)
                self.last_exit_code = status as i32
            Err(msg):
                self._write_error("run: {msg}")
                self.last_exit_code = 1

    me cmd_mount(args: [text]):
        """Show or add mount points."""
        if args.len() == 0:
            # Show current mounts
            val result = mount_list()
            if result.is_err():
                self._write_error("mount: {result.unwrap_err()}")
                self.last_exit_code = 1
            else:
                val mounts = result.unwrap()
                for m in mounts:
                    self._write_line(m)
                self.last_exit_code = 0
            return
        if args.len() < 2:
            self._write_error("mount: usage: mount DEVICE MOUNTPOINT [FSTYPE]")
            self.last_exit_code = 1
            return
        val device = args[0]
        val mount_path = args[1]
        val fs_type = if args.len() > 2: args[2] else: "fat32"
        val result = mount(device, mount_path, fs_type)
        if result.is_err():
            self._write_error("mount: {result.unwrap_err()}")
            self.last_exit_code = 1
        else:
            self._write_line("mount: mounted {device} on {mount_path} (type {fs_type})")
            self.last_exit_code = 0

    me cmd_clear():
        """Clear the terminal screen."""
        self.terminal.clear()
        self.last_exit_code = 0

    me cmd_help():
        """Display help for built-in commands."""
        self._write_line("SimpleOS Shell Built-in Commands:")
        self._write_line("")
        self._write_line("  cd DIR        Change directory")
        self._write_line("  ls/list [-a] [-l] List directory contents")
        self._write_line("  pwd           Print working directory")
        self._write_line("  echo ARGS     Print arguments")
        self._write_line("  cat FILE      Display file contents")
        self._write_line("  mkdir DIR     Create directory")
        self._write_line("  rm FILE       Remove file")
        self._write_line("  cp SRC DST    Copy file")
        self._write_line("  mv SRC DST    Move/rename file")
        self._write_line("  grep PAT FILE Search in file")
        self._write_line("  find [PATH] [-name PATTERN] Find files")
        self._write_line("  ps            List processes")
        self._write_line("  kill PID      Send signal to process")
        self._write_line("  run CMD       Run an external command")
        self._write_line("  mem           Show memory information")
        self._write_line("  reboot        Request a system restart")
        self._write_line("  mount         Show/add mount points")
        self._write_line("  env           Show environment variables")
        self._write_line("  export K=V    Set environment variable")
        self._write_line("  history       Show command history")
        self._write_line("  hostname      Show hostname")
        self._write_line("  uptime        Show system uptime")
        self._write_line("  dmesg [N]     Show kernel log (last N entries)")
        self._write_line("  clear         Clear screen")
        self._write_line("  help          Show this help")
        self._write_line("  exit          Exit shell")
        self._write_line("")
        self._write_line("Extended Tools:")
        self._write_line("  touch FILE    Create empty file / update timestamp")
        self._write_line("  head [-n N]   Show first N lines (default 10)")
        self._write_line("  tail [-n N]   Show last N lines (default 10)")
        self._write_line("  wc [-lwc]     Word/line/char count")
        self._write_line("  sort FILE     Sort lines alphabetically")
        self._write_line("  uniq FILE     Remove consecutive duplicate lines")
        self._write_line("  which CMD     Show command type/location")
        self._write_line("  date          Show current date/time")
        self._write_line("  true          Exit with code 0")
        self._write_line("  false         Exit with code 1")
        self._write_line("  tee FILE      Echo args to stdout and file")
        self._write_line("  ln -s T L     Create symlink")
        self._write_line("  chmod M FILE  Change permissions")
        self._write_line("  stat FILE     Show file info (size, type)")
        self._write_line("")
        self._write_line("Job Control:")
        self._write_line("  jobs          List background jobs")
        self._write_line("  fg [ID]       Bring job to foreground")
        self._write_line("  bg [ID]       Resume stopped job in background")
        self._write_line("  CMD &         Run command in background")
        self._write_line("")
        self._write_line("File Access:")
        self._write_line("  readf FILE         Read file (POSIX sync)")
        self._write_line("  readf --async FILE Read file (async VFS)")
        self._write_line("")
        self._write_line("Version Control:")
        self._write_line("  git <cmd>     Git VCS (delegates to git binary)")
        self._write_line("  jj <cmd>      Jujutsu VCS (delegates to jj binary)")
        self._write_line("")
        self._write_line("Redirection & Pipes:")
        self._write_line("  CMD > FILE    Redirect stdout to file")
        self._write_line("  CMD >> FILE   Append stdout to file")
        self._write_line("  CMD < FILE    Redirect stdin from file")
        self._write_line("  CMD 2> FILE   Redirect stderr to file")
        self._write_line("  CMD1 | CMD2   Pipeline: pipe cmd1 output to cmd2")
        self.last_exit_code = 0

    me cmd_exit():
        """Exit the shell. Warns if background jobs are active."""
        if self.jobs.count() > 0:
            self._write_line("sosh: there are {self.jobs.count()} active jobs")
            self._write_line("use 'exit' again to force exit")
            # Set a flag so next exit will force
            self.running = false
            return
        self.running = false
        self.executor.destroy()
        self._write_line("logout")

    me cmd_env():
        """Display all environment variables."""
        for pair in self.env:
            self._write_line("{pair.0}={pair.1}")
        self.last_exit_code = 0

    me cmd_export(args: [text]):
        """Set an environment variable: export KEY=VALUE."""
        self.last_exit_code = 0
        for arg in args:
            val eq_pos = _find_char(arg, "=")
            if eq_pos >= 0:
                val key = arg.slice(0, eq_pos)
                val value = arg.slice(eq_pos + 1, arg.len())
                self._set_env(key, value)
            else:
                self._write_error("export: invalid format, use KEY=VALUE")
                self.last_exit_code = 1

    fn _join_child_path(parent: text, child: text) -> text:
        if parent == "/":
            return "/{child}"
        "{parent}/{child}"

    fn _mkdir_with_parents(path: text) -> Result<bool, text>:
        if self.vfs == nil:
            return Result.Err("no filesystem mounted")
        var current = ""
        for part in path.split("/"):
            if part == "":
                continue
            current = if current == "": "/{part}" else: "{current}/{part}"
            val stat_result = self.vfs.stat(current)
            if stat_result.is_ok():
                val node = stat_result.unwrap()
                if node.kind != FsNodeKind.Directory:
                    return Result.Err("path exists and is not a directory: {current}")
                continue
            val mkdir_result = self.vfs.mkdir(current)
            if mkdir_result.is_err():
                return mkdir_result
        Result.Ok(true)

    fn _copy_path(src: text, dst: text, recursive: bool) -> Result<bool, text>:
        if self.vfs == nil:
            return Result.Err("no filesystem mounted")
        val stat_result = self.vfs.stat(src)
        if stat_result.is_err():
            return Result.Err(stat_result.unwrap_err())
        val node = stat_result.unwrap()
        if node.kind == FsNodeKind.Directory:
            if not recursive:
                return Result.Err("omitting directory '{src}'")
            self._mkdir_with_parents(dst)?
            val entries_result = self.vfs.readdir(src)
            if entries_result.is_err():
                return Result.Err(entries_result.unwrap_err())
            for entry in entries_result.unwrap():
                if entry.name == "." or entry.name == "..":
                    continue
                self._copy_path(self._join_child_path(src, entry.name), self._join_child_path(dst, entry.name), true)?
            return Result.Ok(true)

        val read_result = self.vfs.read_text(src)
        if read_result.is_err():
            return Result.Err(read_result.unwrap_err())
        val write_result = self.vfs.write_text(dst, read_result.unwrap())
        if write_result.is_err():
            return Result.Err(write_result.unwrap_err())
        Result.Ok(true)

    fn _remove_path(path: text, recursive: bool, force: bool) -> Result<bool, text>:
        if self.vfs == nil:
            return Result.Err("no filesystem mounted")
        val stat_result = self.vfs.stat(path)
        if stat_result.is_err():
            if force:
                return Result.Ok(true)
            return Result.Err(stat_result.unwrap_err())
        val node = stat_result.unwrap()
        if node.kind == FsNodeKind.Directory:
            if not recursive:
                return Result.Err("cannot remove '{path}': is a directory")
            val entries_result = self.vfs.readdir(path)
            if entries_result.is_err():
                return Result.Err(entries_result.unwrap_err())
            for entry in entries_result.unwrap():
                if entry.name == "." or entry.name == "..":
                    continue
                self._remove_path(self._join_child_path(path, entry.name), true, force)?
            return self.vfs.rmdir(path)
        self.vfs.unlink(path)

    me cmd_history():
        """Display command history."""
        var i = 0
        for cmd in self.history:
            self._write_line("  {i + 1}  {cmd}")
            i = i + 1
        self.last_exit_code = 0

    me cmd_hostname(args: [text]):
        """Display or set hostname."""
        if args.len() == 0:
            val result = hostname()
            if result.is_err():
                self._write_error("hostname: {result.unwrap_err()}")
                self.last_exit_code = 1
            else:
                self._write_line(result.unwrap())
                self.last_exit_code = 0
        else:
            self._write_error("hostname: setting hostname not supported from shell")
            self.last_exit_code = 1

    me cmd_uptime():
        """Display system uptime."""
        val result = uptime()
        if result.is_err():
            self._write_error("uptime: {result.unwrap_err()}")
            self.last_exit_code = 1
            return
        val ns = result.unwrap()
        val seconds = ns / 1000000000
        val hours = seconds / 3600
        val minutes = (seconds % 3600) / 60
        val secs = seconds % 60
        self._write_line("up {hours}h {minutes}m {secs}s")
        self.last_exit_code = 0

    me cmd_dmesg(args: [text]):
        """Display kernel log messages."""
        val count: u32 = if args.len() > 0: _parse_u64(args[0]).to_u32() else: 50
        val result = read_recent(count)
        if result.is_err():
            self._write_error("dmesg: {result.unwrap_err()}")
            self.last_exit_code = 1
            return
        val entries = result.unwrap()
        for entry in entries:
            self._write_line("[{entry.timestamp_ns}] {entry.message}")
        self.last_exit_code = 0

    me cmd_mem(args: [text]):
        """Display memory information."""
        if args.len() > 0 and args[0] == "--help":
            self._write_line("usage: mem")
            self.last_exit_code = 0
            return
        val result = mem_info()
        if result.is_err():
            self._write_error("mem: {result.unwrap_err()}")
            self.last_exit_code = 1
            return
        val info = result.unwrap()
        self._write_line("Memory: total={info.total_pages} pages free={info.free_pages} pages used={info.used_pages} pages size={info.page_size} bytes")
        self.last_exit_code = 0

    me cmd_reboot(args: [text]):
        """Validate a reboot request."""
        if args.len() > 0 and args[0] == "--help":
            self._write_line("usage: reboot")
            self.last_exit_code = 0
            return
        val result = reboot()
        if result.is_err():
            self._write_error("reboot: {result.unwrap_err()}")
            self.last_exit_code = 1
            return
        self.last_exit_code = 0

    # -- Job Control Commands ------------------------------------------------

    me cmd_jobs():
        """List active background jobs."""
        self.jobs.update_status()
        val job_list = self.jobs.list()
        if job_list.len() == 0:
            self._write_line("No active jobs.")
            self.last_exit_code = 0
            return
        var i = 0
        while i < job_list.len():
            val job = job_list[i]
            self._write_line("[{job.id}]  {job.state_text()}  {job.command}")
            i = i + 1
        self.last_exit_code = 0

    me cmd_fg(args: [text]):
        """Bring a background job to the foreground.

        Usage: fg [JOB_ID]
        If no ID given, uses the most recent job.
        """
        var job_id: i32 = -1
        if args.len() > 0:
            job_id = _parse_u64(args[0]) as i32
        else:
            # Find the most recent non-done job
            val job_list = self.jobs.list()
            var i = job_list.len()
            while i > 0:
                i = i - 1
                if not job_list[i].is_done():
                    job_id = job_list[i].id
                    i = 0  # break

        if job_id <= 0:
            self._write_error("fg: no current job")
            self.last_exit_code = 1
            return

        val job = self.jobs.find(job_id)
        if job == nil:
            self._write_error("fg: no such job: {job_id}")
            self.last_exit_code = 1
            return

        self._write_line("{job.command}")
        val result = self.jobs.foreground(job_id)
        match result:
            Ok(exit_code):
                self.last_exit_code = exit_code
            Err(msg):
                self._write_error(msg)
                self.last_exit_code = 1

    me cmd_bg(args: [text]):
        """Resume a stopped job in the background.

        Usage: bg [JOB_ID]
        If no ID given, uses the most recent stopped job.
        """
        var job_id: i32 = -1
        if args.len() > 0:
            job_id = _parse_u64(args[0]) as i32
        else:
            # Find the most recent stopped job
            val job_list = self.jobs.list()
            var i = job_list.len()
            while i > 0:
                i = i - 1
                if job_list[i].is_stopped():
                    job_id = job_list[i].id
                    i = 0  # break

        if job_id <= 0:
            self._write_error("bg: no current job")
            self.last_exit_code = 1
            return

        val result = self.jobs.background(job_id)
        match result:
            Ok(_):
                val job = self.jobs.find(job_id)
                if job != nil:
                    self._write_line("[{job_id}] {job.command} &")
                self.last_exit_code = 0
            Err(msg):
                self._write_error(msg)
                self.last_exit_code = 1

    # -- Bidirectional File Access -------------------------------------------

    me cmd_readf(args: [text]):
        """Report that the legacy bidirectional file helper is unavailable."""
        self._write_error("readf: unavailable in this build; use cat or shell redirection")
        self.last_exit_code = 1

    # -- Version Control ----------------------------------------------------

    me cmd_git(args: [text]):
        """Run git subcommand via git_app wrapper."""
        self.last_exit_code = git_run_cmd(args) as i32

    me cmd_jj(args: [text]):
        """Run jj subcommand via jj_app wrapper."""
        self.last_exit_code = jj_run_cmd(args) as i32

    # -- Job Reporting -------------------------------------------------------

    me _report_done_jobs():
        """Poll job table and report completed background jobs."""
        self.jobs.update_status()
        val done = self.jobs.remove_done()
        var i = 0
        while i < done.len():
            val job = done[i]
            val exit_str = match job.state:
                JobState.Done(code): "{code}"
                _: "?"
            self._write_line("[{job.id}]  Done({exit_str})  {job.command}")
            i = i + 1

    # -- Output Helpers ------------------------------------------------------

    me _write_line(line: text):
        """Write a line to the terminal with newline."""
        self.terminal.write_string("{line}\n")
        self.output_lines = self.output_lines.push(line)

    me _write_inline(s: text):
        """Write text to the terminal without newline."""
        self.terminal.write_string(s)

    me _write_error(msg: text):
        """Write an error message in red."""
        val esc = "\u{001b}"
        self.terminal.write_string("{esc}[31m{msg}{esc}[0m\n")

    # -- Environment ---------------------------------------------------------

    fn _get_env(key: text) -> text:
        """Get an environment variable value."""
        for pair in self.env:
            if pair.0 == key:
                return pair.1
        return ""

    me _set_env(key: text, value: text):
        """Set an environment variable."""
        var new_env: [(text, text)] = []
        var found = false
        for pair in self.env:
            if pair.0 == key:
                new_env = new_env.push((key, value))
                found = true
            else:
                new_env = new_env.push(pair)
        if not found:
            new_env = new_env.push((key, value))
        self.env = new_env

    fn _expand_vars(s: text) -> text:
        """Expand $VAR, $?, ${var:-default}, $0-$9, $@, $*, $# and $(cmd) in a string."""
        val pre = self._expand_cmd_substitution(s)
        return shell_expand(pre, self.variables, self.env, self.last_exit_code, [])

    fn _expand_cmd_substitution(s: text) -> text:
        """Pre-process $(cmd) and `cmd` command substitution before variable expansion."""
        var result = ""
        var i = 0
        while i < s.len():
            val ch = s.slice(i, i + 1)
            if ch == "$" and i + 1 < s.len() and s.slice(i + 1, i + 2) == "(":
                # Find matching closing )
                var depth = 1
                var j = i + 2
                while j < s.len() and depth > 0:
                    val jch = s.slice(j, j + 1)
                    if jch == "(":
                        depth = depth + 1
                    elif jch == ")":
                        depth = depth - 1
                    j = j + 1
                val inner = s.slice(i + 2, j - 1)
                val output = self.execute_capture(inner)
                result = "{result}{output}"
                i = j
            elif ch == "`":
                # Backtick substitution
                var j = i + 1
                while j < s.len() and s.slice(j, j + 1) != "`":
                    j = j + 1
                val inner = s.slice(i + 1, j)
                val output = self.execute_capture(inner)
                result = "{result}{output}"
                i = j + 1
            else:
                result = "{result}{ch}"
                i = i + 1
        return result

    fn execute_capture(cmd: text) -> text:
        """Execute cmd and return its stdout as text (for command substitution)."""
        val trimmed = cmd.trim()
        # Handle pure-compute cases directly — these are the most common in bootstrap scripts
        if trimmed == "pwd":
            return self.cwd
        if trimmed == "hostname":
            return self._get_env("HOSTNAME")
        if trimmed == "uname" or trimmed == "uname -s":
            return "SimpleOS"
        if trimmed == "uname -m":
            return "x86_64"
        if trimmed == "uname -r":
            return "0.1.0"
        if trimmed == "whoami":
            val user = self._get_env("USER")
            return if user == "": "root" else: user
        if trimmed == "date":
            return "Thu Jan  1 00:00:00 UTC 2026"
        if trimmed.starts_with("echo "):
            return trimmed.slice(5, trimmed.len()).trim()
        if trimmed.starts_with("dirname "):
            val path = _unquote_simple(trimmed.slice(8, trimmed.len()).trim())
            return _parent_path(path)
        if trimmed.starts_with("basename "):
            val path = _unquote_simple(trimmed.slice(9, trimmed.len()).trim())
            return _basename_of(path)
        # "cd dir && pwd" — common bootstrap pattern
        if trimmed.contains(" && pwd"):
            val cd_part = trimmed.slice(0, trimmed.len() - 7).trim()
            if cd_part.starts_with("cd "):
                val dir = _unquote_simple(cd_part.slice(3, cd_part.len()).trim())
                return self._resolve_path(dir)
        # Fallback: execute and capture via capture_lines
        val old_lines = self.capture_lines
        self.capture_lines = []
        self.capture_mode = true
        self.execute(trimmed)
        self.capture_mode = false
        var buf = ""
        for line in self.capture_lines:
            if buf == "":
                buf = line
            else:
                buf = "{buf}\n{line}"
        self.capture_lines = old_lines
        # Trim trailing newline
        if buf.ends_with("\n"):
            buf = buf.slice(0, buf.len() - 1)
        return buf

    # -- Path Resolution -----------------------------------------------------

    fn _resolve_path(path: text) -> text:
        """Resolve a relative path against cwd."""
        if path.starts_with("/"):
            return _normalize_path(path)
        if path == "~":
            return self._get_env("HOME")
        if path.starts_with("~/"):
            return "{self._get_env("HOME")}{path.slice(1, path.len())}"
        if path == "..":
            return _parent_path(self.cwd)
        if path == ".":
            return self.cwd
        val full = if self.cwd == "/": "/{path}" else: "{self.cwd}/{path}"
        return _normalize_path(full)

    fn cmd_source(args: [text]):
        """Source (execute) a shell script file."""
        if args.len() == 0:
            self.terminal.write_string("source: usage: source <file> [args...]\n")
            self.last_exit_code = 1
            return
        val path = self._resolve_path(args[0])
        var script_args: [text] = [args[0]]
        var i = 1
        while i < args.len():
            script_args = script_args.push(args[i])
            i = i + 1
        if self.vfs != nil:
            val result = self.vfs.read_text(path)
            if result.is_ok():
                self.execute_script_text(result.unwrap(), script_args)
            else:
                self.terminal.write_string("source: {path}: not found\n")
                self.last_exit_code = 1
        else:
            self.terminal.write_string("source: no filesystem\n")
            self.last_exit_code = 1

    fn execute_script_text(source: text, script_args: [text]):
        """Parse and execute shell script source text."""
        val engine = ScriptEngine.new()
        val stmts = engine.parse(source)
        var i = 0
        while i < stmts.len():
            self._execute_stmt(stmts[i], script_args)
            i = i + 1

    fn _execute_stmt(stmt: Stmt, script_args: [text]):
        """Execute a single parsed statement."""
        match stmt.kind:
            case StmtKind.Command:
                if stmt.args.len() > 0:
                    val raw_cmd = stmt.args[0]
                    val aliased = shell_apply_alias(raw_cmd, self.aliases)
                    var expanded = shell_expand(aliased, self.variables, self.env, self.last_exit_code, script_args)
                    var i = 1
                    while i < stmt.args.len():
                        expanded = "{expanded} {shell_expand(stmt.args[i], self.variables, self.env, self.last_exit_code, script_args)}"
                        i = i + 1
                    self.execute(expanded)
            case StmtKind.Assign:
                val key = stmt.var_name
                val value = shell_expand(stmt.args[0], self.variables, self.env, self.last_exit_code, script_args)
                var new_vars: [(text, text)] = []
                var found = false
                for pair in self.variables:
                    if pair.0 == key:
                        new_vars = new_vars.push((key, value))
                        found = true
                    else:
                        new_vars = new_vars.push(pair)
                if not found:
                    new_vars = new_vars.push((key, value))
                self.variables = new_vars
            case StmtKind.If:
                var executed = false
                for branch in stmt.branches:
                    val cond_expanded = shell_expand(branch.condition, self.variables, self.env, self.last_exit_code, script_args)
                    if cond_expanded != "" and cond_expanded != "0" and cond_expanded != "false":
                        self.execute_script_text(_join_lines(branch.body), script_args)
                        executed = true
                        break
                if not executed:
                    self.execute_script_text(_join_lines(stmt.else_body), script_args)
            case StmtKind.While:
                var keep_going = true
                while keep_going:
                    val cond = shell_expand(stmt.condition, self.variables, self.env, self.last_exit_code, script_args)
                    if cond == "" or cond == "0" or cond == "false":
                        keep_going = false
                    else:
                        self.execute_script_text(_join_lines(stmt.body), script_args)
                        if self.last_exit_code == -1:
                            self.last_exit_code = 0
                            keep_going = false
            case StmtKind.For:
                for item in stmt.items:
                    var new_vars2: [(text, text)] = []
                    var found2 = false
                    for pair in self.variables:
                        if pair.0 == stmt.var_name:
                            new_vars2 = new_vars2.push((stmt.var_name, item))
                            found2 = true
                        else:
                            new_vars2 = new_vars2.push(pair)
                    if not found2:
                        new_vars2 = new_vars2.push((stmt.var_name, item))
                    self.variables = new_vars2
                    self.execute_script_text(_join_lines(stmt.body), script_args)
                    if self.last_exit_code == -1:
                        self.last_exit_code = 0
                        break
            case StmtKind.FnDef:
                val fn_body = _join_lines(stmt.body)
                var new_fns: [(text, text)] = []
                var found3 = false
                for pair in self.shell_functions:
                    if pair.0 == stmt.var_name:
                        new_fns = new_fns.push((stmt.var_name, fn_body))
                        found3 = true
                    else:
                        new_fns = new_fns.push(pair)
                if not found3:
                    new_fns = new_fns.push((stmt.var_name, fn_body))
                self.shell_functions = new_fns
            case StmtKind.Source:
                self.cmd_source(stmt.args)
            case StmtKind.BreakStmt:
                self.last_exit_code = -1
            case StmtKind.ContinueStmt:
                self.last_exit_code = -2
            case StmtKind.ReturnStmt:
                if stmt.args.len() > 0:
                    self.last_exit_code = stmt.args[0].to_i32()
                else:
                    self.last_exit_code = 0
            case _:
                pass

    fn cmd_read(args: [text]):
        """Read a line of input into a variable."""
        if args.len() == 0:
            self.last_exit_code = 0
            return
        val input = self.terminal.read_input()
        val var_name = args[0]
        var new_vars: [(text, text)] = []
        var found = false
        for pair in self.variables:
            if pair.0 == var_name:
                new_vars = new_vars.push((var_name, input))
                found = true
            else:
                new_vars = new_vars.push(pair)
        if not found:
            new_vars = new_vars.push((var_name, input))
        self.variables = new_vars
        self.last_exit_code = 0

    fn cmd_alias(args: [text]):
        """Set or list aliases."""
        if args.len() == 0:
            self.last_exit_code = builtin_alias_list(self.aliases, self.terminal)
            return
        for arg in args:
            val eq_pos = _find_char_pos(arg, "=")
            if eq_pos >= 0:
                val name = arg.slice(0, eq_pos)
                var value = arg.slice(eq_pos + 1, arg.len())
                if value.starts_with("'") and value.len() > 1:
                    value = value.slice(1, value.len() - 1)
                var new_aliases: [(text, text)] = []
                var found = false
                for pair in self.aliases:
                    if pair.0 == name:
                        new_aliases = new_aliases.push((name, value))
                        found = true
                    else:
                        new_aliases = new_aliases.push(pair)
                if not found:
                    new_aliases = new_aliases.push((name, value))
                self.aliases = new_aliases
        self.last_exit_code = 0

    fn cmd_unalias(args: [text]):
        """Remove an alias."""
        for arg in args:
            var new_aliases: [(text, text)] = []
            for pair in self.aliases:
                if pair.0 != arg:
                    new_aliases = new_aliases.push(pair)
            self.aliases = new_aliases
        self.last_exit_code = 0

    fn cmd_shift(args: [text]):
        """Shift positional parameters (no-op for interactive mode)."""
        self.last_exit_code = 0

    fn cmd_trap(args: [text]):
        """Register a signal handler (stored in variables for now)."""
        if args.len() >= 2:
            var new_vars: [(text, text)] = []
            var found = false
            val trap_key = "_trap_{args[1]}"
            for pair in self.variables:
                if pair.0 == trap_key:
                    new_vars = new_vars.push((trap_key, args[0]))
                    found = true
                else:
                    new_vars = new_vars.push(pair)
            if not found:
                new_vars = new_vars.push((trap_key, args[0]))
            self.variables = new_vars
        self.last_exit_code = 0

    fn cmd_wait(args: [text]):
        """Wait for background jobs to complete."""
        self.last_exit_code = 0

    fn cmd_return(args: [text]):
        """Return from a function with optional exit code."""
        if args.len() > 0:
            self.last_exit_code = args[0].to_i32()
        else:
            self.last_exit_code = 0

    fn cmd_set(args: [text]):
        """Set shell options. Supports -e (exit on error) and +e (disable)."""
        for arg in args:
            if arg == "-e" or arg == "-o" or arg == "errexit":
                self.exit_on_error = true
            elif arg == "+e":
                self.exit_on_error = false
        self.last_exit_code = 0

    fn cmd_mkfifo(args: [text]):
        """Create a named pipe (FIFO). Stub — VFS FIFOs not yet supported."""
        if args.len() == 0:
            self.terminal.write_string("mkfifo: usage: mkfifo <name>\n")
            self.last_exit_code = 1
            return
        self.terminal.write_string("mkfifo: not supported on this filesystem\n")
        self.last_exit_code = 1

    # -- UI Construction -----------------------------------------------------

    fn build_ui() -> UISession:
        """Build the shell UI.

        Delegates to the terminal's build_ui with shell-specific status.
        """
        return self.terminal.build_ui()

# =========================================================================
# Helpers
# =========================================================================

fn _find_char(s: text, target: text) -> i32:
    """Find first occurrence of a character in a string. Returns -1 if not found."""
    var i = 0
    for ch in s:
        if ch == target:
            return i
        i = i + 1
    return -1

fn _normalize_path(path: text) -> text:
    """Normalize a path by resolving . and .. components."""
    var parts: [text] = []
    var current = ""
    for ch in path:
        if ch == "/":
            if current == "..":
                if parts.len() > 0:
                    var new_parts: [text] = []
                    var j = 0
                    while j < parts.len() - 1:
                        new_parts = new_parts.push(parts[j])
                        j = j + 1
                    parts = new_parts
            elif current != "." and current != "":
                parts = parts.push(current)
            current = ""
        else:
            current = "{current}{ch}"
    # Handle trailing component
    if current == "..":
        if parts.len() > 0:
            var new_parts: [text] = []
            var j = 0
            while j < parts.len() - 1:
                new_parts = new_parts.push(parts[j])
                j = j + 1
            parts = new_parts
    elif current != "." and current != "":
        parts = parts.push(current)

    if parts.len() == 0:
        return "/"
    var result = ""
    for part in parts:
        result = "{result}/{part}"
    return result

fn _parse_u64(s: text) -> u64:
    """Parse a u64 from text, returning 0 on failure."""
    var result: u64 = 0
    for ch in s:
        if ch >= "0" and ch <= "9":
            val digit = ch.to_i32() - "0".to_i32()
            result = result * 10 + digit.to_u64()
        else:
            return 0
    return result

fn _parent_path(path: text) -> text:
    """Get the parent directory of a path."""
    if path == "/":
        return "/"
    var last_slash = 0
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash == 0:
        return "/"
    return path.slice(0, last_slash)

fn _join_lines(lines: [text]) -> text:
    """Join a list of lines into a single text with newlines."""
    var result = ""
    for line in lines:
        result = "{result}{line}\n"
    return result

fn _find_chain_op(s: text, op: text) -> i32:
    """Find op in s outside of quotes. Returns position or -1."""
    var in_quote = false
    var quote_char = ""
    var i = 0
    while i < s.len():
        val ch = s.slice(i, i + 1)
        if in_quote:
            if ch == quote_char:
                in_quote = false
        else:
            if ch == "\"" or ch == "'":
                in_quote = true
                quote_char = ch
            elif i + op.len() <= s.len():
                if s.slice(i, i + op.len()) == op:
                    return i
        i = i + 1
    return -1

fn _basename_of(path: text) -> text:
    """Return the last component of a path."""
    if path == "/" or path == "":
        return path
    val normalized = if path.ends_with("/"): path.slice(0, path.len() - 1) else: path
    var last_slash = -1
    var i = 0
    for ch in normalized:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash < 0:
        return normalized
    return normalized.slice(last_slash + 1, normalized.len())

fn _unquote_simple(s: text) -> text:
    """Strip surrounding single or double quotes from a string."""
    if s.len() >= 2:
        val first = s.slice(0, 1)
        val last = s.slice(s.len() - 1, s.len())
        if (first == "\"" and last == "\"") or (first == "'" and last == "'"):
            return s.slice(1, s.len() - 1)
    return s

fn _find_char_pos(s: text, ch: text) -> i32:
    """Find position of first occurrence of ch in s. Returns -1 if not found."""
    var pos = 0
    for c in s:
        if c == ch:
            return pos
        pos = pos + 1
    return -1

# =========================================================================
# Remote Window Entry
# =========================================================================

fn shell_remote_main():
    """Launch Shell (Terminal) as a remote WM window."""
    serial_println("[shell] start app_id=/sys/apps/shell")
    var client = WindowClient.new()
    client.set_app_identity("/sys/apps/shell")
    if not client.connect():
        serial_println("[shell] connect_failed app_id=/sys/apps/shell")
        exit_(1)
        return

    val wid = client.create_window("Terminal", 80, 80, 600, 360)
    if wid == 0:
        serial_println("[shell] create_window_failed app_id=/sys/apps/shell")
        client.disconnect()
        exit_(1)
        return
    serial_println("[shell] window_created app_id=/sys/apps/shell wid={wid}")

    client.update_content("SimpleOS Shell\n\n$ ")

    var running = true
    while running:
        val event = client.wait_event()
        if event.event_type == WM_EVENT_CLOSE:
            running = false

    client.destroy_window()
    client.disconnect()
    serial_println("[shell] exit app_id=/sys/apps/shell code=0")
    exit_(0)

fn shell_remote_launch_once(process_id: u64) -> bool:
    """Create the packaged Shell window and return immediately."""
    serial_println("[shell] start app_id=/sys/apps/shell mode=filesystem-process pid={process_id}")
    var client = WindowClient.new()
    client.set_app_identity("/sys/apps/shell")
    if not client.connect():
        serial_println("[shell] connect_failed app_id=/sys/apps/shell mode=filesystem-process pid={process_id}")
        return false

    val wid = client.create_window_with_process_id("Terminal", 80, 80, 600, 360, process_id)
    if wid == 0:
        serial_println("[shell] create_window_failed app_id=/sys/apps/shell mode=filesystem-process pid={process_id}")
        client.disconnect()
        return false
    serial_println("[shell] window_created app_id=/sys/apps/shell wid={wid} mode=filesystem-process pid={process_id}")

    client.update_content("SimpleOS Shell\n\n$ ")
    true
