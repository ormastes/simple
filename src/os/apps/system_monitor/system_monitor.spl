use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class SystemMonitor:

    static fn new() -> SystemMonitor:
        SystemMonitor()

    me build_ui() -> UISession:
        val cpu_panel = panel("cpu_panel", "CPU", [
            row("cpu_usage_row", [
                label("lbl_cpu_usage", "Usage:"),
                text_widget("val_cpu_usage", "23%")
            ]),
            text_widget("cpu_bar", "[####......] 23%"),
            row("cpu_cores_row", [
                label("lbl_cpu_cores", "Cores:"),
                text_widget("val_cpu_cores", "4")
            ]),
            row("cpu_freq_row", [
                label("lbl_cpu_freq", "Frequency:"),
                text_widget("val_cpu_freq", "2400 MHz")
            ]),
            row("cpu_temp_row", [
                label("lbl_cpu_temp", "Temperature:"),
                text_widget("val_cpu_temp", "48 C")
            ]),
            panel("cpu_per_core", "Per-Core Usage", [
                text_widget("core_0", "Core 0: [###.......] 28%"),
                text_widget("core_1", "Core 1: [##........] 18%"),
                text_widget("core_2", "Core 2: [####......] 35%"),
                text_widget("core_3", "Core 3: [#.........] 12%")
            ])
        ])

        val mem_panel = panel("mem_panel", "Memory", [
            row("mem_usage_row", [
                label("lbl_mem_usage", "Usage:"),
                text_widget("val_mem_usage", "512 MB / 4096 MB")
            ]),
            text_widget("mem_bar", "[##........] 12.5%"),
            row("mem_used_row", [
                label("lbl_mem_used", "Used:"),
                text_widget("val_mem_used", "512 MB")
            ]),
            row("mem_cached_row", [
                label("lbl_mem_cached", "Cached:"),
                text_widget("val_mem_cached", "256 MB")
            ]),
            row("mem_free_row", [
                label("lbl_mem_free", "Free:"),
                text_widget("val_mem_free", "3328 MB")
            ]),
            row("swap_row", [
                label("lbl_swap", "Swap:"),
                text_widget("val_swap", "0 MB / 0 MB")
            ])
        ])

        val process_list = panel("proc_panel", "Processes", [
            row("proc_header", [
                label("ph_pid", "PID"),
                label("ph_name", "Name"),
                label("ph_cpu", "CPU%"),
                label("ph_mem", "MEM%")
            ]),
            row("proc_1", [
                text_widget("p1_pid", "1"),
                text_widget("p1_name", "init"),
                text_widget("p1_cpu", "0.0"),
                text_widget("p1_mem", "0.1")
            ]),
            row("proc_2", [
                text_widget("p2_pid", "42"),
                text_widget("p2_name", "kernel_worker"),
                text_widget("p2_cpu", "1.2"),
                text_widget("p2_mem", "0.5")
            ]),
            row("proc_3", [
                text_widget("p3_pid", "101"),
                text_widget("p3_name", "desktop_compositor"),
                text_widget("p3_cpu", "5.3"),
                text_widget("p3_mem", "2.1")
            ]),
            row("proc_4", [
                text_widget("p4_pid", "120"),
                text_widget("p4_name", "system_monitor"),
                text_widget("p4_cpu", "0.8"),
                text_widget("p4_mem", "0.9")
            ]),
            row("proc_5", [
                text_widget("p5_pid", "135"),
                text_widget("p5_name", "file_manager"),
                text_widget("p5_cpu", "0.1"),
                text_widget("p5_mem", "1.4")
            ]),
            button("btn_kill", "Kill Process", "sysmon.kill"),
            button("btn_refresh", "Refresh", "sysmon.refresh")
        ])

        val disk_panel = panel("disk_panel", "Disk I/O", [
            row("disk_read", [
                label("lbl_disk_read", "Read:"),
                text_widget("val_disk_read", "2.4 MB/s")
            ]),
            row("disk_write", [
                label("lbl_disk_write", "Write:"),
                text_widget("val_disk_write", "0.8 MB/s")
            ]),
            text_widget("disk_usage", "Disk: [########..] 80%  (40 GB / 50 GB)")
        ])

        val status = statusbar("sysmon_status", "Processes: 5  |  Load: 0.23", "Updated: now")

        val root = column("sysmon_root", [
            cpu_panel,
            mem_panel,
            disk_panel,
            process_list,
            status
        ])

        val tree = build_tree_with_title(root, "System Monitor", "dark")
        UISession.new(tree)
