use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class ImageViewer:

    static fn new() -> ImageViewer:
        ImageViewer()

    me build_ui() -> UISession:
        val toolbar = panel("img_toolbar", "Toolbar", [
            row("img_tools", [
                button("btn_open", "Open", "image.open"),
                button("btn_zoom_in", "Zoom In", "image.zoom.in"),
                button("btn_zoom_out", "Zoom Out", "image.zoom.out"),
                button("btn_fit", "Fit", "image.zoom.fit"),
                button("btn_rotate", "Rotate", "image.rotate")
            ])
        ])

        val image_area = panel("img_display", "Image", [
            text_widget("img_placeholder", "[Image Display Area]"),
            label("img_hint", "Open an image to view it here")
        ])

        val status = statusbar("img_status", "No file open", "100% | --x--")

        val root = column("image_viewer_root", [
            toolbar,
            image_area,
            status
        ])

        val tree = build_tree_with_title(root, "Image Viewer", "dark")
        UISession.new(tree)
