# Snake App
#
# Classic snake game with text-art board.
# Board symbols: # border, O snake head, o snake body, * food, space empty

use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{
    column, row, panel, text_widget, button, label, statusbar,
    build_tree_with_title, with_height, with_width, with_flex, with_background
}

# =========================================================================
# SnakeApp
# =========================================================================

class SnakeApp:
    session: UISession

    static fn new() -> SnakeApp:
        val tree = SnakeApp._build_tree()
        val session = UISession.new(tree)
        return SnakeApp(session: session)

    me build_ui() -> UISession:
        me.session

    # Board rows — 14 wide x 12 tall (including border)
    static fn _row_top() -> text:    return "##############"
    static fn _row_1() -> text:      return "#            #"
    static fn _row_2() -> text:      return "#   *        #"
    static fn _row_3() -> text:      return "#            #"
    static fn _row_4() -> text:      return "#   o        #"
    static fn _row_5() -> text:      return "#   o        #"
    static fn _row_6() -> text:      return "#   o o o O  #"
    static fn _row_7() -> text:      return "#            #"
    static fn _row_8() -> text:      return "#            #"
    static fn _row_9() -> text:      return "#            #"
    static fn _row_10() -> text:     return "#            #"
    static fn _row_bot() -> text:    return "##############"

    static fn _build_tree() -> UITree:
        # Toolbar row — game controls
        val toolbar = row("toolbar", [
            button("btn_start",  "Start",  "snake.start"),
            button("btn_pause",  "Pause",  "snake.pause"),
            button("btn_reset",  "Reset",  "snake.reset"),
        ])

        # Board panel
        val board_panel = panel("board_panel", "Game Board", [
            text_widget("top",   SnakeApp._row_top()),
            text_widget("r1",    SnakeApp._row_1()),
            text_widget("r2",    SnakeApp._row_2()),
            text_widget("r3",    SnakeApp._row_3()),
            text_widget("r4",    SnakeApp._row_4()),
            text_widget("r5",    SnakeApp._row_5()),
            text_widget("r6",    SnakeApp._row_6()),
            text_widget("r7",    SnakeApp._row_7()),
            text_widget("r8",    SnakeApp._row_8()),
            text_widget("r9",    SnakeApp._row_9()),
            text_widget("r10",   SnakeApp._row_10()),
            text_widget("bot",   SnakeApp._row_bot()),
        ])

        # Info sidebar
        val info_panel = panel("info_panel", "Info", [
            label("lbl_score",      "Score:  42"),
            label("lbl_length",     "Length: 6"),
            label("lbl_level",      "Level:  1"),
            label("lbl_sep",        ""),
            label("lbl_controls",   "Controls:"),
            label("lbl_up",         "  Arrow Up    — move up"),
            label("lbl_down",       "  Arrow Down  — move down"),
            label("lbl_left",       "  Arrow Left  — move left"),
            label("lbl_right",      "  Arrow Right — move right"),
            label("lbl_sep2",       ""),
            label("lbl_legend",     "Legend:"),
            label("lbl_head",       "  O = Snake head"),
            label("lbl_body",       "  o = Snake body"),
            label("lbl_food",       "  * = Food"),
            label("lbl_wall",       "  # = Wall"),
        ])

        # Status bar
        val status = statusbar("statusbar", "Status: Running", "High Score: 120")

        val root = column("root", [
            toolbar,
            row("main_area", [
                board_panel,
                info_panel,
            ]),
            status,
        ])

        return build_tree_with_title(root, "Snake", "default")
