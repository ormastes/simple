# Snake — Classic Arcade Snake Game
#
# A 20x20 grid-based snake game with arrow-key controls,
# food collection, score tracking, and collision detection.
# Space advances one tick; Enter restarts after game over.
#
# MDSOC: feature dimension, apps layer

use common.ui.builder.{
    column, row, panel, button, text_widget, label,
    statusbar, menubar, build_tree_with_title,
    with_flex, with_width
}
use common.ui.widget.{WidgetNode, UITree, UIEvent}
use common.ui.session.{UISession}

# =========================================================================
# Point
# =========================================================================

struct Point:
    """A 2D coordinate on the game grid."""
    x: i32
    y: i32

# =========================================================================
# Direction
# =========================================================================

enum Direction:
    """Movement direction for the snake."""
    Up
    Down
    Left
    Right

# =========================================================================
# Snake App
# =========================================================================

class SnakeApp:
    """Classic arcade snake game on a 20x20 grid.

    The snake moves one cell per tick. Eat food (@) to grow
    and score points. Colliding with a wall or your own body
    ends the game.
    """
    body: [Point]
    direction: Direction
    food: Point
    score: i32
    game_over: bool
    width: i32
    height: i32
    tick_count: i32

impl SnakeApp:

    static fn new() -> SnakeApp:
        """Create a new snake game with default state."""
        val initial_body = [
            Point(x: 10, y: 10),
            Point(x: 9, y: 10),
            Point(x: 8, y: 10)
        ]
        var app = SnakeApp(
            body: initial_body,
            direction: Direction.Right,
            food: Point(x: 0, y: 0),
            score: 0,
            game_over: false,
            width: 20,
            height: 20,
            tick_count: 0
        )
        app.food = app._spawn_food()
        app

    # -- Core Game Logic -----------------------------------------------------

    me tick():
        """Advance the snake by one step.

        Moves the head in the current direction, checks for food
        collection (grow + score), and detects wall/self collisions.
        """
        if self.game_over:
            return

        val head = self.body[0]
        val new_head = match self.direction:
            Direction.Up: Point(x: head.x, y: head.y - 1)
            Direction.Down: Point(x: head.x, y: head.y + 1)
            Direction.Left: Point(x: head.x - 1, y: head.y)
            Direction.Right: Point(x: head.x + 1, y: head.y)

        # Wall collision
        if (new_head.x < 0 or new_head.x >= self.width or
            new_head.y < 0 or new_head.y >= self.height):
            self.game_over = true
            return

        # Self collision
        if self._body_contains(new_head):
            self.game_over = true
            return

        # Build new body with head prepended
        var new_body = [new_head]
        val ate_food = (new_head.x == self.food.x and new_head.y == self.food.y)

        if ate_food:
            # Keep entire old body (snake grows by one)
            var i = 0
            while i < self.body.len():
                new_body = new_body.push(self.body[i])
                i = i + 1
            self.score = self.score + 10
            self.body = new_body
            self.food = self._spawn_food()
        else:
            # Copy all but the last segment (tail drops off)
            var i = 0
            while i < self.body.len() - 1:
                new_body = new_body.push(self.body[i])
                i = i + 1
            self.body = new_body

        self.tick_count = self.tick_count + 1

    me reset():
        """Reset the game to its initial state."""
        self.body = [
            Point(x: 10, y: 10),
            Point(x: 9, y: 10),
            Point(x: 8, y: 10)
        ]
        self.direction = Direction.Right
        self.score = 0
        self.game_over = false
        self.tick_count = 0
        self.food = self._spawn_food()

    # -- Direction Handling ---------------------------------------------------

    me set_direction(new_dir: Direction):
        """Change direction, preventing 180-degree reversal."""
        val dominated = match new_dir:
            Direction.Up:
                match self.direction:
                    Direction.Down: true
                    _: false
            Direction.Down:
                match self.direction:
                    Direction.Up: true
                    _: false
            Direction.Left:
                match self.direction:
                    Direction.Right: true
                    _: false
            Direction.Right:
                match self.direction:
                    Direction.Left: true
                    _: false
        if not dominated:
            self.direction = new_dir

    # -- Food Spawning -------------------------------------------------------

    fn _spawn_food() -> Point:
        """Spawn food at a deterministic position based on score as seed.

        Uses a simple hash to pick coordinates, retrying if the
        position overlaps the snake body.
        """
        var seed = self.score + self.tick_count + 7
        var attempts = 0
        while attempts < 400:
            val fx = _pseudo_hash(seed + attempts * 13) % self.width
            val fy = _pseudo_hash(seed + attempts * 37 + 5) % self.height
            val candidate = Point(x: fx, y: fy)
            if not self._body_contains(candidate):
                return candidate
            attempts = attempts + 1
        # Fallback: scan for first empty cell
        var y = 0
        while y < self.height:
            var x = 0
            while x < self.width:
                val p = Point(x: x, y: y)
                if not self._body_contains(p):
                    return p
                x = x + 1
            y = y + 1
        Point(x: 0, y: 0)

    fn _body_contains(p: Point) -> bool:
        """Check whether any body segment occupies the given point."""
        for seg in self.body:
            if seg.x == p.x and seg.y == p.y:
                return true
        false

    # -- Input Handling ------------------------------------------------------

    me handle_key(key: text):
        """Map keyboard input to game actions."""
        match key:
            "Up" => self.set_direction(Direction.Up)
            "Down" => self.set_direction(Direction.Down)
            "Left" => self.set_direction(Direction.Left)
            "Right" => self.set_direction(Direction.Right)
            "Space" => self.tick()
            "Enter":
                if self.game_over:
                    self.reset()
            _ => pass_dn

    me handle_action(action: text):
        """Dispatch button action strings."""
        match action:
            "new_game" => self.reset()
            "tick" => self.tick()
            "up" => self.set_direction(Direction.Up)
            "down" => self.set_direction(Direction.Down)
            "left" => self.set_direction(Direction.Left)
            "right" => self.set_direction(Direction.Right)
            _ => pass_dn

    # -- Grid Rendering ------------------------------------------------------

    fn _render_grid() -> text:
        """Render the 20x20 game grid as a multiline string.

        Symbols:
          # = snake head
          o = snake body
          @ = food
          . = empty cell
        """
        var board_text = ""
        # Top border
        board_text = "+{_repeat_char("-", self.width)}+"
        var y = 0
        while y < self.height:
            var row_text = "|"
            var x = 0
            while x < self.width:
                val cell = self._cell_at(x, y)
                row_text = "{row_text}{cell}"
                x = x + 1
            row_text = "{row_text}|"
            board_text = "{board_text}\n{row_text}"
            y = y + 1
        # Bottom border
        board_text = "{board_text}\n+{_repeat_char("-", self.width)}+"
        board_text

    fn _cell_at(x: i32, y: i32) -> text:
        """Return the display character for a given cell."""
        # Check head (first body segment)
        val head = self.body[0]
        if head.x == x and head.y == y:
            return "#"
        # Check body segments
        var i = 1
        while i < self.body.len():
            val seg = self.body[i]
            if seg.x == x and seg.y == y:
                return "o"
            i = i + 1
        # Check food
        if self.food.x == x and self.food.y == y:
            return "@"
        "."

    # -- UI Construction -----------------------------------------------------

    fn build_ui() -> UISession:
        """Build the snake game UI.

        Layout:
          Menu bar
          Game grid panel (multiline text)
          Info panel (score, length, status)
          Control buttons row
          Status bar
        """
        val grid_text = self._render_grid()

        val dir_text = match self.direction:
            Direction.Up: "Up"
            Direction.Down: "Down"
            Direction.Left: "Left"
            Direction.Right: "Right"

        val state_text = if self.game_over:
            "GAME OVER - Press Enter or New Game"
        else:
            "Playing - Space to advance"

        val root = column("snake_root", [
            # Menu bar
            menubar("snake_menu", [
                "Game"
            ]),

            # Game board_text
            with_flex(panel("snake_grid_panel", "Snake", [
                text_widget("snake_grid", grid_text)
            ]), 1),

            # Info panel
            panel("snake_info_panel", "Info", [
                row("snake_info_row", [
                    with_flex(label("snake_score_label", "Score: {self.score}"), 1),
                    with_flex(label("snake_length_label", "Length: {self.body.len()}"), 1),
                    with_flex(label("snake_dir_label", "Dir: {dir_text}"), 1)
                ]),
                label("snake_state_label", state_text)
            ]),

            # Control buttons
            row("snake_controls", [
                with_flex(button("btn_up", "Up", "up"), 1),
                with_flex(button("btn_down", "Down", "down"), 1),
                with_flex(button("btn_left", "Left", "left"), 1),
                with_flex(button("btn_right", "Right", "right"), 1),
                with_flex(button("btn_tick", "Step", "tick"), 1),
                with_flex(button("btn_new", "New Game", "new_game"), 1)
            ]),

            # Status bar
            statusbar("snake_status",
                state_text,
                "Score: {self.score} | Tick: {self.tick_count}"
            )
        ])

        val tree = build_tree_with_title(root, "Snake", "dark")
        UISession.new(tree)

# =========================================================================
# Helpers
# =========================================================================

fn _pseudo_hash(n: i32) -> i32:
    """Simple deterministic hash for food placement.

    Produces a non-negative integer from any input.
    """
    var h = n
    h = (h * 2654435761) % 1000000007
    if h < 0:
        h = h * -1
    h

fn _repeat_char(ch: text, count: i32) -> text:
    """Repeat a character count times."""
    var result = ""
    var i = 0
    while i < count:
        result = "{result}{ch}"
        i = i + 1
    result
