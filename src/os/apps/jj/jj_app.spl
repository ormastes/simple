# SimpleOS JJ — Jujutsu VCS Wrapper Application
#
# A jj (Jujutsu) command wrapper for SimpleOS that delegates to the host
# jj binary via rt_process_run in hosted mode. Provides argument validation,
# help text, and formatted error messages.
#
# Commands:
#   jj init                       — Initialize a new jj repository
#   jj log                        — Show revision log
#   jj status / jj st             — Show working copy status
#   jj diff                       — Show diff of current change
#   jj new                        — Create a new change
#   jj describe -m "message"      — Describe current change
#   jj commit -m "message"        — Commit current change
#   jj bookmark set NAME [-r REV] — Set a bookmark
#   jj git push                   — Push to remote via git
#   jj git fetch                  — Fetch from remote via git
#   jj rebase -d DEST             — Rebase onto destination
#   jj squash                     — Squash into parent
#   jj abandon                    — Abandon current change
#   jj help                       — Show available commands

# ============================================================================
# FFI
# ============================================================================

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(key: text) -> text

# ============================================================================
# Core: delegate to host jj binary
# ============================================================================

fn jj_run(args: [text]) -> (text, text, i64):
    """Run jj with the given arguments and return (stdout, stderr, exit_code)."""
    rt_process_run("jj", args)

fn print_output(stdout: text, stderr: text):
    """Print jj output, preferring stdout but falling back to stderr."""
    val out = stdout.trim()
    val err = stderr.trim()
    if out != "":
        print out
    if err != "":
        print err

# ============================================================================
# Individual command handlers
# ============================================================================

fn jj_init(args: [text]) -> i64:
    """jj init — Initialize a new jj repository."""
    var cmd_args: [text] = ["init"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = jj_run(cmd_args)
    print_output(out, err)
    code

fn jj_log(args: [text]) -> i64:
    """jj log — Show revision log (with --no-pager by default)."""
    var cmd_args: [text] = ["log", "--no-pager"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = jj_run(cmd_args)
    print_output(out, err)
    code

fn jj_status(args: [text]) -> i64:
    """jj status — Show working copy status."""
    var cmd_args: [text] = ["status"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = jj_run(cmd_args)
    print_output(out, err)
    code

fn jj_diff(args: [text]) -> i64:
    """jj diff — Show diff of current change."""
    var cmd_args: [text] = ["diff"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = jj_run(cmd_args)
    print_output(out, err)
    code

fn jj_new(args: [text]) -> i64:
    """jj new — Create a new change."""
    var cmd_args: [text] = ["new"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = jj_run(cmd_args)
    print_output(out, err)
    code

fn jj_describe(args: [text]) -> i64:
    """jj describe -m MSG — Describe current change."""
    var has_message = false
    for a in args:
        if a == "-m":
            has_message = true
    if not has_message and args.len() == 0:
        print "jj describe: use -m to provide a description"
        print "usage: jj describe -m \"<message>\""
        return 1
    var cmd_args: [text] = ["describe"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = jj_run(cmd_args)
    print_output(out, err)
    code

fn jj_commit(args: [text]) -> i64:
    """jj commit -m MSG — Commit current change."""
    var has_message = false
    for a in args:
        if a == "-m":
            has_message = true
    if not has_message and args.len() == 0:
        print "jj commit: use -m to provide a commit message"
        print "usage: jj commit -m \"<message>\""
        return 1
    var cmd_args: [text] = ["commit"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = jj_run(cmd_args)
    print_output(out, err)
    code

fn jj_bookmark(args: [text]) -> i64:
    """jj bookmark set NAME [-r REV] — Set a bookmark."""
    if args.len() == 0:
        print "usage: jj bookmark set <name> [-r <rev>]"
        return 1
    var cmd_args: [text] = ["bookmark"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = jj_run(cmd_args)
    print_output(out, err)
    code

fn jj_git(args: [text]) -> i64:
    """jj git push/fetch — Git integration commands."""
    if args.len() == 0:
        print "usage: jj git <push|fetch>"
        return 1
    var cmd_args: [text] = ["git"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = jj_run(cmd_args)
    print_output(out, err)
    code

fn jj_rebase(args: [text]) -> i64:
    """jj rebase -d DEST — Rebase onto destination."""
    var has_dest = false
    for a in args:
        if a == "-d":
            has_dest = true
    if not has_dest and args.len() == 0:
        print "jj rebase: use -d to specify destination"
        print "usage: jj rebase -d <destination>"
        return 1
    var cmd_args: [text] = ["rebase"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = jj_run(cmd_args)
    print_output(out, err)
    code

fn jj_squash(args: [text]) -> i64:
    """jj squash — Squash into parent change."""
    var cmd_args: [text] = ["squash"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = jj_run(cmd_args)
    print_output(out, err)
    code

fn jj_abandon(args: [text]) -> i64:
    """jj abandon — Abandon current change."""
    var cmd_args: [text] = ["abandon"]
    for a in args:
        cmd_args.append(a)
    val (out, err, code) = jj_run(cmd_args)
    print_output(out, err)
    code

fn jj_passthrough(args: [text]) -> i64:
    """Pass unrecognized jj subcommands directly to jj."""
    val (out, err, code) = jj_run(args)
    print_output(out, err)
    code

# ============================================================================
# Help
# ============================================================================

fn jj_help_text() -> text:
    var lines: [text] = []
    lines.append("SimpleOS JJ — Jujutsu Version Control Wrapper")
    lines.append("")
    lines.append("Commands:")
    lines.append("  jj init                       Initialize repository")
    lines.append("  jj log                        Show revision log")
    lines.append("  jj status                     Show working copy status")
    lines.append("  jj st                         Alias for status")
    lines.append("  jj diff                       Show diff of current change")
    lines.append("  jj new                        Create a new change")
    lines.append("  jj describe -m \"msg\"          Describe current change")
    lines.append("  jj commit -m \"msg\"            Commit current change")
    lines.append("  jj bookmark set <name> [-r R] Set a bookmark")
    lines.append("  jj git push                   Push to remote via git")
    lines.append("  jj git fetch                  Fetch from remote via git")
    lines.append("  jj rebase -d <dest>           Rebase onto destination")
    lines.append("  jj squash                     Squash into parent")
    lines.append("  jj abandon                    Abandon current change")
    lines.append("  jj help                       Show this help")
    lines.append("")
    lines.append("Any unrecognized subcommand is passed through to jj.")
    lines.join("\n")

fn jj_help(args: [text]) -> i64:
    print jj_help_text()
    0

# ============================================================================
# CLI Dispatcher
# ============================================================================

fn jj_run_cmd(args: [text]) -> i64:
    """Run a jj command. Returns 0 on success, non-zero on error."""
    if args.len() == 0:
        print jj_help_text()
        return 0

    val subcmd = args[0]
    val rest = args.slice(1, args.len())

    match subcmd:
        "init":     jj_init(rest)
        "log":      jj_log(rest)
        "status":   jj_status(rest)
        "st":       jj_status(rest)
        "diff":     jj_diff(rest)
        "new":      jj_new(rest)
        "describe": jj_describe(rest)
        "commit":   jj_commit(rest)
        "bookmark": jj_bookmark(rest)
        "git":      jj_git(rest)
        "rebase":   jj_rebase(rest)
        "squash":   jj_squash(rest)
        "abandon":  jj_abandon(rest)
        "help":     jj_help(rest)
        _:          jj_passthrough(args)

# ============================================================================
# Standalone entry point (for testing outside shell)
# ============================================================================

fn main() -> i64:
    val args_str = rt_env_get("JJ_ARGS")
    if args_str != "":
        val parts = args_str.split(" ")
        return jj_run_cmd(parts)
    print jj_help_text()
    return 0
