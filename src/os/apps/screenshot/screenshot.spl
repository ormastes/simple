use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class ScreenshotApp:

    static fn new() -> ScreenshotApp:
        ScreenshotApp()

    me build_ui() -> UISession:
        val capture_modes = panel("capture_modes", "Capture Mode", [
            row("mode_row", [
                button("btn_fullscreen", "Full Screen", "screenshot.capture.fullscreen"),
                button("btn_window", "Window", "screenshot.capture.window"),
                button("btn_region", "Region", "screenshot.capture.region")
            ])
        ])

        val capture_options = panel("capture_options", "Options", [
            row("delay_row", [
                label("delay_label", "Delay (s):"),
                button("btn_delay_0", "0", "screenshot.delay.0"),
                button("btn_delay_3", "3", "screenshot.delay.3"),
                button("btn_delay_5", "5", "screenshot.delay.5")
            ]),
            row("save_row", [
                label("save_label", "Save to:"),
                text_widget("save_location", "~/Pictures/Screenshots")
            ])
        ])

        val preview_area = panel("preview_area", "Preview", [
            text_widget("preview_placeholder", "[Screenshot Preview]")
        ])

        val actions = panel("screenshot_actions", "Actions", [
            row("action_row", [
                button("btn_save", "Save", "screenshot.save"),
                button("btn_copy", "Copy", "screenshot.copy"),
                button("btn_discard", "Discard", "screenshot.discard")
            ])
        ])

        val status = statusbar("screenshot_status", "Ready", "PNG | ~/Pictures/Screenshots")

        val root = column("screenshot_root", [
            capture_modes,
            capture_options,
            preview_area,
            actions,
            status
        ])

        val tree = build_tree_with_title(root, "Screenshot", "dark")
        UISession.new(tree)
