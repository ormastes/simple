# Solitaire App
#
# Klondike Solitaire with text-art card tableau, foundation piles,
# and stock/waste pile display.
#
# Card notation: suit symbols (H=Hearts, D=Diamonds, C=Clubs, S=Spades)
# Rank: A 2 3 4 5 6 7 8 9 T J Q K
# Face-down: [##]    Face-up: [AS] [KH] etc.    Empty slot: [  ]

use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{
    column, row, panel, text_widget, button, label, statusbar,
    build_tree_with_title, with_height, with_width, with_flex, with_background
}

# =========================================================================
# SolitaireApp
# =========================================================================

class SolitaireApp:
    session: UISession

    static fn new() -> SolitaireApp:
        val tree = SolitaireApp._build_tree()
        val session = UISession.new(tree)
        return SolitaireApp(session: session)

    me build_ui() -> UISession:
        me.session

    # -------------------------------------------------------------------------
    # Top area: stock/waste + foundations
    # -------------------------------------------------------------------------

    # Stock pile (face-down deck)
    static fn _stock() -> text:       return "[##][##]"
    # Waste pile (last 3 turned cards)
    static fn _waste() -> text:       return "[3C][7D][JH]"

    # Four foundation piles (built up by suit from Ace)
    static fn _found_h() -> text:     return "[5H]"   # Hearts — built to 5
    static fn _found_d() -> text:     return "[3D]"   # Diamonds — built to 3
    static fn _found_c() -> text:     return "[2C]"   # Clubs — built to 2
    static fn _found_s() -> text:     return "[AS]"   # Spades — built to A

    # -------------------------------------------------------------------------
    # Tableau columns (7 columns, varying height)
    # -------------------------------------------------------------------------

    # Column 1 — 1 face-up
    static fn _col1_r1() -> text:     return "[KH]"
    static fn _col1_r2() -> text:     return "[QS]"
    static fn _col1_r3() -> text:     return "[JH]"
    static fn _col1_r4() -> text:     return "[TC]"
    static fn _col1_r5() -> text:     return "[9H]"
    static fn _col1_r6() -> text:     return "[8S]"

    # Column 2
    static fn _col2_r1() -> text:     return "[##]"
    static fn _col2_r2() -> text:     return "[##]"
    static fn _col2_r3() -> text:     return "[QH]"
    static fn _col2_r4() -> text:     return "[JC]"
    static fn _col2_r5() -> text:     return "[TD]"

    # Column 3
    static fn _col3_r1() -> text:     return "[##]"
    static fn _col3_r2() -> text:     return "[##]"
    static fn _col3_r3() -> text:     return "[##]"
    static fn _col3_r4() -> text:     return "[7H]"

    # Column 4
    static fn _col4_r1() -> text:     return "[##]"
    static fn _col4_r2() -> text:     return "[##]"
    static fn _col4_r3() -> text:     return "[##]"
    static fn _col4_r4() -> text:     return "[##]"
    static fn _col4_r5() -> text:     return "[6S]"
    static fn _col4_r6() -> text:     return "[5H]"

    # Column 5
    static fn _col5_r1() -> text:     return "[##]"
    static fn _col5_r2() -> text:     return "[##]"
    static fn _col5_r3() -> text:     return "[##]"
    static fn _col5_r4() -> text:     return "[##]"
    static fn _col5_r5() -> text:     return "[##]"
    static fn _col5_r6() -> text:     return "[4C]"

    # Column 6
    static fn _col6_r1() -> text:     return "[##]"
    static fn _col6_r2() -> text:     return "[##]"
    static fn _col6_r3() -> text:     return "[##]"
    static fn _col6_r4() -> text:     return "[##]"
    static fn _col6_r5() -> text:     return "[##]"
    static fn _col6_r6() -> text:     return "[##]"
    static fn _col6_r7() -> text:     return "[3H]"

    # Column 7
    static fn _col7_r1() -> text:     return "[##]"
    static fn _col7_r2() -> text:     return "[##]"
    static fn _col7_r3() -> text:     return "[##]"
    static fn _col7_r4() -> text:     return "[##]"
    static fn _col7_r5() -> text:     return "[##]"
    static fn _col7_r6() -> text:     return "[##]"
    static fn _col7_r7() -> text:     return "[##]"
    static fn _col7_r8() -> text:     return "[2D]"

    static fn _build_tree() -> UITree:
        # Toolbar
        val toolbar = row("toolbar", [
            button("btn_new",   "New Game", "solitaire.new_game"),
            button("btn_undo",  "Undo",     "solitaire.undo"),
            button("btn_hint",  "Hint",     "solitaire.hint"),
            button("btn_auto",  "Auto Finish", "solitaire.auto_finish"),
        ])

        # Top area: stock + waste + spacer + foundations
        val stock_waste_panel = panel("stock_waste_panel", "Stock / Waste", [
            row("sw_row", [
                column("stock_col", [
                    label("lbl_stock",  "Stock:"),
                    text_widget("stock_cards", SolitaireApp._stock()),
                ]),
                column("waste_col", [
                    label("lbl_waste",  "Waste:"),
                    text_widget("waste_cards", SolitaireApp._waste()),
                ]),
            ]),
        ])

        val found_panel = panel("found_panel", "Foundations", [
            row("found_row", [
                column("fh_col", [
                    label("lbl_fh", "Hearts:"),
                    text_widget("fh", SolitaireApp._found_h()),
                ]),
                column("fd_col", [
                    label("lbl_fd", "Diamonds:"),
                    text_widget("fd", SolitaireApp._found_d()),
                ]),
                column("fc_col", [
                    label("lbl_fc", "Clubs:"),
                    text_widget("fc", SolitaireApp._found_c()),
                ]),
                column("fs_col", [
                    label("lbl_fs", "Spades:"),
                    text_widget("fs", SolitaireApp._found_s()),
                ]),
            ]),
        ])

        # Tableau — 7 columns side by side
        val col1 = panel("col1", "1", [
            text_widget("c1r1", SolitaireApp._col1_r1()),
            text_widget("c1r2", SolitaireApp._col1_r2()),
            text_widget("c1r3", SolitaireApp._col1_r3()),
            text_widget("c1r4", SolitaireApp._col1_r4()),
            text_widget("c1r5", SolitaireApp._col1_r5()),
            text_widget("c1r6", SolitaireApp._col1_r6()),
        ])

        val col2 = panel("col2", "2", [
            text_widget("c2r1", SolitaireApp._col2_r1()),
            text_widget("c2r2", SolitaireApp._col2_r2()),
            text_widget("c2r3", SolitaireApp._col2_r3()),
            text_widget("c2r4", SolitaireApp._col2_r4()),
            text_widget("c2r5", SolitaireApp._col2_r5()),
        ])

        val col3 = panel("col3", "3", [
            text_widget("c3r1", SolitaireApp._col3_r1()),
            text_widget("c3r2", SolitaireApp._col3_r2()),
            text_widget("c3r3", SolitaireApp._col3_r3()),
            text_widget("c3r4", SolitaireApp._col3_r4()),
        ])

        val col4 = panel("col4", "4", [
            text_widget("c4r1", SolitaireApp._col4_r1()),
            text_widget("c4r2", SolitaireApp._col4_r2()),
            text_widget("c4r3", SolitaireApp._col4_r3()),
            text_widget("c4r4", SolitaireApp._col4_r4()),
            text_widget("c4r5", SolitaireApp._col4_r5()),
            text_widget("c4r6", SolitaireApp._col4_r6()),
        ])

        val col5 = panel("col5", "5", [
            text_widget("c5r1", SolitaireApp._col5_r1()),
            text_widget("c5r2", SolitaireApp._col5_r2()),
            text_widget("c5r3", SolitaireApp._col5_r3()),
            text_widget("c5r4", SolitaireApp._col5_r4()),
            text_widget("c5r5", SolitaireApp._col5_r5()),
            text_widget("c5r6", SolitaireApp._col5_r6()),
        ])

        val col6 = panel("col6", "6", [
            text_widget("c6r1", SolitaireApp._col6_r1()),
            text_widget("c6r2", SolitaireApp._col6_r2()),
            text_widget("c6r3", SolitaireApp._col6_r3()),
            text_widget("c6r4", SolitaireApp._col6_r4()),
            text_widget("c6r5", SolitaireApp._col6_r5()),
            text_widget("c6r6", SolitaireApp._col6_r6()),
            text_widget("c6r7", SolitaireApp._col6_r7()),
        ])

        val col7 = panel("col7", "7", [
            text_widget("c7r1", SolitaireApp._col7_r1()),
            text_widget("c7r2", SolitaireApp._col7_r2()),
            text_widget("c7r3", SolitaireApp._col7_r3()),
            text_widget("c7r4", SolitaireApp._col7_r4()),
            text_widget("c7r5", SolitaireApp._col7_r5()),
            text_widget("c7r6", SolitaireApp._col7_r6()),
            text_widget("c7r7", SolitaireApp._col7_r7()),
            text_widget("c7r8", SolitaireApp._col7_r8()),
        ])

        val tableau = panel("tableau", "Tableau", [
            row("tableau_row", [
                col1, col2, col3, col4, col5, col6, col7,
            ]),
        ])

        # Legend
        val legend = panel("legend_panel", "Legend", [
            label("leg_facedown", "[##] = Face-down card"),
            label("leg_faceup",   "[XY] = Face-up card (X=rank, Y=suit)"),
            label("leg_suits",    "Suits: H=Hearts D=Diamonds C=Clubs S=Spades"),
            label("leg_ranks",    "Ranks: A 2..9 T J Q K"),
        ])

        # Status bar
        val status = statusbar("statusbar", "Moves: 23", "Cards in stock: 19")

        val root = column("root", [
            toolbar,
            row("top_area", [
                stock_waste_panel,
                found_panel,
            ]),
            tableau,
            legend,
            status,
        ])

        return build_tree_with_title(root, "Solitaire", "default")
