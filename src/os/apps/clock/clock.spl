# Clock App — MDSOC+ capsule with ECS inner state
#
# MDSOC+: capsule outer + ECS business layer.
# Capsule owns a ClockAppWorld (ECS) and a UISession (presentation).

use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}
use std.ecs.entity.{Entity}
use os.apps.clock.ecs.world.{ClockAppWorld}
use os.apps.clock.ecs.systems.{sys_tick_stopwatch, sys_tick_timer}

class ClockApp:
    world: ClockAppWorld
    clock_entity: Entity
    stopwatch_entity: Entity
    timer_entity: Entity

    static fn new() -> ClockApp:
        var w = ClockAppWorld.new()
        val ce = w.spawn_clock()
        val se = w.spawn_stopwatch()
        val te = w.spawn_timer()
        ClockApp(world: w, clock_entity: ce, stopwatch_entity: se, timer_entity: te)

    me build_ui() -> UISession:
        val clock_display = panel("clock_display", "Current Time", [
            text_widget("time_display", "12:00:00"),
            text_widget("date_display", "Wednesday, May 7, 2026"),
            text_widget("timezone_display", "UTC+0")
        ])

        val stopwatch_controls = row("sw_controls", [
            button("btn_sw_start", "Start", "stopwatch.start"),
            button("btn_sw_stop", "Stop", "stopwatch.stop"),
            button("btn_sw_reset", "Reset", "stopwatch.reset"),
            button("btn_sw_lap", "Lap", "stopwatch.lap")
        ])

        val stopwatch_laps = panel("sw_laps", "Lap Times", [
            text_widget("lap_1", "Lap 1: --:--.--"),
            text_widget("lap_2", "Lap 2: --:--.--"),
            text_widget("lap_3", "Lap 3: --:--.--")
        ])

        val stopwatch = panel("stopwatch", "Stopwatch", [
            text_widget("sw_elapsed", "00:00.0"),
            stopwatch_controls,
            stopwatch_laps
        ])

        val timer_controls = row("timer_controls", [
            button("btn_timer_start", "Start", "timer.start"),
            button("btn_timer_pause", "Pause", "timer.pause"),
            button("btn_timer_reset", "Reset", "timer.reset")
        ])

        val timer = panel("timer", "Timer", [
            text_widget("timer_set", "Set: 00:05:00"),
            text_widget("timer_remaining", "Remaining: 00:05:00"),
            timer_controls
        ])

        val root = column("clock_root", [
            clock_display,
            stopwatch,
            timer
        ])

        val tree = build_tree_with_title(root, "Clock", "dark")
        UISession.new(tree)

    me tick(dt_ms: u64):
        """Advance stopwatch and timer by dt_ms via ECS systems."""
        sys_tick_stopwatch(me.world, dt_ms)
        sys_tick_timer(me.world, dt_ms)
