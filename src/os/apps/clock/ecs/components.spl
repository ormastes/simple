# Clock App ECS Components — POD structs for clock/stopwatch/timer state
#
# MDSOC+: ECS component types for the clock app capsule.

struct TimeDisplay:
    """Current formatted time string."""
    time_text: text

struct DateDisplay:
    """Current formatted date string."""
    date_text: text

struct TimezoneDisplay:
    """Current timezone label."""
    tz_text: text

struct StopwatchState:
    """Stopwatch elapsed time and running flag."""
    elapsed_ms: u64
    running: bool

struct StopwatchLap:
    """A recorded lap time."""
    lap_ms: u64

struct TimerState:
    """Countdown timer state."""
    set_ms: u64
    remaining_ms: u64
    running: bool
