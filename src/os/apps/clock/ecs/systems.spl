# Clock App ECS Systems — free functions operating on ClockAppWorld
#
# MDSOC+: stateless system functions for the clock app capsule.

use os.apps.clock.ecs.world.{ClockAppWorld}
use os.apps.clock.ecs.components.{StopwatchState, TimerState}

fn sys_tick_stopwatch(world: ClockAppWorld, dt_ms: u64):
    """Advance running stopwatches by dt_ms."""
    var i: i32 = 0
    while i < world.stopwatches.len():
        if world.stopwatches.dense[i].running:
            world.stopwatches.dense[i] = StopwatchState(
                elapsed_ms: world.stopwatches.dense[i].elapsed_ms + dt_ms,
                running: true
            )
            world.stopwatches.ticks[i] = world.base.now()
        i = i + 1

fn sys_tick_timer(world: ClockAppWorld, dt_ms: u64):
    """Count down running timers by dt_ms, clamping at zero."""
    var i: i32 = 0
    while i < world.timers.len():
        if world.timers.dense[i].running:
            val remaining = world.timers.dense[i].remaining_ms
            val new_remaining = if remaining > dt_ms: remaining - dt_ms else: 0
            world.timers.dense[i] = TimerState(
                set_ms: world.timers.dense[i].set_ms,
                remaining_ms: new_remaining,
                running: new_remaining > 0
            )
            world.timers.ticks[i] = world.base.now()
        i = i + 1
