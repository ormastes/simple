# Clock App ECS World — per-app container
#
# MDSOC+: the ClockAppWorld owns all clock-related entities and components.

use std.ecs.entity.{Entity, EntityAllocator}
use std.ecs.component_store.{ComponentStore}
use std.ecs.world.{WorldBase}
use os.apps.clock.ecs.components.{TimeDisplay, DateDisplay, TimezoneDisplay, StopwatchState, StopwatchLap, TimerState}

struct ClockAppWorld:
    """ECS world for the clock application."""
    base: WorldBase
    time_displays: ComponentStore<TimeDisplay>
    date_displays: ComponentStore<DateDisplay>
    tz_displays: ComponentStore<TimezoneDisplay>
    stopwatches: ComponentStore<StopwatchState>
    laps: ComponentStore<StopwatchLap>
    timers: ComponentStore<TimerState>

    static fn new() -> ClockAppWorld:
        ClockAppWorld(
            base: WorldBase.new(),
            time_displays: ComponentStore.new(),
            date_displays: ComponentStore.new(),
            tz_displays: ComponentStore.new(),
            stopwatches: ComponentStore.new(),
            laps: ComponentStore.new(),
            timers: ComponentStore.new()
        )

    fn spawn_clock(self) -> Entity:
        """Spawn the singleton clock display entity."""
        val e = self.base.spawn()
        val tick = self.base.now()
        self.time_displays.insert(e, TimeDisplay(time_text: "12:00:00"), tick)
        self.date_displays.insert(e, DateDisplay(date_text: ""), tick)
        self.tz_displays.insert(e, TimezoneDisplay(tz_text: "UTC+0"), tick)
        e

    fn spawn_stopwatch(self) -> Entity:
        """Spawn a stopwatch entity."""
        val e = self.base.spawn()
        val tick = self.base.now()
        self.stopwatches.insert(e, StopwatchState(elapsed_ms: 0, running: false), tick)
        e

    fn spawn_timer(self) -> Entity:
        """Spawn a countdown timer entity."""
        val e = self.base.spawn()
        val tick = self.base.now()
        self.timers.insert(e, TimerState(set_ms: 300000, remaining_ms: 300000, running: false), tick)
        e
