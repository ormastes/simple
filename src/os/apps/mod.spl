# SimpleOS Core Applications
#
# Built using existing UI widget system:
#   - Terminal emulator (VT100/ANSI)
#   - Shell (port existing shell/)
#   - File manager (tree + list views)
#   - Text editor (modal, syntax highlighting)
#   - System monitor (process list, CPU/memory)
#   - Package manager

use os.apps.terminal.terminal
use os.apps.shell.shell_app
use os.apps.file_manager.file_manager
use os.apps.editor.editor
use os.apps.system_monitor.system_monitor
