use common.ui.showcase_catalog.{
    ShowcaseEntry,
    ShowcaseSurface,
    showcase_find,
    showcase_surface_supported,
}

struct ShowcaseLaunchRequest:
    app_id: text
    surface: text
    installed_path: text

fn _showcase_surface_from_key(key: text) -> Result<ShowcaseSurface, text>:
    if key == "standalone":
        return Ok(ShowcaseSurface.Standalone)
    if key == "host_wm":
        return Ok(ShowcaseSurface.HostWm)
    if key == "simpleos_wm":
        return Ok(ShowcaseSurface.SimpleOsWm)
    Err("showcase-action-unknown-surface:{key}")

fn _showcase_launch_request(entry: ShowcaseEntry, surface: text) -> ShowcaseLaunchRequest:
    ShowcaseLaunchRequest(
        app_id: entry.app_id,
        surface: surface,
        installed_path: entry.installed_path,
    )

fn parse_showcase_launch_action(action: text) -> Result<ShowcaseLaunchRequest, text>:
    val parts = action.split(":")
    if parts.len() != 3:
        return Err("showcase-action-malformed")
    if parts[0] != "showcase.launch":
        return Err("showcase-action-malformed")
    val app_id = parts[1]
    val surface_key = parts[2]
    if app_id == "" or surface_key == "":
        return Err("showcase-action-malformed")
    val surface_result = _showcase_surface_from_key(surface_key)
    match surface_result:
        case Err(message):
            Err(message)
        case Ok(surface):
            val found = showcase_find(app_id)
            if found == nil:
                return Err("showcase-action-unknown-app:{app_id}")
            val entry = found.unwrap()
            if not showcase_surface_supported(entry, surface):
                return Err("showcase-action-blocked:{app_id}:{surface_key}")
            Ok(_showcase_launch_request(entry, surface_key))
