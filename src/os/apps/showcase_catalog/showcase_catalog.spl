use common.ui.widget.{WidgetNode}
use common.ui.builder.{column, row, panel, text_widget, button, build_tree_with_title}
use common.ui.showcase_catalog.{ShowcaseEntry, ShowcaseSurface, showcase_catalog, showcase_surface_supported}
use nogc_sync_mut.ui.session.{UISession}

class ShowcaseCatalogApp:

    static fn new() -> ShowcaseCatalogApp:
        ShowcaseCatalogApp()

    me build_ui() -> UISession:
        var cards: [WidgetNode] = []
        for entry in showcase_catalog():
            cards = cards.push(showcase_entry_panel(entry))
        val root = column("showcase_catalog_root", cards)
        UISession.new(build_tree_with_title(root, "Showcase Catalog", "dark"))

fn showcase_entry_panel(entry: ShowcaseEntry) -> WidgetNode:
    val id = entry.app_id
    panel("showcase_entry_{id}", entry.title, [
        text_widget("showcase_title_{id}", entry.title),
        text_widget("showcase_app_id_{id}", "App ID: {entry.app_id}"),
        text_widget("showcase_installed_path_{id}", "Installed path: {entry.installed_path}"),
        showcase_surface_row(entry, ShowcaseSurface.Standalone, "standalone", "Standalone"),
        showcase_surface_row(entry, ShowcaseSurface.HostWm, "host_wm", "Host WM"),
        showcase_surface_row(entry, ShowcaseSurface.SimpleOsWm, "simpleos_wm", "SimpleOS WM")
    ])

fn showcase_surface_row(entry: ShowcaseEntry, surface: ShowcaseSurface, surface_key: text, surface_label: text) -> WidgetNode:
    val ready = showcase_surface_supported(entry, surface)
    val readiness = if ready: "Ready" else: "Blocked"
    val app_id = entry.app_id
    var launch = button(
        "showcase_launch_{app_id}_{surface_key}",
        "{surface_label} {readiness}",
        "showcase.launch:{app_id}:{surface_key}"
    )
    launch = launch.set_prop("disabled", if ready: "false" else: "true")
    row("showcase_surface_{app_id}_{surface_key}", [
        text_widget("showcase_readiness_{app_id}_{surface_key}", "{surface_label}: {readiness}"),
        launch
    ])
