use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class TodoApp:

    static fn new() -> TodoApp:
        TodoApp()

    me build_ui() -> UISession:
        val toolbar = row("todo_toolbar", [
            button("btn_add", "+ Add Task", "todo.add"),
            button("btn_filter_all", "All", "todo.filter.all"),
            button("btn_filter_active", "Active", "todo.filter.active"),
            button("btn_filter_done", "Done", "todo.filter.done"),
            button("btn_clear_done", "Clear Done", "todo.clear_done")
        ])

        val todo_items = panel("todo_list", "Tasks", [
            row("item_1", [
                label("chk_1", "[x]"),
                text_widget("task_1", "Set up SimpleOS development environment"),
                button("btn_del_1", "x", "todo.delete.1")
            ]),
            row("item_2", [
                label("chk_2", "[x]"),
                text_widget("task_2", "Write kernel memory allocator"),
                button("btn_del_2", "x", "todo.delete.2")
            ]),
            row("item_3", [
                label("chk_3", "[x]"),
                text_widget("task_3", "Implement basic file system (FAT32)"),
                button("btn_del_3", "x", "todo.delete.3")
            ]),
            row("item_4", [
                label("chk_4", "[ ]"),
                text_widget("task_4", "Add network stack (TCP/IP)"),
                button("btn_del_4", "x", "todo.delete.4")
            ]),
            row("item_5", [
                label("chk_5", "[ ]"),
                text_widget("task_5", "Build desktop compositor"),
                button("btn_del_5", "x", "todo.delete.5")
            ]),
            row("item_6", [
                label("chk_6", "[ ]"),
                text_widget("task_6", "Implement IPC message passing"),
                button("btn_del_6", "x", "todo.delete.6")
            ]),
            row("item_7", [
                label("chk_7", "[ ]"),
                text_widget("task_7", "Write audio driver"),
                button("btn_del_7", "x", "todo.delete.7")
            ]),
            row("item_8", [
                label("chk_8", "[ ]"),
                text_widget("task_8", "GPU/display driver"),
                button("btn_del_8", "x", "todo.delete.8")
            ])
        ])

        val add_row = row("todo_add_row", [
            label("lbl_new", "New task:"),
            text_widget("new_task_input", "Type task here..."),
            button("btn_add_confirm", "Add", "todo.add.confirm")
        ])

        val status = statusbar("todo_status", "8 tasks  |  3 done  |  5 remaining", "SimpleOS Todo")

        val root = column("todo_root", [
            toolbar,
            todo_items,
            add_row,
            status
        ])

        val tree = build_tree_with_title(root, "Todo", "dark")
        UISession.new(tree)
