# Tetris App
#
# Classic Tetris with a 10-wide x 20-tall play field (text-art),
# next-piece preview panel, and score/level/lines sidebar.

use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{
    column, row, panel, text_widget, button, label, statusbar,
    build_tree_with_title, with_height, with_width, with_flex, with_background
}

# =========================================================================
# TetrisApp
# =========================================================================

class TetrisApp:
    session: UISession

    static fn new() -> TetrisApp:
        val tree = TetrisApp._build_tree()
        val session = UISession.new(tree)
        return TetrisApp(session: session)

    me build_ui() -> UISession:
        me.session

    # Play field rows — 12 chars wide (10 cells + 2 borders)
    static fn _pf_top() -> text:  return "|----------|"
    static fn _pf_r01() -> text:  return "|          |"
    static fn _pf_r02() -> text:  return "|    []    |"
    static fn _pf_r03() -> text:  return "|    []    |"
    static fn _pf_r04() -> text:  return "|  [][][]  |"
    static fn _pf_r05() -> text:  return "|          |"
    static fn _pf_r06() -> text:  return "|          |"
    static fn _pf_r07() -> text:  return "|          |"
    static fn _pf_r08() -> text:  return "|    [][]  |"
    static fn _pf_r09() -> text:  return "|  [][]    |"
    static fn _pf_r10() -> text:  return "|          |"
    static fn _pf_r11() -> text:  return "|          |"
    static fn _pf_r12() -> text:  return "|[]        |"
    static fn _pf_r13() -> text:  return "|[]  []    |"
    static fn _pf_r14() -> text:  return "|[]  [][]  |"
    static fn _pf_r15() -> text:  return "|[][][]    |"
    static fn _pf_r16() -> text:  return "|[][]      |"
    static fn _pf_r17() -> text:  return "|[][][][][] |"
    static fn _pf_r18() -> text:  return "|[][][][]  |"
    static fn _pf_r19() -> text:  return "|[][][][][] |"
    static fn _pf_r20() -> text:  return "|[][][][][] |"
    static fn _pf_bot() -> text:  return "|__________|"

    # Next piece — I-tetromino preview
    static fn _next_r1() -> text: return ".....  "
    static fn _next_r2() -> text: return "[][][]  "
    static fn _next_r3() -> text: return ".....  "

    static fn _build_tree() -> UITree:
        # Toolbar
        val toolbar = row("toolbar", [
            button("btn_start",  "Start",  "tetris.start"),
            button("btn_pause",  "Pause",  "tetris.pause"),
            button("btn_reset",  "Reset",  "tetris.reset"),
        ])

        # Play field panel
        val field_panel = panel("field_panel", "Play Field", [
            text_widget("pf_top",  TetrisApp._pf_top()),
            text_widget("pf_r01",  TetrisApp._pf_r01()),
            text_widget("pf_r02",  TetrisApp._pf_r02()),
            text_widget("pf_r03",  TetrisApp._pf_r03()),
            text_widget("pf_r04",  TetrisApp._pf_r04()),
            text_widget("pf_r05",  TetrisApp._pf_r05()),
            text_widget("pf_r06",  TetrisApp._pf_r06()),
            text_widget("pf_r07",  TetrisApp._pf_r07()),
            text_widget("pf_r08",  TetrisApp._pf_r08()),
            text_widget("pf_r09",  TetrisApp._pf_r09()),
            text_widget("pf_r10",  TetrisApp._pf_r10()),
            text_widget("pf_r11",  TetrisApp._pf_r11()),
            text_widget("pf_r12",  TetrisApp._pf_r12()),
            text_widget("pf_r13",  TetrisApp._pf_r13()),
            text_widget("pf_r14",  TetrisApp._pf_r14()),
            text_widget("pf_r15",  TetrisApp._pf_r15()),
            text_widget("pf_r16",  TetrisApp._pf_r16()),
            text_widget("pf_r17",  TetrisApp._pf_r17()),
            text_widget("pf_r18",  TetrisApp._pf_r18()),
            text_widget("pf_r19",  TetrisApp._pf_r19()),
            text_widget("pf_r20",  TetrisApp._pf_r20()),
            text_widget("pf_bot",  TetrisApp._pf_bot()),
        ])

        # Sidebar: next piece + stats + controls
        val next_panel = panel("next_panel", "Next Piece", [
            text_widget("next_r1", TetrisApp._next_r1()),
            text_widget("next_r2", TetrisApp._next_r2()),
            text_widget("next_r3", TetrisApp._next_r3()),
        ])

        val stats_panel = panel("stats_panel", "Stats", [
            label("lbl_score",  "Score:  1840"),
            label("lbl_level",  "Level:  3"),
            label("lbl_lines",  "Lines:  18"),
        ])

        val controls_panel = panel("controls_panel", "Controls", [
            label("lbl_left",   "Left Arrow  — move left"),
            label("lbl_right",  "Right Arrow — move right"),
            label("lbl_up",     "Up Arrow    — rotate"),
            label("lbl_down",   "Down Arrow  — soft drop"),
            label("lbl_space",  "Space       — hard drop"),
        ])

        val sidebar = column("sidebar", [
            next_panel,
            stats_panel,
            controls_panel,
        ])

        # Status bar
        val status = statusbar("statusbar", "Status: Playing", "High Score: 9420")

        val root = column("root", [
            toolbar,
            row("main_area", [
                field_panel,
                sidebar,
            ]),
            status,
        ])

        return build_tree_with_title(root, "Tetris", "default")
