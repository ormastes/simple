# smux_contract.spl — Core data contracts for the SimpleOS terminal multiplexer (smux).
#
# Defines identity and state types for sessions, windows, and panes.
# No imports required — standalone value types, no fn main needed.

class SessionId:
    session_name: text
    created_at: int
    is_attached: bool
    session_index: int

    me matches_name(name: text) -> bool:
        return me.session_name == name

    me to_text() -> text:
        return "session[" + me.session_index.to_text() + "]:" + me.session_name

    static fn create(name: text, idx: int) -> SessionId:
        return SessionId(session_name: name, created_at: 0, is_attached: false, session_index: idx)


class WindowId:
    window_index: int
    title: text
    is_active: bool
    pane_count: int

    me activate() -> WindowId:
        return WindowId(window_index: me.window_index, title: me.title, is_active: true, pane_count: me.pane_count)

    me deactivate() -> WindowId:
        return WindowId(window_index: me.window_index, title: me.title, is_active: false, pane_count: me.pane_count)

    me to_text() -> text:
        return "window[" + me.window_index.to_text() + "]:" + me.title

    static fn create(idx: int, title: text) -> WindowId:
        return WindowId(window_index: idx, title: title, is_active: false, pane_count: 0)


class PaneId:
    pane_index: int
    width: int
    height: int
    scroll_pos: int

    me area() -> int:
        return me.width * me.height

    me resize(w: int, h: int) -> PaneId:
        return PaneId(pane_index: me.pane_index, width: w, height: h, scroll_pos: me.scroll_pos)

    me to_text() -> text:
        return "pane[" + me.pane_index.to_text() + "] " + me.width.to_text() + "x" + me.height.to_text()

    static fn create(idx: int, w: int, h: int) -> PaneId:
        return PaneId(pane_index: idx, width: w, height: h, scroll_pos: 0)


class SessionState:
    sid: SessionId
    f0_win: WindowId
    f1_win: WindowId
    f2_win: WindowId
    active_count: int

    me active_window() -> WindowId:
        if me.f0_win.is_active == true:
            return me.f0_win
        if me.f1_win.is_active == true:
            return me.f1_win
        if me.f2_win.is_active == true:
            return me.f2_win
        return me.f0_win

    me add_window(w: WindowId) -> SessionState:
        if me.active_count == 0:
            return SessionState(sid: me.sid, f0_win: w, f1_win: me.f1_win, f2_win: me.f2_win, active_count: 1)
        if me.active_count == 1:
            return SessionState(sid: me.sid, f0_win: me.f0_win, f1_win: w, f2_win: me.f2_win, active_count: 2)
        return SessionState(sid: me.sid, f0_win: me.f0_win, f1_win: me.f1_win, f2_win: w, active_count: 3)

    me is_empty() -> bool:
        return me.active_count == 0

    static fn create(s: SessionId) -> SessionState:
        val dummy = WindowId.create(0, "")
        return SessionState(sid: s, f0_win: dummy, f1_win: dummy, f2_win: dummy, active_count: 0)
