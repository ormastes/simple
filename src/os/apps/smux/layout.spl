#![allow(unnamed_duplicate_typed_args)]
# Smux Layout Helpers

class MuxSplitPlan:
    old_cols: i32
    old_rows: i32
    new_cols: i32
    new_rows: i32

fn smux_plan_split(cols: i32, rows: i32, direction: text) -> Result<MuxSplitPlan, text>:
    if direction == "horizontal":
        val old_rows = if rows > 1: rows / 2 else: 1
        val new_rows = if rows - old_rows > 0: rows - old_rows else: 1
        return Ok(MuxSplitPlan(old_cols: cols, old_rows: old_rows, new_cols: cols, new_rows: new_rows))

    if direction == "vertical":
        val old_cols = if cols > 1: cols / 2 else: 1
        val new_cols = if cols - old_cols > 0: cols - old_cols else: 1
        return Ok(MuxSplitPlan(old_cols: old_cols, old_rows: rows, new_cols: new_cols, new_rows: rows))

    Err("invalid split direction: {direction}")

