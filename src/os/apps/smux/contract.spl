#![allow(unnamed_duplicate_typed_args)]
# Smux Contract
#
# Shared types for the native SimpleOS tmux-like multiplexer.

enum MuxBackendKind:
    NativeShell
    ExternalTmux

class MuxSession:
    id: text
    name: text
    active_window_id: text
    attached_clients: i64
    created_at: text
    generation: i64

class MuxWindow:
    id: text
    session_id: text
    name: text
    index: i64
    active_pane_id: text

class MuxPane:
    id: text
    window_id: text
    index: i64
    state: text
    cols: i32
    rows: i32
    backend_kind: MuxBackendKind
    backend_handle: text
    last_command: text
    last_error: text

class MuxCapture:
    content: text
    pane_id: text
    rows: i64

class MuxClientAttachment:
    client_id: text
    session_id: text
    cols: i32
    rows: i32

class MuxAttachResult:
    attached: bool
    session_id: text
    client_id: text

class SmuxMetrics:
    startup_count: i64
    last_startup_ns: u64
    attach_count: i64
    detach_count: i64
    split_count: i64
    resize_count: i64
    send_text_count: i64
    send_command_count: i64
    capture_count: i64
