# service.spl — Authoritative session/window/pane state for the smux service.
#
# Global mutable service state stored in module-level vars.
# Provides session registry, window registry, pane registry, attach table,
# and observable counters.

use os.apps.smux.contract.{
    MuxSession, MuxWindow, MuxPane, MuxCapture, MuxClientAttachment,
    SmuxMetrics, MuxBackendKind
}
use os.apps.smux.buffer.{ScrollbackBuffer}

# =========================================================================
# Pane record — pane state + its scrollback buffer
# =========================================================================

class PaneRecord:
    pane: MuxPane
    buf: ScrollbackBuffer
    focus: bool

    me feed(line: text) -> PaneRecord:
        return PaneRecord(pane: me.pane, buf: me.buf.append(line), focus: me.focus)

    me resize(c: int, r: int) -> PaneRecord:
        val p = me.pane
        val np = MuxPane(
            id: p.id,
            window_id: p.window_id,
            session_id: p.session_id,
            backend_kind: p.backend_kind,
            state: p.state,
            cols: c,
            rows: r
        )
        return PaneRecord(pane: np, buf: me.buf, focus: me.focus)

    me capture(max_lines: int) -> MuxCapture:
        return MuxCapture.create(me.pane.id, me.buf.capture(max_lines), me.buf.line_count())

    static fn create(p: MuxPane) -> PaneRecord:
        return PaneRecord(pane: p, buf: ScrollbackBuffer.create(), focus: false)


# =========================================================================
# Service registry — flat fixed-capacity tables (up to 8 sessions)
# =========================================================================

class ServiceState:
    # sessions: up to 8
    s0: MuxSession
    s1: MuxSession
    s2: MuxSession
    s3: MuxSession
    s4: MuxSession
    s5: MuxSession
    s6: MuxSession
    s7: MuxSession
    session_count: int

    # windows: up to 8
    w0: MuxWindow
    w1: MuxWindow
    w2: MuxWindow
    w3: MuxWindow
    w4: MuxWindow
    w5: MuxWindow
    w6: MuxWindow
    w7: MuxWindow
    window_count: int

    # panes: up to 8
    p0: PaneRecord
    p1: PaneRecord
    p2: PaneRecord
    p3: PaneRecord
    p4: PaneRecord
    p5: PaneRecord
    p6: PaneRecord
    p7: PaneRecord
    pane_count: int

    # attach table: up to 4 clients
    c0: MuxClientAttachment
    c1: MuxClientAttachment
    c2: MuxClientAttachment
    c3: MuxClientAttachment
    client_count: int

    # counters
    next_id: int
    metrics: SmuxMetrics

    # --- session helpers ---

    me find_session_idx(sid: text) -> int:
        if me.session_count > 0:
            if me.s0.id == sid:
                return 0
        if me.session_count > 1:
            if me.s1.id == sid:
                return 1
        if me.session_count > 2:
            if me.s2.id == sid:
                return 2
        if me.session_count > 3:
            if me.s3.id == sid:
                return 3
        if me.session_count > 4:
            if me.s4.id == sid:
                return 4
        if me.session_count > 5:
            if me.s5.id == sid:
                return 5
        if me.session_count > 6:
            if me.s6.id == sid:
                return 6
        if me.session_count > 7:
            if me.s7.id == sid:
                return 7
        return -1

    me get_session(idx: int) -> MuxSession:
        if idx == 0:
            return me.s0
        if idx == 1:
            return me.s1
        if idx == 2:
            return me.s2
        if idx == 3:
            return me.s3
        if idx == 4:
            return me.s4
        if idx == 5:
            return me.s5
        if idx == 6:
            return me.s6
        if idx == 7:
            return me.s7
        return me.s0

    me add_session(s: MuxSession) -> ServiceState:
        var st = me
        val n = me.session_count
        if n == 0:
            st = ServiceState(s0: s, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: n + 1, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if n == 1:
            st = ServiceState(s0: me.s0, s1: s, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: n + 1, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if n == 2:
            st = ServiceState(s0: me.s0, s1: me.s1, s2: s, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: n + 1, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if n == 3:
            st = ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: s, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: n + 1, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if n >= 4:
            st = me
        return st

    # --- window helpers ---

    me find_window_idx(wid: text) -> int:
        if me.window_count > 0:
            if me.w0.id == wid:
                return 0
        if me.window_count > 1:
            if me.w1.id == wid:
                return 1
        if me.window_count > 2:
            if me.w2.id == wid:
                return 2
        if me.window_count > 3:
            if me.w3.id == wid:
                return 3
        if me.window_count > 4:
            if me.w4.id == wid:
                return 4
        if me.window_count > 5:
            if me.w5.id == wid:
                return 5
        if me.window_count > 6:
            if me.w6.id == wid:
                return 6
        if me.window_count > 7:
            if me.w7.id == wid:
                return 7
        return -1

    me get_window(idx: int) -> MuxWindow:
        if idx == 0:
            return me.w0
        if idx == 1:
            return me.w1
        if idx == 2:
            return me.w2
        if idx == 3:
            return me.w3
        if idx == 4:
            return me.w4
        if idx == 5:
            return me.w5
        if idx == 6:
            return me.w6
        if idx == 7:
            return me.w7
        return me.w0

    me add_window(w: MuxWindow) -> ServiceState:
        var st = me
        val n = me.window_count
        if n == 0:
            st = ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: w, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: n + 1, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if n == 1:
            st = ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: w, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: n + 1, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if n == 2:
            st = ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: w, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: n + 1, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if n == 3:
            st = ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: w, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: n + 1, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if n >= 4:
            st = me
        return st

    # --- pane helpers ---

    me find_pane_idx(pid: text) -> int:
        if me.pane_count > 0:
            if me.p0.pane.id == pid:
                return 0
        if me.pane_count > 1:
            if me.p1.pane.id == pid:
                return 1
        if me.pane_count > 2:
            if me.p2.pane.id == pid:
                return 2
        if me.pane_count > 3:
            if me.p3.pane.id == pid:
                return 3
        if me.pane_count > 4:
            if me.p4.pane.id == pid:
                return 4
        if me.pane_count > 5:
            if me.p5.pane.id == pid:
                return 5
        if me.pane_count > 6:
            if me.p6.pane.id == pid:
                return 6
        if me.pane_count > 7:
            if me.p7.pane.id == pid:
                return 7
        return -1

    me get_pane(idx: int) -> PaneRecord:
        if idx == 0:
            return me.p0
        if idx == 1:
            return me.p1
        if idx == 2:
            return me.p2
        if idx == 3:
            return me.p3
        if idx == 4:
            return me.p4
        if idx == 5:
            return me.p5
        if idx == 6:
            return me.p6
        if idx == 7:
            return me.p7
        return me.p0

    me replace_pane(idx: int, pr: PaneRecord) -> ServiceState:
        if idx == 0:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: pr, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if idx == 1:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: pr, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if idx == 2:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: pr, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if idx == 3:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: pr, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if idx == 4:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: pr, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if idx == 5:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: pr, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if idx == 6:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: pr, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        if idx == 7:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: pr, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)
        return me

    me add_pane(pr: PaneRecord) -> ServiceState:
        val n = me.pane_count
        if n == 0:
            return me.replace_pane(0, pr).with_pane_count(n + 1)
        if n == 1:
            return me.replace_pane(1, pr).with_pane_count(n + 1)
        if n == 2:
            return me.replace_pane(2, pr).with_pane_count(n + 1)
        if n == 3:
            return me.replace_pane(3, pr).with_pane_count(n + 1)
        if n == 4:
            return me.replace_pane(4, pr).with_pane_count(n + 1)
        if n == 5:
            return me.replace_pane(5, pr).with_pane_count(n + 1)
        if n == 6:
            return me.replace_pane(6, pr).with_pane_count(n + 1)
        if n == 7:
            return me.replace_pane(7, pr).with_pane_count(n + 1)
        return me

    me with_pane_count(n: int) -> ServiceState:
        return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: n, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: me.metrics)

    me with_metrics(m: SmuxMetrics) -> ServiceState:
        return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: me.next_id, metrics: m)

    me with_next_id(n: int) -> ServiceState:
        return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count, next_id: n, metrics: me.metrics)

    # --- client helpers ---

    me find_client_idx(cid: text) -> int:
        if me.client_count > 0:
            if me.c0.client_id == cid:
                return 0
        if me.client_count > 1:
            if me.c1.client_id == cid:
                return 1
        if me.client_count > 2:
            if me.c2.client_id == cid:
                return 2
        if me.client_count > 3:
            if me.c3.client_id == cid:
                return 3
        return -1

    me get_client(idx: int) -> MuxClientAttachment:
        if idx == 0:
            return me.c0
        if idx == 1:
            return me.c1
        if idx == 2:
            return me.c2
        return me.c3

    me add_client(c: MuxClientAttachment) -> ServiceState:
        val n = me.client_count
        if n == 0:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: c, c1: me.c1, c2: me.c2, c3: me.c3, client_count: n + 1, next_id: me.next_id, metrics: me.metrics)
        if n == 1:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: c, c2: me.c2, c3: me.c3, client_count: n + 1, next_id: me.next_id, metrics: me.metrics)
        if n == 2:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: c, c3: me.c3, client_count: n + 1, next_id: me.next_id, metrics: me.metrics)
        if n == 3:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: c, client_count: n + 1, next_id: me.next_id, metrics: me.metrics)
        return me

    me remove_client(idx: int) -> ServiceState:
        val detached = MuxClientAttachment(client_id: "", session_id: "", attached: false, cols: 0, rows: 0)
        if idx == 0:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: detached, c1: me.c1, c2: me.c2, c3: me.c3, client_count: me.client_count - 1, next_id: me.next_id, metrics: me.metrics)
        if idx == 1:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: detached, c2: me.c2, c3: me.c3, client_count: me.client_count - 1, next_id: me.next_id, metrics: me.metrics)
        if idx == 2:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: detached, c3: me.c3, client_count: me.client_count - 1, next_id: me.next_id, metrics: me.metrics)
        if idx == 3:
            return ServiceState(s0: me.s0, s1: me.s1, s2: me.s2, s3: me.s3, s4: me.s4, s5: me.s5, s6: me.s6, s7: me.s7, session_count: me.session_count, w0: me.w0, w1: me.w1, w2: me.w2, w3: me.w3, w4: me.w4, w5: me.w5, w6: me.w6, w7: me.w7, window_count: me.window_count, p0: me.p0, p1: me.p1, p2: me.p2, p3: me.p3, p4: me.p4, p5: me.p5, p6: me.p6, p7: me.p7, pane_count: me.pane_count, c0: me.c0, c1: me.c1, c2: me.c2, c3: detached, client_count: me.client_count - 1, next_id: me.next_id, metrics: me.metrics)
        return me

    static fn empty() -> ServiceState:
        val dummy_session = MuxSession.create("", "")
        val dummy_window = MuxWindow.create("", "", "")
        val dummy_pane = MuxPane.create("", "", "")
        val dummy_pr = PaneRecord.create(dummy_pane)
        val dummy_client = MuxClientAttachment(client_id: "", session_id: "", attached: false, cols: 0, rows: 0)
        return ServiceState(
            s0: dummy_session, s1: dummy_session, s2: dummy_session, s3: dummy_session,
            s4: dummy_session, s5: dummy_session, s6: dummy_session, s7: dummy_session,
            session_count: 0,
            w0: dummy_window, w1: dummy_window, w2: dummy_window, w3: dummy_window,
            w4: dummy_window, w5: dummy_window, w6: dummy_window, w7: dummy_window,
            window_count: 0,
            p0: dummy_pr, p1: dummy_pr, p2: dummy_pr, p3: dummy_pr,
            p4: dummy_pr, p5: dummy_pr, p6: dummy_pr, p7: dummy_pr,
            pane_count: 0,
            c0: dummy_client, c1: dummy_client, c2: dummy_client, c3: dummy_client,
            client_count: 0,
            next_id: 1,
            metrics: SmuxMetrics.zero()
        )
