# smux_remote.spl — Filesystem identity and remote-launch helpers for smux.
#
# Provides the app ID marker used by the OS package registry and
# the deferred remote-launch stub.

pub val SMUX_APP_ID: text = "smux"

pub fn smux_ready_marker(version: int) -> text:
    return SMUX_APP_ID + "-v" + version.to_text()

pub fn smux_remote_launch_once(version: int) -> bool:
    # Stub: native service needs no external launch in this release
    pass_do_nothing
    return true

pub fn smux_remote_main():
    pass_do_nothing
