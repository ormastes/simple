#![allow(unnamed_duplicate_typed_args)]
# Smux Remote — minimal filesystem-process entrypoints for disk staging.


use os.userlib.process.{getpid, yield_}
use os.apps.smux.api.{smux_create_session, smux_list_sessions}
use os.kernel.log.klog_api.{log_init, log_info, log_warn, log_error, log_raw, log_raw_println}

val SMUX_APP_ID: text = "/sys/apps/smux"

fn _ensure_session(name: text):
    if smux_list_sessions().len() > 0:
        return
    val _created = smux_create_session(name)

pub fn smux_ready_marker(process_id: u64) -> text:
    "[smux] started app_id={SMUX_APP_ID} mode=filesystem-process pid={process_id}"

pub fn smux_remote_launch_once(process_id: u64) -> bool:
    _ensure_session("main")
    log_info("[app.smux] " + smux_ready_marker(process_id))
    true

pub fn smux_remote_main():
    _ensure_session("main")
    log_info("[app.smux] " + smux_ready_marker(getpid()))
    while true:
        yield_()
