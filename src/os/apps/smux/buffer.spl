#![allow(unnamed_duplicate_typed_args)]
# Smux Capture Buffer

use os.apps.smux.contract.{MuxCapture}

class CaptureBuffer:
    lines: [text]
    max_lines: i64

impl CaptureBuffer:

    static fn new(max_lines: i64) -> CaptureBuffer:
        CaptureBuffer(
            lines: [],
            max_lines: if max_lines > 0: max_lines else: 200
        )

    me append_text(output: text):
        if output == "":
            return

        val parts = output.split("\n")
        for part in parts:
            self.lines = self.lines.push(part)

        while self.lines.len() > self.max_lines:
            self.lines = self.lines[1:]

    fn capture(pane_id: text, history_lines: i64) -> MuxCapture:
        val limit = if history_lines > 0: history_lines else: self.max_lines
        var start = 0
        if self.lines.len() > limit:
            start = self.lines.len() - limit

        var selected: [text] = []
        var i = start
        while i < self.lines.len():
            selected = selected.push(self.lines[i])
            i = i + 1

        val content = selected.join("\n")
        val rows = selected.len()
        MuxCapture(content: content, pane_id: pane_id, rows: rows)

