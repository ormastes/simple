use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{
    column, row, panel, text_widget, button, label, statusbar,
    build_tree_with_title
}

class FileExplorer:
    root_path: text

    static fn new(path: text) -> FileExplorer:
        FileExplorer(root_path: path)

    me build_ui() -> UISession:
        val address_bar = row("fe_addr", [
            label("fe_path_label", "Path:"),
            label("fe_path_val", me.root_path),
            button("fe_go", "Go", "navigate")
        ])

        val tree_view = panel("fe_tree", "Directory Tree", [
            text_widget("fe_t1", "/ (root)"),
            text_widget("fe_t2", "  +-- bin/"),
            text_widget("fe_t3", "  +-- boot/"),
            text_widget("fe_t4", "  +-- dev/"),
            text_widget("fe_t5", "  +-- etc/"),
            text_widget("fe_t6", "  |   +-- network/"),
            text_widget("fe_t7", "  |   +-- init.d/"),
            text_widget("fe_t8", "  +-- home/"),
            text_widget("fe_t9", "  |   +-- user/"),
            text_widget("fe_t10", "  +-- proc/"),
            text_widget("fe_t11", "  +-- sys/"),
            text_widget("fe_t12", "  +-- tmp/"),
            text_widget("fe_t13", "  +-- usr/"),
            text_widget("fe_t14", "  |   +-- bin/"),
            text_widget("fe_t15", "  |   +-- lib/"),
            text_widget("fe_t16", "  +-- var/"),
            text_widget("fe_t17", "      +-- log/")
        ])

        val status = statusbar("fe_status", "17 entries", me.root_path)

        val root = column("fe_root", [
            address_bar,
            tree_view,
            status
        ])

        val tree = build_tree_with_title(root, "File Explorer", "dark")
        UISession.new(tree)
