use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class SettingsApp:

    static fn new() -> SettingsApp:
        SettingsApp()

    me build_ui() -> UISession:
        val sysinfo = panel("sysinfo", "System Information", [
            row("sysinfo_os", [
                label("lbl_os", "OS Name:"),
                text_widget("val_os", "SimpleOS")
            ]),
            row("sysinfo_ver", [
                label("lbl_ver", "Version:"),
                text_widget("val_ver", "0.1.0")
            ]),
            row("sysinfo_arch", [
                label("lbl_arch", "Architecture:"),
                text_widget("val_arch", "x86_64")
            ]),
            row("sysinfo_kernel", [
                label("lbl_kernel", "Kernel:"),
                text_widget("val_kernel", "simple-kernel 0.1.0")
            ]),
            row("sysinfo_uptime", [
                label("lbl_uptime", "Uptime:"),
                text_widget("val_uptime", "0d 0h 5m")
            ])
        ])

        val display_settings = panel("display", "Display Settings", [
            row("disp_res", [
                label("lbl_res", "Resolution:"),
                text_widget("val_res", "1920 x 1080"),
                button("btn_res_change", "Change", "settings.display.resolution")
            ]),
            row("disp_depth", [
                label("lbl_depth", "Color Depth:"),
                text_widget("val_depth", "32-bit (True Color)")
            ]),
            row("disp_refresh", [
                label("lbl_refresh", "Refresh Rate:"),
                text_widget("val_refresh", "60 Hz")
            ]),
            row("disp_scale", [
                label("lbl_scale", "UI Scale:"),
                text_widget("val_scale", "100%"),
                button("btn_scale_up", "+", "settings.display.scale.up"),
                button("btn_scale_down", "-", "settings.display.scale.down")
            ]),
            row("disp_theme", [
                label("lbl_theme", "Theme:"),
                text_widget("val_theme", "Dark"),
                button("btn_theme_toggle", "Toggle", "settings.display.theme")
            ])
        ])

        val memory_info = panel("memory", "Memory", [
            row("mem_total", [
                label("lbl_mem_total", "Total RAM:"),
                text_widget("val_mem_total", "4096 MB")
            ]),
            row("mem_used", [
                label("lbl_mem_used", "Used:"),
                text_widget("val_mem_used", "512 MB")
            ]),
            row("mem_free", [
                label("lbl_mem_free", "Free:"),
                text_widget("val_mem_free", "3584 MB")
            ]),
            row("mem_swap", [
                label("lbl_swap", "Swap:"),
                text_widget("val_swap", "0 MB / 0 MB")
            ])
        ])

        val network_settings = panel("network", "Network", [
            row("net_hostname", [
                label("lbl_hostname", "Hostname:"),
                text_widget("val_hostname", "simpleos-desktop")
            ]),
            row("net_ip", [
                label("lbl_ip", "IP Address:"),
                text_widget("val_ip", "192.168.1.100")
            ]),
            row("net_dns", [
                label("lbl_dns", "DNS:"),
                text_widget("val_dns", "8.8.8.8")
            ]),
            button("btn_net_config", "Configure Network", "settings.network.configure")
        ])

        val apply_row = row("settings_apply", [
            button("btn_apply", "Apply", "settings.apply"),
            button("btn_reset", "Reset to Defaults", "settings.reset")
        ])

        val status = statusbar("settings_status", "SimpleOS 0.1.0", "Settings")

        val root = column("settings_root", [
            sysinfo,
            display_settings,
            memory_info,
            network_settings,
            apply_row,
            status
        ])

        val tree = build_tree_with_title(root, "Settings", "dark")
        UISession.new(tree)
