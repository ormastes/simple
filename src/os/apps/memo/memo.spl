use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class MemoApp:

    static fn new() -> MemoApp:
        MemoApp()

    me build_ui() -> UISession:
        val toolbar = row("memo_toolbar", [
            button("btn_new", "New", "memo.new"),
            button("btn_open", "Open", "memo.open"),
            button("btn_save", "Save", "memo.save"),
            button("btn_save_as", "Save As", "memo.save_as"),
            button("btn_print", "Print", "memo.print"),
            button("btn_find", "Find", "memo.find")
        ])

        val format_bar = row("memo_format_bar", [
            button("btn_bold", "Bold", "memo.format.bold"),
            button("btn_italic", "Italic", "memo.format.italic"),
            button("btn_underline", "Underline", "memo.format.underline"),
            button("btn_align_left", "Left", "memo.align.left"),
            button("btn_align_center", "Center", "memo.align.center"),
            button("btn_align_right", "Right", "memo.align.right")
        ])

        val text_area = panel("memo_text_area", "Document", [
            text_widget("line_1", "Welcome to Memo — SimpleOS notepad"),
            text_widget("line_2", ""),
            text_widget("line_3", "Start typing your notes here."),
            text_widget("line_4", ""),
            text_widget("line_5", "Features:"),
            text_widget("line_6", "  - Plain text editing"),
            text_widget("line_7", "  - File open and save"),
            text_widget("line_8", "  - Find and replace"),
            text_widget("line_9", "  - Print support")
        ])

        val status = statusbar("memo_status", "Lines: 9  Chars: 142", "Untitled.txt  |  UTF-8")

        val root = column("memo_root", [
            toolbar,
            format_bar,
            text_area,
            status
        ])

        val tree = build_tree_with_title(root, "Memo", "dark")
        UISession.new(tree)
