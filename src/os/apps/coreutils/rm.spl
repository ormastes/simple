# coreutils/rm — unlink files
#
# Supports -f to suppress ENOENT (missing-file) failures.
#
# MDSOC: feature dimension, coreutils layer

extern fn vfs_unlink(path: text) -> i32
extern fn println(msg: text)

val _ENOENT_NEG: i32 = 0 - 2

fn rm_one(path: text, force: bool) -> i32:
    """Unlink one path. When force is true, missing files count as success.
    Returns 0 on success, -errno on failure."""
    val r = vfs_unlink(path)
    if r == 0:
        return 0i32
    if force and r == _ENOENT_NEG:
        return 0i32
    r

fn main_rm(args: [text]) -> i32:
    """Remove files.

    Usage: rm [-f] path [path...]
    """
    var force: bool = false
    var paths: [text] = []
    var i: u64 = 0
    while i < args.len():
        val a = args[i]
        if a == "-f":
            force = true
        elif a == "--help":
            println("usage: rm [-f] path [path...]")
            return 0i32
        else:
            paths.push(a)
        i = i + 1
    if paths.len() == 0u64:
        println("rm: missing operand")
        return 1i32
    var failures: i32 = 0
    var j: u64 = 0
    while j < paths.len():
        val r = rm_one(paths[j], force)
        if r != 0:
            failures = failures + 1
        j = j + 1
    failures
