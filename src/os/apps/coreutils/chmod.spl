# chmod — Change file permissions
#
# Coreutils chmod: parse an octal mode string and apply it to one or more paths.
# No inheritance. Externs declared; not implemented here.
#
# MDSOC: feature dimension, coreutils layer

extern fn vfs_chmod(path: text, mode: u32) -> i32
extern fn println(msg: text)

# =========================================================================
# parse_octal — Convert octal text to i64, -1 on failure
# =========================================================================

fn parse_octal(s: text) -> i64:
    """Parse an octal mode string (e.g. "0755", "644") to i64.

    Returns -1 if the string is empty or contains non-octal digits.
    Accepts an optional leading '0'.
    """
    if s.len() == 0:
        return -1i64
    var result: i64 = 0
    var started = false
    var i = 0
    while i < s.len():
        val ch = s.char_at(i)
        if ch == "0" and not started:
            started = true
            i = i + 1
        elif ch >= "0" and ch <= "7":
            started = true
            val digit = ch.to_i64() - "0".to_i64()
            result = result * 8i64 + digit
            i = i + 1
        else:
            return -1i64
    if not started:
        return -1i64
    return result

# =========================================================================
# chmod_one — Apply mode to a single path
# =========================================================================

fn chmod_one(path: text, mode: u32) -> i32:
    """Call vfs_chmod for a single path. Returns vfs_chmod return value."""
    return vfs_chmod(path, mode)

# =========================================================================
# main_chmod — Entry point
# =========================================================================

fn main_chmod(args: [text]) -> i32:
    """chmod: change file permissions.

    Usage: chmod MODE PATH [PATH...]
    MODE is an octal string such as "0755" or "644".
    Returns 1 on bad argument count or invalid mode.
    Returns non-zero on any vfs_chmod failure.
    """
    if args.len() < 2:
        println("Usage: chmod MODE PATH [PATH...]")
        return 1i32
    val mode_text = args[0]
    val mode_val = parse_octal(mode_text)
    if mode_val < 0i64:
        println("chmod: invalid mode")
        return 1i32
    var failures: i32 = 0
    var i = 1
    while i < args.len():
        val path = args[i]
        val rc = chmod_one(path, mode_val as u32)
        if rc != 0:
            println("chmod: {path}: operation failed ({rc})")
            failures = failures + 1
        i = i + 1
    return failures
