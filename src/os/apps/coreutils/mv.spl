# coreutils/mv — move / rename file
#
# Tries vfs_rename first; on -EXDEV (18) falls back to cp + unlink.
#
# MDSOC: feature dimension, coreutils layer

use os.apps.coreutils.cp.{cp_one}

extern fn vfs_rename(old_path: text, new_path: text) -> i32
extern fn vfs_unlink(path: text) -> i32
extern fn println(msg: text)

val _EXDEV_NEG: i32 = 0 - 18

fn mv_one(src: text, dst: text) -> i32:
    """Rename src to dst. Falls back to copy+unlink across devices.
    Returns 0 on success, -errno otherwise."""
    val r = vfs_rename(src, dst)
    if r == 0:
        return 0i32
    if r != _EXDEV_NEG:
        return r
    val cr = cp_one(src, dst)
    if cr != 0:
        return cr
    vfs_unlink(src)

fn main_mv(args: [text]) -> i32:
    """Move a file.

    Usage: mv SRC DST
    """
    if args.len() != 2u64:
        println("Usage: mv SRC DST")
        return 1i32
    mv_one(src: args[0u64], dst: args[1u64])
