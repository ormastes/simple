# coreutils/kill — send signal to process(es)
#
# Accepts numeric (-9) and symbolic (-SIGINT) signal flags.
# Default signal when unspecified is SIGTERM (15).
#
# MDSOC: feature dimension, coreutils layer

extern fn signal_deliver(target_pid: u64, signo: i32) -> i32
extern fn println(msg: text)

val _SIGINT: i32 = 2
val _SIGKILL: i32 = 9
val _SIGUSR1: i32 = 10
val _SIGUSR2: i32 = 12
val _SIGTERM: i32 = 15

fn parse_signal(s: text) -> i32:
    """Parse a signal token that begins with '-'. Returns signo or -1."""
    if s.len() < 2u64:
        return -1i32
    if s[0u64] != "-":
        return -1i32
    val rest = s.substring(1u64, s.len())
    if rest == "9":
        return _SIGKILL
    if rest == "15":
        return _SIGTERM
    if rest == "2":
        return _SIGINT
    if rest == "10":
        return _SIGUSR1
    if rest == "12":
        return _SIGUSR2
    if rest == "SIGINT":
        return _SIGINT
    if rest == "SIGKILL":
        return _SIGKILL
    if rest == "SIGTERM":
        return _SIGTERM
    if rest == "SIGUSR1":
        return _SIGUSR1
    if rest == "SIGUSR2":
        return _SIGUSR2
    -1i32

fn parse_pid(s: text) -> i64:
    """Parse an unsigned decimal pid. Returns -1 on invalid input."""
    if s.len() == 0u64:
        return -1i64
    var n: i64 = 0
    var i: u64 = 0
    while i < s.len():
        val ch = s[i]
        if ch < "0" or ch > "9":
            return -1i64
        n = n * 10i64 + (ch.to_i64() - "0".to_i64())
        i = i + 1
    n

fn main_kill(args: [text]) -> i32:
    """Send a signal to one or more processes.

    Usage: kill [-SIGNAL] PID [PID...]
    """
    if args.len() == 0u64:
        println("Usage: kill [-SIGNAL] PID [PID...]")
        return 1i32

    var signo: i32 = _SIGTERM
    var start: u64 = 0
    if args[0u64].len() > 0u64 and args[0u64][0u64] == "-":
        if args[0u64] == "--help":
            println("usage: kill [-SIGNAL] PID [PID...]")
            return 0i32
        val s = parse_signal(args[0u64])
        if s < 0:
            println("kill: unknown signal")
            return 1i32
        signo = s
        start = 1u64

    if start >= args.len():
        println("kill: missing pid")
        return 1i32

    var failures: i32 = 0
    var i: u64 = start
    while i < args.len():
        val pid = parse_pid(args[i])
        if pid < 0i64:
            println("kill: invalid pid")
            failures = failures + 1
        else:
            val r = signal_deliver(pid as u64, signo)
            if r != 0:
                failures = failures + 1
        i = i + 1
    failures
