# coreutils/mem — show system memory information
#
# Thin command wrapper around the existing system info syscall helpers.
#
# MDSOC: feature dimension, coreutils layer

use os.userlib.system.{mem_info}
extern fn println(msg: text)

fn main_mem(args: [text]) -> i32:
    """Print memory usage information.

    Usage: mem [--help]
    """
    if args.len() > 0u64 and args[0u64] == "--help":
        println("usage: mem")
        return 0i32

    val result = mem_info()
    if result.is_err():
        println("mem: {result.unwrap_err()}")
        return 1i32

    val info = result.unwrap()
    println("total={info.total_pages} free={info.free_pages} used={info.used_pages} page_size={info.page_size}")
    0i32
