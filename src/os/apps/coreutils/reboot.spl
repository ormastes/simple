# coreutils/reboot — request a system restart
# MDSOC: feature dimension, coreutils layer

use os.userlib.system.{reboot}

extern fn println(msg: text)

fn main_reboot(args: [text]) -> i32:
    """Validate a reboot request.

    Usage: reboot [--help]
    """
    if args.len() > 0u64 and args[0u64] == "--help":
        println("usage: reboot")
        return 0i32

    val result = reboot()
    if result.is_err():
        println("reboot: {result.unwrap_err()}")
        return 1i32
    0i32
