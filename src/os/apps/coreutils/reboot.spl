# coreutils/reboot — validate a reboot request
#
# The shell MVP slice validates command wiring here; the kernel-facing reboot
# primitive is not exposed in this write scope.
#
# MDSOC: feature dimension, coreutils layer

extern fn println(msg: text)

fn main_reboot(args: [text]) -> i32:
    """Validate a reboot request.

    Usage: reboot [--help]
    """
    if args.len() > 0u64 and args[0u64] == "--help":
        println("usage: reboot")
        return 0i32

    println("reboot: restart is not implemented in this build")
    1i32
