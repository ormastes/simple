# coreutils/cp — copy file
#
# Simple two-arg copy: open src, read all, write dst, close both.
# No recursive -r in this pass; single-file only.
#
# MDSOC: feature dimension, coreutils layer

extern fn vfs_open(path: text, flags: i32) -> i64
extern fn vfs_create(path: text, mode: u32) -> i64
extern fn vfs_read_all(handle: i64) -> [u8]
extern fn vfs_write_all(handle: i64, data: [u8]) -> i64
extern fn vfs_close(handle: i64) -> i32
extern fn println(msg: text)

val _O_RDONLY: i32 = 0
val _DEFAULT_MODE: u32 = 0o644u32

fn cp_one(src: text, dst: text) -> i32:
    """Copy src to dst. Returns 0 on success, -errno on IO failure."""
    val src_h = vfs_open(src, _O_RDONLY)
    if src_h < 0:
        return src_h as i32
    val data = vfs_read_all(src_h)
    vfs_close(src_h)
    val dst_h = vfs_create(dst, _DEFAULT_MODE)
    if dst_h < 0:
        return dst_h as i32
    val wrote = vfs_write_all(dst_h, data)
    vfs_close(dst_h)
    if wrote < 0:
        return wrote as i32
    0

fn main_cp(args: [text]) -> i32:
    """Copy a single file.

    Usage: cp SRC DST
    """
    if args.len() != 2u64:
        println("Usage: cp SRC DST")
        return 1i32
    cp_one(src: args[0u64], dst: args[1u64])
