    pkgs = pkgs.push(Package(name: "simple-screenshot", version: "1.0.1", size: "0.8 MB", description: "Screen capture tool with region selection", category: "Utilities", status: PackageStatus.Available, installed_version: ""))
    pkgs = pkgs.push(Package(name: "simple-archive", version: "1.2.0", size: "1.5 MB", description: "Archive and compression tools (tar, gzip, zstd)", category: "Utilities", status: PackageStatus.Updatable, installed_version: "1.1.0"))
    pkgs = pkgs.push(Package(name: "simple-disk-manager", version: "1.0.0", size: "1.9 MB", description: "Disk and partition management utility", category: "Utilities", status: PackageStatus.Available, installed_version: ""))

    # --- Network (5) ---
