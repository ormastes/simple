# Package Manager — Software Package Management
#
# Browse, install, remove, and update software packages.
# Tabbed interface with search, category filtering, and
# a detail panel for inspecting selected packages.
#
# MDSOC: feature dimension, apps layer

use common.ui.builder.{
    column, row, panel, button, text_widget, label,
    statusbar, menubar, table_widget, build_tree_with_title,
    with_flex, with_width, tabs
}
use common.ui.widget.{WidgetNode, UITree, UIEvent}
use common.ui.session.{UISession}

# =========================================================================
# Data Models
# =========================================================================

enum PackageStatus:
    """Installation status of a package."""
    Installed
    Available
    Updatable

struct Package:
    """A software package with metadata."""
    name: text
    version: text
    size: text
    description: text
    category: text
    status: PackageStatus
    installed_version: text

# =========================================================================
# Helpers
# =========================================================================

fn _status_label(status: PackageStatus) -> text:
    """Format package status for display."""
    match status:
        PackageStatus.Installed => "[installed]"
        PackageStatus.Available => "[available]"
        PackageStatus.Updatable => "[updatable]"

fn _status_short(status: PackageStatus) -> text:
    """Short status tag for table rows."""
    match status:
        PackageStatus.Installed => "Inst"
        PackageStatus.Available => "Avail"
        PackageStatus.Updatable => "Upd"

fn _repeat_char(ch: text, count: i32) -> text:
    """Repeat a character count times."""
    var result = ""
    var i = 0
    while i < count:
        result = "{result}{ch}"
        i = i + 1
    return result

fn _progress_bar(percent: i32, width: i32) -> text:
    """Build an ASCII progress bar like [########....] 67%."""
    val clamped = if percent < 0: 0
        elif percent > 100: 100
        else: percent
    val filled = (clamped * width) / 100
    val empty = width - filled
    var bar = "["
    bar = bar + _repeat_char("#", filled)
    bar = bar + _repeat_char(".", empty)
    bar = bar + "] {clamped}%"
    return bar

fn _tab_index(tab_name: text) -> i32:
    """Convert tab name to index."""
    match tab_name:
        "Installed" => 0
        "Available" => 1
        "Updates" => 2
        _ => 0

# =========================================================================
# Sample Data
# =========================================================================

