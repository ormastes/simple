    pkgs = pkgs.push(Package(name: "simple-build-tools", version: "1.2.0", size: "3.8 MB", description: "Build system, linker wrapper, and native compilation tools", category: "Development", status: PackageStatus.Installed, installed_version: "1.2.0"))
    pkgs = pkgs.push(Package(name: "simple-test-runner", version: "1.1.0", size: "2.4 MB", description: "SSpec test framework and runner with BDD matchers", category: "Development", status: PackageStatus.Installed, installed_version: "1.1.0"))
