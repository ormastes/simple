use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class PackageManagerApp:

    static fn new() -> PackageManagerApp:
        PackageManagerApp()

    me build_ui() -> UISession:
        val search_bar = row("pkg_search_bar", [
            label("lbl_pkg_search", "Search:"),
            text_widget("pkg_search_input", ""),
            button("btn_pkg_search", "Find", "pkgmgr.search"),
            button("btn_pkg_refresh", "Refresh List", "pkgmgr.refresh")
        ])

        val pkg_header = row("pkg_header", [
            label("hdr_pkg_name", "Package"),
            label("hdr_pkg_ver", "Version"),
            label("hdr_pkg_status", "Status"),
            label("hdr_pkg_size", "Size")
        ])

        val pkg1 = row("pkg_simpleos_base", [
            text_widget("pkg1_name", "simpleos-base"),
            text_widget("pkg1_ver", "0.1.0"),
            text_widget("pkg1_status", "Installed"),
            text_widget("pkg1_size", "42.3 MB")
        ])

        val pkg2 = row("pkg_simple_compiler", [
            text_widget("pkg2_name", "simple-compiler"),
            text_widget("pkg2_ver", "1.0.0"),
            text_widget("pkg2_status", "Installed"),
            text_widget("pkg2_size", "18.7 MB")
        ])

        val pkg3 = row("pkg_simple_stdlib", [
            text_widget("pkg3_name", "simple-stdlib"),
            text_widget("pkg3_ver", "1.0.1"),
            text_widget("pkg3_status", "Update available"),
            text_widget("pkg3_size", "9.2 MB")
        ])

        val pkg4 = row("pkg_simple_gpu", [
            text_widget("pkg4_name", "simple-gpu"),
            text_widget("pkg4_ver", "0.3.0"),
            text_widget("pkg4_status", "Available"),
            text_widget("pkg4_size", "55.1 MB")
        ])

        val pkg5 = row("pkg_simple_net", [
            text_widget("pkg5_name", "simple-net"),
            text_widget("pkg5_ver", "0.2.4"),
            text_widget("pkg5_status", "Installed"),
            text_widget("pkg5_size", "6.8 MB")
        ])

        val pkg6 = row("pkg_simple_audio", [
            text_widget("pkg6_name", "simple-audio"),
            text_widget("pkg6_ver", "0.1.2"),
            text_widget("pkg6_status", "Available"),
            text_widget("pkg6_size", "4.5 MB")
        ])

        val package_list = panel("package_list", "Packages", [
            pkg_header,
            pkg1,
            pkg2,
            pkg3,
            pkg4,
            pkg5,
            pkg6
        ])

        val actions = row("pkg_actions", [
            button("btn_install", "Install", "pkgmgr.install"),
            button("btn_remove", "Remove", "pkgmgr.remove"),
            button("btn_update", "Update", "pkgmgr.update"),
            button("btn_update_all", "Update All", "pkgmgr.update_all")
        ])

        val status = statusbar("pkgmgr_status", "Installed: 4  Available: 2", "1 update available")

        val root = column("pkgmgr_root", [
            search_bar,
            package_list,
            actions,
            status
        ])

        val tree = build_tree_with_title(root, "Package Manager", "dark")
        UISession.new(tree)
