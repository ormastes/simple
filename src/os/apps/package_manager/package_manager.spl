    pkgs = pkgs.push(Package(name: "simple-compiler", version: "3.1.0", size: "18.2 MB", description: "Simple language compiler with Cranelift backend", category: "Development", status: PackageStatus.Installed, installed_version: "3.1.0"))
    pkgs = pkgs.push(Package(name: "simple-lsp", version: "2.0.1", size: "6.3 MB", description: "Language Server Protocol implementation for Simple", category: "Development", status: PackageStatus.Updatable, installed_version: "1.9.0"))
