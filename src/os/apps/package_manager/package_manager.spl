    # --- System (6) ---
    pkgs = pkgs.push(Package(name: "simple-kernel", version: "1.2.0", size: "4.8 MB", description: "SimpleOS microkernel with scheduler and memory manager", category: "System", status: PackageStatus.Installed, installed_version: "1.2.0"))
    pkgs = pkgs.push(Package(name: "simple-init", version: "1.0.3", size: "1.2 MB", description: "Init system and service manager for SimpleOS", category: "System", status: PackageStatus.Installed, installed_version: "1.0.3"))
