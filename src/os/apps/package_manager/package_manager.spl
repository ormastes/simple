use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}
use os.services.pkg.pkg_service.{pkg_service_init, pkg_service_install, pkg_service_remove, pkg_service_list_installed, pkg_service_list_available, pkg_service_search}

extern fn serial_println(msg: text)

class PackageManagerApp:

    static fn new() -> PackageManagerApp:
        pkg_service_init()
        PackageManagerApp()

    me build_ui() -> UISession:
        val search_bar = row("pkg_search_bar", [
            label("lbl_pkg_search", "Search:"),
            text_widget("pkg_search_input", ""),
            button("btn_pkg_search", "Find", "pkgmgr.search"),
            button("btn_pkg_refresh", "Refresh List", "pkgmgr.refresh")
        ])

        val pkg_header = row("pkg_header", [
            label("hdr_pkg_name", "Package"),
            label("hdr_pkg_status", "Status")
        ])

        val installed = pkg_service_list_installed()
        val available = pkg_service_list_available()

        serial_println("[pkgmgr_app] installed={installed.len()} available={available.len()}")

        var pkg_rows: [WidgetNode] = [pkg_header]

        var inst_idx: i64 = 0
        while inst_idx < installed.len():
            val pkg_name = installed[inst_idx]
            val row_id = "pkg_inst_{inst_idx}"
            val pkg_row = row(row_id, [
                text_widget("{row_id}_name", pkg_name),
                text_widget("{row_id}_status", "Installed")
            ])
            pkg_rows = pkg_rows.push(pkg_row)
            inst_idx = inst_idx + 1

        var avail_idx: i64 = 0
        while avail_idx < available.len():
            val pkg_name = available[avail_idx]
            val row_id = "pkg_avail_{avail_idx}"
            val pkg_row = row(row_id, [
                text_widget("{row_id}_name", pkg_name),
                text_widget("{row_id}_status", "Available")
            ])
            pkg_rows = pkg_rows.push(pkg_row)
            avail_idx = avail_idx + 1

        val package_list = panel("package_list", "Packages", pkg_rows)

        val actions = row("pkg_actions", [
            button("btn_install", "Install", "pkgmgr.install"),
            button("btn_remove", "Remove", "pkgmgr.remove"),
            button("btn_update", "Update", "pkgmgr.update"),
            button("btn_update_all", "Update All", "pkgmgr.update_all"),
            button("btn_removable", "Install from Removable", "pkgmgr.install_removable")
        ])

        val inst_count = installed.len()
        val avail_count = available.len()
        val status = statusbar("pkgmgr_status", "Installed: {inst_count}  Available: {avail_count}", "")

        val root = column("pkgmgr_root", [
            search_bar,
            package_list,
            actions,
            status
        ])

        val tree = build_tree_with_title(root, "Package Manager", "dark")
        UISession.new(tree)

    me handle_install(name: text):
        val ok = pkg_service_install(name)
        if ok:
            serial_println("[pkgmgr_app] install ok: {name}")
        else:
            serial_println("[pkgmgr_app] install failed: {name}")

    me handle_remove(name: text):
        val ok = pkg_service_remove(name)
        if ok:
            serial_println("[pkgmgr_app] remove ok: {name}")
        else:
            serial_println("[pkgmgr_app] remove failed: {name}")

    me handle_search(query: text) -> [text]:
        val results = pkg_service_search(query)
        serial_println("[pkgmgr_app] search '{query}' -> {results.len()} results")
        results
