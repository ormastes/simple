# Hello World Application Manifest
app:
    name: "Hello World"
    version: "1.0.0"
    description: "SimpleOS Hello World demonstration app"
    binary: "/apps/hello_world"
    icon: "hello"

shortcut:
    key: "H"
    modifiers: ["Meta"]
    description: "Launch Hello World"

window:
    title: "Hello World"
    width: 400
    height: 300
    resizable: true
    min_width: 200
    min_height: 150

author:
    name: "SimpleOS"
    url: "https://github.com/ormastes/simple"
