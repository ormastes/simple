# Hello World ECS World — per-app container
#
# MDSOC+: the HelloWorld owns welcome screen entities and components.

use std.ecs.entity.{Entity, EntityAllocator}
use std.ecs.component_store.{ComponentStore}
use std.ecs.world.{WorldBase}
use os.apps.hello_world.ecs.components.{Greeting, SystemInfo, AppVersion}

struct HelloWorldWorld:
    """ECS world for the hello_world demo app."""
    base: WorldBase
    greetings: ComponentStore<Greeting>
    sys_infos: ComponentStore<SystemInfo>
    versions: ComponentStore<AppVersion>

    static fn new() -> HelloWorldWorld:
        HelloWorldWorld(
            base: WorldBase.new(),
            greetings: ComponentStore.new(),
            sys_infos: ComponentStore.new(),
            versions: ComponentStore.new()
        )

    fn spawn_greeting(self) -> Entity:
        """Spawn the main greeting entity."""
        val e = self.base.spawn()
        val tick = self.base.now()
        self.greetings.insert(e, Greeting(title: "Hello, SimpleOS!"), tick)
        self.versions.insert(e, AppVersion(version: "0.1.0"), tick)
        e

    fn spawn_sys_info(self, label_text: text, value_text: text) -> Entity:
        """Spawn a system info display entity."""
        val e = self.base.spawn()
        val tick = self.base.now()
        self.sys_infos.insert(e, SystemInfo(label_text: label_text, value_text: value_text), tick)
        e
