# Hello World ECS Components — POD structs for welcome screen state
#
# MDSOC+: minimal component types for the hello_world demo app.

struct Greeting:
    """Welcome title text."""
    title: text

struct SystemInfo:
    """System information label and value."""
    label_text: text
    value_text: text

struct AppVersion:
    """Application version string."""
    version: text
