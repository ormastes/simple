# Hello World ECS Systems — free functions operating on HelloWorldWorld
#
# MDSOC+: stateless system functions for the hello_world demo capsule.
# Minimal — the hello_world app has no real business logic,
# so systems are stubs that will be wired when app lifecycle lands.

use os.apps.hello_world.ecs.world.{HelloWorldWorld}
use os.apps.hello_world.ecs.components.{Greeting}

fn sys_update_greeting(world: HelloWorldWorld, new_title: text):
    """Update the greeting title on the singleton entity."""
    var i: i32 = 0
    while i < world.greetings.len():
        world.greetings.dense[i] = Greeting(title: new_title)
        world.greetings.ticks[i] = world.base.now()
        i = i + 1
