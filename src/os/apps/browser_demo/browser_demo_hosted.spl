# Hosted Browser Demo — real browser renderer path for the host WM

use common.window_protocol.window_protocol.{WM_EVENT_CLOSE}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}
use common.render_scene.executor.{execute_scene_to_buffer}
use os.userlib.window.{WindowClient}
use os.userlib.log.{log_info, log_error}

extern fn rt_sleep_ms(ms: i64)

fn hosted_create_demo_dom() -> BeDomNode:
    var root = BeDomNode.element("div")
    root.set_style("background-color", "#f0f0f0")
    root.set_style("padding", "16")
    root.set_style("width", "600")
    root.set_style("height", "400")

    var header = BeDomNode.element("div")
    header.set_style("background-color", "#007acc")
    header.set_style("color", "#ffffff")
    header.set_style("padding", "12")
    header.set_style("font-size", "16")
    header.add_child(BeDomNode.text("Browser Rendering Demo"))
    root.add_child(header)

    var flex_row = BeDomNode.element("div")
    flex_row.set_style("display", "flex")
    flex_row.set_style("flex-direction", "row")
    flex_row.set_style("gap", "8")
    flex_row.set_style("padding", "8")

    var box1 = BeDomNode.element("div")
    box1.set_style("width", "120")
    box1.set_style("height", "80")
    box1.set_style("background-color", "#ff6b6b")
    box1.add_child(BeDomNode.text("Red Box"))

    var box2 = BeDomNode.element("div")
    box2.set_style("width", "120")
    box2.set_style("height", "80")
    box2.set_style("background-color", "#51cf66")
    box2.add_child(BeDomNode.text("Green Box"))

    var box3 = BeDomNode.element("div")
    box3.set_style("width", "120")
    box3.set_style("height", "80")
    box3.set_style("background-color", "#339af0")
    box3.add_child(BeDomNode.text("Blue Box"))

    flex_row.add_child(box1)
    flex_row.add_child(box2)
    flex_row.add_child(box3)
    root.add_child(flex_row)

    var para = BeDomNode.element("p")
    para.set_style("padding", "8")
    para.set_style("color", "#333333")
    para.set_style("font-size", "14")
    para.add_child(BeDomNode.text("This paragraph demonstrates text wrapping in the browser rendering engine."))
    root.add_child(para)

    var footer = BeDomNode.element("div")
    footer.set_style("background-color", "#2d2d2d")
    footer.set_style("color", "#cccccc")
    footer.set_style("padding", "8")
    footer.add_child(BeDomNode.text("SimpleOS Browser Engine v0.1"))
    root.add_child(footer)
    root

fn hosted_count_nodes(node: BeDomNode) -> i32:
    var count: i32 = 1
    for child in node.children:
        count = count + hosted_count_nodes(child)
    count

fn hosted_count_visible_pixels(buffer: [u32], bg_color: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < buffer.len():
        if buffer[idx] != bg_color:
            count = count + 1
        idx = idx + 1
    count

fn hosted_render_demo_stats(width: i32, height: i32) -> (i32, i32):
    val dom = hosted_create_demo_dom()
    var renderer = BrowserRenderer.create(width, height)
    renderer.set_background(0xFFF0F0F0)
    val result = renderer.render_dom(dom)
    val scene = result.to_scene()
    var buffer: [u32] = []
    var i: i32 = 0
    while i < width * height:
        buffer = buffer + [0xFFF0F0F0]
        i = i + 1
    buffer = execute_scene_to_buffer(scene, buffer, width, height)
    (hosted_count_nodes(dom), hosted_count_visible_pixels(buffer, 0xFFF0F0F0))

fn browser_demo_hosted_main() -> i64:
    log_info("[browser_demo] start app_id=/sys/apps/browser_demo mode=hosted")
    val (node_count, pixel_count) = hosted_render_demo_stats(600, 400)
    log_info("[browser_demo] render stats nodes={node_count} pixels={pixel_count} mode=hosted")

    var main_client = WindowClient.new()
    main_client.set_app_identity("/sys/apps/browser_demo")
    if not main_client.connect():
        log_error("[browser_demo] connect_failed app_id=/sys/apps/browser_demo client=main mode=hosted")
        return 1

    val main_wid = main_client.create_window("Browser Demo", 120, 90, 460, 260)
    if main_wid == 0:
        main_client.disconnect()
        return 1
    main_client.update_content(
        "Browser Demo\n\napp_id: /sys/apps/browser_demo\nwindow: main\nrenderer: original browser engine\nnodes: {node_count}\npixels: {pixel_count}"
    )

    var inspector_client = WindowClient.new()
    inspector_client.set_app_identity("/sys/apps/browser_demo")
    if not inspector_client.connect():
        main_client.destroy_window()
        main_client.disconnect()
        return 1

    val inspector_wid = inspector_client.create_window("Browser Demo Inspector", 620, 120, 320, 220)
    if inspector_wid == 0:
        inspector_client.disconnect()
        main_client.destroy_window()
        main_client.disconnect()
        return 1
    inspector_client.update_content(
        "Inspector\n\napp_id: /sys/apps/browser_demo\nwindow: secondary\nrenderer: original browser engine\nnodes: {node_count}\npixels: {pixel_count}"
    )

    var running = true
    while running:
        val main_event = main_client.poll_event()
        if main_event != nil and main_event.event_type == WM_EVENT_CLOSE:
            running = false
        val inspector_event = inspector_client.poll_event()
        if inspector_event != nil and inspector_event.event_type == WM_EVENT_CLOSE:
            running = false
        rt_sleep_ms(16)

    inspector_client.destroy_window()
    inspector_client.disconnect()
    main_client.destroy_window()
    main_client.disconnect()
    log_info("[browser_demo] exit app_id=/sys/apps/browser_demo code=0 mode=hosted")
    0
