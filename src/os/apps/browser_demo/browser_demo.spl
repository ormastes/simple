# Browser Demo — validates the browser rendering engine pipeline
#
# This app demonstrates rendering through two paths:
# 1. Widget tree -> standard UI session (normal app path for shell integration)
# 2. Direct DOM construction -> layout -> paint -> pixels (raw browser path)
#
# The demo creates a layout with:
# - A header with title and colored background
# - A row of three styled boxes showing flexbox layout
# - A paragraph of wrapped text
# - A footer with dark background
#
# This proves the browser engine can handle: box model, flexbox,
# text wrap, colors, borders, backgrounds, and nested elements.
#
# MDSOC: feature dimension, apps layer

use common.ui.builder.{
    column, row, panel, text_widget, button, label,
    statusbar, build_tree_with_title,
    with_flex, with_width, with_height
}
use common.ui.widget.{WidgetNode, UITree, UIEvent}
use common.ui.session.{UISession}
use common.window_protocol.window_protocol.{WM_EVENT_CLOSE}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.css.{default_style}
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer, BeRenderResult}
use common.render_scene.scene.{RenderScene, SceneCommand}
use common.render_scene.executor.{execute_scene_to_buffer}
use os.userlib.window.{WindowClient}
use os.userlib.process.{yield_, exit_}

extern fn serial_println(msg: text)

# =========================================================================
# Browser Demo App — Widget-based UI (Part A)
# =========================================================================

class BrowserDemoApp:
    """Browser rendering demo application.

    Validates the full browser engine pipeline end-to-end:
    DOM construction, CSS resolution, layout, paint, and pixel output.
    Also provides a standard widget UI for shell integration.
    """
    running: bool
    pixel_count: i32
    node_count: i32
    render_done: bool

impl BrowserDemoApp:

    static fn new() -> BrowserDemoApp:
        """Create a Browser Demo app in its initial state."""
        BrowserDemoApp(
            running: true,
            pixel_count: 0,
            node_count: 0,
            render_done: false
        )

    # -- Input Handling ------------------------------------------------------

    me handle_event(event: UIEvent):
        """Handle UI events: Escape closes, button triggers render."""
        match event:
            UIEvent.Quit:
                self.running = false
            UIEvent.KeyPress(key):
                self.handle_key(key)
            UIEvent.Action(action):
                self.handle_action(action)
            _ => pass_dn

    me handle_action(action: text):
        """Dispatch button action strings."""
        match action:
            "run_render" =>
                self.run_browser_render()
            _ => pass_dn

    me handle_key(key: text):
        """Map keyboard input to actions."""
        match key:
            "Escape" => self.running = false
            "r" => me run_browser_render()
            _ => pass_dn

    fn is_running() -> bool:
        """Return whether the app is still running."""
        self.running

    # -- Browser Render Pipeline (Part B) ------------------------------------

    me run_browser_render():
        """Execute the full browser rendering pipeline and store stats."""
        val width: i32 = 600
        val height: i32 = 400

        serial_println("[browser-demo] render start")

        val dom = create_demo_dom()
        var renderer = BrowserRenderer(
            viewport_w: width,
            viewport_h: height,
            bg_color: 0xFFF0F0F0
        )
        val result = renderer.render_dom(dom)
        val scene = result.to_scene()

        # Allocate pixel buffer and rasterize
        var buffer: [u32] = []
        var i: i32 = 0
        while i < width * height:
            buffer = buffer + [0xFFF0F0F0]
            i = i + 1
        execute_scene_to_buffer(scene, buffer, width, height)

        self.pixel_count = count_visible_pixels(buffer, 0xFFF0F0F0)
        self.node_count = result.node_count
        self.render_done = true
        serial_println("[browser-demo] render stats nodes={self.node_count} pixels={self.pixel_count}")

    # -- UI Construction (Part A) --------------------------------------------

    fn build_ui() -> UISession:
        """Build the Browser Demo UI.

        Layout:
          Panel with description of what the demo tests
          Render button to trigger browser pipeline
          Status bar with render stats
        """
        val status_text = if self.render_done:
            "Rendered {self.node_count} DOM nodes -> {self.pixel_count} pixels | Press Escape to close"
        else:
            "Press 'r' or click Render to run browser pipeline | Escape to close"

        val root = column("browser_demo_root", [
            # Title panel
            with_flex(panel("browser_demo_panel", "", [
                text_widget("browser_demo_title", "Browser Rendering Demo"),
                label("browser_demo_desc1", "Validates the browser engine pipeline:"),
                label("browser_demo_desc2", "DOM -> CSS -> Layout -> Paint -> Pixels"),
                label("browser_demo_sep", ""),
                label("browser_demo_desc3", "Tests: box model, flexbox row layout,"),
                label("browser_demo_desc4", "text wrapping, colors, backgrounds")
            ]), 1),

            # Render button
            row("browser_demo_button_row", [
                with_flex(button("btn_render", "Run Browser Render", "run_render"), 1)
            ]),

            # Status bar
            statusbar("browser_demo_status",
                status_text,
                "Browser Demo"
            )
        ])

        val tree = build_tree_with_title(root, "Browser Demo", "dark")
        UISession.new(tree)

# =========================================================================
# Direct DOM Rendering (Part B)
# =========================================================================

fn create_demo_dom() -> BeDomNode:
    """Build a DOM tree manually showing browser engine features.

    Creates: root div, header, flex row with 3 colored boxes,
    text paragraph, and footer — exercising the full CSS property set.
    """
    # Root div with light gray background
    var root = BeDomNode.element("div")
    root.set_style("background-color", "#f0f0f0")
    root.set_style("padding", "16")
    root.set_style("width", "600")
    root.set_style("height", "400")

    # Header — blue background, white text
    var header = BeDomNode.element("div")
    header.set_style("background-color", "#007acc")
    header.set_style("color", "#ffffff")
    header.set_style("padding", "12")
    header.set_style("font-size", "16")
    var header_text = BeDomNode.text("Browser Rendering Demo")
    header.add_child(header_text)
    root.add_child(header)

    # Flexbox row with 3 colored boxes
    var flex_row = BeDomNode.element("div")
    flex_row.set_style("display", "flex")
    flex_row.set_style("flex-direction", "row")
    flex_row.set_style("gap", "8")
    flex_row.set_style("padding", "8")

    var box1 = BeDomNode.element("div")
    box1.set_style("width", "120")
    box1.set_style("height", "80")
    box1.set_style("background-color", "#ff6b6b")
    box1.set_style("border-radius", "4")
    var box1_text = BeDomNode.text("Red Box")
    box1.add_child(box1_text)

    var box2 = BeDomNode.element("div")
    box2.set_style("width", "120")
    box2.set_style("height", "80")
    box2.set_style("background-color", "#51cf66")
    box2.set_style("border-radius", "4")
    var box2_text = BeDomNode.text("Green Box")
    box2.add_child(box2_text)

    var box3 = BeDomNode.element("div")
    box3.set_style("width", "120")
    box3.set_style("height", "80")
    box3.set_style("background-color", "#339af0")
    box3.set_style("border-radius", "4")
    var box3_text = BeDomNode.text("Blue Box")
    box3.add_child(box3_text)

    flex_row.add_child(box1)
    flex_row.add_child(box2)
    flex_row.add_child(box3)
    root.add_child(flex_row)

    # Wrapped text paragraph
    var para = BeDomNode.element("p")
    para.set_style("padding", "8")
    para.set_style("color", "#333333")
    para.set_style("font-size", "14")
    var para_text = BeDomNode.text("This paragraph demonstrates text wrapping in the browser rendering engine. The layout engine handles word-level wrapping at container boundaries using VGA bitmap font metrics.")
    para.add_child(para_text)
    root.add_child(para)

    # Footer with dark background
    var footer = BeDomNode.element("div")
    footer.set_style("background-color", "#2d2d2d")
    footer.set_style("color", "#cccccc")
    footer.set_style("padding", "8")
    var footer_text = BeDomNode.text("SimpleOS Browser Engine v0.1")
    footer.add_child(footer_text)
    root.add_child(footer)

    return root

fn count_visible_pixels(buffer: [u32], bg_color: u32) -> i32:
    var count: i32 = 0
    var idx: i32 = 0
    while idx < buffer.len():
        if buffer[idx] != bg_color:
            count = count + 1
        idx = idx + 1
    count

fn render_demo_to_pixels(width: i32, height: i32) -> [u32]:
    """Full pipeline: DOM -> layout -> paint -> scene -> pixels.

    Creates the demo DOM, renders through the browser engine,
    and rasterizes to a pixel buffer via the software executor.
    """
    val dom = create_demo_dom()
    var renderer = BrowserRenderer(
        viewport_w: width,
        viewport_h: height,
        bg_color: 0xFFF0F0F0
    )
    val result = renderer.render_dom(dom)
    val scene = result.to_scene()

    # Initialize buffer with background color
    var buffer: [u32] = []
    var i: i32 = 0
    while i < width * height:
        buffer = buffer + [0xFFF0F0F0]
        i = i + 1

    execute_scene_to_buffer(scene, buffer, width, height)
    return buffer

fn demo_node_count() -> i32:
    """Return the number of DOM nodes in the demo tree (for testing)."""
    val dom = create_demo_dom()
    return _count_nodes(dom)

fn _count_nodes(node: BeDomNode) -> i32:
    """Recursively count all nodes in a DOM tree."""
    var count: i32 = 1
    for child in node.children:
        count = count + _count_nodes(child)
    return count

# =========================================================================
# Remote Window Entry
# =========================================================================

fn browser_demo_remote_main():
    """Launch Browser Demo as a real multi-window remote app."""
    var main_client = WindowClient.new()
    main_client.set_app_identity("/sys/apps/browser_demo")
    if not main_client.connect():
        exit_(1)
        return

    val main_wid = main_client.create_window("Browser Demo", 120, 90, 460, 260)
    if main_wid == 0:
        main_client.disconnect()
        exit_(1)
        return

    var inspector_client = WindowClient.new()
    inspector_client.set_app_identity("/sys/apps/browser_demo")
    if not inspector_client.connect():
        main_client.destroy_window()
        main_client.disconnect()
        exit_(1)
        return

    val inspector_wid = inspector_client.create_window("Browser Demo Inspector", 620, 120, 320, 220)
    if inspector_wid == 0:
        inspector_client.disconnect()
        main_client.destroy_window()
        main_client.disconnect()
        exit_(1)
        return

    main_client.update_content(
        "Browser Demo\n\nPrimary window owned by launcher app identity.\nA second inspector window should group under the same process."
    )
    inspector_client.update_content(
        "Inspector\n\napp_id: /sys/apps/browser_demo\nwindow: secondary"
    )

    var running = true
    while running:
        val main_event = main_client.poll_event()
        if main_event != nil and main_event.event_type == WM_EVENT_CLOSE:
            running = false

        val inspector_event = inspector_client.poll_event()
        if inspector_event != nil and inspector_event.event_type == WM_EVENT_CLOSE:
            running = false

        yield_()

    inspector_client.destroy_window()
    inspector_client.disconnect()
    main_client.destroy_window()
    main_client.disconnect()
    exit_(0)
