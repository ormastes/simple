use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class BrowserDemoApp:

    static fn new() -> BrowserDemoApp:
        BrowserDemoApp()

    me build_ui() -> UISession:
        val nav_buttons = row("nav_buttons", [
            button("btn_back", "< Back", "browser.back"),
            button("btn_forward", "Forward >", "browser.forward"),
            button("btn_refresh", "Refresh", "browser.refresh"),
            button("btn_home", "Home", "browser.home")
        ])

        val address_bar = panel("address_panel", "Address", [
            row("addr_row", [
                label("lbl_url", "URL:"),
                text_widget("url_input", "https://simpleos.example.org/welcome")
            ]),
            nav_buttons
        ])

        val page_content = panel("page_content", "Page Content", [
            text_widget("page_title", "Welcome to SimpleOS Web"),
            text_widget("page_h1", "SimpleOS - The Simple Operating System"),
            text_widget("page_p1", "SimpleOS is a modern operating system built entirely in the Simple programming language."),
            text_widget("page_p2", "Features: Fast boot, Secure by design, Simple language apps, Native GPU support."),
            text_widget("page_link1", "[Learn More]  [Download]  [Documentation]  [Community]")
        ])

        val status = statusbar("browser_status", "Connected - TLS 1.3", "Page loaded in 0.3s")

        val root = column("browser_root", [
            address_bar,
            page_content,
            status
        ])

        val tree = build_tree_with_title(root, "SimpleOS Browser", "dark")
        UISession.new(tree)
