use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{
    column, row, panel, text_widget, button, label, statusbar,
    build_tree_with_title
}

class LogViewerApp:
    static fn new() -> LogViewerApp:
        LogViewerApp()

    me build_ui() -> UISession:
        val toolbar = row("log_toolbar", [
            button("log_open", "Open Log", "open_log"),
            button("log_refresh", "Refresh", "refresh"),
            button("log_clear", "Clear", "clear_view"),
            button("log_export", "Export", "export_log")
        ])

        val filters = row("log_filters", [
            label("log_filter_label", "Filter:"),
            button("log_all", "All", "filter_all"),
            button("log_info", "INFO", "filter_info"),
            button("log_warn", "WARN", "filter_warn"),
            button("log_error", "ERROR", "filter_error"),
            button("log_debug", "DEBUG", "filter_debug")
        ])

        val log_entries = panel("log_entries", "System Log", [
            text_widget("log_e1", "[2026-05-07 08:00:01] INFO   kernel: SimpleOS v0.1.0 booting"),
            text_widget("log_e2", "[2026-05-07 08:00:01] INFO   kernel: Memory: 256 MB detected"),
            text_widget("log_e3", "[2026-05-07 08:00:02] INFO   driver: Framebuffer initialized 1024x768"),
            text_widget("log_e4", "[2026-05-07 08:00:02] INFO   vfs: Root filesystem mounted"),
            text_widget("log_e5", "[2026-05-07 08:00:03] WARN   net: No network interface detected"),
            text_widget("log_e6", "[2026-05-07 08:00:03] INFO   desktop: Shell started"),
            text_widget("log_e7", "[2026-05-07 08:00:04] INFO   launcher: Registered 28 applications"),
            text_widget("log_e8", "[2026-05-07 08:00:05] ERROR  audio: Audio device not found"),
            text_widget("log_e9", "[2026-05-07 08:00:05] INFO   compositor: Window manager ready"),
            text_widget("log_e10", "[2026-05-07 08:00:06] DEBUG  shell: Taskbar rendered"),
            text_widget("log_e11", "[2026-05-07 08:00:10] INFO   app: Log Viewer opened"),
            text_widget("log_e12", "[2026-05-07 08:00:12] WARN   disk: /dev/sda3 usage above 80%")
        ])

        val status = statusbar("log_status", "12 entries  |  2 warnings  |  1 error", "/var/log/system.log")

        val root = column("log_root", [
            toolbar,
            filters,
            log_entries,
            status
        ])

        val tree = build_tree_with_title(root, "Log Viewer", "dark")
        UISession.new(tree)
