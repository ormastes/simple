# SimpleOS VCS — Version Control System Application
#
# A file-level VCS for SimpleOS using VFS or host file I/O.
# Works both on baremetal SimpleOS (via VFS syscalls) and
# hosted mode (via rt_file_* / rt_process_run).
#
# Commands:
#   vcs init                  — Initialize a new repository
#   vcs add <file> ...        — Stage files for commit
#   vcs commit -m "message"   — Create a snapshot of staged files
#   vcs log                   — Show commit history
#   vcs status                — Show modified/staged/untracked files
#   vcs diff [file]           — Show line-by-line diff vs last commit
#   vcs checkout <hash>       — Restore files from a commit
#   vcs show <hash>           — Show commit details
#
# Storage layout:
#   .vcs/
#     HEAD              — current commit hash
#     config            — repo config (author name, etc.)
#     staging/          — staged file copies (flat: filename only)
#     staging.manifest  — list of staged paths (relative to repo root)
#     commits/          — commit metadata (hash.txt)
#     objects/          — file snapshots (hash/relative_path)

# ============================================================================
# FFI — works in interpreter (hosted) mode
# ============================================================================

extern fn rt_file_write_text(path: text, content: text)
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_remove(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_env_get(key: text) -> text

# ============================================================================
# Helpers
# ============================================================================

fn file_read(path: text) -> text:
    """Read file via cat (works in interpreter — rt_file_read_text returns Option)."""
    val (out, _, code) = rt_process_run("cat", [path])
    if code == 0:
        return out
    ""

fn file_list(dir: text) -> [text]:
    """List files in directory."""
    val (out, _, code) = rt_process_run("ls", ["-1", dir])
    if code != 0:
        return []
    val trimmed = out.trim()
    if trimmed == "":
        return []
    trimmed.split("\n")

fn file_copy(src: text, dst: text) -> bool:
    val (_, _, code) = rt_process_run("cp", [src, dst])
    code == 0

fn dir_create(path: text):
    rt_process_run("mkdir", ["-p", [path]])

fn dir_remove(path: text):
    rt_process_run("rm", ["-rf", [path]])

fn timestamp_now() -> text:
    """Get current timestamp via date."""
    val (out, _, code) = rt_process_run("date", ["+%Y-%m-%dT%H:%M:%S"])
    if code == 0:
        return out.trim()
    "unknown"

# ============================================================================
# Data Structures
# ============================================================================

struct VcsCommit:
    """A single commit snapshot."""
    hash: text
    parent: text
    message: text
    timestamp: text
    files: [text]

# ============================================================================
# Hash
# ============================================================================

fn vcs_hash(message: text, ts: text, parent: text) -> text:
    """djb2 hash → 8 hex chars."""
    var h: i64 = 5381
    val input = ts + ":" + message + ":" + parent
    var i: i64 = 0
    while i < input.len():
        h = ((h * 33) + (i + 1)) % 999999937
        i = i + 1
    if h < 0:
        h = h * -1
    var result = ""
    var v = h
    var d = 0
    while d < 8:
        val r = v % 16
        if r < 10:
            result = r.to_text() + result
        else if r == 10:
            result = "a" + result
        else if r == 11:
            result = "b" + result
        else if r == 12:
            result = "c" + result
        else if r == 13:
            result = "d" + result
        else if r == 14:
            result = "e" + result
        else:
            result = "f" + result
        v = v / 16
        d = d + 1
    result

# ============================================================================
# Commit Serialization
# ============================================================================

fn serialize_commit(c: VcsCommit) -> text:
    var lines: [text] = []
    lines.append("hash: " + c.hash)
    lines.append("parent: " + c.parent)
    lines.append("message: " + c.message)
    lines.append("timestamp: " + c.timestamp)
    lines.append("files:")
    for f in c.files:
        lines.append("  " + f)
    lines.join("\n") + "\n"

fn parse_commit(data: text) -> VcsCommit:
    var hash = ""
    var parent = ""
    var message = ""
    var timestamp = ""
    var files: [text] = []
    val lines = data.split("\n")
    for line in lines:
        if line.starts_with("hash: "):
            hash = line.slice(6, line.len())
        else if line.starts_with("parent: "):
            parent = line.slice(8, line.len())
        else if line.starts_with("message: "):
            message = line.slice(9, line.len())
        else if line.starts_with("timestamp: "):
            timestamp = line.slice(11, line.len())
        else if line.starts_with("  "):
            val fname = line.trim()
            if fname.len() > 0:
                files.append(fname)
    VcsCommit(hash: hash, parent: parent, message: message, timestamp: timestamp, files: files)

# ============================================================================
# VCS Engine
# ============================================================================

struct VcsEngine:
    """VCS operations bound to a working directory."""
    root: text      # working directory
    vcs_dir: text   # .vcs directory

fn vcs_new(root: text) -> VcsEngine:
    VcsEngine(root: root, vcs_dir: root + "/.vcs")

# --- init ---
fn vcs_init(e: VcsEngine) -> bool:
    dir_create(e.vcs_dir)
    dir_create(e.vcs_dir + "/commits")
    dir_create(e.vcs_dir + "/staging")
    dir_create(e.vcs_dir + "/objects")
    rt_file_write_text(e.vcs_dir + "/HEAD", "")
    rt_file_write_text(e.vcs_dir + "/staging.manifest", "")
    rt_file_write_text(e.vcs_dir + "/config", "author: user\n")
    true

# --- add ---
fn vcs_add(e: VcsEngine, files: [text]) -> i64:
    """Stage files. Returns count of files staged."""
    var manifest = file_read(e.vcs_dir + "/staging.manifest")
    var count: i64 = 0
    for f in files:
        val src = e.root + "/" + f
        if not rt_file_exists(src):
            print "vcs: file not found: {f}"
            continue
        val dst = e.vcs_dir + "/staging/" + f
        # Create parent dirs for nested paths
        val parts = f.split("/")
        if parts.len() > 1:
            var parent_path = e.vcs_dir + "/staging"
            var pi = 0
            while pi < parts.len() - 1:
                parent_path = parent_path + "/" + parts[pi]
                dir_create(parent_path)
                pi = pi + 1
        file_copy(src, dst)
        # Add to manifest if not already there
        if not manifest.contains(f):
            if manifest.len() > 0 and not manifest.ends_with("\n"):
                manifest = manifest + "\n"
            manifest = manifest + f + "\n"
        count = count + 1
    rt_file_write_text(e.vcs_dir + "/staging.manifest", manifest)
    count

# --- commit ---
fn vcs_commit(e: VcsEngine, message: text) -> text:
    """Create commit from staging. Returns hash or empty on error."""
    val manifest = file_read(e.vcs_dir + "/staging.manifest").trim()
    if manifest == "":
        print "vcs: nothing staged to commit"
        return ""

    val files = manifest.split("\n")
    val head = file_read(e.vcs_dir + "/HEAD").trim()
    val ts = timestamp_now()
    val hash = vcs_hash(message, ts, head)

    # Copy staged files to objects/<hash>/
    val obj_dir = e.vcs_dir + "/objects/" + hash
    dir_create(obj_dir)
    for f in files:
        val src = e.vcs_dir + "/staging/" + f
        val dst = obj_dir + "/" + f
        # Create parent dirs
        val parts = f.split("/")
        if parts.len() > 1:
            var parent_path = obj_dir
            var pi = 0
            while pi < parts.len() - 1:
                parent_path = parent_path + "/" + parts[pi]
                dir_create(parent_path)
                pi = pi + 1
        file_copy(src, dst)

    # Write commit metadata
    val commit = VcsCommit(hash: hash, parent: head, message: message, timestamp: ts, files: files)
    rt_file_write_text(e.vcs_dir + "/commits/" + hash + ".txt", serialize_commit(commit))

    # Update HEAD
    rt_file_write_text(e.vcs_dir + "/HEAD", hash)

    # Clear staging
    dir_remove(e.vcs_dir + "/staging")
    dir_create(e.vcs_dir + "/staging")
    rt_file_write_text(e.vcs_dir + "/staging.manifest", "")

    hash

# --- log ---
fn vcs_log(e: VcsEngine) -> [VcsCommit]:
    """Walk commit chain from HEAD backward."""
    var commits: [VcsCommit] = []
    var current = file_read(e.vcs_dir + "/HEAD").trim()
    while current != "":
        val path = e.vcs_dir + "/commits/" + current + ".txt"
        if not rt_file_exists(path):
            break
        val data = file_read(path)
        val commit = parse_commit(data)
        commits.append(commit)
        current = commit.parent
    commits

# --- status ---
fn vcs_status(e: VcsEngine) -> text:
    """Report staged files and HEAD."""
    val head = file_read(e.vcs_dir + "/HEAD").trim()
    val manifest = file_read(e.vcs_dir + "/staging.manifest").trim()

    var lines: [text] = []
    if head == "":
        lines.append("On initial commit (no commits yet)")
    else:
        lines.append("HEAD: " + head)

    if manifest != "":
        lines.append("")
        lines.append("Staged for commit:")
        val staged = manifest.split("\n")
        for f in staged:
            if f.trim().len() > 0:
                lines.append("  + " + f.trim())
    else:
        lines.append("")
        lines.append("Nothing staged for commit")

    lines.join("\n")

# --- diff ---
fn vcs_diff(e: VcsEngine, file: text) -> text:
    """Diff working file vs last committed version."""
    val head = file_read(e.vcs_dir + "/HEAD").trim()
    if head == "":
        return "vcs: no commits yet"

    val committed_path = e.vcs_dir + "/objects/" + head + "/" + file
    if not rt_file_exists(committed_path):
        return "vcs: file '{file}' not in commit {head}"

    val working_path = e.root + "/" + file
    if not rt_file_exists(working_path):
        return "vcs: file '{file}' deleted from working directory"

    val old = file_read(committed_path)
    val new_ = file_read(working_path)

    if old == new_:
        return "vcs: no changes in '{file}'"

    # Line-by-line diff
    val old_lines = old.split("\n")
    val new_lines = new_.split("\n")
    var result: [text] = []
    result.append("--- a/" + file + " (committed)")
    result.append("+++ b/" + file + " (working)")

    var max = old_lines.len()
    if new_lines.len() > max:
        max = new_lines.len()
    var i: i64 = 0
    while i < max:
        if i < old_lines.len() and i < new_lines.len():
            if old_lines[i] == new_lines[i]:
                result.append(" " + old_lines[i])
            else:
                result.append("-" + old_lines[i])
                result.append("+" + new_lines[i])
        else if i < old_lines.len():
            result.append("-" + old_lines[i])
        else:
            result.append("+" + new_lines[i])
        i = i + 1
    result.join("\n")

# --- show ---
fn vcs_show(e: VcsEngine, hash: text) -> text:
    """Show commit details."""
    val path = e.vcs_dir + "/commits/" + hash + ".txt"
    if not rt_file_exists(path):
        return "vcs: commit '{hash}' not found"
    val data = file_read(path)
    val commit = parse_commit(data)
    var lines: [text] = []
    lines.append("commit " + commit.hash)
    lines.append("parent: " + commit.parent)
    lines.append("date:   " + commit.timestamp)
    lines.append("")
    lines.append("    " + commit.message)
    lines.append("")
    lines.append("files:")
    for f in commit.files:
        lines.append("  " + f)
    lines.join("\n")

# --- checkout ---
fn vcs_checkout(e: VcsEngine, hash: text) -> bool:
    """Restore files from a commit."""
    val path = e.vcs_dir + "/commits/" + hash + ".txt"
    if not rt_file_exists(path):
        print "vcs: commit '{hash}' not found"
        return false
    val data = file_read(path)
    val commit = parse_commit(data)
    for f in commit.files:
        val src = e.vcs_dir + "/objects/" + hash + "/" + f
        val dst = e.root + "/" + f
        # Create parent dirs
        val parts = f.split("/")
        if parts.len() > 1:
            var parent_path = e.root
            var pi = 0
            while pi < parts.len() - 1:
                parent_path = parent_path + "/" + parts[pi]
                dir_create(parent_path)
                pi = pi + 1
        file_copy(src, dst)
    rt_file_write_text(e.vcs_dir + "/HEAD", hash)
    true

# ============================================================================
# CLI Dispatcher
# ============================================================================

fn vcs_run(cwd: text, args: [text]) -> i64:
    """Run a VCS command. Returns 0 on success, 1 on error."""
    if args.len() == 0:
        print vcs_help_text()
        return 0

    val cmd = args[0]
    val e = vcs_new(cwd)

    if cmd == "init":
        vcs_init(e)
        print "Initialized empty VCS repository in {cwd}/.vcs/"
        return 0

    # All other commands require an initialized repo
    if not rt_file_exists(e.vcs_dir + "/HEAD"):
        print "vcs: not a vcs repository (run 'vcs init' first)"
        return 1

    if cmd == "add":
        if args.len() < 2:
            print "vcs: specify files to add"
            return 1
        var files: [text] = []
        var i: i64 = 1
        while i < args.len():
            files.append(args[i])
            i = i + 1
        val count = vcs_add(e, files)
        print "Staged {count} file(s)"
        return 0

    if cmd == "commit":
        var message = ""
        var i: i64 = 1
        while i < args.len():
            if args[i] == "-m" and i + 1 < args.len():
                message = args[i + 1]
                i = i + 2
            else:
                i = i + 1
        if message == "":
            print "vcs: commit message required (-m \"message\")"
            return 1
        val hash = vcs_commit(e, message)
        if hash != "":
            print "[{hash}] {message}"
            return 0
        return 1

    if cmd == "log":
        val commits = vcs_log(e)
        if commits.len() == 0:
            print "No commits yet"
            return 0
        for c in commits:
            print "commit {c.hash}"
            if c.parent != "":
                print "parent {c.parent}"
            print "date   {c.timestamp}"
            print ""
            print "    {c.message}"
            print ""
        return 0

    if cmd == "status":
        print vcs_status(e)
        return 0

    if cmd == "diff":
        if args.len() < 2:
            print "vcs: specify file to diff"
            return 1
        print vcs_diff(e, args[1])
        return 0

    if cmd == "show":
        if args.len() < 2:
            print "vcs: specify commit hash"
            return 1
        print vcs_show(e, args[1])
        return 0

    if cmd == "checkout":
        if args.len() < 2:
            print "vcs: specify commit hash"
            return 1
        val ok = vcs_checkout(e, args[1])
        if ok:
            print "Checked out commit {args[1]}"
            return 0
        return 1

    if cmd == "help":
        print vcs_help_text()
        return 0

    print "vcs: unknown command '{cmd}'"
    print vcs_help_text()
    return 1

fn vcs_help_text() -> text:
    var lines: [text] = []
    lines.append("SimpleOS VCS — Version Control System")
    lines.append("")
    lines.append("Commands:")
    lines.append("  vcs init                  Initialize repository")
    lines.append("  vcs add <file> ...        Stage files")
    lines.append("  vcs commit -m \"msg\"       Create commit")
    lines.append("  vcs log                   Show history")
    lines.append("  vcs status                Show working state")
    lines.append("  vcs diff <file>           Diff vs last commit")
    lines.append("  vcs show <hash>           Show commit details")
    lines.append("  vcs checkout <hash>       Restore from commit")
    lines.append("  vcs help                  Show this help")
    lines.join("\n")

# ============================================================================
# Standalone entry point (for testing outside shell)
# ============================================================================

fn main() -> i64:
    val cwd = rt_env_get("PWD")
    # Skip first arg if it's "vcs"
    val args = rt_env_get("VCS_ARGS")
    if args != "":
        val parts = args.split(" ")
        return vcs_run(cwd, parts)
    # Default: show help
    print vcs_help_text()
    return 0
