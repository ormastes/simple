# SimpleOS VCS — Lightweight Version Control System
#
# A simplified git-like VCS for SimpleOS using the VFS.
# Supports: init, add, commit, log, status, diff
#
# Storage layout (under .vcs/ in repo root):
#   .vcs/
#     HEAD          — current commit hash (text file)
#     commits/      — commit objects (hash.txt files)
#     staging/      — staged file copies
#     objects/      — committed file snapshots (hash/filename)

use os.services.vfs.vfs.{VfsService}
