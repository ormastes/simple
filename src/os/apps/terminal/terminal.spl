# Terminal Emulator App
#
# SimpleOS terminal emulator with scrollable output area,
# prompt line, and command input.

use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title, with_height, with_width, with_flex, with_background}

class Terminal:
    cols: i32
    rows: i32

    static fn new(cols: i32, rows: i32) -> Terminal:
        Terminal(cols: cols, rows: rows)

    me build_ui() -> UISession:
        val toolbar = row("toolbar",
            [button("btn_new", "New Tab", "terminal.new_tab"),
             button("btn_clear", "Clear", "terminal.clear"),
             button("btn_copy", "Copy", "terminal.copy"),
             button("btn_paste", "Paste", "terminal.paste"),
             with_flex(label("spacer", ""), 1),
             button("btn_settings", "Settings", "terminal.settings")])

        val output_lines = column("output",
            [text_widget("line1", "SimpleOS Terminal v0.1 — type 'help' for commands"),
             text_widget("line2", ""),
             text_widget("line3", "$ ls -la /home/user"),
             text_widget("line4", "total 48"),
             text_widget("line5", "drwxr-xr-x  5 user user 4096 May  7 10:22 ."),
             text_widget("line6", "drwxr-xr-x 12 root root 4096 May  7 09:00 .."),
             text_widget("line7", "-rw-r--r--  1 user user  220 May  7 09:00 .bash_logout"),
             text_widget("line8", "-rw-r--r--  1 user user 3526 May  7 09:00 .bashrc"),
             text_widget("line9", "drwxr-xr-x  2 user user 4096 May  7 10:15 Documents"),
             text_widget("line10", "drwxr-xr-x  2 user user 4096 May  7 09:30 Downloads"),
             text_widget("line11", "drwxr-xr-x  2 user user 4096 May  7 09:00 Pictures"),
             text_widget("line12", ""),
             text_widget("line13", "$ uname -a"),
             text_widget("line14", "SimpleOS 0.1.0 x86_64 SimpleOS Kernel")])

        val prompt_row = row("prompt_row",
            [label("prompt_label", "$ "),
             with_flex(text_widget("input_line", "_"), 1)])

        val main_area = column("main_area",
            [with_flex(panel("output_panel", "Output", [output_lines]), 1),
             prompt_row])

        val c = me.cols
        val r = me.rows
        val root = column("root",
            [toolbar,
             with_flex(main_area, 1),
             statusbar("status", "SimpleOS Terminal", "{c}x{r}")])

        val tree = build_tree_with_title(root, "Terminal", "dark")
        UISession.new(tree)
