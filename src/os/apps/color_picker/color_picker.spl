use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class ColorPickerApp:

    static fn new() -> ColorPickerApp:
        ColorPickerApp()

    me build_ui() -> UISession:
        val color_preview = panel("color_preview", "Color Preview", [
            text_widget("swatch", "[Color Swatch]"),
            row("rgb_row", [
                label("r_label", "R:"),
                text_widget("r_value", "128"),
                label("g_label", "G:"),
                text_widget("g_value", "64"),
                label("b_label", "B:"),
                text_widget("b_value", "255")
            ]),
            row("hex_row", [
                label("hex_label", "Hex:"),
                text_widget("hex_value", "#8040FF"),
                button("btn_copy_hex", "Copy", "colorpicker.copy.hex")
            ])
        ])

        val preset_colors = panel("preset_colors", "Preset Colors", [
            row("presets_row1", [
                button("btn_preset_red", "Red", "colorpicker.preset.red"),
                button("btn_preset_orange", "Orange", "colorpicker.preset.orange"),
                button("btn_preset_yellow", "Yellow", "colorpicker.preset.yellow"),
                button("btn_preset_green", "Green", "colorpicker.preset.green")
            ]),
            row("presets_row2", [
                button("btn_preset_blue", "Blue", "colorpicker.preset.blue"),
                button("btn_preset_indigo", "Indigo", "colorpicker.preset.indigo"),
                button("btn_preset_violet", "Violet", "colorpicker.preset.violet"),
                button("btn_preset_white", "White", "colorpicker.preset.white")
            ]),
            row("presets_row3", [
                button("btn_preset_black", "Black", "colorpicker.preset.black"),
                button("btn_preset_gray", "Gray", "colorpicker.preset.gray"),
                button("btn_preset_pink", "Pink", "colorpicker.preset.pink"),
                button("btn_preset_brown", "Brown", "colorpicker.preset.brown")
            ])
        ])

        val recent_colors = panel("recent_colors", "Recent Colors", [
            row("recent_row", [
                button("btn_recent_1", "#FF0000", "colorpicker.recent.1"),
                button("btn_recent_2", "#00FF00", "colorpicker.recent.2"),
                button("btn_recent_3", "#0000FF", "colorpicker.recent.3"),
                button("btn_recent_4", "#FFFF00", "colorpicker.recent.4")
            ])
        ])

        val status = statusbar("colorpicker_status", "#8040FF", "RGB(128, 64, 255)")

        val root = column("colorpicker_root", [
            color_preview,
            preset_colors,
            recent_colors,
            status
        ])

        val tree = build_tree_with_title(root, "Color Picker", "dark")
        UISession.new(tree)
