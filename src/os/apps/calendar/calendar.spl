use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class CalendarApp:

    static fn new() -> CalendarApp:
        CalendarApp()

    me build_ui() -> UISession:
        val month_nav = row("month_nav", [
            button("btn_prev_month", "< Prev", "calendar.prev_month"),
            text_widget("month_year_label", "May 2026"),
            button("btn_next_month", "Next >", "calendar.next_month")
        ])

        val dow_headers = row("dow_headers", [
            label("lbl_su", "Su"),
            label("lbl_mo", "Mo"),
            label("lbl_tu", "Tu"),
            label("lbl_we", "We"),
            label("lbl_th", "Th"),
            label("lbl_fr", "Fr"),
            label("lbl_sa", "Sa")
        ])

        val week1 = row("week1", [
            label("d_empty1", ""),
            label("d_empty2", ""),
            label("d_empty3", ""),
            label("d_empty4", ""),
            button("d_1", "1", "calendar.day.1"),
            button("d_2", "2", "calendar.day.2"),
            button("d_3", "3", "calendar.day.3")
        ])

        val week2 = row("week2", [
            button("d_4", "4", "calendar.day.4"),
            button("d_5", "5", "calendar.day.5"),
            button("d_6", "6", "calendar.day.6"),
            button("d_7", "7", "calendar.day.7"),
            button("d_8", "8", "calendar.day.8"),
            button("d_9", "9", "calendar.day.9"),
            button("d_10", "10", "calendar.day.10")
        ])

        val week3 = row("week3", [
            button("d_11", "11", "calendar.day.11"),
            button("d_12", "12", "calendar.day.12"),
            button("d_13", "13", "calendar.day.13"),
            button("d_14", "14", "calendar.day.14"),
            button("d_15", "15", "calendar.day.15"),
            button("d_16", "16", "calendar.day.16"),
            button("d_17", "17", "calendar.day.17")
        ])

        val week4 = row("week4", [
            button("d_18", "18", "calendar.day.18"),
            button("d_19", "19", "calendar.day.19"),
            button("d_20", "20", "calendar.day.20"),
            button("d_21", "21", "calendar.day.21"),
            button("d_22", "22", "calendar.day.22"),
            button("d_23", "23", "calendar.day.23"),
            button("d_24", "24", "calendar.day.24")
        ])

        val week5 = row("week5", [
            button("d_25", "25", "calendar.day.25"),
            button("d_26", "26", "calendar.day.26"),
            button("d_27", "27", "calendar.day.27"),
            button("d_28", "28", "calendar.day.28"),
            button("d_29", "29", "calendar.day.29"),
            button("d_30", "30", "calendar.day.30"),
            button("d_31", "31", "calendar.day.31")
        ])

        val grid = panel("calendar_grid", "May 2026", [
            month_nav,
            dow_headers,
            week1,
            week2,
            week3,
            week4,
            week5
        ])

        val events = panel("events_panel", "Events", [
            text_widget("evt_1", "May 7  - SimpleOS 0.1 Release"),
            text_widget("evt_2", "May 14 - Team Sync Meeting"),
            text_widget("evt_3", "May 21 - Kernel Hackathon"),
            text_widget("evt_4", "May 28 - Community Demo Day"),
            row("event_actions", [
                button("btn_add_event", "Add Event", "calendar.add_event"),
                button("btn_view_event", "View", "calendar.view_event")
            ])
        ])

        val status = statusbar("calendar_status", "May 2026", "4 events this month")

        val root = column("calendar_root", [
            grid,
            events,
            status
        ])

        val tree = build_tree_with_title(root, "Calendar", "dark")
        UISession.new(tree)
