use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class UpgradeGuiApp:

    static fn new() -> UpgradeGuiApp:
        UpgradeGuiApp()

    me build_ui() -> UISession:
        val current_info = panel("current_info", "Current Version", [
            row("cur_os_row", [
                label("lbl_cur_os", "OS:"),
                text_widget("val_cur_os", "SimpleOS 0.1.0")
            ]),
            row("cur_kernel_row", [
                label("lbl_cur_kernel", "Kernel:"),
                text_widget("val_cur_kernel", "simple-kernel 0.1.0")
            ]),
            row("cur_installed_row", [
                label("lbl_cur_installed", "Installed:"),
                text_widget("val_cur_installed", "2026-04-01")
            ])
        ])

        val update_info = panel("update_info", "Available Update", [
            row("upd_ver_row", [
                label("lbl_upd_ver", "New version:"),
                text_widget("val_upd_ver", "SimpleOS 0.2.0")
            ]),
            row("upd_date_row", [
                label("lbl_upd_date", "Released:"),
                text_widget("val_upd_date", "2026-05-07")
            ]),
            row("upd_size_row", [
                label("lbl_upd_size", "Download size:"),
                text_widget("val_upd_size", "87.4 MB")
            ])
        ])

        val release_notes = panel("release_notes", "Release Notes - SimpleOS 0.2.0", [
            text_widget("rn_title", "What's new in 0.2.0:"),
            text_widget("rn_item1", "- Improved GPU driver performance (+40%)"),
            text_widget("rn_item2", "- Network stack stability fixes"),
            text_widget("rn_item3", "- New package manager UI"),
            text_widget("rn_item4", "- Simple compiler 1.0.1 (faster builds)"),
            text_widget("rn_item5", "- Security: patched 3 CVEs in kernel"),
            text_widget("rn_item6", "- 47 bug fixes across all subsystems")
        ])

        val progress = panel("upgrade_progress", "Upgrade Progress", [
            text_widget("upg_step", "Status: Ready to download"),
            text_widget("upg_bar", "[                    ]  0%"),
            text_widget("upg_detail", "Press Download to begin fetching the update.")
        ])

        val actions = row("upgrade_actions", [
            button("btn_download", "Download", "upgrade.download"),
            button("btn_install", "Install Update", "upgrade.install"),
            button("btn_remind", "Remind Later", "upgrade.remind"),
            button("btn_skip", "Skip This Version", "upgrade.skip")
        ])

        val status = statusbar("upgrade_status", "SimpleOS 0.2.0 available", "87.4 MB download required")

        val root = column("upgrade_root", [
            current_info,
            update_info,
            release_notes,
            progress,
            actions,
            status
        ])

        val tree = build_tree_with_title(root, "SimpleOS Upgrade", "dark")
        UISession.new(tree)
