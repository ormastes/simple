use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class InstallerGuiApp:

    static fn new() -> InstallerGuiApp:
        InstallerGuiApp()

    me build_ui() -> UISession:
        val wizard_steps = row("wizard_steps", [
            label("step_welcome", "1. Welcome"),
            label("step_sep1", ">"),
            label("step_disk", "2. Disk"),
            label("step_sep2", ">"),
            label("step_confirm", "3. Confirm"),
            label("step_sep3", ">"),
            label("step_install", "4. Install")
        ])

        val welcome_step = panel("welcome_step", "Welcome to SimpleOS Installer", [
            text_widget("welcome_msg1", "Welcome to the SimpleOS 0.1.0 installation wizard."),
            text_widget("welcome_msg2", "This wizard will guide you through the installation process."),
            text_widget("welcome_msg3", "Requirements: 4 GB RAM, 20 GB disk space, x86_64 CPU."),
            text_widget("welcome_msg4", "Please ensure you have backed up any important data before continuing.")
        ])

        val disk_step = panel("disk_step", "Disk Selection", [
            row("disk_header", [
                label("hdr_disk_dev", "Device"),
                label("hdr_disk_size", "Size"),
                label("hdr_disk_type", "Type"),
                label("hdr_disk_action", "Action")
            ]),
            row("disk_sda", [
                text_widget("disk1_dev", "/dev/sda"),
                text_widget("disk1_size", "120 GB"),
                text_widget("disk1_type", "SSD"),
                button("btn_select_sda", "Select", "installer.select_disk.sda")
            ]),
            row("disk_sdb", [
                text_widget("disk2_dev", "/dev/sdb"),
                text_widget("disk2_size", "500 GB"),
                text_widget("disk2_type", "HDD"),
                button("btn_select_sdb", "Select", "installer.select_disk.sdb")
            ]),
            row("disk_opts", [
                label("lbl_erase", "Erase disk and install:"),
                button("btn_erase_yes", "Yes", "installer.erase.yes"),
                button("btn_erase_no", "No (custom)", "installer.erase.no")
            ])
        ])

        val confirm_step = panel("confirm_step", "Confirm Installation", [
            row("confirm_os", [
                label("lbl_confirm_os", "OS:"),
                text_widget("confirm_os_val", "SimpleOS 0.1.0")
            ]),
            row("confirm_disk", [
                label("lbl_confirm_disk", "Target disk:"),
                text_widget("confirm_disk_val", "/dev/sda (120 GB)")
            ]),
            row("confirm_mode", [
                label("lbl_confirm_mode", "Install mode:"),
                text_widget("confirm_mode_val", "Full erase and install")
            ]),
            text_widget("confirm_warn", "WARNING: All data on the selected disk will be erased.")
        ])

        val progress = panel("progress_panel", "Installation Progress", [
            text_widget("prog_step", "Step: Waiting to start"),
            text_widget("prog_bar", "[                    ]  0%"),
            text_widget("prog_detail", "Press Install to begin.")
        ])

        val nav_buttons = row("installer_nav", [
            button("btn_back", "< Back", "installer.back"),
            button("btn_next", "Next >", "installer.next"),
            button("btn_install", "Install", "installer.install"),
            button("btn_cancel", "Cancel", "installer.cancel")
        ])

        val status = statusbar("installer_status", "Step 1 of 4: Welcome", "Ready")

        val root = column("installer_root", [
            wizard_steps,
            welcome_step,
            disk_step,
            confirm_step,
            progress,
            nav_buttons,
            status
        ])

        val tree = build_tree_with_title(root, "SimpleOS Installer", "dark")
        UISession.new(tree)
