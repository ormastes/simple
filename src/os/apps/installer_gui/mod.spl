# Installer GUI Module — GUI Apps for Package Management and OS Installation
# MDSOC: feature dimension, apps layer
#
# Submodules:
#   installer_gui  — macOS/Linux-style multi-step OS installer wizard
#   install_dialog — Reusable app install/remove confirmation dialogs
#   upgrade_gui    — macOS Software Update style upgrade panel

