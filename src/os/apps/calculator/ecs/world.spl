# Calculator ECS World — per-app container
#
# MDSOC+: the CalcWorld owns all calculator entities and their component data.
# Follows the same pattern as WmWorld, PmWorld, ClockWorld.

use std.ecs.entity.{Entity, EntityAllocator}
use std.ecs.component_store.{ComponentStore}
use std.ecs.world.{WorldBase}
use os.apps.calculator.ecs.components.{DisplayValue, DisplayExpr, CalcOperator, CalcAccumulator, InputState}

struct CalcWorld:
    """ECS world that owns calculator UI state entities."""
    base: WorldBase
    display_values: ComponentStore<DisplayValue>
    display_exprs: ComponentStore<DisplayExpr>
    operators: ComponentStore<CalcOperator>
    accumulators: ComponentStore<CalcAccumulator>
    input_states: ComponentStore<InputState>

    static fn new() -> CalcWorld:
        CalcWorld(
            base: WorldBase.new(),
            display_values: ComponentStore.new(),
            display_exprs: ComponentStore.new(),
            operators: ComponentStore.new(),
            accumulators: ComponentStore.new(),
            input_states: ComponentStore.new()
        )

    fn spawn_calc(self) -> Entity:
        """Spawn the singleton calculator entity with default components."""
        val e = self.base.spawn()
        val tick = self.base.now()
        self.display_values.insert(e, DisplayValue(value: "0"), tick)
        self.display_exprs.insert(e, DisplayExpr(expr: ""), tick)
        self.operators.insert(e, CalcOperator(op: 0), tick)
        self.accumulators.insert(e, CalcAccumulator(value: 0.0), tick)
        self.input_states.insert(e, InputState(entering: true), tick)
        e
