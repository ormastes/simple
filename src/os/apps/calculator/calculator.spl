use common.ui.widget.{WidgetNode, UITree}
use common.ui.session.{UISession}
use common.ui.builder.{column, row, panel, text_widget, button, label, statusbar, build_tree_with_title}

class Calculator:

    static fn new() -> Calculator:
        Calculator()

    me build_ui() -> UISession:
        val display = panel("calc_display", "Calculator", [
            text_widget("display_value", "0"),
            text_widget("display_expr", "")
        ])

        val row_clear = row("row_clear", [
            button("btn_clear", "C", "calc.clear"),
            button("btn_sign", "+/-", "calc.sign"),
            button("btn_pct", "%", "calc.percent"),
            button("btn_div", "/", "calc.op.div")
        ])

        val row_789 = row("row_789", [
            button("btn_7", "7", "calc.digit.7"),
            button("btn_8", "8", "calc.digit.8"),
            button("btn_9", "9", "calc.digit.9"),
            button("btn_mul", "*", "calc.op.mul")
        ])

        val row_456 = row("row_456", [
            button("btn_4", "4", "calc.digit.4"),
            button("btn_5", "5", "calc.digit.5"),
            button("btn_6", "6", "calc.digit.6"),
            button("btn_sub", "-", "calc.op.sub")
        ])

        val row_123 = row("row_123", [
            button("btn_1", "1", "calc.digit.1"),
            button("btn_2", "2", "calc.digit.2"),
            button("btn_3", "3", "calc.digit.3"),
            button("btn_add", "+", "calc.op.add")
        ])

        val row_0eq = row("row_0eq", [
            button("btn_0", "0", "calc.digit.0"),
            button("btn_dot", ".", "calc.dot"),
            button("btn_eq", "=", "calc.equals")
        ])

        val keypad = panel("keypad", "Keypad", [
            row_clear,
            row_789,
            row_456,
            row_123,
            row_0eq
        ])

        val root = column("calc_root", [
            display,
            keypad
        ])

        val tree = build_tree_with_title(root, "Calculator", "dark")
        UISession.new(tree)
