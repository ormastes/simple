# FS-Exec Fallback Contract — arch-neutral resident-manifest fallback detection
#
# Single source of truth for the two serial-output patterns that indicate
# a resident-manifest fallback was used instead of genuine FS-exec proof.
# All architecture lanes (x86_64, riscv64, riscv32, arm64, arm32) must
# reject serial output containing these patterns as completion evidence.
#
# Usage: import fs_exec_serial_rejects_fallback and call it in each arch's
# serial-acceptance path before returning "ready".

pub val FS_EXEC_FALLBACK_PATTERN_RESIDENT_ACTIVE: text = "[desktop-e2e] resident-fallback:active"
pub val FS_EXEC_FALLBACK_PATTERN_LAUNCHER: text = "[launcher] fallback=resident-manifest"

pub fn fs_exec_serial_has_fallback(serial_output: text) -> bool:
    """Return true if serial output contains a resident-manifest fallback pattern.

    The two patterns are:
      [desktop-e2e] resident-fallback:active  — e2e probe detected fallback mode
      [launcher] fallback=resident-manifest   — launcher logged fallback activation

    Either pattern is sufficient; the launcher log may be absent on old kernels.
    """
    (serial_output.contains(FS_EXEC_FALLBACK_PATTERN_RESIDENT_ACTIVE) or
     serial_output.contains(FS_EXEC_FALLBACK_PATTERN_LAUNCHER))

pub fn fs_exec_serial_rejects_fallback(serial_output: text) -> bool:
    """Return true if the serial output is free of resident-manifest fallback patterns.

    Use this as a fail-closed guard: completion evidence is only valid when
    this returns true. A false return means the run fell back to the resident
    manifest and did NOT exercise genuine FS-exec paths.
    """
    not fs_exec_serial_has_fallback(serial_output)
