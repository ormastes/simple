# OS Task — Task wrapper for the OS async executor
#
# Wraps a poll function (type-erased to i64) with an ID and completion state.
# The executor manages a list of OsTask and polls them in round-robin order.
#
# OsTaskHandle is the user-facing handle returned by executor.spawn().

use os.async.os_poll.{OsPoll}
use os.async.os_waker.{OsWaker}

# ============================================================================
# OsTaskHandle — User-facing handle
# ============================================================================

struct OsTaskHandle:
    """Handle to a spawned async task.

    Returned by OsExecutor.spawn(). Use with executor.get_result()
    to retrieve the task's completion value.
    """
    id: u64
    completed: bool

# ============================================================================
# OsTask — Internal task wrapper
# ============================================================================

struct OsTask:
    """Internal task representation used by the executor.

    The future is stored as a type-erased poll function (fn(OsWaker) -> OsPoll<i64>)
    since the executor needs a heterogeneous task list. Higher-level wrappers
    can handle type conversion at the spawn boundary.
    """
    id: u64
    poll_fn: fn(OsWaker) -> OsPoll<i64>
    completed: bool
    result: i64
