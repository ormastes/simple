# Minimal cooperative executor state for SimpleOS services.

use os.async.os_waker.{OsWaker}

class OsExecutor:
    next_task_id: u64
    wake_count: u64

    static fn new() -> OsExecutor:
        OsExecutor(next_task_id: 1, wake_count: 0)

    me allocate_task_id() -> u64:
        val task_id = self.next_task_id
        self.next_task_id = self.next_task_id + 1
        task_id

    me make_waker() -> OsWaker:
        OsWaker.new(0, self.allocate_task_id())

    me notify(waker: OsWaker) -> bool:
        self.wake_count = self.wake_count + 1
        waker.wake()

    me pending_wakes() -> u64:
        self.wake_count
