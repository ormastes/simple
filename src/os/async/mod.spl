# OS Async Runtime — Notification-based async I/O for SimpleOS
#
# Provides an OS-level async runtime that uses L4-style kernel notification
# objects for sleep/wakeup instead of host OS primitives (epoll/kqueue).
#
# Architecture:
#   OsFuture<T>  — trait for pollable async operations
#   OsWaker      — signals a notification to wake the executor
#   OsExecutor   — single-threaded task executor (sleeps on NotificationWait)
#   SpscRing     — lock-free ring buffer for shared-memory data paths
#   WaitAny      — multiplexed wait on multiple notifications
#
# Usage:
#   val exec = OsExecutor.new()
#   val handle = exec.spawn(\waker: my_async_operation(waker))
#   exec.run_until_complete()
#   val result = exec.get_result(handle)
#   exec.destroy()

use os.async.os_poll.{OsPoll}
use os.async.os_waker.{OsWaker}
use os.async.os_future.{OsFuture, ReadyFuture, PendingFuture}
use os.async.os_task.{OsTask, OsTaskHandle}
use os.async.os_executor.{OsExecutor}
use os.async.ring_buffer.{SpscRing}
use os.async.wait_any.{WaitAnyResult, wait_any_poll, wait_any_blocking, wait_one}
