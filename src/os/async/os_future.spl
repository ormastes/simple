# SimpleOS future trait and immediate future adapter.

use os.async.os_poll.{OsPoll}
use os.async.os_waker.{OsWaker}

trait OsFuture<T>:
    fn poll(waker: OsWaker) -> OsPoll<T>

class ReadyFuture<T>:
    value: T

    static fn new(value: T) -> ReadyFuture<T>:
        ReadyFuture(value: value)

impl OsFuture<T> for ReadyFuture<T>:
    fn poll(waker: OsWaker) -> OsPoll<T>:
        OsPoll.Ready(value: self.value)
