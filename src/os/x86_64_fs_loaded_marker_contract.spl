"""
x86_64 FS-Loaded Tool Apps — scoped marker contract for the six tool apps.

This is a SUBSET projection of desktop_uefi_required_marker_fragments() in
src/os/desktop_qemu_contract.spl (which remains the canonical source of truth).
It exposes only the marker fragments required to prove the six tool apps defined
in x86_64_fs_loaded_tool_apps.spl, for targeted focused testing.

Do NOT diverge from the literal marker strings in desktop_qemu_contract.spl.
"""

# VFS-read proof marker fragment for a tool app.
# Matches: [desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/<name> bytes=
pub fn vfs_app_read_marker(app_name: text) -> text:
    "[desktop-e2e] vfs-app-read:ok source=generic-vfs path=/sys/apps/{app_name} bytes="

# Process-backed launch proof marker fragment for a tool app.
# Matches: [desktop-e2e] process-backed:ok app=<name> pid=
pub fn process_backed_marker(app_name: text) -> text:
    "[desktop-e2e] process-backed:ok app={app_name} pid="

# simple_browser WM ownership proof marker fragment.
pub fn browser_wm_owner_marker() -> text:
    "[desktop-e2e] wm-owner:ok app=simple_browser pid="

# simple_browser render proof marker fragment.
pub fn browser_render_proof_marker() -> text:
    "[desktop-e2e] render-proof:ok app=simple_browser pid="

# simple_browser page_rendered marker fragment.
pub fn browser_page_rendered_marker() -> text:
    "[simple_browser] page_rendered app_id=/sys/apps/simple_browser"

# llvm toolchain-launch marker fragment (native-wrapper lane).
# Per plan: mode=native-wrapper, tool=/usr/bin/clang
pub fn llvm_toolchain_launch_marker() -> text:
    "[desktop-e2e] toolchain-launch:ok app=llvm mode=native-wrapper lane=x86_64-simpleos status=guest-exec tool=/usr/bin/clang"

# rust toolchain-launch marker fragment (native-wrapper lane).
# Per plan: status=report-and-gate, aux=/usr/bin/cargo
pub fn rust_toolchain_launch_marker() -> text:
    "[desktop-e2e] toolchain-launch:ok app=rust mode=native-wrapper lane=x86_64-simpleos status=report-and-gate tool=/usr/bin/rustc aux=/usr/bin/cargo"

# All required marker fragments for the six tool apps (subset projection).
# Canonical: desktop_uefi_required_marker_fragments() in desktop_qemu_contract.spl
pub fn tool_apps_required_marker_fragments() -> [text]:
    var markers: [text] = []
    for app_name in [
        "simple_browser",
        "simple_compiler",
        "simple_interpreter",
        "simple_loader",
        "llvm",
        "rust"
    ]:
        markers.push(vfs_app_read_marker(app_name))
        markers.push(process_backed_marker(app_name))
    markers.push(browser_wm_owner_marker())
    markers.push(browser_render_proof_marker())
    markers.push(browser_page_rendered_marker())
    markers.push(llvm_toolchain_launch_marker())
    markers.push(rust_toolchain_launch_marker())
    markers

# Returns true only if serial output contains all required tool-app marker fragments.
# Resident-manifest fallback does not satisfy this contract.
pub fn tool_apps_serial_accepts_completion(serial_output: text) -> bool:
    for marker in tool_apps_required_marker_fragments():
        if not serial_output.contains(marker):
            return false
    true

# Prints which marker fragments are absent from the serial output.
pub fn print_tool_apps_missing_markers(serial_output: text):
    for marker in tool_apps_required_marker_fragments():
        if not serial_output.contains(marker):
            print "[test] missing marker fragment: {marker}"
