"""
SOSIX process compatibility helpers.

Thin wrappers that adapt the raw SOSIX request-slot API into a simple
synchronous surface for callers that do not need async tracking.
"""

use os.sosix.process.{
    SOSIX_PROCESS_MAX_REQUESTS,
    sosix_process_init,
    sosix_process_spawn,
    sosix_process_wait_request
}

fn sosix_spawn_sync(path: text, priority: u8) -> i64:
    """
    Synchronous spawn: start a binary and wait for the request to complete.
    Returns the kernel result (>= 0 = new PID, < 0 = errno).
    """
    val req = sosix_process_spawn(path, [], priority)
    if req >= SOSIX_PROCESS_MAX_REQUESTS:
        return -1
    sosix_process_wait_request(req)

fn sosix_compat_init():
    """Initialise the process subsystem via the native SOSIX API."""
    sosix_process_init()
