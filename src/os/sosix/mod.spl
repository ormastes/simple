# SOSIX — Simple-native async OS interface.

use os.sosix.process.{sosix_process_init}
use os.sosix.share.{sosix_share_init}
use os.sosix.io_state.{sosix_io_init}
use os.sosix.socket_share.{sosix_socket_share_init}
use os.sosix.dylib_share.{sosix_dylib_share_init}
use os.sosix.fd_ownership.{sosix_fd_ownership_init}

fn sosix_init():
    """Initialize SOSIX process, sharing, async I/O, socket transfers, dylib grants, and FD ownership state."""
    sosix_process_init()
    sosix_share_init()
    sosix_io_init()
    sosix_socket_share_init()
    sosix_dylib_share_init()
    sosix_fd_ownership_init()
