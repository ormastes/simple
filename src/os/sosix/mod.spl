# SOSIX — Simple-native async OS interface.

use os.sosix.process.{sosix_process_init}
use os.sosix.share.{sosix_share_init}
use os.sosix.io.{sosix_io_init}

fn sosix_init():
    """Initialize SOSIX process, sharing, and async I/O state for this runtime."""
    sosix_process_init()
    sosix_share_init()
    sosix_io_init()
