"""
SOSIX dataset-from-VFS bridge stub.

`dataset_create_from_file` will populate an immutable dataset from a VFS path
once the VFS byte-reading API stabilises. Currently returns ENOSYS.
"""

use os.kernel.errno.{ENOSYS, EINVAL}
use os.sosix.share.{
    SOSIX_DATASET_MAX_BYTES,
    sosix_dataset_create,
    sosix_dataset_write,
    sosix_dataset_seal
}

val SOSIX_DATASET_VFS_ENOSYS: i64 = 0 - ENOSYS as i64

fn sosix_dataset_create_from_file(path: text, max_bytes: u64) -> i64:
    """
    Create a sealed immutable dataset populated from a VFS file.

    Returns a dataset handle (>= 0) on success, or a negative errno on failure.
    Currently always returns ENOSYS until VFS byte-read integration lands.
    """
    if path.len() == 0:
        return 0 - EINVAL as i64
    if max_bytes == 0 or max_bytes > SOSIX_DATASET_MAX_BYTES:
        return 0 - EINVAL as i64
    # Placeholder: VFS read not yet wired.
    SOSIX_DATASET_VFS_ENOSYS

fn sosix_dataset_vfs_available() -> bool:
    """Return true when the dataset-from-VFS path is implemented."""
    false
