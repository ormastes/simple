fn simpleos_platform_staged_toolchain_app_names(name: text) -> [text]:
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        var names: [text] = []
        for app in simpleos_platform_targets()[idx].staged_toolchain_apps:
            names.push(app.app_name)
        return names
    []

fn simpleos_platform_qemu_smoke_lane(name: text) -> SimpleOsLaneContract:
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        return simpleos_platform_targets()[idx].qemu_smoke_lane
    _lane_contract(
        "unknown-smoke",
        SimpleOsLaneKind.Smoke,
        SimpleOsFirmwareContractKind.LimineBios,
        SimpleOsImageLayoutKind.KernelOnly,
        "src/os/kernel/arch/x86_64/boot.spl",
        "src/os/kernel/arch/x86_64/linker.ld",
        "build/os/simpleos_unknown.elf",
        "128M",
        "",
        [],
        10000,
        [],
        [],
        "",
        "build/os/simpleos_unknown.elf"
    )

fn simpleos_platform_qemu_acceptance_lane(name: text) -> SimpleOsLaneContract:
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        return simpleos_platform_targets()[idx].qemu_acceptance_lane
    simpleos_platform_qemu_smoke_lane(name)

fn simpleos_platform_qemu_additional_lanes(name: text) -> [SimpleOsLaneContract]:
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        return simpleos_platform_targets()[idx].qemu_additional_lanes
    []

fn simpleos_platform_qemu_lane(name: text, lane_name: text) -> SimpleOsLaneContract?:
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        val tgts = simpleos_platform_targets()
        val smoke = tgts[idx].qemu_smoke_lane
        if smoke.name == lane_name:
            return smoke
        val accept = tgts[idx].qemu_acceptance_lane
        if accept.name == lane_name:
            return accept
        for lane in tgts[idx].qemu_additional_lanes:
            if lane.name == lane_name:
                return lane
    nil

fn simpleos_platform_qemu_lanes(name: text) -> [SimpleOsLaneContract]:
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        val tgts = simpleos_platform_targets()
        val smoke = tgts[idx].qemu_smoke_lane
        var lanes = [smoke]
        val accept = tgts[idx].qemu_acceptance_lane
        if accept.name != smoke.name:
            lanes.push(accept)
        for lane in tgts[idx].qemu_additional_lanes:
            lanes.push(lane)
        return lanes
    []

fn simpleos_platform_qemu_lane_or_smoke(name: text, lane_name: text) -> SimpleOsLaneContract:
    """Return the named QEMU lane, or the smoke lane if not found. Never returns Option."""
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        val tgts = simpleos_platform_targets()
        val smoke = tgts[idx].qemu_smoke_lane
        if smoke.name == lane_name:
            return smoke
        val accept = tgts[idx].qemu_acceptance_lane
        if accept.name == lane_name:
            return accept
        for lane in tgts[idx].qemu_additional_lanes:
            if lane.name == lane_name:
                return lane
        return smoke
    simpleos_platform_qemu_smoke_lane(name)

fn simpleos_platform_has_qemu_lane(name: text, lane_name: text) -> bool:
    """Return true if the named target has a QEMU lane with the given lane name."""
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        val tgts = simpleos_platform_targets()
        val smoke = tgts[idx].qemu_smoke_lane
        if smoke.name == lane_name:
            return true
        val accept = tgts[idx].qemu_acceptance_lane
        if accept.name == lane_name:
            return true
        for lane in tgts[idx].qemu_additional_lanes:
            if lane.name == lane_name:
                return true
    false

fn simpleos_platform_qemu_lane_timeout_ms(name: text, lane_name: text) -> i64:
    """Return timeout_ms for the named lane, or 0 if not found. Never returns Option."""
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        val tgts = simpleos_platform_targets()
        val smoke = tgts[idx].qemu_smoke_lane
        if smoke.name == lane_name:
            return smoke.timeout_ms
        val accept = tgts[idx].qemu_acceptance_lane
        if accept.name == lane_name:
            return accept.timeout_ms
        for lane in tgts[idx].qemu_additional_lanes:
            if lane.name == lane_name:
                return lane.timeout_ms
    0

fn simpleos_platform_qemu_lane_required_markers(name: text, lane_name: text) -> [text]:
    """Return required_serial_markers for the named lane, or [] if not found. Never returns Option."""
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        val tgts = simpleos_platform_targets()
        val smoke = tgts[idx].qemu_smoke_lane
        if smoke.name == lane_name:
            return smoke.required_serial_markers
        val accept = tgts[idx].qemu_acceptance_lane
        if accept.name == lane_name:
            return accept.required_serial_markers
        for lane in tgts[idx].qemu_additional_lanes:
            if lane.name == lane_name:
                return lane.required_serial_markers
    []

fn simpleos_platform_qemu_acceptance_required_markers(name: text) -> [text]:
    simpleos_platform_qemu_acceptance_lane(name).required_serial_markers

fn simpleos_platform_qemu_acceptance_timeout_ms(name: text) -> i64:
    simpleos_platform_qemu_acceptance_lane(name).timeout_ms

fn simpleos_platform_board_lane(name: text) -> SimpleOsLaneContract?:
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        return simpleos_platform_targets()[idx].board_lane
    nil

fn simpleos_platform_has_board_lane(name: text) -> bool:
    """Return true if the platform has a board lane declared. Avoids Option<large-struct>."""
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        val board = simpleos_platform_targets()[idx].board_lane
        return board != nil
    false

fn simpleos_platform_board_lane_direct(name: text) -> SimpleOsLaneContract:
    """Return the board lane, or smoke lane if none declared. Never returns Option."""
    # board_lane is SimpleOsLaneContract? on the target struct. Access locally (not via fn return).
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        val tgt = simpleos_platform_targets()[idx]
        if val board = tgt.board_lane:
            return board
        return tgt.qemu_smoke_lane
    simpleos_platform_qemu_smoke_lane(name)
