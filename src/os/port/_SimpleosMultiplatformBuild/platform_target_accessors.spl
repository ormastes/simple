# SimpleOS multi-platform build — accessor functions over the platform target
# catalog (lookups, flags, QEMU/board lanes, markers, timeouts).
use os.port.simpleos_multiplatform_build.*
# SimpleOS Multi-Platform Build Catalog
#
# Centralizes target triples, C/ASM boot inputs, and freestanding compiler
# flags for SimpleOS kernel and boot-wrapper binaries.

use os.kernel.arch.arch_context.{Architecture}

fn simpleos_platform_target_matches(target: SimpleOsPlatformBuildTarget, name: text) -> bool:
    if target.name == name:
        return true
    if target.native_target == name:
        return true
    if target.clang_target == name:
        return true
    for alias in target.aliases:
        if alias == name:
            return true
    false

fn _simpleos_platform_target_index(name: text) -> i64:
    """Return the 0-based index of the named target in simpleos_platform_targets(), or -1."""
    val targets = simpleos_platform_targets()
    var idx: i64 = 0
    for target in targets:
        if simpleos_platform_target_matches(target, name):
            return idx
        idx = idx + 1
    -1

fn simpleos_platform_target_by_name(name: text) -> SimpleOsPlatformBuildTarget?:
    """Resolve a SimpleOS platform target by canonical name, triple, or alias."""
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        return simpleos_platform_targets()[idx]
    nil

fn simpleos_platform_target_names() -> [text]:
    """Return canonical SimpleOS platform target names."""
    var names: [text] = []
    for target in simpleos_platform_targets():
        names.push(target.name)
    names

fn simpleos_platform_artifact_slug(name: text) -> text:
    val idx = _simpleos_platform_target_index(name)
    if idx >= 0:
        return simpleos_platform_targets()[idx].platform_slug
    "unknown"

