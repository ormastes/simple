# UNIFIED DIFF — apply with: cd $RUST_FORK && patch -p1 < rustc_llvm_build_rs.patch
#
# When building rustc_llvm against a SimpleOS target, we must use the LLVM
# that was built *for* SimpleOS (Workstream A). Upstream build.rs falls back
# to the system/host LLVM when llvm-config is missing — that silently picks
# up the wrong triple and breaks link.
#
# After this patch: target_os="simpleos" => llvm-config is mandatory and
# resolved from $SDKROOT or $LLVM_CONFIG; no host fallback.

--- a/compiler/rustc_llvm/build.rs
+++ b/compiler/rustc_llvm/build.rs
@@ -- fn find_llvm_config() -> PathBuf {
 fn find_llvm_config() -> PathBuf {
+    // SimpleOS: require an explicit SDK-provided llvm-config. No host fallback.
+    let target_os = env::var("CARGO_CFG_TARGET_OS").unwrap_or_default();
+    if target_os == "simpleos" {
+        if let Ok(v) = env::var("LLVM_CONFIG") {
+            let p = PathBuf::from(v);
+            if p.exists() {
+                return p;
+            }
+            panic!(
+                "rustc_llvm: LLVM_CONFIG='{}' does not exist (required for simpleos target)",
+                p.display()
+            );
+        }
+        if let Ok(sdk) = env::var("SDKROOT") {
+            let p = PathBuf::from(&sdk).join("bin/llvm-config");
+            if p.exists() {
+                return p;
+            }
+            panic!(
+                "rustc_llvm: $SDKROOT/bin/llvm-config missing at {} (required for simpleos target)",
+                p.display()
+            );
+        }
+        panic!(
+            "rustc_llvm: target_os=simpleos requires LLVM_CONFIG or SDKROOT to point at a SimpleOS LLVM build (Workstream A)"
+        );
+    }
+
     // ... existing host-fallback logic unchanged below ...
     if let Ok(v) = env::var("LLVM_CONFIG") {
         return PathBuf::from(v);
     }
     // host default
     which::which("llvm-config").expect("llvm-config not found")
 }
