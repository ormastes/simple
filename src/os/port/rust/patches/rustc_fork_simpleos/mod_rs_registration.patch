# UNIFIED DIFF — apply with: cd $RUST_FORK && patch -p1 < mod_rs_registration.patch
#
# Registers the four new simpleos modules in compiler/rustc_target/src/spec/mod.rs.
# Two hunks:
#   (1) `mod NAME;` declarations (kept alphabetized with neighbors).
#   (2) entries inside the `supported_targets! { ... }` invocation.
#
# Context lines rely on upstream neighbor modules. If upstream renames or
# removes `x86_64_unknown_none` / `riscv64gc_unknown_none_elf`, adjust the
# anchors before applying.
#
# Hunk preview (informative; real diff below):
# + mod aarch64_unknown_simpleos;
# + mod riscv32imac_unknown_simpleos;
# + mod riscv64gc_unknown_simpleos;
# + mod x86_64_unknown_simpleos;
# + ("aarch64-unknown-simpleos",     aarch64_unknown_simpleos),
# + ("riscv32imac-unknown-simpleos", riscv32imac_unknown_simpleos),
# + ("riscv64gc-unknown-simpleos",   riscv64gc_unknown_simpleos),
# + ("x86_64-unknown-simpleos",      x86_64_unknown_simpleos),

--- a/compiler/rustc_target/src/spec/mod.rs
+++ b/compiler/rustc_target/src/spec/mod.rs
@@ -- mod aarch64_unknown_redox;
 mod aarch64_unknown_redox;
+mod aarch64_unknown_simpleos;
 mod aarch64_unknown_teeos;
@@ -- mod riscv32imac_unknown_none_elf;
 mod riscv32imac_unknown_none_elf;
+mod riscv32imac_unknown_simpleos;
 mod riscv32imc_esp_espidf;
@@ -- mod riscv64gc_unknown_none_elf;
 mod riscv64gc_unknown_none_elf;
+mod riscv64gc_unknown_simpleos;
 mod riscv64imac_unknown_none_elf;
@@ -- mod x86_64_unknown_none;
 mod x86_64_unknown_none;
+mod x86_64_unknown_simpleos;
 mod x86_64_unknown_openbsd;
@@ -- supported_targets! {
     ("aarch64-unknown-redox",                 aarch64_unknown_redox),
+    ("aarch64-unknown-simpleos",              aarch64_unknown_simpleos),
     ("aarch64-unknown-teeos",                 aarch64_unknown_teeos),
@@ --
     ("riscv32imac-unknown-none-elf",          riscv32imac_unknown_none_elf),
+    ("riscv32imac-unknown-simpleos",          riscv32imac_unknown_simpleos),
     ("riscv32imc-esp-espidf",                 riscv32imc_esp_espidf),
@@ --
     ("riscv64gc-unknown-none-elf",            riscv64gc_unknown_none_elf),
+    ("riscv64gc-unknown-simpleos",            riscv64gc_unknown_simpleos),
     ("riscv64imac-unknown-none-elf",          riscv64imac_unknown_none_elf),
@@ --
     ("x86_64-unknown-none",                   x86_64_unknown_none),
+    ("x86_64-unknown-simpleos",               x86_64_unknown_simpleos),
     ("x86_64-unknown-openbsd",                x86_64_unknown_openbsd),
 }
