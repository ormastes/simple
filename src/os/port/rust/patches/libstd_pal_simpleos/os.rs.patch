//! Target: `library/std/src/sys/pal/simpleos/os.rs`
//!
//! `errno`, `error_string`, `getcwd`, `chdir`. `current_exe` and `temp_dir`
//! are best-effort — SimpleOS does not yet track the binary path.

use crate::error::Error as StdError;
use crate::ffi::{CStr, OsStr, OsString};
use crate::fmt;
use crate::io;
use crate::marker::PhantomData;
use crate::os::simpleos::ffi::{OsStrExt, OsStringExt};
use crate::path::{self, PathBuf};

unsafe extern "C" {
    // libsimpleos_c TLS slot — same ABI as glibc's `__errno_location`.
    fn __errno_location() -> *mut i32;
    fn strerror_r(errnum: i32, buf: *mut u8, buflen: usize) -> i32;
    fn getcwd(buf: *mut u8, size: usize) -> *mut u8;
    fn chdir(path: *const i8) -> i32;
}

pub fn errno() -> i32 {
    unsafe { *__errno_location() }
}

pub fn set_errno(e: i32) {
    unsafe { *__errno_location() = e; }
}

pub fn error_string(errno: i32) -> crate::string::String {
    let mut buf = [0u8; 128];
    let r = unsafe { strerror_r(errno, buf.as_mut_ptr(), buf.len()) };
    if r != 0 {
        return crate::format!("unknown error {errno}");
    }
    // Find NUL.
    let len = buf.iter().position(|&b| b == 0).unwrap_or(buf.len());
    crate::string::String::from_utf8_lossy(&buf[..len]).into_owned()
}

pub fn getcwd() -> io::Result<PathBuf> {
    let mut buf = crate::vec::Vec::with_capacity(256);
    loop {
        buf.resize(buf.capacity(), 0u8);
        let p = unsafe { getcwd(buf.as_mut_ptr(), buf.len()) };
        if !p.is_null() {
            let len = buf.iter().position(|&b| b == 0).unwrap_or(buf.len());
            buf.truncate(len);
            return Ok(PathBuf::from(OsString::from_vec(buf)));
        }
        // ERANGE — double the buffer.
        if errno() != 34 {
            return Err(io::Error::from_raw_os_error(errno()));
        }
        let new_cap = buf.capacity().saturating_mul(2);
        buf.reserve(new_cap);
    }
}

pub fn chdir(p: &path::Path) -> io::Result<()> {
    let c = crate::ffi::CString::new(p.as_os_str().as_bytes())
        .map_err(|_| io::Error::from(io::ErrorKind::InvalidInput))?;
    let r = unsafe { chdir(c.as_ptr()) };
    if r < 0 { Err(io::Error::from_raw_os_error(errno())) } else { Ok(()) }
}

pub fn current_exe() -> io::Result<PathBuf> {
    // TODO: libsimpleos_c currently has no `procfs` equivalent. Stub out
    // until the kernel exposes `/proc/self/exe` or similar.
    Err(io::Error::from(io::ErrorKind::Unsupported))
}

pub fn temp_dir() -> PathBuf { PathBuf::from("/tmp") }

pub fn exit(code: i32) -> ! { crate::sys::process::exit(code) }

pub fn getpid() -> u32 {
    // TODO: libsimpleos_c `getpid`. No PIDs exist at phase-B1 scope.
    1
}

// Display shim used by `io::Error::other`.
pub struct JoinPathsError;

impl fmt::Display for JoinPathsError {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        "path joining is unsupported on SimpleOS".fmt(f)
    }
}

impl fmt::Debug for JoinPathsError {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result { fmt::Display::fmt(self, f) }
}

impl StdError for JoinPathsError {
    fn description(&self) -> &str { "unsupported" }
}

// split/join live in env.rs; re-export for `sys::os` consumers.
pub use crate::sys::env::{join_paths, split_paths, SplitPaths, PATH_SEPARATOR};

