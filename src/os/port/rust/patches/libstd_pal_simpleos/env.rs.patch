//! Target: `library/std/src/sys/pal/simpleos/env.rs`
//!
//! Command-line arguments and environment variables.
//!
//! * `args()` walks a host-provided `__simpleos_argv_ptr` extern that the
//!   runtime populates from `_start`. `init()` stashes the same `(argc, argv)`
//!   that `rt::lang_start` hands us; both sources should agree.
//! * `env::var` / `env::vars` / `set_var` stub to `Err`/noop — SimpleOS has
//!   no environment block yet.

use crate::ffi::{CStr, OsStr, OsString};
use crate::fmt;
use crate::io;
use crate::os::simpleos::ffi::OsStrExt;
use crate::path::{self, PathBuf};
use crate::sync::atomic::{AtomicIsize, AtomicPtr, Ordering};

// Populated by `rt::init` from the `_start` trampoline; also available
// directly as a runtime symbol for crates that skip `rt::lang_start`.
unsafe extern "C" {
    static __simpleos_argv_ptr: *const *const u8;
    static __simpleos_argc: isize;
}

static ARGC: AtomicIsize = AtomicIsize::new(0);
static ARGV: AtomicPtr<*const u8> = AtomicPtr::new(core::ptr::null_mut());

/// Stash `(argc, argv)` for later `args()` calls.
///
/// # Safety
/// `argv` must point to `argc + 1` NUL-terminated C strings (the trailing slot
/// is NULL per convention) that live for the whole process.
pub unsafe fn init(argc: isize, argv: *const *const u8) {
    ARGC.store(argc, Ordering::Relaxed);
    ARGV.store(argv as *mut *const u8, Ordering::Relaxed);
}

pub struct Args { iter: crate::vec::IntoIter<OsString> }

impl !Send for Args {}
impl !Sync for Args {}

impl fmt::Debug for Args {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        f.debug_list().entries(self.iter.as_slice()).finish()
    }
}

impl Iterator for Args {
    type Item = OsString;
    fn next(&mut self) -> Option<OsString> { self.iter.next() }
    fn size_hint(&self) -> (usize, Option<usize>) { self.iter.size_hint() }
}

impl ExactSizeIterator for Args {
    fn len(&self) -> usize { self.iter.len() }
}

impl DoubleEndedIterator for Args {
    fn next_back(&mut self) -> Option<OsString> { self.iter.next_back() }
}

pub fn args() -> Args {
    let (mut argc, mut argv) = (ARGC.load(Ordering::Relaxed), ARGV.load(Ordering::Relaxed));
    if argv.is_null() {
        // Fall back to the raw runtime symbols if `init` was never called.
        unsafe {
            argc = __simpleos_argc;
            argv = __simpleos_argv_ptr as *mut *const u8;
        }
    }
    let mut v = crate::vec::Vec::new();
    if !argv.is_null() && argc > 0 {
        for i in 0..argc {
            let p = unsafe { *argv.offset(i) };
            if p.is_null() { break; }
            let s = unsafe { CStr::from_ptr(p as *const i8) };
            v.push(OsStr::from_bytes(s.to_bytes()).to_owned());
        }
    }
    Args { iter: v.into_iter() }
}

// --- Environment (unsupported) --------------------------------------------

pub struct Env;

impl Iterator for Env {
    type Item = (OsString, OsString);
    fn next(&mut self) -> Option<Self::Item> { None }
}

pub fn env() -> Env { Env }

pub fn getenv(_k: &OsStr) -> Option<OsString> { None }

pub unsafe fn setenv(_k: &OsStr, _v: &OsStr) -> io::Result<()> {
    Err(io::Error::from(io::ErrorKind::Unsupported))
}

pub unsafe fn unsetenv(_k: &OsStr) -> io::Result<()> {
    Err(io::Error::from(io::ErrorKind::Unsupported))
}

// Path separators match POSIX conventions.
pub const PATH_SEPARATOR: u8 = b':';
pub fn split_paths(_unparsed: &OsStr) -> SplitPaths<'_> { SplitPaths(core::marker::PhantomData) }

pub struct SplitPaths<'a>(core::marker::PhantomData<&'a ()>);
impl<'a> Iterator for SplitPaths<'a> {
    type Item = PathBuf;
    fn next(&mut self) -> Option<PathBuf> { None }
}

pub struct JoinPathsError;
impl fmt::Display for JoinPathsError {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        "path joining is unsupported on SimpleOS".fmt(f)
    }
}
impl fmt::Debug for JoinPathsError {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result { fmt::Display::fmt(self, f) }
}
impl crate::error::Error for JoinPathsError {}

pub fn join_paths<I, T>(_paths: I) -> Result<OsString, JoinPathsError>
where I: Iterator<Item = T>, T: AsRef<OsStr>,
{ Err(JoinPathsError) }

pub fn home_dir() -> Option<PathBuf> { None }
