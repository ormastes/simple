#!/usr/bin/env sh
# offline_build.shs -- cross-compile a Rust crate for SimpleOS without
# any network access. Depends on a populated ./vendor/ directory (see
# src/compiler_rust/vendor/README.md).
#
# Usage:
#   sh src/os/port/rust/offline_build.shs [project_dir]
#
# Env:
#   SDKROOT   sysroot root (default: build/os/sysroot)
#   CARGO     cargo invocation (default: "cargo +nightly")

set -eu

PROJECT_DIR="${1:-src/compiler_rust}"
SDKROOT="${SDKROOT:-build/os/sysroot}"
CARGO="${CARGO:-cargo +nightly}"
TARGET="x86_64-unknown-simpleos"

if [ ! -d "$PROJECT_DIR" ]; then
    echo "[offline-build] ERROR: project dir not found: $PROJECT_DIR" >&2
    exit 1
fi

echo "[offline-build] project : $PROJECT_DIR"
echo "[offline-build] sdkroot : $SDKROOT"
echo "[offline-build] cargo   : $CARGO"
echo "[offline-build] target  : $TARGET"

# Print cargo version for reproducibility.
# shellcheck disable=SC2086
$CARGO --version || {
    echo "[offline-build] ERROR: cargo not runnable: $CARGO" >&2
    exit 1
}

cd "$PROJECT_DIR"

if [ ! -d "vendor" ]; then
    echo "[offline-build] WARN: vendor/ missing in $PROJECT_DIR" >&2
    echo "[offline-build] did you run \`cargo vendor\`?" >&2
fi

export SDKROOT

# shellcheck disable=SC2086
if ! $CARGO build \
        --offline \
        --release \
        --target "$TARGET" \
        -Z build-std=core,alloc,compiler_builtins; then
    echo "[offline-build] ERROR: cargo build failed" >&2
    echo "[offline-build] hint: did you run \`cargo vendor\`?" >&2
    exit 1
fi

echo "[offline-build] OK"
