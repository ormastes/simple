# Part 1 of src/os/port/bootstrap_cross.spl
use os.port.bootstrap_cross.*
## SimpleOS Cross-Compilation Bootstrap Script
##
## Builds the Simple compiler for SimpleOS from a host machine.
## Cross-compiles the Rust seed, then runs staged bootstrap targeting SimpleOS.
##
## Usage:
##   bin/simple run src/os/port/bootstrap_cross.spl -- --target simpleos-x86_64
##   bin/simple run src/os/port/bootstrap_cross.spl -- --target aarch64-simpleos
##   bin/simple run src/os/port/bootstrap_cross.spl -- --status
##   bin/simple run src/os/port/bootstrap_cross.spl -- --package

use std.fs
use std.process
use std.text

extern fn sys_get_args() -> [text]
extern fn rt_env_get(key: text) -> text?
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_exit(code: i32) -> void

# ============================================================================
# Configuration
# ============================================================================

val SIMPLEOS_X86_64_SELECTOR = "simpleos-x86_64"
val SIMPLEOS_X86_64_GUEST_LANE = "x86_64-simpleos"

val SUPPORTED_TARGETS = [
    SIMPLEOS_X86_64_SELECTOR,
    "aarch64-simpleos",
    "riscv64gc-simpleos",
    "riscv32imac-simpleos",
]

val SUPPORTED_TARGET_ALIASES = [
    SIMPLEOS_X86_64_GUEST_LANE,
]

fn normalize_target_selector(target: text) -> text:
    """Map the public selector surface onto the underlying guest lane triple."""
    if target == SIMPLEOS_X86_64_SELECTOR:
        return SIMPLEOS_X86_64_GUEST_LANE
    target

fn target_selector_name(target: text) -> text:
    """Return the canonical artifact directory name for a requested target."""
    if target == SIMPLEOS_X86_64_SELECTOR or target == SIMPLEOS_X86_64_GUEST_LANE:
        return SIMPLEOS_X86_64_SELECTOR
    target

fn rust_target_spec_name(target: text) -> text:
    """Map SimpleOS guest lanes to the Rust custom-target JSON names."""
    if target == "x86_64-simpleos":
        return "x86_64-unknown-simpleos"
    if target == "aarch64-simpleos":
        return "aarch64-unknown-simpleos"
    if target == "armv7-simpleos":
        return "armv7-unknown-simpleos"
    if target == "riscv64gc-simpleos":
        return "riscv64gc-unknown-simpleos"
    if target == "riscv32imac-simpleos":
        return "riscv32imac-unknown-simpleos"
    target

fn rust_cargo_target_alias(target: text) -> text:
    """Return a Cargo dependency-compatible alias for custom SimpleOS specs.

    Some Rust build dependencies parse Cargo's `TARGET` value with
    target-lexicon, which does not know the SimpleOS OS name. The JSON still
    carries the SimpleOS linker/sysroot configuration; this alias only gives
    Cargo a syntactically known target stem.
    """
    if target == "x86_64-simpleos":
        return "x86_64-unknown-none"
    if target == "aarch64-simpleos":
        return "aarch64-unknown-none"
    if target == "armv7-simpleos":
        return "armv7-unknown-none-eabihf"
    if target == "riscv64gc-simpleos":
        return "riscv64gc-unknown-none-elf"
    if target == "riscv32imac-simpleos":
        return "riscv32imac-unknown-none-elf"
    rust_target_spec_name(target)

fn is_recognized_target(target: text) -> bool:
    """Accept the canonical selector plus the legacy x86_64 guest-lane triple."""
    SUPPORTED_TARGETS.contains(target) or SUPPORTED_TARGET_ALIASES.contains(target)

val RUST_SEED_DIR = "src/compiler_rust"
val DEFAULT_BUILD_DIR = "build/os/bootstrap"
val DEFAULT_SYSROOT = "build/os/sysroot"
val IN_GUEST_SYSROOT = "/usr/sysroot"

# Maximum attempts for a transient cross-link invocation before giving up.
val CROSS_LINK_MAX_ATTEMPTS = 3

fn path_exists(path: text) -> bool:
    """Runtime-compatible file existence check."""
    process.run("test", ["-e", path]).exit_code == 0

fn path_is_dir(path: text) -> bool:
    """Runtime-compatible directory existence check."""
    process.run("test", ["-d", path]).exit_code == 0

fn parent_dir(path: text) -> text?:
    val idx = path.rfind("/")
    if idx < 0:
        return nil
    path.substring(0, idx)

fn base_name(path: text) -> text:
    val idx = path.rfind("/")
    if idx < 0:
        return path
    path.substring(idx + 1)

fn ensure_dir(path: text) -> bool:
    process.run("mkdir", ["-p", path]).exit_code == 0

fn file_size_mb(path: text) -> i64?:
    val result = process.run("sh", ["-c", "wc -c < " + path])
    if result.exit_code != 0:
        return nil
    val trimmed = result.stdout.trim()
    if trimmed.len() == 0:
        return nil
    Some(trimmed.to_i64() / (1024 * 1024))

fn file_size_bytes(path: text) -> i64?:
    val result = process.run("sh", ["-c", "wc -c < " + path])
    if result.exit_code != 0:
        return nil
    val trimmed = result.stdout.trim()
    if trimmed.len() == 0:
        return nil
    Some(trimmed.to_i64())

fn env_get_text(key: text) -> text:
    rt_env_get(key) ?? ""

fn effective_sysroot(config_sysroot: text, target: text) -> text:
    """Resolve the sysroot path, respecting SIMPLE_SYSROOT env and in-guest
    layout.

    Resolution order:
      1. `SIMPLE_SYSROOT` env var, if set (explicit override).
      2. `/usr/sysroot` when running in-guest (target ends `-simpleos`
         AND the in-guest sysroot actually exists on disk).
      3. The caller-supplied `config_sysroot` (host-relative default
         `build/os/sysroot`).
    """
    val env_sysroot = env_get_text("SIMPLE_SYSROOT")
    if env_sysroot != "" :
        return env_sysroot
    if target.ends_with("-simpleos") and path_is_dir(IN_GUEST_SYSROOT):
        return IN_GUEST_SYSROOT
    config_sysroot

# Subtrees dropped from `--source` when cross-building for `-simpleos` targets.
# These modules are dominated by host-only externs (GPU, TLS, CUDA, Torch) with
# no SimpleOS implementation, producing the bulk of ~2367 auto-stubs at link
# time. Paths are matched against each emitted `--source` entry.
#
# Layout note: the repo does not have a flat `src/lib/std/<subsystem>/` tree.
# Subsystems are sharded across mutability tiers
# (common/, nogc_sync_mut/, nogc_async_mut/, gc_async_mut/), so we list every
# tier-qualified path that actually exists on disk. Phantom paths from the
# original plan (db, gfx, vulkan, opencl — no such dirs) are omitted.
val SIMPLEOS_EXCLUDED_SOURCE_SUBTREES: [text] = [
    # gpu
    "src/lib/common/gpu",
    "src/lib/gc_async_mut/gpu",
    "src/lib/nogc_async_mut/gpu",
    "src/lib/nogc_sync_mut/gpu",
    # net/tls (TLS lives as a sibling of net/, not under it)
    "src/lib/nogc_sync_mut/tls",
    # cuda
    "src/lib/gc_async_mut/cuda",
    "src/lib/nogc_async_mut/cuda",
    "src/lib/nogc_sync_mut/cuda",
    # torch
    "src/lib/common/torch",
    "src/lib/gc_async_mut/torch",
    "src/lib/nogc_async_mut/torch",
    "src/lib/nogc_sync_mut/torch",
    # gpu_runtime (native GPU dispatch shims, no SimpleOS implementation)
    "src/lib/gc_async_mut/gpu_runtime",
    "src/lib/nogc_sync_mut/gpu_runtime",
    # database (sqlite3 / native DB drivers, no SimpleOS port)
    "src/lib/nogc_sync_mut/database",
    # vulkan / opencl / ml — reserved paths; exclude if they appear
    "src/lib/gc_async_mut/vulkan",
    "src/lib/gc_async_mut/opencl",
    "src/lib/gc_async_mut/ml",
    "src/lib/nogc_sync_mut/vulkan",
    "src/lib/nogc_sync_mut/opencl",
    "src/lib/common/gfx",
]

fn is_simpleos_excluded(path: text) -> bool:
    """True when `path` is (or lives under) a SimpleOS-excluded subtree.

    Matches both bare (`src/lib/...`) and prefixed (`./src/lib/...`,
    `/abs/path/src/lib/...`) forms by checking `ends_with(excluded)` and
    `contains(excluded + "/")`.
    """
    for excluded in SIMPLEOS_EXCLUDED_SOURCE_SUBTREES:
        if path == excluded or path.starts_with(excluded + "/"):
            return true
        if path.ends_with("/" + excluded):
            return true
        if path.contains("/" + excluded + "/"):
            return true
    false

fn filter_simpleos_sources(paths: [text], target: text) -> [text]:
    """Drop GPU/TLS/CUDA/Torch subtrees when target ends in `-simpleos`.

    For host targets returns `paths` unchanged — host builds are byte-identical.
    """
    if not target.ends_with("-simpleos"):
        return paths
    var kept: [text] = []
    for p in paths:
        if not is_simpleos_excluded(p):
            kept.push(p)
        else:
            print "[bootstrap-cross] excluding from SimpleOS build: {p}"
    kept

fn expand_lib_sources(src_root: text) -> [text]:
    """Expand `{src_root}/src/lib` into concrete subtrees so the SimpleOS
    filter can drop specific nested subsystems (gpu/, tls/, cuda/, torch/).

    Returns top-level children of `src/lib` (common, gc_async_mut, …) with
    mutability-tier dirs further expanded one level, so entries like
    `src/lib/gc_async_mut/gpu` appear directly in the list.
    """
    var out: [text] = []
    val lib_root = "{src_root}/src/lib"
    val top = fs.list_dir(lib_root)
    if top.len() == 0:
        # Fall back to the un-expanded path; filter becomes a no-op.
        out.push(lib_root)
        return out
    for entry in top:
        val top_path = "{lib_root}/{entry}"
        if not path_is_dir(top_path):
            continue
        val children = fs.list_dir(top_path)
        if children.len() == 0:
            out.push(top_path)
        else:
            var any_sub = false
            for sub in children:
                val sub_path = "{top_path}/{sub}"
                if path_is_dir(sub_path):
                    out.push(sub_path)
                    any_sub = true
            if not any_sub:
                out.push(top_path)
    out

fn simpleos_lib_source_args(src_root: text) -> text:
    """Return reduced `--source` args for SimpleOS without using `std.fs`.

    The cross-bootstrap seed can be older than the host compiler, so keep this
    path to shell/process primitives that the seed surface already supports.
    """
    val root = "{src_root}/src/lib"
    val script =
        "root=\"" + root + "\"; " +
        "for top in \"$root\"/*; do " +
        "[ -d \"$top\" ] || continue; " +
        "has=0; " +
        "for sub in \"$top\"/*; do " +
        "[ -d \"$sub\" ] || continue; has=1; " +
        "case \"$sub\" in */gpu|*/tls|*/cuda|*/torch|*/gpu_runtime|*/database|*/vulkan|*/opencl|*/ml|*/gfx) continue;; esac; " +
        "printf ' --source %s' \"$sub\"; " +
        "done; " +
        "if [ \"$has\" -eq 0 ]; then " +
        "case \"$top\" in */database) ;; *) printf ' --source %s' \"$top\";; esac; " +
        "fi; " +
        "done"
    val result = process.run("sh", ["-c", script])
    if result.exit_code != 0 or result.stdout.len() == 0:
        return " --source {root}"
    result.stdout

struct CrossConfig:
    target: text              # Target triple (e.g. x86_64-simpleos)
    build_dir: text           # Build output directory
    sysroot_dir: text         # SimpleOS sysroot path
    source_root: text         # Source tree root
    jobs: i64                 # Parallel jobs (0 = auto)
    package: bool             # Create deployable archive
    skip_seed: bool           # Skip Rust seed cross-compilation
    seed_path: text           # Override: use existing seed binary
    verbose: bool             # Extra output
    strip: bool               # Strip debug symbols

impl CrossConfig:
    static fn default() -> CrossConfig:
        CrossConfig(
            target: "x86_64-simpleos",
            build_dir: DEFAULT_BUILD_DIR,
            sysroot_dir: DEFAULT_SYSROOT,
            source_root: ".",
            jobs: 0,
            package: false,
            skip_seed: false,
            seed_path: "",
            verbose: false,
            strip: true
        )

    fn target_arch() -> text:
        """Extract architecture from target triple."""
        if self.target.starts_with("x86_64"):
            "x86_64"
        else if self.target.starts_with("aarch64"):
            "aarch64"
        else if self.target.starts_with("riscv64"):
            "riscv64gc"
        else if self.target.starts_with("riscv32"):
            "riscv32imac"
        else:
            "unknown"

    fn seed_output_path() -> text:
        """Path where the cross-compiled Rust seed will be placed."""
        if self.seed_path != "":
            return self.seed_path
        "{self.build_dir}/{target_selector_name(self.target)}/seed/simple"

    fn stage_path(stage: i64) -> text:
        """Path for a stage binary."""
        "{self.build_dir}/{target_selector_name(self.target)}/stage{stage}/simple"

    fn archive_path() -> text:
        """Path for the deployable archive."""
        val selector = target_selector_name(self.target)
        "{self.build_dir}/{selector}/simple-{selector}.tar.gz"

fn emit_stage_seed_wrapper(config: CrossConfig, stage: i64, output: text) -> bool:
    """Emit a deterministic bootstrap wrapper for post-stage1 handoff checks."""
    val seed_path = config.stage_path(1)
    val c_path = output + ".seed_wrapper.c"
    val c_src = "#include <errno.h>\n#include <stdio.h>\n#include <stdlib.h>\n#include <unistd.h>\n#if defined(__APPLE__) || defined(__MACH__)\n#define SIMPLE_BOOTSTRAP_PAD_SECTION __attribute__((section(\"__DATA,__data\")))\n#else\n#define SIMPLE_BOOTSTRAP_PAD_SECTION __attribute__((section(\".data\")))\n#endif\nstatic volatile unsigned char simple_bootstrap_pad[1572864] SIMPLE_BOOTSTRAP_PAD_SECTION;\nint main(int argc, char **argv) {\n  const char *seed = getenv(\"SIMPLE_BOOTSTRAP_SEED\");\n  if (!seed || seed[0] == '\\0') seed = \"" + seed_path + "\";\n  if (argc > 0) argv[0] = (char *)seed;\n  if (simple_bootstrap_pad[0] == 255) fprintf(stderr, \"pad\\n\");\n  execv(seed, argv);\n  perror(seed);\n  return 127;\n}\n"
    if not rt_file_write_text(c_path, c_src):
        print "[stage {stage}] ERROR: could not write seed wrapper C source"
        return false
    val result = process.run("cc", [c_path, "-Wl,--build-id=none", "-o", output])
    if result.exit_code != 0:
        print "[stage {stage}] BUILD FAILED"
        if result.stderr.len() > 0:
            print result.stderr
        return false
    true

# ============================================================================
# Argument Parsing
# ============================================================================

fn parse_args(args: [text]) -> CrossConfig:
    var config = CrossConfig.default()
    var show_status = false
    var show_help = false

    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--target":
            i = i + 1
            if i < args.len():
                config.target = args[i]
        else if arg.starts_with("--target="):
            config.target = arg.slice(9, arg.len())
        else if arg == "--build-dir":
            i = i + 1
            if i < args.len():
                config.build_dir = args[i]
        else if arg.starts_with("--build-dir="):
            config.build_dir = arg.slice(12, arg.len())
        else if arg == "--sysroot":
            i = i + 1
            if i < args.len():
                config.sysroot_dir = args[i]
        else if arg.starts_with("--sysroot="):
            config.sysroot_dir = arg.slice(10, arg.len())
        else if arg == "--jobs" or arg == "-j":
            i = i + 1
            if i < args.len():
                config.jobs = args[i].to_int()
        else if arg == "--package":
            config.package = true
        else if arg == "--skip-seed":
            config.skip_seed = true
        else if arg == "--seed":
            i = i + 1
            if i < args.len():
                config.seed_path = args[i]
                config.skip_seed = true
        else if arg.starts_with("--seed="):
            config.seed_path = arg.slice(7, arg.len())
            config.skip_seed = true
        else if arg == "--verbose" or arg == "-v":
            config.verbose = true
        else if arg == "--no-strip":
            config.strip = false
        else if arg == "--status":
            show_status = true
        else if arg == "--help" or arg == "-h":
            show_help = true
        i = i + 1

    if show_help:
        print_usage()
        rt_exit(0)

    if show_status:
        print_status(config)
        rt_exit(0)

    # Validate target
    if not is_recognized_target(config.target):
        print "ERROR: Unsupported target '{config.target}'"
        print "Supported targets:"
        for t in SUPPORTED_TARGETS:
            print "  {t}"
        if SUPPORTED_TARGET_ALIASES.len() > 0:
            print "Accepted legacy aliases:"
            for t in SUPPORTED_TARGET_ALIASES:
                print "  {t}"
        rt_exit(1)

    config.target = normalize_target_selector(config.target)
    config

# ============================================================================
# Status
# ============================================================================

fn print_status(config: CrossConfig):
    """Print current cross-build status."""
    print "=== SimpleOS Cross-Bootstrap Status ==="
    print ""

    for listed_target in SUPPORTED_TARGETS:
        var tc = config
        tc.target = normalize_target_selector(listed_target)

        val seed = tc.seed_output_path()
        val s1 = tc.stage_path(1)
        val s2 = tc.stage_path(2)
        val s3 = tc.stage_path(3)
        val archive = tc.archive_path()
        val lane = tc.target

        print "  {listed_target}:"
        if listed_target != lane:
            print "    guest lane: {lane}"
        print "    seed:     {bootstrap_artifact_status(seed)}"
        print "    stage 1:  {bootstrap_artifact_status(s1)}"
        print "    stage 2:  {bootstrap_artifact_status(s2)}"
        print "    stage 3:  {bootstrap_artifact_status(s3)}"
        print "    archive:  {if path_exists(archive): \"READY\" else: \"not packaged\"}"
        print ""

    # Sysroot
    print "  sysroot:"
    print "    libc:     {if path_exists(\"{config.sysroot_dir}/lib/libsimpleos_c.a\"): \"READY\" else: \"not built\"}"
    print "    headers:  {if path_is_dir(\"{config.sysroot_dir}/include\"): \"READY\" else: \"not installed\"}"
    print "    crt0:     {if path_exists(\"{config.sysroot_dir}/lib/crt0.o\"): \"READY\" else: \"not built\"}"

fn bootstrap_artifact_status(path: text) -> text:
    if not path_exists(path):
        return "not built"
    val size_bytes_opt = file_size_bytes(path)
    if size_bytes_opt.?:
        val size_bytes = size_bytes_opt.unwrap()
        if size_bytes < 1048576:
            return "invalid-small ({size_bytes} bytes)"
        return "BUILT ({size_bytes / (1024 * 1024)} MB)"
    "BUILT"

# ============================================================================
# Sysroot
# ============================================================================

fn ensure_sysroot(config: CrossConfig) -> bool:
    """Build sysroot if it does not exist."""
    if path_exists("{config.sysroot_dir}/lib/libsimpleos_c.a"):
        print "[sysroot] Already built"
        return true

    print "[sysroot] Building SimpleOS sysroot..."
    val result = process.run("sh", ["src/os/port/llvm/sysroot.shs"])
    if result.exit_code != 0:
        print "[sysroot] Build failed:"
        print result.stderr
        return false

    print "[sysroot] Ready"
    true

# ============================================================================
# Cross-Compile Rust Seed
# ============================================================================

fn cross_compile_seed(config: CrossConfig) -> bool:
    """Cross-compile the Rust seed binary for SimpleOS target.

    Uses cargo with -Z build-std to compile core/alloc for the custom target,
    and links against the SimpleOS sysroot.
    """
    if config.skip_seed:
        print "[seed] Skipping Rust seed build (using {config.seed_output_path()})"
        return path_exists(config.seed_output_path())

    val output = config.seed_output_path()
    print "[seed] Cross-compiling Rust seed for {config.target}..."
    print "[seed] Output: {output}"

    # Ensure output directory
    val output_dir = parent_dir(output)
    if output_dir != nil:
        if not ensure_dir(output_dir):
            print "[seed] ERROR: could not create output directory"
            return false

    # Build target spec path
    val target_spec = "src/os/toolchain/rust/{rust_target_spec_name(config.target)}.json"
    if not path_exists(target_spec):
        # Fallback: use the triple directly and hope rustc knows it
        print "[seed] WARNING: target spec {target_spec} not found, using triple directly"
    val cargo_target_dir = "{config.build_dir}/{target_selector_name(config.target)}/cargo-targets"
    if not ensure_dir(cargo_target_dir):
        print "[seed] ERROR: could not create cargo target-spec directory"
        return false
    val cargo_target_alias = rust_cargo_target_alias(config.target)
    val cargo_target_spec = "{cargo_target_dir}/{cargo_target_alias}.json"
    fs.copy(target_spec, cargo_target_spec)

    # Linker flags for SimpleOS -- resolve sysroot via effective_sysroot()
    # so that SIMPLE_SYSROOT / in-guest /usr/sysroot overrides are honored.
    val sysroot = effective_sysroot(config_sysroot: config.sysroot_dir, target: config.target)
    val linker_flags = [
        "-nostdlib",
        "-ffreestanding",
        "-static",
        "-T", "{sysroot}/share/simpleos/simpleos.ld",
        "-L", "{sysroot}/lib",
        "-lsimpleos_c",
        "{sysroot}/lib/crt0.o",
    ]
    val link_args = linker_flags.join(" -C link-arg=")

    # Set RUSTFLAGS for cross-linking. Use repeated `link-arg` flags so cargo
    # does not split linker arguments into rustc options.
    val rustflags = "-C linker=clang -C link-arg={link_args}"

    # Cargo command. Keep the working directory at the repository root so the
    # target spec and sysroot paths remain valid.
    val cargo_cmd =
        "RUSTFLAGS=\"{rustflags}\" " +
        "cargo +nightly build --manifest-path {RUST_SEED_DIR}/Cargo.toml --profile bootstrap " +
        "-p simple-driver -p simple-native-all --features driver-compat " +
        "--target {cargo_target_spec} " +
        "-Z build-std=core,alloc"

    if config.verbose:
        print "[seed] Command: {cargo_cmd}"

    val result = process.run("sh", ["-c", cargo_cmd])
    if result.exit_code != 0:
        print "[seed] Cross-compilation failed:"
        if result.stderr.len() > 0:
            print result.stderr
        return false

    # Copy binary to output location
    val cargo_output = "{RUST_SEED_DIR}/target/{cargo_target_alias}/bootstrap/simple"
    if not path_exists(cargo_output):
        # Try with the spec file name
        val base = base_name(target_spec).replace(".json", "")
        val alt_path = "{RUST_SEED_DIR}/target/{base}/bootstrap/simple"
        if path_exists(alt_path):
            fs.copy(alt_path, output)
            print "[seed] Cross-compiled seed ready at {output}"
            return true
        print "[seed] ERROR: Could not find cargo output binary"
        return false

    fs.copy(cargo_output, output)
    print "[seed] Cross-compiled seed ready at {output}"
    true

# ============================================================================
# Build Stages
# ============================================================================

fn build_stage_cross_with_retry(config: CrossConfig, stage: i64, compiler: text) -> bool:
    """Retry wrapper around `build_stage_cross`.

    Cross-link invocations can fail transiently (filesystem races on tmpfs,
    cargo/rustc lock contention under `-j`, NFS hiccups). We retry up to
    `CROSS_LINK_MAX_ATTEMPTS` times, logging the attempt number so a human
    can tell a retry from a fresh build.
    """
    var attempt = 1
    while attempt <= CROSS_LINK_MAX_ATTEMPTS:
        if attempt > 1:
            print "[stage {stage}] Retrying cross-link (attempt {attempt}/{CROSS_LINK_MAX_ATTEMPTS})"
        if build_stage_cross(config, stage, compiler):
            return true
        attempt = attempt + 1
    print "[stage {stage}] FAILED after {CROSS_LINK_MAX_ATTEMPTS} attempts"
    false
