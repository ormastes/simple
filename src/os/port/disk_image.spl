# SimpleOS FAT32 disk-image builder — IF-06 + IF-07 / Wave-4a.
#
# Produces a minimal but mountable FAT32 raw disk image:
#   BPB (sector 0), FSInfo (sector 1), FAT1 (sectors 32-159),
#   FAT2 (sectors 160-287), root dir (cluster 2 / sector 288),
#   payload data (cluster 3+ / sector 289+).
#
# Wave-4a: single payload file, 8.3 name, no LFN, no subdirectories.

# IF-13 wave-4d: write structural bytes via rt_file_write_bytes, then ask the
# kernel to zero-extend to full image size via rt_file_truncate. Building a
# 32 MiB byte buffer in the interpreter is intractable (>30s for 1 MiB).
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_file_truncate(path: text, size: u64) -> bool

# -- Public types -----------------------------------------------------------

struct PayloadEntry:
    """One file to embed in the image."""
    path: text       # 8.3 name used as the FAT directory entry name
    data: [u8]       # Raw file contents

struct DiskImageConfig:
    """Builder configuration for one disk image."""
    size_mb: u64
    payloads: [PayloadEntry]

# -- Internal LE helpers ----------------------------------------------------

fn _push_u8(buf: [u8], v: u8):
    buf.push(v)

fn _push_u16(buf: [u8], v: u32):
    buf.push((v & 0xFF) as u8)
    buf.push(((v >> 8) & 0xFF) as u8)

fn _push_u32(buf: [u8], v: u32):
    buf.push((v & 0xFF) as u8)
    buf.push(((v >> 8) & 0xFF) as u8)
    buf.push(((v >> 16) & 0xFF) as u8)
    buf.push(((v >> 24) & 0xFF) as u8)

fn _push_zeros(buf: [u8], count: u64):
    var i: u64 = 0u64
    while i < count:
        buf.push(0u8)
        i = i + 1u64

fn _push_str11(buf: [u8], s: text):
    """Push exactly 11 ASCII bytes, space-padded (8.3 FAT name)."""
    var i: u64 = 0u64
    while i < 11u64:
        if i < s.length:
            buf.push(s[i] as u8)
        else:
            buf.push(0x20u8)
        i = i + 1u64

# -- Sector builders --------------------------------------------------------

fn _build_bpb(buf: [u8], total_sectors: u32, fat_size: u32):
    """Write 512-byte BPB (sector 0)."""
    # Jump boot (3 bytes)
    buf.push(0xEBu8)
    buf.push(0x58u8)
    buf.push(0x90u8)
    # OEM name (8 bytes)
    _push_str11(buf, "SIMPLEOS")
    buf.push(0x20u8)
    buf.push(0x20u8)
    buf.push(0x20u8)
    # BPB fields
    _push_u16(buf, 512u32)       # bytes_per_sector
    _push_u8(buf, 1u8)           # sectors_per_cluster
    _push_u16(buf, 32u32)        # reserved_sectors
    _push_u8(buf, 2u8)           # num_fats
    _push_u16(buf, 0u32)         # root_entry_count (0 = FAT32)
    _push_u16(buf, 0u32)         # total_sectors_16 (0 = use 32-bit field)
    _push_u8(buf, 0xF8u8)        # media type (fixed disk)
    _push_u16(buf, 0u32)         # fat_size_16 (0 = FAT32)
    _push_u16(buf, 63u32)        # sectors_per_track
    _push_u16(buf, 255u32)       # num_heads
    _push_u32(buf, 0u32)         # hidden_sectors
    _push_u32(buf, total_sectors) # total_sectors_32
    # FAT32 extended BPB
    _push_u32(buf, fat_size)     # fat_size_32
    _push_u16(buf, 0u32)         # ext_flags
    _push_u16(buf, 0u32)         # fs_version
    _push_u32(buf, 2u32)         # root_cluster
    _push_u16(buf, 1u32)         # fs_info sector
    _push_u16(buf, 6u32)         # backup_boot_sector
    _push_zeros(buf, 12u64)      # reserved
    _push_u8(buf, 0x80u8)        # drive_number
    _push_u8(buf, 0u8)           # reserved1
    _push_u8(buf, 0x29u8)        # boot_sig
    _push_u32(buf, 0x12345678u32) # vol_id
    _push_str11(buf, "SIMPLEOS   ") # vol_label (11 chars)
    buf.push(0x46u8)             # "FAT32   "
    buf.push(0x41u8)
    buf.push(0x54u8)
    buf.push(0x33u8)
    buf.push(0x32u8)
    buf.push(0x20u8)
    buf.push(0x20u8)
    buf.push(0x20u8)
    # Boot code placeholder (420 bytes)
    _push_zeros(buf, 420u64)
    # Signature
    buf.push(0x55u8)
    buf.push(0xAAu8)

fn _build_fsinfo(buf: [u8]):
    """Write 512-byte FSInfo (sector 1)."""
    _push_u32(buf, 0x41615252u32)  # lead_sig
    _push_zeros(buf, 480u64)
    _push_u32(buf, 0x61417272u32)  # struct_sig
    _push_u32(buf, 0xFFFFFFFFu32)  # free_count (unknown)
    _push_u32(buf, 0xFFFFFFFFu32)  # next_free (unknown)
    _push_zeros(buf, 12u64)
    buf.push(0x00u8)
    buf.push(0x00u8)
    buf.push(0x55u8)
    buf.push(0xAAu8)

fn _build_fat(buf: [u8], fat_sectors: u64, payload_clusters: u64):
    """Build one FAT table."""
    # Entry 0: media byte
    _push_u32(buf, 0x0FFFFFF8u32)
    # Entry 1: EOC
    _push_u32(buf, 0x0FFFFFFFu32)
    # Entry 2: root dir cluster (EOC)
    _push_u32(buf, 0x0FFFFFFFu32)
    # Entries 3..3+payload_clusters-1: chain, last = EOC
    var c: u64 = 0u64
    while c < payload_clusters:
        if c + 1u64 < payload_clusters:
            _push_u32(buf, (4u64 + c) as u32)
        else:
            _push_u32(buf, 0x0FFFFFFFu32)
        c = c + 1u64
    # Pad to fat_sectors * 512 bytes
    val used: u64 = (3u64 + payload_clusters) * 4u64
    val total: u64 = fat_sectors * 512u64
    if total > used:
        _push_zeros(buf, total - used)

fn _build_dir_entry(buf: [u8], name83: text, first_cluster: u32, file_size: u32):
    """Write one 32-byte FAT directory entry."""
    _push_str11(buf, name83)     # name (11 bytes)
    _push_u8(buf, 0x20u8)        # attr: archive
    _push_u8(buf, 0u8)           # NTRes
    _push_u8(buf, 0u8)           # CrtTimeTenth
    _push_u16(buf, 0u32)         # CrtTime
    _push_u16(buf, 0u32)         # CrtDate
    _push_u16(buf, 0u32)         # LstAccDate
    _push_u16(buf, (first_cluster >> 16) & 0xFFFFu32)  # FstClusHI
    _push_u16(buf, 0u32)         # WrtTime
    _push_u16(buf, 0u32)         # WrtDate
    _push_u16(buf, first_cluster & 0xFFFFu32)           # FstClusLO
    _push_u32(buf, file_size)    # FileSize

# -- Public API -------------------------------------------------------------

fn build(cfg: DiskImageConfig, out_path: text) -> Result<(), text>:
    """Build a minimal FAT32 disk image at out_path.

    Wave-4a: single payload supported; multi-payload is TODO(wave-4b).
    """
    if cfg.size_mb == 0u64:
        return Err("disk_image.build: size_mb must be > 0")
    if cfg.payloads.length == 0:
        return Err("disk_image.build: at least one payload required")

    val total_sectors: u32 = (cfg.size_mb * 2048u64) as u32
    val fat_sectors: u64 = 128u64   # 64 KiB per FAT, covers 16K clusters
    val data_start: u64 = 32u64 + fat_sectors * 2u64  # sector 288

    # Use first payload only (wave-4a)
    val p = cfg.payloads[0]
    val file_size: u32 = p.data.length as u32
    val bytes_per_cluster: u64 = 512u64
    var payload_clusters: u64 = p.data.length as u64 / bytes_per_cluster
    if (p.data.length as u64) % bytes_per_cluster > 0u64:
        payload_clusters = payload_clusters + 1u64
    if payload_clusters == 0u64:
        payload_clusters = 1u64

    var img: [u8] = []

    # Sector 0: BPB
    _build_bpb(img, total_sectors: total_sectors, fat_size: fat_sectors as u32)

    # Sector 1: FSInfo
    _build_fsinfo(img)

    # Sectors 2-31: reserved (zeros)
    _push_zeros(img, 30u64 * 512u64)

    # Sectors 32-159: FAT1
    _build_fat(img, fat_sectors: fat_sectors, payload_clusters: payload_clusters)

    # Sectors 160-287: FAT2 (copy)
    _build_fat(img, fat_sectors: fat_sectors, payload_clusters: payload_clusters)

    # Sector 288 (cluster 2): root directory — one entry + zeros to fill cluster
    _build_dir_entry(img, p.path, first_cluster: 3u32, file_size: file_size)
    _push_zeros(img, 512u64 - 32u64)   # rest of cluster

    # Cluster 3+: payload data, padded to cluster boundary
    var bi: u64 = 0u64
    while bi < p.data.length as u64:
        img.push(p.data[bi])
        bi = bi + 1u64
    val padded: u64 = payload_clusters * bytes_per_cluster
    val written: u64 = p.data.length as u64
    if padded > written:
        _push_zeros(img, padded - written)

    # IF-13 wave-4d: write only the structural prefix (~150 KiB), then let
    # the kernel zero-extend to full image size via ftruncate. This avoids
    # building a 32 MiB byte array in the interpreter (intractable: >30s/MiB).
    val img_bytes: u64 = cfg.size_mb * 1024u64 * 1024u64
    if not rt_file_write_bytes(out_path, img):
        return Err("disk_image.build: write failed: " + out_path)
    if not rt_file_truncate(out_path, img_bytes):
        return Err("disk_image.build: truncate failed: " + out_path)
    Ok(())
