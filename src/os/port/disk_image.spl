# SimpleOS FAT32 disk-image builder — IF-06 + IF-07 / Wave-4a.
#
# Produces a minimal but mountable FAT32 raw disk image:
#   BPB (sector 0), FSInfo (sector 1), reserved (sectors 2-31),
#   FAT1 (sector 32, `fat_sectors` long), FAT2 (immediately after FAT1,
#   same length), root dir (cluster 2, immediately after FAT2),
#   payload data (cluster 3+, immediately after root dir).
#   `fat_sectors` is sized dynamically from the total data-cluster count
#   (see `build()` "FAT sizing" below) -- it is NOT a fixed constant, so
#   compute sector offsets from `fat_size_32` in the BPB rather than
#   hardcoding sector 288/289 as earlier revisions of this file did.
#
# Wave-4a began with one 8.3 payload. Nested payloads now retain an 8.3 alias
# and add ASCII VFAT long-name slots only when a component needs them.
#
# clang_as_general_fs_exec (Phase 1, task 1, 2026-07-07): added real nested
# FAT32 subdirectory support (`DiskImageConfig.nested_payloads`) so a file
# like clang_static can live at a general path (e.g. /usr/bin/clang) instead
# of only a flat-root 8.3 slot. Verified via a `bin/simple run` probe: a
# 1 MiB image with one nested payload builds correctly in ~2s (19456 bytes,
# byte-matches the hand-computed structural layout) and every added
# subdirectory/file resolves through the *unmodified*, general-purpose
# `Fat32Core.resolve_path` (std.fs_driver.fat32_core) -- no path-specific
# special-casing. Do not reintroduce a blanket
# "nested_payloads requires mkfs.fat+mcopy" guard without re-measuring: the
# earlier timeout that motivated such a guard came from the *pre-existing*
# fat_sectors=128 (64 KiB) FAT zero-padding cost on large images, not from
# nested-directory construction, which adds only a few hundred bytes.

# IF-13 wave-4d: write structural bytes via rt_file_write_bytes, then ask the
# kernel to zero-extend to full image size via rt_file_truncate. Building a
# 32 MiB byte buffer in the interpreter is intractable (>30s for 1 MiB).
extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_file_truncate(path: text, size: u64) -> bool

# -- Public types -----------------------------------------------------------

struct PayloadEntry:
    """One file to embed in the image."""
    path: text       # Preferred 8.3 alias (flat-root name or nested LFN alias)
    data: [u8]       # Raw file contents
    guest_path: text # Optional guest VFS path (e.g. /sys/apps/simple).
                     # Empty string means flat-root placement.

struct DiskImageConfig:
    """Builder configuration for one disk image."""
    size_mb: u64
    payloads: [PayloadEntry]
    # Real FAT32 subdirectory placements (guest_path required, e.g.
    # "/usr/bin/clang"). Kept separate from `payloads` so existing flat-root
    # callers are byte-for-byte unaffected. Defaults to `[]` so callers that
    # only need flat-root payloads can omit this field entirely -- see
    # doc/08_tracking/bug/disk_image_fat32_builder_defects.md #1: omitting a
    # non-defaulted `[T]` struct field silently binds it to `nil` at runtime
    # (a compiler struct-literal-init defect, not caught at compile time),
    # and `for x in nil:` / `nil.length` then blow up downstream. Working
    # around it here with a field default avoids relying on a fix to that
    # compiler defect.
    nested_payloads: [PayloadEntry] = []

# -- Internal LE helpers ----------------------------------------------------
#
# NOTE: Simple arrays are value types -- passed BY COPY to functions. A
# helper that takes `buf: [u8]` and calls `buf.push(...)` only mutates its
# own local copy; the caller's array is untouched (see project memory
# feedback_arrays_value_types.md, independently confirmed here via a minimal
# `bin/simple run` repro). Every helper below therefore returns the updated
# array and every call site reassigns: `buf = _push_u8(buf, v)`.

fn _push_u8(buf: [u8], v: u8) -> [u8]:
    buf.push(v)
    buf

fn _push_u16(buf: [u8], v: u32) -> [u8]:
    buf.push((v & 0xFF) as u8)
    buf.push(((v >> 8) & 0xFF) as u8)
    buf

fn _push_u32(buf: [u8], v: u32) -> [u8]:
    buf.push((v & 0xFF) as u8)
    buf.push(((v >> 8) & 0xFF) as u8)
    buf.push(((v >> 16) & 0xFF) as u8)
    buf.push(((v >> 24) & 0xFF) as u8)
    buf

fn _push_zeros(buf: [u8], count: u64) -> [u8]:
    var i: u64 = 0u64
    while i < count:
        buf.push(0u8)
        i = i + 1u64
    buf

fn _push_str8(buf: [u8], s: text) -> [u8]:
    """Push exactly 8 ASCII bytes, space-padded (BS_OEMName field)."""
    var i: u64 = 0u64
    while i < 8u64:
        if i < s.length:
            buf.push(s[i] as u8)
        else:
            buf.push(0x20u8)
        i = i + 1u64
    buf

fn _push_str11(buf: [u8], s: text) -> [u8]:
    """Push exactly 11 ASCII bytes, space-padded (8.3 FAT name / vol_label)."""
    var i: u64 = 0u64
    while i < 11u64:
        if i < s.length:
            buf.push(s[i] as u8)
        else:
            buf.push(0x20u8)
        i = i + 1u64
    buf

fn _pad_trunc(s: text, width: u64) -> text:
    """Truncate/space-pad `s` to exactly `width` chars (helper for 8.3 names)."""
    var result: text = ""
    var i: u64 = 0u64
    while i < width:
        if i < s.length:
            result = result + s.substring(i, i + 1u64)
        else:
            result = result + " "
        i = i + 1u64
    result

fn _to_8_3_name(name: text) -> text:
    """Convert a filename like "FSEXECBG.ELF" into an 11-char FAT 8.3 name
    "FSEXECBGELF" (dot dropped, base padded/truncated to 8 chars, extension
    padded/truncated to 3 chars, uppercased). Matches the C reader's
    `_fat32_make_8_3_name` in
    examples/09_embedded/simple_os/arch/x86_64/boot/baremetal_stubs.c, which
    takes the LAST '.' in the name as the extension separator -- see
    doc/08_tracking/bug/disk_image_fat32_builder_defects.md #3 (dirents were
    previously stored verbatim-with-dot, e.g. "FSEXECBG.EL", so the C reader's
    8.3-normalized lookup never matched)."""
    var dot_idx: i64 = -1
    var i: u64 = 0u64
    while i < name.length:
        if (name[i] as u8) == 0x2Eu8:
            dot_idx = i as i64
        i = i + 1u64
    var base: text = name
    var ext: text = ""
    if dot_idx >= 0:
        base = name.substring(0u64, dot_idx as u64)
        ext = name.substring((dot_idx as u64) + 1u64, name.length)
    _pad_trunc(base.upper(), 8u64) + _pad_trunc(ext.upper(), 3u64)

fn _fat_short_char_valid(b: u8) -> bool:
    (b >= 0x41u8 and b <= 0x5Au8) or
    (b >= 0x61u8 and b <= 0x7Au8) or
    (b >= 0x30u8 and b <= 0x39u8) or
    b == 0x24u8 or b == 0x25u8 or b == 0x27u8 or b == 0x2Du8 or
    b == 0x5Fu8 or b == 0x40u8 or b == 0x7Eu8 or b == 0x60u8 or
    b == 0x21u8 or b == 0x28u8 or b == 0x29u8 or b == 0x7Bu8 or
    b == 0x7Du8 or b == 0x5Eu8 or b == 0x23u8 or b == 0x26u8

fn _vfat_ascii_name_valid(name: text) -> bool:
    if name.length == 0u64 or name.length > 255u64 or name == "." or name == "..":
        return false
    if (name[name.length - 1u64] as u8) == 0x20u8 or (name[name.length - 1u64] as u8) == 0x2Eu8:
        return false
    var i: u64 = 0u64
    while i < name.length:
        val b = name[i] as u8
        if b < 0x20u8 or b > 0x7Eu8 or b == 0x22u8 or b == 0x2Au8 or
           b == 0x2Fu8 or b == 0x3Au8 or b == 0x3Cu8 or b == 0x3Eu8 or
           b == 0x3Fu8 or b == 0x5Cu8 or b == 0x7Cu8:
            return false
        i = i + 1u64
    true

fn _fat_short_name_lossless(name: text) -> bool:
    var dot_idx: i64 = -1
    var dot_count: u64 = 0u64
    var i: u64 = 0u64
    while i < name.length:
        if (name[i] as u8) == 0x2Eu8:
            dot_idx = i as i64
            dot_count = dot_count + 1u64
        i = i + 1u64
    if dot_count > 1u64:
        return false
    var base_len = name.length
    var ext_start = name.length
    if dot_idx >= 0:
        base_len = dot_idx as u64
        ext_start = base_len + 1u64
    val ext_len = name.length - ext_start
    if base_len == 0u64 or base_len > 8u64 or ext_len > 3u64:
        return false
    i = 0u64
    while i < name.length:
        val b = name[i] as u8
        if b != 0x2Eu8 and not _fat_short_char_valid(b):
            return false
        i = i + 1u64
    true

fn _fat_raw_name83_valid(name: text) -> bool:
    if name.length != 11u64 or (name[0] as u8) == 0x20u8:
        return false
    var i: u64 = 0u64
    while i < 11u64:
        val b = name[i] as u8
        if b != 0x20u8 and not _fat_short_char_valid(b):
            return false
        i = i + 1u64
    true

fn _take_text(value: text, width: u64) -> text:
    var out = ""
    var i: u64 = 0u64
    while i < value.length and i < width:
        out = out + value.substring(i, i + 1u64)
        i = i + 1u64
    out

fn _fat_short_alias_candidate(name: text, ordinal: u64) -> text:
    var dot_idx: i64 = -1
    var i: u64 = 0u64
    while i < name.length:
        if (name[i] as u8) == 0x2Eu8:
            dot_idx = i as i64
        i = i + 1u64
    var base = name
    var ext = ""
    if dot_idx >= 0:
        base = name.substring(0u64, dot_idx as u64)
        ext = name.substring((dot_idx as u64) + 1u64, name.length)
    var clean_base = ""
    val upper_base = base.upper()
    i = 0u64
    while i < upper_base.length:
        if _fat_short_char_valid(upper_base[i] as u8):
            clean_base = clean_base + upper_base.substring(i, i + 1u64)
        else:
            clean_base = clean_base + "_"
        i = i + 1u64
    if clean_base == "":
        clean_base = "_"
    var clean_ext = ""
    val upper_ext = ext.upper()
    i = 0u64
    while i < upper_ext.length:
        if _fat_short_char_valid(upper_ext[i] as u8):
            clean_ext = clean_ext + upper_ext.substring(i, i + 1u64)
        else:
            clean_ext = clean_ext + "_"
        i = i + 1u64
    val suffix = "~" + ordinal.to_text()
    var prefix_width: u64 = 1u64
    if suffix.length < 8u64:
        prefix_width = 8u64 - suffix.length
    val short_base = _take_text(clean_base, prefix_width) + suffix
    _pad_trunc(short_base, 8u64) + _pad_trunc(clean_ext, 3u64)

fn _fat_short_alias_used(alias: text, parent: i64,
                         flat_names: [text],
                         dir_names: [text], dir_parents: [i64],
                         leaf_names: [text], leaf_parents: [i64]) -> bool:
    var i: u64 = 0u64
    if parent == -1:
        while i < flat_names.length:
            if flat_names[i] == alias:
                return true
            i = i + 1u64
    i = 0u64
    while i < dir_names.length:
        if dir_parents[i] == parent and dir_names[i] == alias:
            return true
        i = i + 1u64
    i = 0u64
    while i < leaf_names.length:
        if leaf_parents[i] == parent and leaf_names[i] == alias:
            return true
        i = i + 1u64
    false

fn _fat_short_name_checksum(name83: text) -> u8:
    var sum: u32 = 0u32
    var i: u64 = 0u64
    while i < 11u64:
        val carry: u32 = if (sum & 1u32) != 0u32: 0x80u32 else: 0u32
        sum = (carry + (sum >> 1) + (name83[i] as u32)) & 0xFFu32
        i = i + 1u64
    sum as u8

fn _vfat_lfn_slot_count(name: text) -> u64:
    if name == "": return 0u64
    (name.length + 12u64) / 13u64

fn _named_dir_entry_slot_count(long_name: text) -> u64:
    1u64 + _vfat_lfn_slot_count(long_name)

fn _push_vfat_name_units(buf: [u8], name: text, start: u64, count: u64) -> [u8]:
    var i: u64 = 0u64
    while i < count:
        val index = start + i
        if index < name.length:
            buf = _push_u16(buf, (name[index] as u8) as u32)
        else:
            if index == name.length:
                buf = _push_u16(buf, 0u32)
            else:
                buf = _push_u16(buf, 0xFFFFu32)
        i = i + 1u64
    buf

fn _build_vfat_lfn_slot(buf: [u8], name: text, ordinal: u64, slot_count: u64, checksum: u8) -> [u8]:
    var sequence = ordinal as u8
    if ordinal == slot_count:
        sequence = sequence | 0x40u8
    buf = _push_u8(buf, sequence)
    val start = (ordinal - 1u64) * 13u64
    buf = _push_vfat_name_units(buf, name, start, 5u64)
    buf = _push_u8(buf, 0x0Fu8)
    buf = _push_u8(buf, 0u8)
    buf = _push_u8(buf, checksum)
    buf = _push_vfat_name_units(buf, name, start + 5u64, 6u64)
    buf = _push_u16(buf, 0u32)
    _push_vfat_name_units(buf, name, start + 11u64, 2u64)

# -- Nested-directory helpers (real FAT32 subdirs for cfg.nested_payloads) --

fn _split_guest_path(guest_path: text) -> [text]:
    """Split "/usr/bin/clang" into ["usr", "bin", "clang"], dropping empty segments."""
    var parts: [text] = []
    var current: text = ""
    var i: u64 = 0u64
    while i < guest_path.length:
        val b: u8 = guest_path[i] as u8
        if b == 0x2Fu8:
            if current.length > 0u64:
                parts.push(current)
                current = ""
        else:
            current = current + guest_path.substring(i, i + 1u64)
        i = i + 1u64
    if current.length > 0u64:
        parts.push(current)
    parts

# -- Sector builders --------------------------------------------------------

fn _build_bpb(buf: [u8], total_sectors: u32, fat_size: u32) -> [u8]:
    """Write 512-byte BPB (sector 0)."""
    # Jump boot (3 bytes)
    buf.push(0xEBu8)
    buf.push(0x58u8)
    buf.push(0x90u8)
    # OEM name (8 bytes — BS_OEMName, bytes 3-10)
    buf = _push_str8(buf, "SIMPLEOS")
    # BPB fields
    buf = _push_u16(buf, 512u32)       # bytes_per_sector
    buf = _push_u8(buf, 1u8)           # sectors_per_cluster
    buf = _push_u16(buf, 32u32)        # reserved_sectors
    buf = _push_u8(buf, 2u8)           # num_fats
    buf = _push_u16(buf, 0u32)         # root_entry_count (0 = FAT32)
    buf = _push_u16(buf, 0u32)         # total_sectors_16 (0 = use 32-bit field)
    buf = _push_u8(buf, 0xF8u8)        # media type (fixed disk)
    buf = _push_u16(buf, 0u32)         # fat_size_16 (0 = FAT32)
    buf = _push_u16(buf, 63u32)        # sectors_per_track
    buf = _push_u16(buf, 255u32)       # num_heads
    buf = _push_u32(buf, 0u32)         # hidden_sectors
    buf = _push_u32(buf, total_sectors) # total_sectors_32
    # FAT32 extended BPB
    buf = _push_u32(buf, fat_size)     # fat_size_32
    buf = _push_u16(buf, 0u32)         # ext_flags
    buf = _push_u16(buf, 0u32)         # fs_version
    buf = _push_u32(buf, 2u32)         # root_cluster
    buf = _push_u16(buf, 1u32)         # fs_info sector
    buf = _push_u16(buf, 6u32)         # backup_boot_sector
    buf = _push_zeros(buf, 12u64)      # reserved
    buf = _push_u8(buf, 0x80u8)        # drive_number
    buf = _push_u8(buf, 0u8)           # reserved1
    buf = _push_u8(buf, 0x29u8)        # boot_sig
    buf = _push_u32(buf, 0x12345678u32) # vol_id
    buf = _push_str11(buf, "SIMPLEOS   ") # vol_label (11 chars)
    buf.push(0x46u8)             # "FAT32   "
    buf.push(0x41u8)
    buf.push(0x54u8)
    buf.push(0x33u8)
    buf.push(0x32u8)
    buf.push(0x20u8)
    buf.push(0x20u8)
    buf.push(0x20u8)
    # Boot code placeholder (420 bytes)
    buf = _push_zeros(buf, 420u64)
    # Signature
    buf.push(0x55u8)
    buf.push(0xAAu8)
    buf

fn _build_fsinfo(buf: [u8]) -> [u8]:
    """Write 512-byte FSInfo (sector 1)."""
    buf = _push_u32(buf, 0x41615252u32)  # lead_sig
    buf = _push_zeros(buf, 480u64)
    buf = _push_u32(buf, 0x61417272u32)  # struct_sig
    buf = _push_u32(buf, 0xFFFFFFFFu32)  # free_count (unknown)
    buf = _push_u32(buf, 0xFFFFFFFFu32)  # next_free (unknown)
    buf = _push_zeros(buf, 12u64)
    buf.push(0x00u8)
    buf.push(0x00u8)
    buf.push(0x55u8)
    buf.push(0xAAu8)
    buf

fn _payload_cluster_count(data_len: u64, bytes_per_cluster: u64) -> u64:
    """Compute the number of clusters needed for a payload of data_len bytes."""
    var n: u64 = data_len / bytes_per_cluster
    if data_len % bytes_per_cluster > 0u64:
        n = n + 1u64
    if n == 0u64:
        n = 1u64
    n

fn _build_fat(buf: [u8], fat_sectors: u64, cluster_counts: [u64]) -> [u8]:
    """Build one FAT table for multiple payload files.

    cluster_counts[i] is the number of clusters for payload i.
    Clusters are laid out contiguously: cluster 3 = start of payload 0,
    cluster 3+N0 = start of payload 1, etc.
    """
    # Entry 0: media byte
    buf = _push_u32(buf, 0x0FFFFFF8u32)
    # Entry 1: EOC
    buf = _push_u32(buf, 0x0FFFFFFFu32)
    # Entry 2: root dir cluster (EOC)
    buf = _push_u32(buf, 0x0FFFFFFFu32)

    var next_cluster: u64 = 3u64
    for cnt in cluster_counts:
        var c: u64 = 0u64
        while c < cnt:
            if c + 1u64 < cnt:
                # Points to next cluster in this file's chain
                buf = _push_u32(buf, (next_cluster + 1u64) as u32)
            else:
                # Last cluster: EOC
                buf = _push_u32(buf, 0x0FFFFFFFu32)
            next_cluster = next_cluster + 1u64
            c = c + 1u64

    # Pad to fat_sectors * 512 bytes
    val total_clusters: u64 = next_cluster - 3u64
    val used: u64 = (3u64 + total_clusters) * 4u64
    val total: u64 = fat_sectors * 512u64
    if total > used:
        buf = _push_zeros(buf, total - used)
    buf

fn _build_dir_entry_attr(buf: [u8], name83: text, first_cluster: u32, file_size: u32, attr: u8) -> [u8]:
    """Write one 32-byte FAT directory entry with an explicit attribute byte."""
    buf = _push_str11(buf, name83)     # name (11 bytes)
    buf = _push_u8(buf, attr)          # attr: 0x20 archive (file) / 0x10 directory
    buf = _push_u8(buf, 0u8)           # NTRes
    buf = _push_u8(buf, 0u8)           # CrtTimeTenth
    buf = _push_u16(buf, 0u32)         # CrtTime
    buf = _push_u16(buf, 0u32)         # CrtDate
    buf = _push_u16(buf, 0u32)         # LstAccDate
    buf = _push_u16(buf, (first_cluster >> 16) & 0xFFFFu32)  # FstClusHI
    buf = _push_u16(buf, 0u32)         # WrtTime
    buf = _push_u16(buf, 0u32)         # WrtDate
    buf = _push_u16(buf, first_cluster & 0xFFFFu32)           # FstClusLO
    buf = _push_u32(buf, file_size)    # FileSize
    buf

fn _build_dir_entry(buf: [u8], name83: text, first_cluster: u32, file_size: u32) -> [u8]:
    """Write one 32-byte FAT directory entry for a file (attr: archive)."""
    _build_dir_entry_attr(buf, name83, first_cluster, file_size, 0x20u8)

fn _build_named_dir_entry_attr(buf: [u8], short_name83: text, long_name: text,
                               first_cluster: u32, file_size: u32, attr: u8) -> [u8]:
    val slot_count = _vfat_lfn_slot_count(long_name)
    if slot_count > 0u64:
        val checksum = _fat_short_name_checksum(short_name83)
        var ordinal = slot_count
        while ordinal > 0u64:
            buf = _build_vfat_lfn_slot(buf, long_name, ordinal, slot_count, checksum)
            ordinal = ordinal - 1u64
    _build_dir_entry_attr(buf, short_name83, first_cluster, file_size, attr)

fn _build_named_dir_entry(buf: [u8], short_name83: text, long_name: text,
                          first_cluster: u32, file_size: u32) -> [u8]:
    _build_named_dir_entry_attr(buf, short_name83, long_name, first_cluster, file_size, 0x20u8)

# -- Public API -------------------------------------------------------------

fn build(cfg: DiskImageConfig, out_path: text) -> Result<(), text>:
    """Build a minimal FAT32 disk image at out_path.

    Supports multiple flat-root payload files (wave-4b, `cfg.payloads`) --
    each gets its own FAT cluster chain and a directory entry in the root
    directory, exactly as before (byte-identical when `nested_payloads` is
    empty). It also supports a small set of real nested-directory placements
    (`cfg.nested_payloads`): each entry's `guest_path` (e.g. "/usr/bin/clang")
    is split into directory components + a leaf filename. Components that do
    not fit 8.3 receive VFAT long-name slots plus a unique short alias;
    directory nodes are shared across payloads with the same parent path.
    """
    if cfg.size_mb == 0u64:
        return Err("disk_image.build: size_mb must be > 0")
    if cfg.payloads.length == 0 and cfg.nested_payloads.length == 0:
        return Err("disk_image.build: at least one payload required")

    val total_sectors: u32 = (cfg.size_mb * 2048u64) as u32
    val bytes_per_cluster: u64 = 512u64

    # --- Cluster layout order: [flat payloads] [nested file data] [dir nodes] ---
    var cluster_counts: [u64] = []
    var flat_name83: [text] = []
    for p in cfg.payloads:
        cluster_counts.push(_payload_cluster_count(p.data.length as u64, bytes_per_cluster))
        flat_name83.push(_to_8_3_name(p.path))

    # Directory-node tracking arrays. Built up directly in this function's own
    # scope (never passed to a helper to mutate) since arrays are copied
    # across function-call boundaries in Simple -- see the note above
    # _push_u8. `dir_keys[i]` uniquely identifies node i as "<parent_idx>/<NAME>".
    var dir_keys: [text] = []
    var dir_name83: [text] = []
    var dir_long_name: [text] = []
    var dir_parent: [i64] = []
    var nested_leaf_name83: [text] = []
    var nested_leaf_long_name: [text] = []
    var nested_leaf_keys: [text] = []
    var nested_parent_idx: [i64] = []

    for np in cfg.nested_payloads:
        val comps = _split_guest_path(np.guest_path)
        if comps.length == 0u64:
            return Err("disk_image.build: nested payload missing guest_path: " + np.path)
        var parent_idx: i64 = -1
        var ci: u64 = 0u64
        while ci < comps.length - 1u64:
            val component = comps[ci]
            if not _vfat_ascii_name_valid(component):
                return Err("disk_image.build: invalid ASCII VFAT directory component: '" + component + "'")
            val upper = component.upper()
            val key = parent_idx.to_text() + "/" + upper
            # Find-or-create, inlined (see note above): a separate helper
            # taking dir_keys/dir_name83/dir_parent as parameters would only
            # mutate its own local copies and silently drop every insert.
            var found_idx: i64 = -1
            var si: u64 = 0u64
            while si < dir_keys.length:
                if dir_keys[si] == key:
                    found_idx = si as i64
                si = si + 1u64
            if found_idx == -1:
                var leaf_conflict = false
                si = 0u64
                while si < nested_leaf_keys.length:
                    if nested_leaf_keys[si] == key:
                        leaf_conflict = true
                    si = si + 1u64
                if leaf_conflict:
                    return Err("disk_image.build: path is already a file: '" + component + "'")
                var short_name = _to_8_3_name(component)
                var long_name = ""
                if not _fat_short_name_lossless(component) or
                   _fat_short_alias_used(short_name, parent_idx, flat_name83, dir_name83, dir_parent, nested_leaf_name83, nested_parent_idx):
                    long_name = component
                    var ordinal: u64 = 1u64
                    short_name = _fat_short_alias_candidate(component, ordinal)
                    while _fat_short_alias_used(short_name, parent_idx, flat_name83, dir_name83, dir_parent, nested_leaf_name83, nested_parent_idx):
                        ordinal = ordinal + 1u64
                        short_name = _fat_short_alias_candidate(component, ordinal)
                dir_keys.push(key)
                dir_name83.push(short_name)
                dir_long_name.push(long_name)
                dir_parent.push(parent_idx)
                found_idx = (dir_keys.length - 1u64) as i64
            parent_idx = found_idx
            ci = ci + 1u64
        val leaf = comps[comps.length - 1u64]
        if not _vfat_ascii_name_valid(leaf):
            return Err("disk_image.build: invalid ASCII VFAT leaf name: '" + leaf + "'")
        val leaf_key = parent_idx.to_text() + "/" + leaf.upper()
        var li: u64 = 0u64
        while li < dir_keys.length:
            if dir_keys[li] == leaf_key:
                return Err("disk_image.build: path is already a directory: '" + leaf + "'")
            li = li + 1u64
        li = 0u64
        while li < nested_leaf_keys.length:
            if nested_leaf_keys[li] == leaf_key:
                return Err("disk_image.build: duplicate nested payload path: '" + np.guest_path + "'")
            li = li + 1u64
        var leaf_short_name = _to_8_3_name(leaf)
        var leaf_long_name = ""
        if not _fat_short_name_lossless(leaf) or
           _fat_short_alias_used(leaf_short_name, parent_idx, flat_name83, dir_name83, dir_parent, nested_leaf_name83, nested_parent_idx):
            leaf_long_name = leaf
            val preferred_short_name = if _fat_raw_name83_valid(np.path): np.path.upper() else: _to_8_3_name(np.path)
            if np.path != "" and (_fat_short_name_lossless(np.path) or _fat_raw_name83_valid(np.path)) and
               not _fat_short_alias_used(preferred_short_name, parent_idx, flat_name83, dir_name83, dir_parent, nested_leaf_name83, nested_parent_idx):
                leaf_short_name = preferred_short_name
            else:
                var leaf_ordinal: u64 = 1u64
                leaf_short_name = _fat_short_alias_candidate(leaf, leaf_ordinal)
                while _fat_short_alias_used(leaf_short_name, parent_idx, flat_name83, dir_name83, dir_parent, nested_leaf_name83, nested_parent_idx):
                    leaf_ordinal = leaf_ordinal + 1u64
                    leaf_short_name = _fat_short_alias_candidate(leaf, leaf_ordinal)
        nested_leaf_name83.push(leaf_short_name)
        nested_leaf_long_name.push(leaf_long_name)
        nested_leaf_keys.push(leaf_key)
        nested_parent_idx.push(parent_idx)
        cluster_counts.push(_payload_cluster_count(np.data.length as u64, bytes_per_cluster))

    val flat_count: u64 = cfg.payloads.length as u64
    val nested_count: u64 = cfg.nested_payloads.length as u64

    var root_entry_slots = flat_count
    var root_di: u64 = 0u64
    while root_di < dir_keys.length:
        if dir_parent[root_di] == -1:
            root_entry_slots = root_entry_slots + _named_dir_entry_slot_count(dir_long_name[root_di])
        root_di = root_di + 1u64
    var root_ni: u64 = 0u64
    while root_ni < nested_count:
        if nested_parent_idx[root_ni] == -1:
            root_entry_slots = root_entry_slots + _named_dir_entry_slot_count(nested_leaf_long_name[root_ni])
        root_ni = root_ni + 1u64
    if root_entry_slots > 16u64:
        return Err("disk_image.build: root directory needs " + root_entry_slots.to_text() +
            " entries but the fixed root cluster holds 16")

    var di: u64 = 0u64
    while di < dir_keys.length:
        var entry_slots: u64 = 0u64
        var child_di: u64 = 0u64
        while child_di < dir_keys.length:
            if dir_parent[child_di] == (di as i64):
                entry_slots = entry_slots + _named_dir_entry_slot_count(dir_long_name[child_di])
            child_di = child_di + 1u64
        var child_ni: u64 = 0u64
        while child_ni < nested_count:
            if nested_parent_idx[child_ni] == (di as i64):
                entry_slots = entry_slots + _named_dir_entry_slot_count(nested_leaf_long_name[child_ni])
            child_ni = child_ni + 1u64
        var dir_clusters = (entry_slots * 32u64 + bytes_per_cluster - 1u64) / bytes_per_cluster
        if dir_clusters == 0u64:
            dir_clusters = 1u64
        cluster_counts.push(dir_clusters)
        di = di + 1u64

    # First-cluster for every item in cluster_counts, replaying the exact same
    # cumulative rule _build_fat uses internally (data clusters start at 3).
    var first_cluster_all: [u64] = []
    var running: u64 = 3u64
    var fci: u64 = 0u64
    while fci < cluster_counts.length:
        first_cluster_all.push(running)
        running = running + cluster_counts[fci]
        fci = fci + 1u64

    # -- FAT sizing (bug #4): size the FAT to the actual data-cluster count
    # instead of a fixed 128-sector table. `running` is now
    # 3 + total_data_clusters (data clusters start at cluster 3, per
    # _build_fat / first_cluster_all above), so total FAT entries needed =
    # entries 0,1,2 (reserved) + one per data cluster = `running`.
    # A fixed 128-sector FAT (16,384 entries) previously overflowed for any
    # payload set needing more than 16,384-3 clusters (~8.39 MB at 512
    # B/cluster): the cluster chain silently overran FAT1 into FAT2 and then
    # into the root directory. See
    # doc/08_tracking/bug/disk_image_fat32_builder_defects.md #4.
    val total_data_clusters: u64 = running - 3u64
    val fat_entries_needed: u64 = running
    val fat_bytes_needed: u64 = fat_entries_needed * 4u64
    var fat_sectors: u64 = fat_bytes_needed / 512u64
    if fat_bytes_needed % 512u64 > 0u64:
        fat_sectors = fat_sectors + 1u64
    if fat_sectors == 0u64:
        fat_sectors = 1u64

    # Reserved(32) + FAT1 + FAT2 + root-dir(1 cluster/sector) + data clusters
    # must all fit inside the requested image size, or the FAT/root-dir/data
    # regions would overlap. Error out clearly instead of silently truncating.
    val sectors_needed: u64 = 32u64 + fat_sectors * 2u64 + 1u64 + total_data_clusters
    if sectors_needed > total_sectors as u64:
        return Err("disk_image.build: payload data needs " + sectors_needed.to_text() +
            " sectors (" + total_data_clusters.to_text() + " data clusters + " +
            fat_sectors.to_text() + "-sector FAT x2 + reserved/root) but the image is only " +
            cfg.size_mb.to_text() + " MiB (" + (total_sectors as u64).to_text() +
            " sectors); increase size_mb")

    var img: [u8] = []

    # Sector 0: BPB
    img = _build_bpb(img, total_sectors: total_sectors, fat_size: fat_sectors as u32)

    # Sector 1: FSInfo
    img = _build_fsinfo(img)

    # Sectors 2-31: reserved (zeros)
    img = _push_zeros(img, 30u64 * 512u64)

    # FAT1: starts at sector 32, `fat_sectors` sectors long (dynamically sized above)
    img = _build_fat(img, fat_sectors: fat_sectors, cluster_counts: cluster_counts)

    # FAT2: copy, immediately follows FAT1
    img = _build_fat(img, fat_sectors: fat_sectors, cluster_counts: cluster_counts)

    # Root directory (cluster 2), immediately follows FAT2.
    # One entry per flat payload (unchanged), plus one directory entry for each
    # top-level nested directory node, plus one file entry for any nested
    # payload placed directly at root (single-component guest_path, e.g. "/x").
    var pi: u64 = 0u64
    while pi < flat_count:
        val p = cfg.payloads[pi]
        img = _build_dir_entry(img, flat_name83[pi], first_cluster: first_cluster_all[pi] as u32, file_size: p.data.length as u32)
        pi = pi + 1u64
    var di2: u64 = 0u64
    while di2 < dir_keys.length:
        if dir_parent[di2] == -1:
            img = _build_named_dir_entry_attr(img, dir_name83[di2], dir_long_name[di2], first_cluster: first_cluster_all[flat_count + nested_count + di2] as u32, file_size: 0u32, attr: 0x10u8)
        di2 = di2 + 1u64
    var nj: u64 = 0u64
    while nj < nested_count:
        if nested_parent_idx[nj] == -1:
            img = _build_named_dir_entry(img, nested_leaf_name83[nj], nested_leaf_long_name[nj], first_cluster: first_cluster_all[flat_count + nj] as u32, file_size: cfg.nested_payloads[nj].data.length as u32)
        nj = nj + 1u64
    # Pad root directory cluster to 512 bytes (each entry is 32 bytes)
    val dir_used: u64 = root_entry_slots * 32u64
    if dir_used < 512u64:
        img = _push_zeros(img, 512u64 - dir_used)

    # Cluster 3+: flat payload data, then nested payload file data, then each
    # directory node's sized cluster chain -- in that exact order.
    var i2: u64 = 0u64
    while i2 < flat_count:
        val p = cfg.payloads[i2]
        val cnt = cluster_counts[i2]
        var bi: u64 = 0u64
        while bi < p.data.length as u64:
            img.push(p.data[bi])
            bi = bi + 1u64
        val padded: u64 = cnt * bytes_per_cluster
        val written: u64 = p.data.length as u64
        if padded > written:
            img = _push_zeros(img, padded - written)
        i2 = i2 + 1u64

    var nk: u64 = 0u64
    while nk < nested_count:
        val np = cfg.nested_payloads[nk]
        val cnt = cluster_counts[flat_count + nk]
        var bi2: u64 = 0u64
        while bi2 < np.data.length as u64:
            img.push(np.data[bi2])
            bi2 = bi2 + 1u64
        val padded2: u64 = cnt * bytes_per_cluster
        val written2: u64 = np.data.length as u64
        if padded2 > written2:
            img = _push_zeros(img, padded2 - written2)
        nk = nk + 1u64

    var dn: u64 = 0u64
    while dn < dir_keys.length:
        var dir_buf: [u8] = []
        var dir_entry_slots: u64 = 0u64
        # Child subdirectories of this node.
        var cd: u64 = 0u64
        while cd < dir_keys.length:
            if dir_parent[cd] == (dn as i64):
                dir_buf = _build_named_dir_entry_attr(dir_buf, dir_name83[cd], dir_long_name[cd], first_cluster: first_cluster_all[flat_count + nested_count + cd] as u32, file_size: 0u32, attr: 0x10u8)
                dir_entry_slots = dir_entry_slots + _named_dir_entry_slot_count(dir_long_name[cd])
            cd = cd + 1u64
        # Nested files whose parent is this node.
        var cf: u64 = 0u64
        while cf < nested_count:
            if nested_parent_idx[cf] == (dn as i64):
                dir_buf = _build_named_dir_entry(dir_buf, nested_leaf_name83[cf], nested_leaf_long_name[cf], first_cluster: first_cluster_all[flat_count + cf] as u32, file_size: cfg.nested_payloads[cf].data.length as u32)
                dir_entry_slots = dir_entry_slots + _named_dir_entry_slot_count(nested_leaf_long_name[cf])
            cf = cf + 1u64
        val used: u64 = dir_entry_slots * 32u64
        val dir_cluster_count = cluster_counts[flat_count + nested_count + dn]
        val dir_capacity = dir_cluster_count * bytes_per_cluster
        if used < dir_capacity:
            dir_buf = _push_zeros(dir_buf, dir_capacity - used)
        var db: u64 = 0u64
        while db < dir_buf.length:
            img.push(dir_buf[db])
            db = db + 1u64
        dn = dn + 1u64

    # IF-13 wave-4d: write only the structural prefix (~150 KiB), then let
    # the kernel zero-extend to full image size via ftruncate. This avoids
    # building a 32 MiB byte array in the interpreter (intractable: >30s/MiB).
    val img_bytes: u64 = cfg.size_mb * 1024u64 * 1024u64
    if not rt_file_write_bytes(out_path, img):
        return Err("disk_image.build: write failed: " + out_path)
    if not rt_file_truncate(out_path, img_bytes):
        val current_len = img.length as u64
        if cfg.size_mb <= 1u64 and current_len < img_bytes:
            img = _push_zeros(img, img_bytes - current_len)
            if not rt_file_write_bytes(out_path, img):
                return Err("disk_image.build: tiny-image rewrite failed: " + out_path)
        else:
            return Err("disk_image.build: truncate failed: " + out_path)
    Ok(())
