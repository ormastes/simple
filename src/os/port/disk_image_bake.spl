# SimpleOS Phase-2 I5 bake harness — combines initramfs + FAT32 disk image.
#
# Pre-built artifacts must exist:
#   /tmp/hello_rs_simpleos/target/target/release/hello_rs  (Rust ELF)
#   /tmp/hello_c.o  (cross-compiled C object)
#
# Run:
#   bin/simple run src/os/port/disk_image_bake.spl
#
# IF-13 wave-4d (this revision): the previous wave-4 bake emitted a 32 MiB
# FAT32 stub via an in-interpreter array-doubling pad because the per-element
# zero-pad in disk_image.build() was intractable (>30s/MiB). With
# rt_file_truncate now available, disk_image.build() writes only the ~150 KiB
# structural prefix and asks the kernel to zero-extend, so we can call the
# real builders with embedded payloads here.

use std.io_runtime as io
use os.port.disk_image.{DiskImageConfig, PayloadEntry, build}
use os.port.initramfs_pack.{PackConfig, PayloadEntry as InitramfsPayloadEntry,
    cmd_build, validate_image}

extern fn rt_file_read_bytes(path: text) -> [u8]

fn _load_payload(path: text, name83: text) -> Result<PayloadEntry, text>:
    """Read a file and wrap as a FAT32 8.3 directory entry."""
    if not io.file_exists(path):
        return Err("bake: payload missing: " + path)
    val data: [u8] = rt_file_read_bytes(path) ?? []
    if data.length == 0:
        return Err("bake: payload empty or unreadable: " + path)
    Ok(PayloadEntry(path: name83, data: data))

fn _build_initramfs(out_initramfs: text, hello_rs_path: text, hello_c_path: text) -> Result<(), text>:
    """Build a real initramfs image and inject the bake payloads into it."""
    var payloads: List<InitramfsPayloadEntry> = [
        InitramfsPayloadEntry(
            host_path: hello_rs_path,
            guest_path: "/usr/share/test/hello_rs",
            is_dir: false,
        ),
    ]
    if io.file_exists(hello_c_path):
        payloads.push(InitramfsPayloadEntry(
            host_path: hello_c_path,
            guest_path: "/usr/share/test/hello_c.o",
            is_dir: false,
        ))

    val config = PackConfig(
        simple_binary: "build/bootstrap/stage3/simple_simpleos",
        llvm_prefix: "build/os/llvm/cross/bin",
        sysroot: "build/os/sysroot",
        source_tree: "src",
        output: out_initramfs,
        staging: out_initramfs + ".staging",
        payloads: payloads,
    )
    cmd_build(config)
    if not validate_image(out_initramfs):
        return Err("bake: initramfs validation failed: " + out_initramfs)
    Ok(())

fn bake(out_disk: text, out_initramfs: text) -> Result<(), text>:
    """Produce FAT32 disk image + validated initramfs image from pre-built ELF artifacts."""
    val hello_rs_path = "/tmp/hello_rs_simpleos/target/target/release/hello_rs"
    val hello_c_path  = "/tmp/hello_c.o"

    # --- Step 1: load hello_rs ---
    val rs_entry = match _load_payload(hello_rs_path, "HELLORS    "):
        case Ok(e):
            print "bake: loaded hello_rs (" + io.file_size(hello_rs_path).to_text() + " bytes)"
            e
        case Err(msg):
            return Err(msg)

    # --- Step 2: load hello_c.o (informational only — wave-4a embeds first payload) ---
    if io.file_exists(hello_c_path):
        print "bake: loaded hello_c.o (" + io.file_size(hello_c_path).to_text() + " bytes)"
    else:
        print "bake: warning — hello_c.o not found (skipped, wave-4a single-payload limit)"

    # --- Step 3: ensure output dir + build real FAT32 image ---
    io.dir_create_all("build/os")
    val cfg = DiskImageConfig(size_mb: 32u64, payloads: [rs_entry])
    match build(cfg, out_disk):
        case Ok(()):
            print "bake: disk image written: " + out_disk
        case Err(e):
            return Err("bake: disk_image.build failed: " + e)

    # --- Step 4: build real initramfs image with injected payloads ---
    match _build_initramfs(out_initramfs, hello_rs_path, hello_c_path):
        case Ok(()):
            print "bake: initramfs image written: " + out_initramfs
        case Err(e):
            return Err(e)

    Ok(())

fn main():
    """Entry: bin/simple src/os/port/disk_image_bake.spl"""
    val disk = "build/os/simpleos_disk.img"
    val initramfs = "build/os/simpleos_initramfs.cpio.zst"
    match bake(disk, initramfs):
        case Ok(()):
            print "bake done: " + disk + "  " + initramfs
        case Err(e):
            print "bake FAILED: " + e
