# SimpleOS Phase-2 I5 bake harness — combines initramfs + FAT32 disk image.
#
# Pure in-process: no subprocess calls. Pre-built artifacts must exist:
#   /tmp/hello_rs_simpleos/target/target/release/hello_rs  (Rust ELF)
#   /tmp/hello_c.o  (cross-compiled C object)
#
# Run:
#   bin/simple run src/os/port/disk_image_bake.spl

use std.fs
use os.port.disk_image as disk_image

fn ensure_dir(path: text):
    if not fs.dir_exists(path):
        fs.create_dir_all(path)

fn bake(out_disk: text, out_initramfs: text) -> Result<(), text>:
    """Produce FAT32 disk image + initramfs stub from pre-built ELF artifacts.

    Step 1 — Read /tmp/hello_rs_simpleos/.../hello_rs (skip if absent).
    Step 2 — Read /tmp/hello_c.o (skip if absent).
    Step 3 — Call disk_image.build() -> out_disk (32 MiB FAT32).
    Step 4 — Write initramfs placeholder to out_initramfs (TODO: real packer).
    """
    val hello_rs_path = "/tmp/hello_rs_simpleos/target/target/release/hello_rs"
    val hello_c_path  = "/tmp/hello_c.o"

    # --- Step 1: load hello_rs ---
    var rs_bytes: [u8] = []
    if fs.exists(hello_rs_path):
        rs_bytes = fs.read_bytes(hello_rs_path)
        print "bake: loaded hello_rs (" + fs.file_size(hello_rs_path).to_text() + " bytes)"
    else:
        print "bake: warning — hello_rs not found, using empty payload"

    # --- Step 2: load hello_c.o ---
    var co_bytes: [u8] = []
    if fs.exists(hello_c_path):
        co_bytes = fs.read_bytes(hello_c_path)
        print "bake: loaded hello_c.o (" + fs.file_size(hello_c_path).to_text() + " bytes)"
    else:
        print "bake: warning — hello_c.o not found, using empty payload"

    # --- Step 3: FAT32 disk image ---
    ensure_dir(fs.parent(out_disk))
    val payloads: [disk_image.PayloadEntry] = [
        disk_image.PayloadEntry(path: "HELLORS ", data: rs_bytes),
        disk_image.PayloadEntry(path: "HELLOCO ", data: co_bytes),
    ]
    val disk_cfg = disk_image.DiskImageConfig(
        size_mb: 32u64,
        payloads: payloads,
    )
    match disk_image.build(disk_cfg, out_disk):
        case Ok(()):
            print "bake: disk image written: " + out_disk
        case Err(e):
            return Err("bake: disk_image.build failed: " + e)

    # --- Step 4: initramfs stub (TODO wave-6: call initramfs_pack.cmd_build) ---
    ensure_dir(fs.parent(out_initramfs))
    val stub: [u8] = [0x28u8, 0x42u8, 0x35u8, 0x44u8, 0x36u8, 0x29u8, 0x0Au8]
    if fs.write_bytes(out_initramfs, stub):
        print "bake: initramfs stub written: " + out_initramfs
    else:
        return Err("bake: failed to write initramfs stub: " + out_initramfs)

    Ok(())

fn main():
    """Entry: bin/simple run src/os/port/disk_image_bake.spl"""
    val disk = "build/os/simpleos_disk.img"
    val initramfs = "build/os/simpleos_initramfs.cpio.zst"
    match bake(disk, initramfs):
        case Ok(()):
            print "bake done: " + disk + "  " + initramfs
        case Err(e):
            print "bake FAILED: " + e
