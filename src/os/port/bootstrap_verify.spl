#![allow(unnamed_duplicate_typed_args)]
## SimpleOS Bootstrap Verification Script
##
## Verifies the Simple compiler bootstrap pipeline on SimpleOS.
## Checks prerequisites, runs each stage, and compares binaries.
##
## Usage:
##   bin/simple run src/os/port/bootstrap_verify.spl
##   bin/simple run src/os/port/bootstrap_verify.spl -- --dry-run
##   bin/simple run src/os/port/bootstrap_verify.spl -- --stage 2
##   bin/simple run src/os/port/bootstrap_verify.spl -- --seed /path/to/seed
##   bin/simple run src/os/port/bootstrap_verify.spl -- --target x86_64-simpleos

use std.fs
use std.process
use std.text
use std.cli

# ============================================================================
# Configuration
# ============================================================================

struct BootstrapConfig:
    seed_path: text           # Path to pre-built Rust seed binary
    source_root: text         # Path to source tree root
    build_dir: text           # Output directory for stage binaries
    sysroot_dir: text         # Path to SimpleOS sysroot
    target: text              # Target triple (x86_64-simpleos, etc.)
    max_stage: i64            # Run up to this stage (1, 2, or 3)
    dry_run: bool             # Only check prerequisites, do not build
    verbose: bool             # Print extra debug info
    strip: bool               # Strip debug symbols from output

impl BootstrapConfig:
    static fn default() -> BootstrapConfig:
        BootstrapConfig(
            seed_path: "src/compiler_rust/target/bootstrap/simple",
            source_root: ".",
            build_dir: "build/bootstrap",
            sysroot_dir: "build/os/sysroot",
            target: "",
            max_stage: 3,
            dry_run: false,
            verbose: false,
            strip: true
        )

# ============================================================================
# Argument Parsing
# ============================================================================

fn parse_args(args: [text]) -> BootstrapConfig:
    var config = BootstrapConfig.default()

    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--dry-run":
            config.dry_run = true
        else if arg == "--verbose" or arg == "-v":
            config.verbose = true
        else if arg == "--no-strip":
            config.strip = false
        else if arg == "--stage":
            i = i + 1
            if i < args.len():
                config.max_stage = args[i].to_int()
        else if arg.starts_with("--stage="):
            config.max_stage = arg.slice(8, arg.len()).to_int()
        else if arg == "--seed":
            i = i + 1
            if i < args.len():
                config.seed_path = args[i]
        else if arg.starts_with("--seed="):
            config.seed_path = arg.slice(7, arg.len())
        else if arg == "--target":
            i = i + 1
            if i < args.len():
                config.target = args[i]
        else if arg.starts_with("--target="):
            config.target = arg.slice(9, arg.len())
        else if arg == "--source-root":
            i = i + 1
            if i < args.len():
                config.source_root = args[i]
        else if arg.starts_with("--source-root="):
            config.source_root = arg.slice(14, arg.len())
        else if arg == "--build-dir":
            i = i + 1
            if i < args.len():
                config.build_dir = args[i]
        else if arg.starts_with("--build-dir="):
            config.build_dir = arg.slice(12, arg.len())
        else if arg == "--sysroot":
            i = i + 1
            if i < args.len():
                config.sysroot_dir = args[i]
        else if arg.starts_with("--sysroot="):
            config.sysroot_dir = arg.slice(10, arg.len())
        else if arg == "--help" or arg == "-h":
            print_usage()
            process.exit(0)
        i = i + 1

    config

# ============================================================================
# Prerequisite Checks
# ============================================================================

struct PrereqResult:
    name: text
    passed: bool
    message: text

fn check_tool(name: text) -> PrereqResult:
    """Check if a command-line tool is available on PATH."""
    val result = process.run("which", [name])
    if result.exit_code == 0:
        val path = result.stdout.trim()
        PrereqResult(name: name, passed: true, message: "found at {path}")
    else:
        PrereqResult(name: name, passed: false, message: "not found on PATH")

fn check_file(name: text, path: text) -> PrereqResult:
    """Check if a required file exists."""
    if fs.exists(path):
        PrereqResult(name: name, passed: true, message: "exists at {path}")
    else:
        PrereqResult(name: name, passed: false, message: "missing: {path}")

fn check_dir(name: text, path: text) -> PrereqResult:
    """Check if a required directory exists."""
    if fs.dir_exists(path):
        PrereqResult(name: name, passed: true, message: "exists at {path}")
    else:
        PrereqResult(name: name, passed: false, message: "missing: {path}")

fn check_all_prerequisites(config: BootstrapConfig) -> bool:
    """Run all prerequisite checks. Returns true if all pass."""
    print "=== Prerequisite Checks ==="
    print ""

    var checks: [PrereqResult] = []

    # Tools
    checks.push(check_tool("clang"))
    checks.push(check_tool("lld"))

    # Seed binary
    checks.push(check_file("Rust seed binary", config.seed_path))

    # Source directories
    val src = config.source_root
    checks.push(check_dir("src/compiler", "{src}/src/compiler"))
    checks.push(check_dir("src/lib", "{src}/src/lib"))
    checks.push(check_dir("src/app", "{src}/src/app"))
    checks.push(check_file("main.spl", "{src}/src/app/cli/main.spl"))
    checks.push(check_file("bootstrap_main.spl", "{src}/src/app/cli/bootstrap_main.spl"))

    # Sysroot (only if targeting SimpleOS)
    if config.target.ends_with("-simpleos") or config.target == "simpleos":
        checks.push(check_dir("sysroot", config.sysroot_dir))
        checks.push(check_file("libsimpleos_c.a", "{config.sysroot_dir}/lib/libsimpleos_c.a"))
        checks.push(check_file("crt0.o", "{config.sysroot_dir}/lib/crt0.o"))
        checks.push(check_file("simpleos.ld", "{config.sysroot_dir}/share/simpleos/simpleos.ld"))
        checks.push(check_dir("sysroot include", "{config.sysroot_dir}/include"))

    # Print results
    var passed = 0
    var failed = 0
    for check in checks:
        val status = if check.passed: "PASS" else: "FAIL"
        print "  [{status}] {check.name}: {check.message}"
        if check.passed:
            passed = passed + 1
        else:
            failed = failed + 1

    print ""
    print "  {passed} passed, {failed} failed"
    print ""

    failed == 0

# ============================================================================
# Build Stages
# ============================================================================

struct StageResult:
    stage: i64
    success: bool
    output_path: text
    duration_secs: i64
    message: text

fn stage_output_path(config: BootstrapConfig, stage: i64) -> text:
    """Return the output binary path for a given stage."""
    val suffix = if config.target != "": "_{config.target}" else: ""
    if stage == 1:
        "{config.build_dir}/stage1_full/simple{suffix}"
    else if stage == 2:
        "{config.build_dir}/stage2/simple{suffix}"
    else:
        "{config.build_dir}/stage3/simple{suffix}"

fn build_stage(config: BootstrapConfig, stage: i64, compiler_path: text) -> StageResult:
    """Run a single bootstrap stage.

    stage 1: Use Rust seed (with SIMPLE_BOOTSTRAP=1)
    stage 2: Use Stage 1 binary
    stage 3: Use Stage 2 binary
    """
    val output = stage_output_path(config, stage)
    val src = config.source_root

    print "[stage {stage}] Building with: {compiler_path}"
    print "[stage {stage}] Output: {output}"

    # Ensure output directory exists
    val output_dir = output.rsplit_once("/")
    if output_dir != nil:
        val dir = output_dir.0
        if not fs.dir_exists(dir):
            fs.mkdir_p(dir)

    # Build args
    var args: [text] = [
        "native-build",
        "--source", "{src}/src/compiler",
        "--source", "{src}/src/lib",
        "--source", "{src}/src/app",
        "--entry", "{src}/src/app/cli/main.spl",
        "-o", output,
    ]
    if config.strip:
        args.push("--strip")

    # Environment
    var env_vars: [text] = [
        "SIMPLE_LIB={src}/src",
    ]

    # Stage 1 needs bootstrap rewriter
    if stage == 1:
        env_vars.push("SIMPLE_BOOTSTRAP=1")

    if config.verbose:
        print "[stage {stage}] Command: {compiler_path} {args.join(\" \")}"
        print "[stage {stage}] Env: {env_vars.join(\", \")}"

    # Build the env-prefixed command
    val env_prefix = env_vars.join(" ")
    val cmd = "{env_prefix} {compiler_path} {args.join(\" \")}"

    val result = process.run("sh", ["-c", cmd])

    if result.exit_code != 0:
        print "[stage {stage}] BUILD FAILED (exit code {result.exit_code})"
        if result.stderr.len() > 0:
            print "[stage {stage}] stderr:"
            print result.stderr
        return StageResult(
            stage: stage,
            success: false,
            output_path: output,
            duration_secs: 0,
            message: "Build failed with exit code {result.exit_code}"
        )

    # Verify output exists
    if not fs.exists(output):
        return StageResult(
            stage: stage,
            success: false,
            output_path: output,
            duration_secs: 0,
            message: "Output binary not found after build"
        )

    val stat = fs.stat(output)
    var size_msg = ""
    if stat.is_ok():
        val size_bytes = stat.unwrap().size
        val size_mb = size_bytes / (1024 * 1024)
        size_msg = " ({size_mb} MB)"

    print "[stage {stage}] SUCCESS{size_msg}"
    StageResult(
        stage: stage,
        success: true,
        output_path: output,
        duration_secs: 0,
        message: "Built successfully{size_msg}"
    )

# ============================================================================
# Comparison
# ============================================================================

fn compare_binaries(path_a: text, path_b: text) -> bool:
    """Compare two binaries for equality.

    Returns true if they are byte-identical.
    """
    print "[verify] Comparing:"
    print "  A: {path_a}"
    print "  B: {path_b}"

    if not fs.exists(path_a):
        print "[verify] FAIL: {path_a} does not exist"
        return false
    if not fs.exists(path_b):
        print "[verify] FAIL: {path_b} does not exist"
        return false

    # Use diff to compare
    val result = process.run("diff", [path_a, path_b])
    if result.exit_code == 0:
        print "[verify] PASS: Binaries are byte-identical"
        return true

    # Not identical -- check stub counts as fallback
    print "[verify] Binaries differ -- checking stub counts..."

    val nm_a = process.run("sh", ["-c", "nm {path_a} 2>/dev/null | grep auto_stub | wc -l"])
    val nm_b = process.run("sh", ["-c", "nm {path_b} 2>/dev/null | grep auto_stub | wc -l"])

    val stubs_a = nm_a.stdout.trim()
    val stubs_b = nm_b.stdout.trim()

    print "[verify]   Stage 2 stubs: {stubs_a}"
    print "[verify]   Stage 3 stubs: {stubs_b}"

    if stubs_a == stubs_b and stubs_a != "0":
        print "[verify] PASS: Stub counts match ({stubs_a} stubs each) -- convergence achieved"
        return true

    # Check file sizes
    val stat_a = fs.stat(path_a)
    val stat_b = fs.stat(path_b)
    if stat_a.is_ok() and stat_b.is_ok():
        val size_a = stat_a.unwrap().size
        val size_b = stat_b.unwrap().size
        print "[verify]   Stage 2 size: {size_a} bytes"
        print "[verify]   Stage 3 size: {size_b} bytes"
        if size_a == size_b:
            print "[verify] INFO: Same size but different content -- may be non-deterministic codegen"

    print "[verify] FAIL: Binaries do not converge"
    false

# ============================================================================
# Smoke Test
# ============================================================================

fn smoke_test(binary_path: text) -> bool:
    """Run basic smoke tests on a built binary."""
    print "[smoke] Testing: {binary_path}"

    # Test --version
    val version_result = process.run(binary_path, ["--version"])
    if version_result.exit_code != 0:
        print "[smoke] FAIL: --version returned exit code {version_result.exit_code}"
        return false
    print "[smoke]   --version: {version_result.stdout.trim()}"

    # Test --help
    val help_result = process.run(binary_path, ["--help"])
    if help_result.exit_code != 0:
        print "[smoke] FAIL: --help returned exit code {help_result.exit_code}"
        return false
    print "[smoke]   --help: OK ({help_result.stdout.len()} bytes output)"

    print "[smoke] PASS: Basic commands work"
    true

# ============================================================================
# Main Pipeline
# ============================================================================

fn run_bootstrap(config: BootstrapConfig) -> bool:
    """Run the full bootstrap pipeline up to config.max_stage."""
    print "=== SimpleOS Bootstrap Verification ==="
    print ""
    print "  Seed:       {config.seed_path}"
    print "  Source:      {config.source_root}"
    print "  Build dir:   {config.build_dir}"
    print "  Target:      {if config.target != \"\": config.target else: \"host\"}"
    print "  Max stage:   {config.max_stage}"
    print "  Dry run:     {config.dry_run}"
    print ""

    # Step 1: Check prerequisites
    val prereqs_ok = check_all_prerequisites(config)
    if not prereqs_ok:
        print "ERROR: Prerequisites not met. Fix the failures above and retry."
        return false

    if config.dry_run:
        print "Dry run complete. All prerequisites met."
        return true

    # Step 2: Stage 1
    print "=== Stage 1: Rust seed -> Stage 1 ==="
    val stage1 = build_stage(config, 1, config.seed_path)
    if not stage1.success:
        print "FAILED at Stage 1: {stage1.message}"
        return false

    # Smoke test Stage 1
    val smoke1 = smoke_test(stage1.output_path)
    if not smoke1:
        print "WARNING: Stage 1 smoke test failed, continuing anyway..."

    if config.max_stage < 2:
        print "=== Stopped at Stage 1 (--stage 1) ==="
        return true

    # Step 3: Stage 2
    print ""
    print "=== Stage 2: Stage 1 -> Stage 2 ==="
    val stage2 = build_stage(config, 2, stage1.output_path)
    if not stage2.success:
        print "FAILED at Stage 2: {stage2.message}"
        return false

    val smoke2 = smoke_test(stage2.output_path)
    if not smoke2:
        print "WARNING: Stage 2 smoke test failed, continuing anyway..."

    if config.max_stage < 3:
        print "=== Stopped at Stage 2 (--stage 2) ==="
        return true

    # Step 4: Stage 3
    print ""
    print "=== Stage 3: Stage 2 -> Stage 3 ==="
    val stage3 = build_stage(config, 3, stage2.output_path)
    if not stage3.success:
        print "FAILED at Stage 3: {stage3.message}"
        return false

    val smoke3 = smoke_test(stage3.output_path)
    if not smoke3:
        print "WARNING: Stage 3 smoke test failed"

    # Step 5: Convergence check
    print ""
    print "=== Convergence Check ==="
    val converged = compare_binaries(stage2.output_path, stage3.output_path)

    # Summary
    print ""
    print "=== Bootstrap Summary ==="
    print "  Stage 1: {if stage1.success: \"PASS\" else: \"FAIL\"}"
    print "  Stage 2: {if stage2.success: \"PASS\" else: \"FAIL\"}"
    print "  Stage 3: {if stage3.success: \"PASS\" else: \"FAIL\"}"
    print "  Convergence: {if converged: \"PASS\" else: \"FAIL\"}"
    print ""

    if converged:
        print "Bootstrap verification PASSED."
    else:
        print "Bootstrap verification FAILED: Stage 2 and Stage 3 do not converge."

    converged

# ============================================================================
# Entry Point
# ============================================================================

fn print_usage():
    print "bootstrap_verify -- SimpleOS Bootstrap Verification"
    print ""
    print "Usage:"
    print "  bin/simple run src/os/port/bootstrap_verify.spl [options]"
    print ""
    print "Options:"
    print "  --dry-run              Check prerequisites only, do not build"
    print "  --stage N              Run only up to stage N (1, 2, or 3)"
    print "  --seed PATH            Path to Rust seed binary"
    print "  --target TRIPLE        Target triple (e.g. x86_64-simpleos)"
    print "  --source-root PATH     Path to source tree root"
    print "  --build-dir PATH       Output directory for stage binaries"
    print "  --sysroot PATH         Path to SimpleOS sysroot"
    print "  --no-strip             Do not strip debug symbols"
    print "  --verbose, -v          Print extra debug info"
    print "  --help, -h             Show this help"
    print ""
    print "Examples:"
    print "  # Check prerequisites only:"
    print "  bin/simple run src/os/port/bootstrap_verify.spl -- --dry-run"
    print ""
    print "  # Full 3-stage bootstrap on host:"
    print "  bin/simple run src/os/port/bootstrap_verify.spl"
    print ""
    print "  # Build only up to stage 2:"
    print "  bin/simple run src/os/port/bootstrap_verify.spl -- --stage 2"
    print ""
    print "  # Use custom seed and target SimpleOS:"
    print "  bin/simple run src/os/port/bootstrap_verify.spl -- \\"
    print "    --seed build/cross/simple --target x86_64-simpleos"

fn main():
    val args = cli.args()
    val config = parse_args(args)
    val ok = run_bootstrap(config)
    if not ok:
        process.exit(1)
