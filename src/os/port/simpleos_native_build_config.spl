# SimpleOS Native Build Configuration
#
# Provides linker flags, sysroot paths, and library lists for
# `simple native-build --target simpleos` to auto-configure.
#
# The sysroot layout (built by src/os/port/llvm/sysroot.shs):
#   build/os/sysroot/
#     include/              — C headers (simpleos_libc.h, stdio.h, etc.)
#     include/c++/          — Minimal C++ headers (new, cstdlib, etc.)
#     lib/                  — libsimpleos_c.a, crt0.o, compiler-rt
#     share/simpleos/       — simpleos.ld linker script
#
# Usage from Simple compiler:
#   val flags = simpleos_linker_flags()
#   val includes = simpleos_include_paths()

use std.fs
use std.process

# ============================================================================
# Sysroot Path
# ============================================================================

fn simpleos_sysroot_path() -> text:
    """Return the path to the SimpleOS sysroot directory."""
    "build/os/sysroot"

# ============================================================================
# Linker Flags
# ============================================================================

fn simpleos_linker_flags() -> [text]:
    """Return linker flags for SimpleOS target.

    These flags configure the linker for a freestanding static binary:
    - nostdlib: no host C library
    - ffreestanding: no hosted environment assumptions
    - static: no dynamic linking
    - linker script: simpleos.ld places .text at 0x10000000
    - library: libsimpleos_c.a (minimal libc for SimpleOS)
    - crt0: startup code that calls main()
    """
    [
        "-nostdlib",
        "-ffreestanding",
        "-static",
        "-T", "build/os/sysroot/share/simpleos/simpleos.ld",
        "-L", "build/os/sysroot/lib",
        "-lsimpleos_c",
        "build/os/sysroot/lib/crt0.o"
    ]

# ============================================================================
# Include Paths
# ============================================================================

fn simpleos_include_paths() -> [text]:
    """Return include paths for SimpleOS target.

    Used when compiling C stubs or FFI wrappers against
    the SimpleOS libc headers.
    """
    [
        "build/os/sysroot/include",
        "build/os/sysroot/include/c++"
    ]

# ============================================================================
# Sysroot Build
# ============================================================================

fn simpleos_ensure_sysroot() -> bool:
    """Build the sysroot if it doesn't exist.

    Checks for libsimpleos_c.a in the sysroot. If missing,
    runs the sysroot build script to compile the libc, install
    headers, and generate the linker script.

    Returns true if the sysroot is ready, false on build failure.
    """
    if fs.exists("build/os/sysroot/lib/libsimpleos_c.a"):
        return true

    val (stdout, stderr, exit_code) = process.run("sh", ["src/os/port/llvm/sysroot.shs"])
    if exit_code != 0:
        print("[simpleos] sysroot build failed: {stderr}")
        return false

    # Verify the sysroot was built successfully
    fs.exists("build/os/sysroot/lib/libsimpleos_c.a")

# ============================================================================
# Target Validation
# ============================================================================

fn simpleos_is_target(target: text) -> bool:
    """Check if a target string refers to SimpleOS.

    Recognized patterns:
    - "simpleos"
    - "x86_64-simpleos"
    - "aarch64-simpleos"
    - "riscv64gc-simpleos"
    - "riscv32imac-simpleos"
    """
    target == "simpleos" or target.ends_with("-simpleos")

fn simpleos_supported_targets() -> [text]:
    """Return list of supported SimpleOS target triples."""
    [
        "x86_64-simpleos",
        "aarch64-simpleos",
        "riscv64gc-simpleos",
        "riscv32imac-simpleos"
    ]

# ============================================================================
# Target Architecture Helpers
# ============================================================================

fn simpleos_target_arch(target: text) -> text:
    """Extract the architecture name from a SimpleOS target triple.

    Returns the LLVM-style arch for the given target.
    """
    if target.starts_with("x86_64"):
        "x86_64"
    else if target.starts_with("aarch64"):
        "aarch64"
    else if target.starts_with("riscv64"):
        "riscv64"
    else if target.starts_with("riscv32"):
        "riscv32"
    else:
        "unknown"

fn simpleos_clang_target(target: text) -> text:
    """Return the clang --target triple for a SimpleOS target.

    Maps our target names to the ELF triple clang expects.
    """
    if target.starts_with("x86_64"):
        "x86_64-unknown-none-elf"
    else if target.starts_with("aarch64"):
        "aarch64-unknown-none-elf"
    else if target.starts_with("riscv64"):
        "riscv64-unknown-none-elf"
    else if target.starts_with("riscv32"):
        "riscv32-unknown-none-elf"
    else:
        "x86_64-unknown-none-elf"

# ============================================================================
# Compiler Flags (for C stubs / FFI wrappers)
# ============================================================================

fn simpleos_c_flags(target: text) -> [text]:
    """Return C compiler flags for compiling SimpleOS C stubs.

    These flags produce freestanding object files compatible with
    the SimpleOS environment.
    """
    var flags = [
        "--target={simpleos_clang_target(target)}",
        "-ffreestanding",
        "-nostdlib",
        "-fno-builtin",
        "-fno-stack-protector",
        "-fno-exceptions",
        "-fno-unwind-tables",
        "-fno-asynchronous-unwind-tables",
        "-O2",
        "-I", "build/os/sysroot/include",
    ]

    # Architecture-specific flags
    if target.starts_with("x86_64"):
        flags.push("-mno-red-zone")
        flags.push("-DOPENSSL_NO_ASM")
        flags.push("-DRING_CORE_NOSTDLIBINC")
        flags.push("-I")
        flags.push("src/compiler_rust/vendor/ring/include")
        flags.push("-I")
        flags.push("src/compiler_rust/vendor/ring")
        flags.push("-I")
        flags.push("src/compiler_rust/vendor/ring/pregenerated")

    flags

# ============================================================================
# CRT Objects
# ============================================================================

fn simpleos_crt_objects() -> [text]:
    """Return paths to CRT startup objects.

    crt0.o contains _start which sets up the stack and calls main().
    """
    [
        "build/os/sysroot/lib/crt0.o"
    ]

# ============================================================================
# Library Paths
# ============================================================================

fn simpleos_library_paths() -> [text]:
    """Return library search paths for the linker."""
    [
        "build/os/sysroot/lib"
    ]

fn simpleos_libraries() -> [text]:
    """Return library names to link against (without -l prefix)."""
    [
        "simpleos_c"
    ]

# ============================================================================
# Linker Script
# ============================================================================

fn simpleos_linker_script() -> text:
    """Return path to the SimpleOS linker script.

    The linker script places .text at 0x10000000 and configures
    the memory layout for SimpleOS user-mode processes.
    """
    "build/os/sysroot/share/simpleos/simpleos.ld"

# ============================================================================
# Full Build Configuration
# ============================================================================

struct SimpleOSBuildConfig:
    target: text
    c_flags: [text]
    linker_flags: [text]
    include_paths: [text]
    library_paths: [text]
    libraries: [text]
    crt_objects: [text]
    linker_script: text
    sysroot: text

fn simpleos_build_config(target: text) -> SimpleOSBuildConfig:
    """Return the full build configuration for a SimpleOS target.

    Convenience function that collects all settings into one struct.
    """
    SimpleOSBuildConfig(
        target: target,
        c_flags: simpleos_c_flags(target),
        linker_flags: simpleos_linker_flags(),
        include_paths: simpleos_include_paths(),
        library_paths: simpleos_library_paths(),
        libraries: simpleos_libraries(),
        crt_objects: simpleos_crt_objects(),
        linker_script: simpleos_linker_script(),
        sysroot: simpleos_sysroot_path()
    )

fn simpleos_validate_sysroot() -> bool:
    """Validate that the sysroot has all required components.

    Returns true if the sysroot is complete and ready for building.
    """
    var ok = true

    if not fs.exists("build/os/sysroot/lib/libsimpleos_c.a"):
        print "[simpleos] Missing: libsimpleos_c.a"
        ok = false

    if not fs.exists("build/os/sysroot/lib/crt0.o"):
        print "[simpleos] Missing: crt0.o"
        ok = false

    if not fs.exists("build/os/sysroot/share/simpleos/simpleos.ld"):
        print "[simpleos] Missing: simpleos.ld linker script"
        ok = false

    if not fs.exists("build/os/sysroot/include/simpleos_libc.h"):
        print "[simpleos] Missing: simpleos_libc.h header"
        ok = false

    if ok:
        print "[simpleos] Sysroot validation: OK"
    else:
        print "[simpleos] Sysroot validation: FAILED"
        print "[simpleos] Run: sh src/os/port/llvm/sysroot.shs"

    ok
