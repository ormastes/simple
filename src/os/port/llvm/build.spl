## LLVM cross-compilation build script for SimpleOS targets.
##
## Usage:
##   bin/simple run src/os/port/llvm/build.spl -- --target x86_64-simpleos
##   bin/simple run src/os/port/llvm/build.spl -- --target aarch64-simpleos --jobs 8
##   bin/simple run src/os/port/llvm/build.spl -- --all

use std.fs
use std.process
use std.text
use std.cli

val SUPPORTED_TARGETS = [
    "x86_64-simpleos",
    "aarch64-simpleos",
    "riscv64gc-simpleos",
    "riscv32imac-simpleos",
]

val LLVM_REPO = "https://github.com/ormastes/llvm-project.git"
val LLVM_BRANCH = "simpleos"
val DEFAULT_INSTALL_PREFIX = "/opt/simpleos-toolchain"

class BuildConfig:
    target: text
    source_dir: text
    build_dir: text
    install_prefix: text
    jobs: i64
    build_compiler_rt: bool

    fn llvm_arch() -> text:
        if self.target.starts_with("x86_64"):
            "X86"
        else if self.target.starts_with("aarch64"):
            "AArch64"
        else if self.target.starts_with("riscv"):
            "RISCV"
        else:
            panic("Unknown architecture for target: {self.target}")

fn parse_args(args: List<text>) -> BuildConfig:
    var target = "x86_64-simpleos"
    var source_dir = "llvm-project"
    var build_dir = "build-llvm"
    var install_prefix = DEFAULT_INSTALL_PREFIX
    var jobs = 0  # 0 means auto-detect
    var build_all = false
    var build_compiler_rt = true

    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--target":
            i = i + 1
            target = args[i]
        else if arg == "--source-dir":
            i = i + 1
            source_dir = args[i]
        else if arg == "--build-dir":
            i = i + 1
            build_dir = args[i]
        else if arg == "--prefix":
            i = i + 1
            install_prefix = args[i]
        else if arg == "--jobs":
            i = i + 1
            jobs = args[i].parse_int()
        else if arg == "--no-compiler-rt":
            build_compiler_rt = false
        else if arg == "--all":
            build_all = true
        i = i + 1

    if build_all:
        # Ensure source is cloned/updated once before building all targets
        val first_config = BuildConfig(
            target: SUPPORTED_TARGETS[0],
            source_dir: source_dir,
            build_dir: build_dir,
            install_prefix: install_prefix,
            jobs: jobs,
            build_compiler_rt: build_compiler_rt,
        )
        clone_or_update_source(first_config)

        # Build for all targets sequentially
        for t in SUPPORTED_TARGETS:
            val config = BuildConfig(
                target: t,
                source_dir: source_dir,
                build_dir: "{build_dir}-{t}",
                install_prefix: install_prefix,
                jobs: jobs,
                build_compiler_rt: build_compiler_rt,
            )
            build_llvm(config)
        process.exit(0)

    BuildConfig(
        target: target,
        source_dir: source_dir,
        build_dir: build_dir,
        install_prefix: install_prefix,
        jobs: jobs,
        build_compiler_rt: build_compiler_rt,
    )

fn check_prerequisites():
    val required_tools = ["cmake", "ninja", "clang", "python3", "git"]
    for tool in required_tools:
        val result = process.run("which", [tool])
        if result.exit_code != 0:
            panic("Required tool not found: {tool}. Please install it first.")
    print "All prerequisites found."

fn clone_or_update_source(config: BuildConfig):
    if fs.exists(config.source_dir):
        print "Source directory exists, updating..."
        process.run_checked("git", ["-C", config.source_dir, "fetch", "origin"])
        process.run_checked("git", ["-C", config.source_dir, "checkout", LLVM_BRANCH])
        process.run_checked("git", ["-C", config.source_dir, "pull", "--rebase"])
    else:
        print "Cloning LLVM source from {LLVM_REPO}..."
        process.run_checked("git", ["clone", "--branch", LLVM_BRANCH, "--depth", "1", LLVM_REPO, config.source_dir])

fn build_llvm(config: BuildConfig):
    print "Building LLVM for target: {config.target}"
    print "  Source:  {config.source_dir}"
    print "  Build:   {config.build_dir}"
    print "  Prefix:  {config.install_prefix}"

    val arch = config.llvm_arch()
    var cmake_args = [
        "-S", "{config.source_dir}/llvm",
        "-B", config.build_dir,
        "-G", "Ninja",
        "-DCMAKE_BUILD_TYPE=Release",
        "-DLLVM_ENABLE_PROJECTS=clang;lld",
        "-DLLVM_TARGETS_TO_BUILD={arch}",
        "-DLLVM_DEFAULT_TARGET_TRIPLE={config.target}",
        "-DCMAKE_INSTALL_PREFIX={config.install_prefix}",
    ]

    print "Configuring LLVM..."
    process.run_checked("cmake", cmake_args)

    var ninja_args = ["-C", config.build_dir]
    if config.jobs > 0:
        ninja_args = ninja_args + ["-j", "{config.jobs}"]

    print "Building LLVM (this may take a while)..."
    process.run_checked("ninja", ninja_args)

    print "Installing LLVM..."
    process.run_checked("ninja", ["-C", config.build_dir, "install"])

    if config.build_compiler_rt:
        build_compiler_rt(config)

    print "LLVM build complete for {config.target}."

fn build_compiler_rt(config: BuildConfig):
    print "Building compiler-rt for {config.target}..."
    val rt_build_dir = "{config.build_dir}-compiler-rt"

    val cmake_args = [
        "-S", "{config.source_dir}/compiler-rt",
        "-B", rt_build_dir,
        "-G", "Ninja",
        "-DCMAKE_C_COMPILER={config.install_prefix}/bin/clang",
        "-DCMAKE_AR={config.install_prefix}/bin/llvm-ar",
        "-DCMAKE_NM={config.install_prefix}/bin/llvm-nm",
        "-DCMAKE_RANLIB={config.install_prefix}/bin/llvm-ranlib",
        "-DCOMPILER_RT_BAREMETAL_BUILD=ON",
        "-DCOMPILER_RT_BUILD_BUILTINS=ON",
        "-DCOMPILER_RT_BUILD_SANITIZERS=OFF",
        "-DCOMPILER_RT_BUILD_XRAY=OFF",
        "-DCOMPILER_RT_BUILD_LIBFUZZER=OFF",
        "-DCOMPILER_RT_BUILD_PROFILE=OFF",
        "-DCMAKE_C_FLAGS=--target={config.target} -ffreestanding -nostdlib",
        "-DCMAKE_INSTALL_PREFIX={config.install_prefix}",
    ]

    process.run_checked("cmake", cmake_args)

    var ninja_args = ["-C", rt_build_dir]
    if config.jobs > 0:
        ninja_args = ninja_args + ["-j", "{config.jobs}"]

    process.run_checked("ninja", ninja_args)
    process.run_checked("ninja", ["-C", rt_build_dir, "install"])
    print "compiler-rt build complete."

fn main():
    print "=== SimpleOS LLVM Build Script ==="
    check_prerequisites()

    val args = cli.args()

    # Dispatch to cross-build mode if requested
    if args.len() > 0 and args[0] == "--cross":
        val cross_args = args.slice(1, args.len())
        cross_build_main(cross_args)
        return

    val config = parse_args(args)
    clone_or_update_source(config)
    build_llvm(config)
    print "=== Build finished successfully ==="

# ===========================================================================
# Cross-compilation orchestrator (Phase 4A-4C)
#
# Drives the 3-stage cross-compile pipeline that produces LLVM/Clang
# binaries that run ON SimpleOS.
#
# Usage:
#   bin/simple run src/os/port/llvm/build.spl -- --cross
#   bin/simple run src/os/port/llvm/build.spl -- --cross --stage host-tools
#   bin/simple run src/os/port/llvm/build.spl -- --cross --status
# ===========================================================================

val CROSS_STAGES: [text] = ["host-tools", "cross", "compiler-rt"]

## Full SimpleOS triple list (unknown-simpleos vendor/OS form) consumed by
## the cross-build pipeline. Keep in sync with SUPPORTED_TARGETS above and
## with patches/simpleos_toolchain_cpp/README.md.
val CROSS_SUPPORTED_TARGETS: [text] = [
    "x86_64-unknown-simpleos",
    "aarch64-unknown-simpleos",
    "riscv64gc-unknown-simpleos",
    "riscv32imac-unknown-simpleos",
]

## Clang resource dir version tag — matches the `lib/clang/<version>/`
## layout produced by upstream LLVM install. Bump together with LLVM.
val CLANG_RESOURCE_VERSION: text = "19"

class CrossBuildConfig:
    llvm_src: text          # Path to llvm-project source
    build_dir: text         # Build output directory
    sysroot_dir: text       # Sysroot output directory
    target_triple: text     # Target triple (x86_64-unknown-simpleos)

impl CrossBuildConfig:
    static fn default() -> CrossBuildConfig:
        CrossBuildConfig(
            llvm_src: "{process.env("HOME")}/llvm-project",
            build_dir: "build/os/llvm",
            sysroot_dir: "build/os/sysroot",
            target_triple: "x86_64-unknown-simpleos"
        )

fn cross_llvm_arch_for(triple: text) -> text:
    """Map a SimpleOS triple to the LLVM_TARGETS_TO_BUILD arch name."""
    if triple.starts_with("x86_64"):
        "X86"
    else if triple.starts_with("aarch64"):
        "AArch64"
    else if triple.starts_with("riscv"):
        "RISCV"
    else:
        panic("Unknown LLVM arch for triple: {triple}")

fn cross_selected_targets() -> [text]:
    """Resolve which triples to build.

    Honours the SIMPLE_TARGET env override: when set (non-empty) only that
    triple is returned, otherwise the full CROSS_SUPPORTED_TARGETS list.
    """
    val override = process.env("SIMPLE_TARGET")
    if override != "":
        return [override]
    CROSS_SUPPORTED_TARGETS

fn cross_build_print_plan():
    """Print the multi-target cross-build plan without executing anything."""
    val targets = cross_selected_targets()
    print "[cross] Plan: build LLVM + compiler-rt for {targets.len()} target(s)"
    for triple in targets:
        val arch = cross_llvm_arch_for(triple)
        print "  - {triple} (arch {arch})"
        print "      build dir : build/os/llvm/cross-{triple}"
        print "      builtins  : build/os/llvm/compiler-rt-{triple}"
        print "      install   : build/os/sysroot/lib/clang/{CLANG_RESOURCE_VERSION}/lib/{triple}"

fn cross_build_status() -> text:
    """Check current cross-build status across all SimpleOS targets."""
    var status = "LLVM Cross-Build Status:\n"

    if fs.dir_exists("build/os/llvm/host-tools/bin"):
        status = status + "  host-tools:  BUILT\n"
    else:
        status = status + "  host-tools:  NOT BUILT\n"

    if fs.exists("build/os/sysroot/lib/libsimpleos_c.a"):
        status = status + "  sysroot:     READY\n"
    else:
        status = status + "  sysroot:     NOT READY\n"

    for triple in CROSS_SUPPORTED_TARGETS:
        val cross_dir = "build/os/llvm/cross-{triple}/bin"
        if fs.dir_exists(cross_dir):
            status = status + "  cross[{triple}]:  BUILT\n"
        else:
            status = status + "  cross[{triple}]:  NOT BUILT\n"

        val rt_dir = "build/os/llvm/compiler-rt-{triple}"
        if fs.dir_exists(rt_dir):
            status = status + "  rt[{triple}]:     BUILT\n"
        else:
            status = status + "  rt[{triple}]:     NOT BUILT\n"

    status

fn cross_build_sysroot() -> bool:
    """Build sysroot (libc headers + libraries + linker script)."""
    print "[cross] Building sysroot..."
    val result = process.run("sh", ["src/os/port/llvm/sysroot.shs"])
    if result.exit_code != 0:
        print "[cross] Sysroot build failed:"
        print result.stderr
        return false
    print "[cross] Sysroot ready"
    true

fn cross_build_stage(stage: text) -> bool:
    """Run a single cross-build stage via build.shs."""
    print "[cross] Running stage: {stage}"
    val result = process.run("sh", ["src/os/port/llvm/build.shs", stage])
    if result.exit_code != 0:
        print "[cross] Stage '{stage}' failed:"
        print result.stderr
        return false
    print "[cross] Stage '{stage}' complete"
    true

fn cross_build_stage_for_target(stage: text, triple: text) -> bool:
    """Run build.shs for a specific stage + SimpleOS target triple.

    The per-target build dir is `build/os/llvm/cross-<triple>` for the
    `cross` stage and `build/os/llvm/compiler-rt-<triple>` for the
    compiler-rt stage; build.shs reads SIMPLEOS_TARGET_TRIPLE to pick these.
    Guarded so only `-simpleos` triples flow through this helper.
    """
    if not triple.ends_with("-simpleos"):
        print "[cross] Skip non-SimpleOS triple: {triple}"
        return true

    print "[cross] Running stage '{stage}' for target {triple}"
    val env = [
        "SIMPLEOS_TARGET_TRIPLE={triple}",
        "SIMPLE_TARGET={triple}",
    ]
    val result = process.run_with_env(
        "sh",
        ["src/os/port/llvm/build.shs", stage],
        env,
    )
    if result.exit_code != 0:
        print "[cross] Stage '{stage}' failed for {triple}:"
        print result.stderr
        return false
    print "[cross] Stage '{stage}' complete for {triple}"
    true

fn build_compiler_rt_for_target(triple: text) -> bool:
    """Build compiler-rt builtins for one SimpleOS triple and install it
    into the clang resource directory at
    `build/os/sysroot/lib/clang/<version>/lib/<triple>/`.

    Delegates the cmake+ninja invocation to build.shs (stage compiler-rt)
    with SIMPLEOS_TARGET_TRIPLE set; this function then stages the
    resulting archives into the resource dir where the clang driver looks
    for them.
    """
    if not triple.ends_with("-simpleos"):
        print "[compiler-rt] Skip non-SimpleOS triple: {triple}"
        return true

    if not cross_build_stage_for_target(stage: "compiler-rt", triple: triple):
        return false

    # Stage archives into clang resource dir.
    val rt_dir = "build/os/llvm/compiler-rt-{triple}"
    val res_lib = "build/os/sysroot/lib/clang/{CLANG_RESOURCE_VERSION}/lib/{triple}"
    fs.mkdir_p(res_lib)
    val copy_script = "find {rt_dir} -name '*.a' -exec cp {{}} {res_lib}/ ';'"
    val result = process.run("sh", ["-c", copy_script])
    if result.exit_code != 0:
        print "[compiler-rt] Install copy failed for {triple}"
        print result.stderr
        return false
    print "[compiler-rt] Installed builtins for {triple} -> {res_lib}"
    true

## Public alias retained for callers / spec text matching.
fn build_compiler_rt(triple: text) -> bool:
    build_compiler_rt_for_target(triple)

fn cross_build_all(config: CrossBuildConfig) -> bool:
    """Run full cross-build pipeline for every selected SimpleOS target.

    Pipeline per triple:
      sysroot (once) -> host-tools (once) -> cross-<triple> -> compiler-rt-<triple>

    The set of triples comes from cross_selected_targets() which honours the
    SIMPLE_TARGET env override.
    """
    val targets = cross_selected_targets()
    print "[cross] Starting LLVM cross-build for SimpleOS"
    print "[cross] Source:  {config.llvm_src}"
    print "[cross] Build:   {config.build_dir}"
    print "[cross] Sysroot: {config.sysroot_dir}"
    print "[cross] Targets: {targets.len()}"
    for triple in targets:
        print "         - {triple}"

    # Step 1: Build sysroot (libc needed by cross-compile) — shared across targets.
    if not cross_build_sysroot():
        return false

    # Step 2: Host tblgen tools — shared across targets.
    if not cross_build_stage("host-tools"):
        print "[cross] Build failed at stage: host-tools"
        return false

    # Step 3-4: Per-target cross LLVM + compiler-rt builtins.
    for triple in targets:
        if not cross_build_stage_for_target(stage: "cross", triple: triple):
            print "[cross] Build failed at stage 'cross' for {triple}"
            return false
        if not build_compiler_rt_for_target(triple):
            print "[cross] Build failed at stage 'compiler-rt' for {triple}"
            return false

    print "[cross] Full LLVM cross-build complete!"
    print cross_build_status()
    true

fn cross_build_main(args: [text]):
    """Entry point for cross-build mode.

    Recognized flags:
      --stage <s>        Run a single stage (host-tools|cross|compiler-rt|sysroot)
      --status           Print multi-target build status
      --target <triple>  Single target override (alias for SIMPLE_TARGET)
      --targets <csv>    Comma-separated subset of CROSS_SUPPORTED_TARGETS
      --all              Build every triple in CROSS_SUPPORTED_TARGETS
      --print-plan       Print per-target build plan and exit
      --llvm-src <path>  Override llvm-project source path
      --help             Show this usage
    Subcommands (first positional):
      compiler-rt        Run the compiler-rt stage for the selected targets
    """
    print "=== SimpleOS LLVM Cross-Build ==="

    # Parse cross-build args
    var stage = ""
    var show_status = false
    var show_plan = false
    var show_help = false
    var want_all = false
    var subcommand = ""
    var target_triple = ""
    var targets_csv = ""
    var llvm_src = ""

    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--stage":
            i = i + 1
            stage = args[i]
        else if arg == "--status":
            show_status = true
        else if arg == "--print-plan":
            show_plan = true
        else if arg == "--help" or arg == "-h":
            show_help = true
        else if arg == "--all":
            want_all = true
        else if arg == "--target":
            i = i + 1
            target_triple = args[i]
        else if arg == "--targets":
            i = i + 1
            targets_csv = args[i]
        else if arg == "--llvm-src":
            i = i + 1
            llvm_src = args[i]
        else if arg == "compiler-rt" or arg == "cross" or arg == "host-tools" or arg == "sysroot":
            subcommand = arg
        i = i + 1

    if show_help:
        print "Usage: build.spl -- --cross [--stage S|--status|--print-plan|--all|--target T|--targets A,B]"
        print "Subcommands: host-tools | cross | compiler-rt | sysroot"
        return

    # Propagate --target / --targets to SIMPLE_TARGET so cross_selected_targets() sees it.
    if target_triple != "":
        process.set_env("SIMPLE_TARGET", target_triple)
    else if targets_csv != "":
        process.set_env("SIMPLE_TARGET", targets_csv)

    if show_status:
        print cross_build_status()
        return

    if show_plan:
        cross_build_print_plan()
        return

    # Subcommand form — runs a single stage for the selected target set.
    if subcommand != "":
        if subcommand == "sysroot":
            val ok = cross_build_sysroot()
            if not ok:
                process.exit(1)
            return
        val targets = cross_selected_targets()
        for triple in targets:
            if subcommand == "compiler-rt":
                if not build_compiler_rt_for_target(triple):
                    process.exit(1)
            else:
                if not cross_build_stage_for_target(stage: subcommand, triple: triple):
                    process.exit(1)
        return

    if stage != "":
        if stage == "sysroot":
            val ok = cross_build_sysroot()
            if not ok:
                process.exit(1)
        else:
            val targets = cross_selected_targets()
            for triple in targets:
                if not cross_build_stage_for_target(stage: stage, triple: triple):
                    process.exit(1)
        return

    # Full build (default or --all). --all simply clears any single-target filter.
    if want_all:
        process.set_env("SIMPLE_TARGET", "")

    var config = CrossBuildConfig.default()
    config = CrossBuildConfig(
        llvm_src: if llvm_src != "": llvm_src else: config.llvm_src,
        build_dir: config.build_dir,
        sysroot_dir: config.sysroot_dir,
        target_triple: if target_triple != "": target_triple else: config.target_triple,
    )
    val ok = cross_build_all(config)
    if not ok:
        process.exit(1)
    print "=== Cross-build finished successfully ==="
