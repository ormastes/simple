# DEPRECATED (desktop SimpleOS): this gate demands the static-relinked
# `clang_static`/`rustc_static` guest binaries — a stand-in for a real loader.
# The proper path is the general FS-exec loader launching an ordinary on-disk
# `x86_64-unknown-simpleos` ELF from /usr/bin/clang (or a SIMPLEOS_TOOLCHAIN_DIR
# env path). Kept only as a legacy fallback until the FS-exec lane (FR-SOS-020+,
# doc/02_requirements/os/simpleos/simpleos_os_subsystem_feature_requests.md) is
# complete. Do NOT build new desktop work on the static path. See
# doc/07_guide/os/simpleos_llvm_toolchain.md § "Desktop SimpleOS launch policy".
pub fn guest_toolchain_execution_gate_detail(clang_static_ready: bool, rustc_static_ready: bool, bake_enabled: bool) -> text:
    """Return READY or a concrete blocker list for real in-guest compiler execution.

    DEPRECATED on desktop SimpleOS (static-relink workaround; kept as legacy
    fallback until the FS-exec loader can launch /usr/bin/clang). See the banner
    above and the toolchain guide's launch-policy section.
    """
    var blockers: List<text> = []
    if not clang_static_ready:
        blockers = blockers + ["missing build/os/clang_static/bin/clang_static"]
    if not rustc_static_ready:
        blockers = blockers + ["missing build/os/rust_static/bin/rustc_static"]
    if not bake_enabled:
        blockers = blockers + ["build/os/.bake_include_toolchain not enabled"]
    if blockers.len() == 0:
        return "READY"
    "blocked: " + blockers.join("; ")
