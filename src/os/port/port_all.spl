## Top-level SimpleOS port dispatcher.
##
## Thin subcommand router that delegates to the per-stage scripts already
## living in `src/os/port/`. Kept deliberately small so that each real
## driver (initramfs packing, audit, verify, e2e) remains the source of
## truth.
##
## Usage:
##   bin/simple run src/os/port/port_all.spl -- <subcommand> [args...]
##
## Subcommands:
##   initramfs-pack     Pack the SimpleOS initramfs image.
##   bootstrap-cross    Cross-build the Simple compiler for SimpleOS.
##   bootstrap-verify   Verify a cross-built Simple toolchain.
##   audit-stubs        Audit auto-stub usage in a bootstrap binary.
##   verify-all         Run the pre-e2e verification phase matrix.
##   e2e-verify         Run the end-to-end QEMU verification orchestrator.

use std.process
use std.cli

val SUBCMDS: [(text, text)] = [
    ("initramfs-pack",   "src/os/port/initramfs_pack.spl"),
    ("bootstrap-cross",  "src/os/port/bootstrap_cross.spl"),
    ("bootstrap-verify", "src/os/port/bootstrap_verify.spl"),
    ("audit-stubs",      "src/os/port/audit_stubs.spl"),
    ("verify-all",       "src/os/port/verify_all.spl"),
    ("e2e-verify",       "src/os/port/e2e_verify.spl"),
]

fn usage():
    print "SimpleOS port dispatcher"
    print ""
    print "Usage: bin/simple run src/os/port/port_all.spl -- <subcommand> [args...]"
    print ""
    print "Subcommands:"
    for pair in SUBCMDS:
        val (name, target) = pair
        val pad = "                ".slice(0, 18 - name.len())
        print "  {name}{pad} -> {target}"

fn resolve(name: text) -> text:
    for pair in SUBCMDS:
        val (n, target) = pair
        if n == name:
            return target
    ""

fn main():
    val raw = cli.args()
    if raw.len() == 0 or raw[0] == "--help" or raw[0] == "-h":
        usage()
        return
    val sub = raw[0]
    val script = resolve(sub)
    if script == "":
        print "error: unknown subcommand: {sub}"
        usage()
        process.exit(2)

    var forwarded: [text] = ["run", script, "--"]
    var i = 1
    while i < raw.len():
        forwarded.push(raw[i])
        i = i + 1

    val result = process.run("bin/simple", forwarded)
    if result.stdout.len() > 0:
        print result.stdout
    if result.stderr.len() > 0:
        print result.stderr
    if result.exit_code != 0:
        process.exit(result.exit_code)
