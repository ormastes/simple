                "examples/simple_os/arch/x86_64/linker.ld",
                "build/os/simpleos_x86_64.elf",
                "512M",
                "",
                ["-device", "isa-debug-exit,iobase=0xf4,iosize=0x04", "-vga", "std"],
                10000,
                [],
                [],
                "",
                "build/os/simpleos_x86_64.elf"
            ),
            qemu_acceptance_lane: _lane_contract(
