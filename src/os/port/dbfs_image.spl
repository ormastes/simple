# Native DBFS rootfs image builder for SimpleOS port tests and boot media.
#
# Layout:
#   LBA 0-1  reserved for NVFS coexistence (left zeroed)
#   LBA 2-3  DBFS superblock replicas
#   LBA 4+   DBFS arena region

use std.fs_driver.mem_block_device.{MemBlockDevice}
use std.fs_driver.types.{OpenFlags, Path}
use std.db.dbfs_engine.superblock.{dbfs_superblock_set_device, dbfs_superblock_format_disk}
use std.db.dbfs_driver.dbfs_driver.{DbFsDriver}

pub struct PayloadEntry:
    """One file to seed into the DBFS root image."""
    name: text
    data: [u8]

pub struct DbfsImageConfig:
    """Configuration for a native DBFS rootfs image."""
    size_sectors: u64
    seeds: [PayloadEntry]

val DBFS_IMAGE_SECTOR_SIZE: u32 = 512u32
val DBFS_IMAGE_FIRST_ARENA_LBA: i64 = 4
val DBFS_IMAGE_MIN_SECTORS: u64 = 8u64
val DBFS_IMAGE_UUID_HI: u64 = 0x53494D504C454653u64
val DBFS_IMAGE_UUID_LO: u64 = 0x44424653524F4F54u64

fn _dbfs_image_valid_path(path: text) -> bool:
    if path == "" or not path.starts_with("/"):
        return false
    if path.contains(".."):
        return false
    true

fn _dbfs_image_seed_driver(driver: DbFsDriver, seeds: [PayloadEntry]) -> Result<(), text>:
    for seed in seeds:
        if not _dbfs_image_valid_path(seed.name):
            return Err("dbfs image seed path must be absolute and non-traversing: " + seed.name)
        val opened = driver.open_path(Path(raw: seed.name), OpenFlags.create_write())
        if opened.is_err():
            return Err("dbfs image seed open failed: " + seed.name)
        val handle = opened.unwrap()
        val wrote = driver.write_bytes_handle(handle, seed.data)
        if wrote.is_err():
            return Err("dbfs image seed write failed: " + seed.name)
        val closed = driver.close_handle(handle)
        if closed.is_err():
            return Err("dbfs image seed close failed: " + seed.name)
    Ok(())

pub fn _dbfs_image_mem_device(cfg: DbfsImageConfig) -> Result<MemBlockDevice, text>:
    """Build an in-memory native DBFS image."""
    if cfg.size_sectors < DBFS_IMAGE_MIN_SECTORS:
        return Err("dbfs image requires at least 8 sectors")
    val dev = MemBlockDevice.new(cfg.size_sectors, DBFS_IMAGE_SECTOR_SIZE)
    dbfs_superblock_set_device(dev)
    if not dbfs_superblock_format_disk(DBFS_IMAGE_UUID_HI, DBFS_IMAGE_UUID_LO):
        return Err("dbfs image superblock format failed")
    val arena_blocks = (cfg.size_sectors as i64) - DBFS_IMAGE_FIRST_ARENA_LBA
    val opened = DbFsDriver.open_on_device(dev, DBFS_IMAGE_FIRST_ARENA_LBA, arena_blocks)
    if opened.is_err():
        return Err("dbfs image driver open failed")
    val seeded = _dbfs_image_seed_driver(opened.unwrap(), cfg.seeds)
    if seeded.is_err():
        return seeded
    Ok(dev)

pub fn build_dbfs_rootfs_image(cfg: DbfsImageConfig, output_path: text) -> Result<bool, text>:
    """Build a native DBFS rootfs raw image and write it to output_path."""
    if output_path == "":
        return Err("dbfs image output path is empty")
    val dev_result = _dbfs_image_mem_device(cfg)
    if dev_result.is_err():
        return Err(dev_result.unwrap_err())
    dev_result.unwrap().write_to_file(output_path)
