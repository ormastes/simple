            clang_target: "i686-unknown-none-elf",
            qemu_system: "qemu-system-i386",
            qemu_machine: "pc",
            qemu_cpu: "qemu32",
            qemu_serial_kind: "com1",
            qemu_serial_base: 0x3F8u64,
            linker_script: "src/os/kernel/arch/x86_32/linker.ld",
            default_entry: "src/os/kernel/arch/x86_32/boot.spl",
