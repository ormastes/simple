# SimpleOS Multi-Platform Build Catalog
#
# Centralizes target triples, C/ASM boot inputs, and freestanding compiler
# flags for SimpleOS kernel and boot-wrapper binaries.

use os.kernel.arch.arch_context.{Architecture}

enum SimpleOsNativeImplementationKind:
    Simple
    EmbeddedAsm
    StandaloneAsm
    NativeC
    NativeObject

enum SimpleOsStandaloneAsmPolicy:
    Disallowed
    EntryStubsOnly
    BroadNativeSurface

class SimpleOsPlatformBuildTarget:
    name: text
    aliases: [text]
    arch: Architecture
    arch_name: text
    bits: i64
    isa: text
    abi: text
    float_abi: text
    native_target: text
    clang_target: text
    qemu_system: text
    qemu_machine: text
    qemu_cpu: text
    qemu_serial_kind: text
    qemu_serial_base: u64
    linker_script: text
    default_entry: text
    output: text
    platform_slug: text
    kernel_output: text
    disk_image_output: text
    source_roots: [text]
    boot_c_sources: [text]
    boot_asm_sources: [text]
    grandfathered_native_sources: [text]
    boot_impl_kind: SimpleOsNativeImplementationKind
    runtime_impl_kind: SimpleOsNativeImplementationKind
    standalone_asm_policy: SimpleOsStandaloneAsmPolicy
    c_flags: [text]
    asm_flags: [text]
    link_flags: [text]
    notes: text

fn _common_c_flags(clang_target: text) -> [text]:
    [
        "--target={clang_target}",
        "-ffreestanding",
        "-nostdlib",
        "-fno-builtin",
        "-fno-stack-protector",
        "-fno-exceptions",
        "-fno-unwind-tables",
        "-fno-asynchronous-unwind-tables",
        "-O2"
    ]

fn _common_asm_flags(clang_target: text) -> [text]:
    [
        "--target={clang_target}",
        "-ffreestanding"
    ]

fn _x86_32_c_flags() -> [text]:
    var flags = _common_c_flags("i686-unknown-none-elf")
    flags.push("-m32")
    flags.push("-march=i686")
    flags.push("-mno-sse")
    flags.push("-mno-mmx")
    flags.push("-fno-pic")
    flags.push("-DSIMPLEOS_ARCH_X86_32=1")
    flags

fn _x86_32_asm_flags() -> [text]:
    var flags = _common_asm_flags("i686-unknown-none-elf")
    flags.push("-m32")
    flags.push("-march=i686")
    flags

fn _x86_64_c_flags() -> [text]:
    var flags = _common_c_flags("x86_64-unknown-none-elf")
    flags.push("-mno-red-zone")
    flags.push("-DSIMPLEOS_ARCH_X86_64=1")
    flags

fn _aarch64_c_flags() -> [text]:
    var flags = _common_c_flags("aarch64-unknown-none-elf")
    flags.push("-DSIMPLEOS_ARCH_AARCH64=1")
    flags

fn _arm32_c_flags() -> [text]:
    var flags = _common_c_flags("armv7-unknown-none-eabihf")
    flags.push("-DSIMPLEOS_ARCH_ARM32=1")
    flags

fn _riscv64_c_flags() -> [text]:
    var flags = _common_c_flags("riscv64-unknown-none-elf")
    flags.push("-march=rv64gc")
    flags.push("-mabi=lp64d")
    flags.push("-DSIMPLEOS_ARCH_RISCV64=1")
    flags

fn _riscv32_c_flags() -> [text]:
    var flags = _common_c_flags("riscv32-unknown-none-elf")
    flags.push("-march=rv32imac")
    flags.push("-mabi=ilp32")
    flags.push("-DSIMPLEOS_ARCH_RISCV32=1")
    flags

fn simpleos_platform_targets() -> [SimpleOsPlatformBuildTarget]:
    """Return all first-class SimpleOS binary build targets."""
    [
        SimpleOsPlatformBuildTarget(
            name: "x86_64-simpleos",
            aliases: ["x86_64", "amd64", "x64"],
            arch: Architecture.X86_64,
            arch_name: "x86_64",
            bits: 64,
            isa: "x86_64",
            abi: "sysv",
            float_abi: "sse2",
            native_target: "x86_64-unknown-none",
            clang_target: "x86_64-unknown-none-elf",
            qemu_system: "qemu-system-x86_64",
            qemu_machine: "q35",
            qemu_cpu: "qemu64",
            qemu_serial_kind: "com1",
            qemu_serial_base: 0x3F8u64,
            linker_script: "examples/simple_os/arch/x86_64/linker.ld",
            default_entry: "examples/simple_os/arch/x86_64/os_entry.spl",
            output: "build/os/simpleos_x86_64.elf",
            platform_slug: "x86_64",
            kernel_output: "build/os/simpleos_x86_64.elf",
            disk_image_output: "build/os/fat32-x86_64.img",
            source_roots: ["src", "examples"],
            boot_c_sources: ["examples/simple_os/arch/x86_64/boot/baremetal_stubs.c"],
            boot_asm_sources: ["examples/simple_os/arch/x86_64/boot/crt0.s"],
            grandfathered_native_sources: [
                "examples/simple_os/arch/x86_64/boot/ap_trampoline.s",
                "examples/simple_os/arch/x86_64/boot/auto_stubs.c",
