fn simpleos_platform_target_matches(target: SimpleOsPlatformBuildTarget, name: text) -> bool:
    if target.name == name:
        return true
    if target.native_target == name:
        return true
    if target.clang_target == name:
        return true
    for alias in target.aliases:
        if alias == name:
            return true
    false

fn simpleos_platform_target_by_name(name: text) -> SimpleOsPlatformBuildTarget?:
    """Resolve a SimpleOS platform target by canonical name, triple, or alias."""
    for target in simpleos_platform_targets():
        if simpleos_platform_target_matches(target, name):
            return target
    nil

fn simpleos_platform_target_names() -> [text]:
    """Return canonical SimpleOS platform target names."""
    var names: [text] = []
    for target in simpleos_platform_targets():
        names.push(target.name)
    names

fn simpleos_platform_artifact_slug(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.platform_slug
    "unknown"

fn simpleos_platform_kernel_output(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.kernel_output
    "build/os/simpleos_unknown.elf"

fn simpleos_platform_disk_image_output(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.disk_image_output
    "build/os/fat32-unknown.img"

fn simpleos_platform_c_flags(name: text) -> [text]:
    if val target = simpleos_platform_target_by_name(name):
        return target.c_flags
    _x86_64_c_flags()

fn simpleos_platform_asm_flags(name: text) -> [text]:
    if val target = simpleos_platform_target_by_name(name):
        return target.asm_flags
    _common_asm_flags("x86_64-unknown-none-elf")

fn simpleos_platform_boot_c_sources(name: text) -> [text]:
    if val target = simpleos_platform_target_by_name(name):
        return target.boot_c_sources
    []

fn simpleos_platform_boot_asm_sources(name: text) -> [text]:
    if val target = simpleos_platform_target_by_name(name):
        return target.boot_asm_sources
    []

fn simpleos_platform_grandfathered_native_sources(name: text) -> [text]:
    if val target = simpleos_platform_target_by_name(name):
        return target.grandfathered_native_sources
    []

fn simpleos_platform_default_entry(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.default_entry
    "src/os/kernel/arch/x86_64/boot.spl"

fn simpleos_platform_linker_script(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.linker_script
    "src/os/kernel/arch/x86_64/linker.ld"

fn simpleos_platform_clang_target(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.clang_target
    "x86_64-unknown-none-elf"

fn simpleos_platform_native_target(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.native_target
    "x86_64-unknown-none"

fn simpleos_platform_qemu_system(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.qemu_system
    "qemu-system-x86_64"

fn simpleos_platform_qemu_machine(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.qemu_machine
    "q35"

fn simpleos_platform_qemu_cpu(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.qemu_cpu
    "qemu64"

fn simpleos_platform_arch_name(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.arch_name
    "unknown"

fn simpleos_platform_isa(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.isa
    "unknown"

fn simpleos_platform_abi(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.abi
    "unknown"

fn simpleos_platform_float_abi(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.float_abi
    "unknown"

fn simpleos_platform_needs_soft_float_runtime(name: text) -> bool:
    if val target = simpleos_platform_target_by_name(name):
        return target.float_abi == "soft"
    false

fn simpleos_platform_boot_impl_kind(name: text) -> SimpleOsNativeImplementationKind:
    if val target = simpleos_platform_target_by_name(name):
        return target.boot_impl_kind
    SimpleOsNativeImplementationKind.NativeC

fn simpleos_platform_runtime_impl_kind(name: text) -> SimpleOsNativeImplementationKind:
    if val target = simpleos_platform_target_by_name(name):
        return target.runtime_impl_kind
    SimpleOsNativeImplementationKind.NativeC

fn simpleos_platform_standalone_asm_policy(name: text) -> SimpleOsStandaloneAsmPolicy:
    if val target = simpleos_platform_target_by_name(name):
        return target.standalone_asm_policy
    SimpleOsStandaloneAsmPolicy.BroadNativeSurface
