# Serial completion contract for the Phase-1 user-exec acceptance payload.
#
# The `hello.elf` payload (built by scripts/os/build_user_hello_elf.shs) makes
# exactly two raw syscalls: write(1,"USEROK\n",7) then exit(0). It is decoupled
# from the compiler/libc toolchain (Blocker 2) on purpose — a single `USEROK`
# line on serial is the EARLIEST real proof that the Phase-1 kernel exec
# keystone (live ring-3 handoff into a prepared user task) works.
#
# This contract flips green at a DIFFERENT gate than the toolchain-exec probe:
# it depends on Phase-1 exec ONLY, not on any clang payload.

pub fn user_hello_exec_marker() -> text:
    "USEROK"

pub fn user_hello_exec_serial_accepts_completion(serial_output: text) -> bool:
    serial_output.contains(user_hello_exec_marker())
