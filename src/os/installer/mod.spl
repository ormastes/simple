# SimpleOS Installer Module
# MDSOC: feature dimension, apps layer
#
# Provides disk image creation, USB installer, and release pipeline.
#
# Submodules:
#   image_builder     — Create bootable disk/USB images
#   usb_installer     — Interactive OS installation from USB
#   release_pipeline  — End-to-end release orchestration

use os.installer.image_builder.{
    ImageConfig, ImageBuilder, PartitionLayout,
    build_usb_installer_image, build_install_image,
    run_image_builder
}

use os.installer.usb_installer.{
    DetectedDisk, PartitionPlan,
    detect_disks, run_installer, run_upgrade,
    run_usb_installer
}

use os.installer.release_pipeline.{
    ReleaseConfig, default_release_config,
    release_all, release_packages, release_usb,
    run_release
}
