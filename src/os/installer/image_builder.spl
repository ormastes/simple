# OS Image Builder — staged filesystem trees + artifact manifests
# MDSOC: feature dimension, apps layer
#
# The previous implementation only appended metadata into `.img` files.
# This builder now materializes concrete filesystem trees under
# `<artifact>.contents/`, writes a deployed-files manifest, and produces
# release-facing artifact descriptors. For the x86_64 install image lane it
# also reuses `scripts/os/make_os_disk.shs` to emit a runnable FAT32 image for
# QEMU while keeping the staged tree as the source of truth for deployment.

use os.packages.os_packages.{list_all_packages}
use os.tools.pkg.pkg_format.{
    ExtendedManifest, PkgArch, PackageType,
    pkg_arch_to_text, pkg_arch_from_text
}
use os.port.font_bundle.{simpleos_font_bundle_entries, load_simpleos_font_bundle_entry}

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_env_get(key: text) -> text?
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_read_bytes(path: text) -> [u8]
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_write_bytes(path: text, content: [u8]) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_dir_list(path: text) -> [text]

# === Image Constants ===

val DEFAULT_IMAGE_SIZE_MB: u64 = 512
val EFI_PARTITION_SIZE_MB: u64 = 64

val _ROOT_LAYOUT = [
    "/boot",
    "/boot/efi",
    "/bin",
    "/sbin",
    "/etc",
    "/etc/shell",
    "/etc/pkg",
    "/etc/registry",
    "/lib",
    "/usr",
    "/usr/bin",
    "/usr/sbin",
    "/usr/lib",
    "/usr/libexec",
    "/usr/libexec/simpleos-installer",
    "/usr/libexec/simpleos-installer/kernel",
    "/usr/libexec/simpleos-installer/packages",
    "/usr/local",
    "/usr/local/bin",
    "/usr/local/lib",
    "/usr/local/share",
    "/usr/local/share/themes",
    "/var",
    "/var/cache",
    "/var/cache/pkg",
    "/var/db",
    "/var/db/pkg",
    "/var/db/pkg/installed",
    "/var/log",
    "/tmp",
    "/home"
]

val _SIMPLE_TOOLCHAIN_ROLE_PATHS: [text] = [
    "/bin/simple",
    "/bin/simple.smf",
    "/usr/bin/simple",
    "/usr/bin/simple.smf",
    "/sys/apps/simple",
    "/sys/apps/simple.smf",
    "/sys/apps/simple_compiler",
    "/sys/apps/simple_compiler.smf",
    "/sys/apps/simple_interpreter",
    "/sys/apps/simple_interpreter.smf",
    "/sys/apps/simple_loader",
    "/sys/apps/simple_loader.smf",
]

# Real guest-native clang toolchain payload. When the static clang binary and
# the sysroot are present on the host we embed the actual toolchain into the
# image; otherwise we fall back to the fixture manifest that the package layer
# already stages. Guest paths use the lowercase /sys/apps/clang the fixtures use
# so the real binary OVERWRITES the placeholder rather than duplicating it.
val _CLANG_STATIC_CANDIDATES: [text] = [
    "build/os/clang_static/bin/clang_static",
    "build/os/clang_static/bin/clang",
]

val _RUSTC_STATIC_CANDIDATES: [text] = [
    "build/os/rust_static/bin/rustc_static",
    "build/os/rustc_static/bin/rustc_static",
]

val _SIMPLEOS_SYSROOT_DIR: text = "build/os/sysroot"

val _CLANG_GUEST_BIN_PATHS: [text] = [
    "/usr/bin/clang",
    "/sys/apps/clang",
]

val _RUSTC_GUEST_BIN_PATHS: [text] = [
    "/usr/bin/rustc",
    "/sys/apps/rust",
]

struct ImageConfig:
    arch: PkgArch
    output_path: text
    image_size_mb: u64
    kernel_path: text
    bootloader_config: text
    package_dir: text
    simple_binary: text
    include_installer: bool

struct PartitionLayout:
    efi_start_sector: u64
    efi_size_sectors: u64
    root_start_sector: u64
    root_size_sectors: u64
    total_sectors: u64

var _image_builder_rootfs_backend: text = "fat32"

class ImageBuilder:
    config: ImageConfig
    layout: PartitionLayout

impl ImageBuilder:
    static fn new(config: ImageConfig) -> ImageBuilder:
        val layout = _compute_layout(config.image_size_mb)
        ImageBuilder(config: config, layout: layout)

    fn build() -> Result<text, text>:
        val arch_name = pkg_arch_to_text(self.config.arch)
        val artifact_kind = if self.config.include_installer: "installer-dvd" else: "disk-image"
        val simple_binary = _effective_simple_binary(self.config)
        if simple_binary != "":
            val simple_check = _validate_simple_binary(simple_binary, self.config.arch)
            if val Err(e) = simple_check:
                return Err(e)
        var font_guest_paths: [text] = []
        var font_blobs: [[u8]] = []
        for entry in simpleos_font_bundle_entries():
            val loaded = load_simpleos_font_bundle_entry(entry)
            if not loaded.valid:
                return Err("SimpleOS font bundle entry invalid: " + loaded.reason)
            font_guest_paths.push(entry.guest_long_path)
            font_blobs.push(loaded.data)
        print "Creating {artifact_kind}: {self.config.output_path}"
        print "  Architecture: {arch_name}"
        print "  Size: {self.config.image_size_mb} MB"

        val staging_root = _staging_root(self.config.output_path)
        val efi_root = "{staging_root}/efi"
        val rootfs_root = "{staging_root}/rootfs"
        val reports_root = "{staging_root}/reports"

        _ensure_dir(staging_root)
        _ensure_dir(efi_root)
        _ensure_dir(rootfs_root)
        _ensure_dir(reports_root)

        var deploy_manifest = _manifest_header(self.config, self.layout)
        deploy_manifest = deploy_manifest + self._populate_efi_partition(efi_root)
        val root_manifest = self._populate_root_partition(rootfs_root, font_guest_paths, font_blobs)?
        deploy_manifest = deploy_manifest + root_manifest

        if self.config.include_installer:
            deploy_manifest = deploy_manifest + self._populate_install_media(rootfs_root)

        val manifest_path = "{reports_root}/deployed-files.sdn"
        write_text(manifest_path, deploy_manifest)
        write_text(_sidecar_manifest_path(self.config.output_path), deploy_manifest)

        val artifact_result = self._materialize_primary_artifact(manifest_path)
        if val Err(e) = artifact_result:
            return Result.Err(e)

        print "  Staged filesystem: {rootfs_root}"
        print "  Deploy manifest: {manifest_path}"
        print "Image created: {self.config.output_path}"
        Result.Ok(self.config.output_path)

    fn _populate_efi_partition(efi_root: text) -> text:
        _ensure_dir("{efi_root}/EFI")
        _ensure_dir("{efi_root}/EFI/BOOT")
        _ensure_dir("{efi_root}/simpleos")

        val kernel_text = _kernel_payload(self.config.kernel_path, self.config.arch)
        write_text("{efi_root}/kernel.elf", kernel_text)
        write_text("{efi_root}/limine.cfg", _effective_bootloader_config(self.config))

        var manifest = ""
        manifest = manifest + _manifest_file("/boot/kernel.elf", "efi-kernel", "simpleos-kernel")
        manifest = manifest + _manifest_file("/boot/limine.cfg", "bootloader-config", "simpleos-kernel")
        manifest

    fn _populate_root_partition(rootfs_root: text, font_guest_paths: [text], font_blobs: [[u8]]) -> Result<text, text>:
        if font_guest_paths.len() != font_blobs.len():
            return Err("SimpleOS font asset staging input mismatch")
        for dir in _ROOT_LAYOUT:
            _ensure_dir("{rootfs_root}{dir}")

        write_text("{rootfs_root}/etc/hostname", "simpleos\n")
        write_text("{rootfs_root}/etc/fstab", _fstab_template())
        write_text("{rootfs_root}/etc/rc.conf", _rc_conf_template())
        write_text("{rootfs_root}/etc/pkg/repos.sdn", _pkg_repo_template())
        write_text("{rootfs_root}/etc/shell/profile.sdn", "shell = \"/bin/shell\"\n")
        write_text("{rootfs_root}/etc/rootfs.sdn", _rootfs_backend_payload(_image_builder_rootfs_backend))
        write_text("{rootfs_root}/sbin/init", _init_payload())
        write_text("{rootfs_root}/boot/kernel.elf", _kernel_payload(self.config.kernel_path, self.config.arch))
        write_text("{rootfs_root}/bin/simplebox", _simplebox_payload())
        _ensure_dir("{rootfs_root}/SYS")
        write_text("{rootfs_root}/SYS/ROOTFS.CFG", _rootfs_boot_marker_payload(_image_builder_rootfs_backend))

        var manifest = ""
        manifest = manifest + _manifest_file("/etc/hostname", "system-config", "simpleos-core")
        manifest = manifest + _manifest_file("/etc/fstab", "system-config", "simpleos-core")
        manifest = manifest + _manifest_file("/etc/rc.conf", "system-config", "simpleos-core")
        manifest = manifest + _manifest_file("/etc/pkg/repos.sdn", "pkg-config", "simpleos-tools")
        manifest = manifest + _manifest_file("/etc/shell/profile.sdn", "shell-config", "simpleos-shell")
        manifest = manifest + _manifest_file("/etc/rootfs.sdn", "rootfs-config", "simpleos-core")
        manifest = manifest + _manifest_file("/sbin/init", "runtime-init", "simpleos-core")
        manifest = manifest + _manifest_file("/boot/kernel.elf", "runtime-kernel", "simpleos-kernel")
        manifest = manifest + _manifest_file("/bin/simplebox", "userland-tool", "simpleos-core")
        manifest = manifest + _manifest_file("/SYS/ROOTFS.CFG", "rootfs-boot-marker", "simpleos-core")

        val packages = list_all_packages(self.config.arch)
        for pkg in packages:
            manifest = manifest + self._deploy_package(rootfs_root, pkg)

        manifest = manifest + self._stage_simple_toolchain_payload(rootfs_root)
        manifest = manifest + self._stage_clang_toolchain_payload(rootfs_root)
        manifest = manifest + self._stage_rust_toolchain_payload(rootfs_root)
        var font_index: i64 = 0
        while font_index < font_guest_paths.len() and font_index < font_blobs.len():
            val font_path = font_guest_paths[font_index]
            _ensure_parent_dirs(rootfs_root, font_path)
            if not rt_file_write_bytes(rootfs_root + font_path, font_blobs[font_index]):
                return Err("SimpleOS font asset staging failed: " + font_path)
            val kind = if font_path.ends_with(".ttf"): "font-asset" else: "font-notice"
            manifest = manifest + _manifest_file(font_path, kind, "simpleos-core")
            font_index = font_index + 1
        Ok(manifest)

    fn _stage_simple_toolchain_payload(rootfs_root: text) -> text:
        val simple_binary = _effective_simple_binary(self.config)
        if simple_binary == "":
            return ""
        if not rt_file_exists(simple_binary):
            return _manifest_file("/SYS/SIMPLETOOL.SDN", "simple-toolchain-missing", "simpleos-tools")

        var manifest = ""
        for guest_path in _SIMPLE_TOOLCHAIN_ROLE_PATHS:
            val target_path = "{rootfs_root}{guest_path}"
            _ensure_parent_dirs(rootfs_root, guest_path)
            val ok = _copy_file(simple_binary, target_path)
            if ok:
                manifest = manifest + _manifest_file(guest_path, "simple-toolchain-role", "simpleos-tools")

        _ensure_dir("{rootfs_root}/SYS")
        write_text("{rootfs_root}/SYS/SIMPLETOOL.SDN", _simple_toolchain_manifest_payload(simple_binary))
        manifest = manifest + _manifest_file("/SYS/SIMPLETOOL.SDN", "simple-toolchain-manifest", "simpleos-tools")
        manifest

    # Embed the REAL guest-native clang toolchain when build/os/clang_static is
    # present; otherwise leave the package-staged fixture in place and record a
    # clear "fixture: clang_static not built" marker. The clang binary is large,
    # so it is copied with `cp` rather than read into a Simple buffer; the 2000+
    # header sysroot is bulk-copied with `cp -a`.
    fn _stage_clang_toolchain_payload(rootfs_root: text) -> text:
        val clang_binary = _effective_clang_binary()
        if clang_binary == "" or not rt_file_exists(clang_binary):
            _ensure_dir("{rootfs_root}/SYS")
            write_text("{rootfs_root}/SYS/CLANGTOOL.SDN", _clang_toolchain_fixture_payload())
            return _manifest_file("/SYS/CLANGTOOL.SDN", "clang-toolchain-fixture", "simpleos-tools")

        var manifest = ""
        for guest_path in _CLANG_GUEST_BIN_PATHS:
            _ensure_parent_dirs(rootfs_root, guest_path)
            if _copy_file(clang_binary, "{rootfs_root}{guest_path}"):
                manifest = manifest + _manifest_file(guest_path, "clang-toolchain-binary", "simpleos-tools")

        val sysroot = _effective_sysroot_dir()
        var sysroot_embedded = false
        if sysroot != "" and rt_file_exists(sysroot):
            _ensure_dir("{rootfs_root}/usr/lib")
            _ensure_dir("{rootfs_root}/usr/share/simpleos")
            val libs_ok = _copy_tree("{sysroot}/lib", "{rootfs_root}/usr/lib")
            val sysroot_ok = _copy_tree(sysroot, "{rootfs_root}/usr/share/simpleos")
            sysroot_embedded = libs_ok and sysroot_ok
            if libs_ok:
                manifest = manifest + _manifest_file("/usr/lib", "clang-sysroot-libs", "simpleos-tools")
            if sysroot_ok:
                manifest = manifest + _manifest_file("/usr/share/simpleos", "clang-sysroot", "simpleos-tools")

        _ensure_dir("{rootfs_root}/SYS")
        write_text("{rootfs_root}/SYS/CLANGTOOL.SDN", _clang_toolchain_embedded_payload(clang_binary, sysroot, sysroot_embedded))
        manifest = manifest + _manifest_file("/SYS/CLANGTOOL.SDN", "clang-toolchain-manifest", "simpleos-tools")
        manifest

    # Optional symmetric rustc_static embedding — shares the clang sysroot.
    fn _stage_rust_toolchain_payload(rootfs_root: text) -> text:
        val rustc_binary = _effective_rustc_binary()
        if rustc_binary == "" or not rt_file_exists(rustc_binary):
            _ensure_dir("{rootfs_root}/SYS")
            write_text("{rootfs_root}/SYS/RUSTTOOL.SDN", _rust_toolchain_fixture_payload())
            return _manifest_file("/SYS/RUSTTOOL.SDN", "rust-toolchain-fixture", "simpleos-tools")

        var manifest = ""
        for guest_path in _RUSTC_GUEST_BIN_PATHS:
            _ensure_parent_dirs(rootfs_root, guest_path)
            if _copy_file(rustc_binary, "{rootfs_root}{guest_path}"):
                manifest = manifest + _manifest_file(guest_path, "rust-toolchain-binary", "simpleos-tools")

        _ensure_dir("{rootfs_root}/SYS")
        write_text("{rootfs_root}/SYS/RUSTTOOL.SDN", _rust_toolchain_embedded_payload(rustc_binary))
        manifest = manifest + _manifest_file("/SYS/RUSTTOOL.SDN", "rust-toolchain-manifest", "simpleos-tools")
        manifest

    fn _populate_install_media(rootfs_root: text) -> text:
        val installer_root = "{rootfs_root}/usr/libexec/simpleos-installer"
        _ensure_dir(installer_root)
        _ensure_dir("{installer_root}/kernel")
        _ensure_dir("{installer_root}/packages")

        write_text("{installer_root}/installer", _installer_payload(self.config.arch))
        write_text("{installer_root}/kernel/kernel.elf", _kernel_payload(self.config.kernel_path, self.config.arch))

        var manifest = ""
        manifest = manifest + _manifest_file("/usr/libexec/simpleos-installer/installer", "install-media", "simpleos-installer")
        manifest = manifest + _manifest_file("/usr/libexec/simpleos-installer/kernel/kernel.elf", "install-media-kernel", "simpleos-installer")

        if self.config.package_dir != "":
            val entries = readdir(self.config.package_dir)
            for entry in entries:
                if entry.ends_with(".spk"):
                    val content = read_text("{self.config.package_dir}/{entry}")
                    write_text("{installer_root}/packages/{entry}", content)
                    manifest = manifest + _manifest_file("/usr/libexec/simpleos-installer/packages/{entry}", "install-package", "simpleos-installer")
        manifest

    fn _deploy_package(rootfs_root: text, pkg: ExtendedManifest) -> text:
        var manifest = ""
        if pkg.pkg_type == PackageType.Meta:
            write_text("{rootfs_root}/var/db/pkg/installed/{pkg.base.name}.sdn", "# meta-package\nname = \"{pkg.base.name}\"\n")
            return _manifest_file("/var/db/pkg/installed/{pkg.base.name}.sdn", "pkg-db", pkg.base.name)

        for file_path in pkg.base.files:
            if file_path == "":
                continue
            if file_path.ends_with("/"):
                _ensure_dir("{rootfs_root}{file_path}")
                manifest = manifest + _manifest_dir(file_path, pkg.base.name)
            else:
                _write_placeholder_payload(rootfs_root, file_path, pkg, self.config.arch)
                manifest = manifest + _manifest_file(file_path, "package-payload", pkg.base.name)
        write_text("{rootfs_root}/var/db/pkg/installed/{pkg.base.name}.sdn", _installed_pkg_record(pkg))
        manifest = manifest + _manifest_file("/var/db/pkg/installed/{pkg.base.name}.sdn", "pkg-db", pkg.base.name)
        manifest

    fn _materialize_primary_artifact(manifest_path: text) -> Result<bool, text>:
        if self.config.arch == PkgArch.X86_64 and not self.config.include_installer:
            val args = [
                "-c",
                _make_os_disk_command(self.config)
            ]
            val (stdout, stderr, exit_code) = rt_process_run_timeout("/bin/sh", args, 120000)
            if stdout != "":
                print stdout.trim()
            if stderr != "":
                print stderr.trim()
            if exit_code == 0 and rt_file_exists(self.config.output_path):
                return Result.Ok(true)
            return Result.Err("FAT32 disk generation failed; refusing non-bootable descriptor fallback")
        _write_artifact_descriptor(self.config, self.layout, manifest_path)
        Result.Ok(true)

fn build_usb_installer_image(
    arch: PkgArch,
    kernel_path: text,
    package_dir: text,
    output_path: text,
    size_mb: u64
) -> Result<text, text>:
    val config = ImageConfig(
        arch: arch,
        output_path: output_path,
        image_size_mb: if size_mb > 0: size_mb else: DEFAULT_IMAGE_SIZE_MB,
        kernel_path: kernel_path,
        bootloader_config: _installer_bootloader_config(arch),
        package_dir: package_dir,
        simple_binary: "",
        include_installer: true
    )
    _image_builder_rootfs_backend = "fat32"
    ImageBuilder.new(config).build()

fn build_usb_installer_image_with_rootfs(
    arch: PkgArch,
    kernel_path: text,
    package_dir: text,
    output_path: text,
    size_mb: u64,
    rootfs_backend: text
) -> Result<text, text>:
    val config = ImageConfig(
        arch: arch,
        output_path: output_path,
        image_size_mb: if size_mb > 0: size_mb else: DEFAULT_IMAGE_SIZE_MB,
        kernel_path: kernel_path,
        bootloader_config: _installer_bootloader_config(arch),
        package_dir: package_dir,
        simple_binary: "",
        include_installer: true
    )
    _image_builder_rootfs_backend = _normalized_rootfs_backend(rootfs_backend)
    ImageBuilder.new(config).build()

