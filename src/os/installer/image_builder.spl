fn _print_image_usage():
    print "Usage: image-builder create [OPTIONS]"
    print ""
    print "Options:"
    print "  --arch=ARCH       Target architecture (x86_64, arm64, riscv64, riscv32)"
    print "  --output=PATH     Output artifact path (default: simpleos.img)"
    print "  --size=SIZE       Image size in MB (default: 512)"
    print "  --kernel=PATH     Path to kernel ELF binary"
    print "  --packages=DIR    Directory containing .spk packages"
    print "  --simple-binary=PATH  Target-native SimpleOS Simple ELF/SMF payload"
    print "  --rootfs=NAME     Runtime rootfs backend marker (fat32, dbfs, nvfs)"
    print "  --installer       Build install-media artifact"
    print "  -h                Show this help"

fn run_image_builder(args: [text]) -> i32:
    for arg in args:
        if arg == "-h":
            _print_image_usage()
            return 0
    if args.len() < 1 or args[0] != "create":
        _print_image_usage()
        return 1

    var arch_str = "x86_64"
    var output = "simpleos.img"
    var size_mb: u64 = DEFAULT_IMAGE_SIZE_MB
    # NOTE: local must not be named `kernel` — a local shadowed by the
    # `os.kernel` module name fails HIR lowering / interp semantic analysis.
    # See doc/08_tracking/bug/local_var_kernel_shadowed_by_module_2026-07-06.md
    var kernel_elf = ""
    var packages = ""
    var simple_binary = ""
    var installer = false
    var rootfs_backend = "fat32"

    var i = 1
    while i < args.len():
        val arg = args[i]
        if arg.starts_with("--arch="):
            arch_str = arg.slice(7, arg.len())
        else if arg.starts_with("--output="):
            output = arg.slice(9, arg.len())
        else if arg.starts_with("--size="):
            size_mb = arg.slice(7, arg.len()).to_u64()
        else if arg.starts_with("--kernel="):
            kernel_elf = arg.slice(9, arg.len())
        else if arg.starts_with("--packages="):
            packages = arg.slice(11, arg.len())
        else if arg.starts_with("--simple-binary="):
            simple_binary = arg.slice(16, arg.len())
        else if arg.starts_with("--rootfs="):
            rootfs_backend = arg.slice(9, arg.len())
        else if arg == "--installer":
            installer = true
        i = i + 1

    val arch_result = pkg_arch_from_text(arch_str)
    if val Err(e) = arch_result:
        print "Error: {e}"
        return 1
    val arch = arch_result.unwrap()

    val result = if installer:
        val config = ImageConfig(
            arch: arch,
            output_path: output,
            image_size_mb: if size_mb > 0: size_mb else: DEFAULT_IMAGE_SIZE_MB,
            kernel_path: kernel_elf,
            bootloader_config: _installer_bootloader_config(arch),
            package_dir: packages,
            simple_binary: simple_binary,
            include_installer: true
        )
        _image_builder_rootfs_backend = _normalized_rootfs_backend(rootfs_backend)
        ImageBuilder.new(config).build()
    else:
        val config = ImageConfig(
            arch: arch,
            output_path: output,
            image_size_mb: if size_mb > 0: size_mb else: DEFAULT_IMAGE_SIZE_MB,
            kernel_path: kernel_elf,
            bootloader_config: "",
            package_dir: packages,
            simple_binary: simple_binary,
            include_installer: false
        )
        _image_builder_rootfs_backend = _normalized_rootfs_backend(rootfs_backend)
        ImageBuilder.new(config).build()

    if val Ok(path) = result:
        print "Artifact created: {path}"
        return 0
    else if val Err(e) = result:
        print "Error: {e}"
        return 1
    0

fn _compute_layout(image_size_mb: u64) -> PartitionLayout:
    val total_sectors = (image_size_mb * 1024 * 1024) / 512
    val efi_start: u64 = 2048
    val efi_sectors = (EFI_PARTITION_SIZE_MB * 1024 * 1024) / 512
    val root_start = efi_start + efi_sectors
    val root_sectors = total_sectors - root_start - 2048
    PartitionLayout(
        efi_start_sector: efi_start,
        efi_size_sectors: efi_sectors,
        root_start_sector: root_start,
        root_size_sectors: root_sectors,
        total_sectors: total_sectors
    )

fn _staging_root(output_path: text) -> text:
    "{output_path}.contents"

fn _sidecar_manifest_path(output_path: text) -> text:
    "{output_path}.manifest.sdn"

fn read_text(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn write_text(path: text, content: text):
    val _ok = rt_file_write_text(path, content)

fn readdir(path: text) -> [text]:
    rt_dir_list(path) ?? []

fn mkdir(path: text):
    val _ok = rt_dir_create_all(path)

fn _ensure_dir(path: text):
    if path == "":
        return
    val parts = path.split("/")
    var current = ""
    val absolute = path.starts_with("/")
    for raw in parts:
        val part = raw.trim()
        if part == "":
            continue
        if current == "":
            current = if absolute: "/" + part else: part
        else:
            current = current + "/" + part
        mkdir(current)

fn _ensure_parent_dirs(rootfs_root: text, file_path: text):
    val parts = file_path.split("/")
    var current = rootfs_root
    var i: u64 = 0
    while i + 1 < parts.len().to_u64():
        val part = parts[i as i64].trim()
        if part != "":
            current = current + "/" + part
            mkdir(current)
        i = i + 1

fn _write_placeholder_payload(rootfs_root: text, file_path: text, pkg: ExtendedManifest, arch: PkgArch):
    _ensure_parent_dirs(rootfs_root, file_path)
    if file_path == "/SYS/LLVMMAN.TXT":
        write_text("{rootfs_root}{file_path}", _toolchain_manifest_payload(arch, "llvm", "LLVM", "/sys/apps/llvm", "local-ir-inspection", "/usr/share/simpleos/toolchain/llvm/hello.ll", "object-assembly-inspection", "/usr/share/simpleos/toolchain/llvm/hello.s", "compile-pipeline-step", "/usr/share/simpleos/toolchain/llvm/pipeline.step"))
        return
    if file_path == "/SYS/CLANGMAN.TXT":
        write_text("{rootfs_root}{file_path}", _toolchain_manifest_payload(arch, "clang", "Clang", "/sys/apps/clang", "local-c-source-inspection", "/usr/share/simpleos/toolchain/clang/hello.c", "driver-flag-inspection", "/usr/share/simpleos/toolchain/clang/flags.rsp", "compile-pipeline-step", "/usr/share/simpleos/toolchain/clang/pipeline.step"))
        return
    if file_path == "/SYS/RUSTMAN.TXT":
        write_text("{rootfs_root}{file_path}", _toolchain_manifest_payload(arch, "rust", "Rust", "/sys/apps/rust", "local-source-inspection", "/usr/share/simpleos/toolchain/rust/hello.rs", "package-layout-inspection", "/usr/share/simpleos/toolchain/rust/Cargo.toml", "build-pipeline-step", "/usr/share/simpleos/toolchain/rust/pipeline.step"))
        return
    if file_path == "/SYS/TOOLSET.SDN":
        write_text("{rootfs_root}{file_path}", _toolset_payload(arch))
        return
    if file_path == "/SYS/LLVMVER.TXT":
        write_text("{rootfs_root}{file_path}", "SimpleOS LLVM standalone app v1\n")
        return
    if file_path == "/SYS/CLANGVER.TXT":
        write_text("{rootfs_root}{file_path}", "clang version 20.0.0\n")
        return
    if file_path == "/SYS/RUSTVER.TXT":
        write_text("{rootfs_root}{file_path}", "SimpleOS Rust standalone app v1\n")
        return
    if file_path == "/usr/share/simpleos/toolchain/llvm/hello.ll":
        write_text("{rootfs_root}{file_path}", "; SimpleOS staged LLVM IR\nsource_filename = \"hello.simple\"\n")
        return
    if file_path == "/usr/share/simpleos/toolchain/llvm/hello.s":
        write_text("{rootfs_root}{file_path}", "; SimpleOS staged assembly\n_start:\n    ret\n")
        return
    if file_path == "/usr/share/simpleos/toolchain/llvm/pipeline.step":
        write_text("{rootfs_root}{file_path}", "pipeline=compile-pipeline-step\ninput=/work/hello.simple\noutput=/work/hello.ll\nnext=/sys/apps/simple_loader\n")
        return
    if file_path == "/usr/share/simpleos/toolchain/clang/hello.c":
        write_text("{rootfs_root}{file_path}", "int main(void) " + "{\n    return 0;\n}\n")
        return
    if file_path == "/usr/share/simpleos/toolchain/clang/flags.rsp":
        write_text("{rootfs_root}{file_path}", "--target=x86_64-unknown-simpleos\n-ffreestanding\n-nostdlib\n-O2\n")
        return
    if file_path == "/usr/share/simpleos/toolchain/clang/pipeline.step":
        write_text("{rootfs_root}{file_path}", "pipeline=compile-pipeline-step\ninput=/work/hello.c\noutput=/work/hello.o\nnext=/sys/apps/simple_loader\n")
        return
    if file_path == "/usr/share/simpleos/toolchain/rust/hello.rs":
        write_text("{rootfs_root}{file_path}", "fn main() " + "{\n    println!(\"hello from simpleos\");\n}\n")
        return
    if file_path == "/usr/share/simpleos/toolchain/rust/Cargo.toml":
        write_text("{rootfs_root}{file_path}", "[package]\nname = \"hello-simpleos\"\nversion = \"0.1.0\"\n")
        return
    if file_path == "/usr/share/simpleos/toolchain/rust/pipeline.step":
        write_text("{rootfs_root}{file_path}", "pipeline=build-pipeline-step\ninput=/work/Cargo.toml\noutput=/work/target/hello\nnext=/sys/apps/simple_loader\n")
        return
    var content = "# simpleos staged payload\n"
    content = content + "package = \"{pkg.base.name}\"\n"
    content = content + "arch = \"{pkg_arch_to_text(arch)}\"\n"
    content = content + "target = \"{file_path}\"\n"
    if file_path.ends_with(".sdn"):
        content = content + "kind = \"config\"\n"
    else:
        content = content + "kind = \"placeholder\"\n"
    write_text("{rootfs_root}{file_path}", content)

fn _toolchain_lane(arch: PkgArch) -> text:
    match arch:
        PkgArch.X86_64: "x86_64-uefi-hardware"
        PkgArch.Arm64: "arm64-virtio-fat32-smf"
        PkgArch.Riscv64: "riscv64-hosted"
        PkgArch.Riscv32: "riscv32-virtio-fat32-smf"
        PkgArch.Any: "x86_64-uefi-hardware"

fn _toolchain_manifest_payload(arch: PkgArch, payload: text, title: text, app_path: text,
                               cap_a: text, proof_a: text,
                               cap_b: text, proof_b: text,
                               cap_c: text, proof_c: text) -> text:
    val lane = _toolchain_lane(arch)
    var out = "payload={payload}\n"
    out = out + "title={title}\n"
    out = out + "entry_app={app_path}\n"
    out = out + "lane={lane}\n"
    out = out + "mode=native-filesystem-app\n"
    out = out + "status=standalone-required\n"
    out = out + "capability_primary={cap_a}\n"
    out = out + "proof_primary={proof_a}\n"
    out = out + "capability_secondary={cap_b}\n"
    out = out + "proof_secondary={proof_b}\n"
    out = out + "capability_pipeline={cap_c}\n"
    out = out + "proof_pipeline={proof_c}\n"
    out

fn _toolset_payload(arch: PkgArch) -> text:
    val lane = _toolchain_lane(arch)
    var out = "[toolchain]\n"
    out = out + "lane = \"{lane}\"\n"
    out = out + "llvm = \"/sys/apps/llvm status=standalone-required\"\n"
    out = out + "clang = \"/sys/apps/clang status=standalone-required\"\n"
    out = out + "rust = \"/sys/apps/rust status=standalone-required\"\n"
    out = out + "developer_export_llvm = \"/usr/bin/clang optional\"\n"
    out = out + "developer_export_rust = \"/usr/bin/rustc optional\"\n"
    out

fn _manifest_header(config: ImageConfig, layout: PartitionLayout) -> text:
    val kind = if config.include_installer: "installer-dvd" else: "disk-image"
    val rootfs_backend = _normalized_rootfs_backend(_image_builder_rootfs_backend)
    var out = "[artifact]\n"
    out = out + "arch = \"{pkg_arch_to_text(config.arch)}\"\n"
    out = out + "output = \"{config.output_path}\"\n"
    out = out + "kind = \"{kind}\"\n"
    out = out + "rootfs_backend = \"{rootfs_backend}\"\n"
    out = out + "image_size_mb = {config.image_size_mb}\n"
    out = out + "efi_start_sector = {layout.efi_start_sector}\n"
    out = out + "efi_size_sectors = {layout.efi_size_sectors}\n"
    out = out + "root_start_sector = {layout.root_start_sector}\n"
    out = out + "root_size_sectors = {layout.root_size_sectors}\n\n"
    out

fn _manifest_file(path: text, role: text, owner: text) -> text:
    "[deploy]\npath = \"{path}\"\nkind = \"file\"\nrole = \"{role}\"\nowner = \"{owner}\"\n\n"

fn _manifest_dir(path: text, owner: text) -> text:
    "[deploy]\npath = \"{path}\"\nkind = \"dir\"\nrole = \"package-dir\"\nowner = \"{owner}\"\n\n"

fn _installed_pkg_record(pkg: ExtendedManifest) -> text:
    var out = "[package]\n"
    out = out + "name = \"{pkg.base.name}\"\n"
    out = out + "version = \"{pkg.base.version.to_text()}\"\n"
    out = out + "arch = \"{pkg_arch_to_text(pkg.arch)}\"\n"
    out = out + "files = {pkg.base.files.len()}\n"
    out

fn _effective_bootloader_config(config: ImageConfig) -> text:
    if config.bootloader_config != "":
        return config.bootloader_config
    _default_bootloader_config(config.arch)

fn _effective_simple_binary(config: ImageConfig) -> text:
    if config.simple_binary != "":
        return config.simple_binary
    val env_path = rt_env_get("SIMPLEOS_SIMPLE_BINARY") ?? ""
    if env_path != "":
        return env_path
    val candidates: [text] = [
        "build/bootstrap/stage3/simple_simpleos",
        "bin/release/x86_64-unknown-simpleos/simple",
        "bin/release/x86_64-simpleos/simple",
    ]
    for candidate in candidates:
        if rt_file_exists(candidate) and rt_file_exists("{candidate}.build_stamp"):
            return candidate
    ""

fn _validate_simple_binary(path: text, arch: PkgArch) -> Result<bool, text>:
    if not rt_file_exists(path):
        return Err("SimpleOS Simple payload is missing: {path}")
    val stamp_path = "{path}.build_stamp"
    if not rt_file_exists(stamp_path):
        return Err("SimpleOS Simple payload lacks target provenance: {stamp_path}")
    val expected_target = match arch:
        PkgArch.X86_64: "x86_64-unknown-simpleos"
        PkgArch.Arm64: "aarch64-unknown-simpleos"
        PkgArch.Riscv64: "riscv64-unknown-simpleos"
        PkgArch.Riscv32: "riscv32-unknown-simpleos"
        PkgArch.Any: "x86_64-unknown-simpleos"
    val stamp = rt_file_read_text(stamp_path)
    if not stamp.contains("target={expected_target}\n"):
        return Err("SimpleOS Simple payload target mismatch: expected {expected_target}")
    if not stamp.contains("entry=src/app/simpleos_tool/main.spl\n") or not stamp.contains("entry_closure=true\n"):
        return Err("SimpleOS Simple payload is not the focused compiler/interpreter/loader entry closure")

    val payload = rt_file_read_bytes(path) ?? []
    if payload.len() < 64 or payload[0] != 0x7fu8 or payload[1] != 0x45u8 or payload[2] != 0x4cu8 or payload[3] != 0x46u8:
        return Err("SimpleOS Simple payload is not an ELF executable")
    val expected_class = if arch == PkgArch.Riscv32: 1u8 else: 2u8
    val expected_machine = match arch:
        PkgArch.X86_64: 62
        PkgArch.Arm64: 183
        PkgArch.Riscv64 | PkgArch.Riscv32: 243
        PkgArch.Any: 62
    val machine = (payload[18] as i64) | ((payload[19] as i64) << 8)
    if payload[4] != expected_class or machine != expected_machine:
        return Err("SimpleOS Simple payload ELF architecture mismatch")
    Ok(true)

fn _simple_toolchain_manifest_payload(simple_binary: text) -> text:
    var out = "[simple_toolchain]\n"
    out = out + "status = \"embedded\"\n"
    out = out + "host_payload = \"{simple_binary}\"\n"
    out = out + "build_stamp = \"{simple_binary}.build_stamp\"\n"
    out = out + "runtime_source = \"simpleos-filesystem\"\n"
    for role_path in _SIMPLE_TOOLCHAIN_ROLE_PATHS:
        out = out + "role = \"{role_path}\"\n"
    out

fn _effective_clang_binary() -> text:
    val env_path = rt_env_get("SIMPLEOS_CLANG_BINARY") ?? ""
    if env_path != "":
        return env_path
    for candidate in _CLANG_STATIC_CANDIDATES:
        if rt_file_exists(candidate):
            return candidate
    ""

fn _effective_rustc_binary() -> text:
    val env_path = rt_env_get("SIMPLEOS_RUSTC_BINARY") ?? ""
    if env_path != "":
        return env_path
    for candidate in _RUSTC_STATIC_CANDIDATES:
        if rt_file_exists(candidate):
            return candidate
    ""

fn _effective_sysroot_dir() -> text:
    val env_path = rt_env_get("SIMPLEOS_SYSROOT") ?? ""
    if env_path != "":
        return env_path
    _SIMPLEOS_SYSROOT_DIR

fn _copy_file(src: text, dst: text) -> bool:
    val cmd = "cp -f " + _shell_quote(src) + " " + _shell_quote(dst)
    val (_o, _e, code) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 60000)
    code == 0 and rt_file_exists(dst)

fn _copy_tree(src: text, dst: text) -> bool:
    val cmd = "mkdir -p " + _shell_quote(dst) + " && cp -a " + _shell_quote(src) + "/. " + _shell_quote(dst) + "/"
    val (_o, _e, code) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 180000)
    code == 0

fn _clang_toolchain_fixture_payload() -> text:
    var out = "[clang_toolchain]\n"
    out = out + "status = \"fixture: clang_static not built\"\n"
    out = out + "expected_binary = \"build/os/clang_static/bin/clang_static\"\n"
    out = out + "expected_sysroot = \"build/os/sysroot\"\n"
    out = out + "note = \"build clang_static + sysroot, then re-run to embed the real toolchain\"\n"
    out

fn _clang_toolchain_embedded_payload(clang_binary: text, sysroot: text, sysroot_embedded: bool) -> text:
    var out = "[clang_toolchain]\n"
    out = out + "status = \"embedded\"\n"
    out = out + "host_payload = \"{clang_binary}\"\n"
    out = out + "target_triple = \"x86_64-unknown-simpleos\"\n"
    out = out + "sysroot_source = \"{sysroot}\"\n"
    out = out + "sysroot_embedded = {sysroot_embedded}\n"
    out = out + "lib_dir = \"/usr/lib\"\n"
    out = out + "sysroot_dir = \"/usr/share/simpleos\"\n"
    for role_path in _CLANG_GUEST_BIN_PATHS:
        out = out + "role = \"{role_path}\"\n"
    out

fn _rust_toolchain_fixture_payload() -> text:
    var out = "[rust_toolchain]\n"
    out = out + "status = \"fixture: rustc_static not built\"\n"
    out = out + "expected_binary = \"build/os/rust_static/bin/rustc_static\"\n"
    out = out + "note = \"build rustc_static, then re-run to embed the real toolchain\"\n"
    out

fn _rust_toolchain_embedded_payload(rustc_binary: text) -> text:
    var out = "[rust_toolchain]\n"
    out = out + "status = \"embedded\"\n"
    out = out + "host_payload = \"{rustc_binary}\"\n"
    out = out + "target_triple = \"x86_64-unknown-simpleos\"\n"
    for role_path in _RUSTC_GUEST_BIN_PATHS:
        out = out + "role = \"{role_path}\"\n"
    out

fn _basename(path: text) -> text:
    var out = path
    for seg in path.split("/"):
        if seg.trim() != "":
            out = seg.trim()
    out

# Detect the ISO authoring tool available on the build host. Returns the tool
# basename (e.g. "xorriso", "mkisofs", "genisoimage") or "iso-tool-missing".
fn detect_iso_tool() -> text:
    val cmd = "command -v xorriso || command -v mkisofs || command -v genisoimage || true"
    val (stdout, _e, _c) = rt_process_run_timeout("/bin/sh", ["-c", cmd], 15000)
    val found = stdout.trim()
    if found == "":
        return "iso-tool-missing"
    _basename(found)

fn _shell_quote(value: text) -> text:
    "'" + value.replace("'", "'\\''") + "'"

# make_os_disk.shs argv: SIZE_BITS IMAGE [KERNEL] [PLATFORM]. The KERNEL slot
# must be the host kernel ELF path (may be empty -> missing-kernel marker);
# passing a directory there makes make_os_disk die("file read failed") and
# forces the descriptor fallback.
fn _make_os_disk_command(config: ImageConfig) -> text:
    val simple_binary = _effective_simple_binary(config)
    var command = ""
    if simple_binary != "":
        command = command + "SIMPLEOS_SIMPLE_BINARY=" + _shell_quote(simple_binary) + " "
    command = command + "sh scripts/os/make_os_disk.shs "
    command = command + _shell_quote(config.image_size_mb.to_text()) + " "
    command = command + _shell_quote(config.output_path) + " "
    command = command + _shell_quote(config.kernel_path) + " "
    command + "x86_64"

fn _kernel_payload(kernel_path: text, arch: PkgArch) -> text:
    if kernel_path != "":
        val content = read_text(kernel_path)
        if content != "":
            return content
    "# placeholder kernel\narch = \"{pkg_arch_to_text(arch)}\"\n"

fn _fstab_template() -> text:
    var out = "# SimpleOS filesystem table\n"
    out = out + "/dev/root / auto defaults 0 1\n"
    out = out + "/dev/efi /boot/efi fat32 defaults 0 2\n"
    out

fn _normalized_rootfs_backend(rootfs_backend: text) -> text:
    if rootfs_backend == "" or rootfs_backend == "fat32":
        return "fat32"
    if rootfs_backend == "dbfs":
        return "dbfs"
    if rootfs_backend == "nvfs":
        return "nvfs"
    "fat32"

fn _rootfs_backend_payload(rootfs_backend: text) -> text:
    val backend = _normalized_rootfs_backend(rootfs_backend)
    var out = "[rootfs]\n"
    out = out + "backend = \"{backend}\"\n"
    out = out + "carrier = \"fat32\"\n"
    out = out + "boot_mode = \"fat32-carrier\"\n"
    out

fn _rootfs_boot_marker_payload(rootfs_backend: text) -> text:
    val backend = _normalized_rootfs_backend(rootfs_backend)
    var out = "rootfs_backend={backend}\n"
    out = out + "rootfs_carrier=fat32\n"
    out = out + "rootfs_boot_mode=fat32-carrier\n"
    out

fn _rc_conf_template() -> text:
    "hostname=\"simpleos\"\nsshd_enable=\"NO\"\nsimpleos_desktop=\"YES\"\n"

fn _pkg_repo_template() -> text:
    "[repositories]\nlocal = \"/var/cache/pkg/local\"\n"

fn _init_payload() -> text:
    "#!/bin/simple-init\nprint(\"SIMPLEOS_INIT_OK\")\n"

fn _simplebox_payload() -> text:
    """Packed /bin/simplebox. Uses the binary compiled by build_simplebox
    (src/os/tools/simplebox/simplebox_build.spl -> build/os/rootfs/bin/simplebox)
    when present; otherwise a placeholder descriptor so the image always has the
    multi-call entry. The real binary genuinely runs the pure-Simple libc."""
    val content = read_text("build/os/rootfs/bin/simplebox")
    if content != "":
        return content
    "# placeholder simplebox — run: build_simplebox(\"simpleos\")\ncommand = \"simplebox --list\"\n"

fn _installer_payload(arch: PkgArch) -> text:
    "# install-media entrypoint\narch = \"{pkg_arch_to_text(arch)}\"\ncommand = \"installer install\"\n"

fn _write_artifact_descriptor(config: ImageConfig, layout: PartitionLayout, manifest_path: text):
    var out = _manifest_header(config, layout)
    out = out + "[descriptor]\n"
    out = out + "staging_root = \"{_staging_root(config.output_path)}\"\n"
    out = out + "deploy_manifest = \"{manifest_path}\"\n"
    out = out + "materialized = false\n"
    write_text(config.output_path, out)

fn _default_bootloader_config(arch: PkgArch) -> text:
    var cfg = "# Limine bootloader config\n"
    cfg = cfg + "TIMEOUT=5\n"
    cfg = cfg + "\n:SimpleOS\n"
    cfg = cfg + "  PROTOCOL=limine\n"
    cfg = cfg + "  KERNEL_PATH=boot:///kernel.elf\n"
    cfg = cfg + "  CMDLINE=console=serial root=/dev/sda2 arch={pkg_arch_to_text(arch)}\n"
    cfg

fn _installer_bootloader_config(arch: PkgArch) -> text:
    var cfg = "TIMEOUT=5\n"
    cfg = cfg + "\n:SimpleOS Installer\n"
    cfg = cfg + "  PROTOCOL=limine\n"
    cfg = cfg + "  KERNEL_PATH=boot:///kernel.elf\n"
    cfg = cfg + "  CMDLINE=console=serial installer=1 root=/dev/sda2 arch={pkg_arch_to_text(arch)}\n"
    cfg = cfg + "\n:SimpleOS (Live)\n"
    cfg = cfg + "  PROTOCOL=limine\n"
    cfg = cfg + "  KERNEL_PATH=boot:///kernel.elf\n"
    cfg = cfg + "  CMDLINE=console=serial live=1 arch={pkg_arch_to_text(arch)}\n"
    cfg
