# =============================================================================
# Salsa20/20 Stream Cipher — Pure Simple Implementation
#
# Implements Salsa20/20 (20-round), HSalsa20, and XSalsa20.
# All operations use u32 — 32-bit safe, no float.
#
# References:
#   DJB, "Salsa20 specification" (2005) — https://cr.yp.to/snuffle/spec.pdf
#   DJB, "Extending the Salsa20 nonce" (XSalsa20, 2008/2011) —
#     https://cr.yp.to/snuffle/xsalsa-20110204.pdf
#
# NOTE: scrypt's 8-round core lives in src/lib/common/scrypt/salsa20.spl.
#       This file is the independent 20-round streaming implementation.
# =============================================================================

mod os.crypto.salsa20

# =============================================================================
# Helpers
# =============================================================================

fn _s20_u32_mask(x: u32) -> u32:
    """Mask to 32 bits."""
    x & 0xFFFFFFFFu32

fn _s20_rotl32(x: u32, n: u32) -> u32:
    """32-bit left rotation."""
    _s20_u32_mask((x << n) | (x >> (32u32 - n)))

fn _s20_le_u32(b: [u8], off: u64) -> u32:
    """Load u32 from bytes in little-endian."""
    b[off].to_u32() | (b[off + 1].to_u32() << 8u32) | (b[off + 2].to_u32() << 16u32) | (b[off + 3].to_u32() << 24u32)

fn _s20_word_b0(w: u32) -> u8:
    """Extract byte 0 (bits 0-7) of a u32, little-endian."""
    (w & 0xFFu32).to_u8()

fn _s20_word_b1(w: u32) -> u8:
    """Extract byte 1 (bits 8-15) of a u32, little-endian."""
    ((w >> 8u32) & 0xFFu32).to_u8()

fn _s20_word_b2(w: u32) -> u8:
    """Extract byte 2 (bits 16-23) of a u32, little-endian."""
    ((w >> 16u32) & 0xFFu32).to_u8()

fn _s20_word_b3(w: u32) -> u8:
    """Extract byte 3 (bits 24-31) of a u32, little-endian."""
    ((w >> 24u32) & 0xFFu32).to_u8()

# =============================================================================
# Salsa20 Quarter Round
# =============================================================================

# =============================================================================
# Salsa20/20 Core — 20-round hash
# =============================================================================

fn salsa20_20_core(input: [u32]) -> [u32]:
    """Salsa20/20 core: 20-round hash of 16 u32 words.

    Performs 10 double-rounds (20 rounds total) then adds initial state.
    Input and output are 16 words (64 bytes).
    Quarter rounds are inlined to avoid array-mutation-through-parameter
    interpreter limitation.

    Example:
        val output = salsa20_20_core(input)
    """
    # Working copy
    var x0: u32 = input[0]
    var x1: u32 = input[1]
    var x2: u32 = input[2]
    var x3: u32 = input[3]
    var x4: u32 = input[4]
    var x5: u32 = input[5]
    var x6: u32 = input[6]
    var x7: u32 = input[7]
    var x8: u32 = input[8]
    var x9: u32 = input[9]
    var x10: u32 = input[10]
    var x11: u32 = input[11]
    var x12: u32 = input[12]
    var x13: u32 = input[13]
    var x14: u32 = input[14]
    var x15: u32 = input[15]

    # 10 double-rounds (20 rounds total)
    # Each double-round = column round + row round
    # QR(a,b,c,d): b^=rotl(a+d,7); c^=rotl(b+a,9); d^=rotl(c+b,13); a^=rotl(d+c,18)
    var round: u64 = 0
    while round < 10:
        # Column round: QR(0,4,8,12)
        x4 = x4 ^ _s20_rotl32(_s20_u32_mask(x0 + x12), 7u32)
        x8 = x8 ^ _s20_rotl32(_s20_u32_mask(x4 + x0), 9u32)
        x12 = x12 ^ _s20_rotl32(_s20_u32_mask(x8 + x4), 13u32)
        x0 = x0 ^ _s20_rotl32(_s20_u32_mask(x12 + x8), 18u32)
        # Column round: QR(5,9,13,1)
        x9 = x9 ^ _s20_rotl32(_s20_u32_mask(x5 + x1), 7u32)
        x13 = x13 ^ _s20_rotl32(_s20_u32_mask(x9 + x5), 9u32)
        x1 = x1 ^ _s20_rotl32(_s20_u32_mask(x13 + x9), 13u32)
        x5 = x5 ^ _s20_rotl32(_s20_u32_mask(x1 + x13), 18u32)
        # Column round: QR(10,14,2,6)
        x14 = x14 ^ _s20_rotl32(_s20_u32_mask(x10 + x6), 7u32)
        x2 = x2 ^ _s20_rotl32(_s20_u32_mask(x14 + x10), 9u32)
        x6 = x6 ^ _s20_rotl32(_s20_u32_mask(x2 + x14), 13u32)
        x10 = x10 ^ _s20_rotl32(_s20_u32_mask(x6 + x2), 18u32)
        # Column round: QR(15,3,7,11)
        x3 = x3 ^ _s20_rotl32(_s20_u32_mask(x15 + x11), 7u32)
        x7 = x7 ^ _s20_rotl32(_s20_u32_mask(x3 + x15), 9u32)
        x11 = x11 ^ _s20_rotl32(_s20_u32_mask(x7 + x3), 13u32)
        x15 = x15 ^ _s20_rotl32(_s20_u32_mask(x11 + x7), 18u32)
        # Row round: QR(0,1,2,3)
        x1 = x1 ^ _s20_rotl32(_s20_u32_mask(x0 + x3), 7u32)
        x2 = x2 ^ _s20_rotl32(_s20_u32_mask(x1 + x0), 9u32)
        x3 = x3 ^ _s20_rotl32(_s20_u32_mask(x2 + x1), 13u32)
        x0 = x0 ^ _s20_rotl32(_s20_u32_mask(x3 + x2), 18u32)
        # Row round: QR(5,6,7,4)
        x6 = x6 ^ _s20_rotl32(_s20_u32_mask(x5 + x4), 7u32)
        x7 = x7 ^ _s20_rotl32(_s20_u32_mask(x6 + x5), 9u32)
        x4 = x4 ^ _s20_rotl32(_s20_u32_mask(x7 + x6), 13u32)
        x5 = x5 ^ _s20_rotl32(_s20_u32_mask(x4 + x7), 18u32)
        # Row round: QR(10,11,8,9)
        x11 = x11 ^ _s20_rotl32(_s20_u32_mask(x10 + x9), 7u32)
        x8 = x8 ^ _s20_rotl32(_s20_u32_mask(x11 + x10), 9u32)
        x9 = x9 ^ _s20_rotl32(_s20_u32_mask(x8 + x11), 13u32)
        x10 = x10 ^ _s20_rotl32(_s20_u32_mask(x9 + x8), 18u32)
        # Row round: QR(15,12,13,14)
        x12 = x12 ^ _s20_rotl32(_s20_u32_mask(x15 + x14), 7u32)
        x13 = x13 ^ _s20_rotl32(_s20_u32_mask(x12 + x15), 9u32)
        x14 = x14 ^ _s20_rotl32(_s20_u32_mask(x13 + x12), 13u32)
        x15 = x15 ^ _s20_rotl32(_s20_u32_mask(x14 + x13), 18u32)

        round = round + 1

    # Add initial state and collect result
    var result: [u32] = []
    result.push(_s20_u32_mask(x0 + input[0]))
    result.push(_s20_u32_mask(x1 + input[1]))
    result.push(_s20_u32_mask(x2 + input[2]))
    result.push(_s20_u32_mask(x3 + input[3]))
    result.push(_s20_u32_mask(x4 + input[4]))
    result.push(_s20_u32_mask(x5 + input[5]))
    result.push(_s20_u32_mask(x6 + input[6]))
    result.push(_s20_u32_mask(x7 + input[7]))
    result.push(_s20_u32_mask(x8 + input[8]))
    result.push(_s20_u32_mask(x9 + input[9]))
    result.push(_s20_u32_mask(x10 + input[10]))
    result.push(_s20_u32_mask(x11 + input[11]))
    result.push(_s20_u32_mask(x12 + input[12]))
    result.push(_s20_u32_mask(x13 + input[13]))
    result.push(_s20_u32_mask(x14 + input[14]))
    result.push(_s20_u32_mask(x15 + input[15]))

    result

# =============================================================================
# Salsa20/20 Block Setup
#
# State layout for 32-byte key (DJB spec §8, σ constants):
#   [0]      = σ0 "expa" = 0x61707865
#   [1..4]   = key[0..15]   (4 words, little-endian)
#   [5]      = σ1 "nd 3" = 0x3320646e
#   [6..7]   = nonce[0..7]  (2 words, little-endian, 8-byte nonce)
#   [8..9]   = counter lo/hi (2 x u32 = 64-bit counter)
#   [10]     = σ2 "2-by" = 0x79622d32
#   [11..14] = key[16..31]  (4 words, little-endian)
#   [15]     = σ3 "te k" = 0x6b206574
# =============================================================================

fn _s20_build_state(key: [u8], nonce: [u8], counter_lo: u32, counter_hi: u32) -> [u32]:
    """Build 16-word Salsa20 state from 32-byte key, 8-byte nonce, and counter."""
    var s: [u32] = []

    # σ0
    s.push(0x61707865u32)
    # key[0..15]
    s.push(_s20_le_u32(key, 0))
    s.push(_s20_le_u32(key, 4))
    s.push(_s20_le_u32(key, 8))
    s.push(_s20_le_u32(key, 12))
    # σ1
    s.push(0x3320646eu32)
    # nonce[0..7]
    s.push(_s20_le_u32(nonce, 0))
    s.push(_s20_le_u32(nonce, 4))
    # counter lo / hi
    s.push(counter_lo)
    s.push(counter_hi)
    # σ2
    s.push(0x79622d32u32)
    # key[16..31]
    s.push(_s20_le_u32(key, 16))
    s.push(_s20_le_u32(key, 20))
    s.push(_s20_le_u32(key, 24))
    s.push(_s20_le_u32(key, 28))
    # σ3
    s.push(0x6b206574u32)

    s

# =============================================================================
# Salsa20/20 Block — generates 64 keystream bytes
# =============================================================================

fn salsa20_20_block(key: [u8], nonce: [u8], counter_lo: u32, counter_hi: u32) -> [u8]:
    """Generate one 64-byte Salsa20/20 keystream block.

    Args:
        key: 32-byte key.
        nonce: 8-byte nonce.
        counter_lo: Low 32 bits of 64-bit block counter.
        counter_hi: High 32 bits of 64-bit block counter.

    Returns: 64 keystream bytes.

    Example:
        val ks = salsa20_20_block(key, nonce, 0, 0)
    """
    val state = _s20_build_state(key, nonce, counter_lo, counter_hi)
    val hashed = salsa20_20_core(state)

    var out: [u8] = []
    var i: u64 = 0
    while i < 16:
        val w = hashed[i]
        out.push(_s20_word_b0(w))
        out.push(_s20_word_b1(w))
        out.push(_s20_word_b2(w))
        out.push(_s20_word_b3(w))
        i = i + 1

    out

# =============================================================================
# Salsa20/20 XOR — stream encrypt/decrypt
# =============================================================================

fn salsa20_20_xor(key: [u8], nonce: [u8], plaintext: [u8]) -> [u8]:
    """Encrypt/decrypt using Salsa20/20 stream cipher.

    Counter starts at 0 and increments by 1 per 64-byte block.

    Args:
        key: 32-byte key.
        nonce: 8-byte nonce.
        plaintext: Data to encrypt (or ciphertext to decrypt).

    Returns: Output bytes, same length as plaintext.

    Example:
        val ct = salsa20_20_xor(key, nonce, message)
        val pt = salsa20_20_xor(key, nonce, ct)
    """
    var output: [u8] = []
    var counter_lo: u32 = 0u32
    var counter_hi: u32 = 0u32
    var pos: u64 = 0
    val total: u64 = plaintext.len()

    while pos < total:
        val state = _s20_build_state(key, nonce, counter_lo, counter_hi)
        val hashed = salsa20_20_core(state)

        # XOR up to 64 bytes from this block
        var word_idx: u64 = 0
        while word_idx < 16 and pos < total:
            val word = hashed[word_idx]
            if pos < total:
                output.push(plaintext[pos] ^ _s20_word_b0(word))
                pos = pos + 1
            if pos < total:
                output.push(plaintext[pos] ^ _s20_word_b1(word))
                pos = pos + 1
            if pos < total:
                output.push(plaintext[pos] ^ _s20_word_b2(word))
                pos = pos + 1
            if pos < total:
                output.push(plaintext[pos] ^ _s20_word_b3(word))
                pos = pos + 1
            word_idx = word_idx + 1

        # Increment 64-bit counter
        val next_lo = _s20_u32_mask(counter_lo + 1u32)
        if next_lo == 0u32:
            counter_hi = _s20_u32_mask(counter_hi + 1u32)
        counter_lo = next_lo

    output

# =============================================================================
# Public alias matching task brief
# =============================================================================

fn salsa20_xor(key: [u8], nonce: [u8], plaintext: [u8]) -> [u8]:
    """Salsa20/20 encrypt/decrypt — 32-byte key, 8-byte nonce.

    Alias for salsa20_20_xor.

    Example:
        val ct = salsa20_xor(key32, nonce8, message)
    """
    salsa20_20_xor(key, nonce, plaintext)

# =============================================================================
# HSalsa20 — Sub-key derivation
#
# Runs the Salsa20/20 core on the initial state but returns only the
# first and last row (words [0,5,10,15, 6,7,8,9]) as 32 bytes — WITHOUT
# adding the initial state back. This is the "raw" (non-hashing) version.
#
# State for HSalsa20 (input is 32-byte key + 16-byte input):
#   [0]      = σ0 = 0x61707865
#   [1..4]   = key[0..15]
#   [5]      = σ1 = 0x3320646e
#   [6..9]   = input[0..15]  (16-byte nonce head, 4 words)
#   [10]     = σ2 = 0x79622d32
#   [11..14] = key[16..31]
#   [15]     = σ3 = 0x6b206574
# =============================================================================

fn _s20_build_hsalsa_state(key: [u8], input: [u8]) -> [u32]:
    """Build 16-word HSalsa20 state from 32-byte key and 16-byte input.

    HSalsa20 state layout (DJB xsalsa-20110204.pdf §2):
      [0]     = σ0 = 0x61707865
      [1..4]  = key[0..15]
      [5]     = σ1 = 0x3320646e
      [6..9]  = input[0..15]  (16-byte nonce head)
      [10]    = σ2 = 0x79622d32
      [11..14]= key[16..31]
      [15]    = σ3 = 0x6b206574
    """
    var s: [u32] = []

    s.push(0x61707865u32)
    s.push(_s20_le_u32(key, 0))
    s.push(_s20_le_u32(key, 4))
    s.push(_s20_le_u32(key, 8))
    s.push(_s20_le_u32(key, 12))
    s.push(0x3320646eu32)
    s.push(_s20_le_u32(input, 0))
    s.push(_s20_le_u32(input, 4))
    s.push(_s20_le_u32(input, 8))
    s.push(_s20_le_u32(input, 12))
    s.push(0x79622d32u32)
    s.push(_s20_le_u32(key, 16))
    s.push(_s20_le_u32(key, 20))
    s.push(_s20_le_u32(key, 24))
    s.push(_s20_le_u32(key, 28))
    s.push(0x6b206574u32)

    s

fn hsalsa20(key: [u8], input: [u8]) -> [u8]:
    """HSalsa20 sub-key derivation.

    Computes the Salsa20/20 round function on the initial state (without
    the final addition of the input state) and extracts 32 output bytes
    from words [0, 5, 10, 15, 6, 7, 8, 9].

    Args:
        key: 32-byte key.
        input: 16-byte input (typically first 16 bytes of XSalsa20 nonce).

    Returns: 32-byte derived sub-key.

    Example:
        val subkey = hsalsa20(key32, nonce_head16)
    """
    val state = _s20_build_hsalsa_state(key, input)

    # Run core WITHOUT adding initial state (raw permutation output)
    # Quarter rounds inlined to avoid array-mutation-through-parameter issue.
    var x0: u32 = state[0]
    var x1: u32 = state[1]
    var x2: u32 = state[2]
    var x3: u32 = state[3]
    var x4: u32 = state[4]
    var x5: u32 = state[5]
    var x6: u32 = state[6]
    var x7: u32 = state[7]
    var x8: u32 = state[8]
    var x9: u32 = state[9]
    var x10: u32 = state[10]
    var x11: u32 = state[11]
    var x12: u32 = state[12]
    var x13: u32 = state[13]
    var x14: u32 = state[14]
    var x15: u32 = state[15]

    var round: u64 = 0
    while round < 10:
        # Column round: QR(0,4,8,12)
        x4 = x4 ^ _s20_rotl32(_s20_u32_mask(x0 + x12), 7u32)
        x8 = x8 ^ _s20_rotl32(_s20_u32_mask(x4 + x0), 9u32)
        x12 = x12 ^ _s20_rotl32(_s20_u32_mask(x8 + x4), 13u32)
        x0 = x0 ^ _s20_rotl32(_s20_u32_mask(x12 + x8), 18u32)
        # Column round: QR(5,9,13,1)
        x9 = x9 ^ _s20_rotl32(_s20_u32_mask(x5 + x1), 7u32)
        x13 = x13 ^ _s20_rotl32(_s20_u32_mask(x9 + x5), 9u32)
        x1 = x1 ^ _s20_rotl32(_s20_u32_mask(x13 + x9), 13u32)
        x5 = x5 ^ _s20_rotl32(_s20_u32_mask(x1 + x13), 18u32)
        # Column round: QR(10,14,2,6)
        x14 = x14 ^ _s20_rotl32(_s20_u32_mask(x10 + x6), 7u32)
        x2 = x2 ^ _s20_rotl32(_s20_u32_mask(x14 + x10), 9u32)
        x6 = x6 ^ _s20_rotl32(_s20_u32_mask(x2 + x14), 13u32)
        x10 = x10 ^ _s20_rotl32(_s20_u32_mask(x6 + x2), 18u32)
        # Column round: QR(15,3,7,11)
        x3 = x3 ^ _s20_rotl32(_s20_u32_mask(x15 + x11), 7u32)
        x7 = x7 ^ _s20_rotl32(_s20_u32_mask(x3 + x15), 9u32)
        x11 = x11 ^ _s20_rotl32(_s20_u32_mask(x7 + x3), 13u32)
        x15 = x15 ^ _s20_rotl32(_s20_u32_mask(x11 + x7), 18u32)
        # Row round: QR(0,1,2,3)
        x1 = x1 ^ _s20_rotl32(_s20_u32_mask(x0 + x3), 7u32)
        x2 = x2 ^ _s20_rotl32(_s20_u32_mask(x1 + x0), 9u32)
        x3 = x3 ^ _s20_rotl32(_s20_u32_mask(x2 + x1), 13u32)
        x0 = x0 ^ _s20_rotl32(_s20_u32_mask(x3 + x2), 18u32)
        # Row round: QR(5,6,7,4)
        x6 = x6 ^ _s20_rotl32(_s20_u32_mask(x5 + x4), 7u32)
        x7 = x7 ^ _s20_rotl32(_s20_u32_mask(x6 + x5), 9u32)
        x4 = x4 ^ _s20_rotl32(_s20_u32_mask(x7 + x6), 13u32)
        x5 = x5 ^ _s20_rotl32(_s20_u32_mask(x4 + x7), 18u32)
        # Row round: QR(10,11,8,9)
        x11 = x11 ^ _s20_rotl32(_s20_u32_mask(x10 + x9), 7u32)
        x8 = x8 ^ _s20_rotl32(_s20_u32_mask(x11 + x10), 9u32)
        x9 = x9 ^ _s20_rotl32(_s20_u32_mask(x8 + x11), 13u32)
        x10 = x10 ^ _s20_rotl32(_s20_u32_mask(x9 + x8), 18u32)
        # Row round: QR(15,12,13,14)
        x12 = x12 ^ _s20_rotl32(_s20_u32_mask(x15 + x14), 7u32)
        x13 = x13 ^ _s20_rotl32(_s20_u32_mask(x12 + x15), 9u32)
        x14 = x14 ^ _s20_rotl32(_s20_u32_mask(x13 + x12), 13u32)
        x15 = x15 ^ _s20_rotl32(_s20_u32_mask(x14 + x13), 18u32)

        round = round + 1

    # Output: first row [0,5,10,15] + middle key words [6,7,8,9]
    # (DJB xsalsa-20110204.pdf §2: z0,z5,z10,z15,z6,z7,z8,z9)
    var out: [u8] = []
    out.push(_s20_word_b0(x0))
    out.push(_s20_word_b1(x0))
    out.push(_s20_word_b2(x0))
    out.push(_s20_word_b3(x0))
    out.push(_s20_word_b0(x5))
    out.push(_s20_word_b1(x5))
    out.push(_s20_word_b2(x5))
    out.push(_s20_word_b3(x5))
    out.push(_s20_word_b0(x10))
    out.push(_s20_word_b1(x10))
    out.push(_s20_word_b2(x10))
    out.push(_s20_word_b3(x10))
    out.push(_s20_word_b0(x15))
    out.push(_s20_word_b1(x15))
    out.push(_s20_word_b2(x15))
    out.push(_s20_word_b3(x15))
    out.push(_s20_word_b0(x6))
    out.push(_s20_word_b1(x6))
    out.push(_s20_word_b2(x6))
    out.push(_s20_word_b3(x6))
    out.push(_s20_word_b0(x7))
    out.push(_s20_word_b1(x7))
    out.push(_s20_word_b2(x7))
    out.push(_s20_word_b3(x7))
    out.push(_s20_word_b0(x8))
    out.push(_s20_word_b1(x8))
    out.push(_s20_word_b2(x8))
    out.push(_s20_word_b3(x8))
    out.push(_s20_word_b0(x9))
    out.push(_s20_word_b1(x9))
    out.push(_s20_word_b2(x9))
    out.push(_s20_word_b3(x9))

    out

# =============================================================================
# XSalsa20 — Extended-nonce stream cipher
#
# XSalsa20(key, nonce24) = Salsa20(HSalsa20(key, nonce[0..16]), nonce[16..24], counter)
# =============================================================================

fn xsalsa20_xor(key: [u8], nonce: [u8], plaintext: [u8]) -> [u8]:
    """Encrypt/decrypt using XSalsa20 — 32-byte key, 24-byte nonce.

    Derives a sub-key via HSalsa20(key, nonce[0..16]) then runs
    Salsa20/20 with sub-key and nonce[16..24].

    Args:
        key: 32-byte key.
        nonce: 24-byte nonce.
        plaintext: Data to encrypt (or ciphertext to decrypt).

    Returns: Output bytes, same length as plaintext.

    Example:
        val ct = xsalsa20_xor(key32, nonce24, message)
        val pt = xsalsa20_xor(key32, nonce24, ct)
    """
    # Extract nonce head (16 bytes) for HSalsa20
    var nonce_head: [u8] = []
    var i: u64 = 0
    while i < 16:
        nonce_head.push(nonce[i])
        i = i + 1

    # Extract nonce tail (8 bytes) for Salsa20/20
    var nonce_tail: [u8] = []
    i = 16
    while i < 24:
        nonce_tail.push(nonce[i])
        i = i + 1

    # Derive sub-key
    val subkey = hsalsa20(key, nonce_head)

    # Run Salsa20/20 with derived key and nonce tail
    salsa20_20_xor(subkey, nonce_tail, plaintext)
