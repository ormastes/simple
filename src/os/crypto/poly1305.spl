# Poly1305 MAC — Pure Simple Implementation (RFC 7539)
#
# One-time authenticator using 130-bit arithmetic in GF(2^130 - 5).
# All operations use u32 — 32-bit safe, no float.
#
# Reference: RFC 7539 (ChaCha20 and Poly1305 for IETF Protocols)
# Reference: D.J. Bernstein, "The Poly1305-AES message-authentication code"

# ============================================================================
# Poly1305 State
# ============================================================================

struct Poly1305State:
    """Poly1305 accumulator state.

    r: clamped key (5 u32 limbs, 26 bits each)
    h: accumulator (5 u32 limbs)
    pad: one-time pad (4 u32 words)
    """
    r0: u32
    r1: u32
    r2: u32
    r3: u32
    r4: u32
    h0: u32
    h1: u32
    h2: u32
    h3: u32
    h4: u32
    pad0: u32
    pad1: u32
    pad2: u32
    pad3: u32

# ============================================================================
# Poly1305 Init
# ============================================================================

fn poly1305_init(key: [u8]) -> Poly1305State:
    """Initialize Poly1305 from 32-byte key.

    key[0..15] = r (clamped), key[16..31] = s (pad).
    Clamp r: clear bits 4,8,12,16 of each 4-byte group and top bits.
    """
    # Load r (first 16 bytes, little-endian) and clamp
    val t0 = _le_u32(key, 0)
    val t1 = _le_u32(key, 4)
    val t2 = _le_u32(key, 8)
    val t3 = _le_u32(key, 12)

    val r0 = t0 & 0x3FFFFFF
    val r1 = ((t0 >> 26) | (t1 << 6)) & 0x3FFFF03
    val r2 = ((t1 >> 20) | (t2 << 12)) & 0x3FFC0FF
    val r3 = ((t2 >> 14) | (t3 << 18)) & 0x3F03FFF
    val r4 = (t3 >> 8) & 0x00FFFFF

    # Load pad (last 16 bytes, little-endian)
    val pad0 = _le_u32(key, 16)
    val pad1 = _le_u32(key, 20)
    val pad2 = _le_u32(key, 24)
    val pad3 = _le_u32(key, 28)

    Poly1305State(
        r0: r0, r1: r1, r2: r2, r3: r3, r4: r4,
        h0: 0, h1: 0, h2: 0, h3: 0, h4: 0,
        pad0: pad0, pad1: pad1, pad2: pad2, pad3: pad3
    )

fn _le_u32(b: [u8], off: u64) -> u32:
    """Load u32 from bytes in little-endian."""
    b[off].to_u32() |
    (b[off + 1].to_u32() << 8) |
    (b[off + 2].to_u32() << 16) |
    (b[off + 3].to_u32() << 24)

# ============================================================================
# Poly1305 Block Processing
# ============================================================================

fn poly1305_block(st: Poly1305State, block: [u8], block_len: u64, hibit: u32) -> Poly1305State:
    """Process one 16-byte block.

    Adds hibit * 2^128 to the block value before accumulating.
    hibit = 1 for normal blocks, 0 for the final partial block.
    """
    # Load block as 5 x 26-bit limbs
    var t0: u32 = 0
    var t1: u32 = 0
    var t2: u32 = 0
    var t3: u32 = 0
    if block_len >= 4:
        t0 = _le_u32(block, 0)
    if block_len >= 8:
        t1 = _le_u32(block, 4)
    if block_len >= 12:
        t2 = _le_u32(block, 8)
    if block_len >= 16:
        t3 = _le_u32(block, 12)

    var h0: u32 = st.h0 + (t0 & 0x3FFFFFF)
    var h1: u32 = st.h1 + (((t0 >> 26) | (t1 << 6)) & 0x3FFFFFF)
    var h2: u32 = st.h2 + (((t1 >> 20) | (t2 << 12)) & 0x3FFFFFF)
    var h3: u32 = st.h3 + (((t2 >> 14) | (t3 << 18)) & 0x3FFFFFF)
    var h4: u32 = st.h4 + ((t3 >> 8) | (hibit << 24))

    # Multiply h * r using u64 intermediates
    val r0 = st.r0
    val r1 = st.r1
    val r2 = st.r2
    val r3 = st.r3
    val r4 = st.r4

    val s1: u32 = r1 * 5
    val s2: u32 = r2 * 5
    val s3: u32 = r3 * 5
    val s4: u32 = r4 * 5

    var d0: u64 = h0.to_u64() * r0.to_u64() + h1.to_u64() * s4.to_u64() + h2.to_u64() * s3.to_u64() + h3.to_u64() * s2.to_u64() + h4.to_u64() * s1.to_u64()
    var d1: u64 = h0.to_u64() * r1.to_u64() + h1.to_u64() * r0.to_u64() + h2.to_u64() * s4.to_u64() + h3.to_u64() * s3.to_u64() + h4.to_u64() * s2.to_u64()
    var d2: u64 = h0.to_u64() * r2.to_u64() + h1.to_u64() * r1.to_u64() + h2.to_u64() * r0.to_u64() + h3.to_u64() * s4.to_u64() + h4.to_u64() * s3.to_u64()
    var d3: u64 = h0.to_u64() * r3.to_u64() + h1.to_u64() * r2.to_u64() + h2.to_u64() * r1.to_u64() + h3.to_u64() * r0.to_u64() + h4.to_u64() * s4.to_u64()
    var d4: u64 = h0.to_u64() * r4.to_u64() + h1.to_u64() * r3.to_u64() + h2.to_u64() * r2.to_u64() + h3.to_u64() * r1.to_u64() + h4.to_u64() * r0.to_u64()

    # Carry propagation (partial reduction mod 2^130 - 5)
    var c: u32 = (d0 >> 26).to_u32()
    h0 = (d0 & 0x3FFFFFF).to_u32()
    d1 = d1 + c.to_u64()

    c = (d1 >> 26).to_u32()
    h1 = (d1 & 0x3FFFFFF).to_u32()
    d2 = d2 + c.to_u64()

    c = (d2 >> 26).to_u32()
    h2 = (d2 & 0x3FFFFFF).to_u32()
    d3 = d3 + c.to_u64()

    c = (d3 >> 26).to_u32()
    h3 = (d3 & 0x3FFFFFF).to_u32()
    d4 = d4 + c.to_u64()

    c = (d4 >> 26).to_u32()
    h4 = (d4 & 0x3FFFFFF).to_u32()
    h0 = h0 + c * 5

    c = h0 >> 26
    h0 = h0 & 0x3FFFFFF
    h1 = h1 + c

    Poly1305State(
        r0: st.r0, r1: st.r1, r2: st.r2, r3: st.r3, r4: st.r4,
        h0: h0, h1: h1, h2: h2, h3: h3, h4: h4,
        pad0: st.pad0, pad1: st.pad1, pad2: st.pad2, pad3: st.pad3
    )

# ============================================================================
# Poly1305 Finalize
# ============================================================================

fn poly1305_finalize(st: Poly1305State) -> [u8]:
    """Finalize Poly1305 — fully reduce h mod 2^130-5, add pad. Returns 16-byte tag."""
    var h0 = st.h0
    var h1 = st.h1
    var h2 = st.h2
    var h3 = st.h3
    var h4 = st.h4

    # Final carry
    var c: u32 = h1 >> 26
    h1 = h1 & 0x3FFFFFF
    h2 = h2 + c
    c = h2 >> 26
    h2 = h2 & 0x3FFFFFF
    h3 = h3 + c
    c = h3 >> 26
    h3 = h3 & 0x3FFFFFF
    h4 = h4 + c
    c = h4 >> 26
    h4 = h4 & 0x3FFFFFF
    h0 = h0 + c * 5
    c = h0 >> 26
    h0 = h0 & 0x3FFFFFF
    h1 = h1 + c

    # Compute h + -p = h - (2^130 - 5) = h + 5 - 2^130
    var g0: u32 = h0 + 5
    c = g0 >> 26
    g0 = g0 & 0x3FFFFFF
    var g1: u32 = h1 + c
    c = g1 >> 26
    g1 = g1 & 0x3FFFFFF
    var g2: u32 = h2 + c
    c = g2 >> 26
    g2 = g2 & 0x3FFFFFF
    var g3: u32 = h3 + c
    c = g3 >> 26
    g3 = g3 & 0x3FFFFFF
    var g4: u32 = h4 + c - (1 << 26)

    # Select h or g based on whether g overflowed (constant-time)
    # mask is all-ones if g4 bit 31 is 0 (g >= 0, meaning h >= p), all-zeros otherwise
    # Use & 0x80000000 instead of >> 31 to avoid signed-shift ambiguity in the interpreter
    val mask: u32 = if (g4 & 0x80000000) == 0: 0xFFFFFFFF else: 0
    g0 = g0 & mask
    g1 = g1 & mask
    g2 = g2 & mask
    g3 = g3 & mask
    g4 = g4 & mask
    val nmask: u32 = ~mask
    h0 = (h0 & nmask) | g0
    h1 = (h1 & nmask) | g1
    h2 = (h2 & nmask) | g2
    h3 = (h3 & nmask) | g3
    h4 = (h4 & nmask) | g4

    # Reassemble h as 4 u32 words
    var f0: u64 = h0.to_u64() | (h1.to_u64() << 26)
    var f1: u64 = (h1.to_u64() >> 6) | (h2.to_u64() << 20)
    var f2: u64 = (h2.to_u64() >> 12) | (h3.to_u64() << 14)
    var f3: u64 = (h3.to_u64() >> 18) | (h4.to_u64() << 8)

    # Add pad (s)
    f0 = f0 + st.pad0.to_u64()
    f1 = f1 + st.pad1.to_u64() + (f0 >> 32)
    f2 = f2 + st.pad2.to_u64() + (f1 >> 32)
    f3 = f3 + st.pad3.to_u64() + (f2 >> 32)

    # Output as 16 bytes (little-endian)
    var tag: [u8] = []
    _put_le_u32(tag, (f0 & 0xFFFFFFFF).to_u32())
    _put_le_u32(tag, (f1 & 0xFFFFFFFF).to_u32())
    _put_le_u32(tag, (f2 & 0xFFFFFFFF).to_u32())
    _put_le_u32(tag, (f3 & 0xFFFFFFFF).to_u32())
    tag

fn _put_le_u32(buf: [u8], val_: u32):
    """Append u32 as 4 bytes little-endian."""
    buf.push((val_ & 0xFF).to_u8())
    buf.push(((val_ >> 8) & 0xFF).to_u8())
    buf.push(((val_ >> 16) & 0xFF).to_u8())
    buf.push(((val_ >> 24) & 0xFF).to_u8())

# ============================================================================
# Public API
# ============================================================================

fn poly1305_mac(key: [u8], message: [u8]) -> [u8]:
    """Compute Poly1305 MAC.

    Args:
        key: 32-byte one-time key (r || s).
        message: Data to authenticate.

    Returns: 16-byte authentication tag.
    """
    var st = poly1305_init(key)

    var pos: u64 = 0
    while pos + 16 <= message.len():
        # Full 16-byte block
        var block: [u8] = []
        var j: u64 = 0
        while j < 16:
            block.push(message[pos + j])
            j = j + 1
        st = poly1305_block(st, block, 16, 1)
        pos = pos + 16

    # Final partial block (if any)
    val remaining = message.len() - pos
    if remaining > 0:
        var block: [u8] = []
        var j: u64 = 0
        while j < remaining:
            block.push(message[pos + j])
            j = j + 1
        # Pad with 0x01 byte followed by zeros to 16 bytes
        block.push(1)
        while block.len() < 16:
            block.push(0)
        st = poly1305_block(st, block, 16, 0)

    poly1305_finalize(st)
