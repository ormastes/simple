fn _s1(x: u8) -> u8:
    _u8_at(_s1_table(), x.to_u64())

fn _s2(x: u8) -> u8:
    _u8_at(_s2_table(), x.to_u64())

# SB3 = inverse of SB1 = _s1inv_table
fn _s3(x: u8) -> u8:
    _u8_at(_s1inv_table(), x.to_u64())

# SB4 = inverse of SB2
fn _s4(x: u8) -> u8:
    _u8_at(_s4_table(), x.to_u64())

# ============================================================================
# Substitution layer (RFC 5794 §2.4.2)
# SL1 (odd rounds):  i%4==0→SB1, i%4==1→SB2, i%4==2→SB3, i%4==3→SB4
# SL2 (even rounds): i%4==0→SB3, i%4==1→SB4, i%4==2→SB1, i%4==3→SB2
# ============================================================================

fn _sub_sl1(state: [u8]) -> [u8]:
    var out: [u8] = _new_buf(16)
    var i: u64 = 0
    while i < 16:
        val b: u8 = _u8_at(state, i)
        val r: u8 = if (i % 4) == 0: _s1(b)
                    else if (i % 4) == 1: _s2(b)
                    else if (i % 4) == 2: _s3(b)
                    else: _s4(b)
        out.push(r)
        i = i + 1
    out

fn _sub_sl2(state: [u8]) -> [u8]:
    var out: [u8] = _new_buf(16)
    var i: u64 = 0
    while i < 16:
        val b: u8 = _u8_at(state, i)
        val r: u8 = if (i % 4) == 0: _s3(b)
                    else if (i % 4) == 1: _s4(b)
                    else if (i % 4) == 2: _s1(b)
                    else: _s2(b)
        out.push(r)
        i = i + 1
    out

# ============================================================================
# Diffusion layer (DL) — RFC 5794 §2.3.2
#
# The 16×16 binary involution matrix. Each output byte is XOR of selected input bytes.
# The matrix definition from RFC 5794 §2.4.4:
#   b0  = b3  ^ b4  ^ b6  ^ b8  ^ b9  ^ b13 ^ b14
#   b1  = b2  ^ b5  ^ b7  ^ b8  ^ b9  ^ b12 ^ b15
#   b2  = b1  ^ b4  ^ b6  ^ b10 ^ b11 ^ b12 ^ b15
#   b3  = b0  ^ b5  ^ b7  ^ b10 ^ b11 ^ b13 ^ b14
#   b4  = b0  ^ b2  ^ b5  ^ b8  ^ b11 ^ b14 ^ b15
#   b5  = b1  ^ b3  ^ b4  ^ b9  ^ b10 ^ b14 ^ b15
#   b6  = b0  ^ b2  ^ b7  ^ b9  ^ b10 ^ b12 ^ b13
#   b7  = b1  ^ b3  ^ b6  ^ b8  ^ b11 ^ b12 ^ b13
#   b8  = b0  ^ b1  ^ b4  ^ b7  ^ b10 ^ b13 ^ b15
#   b9  = b0  ^ b1  ^ b5  ^ b6  ^ b11 ^ b12 ^ b14
#   b10 = b2  ^ b3  ^ b5  ^ b6  ^ b8  ^ b13 ^ b15
#   b11 = b2  ^ b3  ^ b4  ^ b7  ^ b9  ^ b12 ^ b14
#   b12 = b1  ^ b2  ^ b6  ^ b7  ^ b9  ^ b11 ^ b14
#   b13 = b0  ^ b3  ^ b6  ^ b7  ^ b8  ^ b10 ^ b15
#   b14 = b0  ^ b3  ^ b4  ^ b5  ^ b9  ^ b11 ^ b12
#   b15 = b1  ^ b2  ^ b4  ^ b5  ^ b8  ^ b10 ^ b13 (wait, RFC uses ^; b15 derived from rows)
# ============================================================================

fn _diffuse(state: [u8]) -> [u8]:
    val b0:  u8 = _u8_at(state, 0)
    val b1:  u8 = _u8_at(state, 1)
    val b2:  u8 = _u8_at(state, 2)
    val b3:  u8 = _u8_at(state, 3)
    val b4:  u8 = _u8_at(state, 4)
    val b5:  u8 = _u8_at(state, 5)
    val b6:  u8 = _u8_at(state, 6)
    val b7:  u8 = _u8_at(state, 7)
    val b8:  u8 = _u8_at(state, 8)
    val b9:  u8 = _u8_at(state, 9)
    val b10: u8 = _u8_at(state, 10)
    val b11: u8 = _u8_at(state, 11)
    val b12: u8 = _u8_at(state, 12)
    val b13: u8 = _u8_at(state, 13)
    val b14: u8 = _u8_at(state, 14)
    val b15: u8 = _u8_at(state, 15)

    var out: [u8] = _new_buf(16)
    out.push(b3  ^ b4  ^ b6  ^ b8  ^ b9  ^ b13 ^ b14)
    out.push(b2  ^ b5  ^ b7  ^ b8  ^ b9  ^ b12 ^ b15)
    out.push(b1  ^ b4  ^ b6  ^ b10 ^ b11 ^ b12 ^ b15)
    out.push(b0  ^ b5  ^ b7  ^ b10 ^ b11 ^ b13 ^ b14)
    out.push(b0  ^ b2  ^ b5  ^ b8  ^ b11 ^ b14 ^ b15)
    out.push(b1  ^ b3  ^ b4  ^ b9  ^ b10 ^ b14 ^ b15)
    out.push(b0  ^ b2  ^ b7  ^ b9  ^ b10 ^ b12 ^ b13)
    out.push(b1  ^ b3  ^ b6  ^ b8  ^ b11 ^ b12 ^ b13)
    out.push(b0  ^ b1  ^ b4  ^ b7  ^ b10 ^ b13 ^ b15)
    out.push(b0  ^ b1  ^ b5  ^ b6  ^ b11 ^ b12 ^ b14)
    out.push(b2  ^ b3  ^ b5  ^ b6  ^ b8  ^ b13 ^ b15)
    out.push(b2  ^ b3  ^ b4  ^ b7  ^ b9  ^ b12 ^ b14)
    out.push(b1  ^ b2  ^ b6  ^ b7  ^ b9  ^ b11 ^ b14)
    out.push(b0  ^ b3  ^ b6  ^ b7  ^ b8  ^ b10 ^ b15)
    out.push(b0  ^ b3  ^ b4  ^ b5  ^ b9  ^ b11 ^ b12)
    out.push(b1  ^ b2  ^ b4  ^ b5  ^ b8  ^ b10 ^ b13)
    out

# ============================================================================
# XOR two 16-byte arrays
# ============================================================================

fn _xor16(a: [u8], b: [u8]) -> [u8]:
    var out: [u8] = _new_buf(16)
    var i: u64 = 0
    while i < 16:
        out.push(_u8_at(a, i) ^ _u8_at(b, i))
        i = i + 1
    out

# ============================================================================
# Key schedule constants CK1, CK2, CK3 (RFC 5794 §2.5)
# Derived from fractional parts of 1/pi, 1/e, 1/sqrt(2)
# ============================================================================

fn _ck1() -> [u8]:
    var c: [u8] = _new_buf(16)
    c.push(0x51u8)
    c.push(0x7cu8)
    c.push(0xc1u8)
    c.push(0xb7u8)
    c.push(0x27u8)
    c.push(0x22u8)
    c.push(0x0au8)
    c.push(0x94u8)
    c.push(0xfeu8)
    c.push(0x13u8)
    c.push(0xabu8)
    c.push(0xe8u8)
    c.push(0xfau8)
    c.push(0x9au8)
    c.push(0x6eu8)
    c.push(0xe0u8)
    c

fn _ck2() -> [u8]:
    var c: [u8] = _new_buf(16)
    c.push(0x6du8)
    c.push(0xb1u8)
    c.push(0x4au8)
    c.push(0xccu8)
    c.push(0x9eu8)
    c.push(0x21u8)
    c.push(0xc8u8)
    c.push(0x20u8)
    c.push(0xffu8)
    c.push(0x28u8)
    c.push(0xb1u8)
    c.push(0xd5u8)
    c.push(0xefu8)
    c.push(0x5du8)
    c.push(0xe2u8)
    c.push(0xb0u8)
    c

fn _ck3() -> [u8]:
    var c: [u8] = _new_buf(16)
    c.push(0xdbu8)
    c.push(0x92u8)
    c.push(0x37u8)
    c.push(0x1du8)
    c.push(0x21u8)
    c.push(0x26u8)
    c.push(0xe9u8)
    c.push(0x70u8)
    c.push(0x03u8)
    c.push(0x24u8)
    c.push(0x97u8)
    c.push(0x75u8)
    c.push(0x04u8)
    c.push(0xe8u8)
    c.push(0xc9u8)
    c.push(0x0eu8)
    c

# ============================================================================
# Key schedule helpers: FO and FE (RFC 5794 §2.5)
# FO(x, ck) = DL(SO(x XOR ck))   -- odd substitution
# FE(x, ck) = DL(SE(x XOR ck))   -- even substitution
# ============================================================================

fn _fo(x: [u8], ck: [u8]) -> [u8]:
    _diffuse(_sub_sl1(_xor16(x, ck)))

fn _fe(x: [u8], ck: [u8]) -> [u8]:
    _diffuse(_sub_sl2(_xor16(x, ck)))

# ============================================================================
# 128-bit left-rotation of a 16-byte block by n bytes (byte granularity)
# RFC 5794 key schedule uses 19-bit and 31-bit byte-level rotations
# ============================================================================

fn _rot128_bytes(blk: [u8], n: u64) -> [u8]:
    # n is number of BITS to rotate left; n is always a multiple of 8 in ARIA
    # RFC 5794 uses 19 and 31 bit rotations at byte level:
    # ">>>" means right rotation in bytes — we implement byte-level right rotation
    # Actually RFC 5794 §2.5 uses right-rotation by bytes:
    #   X <<< n means rotate left by n bits
    # We work at bit level: rotate 128-bit value left by n bits.
    # blk[0] is the most-significant byte.
    val nbits: u64 = n % 128
    val nbytes: u64 = nbits / 8
    val shift:  u64 = nbits % 8
    var out: [u8] = _new_buf(16)
    var i: u64 = 0
    if shift == 0:
        while i < 16:
            out.push(_u8_at(blk, (i + nbytes) % 16))
            i = i + 1
    else:
        val rshift: u64 = 8 - shift
        while i < 16:
            val cur: u64 = _u8_at(blk, (i + nbytes) % 16).to_u64()
            val nxt: u64 = _u8_at(blk, (i + nbytes + 1) % 16).to_u64()
            out.push(((cur << shift) | (nxt >> rshift)).to_u8())
            i = i + 1
    out

# Right-rotation by n bits = left-rotation by (128-n) bits
fn _rrot128_bits(blk: [u8], n: u64) -> [u8]:
    _rot128_bytes(blk, 128 - (n % 128))

# ============================================================================
# ARIA key schedule (RFC 5794 §2.5)
#
# For a key of length klen bytes:
#   - 128-bit: Nr=12, 13 round keys (W0..W3 → ek1..ek13)
#   - 192-bit: Nr=14, 15 round keys
#   - 256-bit: Nr=16, 17 round keys
#
# W0 = KL  (left 16 bytes of key, zero-padded)
# W1 = FO(W0, CK1) XOR KR
# W2 = FE(W1, CK2) XOR W0
# W3 = FO(W2, CK3) XOR W1
#
# Round keys (ek) are derived from 128-bit substrings at specified offsets:
#   ek_i = W_{(i-1)%4} <<< offset_i  (right- or left-rotation depending on spec)
# ============================================================================

fn _key_schedule(key: [u8]) -> [[u8]]:
    val klen: u64 = key.len().to_u64()

    # Split key into KL (left 16 bytes) and KR (right part, zero-padded to 16)
    var kl: [u8] = _new_buf(16)
    var kr: [u8] = _new_buf(16)
    var i: u64 = 0
    while i < 16:
        if i < klen:
            kl.push(_u8_at(key, i))
        else:
            kl.push(0x00u8)
        i = i + 1
    i = 0
    while i < 16:
        val ki: u64 = i + 16
        if ki < klen:
            kr.push(_u8_at(key, ki))
        else:
            kr.push(0x00u8)
        i = i + 1

    # For 192/256-bit keys, we need a third 16-byte chunk
    var km: [u8] = _new_buf(16)
    i = 0
    while i < 16:
        val ki: u64 = i + 32
        if ki < klen:
            km.push(_u8_at(key, ki))
        else:
            km.push(0x00u8)
        i = i + 1

    # Select CK based on key length (RFC 5794 §2.5)
    # 128-bit: (CK1, CK2, CK3)
    # 192-bit: (CK2, CK3, CK1)
    # 256-bit: (CK3, CK1, CK2)
    val ck_a: [u8] = if klen == 16: _ck1() else if klen == 24: _ck2() else: _ck3()
    val ck_b: [u8] = if klen == 16: _ck2() else if klen == 24: _ck3() else: _ck1()
    val ck_c: [u8] = if klen == 16: _ck3() else if klen == 24: _ck1() else: _ck2()

    # W0 = KL
    # For 192: W0 = KL XOR (KR || 0..0) — KR is already zero-padded above
    # For 256: W0 = KL XOR KM_left (but the spec uses KL directly as first W)
    # Actually per RFC 5794 §2.5: W0 = KL for all key lengths.
    # The difference is only in how CKs are selected.
    val w0: [u8] = kl

    # W1 = FO(W0, CK_a) XOR KR
    val w1: [u8] = _xor16(_fo(w0, ck_a), kr)

    # W2 = FE(W1, CK_b) XOR W0
    val w2: [u8] = _xor16(_fe(w1, ck_b), w0)

    # W3 = FO(W2, CK_c) XOR W1
    val w3: [u8] = _xor16(_fo(w2, ck_c), w1)

    # For 256-bit keys, XOR KM into W0..W3 before extracting round keys
    # Per RFC 5794 §2.5, for 256-bit: the key schedule uses W0=KL, W1=FO(W0,CK3)^KR,
    # W2=FE(W1,CK1)^W0^KMR, W3=FO(W2,CK2)^W1
    # where KMR = right 16 bytes of the 256-bit key (km above).
    # Let's re-derive carefully per spec for 256-bit:
    # The spec says KL = key[0:16], KR = key[16:32], KM = key[32:48] — but 256=32B, not 48.
    # Actually for 256-bit: KL = key[0:16], KR = key[16:32], CKs = (CK3,CK1,CK2)
    # W0=KL, W1=FO(W0,CK3)^KR, W2=FE(W1,CK1)^W0, W3=FO(W2,CK2)^W1  -- same formula!
    # So the W0-W3 derived above are correct for all key lengths (km is unused, KR handles it).

    # Number of rounds
    val nr: u64 = if klen == 16: 12 else if klen == 24: 14 else: 16

    # Extract round keys: RFC 5794 §2.5 Table 1
    # ek1  = W0 >>> 0   (no rotation)
    # ek2  = W1 <<< 19
    # ek3  = W2 <<< 31
    # ek4  = W3 >>> 61  (= <<< 67)
    # ek5  = W0 >>> 31  (= <<< 97)
    # ek6  = W1 <<< 61
    # ek7  = W2 <<< 77 (= <<< 77)
    # ek8  = W3 >>> 31 = <<< 97
    # ... (pattern: left-rotations alternating with right-rotations)
    # Full table from RFC 5794 §2.5:
    #   ek1  = W0
    #   ek2  = W1 <<< 19
    #   ek3  = W2 <<< 31
    #   ek4  = W3 >>> 61
    #   ek5  = W0 >>> 31
    #   ek6  = W1 <<< 61
    #   ek7  = W2 >>> 19  (=<<< 109)
    #   ek8  = W3 <<< 31
    #   ek9  = W0 <<< 77 (= <<< 77)
    #   ek10 = W1 >>> 31
    #   ek11 = W2 <<< 77
    #   ek12 = W3 >>> 19
    #   ek13 = W0 <<< 31  (if nr>=12)
    #   ek14 = W1 <<< 109 (if nr>=14)
    #   ek15 = W2 >>> 61  (if nr>=14)
    #   ek16 = W3 <<< 19  (if nr>=16)
    #   ek17 = W0 >>> 77  (if nr>=16)
    # Right rotation by n = left rotation by (128-n)

    # RFC 5794 §2.5: each ek_i = W_a XOR (W_b rotated)
    # ek1  = W0 ^ (W1 >>> 19) = W0 ^ (W1 <<< 109)
    # ek2  = W1 ^ (W2 >>> 19) = W1 ^ (W2 <<< 109)
    # ek3  = W2 ^ (W3 >>> 19) = W2 ^ (W3 <<< 109)
    # ek4  = W3 ^ (W0 >>> 19) = W3 ^ (W0 <<< 109)  [note: (W0>>>19) ^ W3 = W3 ^ (W0<<<109)]
    # ek5  = W0 ^ (W1 >>> 31) = W0 ^ (W1 <<< 97)
    # ek6  = W1 ^ (W2 >>> 31) = W1 ^ (W2 <<< 97)
    # ek7  = W2 ^ (W3 >>> 31) = W2 ^ (W3 <<< 97)
    # ek8  = W3 ^ (W0 >>> 31) = W3 ^ (W0 <<< 97)
    # ek9  = W0 ^ (W1 <<< 61)
    # ek10 = W1 ^ (W2 <<< 61)
    # ek11 = W2 ^ (W3 <<< 61)
    # ek12 = W3 ^ (W0 <<< 61)
    # ek13 = W0 ^ (W1 <<< 31)
    # ek14 = W1 ^ (W2 <<< 31)
    # ek15 = W2 ^ (W3 <<< 31)
    # ek16 = W3 ^ (W0 <<< 31)
    # ek17 = W0 ^ (W1 <<< 19)
    var rks: [[u8]] = []
    rks.push(_xor16(w0, _rot128_bytes(w1, 128 - 19)))
    rks.push(_xor16(w1, _rot128_bytes(w2, 128 - 19)))
    rks.push(_xor16(w2, _rot128_bytes(w3, 128 - 19)))
    rks.push(_xor16(w3, _rot128_bytes(w0, 128 - 19)))
    rks.push(_xor16(w0, _rot128_bytes(w1, 128 - 31)))
    rks.push(_xor16(w1, _rot128_bytes(w2, 128 - 31)))
    rks.push(_xor16(w2, _rot128_bytes(w3, 128 - 31)))
    rks.push(_xor16(w3, _rot128_bytes(w0, 128 - 31)))
    rks.push(_xor16(w0, _rot128_bytes(w1, 61)))
    rks.push(_xor16(w1, _rot128_bytes(w2, 61)))
    rks.push(_xor16(w2, _rot128_bytes(w3, 61)))
    rks.push(_xor16(w3, _rot128_bytes(w0, 61)))
    rks.push(_xor16(w0, _rot128_bytes(w1, 31)))
    if nr >= 14:
        rks.push(_xor16(w1, _rot128_bytes(w2, 31)))
        rks.push(_xor16(w2, _rot128_bytes(w3, 31)))
        if nr >= 16:
            rks.push(_xor16(w3, _rot128_bytes(w0, 31)))
            rks.push(_xor16(w0, _rot128_bytes(w1, 19)))
    rks

# ============================================================================
# ARIA encryption (RFC 5794 §2.2)
# ============================================================================

fn aria_encrypt_block(key: [u8], plaintext: [u8]) -> [u8]:
    """Encrypt a 16-byte block with ARIA using a 16/24/32-byte key.

    Args:
        key:       16, 24, or 32-byte key (128/192/256-bit).
        plaintext: 16-byte plaintext block.

    Returns: 16-byte ciphertext block.
    """
    val klen: u64 = key.len().to_u64()
    val nr: u64 = if klen == 16: 12 else if klen == 24: 14 else: 16

    val rks: [[u8]] = _key_schedule(key)

    var state: [u8] = _new_buf(16)
    var i: u64 = 0
    while i < 16:
        state.push(_u8_at(plaintext, i))
        i = i + 1

    # Rounds 1 .. nr-1: XOR key, substitute, diffuse
    var round: u64 = 1
    while round < nr:
        val rk: [u8] = rks[round.to_i64() - 1]
        val after_xor: [u8] = _xor16(state, rk)
        val after_sub: [u8] = if (round % 2) == 1: _sub_sl1(after_xor) else: _sub_sl2(after_xor)
        state = _diffuse(after_sub)
        round = round + 1

    # Final round nr: XOR key, substitute, XOR key (no diffusion)
    val rk_nr: [u8] = rks[nr.to_i64() - 1]
    val after_xor_nr: [u8] = _xor16(state, rk_nr)
    val after_sub_nr: [u8] = if (nr % 2) == 1: _sub_sl1(after_xor_nr) else: _sub_sl2(after_xor_nr)
    val rk_final: [u8] = rks[nr.to_i64()]
    _xor16(after_sub_nr, rk_final)

# ============================================================================
# ARIA decryption (RFC 5794 §2.2)
# Decryption uses the same structure but with reversed round keys,
# and swaps odd/even substitution layers.
# ============================================================================

fn aria_decrypt_block(key: [u8], ciphertext: [u8]) -> [u8]:
    """Decrypt a 16-byte block with ARIA using a 16/24/32-byte key.

    Args:
        key:        16, 24, or 32-byte key (128/192/256-bit).
        ciphertext: 16-byte ciphertext block.

    Returns: 16-byte plaintext block.
    """
    val klen: u64 = key.len().to_u64()
    val nr: u64 = if klen == 16: 12 else if klen == 24: 14 else: 16

    val rks: [[u8]] = _key_schedule(key)

    # Decryption round keys: dk_i = rks[nr+1-i] for i=1..nr+1
    # dk1 = ek_{nr+1}, dk2 = DL(ek_nr), ... dk_nr = DL(ek_2), dk_{nr+1} = ek_1
    # The intermediate decryption keys are diffused versions of the encryption keys.
    var dks: [[u8]] = []
    dks.push(rks[nr.to_i64()])
    var j: u64 = nr - 1
    while j >= 1:
        dks.push(_diffuse(rks[j.to_i64() - 1]))
        if j == 1:
            j = 0
        else:
            j = j - 1
    dks.push(rks[0])

    var state: [u8] = _new_buf(16)
    var i: u64 = 0
    while i < 16:
        state.push(_u8_at(ciphertext, i))
        i = i + 1

    # Rounds 1..nr-1 with decryption keys and swapped substitution
    # For decryption, round parity is flipped vs encryption:
    # encrypt odd rounds use sub_odd; decrypt round 1 uses sub_even (since it's ek_{nr})
    var round: u64 = 1
    while round < nr:
        val rk: [u8] = dks[round.to_i64() - 1]
        val after_xor: [u8] = _xor16(state, rk)
        # Decrypt round parity: if (nr - round + 1) was odd in encryption, use sub_odd
        # In encryption, round r used sub_odd if r%2==1. In decryption with reversed key order,
        # the corresponding encrypt round index is (nr+1 - round).
        # So: if (nr + 1 - round) % 2 == 1 => sub_odd, else sub_even
        val enc_round: u64 = nr + 1 - round
        val after_sub: [u8] = if (enc_round % 2) == 1: _sub_sl1(after_xor) else: _sub_sl2(after_xor)
        state = _diffuse(after_sub)
        round = round + 1

    # Final round: XOR key, substitute, XOR key (no diffusion)
    val rk_nr: [u8] = dks[nr.to_i64() - 1]
    val after_xor_nr: [u8] = _xor16(state, rk_nr)
    val enc_round_final: u64 = 1
    val after_sub_nr: [u8] = if (enc_round_final % 2) == 1: _sub_sl1(after_xor_nr) else: _sub_sl2(after_xor_nr)
    val rk_final: [u8] = dks[nr.to_i64()]
    _xor16(after_sub_nr, rk_final)
