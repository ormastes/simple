#![allow(unnamed_duplicate_typed_args)]
# ARIA Block Cipher — Pure Simple Implementation (RFC 5794 / KS X 1213)
#
# 128-bit block cipher with 128/192/256-bit keys.
# 12/14/16 rounds for 128/192/256-bit keys respectively.
#
# Round structure (RFC 5794 §2.2):
#   - AddRoundKey: XOR state with round key
#   - Substitution: odd rounds use (S1,S2,S1^-1,S2^-1), even use (S1^-1,S2^-1,S1,S2)
#   - Diffusion (DL): binary matrix multiplication on 16 bytes
#   - Final round: AddRoundKey only (no diffusion)
#
# S-box definitions (RFC 5794 §2.4):
#   S1 = AES S-box
#   S2 = AES S-box with bit-reversed input and bit-reversed output
#   S1^-1 = inverse AES S-box
#   S2^-1 = S2^-1 (inverse of S2)
#
# Key schedule (RFC 5794 §2.5): Feistel-like using CK1/CK2/CK3 constants.
#
# Exposed API:
#   aria_encrypt_block(key: [u8], plaintext: [u8]) -> [u8]
#   aria_decrypt_block(key: [u8], ciphertext: [u8]) -> [u8]
#
# No SFFI/Rust FFI — pure Simple, suitable for baremetal.
#
# Reference: RFC 5794 — A Description of the ARIA Encryption Algorithm
#   https://datatracker.ietf.org/doc/html/rfc5794

extern fn rt_array_new_with_cap(cap: i64) -> [u8]

fn _u8_at(buf: [u8], idx: u64) -> u8:
    buf[idx.to_i64()]

fn _new_buf(cap: u64) -> [u8]:
    rt_array_new_with_cap(cap.to_i64())

