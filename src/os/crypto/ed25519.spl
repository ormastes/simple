# Ed25519 — Pure Simple Digital Signatures (RFC 8032)
#
# Implements Ed25519 signing and verification for SimpleOS.
# No SFFI/Rust SFFI — pure Simple language, suitable for baremetal.
#
# Uses the twisted Edwards curve: -x^2 + y^2 = 1 + d*x^2*y^2
# where d = -121665/121666 mod p, p = 2^255 - 19.
#
# Reuses Fe25519 field arithmetic from curve25519.spl.
# Requires SHA-512 from sha512.spl.
#
# Reference: RFC 8032 (Edwards-Curve Digital Signature Algorithm)
# Reference: HWCD08 (Twisted Edwards Curves Revisited)
#
# Sub-files:
#   ed25519_ops.spl    — EdPoint struct, field helpers, curve constants, point ops
#   ed25519_scalar.spl — scalar arithmetic mod L (sc_reduce, sc_muladd)

use os.crypto.ed25519_ops.{EdPoint, fe_neg, fe_is_negative, fe_pow2252m3, fe_sqrt, _fe_sqrt_m1, _ed25519_d, _ed25519_2d, _ed25519_base_point, ed_point_identity, ed_point_add, ed_point_double, ed_point_cselect, ed_scalar_mul, ed_scalar_mul_basepoint, ed_point_encode, ed_point_decode}
use os.crypto.ed25519_scalar.{sc_reduce, sc_muladd, _bytes_to_limbs32, _sc_sub_L}
use os.crypto.dual_backend.{DualBackendMode, DualBackendPreference, dual_backend_choose_bytes, dual_backend_default_config}
# Pure-Simple SHA-512 (FIPS 180-4) — drop-in replacement for the
# baremetal C `rt_sha512_*` extern that has no interpreter dispatch.
# Brings `rotr64` into scope transitively for the indexed sha512_bytes lib.
use std.crypto.sha512.{sha512_bytes}
use std.crypto.types.{rotr64}
extern fn serial_println(msg: text)
extern fn rt_tls13_sha512_full(data: [u8]) -> [u8]
extern fn rt_ed25519_sc_reduce_64(data: [u8]) -> [u8]
extern fn rt_ed25519_sc_muladd(a: [u8], b: [u8], c: [u8]) -> [u8]
extern fn rt_ed25519_sign_seed(private_seed: [u8], public_key: [u8], message: [u8]) -> [u8]

# ============================================================================
# Ed25519 Scalar Clamping
# ============================================================================

fn _ed25519_clamp(h: [u8]) -> [u8]:
    """Clamp the lower 32 bytes of SHA-512 output per Ed25519 spec.

    Clear bits 0, 1, 2 of first byte.
    Clear bit 255 (top bit of byte 31).
    Set bit 254 of byte 31.
    """
    var clamped: [u8] = []
    var i: u64 = 0
    while i < 32:
        var byte = _u8_at(h, i)
        if i == 0:
            byte = byte & 0xF8
        if i == 31:
            byte = (byte & 0x7F) | 0x40
        clamped.push(byte)
        i = i + 1
    clamped

fn _ed25519_reduce_32_to_scalar(s: [u8]) -> [u8]:
    var wide: [u8] = []
    var i: u64 = 0
    while i < 64:
        if i < s.len():
            wide.push(_u8_at(s, i))
        else:
            wide.push(0)
        i = i + 1
    sc_reduce(wide)

# ============================================================================
# SHA-512 (pure-Simple) — bridges [u8] <-> list for std.crypto.sha512
# ============================================================================

fn _sha512_u8(data: [u8]) -> [u8]:
    """SHA-512 over [u8], returning [u8].

    Wraps `std.crypto.sha512.sha512_bytes` (pure-Simple, FIPS 180-4) so the
    rest of this module can stay in `[u8]`. Avoids the `rt_sha512_hash` /
    `rt_sha512_byte` baremetal externs which have no interpreter dispatch.
    """
    serial_println("[ed25519] pure sha512: pack start")
    var lst: list = []
    var i: u64 = 0
    while i < data.len():
        lst.push(data[i].to_i64())
        i = i + 1
    serial_println("[ed25519] pure sha512: pack done")
    serial_println("[ed25519] pure sha512: hash start")
    val h_lst = sha512_bytes(lst)
    serial_println("[ed25519] pure sha512: hash done")
    var out: [u8] = []
    var j: i64 = 0
    while j < h_lst.len():
        out.push((h_lst[j] & 0xFF).to_u8())
        j = j + 1
    out

# ============================================================================
# SHA-512 mod L helper
# ============================================================================

fn _sha512_modl(data: [u8]) -> [u8]:
    """Compute SHA-512(data) then reduce the 64-byte result modulo L.

    Returns 32-byte scalar.
    """
    val hash = _sha512_u8(data)
    val reduced = rt_ed25519_sc_reduce_64(hash)
    if reduced.len() == 32:
        return reduced
    sc_reduce(hash)

fn _sha512_u8_live(data: [u8]) -> [u8]:
    rt_tls13_sha512_full(data)

fn _sha512_modl_live(data: [u8]) -> [u8]:
    serial_println("[ed25519] live modl: sha512 start")
    val hash = _sha512_u8_live(data)
    serial_println("[ed25519] live modl: sha512 done")
    serial_println("[ed25519] live modl: reduce start")
    val reduced = rt_ed25519_sc_reduce_64(hash)
    serial_println("[ed25519] live modl: reduce done")
    reduced

fn _sc_muladd_live(a: [u8], b: [u8], c: [u8]) -> [u8]:
    rt_ed25519_sc_muladd(a, b, c)

fn _ed25519_nonzero_count(data: [u8]) -> u64:
    var count: u64 = 0
    var i: u64 = 0
    while i < data.len():
        if _u8_at(data, i) != 0:
            count = count + 1
        i = i + 1
    count

fn _ed25519_edge_byte(data: [u8], last: bool) -> u8:
    if data.len() == 0:
        return 0
    if last:
        return _u8_at(data, data.len() - 1)
    _u8_at(data, 0)

fn _ed25519_trace_bytes(label: text, data: [u8]):
    serial_println("[ed25519] trace " + label + " len=" + data.len().to_text() +
        " nz=" + _ed25519_nonzero_count(data).to_text() +
        " first=" + _ed25519_edge_byte(data, false).to_u64().to_text() +
        " last=" + _ed25519_edge_byte(data, true).to_u64().to_text())

# ============================================================================
# Pure-Simple [u8] indexing helper
# ============================================================================
#
# Historically this module delegated to `rt_ed25519_keypair`/`rt_ed25519_sign`/
# `rt_ed25519_verify` baremetal C externs. Those have no interpreter dispatch,
# so the public API silently produced zero pubkeys / empty signatures and
# could never byte-match RFC 8032 §7.1 vectors. See
# `doc/08_tracking/bug/ed25519_rfc8032_vector_mismatch_2026-05-01.md`. The
# pure-Simple code below uses the field/scalar/point primitives already in
# this file.
#
# Baremetal note: `_ed25519_*` C helpers in `baremetal_stubs.c` are now
# orphaned for the public API. Baremetal Ed25519 has not been re-validated
# post-rewire.
#
# Constant-time note: `ed_scalar_mul` IS constant-time as of 2026-05-01.
# It uses an always-add-and-select inner loop with `ed_point_cselect` (XOR-mask
# pattern, mirrors `fe_cswap` from curve25519.spl). No data-dependent branch on
# scalar bits; runtime is independent of scalar Hamming weight. Fix tracked in
# `doc/08_tracking/bug/ed25519_scalar_mul_not_constant_time_2026-05-01.md`.

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

fn _u8_at(data: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(data, idx.to_i64()).to_u8()

# ============================================================================
# Public API — pure Simple, RFC 8032 §5.1 conformant
# ============================================================================

fn ed25519_keypair_from_seed(seed: [u8]) -> ([u8], [u8]):
    """Derive (private_seed, public_key) from a 32-byte seed.

    Per RFC 8032 §5.1.5:
      1. h = SHA-512(seed)              # 64 bytes
      2. a = clamp(h[0..32])            # scalar
      3. A = a * B                      # scalar mult by base point
      4. encode A as 32 bytes (little-endian y, top bit = sign of x)
    """
    val h = _sha512_u8(seed)
    val a = _ed25519_clamp(h)
    val big_a = ed_scalar_mul_basepoint(_ed25519_reduce_32_to_scalar(a))
    val pk = ed_point_encode(big_a)
    (seed, pk)

fn ed25519_sign(private_seed: [u8], public_key: [u8], message: [u8]) -> [u8]:
    """Sign a message with Ed25519. Returns a 64-byte signature (R || S).

    Per RFC 8032 §5.1.6:
      h = SHA-512(seed)
      a = clamp(h[0..32]); prefix = h[32..64]
      r = SHA-512(prefix || M) mod L
      R = r * B
      k = SHA-512(encode(R) || A || M) mod L
      S = (r + k * a) mod L
      signature = encode(R) || S
    """
    serial_println("[ed25519] sign: seed sha512 start")
    val h = _sha512_u8(private_seed)
    serial_println("[ed25519] sign: seed sha512 done")
    val a = _ed25519_clamp(h)
    # NOTE(constant-time): `a` is the secret scalar. `ed_scalar_mul` is
    # constant-time as of 2026-05-01 (always-add-and-select), so timing does
    # not leak Hamming weight of `a`. See
    # doc/08_tracking/bug/ed25519_scalar_mul_not_constant_time_2026-05-01.md.

    # prefix = h[32..64]
    var prefix: [u8] = []
    var i: u64 = 32
    while i < 64:
        prefix.push(_u8_at(h, i))
        i = i + 1

    # r = SHA-512(prefix || M) mod L
    var prefix_msg: [u8] = []
    i = 0
    while i < prefix.len():
        prefix_msg.push(_u8_at(prefix, i))
        i = i + 1
    i = 0
    while i < message.len():
        prefix_msg.push(_u8_at(message, i))
        i = i + 1
    serial_println("[ed25519] sign: nonce hash start")
    val r = _sha512_modl(prefix_msg)
    serial_println("[ed25519] sign: nonce hash done")

    # R = r * B; encoded R = ed_point_encode(R)
    serial_println("[ed25519] sign: R scalar mul start")
    val big_r = ed_scalar_mul_basepoint(r)
    serial_println("[ed25519] sign: R scalar mul done")
    val r_enc = ed_point_encode(big_r)
    serial_println("[ed25519] sign: R encode done")

    # k = SHA-512(R_enc || A || M) mod L
    var k_input: [u8] = []
    i = 0
    while i < r_enc.len():
        k_input.push(_u8_at(r_enc, i))
        i = i + 1
    i = 0
    while i < public_key.len():
        k_input.push(_u8_at(public_key, i))
        i = i + 1
    i = 0
    while i < message.len():
        k_input.push(_u8_at(message, i))
        i = i + 1
    serial_println("[ed25519] sign: challenge hash start")
    val k = _sha512_modl(k_input)
    serial_println("[ed25519] sign: challenge hash done")

    # S = (r + k * a) mod L  (sc_muladd computes (a*b + c) mod L)
    serial_println("[ed25519] sign: S muladd start")
    val s = sc_muladd(k, a, r)
    serial_println("[ed25519] sign: S muladd done")
    _ed25519_trace_bytes("s", s)
    var s_copy_probe: [u8] = []
    i = 0
    while i < s.len():
        s_copy_probe.push(_u8_at(s, i))
        i = i + 1
    _ed25519_trace_bytes("s_copy", s_copy_probe)

    # signature = R_enc (32) || S (32)
    var sig: [u8] = []
    i = 0
    while i < 64:
        if i < 32:
            sig.push(_u8_at(r_enc, i))
        else:
            sig.push(_u8_at(s, i - 32))
        i = i + 1
    serial_println("[ed25519] sign: done")
    sig

fn _ed25519_sign_live_runtime(private_seed: [u8], public_key: [u8], message: [u8]) -> [u8]:
    val direct_sig = rt_ed25519_sign_seed(private_seed, public_key, message)
    if direct_sig.len() == 64:
        return direct_sig
    serial_println("[ed25519] sign: seed sha512 start")
    val h = _sha512_u8_live(private_seed)
    serial_println("[ed25519] sign: seed sha512 done")
    val a = _ed25519_clamp(h)

    var prefix: [u8] = []
    var i: u64 = 32
    while i < 64:
        prefix.push(_u8_at(h, i))
        i = i + 1

    var prefix_msg: [u8] = []
    i = 0
    while i < prefix.len():
        prefix_msg.push(_u8_at(prefix, i))
        i = i + 1
    i = 0
    while i < message.len():
        prefix_msg.push(_u8_at(message, i))
        i = i + 1
    serial_println("[ed25519] sign: nonce hash start")
    val r = _sha512_modl_live(prefix_msg)
    serial_println("[ed25519] sign: nonce hash done")

    serial_println("[ed25519] sign: R scalar mul start")
    val big_r = ed_scalar_mul_basepoint(r)
    serial_println("[ed25519] sign: R scalar mul done")
    val r_enc = ed_point_encode(big_r)
    serial_println("[ed25519] sign: R encode done")

    var k_input: [u8] = []
    i = 0
    while i < r_enc.len():
        k_input.push(_u8_at(r_enc, i))
        i = i + 1
    i = 0
    while i < public_key.len():
        k_input.push(_u8_at(public_key, i))
        i = i + 1
    i = 0
    while i < message.len():
        k_input.push(_u8_at(message, i))
        i = i + 1
    serial_println("[ed25519] sign: challenge hash start")
    val k = _sha512_modl_live(k_input)
    serial_println("[ed25519] sign: challenge hash done")

    serial_println("[ed25519] sign: S muladd start")
    val s = _sc_muladd_live(k, a, r)
    serial_println("[ed25519] sign: S muladd done")

    var sig: [u8] = []
    i = 0
    while i < 64:
        if i < 32:
            sig.push(_u8_at(r_enc, i))
        else:
            sig.push(_u8_at(s, i - 32))
        i = i + 1
    serial_println("[ed25519] sign: done")
    sig

fn ed25519_sign_live_runtime_only(private_seed: [u8], public_key: [u8], message: [u8]) -> [u8]:
    _ed25519_sign_live_runtime(private_seed, public_key, message)

fn ed25519_sign_live_pure_only(private_seed: [u8], public_key: [u8], message: [u8]) -> [u8]:
    ed25519_sign(private_seed, public_key, message)

fn ed25519_sign_live(private_seed: [u8], public_key: [u8], message: [u8]) -> [u8]:
    val config = dual_backend_default_config()
    val inputs: [text] = []
    if config.mode == DualBackendMode.Normal:
        if config.preference == DualBackendPreference.PureSimpleFirst:
            val pure_output = ed25519_sign(private_seed, public_key, message)
            if pure_output.len() > 0:
                return pure_output
            return _ed25519_sign_live_runtime(private_seed, public_key, message)
        val runtime_output = _ed25519_sign_live_runtime(private_seed, public_key, message)
        if runtime_output.len() > 0:
            return runtime_output
        return ed25519_sign(private_seed, public_key, message)

    serial_println("[ed25519] dual-run runtime start")
    val runtime_output = _ed25519_sign_live_runtime(private_seed, public_key, message)
    serial_println("[ed25519] dual-run runtime done")
    serial_println("[ed25519] dual-run pure start")
    val pure_output = ed25519_sign(private_seed, public_key, message)
    serial_println("[ed25519] dual-run pure done")
    dual_backend_choose_bytes(
        "ed25519",
        "sign_live",
        config,
        inputs,
        runtime_output,
        pure_output
    )

fn ed25519_verify(public_key: [u8], message: [u8], signature: [u8]) -> bool:
    """Verify an Ed25519 signature. Returns true on success.

    Per RFC 8032 §5.1.7:
      parse R = signature[0..32], S = signature[32..64]
      reject if S >= L
      A = decode(public_key);   reject if invalid
      Rp = decode(R);           reject if invalid
      k = SHA-512(R || A || M) mod L
      check  S * B  ==  R + k * A
    """
    if signature.len() != 64:
        return false
    if public_key.len() != 32:
        return false

    # Split signature
    var r_bytes: [u8] = []
    var s_bytes: [u8] = []
    var i: u64 = 0
    while i < 32:
        r_bytes.push(signature[i])
        i = i + 1
    while i < 64:
        s_bytes.push(signature[i])
        i = i + 1

    # Reject non-canonical S (S must be < L)
    if _sc_is_geq_L(s_bytes):
        return false

    # Decode A and R; if either fails, verification fails
    val big_a = ed_point_decode(public_key)
    val big_r = ed_point_decode(r_bytes)

    # k = SHA-512(R || A || M) mod L
    var k_input: [u8] = []
    i = 0
    while i < r_bytes.len():
        k_input.push(r_bytes[i])
        i = i + 1
    i = 0
    while i < public_key.len():
        k_input.push(public_key[i])
        i = i + 1
    i = 0
    while i < message.len():
        k_input.push(message[i])
        i = i + 1
    val k = _sha512_modl(k_input)

    # Check  S * B  ==  R + k * A
    val sb = ed_scalar_mul_basepoint(s_bytes)
    val ka = ed_scalar_mul(k, big_a)
    val rhs = ed_point_add(p1: big_r, p2: ka)

    # Compare encoded forms (avoids projective-coordinate equivalence pitfalls)
    val sb_enc = ed_point_encode(sb)
    val rhs_enc = ed_point_encode(rhs)
    _bytes_equal(a: sb_enc, b: rhs_enc)

# ============================================================================
# Internal Helpers
# ============================================================================

fn _sc_is_geq_L(s: [u8]) -> bool:
    """Check if a 32-byte scalar s >= L.

    Used to reject non-canonical S values in verification.
    """
    val limbs = _bytes_to_limbs32(s, 8)
    val sub = _sc_sub_L(limbs)
    # If borrow (limb[8]) is 0, s >= L
    sub[8] == 0

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    """Constant-time comparison of two byte arrays."""
    if a.len() != b.len():
        return false
    var diff: u8 = 0
    var i: u64 = 0
    while i < a.len():
        diff = diff | (a[i] ^ b[i])
        i = i + 1
    diff == 0

# ============================================================================
# Self-Test — RFC 8032 Section 7.1 Test Vectors
# ============================================================================

fn ed25519_self_test() -> Result<bool, text>:
    """Run Ed25519 against RFC 8032 §7.1 test vectors. Returns Ok or Err."""
    _ed25519_self_test_pure_simple()

fn _ed25519_self_test_pure_simple() -> Result<bool, text>:
    """Original Pure Simple Ed25519 self-test — disabled in baremetal."""
    # --- Test Vector 1 (RFC 8032 Section 7.1, TEST 1) ---
    # SECRET KEY (seed): 9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60
    # PUBLIC KEY:        d75a980182b10ab7d54bfed3c964073a0ee172f3daa6232 5af021a68f707511a
    # MESSAGE:           (empty)
    # SIGNATURE:         e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e06522490155
    #                    5fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b
    val seed1: [u8] = [
        0x9d, 0x61, 0xb1, 0x9d, 0xef, 0xfd, 0x5a, 0x60,
        0xba, 0x84, 0x4a, 0xf4, 0x92, 0xec, 0x2c, 0xc4,
        0x44, 0x49, 0xc5, 0x69, 0x7b, 0x32, 0x69, 0x19,
        0x70, 0x3b, 0xac, 0x03, 0x1c, 0xae, 0x7f, 0x60
    ]
    val expected_pub1: [u8] = [
        0xd7, 0x5a, 0x98, 0x01, 0x82, 0xb1, 0x0a, 0xb7,
        0xd5, 0x4b, 0xfe, 0xd3, 0xc9, 0x64, 0x07, 0x3a,
        0x0e, 0xe1, 0x72, 0xf3, 0xda, 0xa6, 0x23, 0x25,
        0xaf, 0x02, 0x1a, 0x68, 0xf7, 0x07, 0x51, 0x1a
    ]
    val expected_sig1: [u8] = [
        0xe5, 0x56, 0x43, 0x00, 0xc3, 0x60, 0xac, 0x72,
        0x90, 0x86, 0xe2, 0xcc, 0x80, 0x6e, 0x82, 0x8a,
        0x84, 0x87, 0x7f, 0x1e, 0xb8, 0xe5, 0xd9, 0x74,
        0xd8, 0x73, 0xe0, 0x65, 0x22, 0x49, 0x01, 0x55,
        0x5f, 0xb8, 0x82, 0x15, 0x90, 0xa3, 0x3b, 0xac,
        0xc6, 0x1e, 0x39, 0x70, 0x1c, 0xf9, 0xb4, 0x6b,
        0xd2, 0x5b, 0xf5, 0xf0, 0x59, 0x5b, 0xbe, 0x24,
        0x65, 0x51, 0x41, 0x43, 0x8e, 0x7a, 0x10, 0x0b
    ]
    val msg1: [u8] = []

    # 1. Verify keypair derivation
    val kp1 = ed25519_keypair_from_seed(seed1)
    val pub1 = kp1.1
    if not _bytes_equal(a: pub1, b: expected_pub1):
        return Err("Ed25519 self-test FAIL: test vector 1 public key mismatch")

    # 2. Verify signing
    val sig1 = ed25519_sign(private_seed: seed1, public_key: pub1, message: msg1)
    if not _bytes_equal(a: sig1, b: expected_sig1):
        return Err("Ed25519 self-test FAIL: test vector 1 signature mismatch")

    # 3. Verify verification accepts valid signature
    if not ed25519_verify(public_key: pub1, message: msg1, signature: sig1):
        return Err("Ed25519 self-test FAIL: test vector 1 verify rejected valid signature")

    # 4. Verify verification rejects corrupted signature
    var bad_sig1: [u8] = []
    var bsi: u64 = 0
    while bsi < sig1.len():
        bad_sig1.push(sig1[bsi])
        bsi = bsi + 1
    bad_sig1[0] = bad_sig1[0] ^ 0x01  # Flip one bit
    if ed25519_verify(public_key: pub1, message: msg1, signature: bad_sig1):
        return Err("Ed25519 self-test FAIL: verify accepted corrupted signature")

    # --- Test Vector 2 (RFC 8032 Section 7.1, TEST 2) ---
    # SECRET KEY: 4ccd089b28ff96da9db6c346ec114e0f5b8a319f35aba624da8cf6ed4fb8a6fb
    # PUBLIC KEY: 3d4017c3e843895a92b70aa74d1b7ebc9c982ccf2ec4968cc0cd55f12af4660c
    # MESSAGE:    72 (single byte 0x72)
    # SIGNATURE:  92a009a9f0d4cab8720e820b5f642540a2b27b5416503f8fb3762223ebdb69da
    #             085ac1e43e159c7e94b2ba95c9ee6f5f6d90bd3e0dfd0e2e78e188cc7e00d5b2
    val seed2: [u8] = [
        0x4c, 0xcd, 0x08, 0x9b, 0x28, 0xff, 0x96, 0xda,
        0x9d, 0xb6, 0xc3, 0x46, 0xec, 0x11, 0x4e, 0x0f,
        0x5b, 0x8a, 0x31, 0x9f, 0x35, 0xab, 0xa6, 0x24,
        0xda, 0x8c, 0xf6, 0xed, 0x4f, 0xb8, 0xa6, 0xfb
    ]
    val expected_pub2: [u8] = [
        0x3d, 0x40, 0x17, 0xc3, 0xe8, 0x43, 0x89, 0x5a,
        0x92, 0xb7, 0x0a, 0xa7, 0x4d, 0x1b, 0x7e, 0xbc,
        0x9c, 0x98, 0x2c, 0xcf, 0x2e, 0xc4, 0x96, 0x8c,
        0xc0, 0xcd, 0x55, 0xf1, 0x2a, 0xf4, 0x66, 0x0c
    ]
    val expected_sig2: [u8] = [
        0x92, 0xa0, 0x09, 0xa9, 0xf0, 0xd4, 0xca, 0xb8,
        0x72, 0x0e, 0x82, 0x0b, 0x5f, 0x64, 0x25, 0x40,
        0xa2, 0xb2, 0x7b, 0x54, 0x16, 0x50, 0x3f, 0x8f,
        0xb3, 0x76, 0x22, 0x23, 0xeb, 0xdb, 0x69, 0xda,
        0x08, 0x5a, 0xc1, 0xe4, 0x3e, 0x15, 0x9c, 0x7e,
        0x94, 0xb2, 0xba, 0x95, 0xc9, 0xee, 0x6f, 0x5f,
        0x6d, 0x90, 0xbd, 0x3e, 0x0d, 0xfd, 0x0e, 0x2e,
        0x78, 0xe1, 0x88, 0xcc, 0x7e, 0x00, 0xd5, 0xb2
    ]
    val msg2: [u8] = [0x72]

    val kp2 = ed25519_keypair_from_seed(seed2)
    val pub2 = kp2.1
    if not _bytes_equal(a: pub2, b: expected_pub2):
        return Err("Ed25519 self-test FAIL: test vector 2 public key mismatch")

    val sig2 = ed25519_sign(private_seed: seed2, public_key: pub2, message: msg2)
    if not _bytes_equal(a: sig2, b: expected_sig2):
        return Err("Ed25519 self-test FAIL: test vector 2 signature mismatch")

    if not ed25519_verify(public_key: pub2, message: msg2, signature: sig2):
        return Err("Ed25519 self-test FAIL: test vector 2 verify rejected valid signature")

    Ok(true)
