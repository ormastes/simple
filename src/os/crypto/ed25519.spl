#![allow(unnamed_duplicate_typed_args)]
# Ed25519 — Pure Simple Digital Signatures (RFC 8032)
#
# Implements Ed25519 signing and verification for SimpleOS.
# No SFFI/Rust FFI — pure Simple language, suitable for baremetal.
#
# Uses the twisted Edwards curve: -x^2 + y^2 = 1 + d*x^2*y^2
# where d = -121665/121666 mod p, p = 2^255 - 19.
#
# Reuses Fe25519 field arithmetic from curve25519.spl.
# Requires SHA-512 from sha512.spl.
#
# Reference: RFC 8032 (Edwards-Curve Digital Signature Algorithm)
# Reference: HWCD08 (Twisted Edwards Curves Revisited)

use os.crypto.curve25519.{Fe25519, fe_zero, fe_one, fe_add, fe_sub, fe_mul, fe_sq, fe_invert, fe_reduce, fe_from_bytes, fe_to_bytes}
use os.crypto.sha512.{sha512}

# ============================================================================
# Extended Point on Ed25519
# ============================================================================

struct EdPoint:
    """Point on the Ed25519 Edwards curve in extended coordinates (X, Y, Z, T).

    Represents the affine point (X/Z, Y/Z) with T = X*Y/Z.
    """
    x: Fe25519
    y: Fe25519
    z: Fe25519
    t: Fe25519

# ============================================================================
# Field Helpers (supplementing curve25519.spl)
# ============================================================================

fn fe_neg(a: Fe25519) -> Fe25519:
    """Negate a field element: -a mod p."""
    fe_sub(fe_zero(), a)

fn fe_is_negative(a: Fe25519) -> bool:
    """Check if the field element is "negative" (low bit of canonical form is 1)."""
    val bytes = fe_to_bytes(a)
    (bytes[0] & 1) == 1

fn fe_pow2252m3(u: Fe25519) -> Fe25519:
    """Compute u^(2^252 - 3) mod p.

    This is u^((p+3)/8 - 1) which is useful for square root computation.
    (p+3)/8 = 2^252 - 2, so u^((p+3)/8) = u * u^(2^252-3).
    Uses the same addition-chain structure as fe_invert.
    """
    # z^2
    var z2 = fe_sq(u)

    # z^(2^2) = z^4
    var t = fe_sq(z2)
    # z^(2^3) = z^8
    t = fe_sq(t)

    # z^9 = z^8 * z
    var z9 = fe_mul(t, u)
    # z^11 = z^9 * z^2
    var z11 = fe_mul(z9, z2)

    # z^22
    t = fe_sq(z11)
    # z^31 = z^22 * z^9
    var z_2_5_0 = fe_mul(t, z9)

    # z^(2^10 - 1)
    t = fe_sq(z_2_5_0)
    var i: u64 = 1
    while i < 5:
        t = fe_sq(t)
        i = i + 1
    var z_2_10_0 = fe_mul(t, z_2_5_0)

    # z^(2^20 - 1)
    t = fe_sq(z_2_10_0)
    i = 1
    while i < 10:
        t = fe_sq(t)
        i = i + 1
    var z_2_20_0 = fe_mul(t, z_2_10_0)

    # z^(2^40 - 1)
    t = fe_sq(z_2_20_0)
    i = 1
    while i < 20:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(t, z_2_20_0)

    # z^(2^50 - 1)
    i = 0
    while i < 10:
        t = fe_sq(t)
        i = i + 1
    var z_2_50_0 = fe_mul(t, z_2_10_0)

    # z^(2^100 - 1)
    t = fe_sq(z_2_50_0)
    i = 1
    while i < 50:
        t = fe_sq(t)
        i = i + 1
    var z_2_100_0 = fe_mul(t, z_2_50_0)

    # z^(2^200 - 1)
    t = fe_sq(z_2_100_0)
    i = 1
    while i < 100:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(t, z_2_100_0)

    # z^(2^250 - 1)
    i = 0
    while i < 50:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(t, z_2_50_0)

    # z^(2^252 - 4)
    t = fe_sq(t)
    t = fe_sq(t)

    # z^(2^252 - 3) = z^(2^252 - 4) * z
    fe_mul(t, u)

fn fe_sqrt(u: Fe25519) -> Fe25519:
    """Compute the square root of u mod p, if it exists.

    Uses u^((p+3)/8) with adjustment by sqrt(-1) if needed.
    For p = 2^255 - 19, (p+3)/8 = 2^252 - 2.

    Returns a root r such that r^2 = u. If u is not a quadratic residue,
    the result is unspecified (caller should verify r^2 == u).
    """
    # r = u^((p+3)/8) = u * u^(2^252 - 3)
    val r_base = fe_mul(u, fe_pow2252m3(u))

    # Check: r^2 == u?
    val r_sq = fe_sq(r_base)
    val check = fe_sub(r_sq, u)
    val check_reduced = fe_reduce(check)

    # If r^2 == u, we're done
    if check_reduced.l0 == 0:
        if check_reduced.l1 == 0:
            if check_reduced.l2 == 0:
                if check_reduced.l3 == 0:
                    if check_reduced.l4 == 0:
                        return r_base

    # Otherwise try r * sqrt(-1)
    # sqrt(-1) = 2^((p-1)/4) mod p
    # We compute sqrt(-1) via the pow chain
    val sqrt_m1 = _fe_sqrt_m1()
    val r_adj = fe_mul(r_base, sqrt_m1)

    r_adj

fn _fe_sqrt_m1() -> Fe25519:
    """Compute sqrt(-1) mod p = 2^((p-1)/4) mod p.

    p-1 = 2^255 - 20, so (p-1)/4 = 2^253 - 5.
    We compute 2^(2^253 - 5) mod p.

    sqrt(-1) = 0x2b8324804fc1df0b2b4d00993dfbd7a72f431806ad2fe478c4ee1b274a0ea0b0
    """
    # Precomputed sqrt(-1) as bytes (little-endian)
    var bytes: [u8] = [
        0xb0, 0xa0, 0x0e, 0x4a, 0x27, 0x1b, 0xee, 0xc4,
        0x78, 0xe4, 0x2f, 0xad, 0x06, 0x18, 0x43, 0x2f,
        0xa7, 0xd7, 0xfb, 0x3d, 0x99, 0x00, 0x4d, 0x2b,
        0x0b, 0xdf, 0xc1, 0x4f, 0x80, 0x24, 0x83, 0x2b
    ]
    fe_from_bytes(bytes)

# ============================================================================
# Curve Constant d
# ============================================================================

fn _ed25519_d() -> Fe25519:
    """Compute d = -121665/121666 mod p = -121665 * inv(121666) mod p.

    d = 0x52036cee2b6ffe738cc740797779e89800700a4d4141d8ab75eb4dca135978a3
    """
    # Precomputed d as bytes (little-endian)
    var bytes: [u8] = [
        0xa3, 0x78, 0x59, 0x13, 0xca, 0x4d, 0xeb, 0x75,
        0xab, 0xd8, 0x41, 0x41, 0x4d, 0x0a, 0x70, 0x00,
        0x98, 0xe8, 0x79, 0x77, 0x79, 0x40, 0xc7, 0x8c,
        0x73, 0xfe, 0x6f, 0x2b, 0xee, 0x6c, 0x03, 0x52
    ]
    fe_from_bytes(bytes)

fn _ed25519_2d() -> Fe25519:
    """Compute 2*d mod p. Used in point addition formulas."""
    val d = _ed25519_d()
    fe_add(d, d)

# ============================================================================
# Ed25519 Base Point B
# ============================================================================

fn _ed25519_base_point() -> EdPoint:
    """Return the Ed25519 base point B.

    B has y = 4/5 mod p, and x is the positive (even) square root.

    By = 0x6666666666666666666666666666666666666666666666666666666666666658
    Bx = 0x216936d3cd6e53fec0a4e231fdd6dc5c692cc7609525a7b2c9562d608f25d51a
    """
    # Bx in little-endian
    var bx_bytes: [u8] = [
        0x1a, 0xd5, 0x25, 0x8f, 0x60, 0x2d, 0x56, 0xc9,
        0xb2, 0xa7, 0x25, 0x95, 0x60, 0xc7, 0x2c, 0x69,
        0x5c, 0xdc, 0xd6, 0xfd, 0x31, 0xe2, 0xa4, 0xc0,
        0xfe, 0x53, 0x6e, 0xcd, 0xd3, 0x36, 0x69, 0x21
    ]
    # By in little-endian
    var by_bytes: [u8] = [
        0x58, 0x66, 0x66, 0x66, 0x66, 0x66, 0x66, 0x66,
        0x66, 0x66, 0x66, 0x66, 0x66, 0x66, 0x66, 0x66,
        0x66, 0x66, 0x66, 0x66, 0x66, 0x66, 0x66, 0x66,
        0x66, 0x66, 0x66, 0x66, 0x66, 0x66, 0x66, 0x66
    ]
    val bx = fe_from_bytes(bx_bytes)
    val by = fe_from_bytes(by_bytes)
    EdPoint(
        x: bx,
        y: by,
        z: fe_one(),
        t: fe_mul(bx, by)
    )

# ============================================================================
# Extended Coordinate Point Operations (HWCD08)
# ============================================================================

fn ed_point_identity() -> EdPoint:
    """Return the neutral element (identity point): (0, 1, 1, 0)."""
    EdPoint(x: fe_zero(), y: fe_one(), z: fe_one(), t: fe_zero())

fn ed_point_add(p1: EdPoint, p2: EdPoint) -> EdPoint:
    """Add two points in extended coordinates.

    Uses unified addition formula from HWCD08 for twisted Edwards curve
    -x^2 + y^2 = 1 + d*x^2*y^2 (a = -1).

    A = X1*X2, B = Y1*Y2, C = T1*d*T2, D = Z1*Z2
    E = (X1+Y1)*(X2+Y2) - A - B
    F = D - C, G = D + C, H = B + A  (+ because a=-1: B - a*A = B+A)
    X3 = E*F, Y3 = G*H, T3 = E*H, Z3 = F*G
    """
    val d = _ed25519_d()

    val a = fe_mul(p1.x, p2.x)
    val b = fe_mul(p1.y, p2.y)
    val c = fe_mul(fe_mul(p1.t, p2.t), d)
    val dd = fe_mul(p1.z, p2.z)

    val x1_plus_y1 = fe_add(p1.x, p1.y)
    val x2_plus_y2 = fe_add(p2.x, p2.y)
    val e = fe_sub(fe_sub(fe_mul(x1_plus_y1, x2_plus_y2), a), b)

    val f = fe_sub(dd, c)
    val g = fe_add(dd, c)
    val h = fe_add(b, a)

    EdPoint(
        x: fe_mul(e, f),
        y: fe_mul(g, h),
        z: fe_mul(f, g),
        t: fe_mul(e, h)
    )

fn ed_point_double(p1: EdPoint) -> EdPoint:
    """Double a point in extended coordinates.

    Uses dedicated doubling formula from HWCD08 for a = -1:
    A = X1^2, B = Y1^2, C = 2*Z1^2
    D = -A (since a = -1), E = (X1+Y1)^2 - A - B
    G = D + B, F = G - C, H = D - B
    X3 = E*F, Y3 = G*H, T3 = E*H, Z3 = F*G
    """
    val a = fe_sq(p1.x)
    val b = fe_sq(p1.y)
    val c = fe_add(fe_sq(p1.z), fe_sq(p1.z))

    val d = fe_neg(a)
    val x_plus_y = fe_add(p1.x, p1.y)
    val e = fe_sub(fe_sub(fe_sq(x_plus_y), a), b)

    val g = fe_add(d, b)
    val f = fe_sub(g, c)
    val h = fe_sub(d, b)

    EdPoint(
        x: fe_mul(e, f),
        y: fe_mul(g, h),
        z: fe_mul(f, g),
        t: fe_mul(e, h)
    )

fn ed_scalar_mul(scalar: [u8], p: EdPoint) -> EdPoint:
    """Scalar multiplication: scalar * P using double-and-add.

    scalar: 32-byte little-endian scalar.
    Iterates from the highest bit down to bit 0.
    """
    var result = ed_point_identity()
    var q = p

    # Process all 256 bits, from bit 0 up, using double-and-add
    # (Process low to high: for each bit, if set add current Q, then double Q)
    var byte_idx: u64 = 0
    while byte_idx < 32:
        val byte_val = scalar[byte_idx]
        var bit: u64 = 0
        while bit < 8:
            if ((byte_val.to_u64() >> bit) & 1) == 1:
                result = ed_point_add(result, q)
            q = ed_point_double(q)
            bit = bit + 1
        byte_idx = byte_idx + 1

    result

# ============================================================================
# Point Encoding / Decoding (RFC 8032 section 5.1.2)
# ============================================================================

fn ed_point_encode(p: EdPoint) -> [u8]:
    """Encode a point to 32 bytes.

    Encoding: y-coordinate in little-endian, with top bit of last byte
    set to the sign (low bit) of the x-coordinate.
    """
    val z_inv = fe_invert(p.z)
    val x = fe_mul(p.x, z_inv)
    val y = fe_mul(p.y, z_inv)

    var encoded = fe_to_bytes(y)

    # Set top bit of last byte to the sign of x
    if fe_is_negative(x):
        encoded[31] = encoded[31] | 0x80

    encoded

fn ed_point_decode(bytes: [u8]) -> EdPoint:
    """Decode a 32-byte encoding to a point on the curve.

    Extracts y from the low 255 bits, recovers x from the curve equation,
    and uses the top bit to select the sign of x.

    Returns the decoded point. If the encoding is invalid (not on curve),
    the result is unspecified.
    """
    # Extract sign bit of x from top bit of last byte
    val x_sign: u64 = (bytes[31].to_u64() >> 7) & 1

    # Clear top bit to get y
    var y_bytes: [u8] = []
    var i: u64 = 0
    while i < 32:
        y_bytes.push(bytes[i])
        i = i + 1
    y_bytes[31] = y_bytes[31] & 0x7F

    val y = fe_from_bytes(y_bytes)

    # Recover x from curve equation: -x^2 + y^2 = 1 + d*x^2*y^2
    # x^2 = (y^2 - 1) / (d*y^2 + 1)
    val y_sq = fe_sq(y)
    val d = _ed25519_d()

    val u = fe_sub(y_sq, fe_one())         # u = y^2 - 1
    val v = fe_add(fe_mul(d, y_sq), fe_one())  # v = d*y^2 + 1

    # x = sqrt(u/v) = u * v^3 * (u * v^7)^((p-5)/8)
    # Or equivalently: x^2 = u * v^(-1), then x = sqrt(u * v^(-1))
    # We use: x = u * v^3 * (u * v^7)^((p-5)/8)
    # Since (p-5)/8 = 2^252 - 3
    val v_sq = fe_sq(v)
    val v_cubed = fe_mul(v_sq, v)
    val v4 = fe_sq(v_sq)
    val v7 = fe_mul(v4, v_cubed)
    val uv7 = fe_mul(u, v7)

    # (u * v^7)^(2^252 - 3)
    val uv7_pow = fe_pow2252m3(uv7)

    # x = u * v^3 * (u * v^7)^(2^252 - 3)
    var x = fe_mul(fe_mul(u, v_cubed), uv7_pow)

    # Verify: v * x^2 == u?
    val vx2 = fe_mul(v, fe_sq(x))
    val check = fe_reduce(fe_sub(vx2, u))

    if check.l0 != 0:
        # Try v * x^2 == -u (need to multiply x by sqrt(-1))
        val sqrt_m1 = _fe_sqrt_m1()
        x = fe_mul(x, sqrt_m1)
    else:
        if check.l1 != 0:
            val sqrt_m1 = _fe_sqrt_m1()
            x = fe_mul(x, sqrt_m1)
        else:
            if check.l2 != 0:
                val sqrt_m1 = _fe_sqrt_m1()
                x = fe_mul(x, sqrt_m1)
            else:
                if check.l3 != 0:
                    val sqrt_m1 = _fe_sqrt_m1()
                    x = fe_mul(x, sqrt_m1)
                else:
                    if check.l4 != 0:
                        val sqrt_m1 = _fe_sqrt_m1()
                        x = fe_mul(x, sqrt_m1)

    # Adjust sign of x to match the encoded sign bit
    if fe_is_negative(x) != (x_sign == 1):
        x = fe_neg(x)

    val t = fe_mul(x, y)
    EdPoint(x: x, y: y, z: fe_one(), t: t)

# ============================================================================
# Scalar Arithmetic modulo L (Ed25519 Group Order)
# ============================================================================
#
# L = 2^252 + 27742317777372353535851937790883648493
# In hex: L = 0x1000000000000000000000000000000014def9dea2f79cd65812631a5cf5d3ed
#
# We represent scalars as arrays of 8 u32 limbs in little-endian order.
# For 64-byte (512-bit) intermediates, we use 16 u32 limbs.

# L as 8 u32 limbs (little-endian)
fn _sc_L() -> [u32]:
    """Return the group order L as 8 u32 limbs (little-endian)."""
    var l: [u32] = []
    l.push(0x5cf5d3ed)  # limb 0 (lowest)
    l.push(0x5812631a)  # limb 1
    l.push(0xa2f79cd6)  # limb 2
    l.push(0x14def9de)  # limb 3
    l.push(0x00000000)  # limb 4
    l.push(0x00000000)  # limb 5
    l.push(0x00000000)  # limb 6
    l.push(0x10000000)  # limb 7 (bit 252)
    l

fn _bytes_to_limbs32(b: [u8], count: u64) -> [u32]:
    """Convert byte array to u32 limbs (little-endian), reading 'count' bytes."""
    var limbs: [u32] = []
    var i: u64 = 0
    while i < count:
        val idx = i * 4
        var val_u32: u32 = 0
        if idx < b.len():
            val_u32 = val_u32 | b[idx].to_u32()
        if (idx + 1) < b.len():
            val_u32 = val_u32 | (b[idx + 1].to_u32() << 8)
        if (idx + 2) < b.len():
            val_u32 = val_u32 | (b[idx + 2].to_u32() << 16)
        if (idx + 3) < b.len():
            val_u32 = val_u32 | (b[idx + 3].to_u32() << 24)
        limbs.push(val_u32)
        i = i + 1
    limbs

fn _limbs32_to_bytes(limbs: [u32], byte_count: u64) -> [u8]:
    """Convert u32 limbs (little-endian) to byte array."""
    var result: [u8] = []
    var i: u64 = 0
    while i < byte_count:
        val limb_idx = i / 4
        val byte_idx = i % 4
        var byte_val: u8 = 0
        if limb_idx < limbs.len():
            byte_val = ((limbs[limb_idx].to_u64() >> (byte_idx * 8)) & 0xFF).to_u8()
        result.push(byte_val)
        i = i + 1
    result

fn _sc_sub_L(a: [u32]) -> [u32]:
    """Subtract L from a (8 limbs). Returns result and sets borrow.
    If borrow is set, a < L so the subtraction underflowed.
    Returns a pair: (result_limbs, borrow).
    We encode this as 9 limbs where limb[8] is the borrow flag.
    """
    val l = _sc_L()
    var result: [u32] = []
    var borrow: u64 = 0
    var i: u64 = 0
    while i < 8:
        val ai: u64 = a[i].to_u64()
        val li: u64 = l[i].to_u64()
        val diff: u64 = ai - li - borrow
        result.push((diff & 0xFFFFFFFF).to_u32())
        # Borrow if diff underflowed (bit 32 set in two's complement)
        if ai < (li + borrow):
            borrow = 1
        else:
            borrow = 0
        i = i + 1
    # Append borrow flag as 9th limb
    result.push(borrow.to_u32())
    result

fn sc_reduce(s: [u8]) -> [u8]:
    """Reduce a 64-byte scalar modulo L to 32 bytes.

    Input: 64 bytes (512 bits), output: 32 bytes (< L).
    Uses schoolbook reduction by repeatedly subtracting L * 2^k.
    """
    # Load 64 bytes into 16 u32 limbs
    var limbs = _bytes_to_limbs32(s, 16)

    # Barrett-like reduction: we reduce from the top down.
    # L ~ 2^252, so we need to reduce the upper portion.
    #
    # Simple approach: interpret as a big number, then do schoolbook
    # modular reduction. We'll use the fact that for any value v < 2^512,
    # we can reduce mod L by repeated subtraction.
    #
    # More efficient: split into low 252 bits and high bits, multiply high
    # part by appropriate constant, and reduce.
    #
    # For simplicity, we use the classic Barrett reduction approach:
    # q = floor(x / L), r = x - q * L
    #
    # We implement a simpler iterative approach since this is not
    # performance-critical (called once per sign/verify).

    # Convert to a wide representation and reduce step by step.
    # Process from the top: for each bit from 511 down to 252,
    # if the bit is set, subtract L shifted to that position.

    # We'll work with 16 u32 limbs (512 bits)
    var bit: u64 = 511
    val l = _sc_L()

    while bit >= 252:
        # Check if bit is set
        val limb_idx = bit / 32
        val bit_idx = bit % 32
        val is_set = (limbs[limb_idx].to_u64() >> bit_idx) & 1

        if is_set == 1:
            # Subtract L << (bit - 252) from limbs
            val shift = bit - 252
            val word_shift = shift / 32
            val bit_shift = shift % 32

            var borrow: u64 = 0
            var j: u64 = 0
            while j < 9:
                val target = j + word_shift
                if target < 16:
                    # Get the shifted L limb value
                    var l_val: u64 = 0
                    if j < 8:
                        l_val = l[j].to_u64() << bit_shift
                    # Add carry from previous limb shift
                    if bit_shift > 0:
                        if j > 0:
                            if (j - 1) < 8:
                                l_val = l_val | (l[j - 1].to_u64() >> (32 - bit_shift))
                    val cur: u64 = limbs[target].to_u64()
                    val sub_val = (l_val & 0xFFFFFFFF) + borrow
                    if cur >= sub_val:
                        limbs[target] = (cur - sub_val).to_u32()
                        borrow = 0
                    else:
                        limbs[target] = ((cur + 0x100000000) - sub_val).to_u32()
                        borrow = 1
                j = j + 1

        if bit == 252:
            # Prevent underflow when decrementing at 252
            break
        bit = bit - 1

    # Now limbs[0..7] holds a value < 2*L (approximately).
    # Do a final conditional subtraction.
    var low8: [u32] = []
    var k: u64 = 0
    while k < 8:
        low8.push(limbs[k])
        k = k + 1

    val sub_result = _sc_sub_L(low8)
    # If borrow (limb[8]) is 0, the subtraction was valid (a >= L), use the result
    # If borrow is 1, a < L, keep the original
    if sub_result[8] == 0:
        # a >= L, use subtracted result
        var final_limbs: [u32] = []
        k = 0
        while k < 8:
            final_limbs.push(sub_result[k])
            k = k + 1
        return _limbs32_to_bytes(final_limbs, 32)

    _limbs32_to_bytes(low8, 32)

fn sc_muladd(a_bytes: [u8], b_bytes: [u8], c_bytes: [u8]) -> [u8]:
    """Compute (a * b + c) mod L, where a, b, c are 32-byte scalars.

    Returns 32-byte result.
    Uses schoolbook multiplication to produce a 64-byte product, adds c,
    then reduces modulo L.
    """
    # Load a, b, c as 8 u32 limbs each
    val a = _bytes_to_limbs32(a_bytes, 8)
    val b = _bytes_to_limbs32(b_bytes, 8)
    val c = _bytes_to_limbs32(c_bytes, 8)

    # Schoolbook multiply a * b into 16 u64 accumulators
    var product: [u64] = []
    var i: u64 = 0
    while i < 16:
        product.push(0)
        i = i + 1

    i = 0
    while i < 8:
        var carry: u64 = 0
        var j: u64 = 0
        while j < 8:
            val idx = i + j
            val mul_val: u64 = a[i].to_u64() * b[j].to_u64()
            val sum: u64 = product[idx] + mul_val + carry
            product[idx] = sum & 0xFFFFFFFF
            carry = sum >> 32
            j = j + 1
        product[i + 8] = product[i + 8] + carry
        i = i + 1

    # Add c to the product
    var add_carry: u64 = 0
    i = 0
    while i < 8:
        val sum: u64 = product[i] + c[i].to_u64() + add_carry
        product[i] = sum & 0xFFFFFFFF
        add_carry = sum >> 32
        i = i + 1
    # Propagate carry through upper limbs
    while add_carry > 0:
        if i >= 16:
            break
        val sum: u64 = product[i] + add_carry
        product[i] = sum & 0xFFFFFFFF
        add_carry = sum >> 32
        i = i + 1

    # Convert product to 64 bytes and reduce mod L
    var prod_bytes: [u8] = []
    i = 0
    while i < 16:
        val limb = product[i]
        prod_bytes.push((limb & 0xFF).to_u8())
        prod_bytes.push(((limb >> 8) & 0xFF).to_u8())
        prod_bytes.push(((limb >> 16) & 0xFF).to_u8())
        prod_bytes.push(((limb >> 24) & 0xFF).to_u8())
        i = i + 1

    sc_reduce(prod_bytes)

# ============================================================================
# Ed25519 Scalar Clamping
# ============================================================================

fn _ed25519_clamp(h: [u8]) -> [u8]:
    """Clamp the lower 32 bytes of SHA-512 output per Ed25519 spec.

    Clear bits 0, 1, 2 of first byte.
    Clear bit 255 (top bit of byte 31).
    Set bit 254 of byte 31.
    """
    var clamped: [u8] = []
    var i: u64 = 0
    while i < 32:
        clamped.push(h[i])
        i = i + 1

    clamped[0] = clamped[0] & 0xF8       # Clear bottom 3 bits
    clamped[31] = clamped[31] & 0x7F      # Clear top bit (bit 255)
    clamped[31] = clamped[31] | 0x40      # Set bit 254
    clamped

# ============================================================================
# SHA-512 mod L helper
# ============================================================================

fn _sha512_modl(data: [u8]) -> [u8]:
    """Compute SHA-512(data) then reduce the 64-byte result modulo L.

    Returns 32-byte scalar.
    """
    val hash = sha512(data)
    sc_reduce(hash)

# ============================================================================
# C-Side Ed25519 — baremetal Cranelift workaround
# ============================================================================
#
# The pure Simple Ed25519 FAULTs on baremetal due to Cranelift codegen bugs
# with deep u64 field arithmetic in extended coordinates (4 field elements
# per point vs X25519's 2). The C implementation in baremetal_stubs.c
# handles all Ed25519 operations reliably.
#
# The C functions use the RuntimeValue array convention:
#   - Input [u8] arrays are read via _ed_rv_to_bytes
#   - Output [u8] arrays are written via _ed_bytes_to_rv (must be pre-allocated)

extern fn rt_ed25519_keypair(seed: [u8], pk_out: [u8]) -> i64
extern fn rt_ed25519_sign(msg: [u8], sk: [u8], sig_out: [u8]) -> i64
extern fn rt_ed25519_verify(msg: [u8], pk: [u8], sig: [u8]) -> i64

# ============================================================================
# Public API
# ============================================================================

fn ed25519_keypair_from_seed(seed: [u8]) -> ([u8], [u8]):
    """Derive (private_key, public_key) from 32-byte seed.

    Delegates to C-side Ed25519 implementation to work around baremetal
    Cranelift codegen bugs with extended-coordinate point arithmetic.

    Per RFC 8032 section 5.1.5:
    1. h = SHA-512(seed)
    2. a = clamp(h[0..32])
    3. A = a * B
    """
    # Pre-allocate 32-byte output array for public key
    var pk: [u8] = []
    var i: u64 = 0
    while i < 32:
        pk.push(0)
        i = i + 1

    val rc = rt_ed25519_keypair(seed, pk)
    if rc != 0:
        # Fallback: return zeros (should not happen with valid 32-byte seed)
        return (seed, pk)

    (seed, pk)

fn ed25519_sign(private_seed: [u8], public_key: [u8], message: [u8]) -> [u8]:
    """Sign a message with Ed25519. Returns 64-byte signature (R || S).

    Delegates to C-side Ed25519 implementation.
    The C function expects sk = seed(32) || pk(32) concatenated.

    Per RFC 8032 section 5.1.6.
    """
    # Build 64-byte sk = private_seed || public_key (standard Ed25519 convention)
    var sk: [u8] = []
    var i: u64 = 0
    while i < private_seed.len():
        sk.push(private_seed[i])
        i = i + 1
    i = 0
    while i < public_key.len():
        sk.push(public_key[i])
        i = i + 1

    # Pre-allocate 64-byte output array for signature
    var sig: [u8] = []
    i = 0
    while i < 64:
        sig.push(0)
        i = i + 1

    rt_ed25519_sign(message, sk, sig)
    sig

fn ed25519_verify(public_key: [u8], message: [u8], signature: [u8]) -> bool:
    """Verify an Ed25519 signature.

    Delegates to C-side Ed25519 implementation.
    Returns true if signature is valid.

    Per RFC 8032 section 5.1.7.
    """
    if signature.len() != 64:
        return false
    if public_key.len() != 32:
        return false

    val rc = rt_ed25519_verify(message, public_key, signature)
    rc == 0

# ============================================================================
# Internal Helpers
# ============================================================================

fn _sc_is_geq_L(s: [u8]) -> bool:
    """Check if a 32-byte scalar s >= L.

    Used to reject non-canonical S values in verification.
    """
    val limbs = _bytes_to_limbs32(s, 8)
    val sub = _sc_sub_L(limbs)
    # If borrow (limb[8]) is 0, s >= L
    sub[8] == 0

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    """Constant-time comparison of two byte arrays."""
    if a.len() != b.len():
        return false
    var diff: u8 = 0
    var i: u64 = 0
    while i < a.len():
        diff = diff | (a[i] ^ b[i])
        i = i + 1
    diff == 0

# ============================================================================
# Self-Test — RFC 8032 Section 7.1 Test Vectors
# ============================================================================

# C-side Ed25519 implementation for baremetal (array ops unreliable in Simple)
extern fn rt_ed25519_self_test() -> i64

fn ed25519_self_test() -> Result<bool, text>:
    """Run Ed25519 against RFC 8032 test vectors. Returns Ok(true) or Err(reason).

    WORKAROUND: Uses C-side implementation because baremetal array push/len/indexing
    are unreliable for the scalar arithmetic (mod L) needed by Ed25519.
    The C implementation in baremetal_stubs.c section 8f handles all crypto.
    """
    val rc = rt_ed25519_self_test()
    if rc == 0:
        return Ok(true)
    return Err("Ed25519 C-side self-test failed")

fn _ed25519_self_test_pure_simple() -> Result<bool, text>:
    """Original Pure Simple Ed25519 self-test — disabled in baremetal."""
    # --- Test Vector 1 (RFC 8032 Section 7.1, TEST 1) ---
    # SECRET KEY (seed): 9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60
    # PUBLIC KEY:        d75a980182b10ab7d54bfed3c964073a0ee172f3daa3f4a18446b0b8d183f8e3
    # MESSAGE:           (empty)
    # SIGNATURE:         e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e06522490155
    #                    5fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b
    val seed1: [u8] = [
        0x9d, 0x61, 0xb1, 0x9d, 0xef, 0xfd, 0x5a, 0x60,
        0xba, 0x84, 0x4a, 0xf4, 0x92, 0xec, 0x2c, 0xc4,
        0x44, 0x49, 0xc5, 0x69, 0x7b, 0x32, 0x69, 0x19,
        0x70, 0x3b, 0xac, 0x03, 0x1c, 0xae, 0x7f, 0x60
    ]
    val expected_pub1: [u8] = [
        0xd7, 0x5a, 0x98, 0x01, 0x82, 0xb1, 0x0a, 0xb7,
        0xd5, 0x4b, 0xfe, 0xd3, 0xc9, 0x64, 0x07, 0x3a,
        0x0e, 0xe1, 0x72, 0xf3, 0xda, 0xa3, 0xf4, 0xa1,
        0x84, 0x46, 0xb0, 0xb8, 0xd1, 0x83, 0xf8, 0xe3
    ]
    val expected_sig1: [u8] = [
        0xe5, 0x56, 0x43, 0x00, 0xc3, 0x60, 0xac, 0x72,
        0x90, 0x86, 0xe2, 0xcc, 0x80, 0x6e, 0x82, 0x8a,
        0x84, 0x87, 0x7f, 0x1e, 0xb8, 0xe5, 0xd9, 0x74,
        0xd8, 0x73, 0xe0, 0x65, 0x22, 0x49, 0x01, 0x55,
        0x5f, 0xb8, 0x82, 0x15, 0x90, 0xa3, 0x3b, 0xac,
        0xc6, 0x1e, 0x39, 0x70, 0x1c, 0xf9, 0xb4, 0x6b,
        0xd2, 0x5b, 0xf5, 0xf0, 0x59, 0x5b, 0xbe, 0x24,
        0x65, 0x51, 0x41, 0x43, 0x8e, 0x7a, 0x10, 0x0b
    ]
    val msg1: [u8] = []

    # 1. Verify keypair derivation
    val kp1 = ed25519_keypair_from_seed(seed1)
    val pub1 = kp1.1
    if not _bytes_equal(pub1, expected_pub1):
        return Err("Ed25519 self-test FAIL: test vector 1 public key mismatch")

    # 2. Verify signing
    val sig1 = ed25519_sign(seed1, pub1, msg1)
    if not _bytes_equal(sig1, expected_sig1):
        return Err("Ed25519 self-test FAIL: test vector 1 signature mismatch")

    # 3. Verify verification accepts valid signature
    if not ed25519_verify(pub1, msg1, sig1):
        return Err("Ed25519 self-test FAIL: test vector 1 verify rejected valid signature")

    # 4. Verify verification rejects corrupted signature
    var bad_sig1: [u8] = []
    var bsi: u64 = 0
    while bsi < sig1.len():
        bad_sig1.push(sig1[bsi])
        bsi = bsi + 1
    bad_sig1[0] = bad_sig1[0] ^ 0x01  # Flip one bit
    if ed25519_verify(pub1, msg1, bad_sig1):
        return Err("Ed25519 self-test FAIL: verify accepted corrupted signature")

    # --- Test Vector 2 (RFC 8032 Section 7.1, TEST 2) ---
    # SECRET KEY: 4ccd089b28ff96da9db6c346ec114e0f5b8a319f35aba624da8cf6ed4fb8a6fb
    # PUBLIC KEY: 3d4017c3e843895a92b70aa74d1b7ebc9c982ccf2ec4968cc0cd55f12af4660c
    # MESSAGE:    72 (single byte 0x72)
    # SIGNATURE:  92a009a9f0d4cab8720e820b5f642540a2b27b5416503f8fb3762223ebdb69da
    #             085ac1e43e159c7e94b2ba95c9ee6f5f6d90bd3e0dfd0e2e78e188cc7e00d5b2
    val seed2: [u8] = [
        0x4c, 0xcd, 0x08, 0x9b, 0x28, 0xff, 0x96, 0xda,
        0x9d, 0xb6, 0xc3, 0x46, 0xec, 0x11, 0x4e, 0x0f,
        0x5b, 0x8a, 0x31, 0x9f, 0x35, 0xab, 0xa6, 0x24,
        0xda, 0x8c, 0xf6, 0xed, 0x4f, 0xb8, 0xa6, 0xfb
    ]
    val expected_pub2: [u8] = [
        0x3d, 0x40, 0x17, 0xc3, 0xe8, 0x43, 0x89, 0x5a,
        0x92, 0xb7, 0x0a, 0xa7, 0x4d, 0x1b, 0x7e, 0xbc,
        0x9c, 0x98, 0x2c, 0xcf, 0x2e, 0xc4, 0x96, 0x8c,
        0xc0, 0xcd, 0x55, 0xf1, 0x2a, 0xf4, 0x66, 0x0c
    ]
    val expected_sig2: [u8] = [
        0x92, 0xa0, 0x09, 0xa9, 0xf0, 0xd4, 0xca, 0xb8,
        0x72, 0x0e, 0x82, 0x0b, 0x5f, 0x64, 0x25, 0x40,
        0xa2, 0xb2, 0x7b, 0x54, 0x16, 0x50, 0x3f, 0x8f,
        0xb3, 0x76, 0x22, 0x23, 0xeb, 0xdb, 0x69, 0xda,
        0x08, 0x5a, 0xc1, 0xe4, 0x3e, 0x15, 0x9c, 0x7e,
        0x94, 0xb2, 0xba, 0x95, 0xc9, 0xee, 0x6f, 0x5f,
        0x6d, 0x90, 0xbd, 0x3e, 0x0d, 0xfd, 0x0e, 0x2e,
        0x78, 0xe1, 0x88, 0xcc, 0x7e, 0x00, 0xd5, 0xb2
    ]
    val msg2: [u8] = [0x72]

    val kp2 = ed25519_keypair_from_seed(seed2)
    val pub2 = kp2.1
    if not _bytes_equal(pub2, expected_pub2):
        return Err("Ed25519 self-test FAIL: test vector 2 public key mismatch")

    val sig2 = ed25519_sign(seed2, pub2, msg2)
    if not _bytes_equal(sig2, expected_sig2):
        return Err("Ed25519 self-test FAIL: test vector 2 signature mismatch")

    if not ed25519_verify(pub2, msg2, sig2):
        return Err("Ed25519 self-test FAIL: test vector 2 verify rejected valid signature")

    Ok(true)
