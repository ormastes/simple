# ---------------------------------------------------------------------------
# GF(2^8) multiply — reduction polynomial x^8+x^4+x^3+x^2+1 = 0x11D
# ---------------------------------------------------------------------------

fn _gf_mul(a_in: i64, b_in: i64) -> i64:
    """Multiply two bytes in GF(2^8) under Whirlpool's polynomial 0x11D."""
    var a = a_in & 0xFF
    var b = b_in & 0xFF
    var p = 0
    var i = 0
    while i < 8:
        if (b & 1) != 0:
            p = p ^ a
        val hi_bit = (a & 0x80) != 0
        a = (a << 1) & 0xFF
        if hi_bit:
            a = a ^ 0x1D
        b = (b >> 1) & 0xFF
        i = i + 1
    p & 0xFF

# ---------------------------------------------------------------------------
# State helpers — 8x8 byte matrix stored as flat 64-element list.
# state[r][c] = flat[r*8 + c]
# ---------------------------------------------------------------------------

fn _state_get(state: list, row: i64, col: i64) -> i64:
    state.get(row * 8 + col) & 0xFF

fn _make_zero_state() -> list:
    var s = []
    var i = 0
    while i < 64:
        s.push(0)
        i = i + 1
    s

fn _xor_states(a: list, b: list) -> list:
    var out = []
    var i = 0
    while i < 64:
        out.push((a.get(i) ^ b.get(i)) & 0xFF)
        i = i + 1
    out

# ---------------------------------------------------------------------------
# Round constant RC[r] — row 0 bytes = S[8*(r-1)+j] for j in 0..7,
# rows 1..7 all zero.  r is 1-based (rounds 1..10).
# ---------------------------------------------------------------------------

fn _round_constant(r: i64) -> list:
    var rc = _make_zero_state()
    var j = 0
    while j < 8:
        rc[j] = _wp_sbox((8 * (r - 1) + j).to_u64())
        j = j + 1
    rc

# ---------------------------------------------------------------------------
# SubBytes — apply S-box to every cell
# ---------------------------------------------------------------------------

fn _sub_bytes(state: list) -> list:
    var out = []
    var i = 0
    while i < 64:
        out.push(_wp_sbox(state.get(i).to_u64()))
        i = i + 1
    out

# ---------------------------------------------------------------------------
# ShiftColumns — column j is shifted DOWN by j positions (cyclically).
# out[i][j] = state[(i - j + 8) mod 8][j]
# ---------------------------------------------------------------------------

fn _shift_columns(state: list) -> list:
    var out = _make_zero_state()
    var col = 0
    while col < 8:
        var row = 0
        while row < 8:
            val src_row = ((row - col) + 8 * 8) % 8
            out[row * 8 + col] = _state_get(state, src_row, col)
            row = row + 1
        col = col + 1
    out

# ---------------------------------------------------------------------------
# MixRows — per-row matrix multiply over GF(2^8).
# Circulant MDS matrix C, first row = (1, 1, 4, 1, 8, 5, 2, 9).
# C[out_col][in_col] = C_row[(out_col - in_col + 8) mod 8] where
# C_row = (1, 1, 4, 1, 8, 5, 2, 9).
# out[i][j] = XOR_{k=0}^{7} gmul(C_row[(j - k + 8) % 8], state[i][k])
# ---------------------------------------------------------------------------

fn _mds_coeff(index: i64) -> i64:
    """First row of the circulant MDS matrix: (1, 1, 4, 1, 8, 5, 2, 9)."""
    if index == 0: 1
    else if index == 1: 1
    else if index == 2: 4
    else if index == 3: 1
    else if index == 4: 8
    else if index == 5: 5
    else if index == 6: 2
    else: 9

fn _mix_rows(state: list) -> list:
    var out = _make_zero_state()
    var row = 0
    while row < 8:
        var col = 0
        while col < 8:
            var acc = 0
            var k = 0
            while k < 8:
                val c_idx = ((col - k) + 64) % 8
                val coeff = _mds_coeff(c_idx)
                val cell = _state_get(state, row, k)
                acc = acc ^ _gf_mul(coeff, cell)
                k = k + 1
            out[row * 8 + col] = acc & 0xFF
            col = col + 1
        row = row + 1
    out

# ---------------------------------------------------------------------------
# AddRoundKey — XOR state with round key (both 64-cell lists)
# ---------------------------------------------------------------------------

fn _add_round_key(state: list, key: list) -> list:
    _xor_states(state, key)

# ---------------------------------------------------------------------------
# One Whirlpool round (excluding key schedule — key is passed in)
# rho(state, key) = AddRoundKey(MixRows(ShiftColumns(SubBytes(state))), key)
# ---------------------------------------------------------------------------

fn _whirlpool_round(state: list, key: list) -> list:
    val s1 = _sub_bytes(state)
    val s2 = _shift_columns(s1)
    val s3 = _mix_rows(s2)
    _add_round_key(s3, key)

# ---------------------------------------------------------------------------
# Key schedule — K[0] = H_prev (initial whitening key)
# K[r] = whirlpool_round(K[r-1], RC[r]) for r = 1..10
# Returns list of 11 round-key states (indices 0..10).
# ---------------------------------------------------------------------------

fn _key_schedule(h_state: list) -> list:
    var k = h_state

    # Store key 0 into flat buffer
    var keys_flat = []
    var ci = 0
    while ci < 64:
        keys_flat.push(h_state.get(ci))
        ci = ci + 1

    var r = 1
    while r <= 10:
        val rc = _round_constant(r)
        k = _whirlpool_round(k, rc)
        var ki = 0
        while ki < 64:
            keys_flat.push(k.get(ki))
            ki = ki + 1
        r = r + 1
    keys_flat

fn _get_round_key(keys_flat: list, round: i64) -> list:
    var k = []
    var i = 0
    while i < 64:
        k.push(keys_flat.get(round * 64 + i))
        i = i + 1
    k

# ---------------------------------------------------------------------------
# Whirlpool block cipher (used inside compression)
# Encrypts block_state under key_state using 10 rounds.
# Returns the 10-round cipher output.
# ---------------------------------------------------------------------------

fn _whirlpool_cipher(block_state: list, key_state: list) -> list:
    val keys_flat = _key_schedule(key_state)
    val k0 = _get_round_key(keys_flat, 0)
    # Initial whitening: eta[0] = block XOR K[0]
    var eta = _add_round_key(block_state, k0)
    var r = 1
    while r <= 10:
        val kr = _get_round_key(keys_flat, r)
        eta = _whirlpool_round(eta, kr)
        r = r + 1
    eta

# ---------------------------------------------------------------------------
# Miyaguchi-Preneel compression
# H_new = W(M, H) XOR H XOR M
# ---------------------------------------------------------------------------

fn _compress(h_state: list, m_state: list) -> list:
    val cipher_out = _whirlpool_cipher(m_state, h_state)
    # H_new = cipher_out XOR h_state XOR m_state
    val xor1 = _xor_states(cipher_out, h_state)
    _xor_states(xor1, m_state)

# ---------------------------------------------------------------------------
# Message block <-> state conversion (big-endian byte order per ISO §13.5)
# Block byte k → state[k/8][k%8] per the μ map (row-major, index 0..63)
# ---------------------------------------------------------------------------

fn _block_to_state(block: [u8], offset: u64) -> list:
    var s = []
    var i: u64 = 0
    while i < 64:
        s.push(_u8_at(block, offset + i).to_i64())
        i = i + 1
    s

fn _state_to_bytes(state: list) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 64:
        out.push((state.get(i) & 0xFF).to_u8())
        i = i + 1
    out

# ---------------------------------------------------------------------------
# Padding — ISO §13.5.
# Append 0x80, zero-fill until total_len ≡ 32 (mod 64),
# then append 32-byte big-endian bit count.
# For inputs up to 2^61 bytes (>>practical), only the last 8 bytes of the
# 32-byte length field are non-zero.
# ---------------------------------------------------------------------------

fn _pad_message(data: [u8]) -> [u8]:
    val data_len = data.len().to_u64()
    val bit_len = data_len * 8

    var padded: [u8] = []
    var i: u64 = 0
    while i < data_len:
        padded.push(_u8_at(data, i))
        i = i + 1

    # Append 0x80
    padded.push(0x80u8)

    # Pad with zeros until length ≡ 32 (mod 64)
    # We need: (padded.len() + 32) ≡ 0 (mod 64)
    # i.e. padded.len() ≡ 32 (mod 64)
    var cur_len = padded.len().to_u64()
    while (cur_len % 64) != 32:
        padded.push(0x00u8)
        cur_len = cur_len + 1

    # Append 32-byte big-endian bit count.
    # Bytes 0..23 are zero for practical inputs; bytes 24..31 encode bit_len.
    var li = 0
    while li < 24:
        padded.push(0x00u8)
        li = li + 1

    # 8-byte big-endian encoding of bit_len
    padded.push(((bit_len >> 56) & 0xFF).to_u8())
    padded.push(((bit_len >> 48) & 0xFF).to_u8())
    padded.push(((bit_len >> 40) & 0xFF).to_u8())
    padded.push(((bit_len >> 32) & 0xFF).to_u8())
    padded.push(((bit_len >> 24) & 0xFF).to_u8())
    padded.push(((bit_len >> 16) & 0xFF).to_u8())
    padded.push(((bit_len >> 8) & 0xFF).to_u8())
    padded.push((bit_len & 0xFF).to_u8())

    padded

# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

fn whirlpool(data: [u8]) -> [u8]:
    """Compute the Whirlpool hash of data. Returns 64-byte digest."""
    val padded = _pad_message(data)
    val num_blocks = padded.len().to_u64() / 64

    # IV = all-zero state
    var h_state = _make_zero_state()

    var block_idx: u64 = 0
    while block_idx < num_blocks:
        val m_state = _block_to_state(padded, block_idx * 64)
        h_state = _compress(h_state, m_state)
        block_idx = block_idx + 1

    _state_to_bytes(h_state)
