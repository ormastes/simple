# Dual backend parity framework for runtime-backed and pure-Simple algorithms.
#
# This module is the shared policy surface for components that can execute both
# a runtime/C-backed implementation and a pure-Simple implementation.

extern fn serial_println(msg: text)

enum DualBackendMode:
    Alpha
    Beta
    Normal

enum DualBackendPreference:
    RuntimeFirst
    PureSimpleFirst

struct DualBackendConfig:
    mode: DualBackendMode
    preference: DualBackendPreference

var _dual_backend_default_config = DualBackendConfig(
    mode: DualBackendMode.Alpha,
    preference: DualBackendPreference.RuntimeFirst
)

fn dual_backend_default_config() -> DualBackendConfig:
    _dual_backend_default_config

fn dual_backend_set_default_config(config: DualBackendConfig):
    _dual_backend_default_config = config

fn dual_backend_alpha_default_mode() -> DualBackendConfig:
    DualBackendConfig(
        mode: DualBackendMode.Alpha,
        preference: DualBackendPreference.RuntimeFirst
    )

fn dual_backend_beta_default_mode() -> DualBackendConfig:
    DualBackendConfig(
        mode: DualBackendMode.Beta,
        preference: DualBackendPreference.RuntimeFirst
    )

fn dual_backend_normal_pure_simple_mode() -> DualBackendConfig:
    DualBackendConfig(
        mode: DualBackendMode.Normal,
        preference: DualBackendPreference.PureSimpleFirst
    )

fn dual_backend_assert_mode() -> DualBackendConfig:
    dual_backend_alpha_default_mode()

fn dual_backend_critical_mode() -> DualBackendConfig:
    dual_backend_beta_default_mode()

fn dual_backend_pure_simple_mode() -> DualBackendConfig:
    dual_backend_normal_pure_simple_mode()

fn dual_backend_alpha_mode(preference: DualBackendPreference) -> DualBackendConfig:
    DualBackendConfig(
        mode: DualBackendMode.Alpha,
        preference: preference
    )

fn dual_backend_beta_mode(preference: DualBackendPreference) -> DualBackendConfig:
    DualBackendConfig(
        mode: DualBackendMode.Beta,
        preference: preference
    )

fn dual_backend_normal_mode(preference: DualBackendPreference) -> DualBackendConfig:
    DualBackendConfig(
        mode: DualBackendMode.Normal,
        preference: preference
    )

fn dual_backend_bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

fn _hex_digit(n: u8) -> u8:
    if n < 10:
        0x30 + n
    else:
        0x61 + (n - 10)

fn dual_backend_hex(data: [u8], limit: u64) -> text:
    var out: [u8] = []
    var i: u64 = 0
    while i < data.len() and i < limit:
        val byte_val = data[i]
        out.push(_hex_digit((byte_val >> 4) & 0x0F))
        out.push(_hex_digit(byte_val & 0x0F))
        i = i + 1
    if i < data.len():
        out.push(0x2E)
        out.push(0x2E)
        out.push(0x2E)
    out.to_text()

fn dual_backend_diff_report(component: text, operation: text, inputs: [text], runtime_output: [u8], pure_output: [u8]) -> text:
    var input_report = ""
    var i: u64 = 0
    while i < inputs.len():
        if i > 0:
            input_report = input_report + ";"
        input_report = input_report + inputs[i]
        i = i + 1
    "{component}:{operation}: runtime/pure mismatch | inputs={input_report} | runtime={dual_backend_hex(runtime_output, 64)} | pure={dual_backend_hex(pure_output, 64)}"

fn dual_backend_scalar_diff_report(component: text, operation: text, inputs: [text], runtime_output: text, pure_output: text) -> text:
    var input_report = ""
    var i: u64 = 0
    while i < inputs.len():
        if i > 0:
            input_report = input_report + ";"
        input_report = input_report + inputs[i]
        i = i + 1
    "{component}:{operation}: runtime/pure mismatch | inputs={input_report} | runtime={runtime_output} | pure={pure_output}"

fn _dual_backend_beta_report(report: text):
    serial_println("[dual-backend] " + report)

fn _dual_backend_alpha_halt(report: text):
    serial_println("[dual-backend] " + report)
    while true:
        pass_dn

fn dual_backend_choose_bytes(
    component: text,
    operation: text,
    config: DualBackendConfig,
    inputs: [text],
    runtime_output: [u8],
    pure_output: [u8]
) -> [u8]:
    if config.mode == DualBackendMode.Normal:
        if config.preference == DualBackendPreference.PureSimpleFirst:
            if pure_output.len() > 0:
                return pure_output
            return runtime_output
        if runtime_output.len() > 0:
            return runtime_output
        return pure_output

    if runtime_output.len() == 0:
        return pure_output
    if pure_output.len() == 0:
        return runtime_output
    if dual_backend_bytes_equal(runtime_output, pure_output):
        if config.preference == DualBackendPreference.PureSimpleFirst:
            return pure_output
        return runtime_output

    val report = dual_backend_diff_report(component, operation, inputs, runtime_output, pure_output)
    if config.mode == DualBackendMode.Alpha:
        _dual_backend_alpha_halt(report)

    _dual_backend_beta_report(report)
    if config.preference == DualBackendPreference.PureSimpleFirst:
        return pure_output
    runtime_output

fn dual_backend_run_bytes(
    component: text,
    operation: text,
    config: DualBackendConfig,
    inputs: [text],
    runtime_run: fn() -> [u8],
    pure_run: fn() -> [u8]
) -> [u8]:
    if config.mode == DualBackendMode.Normal:
        if config.preference == DualBackendPreference.PureSimpleFirst:
            val pure_output = pure_run()
            if pure_output.len() > 0:
                return pure_output
            return runtime_run()
        val runtime_output = runtime_run()
        if runtime_output.len() > 0:
            return runtime_output
        return pure_run()

    val runtime_output = runtime_run()
    val pure_output = pure_run()
    dual_backend_choose_bytes(component, operation, config, inputs, runtime_output, pure_output)

fn dual_backend_choose_bool(
    component: text,
    operation: text,
    config: DualBackendConfig,
    inputs: [text],
    runtime_output: bool,
    pure_output: bool
) -> bool:
    if config.mode == DualBackendMode.Normal:
        if config.preference == DualBackendPreference.PureSimpleFirst:
            return pure_output
        return runtime_output

    if runtime_output == pure_output:
        if config.preference == DualBackendPreference.PureSimpleFirst:
            return pure_output
        return runtime_output

    val report = dual_backend_scalar_diff_report(component, operation, inputs, runtime_output.to_text(), pure_output.to_text())
    if config.mode == DualBackendMode.Alpha:
        _dual_backend_alpha_halt(report)

    _dual_backend_beta_report(report)
    if config.preference == DualBackendPreference.PureSimpleFirst:
        return pure_output
    runtime_output

fn dual_backend_run_bool(
    component: text,
    operation: text,
    config: DualBackendConfig,
    inputs: [text],
    runtime_run: fn() -> bool,
    pure_run: fn() -> bool
) -> bool:
    if config.mode == DualBackendMode.Normal:
        if config.preference == DualBackendPreference.PureSimpleFirst:
            return pure_run()
        return runtime_run()

    val runtime_output = runtime_run()
    val pure_output = pure_run()
    dual_backend_choose_bool(component, operation, config, inputs, runtime_output, pure_output)

fn dual_backend_choose_u64(
    component: text,
    operation: text,
    config: DualBackendConfig,
    inputs: [text],
    runtime_output: u64,
    pure_output: u64
) -> u64:
    if config.mode == DualBackendMode.Normal:
        if config.preference == DualBackendPreference.PureSimpleFirst:
            return pure_output
        return runtime_output

    if runtime_output == pure_output:
        if config.preference == DualBackendPreference.PureSimpleFirst:
            return pure_output
        return runtime_output

    val report = dual_backend_scalar_diff_report(component, operation, inputs, runtime_output.to_text(), pure_output.to_text())
    if config.mode == DualBackendMode.Alpha:
        _dual_backend_alpha_halt(report)

    _dual_backend_beta_report(report)
    if config.preference == DualBackendPreference.PureSimpleFirst:
        return pure_output
    runtime_output

fn dual_backend_run_u64(
    component: text,
    operation: text,
    config: DualBackendConfig,
    inputs: [text],
    runtime_run: fn() -> u64,
    pure_run: fn() -> u64
) -> u64:
    if config.mode == DualBackendMode.Normal:
        if config.preference == DualBackendPreference.PureSimpleFirst:
            return pure_run()
        return runtime_run()

    val runtime_output = runtime_run()
    val pure_output = pure_run()
    dual_backend_choose_u64(component, operation, config, inputs, runtime_output, pure_output)

fn dual_backend_choose_text(
    component: text,
    operation: text,
    config: DualBackendConfig,
    inputs: [text],
    runtime_output: text,
    pure_output: text
) -> text:
    if config.mode == DualBackendMode.Normal:
        if config.preference == DualBackendPreference.PureSimpleFirst:
            if pure_output != "":
                return pure_output
            return runtime_output
        if runtime_output != "":
            return runtime_output
        return pure_output

    if runtime_output == pure_output:
        if config.preference == DualBackendPreference.PureSimpleFirst:
            return pure_output
        return runtime_output

    val report = dual_backend_scalar_diff_report(component, operation, inputs, runtime_output, pure_output)
    if config.mode == DualBackendMode.Alpha:
        _dual_backend_alpha_halt(report)

    _dual_backend_beta_report(report)
    if config.preference == DualBackendPreference.PureSimpleFirst:
        return pure_output
    runtime_output

fn dual_backend_run_text(
    component: text,
    operation: text,
    config: DualBackendConfig,
    inputs: [text],
    runtime_run: fn() -> text,
    pure_run: fn() -> text
) -> text:
    if config.mode == DualBackendMode.Normal:
        if config.preference == DualBackendPreference.PureSimpleFirst:
            val pure_output = pure_run()
            if pure_output != "":
                return pure_output
            return runtime_run()
        val runtime_output = runtime_run()
        if runtime_output != "":
            return runtime_output
        return pure_run()

    val runtime_output = runtime_run()
    val pure_output = pure_run()
    dual_backend_choose_text(component, operation, config, inputs, runtime_output, pure_output)

export DualBackendMode, DualBackendPreference, DualBackendConfig
export dual_backend_default_config, dual_backend_set_default_config
export dual_backend_alpha_default_mode, dual_backend_beta_default_mode, dual_backend_normal_pure_simple_mode
export dual_backend_assert_mode, dual_backend_critical_mode, dual_backend_pure_simple_mode
export dual_backend_alpha_mode, dual_backend_beta_mode, dual_backend_normal_mode
export dual_backend_bytes_equal, dual_backend_diff_report, dual_backend_scalar_diff_report
export dual_backend_choose_bytes, dual_backend_run_bytes
export dual_backend_choose_bool, dual_backend_run_bool
export dual_backend_choose_u64, dual_backend_run_u64
export dual_backend_choose_text, dual_backend_run_text
