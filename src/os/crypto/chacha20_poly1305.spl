#![allow(unnamed_duplicate_typed_args)]
# ChaCha20-Poly1305 AEAD — Pure Simple Implementation (RFC 7539)
#
# Authenticated Encryption with Associated Data combining ChaCha20
# and Poly1305. All operations use u32 — 32-bit safe, no float.
#
# This is the IETF construction (RFC 7539), not the original NaCl version.
# The SSH variant (chacha20-poly1305@openssh.com) uses a different nonce
# construction — see ssh_cipher.spl for the SSH-specific wrapper.
#
# Reference: RFC 7539 (ChaCha20 and Poly1305 for IETF Protocols)

use os.crypto.chacha20.{chacha20_block, chacha20_encrypt}
use os.crypto.poly1305.{poly1305_mac}

# ============================================================================
# Result Type
# ============================================================================

enum Chacha20Poly1305Result:
    Ok(data: [u8])
    Err(msg: text)

# ============================================================================
# Helpers
# ============================================================================

fn _pad16(buf: [u8], data_len: u64):
    """Append zero padding to make data_len a multiple of 16."""
    val rem = data_len % 16
    if rem != 0:
        var i: u64 = 0
        while i < (16 - rem):
            buf.push(0)
            i = i + 1

fn _put_le_u64(buf: [u8], val_: u64):
    """Append u64 as 8 bytes little-endian."""
    buf.push((val_ & 0xFF).to_u8())
    buf.push(((val_ >> 8) & 0xFF).to_u8())
    buf.push(((val_ >> 16) & 0xFF).to_u8())
    buf.push(((val_ >> 24) & 0xFF).to_u8())
    buf.push(((val_ >> 32) & 0xFF).to_u8())
    buf.push(((val_ >> 40) & 0xFF).to_u8())
    buf.push(((val_ >> 48) & 0xFF).to_u8())
    buf.push(((val_ >> 56) & 0xFF).to_u8())

# ============================================================================
# Poly1305 Key Generation (RFC 7539 Section 2.6)
# ============================================================================

fn _generate_poly1305_key(key: [u8], nonce: [u8]) -> [u8]:
    """Generate Poly1305 one-time key from ChaCha20 with counter=0.

    The first 32 bytes of ChaCha20 block 0 are used as the Poly1305 key.
    """
    # Convert key bytes to u32 words (little-endian)
    var key_words: [u32] = []
    var i: u64 = 0
    while i < 8:
        val base = i * 4
        val word = key[base].to_u32() |
                   (key[base + 1].to_u32() << 8) |
                   (key[base + 2].to_u32() << 16) |
                   (key[base + 3].to_u32() << 24)
        key_words.push(word)
        i = i + 1

    # Convert nonce bytes to u32 words (little-endian)
    var nonce_words: [u32] = []
    i = 0
    while i < 3:
        val base = i * 4
        val word = nonce[base].to_u32() |
                   (nonce[base + 1].to_u32() << 8) |
                   (nonce[base + 2].to_u32() << 16) |
                   (nonce[base + 3].to_u32() << 24)
        nonce_words.push(word)
        i = i + 1

    # Generate block 0
    val block = chacha20_block(key_words, 0, nonce_words)

    # Extract first 32 bytes (8 u32 words)
    var poly_key: [u8] = []
    i = 0
    while i < 8:
        val word = block[i]
        poly_key.push((word & 0xFF).to_u8())
        poly_key.push(((word >> 8) & 0xFF).to_u8())
        poly_key.push(((word >> 16) & 0xFF).to_u8())
        poly_key.push(((word >> 24) & 0xFF).to_u8())
        i = i + 1

    poly_key

# ============================================================================
# Construct Poly1305 Input (RFC 7539 Section 2.8)
# ============================================================================

fn _build_mac_data(aad: [u8], ciphertext: [u8]) -> [u8]:
    """Build the Poly1305 input per RFC 7539 Section 2.8:
    pad16(AAD) || pad16(ciphertext) || len(AAD) as u64 LE || len(ciphertext) as u64 LE
    """
    var mac_data: [u8] = []
    var i: u64 = 0

    # AAD
    while i < aad.len():
        mac_data.push(aad[i])
        i = i + 1
    val aad_rem = aad.len() % 16
    if aad_rem != 0:
        var pad_i: u64 = 0
        while pad_i < (16 - aad_rem):
            mac_data.push(0)
            pad_i = pad_i + 1

    # Ciphertext
    i = 0
    while i < ciphertext.len():
        mac_data.push(ciphertext[i])
        i = i + 1
    val cipher_rem = ciphertext.len() % 16
    if cipher_rem != 0:
        var pad_j: u64 = 0
        while pad_j < (16 - cipher_rem):
            mac_data.push(0)
            pad_j = pad_j + 1

    # Lengths as u64 LE
    val aad_len = aad.len()
    mac_data.push((aad_len & 0xFF).to_u8())
    mac_data.push(((aad_len >> 8) & 0xFF).to_u8())
    mac_data.push(((aad_len >> 16) & 0xFF).to_u8())
    mac_data.push(((aad_len >> 24) & 0xFF).to_u8())
    mac_data.push(((aad_len >> 32) & 0xFF).to_u8())
    mac_data.push(((aad_len >> 40) & 0xFF).to_u8())
    mac_data.push(((aad_len >> 48) & 0xFF).to_u8())
    mac_data.push(((aad_len >> 56) & 0xFF).to_u8())
    val cipher_len = ciphertext.len()
    mac_data.push((cipher_len & 0xFF).to_u8())
    mac_data.push(((cipher_len >> 8) & 0xFF).to_u8())
    mac_data.push(((cipher_len >> 16) & 0xFF).to_u8())
    mac_data.push(((cipher_len >> 24) & 0xFF).to_u8())
    mac_data.push(((cipher_len >> 32) & 0xFF).to_u8())
    mac_data.push(((cipher_len >> 40) & 0xFF).to_u8())
    mac_data.push(((cipher_len >> 48) & 0xFF).to_u8())
    mac_data.push(((cipher_len >> 56) & 0xFF).to_u8())

    mac_data

# ============================================================================
# AEAD Encrypt (RFC 7539 Section 2.8)
# ============================================================================

fn chacha20_poly1305_encrypt(key: [u8], nonce: [u8], plaintext: [u8], aad: [u8]) -> [u8]:
    """ChaCha20-Poly1305 AEAD encryption.

    Args:
        key: 32-byte key.
        nonce: 12-byte nonce.
        plaintext: Data to encrypt.
        aad: Additional authenticated data.

    Returns: ciphertext || 16-byte Poly1305 tag.
    """
    # Generate Poly1305 one-time key from block 0
    val poly_key = _generate_poly1305_key(key, nonce)

    # Encrypt plaintext with ChaCha20 starting at counter=1
    val ciphertext = chacha20_encrypt(key, 1, nonce, plaintext)

    # Compute Poly1305 tag
    val mac_data = _build_mac_data(aad, ciphertext)
    val tag = poly1305_mac(poly_key, mac_data)

    # Return ciphertext || tag
    var result: [u8] = []
    var i: u64 = 0
    while i < ciphertext.len():
        result.push(ciphertext[i])
        i = i + 1
    i = 0
    while i < 16:
        result.push(tag[i])
        i = i + 1

    result

# ============================================================================
# AEAD Decrypt (RFC 7539 Section 2.8)
# ============================================================================

fn chacha20_poly1305_decrypt(key: [u8], nonce: [u8], ciphertext: [u8], aad: [u8], tag: [u8]) -> Chacha20Poly1305Result:
    """ChaCha20-Poly1305 AEAD decryption.

    Args:
        key: 32-byte key.
        nonce: 12-byte nonce.
        ciphertext: Encrypted data (without tag).
        aad: Additional authenticated data.
        tag: 16-byte Poly1305 tag to verify.

    Returns: Chacha20Poly1305Result.Ok with plaintext on success.
    """
    if tag.len() != 16:
        return Chacha20Poly1305Result.Err("invalid tag length")

    # Generate Poly1305 one-time key from block 0
    val poly_key = _generate_poly1305_key(key, nonce)

    # Compute expected tag
    val mac_data = _build_mac_data(aad, ciphertext)
    val expected_tag = poly1305_mac(poly_key, mac_data)

    # Constant-time tag comparison
    var diff: u8 = 0
    var i: u64 = 0
    while i < 16:
        diff = diff | (expected_tag[i] ^ tag[i])
        i = i + 1

    if diff != 0:
        return Chacha20Poly1305Result.Err("authentication tag mismatch")

    # Decrypt with ChaCha20 starting at counter=1
    val plaintext = chacha20_encrypt(key, 1, nonce, ciphertext)

    Chacha20Poly1305Result.Ok(data: plaintext)
