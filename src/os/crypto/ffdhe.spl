# ============================================================================
# Public API — named-group primes
# ============================================================================

fn ffdhe2048_p() -> list:
    _f_bytes_to_bigint_be(_f_hex_to_bytes(_ffdhe2048_p_hex()))

fn ffdhe3072_p() -> list:
    _f_bytes_to_bigint_be(_f_hex_to_bytes(_ffdhe3072_p_hex()))

fn ffdhe4096_p() -> list:
    _f_bytes_to_bigint_be(_f_hex_to_bytes(_ffdhe4096_p_hex()))

fn ffdhe_g() -> list:
    _f_from_i64(2)

# ============================================================================
# DH key-agreement primitives
# ============================================================================

# ffdhe_keygen: compute public key from caller-supplied private scalar bytes.
#   scalar_bytes — big-endian entropy bytes (caller generates from CSPRNG).
#   Returns [priv_bigint, pub_bigint] where pub = g^priv mod p.
#
# NOTE: interpreter-mode 2048-bit modexp takes O(minutes); mark @slow.
fn ffdhe_keygen(p: list, g: list, scalar_bytes: [u8]) -> list:
    val priv = _f_bytes_to_bigint_be(scalar_bytes)
    val pub = _f_mod_exp(g, priv, p)
    [priv, pub]

# ffdhe_dh: shared secret = peer_pub^my_priv mod p.
#
# NOTE: interpreter-mode 2048-bit modexp takes O(minutes); mark @slow.
fn ffdhe_dh(my_priv: list, peer_pub: list, p: list) -> list:
    _f_mod_exp(peer_pub, my_priv, p)

# ffdhe_pub_to_bytes: serialize BigInt public key / shared secret as
# big-endian bytes of exactly byte_len bytes (zero-padded on the left).
fn ffdhe_pub_to_bytes(pub: list, byte_len: u64) -> [u8]:
    _f_bigint_to_bytes_be(pub, byte_len)

# ffdhe_bytes_to_pub: deserialize big-endian bytes to a BigInt.
fn ffdhe_bytes_to_pub(bytes: [u8]) -> list:
    _f_bytes_to_bigint_be(bytes)

# ffdhe_prime_bytes: canonical big-endian encoding of a named-group prime.
# Used by the KAT spec to compute SHA-256 integrity fingerprints.
fn ffdhe_prime_bytes(p: list, byte_len: u64) -> [u8]:
    _f_bigint_to_bytes_be(p, byte_len)
