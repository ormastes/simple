# P-384 Field Arithmetic (mod p)
#
# 384-bit field arithmetic using 12 x 32-bit limbs stored in u64 (little-endian).
# l0 = bits 0..31, lb = bits 352..383.
# This avoids the interpreter's bit-63 truncation bug.
#
# Also provides HMAC-SHA-384 (used by RFC 6979 nonce generation in p384.spl).
#
# References:
#   * FIPS 186-4 / SEC2 v2.0 §2.5.1 (P-384 parameters)
#   * RFC 2104 (HMAC)

use os.crypto.sha384.{sha384}

# ============================================================================
# HMAC-SHA-384 (RFC 2104) — inline since sha384.spl doesn't export one
# Block size = 128 bytes, output = 48 bytes
# ============================================================================

fn _sha384_hmac(key: [u8], data: [u8]) -> [u8]:
    """HMAC-SHA-384 per RFC 2104."""
    val block_size: u64 = 128
    val hash_len: u64 = 48
    # Normalize key
    var k_prime: [u8] = []
    if key.len().to_u64() > block_size:
        val hashed = sha384(key)
        var j: u64 = 0
        while j < hash_len:
            k_prime.push(hashed[j])
            j = j + 1
    else:
        var j: u64 = 0
        while j < key.len().to_u64():
            k_prime.push(key[j])
            j = j + 1
    while k_prime.len().to_u64() < block_size:
        k_prime.push(0x00)
    # Inner: H((K ^ ipad) || data)
    var inner_input: [u8] = []
    var i: u64 = 0
    while i < block_size:
        val xored: u8 = (k_prime[i] ^ 0x36u8)
        inner_input.push(xored)
        i = i + 1
    i = 0
    while i < data.len().to_u64():
        inner_input.push(data[i])
        i = i + 1
    val inner_hash = sha384(inner_input)
    # Outer: H((K ^ opad) || inner_hash)
    var outer_input: [u8] = []
    i = 0
    while i < block_size:
        val xored: u8 = (k_prime[i] ^ 0x5Cu8)
        outer_input.push(xored)
        i = i + 1
    i = 0
    while i < hash_len:
        outer_input.push(inner_hash[i])
        i = i + 1
    sha384(outer_input)

# ============================================================================
# Constants
# ============================================================================

val MASK32: u64 = 0xFFFFFFFF

# ============================================================================
# Field element type: 12 x 32-bit limbs in u64 (little-endian)
# ============================================================================

struct Fe384:
    l0: u64
    l1: u64
    l2: u64
    l3: u64
    l4: u64
    l5: u64
    l6: u64
    l7: u64
    l8: u64
    l9: u64
    la: u64
    lb: u64

# --- P-384 prime limbs (little-endian 32-bit) ---
# p = FFFFFFFF FFFFFFFF FFFFFFFF FFFFFFFF FFFFFFFF FFFFFFFF FFFFFFFF FFFFFFFE
#     FFFFFFFF 00000000 00000000 FFFFFFFF
# LE 32-bit: [0xFFFFFFFF, 0x00000000, 0x00000000, 0xFFFFFFFF,
#             0xFFFFFFFE, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF,
#             0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF]

fn _p_limb(idx: u64) -> u64:
    if idx == 0: return MASK32
    elif idx == 1: return 0
    elif idx == 2: return 0
    elif idx == 3: return MASK32
    elif idx == 4: return 0xFFFFFFFE
    elif idx == 5: return MASK32
    elif idx == 6: return MASK32
    elif idx == 7: return MASK32
    elif idx == 8: return MASK32
    elif idx == 9: return MASK32
    elif idx == 10: return MASK32
    else: return MASK32

# --- Curve order n limbs (little-endian 32-bit) ---
# n = FFFFFFFF FFFFFFFF FFFFFFFF FFFFFFFF FFFFFFFF FFFFFFFF C7634D81 F4372DDF
#     581A0DB2 48B0A77A ECEC196A CCC52973
# LE 32-bit: [0xCCC52973, 0xECEC196A, 0x48B0A77A, 0x581A0DB2,
#             0xF4372DDF, 0xC7634D81, 0xFFFFFFFF, 0xFFFFFFFF,
#             0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF]

fn _n_limb(idx: u64) -> u64:
    if idx == 0: return 0xCCC52973
    elif idx == 1: return 0xECEC196A
    elif idx == 2: return 0x48B0A77A
    elif idx == 3: return 0x581A0DB2
    elif idx == 4: return 0xF4372DDF
    elif idx == 5: return 0xC7634D81
    elif idx == 6: return MASK32
    elif idx == 7: return MASK32
    elif idx == 8: return MASK32
    elif idx == 9: return MASK32
    elif idx == 10: return MASK32
    else: return MASK32

# ============================================================================
# Field element constructors
# ============================================================================

fn fe_zero() -> Fe384:
    Fe384(l0: 0, l1: 0, l2: 0, l3: 0, l4: 0, l5: 0,
          l6: 0, l7: 0, l8: 0, l9: 0, la: 0, lb: 0)

fn fe_one() -> Fe384:
    Fe384(l0: 1, l1: 0, l2: 0, l3: 0, l4: 0, l5: 0,
          l6: 0, l7: 0, l8: 0, l9: 0, la: 0, lb: 0)

fn _fe_get(a: Fe384, idx: u64) -> u64:
    if idx == 0: return a.l0
    elif idx == 1: return a.l1
    elif idx == 2: return a.l2
    elif idx == 3: return a.l3
    elif idx == 4: return a.l4
    elif idx == 5: return a.l5
    elif idx == 6: return a.l6
    elif idx == 7: return a.l7
    elif idx == 8: return a.l8
    elif idx == 9: return a.l9
    elif idx == 10: return a.la
    else: return a.lb

fn _fe_from_arr(a: [u64]) -> Fe384:
    Fe384(l0: a[0u64], l1: a[1u64], l2: a[2u64], l3: a[3u64],
          l4: a[4u64], l5: a[5u64], l6: a[6u64], l7: a[7u64],
          l8: a[8u64], l9: a[9u64], la: a[10u64], lb: a[11u64])

fn _fe_to_arr(a: Fe384) -> [u64]:
    var r: [u64] = []
    r.push(a.l0)
    r.push(a.l1)
    r.push(a.l2)
    r.push(a.l3)
    r.push(a.l4)
    r.push(a.l5)
    r.push(a.l6)
    r.push(a.l7)
    r.push(a.l8)
    r.push(a.l9)
    r.push(a.la)
    r.push(a.lb)
    r

# ============================================================================
# Byte encoding/decoding (big-endian 48 bytes <-> 12 LE 32-bit limbs)
# ============================================================================

fn fe_from_bytes(b: [u8]) -> Fe384:
    """Decode 48 big-endian bytes to Fe384."""
    # Big-endian byte[0] is MSB = limb 11 high byte
    # Each limb is 4 bytes. Limb i covers bytes [44-4i .. 47-4i] (BE offset)
    var limbs: [u64] = []
    var i: u64 = 0
    while i < 12:
        limbs.push(0)
        i = i + 1
    i = 0
    while i < 12:
        val be_offset: u64 = 44 - (i * 4)
        var limb_val: u64 = 0
        val b0: u64 = b[be_offset].to_u64()
        val b1: u64 = b[be_offset + 1].to_u64()
        val b2: u64 = b[be_offset + 2].to_u64()
        val b3: u64 = b[be_offset + 3].to_u64()
        limb_val = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        limbs[i] = limb_val
        i = i + 1
    _fe_from_arr(limbs)

fn fe_to_bytes(a: Fe384) -> [u8]:
    """Encode Fe384 as 48 big-endian bytes."""
    var result: [u8] = []
    var i: u64 = 0
    while i < 48:
        result.push(0x00)
        i = i + 1
    i = 0
    while i < 12:
        val limb_val: u64 = _fe_get(a, i)
        val be_offset: u64 = 44 - (i * 4)
        result[be_offset] = ((limb_val >> 24) & 0xFF).to_u8()
        result[be_offset + 1] = ((limb_val >> 16) & 0xFF).to_u8()
        result[be_offset + 2] = ((limb_val >> 8) & 0xFF).to_u8()
        result[be_offset + 3] = (limb_val & 0xFF).to_u8()
        i = i + 1
    result

# ============================================================================
# Field addition: a + b mod p
# ============================================================================

fn fe_add(a: Fe384, b: Fe384) -> Fe384:
    var limbs: [u64] = []
    var i: u64 = 0
    while i < 12:
        limbs.push(0)
        i = i + 1
    var carry: u64 = 0
    i = 0
    while i < 12:
        val s: u64 = _fe_get(a, i) + _fe_get(b, i) + carry
        limbs[i] = s & MASK32
        carry = (s >> 32) & MASK32
        i = i + 1
    # Conditional subtract p if sum >= p
    _fe_cond_sub_p(_fe_from_arr(limbs), carry)

fn _fe_cond_sub_p(a: Fe384, top_carry: u64) -> Fe384:
    """If a >= p (indicated by top_carry or comparison), subtract p."""
    # Try subtracting p
    var limbs: [u64] = []
    var i: u64 = 0
    while i < 12:
        limbs.push(0)
        i = i + 1
    var borrow: u64 = 0
    i = 0
    while i < 12:
        val ai: u64 = _fe_get(a, i)
        val pi: u64 = _p_limb(i)
        val diff: u64 = ai + (1 << 32) - pi - borrow
        limbs[i] = diff & MASK32
        borrow = 1 - ((diff >> 32) & 1)
        i = i + 1
    # If top_carry==1 or borrow==0 (meaning a >= p), use the subtracted result
    val use_sub: u64 = if top_carry == 1 { 1 } elif borrow == 0 { 1 } else { 0 }
    _fe_cond_select(a, _fe_from_arr(limbs), use_sub)

fn _fe_cond_select(a: Fe384, b: Fe384, take_b: u64) -> Fe384:
    """Return b if take_b==1, else a. Branch-free via XOR mask."""
    val mask: u64 = (0 - take_b) & MASK32
    Fe384(
        l0: a.l0 ^ (mask & (a.l0 ^ b.l0)),
        l1: a.l1 ^ (mask & (a.l1 ^ b.l1)),
        l2: a.l2 ^ (mask & (a.l2 ^ b.l2)),
        l3: a.l3 ^ (mask & (a.l3 ^ b.l3)),
        l4: a.l4 ^ (mask & (a.l4 ^ b.l4)),
        l5: a.l5 ^ (mask & (a.l5 ^ b.l5)),
        l6: a.l6 ^ (mask & (a.l6 ^ b.l6)),
        l7: a.l7 ^ (mask & (a.l7 ^ b.l7)),
        l8: a.l8 ^ (mask & (a.l8 ^ b.l8)),
        l9: a.l9 ^ (mask & (a.l9 ^ b.l9)),
        la: a.la ^ (mask & (a.la ^ b.la)),
        lb: a.lb ^ (mask & (a.lb ^ b.lb))
    )

# ============================================================================
# Field subtraction: a - b mod p
# ============================================================================

fn fe_sub(a: Fe384, b: Fe384) -> Fe384:
    var limbs: [u64] = []
    var i: u64 = 0
    while i < 12:
        limbs.push(0)
        i = i + 1
    var borrow: u64 = 0
    i = 0
    while i < 12:
        val ai: u64 = _fe_get(a, i)
        val bi: u64 = _fe_get(b, i)
        val diff: u64 = ai + (1 << 32) - bi - borrow
        limbs[i] = diff & MASK32
        borrow = 1 - ((diff >> 32) & 1)
        i = i + 1
    # If borrow, add p back
    val result = _fe_from_arr(limbs)
    if borrow == 1:
        return _fe_add_p(result)
    result

fn _fe_add_p(a: Fe384) -> Fe384:
    """Add p to a (for underflow correction)."""
    var limbs: [u64] = []
    var i: u64 = 0
    while i < 12:
        limbs.push(0)
        i = i + 1
    var carry: u64 = 0
    i = 0
    while i < 12:
        val s: u64 = _fe_get(a, i) + _p_limb(i) + carry
        limbs[i] = s & MASK32
        carry = (s >> 32) & MASK32
        i = i + 1
    _fe_from_arr(limbs)

# ============================================================================
# Field multiplication: a * b mod p
# Schoolbook 12x12 -> 24 limb product, then reduce mod p
# ============================================================================

fn fe_mul(a: Fe384, b: Fe384) -> Fe384:
    val wide = _fe_mul_wide(a, b)
    _fe_reduce_wide(wide)

fn fe_sq(a: Fe384) -> Fe384:
    fe_mul(a, a)

fn _fe_mul_wide(a: Fe384, b: Fe384) -> [u64]:
    """12x12 schoolbook multiply. Each limb is 32 bits, so product of two
    limbs fits in 64 bits. Result: 24 limbs of 32-bit values."""
    var prod: [u64] = []
    var pi: u64 = 0
    while pi < 24:
        prod.push(0)
        pi = pi + 1
    var i: u64 = 0
    while i < 12:
        var carry: u64 = 0
        val ai: u64 = _fe_get(a, i)
        var j: u64 = 0
        while j < 12:
            val bj: u64 = _fe_get(b, j)
            val t: u64 = ai * bj + prod[i + j] + carry
            prod[i + j] = t & MASK32
            carry = (t >> 32) & MASK32
            j = j + 1
        var k: u64 = i + 12
        while carry != 0 and k < 24:
            val s: u64 = prod[k] + carry
            prod[k] = s & MASK32
            carry = (s >> 32) & MASK32
            k = k + 1
        i = i + 1
    prod

fn _fe_reduce_wide(w: [u64]) -> Fe384:
    """Reduce 768-bit (24-limb) value mod p via iterative R-multiplication.
    R = 2^384 mod p = 2^128 + 2^96 - 2^32 + 1
    LE 32-bit limbs: [1, 0xFFFFFFFF, 0xFFFFFFFF, 0, 1, 0, 0, 0, 0, 0, 0, 0]."""
    # Split into hi (limbs 12..23) and lo (limbs 0..11)
    # result = hi * R + lo, then iterate until hi portion is zero
    var lo: [u64] = []
    var i: u64 = 0
    while i < 12:
        lo.push(w[i])
        i = i + 1
    var hi: [u64] = []
    i = 0
    while i < 12:
        hi.push(w[12 + i])
        i = i + 1
    # Multiply hi by R and add to lo
    # R = [1, 0xFFFFFFFF, 0xFFFFFFFF, 0, 1, 0, 0, 0, 0, 0, 0, 0]
    # hi*R is at most 12+5 = 17 limbs, but since hi is at most 384 bits
    # and R is 129 bits, hi*R is at most 513 bits = 17 limbs.
    # After adding lo, result is at most ~514 bits.
    # We do another round: split that into hi2 (limbs 12..16) and lo2 (limbs 0..11)
    # hi2 * R is at most (514-384=130 bits) + 129 bits = ~260 bits, fits in 12 limbs.
    # One more add and a conditional subtract should suffice.

    val sum1 = _reduce_one_round(hi, lo)
    # sum1 is at most 17 limbs. Extract hi2 (limbs 12..16) and lo2 (0..11).
    var lo2: [u64] = []
    i = 0
    while i < 12:
        lo2.push(sum1[i])
        i = i + 1
    var hi2: [u64] = []
    i = 12
    while i < sum1.len().to_u64():
        hi2.push(sum1[i])
        i = i + 1
    # Pad hi2 to 12 limbs
    while hi2.len().to_u64() < 12:
        hi2.push(0)

    val sum2 = _reduce_one_round(hi2, lo2)
    # sum2 should be at most ~13 limbs. One more round if needed.
    var lo3: [u64] = []
    i = 0
    while i < 12:
        lo3.push(sum2[i])
        i = i + 1
    var hi3: [u64] = []
    i = 12
    while i < sum2.len().to_u64():
        hi3.push(sum2[i])
        i = i + 1
    while hi3.len().to_u64() < 12:
        hi3.push(0)

    val sum3 = _reduce_one_round(hi3, lo3)
    # Now should fit in 12 limbs. Final conditional subtract.
    var final_limbs: [u64] = []
    i = 0
    while i < 12:
        final_limbs.push(sum3[i])
        i = i + 1
    val raw = _fe_from_arr(final_limbs)
    _fe_cond_sub_p(raw, 0)

fn _reduce_one_round(hi: [u64], lo: [u64]) -> [u64]:
    """Compute hi * R + lo where R = [1, 0xFFFFFFFF, 0xFFFFFFFF, 0, 1, 0...].
    Returns up to 17 limbs."""
    # hi * R: schoolbook multiply hi (12 limbs) by R (5 nonzero limbs)
    # R limbs: r0=1, r1=0xFFFFFFFF, r2=0xFFFFFFFF, r3=0, r4=1
    var prod: [u64] = []
    var pi: u64 = 0
    while pi < 17:
        prod.push(0)
        pi = pi + 1
    # Multiply by r0=1
    var i: u64 = 0
    while i < 12:
        prod[i] = prod[i] + hi[i]
        i = i + 1
    # Multiply by r1=0xFFFFFFFF
    i = 0
    var carry: u64 = 0
    while i < 12:
        val t: u64 = hi[i] * MASK32 + prod[i + 1] + carry
        prod[i + 1] = t & MASK32
        carry = (t >> 32) & MASK32
        i = i + 1
    prod[13] = prod[13] + carry
    # Multiply by r2=0xFFFFFFFF
    carry = 0
    i = 0
    while i < 12:
        val t: u64 = hi[i] * MASK32 + prod[i + 2] + carry
        prod[i + 2] = t & MASK32
        carry = (t >> 32) & MASK32
        i = i + 1
    prod[14] = prod[14] + carry
    # r3 = 0, skip
    # Multiply by r4=1
    i = 0
    while i < 12:
        prod[i + 4] = prod[i + 4] + hi[i]
        i = i + 1
    # Now propagate carries through prod
    carry = 0
    i = 0
    while i < 17:
        val s: u64 = prod[i] + carry
        prod[i] = s & MASK32
        carry = (s >> 32) & MASK32
        i = i + 1
    # Add lo to prod
    carry = 0
    i = 0
    while i < 12:
        val s: u64 = prod[i] + lo[i] + carry
        prod[i] = s & MASK32
        carry = (s >> 32) & MASK32
        i = i + 1
    # Propagate carry
    while i < 17:
        val s: u64 = prod[i] + carry
        prod[i] = s & MASK32
        carry = (s >> 32) & MASK32
        i = i + 1
    prod

# ============================================================================
# Field inversion: a^(p-2) mod p via square-and-multiply
# ============================================================================

fn fe_inv(a: Fe384) -> Fe384:
    """Modular inverse via Fermat: a^(p-2) mod p.
    p-2 = FFFFFFFF...FFFFFFFE FFFFFFFF 00000000 00000000 FFFFFFFD
    (same as p except last limb is 0xFFFFFFFD instead of 0xFFFFFFFF)."""
    # We use the binary method: scan p-2 MSB to LSB
    val exp_bytes = _p_minus_2_bytes()
    var result = fe_one()
    var i: u64 = 0
    while i < 48:
        var bit: u64 = 0
        while bit < 8:
            result = fe_sq(result)
            val byte_val: u64 = exp_bytes[i].to_u64()
            val bit_set: u64 = (byte_val >> (7 - bit)) & 1
            if bit_set == 1:
                result = fe_mul(result, a)
            bit = bit + 1
        i = i + 1
    result

fn _p_minus_2_bytes() -> [u8]:
    """p - 2 as 48 big-endian bytes."""
    # p = FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFE
    #     FFFFFFFF0000000000000000FFFFFFFF
    # p-2 = FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFE
    #       FFFFFFFF0000000000000000FFFFFFFD
    var b: [u8] = []
    # Bytes 0-27: top 224 bits are all 0xFF
    var i: u64 = 0
    while i < 28:
        b.push(0xFF)
        i = i + 1
    # Bytes 28-31: 0xFFFFFFFE
    b.push(0xFF)
    b.push(0xFF)
    b.push(0xFF)
    b.push(0xFE)
    # Bytes 32-35: 0xFFFFFFFF
    b.push(0xFF)
    b.push(0xFF)
    b.push(0xFF)
    b.push(0xFF)
    # Bytes 36-39: 0x00000000
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    # Bytes 40-43: 0x00000000
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    b.push(0x00)
    # Bytes 44-47: 0xFFFFFFFF - 2 = 0xFFFFFFFD
    b.push(0xFF)
    b.push(0xFF)
    b.push(0xFF)
    b.push(0xFD)
    b

# ============================================================================
# Field equality
# ============================================================================

fn fe_eq(a: Fe384, b: Fe384) -> bool:
    val diff =
        (a.l0 ^ b.l0) |
        (a.l1 ^ b.l1) |
        (a.l2 ^ b.l2) |
        (a.l3 ^ b.l3) |
        (a.l4 ^ b.l4) |
        (a.l5 ^ b.l5) |
        (a.l6 ^ b.l6) |
        (a.l7 ^ b.l7) |
        (a.l8 ^ b.l8) |
        (a.l9 ^ b.l9) |
        (a.la ^ b.la) |
        (a.lb ^ b.lb)
    (diff & MASK32) == 0
