# HKDF-RIPEMD-160 — Pure Simple Implementation
#
# HKDF (HMAC-based Key Derivation Function) per RFC 5869, using RIPEMD-160
# as the underlying hash function.
#
# Hash parameters:
#   HashLen = 20 bytes (160 bits)
#   Max output length: 255 * 20 = 5100 bytes
#
# Public API:
#   hkdf_ripemd160_extract(salt, ikm) -> list        — 20-byte PRK
#   hkdf_ripemd160_expand(prk, info, length) -> Result<list, HkdfError>
#   hkdf_ripemd160(salt, ikm, info, length)  -> Result<list, HkdfError>
#
# Implementation notes:
#   - All byte buffers are list (i64 values, one per byte), matching the
#     hmac_ripemd160 dependency convention.
#   - if/elif/else chains used throughout (sequential `if` returns fire only first).
#   - Module-level helpers avoid it-block var-mutation pitfall.
#   - Counter byte is a SINGLE byte (0x01..0xFF), not 4-byte big-endian.
#
# tag: crypto, hkdf, ripemd160, rfc5869

use os.crypto.hmac_ripemd160.{hmac_ripemd160}

# =============================================================================
# Error type
# =============================================================================

enum HkdfError:
    LengthExceeded

# =============================================================================
# Internal helper — build a list of n zero bytes
# =============================================================================

fn _hkdf_r160_zeros(n: i64) -> list:
    var buf = []
    var i = 0
    while i < n:
        buf.push(0)
        i = i + 1
    buf

# =============================================================================
# HKDF-RIPEMD-160 Extract
# =============================================================================
#
# RFC 5869 §2.2: PRK = HMAC-Hash(salt, IKM)
# If salt is empty, use HashLen (20) zero bytes per RFC 5869 §2.2.

fn hkdf_ripemd160_extract(salt: list, ikm: list) -> list:
    var effective_salt = []
    if salt.len() == 0:
        effective_salt = _hkdf_r160_zeros(20)
    else:
        var i = 0
        while i < salt.len():
            effective_salt.push(salt.get(i))
            i = i + 1
    hmac_ripemd160(effective_salt, ikm)

# =============================================================================
# HKDF-RIPEMD-160 Expand
# =============================================================================
#
# RFC 5869 §2.3: OKM = T(1) || T(2) || ... || T(N), first `length` bytes
#   T(0)  = empty
#   T(i)  = HMAC-RIPEMD-160(PRK, T(i-1) || info || [i])
#   N     = ceil(length / 20)
#   length must be >= 0 and <= 255 * 20 (5100)
#
# Returns Ok([]) for length == 0 (RFC 5869 does not prohibit zero-length).
# Returns Err(LengthExceeded) for length > 5100.

fn hkdf_ripemd160_expand(prk: list, info: list, length: i64) -> Result<list, HkdfError>:
    if length > 5100:
        Err(HkdfError.LengthExceeded)
    elif length == 0:
        Ok([])
    else:
        var expanded = []
        var prev_t = []
        var counter = 1
        while expanded.len() < length:
            # Build HMAC input: T(i-1) || info || counter_byte
            var hmac_input = []
            var j = 0
            while j < prev_t.len():
                hmac_input.push(prev_t.get(j))
                j = j + 1
            j = 0
            while j < info.len():
                hmac_input.push(info.get(j))
                j = j + 1
            hmac_input.push(counter & 0xFF)
            prev_t = hmac_ripemd160(prk, hmac_input)
            j = 0
            while j < prev_t.len():
                expanded.push(prev_t.get(j))
                j = j + 1
            counter = counter + 1
        # Truncate to exact length
        var result = []
        var i = 0
        while i < length:
            result.push(expanded.get(i))
            i = i + 1
        Ok(result)

# =============================================================================
# HKDF-RIPEMD-160 Combined (Extract + Expand)
# =============================================================================

fn hkdf_ripemd160(salt: list, ikm: list, info: list, length: i64) -> Result<list, HkdfError>:
    val prk = hkdf_ripemd160_extract(salt, ikm)
    hkdf_ripemd160_expand(prk, info, length)
