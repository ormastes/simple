# AES round constants (Rcon) for key expansion
# Rcon[i] = [rc_i, 0, 0, 0] where rc_1=1, rc_i = 2*rc_{i-1} in GF(2^8)
val RCON: [u32] = [
    0x01000000, 0x02000000, 0x04000000, 0x08000000,
    0x10000000, 0x20000000, 0x40000000, 0x80000000,
    0x1b000000, 0x36000000
]

# ============================================================================
# Result Type for Decryption
# ============================================================================

enum AesGcmResult:
    Ok(data: [u8])
    Err(msg: text)

# ============================================================================
# AES-256 Core Helpers
# ============================================================================

fn _sub_word(w: u32) -> u32:
    """Apply S-box to each byte of a 32-bit word."""
    val b0 = SBOX[((w >> 24) & 0xFF).to_u64()]
    val b1 = SBOX[((w >> 16) & 0xFF).to_u64()]
    val b2 = SBOX[((w >> 8) & 0xFF).to_u64()]
    val b3 = SBOX[(w & 0xFF).to_u64()]
    (b0.to_u32() << 24) | (b1.to_u32() << 16) | (b2.to_u32() << 8) | b3.to_u32()

fn _rot_word(w: u32) -> u32:
    """Rotate word left by 8 bits: [a0,a1,a2,a3] -> [a1,a2,a3,a0]."""
    ((w << 8) | (w >> 24)) & 0xFFFFFFFF

# ============================================================================
# AES-256 Key Expansion (FIPS 197, Section 5.2)
# ============================================================================

fn aes256_key_expansion(key: [u8]) -> [u32]:
    """Expand 32-byte AES-256 key into 60 round key words (240 bytes).

    AES-256 has Nk=8 (key words), Nr=14 (rounds), Nb=4 (block words).
    Total expanded key: 4 * (Nr + 1) = 60 words.
    """
    val nk: u64 = 8
    val nr: u64 = 14
    val total_words: u64 = 4 * (nr + 1)  # 60

    var w: [u32] = []

    # First Nk words come directly from the key
    var i: u64 = 0
    while i < nk:
        val base = i * 4
        val word = (key[base].to_u32() << 24) |
                   (key[base + 1].to_u32() << 16) |
                   (key[base + 2].to_u32() << 8) |
                   key[base + 3].to_u32()
        w.push(word)
        i = i + 1

    # Generate remaining words
    while i < total_words:
        var temp = w[i - 1]
        if (i % nk) == 0:
            temp = _sub_word(_rot_word(temp)) ^ RCON[(i / nk) - 1]
        elif (i % nk) == 4:
            temp = _sub_word(temp)
        w.push(w[i - nk] ^ temp)
        i = i + 1

    w

# ============================================================================
# AES State Operations (4x4 byte matrix, column-major)
# ============================================================================
#
# State is represented as [u8] of length 16.
# state[r + 4*c] = byte at row r, column c.

fn _sub_bytes(state: [u8]) -> [u8]:
    """Apply S-box substitution to each byte."""
    var result: [u8] = []
    var i: u64 = 0
    while i < 16:
        result.push(SBOX[state[i].to_u64()])
        i = i + 1
    result

fn _shift_rows(state: [u8]) -> [u8]:
    """Cyclically shift rows.

    Row 0: no shift
    Row 1: shift left 1
    Row 2: shift left 2
    Row 3: shift left 3
    """
    var r: [u8] = []
    var i: u64 = 0
    while i < 16:
        r.push(0x00)
        i = i + 1

    # Row 0: no shift
    r[0] = state[0]
    r[4] = state[4]
    r[8] = state[8]
    r[12] = state[12]

    # Row 1: shift left 1
    r[1] = state[5]
    r[5] = state[9]
    r[9] = state[13]
    r[13] = state[1]

    # Row 2: shift left 2
    r[2] = state[10]
    r[6] = state[14]
    r[10] = state[2]
    r[14] = state[6]

    # Row 3: shift left 3
    r[3] = state[15]
    r[7] = state[3]
    r[11] = state[7]
    r[15] = state[11]

    r

fn _xtime(b: u8) -> u8:
    """Multiply by x (0x02) in GF(2^8) with reduction polynomial 0x1b."""
    val shifted = (b.to_u32() << 1) & 0xFF
    if (b & 0x80) != 0:
        (shifted ^ 0x1b).to_u8()
    else:
        shifted.to_u8()

fn _gf_mul(a: u8, b: u8) -> u8:
    """Multiply two bytes in GF(2^8)."""
    var result: u8 = 0x00
    var aa = a
    var bb = b
    var i: u64 = 0
    while i < 8:
        if (bb & 0x01) != 0:
            result = result ^ aa
        aa = _xtime(aa)
        bb = (bb >> 1).to_u8()
        i = i + 1
    result

fn _mix_columns(state: [u8]) -> [u8]:
    """Mix columns using GF(2^8) matrix multiplication.

    Each column is multiplied by the fixed polynomial:
    [2, 3, 1, 1]
    [1, 2, 3, 1]
    [1, 1, 2, 3]
    [3, 1, 1, 2]
    """
    var r: [u8] = []
    var i: u64 = 0
    while i < 16:
        r.push(0x00)
        i = i + 1

    var c: u64 = 0
    while c < 4:
        val base = c * 4
        val s0 = state[base]
        val s1 = state[base + 1]
        val s2 = state[base + 2]
        val s3 = state[base + 3]

        r[base]     = _gf_mul(0x02, s0) ^ _gf_mul(0x03, s1) ^ s2 ^ s3
        r[base + 1] = s0 ^ _gf_mul(0x02, s1) ^ _gf_mul(0x03, s2) ^ s3
        r[base + 2] = s0 ^ s1 ^ _gf_mul(0x02, s2) ^ _gf_mul(0x03, s3)
        r[base + 3] = _gf_mul(0x03, s0) ^ s1 ^ s2 ^ _gf_mul(0x02, s3)

        c = c + 1
    r

fn _add_round_key(state: [u8], round_keys: [u32], round: u64) -> [u8]:
    """XOR state with round key (4 words starting at round * 4)."""
    var result: [u8] = []
    var c: u64 = 0
    while c < 4:
        val rk = round_keys[round * 4 + c]
        val base = c * 4
        result.push((state[base] ^ ((rk >> 24) & 0xFF).to_u8()))
        result.push((state[base + 1] ^ ((rk >> 16) & 0xFF).to_u8()))
        result.push((state[base + 2] ^ ((rk >> 8) & 0xFF).to_u8()))
        result.push((state[base + 3] ^ (rk & 0xFF).to_u8()))
        c = c + 1
    result

# ============================================================================
# AES-256 Encryption (single block)
# ============================================================================

fn aes256_encrypt_block(plaintext: [u8], round_keys: [u32]) -> [u8]:
    """Encrypt one 16-byte block with AES-256.

    Args:
        plaintext: 16 bytes of plaintext.
        round_keys: 60 expanded key words from aes256_key_expansion.

    Returns: 16 bytes of ciphertext.
    """
    val nr: u64 = 14

    # Convert plaintext to column-major state
    var state: [u8] = []
    var c: u64 = 0
    while c < 4:
        var r: u64 = 0
        while r < 4:
            state.push(plaintext[r + c * 4])
            r = r + 1
        c = c + 1

    # Initial round key addition
    state = _add_round_key(state, round_keys, 0)

    # Rounds 1 through Nr-1
    var round: u64 = 1
    while round < nr:
        state = _sub_bytes(state)
        state = _shift_rows(state)
        state = _mix_columns(state)
        state = _add_round_key(state, round_keys, round)
        round = round + 1

    # Final round (no MixColumns)
    state = _sub_bytes(state)
    state = _shift_rows(state)
    state = _add_round_key(state, round_keys, nr)

    # Convert column-major state back to row-major output
    var output: [u8] = []
    c = 0
    while c < 4:
        var r2: u64 = 0
        while r2 < 4:
            output.push(state[r2 + c * 4])
            r2 = r2 + 1
        c = c + 1

    output

# ============================================================================
# GF(2^128) Multiplication for GHASH
# ============================================================================

fn gf128_mul(x: [u8], y: [u8]) -> [u8]:
    """Multiply two 128-bit elements in GF(2^128).

    Uses the polynomial x^128 + x^7 + x^2 + x + 1 (R = 0xE1000000...).
    Bit-by-bit multiplication with reduction.

    Args:
        x: 16-byte element.
        y: 16-byte element.

    Returns: 16-byte product.
    """
    # Initialize Z = 0 (16 bytes)
    var z: [u8] = []
    var i: u64 = 0
    while i < 16:
        z.push(0x00)
        i = i + 1

    # V = Y (working copy)
    var v: [u8] = []
    i = 0
    while i < 16:
        v.push(y[i])
        i = i + 1

    # For each bit of X (MSB first, 128 bits)
    i = 0
    while i < 128:
        val byte_idx = i / 8
        val bit_idx = 7 - (i % 8)

        # If bit i of X is set, Z = Z XOR V
        if ((x[byte_idx] >> bit_idx) & 0x01) != 0:
            var j: u64 = 0
            while j < 16:
                z[j] = z[j] ^ v[j]
                j = j + 1

        # Check if LSB of V is set (for reduction)
        val lsb = v[15] & 0x01

        # Right-shift V by 1 bit
        var j: u64 = 15
        while j > 0:
            v[j] = (((v[j].to_u32() >> 1) | ((v[j - 1].to_u32() & 0x01) << 7)) & 0xFF).to_u8()
            j = j - 1
        v[0] = (v[0].to_u32() >> 1).to_u8()

        # If LSB was set, XOR with R (0xE1 in first byte)
        if lsb != 0:
            v[0] = v[0] ^ 0xE1

        i = i + 1

    z

# ============================================================================
# GHASH
# ============================================================================

fn _ghash_block(h: [u8], y: [u8], x_block: [u8]) -> [u8]:
    """Process one 16-byte block for GHASH: Y_i = (Y_{i-1} XOR X_i) * H."""
    var xored: [u8] = []
    var i: u64 = 0
    while i < 16:
        xored.push(y[i] ^ x_block[i])
        i = i + 1
    gf128_mul(xored, h)

fn _pad_to_16(data: [u8]) -> [u8]:
    """Pad data to a multiple of 16 bytes with zeros."""
    var result: [u8] = []
    var i: u64 = 0
    while i < data.len():
        result.push(data[i])
        i = i + 1
    while (result.len() % 16) != 0:
        result.push(0x00)
    result

fn ghash(h: [u8], aad: [u8], ciphertext: [u8]) -> [u8]:
    """Compute GHASH for GCM.

    GHASH_H(A, C) processes: pad(A) || pad(C) || len(A) || len(C)

    Args:
        h: 16-byte hash subkey (AES_K(0^128)).
        aad: Additional authenticated data.
        ciphertext: Ciphertext bytes.

    Returns: 16-byte GHASH tag.
    """
    # Initialize Y = 0
    var y: [u8] = []
    var i: u64 = 0
    while i < 16:
        y.push(0x00)
        i = i + 1

    # Process padded AAD blocks
    val padded_aad = _pad_to_16(aad)
    i = 0
    while i < padded_aad.len():
        var block: [u8] = []
        var j: u64 = 0
        while j < 16:
            block.push(padded_aad[i + j])
            j = j + 1
        y = _ghash_block(h, y, block)
        i = i + 16

    # Process padded ciphertext blocks
    val padded_ct = _pad_to_16(ciphertext)
    i = 0
    while i < padded_ct.len():
        var block: [u8] = []
        var j: u64 = 0
        while j < 16:
            block.push(padded_ct[i + j])
            j = j + 1
        y = _ghash_block(h, y, block)
        i = i + 16

    # Final block: len(A) || len(C) in bits, each as 64-bit big-endian
    val aad_bits: u64 = aad.len() * 8
    val ct_bits: u64 = ciphertext.len() * 8

    var len_block: [u8] = []
    len_block.push(((aad_bits >> 56) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 48) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 40) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 32) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 24) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 16) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 8) & 0xFF).to_u8())
    len_block.push((aad_bits & 0xFF).to_u8())
    len_block.push(((ct_bits >> 56) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 48) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 40) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 32) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 24) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 16) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 8) & 0xFF).to_u8())
    len_block.push((ct_bits & 0xFF).to_u8())

    y = _ghash_block(h, y, len_block)
    y

# ============================================================================
# GCTR — AES-CTR with Incrementing Counter
# ============================================================================

fn _inc32(counter: [u8]) -> [u8]:
    """Increment the rightmost 32 bits of a 16-byte counter block."""
    var result: [u8] = []
    var i: u64 = 0
    while i < 16:
        result.push(counter[i])
        i = i + 1

    # Increment the last 4 bytes as a 32-bit big-endian integer
    val c = (result[12].to_u32() << 24) |
            (result[13].to_u32() << 16) |
            (result[14].to_u32() << 8) |
            result[15].to_u32()
    val c_inc = (c + 1) & 0xFFFFFFFF
    result[12] = ((c_inc >> 24) & 0xFF).to_u8()
    result[13] = ((c_inc >> 16) & 0xFF).to_u8()
    result[14] = ((c_inc >> 8) & 0xFF).to_u8()
    result[15] = (c_inc & 0xFF).to_u8()
    result

fn gctr(round_keys: [u32], icb: [u8], input: [u8]) -> [u8]:
    """AES-CTR mode encryption/decryption.

    Encrypts each block by XORing with AES(key, counter), then increments counter.

    Args:
        round_keys: Expanded AES-256 key (60 words).
        icb: Initial counter block (16 bytes).
        input: Plaintext or ciphertext bytes.

    Returns: Output bytes (same length as input).
    """
    if input.len() == 0:
        return []

    var output: [u8] = []
    var cb = icb
    val num_full_blocks = input.len() / 16

    # Process full 16-byte blocks
    var i: u64 = 0
    while i < num_full_blocks:
        val enc_cb = aes256_encrypt_block(cb, round_keys)
        val offset = i * 16
        var j: u64 = 0
        while j < 16:
            output.push(input[offset + j] ^ enc_cb[j])
            j = j + 1
        cb = _inc32(cb)
        i = i + 1

    # Process partial last block
    val remaining = input.len() % 16
    if remaining > 0:
        val enc_cb = aes256_encrypt_block(cb, round_keys)
        val offset = num_full_blocks * 16
        var j: u64 = 0
        while j < remaining:
            output.push(input[offset + j] ^ enc_cb[j])
            j = j + 1

    output

# ============================================================================
# AES-256-GCM Encryption
# ============================================================================

fn _make_j0(nonce: [u8]) -> [u8]:
    """Construct J0 (initial counter block) from 12-byte nonce.

    For 96-bit nonces: J0 = nonce || 0x00000001.
    """
    var j0: [u8] = []
    var i: u64 = 0
    while i < 12:
        j0.push(nonce[i])
        i = i + 1
    # Append 32-bit counter = 1
    j0.push(0x00)
    j0.push(0x00)
    j0.push(0x00)
    j0.push(0x01)
    j0

fn aes256_gcm_encrypt(key: [u8], nonce: [u8], plaintext: [u8], aad: [u8]) -> [u8]:
    """AES-256-GCM authenticated encryption.

    Args:
        key: 32-byte AES-256 key.
        nonce: 12-byte nonce (IV).
        plaintext: Data to encrypt.
        aad: Additional authenticated data (not encrypted, but authenticated).

    Returns: ciphertext || 16-byte authentication tag (concatenated).
        The last 16 bytes of the result are the tag.
    """
    val round_keys = aes256_key_expansion(key)

    # Compute hash subkey H = AES_K(0^128)
    var zero_block: [u8] = []
    var i: u64 = 0
    while i < 16:
        zero_block.push(0x00)
        i = i + 1
    val h = aes256_encrypt_block(zero_block, round_keys)

    # Construct J0 from nonce
    val j0 = _make_j0(nonce)

    # Encrypt plaintext: C = GCTR_K(inc32(J0), P)
    val icb = _inc32(j0)
    val ciphertext = gctr(round_keys, icb, plaintext)

    # Compute GHASH over AAD and ciphertext
    val s = ghash(h, aad, ciphertext)

    # Compute tag: T = MSBt(GCTR_K(J0, S))
    val tag = gctr(round_keys, j0, s)

    # Return ciphertext || tag
    var result: [u8] = []
    i = 0
    while i < ciphertext.len():
        result.push(ciphertext[i])
        i = i + 1
    i = 0
    while i < 16:
        result.push(tag[i])
        i = i + 1
    result

# ============================================================================
# AES-256-GCM Decryption
# ============================================================================

fn aes256_gcm_decrypt(key: [u8], nonce: [u8], ciphertext: [u8], aad: [u8], tag: [u8]) -> AesGcmResult:
    """AES-256-GCM authenticated decryption.

    Args:
        key: 32-byte AES-256 key.
        nonce: 12-byte nonce (IV).
        ciphertext: Encrypted data (without tag).
        aad: Additional authenticated data.
        tag: 16-byte authentication tag to verify.

    Returns: AesGcmResult.Ok with plaintext on success,
             AesGcmResult.Err on tag mismatch.
    """
    val round_keys = aes256_key_expansion(key)

    # Compute hash subkey H = AES_K(0^128)
    var zero_block: [u8] = []
    var i: u64 = 0
    while i < 16:
        zero_block.push(0x00)
        i = i + 1
    val h = aes256_encrypt_block(zero_block, round_keys)

    # Construct J0 from nonce
    val j0 = _make_j0(nonce)

    # Compute GHASH over AAD and ciphertext
    val s = ghash(h, aad, ciphertext)

    # Compute expected tag: T' = MSBt(GCTR_K(J0, S))
    val expected_tag = gctr(round_keys, j0, s)

    # Constant-time tag comparison
    var diff: u8 = 0x00
    i = 0
    while i < 16:
        diff = diff | (expected_tag[i] ^ tag[i])
        i = i + 1

    if diff != 0:
        return AesGcmResult.Err("authentication tag mismatch")

    # Decrypt: P = GCTR_K(inc32(J0), C)
    val icb = _inc32(j0)
    val plaintext = gctr(round_keys, icb, ciphertext)

    AesGcmResult.Ok(data: plaintext)
