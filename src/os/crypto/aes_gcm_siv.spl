    t.push(0x70) ; t.push(0x3e) ; t.push(0xb5) ; t.push(0x66)
    t.push(0x48) ; t.push(0x03) ; t.push(0xf6) ; t.push(0x0e)
    t.push(0x61) ; t.push(0x35) ; t.push(0x57) ; t.push(0xb9)
    t.push(0x86) ; t.push(0xc1) ; t.push(0x1d) ; t.push(0x9e)
