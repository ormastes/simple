# ECDH on NIST P-256 (secp256r1) — pure-Simple
#
# Provides scalar multiplication on the SEC1 short-Weierstrass curve
#     y^2 = x^3 - 3x + b   (mod p)
# over GF(p) with `p = 2^256 - 2^224 + 2^192 + 2^96 - 1`.
#
# Public surface (TLS 1.3 §4.2.8 secp256r1 key_share builder needs only the
# base-point multiplication path; the arbitrary-point path is provided for
# the deferred ECDHE shared-secret derivation):
#
#   p256_keypair_pub(scalar)         -> 65-byte uncompressed pubkey 04||X||Y
#   p256_ecdh_shared_x(scalar, peer) -> 32-byte shared X (deferred wiring)
#
# Algorithm: Jacobian (X:Y:Z) coordinates with affine-mixed point addition;
# 256-bit MSB-first double-and-add scalar loop. The `b` curve constant for
# P-256 is the standard SEC2 / FIPS 186-4 value:
#   b = 5AC635D8AA3A93E7 B3EBBD55769886BC 651D06B0CC53B0F6 3BCE3C3E27D2604B
#
# Generator G (SEC2):
#   Gx = 6B17D1F2E12C4247 F8BCE6E563A440F2 77037D812DEB33A0 F4A13945D898C296
#   Gy = 4FE342E2FE1A7F9B 8EE7EB4A7C0F9E16 2BCE33576B315ECE CBB6406837BF51F5
#
# Side-channel posture: scalar-bit code path is constant-time as of 2026-05-01.
# `_scalar_mul_affine` now uses an always-add-and-select inner loop with the
# `p256_point_cselect` XOR-mask helper (mirrors `ed_point_cselect` in
# `ed25519.spl` and `fe_cond_select` in `fe_p256.spl`). Both `_jac_double` and
# `_jac_add_mixed` fire on every bit; a constant-time mask chooses whether to
# keep the added candidate. There is no branch on a scalar bit.
#
# Residual non-CT branches still tracked under the same FR (items #2/#3):
#   * `_jac_add_mixed` short-circuits on `p.inf` and on the equal-points case
#     (`fe_eq(p.x,u2)` / `fe_eq(p.y,s2)`).
#   * `_jac_double`/`_to_affine` short-circuit on `p.inf`.
# These are intermediate-point branches, not scalar-bit branches; they are
# not attacker-observable through the scalar's Hamming weight on the typical
# secret-scalar trajectory but should still land before broad ECDHE exposure.
# See:
#   doc/08_tracking/feature_request/p256_scalar_mult_constant_time_2026-05-01.md
#
# References:
#   * SEC2 v2.0 §2.4.2 (P-256 parameters)
#   * Cohen, Miyaji, Ono, "Efficient Elliptic Curve Exponentiation Using
#     Mixed Coordinates" (1998) — Jacobian add/double formulae used here.
#   * RFC 8446 §4.2.8.2 + RFC 8422 §5.4 (uncompressed point format).

use std.common.math.field.fe_p256.{
    FeP256,
    fe_zero, fe_one,
    fe_add, fe_sub,
    fe_mul, fe_sq, fe_inv,
    fe_from_bytes, fe_to_bytes,
    fe_eq
}

# ============================================================================
# Curve constants
# ============================================================================

fn _gx() -> FeP256:
    fe_from_bytes([
        0x6Bu8, 0x17u8, 0xD1u8, 0xF2u8, 0xE1u8, 0x2Cu8, 0x42u8, 0x47u8,
        0xF8u8, 0xBCu8, 0xE6u8, 0xE5u8, 0x63u8, 0xA4u8, 0x40u8, 0xF2u8,
        0x77u8, 0x03u8, 0x7Du8, 0x81u8, 0x2Du8, 0xEBu8, 0x33u8, 0xA0u8,
        0xF4u8, 0xA1u8, 0x39u8, 0x45u8, 0xD8u8, 0x98u8, 0xC2u8, 0x96u8
    ])

fn _gy() -> FeP256:
    fe_from_bytes([
        0x4Fu8, 0xE3u8, 0x42u8, 0xE2u8, 0xFEu8, 0x1Au8, 0x7Fu8, 0x9Bu8,
        0x8Eu8, 0xE7u8, 0xEBu8, 0x4Au8, 0x7Cu8, 0x0Fu8, 0x9Eu8, 0x16u8,
        0x2Bu8, 0xCEu8, 0x33u8, 0x57u8, 0x6Bu8, 0x31u8, 0x5Eu8, 0xCEu8,
        0xCBu8, 0xB6u8, 0x40u8, 0x68u8, 0x37u8, 0xBFu8, 0x51u8, 0xF5u8
    ])

# ============================================================================
# Jacobian point: (X, Y, Z). Affine = (X/Z^2, Y/Z^3). Z=0 is the
# point-at-infinity (we use a sentinel struct field).
# ============================================================================

struct JacP256:
    x: FeP256
    y: FeP256
    z: FeP256
    inf: bool

fn _jac_inf() -> JacP256:
    JacP256(x: fe_zero(), y: fe_one(), z: fe_zero(), inf: true)

fn _jac_from_affine(ax: FeP256, ay: FeP256) -> JacP256:
    JacP256(x: ax, y: ay, z: fe_one(), inf: false)

# ============================================================================
# Jacobian point doubling — Cohen 1998 §3 (a = -3 short Weierstrass).
# Cost: 4M + 4S; uses the a=-3 trick:
#   M = 3*(X1-Z1^2)*(X1+Z1^2) = 3*X1^2 - 3*Z1^4
# ============================================================================

fn _jac_double(p: JacP256) -> JacP256:
    if p.inf:
        return _jac_inf()
    val zz = fe_sq(p.z)         # Z1^2
    val xz = fe_sub(p.x, zz)    # X1 - Z1^2
    val xpz = fe_add(p.x, zz)   # X1 + Z1^2
    val mraw = fe_mul(xz, xpz)  # (X1-Z1^2)(X1+Z1^2) = X1^2 - Z1^4
    val m = fe_add(fe_add(mraw, mraw), mraw)  # 3*(X1^2 - Z1^4) = 3X^2 - 3Z^4 (a=-3)

    val yy = fe_sq(p.y)         # Y1^2
    val xyy = fe_mul(p.x, yy)   # X1 * Y1^2
    val s = fe_add(xyy, xyy)
    val s2 = fe_add(s, s)       # S = 4*X1*Y1^2

    val m2 = fe_sq(m)
    val s2x2 = fe_add(s2, s2)   # 2S
    val x3 = fe_sub(m2, s2x2)   # X3 = M^2 - 2S

    val sxm = fe_sub(s2, x3)
    val msxm = fe_mul(m, sxm)
    val yyy = fe_sq(yy)
    val yyy8 = fe_add(fe_add(fe_add(yyy, yyy), fe_add(yyy, yyy)),
                      fe_add(fe_add(yyy, yyy), fe_add(yyy, yyy)))  # 8*Y1^4
    val y3 = fe_sub(msxm, yyy8)  # Y3 = M*(S - X3) - 8*Y1^4

    val yz = fe_mul(p.y, p.z)
    val z3 = fe_add(yz, yz)      # Z3 = 2*Y1*Z1

    JacP256(x: x3, y: y3, z: z3, inf: false)

# ============================================================================
# Jacobian + affine mixed addition — Cohen §4.3 (Z2 = 1).
# Cost: 8M + 3S.
# ============================================================================

fn _jac_add_mixed(p: JacP256, ax: FeP256, ay: FeP256) -> JacP256:
    if p.inf:
        return JacP256(x: ax, y: ay, z: fe_one(), inf: false)

    val z1z1 = fe_sq(p.z)            # Z1^2
    val u2 = fe_mul(ax, z1z1)        # U2 = X2 * Z1^2
    val z1z1z1 = fe_mul(z1z1, p.z)
    val s2 = fe_mul(ay, z1z1z1)      # S2 = Y2 * Z1^3

    if fe_eq(p.x, u2):
        if fe_eq(p.y, s2):
            return _jac_double(p)
        # P + (-P) = O
        return _jac_inf()

    val h = fe_sub(u2, p.x)          # H = U2 - X1
    val r = fe_sub(s2, p.y)          # r = S2 - Y1
    val hh = fe_sq(h)                # HH = H^2
    val hhh = fe_mul(hh, h)          # HHH = H^3
    val v = fe_mul(p.x, hh)          # V = X1 * HH

    val rr = fe_sq(r)
    val v2 = fe_add(v, v)
    val x3 = fe_sub(fe_sub(rr, hhh), v2)  # X3 = r^2 - HHH - 2V

    val vmx = fe_sub(v, x3)
    val rvmx = fe_mul(r, vmx)
    val y1hhh = fe_mul(p.y, hhh)
    val y3 = fe_sub(rvmx, y1hhh)     # Y3 = r*(V - X3) - Y1*HHH

    val z3 = fe_mul(p.z, h)          # Z3 = Z1 * H

    JacP256(x: x3, y: y3, z: z3, inf: false)

# ============================================================================
# Constant-time conditional Jacobian point select.
#
# Mirrors the XOR-mask discipline of `fe_cond_select` (in `fe_p256.spl`) and
# `ed_point_cselect` (in `ed25519.spl`). Returns `p1` when `choose_p1 == 1`,
# else `p0`. Same field operations execute regardless of the mask bit; no
# data-dependent branches.
#
# `inf` is a `bool`, so we convert to a `u64` (0/1), apply the same XOR-mask,
# and convert back. The B6 memory note applies: the compiler must NOT
# branch-fold these XOR/AND ops — they are arithmetic, not compares.
# ============================================================================

fn p256_point_cselect(p0: JacP256, p1: JacP256, choose_p1: u64) -> JacP256:
    """Constant-time point select: returns p1 if choose_p1=1, else p0.

    Uses the XOR-mask pattern from `fe_cond_select`:
        out = a ^ (mask & (a ^ b))
    where mask = 0 - choose_p1 (all-ones if 1, all-zeros if 0).
    """
    val mask: u64 = 0u64 - choose_p1
    val inf0_u: u64 = if p0.inf { 1u64 } else { 0u64 }
    val inf1_u: u64 = if p1.inf { 1u64 } else { 0u64 }
    val inf_out_u: u64 = inf0_u ^ (mask & (inf0_u ^ inf1_u))
    JacP256(
        x: FeP256(
            l0: p0.x.l0 ^ (mask & (p0.x.l0 ^ p1.x.l0)),
            l1: p0.x.l1 ^ (mask & (p0.x.l1 ^ p1.x.l1)),
            l2: p0.x.l2 ^ (mask & (p0.x.l2 ^ p1.x.l2)),
            l3: p0.x.l3 ^ (mask & (p0.x.l3 ^ p1.x.l3))
        ),
        y: FeP256(
            l0: p0.y.l0 ^ (mask & (p0.y.l0 ^ p1.y.l0)),
            l1: p0.y.l1 ^ (mask & (p0.y.l1 ^ p1.y.l1)),
            l2: p0.y.l2 ^ (mask & (p0.y.l2 ^ p1.y.l2)),
            l3: p0.y.l3 ^ (mask & (p0.y.l3 ^ p1.y.l3))
        ),
        z: FeP256(
            l0: p0.z.l0 ^ (mask & (p0.z.l0 ^ p1.z.l0)),
            l1: p0.z.l1 ^ (mask & (p0.z.l1 ^ p1.z.l1)),
            l2: p0.z.l2 ^ (mask & (p0.z.l2 ^ p1.z.l2)),
            l3: p0.z.l3 ^ (mask & (p0.z.l3 ^ p1.z.l3))
        ),
        inf: inf_out_u == 1u64
    )

# ============================================================================
# 256-bit MSB-first scalar mult on (ax, ay) — always-add-and-select.
#
# scalar: 32 bytes big-endian. Constant-time on the secret-scalar code path
# w.r.t. the scalar's Hamming weight: every bit fires both `_jac_double` and
# `_jac_add_mixed`, then a `p256_point_cselect` chooses between the doubled-
# only accumulator and the doubled-then-added accumulator. No data-dependent
# branch on scalar bits. (Lower-level `_jac_add_mixed`/`_jac_double`/
# `_to_affine` still carry the `if p.inf:`/`fe_eq` branches tracked under
# items #2/#3 of the same FR; that hardening is intentionally out of scope
# for this fix per the FR's Required Changes #1.)
# ============================================================================

fn _scalar_mul_affine(scalar: [u8], ax: FeP256, ay: FeP256) -> JacP256:
    var acc = _jac_inf()
    var i: u64 = 0
    while i < 32:
        val byte = scalar[i]
        var bit: u64 = 0
        while bit < 8:
            acc = _jac_double(acc)
            # MSB-first bit_set; data-independent shift on `bit`, not on `byte`.
            val bit_set: u64 = (byte.to_u64() >> (7u64 - bit)) & 1u64
            val candidate = _jac_add_mixed(acc, ax, ay)
            acc = p256_point_cselect(p0: acc, p1: candidate, choose_p1: bit_set)
            bit = bit + 1
        i = i + 1
    acc

# ============================================================================
# Affine projection: (X/Z^2, Y/Z^3). Returns (x, y) FeP256 pair.
# ============================================================================

fn _to_affine(p: JacP256) -> (FeP256, FeP256):
    if p.inf:
        return (fe_zero(), fe_zero())
    val zinv = fe_inv(p.z)
    val zinv2 = fe_sq(zinv)
    val zinv3 = fe_mul(zinv2, zinv)
    val ax = fe_mul(p.x, zinv2)
    val ay = fe_mul(p.y, zinv3)
    (ax, ay)

# ============================================================================
# Public API
# ============================================================================

fn p256_keypair_pub(scalar: [u8]) -> [u8]:
    """Compute the SEC1 uncompressed public key for a P-256 ephemeral.

    Args:
        scalar: 32 bytes big-endian secret. Caller MUST supply a value in
                [1, n-1] where n is the curve order; this routine does not
                validate the range (the M3 advertise-only scope drives only
                fixed test vectors).

    Returns: 65 bytes `04 || X || Y` per RFC 8446 §4.2.8.2 + RFC 8422 §5.4.
             Empty array if scalar.len() != 32.
    """
    if scalar.len() != 32:
        return []
    val jac = _scalar_mul_affine(scalar, _gx(), _gy())
    val (ax, ay) = _to_affine(jac)
    val x_bytes = fe_to_bytes(ax)
    val y_bytes = fe_to_bytes(ay)
    var out: [u8] = []
    out.push(0x04u8)
    var i: u64 = 0
    while i < 32:
        out.push(x_bytes[i])
        i = i + 1
    i = 0
    while i < 32:
        out.push(y_bytes[i])
        i = i + 1
    out

fn p256_ecdh_shared_x(scalar: [u8], peer_uncompressed: [u8]) -> [u8]:
    """Compute the X-coordinate of `scalar * peer_pubkey`.

    Args:
        scalar: 32 bytes big-endian secret.
        peer_uncompressed: 65 bytes `04 || X || Y` per RFC 8446 §4.2.8.2.

    Returns: 32 bytes big-endian shared-secret X. Empty on size errors.

    DEFERRED: this entry point is plumbed for the eventual ECDHE
    handshake-secret derivation but is NOT yet exercised by any TLS 1.3
    connect-flow caller. See `crypto_recovery_status.md` Wave-1 outcomes.
    """
    if scalar.len() != 32:
        return []
    if peer_uncompressed.len() != 65:
        return []
    if peer_uncompressed[0u64] != 0x04u8:
        return []
    var px_bytes: [u8] = []
    var py_bytes: [u8] = []
    var i: u64 = 0
    while i < 32:
        px_bytes.push(peer_uncompressed[1u64 + i])
        i = i + 1
    i = 0
    while i < 32:
        py_bytes.push(peer_uncompressed[33u64 + i])
        i = i + 1
    val px = fe_from_bytes(px_bytes)
    val py = fe_from_bytes(py_bytes)
    val jac = _scalar_mul_affine(scalar, px, py)
    val (ax, _ay) = _to_affine(jac)
    fe_to_bytes(ax)
