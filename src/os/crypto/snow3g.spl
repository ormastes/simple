#![allow(unnamed_duplicate_typed_args)]
# SNOW 3G Stream Cipher — Pure Simple Implementation
#
# Implements SNOW 3G stream cipher per 3GPP TS 35.216,
# plus UEA2 (confidentiality) per 3GPP TS 35.215
# and UIA2 (integrity MAC) per 3GPP TS 35.215.
#
# References:
#   3GPP TS 35.216 — SNOW 3G specification
#   3GPP TS 35.215 — UEA2 and UIA2 algorithms
#   3GPP TS 35.217 — UEA2 and UIA2 test data
#
# Architecture:
#   LFSR: 16 x 32-bit cells, feedback polynomial over GF(2^32)
#   FSM:  3 registers R1, R2, R3 (32-bit each)
#   S-box S_R: Rijndael / AES SubBytes (same as ZUC S0)
#   S-box S_Q: SNOW 3G-specific 8-bit substitution
#   MUL_alpha / DIV_alpha: GF(2^32) multiply/divide by alpha
#
# NOTE: verified in interpreter mode per
# .claude/memory/feedback_compile_mode_false_greens.md

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

# ============================================================================
# Internal helpers
# ============================================================================

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

fn _logical_shr32(x: u32, n: u32) -> u32:
    """Logical (zero-extending) right shift for u32."""
    val xu = x.to_u64()
    val nu = n.to_u64()
    val mask: u64 = (1u64 << (32u64 - nu)) - 1u64
    ((xu >> nu) & mask).to_u32()

fn _add32(a: u32, b: u32) -> u32:
    """32-bit addition mod 2^32."""
    ((a.to_u64() + b.to_u64()) & 0xFFFFFFFFu64).to_u32()

fn _make32(b0: u8, b1: u8, b2: u8, b3: u8) -> u32:
    """Pack 4 bytes big-endian into u32."""
    (b0.to_u32() << 24) | (b1.to_u32() << 16) | (b2.to_u32() << 8) | b3.to_u32()

fn _b0(x: u32) -> u8:
    ((x >> 24) & 0xFFu32).to_u8()

fn _b1(x: u32) -> u8:
    ((x >> 16) & 0xFFu32).to_u8()

fn _b2(x: u32) -> u8:
    ((x >> 8) & 0xFFu32).to_u8()

fn _b3(x: u32) -> u8:
    (x & 0xFFu32).to_u8()

# ============================================================================
# S_R — Rijndael / AES SubBytes (same as ZUC S0 / AES SubBytes FIPS 197)
# ============================================================================

