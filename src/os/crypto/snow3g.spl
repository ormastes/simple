# ============================================================================
# S_Q — SNOW 3G S-box (TS 35.216 §3.3, Table 1)
# ============================================================================

fn _sq(x: u8) -> u8:
    """SNOW 3G S_Q S-box."""
    val t = x.to_u64()
    if t == 0u64: 0x25u8
    else if t == 1u64: 0x24u8
