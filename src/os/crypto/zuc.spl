fn _s1(x: u8) -> u8:
    """ZUC S1 box — TS 35.221 Annex A, Table 2."""
    val t = x.to_u64()
    if t == 0u64:   0x55u8
    else if t == 1u64:   0xc2u8
    else if t == 2u64:   0x63u8
    else if t == 3u64:   0x71u8
