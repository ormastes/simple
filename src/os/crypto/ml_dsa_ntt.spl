        1182243, 87208, 636927, 4415111, 4423672, 6084020, 5095502, 4663471,
        8352605, 822541, 1009365, 5926272, 6400920, 1596822, 4423473, 4620952,
        6695264, 4969849, 2678278, 4611469, 4829411, 635956, 8129971, 5925040,
