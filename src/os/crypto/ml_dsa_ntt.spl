# =============================================================================
# ML-DSA-65 — Polynomial Arithmetic + NTT (FIPS 204 §F / Appendix B.1)
#
# Module-Lattice-Based Digital Signature Standard (NIST FIPS 204, August 2024).
# Counterpart to ML-KEM-768 (FIPS 203). This file provides the Z_q[X]/(X^256+1)
# ring arithmetic, the NTT machinery, and the Power2Round / Decompose / HighBits
# / LowBits / MakeHint / UseHint primitives that ML-DSA Sign/Verify build on.
#
# Parameter set: ML-DSA-65 (NIST security category 3)
#   n       = 256             — polynomial degree
#   q       = 8380417         — prime modulus  ( = 2^23 - 2^13 + 1 )
#   d       = 13              — bits dropped by Power2Round
#   tau     = 49              — Hamming weight of c
#   gamma1  = 2^19 = 524288   — masking range for y
#   gamma2  = (q-1)/32 = 261888— low-bits modulus
#   k       = 6               — rows of A (and t, t1, t0, w, ...)
#   l       = 5               — cols of A (and s1, y, z, ...)
#   eta     = 4               — secret-key coefficient bound
#   beta    = tau * eta = 196 — z-norm rejection bound (excluded)
#   omega   = 55              — max ones in hint h
#
# The NTT here uses zeta = 1753 (primitive 512-th root of unity mod q) with
# BitRev8 ordering of the zeta exponents, distinct from ML-KEM's ζ=17 / BitRev7.
# Pointwise multiplication in NTT domain is plain coefficient-wise (FIPS 204
# represents a poly in NTT as 256 elements; ML-KEM represents it as 128 pairs).
#
# Reference: NIST FIPS 204 — Module-Lattice-Based Digital Signature Standard,
#   https://csrc.nist.gov/pubs/fips/204/final
# Related:   src/os/crypto/ml_kem_ntt.spl (sibling KEM ring),
#            doc/08_tracking/crypto_recovery_status.md M5 (post-quantum).
# =============================================================================

mod os.crypto.ml_dsa_ntt

# -----------------------------------------------------------------------------
# Parameter accessors (FIPS 204 §4 Table 1, ML-DSA-65 row).
# -----------------------------------------------------------------------------

fn ml_dsa_n() -> i64:
    256

fn ml_dsa_q() -> i64:
    8380417

fn ml_dsa_d() -> i64:
    13

fn ml_dsa_tau_65() -> i64:
    49

fn ml_dsa_gamma1_65() -> i64:
    524288

fn ml_dsa_gamma2_65() -> i64:
    261888

fn ml_dsa_k_65() -> i64:
    6

fn ml_dsa_l_65() -> i64:
    5

fn ml_dsa_eta_65() -> i64:
    4

fn ml_dsa_beta_65() -> i64:
    196

fn ml_dsa_omega_65() -> i64:
    55

# -----------------------------------------------------------------------------
# Modular reduction helpers (Z_q with q = 8380417).
# Caller-side discipline keeps intermediates within ±2^53, so a centred
# `((x % q) + q) % q` is safe under i64 arithmetic.
# -----------------------------------------------------------------------------

fn modq(x: i64) -> i64:
    val q = ml_dsa_q()
    val r = x % q
    if r < 0:
        r + q
    else:
        r

# Centred representative in (-q/2, q/2]. Used by Decompose / norm checks.
fn modq_centered(x: i64) -> i64:
    val q = ml_dsa_q()
    val r = modq(x)
    if r > q / 2:
        r - q
    else:
        r

# Infinity-norm of a polynomial under centred reduction.
fn poly_infinity_norm(p: list) -> i64:
    var m = 0
    var i = 0
    while i < 256:
        val c = modq_centered(p.get(i))
        val a = if c < 0: -c else: c
        if a > m:
            m = a
        i = i + 1
    m

# -----------------------------------------------------------------------------
# Zeta table — primitive 512-th root of unity mod q (FIPS 204 §F / App B.1).
#
# zeta = 1753.  zetas[i] = zeta^(BitRev8(i)) mod q for i in 0..255.
# zetas[0] = 1 is unused (Algorithm 41 starts with k=0 and pre-increments k).
# Verified: zeta^256 mod q = q - 1 (i.e. -1), zetas[1] = 4808194 matches
# the FIPS 204 reference implementation Table 7.
# -----------------------------------------------------------------------------

fn _ntt_zetas() -> list:
    [
        1, 4808194, 3765607, 3761513, 5178923, 5496691, 5234739, 5178987,
        7778734, 3542485, 2682288, 2129892, 3764867, 7375178, 557458, 7159240,
        5010068, 4317364, 2663378, 6705802, 4855975, 7946292, 676590, 7044481,
        5152541, 1714295, 2453983, 1460718, 7737789, 4795319, 2815639, 2283733,
        3602218, 3182878, 2740543, 4793971, 5269599, 2101410, 3704823, 1159875,
        394148, 928749, 1095468, 4874037, 2071829, 4361428, 3241972, 2156050,
