# -----------------------------------------------------------------------------
# Forward NTT — FIPS 204 Algorithm 41 (NTT).
#
# Input:  f in Z_q^256 (coefficient domain).
# Output: f̂ in Z_q^256 (NTT domain — element-wise representation).
#
# The Cooley-Tukey decimation-in-time butterfly walks layers from len=128
# down to len=1, with k advancing 1..255 across the zetas table.
# -----------------------------------------------------------------------------

fn ntt(f_in: list) -> list:
    val q = ml_dsa_q()
    val zetas = _ntt_zetas()
    var f = []
    var i = 0
    while i < 256:
        f.push(f_in.get(i))
        i = i + 1

    var k = 0
    var len = 128
    while len >= 1:
        var start = 0
        while start < 256:
            k = k + 1
            val zeta = zetas.get(k)
            var j = start
            while j < start + len:
                val t = (zeta * f.get(j + len)) % q
                val fj = f.get(j)
                f[j + len] = modq(fj - t)
                f[j] = modq(fj + t)
                j = j + 1
            start = start + 2 * len
        len = len / 2
    f

# -----------------------------------------------------------------------------
# Inverse NTT — FIPS 204 Algorithm 42 (NTT⁻¹).
#
# Walks zetas in reverse (k = 256, decrementing) and finishes with the
# scaling factor f = 8347681 (= n^{-1} mod q for n=256 with negated zetas).
# Per FIPS 204, the inverse NTT also negates each zeta read.
# -----------------------------------------------------------------------------

fn intt(f_in: list) -> list:
    val q = ml_dsa_q()
    val zetas = _ntt_zetas()
    var f = []
    var i = 0
    while i < 256:
        f.push(f_in.get(i))
        i = i + 1

    var k = 256
    var len = 1
    while len <= 128:
        var start = 0
        while start < 256:
            k = k - 1
            # FIPS 204 Algorithm 42 line 7: zeta = -zetas[k]
            val zeta = q - zetas.get(k)
            var j = start
            while j < start + len:
                val t = f.get(j)
                val fjl = f.get(j + len)
                f[j] = modq(t + fjl)
                f[j + len] = modq((zeta * (t - fjl)) % q)
                j = j + 1
            start = start + 2 * len
        len = len * 2

    # Final scaling: multiply each coefficient by 256^{-1} mod q.
    # 256^{-1} mod 8380417 = 8347681.
    val n_inv = 8347681
    var idx = 0
    while idx < 256:
        f[idx] = (f.get(idx) * n_inv) % q
        idx = idx + 1
    f

# -----------------------------------------------------------------------------
# Pointwise multiplication in NTT domain — FIPS 204 Algorithm 45.
#
# In ML-DSA's NTT representation each polynomial is held as 256 separate
# Z_q elements; multiplication is straight coefficient-wise.
# -----------------------------------------------------------------------------

fn ntt_multiply(a: list, b: list) -> list:
    val q = ml_dsa_q()
    var c = []
    var i = 0
    while i < 256:
        c.push((a.get(i) * b.get(i)) % q)
        i = i + 1
    c

# -----------------------------------------------------------------------------
# Polynomial add / sub in coefficient or NTT domain.
# -----------------------------------------------------------------------------

fn poly_add(a: list, b: list) -> list:
    var c = []
    var i = 0
    while i < 256:
        c.push(modq(a.get(i) + b.get(i)))
        i = i + 1
    c

fn poly_sub(a: list, b: list) -> list:
    var c = []
    var i = 0
    while i < 256:
        c.push(modq(a.get(i) - b.get(i)))
        i = i + 1
    c

# Multiply every coefficient by a small scalar mod q.
fn poly_scalar_mul(p: list, s: i64) -> list:
    val q = ml_dsa_q()
    var c = []
    var i = 0
    while i < 256:
        c.push(modq((p.get(i) * s) % q))
        i = i + 1
    c

# -----------------------------------------------------------------------------
# Power2Round — FIPS 204 Algorithm 35.
#
# Splits r ∈ Z_q into (r1, r0) with r = r1 * 2^d + r0, r0 ∈ (-2^(d-1), 2^(d-1)],
# and r1 ∈ [0, 2^(23-d)). Returns tuple (r1, r0_centred).
# -----------------------------------------------------------------------------

fn power2round_int(r_in: i64) -> tuple:
    val q = ml_dsa_q()
    val d = ml_dsa_d()
    val r = modq(r_in)
    val pow_d = 8192            # 2^13
    val half  = 4096            # 2^(d-1)
    # r0 ∈ (-2^(d-1), 2^(d-1)]
    val low = r % pow_d
    var r0 = low
    if r0 > half:
        r0 = r0 - pow_d
    # r1 = (r - r0) / 2^d  (note: r is in [0,q); r - r0 is a multiple of 2^d)
    val r1 = (r - r0) / pow_d
    (r1, r0)

# Apply Power2Round to every coefficient. Returns tuple (r1_poly, r0_poly).
fn power2round_poly(r: list) -> tuple:
    var r1 = []
    var r0 = []
    var i = 0
    while i < 256:
        val pair = power2round_int(r.get(i))
        r1.push(pair[0])
        r0.push(pair[1])
        i = i + 1
    (r1, r0)

# -----------------------------------------------------------------------------
# Decompose — FIPS 204 Algorithm 36.
#
# Splits r ∈ Z_q into (r1, r0) with r ≡ r1 * 2γ2 + r0  (mod q),
# r0 ∈ (-γ2, γ2] except boundary case where r1 wraps to 0 and r0 is corrected.
# For ML-DSA-65: γ2 = (q-1)/32 = 261888, so 2γ2 divides q-1.
# -----------------------------------------------------------------------------

fn decompose_int(r_in: i64) -> tuple:
    val q = ml_dsa_q()
    val gamma2 = ml_dsa_gamma2_65()
    val two_g  = 2 * gamma2     # 523776
    val r = modq(r_in)
    val low = r % two_g
    var r0 = low
    if r0 > gamma2:
        r0 = r0 - two_g
    var r1 = (r - r0) / two_g
    # FIPS 204 §B.2 boundary: if r - r0 == q - 1 then r1 = 0, r0 = r0 - 1.
    if r - r0 == q - 1:
        r1 = 0
        r0 = r0 - 1
    (r1, r0)

fn decompose_poly(r: list) -> tuple:
    var r1 = []
    var r0 = []
    var i = 0
    while i < 256:
        val pair = decompose_int(r.get(i))
        r1.push(pair[0])
        r0.push(pair[1])
        i = i + 1
    (r1, r0)

# HighBits / LowBits — projections of Decompose (Algorithms 37 & 38).
fn high_bits_int(r: i64) -> i64:
    val pair = decompose_int(r)
    pair[0]

fn low_bits_int(r: i64) -> i64:
    val pair = decompose_int(r)
    pair[1]

fn high_bits_poly(r: list) -> list:
    val parts = decompose_poly(r)
    parts[0]

fn low_bits_poly(r: list) -> list:
    val parts = decompose_poly(r)
    parts[1]

# -----------------------------------------------------------------------------
# MakeHint / UseHint — FIPS 204 Algorithms 39 & 40.
#
# MakeHint(z, r):  returns 1 if HighBits(r) != HighBits(r + z), else 0.
# UseHint(h, r):   recovers the corrected high bits given hint bit h.
# -----------------------------------------------------------------------------

fn make_hint_int(z: i64, r: i64) -> i64:
    val a = high_bits_int(r)
    val b = high_bits_int(r + z)
    if a == b:
        0
    else:
        1

fn make_hint_poly(z: list, r: list) -> list:
    var h = []
    var i = 0
    while i < 256:
        h.push(make_hint_int(z.get(i), r.get(i)))
        i = i + 1
    h

# Cardinality m = (q-1)/(2γ2) = 16 for ML-DSA-65 → r1 ∈ [0, 16).
fn _hint_modulus_65() -> i64:
    val q = ml_dsa_q()
    val gamma2 = ml_dsa_gamma2_65()
    (q - 1) / (2 * gamma2)

fn use_hint_int(h: i64, r: i64) -> i64:
    val m = _hint_modulus_65()
    val parts = decompose_int(r)
    val r1 = parts[0]
    val r0 = parts[1]
    if h == 0:
        r1
    else:
        if r0 > 0:
            ((r1 + 1) % m + m) % m
        else:
            ((r1 - 1) % m + m) % m

fn use_hint_poly(h: list, r: list) -> list:
    var w1 = []
    var i = 0
    while i < 256:
        w1.push(use_hint_int(h.get(i), r.get(i)))
        i = i + 1
    w1
