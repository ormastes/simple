#![allow(unnamed_duplicate_typed_args)]
# OCB3 — Offset Codebook Mode v3 Authenticated Encryption
#
# AES-128-OCB3 per RFC 7253.  Provides authenticated encryption with
# associated data (AEAD): one-pass confidentiality + integrity.
#
# No SFFI/Rust FFI — pure Simple language, suitable for baremetal.
#
# Reference: RFC 7253 — The OCB Authenticated-Encryption Algorithm
#   §2  Notation and Conventions
#   §4  OCB Global Parameters and Key Setup
#   §5  Processing Associated Data: HASH
#   §6  OCB-ENCRYPT / OCB-DECRYPT
#
# Algorithm summary (128-bit tag, 96-bit nonce, AES-128):
#   L_* = ENCIPHER(K, 0^128)
#   L_$ = double(L_*)
#   L_i = double(L_{i-1})   for i >= 0
#   Offset_0 derived from nonce via ENCIPHER(K, top) with bottom-bit shift
#   For each block i: Offset_i = Offset_{i-1} XOR L_{ntz(i)}
#   C_i  = Offset_i XOR ENCIPHER(K, P_i XOR Offset_i)
#   Checksum = XOR of all P_i (plus partial last-block contribution)
#   Tag = ENCIPHER(K, Checksum XOR Offset_m XOR L_$) XOR HASH(K, A)
#   HASH(K, A): processes AAD blocks similarly with Offset and L values.

use os.crypto.aes128_gcm.{aes128_key_expansion, aes128_encrypt_block}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]
extern fn rt_aes_decrypt_block_with_expanded(block: [u8], expanded_key: [u8], num_rounds: i64) -> [u8]

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

# ============================================================================
# GF(2^128) doubling — multiply by x (left-shift with reduction)
# Polynomial: x^128 + x^7 + x^2 + x + 1
# If msb(V) == 0:  double(V) = V << 1
# If msb(V) == 1:  double(V) = (V << 1) XOR 0x00...0087
# ============================================================================

fn _ocb3_double(block: [u8]) -> [u8]:
    """GF(2^128) doubling (left shift with conditional XOR 0x87 on last byte)."""
    var out: [u8] = rt_array_new_with_cap(16)
    val msb = (_u8_at(block, 0).to_u32() >> 7) & 0x01
    var i: u64 = 0
    while i < 15:
        val cur = _u8_at(block, i).to_u32()
        val nxt = _u8_at(block, i + 1).to_u32()
        out.push(((cur << 1 | nxt >> 7) & 0xFF).to_u8())
        i = i + 1
    val last = ((_u8_at(block, 15).to_u32() << 1) & 0xFF).to_u8()
    if msb != 0:
        out.push((last.to_u32() ^ 0x87).to_u8())
    else:
        out.push(last)
    out

# ============================================================================
# XOR two 16-byte blocks
# ============================================================================

fn _xor16(a: [u8], b: [u8]) -> [u8]:
    var out: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        out.push(_u8_at(a, i) ^ _u8_at(b, i))
        i = i + 1
    out

# ============================================================================
# ntz — number of trailing zero bits in a positive integer
# ntz(1)=0, ntz(2)=1, ntz(3)=0, ntz(4)=2, ...
# ============================================================================

fn _ntz(n: u64) -> u64:
    if n == 0:
        return 64
    var v = n
    var count: u64 = 0
    while (v & 1) == 0:
        count = count + 1
        v = v >> 1
    count

# ============================================================================
# Build the L table: [L_*, L_$, L_0, L_1, ..., L_30]
# L_* = ENCIPHER(K, 0^128)
# L_$ = double(L_*)
# L_i = double(L_{i-1}) for i >= 0
# ============================================================================

fn _aes128_decrypt_block(block: [u8], round_keys: [u8]) -> [u8]:
    rt_aes_decrypt_block_with_expanded(block, round_keys, 10)

fn _ocb3_build_l_table(round_keys: [u8]) -> [[u8]]:
    """Returns [L_*, L_$, L_0, L_1, ..., L_30]."""
    var zero: [u8] = rt_array_new_with_cap(16)
    var zi: u64 = 0
    while zi < 16:
        zero.push(0x00)
        zi = zi + 1

    val l_star = aes128_encrypt_block(zero, round_keys)
    val l_dollar = _ocb3_double(l_star)

    var table: [[u8]] = []
    table.push(l_star)
    table.push(l_dollar)

    # L_0 .. L_30  (index 2 .. 32 in table)
    var prev = l_star
    var idx: u64 = 0
    while idx < 31:
        val next = _ocb3_double(prev)
        table.push(next)
        prev = next
        idx = idx + 1

    table

# Index into a [[u8]] table by iterating (Simple has no generic list indexer).
fn _table_get(table: [[u8]], idx: u64) -> [u8]:
    var i: u64 = 0
    for entry in table:
        if i == idx:
            return entry
        i = i + 1
    # Fallback — should not reach here.
    var fallback: [u8] = rt_array_new_with_cap(16)
    var j: u64 = 0
    while j < 16:
        fallback.push(0x00)
        j = j + 1
    fallback

# Retrieve L_{ntz(block_num)} from the table.
# Table layout: index 0 = L_*, index 1 = L_$, index 2+k = L_k.
fn _l_ntz(table: [[u8]], block_num: u64) -> [u8]:
    _table_get(table, _ntz(block_num) + 2)

# ============================================================================
# Nonce-to-Offset_0 derivation (RFC 7253 §4)
#
# For TAGLEN=128, nlen=12 (96-bit nonce):
#   128-bit Nonce value = 0x00000001 || N[0..11]
#   bottom = last 6 bits of Nonce128  (= last 6 bits of N[11])
#   top    = Nonce128 with last 6 bits zeroed
#   Ktop   = ENCIPHER(K, top)
#   Stretch = Ktop || (Ktop[0..7] XOR Ktop[1..8])  (24 bytes)
#   Offset_0 = Stretch[bottom .. bottom+127]  (bit-addressed window)
# ============================================================================

fn _ocb3_nonce_to_offset(round_keys: [u8], nonce: [u8]) -> [u8]:
    """Derive Offset_0 from key and 12-byte nonce per RFC 7253 §4."""
    # Build the 128-bit Nonce value: [0x00, 0x00, 0x00, 0x01, nonce[0..11]]
    var nonce128: [u8] = rt_array_new_with_cap(16)
    nonce128.push(0x00)
    nonce128.push(0x00)
    nonce128.push(0x00)
    nonce128.push(0x01)
    var ni: u64 = 0
    while ni < 12:
        nonce128.push(_u8_at(nonce, ni))
        ni = ni + 1

    # bottom = last 6 bits of nonce128[15]
    val bottom: u64 = (_u8_at(nonce128, 15).to_u32() & 0x3F).to_u64()

    # top = nonce128 with last 6 bits cleared
    var top: [u8] = rt_array_new_with_cap(16)
    var ti: u64 = 0
    while ti < 15:
        top.push(_u8_at(nonce128, ti))
        ti = ti + 1
    top.push((_u8_at(nonce128, 15).to_u32() & 0xC0).to_u8())

    # Ktop = ENCIPHER(K, top)
    val ktop = aes128_encrypt_block(top, round_keys)

    # Stretch = Ktop || (Ktop[0..7] XOR Ktop[1..8])  (24 bytes)
    var stretch: [u8] = rt_array_new_with_cap(24)
    var si: u64 = 0
    while si < 16:
        stretch.push(_u8_at(ktop, si))
        si = si + 1
    si = 0
    while si < 8:
        stretch.push(_u8_at(ktop, si) ^ _u8_at(ktop, si + 1))
        si = si + 1

    # Offset_0 = Stretch[bottom..bottom+127] (bit-addressed)
    val byte_shift: u64 = bottom >> 3
    val bit_shift: u32 = (bottom & 7).to_u32()

    var offset: [u8] = rt_array_new_with_cap(16)
    if bit_shift == 0:
        var oi: u64 = 0
        while oi < 16:
            offset.push(_u8_at(stretch, byte_shift + oi))
            oi = oi + 1
    else:
        val rshift: u32 = 8 - bit_shift
        var oi: u64 = 0
        while oi < 16:
            val cur = _u8_at(stretch, byte_shift + oi).to_u32()
            val nxt = _u8_at(stretch, byte_shift + oi + 1).to_u32()
            offset.push(((cur << bit_shift | nxt >> rshift) & 0xFF).to_u8())
            oi = oi + 1
    offset

# ============================================================================
# HASH(K, A) — process AAD (RFC 7253 §5)
# Returns a 16-byte sum used to blind the authentication tag.
# ============================================================================

fn _ocb3_hash(round_keys: [u8], aad: [u8], l_table: [[u8]]) -> [u8]:
    """Compute HASH(K, A) for OCB3.  Returns a 16-byte authentication offset."""
    var sum: [u8] = rt_array_new_with_cap(16)
    var si: u64 = 0
    while si < 16:
        sum.push(0x00)
        si = si + 1

    var offset_h: [u8] = rt_array_new_with_cap(16)
    var oi: u64 = 0
    while oi < 16:
        offset_h.push(0x00)
        oi = oi + 1

    val num_full = aad.len() / 16
    var i: u64 = 0
    while i < num_full:
        # Offset_i = Offset_{i-1} XOR L_{ntz(i+1)}
        offset_h = _xor16(offset_h, _l_ntz(l_table, i + 1))

        var blk: [u8] = rt_array_new_with_cap(16)
        var bi: u64 = 0
        while bi < 16:
            blk.push(_u8_at(aad, i * 16 + bi))
            bi = bi + 1

        sum = _xor16(sum, aes128_encrypt_block(_xor16(offset_h, blk), round_keys))
        i = i + 1

    # Process partial last block (if any)
    val rem = aad.len() % 16
    if rem > 0:
        # Offset_* = Offset_last XOR L_*
        offset_h = _xor16(offset_h, _table_get(l_table, 0))

        # Pad partial block with 1 || 0*
        var pad_blk: [u8] = rt_array_new_with_cap(16)
        var pi: u64 = 0
        while pi < rem:
            pad_blk.push(_u8_at(aad, num_full * 16 + pi))
            pi = pi + 1
        pad_blk.push(0x80)
        while pad_blk.len() < 16:
            pad_blk.push(0x00)

        sum = _xor16(sum, aes128_encrypt_block(_xor16(offset_h, pad_blk), round_keys))

    sum

# ============================================================================
# Public API
# ============================================================================

enum Ocb3Result:
    Ok(data: [u8])
    Err(msg: text)

fn ocb3_encrypt(key: [u8], nonce: [u8], aad: [u8], plaintext: [u8]) -> [u8]:
    """OCB3 authenticated encryption (AES-128, 128-bit tag).

    Args:
        key:       16-byte AES-128 key.
        nonce:     12-byte nonce (must be unique per key).
        aad:       Additional authenticated data (not encrypted).
        plaintext: Message to encrypt.

    Returns: ciphertext || 16-byte authentication tag (concatenated).
    """
    val round_keys = aes128_key_expansion(key)
    val l_table = _ocb3_build_l_table(round_keys)
    val l_dollar = _table_get(l_table, 1)

    var offset: [u8] = _ocb3_nonce_to_offset(round_keys, nonce)
    var checksum: [u8] = rt_array_new_with_cap(16)
    var ci: u64 = 0
    while ci < 16:
        checksum.push(0x00)
        ci = ci + 1

    val num_full = plaintext.len() / 16
    var out: [u8] = rt_array_new_with_cap(plaintext.len().to_i64())

    # Process full 16-byte plaintext blocks
    var i: u64 = 0
    while i < num_full:
        offset = _xor16(offset, _l_ntz(l_table, i + 1))

        var p_blk: [u8] = rt_array_new_with_cap(16)
        var bi: u64 = 0
        while bi < 16:
            p_blk.push(_u8_at(plaintext, i * 16 + bi))
            bi = bi + 1

        checksum = _xor16(checksum, p_blk)

        val c_blk = _xor16(offset, aes128_encrypt_block(_xor16(offset, p_blk), round_keys))
        bi = 0
        while bi < 16:
            out.push(_u8_at(c_blk, bi))
            bi = bi + 1
        i = i + 1

    # Process partial last block (if any)
    val rem = plaintext.len() % 16
    if rem > 0:
        # Offset_* = Offset_m XOR L_*
        offset = _xor16(offset, _table_get(l_table, 0))

        # Pad = ENCIPHER(K, Offset_*)
        val pad = aes128_encrypt_block(offset, round_keys)

        # C_last[0..rem] = P_last[0..rem] XOR Pad[0..rem]
        # Checksum XOR= P_last || 0x80 || 0*  (padded to 16 bytes)
        var p_last: [u8] = rt_array_new_with_cap(16)
        var pi: u64 = 0
        while pi < rem:
            val byte = _u8_at(plaintext, num_full * 16 + pi)
            p_last.push(byte)
            out.push(byte ^ _u8_at(pad, pi))
            pi = pi + 1
        p_last.push(0x80)
        while p_last.len() < 16:
            p_last.push(0x00)
        checksum = _xor16(checksum, p_last)

    # Tag = ENCIPHER(K, Checksum XOR Offset_* XOR L_$) XOR HASH(K, A)
    val tag_input = _xor16(_xor16(checksum, offset), l_dollar)
    val tag_base = aes128_encrypt_block(tag_input, round_keys)
    val hash_val = _ocb3_hash(round_keys, aad, l_table)
    val tag = _xor16(tag_base, hash_val)

    # Append 16-byte tag to ciphertext
    var ti: u64 = 0
    while ti < 16:
        out.push(_u8_at(tag, ti))
        ti = ti + 1

    out

fn ocb3_decrypt(key: [u8], nonce: [u8], aad: [u8], ciphertext_tag: [u8]) -> Ocb3Result:
    """OCB3 authenticated decryption (AES-128, 128-bit tag).

    Args:
        key:            16-byte AES-128 key.
        nonce:          12-byte nonce.
        aad:            Additional authenticated data.
        ciphertext_tag: ciphertext || 16-byte tag (last 16 bytes = tag).

    Returns: Ocb3Result.Ok(plaintext) on success,
             Ocb3Result.Err on authentication failure.

    Full-block decryption uses the AES inverse cipher via
    rt_aes_decrypt_block_with_expanded. Partial final blocks continue to use the
    RFC 7253 ENCIPHER(K, Offset_*) pad path.
    """
    if ciphertext_tag.len() < 16:
        return Ocb3Result.Err("input too short: missing tag")

    val ct_len = ciphertext_tag.len() - 16

    # Extract received tag (last 16 bytes)
    var tag_rcv: [u8] = rt_array_new_with_cap(16)
    var ti: u64 = 0
    while ti < 16:
        tag_rcv.push(_u8_at(ciphertext_tag, ct_len.to_u64() + ti))
        ti = ti + 1

    val round_keys = aes128_key_expansion(key)
    val l_table = _ocb3_build_l_table(round_keys)
    val l_dollar = _table_get(l_table, 1)

    var offset: [u8] = _ocb3_nonce_to_offset(round_keys, nonce)
    var checksum: [u8] = rt_array_new_with_cap(16)
    var ci: u64 = 0
    while ci < 16:
        checksum.push(0x00)
        ci = ci + 1

    val num_full = ct_len / 16
    var plaintext: [u8] = rt_array_new_with_cap(ct_len.to_i64())

    # Process full 16-byte ciphertext blocks:
    #   P_i = Offset_i XOR DECIPHER(K, C_i XOR Offset_i)
    var i: u64 = 0
    while i < num_full:
        offset = _xor16(offset, _l_ntz(l_table, i + 1))

        var c_blk: [u8] = rt_array_new_with_cap(16)
        var bi: u64 = 0
        while bi < 16:
            c_blk.push(_u8_at(ciphertext_tag, i * 16 + bi))
            bi = bi + 1

        val p_blk = _xor16(offset, _aes128_decrypt_block(_xor16(offset, c_blk), round_keys))
        checksum = _xor16(checksum, p_blk)
        bi = 0
        while bi < 16:
            plaintext.push(_u8_at(p_blk, bi))
            bi = bi + 1
        i = i + 1

    # Process partial last block (CTR-mode; uses ENCIPHER, correct)
    val rem = ct_len % 16
    if rem > 0:
        offset = _xor16(offset, _table_get(l_table, 0))

        val pad = aes128_encrypt_block(offset, round_keys)

        var p_last: [u8] = rt_array_new_with_cap(16)
        var pi: u64 = 0
        while pi < rem:
            val byte = _u8_at(ciphertext_tag, num_full * 16 + pi) ^ _u8_at(pad, pi)
            p_last.push(byte)
            plaintext.push(byte)
            pi = pi + 1
        p_last.push(0x80)
        while p_last.len() < 16:
            p_last.push(0x00)
        checksum = _xor16(checksum, p_last)

    # Recompute expected tag
    val tag_input = _xor16(_xor16(checksum, offset), l_dollar)
    val tag_base = aes128_encrypt_block(tag_input, round_keys)
    val hash_val = _ocb3_hash(round_keys, aad, l_table)
    val tag_exp = _xor16(tag_base, hash_val)

    # Constant-time tag comparison
    var diff: u8 = 0x00
    ti = 0
    while ti < 16:
        diff = diff | (_u8_at(tag_exp, ti) ^ _u8_at(tag_rcv, ti))
        ti = ti + 1

    if diff != 0:
        return Ocb3Result.Err("authentication tag mismatch")

    Ocb3Result.Ok(data: plaintext)
