#![allow(unnamed_duplicate_typed_args)]
# OCB3 — Offset Codebook Mode v3 Authenticated Encryption
#
# AES-128-OCB3 per RFC 7253.  Provides authenticated encryption with
# associated data (AEAD): one-pass confidentiality + integrity.
#
# No SFFI/Rust FFI — pure Simple language, suitable for baremetal.
#
# Reference: RFC 7253 — The OCB Authenticated-Encryption Algorithm
#   §2  Notation and Conventions
#   §4  OCB Global Parameters and Key Setup
#   §5  Processing Associated Data: HASH
#   §6  OCB-ENCRYPT / OCB-DECRYPT
#
# Algorithm summary (128-bit tag, 96-bit nonce, AES-128):
#   L_* = ENCIPHER(K, 0^128)
#   L_$ = double(L_*)
#   L_i = double(L_{i-1})   for i >= 0
#   Offset_0 derived from nonce via ENCIPHER(K, top XOR stretch) with bottom
#   For each block i: Offset_i = Offset_{i-1} XOR L_{ntz(i)}
#   C_i  = Offset_i XOR ENCIPHER(K, P_i XOR Offset_i)
#   Checksum = XOR of all P_i (plus partial last-block contribution)
#   Tag = ENCIPHER(K, Checksum XOR Offset_m XOR L_$) XOR HASH(K, A)
#   HASH(K, A): processes AAD blocks similarly with Offset and L values.

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]
extern fn rt_aes128_encrypt_block_pure(key: [u8], block: [u8]) -> [u8]

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

# ============================================================================
# GF(2^128) doubling — multiply by x (i.e., left-shift with reduction)
# Polynomial: x^128 + x^7 + x^2 + x + 1  (same as GCM's field)
# If msb == 0:  double(V) = V << 1
# If msb == 1:  double(V) = (V << 1) XOR 0x00000000...00000087
# ============================================================================

fn _ocb3_double(block: [u8]) -> [u8]:
    """GF(2^128) doubling (left shift with conditional XOR 0x87 on lsb)."""
    var out: [u8] = rt_array_new_with_cap(16)
    val msb = (_u8_at(block, 0) >> 7) & 0x01
    var i: u64 = 0
    while i < 15:
        val cur = _u8_at(block, i).to_u32()
        val nxt = _u8_at(block, i + 1).to_u32()
        out.push(((cur.shl(1) | nxt.shr(7)) & 0xFF).to_u8())
        i = i + 1
    val last = (_u8_at(block, 15).to_u32().shl(1) & 0xFF).to_u8()
    if msb != 0:
        out.push((last ^ 0x87).to_u8())
    else:
        out.push(last)
    out

# ============================================================================
# XOR two 16-byte blocks
# ============================================================================

fn _xor16(a: [u8], b: [u8]) -> [u8]:
    var out: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        out.push(_u8_at(a, i) ^ _u8_at(b, i))
        i = i + 1
    out

# ============================================================================
# ntz — number of trailing zero bits in a positive integer
# ntz(1)=0, ntz(2)=1, ntz(3)=0, ntz(4)=2, ...
# ============================================================================

fn _ntz(n: u64) -> u64:
    if n == 0:
        return 64
    var v = n
    var count: u64 = 0
    while (v & 1) == 0:
        count = count + 1
        v = v.shr(1)
    count

# ============================================================================
# Build the L table: L_* (index 0), L_$ (index 1), L_0..L_k (index 2+)
# We build enough L entries to cover all blocks (up to 64 levels of doubling
# are sufficient for any practical message size).
# ============================================================================

fn _ocb3_build_l_table(key: [u8]) -> [[u8]]:
    """Returns [L_*, L_$, L_0, L_1, ..., L_30]."""
    var zero: [u8] = rt_array_new_with_cap(16)
    var zi: u64 = 0
    while zi < 16:
        zero.push(0x00)
        zi = zi + 1

    val l_star = rt_aes128_encrypt_block_pure(key, zero)
    val l_dollar = _ocb3_double(l_star)

    var table: [[u8]] = []
    table.push(l_star)
    table.push(l_dollar)

    # L_0 .. L_30
    var prev = l_star
    var idx: u64 = 0
    while idx < 31:
        val next = _ocb3_double(prev)
        table.push(next)
        prev = next
        idx = idx + 1

    table

fn _l_at(table: [[u8]], i: u64) -> [u8]:
    """L_* = table[0], L_$ = table[1], L_0 = table[2], L_i = table[i+2]."""
    rt_bytes_u8_at(table, (i + 2).to_i64())  # placeholder — see below

# NOTE: Simple doesn't have generic index on [[u8]] via rt_bytes_u8_at.
# We use a helper that indexes into a flat list via iteration.
fn _table_get(table: [[u8]], idx: u64) -> [u8]:
    var i: u64 = 0
    for entry in table:
        if i == idx:
            return entry
        i = i + 1
    # Should not reach here; return zeros as fallback.
    var fallback: [u8] = rt_array_new_with_cap(16)
    var j: u64 = 0
    while j < 16:
        fallback.push(0x00)
        j = j + 1
    fallback

# ============================================================================
# Nonce-to-Offset_0 derivation (RFC 7253 §4)
#
# For 128-bit tag (TAGLEN=128), nonce must be < 128 bits. We fix nonce_len=12
# (96-bit nonce as [u8] of length 12), tag_len=128 bits (16 bytes).
#
# nonce_enc = (TAGLEN mod 128) || 0^(127-96-1) || 1 || nonce   (128-bit value)
#           = 0x00000000000000000000000000000001 XOR (00||nonce<<1)
# Actually per RFC 7253 §4:
#   Nonce = num2str(TAGLEN mod 128, 7) || zeros(128-7-nlen*8-1) || 1 || N
# For TAGLEN=128 mod 128 = 0, nlen=12:
#   Nonce = 0b0000000 || 0^(128-7-96-1) || 1 || N[96 bits]
#         = 0x00 00 00 00 01 || N[12 bytes]   (total 17 bytes truncated to 128 bits ... no)
# Let's follow the RFC exactly:
#   Nonce = num2str(128 mod 128, 7) || zeros(120 - nlen*8) || 1 || N
#   nlen=12, nlen*8=96. zeros(120-96)=zeros(24)=3 zero bytes
#   Nonce = 0x00 (7-bit 0, then 1 more bit) || 3 zero bytes || 0x01 || N[12]
# = 0x00000000 01 N[0]..N[11]  — that's 17 bytes, still wrong.
# RFC 7253 §4 actual text:
#   Nonce = num2str(TAGLEN mod 128, 7) || zeros(128-7-nlen*8-1) || 1 || N
#   For TAGLEN=128, 128 mod 128 = 0. num2str(0,7) = 7-bit zero = 0b0000000.
#   zeros(128 - 7 - 96 - 1) = zeros(24) = 3 bytes.
#   Full 128-bit value = 0b 0000000 000000000000000000000 1 <96-bit N>
#   = 0x00 00 00 00 | N (with leading 0x01 bit before N)
# In bytes: byte0=0x00, byte1=0x00, byte2=0x00, then 1 bit '1', then N[96-bit]
# Practical: the 128-bit Nonce value is:
#   bits 127..121 = 0 (7 bits)
#   bits 120..25  = 0 (96-? bits of zeros, then the separator 1 bit)
# Let's compute directly:
#   Nonce128 = (0 << 121) | (0 << 25) | (1 << 96) | nonce_as_int
# = 0x00000001 || N[0..11]
# So as 16 bytes: [0x00, 0x00, 0x00, 0x01, N[0], N[1], ..., N[11]]
#
# Then: top   = Nonce128 with bottom 6 bits cleared
#        bottom = last 6 bits of Nonce128
#        Ktop = ENCIPHER(K, top)
#        Stretch = Ktop || (Ktop[0..7] XOR Ktop[1..8])  (192 bits)
#        Offset_0 = Stretch[bottom .. bottom+127]
# ============================================================================

fn _ocb3_nonce_to_offset(key: [u8], nonce: [u8]) -> [u8]:
    """Derive Offset_0 from key and 12-byte nonce per RFC 7253 §4."""
    # Build the 128-bit Nonce value:
    # [0x00, 0x00, 0x00, 0x01, nonce[0..11]]
    var nonce128: [u8] = rt_array_new_with_cap(16)
    nonce128.push(0x00)
    nonce128.push(0x00)
    nonce128.push(0x00)
    nonce128.push(0x01)
    var ni: u64 = 0
    while ni < 12:
        nonce128.push(_u8_at(nonce, ni))
        ni = ni + 1

    # Extract bottom 6 bits (bit shift amount)
    val bottom: u64 = (_u8_at(nonce128, 15) & 0x3F).to_u64()

    # top = nonce128 with last 6 bits cleared
    var top: [u8] = rt_array_new_with_cap(16)
    var ti: u64 = 0
    while ti < 15:
        top.push(_u8_at(nonce128, ti))
        ti = ti + 1
    top.push(_u8_at(nonce128, 15) & 0xC0)

    # Ktop = ENCIPHER(K, top)
    val ktop = rt_aes128_encrypt_block_pure(key, top)

    # Stretch = Ktop || (Ktop[0..7] XOR Ktop[1..8])  (24 bytes)
    var stretch: [u8] = rt_array_new_with_cap(24)
    var si: u64 = 0
    while si < 16:
        stretch.push(_u8_at(ktop, si))
        si = si + 1
    si = 0
    while si < 8:
        stretch.push(_u8_at(ktop, si) ^ _u8_at(ktop, si + 1))
        si = si + 1

    # Offset_0 = Stretch[bottom .. bottom+128-1]  (bit addressing)
    # Compute as byte-shift + bit-shift within bytes.
    val byte_shift = bottom / 8
    val bit_shift = bottom % 8

    var offset: [u8] = rt_array_new_with_cap(16)
    if bit_shift == 0:
        var oi: u64 = 0
        while oi < 16:
            offset.push(_u8_at(stretch, byte_shift + oi))
            oi = oi + 1
    else:
        var oi: u64 = 0
        while oi < 16:
            val cur = _u8_at(stretch, byte_shift + oi).to_u32()
            val nxt = _u8_at(stretch, byte_shift + oi + 1).to_u32()
            offset.push(((cur.shl(bit_shift) | nxt.shr(8 - bit_shift)) & 0xFF).to_u8())
            oi = oi + 1
    offset

# ============================================================================
# HASH(K, A) — process AAD (RFC 7253 §5)
# ============================================================================

fn _ocb3_hash(key: [u8], aad: [u8], l_table: [[u8]]) -> [u8]:
    """Compute HASH(K, A) for OCB3.  Returns a 16-byte authentication offset."""
    var sum: [u8] = rt_array_new_with_cap(16)
    var si: u64 = 0
    while si < 16:
        sum.push(0x00)
        si = si + 1

    var offset_h: [u8] = rt_array_new_with_cap(16)
    var oi: u64 = 0
    while oi < 16:
        offset_h.push(0x00)
        oi = oi + 1

    val num_full = aad.len() / 16
    var i: u64 = 0
    while i < num_full:
        # Offset_i = Offset_{i-1} XOR L_{ntz(i+1)}
        val li = _table_get(l_table, _ntz(i + 1) + 2)
        offset_h = _xor16(offset_h, li)

        # Extract block A_i
        var blk: [u8] = rt_array_new_with_cap(16)
        var bi: u64 = 0
        while bi < 16:
            blk.push(_u8_at(aad, i * 16 + bi))
            bi = bi + 1

        sum = _xor16(sum, rt_aes128_encrypt_block_pure(key, _xor16(offset_h, blk)))
        i = i + 1

    # Process partial last block (if any)
    val rem = aad.len() % 16
    if rem > 0:
        # Offset_* = Offset_last XOR L_*
        val l_star = _table_get(l_table, 0)
        offset_h = _xor16(offset_h, l_star)

        # Pad partial block with 1 || 0*
        var pad_blk: [u8] = rt_array_new_with_cap(16)
        var pi: u64 = 0
        while pi < rem:
            pad_blk.push(_u8_at(aad, num_full * 16 + pi))
            pi = pi + 1
        pad_blk.push(0x80)
        while pad_blk.len() < 16:
            pad_blk.push(0x00)

        sum = _xor16(sum, rt_aes128_encrypt_block_pure(key, _xor16(offset_h, pad_blk)))

    sum

# ============================================================================
# Public API
# ============================================================================

enum Ocb3Result:
    Ok(data: [u8])
    Err(msg: text)

fn ocb3_encrypt(key: [u8], nonce: [u8], aad: [u8], plaintext: [u8]) -> [u8]:
    """OCB3 authenticated encryption (AES-128, 128-bit tag).

    Args:
        key:       16-byte AES-128 key.
        nonce:     12-byte nonce (must be unique per key).
        aad:       Additional authenticated data (not encrypted).
        plaintext: Message to encrypt.

    Returns: ciphertext || 16-byte authentication tag (concatenated).
    """
    val l_table = _ocb3_build_l_table(key)
    val l_dollar = _table_get(l_table, 1)

    var offset: [u8] = _ocb3_nonce_to_offset(key, nonce)
    var checksum: [u8] = rt_array_new_with_cap(16)
    var ci: u64 = 0
    while ci < 16:
        checksum.push(0x00)
        ci = ci + 1

    val num_full = plaintext.len() / 16
    var out: [u8] = rt_array_new_with_cap(plaintext.len().to_i64())

    # Process full blocks
    var i: u64 = 0
    while i < num_full:
        val li = _table_get(l_table, _ntz(i + 1) + 2)
        offset = _xor16(offset, li)

        var p_blk: [u8] = rt_array_new_with_cap(16)
        var bi: u64 = 0
        while bi < 16:
            p_blk.push(_u8_at(plaintext, i * 16 + bi))
            bi = bi + 1

        checksum = _xor16(checksum, p_blk)

        val c_blk = _xor16(offset, rt_aes128_encrypt_block_pure(key, _xor16(offset, p_blk)))
        bi = 0
        while bi < 16:
            out.push(_u8_at(c_blk, bi))
            bi = bi + 1
        i = i + 1

    # Process partial last block (if any)
    val rem = plaintext.len() % 16
    if rem > 0:
        # Offset_* = Offset_m XOR L_*
        val l_star = _table_get(l_table, 0)
        offset = _xor16(offset, l_star)

        # Pad = ENCIPHER(K, Offset_*)
        val pad = rt_aes128_encrypt_block_pure(key, offset)

        # C_last = P_last XOR Pad[0..rem]
        # Checksum update: pad P_last with 0x80 || 0* to 16 bytes
        var p_last: [u8] = rt_array_new_with_cap(16)
        var pi: u64 = 0
        while pi < rem:
            val byte = _u8_at(plaintext, num_full * 16 + pi)
            p_last.push(byte)
            out.push(byte ^ _u8_at(pad, pi))
            pi = pi + 1
        p_last.push(0x80)
        while p_last.len() < 16:
            p_last.push(0x00)
        checksum = _xor16(checksum, p_last)

    # Tag = ENCIPHER(K, Checksum XOR Offset_* XOR L_$) XOR HASH(K, A)
    val tag_input = _xor16(_xor16(checksum, offset), l_dollar)
    val tag_base = rt_aes128_encrypt_block_pure(key, tag_input)
    val hash_val = _ocb3_hash(key, aad, l_table)
    val tag = _xor16(tag_base, hash_val)

    # Append tag to ciphertext
    var ti: u64 = 0
    while ti < 16:
        out.push(_u8_at(tag, ti))
        ti = ti + 1

    out

fn ocb3_decrypt(key: [u8], nonce: [u8], aad: [u8], ciphertext_tag: [u8]) -> Ocb3Result:
    """OCB3 authenticated decryption (AES-128, 128-bit tag).

    Args:
        key:            16-byte AES-128 key.
        nonce:          12-byte nonce.
        aad:            Additional authenticated data.
        ciphertext_tag: ciphertext || 16-byte tag (last 16 bytes = tag).

    Returns: Ocb3Result.Ok(plaintext) on success,
             Ocb3Result.Err on authentication failure.
    """
    if ciphertext_tag.len() < 16:
        return Ocb3Result.Err("input too short: missing tag")

    val ct_len = ciphertext_tag.len() - 16

    # Extract tag
    var tag_rcv: [u8] = rt_array_new_with_cap(16)
    var ti: u64 = 0
    while ti < 16:
        tag_rcv.push(_u8_at(ciphertext_tag, ct_len.to_u64() + ti))
        ti = ti + 1

    val l_table = _ocb3_build_l_table(key)
    val l_dollar = _table_get(l_table, 1)

    var offset: [u8] = _ocb3_nonce_to_offset(key, nonce)
    var checksum: [u8] = rt_array_new_with_cap(16)
    var ci: u64 = 0
    while ci < 16:
        checksum.push(0x00)
        ci = ci + 1

    val num_full = ct_len / 16
    var plaintext: [u8] = rt_array_new_with_cap(ct_len.to_i64())

    # Process full blocks (decrypt)
    var i: u64 = 0
    while i < num_full:
        val li = _table_get(l_table, _ntz(i + 1) + 2)
        offset = _xor16(offset, li)

        var c_blk: [u8] = rt_array_new_with_cap(16)
        var bi: u64 = 0
        while bi < 16:
            c_blk.push(_u8_at(ciphertext_tag, i * 16 + bi))
            bi = bi + 1

        # P_i = Offset_i XOR DECIPHER(K, C_i XOR Offset_i)
        # For OCB3 decryption uses AES inverse; however we use the encrypt-based
        # formulation: DECIPHER(K, X) is AES^-1(K, X).
        # Since we don't have rt_aes128_decrypt_block_pure, we use the fact that
        # OCB decrypt requires DECIPHER.  We call rt_aes128_encrypt_block_pure
        # which is ENCIPHER.  For the block cipher call:
        #   P_i = Offset XOR DECIPHER(K, C_i XOR Offset)
        # We must use AES decryption here.  As a workaround, for the test vectors
        # we note that the pure-Simple path needs rt_aes128_decrypt_block_pure.
        # We mark this as TODO: add rt_aes128_decrypt_block_pure extern when
        # the runtime exposes it.  For now we produce a stub that always fails
        # authenticate so callers know it is not yet implemented.
        # TODO(ocb3-decrypt): needs rt_aes128_decrypt_block_pure extern.
        # placeholder: use encrypt (wrong, will fail auth)
        val p_blk = _xor16(offset, rt_aes128_encrypt_block_pure(key, _xor16(offset, c_blk)))
        checksum = _xor16(checksum, p_blk)
        bi = 0
        while bi < 16:
            plaintext.push(_u8_at(p_blk, bi))
            bi = bi + 1
        i = i + 1

    # Process partial last block (if any)
    val rem = ct_len % 16
    if rem > 0:
        val l_star = _table_get(l_table, 0)
        offset = _xor16(offset, l_star)

        val pad = rt_aes128_encrypt_block_pure(key, offset)

        var p_last: [u8] = rt_array_new_with_cap(16)
        var pi: u64 = 0
        while pi < rem:
            val byte = _u8_at(ciphertext_tag, num_full * 16 + pi) ^ _u8_at(pad, pi)
            p_last.push(byte)
            plaintext.push(byte)
            pi = pi + 1
        p_last.push(0x80)
        while p_last.len() < 16:
            p_last.push(0x00)
        checksum = _xor16(checksum, p_last)

    # Recompute tag
    val tag_input = _xor16(_xor16(checksum, offset), l_dollar)
    val tag_base = rt_aes128_encrypt_block_pure(key, tag_input)
    val hash_val = _ocb3_hash(key, aad, l_table)
    val tag_exp = _xor16(tag_base, hash_val)

    # Constant-time tag comparison
    var diff: u8 = 0x00
    ti = 0
    while ti < 16:
        diff = diff | (_u8_at(tag_exp, ti) ^ _u8_at(tag_rcv, ti))
        ti = ti + 1

    if diff != 0:
        return Ocb3Result.Err("authentication tag mismatch")

    Ocb3Result.Ok(data: plaintext)
