#![allow(unnamed_duplicate_typed_args)]
# Tiger/192 -- Pure Simple Implementation (Anderson+Biham 1996)
#
# Implements Tiger/192 cryptographic hash function.
# No SFFI/Rust FFI -- pure Simple language, suitable for baremetal.
#
# Reference: Ross Anderson and Eli Biham, "Tiger: A Fast New Hash Function",
#            Fast Software Encryption, 1996.
#
# Tiger/192 produces a 24-byte (192-bit) digest.
# Padding: 0x01 byte (NOT 0x80 like SHA) followed by zeros + 64-bit LE bit-length.
# Initial state: a=0x0123456789ABCDEF, b=0xFEDCBA9876543210, c=0xF096A5B4C3B2E187.
# Output: a||b||c, each as 8 bytes little-endian.

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

fn _u8_at(buf: [u8], idx: i64) -> i64:
    rt_bytes_u8_at(buf, idx)

# ============================================================================
# 64-bit helpers
# ============================================================================

fn _lshr64(x: i64, n: i64) -> i64:
    """Logical (unsigned) right-shift of i64 by n bits (n must be 1..63).

    Simple's >> on i64 is arithmetic (sign-extending). For Tiger key schedule
    we need logical right shift of ~x which has high bit set.
    NOTE: n must not be 0 (would compute 1<<64, overflowing i64).
    """
    val mask = (1 << (64 - n)) - 1
    (x >> n) & mask

# ============================================================================
# Tiger S-boxes T1..T4 (256 x 64-bit entries each)
# ============================================================================

