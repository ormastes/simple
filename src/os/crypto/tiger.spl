# Tiger/192 -- Pure Simple Implementation
#
# Anderson & Biham, "Tiger: A Fast New Hash Function", FSE 1996.
# Three 64-bit state words, 512-bit blocks, 3 passes x 8 rounds.
# 4 S-boxes of 256 x 64-bit entries (little-endian throughout).
#
# Padding byte: 0x01 (original Tiger; Tiger2 uses 0x80).
# Output: 192 bits (24 bytes), 3 x 64-bit words in little-endian order.
#
# S-box source: RHash project (rhash/RHash), tiger_sbox.c
# (canonical values from Anderson/Biham reference C implementation)

use os.crypto.tiger_sbox_t1t2.{_t1, _t2}
use os.crypto.tiger_sbox_t3t4.{_t3, _t4}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

fn _u8_at_tiger(buf: [u8], idx: i64) -> u8:
    rt_bytes_u8_at(buf, idx).to_u8()

# ============================================================================
# u64 helpers
# ============================================================================
# WORKAROUND: interpreter applies arithmetic (sign-extending) right-shift
# to u64 fn parameters. Use _logical_shr64 for all >> on u64 fn params.
# See: doc/08_tracking/bug/u64_right_shift_fn_param_arithmetic_2026-05-02.md

fn _u64_mask(x: u64) -> u64:
    x & 0xFFFFFFFFFFFFFFFF

fn _logical_shr64(x: u64, n: u64) -> u64:
    val mask: u64 = _u64_mask((1u64 << (64u64 - n)) - 1u64)
    (x >> n) & mask

# ============================================================================
# Tiger round function
# ============================================================================
# Reference pass macro cycles 8 rounds over three arg-positions:
#   round(a,b,c,x0) round(b,c,a,x1) round(c,a,b,x2)
#   round(a,b,c,x3) round(b,c,a,x4) round(c,a,b,x5)
#   round(a,b,c,x6) round(b,c,a,x7)
#
# round(a,b,c,x,mul):
#   c ^= x
#   a -= t1[c[0]] ^ t2[c[2]] ^ t3[c[4]] ^ t4[c[6]]
#   b += t4[c[1]] ^ t3[c[3]] ^ t2[c[5]] ^ t1[c[7]]
#   b *= mul
# where c[n] = byte n of c (0=LSB)

fn _tiger_round(a: u64, b: u64, c_in: u64, x: u64, mul: u64) -> [u64]:
    val c: u64 = _u64_mask(c_in ^ x)
    # byte 0: no shift needed (avoids shift-by-0 edge case in _logical_shr64)
    val c0: i64 = (c & 0xFF).to_i64()
    val c1: i64 = (_logical_shr64(c, 8u64) & 0xFF).to_i64()
    val c2: i64 = (_logical_shr64(c, 16u64) & 0xFF).to_i64()
    val c3: i64 = (_logical_shr64(c, 24u64) & 0xFF).to_i64()
    val c4: i64 = (_logical_shr64(c, 32u64) & 0xFF).to_i64()
    val c5: i64 = (_logical_shr64(c, 40u64) & 0xFF).to_i64()
    val c6: i64 = (_logical_shr64(c, 48u64) & 0xFF).to_i64()
    val c7: i64 = (_logical_shr64(c, 56u64) & 0xFF).to_i64()
    val new_a: u64 = _u64_mask(a - (_u64_mask(_t1(c0) ^ _t2(c2)) ^ _u64_mask(_t3(c4) ^ _t4(c6))))
    val tmp_b: u64 = _u64_mask(b + (_u64_mask(_t4(c1) ^ _t3(c3)) ^ _u64_mask(_t2(c5) ^ _t1(c7))))
    val new_b: u64 = _u64_mask(tmp_b * mul)
    var result: [u64] = []
    result.push(new_a)
    result.push(new_b)
    result.push(c)
    result

# Tiger pass: 8 rounds cycling through (a,b,c), (b,c,a), (c,a,b)
fn _tiger_pass(a_in: u64, b_in: u64, c_in: u64, x: [u64], mul: u64) -> [u64]:
    var a: u64 = a_in
    var b: u64 = b_in
    var c: u64 = c_in
    val r0 = _tiger_round(a, b, c, x[0], mul)
    a = r0[0]
    b = r0[1]
    c = r0[2]
    val r1 = _tiger_round(b, c, a, x[1], mul)
    b = r1[0]
    c = r1[1]
    a = r1[2]
    val r2 = _tiger_round(c, a, b, x[2], mul)
    c = r2[0]
    a = r2[1]
    b = r2[2]
    val r3 = _tiger_round(a, b, c, x[3], mul)
    a = r3[0]
    b = r3[1]
    c = r3[2]
    val r4 = _tiger_round(b, c, a, x[4], mul)
    b = r4[0]
    c = r4[1]
    a = r4[2]
    val r5 = _tiger_round(c, a, b, x[5], mul)
    c = r5[0]
    a = r5[1]
    b = r5[2]
    val r6 = _tiger_round(a, b, c, x[6], mul)
    a = r6[0]
    b = r6[1]
    c = r6[2]
    val r7 = _tiger_round(b, c, a, x[7], mul)
    b = r7[0]
    c = r7[1]
    a = r7[2]
    var out: [u64] = []
    out.push(a)
    out.push(b)
    out.push(c)
    out

# Tiger key schedule (runs between passes, transforms x[0..7])
fn _tiger_key_schedule(x_in: [u64]) -> [u64]:
    var x: [u64] = []
    var k: i64 = 0
    while k < 8:
        x.push(x_in[k])
        k = k + 1
    x[0] = _u64_mask(x[0] - (_u64_mask(x[7] ^ 0xA5A5A5A5A5A5A5A5)))
    x[1] = _u64_mask(x[1] ^ x[0])
    x[2] = _u64_mask(x[2] + x[1])
    x[3] = _u64_mask(x[3] - (_u64_mask(x[2] ^ _u64_mask(_u64_mask(~x[1]) << 19))))
    x[4] = _u64_mask(x[4] ^ x[3])
    x[5] = _u64_mask(x[5] + x[4])
    x[6] = _u64_mask(x[6] - (_u64_mask(x[5] ^ _logical_shr64(_u64_mask(~x[4]), 23u64))))
    x[7] = _u64_mask(x[7] ^ x[6])
    x[0] = _u64_mask(x[0] + x[7])
    x[1] = _u64_mask(x[1] - (_u64_mask(x[0] ^ _u64_mask(_u64_mask(~x[7]) << 19))))
    x[2] = _u64_mask(x[2] ^ x[1])
    x[3] = _u64_mask(x[3] + x[2])
    x[4] = _u64_mask(x[4] - (_u64_mask(x[3] ^ _logical_shr64(_u64_mask(~x[2]), 23u64))))
    x[5] = _u64_mask(x[5] ^ x[4])
    x[6] = _u64_mask(x[6] + x[5])
    x[7] = _u64_mask(x[7] - (_u64_mask(x[6] ^ 0x0123456789ABCDEF)))
    x

# Tiger block compression (one 512-bit block = 8 x 64-bit LE words)
# Reference sequence:
#   pass(a,b,c, 5); key_schedule; pass(c,a,b, 7); key_schedule; pass(b,c,a, 9)
#   feedforward: state[0] ^= a;  state[1] = b - state[1];  state[2] += c
fn _tiger_compress(state: [u64], block: [u64]) -> [u64]:
    var a: u64 = state[0]
    var b: u64 = state[1]
    var c: u64 = state[2]
    var x: [u64] = []
    var k: i64 = 0
    while k < 8:
        x.push(block[k])
        k = k + 1
    val p1 = _tiger_pass(a, b, c, x, 5u64)
    a = p1[0]
    b = p1[1]
    c = p1[2]
    x = _tiger_key_schedule(x)
    val p2 = _tiger_pass(c, a, b, x, 7u64)
    c = p2[0]
    a = p2[1]
    b = p2[2]
    x = _tiger_key_schedule(x)
    val p3 = _tiger_pass(b, c, a, x, 9u64)
    b = p3[0]
    c = p3[1]
    a = p3[2]
    var result: [u64] = []
    result.push(_u64_mask(a ^ state[0]))
    result.push(_u64_mask(b - state[1]))
    result.push(_u64_mask(c + state[2]))
    result

# ============================================================================
# Padding: little-endian, pad byte 0x01 (original Tiger)
# ============================================================================

fn _tiger_pad(data: [u8]) -> [u8]:
    val data_len: i64 = data.len().to_i64()
    val bit_len: u64 = data_len.to_u64() * 8u64
    var padded: [u8] = []
    var i: i64 = 0
    while i < data_len:
        padded.push(_u8_at_tiger(data, i))
        i = i + 1
    # Pad byte 0x01 (original Tiger, NOT 0x80 which is Tiger2)
    padded.push(0x01)
    # Zero-pad until length == 56 (mod 64)
    while (padded.len() % 64) != 56:
        padded.push(0x00)
    # Append 64-bit little-endian message bit-length
    padded.push((bit_len & 0xFF).to_u8())
    padded.push((_logical_shr64(bit_len, 8u64) & 0xFF).to_u8())
    padded.push((_logical_shr64(bit_len, 16u64) & 0xFF).to_u8())
    padded.push((_logical_shr64(bit_len, 24u64) & 0xFF).to_u8())
    padded.push((_logical_shr64(bit_len, 32u64) & 0xFF).to_u8())
    padded.push((_logical_shr64(bit_len, 40u64) & 0xFF).to_u8())
    padded.push((_logical_shr64(bit_len, 48u64) & 0xFF).to_u8())
    padded.push((_logical_shr64(bit_len, 56u64) & 0xFF).to_u8())
    padded

# ============================================================================
# Tiger/192 public API
# ============================================================================

fn tiger192(data: [u8]) -> [u8]:
    val padded = _tiger_pad(data)
    var state: [u64] = []
    state.push(0x0123456789ABCDEF)
    state.push(0xFEDCBA9876543210)
    state.push(0xF096A5B4C3B2E187)
    var offset: i64 = 0
    while offset < padded.len().to_i64():
        var block: [u64] = []
        var wi: i64 = 0
        while wi < 8:
            val base: i64 = offset + wi * 8
            val b0: u64 = _u8_at_tiger(padded, base).to_u64()
            val b1: u64 = _u64_mask(_u8_at_tiger(padded, base + 1).to_u64() << 8u64)
            val b2: u64 = _u64_mask(_u8_at_tiger(padded, base + 2).to_u64() << 16u64)
            val b3: u64 = _u64_mask(_u8_at_tiger(padded, base + 3).to_u64() << 24u64)
            val b4: u64 = _u64_mask(_u8_at_tiger(padded, base + 4).to_u64() << 32u64)
            val b5: u64 = _u64_mask(_u8_at_tiger(padded, base + 5).to_u64() << 40u64)
            val b6: u64 = _u64_mask(_u8_at_tiger(padded, base + 6).to_u64() << 48u64)
            val b7: u64 = _u64_mask(_u8_at_tiger(padded, base + 7).to_u64() << 56u64)
            block.push(_u64_mask(b0 | b1 | b2 | b3 | b4 | b5 | b6 | b7))
            wi = wi + 1
        state = _tiger_compress(state, block)
        offset = offset + 64
    var out: [u8] = []
    var si: i64 = 0
    while si < 3:
        val w: u64 = state[si]
        out.push((w & 0xFF).to_u8())
        out.push((_logical_shr64(w, 8u64) & 0xFF).to_u8())
        out.push((_logical_shr64(w, 16u64) & 0xFF).to_u8())
        out.push((_logical_shr64(w, 24u64) & 0xFF).to_u8())
        out.push((_logical_shr64(w, 32u64) & 0xFF).to_u8())
        out.push((_logical_shr64(w, 40u64) & 0xFF).to_u8())
        out.push((_logical_shr64(w, 48u64) & 0xFF).to_u8())
        out.push((_logical_shr64(w, 56u64) & 0xFF).to_u8())
        si = si + 1
    out

fn _tiger_hex_nibble(n: u8) -> text:
    if n == 0: "0"
    else if n == 1: "1"
    else if n == 2: "2"
    else if n == 3: "3"
    else if n == 4: "4"
    else if n == 5: "5"
    else if n == 6: "6"
    else if n == 7: "7"
    else if n == 8: "8"
    else if n == 9: "9"
    else if n == 10: "a"
    else if n == 11: "b"
    else if n == 12: "c"
    else if n == 13: "d"
    else if n == 14: "e"
    else: "f"

fn tiger_hex(data: [u8]) -> text:
    val digest = tiger192(data)
    var s: text = ""
    var i: i64 = 0
    while i < 24:
        val byte = digest[i]
        s = s + _tiger_hex_nibble((byte >> 4) & 0x0F)
        s = s + _tiger_hex_nibble(byte & 0x0F)
        i = i + 1
    s
