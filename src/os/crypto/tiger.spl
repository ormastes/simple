# ============================================================================
# Tiger round function
# ============================================================================

fn _tiger_round(a: i64, b: i64, c: i64, x: i64, mul: i64,
                t1: [i64], t2: [i64], t3: [i64], t4: [i64]) -> [i64]:
    """One Tiger round. Returns updated [a, b, c].

    c ^= x
    a -= t1[c[0]] ^ t2[c[2]] ^ t3[c[4]] ^ t4[c[6]]
    b += t4[c[1]] ^ t3[c[3]] ^ t2[c[5]] ^ t1[c[7]]
    b *= mul
    where c[n] = byte n of c (0=LSB).

    NOTE: byte extraction uses arithmetic >> then & 0xFF, which is correct because
    & 0xFF clears sign-extension bits.
    """
    val c2 = c ^ x
    # byte extraction: arithmetic >> is fine because & 0xFF clears sign bits
    val a2 = a - (t1[(c2) & 0xFF] ^ t2[(c2 >> 16) & 0xFF] ^
                  t3[(c2 >> 32) & 0xFF] ^ t4[_lshr64(c2, 48) & 0xFF])
    val b2 = b + (t4[(c2 >> 8) & 0xFF] ^ t3[(c2 >> 24) & 0xFF] ^
                  t2[_lshr64(c2, 40) & 0xFF] ^ t1[_lshr64(c2, 56) & 0xFF])
    val b3 = b2 * mul
    var res: [i64] = []
    res.push(a2)
    res.push(b3)
    res.push(c2)
    res

# ============================================================================
# Tiger pass (8 rounds with role rotation)
# ============================================================================

fn _tiger_pass(a: i64, b: i64, c: i64, x: [i64], mul: i64,
               t1: [i64], t2: [i64], t3: [i64], t4: [i64]) -> [i64]:
    """One pass over 8 message words with role rotation. Returns [a, b, c]."""
    # round 0: (a,b,c, x[0])
    var r = _tiger_round(a, b, c, x[0], mul, t1, t2, t3, t4)
    # round 1: (b,c,a, x[1])  -- rotate roles
    r = _tiger_round(r[1], r[2], r[0], x[1], mul, t1, t2, t3, t4)
    val a1 = r[2]
    val b1 = r[0]
    val c1 = r[1]
    # round 2: (c,a,b, x[2])
    r = _tiger_round(c1, a1, b1, x[2], mul, t1, t2, t3, t4)
    val c2 = r[0]
    val a2 = r[1]
    val b2 = r[2]
    # round 3: (a,b,c, x[3])
    r = _tiger_round(a2, b2, c2, x[3], mul, t1, t2, t3, t4)
    # round 4: (b,c,a, x[4])
    r = _tiger_round(r[1], r[2], r[0], x[4], mul, t1, t2, t3, t4)
    val a4 = r[2]
    val b4 = r[0]
    val c4 = r[1]
    # round 5: (c,a,b, x[5])
    r = _tiger_round(c4, a4, b4, x[5], mul, t1, t2, t3, t4)
    val c5 = r[0]
    val a5 = r[1]
    val b5 = r[2]
    # round 6: (a,b,c, x[6])
    r = _tiger_round(a5, b5, c5, x[6], mul, t1, t2, t3, t4)
    # round 7: (b,c,a, x[7])
    r = _tiger_round(r[1], r[2], r[0], x[7], mul, t1, t2, t3, t4)
    val a7 = r[2]
    val b7 = r[0]
    val c7 = r[1]

    var out: [i64] = []
    out.push(a7)
    out.push(b7)
    out.push(c7)
    out

# ============================================================================
# Tiger key schedule
# ============================================================================

fn _key_schedule(x: [i64]) -> [i64]:
    """Tiger key schedule: update the 8-word message block x."""
    var x0 = x[0]
    var x1 = x[1]
    var x2 = x[2]
    var x3 = x[3]
    var x4 = x[4]
    var x5 = x[5]
    var x6 = x[6]
    var x7 = x[7]

    # 0xA5A5A5A5A5A5A5A5 as i64 = -6510615555426900571
    x0 = x0 - (x7 ^ -6510615555426900571)
    x1 = x1 ^ x0
    x2 = x2 + x1
    x3 = x3 - (x2 ^ ((~x1) << 19))
    x4 = x4 ^ x3
    x5 = x5 + x4
    x6 = x6 - (x5 ^ _lshr64(~x4, 23))
    x7 = x7 ^ x6
    x0 = x0 + x7
    x1 = x1 - (x0 ^ ((~x7) << 19))
    x2 = x2 ^ x1
    x3 = x3 + x2
    x4 = x4 - (x3 ^ _lshr64(~x2, 23))
    x5 = x5 ^ x4
    x6 = x6 + x5
    # 0x0123456789ABCDEF as i64 = 81985529216486895
    x7 = x7 - (x6 ^ 81985529216486895)

    var out: [i64] = []
    out.push(x0)
    out.push(x1)
    out.push(x2)
    out.push(x3)
    out.push(x4)
    out.push(x5)
    out.push(x6)
    out.push(x7)
    out

# ============================================================================
# Tiger block compression
# ============================================================================

fn _tiger_compress(block: [u8], offset: i64, state: [i64],
                   t1: [i64], t2: [i64], t3: [i64], t4: [i64]) -> [i64]:
    """Process one 64-byte Tiger block. Returns updated [a, b, c]."""
    val aa = state[0]
    val bb = state[1]
    val cc = state[2]
    var a = aa
    var b = bb
    var c = cc

    # Load 8 little-endian 64-bit words from block[offset..offset+64]
    var x: [i64] = []
    var wi: i64 = 0
    while wi < 8:
        val base = offset + wi * 8
        val w = _u8_at(block, base) |
            (_u8_at(block, base + 1) << 8) |
            (_u8_at(block, base + 2) << 16) |
            (_u8_at(block, base + 3) << 24) |
            (_u8_at(block, base + 4) << 32) |
            (_u8_at(block, base + 5) << 40) |
            (_u8_at(block, base + 6) << 48) |
            (_u8_at(block, base + 7) << 56)
        x.push(w)
        wi = wi + 1

    # Pass 1 (mul=5): roles (a,b,c)
    var p = _tiger_pass(a, b, c, x, 5, t1, t2, t3, t4)
    a = p[0]
    b = p[1]
    c = p[2]

    # Key schedule
    x = _key_schedule(x)

    # Pass 2 (mul=7): roles (c,a,b) -> tiger_pass(c,a,b) returns [c',a',b']
    p = _tiger_pass(c, a, b, x, 7, t1, t2, t3, t4)
    c = p[0]
    a = p[1]
    b = p[2]

    # Key schedule
    x = _key_schedule(x)

    # Pass 3 (mul=9): roles (b,c,a) -> tiger_pass(b,c,a) returns [b',c',a']
    p = _tiger_pass(b, c, a, x, 9, t1, t2, t3, t4)
    b = p[0]
    c = p[1]
    a = p[2]

    # Feedforward
    a = a ^ aa
    b = b - bb
    c = c + cc

    var out: [i64] = []
    out.push(a)
    out.push(b)
    out.push(c)
    out

# ============================================================================
# Tiger padding
# ============================================================================

fn _tiger_pad(data: [u8], data_len: i64) -> [u8]:
    """Pad message for Tiger: 0x01 byte, zeros to 56 mod 64, then 8-byte LE bit-length."""
    var padded: [u8] = []
    var i: i64 = 0
    while i < data_len:
        padded.push(_u8_at(data, i).to_u8())
        i = i + 1

    # Tiger padding byte is 0x01 (not 0x80 like SHA-1/SHA-2)
    padded.push(0x01)

    # Zero-pad until length == 56 (mod 64)
    while (padded.len().to_i64() % 64) != 56:
        padded.push(0x00)

    # Append 8-byte little-endian bit-length
    val bit_len = data_len * 8
    padded.push((bit_len & 0xFF).to_u8())
    padded.push(((bit_len >> 8) & 0xFF).to_u8())
    padded.push(((bit_len >> 16) & 0xFF).to_u8())
    padded.push(((bit_len >> 24) & 0xFF).to_u8())
    padded.push((_lshr64(bit_len, 32) & 0xFF).to_u8())
    padded.push((_lshr64(bit_len, 40) & 0xFF).to_u8())
    padded.push((_lshr64(bit_len, 48) & 0xFF).to_u8())
    padded.push((_lshr64(bit_len, 56) & 0xFF).to_u8())

    padded

# ============================================================================
# Public API
# ============================================================================

fn tiger192(data: [u8]) -> [u8]:
    """Tiger/192 hash. Returns 24 bytes (192-bit digest).

    Output byte order: a||b||c, each word serialized little-endian.

    Reference vectors (Anderson+Biham 1996):
      tiger192("")      = 3293ac630c13f0245f92bbb1766e16167a4e58492dde73f3
      tiger192("a")     = 77befbef2e7ef8ab2ec8f93bf587a7fc613e247f5f247809
      tiger192("abc")   = 2aab1484e8c158f2bfb8c5ff41b57a525129131c957b5f93
      tiger192("Tiger") = dd00230799f5009fec6debc838bb6a27df2b9d6f110c7937
    """
    val t1 = _t1()
    val t2 = _t2()
    val t3 = _t3()
    val t4 = _t4()

    val data_len = data.len().to_i64()
    val padded = _tiger_pad(data, data_len)

    # Initial state (Anderson+Biham 1996)
    # a=0x0123456789ABCDEF = 81985529216486895
    # b=0xFEDCBA9876543210 = -81985529216486896
    # c=0xF096A5B4C3B2E187 = -1110518062304271993
    var state: [i64] = []
    state.push(81985529216486895)
    state.push(-81985529216486896)
    state.push(-1110518062304271993)

    # Process 64-byte blocks
    var offset: i64 = 0
    val total_len = padded.len().to_i64()
    while offset < total_len:
        state = _tiger_compress(padded, offset, state, t1, t2, t3, t4)
        offset = offset + 64

    # Serialize: each of a, b, c as 8 bytes little-endian
    var out: [u8] = []
    var wi: i64 = 0
    while wi < 3:
        val w = state[wi]
        out.push((w & 0xFF).to_u8())
        out.push(((w >> 8) & 0xFF).to_u8())
        out.push(((w >> 16) & 0xFF).to_u8())
        out.push(((w >> 24) & 0xFF).to_u8())
        out.push((_lshr64(w, 32) & 0xFF).to_u8())
        out.push((_lshr64(w, 40) & 0xFF).to_u8())
        out.push((_lshr64(w, 48) & 0xFF).to_u8())
        out.push((_lshr64(w, 56) & 0xFF).to_u8())
        wi = wi + 1
    out
