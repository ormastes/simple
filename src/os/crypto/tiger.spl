#![allow(unnamed_duplicate_typed_args)]
# Tiger/192 -- Pure Simple Implementation
#
# Anderson & Biham, "Tiger: A Fast New Hash Function", FSE 1996.
# Three 64-bit state words, 512-bit blocks, 3 passes x 8 rounds.
# 4 S-boxes of 256 x 64-bit entries (little-endian throughout).
#
# Padding byte: 0x01 (original Tiger; Tiger2 uses 0x80).
# Output: 192 bits (24 bytes), 3 x 64-bit words in little-endian order.
#
# S-box source: RHash project (rhash/RHash), tiger_sbox.c
# (canonical values from Anderson/Biham reference C implementation)

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

fn _u8_at_tiger(buf: [u8], idx: i64) -> u8:
    rt_bytes_u8_at(buf, idx).to_u8()

# ============================================================================
# u64 helpers
# ============================================================================
# WORKAROUND: interpreter applies arithmetic (sign-extending) right-shift
# to u64 fn parameters. Use _logical_shr64 for all >> on u64 fn params.
# See: doc/08_tracking/bug/u64_right_shift_fn_param_arithmetic_2026-05-02.md

fn _u64_mask(x: u64) -> u64:
    x & 0xFFFFFFFFFFFFFFFF

fn _logical_shr64(x: u64, n: u64) -> u64:
    val mask: u64 = _u64_mask((1u64 << (64u64 - n)) - 1u64)
    (x >> n) & mask

# ============================================================================
# S-Boxes (Anderson+Biham canonical, 4 x 256 x 64-bit)
# S-box source: rhash/RHash tiger_sbox.c (verified against reference paper)
# ============================================================================

