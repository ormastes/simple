# PBKDF2 — Password-Based Key Derivation Function 2 (RFC 2898 / RFC 8018)
#
# Pure Simple implementation using [u8]-typed API for baremetal SimpleOS.
# Uses HMAC-SHA-256 from os.crypto.sha256 as the PRF.
#
# NOTE: sha256_hmac([u8],[u8]) has a known rt_bytes_u8_at bug in interpreter
# mode where key bytes read as 0. We use sha256_hmac_from_list(list,list)
# which is the working path (same as std.crypto.pbkdf2).
#
# Public API:
#   pbkdf2_sha256(password: [u8], salt: [u8], iterations: i64, dk_len: i64) -> [u8]
#     Derives a key of `dk_len` bytes from `password` using `salt` and
#     `iterations` rounds of HMAC-SHA-256.
#
# Algorithm (RFC 2898 §5.2):
#   For each block i = 1..ceil(dkLen/hLen):
#     U_1 = PRF(password, salt || INT(i))   # INT(i) = 4-byte big-endian
#     U_j = PRF(password, U_{j-1})          # j = 2..c
#     T_i = U_1 XOR U_2 XOR ... XOR U_c
#   DK = T_1 || T_2 || ... (truncated to dkLen)
#
# Reference: RFC 2898 (PKCS#5 v2.0), RFC 8018 (PKCS#5 v2.1), RFC 6070 (test vectors)
# KAT: test/unit/os/crypto/pbkdf2_spec.spl
# ============================================================================

use os.crypto.sha256.{sha256_hmac_from_list}

# ============================================================================
# Helpers — [u8] <-> list conversion
# ============================================================================

fn _u8_to_list(arr: [u8]) -> list:
    var lst: list = []
    var i: i64 = 0
    while i < arr.len():
        val byte: u8 = arr[i]
        lst.push(byte.to_i64())
        i = i + 1
    lst

fn _list_to_u8(lst: list) -> [u8]:
    var arr: [u8] = []
    var i: i64 = 0
    while i < lst.len():
        val v: i64 = lst.get(i)
        var byte: u8 = v.to_u8()
        arr.push(byte)
        i = i + 1
    arr

# ============================================================================
# PBKDF2-HMAC-SHA-256
# ============================================================================

# Derive a key of `dk_len` bytes from `password` using PBKDF2-HMAC-SHA-256.
# reason: positional crypto pbkdf2 API
fn pbkdf2_sha256(password: [u8], salt: [u8], iterations: i64, dk_len: i64) -> [u8]:
    val h_len: i64 = 32
    val blocks_needed: i64 = (dk_len + h_len - 1) / h_len

    # Convert password to list once (reused for every HMAC call)
    val pwd_list: list = _u8_to_list(password)

    var result: [u8] = []
    var block_num: i64 = 1

    while block_num <= blocks_needed:
        # Build salt || INT(block_num) as list
        var salt_block: list = []
        var si: i64 = 0
        while si < salt.len():
            val sb: u8 = salt[si]
            salt_block.push(sb.to_i64())
            si = si + 1

        salt_block.push((block_num >> 24) & 0xFF)
        salt_block.push((block_num >> 16) & 0xFF)
        salt_block.push((block_num >> 8) & 0xFF)
        salt_block.push(block_num & 0xFF)

        # U_1 = HMAC(password, salt || INT(i))
        # sha256_hmac_from_list returns [u8]
        var u_arr: [u8] = sha256_hmac_from_list(pwd_list, salt_block)
        var u_list: list = _u8_to_list(u_arr)

        # t = U_1 (copy as list for XOR operations)
        var t: list = []
        var ti: i64 = 0
        while ti < h_len:
            t.push(u_list.get(ti))
            ti = ti + 1

        # U_2 .. U_c: t ^= U_j
        var iteration: i64 = 1
        while iteration < iterations:
            u_arr = sha256_hmac_from_list(pwd_list, u_list)
            u_list = _u8_to_list(u_arr)

            # XOR fold: t ^= u
            var xi: i64 = 0
            while xi < h_len:
                t[xi] = t.get(xi) ^ u_list.get(xi)
                xi = xi + 1

            iteration = iteration + 1

        # Append T_i to result
        var ri: i64 = 0
        while ri < h_len:
            val rv: i64 = t.get(ri)
            var rb: u8 = rv.to_u8()
            result.push(rb)
            ri = ri + 1

        block_num = block_num + 1

    # Truncate to dk_len
    if result.len() == dk_len:
        result
    else:
        var truncated: [u8] = []
        var fi: i64 = 0
        while fi < dk_len:
            val fb: u8 = result[fi]
            truncated.push(fb)
            fi = fi + 1
        truncated
