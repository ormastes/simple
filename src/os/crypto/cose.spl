# COSE Sign1 + Mac0 — RFC 9052 (CBOR Object Signing and Encryption)
#
# Implements COSE_Sign1 (§4.4) and COSE_Mac0 (§6.2) for single-signer
# and single-MAC use cases. Sign/Mac (multi-recipient) and Encrypt0/
# Encrypt are out of scope (W20+).
#
# Algorithms:
#   ES256  — ECDSA P-256 / SHA-256 (alg id = -7)
#   EdDSA  — Ed25519 (alg id = -8)
#   HS256  — HMAC-SHA-256 (alg id = 5)
#
# Wire format (CBOR arrays, RFC 9052):
#   COSE_Sign1:  tag(18) + [protected, unprotected, payload, signature]
#   COSE_Mac0:   tag(17) + [protected, unprotected, payload, tag]
#
# Sig_structure (RFC 9052 §4.4):
#   ["Signature1", protected, external_aad, payload]
#
# MAC_structure (RFC 9052 §6.2):
#   ["MAC0", protected, external_aad, payload]
#
# Public API:
#   cose_sign1_create(payload, alg, key)       -> [u8]
#   cose_sign1_verify(cose_bytes, alg, key)    -> CoseVerifyResult
#   cose_mac0_create(payload, key)             -> [u8]
#   cose_mac0_verify(cose_bytes, key)          -> CoseVerifyResult
#
# All payloads are [u8] (feedback_text_only_byte_cliffs.md).
# CBOR internals use [i64] as required by the cbor encode/decode API.
#
# References:
#   RFC 9052 — CBOR Object Signing and Encryption (COSE)
#   RFC 8152 — Previous COSE spec (Appendix C KATs still valid)

use os.crypto.ed25519.{ed25519_keypair_from_seed, ed25519_sign, ed25519_verify}
use os.crypto.ecdsa_p256.{ecdsa_p256_sign_fixed, ecdsa_p256_verify_fixed}
use std.common.cbor.encode.{
    cbor_encode_bytes,
    cbor_encode_text,
    cbor_encode_array_header,
    cbor_encode_map_header,
    cbor_encode_int,
    cbor_encode_tagged
}
use std.common.cbor.decode.{
    cbor_decode_bytes,
    cbor_decode_array_header,
    cbor_decode_tag,
    cbor_item_size
}

# ============================================================================
# Algorithm IDs (RFC 9052 Table 1 / IANA COSE Algorithms)
# ============================================================================

fn cose_alg_es256() -> i64:
    """ECDSA w/ SHA-256, P-256 curve. COSE algorithm id = -7."""
    return -7

fn cose_alg_eddsa() -> i64:
    """Ed25519. COSE algorithm id = -8."""
    return -8

fn cose_alg_hs256() -> i64:
    """HMAC w/ SHA-256. COSE algorithm id = 5."""
    5

# COSE tag numbers
fn cose_tag_sign1() -> i64:
    """COSE_Sign1 CBOR tag = 18."""
    18

fn cose_tag_mac0() -> i64:
    """COSE_Mac0 CBOR tag = 17."""
    17

# ============================================================================
# CoseError / CoseVerifyResult
# ============================================================================

enum CoseError:
    """Error type for COSE operations."""
    InvalidStructure(msg: text)
    SignatureMismatch
    AlgorithmRejected(msg: text)
    InvalidEncoding(msg: text)

enum CoseVerifyResult:
    """Result of cose_sign1_verify or cose_mac0_verify.
    Ok carries the decoded payload bytes."""
    Ok(payload: [u8])
    Err(error: CoseError)

# ============================================================================
# Internal: [u8] <-> [i64] conversion helpers
# ============================================================================

fn _u8_to_i64(data: [u8]) -> [i64]:
    """Convert [u8] to [i64] for CBOR encode/decode API."""
    var out: [i64] = []
    var i: u64 = 0
    while i < data.len():
        out.push(data[i].to_i64())
        i = i + 1
    out

fn _i64_to_u8(data: [i64]) -> [u8]:
    """Convert [i64] to [u8] after CBOR decode."""
    var out: [u8] = []
    var i = 0
    while i < data.len():
        out.push(data[i].to_u8())
        i = i + 1
    out

fn _i64_concat(a: [i64], b: [i64]) -> [i64]:
    """Concatenate two [i64] byte arrays."""
    var out: [i64] = []
    var i = 0
    while i < a.len():
        out.push(a[i])
        i = i + 1
    i = 0
    while i < b.len():
        out.push(b[i])
        i = i + 1
    out

fn _u8_concat(a: [u8], b: [u8]) -> [u8]:
    """Concatenate two [u8] arrays."""
    var out: [u8] = []
    var i: u64 = 0
    while i < a.len():
        out.push(a[i])
        i = i + 1
    i = 0
    while i < b.len():
        out.push(b[i])
        i = i + 1
    out

# ============================================================================
# Internal: constant-time [u8] comparison (timing-safe)
# ============================================================================

fn _cose_ct_eq(a: [u8], b: [u8]) -> bool:
    """Constant-time equality check for [u8] arrays."""
    if a.len() != b.len():
        return false
    var acc: i64 = 0
    var i: u64 = 0
    while i < a.len():
        acc = acc | (a[i].to_i64() ^ b[i].to_i64())
        i = i + 1
    acc == 0

# ============================================================================
# Internal: inline SHA-256 (self-contained, avoids module arity conflicts)
# ============================================================================

fn _cose_sha256_k() -> list:
    [
        0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5,
        0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
        0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3,
        0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
        0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc,
        0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
        0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7,
        0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
        0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13,
        0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
        0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3,
        0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
        0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5,
        0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
        0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208,
        0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2
    ]

fn _cose_sha256_init_h() -> list:
    [0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a,
     0x510e527f, 0x9b05688c, 0x1f83d9ab, 0x5be0cd19]

fn _cose_rotr32(x: i64, n: i64) -> i64:
    val mask: i64 = 0xFFFFFFFF
    ((x >> n) | ((x << (32 - n)) & mask)) & mask

fn _cose_ch(e: i64, f: i64, g: i64) -> i64:
    (e & f) ^ ((e ^ 0xFFFFFFFF) & g) & 0xFFFFFFFF

fn _cose_maj(a: i64, b: i64, c: i64) -> i64:
    (a & b) ^ (a & c) ^ (b & c)

fn _cose_sigma0(a: i64) -> i64:
    _cose_rotr32(a, 2) ^ _cose_rotr32(a, 13) ^ _cose_rotr32(a, 22)

fn _cose_sigma1(e: i64) -> i64:
    _cose_rotr32(e, 6) ^ _cose_rotr32(e, 11) ^ _cose_rotr32(e, 25)

fn _cose_gamma0(x: i64) -> i64:
    _cose_rotr32(x, 7) ^ _cose_rotr32(x, 18) ^ (x >> 3)

fn _cose_gamma1(x: i64) -> i64:
    _cose_rotr32(x, 17) ^ _cose_rotr32(x, 19) ^ (x >> 10)

fn _cose_sha256_pad(bytes: list) -> list:
    val orig_len = bytes.len()
    val bit_len = orig_len * 8
    var padded = []
    var i = 0
    while i < orig_len:
        padded.push(bytes.get(i))
        i = i + 1
    padded.push(0x80)
    while (padded.len() % 64) != 56:
        padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push(0)
    padded.push((bit_len >> 24) & 0xFF)
    padded.push((bit_len >> 16) & 0xFF)
    padded.push((bit_len >> 8) & 0xFF)
    padded.push(bit_len & 0xFF)
    padded

fn _cose_sha256_compress(h_state: list, block: list) -> list:
    val k = _cose_sha256_k()
    var w = []
    var i = 0
    while i < 16:
        val idx = i * 4
        val word = ((block.get(idx) & 0xFF) << 24) | ((block.get(idx + 1) & 0xFF) << 16) | ((block.get(idx + 2) & 0xFF) << 8) | (block.get(idx + 3) & 0xFF)
        w.push(word)
        i = i + 1
    while i < 64:
        val s0 = _cose_gamma0(w.get(i - 15))
        val s1 = _cose_gamma1(w.get(i - 2))
        val word = (w.get(i - 16) + s0 + w.get(i - 7) + s1) & 0xFFFFFFFF
        w.push(word)
        i = i + 1
    var a = h_state.get(0)
    var b = h_state.get(1)
    var c = h_state.get(2)
    var d = h_state.get(3)
    var e = h_state.get(4)
    var f = h_state.get(5)
    var g = h_state.get(6)
    var hh = h_state.get(7)
    i = 0
    while i < 64:
        val t1 = (hh + _cose_sigma1(e) + _cose_ch(e, f, g) + k.get(i) + w.get(i)) & 0xFFFFFFFF
        val t2 = (_cose_sigma0(a) + _cose_maj(a, b, c)) & 0xFFFFFFFF
        hh = g
        g = f
        f = e
        e = (d + t1) & 0xFFFFFFFF
        d = c
        c = b
        b = a
        a = (t1 + t2) & 0xFFFFFFFF
        i = i + 1
    [
        (h_state.get(0) + a) & 0xFFFFFFFF,
        (h_state.get(1) + b) & 0xFFFFFFFF,
        (h_state.get(2) + c) & 0xFFFFFFFF,
        (h_state.get(3) + d) & 0xFFFFFFFF,
        (h_state.get(4) + e) & 0xFFFFFFFF,
        (h_state.get(5) + f) & 0xFFFFFFFF,
        (h_state.get(6) + g) & 0xFFFFFFFF,
        (h_state.get(7) + hh) & 0xFFFFFFFF
    ]

fn _cose_sha256_list(bytes: list) -> list:
    val padded = _cose_sha256_pad(bytes)
    var h = _cose_sha256_init_h()
    var i = 0
    while i < padded.len():
        var block = []
        var j = 0
        while j < 64:
            block.push(padded.get(i + j))
            j = j + 1
        h = _cose_sha256_compress(h, block)
        i = i + 64
    var result = []
    i = 0
    while i < 8:
        val v = h.get(i)
        result.push((v >> 24) & 0xFF)
        result.push((v >> 16) & 0xFF)
        result.push((v >> 8) & 0xFF)
        result.push(v & 0xFF)
        i = i + 1
    result

# ============================================================================
# Internal: HMAC-SHA-256 over [u8] key and [u8] message → 32-byte [u8]
# ============================================================================

fn _cose_hmac_sha256(key: [u8], message: [u8]) -> [u8]:
    """HMAC-SHA-256 (FIPS 198-1) over raw byte arrays."""
    val block_size: i64 = 64
    # Prepare key as list (hash if >block_size)
    var k = []
    var i: u64 = 0
    if key.len().to_i64() > block_size:
        var kl = []
        while i < key.len():
            kl.push(key[i].to_i64())
            i = i + 1
        k = _cose_sha256_list(kl)
    else:
        while i < key.len():
            k.push(key[i].to_i64())
            i = i + 1
    while k.len() < block_size:
        k.push(0)
    # Build padded keys
    var i_key_pad = []
    var o_key_pad = []
    var j = 0
    while j < block_size:
        i_key_pad.push(k.get(j) ^ 0x36)
        o_key_pad.push(k.get(j) ^ 0x5c)
        j = j + 1
    # inner = SHA256(i_key_pad || message)
    var inner_input = []
    j = 0
    while j < i_key_pad.len():
        inner_input.push(i_key_pad.get(j))
        j = j + 1
    i = 0
    while i < message.len():
        inner_input.push(message[i].to_i64())
        i = i + 1
    val inner_hash = _cose_sha256_list(inner_input)
    # outer = SHA256(o_key_pad || inner_hash)
    var outer_input = []
    j = 0
    while j < o_key_pad.len():
        outer_input.push(o_key_pad.get(j))
        j = j + 1
    j = 0
    while j < inner_hash.len():
        outer_input.push(inner_hash.get(j))
        j = j + 1
    val out_list = _cose_sha256_list(outer_input)
    var result: [u8] = []
    j = 0
    while j < out_list.len():
        result.push(out_list.get(j).to_u8())
        j = j + 1
    result

# ============================================================================
# Internal: build protected header CBOR bytes
#
# Protected header = CBOR map {1: alg_id} serialised as a bstr
# (RFC 9052 §3: protected headers MUST be a serialised CBOR map)
# ============================================================================

fn _cose_make_protected(alg_id: i64) -> [i64]:
    """Encode protected header as CBOR bstr containing {1: alg_id}."""
    # Map header: {1 entry}
    val map_hdr = cbor_encode_map_header(1)
    # Key = 1 (alg label), Value = alg_id
    val key_bytes = cbor_encode_int(1)
    val val_bytes = cbor_encode_int(alg_id)
    val map_content = _i64_concat(_i64_concat(map_hdr, key_bytes), val_bytes)
    # Wrap as bstr
    cbor_encode_bytes(map_content)

fn _cose_empty_map() -> [i64]:
    """CBOR empty map {} — used as unprotected headers."""
    cbor_encode_map_header(0)

fn _cose_nil_bytes_cbor() -> [i64]:
    """CBOR nil bytes (bstr of length 0) — used for empty external_aad."""
    cbor_encode_bytes([])

# ============================================================================
# Internal: build Sig_structure / MAC_structure to-be-signed/maced bytes
# ============================================================================

fn _cose_build_sig_structure(protected_bstr: [i64], payload: [u8]) -> [u8]:
    """Build ToBeSigned for COSE_Sign1 per RFC 9052 §4.4.
    Sig_structure = ["Signature1", protected_bstr, external_aad, payload]
    external_aad = h'' (empty bstr)."""
    # Array of 4 elements
    val arr_hdr = cbor_encode_array_header(4)
    # "Signature1" text
    val ctx_text = cbor_encode_text("Signature1")
    # protected_bstr already encoded as bstr
    # external_aad = empty bstr
    val ext_aad = _cose_nil_bytes_cbor()
    # payload as bstr
    val payload_cbor = cbor_encode_bytes(_u8_to_i64(payload))

    val structure = _i64_concat(
        _i64_concat(
            _i64_concat(
                _i64_concat(arr_hdr, ctx_text),
                protected_bstr
            ),
            ext_aad
        ),
        payload_cbor
    )
    _i64_to_u8(structure)

fn _cose_build_mac_structure(protected_bstr: [i64], payload: [u8]) -> [u8]:
    """Build ToBeMAC'd for COSE_Mac0 per RFC 9052 §6.2.
    MAC_structure = ["MAC0", protected_bstr, external_aad, payload]
    external_aad = h'' (empty bstr)."""
    val arr_hdr = cbor_encode_array_header(4)
    val ctx_text = cbor_encode_text("MAC0")
    val ext_aad = _cose_nil_bytes_cbor()
    val payload_cbor = cbor_encode_bytes(_u8_to_i64(payload))

    val structure = _i64_concat(
        _i64_concat(
            _i64_concat(
                _i64_concat(arr_hdr, ctx_text),
                protected_bstr
            ),
            ext_aad
        ),
        payload_cbor
    )
    _i64_to_u8(structure)

# ============================================================================
# Internal: sign dispatch
# ============================================================================

fn _cose_sign(alg_id: i64, key: [u8], to_be_signed: [u8]) -> [u8]:
    """Dispatch signing by algorithm id. Returns raw signature bytes."""
    if alg_id == cose_alg_eddsa():
        # Ed25519: key is 32-byte seed
        val kp = ed25519_keypair_from_seed(key)
        val seed = kp.0
        val pub_key = kp.1
        ed25519_sign(seed, pub_key, to_be_signed)
    else:
        if alg_id == cose_alg_es256():
            # ECDSA P-256: key is PKCS#8 DER
            ecdsa_p256_sign_fixed(key, to_be_signed)
        else:
            # HS256 — not used for Sign1 (it's MAC); return empty to signal error
            []

fn _cose_verify_sig(alg_id: i64, key: [u8], to_be_signed: [u8], signature: [u8]) -> bool:
    """Dispatch signature verification by algorithm id."""
    if alg_id == cose_alg_eddsa():
        # Ed25519: key is 32-byte compressed public key
        ed25519_verify(key, to_be_signed, signature)
    else:
        if alg_id == cose_alg_es256():
            # ECDSA P-256: key is SPKI DER
            ecdsa_p256_verify_fixed(key, to_be_signed, signature)
        else:
            false

# ============================================================================
# Internal: encode COSE_Sign1 / COSE_Mac0 CBOR structures
# ============================================================================

fn _cose_encode_sign1(protected_bstr: [i64], payload: [u8], signature: [u8]) -> [u8]:
    """Encode COSE_Sign1 as tagged CBOR array.
    Structure: tag(18) + [protected_bstr, {}, payload_bstr, signature_bstr]"""
    val arr_hdr = cbor_encode_array_header(4)
    val unprotected = _cose_empty_map()
    val payload_bstr = cbor_encode_bytes(_u8_to_i64(payload))
    val sig_bstr = cbor_encode_bytes(_u8_to_i64(signature))

    val inner = _i64_concat(
        _i64_concat(
            _i64_concat(
                _i64_concat(arr_hdr, protected_bstr),
                unprotected
            ),
            payload_bstr
        ),
        sig_bstr
    )
    val tagged = cbor_encode_tagged(cose_tag_sign1(), inner)
    _i64_to_u8(tagged)

fn _cose_encode_mac0(protected_bstr: [i64], payload: [u8], mac_tag: [u8]) -> [u8]:
    """Encode COSE_Mac0 as tagged CBOR array.
    Structure: tag(17) + [protected_bstr, {}, payload_bstr, tag_bstr]"""
    val arr_hdr = cbor_encode_array_header(4)
    val unprotected = _cose_empty_map()
    val payload_bstr = cbor_encode_bytes(_u8_to_i64(payload))
    val tag_bstr = cbor_encode_bytes(_u8_to_i64(mac_tag))

    val inner = _i64_concat(
        _i64_concat(
            _i64_concat(
                _i64_concat(arr_hdr, protected_bstr),
                unprotected
            ),
            payload_bstr
        ),
        tag_bstr
    )
    val tagged = cbor_encode_tagged(cose_tag_mac0(), inner)
    _i64_to_u8(tagged)

# ============================================================================
# Internal: decode helpers
#
# COSE_Sign1 wire = tag(18) + array[protected_bstr, unprotected_map,
#                                   payload_bstr, signature_bstr]
# We decode: tag → skip, array header → skip, then 4 bstr/map items.
# ============================================================================

fn _cose_decode_inner(bytes_i64: [i64], offset: i64) -> ([i64], [i64], [i64], [i64], bool):
    """Decode the inner array of a COSE_Sign1 or COSE_Mac0.
    Returns (protected_bstr, payload_bstr, last_bstr, remaining_i64, ok).
    Caller provides offset pointing to the array header."""
    # Decode array header — expect 4 elements
    val arr = cbor_decode_array_header(bytes_i64, offset)
    val arr_count = arr.0
    val arr_consumed = arr.2
    if arr_count != 4:
        return ([], [], [], [], false)

    var pos = offset + arr_consumed

    # Element 0: protected headers (bstr)
    val prot = cbor_decode_bytes(bytes_i64, pos)
    val prot_bytes = prot.0
    val prot_consumed = prot.1
    if prot_consumed == 0:
        return ([], [], [], [], false)
    # Re-encode as bstr for Sig_structure (need the original encoded form)
    val prot_bstr = cbor_encode_bytes(prot_bytes)
    pos = pos + prot_consumed

    # Element 1: unprotected headers (map — skip over it)
    val unprotected_size = cbor_item_size(bytes_i64, pos)
    if unprotected_size == 0:
        return ([], [], [], [], false)
    pos = pos + unprotected_size

    # Element 2: payload (bstr)
    val payload = cbor_decode_bytes(bytes_i64, pos)
    val payload_bytes = payload.0
    val payload_consumed = payload.1
    if payload_consumed == 0:
        return ([], [], [], [], false)
    pos = pos + payload_consumed

    # Element 3: signature or mac tag (bstr)
    val last = cbor_decode_bytes(bytes_i64, pos)
    val last_bytes = last.0
    val last_consumed = last.1
    if last_consumed == 0:
        return ([], [], [], [], false)

    (prot_bstr, prot_bytes, payload_bytes, last_bytes, true)

fn _cose_parse_alg_from_protected(prot_bytes: [i64]) -> i64:
    """Extract alg integer from CBOR map {1: alg_id}.
    Returns alg_id, or 0 if not found."""
    # prot_bytes is the inner CBOR map {1: alg_id}.
    # For a 1-entry map, header is 0xa1 (1 byte). Walk manually.
    if prot_bytes.len() == 0:
        return 0
    # Skip the map header byte(s)
    # map header = cbor_encode_map_header(1) which for count=1 is [0xa1] (1 byte)
    var key_offset = 1
    # Decode the key (should be int 1 = 0x01)
    if key_offset >= prot_bytes.len():
        return 0
    val key_byte = prot_bytes[key_offset]
    # CBOR unsigned int 1 = 0x01 (major 0, additional 1)
    if key_byte != 1:
        return 0
    val val_offset = key_offset + 1
    if val_offset >= prot_bytes.len():
        return 0
    # Decode value: CBOR int (may be negative for ES256=-7, EdDSA=-8, positive for HS256=5)
    val val_byte = prot_bytes[val_offset]
    # Positive int (major 0): value = val_byte & 0x1F if <= 23
    val major = val_byte >> 5
    val additional = val_byte & 0x1F
    if major == 0:
        # Unsigned int
        if additional <= 23:
            return additional
        return 0
    if major == 1:
        # Negative int: value = -1 - additional (for small values)
        if additional <= 23:
            return -1 - additional
        # 1-byte extended negative: -1 - next byte
        if additional == 24:
            if val_offset + 1 < prot_bytes.len():
                return -1 - prot_bytes[val_offset + 1]
        return 0
    0

# ============================================================================
# Public API: COSE_Sign1
# ============================================================================

fn cose_sign1_create(payload: [u8], alg_id: i64, key: [u8]) -> [u8]:
    """Create a COSE_Sign1 message.

    payload:  arbitrary bytes to protect
    alg_id:   cose_alg_eddsa() or cose_alg_es256()
    key:      Ed25519 seed (32 bytes) or ECDSA P-256 PKCS#8 DER

    Returns CBOR-encoded COSE_Sign1 bytes (tag 18).
    Returns empty [u8] on sign failure."""
    val protected_bstr = _cose_make_protected(alg_id)
    val to_be_signed = _cose_build_sig_structure(protected_bstr, payload)
    val signature = _cose_sign(alg_id, key, to_be_signed)
    if signature.len() == 0:
        return []
    _cose_encode_sign1(protected_bstr, payload, signature)

fn cose_sign1_verify(cose_bytes: [u8], alg_id: i64, key: [u8]) -> CoseVerifyResult:
    """Verify a COSE_Sign1 message.

    cose_bytes: CBOR bytes from cose_sign1_create (tag 18)
    alg_id:     expected algorithm id (must match protected headers)
    key:        Ed25519 pub key (32 bytes) or ECDSA SPKI DER

    Returns CoseVerifyResult.Ok(payload) on success."""
    val bytes_i64 = _u8_to_i64(cose_bytes)
    if bytes_i64.len() == 0:
        return CoseVerifyResult.Err(CoseError.InvalidStructure("empty input"))

    # Decode outer tag (optional — some implementations omit it)
    var inner_offset = 0
    val tag_result = cbor_decode_tag(bytes_i64, 0)
    val tag_num = tag_result.0
    val tag_consumed = tag_result.1
    if tag_consumed > 0:
        if tag_num != cose_tag_sign1():
            return CoseVerifyResult.Err(CoseError.InvalidStructure("expected tag 18 (COSE_Sign1)"))
        inner_offset = tag_consumed

    val decoded = _cose_decode_inner(bytes_i64, inner_offset)
    val prot_bstr = decoded.0
    val prot_content = decoded.1
    val payload_bytes = decoded.2
    val sig_bytes = decoded.3
    val ok = decoded.4
    if not ok:
        return CoseVerifyResult.Err(CoseError.InvalidStructure("malformed COSE_Sign1 array"))

    # Check alg in protected headers matches expected
    val found_alg = _cose_parse_alg_from_protected(prot_content)
    if found_alg != alg_id:
        return CoseVerifyResult.Err(CoseError.AlgorithmRejected("alg mismatch in protected headers"))

    val to_be_signed = _cose_build_sig_structure(prot_bstr, _i64_to_u8(payload_bytes))
    val valid = _cose_verify_sig(alg_id, key, to_be_signed, _i64_to_u8(sig_bytes))
    if not valid:
        return CoseVerifyResult.Err(CoseError.SignatureMismatch)

    CoseVerifyResult.Ok(_i64_to_u8(payload_bytes))

# ============================================================================
# Public API: COSE_Mac0
# ============================================================================

fn cose_mac0_create(payload: [u8], key: [u8]) -> [u8]:
    """Create a COSE_Mac0 message using HMAC-SHA-256.

    payload: arbitrary bytes to MAC
    key:     HMAC-SHA-256 symmetric key (any length; ≥32 bytes recommended)

    Returns CBOR-encoded COSE_Mac0 bytes (tag 17)."""
    val protected_bstr = _cose_make_protected(cose_alg_hs256())
    val to_be_maced = _cose_build_mac_structure(protected_bstr, payload)
    val mac_tag = _cose_hmac_sha256(key, to_be_maced)
    _cose_encode_mac0(protected_bstr, payload, mac_tag)

fn cose_mac0_verify(cose_bytes: [u8], key: [u8]) -> CoseVerifyResult:
    """Verify a COSE_Mac0 message using HMAC-SHA-256.

    cose_bytes: CBOR bytes from cose_mac0_create (tag 17)
    key:        HMAC-SHA-256 symmetric key

    Returns CoseVerifyResult.Ok(payload) on success."""
    val bytes_i64 = _u8_to_i64(cose_bytes)
    if bytes_i64.len() == 0:
        return CoseVerifyResult.Err(CoseError.InvalidStructure("empty input"))

    var inner_offset = 0
    val tag_result = cbor_decode_tag(bytes_i64, 0)
    val tag_num = tag_result.0
    val tag_consumed = tag_result.1
    if tag_consumed > 0:
        if tag_num != cose_tag_mac0():
            return CoseVerifyResult.Err(CoseError.InvalidStructure("expected tag 17 (COSE_Mac0)"))
        inner_offset = tag_consumed

    val decoded = _cose_decode_inner(bytes_i64, inner_offset)
    val prot_bstr = decoded.0
    val prot_content = decoded.1
    val payload_bytes = decoded.2
    val mac_bytes = decoded.3
    val ok = decoded.4
    if not ok:
        return CoseVerifyResult.Err(CoseError.InvalidStructure("malformed COSE_Mac0 array"))

    val to_be_maced = _cose_build_mac_structure(prot_bstr, _i64_to_u8(payload_bytes))
    val expected_mac = _cose_hmac_sha256(key, to_be_maced)
    if not _cose_ct_eq(expected_mac, _i64_to_u8(mac_bytes)):
        return CoseVerifyResult.Err(CoseError.SignatureMismatch)

    CoseVerifyResult.Ok(_i64_to_u8(payload_bytes))
