# CRC-32 (IEEE 802.3) and CRC-32C (Castagnoli) — Pure Simple Implementation
#
# Two standard CRC-32 variants:
#   crc32  — IEEE 802.3 poly 0xEDB88320 (reflected 0x04C11DB7)
#             Used by: gzip, Ethernet, PNG, ZIP
#   crc32c — Castagnoli poly 0x82F63B78 (reflected 0x1EDC6F41)
#             Used by: iSCSI, Btrfs, SCTP, NVMe
#
# Both use:
#   - 256-entry lookup table (table-driven, byte-at-a-time)
#   - init  = 0xFFFFFFFF
#   - xorout = 0xFFFFFFFF
#   - refin = refout = true  (reflected input/output)
#
# Reference: ISO 3309, ITU-T V.42 (IEEE), IETF RFC 3720 (Castagnoli)
# ============================================================================

# ============================================================================
# Table generation
# ============================================================================

extern fn rt_typed_bytes_u32_le_at(buf: [u8], off: u64) -> u64
extern fn rt_typed_bytes_u8_unchecked(buf: [u8], off: u64) -> u64
extern fn rt_typed_bytes_u64_le_unchecked(buf: [u8], off: u64) -> u64

var _IEEE_TABLE_CACHE: [u8] = []
var _IEEE_TABLE_READY: bool = false
var _CASTAGNOLI_TABLE_CACHE: [u8] = []
var _CASTAGNOLI_TABLE_READY: bool = false

fn _push_u32_le(tbl: [u8], value: u32) -> [u8]:
    var out = tbl
    out.push((value & 0xFF).to_u8())
    out.push(((value >> 8) & 0xFF).to_u8())
    out.push(((value >> 16) & 0xFF).to_u8())
    out.push(((value >> 24) & 0xFF).to_u8())
    out

fn _make_table(poly: u32) -> [u8]:
    var tbl: [u8] = []
    var i: u32 = 0
    while i < 256:
        var crc: u32 = i
        var bit: u32 = 0
        while bit < 8:
            if (crc & 1) == 1:
                crc = (crc >> 1) ^ poly
            else:
                crc = crc >> 1
            bit = bit + 1
        tbl = _push_u32_le(tbl, crc)
        i = i + 1
    tbl

fn _ieee_table() -> [u8]:
    if not _IEEE_TABLE_READY:
        _IEEE_TABLE_CACHE = _make_table(0xEDB88320)
        _IEEE_TABLE_READY = true
    _IEEE_TABLE_CACHE

fn _castagnoli_table() -> [u8]:
    if not _CASTAGNOLI_TABLE_READY:
        _CASTAGNOLI_TABLE_CACHE = _make_table(0x82F63B78)
        _CASTAGNOLI_TABLE_READY = true
    _CASTAGNOLI_TABLE_CACHE

# ============================================================================
# Core engine
# ============================================================================

fn _crc32_update_table(state: u32, data: [u8], tbl: [u8]) -> u32:
    var crc: u32 = state
    var length = data.len().to_u64()
    var i: u64 = 0u64
    while (i + 8u64) <= length:
        val word = rt_typed_bytes_u64_le_unchecked(data, i)
        var byte_val: u32 = (word & 0xFFu64).to_u32()
        var idx: u32 = (crc ^ byte_val) & 0xFF
        crc = (crc >> 8) ^ rt_typed_bytes_u32_le_at(tbl, idx.to_u64() * 4u64).to_u32()
        byte_val = ((word >> 8u64) & 0xFFu64).to_u32()
        idx = (crc ^ byte_val) & 0xFF
        crc = (crc >> 8) ^ rt_typed_bytes_u32_le_at(tbl, idx.to_u64() * 4u64).to_u32()
        byte_val = ((word >> 16u64) & 0xFFu64).to_u32()
        idx = (crc ^ byte_val) & 0xFF
        crc = (crc >> 8) ^ rt_typed_bytes_u32_le_at(tbl, idx.to_u64() * 4u64).to_u32()
        byte_val = ((word >> 24u64) & 0xFFu64).to_u32()
        idx = (crc ^ byte_val) & 0xFF
        crc = (crc >> 8) ^ rt_typed_bytes_u32_le_at(tbl, idx.to_u64() * 4u64).to_u32()
        byte_val = ((word >> 32u64) & 0xFFu64).to_u32()
        idx = (crc ^ byte_val) & 0xFF
        crc = (crc >> 8) ^ rt_typed_bytes_u32_le_at(tbl, idx.to_u64() * 4u64).to_u32()
        byte_val = ((word >> 40u64) & 0xFFu64).to_u32()
        idx = (crc ^ byte_val) & 0xFF
        crc = (crc >> 8) ^ rt_typed_bytes_u32_le_at(tbl, idx.to_u64() * 4u64).to_u32()
        byte_val = ((word >> 48u64) & 0xFFu64).to_u32()
        idx = (crc ^ byte_val) & 0xFF
        crc = (crc >> 8) ^ rt_typed_bytes_u32_le_at(tbl, idx.to_u64() * 4u64).to_u32()
        byte_val = ((word >> 56u64) & 0xFFu64).to_u32()
        idx = (crc ^ byte_val) & 0xFF
        crc = (crc >> 8) ^ rt_typed_bytes_u32_le_at(tbl, idx.to_u64() * 4u64).to_u32()
        i = i + 8u64
    while i < length:
        val idx: u32 = (crc ^ rt_typed_bytes_u8_unchecked(data, i).to_u32()) & 0xFF
        crc = (crc >> 8) ^ rt_typed_bytes_u32_le_at(tbl, idx.to_u64() * 4u64).to_u32()
        i = i + 1u64
    crc

# ============================================================================
# Public API — CRC-32 IEEE 802.3 (one-shot and streaming)
# ============================================================================

fn crc32_init() -> u32:
    0xFFFFFFFF

fn crc32_update(state: u32, data: [u8]) -> u32:
    _crc32_update_table(state, data, _ieee_table())

fn crc32_finalize(state: u32) -> u32:
    state ^ 0xFFFFFFFF

fn crc32(data: [u8]) -> u32:
    crc32_finalize(crc32_update(crc32_init(), data))

# ============================================================================
# Public API — CRC-32C Castagnoli (one-shot and streaming)
# ============================================================================

fn crc32c_init() -> u32:
    0xFFFFFFFF

fn crc32c_update(state: u32, data: [u8]) -> u32:
    _crc32_update_table(state, data, _castagnoli_table())

fn crc32c_finalize(state: u32) -> u32:
    state ^ 0xFFFFFFFF

fn crc32c(data: [u8]) -> u32:
    crc32c_finalize(crc32c_update(crc32c_init(), data))

# ============================================================================
# Per-element update wrappers (pattern-matchable by compiler intrinsic engine)
# ============================================================================

fn update_byte(state: u32, byte: u8) -> u32:
    val tbl = _ieee_table()
    val idx: u32 = (state ^ byte.to_u32()) & 0xFF
    (state >> 8) ^ rt_typed_bytes_u32_le_at(tbl, idx.to_u64() * 4u64).to_u32()

fn update_u32(state: u32, word: u32) -> u32:
    var crc = state
    val tbl = _ieee_table()
    var i = 0
    while i < 4:
        val byte: u32 = (word >> (i * 8)) & 0xFF
        val idx: u32 = (crc ^ byte) & 0xFF
        crc = (crc >> 8) ^ rt_typed_bytes_u32_le_at(tbl, idx.to_u64() * 4u64).to_u32()
        i = i + 1
    crc

fn update_u64(state: u32, qword: u64) -> u32:
    var crc = state
    val tbl = _ieee_table()
    var i = 0
    while i < 8:
        val byte: u32 = ((qword >> (i * 8)) & 0xFF).to_u32()
        val idx: u32 = (crc ^ byte) & 0xFF
        crc = (crc >> 8) ^ rt_typed_bytes_u32_le_at(tbl, idx.to_u64() * 4u64).to_u32()
        i = i + 1
    crc
