# ============================================================================
# System parameters FK and constant key CK
# ============================================================================

fn _sm4_fk() -> [u32]:
    """FK system parameters."""
    var fk: [u32] = []
    var v: u32 = 0xA3B1BAC6
    fk.push(v)
    v = 0x56AA3350
    fk.push(v)
    v = 0x677D9197
    fk.push(v)
    v = 0xB27022DC
    fk.push(v)
    fk

fn _sm4_ck() -> [u32]:
    """CK constant key array (GM/T 0002-2012 Table 2), 32 words."""
    var ck: [u32] = []
    var v: u32 = 0x00070E15
    ck.push(v)
    v = 0x1C232A31
    ck.push(v)
    v = 0x383F464D
    ck.push(v)
    v = 0x545B6269
    ck.push(v)
    v = 0x70777E85
    ck.push(v)
    v = 0x8C939AA1
    ck.push(v)
    v = 0xA8AFB6BD
    ck.push(v)
    v = 0xC4CBD2D9
    ck.push(v)
    v = 0xE0E7EEF5
    ck.push(v)
    v = 0xFC030A11
    ck.push(v)
    v = 0x181F262D
    ck.push(v)
    v = 0x343B4249
    ck.push(v)
    v = 0x50575E65
    ck.push(v)
    v = 0x6C737A81
    ck.push(v)
    v = 0x888F969D
    ck.push(v)
    v = 0xA4ABB2B9
    ck.push(v)
    v = 0xC0C7CED5
    ck.push(v)
    v = 0xDCE3EAF1
    ck.push(v)
