# ============================================================================
# tau: apply S-box to each byte of a u32 word
# ============================================================================

fn _sm4_tau(sbox: [u8], word: u32) -> u32:
    """Apply S-box substitution to each of the 4 bytes of word."""
    val b0 = sbox[((word >> 24) & 0xFF).to_i64()].to_u32()
    val b1 = sbox[((word >> 16) & 0xFF).to_i64()].to_u32()
    val b2 = sbox[((word >> 8) & 0xFF).to_i64()].to_u32()
    val b3 = sbox[(word & 0xFF).to_i64()].to_u32()
    (b0 << 24) | (b1 << 16) | (b2 << 8) | b3

# ============================================================================
# Linear transform L (round function)
# L(B) = B XOR (B<<<2) XOR (B<<<10) XOR (B<<<18) XOR (B<<<24)
# ============================================================================

fn _sm4_L(b: u32) -> u32:
    """SM4 linear transform L for the round function."""
    val r2 = _sm4_rotl32(b, 2)
    val r10 = _sm4_rotl32(b, 10)
    val r18 = _sm4_rotl32(b, 18)
    val r24 = _sm4_rotl32(b, 24)
    b ^ r2 ^ r10 ^ r18 ^ r24

# ============================================================================
# Linear transform L' (key expansion)
# L'(B) = B XOR (B<<<13) XOR (B<<<23)
# ============================================================================

fn _sm4_L_prime(b: u32) -> u32:
    """SM4 linear transform L' for the key schedule."""
    val r13 = _sm4_rotl32(b, 13)
    val r23 = _sm4_rotl32(b, 23)
    b ^ r13 ^ r23

# ============================================================================
# T transform (round): T(A) = L(tau(A))
# T' transform (key schedule): T'(A) = L'(tau(A))
# ============================================================================

fn _sm4_T(sbox: [u8], a: u32) -> u32:
    """Full nonlinear transform T = L(tau(A)) for the round function."""
    _sm4_L(_sm4_tau(sbox, a))

fn _sm4_T_prime(sbox: [u8], a: u32) -> u32:
    """Full nonlinear transform T' = L'(tau(A)) for the key schedule."""
    _sm4_L_prime(_sm4_tau(sbox, a))

# ============================================================================
# Block I/O — big-endian byte <-> u32 word conversion
# ============================================================================

fn _sm4_load_block_be(b: [u8]) -> [u32]:
    """Load 16 bytes as 4 u32 words, big-endian (SM4 standard)."""
    var out: [u32] = []
    var i: i64 = 0
    while i < 4:
        val base = i * 4
        val word = (b[base].to_u32() << 24) |
                   (b[base + 1].to_u32() << 16) |
                   (b[base + 2].to_u32() << 8) |
                   b[base + 3].to_u32()
        out.push(word)
        i = i + 1
    out

fn _sm4_store_block_be(words: [u32]) -> [u8]:
    """Store 4 u32 words as 16 bytes, big-endian."""
    var out: [u8] = []
    var i: i64 = 0
    while i < 4:
        val w = words[i]
        out.push(((w >> 24) & 0xFF).to_u8())
        out.push(((w >> 16) & 0xFF).to_u8())
        out.push(((w >> 8) & 0xFF).to_u8())
        out.push((w & 0xFF).to_u8())
        i = i + 1
    out

# ============================================================================
# Key expansion — expand 128-bit key to 32 round keys
# ============================================================================

fn sm4_key_expand(key: [u8]) -> [u32]:
    """Expand a 16-byte key to 32 u32 round keys.

    Algorithm:
    1. Load key as 4 big-endian u32 words MK[0..3]
    2. K[i] = MK[i] XOR FK[i]  for i = 0..3
    3. rk[i] = K[i+4] = K[i] XOR T'(K[i+1] XOR K[i+2] XOR K[i+3] XOR CK[i])
    """
    val sbox = _sm4_sbox()
    val fk = _sm4_fk()
    val ck = _sm4_ck()

    # Load key as big-endian u32
    val mk = _sm4_load_block_be(key)

    # Initialize K[0..3] = MK XOR FK
    var K: [u32] = []
    var ki: i64 = 0
    while ki < 4:
        K.push(mk[ki] ^ fk[ki])
        ki = ki + 1

    # Generate 32 round keys
    var rk: [u32] = []
    var i: i64 = 0
    while i < 32:
        val t = K[i] ^ _sm4_T_prime(sbox, K[i + 1] ^ K[i + 2] ^ K[i + 3] ^ ck[i])
        rk.push(t)
        K.push(t)
        i = i + 1

    rk

# ============================================================================
# Core encrypt/decrypt function — takes pre-expanded round keys
# Decrypt uses reversed round keys (rk[31..0])
# ============================================================================

fn _sm4_crypt_core(sbox: [u8], rk: [u32], block: [u8]) -> [u8]:
    """Apply 32 SM4 rounds to block using provided round keys.

    Output is (X[35], X[34], X[33], X[32]) — SM4 R-transform reversal.
    """
    var X = _sm4_load_block_be(block)

    # 32 rounds
    var r: i64 = 0
    while r < 32:
        val t = X[r] ^ _sm4_T(sbox, X[r + 1] ^ X[r + 2] ^ X[r + 3] ^ rk[r])
        X.push(t)
        r = r + 1

    # R-transform: output = (X[35], X[34], X[33], X[32])
    var result: [u32] = []
    result.push(X[35])
    result.push(X[34])
    result.push(X[33])
    result.push(X[32])

    _sm4_store_block_be(result)

# ============================================================================
# Public API
# ============================================================================

fn sm4_encrypt_block(key: [u8], plaintext: [u8]) -> [u8]:
    """Encrypt a 16-byte block using the given 16-byte key.

    Returns 16 ciphertext bytes.  Both key and plaintext must be exactly
    16 bytes.  Byte order follows GM/T 0002-2012 (big-endian).
    """
    val sbox = _sm4_sbox()
    val rk = sm4_key_expand(key)
    _sm4_crypt_core(sbox, rk, plaintext)

fn sm4_decrypt_block(key: [u8], ciphertext: [u8]) -> [u8]:
    """Decrypt a 16-byte block using the given 16-byte key.

    Decryption is identical to encryption with the round keys reversed.
    Returns 16 plaintext bytes.
    """
    val sbox = _sm4_sbox()
    val rk_fwd = sm4_key_expand(key)

    # Reverse round keys
    var rk: [u32] = []
    var i: i64 = 31
    while i >= 0:
        rk.push(rk_fwd[i])
        i = i - 1

    _sm4_crypt_core(sbox, rk, ciphertext)
