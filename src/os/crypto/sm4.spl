"""
SM4 Block Cipher — Pure Simple Implementation

Chinese national standard GB/T 32907-2016 (also GM/T 0002-2012).
128-bit block, 128-bit key, 32-round Feistel-like structure.

Byte order: big-endian (SM4 standard).  Block[0] is the high byte of X[0].
Output reversal: ciphertext = (X[35], X[34], X[33], X[32]).

Reference: GM/T 0002-2012 / GB/T 32907-2016
https://www.gmbz.org.cn/upload/2018-07-24/1532401392842079739.pdf

Exposed API:
  sm4_key_expand(key: [u8]) -> [u32]
  sm4_encrypt_block(key: [u8], plaintext: [u8]) -> [u8]
  sm4_decrypt_block(key: [u8], ciphertext: [u8]) -> [u8]

No SFFI/Rust FFI — pure Simple, suitable for baremetal.

Interpreter note: local [u32] var push is broken in the interpreter; all
array-building uses the parameter-push workaround (push into a parameter
array, not a local var). See feedback_it_block_var_mutation.md.
"""

# ============================================================================
# 32-bit rotation helper
# ============================================================================

fn _sm4_rotl32(x: u32, n: u32) -> u32:
    """Left-rotate x by n bits (32-bit)."""
    ((x << n) | (x >> (32 - n))) & 0xFFFFFFFF

# ============================================================================
# SM4 S-box (GB/T 32907-2016 Appendix A, Table 1) — 256 bytes
# ============================================================================

fn _sm4_sbox() -> [u8]:
    [
        0xD6u8, 0x90u8, 0xE9u8, 0xFEu8, 0xCCu8, 0xE1u8, 0x3Du8, 0xB7u8,
        0x16u8, 0xB6u8, 0x14u8, 0xC2u8, 0x28u8, 0xFBu8, 0x2Cu8, 0x05u8,
        0x2Bu8, 0x67u8, 0x9Au8, 0x76u8, 0x2Au8, 0xBEu8, 0x04u8, 0xC3u8,
        0xAAu8, 0x44u8, 0x13u8, 0x26u8, 0x49u8, 0x86u8, 0x06u8, 0x99u8,
        0x9Cu8, 0x42u8, 0x50u8, 0xF4u8, 0x91u8, 0xEFu8, 0x98u8, 0x7Au8,
        0x33u8, 0x54u8, 0x0Bu8, 0x43u8, 0xEDu8, 0xCFu8, 0xACu8, 0x62u8,
        0xE4u8, 0xB3u8, 0x1Cu8, 0xA9u8, 0xC9u8, 0x08u8, 0xE8u8, 0x95u8,
        0x80u8, 0xDFu8, 0x94u8, 0xFAu8, 0x75u8, 0x8Fu8, 0x3Fu8, 0xA6u8,
        0x47u8, 0x07u8, 0xA7u8, 0xFCu8, 0xF3u8, 0x73u8, 0x17u8, 0xBAu8,
        0x83u8, 0x59u8, 0x3Cu8, 0x19u8, 0xE6u8, 0x85u8, 0x4Fu8, 0xA8u8,
        0x68u8, 0x6Bu8, 0x81u8, 0xB2u8, 0x71u8, 0x64u8, 0xDAu8, 0x8Bu8,
        0xF8u8, 0xEBu8, 0x0Fu8, 0x4Bu8, 0x70u8, 0x56u8, 0x9Du8, 0x35u8,
        0x1Eu8, 0x24u8, 0x0Eu8, 0x5Eu8, 0x63u8, 0x58u8, 0xD1u8, 0xA2u8,
        0x25u8, 0x22u8, 0x7Cu8, 0x3Bu8, 0x01u8, 0x21u8, 0x78u8, 0x87u8,
        0xD4u8, 0x00u8, 0x46u8, 0x57u8, 0x9Fu8, 0xD3u8, 0x27u8, 0x52u8,
        0x4Cu8, 0x36u8, 0x02u8, 0xE7u8, 0xA0u8, 0xC4u8, 0xC8u8, 0x9Eu8,
        0xEAu8, 0xBFu8, 0x8Au8, 0xD2u8, 0x40u8, 0xC7u8, 0x38u8, 0xB5u8,
        0xA3u8, 0xF7u8, 0xF2u8, 0xCEu8, 0xF9u8, 0x61u8, 0x15u8, 0xA1u8,
        0xE0u8, 0xAEu8, 0x5Du8, 0xA4u8, 0x9Bu8, 0x34u8, 0x1Au8, 0x55u8,
        0xADu8, 0x93u8, 0x32u8, 0x30u8, 0xF5u8, 0x8Cu8, 0xB1u8, 0xE3u8,
        0x1Du8, 0xF6u8, 0xE2u8, 0x2Eu8, 0x82u8, 0x66u8, 0xCAu8, 0x60u8,
        0xC0u8, 0x29u8, 0x23u8, 0xABu8, 0x0Du8, 0x53u8, 0x4Eu8, 0x6Fu8,
        0xD5u8, 0xDBu8, 0x37u8, 0x45u8, 0xDEu8, 0xFDu8, 0x8Eu8, 0x2Fu8,
        0x03u8, 0xFFu8, 0x6Au8, 0x72u8, 0x6Du8, 0x6Cu8, 0x5Bu8, 0x51u8,
        0x8Du8, 0x1Bu8, 0xAFu8, 0x92u8, 0xBBu8, 0xDDu8, 0xBCu8, 0x7Fu8,
        0x11u8, 0xD9u8, 0x5Cu8, 0x41u8, 0x1Fu8, 0x10u8, 0x5Au8, 0xD8u8,
        0x0Au8, 0xC1u8, 0x31u8, 0x88u8, 0xA5u8, 0xCDu8, 0x7Bu8, 0xBDu8,
        0x2Du8, 0x74u8, 0xD0u8, 0x12u8, 0xB8u8, 0xE5u8, 0xB4u8, 0xB0u8,
        0x89u8, 0x69u8, 0x97u8, 0x4Au8, 0x0Cu8, 0x96u8, 0x77u8, 0x7Eu8,
        0x65u8, 0xB9u8, 0xF1u8, 0x09u8, 0xC5u8, 0x6Eu8, 0xC6u8, 0x84u8,
        0x18u8, 0xF0u8, 0x7Du8, 0xECu8, 0x3Au8, 0xDCu8, 0x4Du8, 0x20u8,
        0x79u8, 0xEEu8, 0x5Fu8, 0x3Eu8, 0xD7u8, 0xCBu8, 0x39u8, 0x48u8
    ]

# ============================================================================
# FK and CK array builders — use parameter pattern to avoid local-push bug
# ============================================================================

fn _sm4_fill_fk(fk: [u32]):
    """Fill FK system parameters into parameter array."""
    var v: u32 = 0xA3B1BAC6
    fk.push(v)
    v = 0x56AA3350
    fk.push(v)
    v = 0x677D9197
    fk.push(v)
    v = 0xB27022DC
    fk.push(v)

fn _sm4_fill_ck(ck: [u32]):
    """Fill CK constant key array (32 words) into parameter array."""
    var v: u32 = 0x00070E15
    ck.push(v)
    v = 0x1C232A31
    ck.push(v)
    v = 0x383F464D
    ck.push(v)
    v = 0x545B6269
    ck.push(v)
    v = 0x70777E85
    ck.push(v)
    v = 0x8C939AA1
    ck.push(v)
    v = 0xA8AFB6BD
    ck.push(v)
    v = 0xC4CBD2D9
    ck.push(v)
    v = 0xE0E7EEF5
    ck.push(v)
    v = 0xFC030A11
    ck.push(v)
    v = 0x181F262D
    ck.push(v)
    v = 0x343B4249
    ck.push(v)
    v = 0x50575E65
    ck.push(v)
    v = 0x6C737A81
    ck.push(v)
    v = 0x888F969D
    ck.push(v)
    v = 0xA4ABB2B9
    ck.push(v)
    v = 0xC0C7CED5
    ck.push(v)
    v = 0xDCE3EAF1
    ck.push(v)
    v = 0xF8FF060D
    ck.push(v)
    v = 0x141B2229
    ck.push(v)
    v = 0x30373E45
    ck.push(v)
    v = 0x4C535A61
    ck.push(v)
    v = 0x686F767D
    ck.push(v)
    v = 0x848B9299
    ck.push(v)
    v = 0xA0A7AEB5
    ck.push(v)
    v = 0xBCC3CAD1
    ck.push(v)
    v = 0xD8DFE6ED
    ck.push(v)
    v = 0xF4FB0209
    ck.push(v)
    v = 0x10171E25
    ck.push(v)
    v = 0x2C333A41
    ck.push(v)
    v = 0x484F565D
    ck.push(v)
    v = 0x646B7279
    ck.push(v)

# ============================================================================
# tau: apply S-box to each byte of a u32 word
# ============================================================================

fn _sm4_tau(sbox: [u8], word: u32) -> u32:
    """Apply S-box substitution to each of the 4 bytes of word."""
    val b0 = sbox[((word >> 24) & 0xFF).to_i64()].to_u32()
    val b1 = sbox[((word >> 16) & 0xFF).to_i64()].to_u32()
    val b2 = sbox[((word >> 8) & 0xFF).to_i64()].to_u32()
    val b3 = sbox[(word & 0xFF).to_i64()].to_u32()
    (b0 << 24) | (b1 << 16) | (b2 << 8) | b3

# ============================================================================
# Linear transforms
# ============================================================================

fn _sm4_L(b: u32) -> u32:
    """SM4 linear transform L for the round function.
    L(B) = B XOR (B<<<2) XOR (B<<<10) XOR (B<<<18) XOR (B<<<24)"""
    val r2 = _sm4_rotl32(b, 2)
    val r10 = _sm4_rotl32(b, 10)
    val r18 = _sm4_rotl32(b, 18)
    val r24 = _sm4_rotl32(b, 24)
    b ^ r2 ^ r10 ^ r18 ^ r24

fn _sm4_L_prime(b: u32) -> u32:
    """SM4 linear transform L' for the key schedule.
    L'(B) = B XOR (B<<<13) XOR (B<<<23)"""
    val r13 = _sm4_rotl32(b, 13)
    val r23 = _sm4_rotl32(b, 23)
    b ^ r13 ^ r23

fn _sm4_T(sbox: [u8], a: u32) -> u32:
    """Full nonlinear transform T = L(tau(A)) for the round function."""
    _sm4_L(_sm4_tau(sbox, a))

fn _sm4_T_prime(sbox: [u8], a: u32) -> u32:
    """Full nonlinear transform T' = L'(tau(A)) for the key schedule."""
    _sm4_L_prime(_sm4_tau(sbox, a))

# ============================================================================
# Block I/O — big-endian byte <-> u32 word conversion
# ============================================================================

fn _sm4_fill_block_be(b: [u8], dest: [u32]):
    """Load 16 bytes as 4 big-endian u32 words into parameter array."""
    var i: i64 = 0
    while i < 4:
        val base = i * 4
        val word = (b[base].to_u32() << 24) |
                   (b[base + 1].to_u32() << 16) |
                   (b[base + 2].to_u32() << 8) |
                   b[base + 3].to_u32()
        dest.push(word)
        i = i + 1

fn _sm4_fill_bytes_be(words: [u32], idx0: i64, idx1: i64, idx2: i64, idx3: i64, dest: [u8]):
    """Store 4 words (by explicit indices) as 16 big-endian bytes into parameter array."""
    val w0 = words[idx0]
    val w1 = words[idx1]
    val w2 = words[idx2]
    val w3 = words[idx3]
    dest.push(((w0 >> 24) & 0xFF).to_u8())
    dest.push(((w0 >> 16) & 0xFF).to_u8())
    dest.push(((w0 >> 8) & 0xFF).to_u8())
    dest.push((w0 & 0xFF).to_u8())
    dest.push(((w1 >> 24) & 0xFF).to_u8())
    dest.push(((w1 >> 16) & 0xFF).to_u8())
    dest.push(((w1 >> 8) & 0xFF).to_u8())
    dest.push((w1 & 0xFF).to_u8())
    dest.push(((w2 >> 24) & 0xFF).to_u8())
    dest.push(((w2 >> 16) & 0xFF).to_u8())
    dest.push(((w2 >> 8) & 0xFF).to_u8())
    dest.push((w2 & 0xFF).to_u8())
    dest.push(((w3 >> 24) & 0xFF).to_u8())
    dest.push(((w3 >> 16) & 0xFF).to_u8())
    dest.push(((w3 >> 8) & 0xFF).to_u8())
    dest.push((w3 & 0xFF).to_u8())

# ============================================================================
# Key expansion helpers — all use parameter-push pattern
# ============================================================================

fn _sm4_fill_K_init(mk: [u32], fk: [u32], kstate: [u32]):
    """Fill K[0..3] = MK[i] XOR FK[i] into parameter array K."""
    var i: i64 = 0
    while i < 4:
        var v: u32 = mk[i] ^ fk[i]
        kstate.push(v)
        i = i + 1

fn _sm4_fill_rk(sbox: [u8], kstate: [u32], ck: [u32], rk: [u32]):
    """Generate 32 round keys into parameter array rk; extends K as well."""
    var i: i64 = 0
    while i < 32:
        var v: u32 = kstate[i] ^ _sm4_T_prime(sbox, kstate[i + 1] ^ kstate[i + 2] ^ kstate[i + 3] ^ ck[i])
        rk.push(v)
        kstate.push(v)
        i = i + 1

fn _sm4_fill_rk_reversed(rk_fwd: [u32], rk_rev: [u32]):
    """Fill rk_rev with reversed round keys from rk_fwd."""
    var i: i64 = 31
    while i >= 0:
        var v: u32 = rk_fwd[i]
        rk_rev.push(v)
        i = i - 1

# ============================================================================
# Key expansion — expand 128-bit key to 32 round keys
# ============================================================================

fn sm4_key_expand(key: [u8]) -> [u32]:
    """Expand a 16-byte key to 32 u32 round keys.

    Algorithm (GB/T 32907-2016 §6.2):
    1. Load key as 4 big-endian u32 words MK[0..3]
    2. K[i] = MK[i] XOR FK[i]  for i = 0..3
    3. rk[i] = K[i+4] = K[i] XOR T'(K[i+1] XOR K[i+2] XOR K[i+3] XOR CK[i])
    """
    val sbox = _sm4_sbox()

    var fk: [u32] = []
    _sm4_fill_fk(fk)

    var ck: [u32] = []
    _sm4_fill_ck(ck)

    var mk: [u32] = []
    _sm4_fill_block_be(key, mk)

    var kstate: [u32] = []
    _sm4_fill_K_init(mk, fk, kstate)

    var rk: [u32] = []
    _sm4_fill_rk(sbox, kstate, ck, rk)

    rk

# ============================================================================
# Core encrypt/decrypt function
# ============================================================================

fn _sm4_crypt_core(sbox: [u8], rk: [u32], block: [u8]) -> [u8]:
    """Apply 32 SM4 rounds to block using provided round keys.

    Output is (X[35], X[34], X[33], X[32]) — SM4 R-transform reversal.
    """
    var xw: [u32] = []
    _sm4_fill_block_be(block, xw)

    # 32 rounds — push new word onto xw each round
    var r: i64 = 0
    while r < 32:
        var v: u32 = xw[r] ^ _sm4_T(sbox, xw[r + 1] ^ xw[r + 2] ^ xw[r + 3] ^ rk[r])
        xw.push(v)
        r = r + 1

    # R-transform: output = (xw[35], xw[34], xw[33], xw[32]) big-endian
    var result: [u8] = []
    _sm4_fill_bytes_be(xw, 35, 34, 33, 32, result)
    result

# ============================================================================
# Public API
# ============================================================================

fn sm4_encrypt_block(key: [u8], plaintext: [u8]) -> [u8]:
    """Encrypt a 16-byte block using the given 16-byte key.

    Returns 16 ciphertext bytes.  Both key and plaintext must be exactly
    16 bytes.  Byte order follows GM/T 0002-2012 (big-endian).
    """
    val sbox = _sm4_sbox()
    val rk = sm4_key_expand(key)
    _sm4_crypt_core(sbox, rk, plaintext)

fn sm4_decrypt_block(key: [u8], ciphertext: [u8]) -> [u8]:
    """Decrypt a 16-byte block using the given 16-byte key.

    Decryption is identical to encryption with the round keys reversed.
    Returns 16 plaintext bytes.
    """
    val sbox = _sm4_sbox()
    val rk_fwd = sm4_key_expand(key)

    var rk: [u32] = []
    _sm4_fill_rk_reversed(rk_fwd, rk)

    _sm4_crypt_core(sbox, rk, ciphertext)
