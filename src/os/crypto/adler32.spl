# Adler-32 and Fletcher-32 Checksums — Pure Simple Implementation
#
# Adler-32: RFC 1950 section 9 — used in zlib/gzip.
# Fletcher-32: lightweight checksum over 16-bit little-endian words.
#
# Both are NON-cryptographic; suitable for integrity checks only.
#
# Adler-32 initial state: A=1, B=0  →  packed state = 1
# Fletcher-32 initial state: sum1=0, sum2=0
#
# Reference: RFC 1950 (Adler-32), Fletcher (1982) (Fletcher-32)
# ============================================================================

# ============================================================================
# Adler-32 (RFC 1950 section 9)
# ============================================================================

fn adler32(data: [u8]) -> i64:
    """Compute Adler-32 checksum per RFC 1950.

    A = 1 + sum of all bytes (mod 65521)
    B = sum of running A values (mod 65521)
    Result = (B << 16) | A

    Example:
        adler32([])          # 1
        adler32([97,98,99])  # 0x024D0127
    """
    adler32_update(1, data)


fn adler32_update(state: i64, data: [u8]) -> i64:
    """Feed more bytes into a packed Adler-32 state.

    The state packs both A and B into a single i64: state = (B << 16) | A.
    Initial state is 1 (A=1, B=0).

    Example:
        val s1 = adler32_update(1, chunk1)
        val s2 = adler32_update(s1, chunk2)
    """
    var mod_val: i64 = 65521
    var a: i64 = state & 0xFFFF
    var b: i64 = (state >> 16) & 0xFFFF
    var i: i64 = 0
    while i < data.len():
        var byte_val: i64 = data[i].to_i64()
        a = (a + byte_val) % mod_val
        b = (b + a) % mod_val
        i = i + 1
    (b << 16) | a


# ============================================================================
# Fletcher-32 (16-bit little-endian word checksum)
# ============================================================================

fn fletcher32(data: [u8]) -> i64:
    """Compute Fletcher-32 checksum over 16-bit little-endian words.

    If data has odd length, the final byte is padded with a zero high byte.

    sum1 = sum2 = 0
    For each 16-bit word w (LE pairs):
        sum1 = (sum1 + w) % 65535
        sum2 = (sum2 + sum1) % 65535
    Result = (sum2 << 16) | sum1

    Example:
        fletcher32([97, 98, 99, 100])  # 0x2926C6C4
    """
    var r: [i64] = fletcher32_update(0, 0, data)
    (r[1] << 16) | r[0]


fn fletcher32_update(sum1: i64, sum2: i64, data: [u8]) -> [i64]:
    """Feed more bytes into a Fletcher-32 streaming state.

    Takes the current sum1 and sum2 accumulators and returns [new_sum1, new_sum2].
    Initial state: sum1=0, sum2=0.

    Example:
        val r1 = fletcher32_update(0, 0, chunk1)
        val r2 = fletcher32_update(r1[0], r1[1], chunk2)
        val checksum = (r2[1] << 16) | r2[0]
    """
    var mod_val: i64 = 65535
    var s1: i64 = sum1
    var s2: i64 = sum2
    var length: i64 = data.len()
    var i: i64 = 0
    while i < length:
        var lo: i64 = data[i].to_i64()
        var hi: i64 = 0
        if i + 1 < length:
            hi = data[i + 1].to_i64()
        var word: i64 = lo | (hi << 8)
        s1 = (s1 + word) % mod_val
        s2 = (s2 + s1) % mod_val
        i = i + 2
    var result: [i64] = []
    result.push(s1)
    result.push(s2)
    result
