#![allow(unnamed_duplicate_typed_args)]

# ============================================================================
# AES-256-CCM — Pure Simple Implementation
#
# AES-256 in Counter-with-CBC-MAC mode per RFC 3610 / NIST SP 800-38C.
# Used by IEEE 802.11i (WPA2/WPA3 with 256-bit key) and
# TLS_AES_256_CCM_SHA384 cipher suite (TLS 1.3, RFC 8446 §B.4).
#
# No SFFI/Rust FFI in the CCM layer itself — pure Simple language.
# AES-256 block encryption via W13-A extern:
#   rt_aes256_encrypt_block_pure(key: [u8], block: [u8]) -> [u8]
# (defined in src/compiler_rust/runtime/src/value/aes.rs:986,
#  dispatched in interpreter_extern/mod.rs:851)
#
# Reference: RFC 3610 — Counter with CBC-MAC (CCM)
#   https://datatracker.ietf.org/doc/html/rfc3610
#   §2  CTR mode counter formatting (A_i blocks)
#   §3  CBC-MAC over header + payload (B_0 .. B_n blocks)
#   §4  CCM Encrypt / CCM Decrypt
#
# Reference: NIST SP 800-38C — Recommendation for Block Cipher Modes of
#   Operation: The CCM Mode for Authentication and Confidentiality.
#
# Parameter ranges (RFC 3610 §2):
#   nonce_len N ∈ {7..13};  L = 15 - N;  max payload = 2^(8L) - 1.
#   tag_len   M ∈ {4, 6, 8, 10, 12, 14, 16}.
#
# This module fixes N=13 (L=2, max payload = 65535 bytes) matching the
# standard deployment profile used by IEEE 802.11i and TLS 1.3 CCM.
# Variable M is supported for the full set {4..16 even}.
# ============================================================================

# W13-A AES-256 block encryption primitive (pure path, no broken _into variant).
# Key is 32 bytes; block is 16 bytes; returns a fresh 16-byte [u8].
extern fn rt_aes256_encrypt_block_pure(key: [u8], block: [u8]) -> [u8]

# Runtime helpers for byte-array operations.
extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

# ============================================================================
# Result type for AES-256-CCM decryption.
# Distinct enum so callers don't need to import AES-128 or GCM types.
# ============================================================================

enum Aes256CcmResult:
    Ok(data: [u8])
    Err(msg: text)

# ============================================================================
# B_0 / A_i / flag-byte construction (RFC 3610 §2.2 + §2.3)
# ============================================================================

fn _flag_b0(adata_present: bool, tag_len: u32, nonce_len: u32) -> u8:
    """Build the flag byte for B_0 (CBC-MAC IV).

    Layout (RFC 3610 §2.2):
        bit 7    : Reserved (0)
        bit 6    : Adata    (1 if AAD present)
        bits 5..3: (M-2)/2  where M = tag_len
        bits 2..0: L-1      where L = 15 - nonce_len
    """
    val l_field: u32 = (15 - nonce_len) - 1
    val m_field: u32 = (tag_len - 2) / 2
    var flag: u32 = (m_field << 3) | (l_field & 0x07)
    if adata_present:
        flag = flag | 0x40
    (flag & 0xFF).to_u8()

fn _flag_a0(nonce_len: u32) -> u8:
    """Flag byte for A_i counter blocks (RFC 3610 §2.3).

    Only the L-1 nibble is set; Adata and M bits are 0.
    """
    val l_field: u32 = (15 - nonce_len) - 1
    (l_field & 0x07).to_u8()

fn _build_b0(nonce: [u8], tag_len: u32, payload_len: u64, adata_present: bool) -> [u8]:
    """Construct B_0: flag || nonce || payload-length (big-endian, L bytes).

    nonce length must equal 15 - L; we encode payload_len in L bytes BE.
    """
    val nonce_len: u32 = nonce.len().to_u32()
    val l: u32 = 15 - nonce_len

    var b0: [u8] = rt_array_new_with_cap(16)
    b0.push(_flag_b0(adata_present, tag_len, nonce_len))

    var i: u64 = 0
    while i < nonce_len.to_u64():
        b0.push(_u8_at(nonce, i))
        i = i + 1

    # Payload length in big-endian, L bytes.
    var pl: u64 = payload_len
    var len_bytes: [u8] = rt_array_new_with_cap(l.to_i64())
    var k: u32 = 0
    while k < l:
        len_bytes.push((pl & 0xFF).to_u8())
        pl = pl >> 8
        k = k + 1
    # Reverse to big-endian.
    var j: u32 = l
    while j > 0:
        j = j - 1
        b0.push(_u8_at(len_bytes, j.to_u64()))

    b0

fn _build_a_i(nonce: [u8], counter: u64) -> [u8]:
    """Construct counter block A_i (RFC 3610 §2.3): flag || nonce || ctr_BE_L.

    counter is encoded big-endian in L = 15 - nonce_len bytes.
    """
    val nonce_len: u32 = nonce.len().to_u32()
    val l: u32 = 15 - nonce_len

    var a: [u8] = rt_array_new_with_cap(16)
    a.push(_flag_a0(nonce_len))

    var i: u64 = 0
    while i < nonce_len.to_u64():
        a.push(_u8_at(nonce, i))
        i = i + 1

    # counter in big-endian, L bytes.
    var ctr: u64 = counter
    var ctr_bytes: [u8] = rt_array_new_with_cap(l.to_i64())
    var k: u32 = 0
    while k < l:
        ctr_bytes.push((ctr & 0xFF).to_u8())
        ctr = ctr >> 8
        k = k + 1
    var j: u32 = l
    while j > 0:
        j = j - 1
        a.push(_u8_at(ctr_bytes, j.to_u64()))

    a

# ============================================================================
# AAD length encoding (RFC 3610 §2.2)
#
# If 0 < a < 2^16 - 2^8       : 2 bytes BE             (most common)
# If 2^16 - 2^8 ≤ a < 2^32     : 0xFF || 0xFE || 4 bytes BE
# If 2^32 ≤ a < 2^64           : 0xFF || 0xFF || 8 bytes BE
# (a == 0 → no encoded length and no AAD blocks at all)
# ============================================================================

fn _encode_aad_len(a: u64) -> [u8]:
    var out: [u8] = rt_array_new_with_cap(10)
    if a == 0:
        return out
    if a < (0x10000 - 0x100):
        # 2 bytes BE
        out.push(((a >> 8) & 0xFF).to_u8())
        out.push((a & 0xFF).to_u8())
        return out
    if a < 0x100000000:
        # 0xFF 0xFE || 4 bytes BE
        out.push(0xFF)
        out.push(0xFE)
        out.push(((a >> 24) & 0xFF).to_u8())
        out.push(((a >> 16) & 0xFF).to_u8())
        out.push(((a >> 8) & 0xFF).to_u8())
        out.push((a & 0xFF).to_u8())
        return out
    # 0xFF 0xFF || 8 bytes BE
    out.push(0xFF)
    out.push(0xFF)
    out.push(((a >> 56) & 0xFF).to_u8())
    out.push(((a >> 48) & 0xFF).to_u8())
    out.push(((a >> 40) & 0xFF).to_u8())
    out.push(((a >> 32) & 0xFF).to_u8())
    out.push(((a >> 24) & 0xFF).to_u8())
    out.push(((a >> 16) & 0xFF).to_u8())
    out.push(((a >> 8) & 0xFF).to_u8())
    out.push((a & 0xFF).to_u8())
    out

# ============================================================================
# CBC-MAC chain (RFC 3610 §3)
#
# X_1 = AES_K(B_0)
# X_{i+1} = AES_K(X_i XOR B_i)   for i = 1..n
# T = first M bytes of X_{n+1}
# ============================================================================

fn _xor_block(a: [u8], b: [u8]) -> [u8]:
    """XOR two 16-byte blocks."""
    var out: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        out.push(_u8_at(a, i) ^ _u8_at(b, i))
        i = i + 1
    out

fn _cbc_mac_absorb(state: [u8], block: [u8], key: [u8]) -> [u8]:
    """One CBC-MAC step: X_{i+1} = AES_K(X_i XOR B_i)."""
    val xored = _xor_block(state, block)
    rt_aes256_encrypt_block_pure(key, xored)

fn _cbc_mac(key: [u8],
            nonce: [u8],
            aad: [u8],
            payload: [u8],
            tag_len: u32) -> [u8]:
    """Compute T = first M bytes of CBC-MAC over (B_0 || B_aad || B_payload).

    Each B_i is 16 bytes; AAD and payload are zero-padded to a multiple of 16.
    """
    val adata_present: bool = aad.len() > 0
    val b0 = _build_b0(nonce, tag_len, payload.len(), adata_present)

    # X_1 = AES_K(B_0)
    var x: [u8] = rt_aes256_encrypt_block_pure(key, b0)

    # AAD blocks: encoded-length || aad, zero-padded to 16-byte multiple.
    if adata_present:
        val aad_len_enc = _encode_aad_len(aad.len())
        var aad_stream: [u8] = rt_array_new_with_cap((aad_len_enc.len() + aad.len()).to_i64())
        var i: u64 = 0
        while i < aad_len_enc.len():
            aad_stream.push(_u8_at(aad_len_enc, i))
            i = i + 1
        var j: u64 = 0
        while j < aad.len():
            aad_stream.push(_u8_at(aad, j))
            j = j + 1

        # Process aad_stream in 16-byte CBC-MAC blocks (zero-pad last).
        var pos: u64 = 0
        val total = aad_stream.len()
        while pos < total:
            var blk: [u8] = rt_array_new_with_cap(16)
            var k: u64 = 0
            while k < 16:
                if (pos + k) < total:
                    blk.push(_u8_at(aad_stream, pos + k))
                else:
                    blk.push(0x00)
                k = k + 1
            x = _cbc_mac_absorb(x, blk, key)
            pos = pos + 16

    # Payload blocks: zero-padded to 16-byte multiple.
    if payload.len() > 0:
        var pos: u64 = 0
        val total = payload.len()
        while pos < total:
            var blk: [u8] = rt_array_new_with_cap(16)
            var k: u64 = 0
            while k < 16:
                if (pos + k) < total:
                    blk.push(_u8_at(payload, pos + k))
                else:
                    blk.push(0x00)
                k = k + 1
            x = _cbc_mac_absorb(x, blk, key)
            pos = pos + 16

    # T = first M bytes of X_{n+1}
    var t: [u8] = rt_array_new_with_cap(tag_len.to_i64())
    var i: u64 = 0
    while i < tag_len.to_u64():
        t.push(_u8_at(x, i))
        i = i + 1
    t

# ============================================================================
# CTR-mode encrypt/decrypt over payload (RFC 3610 §2.3)
#
# S_i = AES_K(A_i)  for i = 0, 1, 2, ...
# Payload bytes are XORed with S_1, S_2, ... (S_0 reserved for tag masking).
# ============================================================================

fn _ctr_xor_payload(key: [u8], nonce: [u8], data: [u8]) -> [u8]:
    """XOR data with the CCM keystream starting at counter=1 (A_1, A_2, ...).

    Used for both encrypt and decrypt (CTR is its own inverse).
    """
    if data.len() == 0:
        return []

    var out: [u8] = rt_array_new_with_cap(data.len().to_i64())
    var i: u64 = 0
    var ctr: u64 = 1  # S_0 reserved for tag mask; payload starts at S_1
    val total = data.len()
    while i < total:
        val a_i = _build_a_i(nonce, ctr)
        val s_i = rt_aes256_encrypt_block_pure(key, a_i)
        var k: u64 = 0
        while k < 16 and (i + k) < total:
            out.push(_u8_at(data, i + k) ^ _u8_at(s_i, k))
            k = k + 1
        i = i + 16
        ctr = ctr + 1
    out

fn _s0_tag_mask(key: [u8], nonce: [u8], tag_len: u32) -> [u8]:
    """Compute first M bytes of S_0 = AES_K(A_0) for tag masking."""
    val a0 = _build_a_i(nonce, 0)
    val s0 = rt_aes256_encrypt_block_pure(key, a0)
    var mask: [u8] = rt_array_new_with_cap(tag_len.to_i64())
    var i: u64 = 0
    while i < tag_len.to_u64():
        mask.push(_u8_at(s0, i))
        i = i + 1
    mask

fn _xor_bytes(a: [u8], b: [u8]) -> [u8]:
    """XOR two byte arrays of equal length."""
    var out: [u8] = rt_array_new_with_cap(a.len().to_i64())
    var i: u64 = 0
    while i < a.len():
        out.push(_u8_at(a, i) ^ _u8_at(b, i))
        i = i + 1
    out

# ============================================================================
# Constant-time tag comparison (RFC 3610 §4 + feedback_no_coverups.md pattern)
#
# Accumulates XOR-OR over all bytes; returns true only if every byte matches.
# Always processes both inputs to full length; no early return.
# Mismatched-length tags are rejected explicitly (length is public).
# ============================================================================

fn _ct_eq_bytes(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var diff: u32 = 0
    var i: u64 = 0
    while i < a.len():
        diff = diff | (_u8_at(a, i) ^ _u8_at(b, i)).to_u32()
        i = i + 1
    diff == 0

# ============================================================================
# AES-256-CCM Encryption (RFC 3610 §4)
#
# Inputs:
#   key       : 32-byte AES-256 key
#   nonce     : 13-byte nonce (CCM with L=2; max payload 65535 bytes)
#   aad       : Additional authenticated data (any length)
#   plaintext : Data to encrypt (any length, but ≤ 65535 with N=13)
#   tag_len   : Authentication tag size in bytes; must be in {4,6,8,10,12,14,16}
#
# Output: ciphertext || U   where:
#   ciphertext = CTR_K(plaintext XOR keystream from A_1, A_2, ...)
#   U          = T XOR (first M bytes of S_0)         (RFC 3610 §4 step 7)
#   T          = first M bytes of CBC-MAC(B_0 || B_aad || B_payload)
#
# Returns: ciphertext concatenated with the tag (M bytes).
# Caller can split via [..len(plaintext)] and [len(plaintext)..].
# Returns [] on parameter errors.
# ============================================================================

fn aes256_ccm_encrypt(key: [u8],
                      nonce: [u8],
                      aad: [u8],
                      plaintext: [u8],
                      tag_len: u32) -> [u8]:
    """AES-256-CCM authenticated encryption per RFC 3610 / NIST SP 800-38C.

    Args:
        key:       32-byte AES-256 key.
        nonce:     13-byte nonce (N=13, L=2 profile).
        aad:       Additional authenticated data.
        plaintext: Plaintext bytes (≤ 65535 with N=13).
        tag_len:   Tag size; must be in {4, 6, 8, 10, 12, 14, 16}.

    Returns: ciphertext || tag    (length == plaintext.len() + tag_len).
             Returns [] on parameter errors.
    """
    if key.len() != 32:
        return []
    if nonce.len() != 13:
        return []
    if (tag_len < 4) or (tag_len > 16) or ((tag_len % 2) != 0):
        return []

    # Step 1-3: CBC-MAC -> T (first M bytes of X_{n+1}).
    val t = _cbc_mac(key, nonce, aad, plaintext, tag_len)

    # Step 4-6: CTR encrypt the plaintext.
    val ciphertext = _ctr_xor_payload(key, nonce, plaintext)

    # Step 7: U = T XOR S_0[0..M].
    val s0_mask = _s0_tag_mask(key, nonce, tag_len)
    val u = _xor_bytes(t, s0_mask)

    # Output: ciphertext || U
    var out: [u8] = rt_array_new_with_cap((ciphertext.len() + u.len()).to_i64())
    var i: u64 = 0
    while i < ciphertext.len():
        out.push(_u8_at(ciphertext, i))
        i = i + 1
    var j: u64 = 0
    while j < u.len():
        out.push(_u8_at(u, j))
        j = j + 1
    out

# ============================================================================
# AES-256-CCM Decryption (RFC 3610 §4)
#
# Inputs:
#   key        : 32-byte AES-256 key
#   nonce      : 13-byte nonce
#   aad        : Additional authenticated data
#   ciphertext : Encrypted bytes (without the tag)
#   tag        : Received authentication tag (M bytes)
#
# Output: Aes256CcmResult.Ok(plaintext) if tag verifies; Err(_) otherwise.
#
# Steps:
#   1. P = ciphertext XOR keystream(A_1, A_2, ...)         (CTR decrypt)
#   2. T' = first M bytes of CBC-MAC(B_0 || B_aad || B_P)
#   3. U' = T' XOR S_0[0..M]
#   4. constant-time compare U' to received tag
# ============================================================================

fn aes256_ccm_decrypt(key: [u8],
                      nonce: [u8],
                      aad: [u8],
                      ciphertext: [u8],
                      tag: [u8]) -> Aes256CcmResult:
    """AES-256-CCM authenticated decryption per RFC 3610 / NIST SP 800-38C.

    Returns Aes256CcmResult.Ok(plaintext) only if the received tag matches
    the recomputed tag in constant time; otherwise Aes256CcmResult.Err.
    """
    if key.len() != 32:
        return Aes256CcmResult.Err("key must be 32 bytes")
    if nonce.len() != 13:
        return Aes256CcmResult.Err("nonce must be 13 bytes")
    val tag_len: u32 = tag.len().to_u32()
    if (tag_len < 4) or (tag_len > 16) or ((tag_len % 2) != 0):
        return Aes256CcmResult.Err("tag length must be in {4,6,8,10,12,14,16}")

    # Step 1: CTR-decrypt to recover plaintext.
    val plaintext = _ctr_xor_payload(key, nonce, ciphertext)

    # Step 2: Recompute CBC-MAC over (B_0 || aad || plaintext).
    val t_recomputed = _cbc_mac(key, nonce, aad, plaintext, tag_len)

    # Step 3: U_expected = T_recomputed XOR S_0[0..M].
    val s0_mask = _s0_tag_mask(key, nonce, tag_len)
    val u_expected = _xor_bytes(t_recomputed, s0_mask)

    # Step 4: constant-time compare.
    if not _ct_eq_bytes(u_expected, tag):
        return Aes256CcmResult.Err("authentication tag mismatch")

    Aes256CcmResult.Ok(data: plaintext)
