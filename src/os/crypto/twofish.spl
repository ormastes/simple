# ============================================================================
# h function — key-dependent substitution + MDS
# ============================================================================
# h(x, L, k):
#   x is a 32-bit word; L is the S-box words (k/8 entries); k is key byte count.
#   Apply successive q0/q1 permutations, XOR with key bytes, then MDS multiply.
#
# 128-bit key (k=16, 2 S-box words L[0], L[1]):
#   b[0] = q1(q0(q0(b[0]) ^ L1_b0) ^ L0_b0)
#   b[1] = q0(q0(q1(b[1]) ^ L1_b1) ^ L0_b1)
#   b[2] = q1(q1(q0(b[2]) ^ L1_b2) ^ L0_b2)
#   b[3] = q0(q1(q1(b[3]) ^ L1_b3) ^ L0_b3)
#
# 256-bit key (k=32, 4 S-box words L[0..3]):
#   First apply q1/q0/q0/q1 with L[3], then q1/q1/q0/q0 with L[2], then 128-bit path

fn _h_128(x: u32, s0: u32, s1: u32) -> u32:
    """h function for 128-bit key (2 S-box words)."""
    val b0 = (x >> 0) & 0xFF
    val b1 = (x >> 8) & 0xFF
    val b2 = (x >> 16) & 0xFF
    val b3 = (x >> 24) & 0xFF
    val s0b0 = (s0 >> 0) & 0xFF
    val s0b1 = (s0 >> 8) & 0xFF
    val s0b2 = (s0 >> 16) & 0xFF
    val s0b3 = (s0 >> 24) & 0xFF
    val s1b0 = (s1 >> 0) & 0xFF
    val s1b1 = (s1 >> 8) & 0xFF
    val s1b2 = (s1 >> 16) & 0xFF
    val s1b3 = (s1 >> 24) & 0xFF
    val c0 = _q1(_q0(_q0(b0.to_u64()).to_u64() ^ s1b0.to_u64()).to_u64() ^ s0b0.to_u64())
    val c1 = _q0(_q0(_q1(b1.to_u64()).to_u64() ^ s1b1.to_u64()).to_u64() ^ s0b1.to_u64())
    val c2 = _q1(_q1(_q0(b2.to_u64()).to_u64() ^ s1b2.to_u64()).to_u64() ^ s0b2.to_u64())
    val c3 = _q0(_q1(_q1(b3.to_u64()).to_u64() ^ s1b3.to_u64()).to_u64() ^ s0b3.to_u64())
    _mds_multiply_word(c0, c1, c2, c3)

fn _h_192(x: u32, s0: u32, s1: u32, s2: u32) -> u32:
    """h function for 192-bit key (3 S-box words)."""
    val b0 = (x >> 0) & 0xFF
    val b1 = (x >> 8) & 0xFF
    val b2 = (x >> 16) & 0xFF
    val b3 = (x >> 24) & 0xFF
    val s2b0 = (s2 >> 0) & 0xFF
    val s2b1 = (s2 >> 8) & 0xFF
    val s2b2 = (s2 >> 16) & 0xFF
    val s2b3 = (s2 >> 24) & 0xFF
    # Apply L[2] layer first (q1,q1,q0,q0)
    val a0 = _q1(b0.to_u64()) ^ s2b0
    val a1 = _q1(b1.to_u64()) ^ s2b1
    val a2 = _q0(b2.to_u64()) ^ s2b2
    val a3 = _q0(b3.to_u64()) ^ s2b3
    # Then 128-bit path with s0, s1
    val packed = a0 | (a1 << 8) | (a2 << 16) | (a3 << 24)
    _h_128(packed, s0, s1)

fn _h_256(x: u32, s0: u32, s1: u32, s2: u32, s3: u32) -> u32:
    """h function for 256-bit key (4 S-box words)."""
    val b0 = (x >> 0) & 0xFF
    val b1 = (x >> 8) & 0xFF
    val b2 = (x >> 16) & 0xFF
    val b3 = (x >> 24) & 0xFF
    val s3b0 = (s3 >> 0) & 0xFF
    val s3b1 = (s3 >> 8) & 0xFF
    val s3b2 = (s3 >> 16) & 0xFF
    val s3b3 = (s3 >> 24) & 0xFF
    # Apply L[3] layer (q1,q0,q0,q1)
    val a0 = _q1(b0.to_u64()) ^ s3b0
    val a1 = _q0(b1.to_u64()) ^ s3b1
    val a2 = _q0(b2.to_u64()) ^ s3b2
    val a3 = _q1(b3.to_u64()) ^ s3b3
    # Then 192-bit path with s0, s1, s2
    val packed = a0 | (a1 << 8) | (a2 << 16) | (a3 << 24)
    _h_192(packed, s0, s1, s2)

# ============================================================================
# Key schedule
# ============================================================================

fn _load_le32(buf: [u8], offset: u64) -> u32:
    """Load 4 bytes from buf[offset] as a little-endian 32-bit word."""
    buf[offset].to_u32() |
    (buf[offset + 1].to_u32() << 8) |
    (buf[offset + 2].to_u32() << 16) |
    (buf[offset + 3].to_u32() << 24)

fn _rol32(v: u32, n: u32) -> u32:
    """32-bit rotate left."""
    ((v << n) | (v >> (32 - n))) & 0xFFFFFFFF

fn _ror32(v: u32, n: u32) -> u32:
    """32-bit rotate right."""
    ((v >> n) | (v << (32 - n))) & 0xFFFFFFFF

fn _twofish_key_schedule(key: [u8]) -> [u32]:
    """Generate 40 subkeys followed by the S-box words.

    Returns a flat array: [K0..K39, S0..S_{N/2-1}]
    where N/2 is 2 (128-bit), 3 (192-bit), or 4 (256-bit).
    """
    val klen: u64 = key.len()
    val n_words: u64 = klen / 4       # 4, 6, or 8
    val n_half: u64 = n_words / 2     # 2, 3, or 4

    # Load key as 32-bit little-endian words
    var m: [u32] = []
    var wi: u64 = 0
    while wi < n_words:
        m.push(_load_le32(key, wi * 4))
        wi = wi + 1

    # Me = even words, Mo = odd words
    var m_even: [u32] = []
    var m_odd: [u32] = []
    var pi: u64 = 0
    while pi < n_half:
        m_even.push(m[pi * 2])
        m_odd.push(m[pi * 2 + 1])
        pi = pi + 1

    # S-box words via RS matrix (one 32-bit word per 8-byte chunk, reversed order)
    var s_words: [u32] = []
    var si: u64 = 0
    while si < n_half:
        s_words.push(_rs_word(key, si * 8))
        si = si + 1
    # Reverse s_words in place
    var lo: u64 = 0
    var hi2: u64 = s_words.len().to_u64() - 1
    while lo < hi2:
        val tmp = s_words[lo]
        s_words[lo] = s_words[hi2]
        s_words[hi2] = tmp
        lo = lo + 1
        hi2 = hi2 - 1

    # Generate 40 subkeys using the h function
    val rho: u32 = 0x01010101
    var subkeys: [u32] = []
    var ri: u64 = 0
    while ri < 20:
        val a_arg: u32 = (2 * ri.to_u32()) * rho
        val b_arg: u32 = (2 * ri.to_u32() + 1) * rho
        var a: u32 = 0
        var b: u32 = 0
        if n_half == 4:
            a = _h_256(a_arg, m_even[0], m_even[1], m_even[2], m_even[3])
            b = _h_256(b_arg, m_odd[0], m_odd[1], m_odd[2], m_odd[3])
        else if n_half == 3:
            a = _h_192(a_arg, m_even[0], m_even[1], m_even[2])
            b = _h_192(b_arg, m_odd[0], m_odd[1], m_odd[2])
        else:
            a = _h_128(a_arg, m_even[0], m_even[1])
            b = _h_128(b_arg, m_odd[0], m_odd[1])
        b = _rol32(b, 8)
        val k_even = (a + b) & 0xFFFFFFFF
        val k_odd_raw = (a + 2 * b) & 0xFFFFFFFF
        val k_odd = _rol32(k_odd_raw, 9)
        subkeys.push(k_even)
        subkeys.push(k_odd)
        ri = ri + 1

    # Append S-box words after the 40 subkeys
    var sei: u64 = 0
    while sei < s_words.len().to_u64():
        subkeys.push(s_words[sei])
        sei = sei + 1

    subkeys

# ============================================================================
# Round g function dispatch
# ============================================================================

fn _g_128(x: u32, sched: [u32]) -> u32:
    """g function for 128-bit key (S words at sched[40] and sched[41])."""
    _h_128(x, sched[40], sched[41])

fn _g_192(x: u32, sched: [u32]) -> u32:
    """g function for 192-bit key (S words at sched[40..42])."""
    _h_192(x, sched[40], sched[41], sched[42])

fn _g_256(x: u32, sched: [u32]) -> u32:
    """g function for 256-bit key (S words at sched[40..43])."""
    _h_256(x, sched[40], sched[41], sched[42], sched[43])

fn _g(x: u32, sched: [u32], klen: u64) -> u32:
    """g function — dispatch on key length."""
    if klen == 32:
        _g_256(x, sched)
    else if klen == 24:
        _g_192(x, sched)
    else:
        _g_128(x, sched)

# ============================================================================
# Encrypt one 16-byte block
# ============================================================================

fn twofish_encrypt_block(key: [u8], plaintext: [u8]) -> [u8]:
    """Encrypt a 16-byte block with a 16/24/32-byte key.

    Args:
        key: 16, 24, or 32 byte key.
        plaintext: 16-byte plaintext block.

    Returns: 16-byte ciphertext block.
    """
    val klen = key.len().to_u64()
    val sched = _twofish_key_schedule(key)

    # Load plaintext as 4 little-endian 32-bit words
    var r0 = _load_le32(plaintext, 0) ^ sched[0]
    var r1 = _load_le32(plaintext, 4) ^ sched[1]
    var r2 = _load_le32(plaintext, 8) ^ sched[2]
    var r3 = _load_le32(plaintext, 12) ^ sched[3]

    # 16 Feistel rounds
    var rnd: u64 = 0
    while rnd < 16:
        val t0 = _g(r0, sched, klen)
        val t1 = _g(_rol32(r1, 8), sched, klen)
        val f0 = (t0 + t1 + sched[2 * rnd + 8]) & 0xFFFFFFFF
        val f1 = (t0 + 2 * t1 + sched[2 * rnd + 9]) & 0xFFFFFFFF
        r2 = _ror32(r2 ^ f0, 1)
        r3 = _rol32(r3, 1) ^ f1
        # Swap half-blocks
        val tmp0 = r0
        val tmp1 = r1
        r0 = r2
        r1 = r3
        r2 = tmp0
        r3 = tmp1
        rnd = rnd + 1

    # Undo final swap
    val out0 = r2 ^ sched[4]
    val out1 = r3 ^ sched[5]
    val out2 = r0 ^ sched[6]
    val out3 = r1 ^ sched[7]

    # Store as little-endian bytes
    var result: [u8] = []
    result.push(((out0 >> 0) & 0xFF).to_u8())
    result.push(((out0 >> 8) & 0xFF).to_u8())
    result.push(((out0 >> 16) & 0xFF).to_u8())
    result.push(((out0 >> 24) & 0xFF).to_u8())
    result.push(((out1 >> 0) & 0xFF).to_u8())
    result.push(((out1 >> 8) & 0xFF).to_u8())
    result.push(((out1 >> 16) & 0xFF).to_u8())
    result.push(((out1 >> 24) & 0xFF).to_u8())
    result.push(((out2 >> 0) & 0xFF).to_u8())
    result.push(((out2 >> 8) & 0xFF).to_u8())
    result.push(((out2 >> 16) & 0xFF).to_u8())
    result.push(((out2 >> 24) & 0xFF).to_u8())
    result.push(((out3 >> 0) & 0xFF).to_u8())
    result.push(((out3 >> 8) & 0xFF).to_u8())
    result.push(((out3 >> 16) & 0xFF).to_u8())
    result.push(((out3 >> 24) & 0xFF).to_u8())
    result

# ============================================================================
# Decrypt one 16-byte block
# ============================================================================

fn twofish_decrypt_block(key: [u8], ciphertext: [u8]) -> [u8]:
    """Decrypt a 16-byte block with a 16/24/32-byte key.

    Args:
        key: 16, 24, or 32 byte key.
        ciphertext: 16-byte ciphertext block.

    Returns: 16-byte plaintext block.
    """
    val klen = key.len().to_u64()
    val sched = _twofish_key_schedule(key)

    # Load ciphertext and undo output whitening
    val c0 = _load_le32(ciphertext, 0) ^ sched[4]
    val c1 = _load_le32(ciphertext, 4) ^ sched[5]
    val c2 = _load_le32(ciphertext, 8) ^ sched[6]
    val c3 = _load_le32(ciphertext, 12) ^ sched[7]

    # After output whitening+undo-last-swap the state is:
    #   [R0_r15_in, R1_r15_in, R2_r15_out, R3_r15_out]
    # Re-apply final swap to recover the post-round-15 Feistel state
    var r0 = c2
    var r1 = c3
    var r2 = c0
    var r3 = c1

    # 16 rounds in reverse
    var rnd: u64 = 15
    var done: u64 = 0
    while done == 0:
        # T0/T1 use the pre-round inputs (positions 2,3 after swap)
        val t0 = _g(r2, sched, klen)
        val t1 = _g(_rol32(r3, 8), sched, klen)
        val f0 = (t0 + t1 + sched[2 * rnd + 8]) & 0xFFFFFFFF
        val f1 = (t0 + 2 * t1 + sched[2 * rnd + 9]) & 0xFFFFFFFF
        # Undo swap: [mixed_L, mixed_R, orig_L, orig_R] -> [orig_L, orig_R, mixed_L, mixed_R]
        val tmp0 = r0
        val tmp1 = r1
        r0 = r2
        r1 = r3
        r2 = tmp0
        r3 = tmp1
        # Undo mix: inverse of ROR(r2^f0, 1) and ROL(r3,1)^f1
        r2 = _rol32(r2, 1) ^ f0
        r3 = _ror32(r3 ^ f1, 1)
        if rnd == 0:
            done = 1
        else:
            rnd = rnd - 1

    # Undo input whitening
    var result: [u8] = []
    val p0 = r0 ^ sched[0]
    val p1 = r1 ^ sched[1]
    val p2 = r2 ^ sched[2]
    val p3 = r3 ^ sched[3]

    result.push(((p0 >> 0) & 0xFF).to_u8())
    result.push(((p0 >> 8) & 0xFF).to_u8())
    result.push(((p0 >> 16) & 0xFF).to_u8())
    result.push(((p0 >> 24) & 0xFF).to_u8())
    result.push(((p1 >> 0) & 0xFF).to_u8())
    result.push(((p1 >> 8) & 0xFF).to_u8())
    result.push(((p1 >> 16) & 0xFF).to_u8())
    result.push(((p1 >> 24) & 0xFF).to_u8())
    result.push(((p2 >> 0) & 0xFF).to_u8())
    result.push(((p2 >> 8) & 0xFF).to_u8())
    result.push(((p2 >> 16) & 0xFF).to_u8())
    result.push(((p2 >> 24) & 0xFF).to_u8())
    result.push(((p3 >> 0) & 0xFF).to_u8())
    result.push(((p3 >> 8) & 0xFF).to_u8())
    result.push(((p3 >> 16) & 0xFF).to_u8())
    result.push(((p3 >> 24) & 0xFF).to_u8())
    result
