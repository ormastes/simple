# Twofish Block Cipher — Pure Simple Implementation
#
# Twofish is a 128-bit symmetric block cipher with 128/192/256-bit key sizes,
# designed by Schneier et al. as an AES finalist (1998).
#
# Supports:
#   twofish_encrypt_block(key: [u8], plaintext: [u8]) -> [u8]
#   twofish_decrypt_block(key: [u8], ciphertext: [u8]) -> [u8]
#
# Key schedule:
#   - 40 subkeys K[0..39], generated via the h function over Me/Mo halves
#   - 4 key-dependent S-box words (one per 64-bit key chunk) via RS matrix
#
# Round function (16 Feistel rounds):
#   - g = h function (q0/q1 permutations + MDS multiply)
#   - PHT: F0 = T0+T1+K, F1 = T0+2*T1+K
#   - XOR + rotate, swap half-blocks each round
#
# References:
#   - Twofish paper: https://www.schneier.com/academic/twofish/
#   - Test vectors: Twofish paper Table 4

# ============================================================================
# GF(2^8) multiply helpers
# ============================================================================

fn _gf_mul_mds(a: u32, b: u32) -> u32:
    """Multiply in GF(2^8) with MDS polynomial 0x169."""
    var p: u32 = 0
    var av: u32 = a & 0xFF
    var bv: u32 = b & 0xFF
    var i: u64 = 0
    while i < 8:
        if bv & 1 != 0:
            p = p ^ av
        bv = bv >> 1
        val hi: u32 = av & 0x80
        av = (av << 1) & 0xFF
        if hi != 0:
            av = av ^ 0x69
        i = i + 1
    p

fn _gf_mul_rs(a: u32, b: u32) -> u32:
    """Multiply in GF(2^8) with RS polynomial 0x14D."""
    var p: u32 = 0
    var av: u32 = a & 0xFF
    var bv: u32 = b & 0xFF
    var i: u64 = 0
    while i < 8:
        if bv & 1 != 0:
            p = p ^ av
        bv = bv >> 1
        val hi: u32 = av & 0x80
        av = (av << 1) & 0xFF
        if hi != 0:
            av = av ^ 0x4D
        i = i + 1
    p

# ============================================================================
# MDS matrix multiply
# ============================================================================
# MDS matrix (4x4 over GF(2^8)):
#   | 01 EF 5B 5B |
#   | 5B EF EF 01 |
#   | EF 5B 01 EF |
#   | EF 01 EF 5B |

fn _mds_col(b0: u32, b1: u32, b2: u32, b3: u32, row: u64) -> u32:
    """Compute one row of the MDS matrix multiply."""
    if row == 0:
        _gf_mul_mds(0x01, b0) ^ _gf_mul_mds(0xEF, b1) ^ _gf_mul_mds(0x5B, b2) ^ _gf_mul_mds(0x5B, b3)
    else if row == 1:
        _gf_mul_mds(0x5B, b0) ^ _gf_mul_mds(0xEF, b1) ^ _gf_mul_mds(0xEF, b2) ^ _gf_mul_mds(0x01, b3)
    else if row == 2:
        _gf_mul_mds(0xEF, b0) ^ _gf_mul_mds(0x5B, b1) ^ _gf_mul_mds(0x01, b2) ^ _gf_mul_mds(0xEF, b3)
    else:
        _gf_mul_mds(0xEF, b0) ^ _gf_mul_mds(0x01, b1) ^ _gf_mul_mds(0xEF, b2) ^ _gf_mul_mds(0x5B, b3)

fn _mds_multiply_word(b0: u32, b1: u32, b2: u32, b3: u32) -> u32:
    """Apply MDS 4x4 multiply to bytes b0..b3, pack result into a 32-bit word."""
    val r0 = _mds_col(b0, b1, b2, b3, 0)
    val r1 = _mds_col(b0, b1, b2, b3, 1)
    val r2 = _mds_col(b0, b1, b2, b3, 2)
    val r3 = _mds_col(b0, b1, b2, b3, 3)
    r0 | (r1 << 8) | (r2 << 16) | (r3 << 24)

# ============================================================================
# RS matrix multiply (for S-box generation from key bytes)
# ============================================================================
# RS matrix (4x8 over GF(2^8)):
#   | 01 A4 55 87 5A 58 DB 9E |
#   | A4 56 82 F3 1E C6 68 E5 |
#   | 02 A1 FC C1 47 AE 3D 19 |
#   | A4 55 87 5A 58 DB 9E 03 |

fn _rs_row(m0: u32, m1: u32, m2: u32, m3: u32, m4: u32, m5: u32, m6: u32, m7: u32, row: u64) -> u32:
    """Compute one row of the RS matrix multiply."""
    if row == 0:
        _gf_mul_rs(0x01, m0) ^ _gf_mul_rs(0xA4, m1) ^ _gf_mul_rs(0x55, m2) ^ _gf_mul_rs(0x87, m3) ^
        _gf_mul_rs(0x5A, m4) ^ _gf_mul_rs(0x58, m5) ^ _gf_mul_rs(0xDB, m6) ^ _gf_mul_rs(0x9E, m7)
    else if row == 1:
        _gf_mul_rs(0xA4, m0) ^ _gf_mul_rs(0x56, m1) ^ _gf_mul_rs(0x82, m2) ^ _gf_mul_rs(0xF3, m3) ^
        _gf_mul_rs(0x1E, m4) ^ _gf_mul_rs(0xC6, m5) ^ _gf_mul_rs(0x68, m6) ^ _gf_mul_rs(0xE5, m7)
    else if row == 2:
        _gf_mul_rs(0x02, m0) ^ _gf_mul_rs(0xA1, m1) ^ _gf_mul_rs(0xFC, m2) ^ _gf_mul_rs(0xC1, m3) ^
        _gf_mul_rs(0x47, m4) ^ _gf_mul_rs(0xAE, m5) ^ _gf_mul_rs(0x3D, m6) ^ _gf_mul_rs(0x19, m7)
    else:
        _gf_mul_rs(0xA4, m0) ^ _gf_mul_rs(0x55, m1) ^ _gf_mul_rs(0x87, m2) ^ _gf_mul_rs(0x5A, m3) ^
        _gf_mul_rs(0x58, m4) ^ _gf_mul_rs(0xDB, m5) ^ _gf_mul_rs(0x9E, m6) ^ _gf_mul_rs(0x03, m7)

fn _rs_word(chunk: [u8], offset: u64) -> u32:
    """Apply RS matrix to 8 bytes at chunk[offset..offset+8], return packed 32-bit word."""
    val m0 = chunk[offset + 0].to_u32()
    val m1 = chunk[offset + 1].to_u32()
    val m2 = chunk[offset + 2].to_u32()
    val m3 = chunk[offset + 3].to_u32()
    val m4 = chunk[offset + 4].to_u32()
    val m5 = chunk[offset + 5].to_u32()
    val m6 = chunk[offset + 6].to_u32()
    val m7 = chunk[offset + 7].to_u32()
    val r0 = _rs_row(m0, m1, m2, m3, m4, m5, m6, m7, 0)
    val r1 = _rs_row(m0, m1, m2, m3, m4, m5, m6, m7, 1)
    val r2 = _rs_row(m0, m1, m2, m3, m4, m5, m6, m7, 2)
    val r3 = _rs_row(m0, m1, m2, m3, m4, m5, m6, m7, 3)
    r0 | (r1 << 8) | (r2 << 16) | (r3 << 24)

# ============================================================================
# q0 permutation table (256 entries)
# ============================================================================

