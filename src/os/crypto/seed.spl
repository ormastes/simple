# ============================================================================
# G function — RFC 4269 §2.2
#
# Input X is treated as X3||X2||X1||X0 (X0 = least-significant byte)
# m0=0xFC, m1=0xF3, m2=0xCF, m3=0x3F
#
# Z0 = {S0(X0)&m0} ^ {S1(X1)&m1} ^ {S0(X2)&m2} ^ {S1(X3)&m3}
# Z1 = {S0(X0)&m1} ^ {S1(X1)&m2} ^ {S0(X2)&m3} ^ {S1(X3)&m0}
# Z2 = {S0(X0)&m2} ^ {S1(X1)&m3} ^ {S0(X2)&m0} ^ {S1(X3)&m1}
# Z3 = {S0(X0)&m3} ^ {S1(X1)&m0} ^ {S0(X2)&m1} ^ {S1(X3)&m2}
#
# Result: Z3||Z2||Z1||Z0 packed as u32 (Z0 in bits 7:0)
# ============================================================================

fn _g(x: u32) -> u32:
    val s0 = _s0()
    val s1 = _s1()
    val x0: u32 = x & 0xFFu32
    val x1: u32 = (x >> 8) & 0xFFu32
    val x2: u32 = (x >> 16) & 0xFFu32
    val x3: u32 = (x >> 24) & 0xFFu32
    val s0x0: u32 = s0[x0.to_i64()].to_u32()
    val s1x1: u32 = s1[x1.to_i64()].to_u32()
    val s0x2: u32 = s0[x2.to_i64()].to_u32()
    val s1x3: u32 = s1[x3.to_i64()].to_u32()
    val z0: u32 = (s0x0 & 0xFCu32) ^ (s1x1 & 0xF3u32) ^ (s0x2 & 0xCFu32) ^ (s1x3 & 0x3Fu32)
    val z1: u32 = (s0x0 & 0xF3u32) ^ (s1x1 & 0xCFu32) ^ (s0x2 & 0x3Fu32) ^ (s1x3 & 0xFCu32)
    val z2: u32 = (s0x0 & 0xCFu32) ^ (s1x1 & 0x3Fu32) ^ (s0x2 & 0xFCu32) ^ (s1x3 & 0xF3u32)
    val z3: u32 = (s0x0 & 0x3Fu32) ^ (s1x1 & 0xFCu32) ^ (s0x2 & 0xF3u32) ^ (s1x3 & 0xCFu32)
    (z3 << 24) | (z2 << 16) | (z1 << 8) | z0

# ============================================================================
# Round function F — RFC 4269 §2.1
#
# R0' = G[G[G[(R0^Ki0)^(R1^Ki1)] + (R0^Ki0)] + G[(R0^Ki0)^(R1^Ki1)]]
#        + G[G[(R0^Ki0)^(R1^Ki1)] + (R0^Ki0)]
# R1' = G[G[G[(R0^Ki0)^(R1^Ki1)] + (R0^Ki0)] + G[(R0^Ki0)^(R1^Ki1)]]
# ============================================================================

fn _f(r0: u32, r1: u32, ki0: u32, ki1: u32) -> (u32, u32):
    val x: u32 = r0 ^ ki0
    val y: u32 = r1 ^ ki1
    val t: u32 = _g(x ^ y)
    val c: u32 = _g(t + x)
    val r1p: u32 = _g(c + t)
    val r0p: u32 = r1p + c
    (r0p, r1p)

# ============================================================================
# Key schedule — RFC 4269 §2.3
#
# KC constants — sqrt(2) / sqrt(3) based, 16 values
# ============================================================================

fn _kc(i: i64) -> u32:
    if i == 0:  0x9E3779B9u32
    else if i == 1:  0x3C6EF373u32
    else if i == 2:  0x78DDE6E6u32
    else if i == 3:  0xF1BBCDCCu32
    else if i == 4:  0xE3779B99u32
    else if i == 5:  0xC6EF3733u32
    else if i == 6:  0x8DDE6E67u32
    else if i == 7:  0x1BBCDCCFu32
    else if i == 8:  0x3779B99Eu32
    else if i == 9:  0x6EF3733Cu32
    else if i == 10: 0xDDE6E678u32
    else if i == 11: 0xBBCDCCF1u32
    else if i == 12: 0x779B99E3u32
    else if i == 13: 0xEF3733C6u32
    else if i == 14: 0xDE6E678Du32
    else:            0xBCDCCF1Bu32

fn _load32be(buf: [u8], off: i64) -> u32:
    val b0: u32 = buf[off].to_u32()
    val b1: u32 = buf[off + 1].to_u32()
    val b2: u32 = buf[off + 2].to_u32()
    val b3: u32 = buf[off + 3].to_u32()
    (b0 << 24) | (b1 << 16) | (b2 << 8) | b3

# Key schedule returns 32 subkeys as a flat [u32] array, interleaved (ki0, ki1)
# rk[2*i] = Ki0, rk[2*i+1] = Ki1 for round i+1
fn _key_schedule(key: [u8]) -> [u32]:
    var k0: u32 = _load32be(key, 0)
    var k1: u32 = _load32be(key, 4)
    var k2: u32 = _load32be(key, 8)
    var k3: u32 = _load32be(key, 12)
    var rk: [u32] = []
    var i: i64 = 0
    while i < 16:
        val kc = _kc(i)
        val rk0: u32 = _g(k0 + k2 - kc)
        val rk1: u32 = _g(k1 - k3 + kc)
        rk.push(rk0)
        rk.push(rk1)
        if (i % 2) == 0:
            # Even index: rotate K0||K1 right 8 bits
            val nk0: u32 = (k0 >> 8) | (k1 << 24)
            val nk1: u32 = (k1 >> 8) | (k0 << 24)
            k0 = nk0
            k1 = nk1
        else:
            # Odd index: rotate K2||K3 left 8 bits
            val nk2: u32 = (k2 << 8) | (k3 >> 24)
            val nk3: u32 = (k3 << 8) | (k2 >> 24)
            k2 = nk2
            k3 = nk3
        i = i + 1
    rk

# ============================================================================
# Feistel encrypt core
#
# 128-bit input: L = L0||L1 (most-significant), R = R0||R1
# Rounds 1-15: T=R; R=L^F(Ki,R); L=T
# Round 16:    L=L^F(K16,R); R unchanged
# Output: L0||L1||R0||R1 big-endian
# ============================================================================

fn seed_encrypt_block(key: [u8], block: [u8]) -> [u8]:
    val rk = _key_schedule(key)
    var l0: u32 = _load32be(block, 0)
    var l1: u32 = _load32be(block, 4)
    var r0: u32 = _load32be(block, 8)
    var r1: u32 = _load32be(block, 12)
    var round: i64 = 0
    while round < 15:
        val ki0: u32 = rk[round * 2]
        val ki1: u32 = rk[round * 2 + 1]
        val fr = _f(r0, r1, ki0, ki1)
        val nl0: u32 = r0
        val nl1: u32 = r1
        val nr0: u32 = l0 ^ fr.0
        val nr1: u32 = l1 ^ fr.1
        l0 = nl0
        l1 = nl1
        r0 = nr0
        r1 = nr1
        round = round + 1
    val fr16 = _f(r0, r1, rk[30], rk[31])
    l0 = l0 ^ fr16.0
    l1 = l1 ^ fr16.1
    var out: [u8] = []
    out.push(((l0 >> 24) & 0xFFu32).to_u8())
    out.push(((l0 >> 16) & 0xFFu32).to_u8())
    out.push(((l0 >> 8) & 0xFFu32).to_u8())
    out.push((l0 & 0xFFu32).to_u8())
    out.push(((l1 >> 24) & 0xFFu32).to_u8())
    out.push(((l1 >> 16) & 0xFFu32).to_u8())
    out.push(((l1 >> 8) & 0xFFu32).to_u8())
    out.push((l1 & 0xFFu32).to_u8())
    out.push(((r0 >> 24) & 0xFFu32).to_u8())
    out.push(((r0 >> 16) & 0xFFu32).to_u8())
    out.push(((r0 >> 8) & 0xFFu32).to_u8())
    out.push((r0 & 0xFFu32).to_u8())
    out.push(((r1 >> 24) & 0xFFu32).to_u8())
    out.push(((r1 >> 16) & 0xFFu32).to_u8())
    out.push(((r1 >> 8) & 0xFFu32).to_u8())
    out.push((r1 & 0xFFu32).to_u8())
    out

# ============================================================================
# Feistel decrypt core
#
# Uses same structure as encrypt but iterates subkeys in reverse order.
# ============================================================================

fn seed_decrypt_block(key: [u8], block: [u8]) -> [u8]:
    val rk = _key_schedule(key)
    var l0: u32 = _load32be(block, 0)
    var l1: u32 = _load32be(block, 4)
    var r0: u32 = _load32be(block, 8)
    var r1: u32 = _load32be(block, 12)
    val fr16 = _f(r0, r1, rk[30], rk[31])
    l0 = l0 ^ fr16.0
    l1 = l1 ^ fr16.1
    var round: i64 = 14
    while round >= 0:
        val ki0: u32 = rk[round * 2]
        val ki1: u32 = rk[round * 2 + 1]
        val fr = _f(r0, r1, ki0, ki1)
        val nl0: u32 = r0
        val nl1: u32 = r1
        val nr0: u32 = l0 ^ fr.0
        val nr1: u32 = l1 ^ fr.1
        l0 = nl0
        l1 = nl1
        r0 = nr0
        r1 = nr1
        round = round - 1
    var out: [u8] = []
    out.push(((l0 >> 24) & 0xFFu32).to_u8())
    out.push(((l0 >> 16) & 0xFFu32).to_u8())
    out.push(((l0 >> 8) & 0xFFu32).to_u8())
    out.push((l0 & 0xFFu32).to_u8())
    out.push(((l1 >> 24) & 0xFFu32).to_u8())
    out.push(((l1 >> 16) & 0xFFu32).to_u8())
    out.push(((l1 >> 8) & 0xFFu32).to_u8())
    out.push((l1 & 0xFFu32).to_u8())
    out.push(((r0 >> 24) & 0xFFu32).to_u8())
    out.push(((r0 >> 16) & 0xFFu32).to_u8())
    out.push(((r0 >> 8) & 0xFFu32).to_u8())
    out.push((r0 & 0xFFu32).to_u8())
    out.push(((r1 >> 24) & 0xFFu32).to_u8())
    out.push(((r1 >> 16) & 0xFFu32).to_u8())
    out.push(((r1 >> 8) & 0xFFu32).to_u8())
    out.push((r1 & 0xFFu32).to_u8())
    out
