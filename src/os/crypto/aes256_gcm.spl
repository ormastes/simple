#![allow(unnamed_duplicate_typed_args)]
# AES-256-GCM — Pure Simple Implementation
#
# AES-256 in Galois/Counter Mode per NIST SP 800-38D.
# No SFFI/Rust FFI — pure Simple language, suitable for baremetal.
# Mirrors src/os/crypto/aes128_gcm.spl post-T3-cleanup.
#
# Reference: FIPS 197 (AES) — §5.2 key expansion, AES-256 special case
#            for word_index % NK == 4 (SubWord without RotWord/Rcon).
# Reference: NIST SP 800-38D (GCM) — Appendix B TC13–TC16.
#
# Required by TLS_AES_256_GCM_SHA384 (RFC 8446 §9.1, code point 0x1302).

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]
extern fn rt_aes_sbox(i: i64) -> i64
extern fn rt_aes_rcon(i: i64) -> i64
extern fn rt_aes256_encrypt_block_into(key: [u8], block: [u8], out: [u8]) -> i64
extern fn rt_tls13_aes256_gcm_encrypt(key: [u8], nonce: [u8], plaintext: [u8], aad: [u8]) -> [u8]

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

# ============================================================================
# AES S-Box / Rcon helpers (FIPS 197, §5.1.1 + §5.2)
# ============================================================================

fn _aes_sbox(index: i64) -> u8:
    rt_aes_sbox(index).to_u8()

fn _aes_rcon(index: i64) -> u32:
    rt_aes_rcon(index).to_u32()

# ============================================================================
# Result Type for Decryption
# ============================================================================

enum Aes256GcmResult:
    Ok(data: [u8])
    Err(msg: text)

# ============================================================================
# AES-256 Key Expansion (FIPS 197, Section 5.2)
#
# Two special cases (vs AES-128's single case):
#   word_idx % 8 == 0: RotWord + SubWord + XOR Rcon  (same as AES-128's nk==4)
#   word_idx % 8 == 4: SubWord ONLY (AES-256-only)
# ============================================================================

fn aes256_key_expansion(key: [u8]) -> [u8]:
    """Expand 32-byte AES-256 key into 240 round-key bytes (15 round keys)."""
    val nk: u64 = 8
    val nr: u64 = 14
    val total_words: u64 = 4 * (nr + 1)  # 60
    val total_bytes: u64 = total_words * 4

    var expanded: [u8] = rt_array_new_with_cap(total_bytes.to_i64())

    var i: u64 = 0
    while i < 32:
        expanded.push(_u8_at(key, i))
        i = i + 1

    var word_idx: u64 = nk
    while word_idx < total_words:
        val prev_base = (word_idx - 1) * 4
        var t0 = _u8_at(expanded, prev_base)
        var t1 = _u8_at(expanded, prev_base + 1)
        var t2 = _u8_at(expanded, prev_base + 2)
        var t3 = _u8_at(expanded, prev_base + 3)

        val m = word_idx % nk
        if m == 0:
            # RotWord + SubWord + Rcon
            val rot0 = t1
            val rot1 = t2
            val rot2 = t3
            val rot3 = t0
            t0 = _aes_sbox(rot0.to_i64())
            t1 = _aes_sbox(rot1.to_i64())
            t2 = _aes_sbox(rot2.to_i64())
            t3 = _aes_sbox(rot3.to_i64())
            val rcon = _aes_rcon(((word_idx / nk) - 1).to_i64())
            t0 = t0 ^ ((rcon >> 24) & 0xFF).to_u8()
            t1 = t1 ^ ((rcon >> 16) & 0xFF).to_u8()
            t2 = t2 ^ ((rcon >> 8) & 0xFF).to_u8()
            t3 = t3 ^ (rcon & 0xFF).to_u8()
        else:
            if m == 4:
                # AES-256-only: SubWord without RotWord, no Rcon
                t0 = _aes_sbox(t0.to_i64())
                t1 = _aes_sbox(t1.to_i64())
                t2 = _aes_sbox(t2.to_i64())
                t3 = _aes_sbox(t3.to_i64())

        val prev_word_base = (word_idx - nk) * 4
        expanded.push(_u8_at(expanded, prev_word_base) ^ t0)
        expanded.push(_u8_at(expanded, prev_word_base + 1) ^ t1)
        expanded.push(_u8_at(expanded, prev_word_base + 2) ^ t2)
        expanded.push(_u8_at(expanded, prev_word_base + 3) ^ t3)
        word_idx = word_idx + 1

    expanded

# ============================================================================
# AES-256 Encryption (single block) — extern-backed
# ============================================================================

fn aes256_encrypt_block(plaintext: [u8], key: [u8]) -> [u8]:
    """Encrypt one 16-byte block with AES-256 using the runtime helper.

    Note: unlike AES-128, the extern takes the raw 32-byte key (not the
    expanded schedule), since rt_aes256_encrypt_block_into runs key
    expansion internally.
    """
    var output: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        output.push(0x00)
        i = i + 1
    if rt_aes256_encrypt_block_into(key, plaintext, output) != 0:
        return []
    output

# ============================================================================
# GF(2^128) Multiplication for GHASH
# ============================================================================

fn gf128_mul(x: [u8], y: [u8]) -> [u8]:
    """Multiply two 128-bit elements in GF(2^128) (poly x^128 + x^7 + x^2 + x + 1)."""
    var z: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        z.push(0x00)
        i = i + 1

    var v: [u8] = rt_array_new_with_cap(16)
    i = 0
    while i < 16:
        v.push(_u8_at(y, i))
        i = i + 1

    i = 0
    while i < 128:
        val byte_idx = i / 8
        val bit_idx = 7 - (i % 8)

        if ((_u8_at(x, byte_idx) >> bit_idx) & 0x01) != 0:
            var z_next: [u8] = rt_array_new_with_cap(16)
            var j: u64 = 0
            while j < 16:
                z_next.push(_u8_at(z, j) ^ _u8_at(v, j))
                j = j + 1
            z = z_next

        val lsb = _u8_at(v, 15) & 0x01
        var v_next: [u8] = rt_array_new_with_cap(16)
        var first = (_u8_at(v, 0).to_u32() >> 1).to_u8()
        if lsb != 0:
            first = first ^ 0xE1
        v_next.push(first)
        var j: u64 = 1
        while j < 16:
            val cur = _u8_at(v, j).to_u32()
            val prev = _u8_at(v, j - 1).to_u32()
            v_next.push((((cur >> 1) | ((prev & 0x01) << 7)) & 0xFF).to_u8())
            j = j + 1
        v = v_next
        i = i + 1

    z

# ============================================================================
# GHASH
# ============================================================================

fn _ghash_block(h: [u8], y: [u8], x_block: [u8]) -> [u8]:
    """Process one 16-byte block: Y_i = (Y_{i-1} XOR X_i) * H."""
    var xored: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        xored.push(_u8_at(y, i) ^ _u8_at(x_block, i))
        i = i + 1
    gf128_mul(xored, h)

fn _pad_to_16(data: [u8]) -> [u8]:
    """Pad data to a multiple of 16 bytes with zeros."""
    val padded_len = if (data.len() % 16) == 0:
        data.len()
    else:
        ((data.len() / 16) + 1) * 16
    var result: [u8] = rt_array_new_with_cap(padded_len.to_i64())
    var i: u64 = 0
    while i < data.len():
        result.push(_u8_at(data, i))
        i = i + 1
    while (result.len() % 16) != 0:
        result.push(0x00)
    result

fn _append_bytes(a: [u8], b: [u8]) -> [u8]:
    """Append two byte arrays."""
    var out: [u8] = rt_array_new_with_cap((a.len() + b.len()).to_i64())
    var i: u64 = 0
    while i < a.len():
        out.push(_u8_at(a, i))
        i = i + 1
    i = 0
    while i < b.len():
        out.push(_u8_at(b, i))
        i = i + 1
    out

fn ghash(h: [u8], aad: [u8], ciphertext: [u8]) -> [u8]:
    """Compute GHASH for GCM: pad(A) || pad(C) || len(A) || len(C)."""
    var y: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        y.push(0x00)
        i = i + 1

    val padded_aad = _pad_to_16(aad)
    i = 0
    while i < padded_aad.len():
        var block: [u8] = rt_array_new_with_cap(16)
        var j: u64 = 0
        while j < 16:
            block.push(_u8_at(padded_aad, i + j))
            j = j + 1
        y = _ghash_block(h, y, block)
        i = i + 16

    val padded_ct = _pad_to_16(ciphertext)
    i = 0
    while i < padded_ct.len():
        var block: [u8] = rt_array_new_with_cap(16)
        var j: u64 = 0
        while j < 16:
            block.push(_u8_at(padded_ct, i + j))
            j = j + 1
        y = _ghash_block(h, y, block)
        i = i + 16

    val aad_bits: u64 = aad.len() * 8
    val ct_bits: u64 = ciphertext.len() * 8

    var len_block: [u8] = rt_array_new_with_cap(16)
    len_block.push(((aad_bits >> 56) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 48) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 40) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 32) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 24) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 16) & 0xFF).to_u8())
    len_block.push(((aad_bits >> 8) & 0xFF).to_u8())
    len_block.push((aad_bits & 0xFF).to_u8())
    len_block.push(((ct_bits >> 56) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 48) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 40) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 32) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 24) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 16) & 0xFF).to_u8())
    len_block.push(((ct_bits >> 8) & 0xFF).to_u8())
    len_block.push((ct_bits & 0xFF).to_u8())

    y = _ghash_block(h, y, len_block)
    y

# ============================================================================
# GCTR — AES-CTR with Incrementing Counter (AES-256 variant)
# ============================================================================

fn _inc32(counter: [u8]) -> [u8]:
    """Increment the rightmost 32 bits of a 16-byte counter block."""
    val c = (_u8_at(counter, 12).to_u32() << 24) |
            (_u8_at(counter, 13).to_u32() << 16) |
            (_u8_at(counter, 14).to_u32() << 8) |
            _u8_at(counter, 15).to_u32()
    val c_inc = (c + 1) & 0xFFFFFFFF

    var result: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 12:
        result.push(_u8_at(counter, i))
        i = i + 1
    result.push(((c_inc >> 24) & 0xFF).to_u8())
    result.push(((c_inc >> 16) & 0xFF).to_u8())
    result.push(((c_inc >> 8) & 0xFF).to_u8())
    result.push((c_inc & 0xFF).to_u8())
    result

fn gctr256(key: [u8], icb: [u8], input: [u8]) -> [u8]:
    """AES-256-CTR: encrypts each block by XORing with AES_K(counter)."""
    if input.len() == 0:
        return []

    var output: [u8] = rt_array_new_with_cap(input.len().to_i64())
    var cb = icb
    val num_full_blocks = input.len() / 16

    var i: u64 = 0
    while i < num_full_blocks:
        val enc_cb = aes256_encrypt_block(cb, key)
        val offset = i * 16
        var j: u64 = 0
        while j < 16:
            output.push(_u8_at(input, offset + j) ^ _u8_at(enc_cb, j))
            j = j + 1
        cb = _inc32(cb)
        i = i + 1

    val remaining = input.len() % 16
    if remaining > 0:
        val enc_cb = aes256_encrypt_block(cb, key)
        val offset = num_full_blocks * 16
        var j: u64 = 0
        while j < remaining:
            output.push(_u8_at(input, offset + j) ^ _u8_at(enc_cb, j))
            j = j + 1

    output

# ============================================================================
# AES-256-GCM Encryption
# ============================================================================

fn _make_j0(nonce: [u8]) -> [u8]:
    """J0 = nonce || 0x00000001 (12-byte nonce path, RFC 5288 / SP 800-38D)."""
    var j0: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 12:
        j0.push(_u8_at(nonce, i))
        i = i + 1
    j0.push(0x00)
    j0.push(0x00)
    j0.push(0x00)
    j0.push(0x01)
    j0

fn aes256_gcm_encrypt(key: [u8], nonce: [u8], plaintext: [u8], aad: [u8]) -> [u8]:
    """AES-256-GCM authenticated encryption.

    Args:
        key: 32-byte AES-256 key.
        nonce: 12-byte nonce (IV).
        plaintext: Data to encrypt.
        aad: Additional authenticated data.

    Returns: ciphertext || 16-byte authentication tag (concatenated).

    Compile-mode fast-path: pure-Simple GHASH/AES uses [u32] shifts that
    Cranelift miscompiles. Delegate to rt_tls13_aes256_gcm_encrypt; the C
    extern returns ciphertext || tag matching this contract.
    """
    val fast = rt_tls13_aes256_gcm_encrypt(key, nonce, plaintext, aad)
    if fast.len() != 0:
        return fast

    # Compute hash subkey H = AES_K(0^128)
    var zero_block: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        zero_block.push(0x00)
        i = i + 1
    val h = aes256_encrypt_block(zero_block, key)

    val j0 = _make_j0(nonce)

    val icb = _inc32(j0)
    val ciphertext = gctr256(key, icb, plaintext)

    val s = ghash(h, aad, ciphertext)

    val tag = gctr256(key, j0, s)

    _append_bytes(ciphertext, tag)

# ============================================================================
# AES-256-GCM Decryption
# ============================================================================

fn aes256_gcm_decrypt(key: [u8], nonce: [u8], ciphertext: [u8], aad: [u8], tag: [u8]) -> Aes256GcmResult:
    """AES-256-GCM authenticated decryption with constant-time tag check."""
    var zero_block: [u8] = rt_array_new_with_cap(16)
    var i: u64 = 0
    while i < 16:
        zero_block.push(0x00)
        i = i + 1
    val h = aes256_encrypt_block(zero_block, key)

    val j0 = _make_j0(nonce)
    val s = ghash(h, aad, ciphertext)
    val expected_tag = gctr256(key, j0, s)

    var diff: u8 = 0x00
    i = 0
    while i < 16:
        diff = diff | (_u8_at(expected_tag, i) ^ _u8_at(tag, i))
        i = i + 1

    if diff != 0:
        return Aes256GcmResult.Err("authentication tag mismatch")

    val icb = _inc32(j0)
    val plaintext = gctr256(key, icb, ciphertext)

    Aes256GcmResult.Ok(data: plaintext)
