    t

fn _inv_sbox(index: i64) -> u8:
    val tbl = _aes_inv_sbox_table()
    _u8_at(tbl, (index & 0xFF).to_u64())

fn _xtime(b: u32) -> u32:
    val shifted = (b << 1) & 0xFF
    if (b & 0x80) != 0:
        (shifted ^ 0x1B) & 0xFF
    else:
        shifted

fn _gf_mul(a: u32, b: u32) -> u32:
    var result: u32 = 0
    var aa = a
    var bb = b
    var i: u32 = 0
    while i < 8:
        if (bb & 1) != 0:
            result = result ^ aa
        aa = _xtime(aa)
        bb = bb >> 1
        i = i + 1
    result & 0xFF

fn _aes_decrypt_block_pure(block: [u8], expanded_key: [u8], num_rounds: i64) -> [u8]:
    var state: [u8] = rt_array_new_with_cap(16)
    var si: u64 = 0
    while si < 16:
        state.push(_u8_at(block, si))
        si = si + 1

    # AddRoundKey with last round key
    val nr = num_rounds.to_u64()
    var rk_off: u64 = nr * 16
    var xi: u64 = 0
    while xi < 16:
        state[xi] = _u8_at(state, xi) ^ _u8_at(expanded_key, rk_off + xi)
        xi = xi + 1

    # Main rounds: Nr-1 down to 1
    var rnd: u64 = nr - 1
    while rnd >= 1:
        # InvShiftRows — state is column-major; rows are shifted right
        var tmp: [u8] = rt_array_new_with_cap(16)
        # Row 0: no shift
        tmp.push(_u8_at(state, 0))
        tmp.push(_u8_at(state, 4))
        tmp.push(_u8_at(state, 8))
        tmp.push(_u8_at(state, 12))
        # Row 1: right by 1
        tmp.push(_u8_at(state, 13))
        tmp.push(_u8_at(state, 1))
        tmp.push(_u8_at(state, 5))
        tmp.push(_u8_at(state, 9))
        # Row 2: right by 2
        tmp.push(_u8_at(state, 10))
        tmp.push(_u8_at(state, 14))
        tmp.push(_u8_at(state, 2))
        tmp.push(_u8_at(state, 6))
        # Row 3: right by 3
        tmp.push(_u8_at(state, 7))
        tmp.push(_u8_at(state, 11))
        tmp.push(_u8_at(state, 15))
        tmp.push(_u8_at(state, 3))

        # InvSubBytes
        var sub: [u8] = rt_array_new_with_cap(16)
        var ssi: u64 = 0
        while ssi < 16:
            sub.push(_inv_sbox(_u8_at(tmp, ssi).to_i64()))
            ssi = ssi + 1

        # AddRoundKey
        rk_off = rnd * 16
        var ark: [u8] = rt_array_new_with_cap(16)
        var ai: u64 = 0
        while ai < 16:
            ark.push(_u8_at(sub, ai) ^ _u8_at(expanded_key, rk_off + ai))
            ai = ai + 1

        # InvMixColumns
        var mc: [u8] = rt_array_new_with_cap(16)
        var col: u64 = 0
        while col < 4:
            val b0 = _u8_at(ark, col * 4).to_u32()
            val b1 = _u8_at(ark, col * 4 + 1).to_u32()
            val b2 = _u8_at(ark, col * 4 + 2).to_u32()
            val b3 = _u8_at(ark, col * 4 + 3).to_u32()
            mc.push((_gf_mul(0x0e, b0) ^ _gf_mul(0x0b, b1) ^ _gf_mul(0x0d, b2) ^ _gf_mul(0x09, b3)).to_u8())
            mc.push((_gf_mul(0x09, b0) ^ _gf_mul(0x0e, b1) ^ _gf_mul(0x0b, b2) ^ _gf_mul(0x0d, b3)).to_u8())
            mc.push((_gf_mul(0x0d, b0) ^ _gf_mul(0x09, b1) ^ _gf_mul(0x0e, b2) ^ _gf_mul(0x0b, b3)).to_u8())
            mc.push((_gf_mul(0x0b, b0) ^ _gf_mul(0x0d, b1) ^ _gf_mul(0x09, b2) ^ _gf_mul(0x0e, b3)).to_u8())
            col = col + 1

        state = mc
        rnd = rnd - 1

    # Final round (no InvMixColumns)
    # InvShiftRows
    var ftmp: [u8] = rt_array_new_with_cap(16)
    ftmp.push(_u8_at(state, 0))
    ftmp.push(_u8_at(state, 4))
    ftmp.push(_u8_at(state, 8))
    ftmp.push(_u8_at(state, 12))
    ftmp.push(_u8_at(state, 13))
    ftmp.push(_u8_at(state, 1))
    ftmp.push(_u8_at(state, 5))
    ftmp.push(_u8_at(state, 9))
    ftmp.push(_u8_at(state, 10))
    ftmp.push(_u8_at(state, 14))
    ftmp.push(_u8_at(state, 2))
    ftmp.push(_u8_at(state, 6))
    ftmp.push(_u8_at(state, 7))
    ftmp.push(_u8_at(state, 11))
    ftmp.push(_u8_at(state, 15))
    ftmp.push(_u8_at(state, 3))

    # InvSubBytes
    var fsub: [u8] = rt_array_new_with_cap(16)
    var fi: u64 = 0
    while fi < 16:
        fsub.push(_inv_sbox(_u8_at(ftmp, fi).to_i64()))
        fi = fi + 1

    # AddRoundKey with round key 0
    var result: [u8] = rt_array_new_with_cap(16)
    var ri: u64 = 0
    while ri < 16:
        result.push(_u8_at(fsub, ri) ^ _u8_at(expanded_key, ri))
        ri = ri + 1

    result

fn _aes128_decrypt_block(block: [u8], key: [u8]) -> [u8]:
    val expanded = aes128_key_expansion(key)
    _aes_decrypt_block_pure(block, expanded, 10)

fn _aes256_decrypt_block(block: [u8], key: [u8]) -> [u8]:
    _aes256_decrypt_block_with_raw_key(block, key)

# Inline AES-256 key expansion mirror — copy of aes256_gcm.aes256_key_expansion.
# We DO NOT import aes256_key_expansion (not re-exported in W13-A surface),
# so we need our own copy that produces the 240-byte schedule.

fn _aes_sbox_table() -> [u8]:
    var t: [u8] = rt_array_new_with_cap(256)
    t.push(0x63) ; t.push(0x7c) ; t.push(0x77) ; t.push(0x7b)
