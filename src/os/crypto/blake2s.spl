#![allow(unnamed_duplicate_typed_args)]
# BLAKE2s — Pure Simple Implementation (RFC 7693)
#
# 32-bit BLAKE2 variant with output 1..32 bytes and key 0..32 bytes.
# Pure Simple language only, no externs, suitable for baremetal.
#
# Reference: RFC 7693 §2-3. IV equals the SHA-256 IV (RFC 7693 §2.6).
#
# u32 truncation: Simple's u64 ops do not auto-truncate; every result is
# masked with U32_MASK after additions and rotations to keep it in 32 bits.

# ============================================================================
# Constants — RFC 7693 §2.6 IV (= SHA-256 IV) and §2.7 SIGMA permutation
# ============================================================================

fn _b2s_iv() -> [u64]:
    """BLAKE2s IV (RFC 7693 §2.6) — same constants as SHA-256 IV.

    Stored as u64 for arithmetic convenience; high 32 bits always zero.
    """
    var iv: [u64] = []
    iv.push(0x6a09e667)
    iv.push(0xbb67ae85)
    iv.push(0x3c6ef372)
    iv.push(0xa54ff53a)
    iv.push(0x510e527f)
    iv.push(0x9b05688c)
    iv.push(0x1f83d9ab)
    iv.push(0x5be0cd19)
    iv

fn _sigma_s(round_idx: i64, j: i64) -> i64:
    """SIGMA[round_idx][j] permutation (RFC 7693 §2.7).

    BLAKE2s uses 10 rounds, exact match to the 10-row SIGMA.
    """
    val r = round_idx
    if r == 0:
        if j == 0: return 0
        if j == 1: return 1
        if j == 2: return 2
        if j == 3: return 3
        if j == 4: return 4
        if j == 5: return 5
        if j == 6: return 6
        if j == 7: return 7
        if j == 8: return 8
        if j == 9: return 9
        if j == 10: return 10
        if j == 11: return 11
        if j == 12: return 12
        if j == 13: return 13
        if j == 14: return 14
        return 15
    if r == 1:
        if j == 0: return 14
        if j == 1: return 10
        if j == 2: return 4
        if j == 3: return 8
        if j == 4: return 9
        if j == 5: return 15
        if j == 6: return 13
        if j == 7: return 6
        if j == 8: return 1
        if j == 9: return 12
        if j == 10: return 0
        if j == 11: return 2
        if j == 12: return 11
        if j == 13: return 7
        if j == 14: return 5
        return 3
    if r == 2:
        if j == 0: return 11
        if j == 1: return 8
        if j == 2: return 12
        if j == 3: return 0
        if j == 4: return 5
        if j == 5: return 2
        if j == 6: return 15
        if j == 7: return 13
        if j == 8: return 10
        if j == 9: return 14
        if j == 10: return 3
        if j == 11: return 6
        if j == 12: return 7
        if j == 13: return 1
        if j == 14: return 9
        return 4
    if r == 3:
        if j == 0: return 7
        if j == 1: return 9
        if j == 2: return 3
        if j == 3: return 1
        if j == 4: return 13
        if j == 5: return 12
        if j == 6: return 11
        if j == 7: return 14
        if j == 8: return 2
        if j == 9: return 6
        if j == 10: return 5
        if j == 11: return 10
        if j == 12: return 4
        if j == 13: return 0
        if j == 14: return 15
        return 8
    if r == 4:
        if j == 0: return 9
        if j == 1: return 0
        if j == 2: return 5
        if j == 3: return 7
        if j == 4: return 2
        if j == 5: return 4
        if j == 6: return 10
        if j == 7: return 15
        if j == 8: return 14
        if j == 9: return 1
        if j == 10: return 11
        if j == 11: return 12
        if j == 12: return 6
        if j == 13: return 8
        if j == 14: return 3
        return 13
    if r == 5:
        if j == 0: return 2
        if j == 1: return 12
        if j == 2: return 6
        if j == 3: return 10
        if j == 4: return 0
        if j == 5: return 11
        if j == 6: return 8
        if j == 7: return 3
        if j == 8: return 4
        if j == 9: return 13
        if j == 10: return 7
        if j == 11: return 5
        if j == 12: return 15
        if j == 13: return 14
        if j == 14: return 1
        return 9
    if r == 6:
        if j == 0: return 12
        if j == 1: return 5
        if j == 2: return 1
        if j == 3: return 15
        if j == 4: return 14
        if j == 5: return 13
        if j == 6: return 4
        if j == 7: return 10
        if j == 8: return 0
        if j == 9: return 7
        if j == 10: return 6
        if j == 11: return 3
        if j == 12: return 9
        if j == 13: return 2
        if j == 14: return 8
        return 11
    if r == 7:
        if j == 0: return 13
        if j == 1: return 11
        if j == 2: return 7
        if j == 3: return 14
        if j == 4: return 12
        if j == 5: return 1
        if j == 6: return 3
        if j == 7: return 9
        if j == 8: return 5
        if j == 9: return 0
        if j == 10: return 15
        if j == 11: return 4
        if j == 12: return 8
        if j == 13: return 6
        if j == 14: return 2
        return 10
    if r == 8:
        if j == 0: return 6
        if j == 1: return 15
        if j == 2: return 14
        if j == 3: return 9
        if j == 4: return 11
        if j == 5: return 3
        if j == 6: return 0
        if j == 7: return 8
        if j == 8: return 12
        if j == 9: return 2
        if j == 10: return 13
        if j == 11: return 7
        if j == 12: return 1
        if j == 13: return 4
        if j == 14: return 10
        return 5
    # r == 9
    if j == 0: return 10
    if j == 1: return 2
    if j == 2: return 8
    if j == 3: return 4
    if j == 4: return 7
    if j == 5: return 6
    if j == 6: return 1
    if j == 7: return 5
    if j == 8: return 15
    if j == 9: return 11
    if j == 10: return 9
    if j == 11: return 14
    if j == 12: return 3
    if j == 13: return 12
    if j == 14: return 13
    return 0

# ============================================================================
# Bit Manipulation Helpers (u32 emulated on u64)
# ============================================================================

fn _rotr32(x: u64, n: u64) -> u64:
    """32-bit right rotation. x must be in 32-bit range; result is in 32-bit range."""
    val xm = x & 0xFFFFFFFF
    ((xm >> n) | (xm << (32 - n))) & 0xFFFFFFFF

# ============================================================================
# G mixing function — RFC 7693 §3.1 (BLAKE2s rotation constants 16,12,8,7)
# ============================================================================

fn _g_mix_s(v: [u64], a: i64, b: i64, c: i64, d: i64, x: u64, y: u64) -> [u64]:
    """G mixing function for BLAKE2s. Returns updated state vector.

    All adds masked to 32 bits.
    """
    var va = v[a]
    var vb = v[b]
    var vc = v[c]
    var vd = v[d]

    va = (va + vb + x) & 0xFFFFFFFF
    vd = _rotr32(vd ^ va, 16)
    vc = (vc + vd) & 0xFFFFFFFF
    vb = _rotr32(vb ^ vc, 12)
    va = (va + vb + y) & 0xFFFFFFFF
    vd = _rotr32(vd ^ va, 8)
    vc = (vc + vd) & 0xFFFFFFFF
    vb = _rotr32(vb ^ vc, 7)

    var out: [u64] = []
    var i: i64 = 0
    while i < 16:
        if i == a:
            out.push(va)
        else:
            if i == b:
                out.push(vb)
            else:
                if i == c:
                    out.push(vc)
                else:
                    if i == d:
                        out.push(vd)
                    else:
                        out.push(v[i])
        i = i + 1
    out

# ============================================================================
# F compression — RFC 7693 §3.2 (10 rounds, 64-byte block)
# ============================================================================

fn _f_compress_s(h: [u64], block: [u8], offset: i64, t0: u64, t1: u64, last: bool) -> [u64]:
    """F compression for BLAKE2s: 10 rounds over a 64-byte block."""
    val iv = _b2s_iv()

    # Initialize work vector v[0..15]
    var v: [u64] = []
    var i: i64 = 0
    while i < 8:
        v.push(h[i])
        i = i + 1
    i = 0
    while i < 8:
        v.push(iv[i])
        i = i + 1

    # XOR offset counter into v[12], v[13]
    v[12] = v[12] ^ (t0 & 0xFFFFFFFF)
    v[13] = v[13] ^ (t1 & 0xFFFFFFFF)

    # If last block, invert v[14] (f0 = 0xFFFFFFFF)
    if last:
        v[14] = v[14] ^ 0xFFFFFFFF

    # Decode 16 little-endian 32-bit message words m[0..15]
    var m: [u64] = []
    var k: i64 = 0
    while k < 16:
        val base = offset + k * 4
        val w: u64 = block[base].to_u64() |
            (block[base + 1].to_u64() << 8) |
            (block[base + 2].to_u64() << 16) |
            (block[base + 3].to_u64() << 24)
        m.push(w)
        k = k + 1

    # 10 rounds
    var r: i64 = 0
    while r < 10:
        # Column step
        v = _g_mix_s(v, 0, 4,  8, 12, m[_sigma_s(r,  0)], m[_sigma_s(r,  1)])
        v = _g_mix_s(v, 1, 5,  9, 13, m[_sigma_s(r,  2)], m[_sigma_s(r,  3)])
        v = _g_mix_s(v, 2, 6, 10, 14, m[_sigma_s(r,  4)], m[_sigma_s(r,  5)])
        v = _g_mix_s(v, 3, 7, 11, 15, m[_sigma_s(r,  6)], m[_sigma_s(r,  7)])
        # Diagonal step
        v = _g_mix_s(v, 0, 5, 10, 15, m[_sigma_s(r,  8)], m[_sigma_s(r,  9)])
        v = _g_mix_s(v, 1, 6, 11, 12, m[_sigma_s(r, 10)], m[_sigma_s(r, 11)])
        v = _g_mix_s(v, 2, 7,  8, 13, m[_sigma_s(r, 12)], m[_sigma_s(r, 13)])
        v = _g_mix_s(v, 3, 4,  9, 14, m[_sigma_s(r, 14)], m[_sigma_s(r, 15)])
        r = r + 1

    # Mix v back into h, all masked to 32 bits
    var new_h: [u64] = []
    i = 0
    while i < 8:
        new_h.push((h[i] ^ v[i] ^ v[i + 8]) & 0xFFFFFFFF)
        i = i + 1
    new_h

# ============================================================================
# Public API — blake2s(key, msg, out_len)
# ============================================================================

fn blake2s(key: [u8], msg: [u8], out_len: i64) -> [u8]:
    """BLAKE2s hash with optional key and variable output length.

    Args:
        key: 0..32 byte key (empty = unkeyed).
        msg: arbitrary message bytes.
        out_len: 1..32 desired digest bytes.

    Returns: digest of `out_len` bytes.

    Reference: RFC 7693 §3.3.
    """
    val key_len = key.len()
    val msg_len = msg.len()

    # Initialize chaining state h = IV; mix parameter block into h[0]
    # Parameter block (RFC 7693 §2.5): nn (digest_length) | kk (key_length) | 1 | 1
    # h[0] ^= 0x01010000 ^ (kk << 8) ^ nn  (mask to 32 bits)
    var h = _b2s_iv()
    val param: u64 = (0x01010000 ^ (key_len.to_u64() << 8) ^ out_len.to_u64()) & 0xFFFFFFFF
    h[0] = h[0] ^ param

    # Build the input stream: if keyed, first 64 bytes = key padded with zeros.
    var stream: [u8] = []
    var stream_len: i64 = 0
    if key_len > 0:
        var i: i64 = 0
        while i < key_len:
            stream.push(key[i])
            i = i + 1
            stream_len = stream_len + 1
        while stream_len < 64:
            stream.push(0)
            stream_len = stream_len + 1
    var j: i64 = 0
    while j < msg_len:
        stream.push(msg[j])
        j = j + 1
        stream_len = stream_len + 1

    if stream_len == 0:
        var k: i64 = 0
        while k < 64:
            stream.push(0)
            k = k + 1
        h = _f_compress_s(h, stream, 0, 0, 0, true)
    else:
        val absorbed_key_bytes: i64 = if key_len > 0: 64 else: 0
        val total_input_bytes: i64 = absorbed_key_bytes + msg_len

        while (stream_len % 64) != 0:
            stream.push(0)
            stream_len = stream_len + 1

        val total_chunks: i64 = stream_len / 64
        var chunk_idx: i64 = 0
        var bytes_processed: i64 = 0

        while chunk_idx < total_chunks - 1:
            bytes_processed = bytes_processed + 64
            h = _f_compress_s(h, stream, chunk_idx * 64, bytes_processed.to_u64(), 0, false)
            chunk_idx = chunk_idx + 1

        h = _f_compress_s(h, stream, chunk_idx * 64, total_input_bytes.to_u64(), 0, true)

    # Serialize first out_len bytes of h as little-endian (4 bytes per word, 32-bit)
    var out: [u8] = []
    var widx: i64 = 0
    var produced: i64 = 0
    while produced < out_len:
        val word = h[widx]
        var shift: u64 = 0
        while shift < 32 and produced < out_len:
            out.push(((word >> shift) & 0xFF).to_u8())
            produced = produced + 1
            shift = shift + 8
        widx = widx + 1
    out
