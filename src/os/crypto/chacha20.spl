# ChaCha20 Stream Cipher — Pure Simple Implementation (RFC 7539)
#
# Extracted from random.spl for shared use by SSH ChaCha20-Poly1305
# and the CSPRNG. All operations use u32 — 32-bit safe, no float.
#
# Reference: RFC 7539 (ChaCha20 and Poly1305 for IETF Protocols)

# ============================================================================
# Helpers
# ============================================================================

fn _u32_mask(x: u32) -> u32:
    """Mask to 32 bits."""
    x & 0xFFFFFFFFu32

fn _rotl32(x: u32, n: u32) -> u32:
    """32-bit left rotation."""
    _u32_mask((x << n) | (x >> (32u32 - n)))

fn _quarter_round_values(a: u32, b: u32, c: u32, d: u32) -> (u32, u32, u32, u32):
    """ChaCha20 quarter-round over four words."""
    var wa = _u32_mask(a + b)
    var wd = _rotl32(d ^ wa, 16u32)

    var wc = _u32_mask(c + wd)
    var wb = _rotl32(b ^ wc, 12u32)

    wa = _u32_mask(wa + wb)
    wd = _rotl32(wd ^ wa, 8u32)

    wc = _u32_mask(wc + wd)
    wb = _rotl32(wb ^ wc, 7u32)

    (wa, wb, wc, wd)

# ============================================================================
# ChaCha20 Block Function
# ============================================================================

fn chacha20_block(key: [u32], counter: u32, nonce: [u32]) -> [u32]:
    """Generate one 64-byte ChaCha20 keystream block.

    State layout (16 x u32):
      [0..3]   = "expand 32-byte k" (constants)
      [4..11]  = 256-bit key (8 words)
      [12]     = 32-bit counter
      [13..15] = 96-bit nonce (3 words)
    """
    val s0 = 0x61707865u32
    val s1 = 0x3320646eu32
    val s2 = 0x79622d32u32
    val s3 = 0x6b206574u32
    val s4 = key[0]
    val s5 = key[1]
    val s6 = key[2]
    val s7 = key[3]
    val s8 = key[4]
    val s9 = key[5]
    val s10 = key[6]
    val s11 = key[7]
    val s12 = counter
    val s13 = nonce[0]
    val s14 = nonce[1]
    val s15 = nonce[2]

    var w0 = s0
    var w1 = s1
    var w2 = s2
    var w3 = s3
    var w4 = s4
    var w5 = s5
    var w6 = s6
    var w7 = s7
    var w8 = s8
    var w9 = s9
    var w10 = s10
    var w11 = s11
    var w12 = s12
    var w13 = s13
    var w14 = s14
    var w15 = s15

    var round: u64 = 0
    while round < 10:
        val (q0, q4, q8, q12) = _quarter_round_values(w0, w4, w8, w12)
        w0 = q0
        w4 = q4
        w8 = q8
        w12 = q12
        val (q1, q5, q9, q13) = _quarter_round_values(w1, w5, w9, w13)
        w1 = q1
        w5 = q5
        w9 = q9
        w13 = q13
        val (q2, q6, q10, q14) = _quarter_round_values(w2, w6, w10, w14)
        w2 = q2
        w6 = q6
        w10 = q10
        w14 = q14
        val (q3, q7, q11, q15) = _quarter_round_values(w3, w7, w11, w15)
        w3 = q3
        w7 = q7
        w11 = q11
        w15 = q15
        val (d0, d5, d10, d15) = _quarter_round_values(w0, w5, w10, w15)
        w0 = d0
        w5 = d5
        w10 = d10
        w15 = d15
        val (d1, d6, d11, d12) = _quarter_round_values(w1, w6, w11, w12)
        w1 = d1
        w6 = d6
        w11 = d11
        w12 = d12
        val (d2, d7, d8, d13) = _quarter_round_values(w2, w7, w8, w13)
        w2 = d2
        w7 = d7
        w8 = d8
        w13 = d13
        val (d3, d4, d9, d14) = _quarter_round_values(w3, w4, w9, w14)
        w3 = d3
        w4 = d4
        w9 = d9
        w14 = d14
        round = round + 1

    var result: [u32] = []
    result.push(_u32_mask(w0 + s0))
    result.push(_u32_mask(w1 + s1))
    result.push(_u32_mask(w2 + s2))
    result.push(_u32_mask(w3 + s3))
    result.push(_u32_mask(w4 + s4))
    result.push(_u32_mask(w5 + s5))
    result.push(_u32_mask(w6 + s6))
    result.push(_u32_mask(w7 + s7))
    result.push(_u32_mask(w8 + s8))
    result.push(_u32_mask(w9 + s9))
    result.push(_u32_mask(w10 + s10))
    result.push(_u32_mask(w11 + s11))
    result.push(_u32_mask(w12 + s12))
    result.push(_u32_mask(w13 + s13))
    result.push(_u32_mask(w14 + s14))
    result.push(_u32_mask(w15 + s15))
    result

# ============================================================================
# ChaCha20 Encrypt/Decrypt (same operation — XOR with keystream)
# ============================================================================

fn chacha20_encrypt(key: [u8], counter: u32, nonce: [u8], plaintext: [u8]) -> [u8]:
    """Encrypt/decrypt data using ChaCha20.

    Args:
        key: 32-byte key.
        counter: Initial block counter.
        nonce: 12-byte nonce.
        plaintext: Data to encrypt (or ciphertext to decrypt).

    Returns: Output bytes (same length as input).
    """
    # Convert key bytes to u32 words (little-endian)
    var key_words: [u32] = []
    var i: u64 = 0
    while i < 8:
        val base = i * 4
        val word = key[base].to_u32() |
                   (key[base + 1].to_u32() << 8) |
                   (key[base + 2].to_u32() << 16) |
                   (key[base + 3].to_u32() << 24)
        key_words.push(word)
        i = i + 1

    # Convert nonce bytes to u32 words (little-endian)
    var nonce_words: [u32] = []
    i = 0
    while i < 3:
        val base = i * 4
        val word = nonce[base].to_u32() |
                   (nonce[base + 1].to_u32() << 8) |
                   (nonce[base + 2].to_u32() << 16) |
                   (nonce[base + 3].to_u32() << 24)
        nonce_words.push(word)
        i = i + 1

    var output: [u8] = []
    var block_counter = counter
    var pos: u64 = 0

    while pos < plaintext.len():
        val block = chacha20_block(key_words, block_counter, nonce_words)

        # Convert block to bytes and XOR
        var j: u64 = 0
        while j < 16 and pos < plaintext.len():
            val word = block[j]
            var b: u64 = 0
            while b < 4 and pos < plaintext.len():
                val keystream_byte = ((word >> (b * 8)) & 0xFF).to_u8()
                output.push(plaintext[pos] ^ keystream_byte)
                pos = pos + 1
                b = b + 1
            j = j + 1

        block_counter = _u32_mask(block_counter + 1u32)

    output

# ============================================================================
# SIMD Vectorized Path (Phase 1 SIMD int intrinsics, 2026-05-01)
#
# Layout: VERTICAL 4-block parallel.
#   - 16 Vec4i state words; each Vec4i lane holds the same word position from
#     four independent blocks (counter+0, +1, +2, +3).
#   - Diagonal rounds operate on the same word positions across blocks, so no
#     inter-lane shuffles are needed (Phase 1 has no shuffle/permute op).
#
# Op map:
#   - bitwise XOR / shl / shr / or  -> simd_xor_i32x4 / simd_shl_i32x4 /
#     simd_shr_i32x4 / simd_or_i32x4 (Phase 1 wired ops)
#   - mod-2^32 add  -> direct field arithmetic on i32 lanes.
#   - xor/or/shifts -> direct field arithmetic with u32 bit-pattern conversion.
#
# Speedup is bounded by the bitwise/rotate fraction of work; in interpreter
# mode the SIMD wins on XOR+rotate may not exceed the per-call extern cost.
# Documented bench in commit message.
# ============================================================================

struct Vec4i:
    x: i32
    y: i32
    z: i32
    w: i32

impl Vec4i:
    static fn splat(value: i32) -> Vec4i:
        Vec4i(x: value, y: value, z: value, w: value)

fn simd_xor_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
    Vec4i(
        x: _u32_to_i32(_i32_to_u32(a.x) ^ _i32_to_u32(b.x)),
        y: _u32_to_i32(_i32_to_u32(a.y) ^ _i32_to_u32(b.y)),
        z: _u32_to_i32(_i32_to_u32(a.z) ^ _i32_to_u32(b.z)),
        w: _u32_to_i32(_i32_to_u32(a.w) ^ _i32_to_u32(b.w)),
    )

fn simd_or_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
    Vec4i(
        x: _u32_to_i32(_i32_to_u32(a.x) | _i32_to_u32(b.x)),
        y: _u32_to_i32(_i32_to_u32(a.y) | _i32_to_u32(b.y)),
        z: _u32_to_i32(_i32_to_u32(a.z) | _i32_to_u32(b.z)),
        w: _u32_to_i32(_i32_to_u32(a.w) | _i32_to_u32(b.w)),
    )

fn simd_shl_i32x4(a: Vec4i, n: i64) -> Vec4i:
    val shift = n.to_u32()
    Vec4i(
        x: _u32_to_i32(_i32_to_u32(a.x) << shift),
        y: _u32_to_i32(_i32_to_u32(a.y) << shift),
        z: _u32_to_i32(_i32_to_u32(a.z) << shift),
        w: _u32_to_i32(_i32_to_u32(a.w) << shift),
    )

fn simd_shr_i32x4(a: Vec4i, n: i64) -> Vec4i:
    val shift = n.to_u32()
    Vec4i(
        x: _u32_to_i32(_i32_to_u32(a.x) >> shift),
        y: _u32_to_i32(_i32_to_u32(a.y) >> shift),
        z: _u32_to_i32(_i32_to_u32(a.z) >> shift),
        w: _u32_to_i32(_i32_to_u32(a.w) >> shift),
    )

fn _vadd(a: Vec4i, b: Vec4i) -> Vec4i:
    """4-lane wrapping i32 add (no extern; relies on Simple's i32 wrap-on-overflow)."""
    Vec4i(x: a.x + b.x, y: a.y + b.y, z: a.z + b.z, w: a.w + b.w)

fn _vrotl16(v: Vec4i) -> Vec4i:
    """4-lane rotate-left by 16."""
    simd_or_i32x4(simd_shl_i32x4(v, 16), simd_shr_i32x4(v, 16))

fn _vrotl12(v: Vec4i) -> Vec4i:
    """4-lane rotate-left by 12."""
    simd_or_i32x4(simd_shl_i32x4(v, 12), simd_shr_i32x4(v, 20))

fn _vrotl8(v: Vec4i) -> Vec4i:
    """4-lane rotate-left by 8."""
    simd_or_i32x4(simd_shl_i32x4(v, 8), simd_shr_i32x4(v, 24))

fn _vrotl7(v: Vec4i) -> Vec4i:
    """4-lane rotate-left by 7."""
    simd_or_i32x4(simd_shl_i32x4(v, 7), simd_shr_i32x4(v, 25))

fn _u32_to_i32(x: u32) -> i32:
    """u32 -> i32 preserving bit pattern (interpret as signed)."""
    # Cast via i64 round-trip: u32 -> i64 (zero-extend) -> i32 (truncate keeps bit pattern)
    val signed = x.to_i64()
    if signed >= 2147483648:
        (signed - 4294967296).to_i32()
    else:
        signed.to_i32()

fn _i32_to_u32(x: i32) -> u32:
    """i32 -> u32 preserving bit pattern."""
    x.to_u32()

fn chacha20_block4_simd(key: [u32], counter: u32, nonce: [u32]) -> [u8]:
    """Generate FOUR 64-byte ChaCha20 keystream blocks in parallel via SIMD.

    Each Vec4i lane processes one independent block:
        lane 0 -> counter
        lane 1 -> counter+1
        lane 2 -> counter+2
        lane 3 -> counter+3

    Returns 256 bytes of keystream (4 * 64).
    """
    # Build initial state words as Vec4i (each lane = same word, different block).
    # Constants: identical across all 4 blocks
    val s0 = Vec4i.splat(_u32_to_i32(0x61707865u32))
    val s1 = Vec4i.splat(_u32_to_i32(0x3320646eu32))
    val s2 = Vec4i.splat(_u32_to_i32(0x79622d32u32))
    val s3 = Vec4i.splat(_u32_to_i32(0x6b206574u32))

    # Key (8 words), splat across blocks
    val s4 = Vec4i.splat(_u32_to_i32(key[0]))
    val s5 = Vec4i.splat(_u32_to_i32(key[1]))
    val s6 = Vec4i.splat(_u32_to_i32(key[2]))
    val s7 = Vec4i.splat(_u32_to_i32(key[3]))
    val s8 = Vec4i.splat(_u32_to_i32(key[4]))
    val s9 = Vec4i.splat(_u32_to_i32(key[5]))
    val s10 = Vec4i.splat(_u32_to_i32(key[6]))
    val s11 = Vec4i.splat(_u32_to_i32(key[7]))

    # Counter: lane k = counter + k (mod 2^32)
    val c0 = _u32_mask(counter + 0u32)
    val c1 = _u32_mask(counter + 1u32)
    val c2 = _u32_mask(counter + 2u32)
    val c3 = _u32_mask(counter + 3u32)
    val s12 = Vec4i(x: _u32_to_i32(c0), y: _u32_to_i32(c1), z: _u32_to_i32(c2), w: _u32_to_i32(c3))

    # Nonce (3 words), splat across blocks
    val s13 = Vec4i.splat(_u32_to_i32(nonce[0]))
    val s14 = Vec4i.splat(_u32_to_i32(nonce[1]))
    val s15 = Vec4i.splat(_u32_to_i32(nonce[2]))

    # Working copy
    var w0 = s0
    var w1 = s1
    var w2 = s2
    var w3 = s3
    var w4 = s4
    var w5 = s5
    var w6 = s6
    var w7 = s7
    var w8 = s8
    var w9 = s9
    var w10 = s10
    var w11 = s11
    var w12 = s12
    var w13 = s13
    var w14 = s14
    var w15 = s15

    # 20 rounds (10 double-rounds): column round + diagonal round.
    # Quarter-round on (a,b,c,d):
    #   a += b; d ^= a; d <<<= 16
    #   c += d; b ^= c; b <<<= 12
    #   a += b; d ^= a; d <<<= 8
    #   c += d; b ^= c; b <<<= 7
    var round: u64 = 0
    while round < 10:
        # ---- Column round ----
        # QR(0,4,8,12)
        w0 = _vadd(w0, w4)
        w12 = _vrotl16(simd_xor_i32x4(w12, w0))
        w8 = _vadd(w8, w12)
        w4 = _vrotl12(simd_xor_i32x4(w4, w8))
        w0 = _vadd(w0, w4)
        w12 = _vrotl8(simd_xor_i32x4(w12, w0))
        w8 = _vadd(w8, w12)
        w4 = _vrotl7(simd_xor_i32x4(w4, w8))

        # QR(1,5,9,13)
        w1 = _vadd(w1, w5)
        w13 = _vrotl16(simd_xor_i32x4(w13, w1))
        w9 = _vadd(w9, w13)
        w5 = _vrotl12(simd_xor_i32x4(w5, w9))
        w1 = _vadd(w1, w5)
        w13 = _vrotl8(simd_xor_i32x4(w13, w1))
        w9 = _vadd(w9, w13)
        w5 = _vrotl7(simd_xor_i32x4(w5, w9))

        # QR(2,6,10,14)
        w2 = _vadd(w2, w6)
        w14 = _vrotl16(simd_xor_i32x4(w14, w2))
        w10 = _vadd(w10, w14)
        w6 = _vrotl12(simd_xor_i32x4(w6, w10))
        w2 = _vadd(w2, w6)
        w14 = _vrotl8(simd_xor_i32x4(w14, w2))
        w10 = _vadd(w10, w14)
        w6 = _vrotl7(simd_xor_i32x4(w6, w10))

        # QR(3,7,11,15)
        w3 = _vadd(w3, w7)
        w15 = _vrotl16(simd_xor_i32x4(w15, w3))
        w11 = _vadd(w11, w15)
        w7 = _vrotl12(simd_xor_i32x4(w7, w11))
        w3 = _vadd(w3, w7)
        w15 = _vrotl8(simd_xor_i32x4(w15, w3))
        w11 = _vadd(w11, w15)
        w7 = _vrotl7(simd_xor_i32x4(w7, w11))

        # ---- Diagonal round ----
        # QR(0,5,10,15)
        w0 = _vadd(w0, w5)
        w15 = _vrotl16(simd_xor_i32x4(w15, w0))
        w10 = _vadd(w10, w15)
        w5 = _vrotl12(simd_xor_i32x4(w5, w10))
        w0 = _vadd(w0, w5)
        w15 = _vrotl8(simd_xor_i32x4(w15, w0))
        w10 = _vadd(w10, w15)
        w5 = _vrotl7(simd_xor_i32x4(w5, w10))

        # QR(1,6,11,12)
        w1 = _vadd(w1, w6)
        w12 = _vrotl16(simd_xor_i32x4(w12, w1))
        w11 = _vadd(w11, w12)
        w6 = _vrotl12(simd_xor_i32x4(w6, w11))
        w1 = _vadd(w1, w6)
        w12 = _vrotl8(simd_xor_i32x4(w12, w1))
        w11 = _vadd(w11, w12)
        w6 = _vrotl7(simd_xor_i32x4(w6, w11))

        # QR(2,7,8,13)
        w2 = _vadd(w2, w7)
        w13 = _vrotl16(simd_xor_i32x4(w13, w2))
        w8 = _vadd(w8, w13)
        w7 = _vrotl12(simd_xor_i32x4(w7, w8))
        w2 = _vadd(w2, w7)
        w13 = _vrotl8(simd_xor_i32x4(w13, w2))
        w8 = _vadd(w8, w13)
        w7 = _vrotl7(simd_xor_i32x4(w7, w8))

        # QR(3,4,9,14)
        w3 = _vadd(w3, w4)
        w14 = _vrotl16(simd_xor_i32x4(w14, w3))
        w9 = _vadd(w9, w14)
        w4 = _vrotl12(simd_xor_i32x4(w4, w9))
        w3 = _vadd(w3, w4)
        w14 = _vrotl8(simd_xor_i32x4(w14, w3))
        w9 = _vadd(w9, w14)
        w4 = _vrotl7(simd_xor_i32x4(w4, w9))

        round = round + 1

    # Add initial state (mod 2^32)
    val o0 = _vadd(w0, s0)
    val o1 = _vadd(w1, s1)
    val o2 = _vadd(w2, s2)
    val o3 = _vadd(w3, s3)
    val o4 = _vadd(w4, s4)
    val o5 = _vadd(w5, s5)
    val o6 = _vadd(w6, s6)
    val o7 = _vadd(w7, s7)
    val o8 = _vadd(w8, s8)
    val o9 = _vadd(w9, s9)
    val o10 = _vadd(w10, s10)
    val o11 = _vadd(w11, s11)
    val o12 = _vadd(w12, s12)
    val o13 = _vadd(w13, s13)
    val o14 = _vadd(w14, s14)
    val o15 = _vadd(w15, s15)

    # Serialize 4 blocks of 16 words each, little-endian, lane-major.
    # Block layout in output: [block0(64B) | block1(64B) | block2(64B) | block3(64B)]
    var out: [u8] = []
    var lane: u64 = 0
    while lane < 4:
        # Extract word k of this block and emit 4 LE bytes
        var k: u64 = 0
        while k < 16:
            var word_i32: i32 = 0
            if k == 0:
                if lane == 0: word_i32 = o0.x
                if lane == 1: word_i32 = o0.y
                if lane == 2: word_i32 = o0.z
                if lane == 3: word_i32 = o0.w
            if k == 1:
                if lane == 0: word_i32 = o1.x
                if lane == 1: word_i32 = o1.y
                if lane == 2: word_i32 = o1.z
                if lane == 3: word_i32 = o1.w
            if k == 2:
                if lane == 0: word_i32 = o2.x
                if lane == 1: word_i32 = o2.y
                if lane == 2: word_i32 = o2.z
                if lane == 3: word_i32 = o2.w
            if k == 3:
                if lane == 0: word_i32 = o3.x
                if lane == 1: word_i32 = o3.y
                if lane == 2: word_i32 = o3.z
                if lane == 3: word_i32 = o3.w
            if k == 4:
                if lane == 0: word_i32 = o4.x
                if lane == 1: word_i32 = o4.y
                if lane == 2: word_i32 = o4.z
                if lane == 3: word_i32 = o4.w
            if k == 5:
                if lane == 0: word_i32 = o5.x
                if lane == 1: word_i32 = o5.y
                if lane == 2: word_i32 = o5.z
                if lane == 3: word_i32 = o5.w
            if k == 6:
                if lane == 0: word_i32 = o6.x
                if lane == 1: word_i32 = o6.y
                if lane == 2: word_i32 = o6.z
                if lane == 3: word_i32 = o6.w
            if k == 7:
                if lane == 0: word_i32 = o7.x
                if lane == 1: word_i32 = o7.y
                if lane == 2: word_i32 = o7.z
                if lane == 3: word_i32 = o7.w
            if k == 8:
                if lane == 0: word_i32 = o8.x
                if lane == 1: word_i32 = o8.y
                if lane == 2: word_i32 = o8.z
                if lane == 3: word_i32 = o8.w
            if k == 9:
                if lane == 0: word_i32 = o9.x
                if lane == 1: word_i32 = o9.y
                if lane == 2: word_i32 = o9.z
                if lane == 3: word_i32 = o9.w
            if k == 10:
                if lane == 0: word_i32 = o10.x
                if lane == 1: word_i32 = o10.y
                if lane == 2: word_i32 = o10.z
                if lane == 3: word_i32 = o10.w
            if k == 11:
                if lane == 0: word_i32 = o11.x
                if lane == 1: word_i32 = o11.y
                if lane == 2: word_i32 = o11.z
                if lane == 3: word_i32 = o11.w
            if k == 12:
                if lane == 0: word_i32 = o12.x
                if lane == 1: word_i32 = o12.y
                if lane == 2: word_i32 = o12.z
                if lane == 3: word_i32 = o12.w
            if k == 13:
                if lane == 0: word_i32 = o13.x
                if lane == 1: word_i32 = o13.y
                if lane == 2: word_i32 = o13.z
                if lane == 3: word_i32 = o13.w
            if k == 14:
                if lane == 0: word_i32 = o14.x
                if lane == 1: word_i32 = o14.y
                if lane == 2: word_i32 = o14.z
                if lane == 3: word_i32 = o14.w
            if k == 15:
                if lane == 0: word_i32 = o15.x
                if lane == 1: word_i32 = o15.y
                if lane == 2: word_i32 = o15.z
                if lane == 3: word_i32 = o15.w

            val word = _i32_to_u32(word_i32)
            out.push((word & 0xFFu32).to_u8())
            out.push(((word >> 8u32) & 0xFFu32).to_u8())
            out.push(((word >> 16u32) & 0xFFu32).to_u8())
            out.push(((word >> 24u32) & 0xFFu32).to_u8())
            k = k + 1
        lane = lane + 1

    out

fn chacha20_encrypt_simd(key: [u8], counter: u32, nonce: [u8], plaintext: [u8]) -> [u8]:
    """SIMD-vectorized ChaCha20 encrypt/decrypt.

    Uses chacha20_block4_simd for the 4-block-aligned bulk and falls back to
    the scalar single-block path for the trailing 1-3 blocks.

    Bit-exact equivalent to chacha20_encrypt for any input.
    """
    # Convert key bytes to u32 words (little-endian)
    var key_words: [u32] = []
    var i: u64 = 0
    while i < 8:
        val base = i * 4
        val word = key[base].to_u32() |
                   (key[base + 1].to_u32() << 8) |
                   (key[base + 2].to_u32() << 16) |
                   (key[base + 3].to_u32() << 24)
        key_words.push(word)
        i = i + 1

    # Convert nonce bytes to u32 words (little-endian)
    var nonce_words: [u32] = []
    i = 0
    while i < 3:
        val base = i * 4
        val word = nonce[base].to_u32() |
                   (nonce[base + 1].to_u32() << 8) |
                   (nonce[base + 2].to_u32() << 16) |
                   (nonce[base + 3].to_u32() << 24)
        nonce_words.push(word)
        i = i + 1

    var output: [u8] = []
    var block_counter = counter
    var pos: u64 = 0
    val total: u64 = plaintext.len()

    # Bulk path: 4 blocks at a time (256 bytes per call)
    while pos + 256 <= total:
        val ks = chacha20_block4_simd(key_words, block_counter, nonce_words)
        var j: u64 = 0
        while j < 256:
            output.push(plaintext[pos + j] ^ ks[j])
            j = j + 1
        pos = pos + 256
        block_counter = _u32_mask(block_counter + 4u32)

    # Tail: scalar single-block path for remaining < 4 blocks
    while pos < total:
        val block = chacha20_block(key_words, block_counter, nonce_words)
        var j: u64 = 0
        while j < 16 and pos < total:
            val word = block[j]
            var b: u64 = 0
            while b < 4 and pos < total:
                val keystream_byte = ((word >> (b * 8)) & 0xFFu32).to_u8()
                output.push(plaintext[pos] ^ keystream_byte)
                pos = pos + 1
                b = b + 1
            j = j + 1
        block_counter = _u32_mask(block_counter + 1u32)

    output
