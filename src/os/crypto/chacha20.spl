# ChaCha20 Stream Cipher — Pure Simple Implementation (RFC 7539)
#
# Extracted from random.spl for shared use by SSH ChaCha20-Poly1305
# and the CSPRNG. All operations use u32 — 32-bit safe, no float.
#
# Reference: RFC 7539 (ChaCha20 and Poly1305 for IETF Protocols)

# ============================================================================
# Helpers
# ============================================================================

fn _u32_mask(x: u32) -> u32:
    """Mask to 32 bits."""
    x & 0xFFFFFFFF

fn _rotl32(x: u32, n: u32) -> u32:
    """32-bit left rotation."""
    _u32_mask((x << n) | (x >> (32 - n)))

fn _quarter_round(state: [u32], a: u64, b: u64, c: u64, d: u64):
    """ChaCha20 quarter round (mutates state in place)."""
    state[a] = _u32_mask(state[a] + state[b])
    state[d] = _rotl32(state[d] ^ state[a], 16)

    state[c] = _u32_mask(state[c] + state[d])
    state[b] = _rotl32(state[b] ^ state[c], 12)

    state[a] = _u32_mask(state[a] + state[b])
    state[d] = _rotl32(state[d] ^ state[a], 8)

    state[c] = _u32_mask(state[c] + state[d])
    state[b] = _rotl32(state[b] ^ state[c], 7)

# ============================================================================
# ChaCha20 Block Function
# ============================================================================

fn chacha20_block(key: [u32], counter: u32, nonce: [u32]) -> [u32]:
    """Generate one 64-byte ChaCha20 keystream block.

    State layout (16 x u32):
      [0..3]   = "expand 32-byte k" (constants)
      [4..11]  = 256-bit key (8 words)
      [12]     = 32-bit counter
      [13..15] = 96-bit nonce (3 words)
    """
    var state: [u32] = []

    # Constants: "expand 32-byte k" in little-endian
    state.push(0x61707865)
    state.push(0x3320646e)
    state.push(0x79622d32)
    state.push(0x6b206574)

    # Key (8 words)
    var i: u64 = 0
    while i < 8:
        state.push(key[i])
        i = i + 1

    # Counter
    state.push(counter)

    # Nonce (3 words)
    i = 0
    while i < 3:
        state.push(nonce[i])
        i = i + 1

    # Working copy
    var working: [u32] = []
    i = 0
    while i < 16:
        working.push(state[i])
        i = i + 1

    # 20 rounds (10 double-rounds)
    var round: u64 = 0
    while round < 10:
        _quarter_round(working, 0, 4, 8, 12)
        _quarter_round(working, 1, 5, 9, 13)
        _quarter_round(working, 2, 6, 10, 14)
        _quarter_round(working, 3, 7, 11, 15)

        _quarter_round(working, 0, 5, 10, 15)
        _quarter_round(working, 1, 6, 11, 12)
        _quarter_round(working, 2, 7, 8, 13)
        _quarter_round(working, 3, 4, 9, 14)

        round = round + 1

    # Add initial state
    var result: [u32] = []
    i = 0
    while i < 16:
        result.push(_u32_mask(working[i] + state[i]))
        i = i + 1

    result

# ============================================================================
# ChaCha20 Encrypt/Decrypt (same operation — XOR with keystream)
# ============================================================================

fn chacha20_encrypt(key: [u8], counter: u32, nonce: [u8], plaintext: [u8]) -> [u8]:
    """Encrypt/decrypt data using ChaCha20.

    Args:
        key: 32-byte key.
        counter: Initial block counter.
        nonce: 12-byte nonce.
        plaintext: Data to encrypt (or ciphertext to decrypt).

    Returns: Output bytes (same length as input).
    """
    # Convert key bytes to u32 words (little-endian)
    var key_words: [u32] = []
    var i: u64 = 0
    while i < 8:
        val base = i * 4
        val word = key[base].to_u32() |
                   (key[base + 1].to_u32() << 8) |
                   (key[base + 2].to_u32() << 16) |
                   (key[base + 3].to_u32() << 24)
        key_words.push(word)
        i = i + 1

    # Convert nonce bytes to u32 words (little-endian)
    var nonce_words: [u32] = []
    i = 0
    while i < 3:
        val base = i * 4
        val word = nonce[base].to_u32() |
                   (nonce[base + 1].to_u32() << 8) |
                   (nonce[base + 2].to_u32() << 16) |
                   (nonce[base + 3].to_u32() << 24)
        nonce_words.push(word)
        i = i + 1

    var output: [u8] = []
    var block_counter = counter
    var pos: u64 = 0

    while pos < plaintext.len():
        val block = chacha20_block(key_words, block_counter, nonce_words)

        # Convert block to bytes and XOR
        var j: u64 = 0
        while j < 16 and pos < plaintext.len():
            val word = block[j]
            var b: u64 = 0
            while b < 4 and pos < plaintext.len():
                val keystream_byte = ((word >> (b * 8)) & 0xFF).to_u8()
                output.push(plaintext[pos] ^ keystream_byte)
                pos = pos + 1
                b = b + 1
            j = j + 1

        block_counter = _u32_mask(block_counter + 1)

    output
