# SCRAM-SHA-256 / SCRAM-SHA-512 / SCRAM-SHA-1 — RFC 5802 + RFC 7677 (hub)
#
# Salted Challenge Response Authentication Mechanism using SHA-256, SHA-512,
# or SHA-1. Used by PostgreSQL, MongoDB, XMPP, IMAP/SMTP for mutual auth.
#
# References:
#   RFC 5802 — SCRAM base protocol
#   RFC 7677 — SCRAM-SHA-256 and SCRAM-SHA-256-PLUS
#   RFC 2104 — HMAC
#
# Sub-files:
#   scram_common.spl  — shared helpers (base64, text, byte utils, ct_eq)
#   scram_sha256.spl  — SCRAM-SHA-256 key derivation + public API
#   scram_sha512.spl  — SCRAM-SHA-512 key derivation + public API
#   scram_sha1.spl    — SCRAM-SHA-1  key derivation + public API

mod os.crypto.scram

use os.crypto.scram_sha256.{scram_sha256_client_first, scram_sha256_client_final, scram_sha256_server_verify, scram_sha256_ct_eq, scram_sha256_decode_server_final, scram_sha256_server_signature_check}
use os.crypto.scram_sha512.{scram_sha512_client_first, scram_sha512_client_final, scram_sha512_server_verify, scram_sha512_ct_eq, scram_sha512_decode_server_final, scram_sha512_server_signature_check}
use os.crypto.scram_sha1.{scram_sha1_client_first, scram_sha1_client_final, scram_sha1_server_verify, scram_sha1_ct_eq, scram_sha1_decode_server_final, scram_sha1_server_signature_check}
