#![allow(unnamed_duplicate_typed_args)]
# SHA-384 — Pure Simple Implementation (FIPS 180-4 §6.5)
#
# SHA-384 is SHA-512 with a different initial hash value (FIPS 180-4 §5.3.4)
# and the output truncated to the leftmost 384 bits (48 bytes / first 6 of
# the 8 hash words).
#
# This module is self-contained: it does NOT depend on rt_sha512_K /
# rt_sha512_H / rt_sha512_hash externs (which are not registered in the
# interpreter). The K-constant lookup, the IV, padding, and the compression
# loop are all reimplemented locally. The SHA-512 algorithm-of-record lives
# in os.crypto.sha512; this file mirrors that algorithm exactly with a
# different IV and 6-of-8 word truncation.
#
# Reference: FIPS 180-4 (Secure Hash Standard) §4.2.3, §5.3.4, §6.5.

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

fn _u8_at_384(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

# ============================================================================
# SHA-384 / SHA-512 Round Constants K (FIPS 180-4 §4.2.3)
# ============================================================================
#
# K[t] for t = 0..79. These are the first 64 bits of the fractional parts of
# the cube roots of the first 80 primes. Stored as a local lookup helper
# rather than a global val array (per the same Cranelift/baremetal constraint
# documented in sha256.spl / sha512.spl).

fn _sha384_k(index: u64) -> u64:
    if index == 0: 0x428A2F98D728AE22
    else if index == 1: 0x7137449123EF65CD
    else if index == 2: 0xB5C0FBCFEC4D3B2F
    else if index == 3: 0xE9B5DBA58189DBBC
    else if index == 4: 0x3956C25BF348B538
    else if index == 5: 0x59F111F1B605D019
    else if index == 6: 0x923F82A4AF194F9B
    else if index == 7: 0xAB1C5ED5DA6D8118
    else if index == 8: 0xD807AA98A3030242
    else if index == 9: 0x12835B0145706FBE
    else if index == 10: 0x243185BE4EE4B28C
    else if index == 11: 0x550C7DC3D5FFB4E2
    else if index == 12: 0x72BE5D74F27B896F
    else if index == 13: 0x80DEB1FE3B1696B1
    else if index == 14: 0x9BDC06A725C71235
    else if index == 15: 0xC19BF174CF692694
    else if index == 16: 0xE49B69C19EF14AD2
    else if index == 17: 0xEFBE4786384F25E3
    else if index == 18: 0x0FC19DC68B8CD5B5
    else if index == 19: 0x240CA1CC77AC9C65
    else if index == 20: 0x2DE92C6F592B0275
    else if index == 21: 0x4A7484AA6EA6E483
    else if index == 22: 0x5CB0A9DCBD41FBD4
    else if index == 23: 0x76F988DA831153B5
    else if index == 24: 0x983E5152EE66DFAB
    else if index == 25: 0xA831C66D2DB43210
    else if index == 26: 0xB00327C898FB213F
    else if index == 27: 0xBF597FC7BEEF0EE4
    else if index == 28: 0xC6E00BF33DA88FC2
    else if index == 29: 0xD5A79147930AA725
    else if index == 30: 0x06CA6351E003826F
    else if index == 31: 0x142929670A0E6E70
    else if index == 32: 0x27B70A8546D22FFC
    else if index == 33: 0x2E1B21385C26C926
    else if index == 34: 0x4D2C6DFC5AC42AED
    else if index == 35: 0x53380D139D95B3DF
    else if index == 36: 0x650A73548BAF63DE
    else if index == 37: 0x766A0ABB3C77B2A8
    else if index == 38: 0x81C2C92E47EDAEE6
    else if index == 39: 0x92722C851482353B
    else if index == 40: 0xA2BFE8A14CF10364
    else if index == 41: 0xA81A664BBC423001
    else if index == 42: 0xC24B8B70D0F89791
    else if index == 43: 0xC76C51A30654BE30
    else if index == 44: 0xD192E819D6EF5218
    else if index == 45: 0xD69906245565A910
    else if index == 46: 0xF40E35855771202A
    else if index == 47: 0x106AA07032BBD1B8
    else if index == 48: 0x19A4C116B8D2D0C8
    else if index == 49: 0x1E376C085141AB53
    else if index == 50: 0x2748774CDF8EEB99
    else if index == 51: 0x34B0BCB5E19B48A8
    else if index == 52: 0x391C0CB3C5C95A63
    else if index == 53: 0x4ED8AA4AE3418ACB
    else if index == 54: 0x5B9CCA4F7763E373
    else if index == 55: 0x682E6FF3D6B2B8A3
    else if index == 56: 0x748F82EE5DEFB2FC
    else if index == 57: 0x78A5636F43172F60
    else if index == 58: 0x84C87814A1F0AB72
    else if index == 59: 0x8CC702081A6439EC
    else if index == 60: 0x90BEFFFA23631E28
    else if index == 61: 0xA4506CEBDE82BDE9
    else if index == 62: 0xBEF9A3F7B2C67915
    else if index == 63: 0xC67178F2E372532B
    else if index == 64: 0xCA273ECEEA26619C
    else if index == 65: 0xD186B8C721C0C207
    else if index == 66: 0xEADA7DD6CDE0EB1E
    else if index == 67: 0xF57D4F7FEE6ED178
    else if index == 68: 0x06F067AA72176FBA
    else if index == 69: 0x0A637DC5A2C898A6
    else if index == 70: 0x113F9804BEF90DAE
    else if index == 71: 0x1B710B35131C471B
    else if index == 72: 0x28DB77F523047D84
    else if index == 73: 0x32CAAB7B40C72493
