    else if index == 77: 0x597F299CFC657E2A
    else if index == 78: 0x5FCB6FAB3AD6FAEC
    else: 0x6C44198C4A475817

# ============================================================================
# SHA-384 Initial Hash Value (FIPS 180-4 §5.3.4)
# ============================================================================

fn _sha384_h(index: u64) -> u64:
    """SHA-384 initial hash values, from FIPS 180-4 §5.3.4."""
    if index == 0: 0xCBBB9D5DC1059ED8
    else if index == 1: 0x629A292A367CD507
    else if index == 2: 0x9159015A3070DD17
    else if index == 3: 0x152FECD8F70E5939
    else if index == 4: 0x67332667FFC00B31
    else if index == 5: 0x8EB44A8768581511
    else if index == 6: 0xDB0C2E0D64F98FA7
    else if index == 7: 0x47B5481DBEFA4FA4
    else: 0

# ============================================================================
# Bit Manipulation Helpers (u64) — same as SHA-512 (FIPS 180-4 §4.1.3)
# ============================================================================
#
# Every arithmetic op is masked to 64 bits — the interpreter does not
# auto-wrap u64 arithmetic, so without masking the addition chain in the
# round function overflows past 2^64 and produces consistent-but-wrong output.

fn _u64_mask(x: u64) -> u64:
    x & 0xFFFFFFFFFFFFFFFF

fn _logical_shr64(x: u64, n: u64) -> u64:
    """Logical right shift on a u64 fn parameter.

    The interpreter's `>>` operator on a u64 fn parameter with bit 63 set
    performs arithmetic (sign-extending) shift instead of logical shift —
    it leaks 1-bits into the high positions. See
    `doc/08_tracking/bug/u64_right_shift_fn_param_arithmetic_2026-05-02.md`.
    Standalone `val x: u64 = 0xCB...; x >> n` is logical, but
    `fn f(x: u64, n: u64): x >> n` is arithmetic. We mask the sign-extended
    bits explicitly: only the low `(64 - n)` bits should be set after a
    logical shift right by `n`. Valid for 1 <= n <= 63.
    """
    val mask: u64 = _u64_mask((1 << (64 - n)) - 1)
    (x >> n) & mask

fn _rotr64_384(x: u64, n: u64) -> u64:
    _u64_mask(_logical_shr64(x, n) | _u64_mask(x << (64 - n)))

fn _ch64_384(e: u64, f: u64, g: u64) -> u64:
    _u64_mask((e & f) ^ (_u64_mask(~e) & g))

fn _maj64_384(a: u64, b: u64, c: u64) -> u64:
    _u64_mask((a & b) ^ (a & c) ^ (b & c))

fn _big_sigma0_384(a: u64) -> u64:
    _u64_mask(_rotr64_384(a, 28) ^ _rotr64_384(a, 34) ^ _rotr64_384(a, 39))

fn _big_sigma1_384(e: u64) -> u64:
    _u64_mask(_rotr64_384(e, 14) ^ _rotr64_384(e, 18) ^ _rotr64_384(e, 41))

fn _small_sigma0_384(w: u64) -> u64:
    _u64_mask(_rotr64_384(w, 1) ^ _rotr64_384(w, 8) ^ _logical_shr64(w, 7))

fn _small_sigma1_384(w: u64) -> u64:
    _u64_mask(_rotr64_384(w, 19) ^ _rotr64_384(w, 61) ^ _logical_shr64(w, 6))

# ============================================================================
# Message Padding (FIPS 180-4 §5.1.2)
# ============================================================================

fn _sha384_pad(data: [u8]) -> [u8]:
    val data_len = data.len()
    val bit_len: u64 = data_len.to_u64() * 8

    var padded: [u8] = []
    var i: u64 = 0
    var padded_count: u64 = 0
    while i < data_len:
        padded.push(data[i])
        padded_count = padded_count + 1
        i = i + 1

    padded.push(0x80)
    padded_count = padded_count + 1

    while (padded_count % 128) != 112:
        padded.push(0x00)
        padded_count = padded_count + 1

    # Upper 64 bits of 128-bit length: zero (we cap at 64-bit message length).
    i = 0
    while i < 8:
        padded.push(0x00)
        padded_count = padded_count + 1
        i = i + 1

    padded.push(((bit_len >> 56) & 0xFF).to_u8())
    padded.push(((bit_len >> 48) & 0xFF).to_u8())
    padded.push(((bit_len >> 40) & 0xFF).to_u8())
    padded.push(((bit_len >> 32) & 0xFF).to_u8())
    padded.push(((bit_len >> 24) & 0xFF).to_u8())
    padded.push(((bit_len >> 16) & 0xFF).to_u8())
    padded.push(((bit_len >> 8) & 0xFF).to_u8())
    padded.push((bit_len & 0xFF).to_u8())
    padded_count = padded_count + 8

    padded

fn _sha384_padded_len(data_len: u64) -> u64:
    val total_without_pad = data_len + 1 + 16
    val remainder = total_without_pad % 128
    if remainder == 0:
        total_without_pad
    else:
        total_without_pad + (128 - remainder)

# ============================================================================
# Block Processing (FIPS 180-4 §6.4.2 / §6.5.2)
# ============================================================================

fn _sha384_process_block(block: [u8], offset: u64, h: [u64]) -> [u64]:
    var w: [u64] = []
    var t: u64 = 0
    while t < 16:
        val base = offset + t * 8
        val w_t: u64 = _u64_mask(
            (_u8_at_384(block, base).to_u64() << 56) |
            (_u8_at_384(block, base + 1).to_u64() << 48) |
            (_u8_at_384(block, base + 2).to_u64() << 40) |
            (_u8_at_384(block, base + 3).to_u64() << 32) |
            (_u8_at_384(block, base + 4).to_u64() << 24) |
            (_u8_at_384(block, base + 5).to_u64() << 16) |
            (_u8_at_384(block, base + 6).to_u64() << 8) |
            _u8_at_384(block, base + 7).to_u64()
        )
        w.push(w_t)
        t = t + 1

    while t < 80:
        val s0 = _small_sigma0_384(w[t - 15])
        val s1 = _small_sigma1_384(w[t - 2])
        val w_t: u64 = _u64_mask(_u64_mask(w[t - 16] + s0) + _u64_mask(w[t - 7] + s1))
        w.push(w_t)
        t = t + 1

    var a = h[0]
    var b = h[1]
    var c = h[2]
    var d = h[3]
    var e = h[4]
    var f = h[5]
    var g = h[6]
    var hh = h[7]

    var round: u64 = 0
    while round < 80:
        val s1 = _big_sigma1_384(e)
        val ch_val = _ch64_384(e, f, g)
        val temp1_a = _u64_mask(hh + s1)
        val temp1_b = _u64_mask(ch_val + _sha384_k(round))
        val temp1_c = _u64_mask(temp1_a + temp1_b)
        val temp1: u64 = _u64_mask(temp1_c + w[round])
        val s0 = _big_sigma0_384(a)
        val maj_val = _maj64_384(a, b, c)
        val temp2: u64 = _u64_mask(s0 + maj_val)

        hh = g
        g = f
        f = e
        e = _u64_mask(d + temp1)
        d = c
        c = b
        b = a
        a = _u64_mask(temp1 + temp2)

        round = round + 1

    var result: [u64] = []
    result.push(_u64_mask(h[0] + a))
    result.push(_u64_mask(h[1] + b))
    result.push(_u64_mask(h[2] + c))
    result.push(_u64_mask(h[3] + d))
    result.push(_u64_mask(h[4] + e))
    result.push(_u64_mask(h[5] + f))
    result.push(_u64_mask(h[6] + g))
    result.push(_u64_mask(h[7] + hh))
    result

# ============================================================================
# Diagnostic helpers (exposed for KAT spec to probe internal state).
# ============================================================================

fn _sha384_diag_w0(data: [u8]) -> u64:
    """Decode the first 8 bytes of the padded message as a big-endian u64.
    For empty input we expect 0x8000000000000000.
    """
    val padded = _sha384_pad(data)
    _u64_mask(
        (_u8_at_384(padded, 0).to_u64() << 56) |
        (_u8_at_384(padded, 1).to_u64() << 48) |
        (_u8_at_384(padded, 2).to_u64() << 40) |
        (_u8_at_384(padded, 3).to_u64() << 32) |
        (_u8_at_384(padded, 4).to_u64() << 24) |
        (_u8_at_384(padded, 5).to_u64() << 16) |
        (_u8_at_384(padded, 6).to_u64() << 8) |
        _u8_at_384(padded, 7).to_u64()
    )

fn _sha384_diag_h0() -> u64:
    """Initial hash word h[0] for SHA-384 — should be 0xcbbb9d5dc1059ed8."""
    _sha384_h(0)

fn _sha384_diag_rotr1() -> u64:
    """rotr64(0x8000000000000000, 1) — should be 0x4000000000000000."""
    val x: u64 = 0x8000000000000000
    _rotr64_384(x, 1)

fn _sha384_diag_shl63() -> u64:
    """0x8000000000000000 << 63 in u64; with wrap, expect 0."""
    val x: u64 = 0x8000000000000000
    _u64_mask(x << 63)

fn _sha384_diag_big_sigma0_h0() -> u64:
    """Probe big_sigma0 against canonical for SHA-384 IV h[0].
    Returns 0xdb9a810738c045b1. Regression guard for the u64-fn-param right-shift
    sign-extension bug fixed via `_logical_shr64`. See
    `doc/08_tracking/bug/u64_right_shift_fn_param_arithmetic_2026-05-02.md`.
    """
    _big_sigma0_384(0xCBBB9D5DC1059ED8)

fn _sha384_diag_rotr_test() -> u64:
    """Run one round computation: big_sigma1(h4 of SHA-384 IV) — fixed expected.

    h[4] = 0x67332667FFC00B31. Sigma1 = ROTR^14 ^ ROTR^18 ^ ROTR^41.
    Reference value (computed offline): 0x18d26a51fdc4ec88. (We'll see what
    the interpreter actually returns to verify masks/rotations.)
    """
    _big_sigma1_384(0x67332667FFC00B31)

# ============================================================================
# SHA-384 Hash (pure Simple)
# ============================================================================

fn _sha512_h(index: u64) -> u64:
    """SHA-512 initial hash values, from FIPS 180-4 §5.3.5.

    Exposed for the SHA-512 KAT spec to probe whether the shared compression
    chain in `_sha384_process_block` is correct independent of the SHA-384
    IV / 6-of-8-word truncation. See `test/unit/os/crypto/sha512_kat_spec.spl`.
    """
    if index == 0: 0x6A09E667F3BCC908
    else if index == 1: 0xBB67AE8584CAA73B
    else if index == 2: 0x3C6EF372FE94F82B
    else if index == 3: 0xA54FF53A5F1D36F1
    else if index == 4: 0x510E527FADE682D1
    else if index == 5: 0x9B05688C2B3E6C1F
    else if index == 6: 0x1F83D9ABFB41BD6B
    else if index == 7: 0x5BE0CD19137E2179
    else: 0

fn _sha384_sha512_emulate(data: [u8]) -> [u8]:
    """Run the SHA-384 compression chain with the SHA-512 IV and emit all 8
    output words. Used by `test/unit/os/crypto/sha512_kat_spec.spl` to baseline
    whether the shared compression chain is correct.
    """
    val padded = _sha384_pad(data)

    var h: [u64] = []
    var hi: u64 = 0
    while hi < 8:
        h.push(_sha512_h(hi))
        hi = hi + 1

    val num_blocks = _sha384_padded_len(data.len().to_u64()) / 128
    var block_idx: u64 = 0
    while block_idx < num_blocks:
        h = _sha384_process_block(padded, block_idx * 128, h)
        block_idx = block_idx + 1

    var digest: [u8] = []
    hi = 0
    while hi < 8:
        val word = h[hi]
        digest.push(((word >> 56) & 0xFF).to_u8())
        digest.push(((word >> 48) & 0xFF).to_u8())
        digest.push(((word >> 40) & 0xFF).to_u8())
        digest.push(((word >> 32) & 0xFF).to_u8())
        digest.push(((word >> 24) & 0xFF).to_u8())
        digest.push(((word >> 16) & 0xFF).to_u8())
        digest.push(((word >> 8) & 0xFF).to_u8())
        digest.push((word & 0xFF).to_u8())
        hi = hi + 1
    digest

fn sha384(data: [u8]) -> [u8]:
    """Compute SHA-384 hash (FIPS 180-4 §6.5) of `data`. Output is 48 bytes.

    Pure-Simple — does not depend on `rt_sha512_K`, `rt_sha512_H`, or
    `rt_sha512_hash`. Reuses the SHA-512 algorithm with the SHA-384 IV
    (FIPS 180-4 §5.3.4) and truncates the digest to 48 bytes (first 6 of
    8 words).
    """
    val padded = _sha384_pad(data)

    var h: [u64] = []
    var hi: u64 = 0
    while hi < 8:
        h.push(_sha384_h(hi))
        hi = hi + 1

    val num_blocks = _sha384_padded_len(data.len().to_u64()) / 128
    var block_idx: u64 = 0
    while block_idx < num_blocks:
        h = _sha384_process_block(padded, block_idx * 128, h)
        block_idx = block_idx + 1

    # Truncate: first 6 words = 384 bits = 48 bytes.
    var digest: [u8] = []
    hi = 0
    while hi < 6:
        val word = h[hi]
        digest.push(((word >> 56) & 0xFF).to_u8())
        digest.push(((word >> 48) & 0xFF).to_u8())
        digest.push(((word >> 40) & 0xFF).to_u8())
        digest.push(((word >> 32) & 0xFF).to_u8())
        digest.push(((word >> 24) & 0xFF).to_u8())
        digest.push(((word >> 16) & 0xFF).to_u8())
        digest.push(((word >> 8) & 0xFF).to_u8())
        digest.push((word & 0xFF).to_u8())
        hi = hi + 1
    digest
