# SimpleOS Crypto Library — Module Root
#
# Pure Simple cryptographic primitives for baremetal SimpleOS.
# No SFFI/Rust FFI (except rt_rdrand for hardware entropy).
#
# Provides:
#   - SHA-256 hash and HMAC-SHA-256
#   - SHA-512 hash
#   - AES-256-GCM authenticated encryption/decryption
#   - X25519 Diffie-Hellman key exchange
#   - Ed25519 digital signatures
#   - Ed448 digital signatures (RFC 8032 §5.2; pure-Simple bigint backend)
#   - CSPRNG (ChaCha20-based, seeded from hardware entropy)
#   - SipHash-2-4 and SipHash-1-3 (keyed PRF, hash-table seed)
#   - CRC-32 (IEEE 802.3) and CRC-32C (Castagnoli) checksums
#   - bcrypt (Provos/Mazières 1999, OpenBSD $2a$ format, Eksblowfish)
#
# Needed by: SSH server, TLS, secure IPC, capability tokens

use os.crypto.sha256.{sha256, sha256_hmac}
use os.crypto.sha224.{sha224}
use os.crypto.sha512.{sha512}
use os.crypto.sha384.{sha384}
use os.crypto.aes_gcm.{aes256_gcm_encrypt, aes256_gcm_decrypt, AesGcmResult}
use os.crypto.curve25519.{x25519, x25519_base}
use os.crypto.ed25519.{ed25519_keypair_from_seed, ed25519_sign, ed25519_verify, ed25519_self_test, EdPoint}
use os.crypto.ed448.{ed448_keygen, ed448_sign, ed448_verify}
use os.crypto.curve448.{x448_clamp, x448_scalar_mult, x448_keygen, x448_dh}
use os.crypto.random.{random_bytes, csprng_seed, random_u32, random_u64, random_range}
use os.crypto.chacha20.{chacha20_encrypt, chacha20_block}
use os.crypto.poly1305.{poly1305_mac}
use os.crypto.chacha20_poly1305.{chacha20_poly1305_encrypt, chacha20_poly1305_decrypt, Chacha20Poly1305Result}
use os.crypto.blake2b.{blake2b}
use os.crypto.blake2s.{blake2s}
use os.crypto.blake3.{blake3, blake3_keyed, blake3_kdf, blake3_xof}
use os.crypto.siphash.{siphash24, siphash13}
use os.crypto.crc32.{crc32, crc32c, crc32_init, crc32_update, crc32_finalize, crc32c_init, crc32c_update, crc32c_finalize}
use os.crypto.bcrypt.{bcrypt_hash, bcrypt_verify}
