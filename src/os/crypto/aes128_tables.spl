# AES-128 Lookup Tables
#
# S-box (FIPS 197, Section 5.1.1) and RCON tables for AES-128.
# Extracted from aes128_gcm.spl to keep file sizes manageable.

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

# ============================================================================
# AES S-Box (FIPS 197, Section 5.1.1) — inline table, no SFFI
# ============================================================================

fn _aes_sbox_table() -> [u8]:
    """Pre-computed AES S-box (256 entries)."""
    var t: [u8] = rt_array_new_with_cap(256)
    # Row 0
    t.push(0x63)
    t.push(0x7c)
    t.push(0x77)
    t.push(0x7b)
