    t.push(0x48)
    t.push(0x03)
    t.push(0xf6)
    t.push(0x0e)
    t.push(0x61)
    t.push(0x35)
    t.push(0x57)
    t.push(0xb9)
    t.push(0x86)
    t.push(0xc1)
    t.push(0x1d)
    t.push(0x9e)
    # Row E
    t.push(0xe1)
    t.push(0xf8)
    t.push(0x98)
    t.push(0x11)
    t.push(0x69)
    t.push(0xd9)
    t.push(0x8e)
    t.push(0x94)
    t.push(0x9b)
    t.push(0x1e)
    t.push(0x87)
    t.push(0xe9)
    t.push(0xce)
    t.push(0x55)
    t.push(0x28)
    t.push(0xdf)
    # Row F
    t.push(0x8c)
    t.push(0xa1)
    t.push(0x89)
    t.push(0x0d)
    t.push(0xbf)
    t.push(0xe6)
    t.push(0x42)
    t.push(0x68)
    t.push(0x41)
    t.push(0x99)
    t.push(0x2d)
    t.push(0x0f)
    t.push(0xb0)
    t.push(0x54)
    t.push(0xbb)
    t.push(0x16)
    t

fn _aes_sbox(index: i64) -> u8:
    """Look up a byte in the AES S-box table."""
    val tbl = _aes_sbox_table()
    _u8_at(tbl, (index & 0xFF).to_u64())

# AES Round Constants (RCON) — packed as u32 with RCON byte in high position
# Index 0 → round 1 constant, etc.  Only 10 entries needed for AES-128.
fn _aes_rcon_table() -> [u8]:
    """AES RCON byte values for rounds 1..10."""
    var t: [u8] = rt_array_new_with_cap(10)
    t.push(0x01)
    t.push(0x02)
    t.push(0x04)
    t.push(0x08)
    t.push(0x10)
    t.push(0x20)
    t.push(0x40)
    t.push(0x80)
    t.push(0x1b)
    t.push(0x36)
    t

fn _aes_rcon(index: i64) -> u32:
    """Return RCON for round (index+1), packed as u32 big-endian (byte << 24)."""
    val tbl = _aes_rcon_table()
    _u8_at(tbl, index.to_u64()).to_u32() << 24
