    t.push(0xa5)
    t.push(0xe5)
    t.push(0xf1)
    t.push(0x71)
    t.push(0xd8)
    t.push(0x31)
    t.push(0x15)
    # Row 3
    t.push(0x04)
    t.push(0xc7)
    t.push(0x23)
    t.push(0xc3)
    t.push(0x18)
    t.push(0x96)
    t.push(0x05)
    t.push(0x9a)
    t.push(0x07)
    t.push(0x12)
    t.push(0x80)
    t.push(0xe2)
