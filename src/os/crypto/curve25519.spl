# Curve25519 — Pure Simple X25519 Diffie-Hellman (RFC 7748)
#
# Implements X25519 key exchange on Curve25519.
# No SFFI/Rust SFFI — pure Simple language, suitable for baremetal.
#
# Field: GF(2^255 - 19), represented as 5 limbs of ~51 bits each (u64).
# Curve: Montgomery curve y^2 = x^3 + 486662*x^2 + x
# Scalar multiplication via Montgomery ladder.
#
# Reference: RFC 7748 (Elliptic Curves for Security)
# Reference: Daniel J. Bernstein, "Curve25519: new Diffie-Hellman speed records"

use os.crypto.curve25519_bigint.{x25519_safe, x25519_base_safe, bigint_roundtrip_probe, bigint_mask_probe, bigint_cswap_probe, bigint_ladder_probe}
use os.crypto.curve25519_smalllimb.{x25519_smalllimb, x25519_base_smalllimb}

fn _curve_debug(msg: text):
    nil

# ============================================================================
# Constants
# ============================================================================

# p = 2^255 - 19
# In limb form (51-bit limbs): p = (2^51 - 19, 2^51 - 1, 2^51 - 1, 2^51 - 1, 2^51 - 1)
val P_LIMB_MASK: u64 = 0x7FFFFFFFFFFFF   # 2^51 - 1 = mask for 51 bits

# a24 = (486662 - 2) / 4 = 121665 (used in Montgomery ladder step)
val A24: u128 = 121665

# ============================================================================
# Field Element: GF(2^255 - 19)
# ============================================================================

struct Fe25519:
    """Field element in GF(2^255-19), represented as 5 limbs of ~51 bits.

    l0 holds bits 0..50
    l1 holds bits 51..101
    l2 holds bits 102..152
    l3 holds bits 153..203
    l4 holds bits 204..254
    """
    l0: u64
    l1: u64
    l2: u64
    l3: u64
    l4: u64

# ============================================================================
# Field Element Constructors
# ============================================================================

fn fe_zero() -> Fe25519:
    """Return the zero element."""
    Fe25519(l0: 0, l1: 0, l2: 0, l3: 0, l4: 0)

fn fe_one() -> Fe25519:
    """Return the multiplicative identity."""
    Fe25519(l0: 1, l1: 0, l2: 0, l3: 0, l4: 0)

# ============================================================================
# Field Arithmetic
# ============================================================================

fn fe_add(a: Fe25519, b: Fe25519) -> Fe25519:
    """Add two field elements. Result may be > p; callers reduce as needed."""
    Fe25519(
        l0: a.l0 + b.l0,
        l1: a.l1 + b.l1,
        l2: a.l2 + b.l2,
        l3: a.l3 + b.l3,
        l4: a.l4 + b.l4
    )

fn fe_sub(a: Fe25519, b: Fe25519) -> Fe25519:
    """Subtract two field elements.

    To avoid underflow, we add 2*p before subtracting.
    2*p limbs: (2^52 - 38, 2^52 - 2, 2^52 - 2, 2^52 - 2, 2^52 - 2)
    """
    Fe25519(
        l0: (a.l0 + 0xFFFFFFFFFFFDA) - b.l0,
        l1: (a.l1 + 0xFFFFFFFFFFFFE) - b.l1,
        l2: (a.l2 + 0xFFFFFFFFFFFFE) - b.l2,
        l3: (a.l3 + 0xFFFFFFFFFFFFE) - b.l3,
        l4: (a.l4 + 0xFFFFFFFFFFFFE) - b.l4
    )

fn _fe_carry(t: Fe25519) -> Fe25519:
    """Carry propagation to keep limbs in ~51-bit range."""
    var l0 = t.l0
    var l1 = t.l1
    var l2 = t.l2
    var l3 = t.l3
    var l4 = t.l4

    var c: u64 = l0 >> 51
    l0 = l0 & P_LIMB_MASK
    l1 = l1 + c

    c = l1 >> 51
    l1 = l1 & P_LIMB_MASK
    l2 = l2 + c

    c = l2 >> 51
    l2 = l2 & P_LIMB_MASK
    l3 = l3 + c

    c = l3 >> 51
    l3 = l3 & P_LIMB_MASK
    l4 = l4 + c

    c = l4 >> 51
    l4 = l4 & P_LIMB_MASK
    l0 = l0 + c * 19    # Reduction: 2^255 = 19 mod p

    Fe25519(l0: l0, l1: l1, l2: l2, l3: l3, l4: l4)

fn _fe_carry_wide(l0: u128, l1: u128, l2: u128, l3: u128, l4: u128) -> Fe25519:
    """Carry propagation for wide intermediates.

    The interpreter checks integer overflow, so the 51x51 limb products must be
    accumulated in a wider type before we fold them back into 51-bit limbs.
    """
    val mask: u128 = P_LIMB_MASK

    var c: u128 = l0 >> 51
    var n0 = l0 & mask
    var n1 = l1 + c

    c = n1 >> 51
    n1 = n1 & mask
    var n2 = l2 + c

    c = n2 >> 51
    n2 = n2 & mask
    var n3 = l3 + c

    c = n3 >> 51
    n3 = n3 & mask
    var n4 = l4 + c

    c = n4 >> 51
    n4 = n4 & mask
    n0 = n0 + c * 19

    c = n0 >> 51
    n0 = n0 & mask
    n1 = n1 + c
    c = n1 >> 51
    n1 = n1 & mask
    n2 = n2 + c
    c = n2 >> 51
    n2 = n2 & mask
    n3 = n3 + c
    c = n3 >> 51
    n3 = n3 & mask
    n4 = n4 + c
    c = n4 >> 51
    n4 = n4 & mask
    n0 = n0 + c * 19
    c = n0 >> 51
    n0 = n0 & mask
    n1 = n1 + c

    Fe25519(
        l0: n0.to_u64(),
        l1: n1.to_u64(),
        l2: n2.to_u64(),
        l3: n3.to_u64(),
        l4: n4.to_u64()
    )

fn fe_mul(a: Fe25519, b: Fe25519) -> Fe25519:
    """Multiply two field elements using schoolbook multiplication with reduction.

    Each limb is at most ~51 bits, so 51x51 products do not fit in u64. The
    interpreter traps on checked overflow, so we accumulate the schoolbook terms
    in u128 and then fold the result back into 51-bit limbs.

    For limbs a_i * b_j where i+j >= 5, we multiply the contribution by 19
    (because that term represents 2^(51*(i+j)) which wraps around as 19 * 2^(51*(i+j-5))).
    """
    val a0: u128 = a.l0
    val a1: u128 = a.l1
    val a2: u128 = a.l2
    val a3: u128 = a.l3
    val a4: u128 = a.l4

    val b0: u128 = b.l0
    val b1: u128 = b.l1
    val b2: u128 = b.l2
    val b3: u128 = b.l3
    val b4: u128 = b.l4

    val b1_19: u128 = b1 * 19
    val b2_19: u128 = b2 * 19
    val b3_19: u128 = b3 * 19
    val b4_19: u128 = b4 * 19

    # Accumulate into 5 limbs using u128 so the interpreter never sees an
    # overflowing 51x51 multiply.
    val p00: u128 = a0 * b0
    val p14: u128 = a1 * b4_19
    val p23: u128 = a2 * b3_19
    val p32: u128 = a3 * b2_19
    val p41: u128 = a4 * b1_19
    val t0: u128 = p00 + p14 + p23 + p32 + p41

    val p01: u128 = a0 * b1
    val p10: u128 = a1 * b0
    val p24: u128 = a2 * b4_19
    val p33: u128 = a3 * b3_19
    val p42: u128 = a4 * b2_19
    val t1: u128 = p01 + p10 + p24 + p33 + p42

    val p02: u128 = a0 * b2
    val p11: u128 = a1 * b1
    val p20: u128 = a2 * b0
    val p34: u128 = a3 * b4_19
    val p43: u128 = a4 * b3_19
    val t2: u128 = p02 + p11 + p20 + p34 + p43

    val p03: u128 = a0 * b3
    val p12: u128 = a1 * b2
    val p21: u128 = a2 * b1
    val p30: u128 = a3 * b0
    val p44: u128 = a4 * b4_19
    val t3: u128 = p03 + p12 + p21 + p30 + p44

    val p04: u128 = a0 * b4
    val p13: u128 = a1 * b3
    val p22: u128 = a2 * b2
    val p31: u128 = a3 * b1
    val p40: u128 = a4 * b0
    val t4: u128 = p04 + p13 + p22 + p31 + p40

    _fe_carry_wide(l0: t0, l1: t1, l2: t2, l3: t3, l4: t4)

fn fe_sq(a: Fe25519) -> Fe25519:
    """Square a field element (optimized: uses symmetry of a*a).

    a^2 = sum of a_i * a_j for all i,j. For i != j the term appears twice.
    """
    val a0: u128 = a.l0
    val a1: u128 = a.l1
    val a2: u128 = a.l2
    val a3: u128 = a.l3
    val a4: u128 = a.l4

    # Double cross-terms
    val a0_2: u128 = a0 * 2
    val a1_2: u128 = a1 * 2
    val a2_2: u128 = a2 * 2
    val a3_2: u128 = a3 * 2

    # Pre-multiply by 19 for reduction
    val a1_38: u128 = a1 * 38
    val a2_38: u128 = a2 * 38
    val a3_38: u128 = a3 * 38
    val a4_19: u128 = a4 * 19

    val sq00: u128 = a0 * a0
    val sq14: u128 = a1_38 * a4
    val sq23: u128 = a2_38 * a3
    val t0: u128 = sq00 + sq14 + sq23

    val sq01: u128 = a0_2 * a1
    val sq24: u128 = a2_38 * a4
    val sq33: u128 = (a3 * a3) * 19
    val t1: u128 = sq01 + sq24 + sq33

    val sq02: u128 = a0_2 * a2
    val sq11: u128 = a1 * a1
    val sq34: u128 = a3_38 * a4
    val t2: u128 = sq02 + sq11 + sq34

    val sq03: u128 = a0_2 * a3
    val sq12: u128 = a1_2 * a2
    val sq44: u128 = a4_19 * a4
    val t3: u128 = sq03 + sq12 + sq44

    val sq04: u128 = a0_2 * a4
    val sq13: u128 = a1_2 * a3
    val sq22: u128 = a2 * a2
    val t4: u128 = sq04 + sq13 + sq22

    _fe_carry_wide(l0: t0, l1: t1, l2: t2, l3: t3, l4: t4)

fn fe_mul_scalar(a: Fe25519, s: u128) -> Fe25519:
    """Multiply a field element by a small scalar."""
    val a0: u128 = a.l0
    val a1: u128 = a.l1
    val a2: u128 = a.l2
    val a3: u128 = a.l3
    val a4: u128 = a.l4

    _fe_carry_wide(
        l0: a0 * s,
        l1: a1 * s,
        l2: a2 * s,
        l3: a3 * s,
        l4: a4 * s
    )

# ============================================================================
# Full Reduction mod p
# ============================================================================

fn fe_reduce(a: Fe25519) -> Fe25519:
    """Fully reduce a field element to canonical [0, p) range.

    After carrying, we may still have a value in [p, 2p). Subtract p if needed.
    """
    var t = _fe_carry(a)

    # One more carry pass to ensure limbs are tight
    t = _fe_carry(t)

    # Check if t >= p by trying t - p
    # p = (2^51 - 19, 2^51 - 1, 2^51 - 1, 2^51 - 1, 2^51 - 1)
    # If after subtracting p, all limbs are >= 0, then t >= p.
    # We compute t - p and check the borrow.
    var l0 = t.l0
    var l1 = t.l1
    var l2 = t.l2
    var l3 = t.l3
    var l4 = t.l4

    # Subtract p conditionally: first add 19 to l0, check if >= 2^51
    var c: u64 = (l0 + 19) >> 51
    c = (l1 + c) >> 51
    c = (l2 + c) >> 51
    c = (l3 + c) >> 51
    c = (l4 + c) >> 51
    # c is 1 if t >= p, 0 otherwise

    # If t >= p, subtract p (which means add 19 and mask)
    l0 = l0 + 19 * c
    c = l0 >> 51
    l0 = l0 & P_LIMB_MASK
    l1 = l1 + c
    c = l1 >> 51
    l1 = l1 & P_LIMB_MASK
    l2 = l2 + c
    c = l2 >> 51
    l2 = l2 & P_LIMB_MASK
    l3 = l3 + c
    c = l3 >> 51
    l3 = l3 & P_LIMB_MASK
    l4 = l4 + c
    l4 = l4 & P_LIMB_MASK

    Fe25519(l0: l0, l1: l1, l2: l2, l3: l3, l4: l4)

# ============================================================================
# Encoding / Decoding
# ============================================================================

fn fe_from_bytes(b: [u8]) -> Fe25519:
    """Decode a 32-byte little-endian encoding into a field element.

    Loads 256 bits, then masks bit 255 (high bit of last byte).
    Splits into 5 limbs of 51 bits.
    """
    # Load bytes into a 256-bit value conceptually
    # Limb 0: bits 0-50 (bytes 0-6, partial byte 6)
    # Limb 1: bits 51-101 (bytes 6-12, partial)
    # Limb 2: bits 102-152 (bytes 12-19, partial)
    # Limb 3: bits 153-203 (bytes 19-25, partial)
    # Limb 4: bits 204-254 (bytes 25-31, partial)

    # Helper: load u64 from 8 bytes little-endian (or fewer at boundary)
    # We'll extract bits directly.

    val l0 = _load_le_u64(b, 0) & P_LIMB_MASK
    val l1 = (_load_le_u64(b, 6) >> 3) & P_LIMB_MASK
    val l2 = (_load_le_u64(b, 12) >> 6) & P_LIMB_MASK
    val l3 = (_load_le_u64(b, 19) >> 1) & P_LIMB_MASK
    val l4 = (_load_le_u64(b, 24) >> 12) & P_LIMB_MASK

    Fe25519(l0: l0, l1: l1, l2: l2, l3: l3, l4: l4)

fn _load_le_u64(b: [u8], offset: u64) -> u64:
    """Load up to 8 bytes from b[offset..] as a little-endian u64."""
    var result: u64 = 0
    var i: u64 = 0
    while i < 8:
        if (offset + i) < b.len():
            result = result | (b[offset + i].to_u64() << (i * 8))
        i = i + 1
    result

fn fe_to_bytes(a: Fe25519) -> [u8]:
    """Encode a field element as 32 bytes, little-endian.

    First fully reduces, then packs limbs into bytes.
    """
    val t = fe_reduce(a)

    # Combine limbs into a 256-bit value and serialize
    # h = l0 + l1*2^51 + l2*2^102 + l3*2^153 + l4*2^204
    var result: [u8] = []
    var i: u64 = 0
    while i < 32:
        result.push(0x00)
        i = i + 1

    # Pack bits from 5 limbs into 32 bytes
    result = _store_limb(buf: result, limb: t.l0, byte_offset: 0, bit_offset: 0)        # bits 0..50 starting at byte 0, bit 0
    result = _store_limb(buf: result, limb: t.l1, byte_offset: 6, bit_offset: 3)        # bits 51..101 starting at byte 6, bit 3
    result = _store_limb(buf: result, limb: t.l2, byte_offset: 12, bit_offset: 6)       # bits 102..152 starting at byte 12, bit 6
    result = _store_limb(buf: result, limb: t.l3, byte_offset: 19, bit_offset: 1)       # bits 153..203 starting at byte 19, bit 1
    result = _store_limb(buf: result, limb: t.l4, byte_offset: 24, bit_offset: 12)      # bits 204..254 starting at byte 24, bit 12

    result

fn _store_limb(buf: [u8], limb: u64, byte_offset: u64, bit_offset: u64) -> [u8]:
    """Store a 51-bit limb into buf at the given byte/bit offset (OR-ing in)."""
    val shifted = limb << bit_offset
    var out: [u8] = []
    var copy_i: u64 = 0
    while copy_i < buf.len():
        out.push(buf[copy_i])
        copy_i = copy_i + 1
    var i: u64 = 0
    while i < 8:
        if (byte_offset + i) < 32:
            val byte_val = ((shifted >> (i * 8)) & 0xFF).to_u8()
            out[byte_offset + i] = out[byte_offset + i] | byte_val
        i = i + 1
    out

# ============================================================================
# Field Inversion via Fermat's Little Theorem
# ============================================================================

fn fe_invert(z: Fe25519) -> Fe25519:
    """Compute z^(-1) = z^(p-2) mod p, where p = 2^255 - 19.

    p-2 = 2^255 - 21

    Uses an addition chain to compute z^(2^255 - 21) efficiently.
    This follows the same chain as the reference implementation.
    """
    # z^2
    var z2 = fe_sq(z)

    # z^(2^2) = z^4
    var t = fe_sq(z2)
    # z^(2^3) = z^8
    t = fe_sq(t)

    # z^9 = z^8 * z
    var z9 = fe_mul(a: t, b: z)
    # z^11 = z^9 * z^2
    var z11 = fe_mul(a: z9, b: z2)

    # z^(2^1 * 11) = z^22
    t = fe_sq(z11)
    # z^(2^5 - 2^0) = z^31 = z^22 * z^9
    var z_2_5_0 = fe_mul(a: t, b: z9)

    # z^(2^10 - 2^0)
    t = fe_sq(z_2_5_0)
    var i: u64 = 1
    while i < 5:
        t = fe_sq(t)
        i = i + 1
    var z_2_10_0 = fe_mul(a: t, b: z_2_5_0)

    # z^(2^20 - 2^0)
    t = fe_sq(z_2_10_0)
    i = 1
    while i < 10:
        t = fe_sq(t)
        i = i + 1
    var z_2_20_0 = fe_mul(a: t, b: z_2_10_0)

    # z^(2^40 - 2^0)
    t = fe_sq(z_2_20_0)
    i = 1
    while i < 20:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(a: t, b: z_2_20_0)

    # z^(2^50 - 2^0)
    i = 0
    while i < 10:
        t = fe_sq(t)
        i = i + 1
    var z_2_50_0 = fe_mul(a: t, b: z_2_10_0)

    # z^(2^100 - 2^0)
    t = fe_sq(z_2_50_0)
    i = 1
    while i < 50:
        t = fe_sq(t)
        i = i + 1
    var z_2_100_0 = fe_mul(a: t, b: z_2_50_0)

    # z^(2^200 - 2^0)
    t = fe_sq(z_2_100_0)
    i = 1
    while i < 100:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(a: t, b: z_2_100_0)

    # z^(2^250 - 2^0)
    i = 0
    while i < 50:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(a: t, b: z_2_50_0)

    # z^(2^255 - 2^5)
    t = fe_sq(t)
    t = fe_sq(t)
    t = fe_sq(t)
    t = fe_sq(t)
    t = fe_sq(t)

    # z^(2^255 - 21) = z^(p-2)
    fe_mul(a: t, b: z11)

# ============================================================================
# Conditional Swap (constant-time)
# ============================================================================

fn fe_cswap(a: Fe25519, b: Fe25519, swap: u64) -> Fe25519:
    """Conditionally return b if swap=1, else a. Constant-time."""
    # mask is all-ones if swap=1, all-zeros if swap=0
    val mask = 0 - swap   # 0xFFFFFFFFFFFFFFFF if swap=1, 0 if swap=0
    Fe25519(
        l0: a.l0 ^ (mask & (a.l0 ^ b.l0)),
        l1: a.l1 ^ (mask & (a.l1 ^ b.l1)),
        l2: a.l2 ^ (mask & (a.l2 ^ b.l2)),
        l3: a.l3 ^ (mask & (a.l3 ^ b.l3)),
        l4: a.l4 ^ (mask & (a.l4 ^ b.l4))
    )

fn _cswap_pair(x1: Fe25519, x2: Fe25519, z1: Fe25519, z2: Fe25519, swap: u64) -> (Fe25519, Fe25519, Fe25519, Fe25519):
    """Conditionally swap two (x, z) pairs. Returns (x1', x2', z1', z2')."""
    val mask = 0 - swap
    val new_x1 = Fe25519(
        l0: x1.l0 ^ (mask & (x1.l0 ^ x2.l0)),
        l1: x1.l1 ^ (mask & (x1.l1 ^ x2.l1)),
        l2: x1.l2 ^ (mask & (x1.l2 ^ x2.l2)),
        l3: x1.l3 ^ (mask & (x1.l3 ^ x2.l3)),
        l4: x1.l4 ^ (mask & (x1.l4 ^ x2.l4))
    )
    val new_x2 = Fe25519(
        l0: x2.l0 ^ (mask & (x1.l0 ^ x2.l0)),
        l1: x2.l1 ^ (mask & (x1.l1 ^ x2.l1)),
        l2: x2.l2 ^ (mask & (x1.l2 ^ x2.l2)),
        l3: x2.l3 ^ (mask & (x1.l3 ^ x2.l3)),
        l4: x2.l4 ^ (mask & (x1.l4 ^ x2.l4))
    )
    val new_z1 = Fe25519(
        l0: z1.l0 ^ (mask & (z1.l0 ^ z2.l0)),
        l1: z1.l1 ^ (mask & (z1.l1 ^ z2.l1)),
        l2: z1.l2 ^ (mask & (z1.l2 ^ z2.l2)),
        l3: z1.l3 ^ (mask & (z1.l3 ^ z2.l3)),
        l4: z1.l4 ^ (mask & (z1.l4 ^ z2.l4))
    )
    val new_z2 = Fe25519(
        l0: z2.l0 ^ (mask & (z1.l0 ^ z2.l0)),
        l1: z2.l1 ^ (mask & (z1.l1 ^ z2.l1)),
        l2: z2.l2 ^ (mask & (z1.l2 ^ z2.l2)),
        l3: z2.l3 ^ (mask & (z1.l3 ^ z2.l3)),
        l4: z2.l4 ^ (mask & (z1.l4 ^ z2.l4))
    )
    (new_x1, new_x2, new_z1, new_z2)

# ============================================================================
# Montgomery Ladder Step
# ============================================================================

fn _ladder_step(x2: Fe25519, z2: Fe25519, x3: Fe25519, z3: Fe25519, x1: Fe25519) -> (Fe25519, Fe25519, Fe25519, Fe25519):
    """One step of the Montgomery ladder.

    Computes differential addition and doubling:
    (x2, z2) = 2 * (x2, z2)
    (x3, z3) = (x2, z2) + (x3, z3)  [differential, using x1 as difference]

    Returns: (new_x2, new_z2, new_x3, new_z3)
    """
    # A = x2 + z2
    val a = fe_add(a: x2, b: z2)
    # AA = A^2
    val aa = fe_sq(a)
    # B = x2 - z2
    val b = fe_sub(a: x2, b: z2)
    # BB = B^2
    val bb = fe_sq(b)
    # E = AA - BB
    val e = fe_sub(a: aa, b: bb)
    # C = x3 + z3
    val c = fe_add(a: x3, b: z3)
    # D = x3 - z3
    val d = fe_sub(a: x3, b: z3)
    # DA = D * A
    val da = fe_mul(a: d, b: a)
    # CB = C * B
    val cb = fe_mul(a: c, b: b)

    # x5 = (DA + CB)^2
    val sum_dc = fe_add(a: da, b: cb)
    val new_x3 = fe_sq(sum_dc)

    # z5 = x1 * (DA - CB)^2
    val diff_dc = fe_sub(a: da, b: cb)
    val diff_sq = fe_sq(diff_dc)
    val new_z3 = fe_mul(a: x1, b: diff_sq)

    # x4 = AA * BB
    val new_x2 = fe_mul(a: aa, b: bb)

    # z4 = E * (AA + a24 * E)
    val a24_e = fe_mul_scalar(e, A24)
    val aa_plus = fe_add(a: aa, b: a24_e)
    val new_z2 = fe_mul(a: e, b: aa_plus)

    (new_x2, new_z2, new_x3, new_z3)

# ============================================================================
# Scalar Clamping (RFC 7748, Section 5)
# ============================================================================

fn _clamp_scalar(scalar: [u8]) -> [u8]:
    """Clamp a 32-byte scalar per RFC 7748.

    Clear bits 0, 1, 2 of first byte.
    Clear bit 7 of last byte.
    Set bit 6 of last byte.
    """
    var clamped: [u8] = []
    var i: u64 = 0
    while i < 32:
        clamped.push(scalar[i])
        i = i + 1

    clamped[0] = clamped[0] & 0xF8       # Clear bottom 3 bits
    clamped[31] = clamped[31] & 0x7F      # Clear top bit
    clamped[31] = clamped[31] | 0x40      # Set bit 254
    clamped

# ============================================================================
# X25519 Scalar Multiplication
# ============================================================================

fn x25519(scalar: [u8], u_coord: [u8]) -> [u8]:
    x25519_smalllimb(scalar, u_coord)

# ============================================================================
# X25519 Base Point Multiplication
# ============================================================================

fn x25519_base(scalar: [u8]) -> [u8]:
    x25519_base_smalllimb(scalar)

fn x25519_bigint_probe(scalar: [u8], u_coord: [u8]) -> [u8]:
    x25519_safe(scalar, u_coord)

fn x25519_base_bigint_probe(scalar: [u8]) -> [u8]:
    x25519_base_safe(scalar)

fn x25519_bigint_roundtrip_probe(u_coord: [u8]) -> [u8]:
    bigint_roundtrip_probe(u_coord)

fn x25519_bigint_mask_probe(u_coord: [u8]) -> [u8]:
    bigint_mask_probe(u_coord)

fn x25519_bigint_cswap_probe() -> i64:
    bigint_cswap_probe()

fn x25519_bigint_ladder_probe() -> i64:
    bigint_ladder_probe()

fn _fe25519_cswap_pair(x1: Fe25519, x2: Fe25519, z1: Fe25519, z2: Fe25519, swap: u64) -> (Fe25519, Fe25519, Fe25519, Fe25519):
    val mask = 0 - swap
    val new_x1 = Fe25519(
        l0: x1.l0 ^ (mask & (x1.l0 ^ x2.l0)),
        l1: x1.l1 ^ (mask & (x1.l1 ^ x2.l1)),
        l2: x1.l2 ^ (mask & (x1.l2 ^ x2.l2)),
        l3: x1.l3 ^ (mask & (x1.l3 ^ x2.l3)),
        l4: x1.l4 ^ (mask & (x1.l4 ^ x2.l4))
    )
    val new_x2 = Fe25519(
        l0: x2.l0 ^ (mask & (x1.l0 ^ x2.l0)),
        l1: x2.l1 ^ (mask & (x1.l1 ^ x2.l1)),
        l2: x2.l2 ^ (mask & (x1.l2 ^ x2.l2)),
        l3: x2.l3 ^ (mask & (x1.l3 ^ x2.l3)),
        l4: x2.l4 ^ (mask & (x1.l4 ^ x2.l4))
    )
    val new_z1 = Fe25519(
        l0: z1.l0 ^ (mask & (z1.l0 ^ z2.l0)),
        l1: z1.l1 ^ (mask & (z1.l1 ^ z2.l1)),
        l2: z1.l2 ^ (mask & (z1.l2 ^ z2.l2)),
        l3: z1.l3 ^ (mask & (z1.l3 ^ z2.l3)),
        l4: z1.l4 ^ (mask & (z1.l4 ^ z2.l4))
    )
    val new_z2 = Fe25519(
        l0: z2.l0 ^ (mask & (z1.l0 ^ z2.l0)),
        l1: z2.l1 ^ (mask & (z1.l1 ^ z2.l1)),
        l2: z2.l2 ^ (mask & (z1.l2 ^ z2.l2)),
        l3: z2.l3 ^ (mask & (z1.l3 ^ z2.l3)),
        l4: z2.l4 ^ (mask & (z1.l4 ^ z2.l4))
    )
    (new_x1, new_x2, new_z1, new_z2)

fn _fe25519_ladder_step(x2: Fe25519, z2: Fe25519, x3: Fe25519, z3: Fe25519, x1: Fe25519) -> (Fe25519, Fe25519, Fe25519, Fe25519):
    val a = fe_add(a: x2, b: z2)
    val aa = fe_sq(a)
    val b = fe_sub(a: x2, b: z2)
    val bb = fe_sq(b)
    val e = fe_sub(a: aa, b: bb)
    val c = fe_add(a: x3, b: z3)
    val d = fe_sub(a: x3, b: z3)
    val da = fe_mul(a: d, b: a)
    val cb = fe_mul(a: c, b: b)
    val sum_dc = fe_add(a: da, b: cb)
    val new_x3 = fe_sq(sum_dc)
    val diff_dc = fe_sub(a: da, b: cb)
    val diff_sq = fe_sq(diff_dc)
    val new_z3 = fe_mul(a: x1, b: diff_sq)
    val new_x2 = fe_mul(a: aa, b: bb)
    val a24_e = fe_mul_scalar(e, A24)
    val aa_plus = fe_add(a: aa, b: a24_e)
    val new_z2 = fe_mul(a: e, b: aa_plus)
    (new_x2, new_z2, new_x3, new_z3)

fn x25519_fe_probe(scalar: [u8], u_coord: [u8]) -> [u8]:
    val k = _clamp_scalar(scalar)
    var u_bytes: [u8] = []
    var i: u64 = 0
    while i < 32:
        u_bytes.push(u_coord[i])
        i = i + 1
    u_bytes[31] = u_bytes[31] & 0x7F
    val u = fe_from_bytes(u_bytes)

    var x_2 = fe_one()
    var z_2 = fe_zero()
    var x_3 = u
    var z_3 = fe_one()
    var prev_bit: u64 = 0
    var bit_pos: u64 = 254
    while bit_pos < 255:
        val byte_idx = bit_pos / 8
        val bit_idx = bit_pos % 8
        val k_bit: u64 = (k[byte_idx].to_u64() >> bit_idx) & 1
        val swap_bit = k_bit ^ prev_bit
        prev_bit = k_bit

        val swapped = _fe25519_cswap_pair(x1: x_2, x2: x_3, z1: z_2, z2: z_3, swap: swap_bit)
        x_2 = swapped.0
        x_3 = swapped.1
        z_2 = swapped.2
        z_3 = swapped.3

        val step = _fe25519_ladder_step(x2: x_2, z2: z_2, x3: x_3, z3: z_3, x1: u)
        x_2 = step.0
        z_2 = step.1
        x_3 = step.2
        z_3 = step.3

        if bit_pos == 0:
            val final_swapped = _fe25519_cswap_pair(x1: x_2, x2: x_3, z1: z_2, z2: z_3, swap: prev_bit)
            x_2 = final_swapped.0
            x_3 = final_swapped.1
            z_2 = final_swapped.2
            z_3 = final_swapped.3

            val z_inv = fe_invert(z_2)
            val result = fe_mul(a: x_2, b: z_inv)
            return fe_to_bytes(result)

        bit_pos = bit_pos - 1

    val z_inv = fe_invert(z_2)
    val result = fe_mul(a: x_2, b: z_inv)
    fe_to_bytes(result)

fn x25519_base_fe_probe(scalar: [u8]) -> [u8]:
    var base_point: [u8] = []
    base_point.push(9)
    var i: u64 = 1
    while i < 32:
        base_point.push(0)
        i = i + 1
    x25519_fe_probe(scalar, base_point)
