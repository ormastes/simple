# Curve25519 — Pure Simple X25519 Diffie-Hellman (RFC 7748)
#
# Implements X25519 key exchange on Curve25519.
# No SFFI/Rust FFI — pure Simple language, suitable for baremetal.
#
# Field: GF(2^255 - 19), represented as 5 limbs of ~51 bits each (u64).
# Curve: Montgomery curve y^2 = x^3 + 486662*x^2 + x
# Scalar multiplication via Montgomery ladder.
#
# Reference: RFC 7748 (Elliptic Curves for Security)
# Reference: Daniel J. Bernstein, "Curve25519: new Diffie-Hellman speed records"

# ============================================================================
# Constants
# ============================================================================

# p = 2^255 - 19
# In limb form (51-bit limbs): p = (2^51 - 19, 2^51 - 1, 2^51 - 1, 2^51 - 1, 2^51 - 1)
val P_LIMB_MASK: u64 = 0x7FFFFFFFFFFFF   # 2^51 - 1 = mask for 51 bits

# a24 = (486662 - 2) / 4 = 121665 (used in Montgomery ladder step)
val A24: u64 = 121666

# ============================================================================
# Field Element: GF(2^255 - 19)
# ============================================================================

struct Fe25519:
    """Field element in GF(2^255-19), represented as 5 limbs of ~51 bits.

    l0 holds bits 0..50
    l1 holds bits 51..101
    l2 holds bits 102..152
    l3 holds bits 153..203
    l4 holds bits 204..254
    """
    l0: u64
    l1: u64
    l2: u64
    l3: u64
    l4: u64

# ============================================================================
# Field Element Constructors
# ============================================================================

fn fe_zero() -> Fe25519:
    """Return the zero element."""
    Fe25519(l0: 0, l1: 0, l2: 0, l3: 0, l4: 0)

fn fe_one() -> Fe25519:
    """Return the multiplicative identity."""
    Fe25519(l0: 1, l1: 0, l2: 0, l3: 0, l4: 0)

# ============================================================================
# Field Arithmetic
# ============================================================================

fn fe_add(a: Fe25519, b: Fe25519) -> Fe25519:
    """Add two field elements. Result may be > p; callers reduce as needed."""
    Fe25519(
        l0: a.l0 + b.l0,
        l1: a.l1 + b.l1,
        l2: a.l2 + b.l2,
        l3: a.l3 + b.l3,
        l4: a.l4 + b.l4
    )

fn fe_sub(a: Fe25519, b: Fe25519) -> Fe25519:
    """Subtract two field elements.

    To avoid underflow, we add 2*p before subtracting.
    2*p limbs: (2^52 - 38, 2^52 - 2, 2^52 - 2, 2^52 - 2, 2^52 - 2)
    """
    Fe25519(
        l0: (a.l0 + 0xFFFFFFFFFFFDA) - b.l0,
        l1: (a.l1 + 0xFFFFFFFFFFFFE) - b.l1,
        l2: (a.l2 + 0xFFFFFFFFFFFFE) - b.l2,
        l3: (a.l3 + 0xFFFFFFFFFFFFE) - b.l3,
        l4: (a.l4 + 0xFFFFFFFFFFFFE) - b.l4
    )

fn _fe_carry(t: Fe25519) -> Fe25519:
    """Carry propagation to keep limbs in ~51-bit range."""
    var l0 = t.l0
    var l1 = t.l1
    var l2 = t.l2
    var l3 = t.l3
    var l4 = t.l4

    var c: u64 = l0 >> 51
    l0 = l0 & P_LIMB_MASK
    l1 = l1 + c

    c = l1 >> 51
    l1 = l1 & P_LIMB_MASK
    l2 = l2 + c

    c = l2 >> 51
    l2 = l2 & P_LIMB_MASK
    l3 = l3 + c

    c = l3 >> 51
    l3 = l3 & P_LIMB_MASK
    l4 = l4 + c

    c = l4 >> 51
    l4 = l4 & P_LIMB_MASK
    l0 = l0 + c * 19    # Reduction: 2^255 = 19 mod p

    Fe25519(l0: l0, l1: l1, l2: l2, l3: l3, l4: l4)

fn fe_mul(a: Fe25519, b: Fe25519) -> Fe25519:
    """Multiply two field elements using schoolbook multiplication with reduction.

    Each limb is at most ~51 bits, so products fit in u64 before accumulation
    requires careful handling. We use the identity 2^255 = 19 (mod p) to reduce
    cross-terms that overflow 255 bits.

    For limbs a_i * b_j where i+j >= 5, we multiply the contribution by 19
    (because that term represents 2^(51*(i+j)) which wraps around as 19 * 2^(51*(i+j-5))).
    """
    val a0 = a.l0
    val a1 = a.l1
    val a2 = a.l2
    val a3 = a.l3
    val a4 = a.l4

    val b0 = b.l0
    val b1 = b.l1
    val b2 = b.l2
    val b3 = b.l3
    val b4 = b.l4

    # Pre-multiply by 19 for reduction terms
    val b1_19 = b1 * 19
    val b2_19 = b2 * 19
    val b3_19 = b3 * 19
    val b4_19 = b4 * 19

    # Accumulate into 5 limbs
    # t0 = a0*b0 + 19*(a1*b4 + a2*b3 + a3*b2 + a4*b1)
    var t0: u64 = a0 * b0 + a1 * b4_19 + a2 * b3_19 + a3 * b2_19 + a4 * b1_19

    # t1 = a0*b1 + a1*b0 + 19*(a2*b4 + a3*b3 + a4*b2)
    var t1: u64 = a0 * b1 + a1 * b0 + a2 * b4_19 + a3 * b3_19 + a4 * b2_19

    # t2 = a0*b2 + a1*b1 + a2*b0 + 19*(a3*b4 + a4*b3)
    var t2: u64 = a0 * b2 + a1 * b1 + a2 * b0 + a3 * b4_19 + a4 * b3_19

    # t3 = a0*b3 + a1*b2 + a2*b1 + a3*b0 + 19*(a4*b4)
    var t3: u64 = a0 * b3 + a1 * b2 + a2 * b1 + a3 * b0 + a4 * b4_19

    # t4 = a0*b4 + a1*b3 + a2*b2 + a3*b1 + a4*b0
    var t4: u64 = a0 * b4 + a1 * b3 + a2 * b2 + a3 * b1 + a4 * b0

    # Carry propagation
    _fe_carry(Fe25519(l0: t0, l1: t1, l2: t2, l3: t3, l4: t4))

fn fe_sq(a: Fe25519) -> Fe25519:
    """Square a field element (optimized: uses symmetry of a*a).

    a^2 = sum of a_i * a_j for all i,j. For i != j the term appears twice.
    """
    val a0 = a.l0
    val a1 = a.l1
    val a2 = a.l2
    val a3 = a.l3
    val a4 = a.l4

    # Double cross-terms
    val a0_2 = a0 * 2
    val a1_2 = a1 * 2
    val a2_2 = a2 * 2
    val a3_2 = a3 * 2

    # Pre-multiply by 19 for reduction
    val a1_38 = a1 * 38
    val a2_38 = a2 * 38
    val a3_38 = a3 * 38
    val a4_19 = a4 * 19

    var t0: u64 = a0 * a0 + a1_38 * a4 + a2_38 * a3
    var t1: u64 = a0_2 * a1 + a2_38 * a4 + a3 * a3 * 19
    var t2: u64 = a0_2 * a2 + a1 * a1 + a3_38 * a4
    var t3: u64 = a0_2 * a3 + a1_2 * a2 + a4_19 * a4
    var t4: u64 = a0_2 * a4 + a1_2 * a3 + a2 * a2

    _fe_carry(Fe25519(l0: t0, l1: t1, l2: t2, l3: t3, l4: t4))

fn fe_mul_scalar(a: Fe25519, s: u64) -> Fe25519:
    """Multiply a field element by a small scalar."""
    _fe_carry(Fe25519(
        l0: a.l0 * s,
        l1: a.l1 * s,
        l2: a.l2 * s,
        l3: a.l3 * s,
        l4: a.l4 * s
    ))

# ============================================================================
# Full Reduction mod p
# ============================================================================

fn fe_reduce(a: Fe25519) -> Fe25519:
    """Fully reduce a field element to canonical [0, p) range.

    After carrying, we may still have a value in [p, 2p). Subtract p if needed.
    """
    var t = _fe_carry(a)

    # One more carry pass to ensure limbs are tight
    t = _fe_carry(t)

    # Check if t >= p by trying t - p
    # p = (2^51 - 19, 2^51 - 1, 2^51 - 1, 2^51 - 1, 2^51 - 1)
    # If after subtracting p, all limbs are >= 0, then t >= p.
    # We compute t - p and check the borrow.
    var l0 = t.l0
    var l1 = t.l1
    var l2 = t.l2
    var l3 = t.l3
    var l4 = t.l4

    # Subtract p conditionally: first add 19 to l0, check if >= 2^51
    var c: u64 = (l0 + 19) >> 51
    c = (l1 + c) >> 51
    c = (l2 + c) >> 51
    c = (l3 + c) >> 51
    c = (l4 + c) >> 51
    # c is 1 if t >= p, 0 otherwise

    # If t >= p, subtract p (which means add 19 and mask)
    l0 = l0 + 19 * c
    c = l0 >> 51
    l0 = l0 & P_LIMB_MASK
    l1 = l1 + c
    c = l1 >> 51
    l1 = l1 & P_LIMB_MASK
    l2 = l2 + c
    c = l2 >> 51
    l2 = l2 & P_LIMB_MASK
    l3 = l3 + c
    c = l3 >> 51
    l3 = l3 & P_LIMB_MASK
    l4 = l4 + c
    l4 = l4 & P_LIMB_MASK

    Fe25519(l0: l0, l1: l1, l2: l2, l3: l3, l4: l4)

# ============================================================================
# Encoding / Decoding
# ============================================================================

fn fe_from_bytes(b: [u8]) -> Fe25519:
    """Decode a 32-byte little-endian encoding into a field element.

    Loads 256 bits, then masks bit 255 (high bit of last byte).
    Splits into 5 limbs of 51 bits.
    """
    # Load bytes into a 256-bit value conceptually
    # Limb 0: bits 0-50 (bytes 0-6, partial byte 6)
    # Limb 1: bits 51-101 (bytes 6-12, partial)
    # Limb 2: bits 102-152 (bytes 12-19, partial)
    # Limb 3: bits 153-203 (bytes 19-25, partial)
    # Limb 4: bits 204-254 (bytes 25-31, partial)

    # Helper: load u64 from 8 bytes little-endian (or fewer at boundary)
    # We'll extract bits directly.

    val l0 = _load_le_u64(b, 0) & P_LIMB_MASK
    val l1 = (_load_le_u64(b, 6) >> 3) & P_LIMB_MASK
    val l2 = (_load_le_u64(b, 12) >> 6) & P_LIMB_MASK
    val l3 = (_load_le_u64(b, 19) >> 1) & P_LIMB_MASK
    val l4 = (_load_le_u64(b, 24) >> 12) & P_LIMB_MASK

    Fe25519(l0: l0, l1: l1, l2: l2, l3: l3, l4: l4)

fn _load_le_u64(b: [u8], offset: u64) -> u64:
    """Load up to 8 bytes from b[offset..] as a little-endian u64."""
    var result: u64 = 0
    var i: u64 = 0
    while i < 8:
        if (offset + i) < b.len():
            result = result | (b[offset + i].to_u64() << (i * 8))
        i = i + 1
    result

fn fe_to_bytes(a: Fe25519) -> [u8]:
    """Encode a field element as 32 bytes, little-endian.

    First fully reduces, then packs limbs into bytes.
    """
    val t = fe_reduce(a)

    # Combine limbs into a 256-bit value and serialize
    # h = l0 + l1*2^51 + l2*2^102 + l3*2^153 + l4*2^204
    var result: [u8] = []
    var i: u64 = 0
    while i < 32:
        result.push(0x00)
        i = i + 1

    # Pack bits from 5 limbs into 32 bytes
    _store_limb(result, t.l0, 0, 0)        # bits 0..50 starting at byte 0, bit 0
    _store_limb(result, t.l1, 6, 3)        # bits 51..101 starting at byte 6, bit 3
    _store_limb(result, t.l2, 12, 6)       # bits 102..152 starting at byte 12, bit 6
    _store_limb(result, t.l3, 19, 1)       # bits 153..203 starting at byte 19, bit 1
    _store_limb(result, t.l4, 24, 12)      # bits 204..254 starting at byte 24, bit 12

    result

fn _store_limb(buf: [u8], limb: u64, byte_offset: u64, bit_offset: u64):
    """Store a 51-bit limb into buf at the given byte/bit offset (OR-ing in)."""
    val shifted = limb << bit_offset
    var i: u64 = 0
    while i < 8:
        if (byte_offset + i) < 32:
            val byte_val = ((shifted >> (i * 8)) & 0xFF).to_u8()
            buf[byte_offset + i] = buf[byte_offset + i] | byte_val
        i = i + 1

# ============================================================================
# Field Inversion via Fermat's Little Theorem
# ============================================================================

fn fe_invert(z: Fe25519) -> Fe25519:
    """Compute z^(-1) = z^(p-2) mod p, where p = 2^255 - 19.

    p-2 = 2^255 - 21

    Uses an addition chain to compute z^(2^255 - 21) efficiently.
    This follows the same chain as the reference implementation.
    """
    # z^2
    var z2 = fe_sq(z)

    # z^(2^2) = z^4
    var t = fe_sq(z2)
    # z^(2^3) = z^8
    t = fe_sq(t)

    # z^9 = z^8 * z
    var z9 = fe_mul(t, z)
    # z^11 = z^9 * z^2
    var z11 = fe_mul(z9, z2)

    # z^(2^1 * 11) = z^22
    t = fe_sq(z11)
    # z^(2^5 - 2^0) = z^31 = z^22 * z^9
    var z_2_5_0 = fe_mul(t, z9)

    # z^(2^10 - 2^0)
    t = fe_sq(z_2_5_0)
    var i: u64 = 1
    while i < 5:
        t = fe_sq(t)
        i = i + 1
    var z_2_10_0 = fe_mul(t, z_2_5_0)

    # z^(2^20 - 2^0)
    t = fe_sq(z_2_10_0)
    i = 1
    while i < 10:
        t = fe_sq(t)
        i = i + 1
    var z_2_20_0 = fe_mul(t, z_2_10_0)

    # z^(2^40 - 2^0)
    t = fe_sq(z_2_20_0)
    i = 1
    while i < 20:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(t, z_2_20_0)

    # z^(2^50 - 2^0)
    i = 0
    while i < 10:
        t = fe_sq(t)
        i = i + 1
    var z_2_50_0 = fe_mul(t, z_2_10_0)

    # z^(2^100 - 2^0)
    t = fe_sq(z_2_50_0)
    i = 1
    while i < 50:
        t = fe_sq(t)
        i = i + 1
    var z_2_100_0 = fe_mul(t, z_2_50_0)

    # z^(2^200 - 2^0)
    t = fe_sq(z_2_100_0)
    i = 1
    while i < 100:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(t, z_2_100_0)

    # z^(2^250 - 2^0)
    i = 0
    while i < 50:
        t = fe_sq(t)
        i = i + 1
    t = fe_mul(t, z_2_50_0)

    # z^(2^255 - 2^5)
    t = fe_sq(t)
    t = fe_sq(t)
    t = fe_sq(t)
    t = fe_sq(t)
    t = fe_sq(t)

    # z^(2^255 - 21) = z^(p-2)
    fe_mul(t, z11)

# ============================================================================
# Conditional Swap (constant-time)
# ============================================================================

fn fe_cswap(a: Fe25519, b: Fe25519, swap: u64) -> Fe25519:
    """Conditionally return b if swap=1, else a. Constant-time."""
    # mask is all-ones if swap=1, all-zeros if swap=0
    val mask = 0 - swap   # 0xFFFFFFFFFFFFFFFF if swap=1, 0 if swap=0
    Fe25519(
        l0: a.l0 ^ (mask & (a.l0 ^ b.l0)),
        l1: a.l1 ^ (mask & (a.l1 ^ b.l1)),
        l2: a.l2 ^ (mask & (a.l2 ^ b.l2)),
        l3: a.l3 ^ (mask & (a.l3 ^ b.l3)),
        l4: a.l4 ^ (mask & (a.l4 ^ b.l4))
    )

fn _cswap_pair(x1: Fe25519, x2: Fe25519, z1: Fe25519, z2: Fe25519, swap: u64) -> (Fe25519, Fe25519, Fe25519, Fe25519):
    """Conditionally swap two (x, z) pairs. Returns (x1', x2', z1', z2')."""
    val mask = 0 - swap
    val new_x1 = Fe25519(
        l0: x1.l0 ^ (mask & (x1.l0 ^ x2.l0)),
        l1: x1.l1 ^ (mask & (x1.l1 ^ x2.l1)),
        l2: x1.l2 ^ (mask & (x1.l2 ^ x2.l2)),
        l3: x1.l3 ^ (mask & (x1.l3 ^ x2.l3)),
        l4: x1.l4 ^ (mask & (x1.l4 ^ x2.l4))
    )
    val new_x2 = Fe25519(
        l0: x2.l0 ^ (mask & (x1.l0 ^ x2.l0)),
        l1: x2.l1 ^ (mask & (x1.l1 ^ x2.l1)),
        l2: x2.l2 ^ (mask & (x1.l2 ^ x2.l2)),
        l3: x2.l3 ^ (mask & (x1.l3 ^ x2.l3)),
        l4: x2.l4 ^ (mask & (x1.l4 ^ x2.l4))
    )
    val new_z1 = Fe25519(
        l0: z1.l0 ^ (mask & (z1.l0 ^ z2.l0)),
        l1: z1.l1 ^ (mask & (z1.l1 ^ z2.l1)),
        l2: z1.l2 ^ (mask & (z1.l2 ^ z2.l2)),
        l3: z1.l3 ^ (mask & (z1.l3 ^ z2.l3)),
        l4: z1.l4 ^ (mask & (z1.l4 ^ z2.l4))
    )
    val new_z2 = Fe25519(
        l0: z2.l0 ^ (mask & (z1.l0 ^ z2.l0)),
        l1: z2.l1 ^ (mask & (z1.l1 ^ z2.l1)),
        l2: z2.l2 ^ (mask & (z1.l2 ^ z2.l2)),
        l3: z2.l3 ^ (mask & (z1.l3 ^ z2.l3)),
        l4: z2.l4 ^ (mask & (z1.l4 ^ z2.l4))
    )
    (new_x1, new_x2, new_z1, new_z2)

# ============================================================================
# Montgomery Ladder Step
# ============================================================================

fn _ladder_step(x2: Fe25519, z2: Fe25519, x3: Fe25519, z3: Fe25519, x1: Fe25519) -> (Fe25519, Fe25519, Fe25519, Fe25519):
    """One step of the Montgomery ladder.

    Computes differential addition and doubling:
    (x2, z2) = 2 * (x2, z2)
    (x3, z3) = (x2, z2) + (x3, z3)  [differential, using x1 as difference]

    Returns: (new_x2, new_z2, new_x3, new_z3)
    """
    # A = x2 + z2
    val a = fe_add(x2, z2)
    # AA = A^2
    val aa = fe_sq(a)
    # B = x2 - z2
    val b = fe_sub(x2, z2)
    # BB = B^2
    val bb = fe_sq(b)
    # E = AA - BB
    val e = fe_sub(aa, bb)
    # C = x3 + z3
    val c = fe_add(x3, z3)
    # D = x3 - z3
    val d = fe_sub(x3, z3)
    # DA = D * A
    val da = fe_mul(d, a)
    # CB = C * B
    val cb = fe_mul(c, b)

    # x5 = (DA + CB)^2
    val sum_dc = fe_add(da, cb)
    val new_x3 = fe_sq(sum_dc)

    # z5 = x1 * (DA - CB)^2
    val diff_dc = fe_sub(da, cb)
    val diff_sq = fe_sq(diff_dc)
    val new_z3 = fe_mul(x1, diff_sq)

    # x4 = AA * BB
    val new_x2 = fe_mul(aa, bb)

    # z4 = E * (AA + a24 * E)
    val a24_e = fe_mul_scalar(e, A24)
    val aa_plus = fe_add(aa, a24_e)
    val new_z2 = fe_mul(e, aa_plus)

    (new_x2, new_z2, new_x3, new_z3)

# ============================================================================
# Scalar Clamping (RFC 7748, Section 5)
# ============================================================================

fn _clamp_scalar(scalar: [u8]) -> [u8]:
    """Clamp a 32-byte scalar per RFC 7748.

    Clear bits 0, 1, 2 of first byte.
    Clear bit 7 of last byte.
    Set bit 6 of last byte.
    """
    var clamped: [u8] = []
    var i: u64 = 0
    while i < 32:
        clamped.push(scalar[i])
        i = i + 1

    clamped[0] = clamped[0] & 0xF8       # Clear bottom 3 bits
    clamped[31] = clamped[31] & 0x7F      # Clear top bit
    clamped[31] = clamped[31] | 0x40      # Set bit 254
    clamped

# ============================================================================
# X25519 Scalar Multiplication
# ============================================================================

fn x25519(scalar: [u8], u_coord: [u8]) -> [u8]:
    """X25519 Diffie-Hellman function (RFC 7748).

    Computes scalar * u_coord on Curve25519.

    Args:
        scalar: 32-byte scalar (private key).
        u_coord: 32-byte u-coordinate of point (public key or base point).

    Returns: 32-byte result (shared secret or public key).
    """
    val k = _clamp_scalar(scalar)

    # Decode u-coordinate (mask high bit per RFC 7748)
    var u_bytes: [u8] = []
    var i: u64 = 0
    while i < 32:
        u_bytes.push(u_coord[i])
        i = i + 1
    u_bytes[31] = u_bytes[31] & 0x7F    # Mask bit 255
    val u = fe_from_bytes(u_bytes)

    # Montgomery ladder
    # x_2 = 1, z_2 = 0 (point at infinity)
    # x_3 = u, z_3 = 1
    var x_2 = fe_one()
    var z_2 = fe_zero()
    var x_3 = u
    var z_3 = fe_one()

    var prev_bit: u64 = 0

    # Iterate from bit 254 down to bit 0
    var bit_pos: u64 = 254
    while bit_pos < 255:    # Will wrap around to MAX_U64 after 0, breaking the loop
        val byte_idx = bit_pos / 8
        val bit_idx = bit_pos % 8
        val k_bit: u64 = (k[byte_idx].to_u64() >> bit_idx) & 1

        # Conditional swap based on bit difference
        val swap_bit = k_bit ^ prev_bit
        prev_bit = k_bit

        # Swap if needed
        val swapped = _cswap_pair(x_2, x_3, z_2, z_3, swap_bit)
        x_2 = swapped.0
        x_3 = swapped.1
        z_2 = swapped.2
        z_3 = swapped.3

        # Ladder step
        val step = _ladder_step(x_2, z_2, x_3, z_3, u)
        x_2 = step.0
        z_2 = step.1
        x_3 = step.2
        z_3 = step.3

        if bit_pos == 0:
            # Break before wrapping
            # Final swap
            val final_swapped = _cswap_pair(x_2, x_3, z_2, z_3, prev_bit)
            x_2 = final_swapped.0
            x_3 = final_swapped.1
            z_2 = final_swapped.2
            z_3 = final_swapped.3

            # Compute result: x_2 * z_2^(-1)
            val z_inv = fe_invert(z_2)
            val result = fe_mul(x_2, z_inv)
            return fe_to_bytes(result)

        bit_pos = bit_pos - 1

    # Should not reach here, but handle edge case
    val z_inv = fe_invert(z_2)
    val result = fe_mul(x_2, z_inv)
    fe_to_bytes(result)

# ============================================================================
# X25519 Base Point Multiplication
# ============================================================================

fn x25519_base(scalar: [u8]) -> [u8]:
    """Compute scalar * G where G is the Curve25519 base point (u=9).

    Used to generate a public key from a private key.

    Args:
        scalar: 32-byte private key.

    Returns: 32-byte public key (u-coordinate).
    """
    # Base point u = 9 (little-endian)
    var base_point: [u8] = []
    base_point.push(9)
    var i: u64 = 1
    while i < 32:
        base_point.push(0)
        i = i + 1

    x25519(scalar, base_point)
