# SHA-512 — Pure Simple Implementation (FIPS 180-4)
#
# Implements SHA-512 hash for SimpleOS.
# No SFFI/Rust SFFI — pure Simple language, suitable for baremetal.
#
# Required by Ed25519 digital signatures.
#
# Key differences from SHA-256:
#   - 64-bit words (u64) instead of 32-bit
#   - 80 rounds instead of 64
#   - Block size: 128 bytes (1024 bits) instead of 64
#   - Output: 64 bytes (512 bits)
#   - Length field: 128 bits (we use 64-bit message length, upper 64 bits zero)
#
# Reference: FIPS 180-4 (Secure Hash Standard)

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

fn _sha512_u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

fn _sha512_add2(a: u64, b: u64) -> u64:
    val a_lo = a & 0xFFFFFFFF
    val a_hi = a >> 32
    val b_lo = b & 0xFFFFFFFF
    val b_hi = b >> 32
    val lo_sum = a_lo + b_lo
    val lo = lo_sum & 0xFFFFFFFF
    val hi = (a_hi + b_hi + (lo_sum >> 32)) & 0xFFFFFFFF
    (hi << 32) | lo

fn _sha512_add4(a: u64, b: u64, c: u64, d: u64) -> u64:
    _sha512_add2(_sha512_add2(a, b), _sha512_add2(c, d))

fn _sha512_add5(a: u64, b: u64, c: u64, d: u64, e: u64) -> u64:
    _sha512_add2(_sha512_add4(a, b, c, d), e)

# ============================================================================
# Constants
# ============================================================================

fn _sha512_k(index: u64) -> u64:
    if index == 0: 0x428A2F98D728AE22
    else if index == 1: 0x7137449123EF65CD
    else if index == 2: 0xB5C0FBCFEC4D3B2F
    else if index == 3: 0xE9B5DBA58189DBBC
    else if index == 4: 0x3956C25BF348B538
    else if index == 5: 0x59F111F1B605D019
    else if index == 6: 0x923F82A4AF194F9B
    else if index == 7: 0xAB1C5ED5DA6D8118
    else if index == 8: 0xD807AA98A3030242
    else if index == 9: 0x12835B0145706FBE
    else if index == 10: 0x243185BE4EE4B28C
    else if index == 11: 0x550C7DC3D5FFB4E2
    else if index == 12: 0x72BE5D74F27B896F
    else if index == 13: 0x80DEB1FE3B1696B1
    else if index == 14: 0x9BDC06A725C71235
    else if index == 15: 0xC19BF174CF692694
    else if index == 16: 0xE49B69C19EF14AD2
    else if index == 17: 0xEFBE4786384F25E3
    else if index == 18: 0x0FC19DC68B8CD5B5
    else if index == 19: 0x240CA1CC77AC9C65
    else if index == 20: 0x2DE92C6F592B0275
    else if index == 21: 0x4A7484AA6EA6E483
    else if index == 22: 0x5CB0A9DCBD41FBD4
    else if index == 23: 0x76F988DA831153B5
    else if index == 24: 0x983E5152EE66DFAB
    else if index == 25: 0xA831C66D2DB43210
    else if index == 26: 0xB00327C898FB213F
    else if index == 27: 0xBF597FC7BEEF0EE4
    else if index == 28: 0xC6E00BF33DA88FC2
    else if index == 29: 0xD5A79147930AA725
    else if index == 30: 0x06CA6351E003826F
