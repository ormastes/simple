fn _sha512_h(index: u64) -> u64:
    if index == 0: 0x6A09E667F3BCC908
    else if index == 1: 0xBB67AE8584CAA73B
    else if index == 2: 0x3C6EF372FE94F82B
    else if index == 3: 0xA54FF53A5F1D36F1
    else if index == 4: 0x510E527FADE682D1
    else if index == 5: 0x9B05688C2B3E6C1F
    else if index == 6: 0x1F83D9ABFB41BD6B
    else if index == 7: 0x5BE0CD19137E2179
    else: 0

# ============================================================================
# Bit Manipulation Helpers (u64)
# ============================================================================

fn rotr64(x: u64, n: u64) -> u64:
    """64-bit right rotation."""
    (x >> n) | (x << (64 - n))

fn ch64(e: u64, f: u64, g: u64) -> u64:
    """SHA-512 Ch function: (e AND f) XOR (NOT e AND g)."""
    (e & f) ^ ((~e) & g)

fn maj64(a: u64, b: u64, c: u64) -> u64:
    """SHA-512 Maj function: (a AND b) XOR (a AND c) XOR (b AND c)."""
    (a & b) ^ (a & c) ^ (b & c)

fn big_sigma0_512(a: u64) -> u64:
    """SHA-512 big Sigma_0: ROTR^28(a) XOR ROTR^34(a) XOR ROTR^39(a)."""
    rotr64(a, 28) ^ rotr64(a, 34) ^ rotr64(a, 39)

fn big_sigma1_512(e: u64) -> u64:
    """SHA-512 big Sigma_1: ROTR^14(e) XOR ROTR^18(e) XOR ROTR^41(e)."""
    rotr64(e, 14) ^ rotr64(e, 18) ^ rotr64(e, 41)

fn small_sigma0_512(w: u64) -> u64:
    """SHA-512 small sigma_0: ROTR^1(w) XOR ROTR^8(w) XOR SHR^7(w)."""
    rotr64(w, 1) ^ rotr64(w, 8) ^ (w >> 7)

fn small_sigma1_512(w: u64) -> u64:
    """SHA-512 small sigma_1: ROTR^19(w) XOR ROTR^61(w) XOR SHR^6(w)."""
    rotr64(w, 19) ^ rotr64(w, 61) ^ (w >> 6)

# ============================================================================
# Message Padding
# ============================================================================

fn sha512_pad(data: [u8]) -> [u8]:
    """Pad message to a multiple of 128 bytes per FIPS 180-4 section 5.1.2.

    Appends bit '1' (0x80 byte), then zeros, then 128-bit big-endian
    bit length, such that the total length is a multiple of 1024 bits (128 bytes).
    We use 64-bit message length (upper 64 bits zero).

    WORKAROUND: Uses manual length counter because .len() is unreliable
    in baremetal Cranelift (returns wrong values after many pushes).
    """
    val data_len = data.len()
    val bit_len: u64 = data_len.to_u64() * 8

    # Start with copy of original data
    var padded: [u8] = []
    var i: u64 = 0
    var padded_count: u64 = 0
    while i < data_len:
        padded.push(_sha512_u8_at(data, i))
        padded_count = padded_count + 1
        i = i + 1

    # Append 0x80 byte (the '1' bit followed by zeros)
    padded.push(0x80)
    padded_count = padded_count + 1

    # Pad with zeros until length is 112 mod 128
    # (leaving 16 bytes for the 128-bit length)
    while (padded_count % 128) != 112:
        padded.push(0x00)
        padded_count = padded_count + 1

    # Append 128-bit big-endian bit length
    # Upper 64 bits are zero (message length fits in 64 bits)
    i = 0
    while i < 8:
        padded.push(0x00)
        padded_count = padded_count + 1
        i = i + 1

    # Lower 64 bits: bit_len in big-endian
    padded.push(((bit_len >> 56) & 0xFF).to_u8())
    padded.push(((bit_len >> 48) & 0xFF).to_u8())
    padded.push(((bit_len >> 40) & 0xFF).to_u8())
    padded.push(((bit_len >> 32) & 0xFF).to_u8())
    padded.push(((bit_len >> 24) & 0xFF).to_u8())
    padded.push(((bit_len >> 16) & 0xFF).to_u8())
    padded.push(((bit_len >> 8) & 0xFF).to_u8())
    padded.push((bit_len & 0xFF).to_u8())
    padded_count = padded_count + 8

    padded

# ============================================================================
# Block Processing
# ============================================================================

fn sha512_process_block(block: [u8], offset: u64, h: [u64]) -> [u64]:
    """Process one 1024-bit (128-byte) block of padded message.

    Args:
        block: The padded message bytes.
        offset: Byte offset into block where this 128-byte chunk starts.
        h: Current hash state [8 x u64].

    Returns: Updated hash state [8 x u64].
    """
    # 1. Prepare the message schedule W[0..79]
    var w: [u64] = []

    # W[0..15]: big-endian decode from block (8 bytes each)
    var t: u64 = 0
    while t < 16:
        val base = offset + t * 8
        val w_t: u64 = (_sha512_u8_at(block, base).to_u64() << 56) |
            (_sha512_u8_at(block, base + 1).to_u64() << 48) |
            (_sha512_u8_at(block, base + 2).to_u64() << 40) |
            (_sha512_u8_at(block, base + 3).to_u64() << 32) |
            (_sha512_u8_at(block, base + 4).to_u64() << 24) |
            (_sha512_u8_at(block, base + 5).to_u64() << 16) |
            (_sha512_u8_at(block, base + 6).to_u64() << 8) |
            _sha512_u8_at(block, base + 7).to_u64()
        w.push(w_t)
        t = t + 1

    # W[16..79]: extended via small sigma functions
    while t < 80:
        val s0 = small_sigma0_512(w[t - 15])
        val s1 = small_sigma1_512(w[t - 2])
        val w_t: u64 = _sha512_add4(w[t - 16], s0, w[t - 7], s1)
        w.push(w_t)
        t = t + 1

    # 2. Initialize working variables
    var a = h[0]
    var b = h[1]
    var c = h[2]
    var d = h[3]
    var e = h[4]
    var f = h[5]
    var g = h[6]
    var hh = h[7]

    # 3. Compression loop (80 rounds)
    var round: u64 = 0
    while round < 80:
        val s1 = big_sigma1_512(e)
        val ch_val = ch64(e, f, g)
        val temp1: u64 = _sha512_add5(hh, s1, ch_val, _sha512_k(round), w[round])
        val s0 = big_sigma0_512(a)
        val maj_val = maj64(a, b, c)
        val temp2: u64 = _sha512_add2(s0, maj_val)

        hh = g
        g = f
        f = e
        e = _sha512_add2(d, temp1)
        d = c
        c = b
        b = a
        a = _sha512_add2(temp1, temp2)

        round = round + 1

    # 4. Compute new hash values
    var result: [u64] = []
    result.push(_sha512_add2(h[0], a))
    result.push(_sha512_add2(h[1], b))
    result.push(_sha512_add2(h[2], c))
    result.push(_sha512_add2(h[3], d))
    result.push(_sha512_add2(h[4], e))
    result.push(_sha512_add2(h[5], f))
    result.push(_sha512_add2(h[6], g))
    result.push(_sha512_add2(h[7], hh))
    result

# ============================================================================
# SHA-512 Hash
# ============================================================================

struct Sha512W16:
    w0: u64
    w1: u64
    w2: u64
    w3: u64
    w4: u64
    w5: u64
    w6: u64
    w7: u64
    w8: u64
    w9: u64
    w10: u64
    w11: u64
    w12: u64
    w13: u64
    w14: u64
    w15: u64

struct Sha512State:
    h0: u64
    h1: u64
    h2: u64
    h3: u64
    h4: u64
    h5: u64
    h6: u64
    h7: u64

fn _sha512_w16_get(w: Sha512W16, idx: u64) -> u64:
    if idx == 0: return w.w0
    if idx == 1: return w.w1
    if idx == 2: return w.w2
    if idx == 3: return w.w3
    if idx == 4: return w.w4
    if idx == 5: return w.w5
    if idx == 6: return w.w6
    if idx == 7: return w.w7
    if idx == 8: return w.w8
    if idx == 9: return w.w9
    if idx == 10: return w.w10
    if idx == 11: return w.w11
    if idx == 12: return w.w12
    if idx == 13: return w.w13
    if idx == 14: return w.w14
    w.w15

fn _sha512_w16_set(w: Sha512W16, idx: u64, value: u64) -> Sha512W16:
    Sha512W16(
        w0: if idx == 0 then value else w.w0,
        w1: if idx == 1 then value else w.w1,
        w2: if idx == 2 then value else w.w2,
        w3: if idx == 3 then value else w.w3,
        w4: if idx == 4 then value else w.w4,
        w5: if idx == 5 then value else w.w5,
        w6: if idx == 6 then value else w.w6,
        w7: if idx == 7 then value else w.w7,
        w8: if idx == 8 then value else w.w8,
        w9: if idx == 9 then value else w.w9,
        w10: if idx == 10 then value else w.w10,
        w11: if idx == 11 then value else w.w11,
        w12: if idx == 12 then value else w.w12,
        w13: if idx == 13 then value else w.w13,
        w14: if idx == 14 then value else w.w14,
        w15: if idx == 15 then value else w.w15
    )

fn _sha512_block_word(block: [u8], offset: u64, t: u64) -> u64:
    val base = offset + t * 8
    (_sha512_u8_at(block, base).to_u64() << 56) |
        (_sha512_u8_at(block, base + 1).to_u64() << 48) |
        (_sha512_u8_at(block, base + 2).to_u64() << 40) |
        (_sha512_u8_at(block, base + 3).to_u64() << 32) |
        (_sha512_u8_at(block, base + 4).to_u64() << 24) |
        (_sha512_u8_at(block, base + 5).to_u64() << 16) |
        (_sha512_u8_at(block, base + 6).to_u64() << 8) |
        _sha512_u8_at(block, base + 7).to_u64()

fn _sha512_initial_state() -> Sha512State:
    Sha512State(
        h0: _sha512_h(0),
        h1: _sha512_h(1),
        h2: _sha512_h(2),
        h3: _sha512_h(3),
        h4: _sha512_h(4),
        h5: _sha512_h(5),
        h6: _sha512_h(6),
        h7: _sha512_h(7)
    )

fn _sha512_compress_one_block_scalar(block: [u8], offset: u64, h: Sha512State) -> Sha512State:
    var w = Sha512W16(
        w0: _sha512_block_word(block, offset, 0),
        w1: _sha512_block_word(block, offset, 1),
        w2: _sha512_block_word(block, offset, 2),
        w3: _sha512_block_word(block, offset, 3),
        w4: _sha512_block_word(block, offset, 4),
        w5: _sha512_block_word(block, offset, 5),
        w6: _sha512_block_word(block, offset, 6),
        w7: _sha512_block_word(block, offset, 7),
        w8: _sha512_block_word(block, offset, 8),
        w9: _sha512_block_word(block, offset, 9),
        w10: _sha512_block_word(block, offset, 10),
        w11: _sha512_block_word(block, offset, 11),
        w12: _sha512_block_word(block, offset, 12),
        w13: _sha512_block_word(block, offset, 13),
        w14: _sha512_block_word(block, offset, 14),
        w15: _sha512_block_word(block, offset, 15)
    )

    var a = h.h0
    var b = h.h1
    var c = h.h2
    var d = h.h3
    var e = h.h4
    var f = h.h5
    var g = h.h6
    var hh = h.h7

    var round: u64 = 0
    while round < 80:
        var w_round: u64 = 0
        if round < 16:
            w_round = _sha512_w16_get(w, round)
        else:
            val s0 = small_sigma0_512(_sha512_w16_get(w, (round - 15) % 16))
            val s1 = small_sigma1_512(_sha512_w16_get(w, (round - 2) % 16))
            w_round = _sha512_add4(_sha512_w16_get(w, (round - 16) % 16), s0, _sha512_w16_get(w, (round - 7) % 16), s1)
            w = _sha512_w16_set(w, round % 16, w_round)

        val s1_big = big_sigma1_512(e)
        val temp1: u64 = _sha512_add5(hh, s1_big, ch64(e, f, g), _sha512_k(round), w_round)
        val temp2: u64 = _sha512_add2(big_sigma0_512(a), maj64(a, b, c))

        hh = g
        g = f
        f = e
        e = _sha512_add2(d, temp1)
        d = c
        c = b
        b = a
        a = _sha512_add2(temp1, temp2)
        round = round + 1

    Sha512State(
        h0: _sha512_add2(h.h0, a),
        h1: _sha512_add2(h.h1, b),
        h2: _sha512_add2(h.h2, c),
        h3: _sha512_add2(h.h3, d),
        h4: _sha512_add2(h.h4, e),
        h5: _sha512_add2(h.h5, f),
        h6: _sha512_add2(h.h6, g),
        h7: _sha512_add2(h.h7, hh)
    )

fn _sha512_digest_state(h: Sha512State) -> [u8]:
    var digest: [u8] = []
    var hi: u64 = 0
    while hi < 8:
        var word: u64 = h.h7
        if hi == 0: word = h.h0
        if hi == 1: word = h.h1
        if hi == 2: word = h.h2
        if hi == 3: word = h.h3
        if hi == 4: word = h.h4
        if hi == 5: word = h.h5
        if hi == 6: word = h.h6
        digest.push(((word >> 56) & 0xFF).to_u8())
        digest.push(((word >> 48) & 0xFF).to_u8())
        digest.push(((word >> 40) & 0xFF).to_u8())
        digest.push(((word >> 32) & 0xFF).to_u8())
        digest.push(((word >> 24) & 0xFF).to_u8())
        digest.push(((word >> 16) & 0xFF).to_u8())
        digest.push(((word >> 8) & 0xFF).to_u8())
        digest.push((word & 0xFF).to_u8())
        hi = hi + 1
    digest

fn sha512(data: [u8]) -> [u8]:
    val padded = sha512_pad(data)

    if padded.len() == 128:
        return _sha512_digest_state(_sha512_compress_one_block_scalar(padded, 0, _sha512_initial_state()))

    var h: [u64] = []
    var hi: u64 = 0
    while hi < 8:
        h.push(_sha512_h(hi))
        hi = hi + 1

    var offset: u64 = 0
    while offset < padded.len():
        h = sha512_process_block(padded, offset, h)
        offset = offset + 128

    var digest: [u8] = []
    hi = 0
    while hi < 8:
        val word = h[hi]
        digest.push(((word >> 56) & 0xFF).to_u8())
        digest.push(((word >> 48) & 0xFF).to_u8())
        digest.push(((word >> 40) & 0xFF).to_u8())
        digest.push(((word >> 32) & 0xFF).to_u8())
        digest.push(((word >> 24) & 0xFF).to_u8())
        digest.push(((word >> 16) & 0xFF).to_u8())
        digest.push(((word >> 8) & 0xFF).to_u8())
        digest.push((word & 0xFF).to_u8())
        hi = hi + 1
    digest

fn sha512_probe_h0_first_byte() -> u8:
    ((_sha512_h(0) >> 56) & 0xFF).to_u8()

fn sha512_probe_k0_first_byte() -> u8:
    ((_sha512_k(0) >> 56) & 0xFF).to_u8()

fn sha512_probe_empty_pad_byte(idx: u64) -> u8:
    val empty: [u8] = []
    val padded = sha512_pad(empty)
    _sha512_u8_at(padded, idx)

fn sha512_probe_empty_pad_len() -> u64:
    val empty: [u8] = []
    sha512_pad(empty).len().to_u64()

fn _sha512_padded_len(data_len: u64) -> u64:
    """Calculate expected padded length for SHA-512 (must be multiple of 128)."""
    val total_without_pad = data_len + 1 + 16
    val remainder = total_without_pad % 128
    if remainder == 0:
        total_without_pad
    else:
        total_without_pad + (128 - remainder)

# ============================================================================
# HMAC-SHA-512 (RFC 2104)
# ============================================================================

fn _normalize_hmac512_key(key: [u8], key_len: u64) -> [u8]:
    val block_size: u64 = 128
    var k_prime: [u8] = []
    if key_len > block_size:
        val hashed_key = sha512(key)
        var j: u64 = 0
        while j < 64:
            k_prime.push(hashed_key[j])
            j = j + 1
    else:
        var j: u64 = 0
        while j < key_len:
            k_prime.push(key[j])
            j = j + 1

    while k_prime.len() < block_size:
        k_prime.push(0x00)

    k_prime

fn _sha512_hmac_with_norm_key(k_prime: [u8], data: [u8], data_len: u64) -> [u8]:
    val block_size: u64 = 128
    var inner_input: [u8] = []
    var i: u64 = 0
    while i < block_size:
        inner_input.push((k_prime[i] ^ 0x36).to_u8())
        i = i + 1
    i = 0
    while i < data_len:
        inner_input.push(data[i])
        i = i + 1

    val inner_hash = sha512(inner_input)

    var outer_input: [u8] = []
    i = 0
    while i < block_size:
        outer_input.push((k_prime[i] ^ 0x5c).to_u8())
        i = i + 1
    i = 0
    while i < 64:
        outer_input.push(inner_hash[i])
        i = i + 1

    sha512(outer_input)

fn sha512_hmac(key: [u8], data: [u8]) -> [u8]:
    val k_prime = _normalize_hmac512_key(key, key.len().to_u64())
    _sha512_hmac_with_norm_key(k_prime, data, data.len().to_u64())

fn _sha512_pure_simple(data: [u8]) -> [u8]:
    """Original Pure Simple SHA-512 helper kept freestanding-clean."""
    val padded = sha512_pad(data)
    var h: [u64] = []
    var i: u64 = 0
    while i < 8:
        h.push(_sha512_h(i))
        i = i + 1
    val num_blocks = _sha512_padded_len(data.len().to_u64()) / 128
    var block_idx: u64 = 0
    while block_idx < num_blocks:
        h = sha512_process_block(padded, block_idx * 128, h)
        block_idx = block_idx + 1
    var digest: [u8] = []
    i = 0
    while i < 8:
        val word = h[i]
        digest.push(((word >> 56) & 0xFF).to_u8())
        digest.push(((word >> 48) & 0xFF).to_u8())
        digest.push(((word >> 40) & 0xFF).to_u8())
        digest.push(((word >> 32) & 0xFF).to_u8())
        digest.push(((word >> 24) & 0xFF).to_u8())
        digest.push(((word >> 16) & 0xFF).to_u8())
        digest.push(((word >> 8) & 0xFF).to_u8())
        digest.push((word & 0xFF).to_u8())
        i = i + 1

    digest
