# AES-GCM-SIV: AES S-box, Rcon, and key expansion helpers.
#
# Provides AES-128 and AES-256 key expansion used by AES-GCM-SIV
# key derivation and block encryption.

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

# ============================================================================
# AES S-box and Rcon tables
# ============================================================================

