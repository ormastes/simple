# SipHash-2-4 and SipHash-1-3 — Pure Simple Implementation
#
# Fast keyed PRF / hash-table seed. Aumasson & Bernstein, 2012.
# Reference: https://www.aumasson.jp/siphash/siphash.pdf
#
# Two variants:
#   siphash24 — 2 c-rounds + 4 d-rounds (reference, conservative)
#   siphash13 — 1 c-round  + 3 d-rounds (Rust HashMap default since 1.13)
#
# Key: 16 bytes, split into two 64-bit little-endian halves k0, k1.
# Input: arbitrary-length byte slice.
# Output: 64-bit tag (u64).
#
# Magic constants: "somepseu", "dorandom", "lygenera", "tedbytes"
#   v0 = k0 ^ 0x736f6d6570736575
#   v1 = k1 ^ 0x646f72616e646f6d
#   v2 = k0 ^ 0x6c7967656e657261
#   v3 = k1 ^ 0x7465646279746573
#
# SipRound (the compress step):
#   v0 += v1; v1 = rotl(v1,13); v1 ^= v0; v0 = rotl(v0,32)
#   v2 += v3; v3 = rotl(v3,16); v3 ^= v2
#   v0 += v3; v3 = rotl(v3,21); v3 ^= v0
#   v2 += v1; v1 = rotl(v1,17); v1 ^= v2; v2 = rotl(v2,32)
#
# All u64 arithmetic wraps naturally (no masking needed).
# Reference test vectors: Aumasson/siphasher vendor tests in
#   src/compiler_rust/vendor/siphasher/src/tests.rs
# ============================================================================

# ============================================================================
# Bit helpers
# ============================================================================

fn _rotl64(x: u64, n: u64) -> u64:
    """64-bit left rotation."""
    (x << n) | (x >> (64 - n))

fn _load_u64_le(buf: [u8], off: u64) -> u64:
    """Load 8 bytes from buf[off..off+7] as a little-endian u64."""
    buf[off].to_u64() |
        (buf[off + 1].to_u64() << 8) |
        (buf[off + 2].to_u64() << 16) |
        (buf[off + 3].to_u64() << 24) |
        (buf[off + 4].to_u64() << 32) |
        (buf[off + 5].to_u64() << 40) |
        (buf[off + 6].to_u64() << 48) |
        (buf[off + 7].to_u64() << 56)

fn _load_tail_le(buf: [u8], off: u64, n: u64) -> u64:
    """Load 0..7 bytes from buf[off..off+n-1] as little-endian u64."""
    var out: u64 = 0
    var i: u64 = 0
    while i < n:
        out = out | (buf[off + i].to_u64() << (i * 8))
        i = i + 1
    out

# ============================================================================
# SipRound (single compression round)
# ============================================================================

fn _sip_round(v0: u64, v1: u64, v2: u64, v3: u64) -> [u64]:
    """One SipRound. Returns [v0, v1, v2, v3]."""
    var a: u64 = v0 + v1
    var b: u64 = _rotl64(v1, 13)
    b = b ^ a
    var c: u64 = _rotl64(a, 32)
    var d: u64 = v2 + v3
    var e: u64 = _rotl64(v3, 16)
    e = e ^ d
    c = c + e
    var f: u64 = _rotl64(e, 21)
    f = f ^ c
    d = d + b
    b = _rotl64(b, 17)
    b = b ^ d
    d = _rotl64(d, 32)
    var result: [u64] = []
    result.push(c)
    result.push(b)
    result.push(d)
    result.push(f)
    result

# ============================================================================
# Core SipHash engine (parameterised by c and d round counts)
# ============================================================================

fn _siphash(key: [u8], msg: [u8], c_rounds: u64, d_rounds: u64) -> u64:
    """SipHash with configurable c (compression) and d (finalization) rounds."""
    # Load key halves as little-endian u64
    val k0: u64 = _load_u64_le(key, 0)
    val k1: u64 = _load_u64_le(key, 8)

    # Initial state with magic constants
    var v0: u64 = k0 ^ 0x736f6d6570736575
    var v1: u64 = k1 ^ 0x646f72616e646f6d
    var v2: u64 = k0 ^ 0x6c7967656e657261
    var v3: u64 = k1 ^ 0x7465646279746573

    val msg_len: u64 = msg.len().to_u64()
    val full_blocks: u64 = msg_len / 8
    val tail_len: u64 = msg_len % 8

    # Process full 8-byte blocks
    var block: u64 = 0
    while block < full_blocks:
        val m: u64 = _load_u64_le(msg, block * 8)
        v3 = v3 ^ m
        # c compression rounds
        var cr: u64 = 0
        while cr < c_rounds:
            val r = _sip_round(v0, v1, v2, v3)
            v0 = r[0]
            v1 = r[1]
            v2 = r[2]
            v3 = r[3]
            cr = cr + 1
        v0 = v0 ^ m
        block = block + 1

    # Final block: tail bytes + length byte in top byte of word
    val tail_off: u64 = full_blocks * 8
    val last_word: u64 = (
        _load_tail_le(msg, tail_off, tail_len) |
        ((msg_len & 0xff) << 56)
    )

    v3 = v3 ^ last_word
    var cr2: u64 = 0
    while cr2 < c_rounds:
        val r2 = _sip_round(v0, v1, v2, v3)
        v0 = r2[0]
        v1 = r2[1]
        v2 = r2[2]
        v3 = r2[3]
        cr2 = cr2 + 1
    v0 = v0 ^ last_word

    # Finalization
    v2 = v2 ^ 0xff
    var dr: u64 = 0
    while dr < d_rounds:
        val r3 = _sip_round(v0, v1, v2, v3)
        v0 = r3[0]
        v1 = r3[1]
        v2 = r3[2]
        v3 = r3[3]
        dr = dr + 1

    v0 ^ v1 ^ v2 ^ v3

# ============================================================================
# Public API
# ============================================================================

fn siphash24(key: [u8], msg: [u8]) -> u64:
    """SipHash-2-4: 2 compression rounds + 4 finalization rounds.

    key must be exactly 16 bytes.
    Standard variant from the 2012 paper.
    """
    _siphash(key, msg, 2, 4)

fn siphash13(key: [u8], msg: [u8]) -> u64:
    """SipHash-1-3: 1 compression round + 3 finalization rounds.

    key must be exactly 16 bytes.
    Faster variant; default in Rust HashMap since 1.13.
    """
    _siphash(key, msg, 1, 3)
