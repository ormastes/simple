#![allow(unnamed_duplicate_typed_args)]
# Camellia Block Cipher — Pure Simple Implementation
#
# 128-bit block, 128-bit and 256-bit key variants.
# 18 rounds (128-bit key) or 24 rounds (256-bit key) Feistel cipher.
# FL/FL-inv layers between every 6-round bank.
#
# Reference: RFC 3713 — A Description of the Camellia Encryption Algorithm
#   https://datatracker.ietf.org/doc/html/rfc3713
#
# Exposed API:
#   camellia128_encrypt_block(key: [u8], block: [u8]) -> [u8]
#   camellia128_decrypt_block(key: [u8], block: [u8]) -> [u8]
#   camellia256_encrypt_block(key: [u8], block: [u8]) -> [u8]
#   camellia256_decrypt_block(key: [u8], block: [u8]) -> [u8]
#
# No SFFI/Rust FFI — pure Simple, suitable for baremetal.

extern fn rt_array_new_with_cap(cap: i64) -> [u8]

fn _u8_at(buf: [u8], idx: u64) -> u8:
    buf[idx.to_i64()]

fn _new_buf(cap: u64) -> [u8]:
    rt_array_new_with_cap(cap.to_i64())

# ============================================================================
# SBOX1 — RFC 3713 Appendix A (256 bytes)
# ============================================================================

fn _sbox1() -> [u8]:
    [
        0x70u8, 0x82u8, 0x2cu8, 0xecu8, 0xb3u8, 0x27u8, 0xc0u8, 0xe5u8,
        0xe4u8, 0x85u8, 0x57u8, 0x35u8, 0xeau8, 0x0cu8, 0xaeu8, 0x41u8,
        0x23u8, 0xefu8, 0x6bu8, 0x93u8, 0x45u8, 0x19u8, 0xa5u8, 0x21u8,
        0xedu8, 0x0eu8, 0x4fu8, 0x4eu8, 0x1du8, 0x65u8, 0x92u8, 0xbdu8,
        0x86u8, 0xb8u8, 0xafu8, 0x8fu8, 0x7cu8, 0xebu8, 0x1fu8, 0xceu8,
        0x3eu8, 0x30u8, 0xdcu8, 0x5fu8, 0x5eu8, 0xc5u8, 0x0bu8, 0x1au8,
        0xa6u8, 0xe1u8, 0x39u8, 0xcau8, 0xd5u8, 0x47u8, 0x5du8, 0x3du8,
        0xd9u8, 0x01u8, 0x5au8, 0xd6u8, 0x51u8, 0x56u8, 0x6cu8, 0x4du8,
        0x8bu8, 0x0du8, 0x9au8, 0x66u8, 0xfbu8, 0xccu8, 0xb0u8, 0x2du8,
        0x74u8, 0x12u8, 0x2bu8, 0x20u8, 0xf0u8, 0xb1u8, 0x84u8, 0x99u8,
        0xdfu8, 0x4cu8, 0xcbu8, 0xc2u8, 0x34u8, 0x7eu8, 0x76u8, 0x05u8,
        0x6du8, 0xb7u8, 0xa9u8, 0x31u8, 0xd1u8, 0x17u8, 0x04u8, 0xd7u8,
        0x14u8, 0x58u8, 0x3au8, 0x61u8, 0xdeu8, 0x1bu8, 0x11u8, 0x1cu8,
        0x32u8, 0x0fu8, 0x9cu8, 0x16u8, 0x53u8, 0x18u8, 0xf2u8, 0x22u8,
        0xfeu8, 0x44u8, 0xcfu8, 0xb2u8, 0xc3u8, 0xb5u8, 0x7au8, 0x91u8,
        0x24u8, 0x08u8, 0xe8u8, 0xa8u8, 0x60u8, 0xfcu8, 0x69u8, 0x50u8,
        0xaau8, 0xd0u8, 0xa0u8, 0x7du8, 0xa1u8, 0x89u8, 0x62u8, 0x97u8,
        0x54u8, 0x5bu8, 0x1eu8, 0x95u8, 0xe0u8, 0xffu8, 0x64u8, 0xd2u8,
        0x10u8, 0xc4u8, 0x00u8, 0x48u8, 0xa3u8, 0xf7u8, 0x75u8, 0xdbu8,
        0x8au8, 0x03u8, 0xe6u8, 0xdau8, 0x09u8, 0x3fu8, 0xddu8, 0x94u8,
        0x87u8, 0x5cu8, 0x83u8, 0x02u8, 0xcdu8, 0x4au8, 0x90u8, 0x33u8,
        0x73u8, 0x67u8, 0xf6u8, 0xf3u8, 0x9du8, 0x7fu8, 0xbfu8, 0xe2u8,
        0x52u8, 0x9bu8, 0xd8u8, 0x26u8, 0xc8u8, 0x37u8, 0xc6u8, 0x3bu8,
        0x81u8, 0x96u8, 0x6fu8, 0x4bu8, 0x13u8, 0xbeu8, 0x63u8, 0x2eu8,
        0xe9u8, 0x79u8, 0xa7u8, 0x8cu8, 0x9fu8, 0x6eu8, 0xbcu8, 0x8eu8,
        0x29u8, 0xf5u8, 0xf9u8, 0xb6u8, 0x2fu8, 0xfdu8, 0xb4u8, 0x59u8,
        0x78u8, 0x98u8, 0x06u8, 0x6au8, 0xe7u8, 0x46u8, 0x71u8, 0xbau8,
        0xd4u8, 0x25u8, 0xabu8, 0x42u8, 0x88u8, 0xa2u8, 0x8du8, 0xfau8,
        0x72u8, 0x07u8, 0xb9u8, 0x55u8, 0xf8u8, 0xeeu8, 0xacu8, 0x0au8,
        0x36u8, 0x49u8, 0x2au8, 0x68u8, 0x3cu8, 0x38u8, 0xf1u8, 0xa4u8,
        0x40u8, 0x28u8, 0xd3u8, 0x7bu8, 0xbbu8, 0xc9u8, 0x43u8, 0xc1u8,
        0x15u8, 0xe3u8, 0xadu8, 0xf4u8, 0x77u8, 0xc7u8, 0x80u8, 0x9eu8
    ]

fn _s1(x: u8) -> u32:
    _u8_at(_sbox1(), x.to_u64()).to_u32()

fn _s2(x: u8) -> u32:
    val v: u32 = _u8_at(_sbox1(), x.to_u64()).to_u32()
    ((v << 1) | (v >> 7)) & 0xFFu32

fn _s3(x: u8) -> u32:
    val v: u32 = _u8_at(_sbox1(), x.to_u64()).to_u32()
    ((v >> 1) | (v << 7)) & 0xFFu32

fn _s4(x: u8) -> u32:
    val xv: u32 = x.to_u32()
    val xr: u8 = (((xv << 1) | (xv >> 7)) & 0xFFu32).to_u8()
    _u8_at(_sbox1(), xr.to_u64()).to_u32()

# ============================================================================
# Sigma constants — RFC 3713 §2.4.1 (exact hex values)
# ============================================================================
fn _c1() -> u64: 0xA09E667F3BCC908Bu64
fn _c2() -> u64: 0xB67AE8584CAA73B2u64
fn _c3() -> u64: 0xC6EF372FE94F82BEu64
fn _c4() -> u64: 0x54FF53A5F1D36F1Cu64
fn _c5() -> u64: 0x10E527FADE682D1Du64
fn _c6() -> u64: 0xB05688C2B3E6C1FDu64

# ============================================================================
# 64-bit I/O helpers (big-endian)
# ============================================================================

fn _ld64(buf: [u8], off: u64) -> u64:
    val b0: u64 = _u8_at(buf, off).to_u64()
    val b1: u64 = _u8_at(buf, off + 1).to_u64()
    val b2: u64 = _u8_at(buf, off + 2).to_u64()
    val b3: u64 = _u8_at(buf, off + 3).to_u64()
    val b4: u64 = _u8_at(buf, off + 4).to_u64()
    val b5: u64 = _u8_at(buf, off + 5).to_u64()
    val b6: u64 = _u8_at(buf, off + 6).to_u64()
    val b7: u64 = _u8_at(buf, off + 7).to_u64()
    (b0 << 56) | (b1 << 48) | (b2 << 40) | (b3 << 32) |
    (b4 << 24) | (b5 << 16) | (b6 << 8) | b7

fn _st64(buf: [u8], v: u64):
    buf.push(((v >> 56) & 0xFFu64).to_u8())
    buf.push(((v >> 48) & 0xFFu64).to_u8())
    buf.push(((v >> 40) & 0xFFu64).to_u8())
    buf.push(((v >> 32) & 0xFFu64).to_u8())
    buf.push(((v >> 24) & 0xFFu64).to_u8())
    buf.push(((v >> 16) & 0xFFu64).to_u8())
    buf.push(((v >> 8) & 0xFFu64).to_u8())
    buf.push((v & 0xFFu64).to_u8())

fn _wr64(buf: [u8], off: u64, v: u64):
    buf[off]     = ((v >> 56) & 0xFFu64).to_u8()
    buf[off + 1] = ((v >> 48) & 0xFFu64).to_u8()
    buf[off + 2] = ((v >> 40) & 0xFFu64).to_u8()
    buf[off + 3] = ((v >> 32) & 0xFFu64).to_u8()
    buf[off + 4] = ((v >> 24) & 0xFFu64).to_u8()
    buf[off + 5] = ((v >> 16) & 0xFFu64).to_u8()
    buf[off + 6] = ((v >> 8) & 0xFFu64).to_u8()
    buf[off + 7] = (v & 0xFFu64).to_u8()

# 128-bit left rotation by n bits (1 <= n <= 63)
fn _rot128(hi: u64, lo: u64, n: u64) -> (u64, u64):
    val rhi: u64 = (hi << n) | (lo >> (64 - n))
    val rlo: u64 = (lo << n) | (hi >> (64 - n))
    (rhi, rlo)

# 128-bit left rotation by 64+n bits (0 <= n <= 63)
fn _rot128p(hi: u64, lo: u64, n: u64) -> (u64, u64):
    # Equivalent to swap(hi,lo) then rotate by n
    if n == 0:
        (lo, hi)
    else:
        val rhi: u64 = (lo << n) | (hi >> (64 - n))
        val rlo: u64 = (hi << n) | (lo >> (64 - n))
        (rhi, rlo)

# ============================================================================
# F-function — RFC 3713 §2.4.1
# Substitution order: (s1,s2,s3,s4,s2,s3,s4,s1) on bytes [7..0] of X.
# P-function (diffusion):
#   z1 = t1^t3^t4^t6^t7^t8
#   z2 = t1^t2^t4^t5^t7^t8
#   z3 = t1^t2^t3^t5^t6^t8
#   z4 = t2^t3^t4^t5^t6^t7
#   z5 = t1^t2^t6^t7^t8
#   z6 = t2^t3^t5^t7^t8
#   z7 = t3^t4^t5^t6^t8
#   z8 = t1^t4^t5^t6^t7
# ============================================================================

fn _f(x: u64, k: u64) -> u64:
    val v: u64 = x ^ k
    val t1: u32 = _s1(((v >> 56) & 0xFFu64).to_u8())
    val t2: u32 = _s2(((v >> 48) & 0xFFu64).to_u8())
    val t3: u32 = _s3(((v >> 40) & 0xFFu64).to_u8())
    val t4: u32 = _s4(((v >> 32) & 0xFFu64).to_u8())
    val t5: u32 = _s2(((v >> 24) & 0xFFu64).to_u8())
    val t6: u32 = _s3(((v >> 16) & 0xFFu64).to_u8())
    val t7: u32 = _s4(((v >> 8) & 0xFFu64).to_u8())
    val t8: u32 = _s1((v & 0xFFu64).to_u8())
    val z1: u64 = (t1 ^ t3 ^ t4 ^ t6 ^ t7 ^ t8).to_u64() & 0xFFu64
    val z2: u64 = (t1 ^ t2 ^ t4 ^ t5 ^ t7 ^ t8).to_u64() & 0xFFu64
    val z3: u64 = (t1 ^ t2 ^ t3 ^ t5 ^ t6 ^ t8).to_u64() & 0xFFu64
    val z4: u64 = (t2 ^ t3 ^ t4 ^ t5 ^ t6 ^ t7).to_u64() & 0xFFu64
    val z5: u64 = (t1 ^ t2 ^ t6 ^ t7 ^ t8).to_u64() & 0xFFu64
    val z6: u64 = (t2 ^ t3 ^ t5 ^ t7 ^ t8).to_u64() & 0xFFu64
    val z7: u64 = (t3 ^ t4 ^ t5 ^ t6 ^ t8).to_u64() & 0xFFu64
    val z8: u64 = (t1 ^ t4 ^ t5 ^ t6 ^ t7).to_u64() & 0xFFu64
    (z1 << 56) | (z2 << 48) | (z3 << 40) | (z4 << 32) |
    (z5 << 24) | (z6 << 16) | (z7 << 8) | z8

# ============================================================================
# FL / FL-inverse — RFC 3713 §2.4.2
# ============================================================================

fn _fl(x: u64, k: u64) -> u64:
    var x1: u32 = ((x >> 32) & 0xFFFFFFFFu64).to_u32()
    var x2: u32 = (x & 0xFFFFFFFFu64).to_u32()
    val k1: u32 = ((k >> 32) & 0xFFFFFFFFu64).to_u32()
    val k2: u32 = (k & 0xFFFFFFFFu64).to_u32()
    val t: u32 = x1 & k1
    x2 = x2 ^ (((t << 1) | (t >> 31)) & 0xFFFFFFFFu32)
    x1 = x1 ^ (x2 | k2)
    (x1.to_u64() << 32) | x2.to_u64()

fn _fli(x: u64, k: u64) -> u64:
    var y1: u32 = ((x >> 32) & 0xFFFFFFFFu64).to_u32()
    var y2: u32 = (x & 0xFFFFFFFFu64).to_u32()
    val k1: u32 = ((k >> 32) & 0xFFFFFFFFu64).to_u32()
    val k2: u32 = (k & 0xFFFFFFFFu64).to_u32()
    y1 = y1 ^ (y2 | k2)
    val t: u32 = y1 & k1
    y2 = y2 ^ (((t << 1) | (t >> 31)) & 0xFFFFFFFFu32)
    (y1.to_u64() << 32) | y2.to_u64()

# ============================================================================
# Key schedule — 128-bit (RFC 3713 §2.4.3, Table 1)
#
# 26 sub-key words at byte offsets 0, 8, 16 ... 200.
# Word index → name:
#   0=kw1  1=kw2  2=k1  3=k2  4=k3  5=k4  6=k5  7=k6
#   8=ke1  9=ke2  10=k7 11=k8 12=k9 13=k10 14=k11 15=k12
#   16=ke3 17=ke4 18=k13 19=k14 20=k15 21=k16 22=k17 23=k18
#   24=kw3 25=kw4
# ============================================================================

fn _ks128(key: [u8]) -> [u8]:
    val kl_h: u64 = _ld64(key, 0)
    val kl_l: u64 = _ld64(key, 8)

    # KA derivation (RFC 3713 §2.4.3)
    var d1: u64 = kl_h
    var d2: u64 = kl_l
    d2 = d2 ^ _f(d1, _c1())
    d1 = d1 ^ _f(d2, _c2())
    d1 = d1 ^ kl_h
    d2 = d2 ^ kl_l
    d2 = d2 ^ _f(d1, _c3())
    d1 = d1 ^ _f(d2, _c4())
    val ka_h: u64 = d1
    val ka_l: u64 = d2

    var sk: [u8] = _new_buf(208)
    var _i: u64 = 0
    while _i < 208:
        sk.push(0x00u8)
        _i = _i + 1

    # Table 1 (RFC 3713) — all rotations of 128-bit KL or KA
    # kw1,kw2 = KL<<<0
    _wr64(sk, 0,   kl_h)
    _wr64(sk, 8,   kl_l)
    # k1,k2 = KA<<<0
    _wr64(sk, 16,  ka_h)
    _wr64(sk, 24,  ka_l)
    # k3,k4 = KL<<<15
    val (r15h, r15l) = _rot128(kl_h, kl_l, 15)
    _wr64(sk, 32,  r15h)
    _wr64(sk, 40,  r15l)
    # k5,k6 = KA<<<15
    val (a15h, a15l) = _rot128(ka_h, ka_l, 15)
    _wr64(sk, 48,  a15h)
    _wr64(sk, 56,  a15l)
    # ke1,ke2 = KA<<<30
    val (a30h, a30l) = _rot128(ka_h, ka_l, 30)
    _wr64(sk, 64,  a30h)
    _wr64(sk, 72,  a30l)
    # k7,k8 = KL<<<45
    val (r45h, r45l) = _rot128(kl_h, kl_l, 45)
    _wr64(sk, 80,  r45h)
    _wr64(sk, 88,  r45l)
    # k9 = KA<<<45 (high word)
    val (a45h, a45l) = _rot128(ka_h, ka_l, 45)
    _wr64(sk, 96,  a45h)
    # k10 = KL<<<60 (low word)
    val (r60h, r60l) = _rot128(kl_h, kl_l, 60)
    _wr64(sk, 104, r60l)
    # k11,k12 = KA<<<60
    val (a60h, a60l) = _rot128(ka_h, ka_l, 60)
    _wr64(sk, 112, a60h)
    _wr64(sk, 120, a60l)
    # ke3,ke4 = KL<<<77  (77 = 64+13)
    val (r77h, r77l) = _rot128p(kl_h, kl_l, 13)
    _wr64(sk, 128, r77h)
    _wr64(sk, 136, r77l)
    # k13,k14 = KL<<<94  (94 = 64+30)
    val (r94h, r94l) = _rot128p(kl_h, kl_l, 30)
    _wr64(sk, 144, r94h)
    _wr64(sk, 152, r94l)
    # k15,k16 = KA<<<94  (94 = 64+30)
    val (a94h, a94l) = _rot128p(ka_h, ka_l, 30)
    _wr64(sk, 160, a94h)
    _wr64(sk, 168, a94l)
    # k17,k18 = KL<<<111  (111 = 64+47)
    val (r111h, r111l) = _rot128p(kl_h, kl_l, 47)
    _wr64(sk, 176, r111h)
    _wr64(sk, 184, r111l)
    # kw3,kw4 = KA<<<111  (111 = 64+47)
    val (a111h, a111l) = _rot128p(ka_h, ka_l, 47)
    _wr64(sk, 192, a111h)
    _wr64(sk, 200, a111l)

    sk

# ============================================================================
# Key schedule — 256-bit (RFC 3713 §2.4.3, Table 2)
#
# 34 sub-key words at byte offsets 0 ... 264.
# Word index → name (RFC 3713 Table 2 order):
#   0=kw1  1=kw2  2=k1   3=k2   4=k3   5=k4   6=k5   7=k6
#   8=ke1  9=ke2  10=k7  11=k8  12=k9  13=k10 14=k11 15=k12
#   16=ke3 17=ke4 18=k13 19=k14 20=k15 21=k16 22=k17 23=k18
#   24=ke5 25=ke6 26=k19 27=k20 28=k21 29=k22 30=k23 31=k24
#   32=kw3 33=kw4
# ============================================================================

fn _ks256(key: [u8]) -> [u8]:
    val kl_h: u64 = _ld64(key, 0)
    val kl_l: u64 = _ld64(key, 8)
    val kr_h: u64 = _ld64(key, 16)
    val kr_r: u64 = _ld64(key, 24)

    # KA derivation
    var d1: u64 = kl_h ^ kr_h
    var d2: u64 = kl_l ^ kr_r
    d2 = d2 ^ _f(d1, _c1())
    d1 = d1 ^ _f(d2, _c2())
    d1 = d1 ^ kl_h
    d2 = d2 ^ kl_l
    d2 = d2 ^ _f(d1, _c3())
    d1 = d1 ^ _f(d2, _c4())
    val ka_h: u64 = d1
    val ka_l: u64 = d2

    # KB derivation
    var e1: u64 = ka_h ^ kr_h
    var e2: u64 = ka_l ^ kr_r
    e2 = e2 ^ _f(e1, _c5())
    e1 = e1 ^ _f(e2, _c6())
    val kb_h: u64 = e1
    val kb_l: u64 = e2

    var sk: [u8] = _new_buf(272)
    var _i: u64 = 0
    while _i < 272:
        sk.push(0x00u8)
        _i = _i + 1

    # Table 2 (RFC 3713) — 256-bit key sub-key schedule (byte offset = index * 8)
    # kw1,kw2 = KL<<<0   (indices 0,1)
    _wr64(sk, 0,   kl_h)
    _wr64(sk, 8,   kl_l)
    # k1,k2 = KB<<<0     (indices 2,3)
    _wr64(sk, 16,  kb_h)
    _wr64(sk, 24,  kb_l)
    # k3,k4 = KR<<<15    (indices 4,5)
    val (b15h, b15l) = _rot128(kr_h, kr_r, 15)
    _wr64(sk, 32,  b15h)
    _wr64(sk, 40,  b15l)
    # k5,k6 = KA<<<15    (indices 6,7)
    val (a15h, a15l) = _rot128(ka_h, ka_l, 15)
    _wr64(sk, 48,  a15h)
    _wr64(sk, 56,  a15l)
    # ke1,ke2 = KR<<<30  (indices 8,9)
    val (b30h, b30l) = _rot128(kr_h, kr_r, 30)
    _wr64(sk, 64,  b30h)
    _wr64(sk, 72,  b30l)
    # k7,k8 = KB<<<30    (indices 10,11)
    val (c30h, c30l) = _rot128(kb_h, kb_l, 30)
    _wr64(sk, 80,  c30h)
    _wr64(sk, 88,  c30l)
    # k9,k10 = KL<<<45   (indices 12,13)
    val (r45h, r45l) = _rot128(kl_h, kl_l, 45)
    _wr64(sk, 96,  r45h)
    _wr64(sk, 104, r45l)
    # k11,k12 = KA<<<45  (indices 14,15)
    val (a45h, a45l) = _rot128(ka_h, ka_l, 45)
    _wr64(sk, 112, a45h)
    _wr64(sk, 120, a45l)
    # ke3,ke4 = KL<<<60  (indices 16,17)
    val (r60h, r60l) = _rot128(kl_h, kl_l, 60)
    _wr64(sk, 128, r60h)
    _wr64(sk, 136, r60l)
    # k13,k14 = KR<<<60  (indices 18,19)
    val (b60h, b60l) = _rot128(kr_h, kr_r, 60)
    _wr64(sk, 144, b60h)
    _wr64(sk, 152, b60l)
    # k15,k16 = KB<<<60  (indices 20,21)
    val (c60h, c60l) = _rot128(kb_h, kb_l, 60)
    _wr64(sk, 160, c60h)
    _wr64(sk, 168, c60l)
    # k17,k18 = KL<<<77 (77=64+13)  (indices 22,23)
    val (r77h, r77l) = _rot128p(kl_h, kl_l, 13)
    _wr64(sk, 176, r77h)
    _wr64(sk, 184, r77l)
    # ke5,ke6 = KA<<<77 (77=64+13)  (indices 24,25)
    val (a77h, a77l) = _rot128p(ka_h, ka_l, 13)
    _wr64(sk, 192, a77h)
    _wr64(sk, 200, a77l)
    # k19,k20 = KR<<<94 (94=64+30)  (indices 26,27)
    val (b94h, b94l) = _rot128p(kr_h, kr_r, 30)
    _wr64(sk, 208, b94h)
    _wr64(sk, 216, b94l)
    # k21,k22 = KA<<<94 (94=64+30)  (indices 28,29)
    val (a94h, a94l) = _rot128p(ka_h, ka_l, 30)
    _wr64(sk, 224, a94h)
    _wr64(sk, 232, a94l)
    # k23,k24 = KL<<<111 (111=64+47) (indices 30,31)
    val (r111h, r111l) = _rot128p(kl_h, kl_l, 47)
    _wr64(sk, 240, r111h)
    _wr64(sk, 248, r111l)
    # kw3,kw4 = KB<<<111 (111=64+47) (indices 32,33)
    val (c111h, c111l) = _rot128p(kb_h, kb_l, 47)
    _wr64(sk, 256, c111h)
    _wr64(sk, 264, c111l)

    sk

# ============================================================================
# Sub-key load helpers
# ============================================================================

fn _sk(sk: [u8], i: u64) -> u64:
    _ld64(sk, i * 8)

# ============================================================================
# Public API — Camellia-128
# ============================================================================

fn camellia128_encrypt_block(key: [u8], block: [u8]) -> [u8]:
    """Encrypt one 16-byte block with a 16-byte Camellia-128 key (RFC 3713)."""
    val sk: [u8] = _ks128(key)
    var d1: u64 = _ld64(block, 0) ^ _sk(sk, 0)   # ^ kw1
    var d2: u64 = _ld64(block, 8) ^ _sk(sk, 1)   # ^ kw2

    d2 = d2 ^ _f(d1, _sk(sk, 2))    # k1
    d1 = d1 ^ _f(d2, _sk(sk, 3))    # k2
    d2 = d2 ^ _f(d1, _sk(sk, 4))    # k3
    d1 = d1 ^ _f(d2, _sk(sk, 5))    # k4
    d2 = d2 ^ _f(d1, _sk(sk, 6))    # k5
    d1 = d1 ^ _f(d2, _sk(sk, 7))    # k6

    d1 = _fl(d1, _sk(sk, 8))        # ke1
    d2 = _fli(d2, _sk(sk, 9))       # ke2

    d2 = d2 ^ _f(d1, _sk(sk, 10))   # k7
    d1 = d1 ^ _f(d2, _sk(sk, 11))   # k8
    d2 = d2 ^ _f(d1, _sk(sk, 12))   # k9
    d1 = d1 ^ _f(d2, _sk(sk, 13))   # k10
    d2 = d2 ^ _f(d1, _sk(sk, 14))   # k11
    d1 = d1 ^ _f(d2, _sk(sk, 15))   # k12

    d1 = _fl(d1, _sk(sk, 16))       # ke3
    d2 = _fli(d2, _sk(sk, 17))      # ke4

    d2 = d2 ^ _f(d1, _sk(sk, 18))   # k13
    d1 = d1 ^ _f(d2, _sk(sk, 19))   # k14
    d2 = d2 ^ _f(d1, _sk(sk, 20))   # k15
    d1 = d1 ^ _f(d2, _sk(sk, 21))   # k16
    d2 = d2 ^ _f(d1, _sk(sk, 22))   # k17
    d1 = d1 ^ _f(d2, _sk(sk, 23))   # k18

    # Final whitening — RFC 3713: output = (D2 ^ kw3) || (D1 ^ kw4)
    val c1: u64 = d2 ^ _sk(sk, 24)  # ^ kw3
    val c2: u64 = d1 ^ _sk(sk, 25)  # ^ kw4

    var ct: [u8] = _new_buf(16)
    var _j: u64 = 0
    while _j < 16:
        ct.push(0x00u8)
        _j = _j + 1
    _wr64(ct, 0, c1)
    _wr64(ct, 8, c2)
    ct

fn camellia128_decrypt_block(key: [u8], block: [u8]) -> [u8]:
    """Decrypt one 16-byte block with a 16-byte Camellia-128 key (RFC 3713)."""
    val sk: [u8] = _ks128(key)
    # Decrypt starts from the whitening end; input halves are swapped relative
    # to encrypt output (c1=D2^kw3 corresponds to d1 in decrypt)
    var d1: u64 = _ld64(block, 0) ^ _sk(sk, 24)  # ^ kw3
    var d2: u64 = _ld64(block, 8) ^ _sk(sk, 25)  # ^ kw4

    d2 = d2 ^ _f(d1, _sk(sk, 23))   # k18
    d1 = d1 ^ _f(d2, _sk(sk, 22))   # k17
    d2 = d2 ^ _f(d1, _sk(sk, 21))   # k16
    d1 = d1 ^ _f(d2, _sk(sk, 20))   # k15
    d2 = d2 ^ _f(d1, _sk(sk, 19))   # k14
    d1 = d1 ^ _f(d2, _sk(sk, 18))   # k13

    # Undo FL(ke3)/FLINV(ke4): decrypt d1=enc-d2 (had FLINV(ke4)), d2=enc-d1 (had FL(ke3))
    d1 = _fl(d1, _sk(sk, 17))        # FL with ke4  (undoes FLINV on enc d2)
    d2 = _fli(d2, _sk(sk, 16))       # FLINV with ke3 (undoes FL on enc d1)

    d2 = d2 ^ _f(d1, _sk(sk, 15))   # k12
    d1 = d1 ^ _f(d2, _sk(sk, 14))   # k11
    d2 = d2 ^ _f(d1, _sk(sk, 13))   # k10
    d1 = d1 ^ _f(d2, _sk(sk, 12))   # k9
    d2 = d2 ^ _f(d1, _sk(sk, 11))   # k8
    d1 = d1 ^ _f(d2, _sk(sk, 10))   # k7

    # Undo FL(ke1)/FLINV(ke2): decrypt d1=enc-d2 (had FLINV(ke2)), d2=enc-d1 (had FL(ke1))
    d1 = _fl(d1, _sk(sk, 9))         # FL with ke2  (undoes FLINV on enc d2)
    d2 = _fli(d2, _sk(sk, 8))        # FLINV with ke1 (undoes FL on enc d1)

    d2 = d2 ^ _f(d1, _sk(sk, 7))    # k6
    d1 = d1 ^ _f(d2, _sk(sk, 6))    # k5
    d2 = d2 ^ _f(d1, _sk(sk, 5))    # k4
    d1 = d1 ^ _f(d2, _sk(sk, 4))    # k3
    d2 = d2 ^ _f(d1, _sk(sk, 3))    # k2
    d1 = d1 ^ _f(d2, _sk(sk, 2))    # k1

    # Final whitening — symmetric with encrypt output swap
    val p1: u64 = d2 ^ _sk(sk, 0)   # ^ kw1
    val p2: u64 = d1 ^ _sk(sk, 1)   # ^ kw2

    var pt: [u8] = _new_buf(16)
    var _j2: u64 = 0
    while _j2 < 16:
        pt.push(0x00u8)
        _j2 = _j2 + 1
    _wr64(pt, 0, p1)
    _wr64(pt, 8, p2)
    pt

# ============================================================================
# Public API — Camellia-256
# ============================================================================

fn camellia256_encrypt_block(key: [u8], block: [u8]) -> [u8]:
    """Encrypt one 16-byte block with a 32-byte Camellia-256 key (RFC 3713)."""
    val sk: [u8] = _ks256(key)
    var d1: u64 = _ld64(block, 0) ^ _sk(sk, 0)   # ^ kw1
    var d2: u64 = _ld64(block, 8) ^ _sk(sk, 1)   # ^ kw2

    d2 = d2 ^ _f(d1, _sk(sk, 2))    # k1
    d1 = d1 ^ _f(d2, _sk(sk, 3))    # k2
    d2 = d2 ^ _f(d1, _sk(sk, 4))    # k3
    d1 = d1 ^ _f(d2, _sk(sk, 5))    # k4
    d2 = d2 ^ _f(d1, _sk(sk, 6))    # k5
    d1 = d1 ^ _f(d2, _sk(sk, 7))    # k6

    d1 = _fl(d1, _sk(sk, 8))        # ke1
    d2 = _fli(d2, _sk(sk, 9))       # ke2

    d2 = d2 ^ _f(d1, _sk(sk, 10))   # k7
    d1 = d1 ^ _f(d2, _sk(sk, 11))   # k8
    d2 = d2 ^ _f(d1, _sk(sk, 12))   # k9
    d1 = d1 ^ _f(d2, _sk(sk, 13))   # k10
    d2 = d2 ^ _f(d1, _sk(sk, 14))   # k11
    d1 = d1 ^ _f(d2, _sk(sk, 15))   # k12

    d1 = _fl(d1, _sk(sk, 16))       # ke3
    d2 = _fli(d2, _sk(sk, 17))      # ke4

    d2 = d2 ^ _f(d1, _sk(sk, 18))   # k13
    d1 = d1 ^ _f(d2, _sk(sk, 19))   # k14
    d2 = d2 ^ _f(d1, _sk(sk, 20))   # k15
    d1 = d1 ^ _f(d2, _sk(sk, 21))   # k16
    d2 = d2 ^ _f(d1, _sk(sk, 22))   # k17
    d1 = d1 ^ _f(d2, _sk(sk, 23))   # k18

    d1 = _fl(d1, _sk(sk, 24))       # ke5
    d2 = _fli(d2, _sk(sk, 25))      # ke6

    d2 = d2 ^ _f(d1, _sk(sk, 26))   # k19
    d1 = d1 ^ _f(d2, _sk(sk, 27))   # k20
    d2 = d2 ^ _f(d1, _sk(sk, 28))   # k21
    d1 = d1 ^ _f(d2, _sk(sk, 29))   # k22
    d2 = d2 ^ _f(d1, _sk(sk, 30))   # k23
    d1 = d1 ^ _f(d2, _sk(sk, 31))   # k24

    val c1: u64 = d2 ^ _sk(sk, 32)  # ^ kw3
    val c2: u64 = d1 ^ _sk(sk, 33)  # ^ kw4

    var ct: [u8] = _new_buf(16)
    var _j3: u64 = 0
    while _j3 < 16:
        ct.push(0x00u8)
        _j3 = _j3 + 1
    _wr64(ct, 0, c1)
    _wr64(ct, 8, c2)
    ct

fn camellia256_decrypt_block(key: [u8], block: [u8]) -> [u8]:
    """Decrypt one 16-byte block with a 32-byte Camellia-256 key (RFC 3713)."""
    val sk: [u8] = _ks256(key)
    var d1: u64 = _ld64(block, 0) ^ _sk(sk, 32)  # ^ kw3
    var d2: u64 = _ld64(block, 8) ^ _sk(sk, 33)  # ^ kw4

    # Undo rounds k19-k24 (sk[26..31]) in reverse
    d2 = d2 ^ _f(d1, _sk(sk, 31))   # k24
    d1 = d1 ^ _f(d2, _sk(sk, 30))   # k23
    d2 = d2 ^ _f(d1, _sk(sk, 29))   # k22
    d1 = d1 ^ _f(d2, _sk(sk, 28))   # k21
    d2 = d2 ^ _f(d1, _sk(sk, 27))   # k20
    d1 = d1 ^ _f(d2, _sk(sk, 26))   # k19

    # Undo FL(ke5)/FLI(ke6) at sk[24,25].
    # Encrypt: d1=FL(ke5), d2=FLI(ke6). Decrypt d1=old-enc-d2, d2=old-enc-d1.
    d1 = _fl(d1, _sk(sk, 25))        # FL with ke6  (undoes FLI on enc d2)
    d2 = _fli(d2, _sk(sk, 24))       # FLI with ke5 (undoes FL on enc d1)

    # Undo rounds k13-k18 (sk[18..23]) in reverse
    d2 = d2 ^ _f(d1, _sk(sk, 23))   # k18
    d1 = d1 ^ _f(d2, _sk(sk, 22))   # k17
    d2 = d2 ^ _f(d1, _sk(sk, 21))   # k16
    d1 = d1 ^ _f(d2, _sk(sk, 20))   # k15
    d2 = d2 ^ _f(d1, _sk(sk, 19))   # k14
    d1 = d1 ^ _f(d2, _sk(sk, 18))   # k13

    # Undo FL(ke3)/FLI(ke4) at sk[16,17].
    # Encrypt: d1=FL(ke3), d2=FLI(ke4). Decrypt d1=old-enc-d2, d2=old-enc-d1.
    d1 = _fl(d1, _sk(sk, 17))        # FL with ke4  (undoes FLI on enc d2)
    d2 = _fli(d2, _sk(sk, 16))       # FLI with ke3 (undoes FL on enc d1)

    # Undo rounds k7-k12 (sk[10..15]) in reverse
    d2 = d2 ^ _f(d1, _sk(sk, 15))   # k12
    d1 = d1 ^ _f(d2, _sk(sk, 14))   # k11
    d2 = d2 ^ _f(d1, _sk(sk, 13))   # k10
    d1 = d1 ^ _f(d2, _sk(sk, 12))   # k9
    d2 = d2 ^ _f(d1, _sk(sk, 11))   # k8
    d1 = d1 ^ _f(d2, _sk(sk, 10))   # k7

    # Undo FL(ke1)/FLI(ke2) at sk[8,9].
    # Encrypt: d1=FL(ke1), d2=FLI(ke2). Decrypt d1=old-enc-d2, d2=old-enc-d1.
    d1 = _fl(d1, _sk(sk, 9))         # FL with ke2  (undoes FLI on enc d2)
    d2 = _fli(d2, _sk(sk, 8))        # FLI with ke1 (undoes FL on enc d1)

    # Undo rounds k1-k6 (sk[2..7]) in reverse
    d2 = d2 ^ _f(d1, _sk(sk, 7))    # k6
    d1 = d1 ^ _f(d2, _sk(sk, 6))    # k5
    d2 = d2 ^ _f(d1, _sk(sk, 5))    # k4
    d1 = d1 ^ _f(d2, _sk(sk, 4))    # k3
    d2 = d2 ^ _f(d1, _sk(sk, 3))    # k2
    d1 = d1 ^ _f(d2, _sk(sk, 2))    # k1

    val p1: u64 = d2 ^ _sk(sk, 0)   # ^ kw1
    val p2: u64 = d1 ^ _sk(sk, 1)   # ^ kw2

    var pt: [u8] = _new_buf(16)
    var _j4: u64 = 0
    while _j4 < 16:
        pt.push(0x00u8)
        _j4 = _j4 + 1
    _wr64(pt, 0, p1)
    _wr64(pt, 8, p2)
    pt

# ============================================================================
# Public API — Camellia-192
# RFC 3713 §2.2: 192-bit key → KL = key[0..15], KR = key[16..23] || ~key[16..23]
# Uses same 24-round structure as Camellia-256.
# ============================================================================

fn _expand192(key: [u8]) -> [u8]:
    """Expand a 24-byte key into a 32-byte key for _ks256."""
    var k32: [u8] = _new_buf(32)
    var _i5: u64 = 0
    while _i5 < 32:
        k32.push(0x00u8)
        _i5 = _i5 + 1
    # Copy first 24 bytes directly
    var _c: u64 = 0
    while _c < 24:
        k32[_c] = _u8_at(key, _c)
        _c = _c + 1
    # Last 8 bytes = NOT of key[16..23]
    var _n: u64 = 0
    while _n < 8:
        val b: u8 = _u8_at(key, 16 + _n)
        k32[24 + _n] = (b.to_u32() ^ 0xFFu32).to_u8()
        _n = _n + 1
    k32

fn camellia192_encrypt_block(key: [u8], block: [u8]) -> [u8]:
    """Encrypt one 16-byte block with a 24-byte Camellia-192 key (RFC 3713)."""
    camellia256_encrypt_block(_expand192(key), block)

fn camellia192_decrypt_block(key: [u8], block: [u8]) -> [u8]:
    """Decrypt one 16-byte block with a 24-byte Camellia-192 key (RFC 3713)."""
    camellia256_decrypt_block(_expand192(key), block)
