# ---------------------------------------------------------------------------
# τ (tau) permutation — GOST R 34.11-2012, §5.2.2
# 64 bytes → 64 bytes; maps position i to tau[i].
# tau[i] = 8*(i%8) + i/8  (column-major to row-major reorder of 8x8 matrix)
# ---------------------------------------------------------------------------

fn _tau(idx: i64) -> i64:
    (8 * (idx % 8)) + (idx / 8)

# ---------------------------------------------------------------------------
# A (linear/MDS transform) — GOST R 34.11-2012, §5.2.3
# Operates on a 64-byte state viewed as 8 rows of 8 bytes.
# Each row is treated as a vector in GF(2^8)^8 multiplied by an 8x8 MDS matrix.
# Reduction polynomial: x^8 + x^7 + x^6 + x + 1 = 0x1C3.
# MDS circulant first row: (148, 32, 133, 16, 194, 192, 1, 251).
# ---------------------------------------------------------------------------

fn _gf_mul_streebog(a_in: i64, b_in: i64) -> i64:
    var a = a_in & 0xFF
    var b = b_in & 0xFF
    var p = 0
    var i = 0
    while i < 8:
        if (b & 1) != 0:
            p = p ^ a
        var hi = (a & 0x80) != 0
        a = (a << 1) & 0xFF
        if hi:
            a = a ^ 0xC3
        b = (b >> 1) & 0xFF
        i = i + 1
    p & 0xFF

fn _mds_row_coeff(k: i64) -> i64:
    # MDS circulant first row from GOST R 34.11-2012 spec
    if k == 0: 148
    else if k == 1: 32
    else if k == 2: 133
    else if k == 3: 16
    else if k == 4: 194
    else if k == 5: 192
    else if k == 6: 1
    else: 251

# ---------------------------------------------------------------------------
# State is a flat list of 64 bytes (i64 values).
# ---------------------------------------------------------------------------

fn _make_zero_state() -> list:
    var s = []
    var i = 0
    while i < 64:
        s.push(0)
        i = i + 1
    s

fn _state_xor(a: list, b: list) -> list:
    var out = []
    var i = 0
    while i < 64:
        out.push((a.get(i) ^ b.get(i)) & 0xFF)
        i = i + 1
    out

# ---------------------------------------------------------------------------
# S — apply π S-box to every byte of state
# ---------------------------------------------------------------------------

fn _apply_s(state: list) -> list:
    var out = []
    var i = 0
    while i < 64:
        out.push(_pi_sbox(state.get(i) & 0xFF))
        i = i + 1
    out

# ---------------------------------------------------------------------------
# P — apply τ permutation to state bytes
# ---------------------------------------------------------------------------

fn _apply_p(state: list) -> list:
    var out = _make_zero_state()
    var i = 0
    while i < 64:
        out[_tau(i)] = state.get(i)
        i = i + 1
    out

# ---------------------------------------------------------------------------
# L — apply MDS linear transform, row by row (8 rows x 8 bytes)
# Each output byte j of row r = XOR_{k=0}^{7} gmul(MDS_row[(j-k+8)%8], in[r*8+k])
# ---------------------------------------------------------------------------

fn _apply_l(state: list) -> list:
    var out = _make_zero_state()
    var row = 0
    while row < 8:
        var col = 0
        while col < 8:
            var acc = 0
            var k = 0
            while k < 8:
                var c_idx = ((col - k) + 64) % 8
                var coeff = _mds_row_coeff(c_idx)
                var cell = state.get(row * 8 + k) & 0xFF
                acc = acc ^ _gf_mul_streebog(coeff, cell)
                k = k + 1
            out[row * 8 + col] = acc & 0xFF
            col = col + 1
        row = row + 1
    out

# ---------------------------------------------------------------------------
# LPS = L(P(S(state))) — the combined round transform
# ---------------------------------------------------------------------------

fn _lps(state: list) -> list:
    var s1 = _apply_s(state)
    var s2 = _apply_p(s1)
    _apply_l(s2)

# ---------------------------------------------------------------------------
# Round keys C[i] = LPS^i(e_1) where e_1 is the first unit vector.
# In practice we compute C[i] = LPS applied i times to a state
# that has 1 in position 0 of row i*8 for round i.
# Per spec §5.2.4: C[i] = LPS(C[i-1]) with C[0] being all-zeros except
# byte 63-i*8 set to 1 per the standard's definition.
# Simplified: derive round keys from iteration counter directly.
# The spec defines C[0] has only bit 0 set at byte position 0,
# C[i] = LPS(C[i-1]).
# ---------------------------------------------------------------------------

fn _compute_round_key(round: i64) -> list:
    # Build C[0]: 64-byte state with bytes corresponding to position
    # (63 - round*8) through (56 - round*8) set to specific values per spec.
    # Per RFC 6986 §A, round constants are LPS iterated:
    # C[i] is the LPS transform applied i times to a state where
    # only byte i*8 is 1 and rest are 0. That matches:
    # "The round constants C[i] are computed as iter_i(LPS, e_1)"
    # where e_1[0]=1, e_1[j]=0 for j>0.
    var base = _make_zero_state()
    base[round * 8] = 1
    _lps(base)

# Pre-compute all 12 round constants using an iterated approach.
# Returns flat list of 12*64 = 768 bytes.
fn _all_round_keys() -> list:
    var keys = []
    # Start with base state for round 0
    var prev = _make_zero_state()
    prev[0] = 1
    var round = 0
    while round < 12:
        var cur = _lps(prev)
        var i = 0
        while i < 64:
            keys.push(cur.get(i))
            i = i + 1
        prev = cur
        round = round + 1
    keys

fn _get_round_key(keys: list, round: i64) -> list:
    var k = []
    var i = 0
    while i < 64:
        k.push(keys.get(round * 64 + i))
        i = i + 1
    k

# ---------------------------------------------------------------------------
# E — encryption (key schedule + 12 rounds) — used inside g_N
# E_K(m) where K is the key (h XOR N) and m is the message block.
# ---------------------------------------------------------------------------

fn _streebog_encrypt(key: list, msg: list) -> list:
    var rkeys = _all_round_keys()
    # Initial whitening: state = msg XOR key
    var state = _state_xor(msg, key)
    var round = 0
    while round < 12:
        # Apply LPS
        state = _lps(state)
        # XOR with round key
        var rk = _get_round_key(rkeys, round)
        state = _state_xor(state, rk)
        # XOR with key XOR-shifted (key schedule: K_i = LPS(K_{i-1}) XOR C[i])
        # Note: in Streebog the key schedule is iterated separately
        round = round + 1
    state

# ---------------------------------------------------------------------------
# g_N — compression function
# g_N(h, m) = E_{h XOR N}(m) XOR h XOR m
# h, m, N are all 64-byte states.
# ---------------------------------------------------------------------------

fn _g_N(h: list, m: list, N: list) -> list:
    # key = h XOR N
    var key = _state_xor(h, N)
    # encrypt m under key using 12-round E
    var rkeys = _all_round_keys()
    # Key schedule: K[0] = key, K[i+1] = LPS(K[i]) XOR C[i]
    var K = key
    var state = _state_xor(m, K)
    var i = 0
    while i < 12:
        state = _lps(state)
        K = _lps(K)
        var rk = _get_round_key(rkeys, i)
        K = _state_xor(K, rk)
        state = _state_xor(state, K)
        i = i + 1
    # Result = E XOR h XOR m
    var tmp = _state_xor(state, h)
    _state_xor(tmp, m)

# ---------------------------------------------------------------------------
# 512-bit modular addition (mod 2^512) for the N accumulator.
# Both operands are 64-byte little-endian states.
# ---------------------------------------------------------------------------

fn _add512(a: list, b: list) -> list:
    var out = _make_zero_state()
    var carry = 0
    var i = 0
    while i < 64:
        var sum = (a.get(i) & 0xFF) + (b.get(i) & 0xFF) + carry
        out[i] = sum & 0xFF
        carry = (sum >> 8) & 0xFF
        i = i + 1
    out

# ---------------------------------------------------------------------------
# Build a 512-bit integer from a single i64 value (little-endian).
# Used to represent the 512-bit message-length counter.
# ---------------------------------------------------------------------------

fn _u64_to_state(v: i64) -> list:
    var s = _make_zero_state()
    s[0] = v & 0xFF
    s[1] = (v >> 8) & 0xFF
    s[2] = (v >> 16) & 0xFF
    s[3] = (v >> 24) & 0xFF
    s[4] = (v >> 32) & 0xFF
    s[5] = (v >> 40) & 0xFF
    s[6] = (v >> 48) & 0xFF
    s[7] = (v >> 56) & 0xFF
    s

# ---------------------------------------------------------------------------
# Copy a 64-byte block from a [u8] buffer at given offset into a state list.
# ---------------------------------------------------------------------------

fn _block_to_state(data: [u8], offset: u64) -> list:
    var s = []
    var i: u64 = 0
    while i < 64:
        s.push(_sb_u8_at(data, offset + i).to_i64())
        i = i + 1
    s

fn _state_to_bytes(state: list) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 64:
        out.push((state.get(i) & 0xFF).to_u8())
        i = i + 1
    out

# ---------------------------------------------------------------------------
# Padding: append 0x01, then zeros to reach 64-byte boundary.
# ---------------------------------------------------------------------------

fn _pad_message(data: [u8]) -> [u8]:
    var data_len = data.len().to_u64()
    var padded: [u8] = []
    var i: u64 = 0
    while i < data_len:
        padded.push(_sb_u8_at(data, i))
        i = i + 1
    # Append 0x01
    padded.push(0x01u8)
    # Zero-pad to next 64-byte boundary
    var cur_len = padded.len().to_u64()
    while (cur_len % 64) != 0:
        padded.push(0x00u8)
        cur_len = cur_len + 1
    padded

# ---------------------------------------------------------------------------
# Core Streebog hash (parametrized by IV and output length)
# ---------------------------------------------------------------------------

fn _streebog_hash(data: [u8], iv: list, out_len: u64) -> [u8]:
    var padded = _pad_message(data)
    var num_blocks = padded.len().to_u64() / 64

    var h = iv
    var N = _make_zero_state()    # bit counter (little-endian 512-bit)
    var sigma = _make_zero_state() # checksum (mod 2^512)

    # Process all blocks except the last one (which is the padded tail)
    # The last block of padded data may be a padding-only block; all get processed.
    # We process from the LAST block toward the first per the Streebog spec.
    # Actually: process blocks in order but feed data blocks through g_N(h, m_i, N_i)
    # then update N = N + 512, sigma = sigma + m_i.
    # Final: h = g_0(g_N(h, len_block, N), sigma)
    # Per RFC 6986 §2.3: process last block first (from the end).

    # We reverse: walk from end toward start for data blocks.
    # But actually per the Streebog spec, blocks are processed RIGHT-TO-LEFT
    # (the last padded 64-byte block first), updating h each time.
    # N starts at 0, incremented by 512 per block.

    # Process blocks right-to-left
    var block_idx = num_blocks
    while block_idx > 0:
        block_idx = block_idx - 1
        var offset = block_idx * 64
        var m = _block_to_state(padded, offset)
        h = _g_N(h, m, N)
        N = _add512(N, _u64_to_state(512))
        sigma = _add512(sigma, m)

    # Finalization: g_N(h, N, 0) then g_N(h, sigma, 0)
    var zero_n = _make_zero_state()
    h = _g_N(h, N, zero_n)
    h = _g_N(h, sigma, zero_n)

    # Extract output: first out_len bytes
    var result: [u8] = []
    var j: u64 = 0
    while j < out_len:
        result.push((h.get(j.to_i64()) & 0xFF).to_u8())
        j = j + 1
    result

# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

fn streebog_512(data: [u8]) -> [u8]:
    """Compute Streebog-512 (GOST R 34.11-2012) hash. Returns 64-byte digest."""
    var iv = _make_zero_state()
    _streebog_hash(data, iv, 64)

fn streebog_256(data: [u8]) -> [u8]:
    """Compute Streebog-256 (GOST R 34.11-2012) hash. Returns 32-byte digest."""
    # IV for -256: all bytes = 0x01
    var iv = []
    var i = 0
    while i < 64:
        iv.push(0x01)
        i = i + 1
    _streebog_hash(data, iv, 32)
