fn _streebog_l_word(word: list) -> list:
    val rows = _streebog_a_rows()
    var out = [0, 0, 0, 0, 0, 0, 0, 0]
    var bit_idx = 0
    while bit_idx < 64:
        val byte_idx = bit_idx / 8
        val bit_in_byte = 7 - (bit_idx % 8)
        if (((word.get(byte_idx) & 0xFF) >> bit_in_byte) & 1) != 0:
