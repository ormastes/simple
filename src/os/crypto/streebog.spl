# ---------------------------------------------------------------------------
# τ (tau) permutation — GOST R 34.11-2012, §5.2.2
# 64 bytes → 64 bytes; maps position i to tau[i].
# tau[i] = 8*(i%8) + i/8  (column-major to row-major reorder of 8x8 matrix)
# ---------------------------------------------------------------------------

fn _tau(idx: i64) -> i64:
    (8 * (idx % 8)) + (idx / 8)

# ---------------------------------------------------------------------------
# A (linear/MDS transform) — GOST R 34.11-2012, §5.2.3
# Operates on a 64-byte state viewed as 8 rows of 8 bytes.
# Each row is multiplied by the 8x8 MDS matrix M over GF(2^8).
# Reduction polynomial: x^8 + x^4 + x^3 + x^2 + 1 = 0x11D.
# MDS matrix M[in_col][out_row] extracted from gostcrypto T-table.
# ---------------------------------------------------------------------------

fn _gf_mul_streebog(a_in: i64, b_in: i64) -> i64:
    # GF(2^8) multiply with reducing polynomial x^8+x^4+x^3+x^2+1 = 0x11D.
    # The low 8 bits of 0x11D are 0x1D, XOR-ed in when the high bit overflows.
    var a = a_in & 0xFF
    var b = b_in & 0xFF
    var p = 0
    var i = 0
    while i < 8:
        if (b & 1) != 0:
            p = p ^ a
        var hi = (a & 0x80) != 0
        a = (a << 1) & 0xFF
        if hi:
            a = a ^ 0x1D
        b = (b >> 1) & 0xFF
        i = i + 1
    p & 0xFF

fn _mds_coeff(in_col: i64, out_row: i64) -> i64:
    # MDS matrix M[in_col][out_row] — full 8x8 matrix over GF(2^8).
    # Extracted from gostcrypto T-table: T[in_col][pi^{-1}[1]].bytes[out_row].
    # Row 0 of in_col 0: 83 e0 8e 2b 4b 31 1c 64
    if in_col == 0:
        if out_row == 0: 0x83  else if out_row == 1: 0xE0  else if out_row == 2: 0x8E
        else if out_row == 3: 0x2B  else if out_row == 4: 0x4B  else if out_row == 5: 0x31
        else if out_row == 6: 0x1C  else: 0x64
    else if in_col == 1:
        if out_row == 0: 0x18  else if out_row == 1: 0xDC  else if out_row == 2: 0xF5
        else if out_row == 3: 0x9E  else if out_row == 4: 0x4F  else if out_row == 5: 0x47
        else if out_row == 6: 0x8B  else: 0xA4
    else if in_col == 2:
        if out_row == 0: 0x28  else if out_row == 1: 0x77  else if out_row == 2: 0x32
        else if out_row == 3: 0x8A  else if out_row == 4: 0xD9  else if out_row == 5: 0x86
        else if out_row == 6: 0x7D  else: 0xF9
    else if in_col == 3:
        if out_row == 0: 0x9E  else if out_row == 1: 0xA8  else if out_row == 2: 0x10
        else if out_row == 3: 0x18  else if out_row == 4: 0x65  else if out_row == 5: 0x8C
        else if out_row == 6: 0x06  else: 0x5B
    else if in_col == 4:
        if out_row == 0: 0x38  else if out_row == 1: 0xC1  else if out_row == 2: 0x93
        else if out_row == 3: 0xBA  else if out_row == 4: 0x8C  else if out_row == 5: 0x65
        else if out_row == 6: 0x21  else: 0x03
    else if in_col == 5:
        if out_row == 0: 0x50  else if out_row == 1: 0x89  else if out_row == 2: 0x8A
        else if out_row == 3: 0x32  else if out_row == 4: 0xA9  else if out_row == 5: 0x9C
        else if out_row == 6: 0xCC  else: 0xAC
    else if in_col == 6:
        if out_row == 0: 0x8E  else if out_row == 1: 0x98  else if out_row == 2: 0x83
        else if out_row == 3: 0x1A  else if out_row == 4: 0x01  else if out_row == 5: 0x0F
        else if out_row == 6: 0xB6  else: 0x46
    else:
        if out_row == 0: 0x64  else if out_row == 1: 0x87  else if out_row == 2: 0x46
        else if out_row == 3: 0xB2  else if out_row == 4: 0x07  else if out_row == 5: 0x8B
        else if out_row == 6: 0x47  else: 0x83

# ---------------------------------------------------------------------------
# State is a flat list of 64 bytes (i64 values).
# ---------------------------------------------------------------------------

fn _make_zero_state() -> list:
    var s = []
    var i = 0
    while i < 64:
        s.push(0)
        i = i + 1
    s

fn _state_xor(a: list, b: list) -> list:
    var out = []
    var i = 0
    while i < 64:
        out.push((a.get(i) ^ b.get(i)) & 0xFF)
        i = i + 1
    out

# ---------------------------------------------------------------------------
# S — apply π S-box to every byte of state
# ---------------------------------------------------------------------------

fn _apply_s(state: list) -> list:
    var out = []
    var i = 0
    while i < 64:
        out.push(_pi_sbox(state.get(i) & 0xFF))
        i = i + 1
    out

# ---------------------------------------------------------------------------
# P — apply τ permutation to state bytes
# ---------------------------------------------------------------------------

fn _apply_p(state: list) -> list:
    var out = []
    var i = 0
    while i < 64:
        out.push(state.get(63 - _tau(63 - i)))
        i = i + 1
    out

# ---------------------------------------------------------------------------
# L — apply MDS linear transform, row by row (8 rows x 8 bytes)
# Each output byte out_row of row r:
#   result[r*8 + out_row] = XOR_{in_col=0}^{7} MDS[in_col][out_row] * state[r*8 + in_col]
# ---------------------------------------------------------------------------

