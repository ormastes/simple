    out

fn _apply_l(state: list) -> list:
    var out = _make_zero_state()
    var word_idx = 0
    while word_idx < 8:
        var word = []
        var i = 0
        while i < 8:
            word.push(state.get(word_idx * 8 + i) & 0xFF)
            i = i + 1
        val transformed = _streebog_l_word(word)
        i = 0
        while i < 8:
            out[word_idx * 8 + i] = transformed.get(i) & 0xFF
            i = i + 1
        word_idx = word_idx + 1
    out

# ---------------------------------------------------------------------------
# LPS = L(P(S(state))) — the combined round transform
# ---------------------------------------------------------------------------

fn _lps(state: list) -> list:
    var s1 = _apply_s(state)
    var s2 = _apply_p(s1)
    _apply_l(s2)

