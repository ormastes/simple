        else if idx == 48: 0x94  else if idx == 49: 0xFE  else if idx == 50: 0x5A  else if idx == 51: 0x63
        else if idx == 52: 0xCD  else if idx == 53: 0xC6  else if idx == 54: 0x02  else if idx == 55: 0x30
        else if idx == 56: 0xFB  else if idx == 57: 0x89  else if idx == 58: 0xC8  else if idx == 59: 0xEF
        else if idx == 60: 0xD0  else if idx == 61: 0x9E  else if idx == 62: 0xCD  else: 0x7B
    # C[11]:
    else:
        if idx == 0: 0x20  else if idx == 1: 0xD7  else if idx == 2: 0x1B  else if idx == 3: 0xF1
        else if idx == 4: 0x4A  else if idx == 5: 0x92  else if idx == 6: 0xBC  else if idx == 7: 0x48
        else if idx == 8: 0x99  else if idx == 9: 0x1B  else if idx == 10: 0xB2  else if idx == 11: 0xD9
        else if idx == 12: 0xD5  else if idx == 13: 0x17  else if idx == 14: 0xF4  else if idx == 15: 0xFA
        else if idx == 16: 0x52  else if idx == 17: 0x28  else if idx == 18: 0xE1  else if idx == 19: 0x88
        else if idx == 20: 0xAA  else if idx == 21: 0xA4  else if idx == 22: 0x1D  else if idx == 23: 0xE7
        else if idx == 24: 0x86  else if idx == 25: 0xCC  else if idx == 26: 0x91  else if idx == 27: 0x18
        else if idx == 28: 0x9D  else if idx == 29: 0xEF  else if idx == 30: 0x80  else if idx == 31: 0x5D
        else if idx == 32: 0x9B  else if idx == 33: 0x9F  else if idx == 34: 0x21  else if idx == 35: 0x30
        else if idx == 36: 0xD4  else if idx == 37: 0x12  else if idx == 38: 0x20  else if idx == 39: 0xF8
        else if idx == 40: 0x77  else if idx == 41: 0x1D  else if idx == 42: 0xDF  else if idx == 43: 0xBC
        else if idx == 44: 0x32  else if idx == 45: 0x3C  else if idx == 46: 0xA4  else if idx == 47: 0xCD
        else if idx == 48: 0x7A  else if idx == 49: 0xB1  else if idx == 50: 0x49  else if idx == 51: 0x04
        else if idx == 52: 0xB0  else if idx == 53: 0x80  else if idx == 54: 0x13  else if idx == 55: 0xD2
        else if idx == 56: 0xBA  else if idx == 57: 0x31  else if idx == 58: 0x16  else if idx == 59: 0xF1
        else if idx == 60: 0x67  else if idx == 61: 0xE7  else if idx == 62: 0x8E  else: 0x37

fn _get_round_constant(round: i64) -> list:
    var k = []
    var i = 0
    while i < 64:
        k.push(_round_key_byte(round, i))
        i = i + 1
    k

# ---------------------------------------------------------------------------
# E — encryption (key schedule + 12 rounds) — used inside g_N.
# Matches gostcrypto _hash_e / _hash_get_key:
#   state = k XOR m
#   for i in 0..11:
#     state = LPS(state)
#     k = LPS(k XOR C[i])
#     state = state XOR k
# ---------------------------------------------------------------------------

fn _streebog_encrypt(key: list, msg: list) -> list:
    var k = key
    var state = _state_xor(k, msg)
    var round = 0
    while round < 12:
        state = _lps(state)
        var ci = _get_round_constant(round)
        k = _lps(_state_xor(k, ci))
        state = _state_xor(state, k)
        round = round + 1
    state

# ---------------------------------------------------------------------------
# g_N — compression function
# g_N(h, m, N) = E_{LPS(h XOR N)}(m) XOR h XOR m
# h, m, N are all 64-byte states.
# Matches gostcrypto _hash_g:
#   k = LPS(h XOR N)
#   result = E(k, m) XOR h XOR m
# ---------------------------------------------------------------------------

fn _g_N(h: list, m: list, N: list) -> list:
    # Initial key = LPS(h XOR N)
    var key = _lps(_state_xor(h, N))
    var enc = _streebog_encrypt(key, m)
    var tmp = _state_xor(enc, h)
    _state_xor(tmp, m)

# ---------------------------------------------------------------------------
# 512-bit modular addition (mod 2^512) for the N accumulator.
# Both operands are 64-byte big-endian states.
# ---------------------------------------------------------------------------

fn _add512(a: list, b: list) -> list:
    var out = _make_zero_state()
    var carry = 0
    var i = 63
    while i >= 0:
        var sum = (a.get(i) & 0xFF) + (b.get(i) & 0xFF) + carry
        out[i] = sum & 0xFF
        carry = (sum >> 8) & 0xFF
        i = i - 1
    out

# ---------------------------------------------------------------------------
# Build a 512-bit integer from a single i64 value (big-endian).
# Used to represent the 512-bit message-length counter.
# ---------------------------------------------------------------------------

fn _u64_to_state(v: i64) -> list:
    var s = _make_zero_state()
    s[56] = (v >> 56) & 0xFF
    s[57] = (v >> 48) & 0xFF
    s[58] = (v >> 40) & 0xFF
    s[59] = (v >> 32) & 0xFF
    s[60] = (v >> 24) & 0xFF
    s[61] = (v >> 16) & 0xFF
    s[62] = (v >> 8) & 0xFF
    s[63] = v & 0xFF
    s

# ---------------------------------------------------------------------------
# Copy a 64-byte block from a [u8] buffer at given offset into a state list.
# ---------------------------------------------------------------------------

fn _block_to_state(data: [u8], offset: u64) -> list:
    var s = []
    var i: u64 = 0
    while i < 64:
        s.push(_sb_u8_at(data, offset + i).to_i64())
        i = i + 1
    s

fn _state_to_bytes(state: list) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 64:
        out.push((state.get(i) & 0xFF).to_u8())
        i = i + 1
    out

# ---------------------------------------------------------------------------
# Build the final padded block 0^(511-|M|) || 1 || M for the remaining prefix.
# ---------------------------------------------------------------------------

fn _final_padded_block(data: [u8], prefix_len: u64) -> list:
    var block = _make_zero_state()
    val marker_idx = 63 - prefix_len.to_i64()
    block[marker_idx] = 0x01
    var i: u64 = 0
    while i < prefix_len:
        block[marker_idx + 1 + i.to_i64()] = _sb_u8_at(data, prefix_len - 1 - i).to_i64()
        i = i + 1
    block

# ---------------------------------------------------------------------------
# Core Streebog hash (parametrized by IV and output length)
# ---------------------------------------------------------------------------

fn _streebog_hash(data: [u8], iv: list, out_len: u64) -> [u8]:
    var h = iv
    var N = _make_zero_state()
    var sigma = _make_zero_state()

    # RFC 6986 consumes complete 512-bit blocks from the message tail.
    var remaining = data.len().to_u64()
    while remaining >= 64:
        val offset = remaining - 64
        val m = _block_to_state(data, offset)
        h = _g_N(h, m, N)
        N = _add512(N, _u64_to_state(512))
        sigma = _add512(sigma, m)
        remaining = offset

    val final_block = _final_padded_block(data, remaining)
    h = _g_N(h, final_block, N)
    N = _add512(N, _u64_to_state((remaining * 8).to_i64()))
    sigma = _add512(sigma, final_block)

    var zero_n = _make_zero_state()
    h = _g_N(h, N, zero_n)
    h = _g_N(h, sigma, zero_n)

    # Extract output: first out_len bytes
    var result: [u8] = []
    var j: u64 = 0
    while j < out_len:
        result.push((h.get(63 - j.to_i64()) & 0xFF).to_u8())
        j = j + 1
    result

# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

fn streebog_512(data: [u8]) -> [u8]:
    """Compute Streebog-512 (GOST R 34.11-2012) hash. Returns 64-byte digest."""
    var iv = _make_zero_state()
    _streebog_hash(data, iv, 64)

fn streebog_256(data: [u8]) -> [u8]:
    """Compute Streebog-256 (GOST R 34.11-2012) hash. Returns 32-byte digest."""
    # IV for -256: all bytes = 0x01
    var iv = []
    var i = 0
    while i < 64:
        iv.push(0x01)
        i = i + 1
    val full = _streebog_hash(data, iv, 64)
    var out: [u8] = []
    var j: u64 = 32
    while j < 64:
        out.push(full[j])
        j = j + 1
    out
