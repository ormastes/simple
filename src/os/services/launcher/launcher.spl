# Launcher Service — app registry, shortcut dispatch, and app spawning
#
# MDSOC: feature dimension, desktop layer
#
# User-space IPC service that maintains an app registry (name -> binary
# path, icon, keyboard shortcut), launches apps on demand via posix_spawn,
# dispatches keyboard shortcuts, and notifies the window manager when an
# app starts.
#
# IPC service on port "launcher"
# Methods:
#   1: REGISTER — register an app (name, path, icon, shortcut)
#   2: LAUNCH   — launch a registered app by name
#   3: LIST     — list all registered apps
#   4: SHORTCUT — dispatch a keyboard shortcut
#
# Syscalls used:
#   22 (IpcCreatePort) — create service IPC port
#   21 (IpcRecv)       — receive IPC messages
#   23 (IpcSend)       — send IPC reply

use os.services.launcher.launcher_registry.{
    LAUNCHER_REGISTER, LAUNCHER_LAUNCH, LAUNCHER_LIST, LAUNCHER_SHORTCUT,
    SYS_IPC_SEND, SYS_IPC_RECV, SYS_IPC_CREATE_PORT, SYS_IPC_CONNECT, SIGTERM,
    MAX_APPS, MAX_PROCESSES, APP_PRIORITY,
    MOD_META, MOD_CTRL, MOD_ALT, MOD_SHIFT,
    app_name, app_path, app_icon, app_shortcut_key, app_shortcut_mod,
    app_pid, app_launch_state, app_window_count, app_exit_code,
    app_launch_count, app_last_pid, app_is_headless, app_active, app_count,
    process_pid, process_app_index, process_app_id, process_name, process_path,
    process_icon, process_state, process_exit_code, process_window_count,
    process_is_headless, process_launch_seq, process_signal_backed,
    process_active, process_count,
    process_sequence, launcher_last_launch_pid,
    launcher_command_resolution_candidates, launcher_associated_app_for_path,
    launcher_resolve_command_path, launcher_launch_path_with_args,
    launcher_open_path, launcher_record_process, launcher_process_is_process_backed,
    launcher_process_can_signal,
    _preferred_app_exec_path, _canonical_app_identity, _app_name, _app_path,
    _app_icon, _app_key, _app_mod, _app_index_by_name, _app_index_by_path,
    _seeded_app_index_by_path, _seeded_app_name_for_path, _seeded_app_icon_for_path,
    _seeded_app_key_for_path, _ensure_seeded_app_slot, _is_running_state,
    _default_app_identity, _classify_final_state, _sync_app_slot,
    _update_process_state, _update_process_window_count, _clear_app_slot_by_pid,
    _remove_app_slot, _finalize_launch, _is_synthetic_pid, _is_process_backed_record,
    _process_index_by_pid, _app_index_by_pid, _looks_like_executable_path
}
use os.userlib.syscall_raw.{syscall}
use os.posix.process_compat.{posix_spawn_with_args, posix_kill}
use os.userlib.process.{spawn, get_task_info}

fn log_raw_println(msg: text):
    # The generic kernel log facade lowers through `print`, which is not safe
    # in the freestanding desktop lane. Launcher state is verified through
    # explicit harness serial markers instead.
    pass_dn

fn _launcher_seed_default_app(name: text, path: text, icon: text, key: u32, modifiers: u32):
    if app_count >= MAX_APPS:
        return
    val slot = app_count
    app_name[slot] = name
    app_path[slot] = path
    app_icon[slot] = icon
    app_shortcut_key[slot] = key
    app_shortcut_mod[slot] = modifiers
    app_pid[slot] = 0
    app_launch_state[slot] = "idle"
    app_window_count[slot] = 0
    app_exit_code[slot] = 0
    app_launch_count[slot] = 0
    app_last_pid[slot] = 0
    app_is_headless[slot] = false
    app_active[slot] = true
    app_count = app_count + 1

# ============================================================================
# Initialization
# ============================================================================

fn launcher_init():
    """Initialize launcher and register default apps."""
    log_raw_println("[launcher] Initializing app launcher...")

    # Clear all slots
    var i: u64 = 0
    while i < MAX_APPS:
        app_name[i] = ""
        app_path[i] = ""
        app_icon[i] = ""
        app_shortcut_key[i] = 0
        app_shortcut_mod[i] = 0
        app_pid[i] = 0
        app_launch_state[i] = "idle"
        app_window_count[i] = 0
        app_exit_code[i] = 0
        app_launch_count[i] = 0
        app_last_pid[i] = 0
        app_is_headless[i] = false
        app_active[i] = false
        i = i + 1
    app_count = 0

    var p: u64 = 0
    while p < MAX_PROCESSES:
        process_pid[p] = 0
        process_app_index[p] = -1
        process_app_id[p] = ""
        process_name[p] = ""
        process_path[p] = ""
        process_icon[p] = ""
        process_state[p] = ""
        process_exit_code[p] = 0
        process_window_count[p] = 0
        process_is_headless[p] = false
        process_launch_seq[p] = 0
        process_signal_backed[p] = false
        process_active[p] = false
        p = p + 1
    process_count = 0
    process_sequence = 1
    launcher_last_launch_pid = 0

    _launcher_seed_default_app("Hello World", "/sys/apps/hello_world.smf", "H", 0x48, MOD_META)
    _launcher_seed_default_app("Calculator", "/sys/apps/calculator.smf", "=", 0x41, MOD_META | MOD_SHIFT)
    _launcher_seed_default_app("Clock", "/sys/apps/clock.smf", "T", 0x59, MOD_META | MOD_SHIFT)
    _launcher_seed_default_app("File Manager", "/sys/apps/file_manager.smf", "F", 0x46, MOD_META)
    _launcher_seed_default_app("Terminal", "/sys/apps/shell.smf", ">", 0x54, MOD_META)
    _launcher_seed_default_app("Browser Demo", "/sys/apps/browser_demo.smf", "B", 0x42, MOD_META)
    _launcher_seed_default_app("Editor", "/sys/apps/editor.smf", "E", 0x45, MOD_META)
    _launcher_seed_default_app("Simple Browser", "/sys/apps/simple_browser.smf", "W", 0x57, MOD_META)
    _launcher_seed_default_app("Simple Compiler", "/sys/apps/simple_compiler.smf", "C", 0x43, MOD_META)
    _launcher_seed_default_app("Simple Interpreter", "/sys/apps/simple_interpreter.smf", "I", 0x49, MOD_META)
    _launcher_seed_default_app("Simple Loader", "/sys/apps/simple_loader.smf", "O", 0x4F, MOD_META)
    _launcher_seed_default_app("LLVM", "/sys/apps/llvm.smf", "L", 0x4C, MOD_META)
    _launcher_seed_default_app("Clang", "/sys/apps/clang.smf", "K", 0x47, MOD_META)
    _launcher_seed_default_app("Rust", "/sys/apps/rust.smf", "R", 0x52, MOD_META)

    log_raw_println("[launcher] Registered {app_count} default apps")

# ============================================================================
# Register / Unregister
# ============================================================================

fn launcher_register(name: text, path: text, icon: text, key: u32, modifiers: u32) -> bool:
    """Register an app in the launcher.

    Args:
      name:      human-readable app name (e.g. "Hello World")
      path:      path to the ELF binary (e.g. "/apps/hello_world")
      icon:      single-character icon for dock display
      key:       keyboard key code (USB HID / ASCII)
      modifiers: modifier flags (MOD_META, MOD_CTRL, MOD_ALT, MOD_SHIFT)

    Returns true on success, false if registry is full.
    """
    val existing = _app_index_by_name(name)
    if existing >= 0:
        val slot = existing.to_u64()
        app_name[slot] = name
        app_path[slot] = path
        app_icon[slot] = icon
        app_shortcut_key[slot] = key
        app_shortcut_mod[slot] = modifiers
        app_active[slot] = true
        log_raw_println("[launcher] Updated: {name} ({path})")
        return true

    if app_count >= MAX_APPS:
        log_raw_println("[launcher] Registry full ({MAX_APPS} slots)")
        return false

    val slot = app_count
    app_name[slot] = name
    app_path[slot] = path
    app_icon[slot] = icon
    app_shortcut_key[slot] = key
    app_shortcut_mod[slot] = modifiers
    app_pid[slot] = 0
    app_launch_state[slot] = "idle"
    app_window_count[slot] = 0
    app_exit_code[slot] = 0
    app_launch_count[slot] = 0
    app_last_pid[slot] = 0
    app_is_headless[slot] = false
    app_active[slot] = true
    app_count = app_count + 1
    log_raw_println("[launcher] Registered: {name} ({path})")
    true

fn launcher_unregister(name: text) -> bool:
    """Unregister an app by name. Returns true if found and removed."""
    val idx = _app_index_by_name(name)
    if idx < 0:
        return false

    val slot = idx.to_u64()
    if app_pid[slot] > 0:
        log_raw_println("[launcher] Unregistering running app: {name} (PID {app_pid[slot]})")
    _remove_app_slot(slot)
    log_raw_println("[launcher] Unregistered: {name}")
    true

# ============================================================================
# Launch
# ============================================================================

fn launcher_launch(name: text) -> i64:
    """Launch an app by name.

    Spawns the app binary via posix_spawn at normal priority.
    Returns PID on success (>= 0), -1 if not found, or negative errno
    on spawn failure.
    """
    val idx = _app_index_by_name(name)
    if idx < 0:
        log_raw_println("[launcher] App not found: {name}")
        return -1

    launcher_launch_by_index(idx.to_u64())

fn launcher_launch_by_index(idx: u64) -> i64:
    """Launch an app by registry index. Returns PID or -1."""
    if idx >= app_count:
        return -1
    val name = _app_name(idx)
    val path = _app_path(idx)
    log_raw_println("[launcher] Launching: {name}")
    launcher_launch_path_with_args(path, [])

fn _launch_seeded_app(path: text) -> i64:
    """Launch one of the seeded desktop apps using canonical metadata.

    On the x86_64 baremetal Cranelift desktop lane, `app_count` currently
    survives across module boundaries while parts of the seeded array-backed
    registry can read back as zeroed inside the shortcut dispatch path. When
    that happens, re-seed the canonical slot metadata locally before spawning
    so Meta+{H,F,T,B,E} still drives the real launcher flow.
    """
    val seeded_index = _seeded_app_index_by_path(path)
    if seeded_index < 0:
        return -1
    val slot = seeded_index.to_u64()
    if slot >= MAX_APPS:
        return -1

    _ensure_seeded_app_slot(slot, path)
    launcher_launch_path_with_args(path, [])

fn _dispatch_seeded_shortcut(key: u32, modifiers: u32) -> bool:
    """Fallback for the canonical desktop shortcuts on baremetal.

    Returns true when the key/modifier pair matches one of the seeded
    canonical seeded apps — the shortcut WAS recognized and the seed
    slot metadata was re-populated. The spawn itself may still fail
    under the baremetal Cranelift lane (no posix_spawn, no NVMe /
    FAT32 manifest); the caller is expected to materialize a resident
    launch in that case. Reporting "dispatched=true" here mirrors the
    main-loop path which also returns true regardless of spawn errno,
    so Meta+H / Meta+F / Meta+T / Meta+B / Meta+E all drive the shell
    materialize path when `app_count` reads back as 0 in the dispatch
    scope (cross-module sized-array global staleness, see
    doc/08_tracking/todo/shortcut_fail_downstream_2026-04-14.md).
    """
    if modifiers != MOD_META:
        return false
    if key == _seeded_app_key_for_path("/sys/apps/hello_world"):
        _launch_seeded_app("/sys/apps/hello_world")
        return true
    if key == _seeded_app_key_for_path("/sys/apps/file_manager"):
        _launch_seeded_app("/sys/apps/file_manager")
        return true
    if key == _seeded_app_key_for_path("/sys/apps/shell"):
        _launch_seeded_app("/sys/apps/shell")
        return true
    if key == _seeded_app_key_for_path("/sys/apps/browser_demo"):
        _launch_seeded_app("/sys/apps/browser_demo")
        return true
    if key == _seeded_app_key_for_path("/sys/apps/editor"):
        _launch_seeded_app("/sys/apps/editor")
        return true
    if key == _seeded_app_key_for_path("/sys/apps/simple_browser"):
        _launch_seeded_app("/sys/apps/simple_browser")
        return true
    if key == _seeded_app_key_for_path("/sys/apps/simple_compiler"):
        _launch_seeded_app("/sys/apps/simple_compiler")
        return true
    if key == _seeded_app_key_for_path("/sys/apps/simple_interpreter"):
        _launch_seeded_app("/sys/apps/simple_interpreter")
        return true
    if key == _seeded_app_key_for_path("/sys/apps/simple_loader"):
        _launch_seeded_app("/sys/apps/simple_loader")
        return true
    if key == _seeded_app_key_for_path("/sys/apps/llvm"):
        _launch_seeded_app("/sys/apps/llvm")
        return true
    if key == _seeded_app_key_for_path("/sys/apps/clang"):
        _launch_seeded_app("/sys/apps/clang")
        return true
    if key == _seeded_app_key_for_path("/sys/apps/rust"):
        _launch_seeded_app("/sys/apps/rust")
        return true
    false

# ============================================================================
# Shortcut Dispatch
# ============================================================================

fn launcher_shortcut_dispatch(key: u32, modifiers: u32) -> bool:
    """Check if a keyboard event matches any app shortcut. Launch if found.

    Called by the input handler when a key event has modifier keys held.
    Returns true if a matching shortcut was found and launch was attempted.
    """
    val seeded = _dispatch_seeded_shortcut(key, modifiers)
    if seeded:
        log_raw_println("[launcher] shortcut fallback key={key} mod={modifiers}")
        return true

    var i: u64 = 0
    while i < app_count:
        if _app_key(i) == key and _app_mod(i) == modifiers:
            log_raw_println("[launcher] shortcut match slot={i} name={_app_name(i)} path={_app_path(i)}")
            launcher_launch(_app_name(i))
            return true
        i = i + 1
    false

# ============================================================================
# Query / Listing
# ============================================================================

fn launcher_list():
    """Print all registered apps to serial."""
    log_raw_println("[launcher] === App Registry ({app_count} entries) ===")
    var i: u64 = 0
    while i < app_count:
        val running = if app_pid[i] > 0: " (running, PID={app_pid[i]}, windows={app_window_count[i]})" else: ""
        val shortcut_desc = _shortcut_desc(_app_key(i), _app_mod(i))
        log_raw_println("  [{i}] {_app_name(i)} — {_app_path(i)} [{shortcut_desc}] state={app_launch_state[i]} launches={app_launch_count[i]}{running}")
        i = i + 1
    log_raw_println("[launcher] === End App Registry ===")

fn launcher_get_app_count() -> i64:
    """Return total number of registered (active) apps."""
    return app_count.to_i64()

fn launcher_get_running_app_count() -> i64:
    var count: i64 = 0
    var i: u64 = 0
    while i < app_count:
        if app_pid[i] > 0:
            count = count + 1
        i = i + 1
    count

fn launcher_get_app_name(idx: u64) -> text:
    """Return app name at given index, or empty string if invalid."""
    if idx >= app_count:
        return ""
    _app_name(idx)

fn launcher_get_app_icon(idx: u64) -> text:
    """Return app icon character at given index, or empty string if invalid."""
    if idx >= app_count:
        return ""
    _app_icon(idx)

fn launcher_get_app_path(idx: u64) -> text:
    """Return app binary path at given index, or empty string if invalid."""
    if idx >= app_count:
        return ""
    _app_path(idx)

fn launcher_get_app_identity(idx: u64) -> text:
    """Return the stable launcher-owned app identity for a registry slot."""
    if idx >= app_count:
        return ""
    _default_app_identity(idx)

fn launcher_is_running(idx: u64) -> bool:
    """Return whether the app at given index has a running instance."""
    if idx >= app_count:
        return false
    app_pid[idx] > 0

fn launcher_get_pid(idx: u64) -> u64:
    """Return the PID of the running instance, or 0 if not running."""
    if idx >= app_count:
        return 0
    app_pid[idx]

fn launcher_get_last_launch_pid() -> u64:
    """Return the most recent launcher PID."""
    launcher_last_launch_pid

fn launcher_get_app_launch_state(idx: u64) -> text:
    if idx >= app_count:
        return ""
    app_launch_state[idx]

fn launcher_get_app_window_count(idx: u64) -> u64:
    if idx >= app_count:
        return 0
    app_window_count[idx]

fn launcher_get_app_exit_code(idx: u64) -> i32:
    if idx >= app_count:
        return 0
    app_exit_code[idx]

fn launcher_get_app_launch_count(idx: u64) -> u64:
    if idx >= app_count:
        return 0
    app_launch_count[idx]

fn launcher_get_app_last_pid(idx: u64) -> u64:
    if idx >= app_count:
        return 0
    app_last_pid[idx]

fn launcher_get_app_is_headless(idx: u64) -> bool:
    if idx >= app_count:
        return false
    app_is_headless[idx]

fn launcher_mark_exited(pid: u64):
    """Mark an app as no longer running when its process exits.

    Called by the process supervisor or wait loop when a child exits.
    """
    launcher_mark_exited_with_code(pid, -1)

fn launcher_mark_exited_with_code(pid: u64, exit_code: i32):
    """Mark an app as exited/crashed/terminated and persist the final exit code."""
    var final_state = if exit_code == -1: "exited" else: "crashed"
    var process_idx = _process_index_by_pid(pid)
    if process_idx >= 0:
        val pslot = process_idx.to_u64()
        final_state = _classify_final_state(process_state[pslot], exit_code)
        process_state[pslot] = final_state
        process_exit_code[pslot] = exit_code
        process_window_count[pslot] = 0
        process_is_headless[pslot] = true
        process_active[pslot] = false

    var app_idx = _app_index_by_pid(pid)
    if app_idx >= 0:
        val slot = app_idx.to_u64()
        val app_id = _default_app_identity(slot)
        if final_state == "terminated":
            log_raw_println("[launcher] Process terminated: {app_name[slot]} (PID {pid}, code {exit_code})")
        elif final_state == "crashed":
            log_raw_println("[launcher] Process crashed: {app_name[slot]} (PID {pid}, code {exit_code})")
        else:
            log_raw_println("[launcher] Process exited: {app_name[slot]} (PID {pid}, code {exit_code})")
        log_raw_println("[launcher] exited app_id={app_id} pid={pid} state={final_state} code={exit_code}")
        _clear_app_slot_by_pid(pid, final_state, exit_code)
        return

    if final_state == "terminated":
        log_raw_println("[launcher] Process terminated: PID {pid} (code {exit_code})")
    elif final_state == "crashed":
        log_raw_println("[launcher] Process crashed: PID {pid} (code {exit_code})")
    else:
        log_raw_println("[launcher] Process exited: PID {pid} (code {exit_code})")
    log_raw_println("[launcher] exited app_id= pid={pid} state={final_state} code={exit_code}")

fn launcher_terminate(pid: u64) -> bool:
    """Request forced termination of a tracked process.

    Flips the tracked state to `terminating` *before* invoking the
    kernel kill so that when `launcher_poll_processes` /
    `launcher_note_task_probe` later observes the death, classification
    via `_classify_final_state` resolves to `terminated` rather than
    `exited` or `crashed`.

    Returns `true` if the termination request was recorded. A return of
    `false` means the PID was not tracked as live, so no kill was sent.
    A kernel-side kill delivery failure is logged but does not unwind
    the state flip — the operator intent is already captured, and the
    reaper will finalize to `terminated` on the next probe regardless of
    whether the signal delivery path was available.
    """
    var process_idx = _process_index_by_pid(pid)
    if process_idx < 0:
        log_raw_println("[launcher] Terminate ignored: PID {pid} not tracked")
        return false
    val pslot = process_idx.to_u64()
    if not _is_running_state(process_state[pslot]):
        log_raw_println("[launcher] Terminate ignored: PID {pid} already in state {process_state[pslot]}")
        return false

    # Record the terminate intent first so that the reaper's subsequent
    # liveness probe classifies the death as `terminated`.
    _update_process_state(pid, "terminating", 0)
    var app_idx = _app_index_by_pid(pid)
    if app_idx >= 0:
        app_launch_state[app_idx.to_u64()] = "terminating"

    if launcher_process_can_signal(pid):
        val result = posix_kill(pid, SIGTERM)
        if result != 0:
            log_raw_println("[launcher] posix_kill SIGTERM failed for PID {pid}: {result} (state kept as terminating)")
        else:
            log_raw_println("[launcher] Terminate sent to PID {pid}")
    else:
        log_raw_println("[launcher] Terminate recorded for registry-only PID {pid}")
    true

fn launcher_note_task_probe(pid: u64, alive: bool, exit_code: i32):
    """Record the outcome of a single task liveness probe.

    Called by `launcher_poll_processes` after sampling the kernel task
    table, and exposed directly so unit tests can drive the state
    machine without a live kernel.

    If `alive` is false, the process is retired through
    `launcher_mark_exited_with_code`, which preserves the existing
    classification rules (terminated vs. crashed vs. exited).
    """
    if alive:
        return
    var process_idx = _process_index_by_pid(pid)
    if process_idx < 0:
        return
    if not _is_running_state(process_state[process_idx.to_u64()]):
        return
    launcher_mark_exited_with_code(pid, exit_code)

fn launcher_poll_processes():
    """Sample every live tracked process and reap anything no longer running.

    Uses `get_task_info` to resolve the current kernel state for each
    tracked PID. Missing tasks and tasks reporting the Zombie state are
    marked exited through `launcher_note_task_probe`. Real crash vs.
    graceful-exit classification is deferred to
    `launcher_mark_exited_with_code`, which inspects the previously
    recorded state machine.

    Must be called from a context that can issue syscalls (e.g. the
    shell event loop). Unit tests should drive
    `launcher_note_task_probe` directly instead.
    """
    var snapshot: [u64] = []
    var i: u64 = 0
    while i < MAX_PROCESSES:
        if _is_running_state(process_state[i]) and _is_process_backed_record(process_pid[i], process_state[i]):
            snapshot = snapshot.push(process_pid[i])
        i = i + 1
    for pid in snapshot:
        match get_task_info(pid):
            case Ok(entry):
                if entry.state == 3:
                    launcher_note_task_probe(pid, false, -1)
            case Err(_):
                launcher_note_task_probe(pid, false, -1)

fn launcher_find_by_name(name: text) -> i64:
    """Find app index by name. Returns -1 if not found."""
    _app_index_by_name(name)

fn launcher_find_process_by_pid(pid: u64) -> i64:
    """Find process record index by PID. Returns -1 if not found."""
    _process_index_by_pid(pid)

fn launcher_get_process_count() -> i64:
    """Return the total number of process records tracked."""
    process_count.to_i64()

fn launcher_get_running_process_count() -> i64:
    var count: i64 = 0
    var i: u64 = 0
    while i < MAX_PROCESSES:
        if process_active[i]:
            count = count + 1
        i = i + 1
    count

fn launcher_get_process_pid(idx: u64) -> u64:
    if idx >= process_count:
        return 0
    process_pid[idx]

fn launcher_get_process_app_index(idx: u64) -> i64:
    if idx >= process_count:
        return -1
    process_app_index[idx]

fn launcher_get_process_name(idx: u64) -> text:
    if idx >= process_count:
        return ""
    process_name[idx]

fn launcher_get_process_path(idx: u64) -> text:
    if idx >= process_count:
        return ""
    process_path[idx]

fn launcher_get_process_app_id(idx: u64) -> text:
    """Return stable app identity for a tracked process."""
    if idx >= process_count:
        return ""
    if process_app_id[idx] != "":
        return process_app_id[idx]
    _canonical_app_identity(process_path[idx])

fn launcher_get_process_icon(idx: u64) -> text:
    if idx >= process_count:
        return ""
    process_icon[idx]

fn launcher_get_process_state(idx: u64) -> text:
    if idx >= process_count:
        return ""
    process_state[idx]

fn launcher_get_process_exit_code(idx: u64) -> i32:
    if idx >= process_count:
        return 0
    process_exit_code[idx]

fn launcher_get_process_window_count(idx: u64) -> u64:
    if idx >= process_count:
        return 0
    process_window_count[idx]

fn launcher_get_process_is_headless(idx: u64) -> bool:
    if idx >= process_count:
        return false
    process_is_headless[idx]

fn launcher_get_process_launch_seq(idx: u64) -> u64:
    if idx >= process_count:
        return 0
    process_launch_seq[idx]

fn launcher_get_process_app_id_for_pid(pid: u64) -> text:
    """Resolve the stable app identity for a PID, or empty string if unknown."""
    log_raw_println("[launcher] process-app-id:lookup:start pid={pid}")
    var slot: u64 = 0
    while slot < MAX_PROCESSES:
        if process_pid[slot] == pid:
            log_raw_println("[launcher] process-app-id:lookup:slot pid={pid} slot={slot}")
            if process_app_id[slot] != "":
                log_raw_println("[launcher] process-app-id:lookup:return pid={pid} source=process-app-id")
                return process_app_id[slot]
            if process_path[slot] != "":
                log_raw_println("[launcher] process-app-id:lookup:return pid={pid} source=process-path")
                return _canonical_app_identity(process_path[slot])
        slot = slot + 1

    val app_idx = _app_index_by_pid(pid)
    if app_idx < 0:
        log_raw_println("[launcher] process-app-id:lookup:return pid={pid} source=missing")
        return ""
    log_raw_println("[launcher] process-app-id:lookup:return pid={pid} source=app-slot app_idx={app_idx}")
    _canonical_app_identity(app_path[app_idx.to_u64()])

fn _launcher_note_app_window_opened(pid: u64):
    var app_idx = _app_index_by_pid(pid)
    if app_idx < 0:
        return
    val aslot = app_idx.to_u64()
    app_window_count[aslot] = app_window_count[aslot] + 1
    app_is_headless[aslot] = false

fn _launcher_note_app_window_closed(pid: u64):
    var app_idx = _app_index_by_pid(pid)
    if app_idx < 0:
        return
    val aslot = app_idx.to_u64()
    if app_window_count[aslot] > 0:
        app_window_count[aslot] = app_window_count[aslot] - 1
    app_is_headless[aslot] = app_window_count[aslot] == 0

fn launcher_note_window_opened(pid: u64):
    """Increment the tracked window count for a launched process."""
    var process_idx = _process_index_by_pid(pid)
    if process_idx < 0:
        return
    val pslot = process_idx.to_u64()
    process_window_count[pslot] = process_window_count[pslot] + 1
    process_is_headless[pslot] = false
    if process_state[pslot] == "running":
        process_active[pslot] = true

    _launcher_note_app_window_opened(pid)

fn launcher_note_window_closed(pid: u64):
    """Decrement the tracked window count for a launched process."""
    var process_idx = _process_index_by_pid(pid)
    if process_idx < 0:
        return
    val pslot = process_idx.to_u64()
    if process_window_count[pslot] > 0:
        process_window_count[pslot] = process_window_count[pslot] - 1
    process_is_headless[pslot] = process_window_count[pslot] == 0

    _launcher_note_app_window_closed(pid)
    if _is_synthetic_pid(pid) and process_window_count[pslot] == 0:
        launcher_mark_exited_with_code(pid, 0)

# ============================================================================
# IPC Service Loop
# ============================================================================

fn launcher_start():
    """Start launcher IPC service: init registry, create port, enter loop."""
    launcher_init()

    val port_result = syscall(SYS_IPC_CREATE_PORT, 0, 0, 0, 0, 0)
    if port_result < 0:
        log_raw_println("[launcher] FATAL: Failed to create IPC port (error {port_result})")
        return

    val port_handle = port_result as u64
    log_raw_println("[launcher] Service ready on IPC port (handle={port_handle})")
    launcher_list()

    # Enter service loop
    launcher_service_loop(port_handle)

fn launcher_service_loop(port_handle: u64):
    """Main service loop — receive IPC messages and dispatch.

    IPC message layout (expected):
      word 0: method ID (LAUNCHER_REGISTER, etc.)
      word 1: sender task ID
      word 2..N: method-specific arguments

    Dispatch will be wired when IPC message framing is finalized
    in the kernel IPC layer.
    """
    log_raw_println("[launcher] Entering service loop...")

    while true:
        val msg_result = syscall(SYS_IPC_RECV, port_handle, 0, 0, 0, 0)
        if msg_result < 0:
            log_raw_println("[launcher] IPC recv error: {msg_result}")
            continue

        log_raw_println("[launcher] Received IPC request (raw={msg_result})")

        # IPC dispatch is intentionally deferred here; the registry and
        # process bookkeeping paths are the part owned by this change.
        continue

# ============================================================================
# Internal Helpers
# ============================================================================

fn _shortcut_desc(key: u32, mods: u32) -> text:
    """Convert a key code + modifier flags to a human-readable description."""
    var desc = ""
    if (mods & MOD_META) != 0:
        desc = desc + "Meta+"
    if (mods & MOD_CTRL) != 0:
        desc = desc + "Ctrl+"
    if (mods & MOD_ALT) != 0:
        desc = desc + "Alt+"
    if (mods & MOD_SHIFT) != 0:
        desc = desc + "Shift+"
    # Key code to character (printable ASCII range)
    if key >= 0x41 and key <= 0x5A:
        val ch = key as u8
        desc = desc + "{ch}"
    else:
        desc = desc + "0x{key}"
    desc

fn _class_name_for_mod(mods: u32) -> text:
    """Return a short string describing modifier flags."""
    var parts: [text] = []
    if (mods & MOD_META) != 0:
        parts = parts.push("Meta")
    if (mods & MOD_CTRL) != 0:
        parts = parts.push("Ctrl")
    if (mods & MOD_ALT) != 0:
        parts = parts.push("Alt")
    if (mods & MOD_SHIFT) != 0:
        parts = parts.push("Shift")
    if parts.len() == 0:
        return "none"
    var result = ""
    var i: u64 = 0
    while i < parts.len():
        if i > 0:
            result = result + "|"
        result = result + parts[i]
        i = i + 1
    result
