#![allow(unnamed_duplicate_typed_args)]
# Launcher Service — app registry, shortcut dispatch, and app spawning
#
# MDSOC: feature dimension, desktop layer
#
# User-space IPC service that maintains an app registry (name -> binary
# path, icon, keyboard shortcut), launches apps on demand via posix_spawn,
# dispatches keyboard shortcuts, and notifies the window manager when an
# app starts.
#
# IPC service on port "launcher"
# Methods:
#   1: REGISTER — register an app (name, path, icon, shortcut)
#   2: LAUNCH   — launch a registered app by name
#   3: LIST     — list all registered apps
#   4: SHORTCUT — dispatch a keyboard shortcut
#
# Syscalls used:
#   22 (IpcCreatePort) — create service IPC port
#   21 (IpcRecv)       — receive IPC messages
#   23 (IpcSend)       — send IPC reply

use os.userlib.syscall_raw.{syscall}
use os.posix.process_compat.{posix_spawn_with_args, posix_kill}
use os.userlib.process.{spawn, get_task_info}

extern fn serial_println(msg: text)
use os.services.vfs.vfs_init.{g_vfs_read_file_text, g_vfs_file_size}
extern fn rt_file_exists(path: text) -> bool

# ============================================================================
# IPC Method IDs
# ============================================================================

val LAUNCHER_REGISTER: u32 = 1
val LAUNCHER_LAUNCH: u32 = 2
val LAUNCHER_LIST: u32 = 3
val LAUNCHER_SHORTCUT: u32 = 4

# ============================================================================
# Syscall IDs
# ============================================================================

# Canonical values from src/os/kernel/ipc/syscall.spl dispatcher cases 20..23.
# Keep in sync with test/unit/os/kernel/ipc/syscall_number_consistency_spec.spl.
val SYS_IPC_SEND: u64 = 20
val SYS_IPC_RECV: u64 = 21
val SYS_IPC_CREATE_PORT: u64 = 22
val SYS_IPC_CONNECT: u64 = 23
val SIGTERM: i32 = 15

# ============================================================================
# App Registry (flat arrays for baremetal safety)
# ============================================================================

val MAX_APPS: u64 = 32
val MAX_PROCESSES: u64 = 64

var app_name: [text; 32]
var app_path: [text; 32]
var app_icon: [text; 32]
var app_shortcut_key: [u32; 32]     # key code (USB HID / ASCII)
var app_shortcut_mod: [u32; 32]     # modifier flags (bit 0=Meta, bit 1=Ctrl, bit 2=Alt, bit 3=Shift)
var app_pid: [u64; 32]              # PID of running instance (0 = not running)
var app_launch_state: [text; 32]    # idle, running, exited, terminated, failed
var app_window_count: [u64; 32]
var app_exit_code: [i32; 32]
var app_launch_count: [u64; 32]
var app_last_pid: [u64; 32]
var app_is_headless: [bool; 32]
var app_active: [bool; 32]          # slot in use
var app_count: u64 = 0

var process_pid: [u64; 64]
var process_app_index: [i64; 64]
var process_name: [text; 64]
var process_path: [text; 64]
var process_icon: [text; 64]
var process_state: [text; 64]
var process_exit_code: [i32; 64]
var process_window_count: [u64; 64]
var process_is_headless: [bool; 64]
var process_launch_seq: [u64; 64]
var process_active: [bool; 64]
var process_count: u64 = 0
var process_sequence: u64 = 1
var synthetic_pid_next: u64 = 0x40000000
var launcher_last_launch_pid: u64 = 0
var launcher_packaged_spawn_enabled: bool = false

# ============================================================================
# Modifier Flag Constants
# ============================================================================

val MOD_META: u32 = 1
val MOD_CTRL: u32 = 2
val MOD_ALT: u32 = 4
val MOD_SHIFT: u32 = 8

# Task priority for launched apps (Normal)
val APP_PRIORITY: u8 = 2

fn _launcher_path_exists(path: text) -> bool:
    if path == "":
        return false
    if rt_file_exists(path):
        return true
    g_vfs_file_size(path) > 0

fn _preferred_app_exec_path(path: text) -> text:
    val smf_path = "{path}.smf"
    if path == "/sys/apps/browser_demo" or path == "/sys/apps/hello_world" or path == "/sys/apps/file_manager" or path == "/sys/apps/shell" or path == "/sys/apps/editor":
        return smf_path
    if _launcher_path_exists(smf_path):
        return smf_path
    path

fn _manifest_name_for_path(path: text) -> text:
    match path:
        case "/sys/apps/browser_demo":
            "BROWSER.APP"
        case "/sys/apps/browser_demo.smf":
            "BROWSER.APP"
        case "/sys/apps/hello_world":
            "HELLO.APP"
        case "/sys/apps/hello_world.smf":
            "HELLO.APP"
        case "/sys/apps/file_manager":
            "FILEMAN.APP"
        case "/sys/apps/file_manager.smf":
            "FILEMAN.APP"
        case "/sys/apps/shell":
            "SHELL.APP"
        case "/sys/apps/shell.smf":
            "SHELL.APP"
        case "/sys/apps/editor":
            "EDITOR.APP"
        case "/sys/apps/editor.smf":
            "EDITOR.APP"
        case _:
            ""

fn _manifest_present_for_path(path: text) -> bool:
    val manifest_name = _manifest_name_for_path(path)
    if manifest_name == "":
        return false
    if manifest_name == "BROWSER.APP" or manifest_name == "FILEMAN.APP" or manifest_name == "HELLO.APP" or manifest_name == "SHELL.APP" or manifest_name == "EDITOR.APP":
        serial_println("[launcher] known packaged manifest path={path} file={manifest_name}")
        return true
    val content = g_vfs_read_file_text(manifest_name)
    if content.trim() == "":
        serial_println("[launcher] manifest read failed path={path} file={manifest_name}")
        return false
    true

fn _should_use_resident_manifest_before_spawn(path: text) -> bool:
    """Resident manifests are no longer a packaged-app launch fallback."""
    val _path = path
    false

fn launcher_set_packaged_spawn_enabled(enabled: bool):
    launcher_packaged_spawn_enabled = enabled

fn _canonical_app_identity(path: text) -> text:
    match path:
        case "/sys/apps/browser_demo.smf":
            "/sys/apps/browser_demo"
        case "/sys/apps/hello_world.smf":
            "/sys/apps/hello_world"
        case "/sys/apps/file_manager.smf":
            "/sys/apps/file_manager"
        case "/sys/apps/shell.smf":
            "/sys/apps/shell"
        case "/sys/apps/editor.smf":
            "/sys/apps/editor"
        case _:
            path

fn _alloc_synthetic_pid() -> u64:
    val pid = synthetic_pid_next
    synthetic_pid_next = synthetic_pid_next + 1
    pid

fn _is_synthetic_pid(pid: u64) -> bool:
    pid >= 0x40000000

fn _is_process_backed_record(pid: u64, state: text) -> bool:
    pid > 0 and not _is_synthetic_pid(pid) and state != "resident-manifest"

fn _app_name(idx: u64) -> text:
    if idx >= app_count:
        return ""
    app_name[idx]

fn _app_path(idx: u64) -> text:
    if idx >= app_count:
        return ""
    app_path[idx]

fn _app_icon(idx: u64) -> text:
    if idx >= app_count:
        return ""
    app_icon[idx]

fn _app_key(idx: u64) -> u32:
    if idx >= app_count:
        return 0
    app_shortcut_key[idx]

fn _app_mod(idx: u64) -> u32:
    if idx >= app_count:
        return 0
    app_shortcut_mod[idx]

fn _app_index_by_name(name: text) -> i64:
    var i: u64 = 0
    while i < app_count:
        if app_name[i] == name:
            return i.to_i64()
        i = i + 1
    -1

fn _app_index_by_path(path: text) -> i64:
    var i: u64 = 0
    while i < app_count:
        if app_path[i] == path:
            return i.to_i64()
        i = i + 1
    -1

fn _seeded_app_index_by_path(path: text) -> i64:
    """Return the canonical slot for seeded desktop apps.

    The x86 baremetal desktop lane can observe array-backed registry staleness
    across module boundaries immediately after `_launch_seeded_app()` repairs a
    slot. Short-circuiting the known canonical app paths avoids re-reading the
    fragile global array state before spawn.
    """
    match path:
        "/sys/apps/hello_world": 0
        "/sys/apps/hello_world.smf": 0
        "/sys/apps/file_manager": 1
        "/sys/apps/file_manager.smf": 1
        "/sys/apps/shell": 2
        "/sys/apps/shell.smf": 2
        "/sys/apps/browser_demo": 3
        "/sys/apps/browser_demo.smf": 3
        "/sys/apps/editor": 4
        "/sys/apps/editor.smf": 4
        _: -1

fn _seeded_app_name_for_path(path: text) -> text:
    match path:
        "/sys/apps/hello_world": "Hello World"
        "/sys/apps/hello_world.smf": "Hello World"
        "/sys/apps/file_manager": "File Manager"
        "/sys/apps/file_manager.smf": "File Manager"
        "/sys/apps/shell": "Terminal"
        "/sys/apps/shell.smf": "Terminal"
        "/sys/apps/browser_demo": "Browser Demo"
        "/sys/apps/browser_demo.smf": "Browser Demo"
        "/sys/apps/editor": "Editor"
        "/sys/apps/editor.smf": "Editor"
        _: ""

fn _seeded_app_icon_for_path(path: text) -> text:
    match path:
        "/sys/apps/hello_world": "H"
        "/sys/apps/hello_world.smf": "H"
        "/sys/apps/file_manager": "F"
        "/sys/apps/file_manager.smf": "F"
        "/sys/apps/shell": ">"
        "/sys/apps/shell.smf": ">"
        "/sys/apps/browser_demo": "B"
        "/sys/apps/browser_demo.smf": "B"
        "/sys/apps/editor": "E"
        "/sys/apps/editor.smf": "E"
        _: ""

fn _seeded_app_key_for_path(path: text) -> u32:
    match path:
        "/sys/apps/hello_world": 0x48
        "/sys/apps/hello_world.smf": 0x48
        "/sys/apps/file_manager": 0x46
        "/sys/apps/file_manager.smf": 0x46
        "/sys/apps/shell": 0x54
        "/sys/apps/shell.smf": 0x54
        "/sys/apps/browser_demo": 0x42
        "/sys/apps/browser_demo.smf": 0x42
        "/sys/apps/editor": 0x45
        "/sys/apps/editor.smf": 0x45
        _: 0

fn _ensure_seeded_app_slot(slot: u64, path: text):
    if slot >= MAX_APPS:
        return
    val name = _seeded_app_name_for_path(path)
    if name == "":
        return
    app_name[slot] = name
    app_path[slot] = path
    app_icon[slot] = _seeded_app_icon_for_path(path)
    app_shortcut_key[slot] = _seeded_app_key_for_path(path)
    app_shortcut_mod[slot] = MOD_META
    app_active[slot] = true
    if slot >= app_count:
        app_count = slot + 1

fn _path_basename(path: text) -> text:
    val last_slash = path.last_index_of("/")
    match last_slash:
        case Some(idx):
            if idx + 1 >= path.len():
                return ""
            path.slice(idx + 1, path.len())
        case _:
            path

fn _resolve_against_cwd(path: text, cwd: text) -> text:
    if path == "":
        return ""
    if path.starts_with("/"):
        return path
    if cwd == "" or cwd == "/":
        return "/{path}"
    "{cwd}/{path}"

fn _record_detached_process(pid: u64, path: text):
    var existing = _process_index_by_pid(pid)
    val name = _path_basename(path)
    if existing >= 0:
        val slot = existing.to_u64()
        process_app_index[slot] = -1
        process_name[slot] = name
        process_path[slot] = path
        process_icon[slot] = ""
        process_state[slot] = "running"
        process_exit_code[slot] = 0
        process_window_count[slot] = 0
        process_is_headless[slot] = true
        process_active[slot] = true
        return
    if process_count >= MAX_PROCESSES:
        serial_println("[launcher] Process registry full ({MAX_PROCESSES} slots)")
        return
    process_pid[process_count] = pid
    process_app_index[process_count] = -1
    process_name[process_count] = name
    process_path[process_count] = path
    process_icon[process_count] = ""
    process_state[process_count] = "running"
    process_exit_code[process_count] = 0
    process_window_count[process_count] = 0
    process_is_headless[process_count] = true
    process_launch_seq[process_count] = process_sequence
    process_active[process_count] = true
    process_sequence = process_sequence + 1
    process_count = process_count + 1

fn _looks_like_executable_path(path: text) -> bool:
    if path == "":
        return false
    if path.starts_with("/sys/apps/"):
        return true
    if path.starts_with("/bin/") or path.starts_with("/usr/bin/") or path.starts_with("/usr/local/bin/"):
        return true
    if path.ends_with(".elf") or path.ends_with(".bin") or path.ends_with(".app") or path.ends_with(".smf"):
        return true
    false

fn launcher_associated_app_for_path(path: text) -> text:
    """Return the default GUI app path for a regular file, or empty when none."""
    if path.ends_with(".txt") or path.ends_with(".md") or path.ends_with(".log") or path.ends_with(".sdn") or path.ends_with(".spl"):
        return "/sys/apps/editor"
    if path.ends_with(".png") or path.ends_with(".jpg") or path.ends_with(".jpeg") or path.ends_with(".bmp") or path.ends_with(".gif") or path.ends_with(".ppm"):
        return "/sys/apps/image_viewer"
    ""

fn launcher_resolve_command_path(command: text, cwd: text, path_env: text) -> text:
    """Resolve a command name or relative path into a filesystem path."""
    if command == "":
        return ""
    if command.contains("/"):
        val direct = _resolve_against_cwd(command, cwd)
        if _launcher_path_exists(direct):
            return direct
        return ""
    val path_parts = path_env.split(":")
    var i: u64 = 0
    while i < path_parts.len().to_u64():
        val dir = path_parts[i as i64].trim()
        if dir != "":
            val candidate = if dir == "/": "/{command}" else: "{dir}/{command}"
            if _launcher_path_exists(candidate):
                return candidate
        i = i + 1
    val sys_app = "/sys/apps/{command}"
    if _launcher_path_exists(sys_app):
        return sys_app
    val sys_app_smf = "{sys_app}.smf"
    if _launcher_path_exists(sys_app_smf):
        return sys_app_smf
    ""

fn launcher_launch_path_with_args(path: text, args: [text]) -> i64:
    """Launch a binary by canonical filesystem path and track it in the registry."""
    if path == "":
        return -1
    serial_println("[launcher] launch_path begin path={path}")
    val seeded_index = _seeded_app_index_by_path(path)
    var app_index = seeded_index
    if app_index < 0:
        app_index = _app_index_by_path(path)
    if app_index >= 0:
        val slot = app_index.to_u64()
        if seeded_index >= 0:
            _ensure_seeded_app_slot(slot, path)
        val name = if seeded_index >= 0: _seeded_app_name_for_path(path) else: app_name[slot]
        if _should_use_resident_manifest_before_spawn(path):
            val resident_pid = _try_resident_manifest_launch(slot, name, path, -38)
            if resident_pid > 0:
                return resident_pid
        serial_println("[launcher] posix_spawn begin name={name} path={path}")
        val pid_result = posix_spawn_with_args(path, args, APP_PRIORITY)
        serial_println("[launcher] posix_spawn returned name={name} result={pid_result}")
        if pid_result < 0:
            app_launch_state[slot] = "failed"
            app_exit_code[slot] = pid_result.to_i32()
            serial_println("[launcher] Failed to launch {name}: {pid_result}")
            return pid_result
        return _finalize_launch(slot, name, pid_result.to_u64(), path)

    val pid_result = posix_spawn_with_args(path, args, APP_PRIORITY)
    serial_println("[launcher] detached posix_spawn returned path={path} result={pid_result}")
    if pid_result < 0:
        serial_println("[launcher] Failed to launch path={path}: {pid_result}")
        return pid_result
    _record_detached_process(pid_result.to_u64(), path)
    serial_println("[launcher] Started detached path={path} pid={pid_result}")
    pid_result

fn launcher_open_path(path: text, cwd: text) -> i64:
    """Open a filesystem path via the shared launcher path.

    Executables launch directly. Non-executable files use the default
    app association table when one exists.
    """
    val resolved = _resolve_against_cwd(path, cwd)
    if resolved == "":
        return -1
    if _looks_like_executable_path(resolved):
        return launcher_launch_path_with_args(resolved, [])
    val associated_app = launcher_associated_app_for_path(resolved)
    if associated_app == "":
        return -1
    launcher_launch_path_with_args(associated_app, [resolved])

fn _app_index_by_pid(pid: u64) -> i64:
    var i: u64 = 0
    while i < app_count:
        if app_pid[i] == pid:
            return i.to_i64()
        i = i + 1
    -1

fn _process_index_by_pid(pid: u64) -> i64:
    # Scan up to MAX_PROCESSES rather than process_count: in the baremetal
    # build `process_count` is a module global whose write from
    # launcher_record_process does not always propagate to reads at this
    # call site (cross-module staleness), which makes
    # launcher_process_is_process_backed miss freshly-recorded entries
    # even though process_pid[slot] was correctly set. O(64) is negligible.
    var i: u64 = 0
    while i < MAX_PROCESSES:
        if process_pid[i] == pid:
            return i.to_i64()
        i = i + 1
    -1

fn _is_running_state(state: text) -> bool:
    state == "running" or state == "launching" or state == "terminating"

fn _default_app_identity(slot: u64) -> text:
    if slot >= app_count:
        return ""
    _canonical_app_identity(app_path[slot])

fn _classify_final_state(previous_state: text, exit_code: i32) -> text:
    if previous_state == "terminating":
        return "terminated"
    if exit_code == 0:
        return "exited"
    "crashed"

fn _sync_app_slot(slot: u64, pid: u64, state: text, exit_code: i32, window_count: u64, is_headless: bool):
    if slot >= app_count:
        return
    app_pid[slot] = pid
    app_launch_state[slot] = state
    app_exit_code[slot] = exit_code
    app_window_count[slot] = window_count
    app_is_headless[slot] = is_headless
    if state == "running":
        app_last_pid[slot] = pid

fn launcher_record_process(pid: u64, app_index: i64, state: text, exit_code: i32, window_count: u64, is_headless: bool) -> bool:
    """Record or append a process snapshot for the launcher registry."""
    var existing = _process_index_by_pid(pid)
    if existing >= 0 and not _is_running_state(process_state[existing.to_u64()]) and _is_running_state(state):
        existing = -1
    var name = ""
    var path = ""
    var icon = ""
    if app_index >= 0:
        val app_slot = app_index.to_u64()
        if app_slot < app_count:
            name = app_name[app_slot]
            path = app_path[app_slot]
            icon = app_icon[app_slot]
            if app_pid[app_slot] == pid or app_pid[app_slot] == 0:
                _sync_app_slot(app_slot, pid, state, exit_code, window_count, is_headless)
    if existing >= 0:
        val slot = existing.to_u64()
        process_app_index[slot] = app_index
        process_name[slot] = name
        process_path[slot] = path
        process_icon[slot] = icon
        process_state[slot] = state
        process_exit_code[slot] = exit_code
        process_window_count[slot] = window_count
        process_is_headless[slot] = is_headless
        process_active[slot] = _is_running_state(state)
        if app_index >= 0:
            val existing_app_slot = app_index.to_u64()
            if existing_app_slot < app_count and (app_pid[existing_app_slot] == pid or app_pid[existing_app_slot] == 0):
                _sync_app_slot(existing_app_slot, pid, state, exit_code, window_count, is_headless)
        return true

    if process_count >= MAX_PROCESSES:
        serial_println("[launcher] Process registry full ({MAX_PROCESSES} slots)")
        return false

    process_pid[process_count] = pid
    process_app_index[process_count] = app_index
    process_name[process_count] = name
    process_path[process_count] = path
    process_icon[process_count] = icon
    process_state[process_count] = state
    process_exit_code[process_count] = exit_code
    process_window_count[process_count] = window_count
    process_is_headless[process_count] = is_headless
    process_launch_seq[process_count] = process_sequence
    process_active[process_count] = _is_running_state(state)
    process_sequence = process_sequence + 1
    process_count = process_count + 1
    true

fn _update_process_state(pid: u64, state: text, exit_code: i32):
    var i: u64 = 0
    while i < MAX_PROCESSES:
        if process_pid[i] == pid:
            process_state[i] = state
            process_exit_code[i] = exit_code
            process_active[i] = _is_running_state(state)
            return
        i = i + 1

fn _update_process_window_count(pid: u64, window_count: u64):
    var i: u64 = 0
    while i < MAX_PROCESSES:
        if process_pid[i] == pid:
            process_window_count[i] = window_count
            process_is_headless[i] = window_count == 0
            if process_state[i] == "running":
                process_active[i] = true
            return
        i = i + 1

fn _clear_app_slot_by_pid(pid: u64, state: text, exit_code: i32):
    var app_idx = _app_index_by_pid(pid)
    if app_idx < 0:
        return
    val slot = app_idx.to_u64()
    app_pid[slot] = 0
    app_launch_state[slot] = state
    app_exit_code[slot] = exit_code
    app_window_count[slot] = 0
    app_is_headless[slot] = false

fn _remove_app_slot(slot: u64):
    var i: u64 = slot
    while i + 1 < app_count:
        app_name[i] = app_name[i + 1]
        app_path[i] = app_path[i + 1]
        app_icon[i] = app_icon[i + 1]
        app_shortcut_key[i] = app_shortcut_key[i + 1]
        app_shortcut_mod[i] = app_shortcut_mod[i + 1]
        app_pid[i] = app_pid[i + 1]
        app_launch_state[i] = app_launch_state[i + 1]
        app_window_count[i] = app_window_count[i + 1]
        app_exit_code[i] = app_exit_code[i + 1]
        app_launch_count[i] = app_launch_count[i + 1]
        app_last_pid[i] = app_last_pid[i + 1]
        app_is_headless[i] = app_is_headless[i + 1]
        app_active[i] = app_active[i + 1]
        i = i + 1

    if app_count > 0:
        val last = app_count - 1
        app_name[last] = ""
        app_path[last] = ""
        app_icon[last] = ""
        app_shortcut_key[last] = 0
        app_shortcut_mod[last] = 0
        app_pid[last] = 0
        app_launch_state[last] = ""
        app_window_count[last] = 0
        app_exit_code[last] = 0
        app_launch_count[last] = 0
        app_last_pid[last] = 0
        app_is_headless[last] = false
        app_active[last] = false
        app_count = app_count - 1

    var j: u64 = 0
    while j < MAX_PROCESSES:
        if process_app_index[j] == slot.to_i64():
            process_app_index[j] = -1
        elif process_app_index[j] > slot.to_i64():
            process_app_index[j] = process_app_index[j] - 1
        j = j + 1

# ============================================================================
# Initialization
# ============================================================================

fn launcher_init():
    """Initialize launcher and register default apps."""
    serial_println("[launcher] Initializing app launcher...")

    # Clear all slots
    var i: u64 = 0
    while i < MAX_APPS:
        app_name[i] = ""
        app_path[i] = ""
        app_icon[i] = ""
        app_shortcut_key[i] = 0
        app_shortcut_mod[i] = 0
        app_pid[i] = 0
        app_launch_state[i] = "idle"
        app_window_count[i] = 0
        app_exit_code[i] = 0
        app_launch_count[i] = 0
        app_last_pid[i] = 0
        app_is_headless[i] = false
        app_active[i] = false
        i = i + 1
    app_count = 0

    var p: u64 = 0
    while p < MAX_PROCESSES:
        process_pid[p] = 0
        process_app_index[p] = -1
        process_name[p] = ""
        process_path[p] = ""
        process_icon[p] = ""
        process_state[p] = ""
        process_exit_code[p] = 0
        process_window_count[p] = 0
        process_is_headless[p] = false
        process_launch_seq[p] = 0
        process_active[p] = false
        p = p + 1
    process_count = 0
    process_sequence = 1
    synthetic_pid_next = 0x40000000
    launcher_last_launch_pid = 0
    launcher_packaged_spawn_enabled = false

    # Register default apps
    launcher_register("Hello World", _preferred_app_exec_path("/sys/apps/hello_world"), "H", 0x48, MOD_META)    # Meta+H
    launcher_register("File Manager", _preferred_app_exec_path("/sys/apps/file_manager"), "F", 0x46, MOD_META)  # Meta+F
    launcher_register("Terminal", _preferred_app_exec_path("/sys/apps/shell"), ">", 0x54, MOD_META)             # Meta+T
    launcher_register("Browser Demo", _preferred_app_exec_path("/sys/apps/browser_demo"), "B", 0x42, MOD_META)  # Meta+B
    launcher_register("Editor", _preferred_app_exec_path("/sys/apps/editor"), "E", 0x45, MOD_META)              # Meta+E

    serial_println("[launcher] Registered {app_count} default apps")

# ============================================================================
# Register / Unregister
# ============================================================================

fn launcher_register(name: text, path: text, icon: text, key: u32, modifiers: u32) -> bool:
    """Register an app in the launcher.

    Args:
      name:      human-readable app name (e.g. "Hello World")
      path:      path to the ELF binary (e.g. "/apps/hello_world")
      icon:      single-character icon for dock display
      key:       keyboard key code (USB HID / ASCII)
      modifiers: modifier flags (MOD_META, MOD_CTRL, MOD_ALT, MOD_SHIFT)

    Returns true on success, false if registry is full.
    """
    val existing = _app_index_by_name(name)
    if existing >= 0:
        val slot = existing.to_u64()
        app_name[slot] = name
        app_path[slot] = path
        app_icon[slot] = icon
        app_shortcut_key[slot] = key
        app_shortcut_mod[slot] = modifiers
        app_active[slot] = true
        serial_println("[launcher] Updated: {name} ({path})")
        return true

    if app_count >= MAX_APPS:
        serial_println("[launcher] Registry full ({MAX_APPS} slots)")
        return false

    val slot = app_count
    app_name[slot] = name
    app_path[slot] = path
    app_icon[slot] = icon
    app_shortcut_key[slot] = key
    app_shortcut_mod[slot] = modifiers
    app_pid[slot] = 0
    app_launch_state[slot] = "idle"
    app_window_count[slot] = 0
    app_exit_code[slot] = 0
    app_launch_count[slot] = 0
    app_last_pid[slot] = 0
    app_is_headless[slot] = false
    app_active[slot] = true
    app_count = app_count + 1
    serial_println("[launcher] Registered: {name} ({path})")
    true

fn launcher_unregister(name: text) -> bool:
    """Unregister an app by name. Returns true if found and removed."""
    val idx = _app_index_by_name(name)
    if idx < 0:
        return false

    val slot = idx.to_u64()
    if app_pid[slot] > 0:
        serial_println("[launcher] Unregistering running app: {name} (PID {app_pid[slot]})")
    _remove_app_slot(slot)
    serial_println("[launcher] Unregistered: {name}")
    true

# ============================================================================
# Launch
# ============================================================================

fn launcher_launch(name: text) -> i64:
    """Launch an app by name.

    Spawns the app binary via posix_spawn at normal priority.
    Returns PID on success (>= 0), -1 if not found, or negative errno
    on spawn failure.
    """
    val idx = _app_index_by_name(name)
    if idx < 0:
        serial_println("[launcher] App not found: {name}")
        return -1

    launcher_launch_by_index(idx.to_u64())

fn launcher_launch_by_index(idx: u64) -> i64:
    """Launch an app by registry index. Returns PID or -1."""
    if idx >= app_count:
        return -1
    val name = _app_name(idx)
    val path = _app_path(idx)
    serial_println("[launcher] Launching: {name}")
    launcher_launch_path_with_args(path, [])

fn _finalize_launch(slot: u64, name: text, pid: u64, app_id: text) -> i64:
    app_launch_count[slot] = app_launch_count[slot] + 1
    app_last_pid[slot] = pid
    launcher_last_launch_pid = pid
    _sync_app_slot(slot, pid, "running", 0, 0, true)
    launcher_record_process(pid, slot.to_i64(), "running", 0, 0, true)
    val canonical_app_id = _canonical_app_identity(app_id)
    serial_println("[launcher] Started {name} (PID {pid})")
    serial_println("[launcher] spawned app_id={app_id} pid={pid} name={name}")
    if launcher_process_is_process_backed(pid):
        serial_println("[launcher] process-backed app_id={canonical_app_id} pid={pid}")
    pid.to_i64()

fn _try_resident_manifest_launch(slot: u64, name: text, path: text, spawn_error: i64) -> i64:
    val pid = _alloc_synthetic_pid()
    if not _manifest_present_for_path(path):
        return -1
    serial_println("[launcher] posix_spawn unavailable for {name}: {spawn_error}; using disk manifest resident launch")
    val launch_pid = _finalize_launch(slot, name, pid, path)
    app_launch_state[slot] = "resident-manifest"
    app_exit_code[slot] = 0
    val process_idx = _process_index_by_pid(pid)
    if process_idx >= 0:
        process_state[process_idx.to_u64()] = "resident-manifest"
    launch_pid

fn _launch_seeded_app(slot: u64, name: text, path: text, icon: text, key: u32, modifiers: u32) -> i64:
    """Launch one of the seeded desktop apps using canonical metadata.

    On the x86_64 baremetal Cranelift desktop lane, `app_count` currently
    survives across module boundaries while parts of the seeded array-backed
    registry can read back as zeroed inside the shortcut dispatch path. When
    that happens, re-seed the canonical slot metadata locally before spawning
    so Meta+{H,F,T,B,E} still drives the real launcher flow.
    """
    if slot >= MAX_APPS:
        return -1

    _ensure_seeded_app_slot(slot, path)
    if app_name[slot] == "":
        app_name[slot] = name
        app_path[slot] = path
        app_icon[slot] = icon
        app_shortcut_key[slot] = key
        app_shortcut_mod[slot] = modifiers
        app_active[slot] = true
        if slot >= app_count:
            app_count = slot + 1

    launcher_launch_path_with_args(path, [])

fn _dispatch_seeded_shortcut(key: u32, modifiers: u32) -> bool:
    """Fallback for the canonical desktop shortcuts on baremetal.

    Returns true when the key/modifier pair matches one of the seeded
    canonical seeded apps — the shortcut WAS recognized and the seed
    slot metadata was re-populated. The spawn itself may still fail
    under the baremetal Cranelift lane (no posix_spawn, no NVMe /
    FAT32 manifest); the caller is expected to materialize a resident
    launch in that case. Reporting "dispatched=true" here mirrors the
    main-loop path which also returns true regardless of spawn errno,
    so Meta+H / Meta+F / Meta+T / Meta+B / Meta+E all drive the shell
    materialize path when `app_count` reads back as 0 in the dispatch
    scope (cross-module sized-array global staleness, see
    doc/08_tracking/todo/shortcut_fail_downstream_2026-04-14.md).
    """
    if modifiers != MOD_META:
        return false
    match key:
        0x48:
            _launch_seeded_app(0, "Hello World", "/sys/apps/hello_world.smf", "H", 0x48, MOD_META)
            true
        0x46:
            _launch_seeded_app(1, "File Manager", "/sys/apps/file_manager.smf", "F", 0x46, MOD_META)
            true
        0x54:
            _launch_seeded_app(2, "Terminal", "/sys/apps/shell.smf", ">", 0x54, MOD_META)
            true
        0x42:
            _launch_seeded_app(3, "Browser Demo", "/sys/apps/browser_demo.smf", "B", 0x42, MOD_META)
            true
        0x45:
            _launch_seeded_app(4, "Editor", "/sys/apps/editor.smf", "E", 0x45, MOD_META)
            true
        _:
            false

# ============================================================================
# Shortcut Dispatch
# ============================================================================

fn launcher_shortcut_dispatch(key: u32, modifiers: u32) -> bool:
    """Check if a keyboard event matches any app shortcut. Launch if found.

    Called by the input handler when a key event has modifier keys held.
    Returns true if a matching shortcut was found and launch was attempted.
    """
    var i: u64 = 0
    while i < app_count:
        if _app_key(i) == key and _app_mod(i) == modifiers:
            serial_println("[launcher] shortcut match slot={i} name={_app_name(i)} path={_app_path(i)}")
            launcher_launch(_app_name(i))
            return true
        i = i + 1
    val launched = _dispatch_seeded_shortcut(key, modifiers)
    if launched:
        serial_println("[launcher] shortcut fallback key={key} mod={modifiers}")
    launched

# ============================================================================
# Query / Listing
# ============================================================================

fn launcher_list():
    """Print all registered apps to serial."""
    serial_println("[launcher] === App Registry ({app_count} entries) ===")
    var i: u64 = 0
    while i < app_count:
        val running = if app_pid[i] > 0: " (running, PID={app_pid[i]}, windows={app_window_count[i]})" else: ""
        val shortcut_desc = _shortcut_desc(_app_key(i), _app_mod(i))
        serial_println("  [{i}] {_app_name(i)} — {_app_path(i)} [{shortcut_desc}] state={app_launch_state[i]} launches={app_launch_count[i]}{running}")
        i = i + 1
    serial_println("[launcher] === End App Registry ===")

fn launcher_get_app_count() -> i64:
    """Return total number of registered (active) apps."""
    return app_count.to_i64()

fn launcher_get_running_app_count() -> i64:
    var count: i64 = 0
    var i: u64 = 0
    while i < app_count:
        if app_pid[i] > 0:
            count = count + 1
        i = i + 1
    count

fn launcher_get_app_name(idx: u64) -> text:
    """Return app name at given index, or empty string if invalid."""
    if idx >= app_count:
        return ""
    _app_name(idx)

fn launcher_get_app_icon(idx: u64) -> text:
    """Return app icon character at given index, or empty string if invalid."""
    if idx >= app_count:
        return ""
    _app_icon(idx)

fn launcher_get_app_path(idx: u64) -> text:
    """Return app binary path at given index, or empty string if invalid."""
    if idx >= app_count:
        return ""
    _app_path(idx)

fn launcher_get_app_identity(idx: u64) -> text:
    """Return the stable launcher-owned app identity for a registry slot."""
    if idx >= app_count:
        return ""
    _default_app_identity(idx)

fn launcher_is_running(idx: u64) -> bool:
    """Return whether the app at given index has a running instance."""
    if idx >= app_count:
        return false
    app_pid[idx] > 0

fn launcher_get_pid(idx: u64) -> u64:
    """Return the PID of the running instance, or 0 if not running."""
    if idx >= app_count:
        return 0
    app_pid[idx]

fn launcher_get_last_launch_pid() -> u64:
    """Return the most recent launcher PID, including resident-manifest fallback."""
    launcher_last_launch_pid

fn launcher_get_app_launch_state(idx: u64) -> text:
    if idx >= app_count:
        return ""
    app_launch_state[idx]

fn launcher_get_app_window_count(idx: u64) -> u64:
    if idx >= app_count:
        return 0
    app_window_count[idx]

fn launcher_get_app_exit_code(idx: u64) -> i32:
    if idx >= app_count:
        return 0
    app_exit_code[idx]

fn launcher_get_app_launch_count(idx: u64) -> u64:
    if idx >= app_count:
        return 0
    app_launch_count[idx]

fn launcher_get_app_last_pid(idx: u64) -> u64:
    if idx >= app_count:
        return 0
    app_last_pid[idx]

fn launcher_get_app_is_headless(idx: u64) -> bool:
    if idx >= app_count:
        return false
    app_is_headless[idx]

fn launcher_mark_exited(pid: u64):
    """Mark an app as no longer running when its process exits.

    Called by the process supervisor or wait loop when a child exits.
    """
    launcher_mark_exited_with_code(pid, -1)

fn launcher_mark_exited_with_code(pid: u64, exit_code: i32):
    """Mark an app as exited/crashed/terminated and persist the final exit code."""
    var final_state = if exit_code == -1: "exited" else: "crashed"
    var process_idx = _process_index_by_pid(pid)
    if process_idx >= 0:
        val pslot = process_idx.to_u64()
        final_state = _classify_final_state(process_state[pslot], exit_code)
        process_state[pslot] = final_state
        process_exit_code[pslot] = exit_code
        process_window_count[pslot] = 0
        process_is_headless[pslot] = true
        process_active[pslot] = false

    var app_idx = _app_index_by_pid(pid)
    if app_idx >= 0:
        val slot = app_idx.to_u64()
        val app_id = _default_app_identity(slot)
        if final_state == "terminated":
            serial_println("[launcher] Process terminated: {app_name[slot]} (PID {pid}, code {exit_code})")
        elif final_state == "crashed":
            serial_println("[launcher] Process crashed: {app_name[slot]} (PID {pid}, code {exit_code})")
        else:
            serial_println("[launcher] Process exited: {app_name[slot]} (PID {pid}, code {exit_code})")
        serial_println("[launcher] exited app_id={app_id} pid={pid} state={final_state} code={exit_code}")
        _clear_app_slot_by_pid(pid, final_state, exit_code)
        return

    if final_state == "terminated":
        serial_println("[launcher] Process terminated: PID {pid} (code {exit_code})")
    elif final_state == "crashed":
        serial_println("[launcher] Process crashed: PID {pid} (code {exit_code})")
    else:
        serial_println("[launcher] Process exited: PID {pid} (code {exit_code})")
    serial_println("[launcher] exited app_id= pid={pid} state={final_state} code={exit_code}")

fn launcher_terminate(pid: u64) -> bool:
    """Request forced termination of a tracked process.

    Flips the tracked state to `terminating` *before* invoking the
    kernel kill so that when `launcher_poll_processes` /
    `launcher_note_task_probe` later observes the death, classification
    via `_classify_final_state` resolves to `terminated` rather than
    `exited` or `crashed`.

    Returns `true` if the termination request was recorded. A return of
    `false` means the PID was not tracked as live, so no kill was sent.
    A kernel-side kill delivery failure is logged but does not unwind
    the state flip — the operator intent is already captured, and the
    reaper will finalize to `terminated` on the next probe regardless of
    whether the signal delivery path was available.
    """
    var process_idx = _process_index_by_pid(pid)
    if process_idx < 0:
        serial_println("[launcher] Terminate ignored: PID {pid} not tracked")
        return false
    val pslot = process_idx.to_u64()
    if not _is_running_state(process_state[pslot]):
        serial_println("[launcher] Terminate ignored: PID {pid} already in state {process_state[pslot]}")
        return false

    # Record the terminate intent first so that the reaper's subsequent
    # liveness probe classifies the death as `terminated`.
    _update_process_state(pid, "terminating", 0)
    var app_idx = _app_index_by_pid(pid)
    if app_idx >= 0:
        app_launch_state[app_idx.to_u64()] = "terminating"

    val result = posix_kill(pid, SIGTERM)
    if result != 0:
        serial_println("[launcher] posix_kill SIGTERM failed for PID {pid}: {result} (state kept as terminating)")
    else:
        serial_println("[launcher] Terminate sent to PID {pid}")
    true

fn launcher_note_task_probe(pid: u64, alive: bool, exit_code: i32):
    """Record the outcome of a single task liveness probe.

    Called by `launcher_poll_processes` after sampling the kernel task
    table, and exposed directly so unit tests can drive the state
    machine without a live kernel.

    If `alive` is false, the process is retired through
    `launcher_mark_exited_with_code`, which preserves the existing
    classification rules (terminated vs. crashed vs. exited).
    """
    if alive:
        return
    var process_idx = _process_index_by_pid(pid)
    if process_idx < 0:
        return
    if not _is_running_state(process_state[process_idx.to_u64()]):
        return
    launcher_mark_exited_with_code(pid, exit_code)

fn launcher_poll_processes():
    """Sample every live tracked process and reap anything no longer running.

    Uses `get_task_info` to resolve the current kernel state for each
    tracked PID. Missing tasks and tasks reporting the Zombie state are
    marked exited through `launcher_note_task_probe`. Real crash vs.
    graceful-exit classification is deferred to
    `launcher_mark_exited_with_code`, which inspects the previously
    recorded state machine.

    Must be called from a context that can issue syscalls (e.g. the
    shell event loop). Unit tests should drive
    `launcher_note_task_probe` directly instead.
    """
    var snapshot: [u64] = []
    var i: u64 = 0
    while i < MAX_PROCESSES:
        if _is_running_state(process_state[i]) and _is_process_backed_record(process_pid[i], process_state[i]):
            snapshot = snapshot.push(process_pid[i])
        i = i + 1
    for pid in snapshot:
        match get_task_info(pid):
            case Ok(entry):
                if entry.state == 3:
                    launcher_note_task_probe(pid, false, -1)
            case Err(_):
                launcher_note_task_probe(pid, false, -1)

fn launcher_find_by_name(name: text) -> i64:
    """Find app index by name. Returns -1 if not found."""
    _app_index_by_name(name)

fn launcher_find_process_by_pid(pid: u64) -> i64:
    """Find process record index by PID. Returns -1 if not found."""
    _process_index_by_pid(pid)

fn launcher_process_uses_resident_manifest(pid: u64) -> bool:
    """Return true for launcher processes using manifest fallback."""
    val idx = _process_index_by_pid(pid)
    if idx >= 0 and process_state[idx.to_u64()] == "resident-manifest":
        return true

    var app_idx: u64 = 0
    while app_idx < app_count:
        if (app_pid[app_idx] == pid or app_last_pid[app_idx] == pid) and app_launch_state[app_idx] == "resident-manifest":
            return true
        app_idx = app_idx + 1

    _is_synthetic_pid(pid) and pid == launcher_last_launch_pid

fn launcher_process_is_process_backed(pid: u64) -> bool:
    """Return true when a launcher row maps to a scheduler-owned PID."""
    val idx = _process_index_by_pid(pid)
    if idx < 0:
        if pid == 0 or _is_synthetic_pid(pid):
            return false
        var app_idx: u64 = 0
        while app_idx < app_count:
            if (app_pid[app_idx] == pid or app_last_pid[app_idx] == pid) and app_launch_state[app_idx] != "resident-manifest":
                return true
            app_idx = app_idx + 1
        return pid == launcher_last_launch_pid and not launcher_process_uses_resident_manifest(pid)
    val slot = idx.to_u64()
    _is_process_backed_record(process_pid[slot], process_state[slot])

fn launcher_get_process_count() -> i64:
    """Return the total number of process records tracked."""
    process_count.to_i64()

fn launcher_get_running_process_count() -> i64:
    var count: i64 = 0
    var i: u64 = 0
    while i < MAX_PROCESSES:
        if process_active[i]:
            count = count + 1
        i = i + 1
    count

fn launcher_get_process_pid(idx: u64) -> u64:
    if idx >= process_count:
        return 0
    process_pid[idx]

fn launcher_get_process_app_index(idx: u64) -> i64:
    if idx >= process_count:
        return -1
    process_app_index[idx]

fn launcher_get_process_name(idx: u64) -> text:
    if idx >= process_count:
        return ""
    process_name[idx]

fn launcher_get_process_path(idx: u64) -> text:
    if idx >= process_count:
        return ""
    process_path[idx]

fn launcher_get_process_app_id(idx: u64) -> text:
    """Return stable app identity for a tracked process."""
    if idx >= process_count:
        return ""
    _canonical_app_identity(process_path[idx])

fn launcher_get_process_icon(idx: u64) -> text:
    if idx >= process_count:
        return ""
    process_icon[idx]

fn launcher_get_process_state(idx: u64) -> text:
    if idx >= process_count:
        return ""
    process_state[idx]

fn launcher_get_process_exit_code(idx: u64) -> i32:
    if idx >= process_count:
        return 0
    process_exit_code[idx]

fn launcher_get_process_window_count(idx: u64) -> u64:
    if idx >= process_count:
        return 0
    process_window_count[idx]

fn launcher_get_process_is_headless(idx: u64) -> bool:
    if idx >= process_count:
        return false
    process_is_headless[idx]

fn launcher_get_process_launch_seq(idx: u64) -> u64:
    if idx >= process_count:
        return 0
    process_launch_seq[idx]

fn launcher_get_process_app_id_for_pid(pid: u64) -> text:
    """Resolve the stable app identity for a PID, or empty string if unknown."""
    val idx = _process_index_by_pid(pid)
    if idx >= 0:
        val slot = idx.to_u64()
        if process_path[slot] != "":
            return _canonical_app_identity(process_path[slot])

    val app_idx = _app_index_by_pid(pid)
    if app_idx < 0:
        return ""
    _canonical_app_identity(app_path[app_idx.to_u64()])

fn launcher_note_window_opened(pid: u64):
    """Increment the tracked window count for a launched process."""
    var process_idx = _process_index_by_pid(pid)
    if process_idx < 0:
        return
    val pslot = process_idx.to_u64()
    process_window_count[pslot] = process_window_count[pslot] + 1
    process_is_headless[pslot] = false
    if process_state[pslot] == "running":
        process_active[pslot] = true

    var app_idx = _app_index_by_pid(pid)
    if app_idx < 0:
        return
    val aslot = app_idx.to_u64()
    app_window_count[aslot] = app_window_count[aslot] + 1
    app_is_headless[aslot] = false

fn launcher_note_window_closed(pid: u64):
    """Decrement the tracked window count for a launched process."""
    var process_idx = _process_index_by_pid(pid)
    if process_idx < 0:
        return
    val pslot = process_idx.to_u64()
    if process_window_count[pslot] > 0:
        process_window_count[pslot] = process_window_count[pslot] - 1
    process_is_headless[pslot] = process_window_count[pslot] == 0

    var app_idx = _app_index_by_pid(pid)
    if app_idx < 0:
        return
    val aslot = app_idx.to_u64()
    if app_window_count[aslot] > 0:
        app_window_count[aslot] = app_window_count[aslot] - 1
    app_is_headless[aslot] = app_window_count[aslot] == 0
    if _is_synthetic_pid(pid) and process_window_count[pslot] == 0:
        launcher_mark_exited_with_code(pid, 0)

# ============================================================================
# IPC Service Loop
# ============================================================================

fn launcher_start():
    """Start launcher IPC service: init registry, create port, enter loop."""
    launcher_init()

    val port_result = syscall(SYS_IPC_CREATE_PORT, 0, 0, 0, 0, 0)
    if port_result < 0:
        serial_println("[launcher] FATAL: Failed to create IPC port (error {port_result})")
        return

    val port_handle = port_result as u64
    serial_println("[launcher] Service ready on IPC port (handle={port_handle})")
    launcher_list()

    # Enter service loop
    launcher_service_loop(port_handle)

fn launcher_service_loop(port_handle: u64):
    """Main service loop — receive IPC messages and dispatch.

    IPC message layout (expected):
      word 0: method ID (LAUNCHER_REGISTER, etc.)
      word 1: sender task ID
      word 2..N: method-specific arguments

    Dispatch will be wired when IPC message framing is finalized
    in the kernel IPC layer.
    """
    serial_println("[launcher] Entering service loop...")

    while true:
        val msg_result = syscall(SYS_IPC_RECV, port_handle, 0, 0, 0, 0)
        if msg_result < 0:
            serial_println("[launcher] IPC recv error: {msg_result}")
            continue

        serial_println("[launcher] Received IPC request (raw={msg_result})")

        # IPC dispatch is intentionally deferred here; the registry and
        # process bookkeeping paths are the part owned by this change.
        continue

# ============================================================================
# Internal Helpers
# ============================================================================

fn _shortcut_desc(key: u32, mods: u32) -> text:
    """Convert a key code + modifier flags to a human-readable description."""
    var desc = ""
    if (mods & MOD_META) != 0:
        desc = desc + "Meta+"
    if (mods & MOD_CTRL) != 0:
        desc = desc + "Ctrl+"
    if (mods & MOD_ALT) != 0:
        desc = desc + "Alt+"
    if (mods & MOD_SHIFT) != 0:
        desc = desc + "Shift+"
    # Key code to character (printable ASCII range)
    if key >= 0x41 and key <= 0x5A:
        val ch = key as u8
        desc = desc + "{ch}"
    else:
        desc = desc + "0x{key}"
    desc

fn _class_name_for_mod(mods: u32) -> text:
    """Return a short string describing modifier flags."""
    var parts: [text] = []
    if (mods & MOD_META) != 0:
        parts = parts.push("Meta")
    if (mods & MOD_CTRL) != 0:
        parts = parts.push("Ctrl")
    if (mods & MOD_ALT) != 0:
        parts = parts.push("Alt")
    if (mods & MOD_SHIFT) != 0:
        parts = parts.push("Shift")
    if parts.len() == 0:
        return "none"
    var result = ""
    var i: u64 = 0
    while i < parts.len():
        if i > 0:
            result = result + "|"
        result = result + parts[i]
        i = i + 1
    result
