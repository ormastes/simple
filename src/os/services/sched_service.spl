# SimpleOS User-Space Scheduler Policy Service (G1)
#
# Decides task priorities and feeds recommendations to the kernel
# mechanism. Does NOT re-implement scheduling mechanism (that lives in
# src/os/kernel/scheduler/scheduler.spl).
#
# ECS internals: entities are managed tasks; components live in per-type
# ComponentStore<T> columns owned by SchedWorld.

use std.ecs.entity.{Entity, EntityAllocator}
use std.ecs.component_store.{ComponentStore}
use std.ecs.world.{WorldBase}

# ============================================================================
# Scheduler class constants (match kernel scheduler.spl)
# ============================================================================

val SCHED_NORMAL: u32 = 0
val SCHED_RT: u32 = 1
val SCHED_DRIVER: u32 = 2
val SCHED_IDLE: u32 = 3

# Priority levels (match kernel 5-level hierarchy)
val PRIO_REALTIME: i32 = 0
val PRIO_HIGH: i32 = 1
val PRIO_NORMAL: i32 = 2
val PRIO_LOW: i32 = 3
val PRIO_IDLE: i32 = 4

val PRIO_MIN: i32 = 0
val PRIO_MAX: i32 = 4

# Driver runaway threshold (ticks_consumed per policy cycle)
val DRIVER_RUNAWAY_THRESHOLD: u64 = 100

# Nice value clamp range
val NICE_MIN: i32 = -20
val NICE_MAX: i32 = 19

# ============================================================================
# Components (per MDSOC+ ECS spec)
# ============================================================================

struct TaskId:
    """Kernel task identifier."""
    value: u32

struct Priority:
    """Scheduling priority level: 0=Realtime .. 4=Idle."""
    level: i32

struct CpuUsage:
    """Ticks consumed this policy epoch (reset after each sys_demote pass)."""
    ticks_consumed: u64

struct Nice:
    """Nice adjustment value [-20, 19]."""
    value: i32

struct SchedClass:
    """SCHED_NORMAL | SCHED_RT | SCHED_DRIVER | SCHED_IDLE"""
    kind: u32

# ============================================================================
# SchedWorld — ECS world for scheduler policy state
# ============================================================================

struct SchedWorld:
    """ECS world that owns all task entities and their component data."""
    base: WorldBase
    task_ids:    ComponentStore<TaskId>
    priorities:  ComponentStore<Priority>
    cpu_usages:  ComponentStore<CpuUsage>
    nices:       ComponentStore<Nice>
    classes:     ComponentStore<SchedClass>

# ============================================================================
# Extern — kernel dispatcher will wire this later
# ============================================================================

extern fn sched_mechanism_set_priority(task: u32, priority: i32)

# ============================================================================
# Helper: find entity for a task_id by scanning task_ids store
# Returns Entity(id: 0, generation: 0) if not found (id==0 sentinel)
# ============================================================================

fn find_entity_for_task(world: SchedWorld, task: u32) -> Entity:
    """Scan task_ids store to find the Entity for a given kernel task id."""
    val count = world.task_ids.len()
    var i = 0
    while i < count:
        val eid_raw = world.task_ids.entity_at(i)
        val e = Entity(id: eid_raw, generation: 1)
        val slot = world.task_ids.get_slot(e)
        if slot >= 0:
            if world.task_ids.dense[slot].value == task:
                return e
        i = i + 1
    Entity(id: 0, generation: 0)

# ============================================================================
# System: sys_demote_runaway_drivers
#
# For each SCHED_DRIVER task whose ticks_consumed > threshold,
# demote priority by one level (clamp to PRIO_MAX) and reset counter.
# ============================================================================

fn sys_demote_runaway_drivers(world: SchedWorld):
    """ECS system: demote runaway driver tasks and reset their usage counters."""
    val count = world.classes.len()
    var to_demote: [i32] = []
    var i = 0
    while i < count:
        val eid_raw = world.classes.entity_at(i)
        val e = Entity(id: eid_raw, generation: 1)
        val cls_slot = world.classes.get_slot(e)
        if cls_slot >= 0:
            if world.classes.dense[cls_slot].kind == SCHED_DRIVER:
                val usage_slot = world.cpu_usages.get_slot(e)
                if usage_slot >= 0:
                    if world.cpu_usages.dense[usage_slot].ticks_consumed > DRIVER_RUNAWAY_THRESHOLD:
                        val prio_slot = world.priorities.get_slot(e)
                        if prio_slot >= 0:
                            if world.priorities.dense[prio_slot].level > PRIO_REALTIME:
                                to_demote = to_demote.push(eid_raw)
        i = i + 1

    val ecs_tick = world.base.now()
    for eid_raw in to_demote:
        val e = Entity(id: eid_raw, generation: 1)
        val prio_slot = world.priorities.get_slot(e)
        if prio_slot >= 0:
            val cur_level = world.priorities.dense[prio_slot].level
            val new_level = cur_level + 1
            val clamped = if new_level > PRIO_MAX: PRIO_MAX else: new_level
            val tid_slot = world.task_ids.get_slot(e)
            if tid_slot >= 0:
                sched_mechanism_set_priority(world.task_ids.dense[tid_slot].value, clamped)
            world.priorities.insert(e, Priority(level: clamped), ecs_tick)
        world.cpu_usages.insert(e, CpuUsage(ticks_consumed: 0), ecs_tick)

    # Reset counters for non-demoted DRIVER tasks too
    val count2 = world.classes.len()
    var j = 0
    while j < count2:
        val eid_raw = world.classes.entity_at(j)
        val e = Entity(id: eid_raw, generation: 1)
        val cls_slot = world.classes.get_slot(e)
        if cls_slot >= 0:
            if world.classes.dense[cls_slot].kind == SCHED_DRIVER:
                val usage_slot = world.cpu_usages.get_slot(e)
                if usage_slot >= 0:
                    if world.cpu_usages.dense[usage_slot].ticks_consumed <= DRIVER_RUNAWAY_THRESHOLD:
                        world.cpu_usages.insert(e, CpuUsage(ticks_consumed: 0), ecs_tick)
        j = j + 1

# ============================================================================
# System: sys_age_priorities
#
# Nudges stale SCHED_NORMAL tasks that have been at a low priority for
# a long time up by one level to prevent starvation.
# ============================================================================

fn sys_age_priorities(world: SchedWorld):
    """ECS system: age stale Normal tasks upward to prevent starvation."""
    val count = world.classes.len()
    var to_age: [i32] = []
    var i = 0
    while i < count:
        val eid_raw = world.classes.entity_at(i)
        val e = Entity(id: eid_raw, generation: 1)
        val cls_slot = world.classes.get_slot(e)
        if cls_slot >= 0:
            if world.classes.dense[cls_slot].kind == SCHED_NORMAL:
                val prio_slot = world.priorities.get_slot(e)
                if prio_slot >= 0:
                    if world.priorities.dense[prio_slot].level > PRIO_HIGH:
                        val usage_slot = world.cpu_usages.get_slot(e)
                        if usage_slot >= 0:
                            if world.cpu_usages.dense[usage_slot].ticks_consumed == 0:
                                to_age = to_age.push(eid_raw)
        i = i + 1

    val ecs_tick = world.base.now()
    for eid_raw in to_age:
        val e = Entity(id: eid_raw, generation: 1)
        val prio_slot = world.priorities.get_slot(e)
        if prio_slot >= 0:
            val aged_level = world.priorities.dense[prio_slot].level - 1
            world.priorities.insert(e, Priority(level: aged_level), ecs_tick)

# ============================================================================
# SchedService — public API
# ============================================================================

class SchedService:
    """User-space scheduler policy service.

    Owns a SchedWorld (ECS world) and exposes a Simple API used by the
    kernel dispatcher to ask what priority a task should have.
    """
    world: SchedWorld
    policy_tick: u64
    started: bool

impl SchedService:
    static fn new() -> SchedService:
        """Create a fresh SchedService."""
        SchedService(
            world: SchedWorld(
                base:       WorldBase.new(),
                task_ids:   ComponentStore.new(),
                priorities: ComponentStore.new(),
                cpu_usages: ComponentStore.new(),
                nices:      ComponentStore.new(),
                classes:    ComponentStore.new()
            ),
            policy_tick: 0,
            started: false
        )

    me sched_register_task(task: u32, sched_kind: u32, priority: i32, nice: i32) -> Entity:
        """Register a new task with the policy service. Returns its entity handle."""
        val clamped_nice = if nice < NICE_MIN: NICE_MIN else: if nice > NICE_MAX: NICE_MAX else: nice
        val clamped_prio = if priority < PRIO_MIN: PRIO_MIN else: if priority > PRIO_MAX: PRIO_MAX else: priority
        val e = self.world.base.spawn()
        val ecs_tick = self.world.base.now()
        self.world.task_ids.insert(e,   TaskId(value: task),                    ecs_tick)
        self.world.priorities.insert(e, Priority(level: clamped_prio),          ecs_tick)
        self.world.cpu_usages.insert(e, CpuUsage(ticks_consumed: 0),           ecs_tick)
        self.world.nices.insert(e,      Nice(value: clamped_nice),              ecs_tick)
        self.world.classes.insert(e,    SchedClass(kind: sched_kind),           ecs_tick)
        e

    me sched_unregister_task(task: u32) -> bool:
        """Mark a task as inactive (removed from policy). Returns true if found."""
        val e = find_entity_for_task(self.world, task)
        if e.id == 0:
            return false
        if not self.world.task_ids.contains(e):
            return false
        self.world.task_ids.remove(e)
        self.world.priorities.remove(e)
        self.world.cpu_usages.remove(e)
        self.world.nices.remove(e)
        self.world.classes.remove(e)
        self.world.base.despawn(e)
        true

    me sched_record_usage(task: u32, ticks: u64) -> bool:
        """Add ticks to a task's CpuUsage component. Returns true if task found."""
        val e = find_entity_for_task(self.world, task)
        if e.id == 0:
            return false
        val slot = self.world.cpu_usages.get_slot(e)
        if slot < 0:
            return false
        val cur = self.world.cpu_usages.dense[slot].ticks_consumed
        self.world.cpu_usages.insert(e, CpuUsage(ticks_consumed: cur + ticks), self.world.base.now())
        true

    fn sched_recommend_priority(task: u32) -> i32:
        """Return the current Priority.level for a task. Returns -1 if not found."""
        val e = find_entity_for_task(self.world, task)
        if e.id == 0:
            return -1
        val slot = self.world.priorities.get_slot(e)
        if slot < 0:
            return -1
        self.world.priorities.dense[slot].level

    me sched_set_nice(task: u32, nice: i32) -> bool:
        """Update a task's Nice component. Clamps to [-20, 19]. Returns true if found."""
        val clamped = if nice < NICE_MIN: NICE_MIN else: if nice > NICE_MAX: NICE_MAX else: nice
        val e = find_entity_for_task(self.world, task)
        if e.id == 0:
            return false
        if not self.world.nices.contains(e):
            return false
        self.world.nices.insert(e, Nice(value: clamped), self.world.base.now())
        true

    me sched_tick() -> u64:
        """Run policy systems once, advance policy_tick, return it."""
        self.world.base.advance()
        sys_demote_runaway_drivers(self.world)
        sys_age_priorities(self.world)
        self.policy_tick = self.policy_tick + 1
        self.started = true
        self.policy_tick
