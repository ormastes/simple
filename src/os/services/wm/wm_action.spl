# WM action contract shared by service and compositor layers.

# ============================================================================
# WmAction — action request returned by the WM service
# ============================================================================

struct WmAction:
    """An action request parsed from an IPC message.

    The WM service parses IPC messages and returns these action structs.
    The shell applies them to its own compositor, avoiding shared state.
    """
    kind: text           # "create_window", "destroy_window", "focus", "resize",
                         # "move", "set_title", "minimize", "maximize", "restore",
                         # "update_tree", "none"
    window_id: u64
    title: text
    x: i32
    y: i32
    width: i32
    height: i32
    content: text        # for update_tree
    process_id: u64      # owning process identity (launch PID or IPC identity)
    app_id: text         # stable app grouping identifier
    owner_port: u64      # for create_window (remote app's reply port)
    src_port: u64        # sender's port for reply routing

fn wm_action_none() -> WmAction:
    WmAction(kind: "none", window_id: 0, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: 0)

