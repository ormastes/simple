# Window Manager Service — IPC server for multi-process window management
#
# Runs inside the compositor process. Creates a named IPC port "compositor"
# and handles window creation, destruction, focus, resize, move, and
# input event delivery for remote app processes.
#
# The WM service serializes/deserializes window protocol messages and
# returns WmAction structs that the shell applies to its compositor.
#
# Wire protocol:
#   Request:  method (u32) | flags (u32) | payload (bytes)
#   Response: status (i32) | payload (bytes)
#
# Payload encoding per method:
#   COMP_CREATE_WINDOW:  title_len(u32) | title(bytes) | x(i32) | y(i32) | w(i32) | h(i32)
#                        | process_id(u64)? | app_id_len(u32)? | app_id(bytes)?
#   COMP_DESTROY_WINDOW: window_id(u64)
#   COMP_UPDATE_TREE:    window_id(u64) | tree_data(bytes)
#   COMP_FOCUS:          window_id(u64)
#   COMP_RESIZE:         window_id(u64) | width(i32) | height(i32)
#   COMP_MOVE:           window_id(u64) | x(i32) | y(i32)
#   COMP_SET_TITLE:      window_id(u64) | title_len(u32) | title(bytes)
#   COMP_MINIMIZE:       window_id(u64)
#   COMP_MAXIMIZE:       window_id(u64)
#   COMP_RESTORE:        window_id(u64)
#
# Response for COMP_CREATE_WINDOW:
#   status(i32) | window_id(u64)

use os.userlib.ipc_protocol.{COMP_CREATE_WINDOW, COMP_CREATE_WEB_WINDOW, COMP_DESTROY_WINDOW, COMP_UPDATE_TREE, COMP_FOCUS, COMP_RESIZE, COMP_MOVE, COMP_SET_TITLE, COMP_MINIMIZE, COMP_MAXIMIZE, COMP_RESTORE, COMP_INPUT_EVENT, COMP_CLOSE_REQUEST, COMP_FOCUS_CHANGED, COMP_TEST_API_REQ}
use os.userlib.syscall_raw.{syscall}
use common.window_protocol.window_protocol.{WmCreateRequest, WmCreateResponse, WmInputEvent, WmCloseRequest, WmResizeRequest, WmMoveRequest, WmFocusEvent, WM_STATUS_OK, WM_STATUS_ERROR, WM_STATUS_NO_SPACE, WM_EVENT_CLOSE, WM_EVENT_FOCUS, wm_input_event, wm_focus_event}
use os.services.launcher.launcher.{launcher_get_process_app_id_for_pid}
use std.ecs.entity.{Entity, EntityAllocator}
use std.ecs.component_store.{ComponentStore}
use std.ecs.change_detection.{ChangeTracker}
use std.ecs.system.{Scheduler}
use std.ecs.world.{WorldBase}

extern fn serial_println(msg: text)

# Syscall numbers — canonical values from src/os/kernel/ipc/syscall.spl
# dispatcher cases 20..23. Keep in sync with test/unit/os/kernel/ipc/
# syscall_number_consistency_spec.spl.
val SYS_IPC_SEND: u64 = 20
val SYS_IPC_RECV: u64 = 21
val SYS_IPC_CREATE_PORT: u64 = 22
val SYS_IPC_CONNECT: u64 = 23

# Named port identifier for compositor discovery
val WM_PORT_NAME: text = "compositor"

# Maximum windows the WM will track
val WM_MAX_WINDOWS: i32 = 256

# Response status codes
val STATUS_OK: i32 = 0
val STATUS_ERR: i32 = -1
val STATUS_INVALID: i32 = -3

# Window state constants
val WIN_STATE_NORMAL: i32 = 0
val WIN_STATE_MINIMIZED: i32 = 1
val WIN_STATE_MAXIMIZED: i32 = 2

# ============================================================================
# WmAction — action request returned by the WM service
# ============================================================================

struct WmAction:
    """An action request parsed from an IPC message.

    The WM service parses IPC messages and returns these action structs.
    The shell applies them to its own compositor, avoiding shared state.
    """
    kind: text           # "create_window", "destroy_window", "focus", "resize",
                         # "move", "set_title", "minimize", "maximize", "restore",
                         # "update_tree", "none"
    window_id: u64
    title: text
    x: i32
    y: i32
    width: i32
    height: i32
    content: text        # for update_tree
    process_id: u64      # owning process identity (launch PID or IPC identity)
    app_id: text         # stable app grouping identifier
    owner_port: u64      # for create_window (remote app's reply port)
    src_port: u64        # sender's port for reply routing

fn wm_action_none() -> WmAction:
    WmAction(kind: "none", window_id: 0, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: 0)

# ============================================================================
# Window Owner Entry — maps window_id to the owning app's reply port
# and records launch/process metadata for shell queries.
# ============================================================================

struct WindowOwner:
    """Tracks which IPC port owns a given window."""
    window_id: u64
    owner_port: u64
    process_id: u64
    app_id: text

# ============================================================================
# ECS component types
# ============================================================================

struct WinId:
    """ECS component: the u64 window identifier."""
    value: u64

struct OwnerPort:
    """ECS component: the IPC reply port of the owning app."""
    value: u64

struct OwnerProcess:
    """ECS component: the process (PID) that owns this window."""
    value: u64

struct WinAppId:
    """ECS component: the stable app-group identifier string."""
    value: text

struct Title:
    """ECS component: the window title string."""
    value: text

struct Geometry:
    """ECS component: the window rectangle."""
    x: i32
    y: i32
    w: i32
    h: i32

struct WindowState:
    """ECS component: current window state (normal/minimized/maximized)."""
    value: i32

# ============================================================================
# WmWorld — ECS container for window manager state
# ============================================================================

class WmWorld:
    """ECS-based world owning all window component stores."""
    base: WorldBase
    win_ids: ComponentStore<WinId>
    owner_ports: ComponentStore<OwnerPort>
    owner_processes: ComponentStore<OwnerProcess>
    app_ids: ComponentStore<WinAppId>
    titles: ComponentStore<Title>
    geometries: ComponentStore<Geometry>
    states: ComponentStore<WindowState>

impl WmWorld:
    static fn new() -> WmWorld:
        WmWorld(
            # The desktop E2E lane materializes several launcher-backed windows
            # in quick succession. Preallocate entity ids up front so the WM
            # does not have to grow its allocator during that hot path.
            base: WorldBase.with_capacity(WM_MAX_WINDOWS),
            win_ids: ComponentStore.new(),
            owner_ports: ComponentStore.new(),
            owner_processes: ComponentStore.new(),
            app_ids: ComponentStore.new(),
            titles: ComponentStore.new(),
            geometries: ComponentStore.new(),
            states: ComponentStore.new()
        )

    fn find_owner_port(self, window_id: u64) -> u64:
        """Find owner port for a window_id. Returns 0 if not found."""
        var i: i32 = 0
        while i < self.win_ids.len():
            if self.win_ids.dense[i].value == window_id:
                val ent_id = self.win_ids.entity_at(i)
                val e = Entity(id: ent_id, generation: 0)
                val slot = self.owner_ports.get_slot(e)
                if slot >= 0:
                    return self.owner_ports.dense[slot].value
                return 0
            i = i + 1
        0

    fn find_entity_for_window(self, window_id: u64) -> Entity:
        """Find the Entity for a window_id. Returns Entity.null() if not found."""
        var i: i32 = 0
        while i < self.win_ids.len():
            if self.win_ids.dense[i].value == window_id:
                val ent_id = self.win_ids.entity_at(i)
                return Entity(id: ent_id, generation: 0)
            i = i + 1
        Entity.null()

    me spawn_window(window_id: u64, owner_port: u64, process_id: u64, app_id: text):
        """Spawn a new entity and insert all window components."""
        serial_println("[wm-service] spawn-window:start wid={window_id} pid={process_id} app_id={app_id}")
        val e = self.base.spawn()
        # The WM uses these stores as current-state metadata, not as a
        # change-detection stream, so a stable tick is sufficient here.
        val tick: i64 = 0
        self.win_ids.insert(e, WinId(value: window_id), tick)
        serial_println("[wm-service] spawn-window:win-id wid={window_id}")
        self.owner_ports.insert(e, OwnerPort(value: owner_port), tick)
        serial_println("[wm-service] spawn-window:owner-port wid={window_id}")
        self.owner_processes.insert(e, OwnerProcess(value: process_id), tick)
        serial_println("[wm-service] spawn-window:owner-process wid={window_id}")
        self.app_ids.insert(e, WinAppId(value: app_id), tick)
        serial_println("[wm-service] spawn-window:app-id wid={window_id}")
        self.titles.insert(e, Title(value: ""), tick)
        serial_println("[wm-service] spawn-window:title wid={window_id}")
        self.geometries.insert(e, Geometry(x: 0, y: 0, w: 0, h: 0), tick)
        serial_println("[wm-service] spawn-window:geometry wid={window_id}")
        self.states.insert(e, WindowState(value: WIN_STATE_NORMAL), tick)
        serial_println("[wm-service] spawn-window:end wid={window_id}")

    me despawn_window(window_id: u64) -> bool:
        """Despawn the entity for window_id. Returns false if not found."""
        val e = self.find_entity_for_window(window_id)
        if e.is_null():
            return false
        self.win_ids.remove(e)
        self.owner_ports.remove(e)
        self.owner_processes.remove(e)
        self.app_ids.remove(e)
        self.titles.remove(e)
        self.geometries.remove(e)
        self.states.remove(e)
        self.base.despawn(e)
        true

    me despawn_windows_for_port(port: u64) -> [u64]:
        """Despawn all windows owned by port, returning their window_ids."""
        var to_destroy: [u64] = []
        var i: i32 = 0
        while i < self.owner_ports.len():
            if self.owner_ports.dense[i].value == port:
                val ent_id = self.owner_ports.entity_at(i)
                val e = Entity(id: ent_id, generation: 0)
                val wid_slot = self.win_ids.get_slot(e)
                if wid_slot >= 0:
                    to_destroy = to_destroy.push(self.win_ids.dense[wid_slot].value)
            i = i + 1
        var j: i32 = 0
        while j < to_destroy.len():
            self.despawn_window(to_destroy[j])
            j = j + 1
        to_destroy

    fn window_ids_for_port(self, port: u64) -> [u64]:
        var ids: [u64] = []
        var i: i32 = 0
        while i < self.owner_ports.len():
            if self.owner_ports.dense[i].value == port:
                val ent_id = self.owner_ports.entity_at(i)
                val e = Entity(id: ent_id, generation: 0)
                val wid_slot = self.win_ids.get_slot(e)
                if wid_slot >= 0:
                    ids = ids.push(self.win_ids.dense[wid_slot].value)
            i = i + 1
        ids

    fn window_ids_for_process(self, process_id: u64) -> [u64]:
        var ids: [u64] = []
        var i: i32 = 0
        while i < self.owner_processes.len():
            if self.owner_processes.dense[i].value == process_id:
                val ent_id = self.owner_processes.entity_at(i)
                val e = Entity(id: ent_id, generation: 0)
                val wid_slot = self.win_ids.get_slot(e)
                if wid_slot >= 0:
                    ids = ids.push(self.win_ids.dense[wid_slot].value)
            i = i + 1
        ids

    fn window_ids_for_app(self, app_id: text) -> [u64]:
        var ids: [u64] = []
        var i: i32 = 0
        while i < self.app_ids.len():
            if self.app_ids.dense[i].value == app_id:
                val ent_id = self.app_ids.entity_at(i)
                val e = Entity(id: ent_id, generation: 0)
                val wid_slot = self.win_ids.get_slot(e)
                if wid_slot >= 0:
                    ids = ids.push(self.win_ids.dense[wid_slot].value)
            i = i + 1
        ids

    fn process_id_for_window(self, window_id: u64) -> u64:
        val e = self.find_entity_for_window(window_id)
        if e.is_null():
            return 0
        val slot = self.owner_processes.get_slot(e)
        if slot < 0:
            return 0
        self.owner_processes.dense[slot].value

    fn app_id_for_window(self, window_id: u64) -> text:
        val e = self.find_entity_for_window(window_id)
        if e.is_null():
            return ""
        val slot = self.app_ids.get_slot(e)
        if slot < 0:
            return ""
        self.app_ids.dense[slot].value

    fn count_for_port(self, port: u64) -> i32:
        var count: i32 = 0
        var i: i32 = 0
        while i < self.owner_ports.len():
            if self.owner_ports.dense[i].value == port:
                count = count + 1
            i = i + 1
        count

    fn count_for_process(self, process_id: u64) -> i32:
        var count: i32 = 0
        var i: i32 = 0
        while i < self.owner_processes.len():
            if self.owner_processes.dense[i].value == process_id:
                count = count + 1
            i = i + 1
        count

    fn count_for_app(self, app_id: text) -> i32:
        var count: i32 = 0
        var i: i32 = 0
        while i < self.app_ids.len():
            if self.app_ids.dense[i].value == app_id:
                count = count + 1
            i = i + 1
        count

    me set_identity(window_id: u64, process_id: u64, app_id: text):
        """Update process/app identity for an existing window."""
        val e = self.find_entity_for_window(window_id)
        if e.is_null():
            return
        val tick: i64 = 0
        self.owner_processes.insert(e, OwnerProcess(value: process_id), tick)
        self.app_ids.insert(e, WinAppId(value: app_id), tick)

# ============================================================================
# Window Manager Service
# ============================================================================

class WmService:
    """IPC server for multi-process window management.

    Runs inside the compositor process. Creates a named IPC port "compositor"
    and parses incoming IPC requests into WmAction structs.

    Responsibilities:
      - Deserialize IPC messages into WmAction structs
      - Track window ownership (window_id -> owner app's reply port)
      - Send IPC replies to remote apps
      - Deliver input events, close requests, and focus changes to apps

    The shell applies WmActions to its own compositor, avoiding shared
    mutable state between WmService and DesktopShell.
    """
    port_id: u64
    world: WmWorld
    owners: [WindowOwner]
    owner_window_ids: [u64; 256]
    owner_ports_fixed: [u64; 256]
    owner_process_ids: [u64; 256]
    owner_app_ids: [text; 256]
    owner_count: i32
    max_windows: i32
    initialized: bool
    running: bool
    request_count: u64

impl WmService:
    static fn new() -> WmService:
        """Create a new WM service (stateless w.r.t. compositor)."""
        WmService(
            port_id: 0,
            world: WmWorld.new(),
            owners: [],
            owner_window_ids: [0; 256],
            owner_ports_fixed: [0; 256],
            owner_process_ids: [0; 256],
            owner_app_ids: [""; 256],
            owner_count: 0,
            max_windows: WM_MAX_WINDOWS,
            initialized: false,
            running: false,
            request_count: 0
        )

    fn window_count(self) -> i32:
        """Return the total number of tracked windows."""
        self.owner_count

    fn find_owner_index(self, window_id: u64) -> i32:
        var i: i32 = 0
        while i < self.owner_count:
            if self.owner_window_ids[i] == window_id:
                return i
            i = i + 1
        -1

    me upsert_owner(window_id: u64, owner_port: u64, process_id: u64, app_id: text):
        val idx = self.find_owner_index(window_id)
        if idx >= 0:
            self.owner_window_ids[idx] = window_id
            self.owner_ports_fixed[idx] = owner_port
            self.owner_process_ids[idx] = process_id
            self.owner_app_ids[idx] = app_id
            return
        if self.owner_count >= WM_MAX_WINDOWS:
            return
        self.owner_window_ids[self.owner_count] = window_id
        self.owner_ports_fixed[self.owner_count] = owner_port
        self.owner_process_ids[self.owner_count] = process_id
        self.owner_app_ids[self.owner_count] = app_id
        self.owner_count = self.owner_count + 1

    # -- Lifecycle -----------------------------------------------------------

    me init() -> bool:
        """Create named IPC port "compositor" and prepare for requests.

        The port is registered with the name "compositor" so remote apps
        can discover it via SYS_IPC_CONNECT("compositor").

        Returns true on success, false if port creation fails.
        """
        # Pass the name pointer and length so the kernel registers a named port.
        # SYS_IPC_CREATE_PORT(name_ptr, name_len, 0, 0, 0) -> port_id
        extern fn unsafe_addr_of(ref: any) -> u64
        val name_ptr = unsafe_addr_of(WM_PORT_NAME)
        val name_len = WM_PORT_NAME.len().to_u64()
        val port = syscall(SYS_IPC_CREATE_PORT, name_ptr, name_len, 0, 0, 0)
        if port < 0:
            serial_println("[wm-service] Failed to create IPC port (error {port})")
            return false
        self.port_id = port.to_u64()
        self.initialized = true
        serial_println("[wm-service] Listening on IPC port {self.port_id} as '{WM_PORT_NAME}'")
        true

    me run_loop():
        """Main service loop (blocking). Prefer poll_once() in shell integration.

        WARNING: This blocking loop cannot return WmActions to the caller.
        It is retained for standalone WM service usage only. In the shell
        integration pattern, use poll_once() which returns WmAction?.
        """
        if not self.initialized:
            serial_println("[wm-service] Cannot run: not initialized")
            return
        self.running = true
        serial_println("[wm-service] Service loop started (blocking mode)")
        while self.running:
            # Receive IPC message -- blocks until message arrives
            val msg_raw = syscall(SYS_IPC_RECV, self.port_id, 0, 0, 0, 0)
            if msg_raw < 0:
                serial_println("[wm-service] IPC recv error: {msg_raw}")
                continue
            self.request_count = self.request_count + 1
            # In blocking mode, parse and discard (no compositor to apply to)
            val _action = self.parse_message(msg_raw.to_u64())

    me poll_once() -> WmAction?:
        """Non-blocking poll: parse one IPC message and return it as a WmAction.

        Used when the WM service is integrated into the shell's main loop.
        The caller (DesktopShell) applies the returned action to its own
        compositor, ensuring a single source of truth for compositor state.

        Returns nil if no message is pending or the service is not initialized.

        SYS_IPC_RECV args: (port_id, timeout_ms, flags, 0, 0)
        timeout_ms = 0 means non-blocking (return immediately if no message).
        flags bit 0 = 1 means non-blocking poll.
        """
        if not self.initialized:
            return nil
        # Non-blocking recv: timeout = 0, flags = 1 (poll mode)
        val msg_raw = syscall(SYS_IPC_RECV, self.port_id, 0, 1, 0, 0)
        if msg_raw <= 0:
            return nil
        self.request_count = self.request_count + 1
        return self.parse_message(msg_raw.to_u64())

    me stop():
        """Signal the service loop to exit."""
        self.running = false
        serial_println("[wm-service] Stopped after {self.request_count} requests")

    # -- Message Parsing ------------------------------------------------------

    me parse_message(msg_addr: u64) -> WmAction:
        """Parse an IPC message header and return the corresponding WmAction.

        IPC message layout: src_port(8) | dst_port(8) | method(4) | flags(4) | payload_len(4) | cap_count(4)
        Payload starts at msg_addr + 32.
        """
        val src_port = _read_u64(msg_addr)
        val method = _read_u32(msg_addr + 16)
        val payload_len = _read_u32(msg_addr + 24)
        val payload_addr = msg_addr + 32

        match method:
            COMP_CREATE_WINDOW:
                return self.parse_create_window(src_port, payload_addr, payload_len)
            COMP_CREATE_WEB_WINDOW:
                return self.parse_create_web_window(src_port, payload_addr, payload_len)
            COMP_DESTROY_WINDOW:
                return self.parse_destroy_window(src_port, payload_addr, payload_len)
            COMP_UPDATE_TREE:
                return self.parse_update_tree(src_port, payload_addr, payload_len)
            COMP_FOCUS:
                return self.parse_focus(src_port, payload_addr, payload_len)
            COMP_RESIZE:
                return self.parse_resize(src_port, payload_addr, payload_len)
            COMP_MOVE:
                return self.parse_move(src_port, payload_addr, payload_len)
            COMP_SET_TITLE:
                return self.parse_set_title(src_port, payload_addr, payload_len)
            COMP_MINIMIZE:
                return self.parse_minimize(src_port, payload_addr, payload_len)
            COMP_MAXIMIZE:
                return self.parse_maximize(src_port, payload_addr, payload_len)
            COMP_RESTORE:
                return self.parse_restore(src_port, payload_addr, payload_len)
            COMP_TEST_API_REQ:
                return self.parse_test_api_req(src_port, payload_addr, payload_len)
            _:
                serial_println("[wm-service] Unknown method {method} from port {src_port}")
                self.send_error_reply(src_port, STATUS_INVALID, "unknown compositor method")
                return wm_action_none()

    me parse_test_api_req(src_port: u64, payload_addr: u64, payload_len: u32) -> WmAction:
        """Bridge the shared /api/test/* LLM-friendly surface into SimpleOS.
        Wave 7: in-kernel routing to handle_test_request against the
        focused window's UISession is reserved. Today the compositor
        replies with STATUS_INVALID and a pointer to the host-socket
        embedding so callers degrade cleanly instead of hanging.
        Protocol contract is fixed — see COMP_TEST_API_REQ in
        src/os/userlib/ipc_protocol.spl."""
        serial_println("[wm-service] COMP_TEST_API_REQ received (payload_len={payload_len}); in-kernel bridge not yet wired")
        self.send_error_reply(src_port, STATUS_INVALID, "COMP_TEST_API_REQ: use host-side /api/test/* socket until Wave 7 kernel bridge lands")
        return wm_action_none()

    # -- Request Parsers (return WmAction) ------------------------------------

    me parse_create_window(src_port: u64, payload_addr: u64, payload_len: u32) -> WmAction:
        """Parse COMP_CREATE_WINDOW into a WmAction.

        Payload: title_len(u32) | title(bytes) | x(i32) | y(i32) | w(i32) | h(i32)
                 | process_id(u64)? | app_id_len(u32)? | app_id(bytes)?
        """
        if self.world.win_ids.len() >= self.max_windows:
            serial_println("[wm-service] Max windows reached, rejecting create")
            self.send_create_response(src_port, WindowId(value: 0), WM_STATUS_NO_SPACE)
            return wm_action_none()

        # Parse title
        val title_len = _read_u32(payload_addr)
        val title = _read_text(payload_addr + 4, title_len)
        val fields_offset = 4 + title_len.to_u64()

        # Parse position and size
        val x = _read_i32(payload_addr + fields_offset)
        val y = _read_i32(payload_addr + fields_offset + 4)
        val w = _read_i32(payload_addr + fields_offset + 8)
        val h = _read_i32(payload_addr + fields_offset + 12)
        var process_id = src_port
        var app_id = ""
        val identity_offset = fields_offset + 16
        if payload_len.to_u64() >= identity_offset + 8:
            process_id = _read_u64(payload_addr + identity_offset)
            if payload_len.to_u64() >= identity_offset + 12:
                val app_id_len = _read_u32(payload_addr + identity_offset + 8)
                if app_id_len > 0 and payload_len.to_u64() >= identity_offset + 12 + app_id_len.to_u64():
                    app_id = _read_text(payload_addr + identity_offset + 12, app_id_len)
        if process_id == 0:
            process_id = src_port
        if app_id == "":
            val launcher_app_id = launcher_get_process_app_id_for_pid(process_id)
            if launcher_app_id != "":
                app_id = launcher_app_id
            else:
                app_id = title

        serial_println("[wm-service] Parsed create_window from port {src_port}: '{title}' ({w}x{h}) pid={process_id} app_id='{app_id}'")
        WmAction(kind: "create_window", window_id: 0, title: title, x: x, y: y, width: w, height: h, content: "", process_id: process_id, app_id: app_id, owner_port: src_port, src_port: src_port)

    me parse_create_web_window(src_port: u64, payload_addr: u64, payload_len: u32) -> WmAction:
        """Parse COMP_CREATE_WEB_WINDOW into a WmAction.

        Payload: url_len(u32) | url(bytes) | x(i32) | y(i32) | w(i32) | h(i32)

        The URL is stashed in WmAction.content so the apply side can route
        the window to the Simple Web Engine rect renderer; title defaults
        to the URL, app_id falls back to the launcher's record for src_port.
        """
        if self.world.win_ids.len() >= self.max_windows:
            serial_println("[wm-service] Max windows reached, rejecting create_web")
            self.send_create_response(src_port, WindowId(value: 0), WM_STATUS_NO_SPACE)
            return wm_action_none()

        val url_len = _read_u32(payload_addr)
        val url = _read_text(payload_addr + 4, url_len)
        val fields_offset = 4 + url_len.to_u64()
        val x = _read_i32(payload_addr + fields_offset)
        val y = _read_i32(payload_addr + fields_offset + 4)
        val w = _read_i32(payload_addr + fields_offset + 8)
        val h = _read_i32(payload_addr + fields_offset + 12)

        var process_id = src_port
        var app_id = launcher_get_process_app_id_for_pid(process_id)
        if app_id == "":
            app_id = url

        serial_println("[wm-service] Parsed create_web_window from port {src_port}: '{url}' ({w}x{h}) pid={process_id}")
        WmAction(kind: "create_web_window", window_id: 0, title: url, x: x, y: y, width: w, height: h, content: url, process_id: process_id, app_id: app_id, owner_port: src_port, src_port: src_port)

    me parse_destroy_window(src_port: u64, payload_addr: u64, payload_len: u32) -> WmAction:
        """Parse COMP_DESTROY_WINDOW into a WmAction.

        Payload: window_id(u64)
        """
        val window_id = _read_u64(payload_addr)

        # Verify ownership
        val owner = self.find_owner(window_id)
        if owner == 0 or owner != src_port:
            serial_println("[wm-service] Destroy denied: port {src_port} does not own window {window_id}")
            self.send_status_reply(src_port, STATUS_ERR)
            return wm_action_none()

        WmAction(kind: "destroy_window", window_id: window_id, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)

    me parse_update_tree(src_port: u64, payload_addr: u64, payload_len: u32) -> WmAction:
        """Parse COMP_UPDATE_TREE into a WmAction.

        Payload: window_id(u64) | content_len(u32) | content_text(bytes)
        """
        val window_id = _read_u64(payload_addr)
        val owner = self.find_owner(window_id)
        if owner == 0 or owner != src_port:
            self.send_status_reply(src_port, STATUS_ERR)
            return wm_action_none()
        # Read content text from payload
        val content_len = _read_u32(payload_addr + 8).to_i32()
        var content: text = ""
        if content_len > 0 and payload_len.to_i32() >= 12 + content_len:
            content = _read_text(payload_addr + 12, content_len.to_u32())

        WmAction(kind: "update_tree", window_id: window_id, title: "", x: 0, y: 0, width: 0, height: 0, content: content, process_id: 0, app_id: "", owner_port: 0, src_port: src_port)

    fn parse_focus(src_port: u64, payload_addr: u64, payload_len: u32) -> WmAction:
        """Parse COMP_FOCUS into a WmAction.

        Payload: window_id(u64)
        """
        val window_id = _read_u64(payload_addr)
        WmAction(kind: "focus", window_id: window_id, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)

    me parse_resize(src_port: u64, payload_addr: u64, payload_len: u32) -> WmAction:
        """Parse COMP_RESIZE into a WmAction.

        Payload: window_id(u64) | width(i32) | height(i32)
        """
        val window_id = _read_u64(payload_addr)
        val width = _read_i32(payload_addr + 8)
        val height = _read_i32(payload_addr + 12)

        val owner = self.find_owner(window_id)
        if owner == 0 or owner != src_port:
            self.send_status_reply(src_port, STATUS_ERR)
            return wm_action_none()

        WmAction(kind: "resize", window_id: window_id, title: "", x: 0, y: 0, width: width, height: height, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)

    me parse_move(src_port: u64, payload_addr: u64, payload_len: u32) -> WmAction:
        """Parse COMP_MOVE into a WmAction.

        Payload: window_id(u64) | x(i32) | y(i32)
        """
        val window_id = _read_u64(payload_addr)
        val x = _read_i32(payload_addr + 8)
        val y = _read_i32(payload_addr + 12)

        val owner = self.find_owner(window_id)
        if owner == 0 or owner != src_port:
            self.send_status_reply(src_port, STATUS_ERR)
            return wm_action_none()

        WmAction(kind: "move", window_id: window_id, title: "", x: x, y: y, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)

    me parse_set_title(src_port: u64, payload_addr: u64, payload_len: u32) -> WmAction:
        """Parse COMP_SET_TITLE into a WmAction.

        Payload: window_id(u64) | title_len(u32) | title(bytes)
        """
        val window_id = _read_u64(payload_addr)
        val title_len = _read_u32(payload_addr + 8)
        val title = _read_text(payload_addr + 12, title_len)

        val owner = self.find_owner(window_id)
        if owner == 0 or owner != src_port:
            self.send_status_reply(src_port, STATUS_ERR)
            return wm_action_none()

        # Touch the title component to record change detection tick
        val e = self.world.find_entity_for_window(window_id)
        if not e.is_null():
            self.world.titles.touch(e, self.world.base.now())

        WmAction(kind: "set_title", window_id: window_id, title: title, x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)

    me parse_minimize(src_port: u64, payload_addr: u64, payload_len: u32) -> WmAction:
        """Parse COMP_MINIMIZE into a WmAction.

        Payload: window_id(u64)
        """
        val window_id = _read_u64(payload_addr)
        val owner = self.find_owner(window_id)
        if owner == 0 or owner != src_port:
            self.send_status_reply(src_port, STATUS_ERR)
            return wm_action_none()

        val e = self.world.find_entity_for_window(window_id)
        if not e.is_null():
            self.world.states.insert(e, WindowState(value: WIN_STATE_MINIMIZED), self.world.base.now())

        WmAction(kind: "minimize", window_id: window_id, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)

    me parse_maximize(src_port: u64, payload_addr: u64, payload_len: u32) -> WmAction:
        """Parse COMP_MAXIMIZE into a WmAction.

        Payload: window_id(u64)
        """
        val window_id = _read_u64(payload_addr)
        val owner = self.find_owner(window_id)
        if owner == 0 or owner != src_port:
            self.send_status_reply(src_port, STATUS_ERR)
            return wm_action_none()

        val e = self.world.find_entity_for_window(window_id)
        if not e.is_null():
            self.world.states.insert(e, WindowState(value: WIN_STATE_MAXIMIZED), self.world.base.now())

        WmAction(kind: "maximize", window_id: window_id, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)

    me parse_restore(src_port: u64, payload_addr: u64, payload_len: u32) -> WmAction:
        """Parse COMP_RESTORE into a WmAction.

        Payload: window_id(u64)
        """
        val window_id = _read_u64(payload_addr)
        val owner = self.find_owner(window_id)
        if owner == 0 or owner != src_port:
            self.send_status_reply(src_port, STATUS_ERR)
            return wm_action_none()

        val e = self.world.find_entity_for_window(window_id)
        if not e.is_null():
            self.world.states.insert(e, WindowState(value: WIN_STATE_NORMAL), self.world.base.now())

        WmAction(kind: "restore", window_id: window_id, title: "", x: 0, y: 0, width: 0, height: 0, content: "", process_id: 0, app_id: "", owner_port: 0, src_port: src_port)

    # -- Outbound Event Delivery ---------------------------------------------

    me send_input_to_owner(window_id: u64, event: WmInputEvent):
        """Send an input event to the app that owns this window via IPC.

        Called by the compositor when a remote window receives input.
        Encodes the WmInputEvent as:
          method(u32=COMP_INPUT_EVENT) | window_id(u64) | event_type(u32) |
          key_code(u32) | mouse_x(i32) | mouse_y(i32) | modifiers(u32)
        """
        val owner = self.find_owner(window_id)
        if owner == 0:
            return

        var buf: [u8] = []
        # Method header
        _push_u32(buf, COMP_INPUT_EVENT)
        # Event payload
        _push_u64(buf, event.window_id)
        _push_u32(buf, event.event_type)
        _push_u32(buf, event.key_code)
        _push_i32(buf, event.mouse_x)
        _push_i32(buf, event.mouse_y)
        _push_u32(buf, event.modifiers)
        _ipc_send(owner, self.port_id, buf)

    me send_close_request(window_id: u64):
        """Send a close request to the app that owns this window.

        Called when the user clicks the close button or presses Alt+F4
        on a remote window. The app should clean up and respond with
        COMP_DESTROY_WINDOW.
        """
        val owner = self.find_owner(window_id)
        if owner == 0:
            return

        var buf: [u8] = []
        _push_u32(buf, COMP_CLOSE_REQUEST)
        _push_u64(buf, window_id)
        _ipc_send(owner, self.port_id, buf)
        serial_println("[wm-service] Sent close request for window {window_id} to port {owner}")

    me send_focus_changed(window_id: u64, focused: bool):
        """Notify the app that a window gained or lost focus.

        Sent when the compositor changes focus between windows, so apps
        can update their visual state (e.g., cursor blink, selection highlight).
        """
        val owner = self.find_owner(window_id)
        if owner == 0:
            return

        var buf: [u8] = []
        _push_u32(buf, COMP_FOCUS_CHANGED)
        _push_u64(buf, window_id)
        val focused_byte: u8 = if focused: 1 else: 0
        buf.push(focused_byte)
        _ipc_send(owner, self.port_id, buf)

    fn send_input_to_port(dst_port: u64, event: WmInputEvent):
        """Send an input event to a specific IPC port.

        Called by the shell to deliver input events to remote app windows.
        The shell owns the compositor and drains pending_remote_events itself.
        """
        var buf: [u8] = []
        # Method header
        _push_u32(buf, COMP_INPUT_EVENT)
        # Event payload
        _push_u64(buf, event.window_id)
        _push_u32(buf, event.event_type)
        _push_u32(buf, event.key_code)
        _push_i32(buf, event.mouse_x)
        _push_i32(buf, event.mouse_y)
        _push_u32(buf, event.modifiers)
        _ipc_send(dst_port, self.port_id, buf)

    # -- Ownership Tracking --------------------------------------------------

    fn find_owner(window_id: u64) -> u64:
        """Look up the owner port for a window. Returns 0 if not found."""
        val idx = self.find_owner_index(window_id)
        if idx < 0:
            return 0
        self.owner_ports_fixed[idx]

    me remove_owner(window_id: u64):
        """Remove ownership tracking for a window."""
        val idx = self.find_owner_index(window_id)
        if idx < 0:
            return
        val last = self.owner_count - 1
        if idx != last:
            self.owner_window_ids[idx] = self.owner_window_ids[last]
            self.owner_ports_fixed[idx] = self.owner_ports_fixed[last]
            self.owner_process_ids[idx] = self.owner_process_ids[last]
            self.owner_app_ids[idx] = self.owner_app_ids[last]
        self.owner_window_ids[last] = 0
        self.owner_ports_fixed[last] = 0
        self.owner_process_ids[last] = 0
        self.owner_app_ids[last] = ""
        self.owner_count = self.owner_count - 1

    me remove_all_windows_for_port(port: u64) -> [u64]:
        """Remove all ownership entries for a disconnected port.

        Returns the list of window IDs that were owned by the port.
        The caller (shell) is responsible for destroying these windows
        on its compositor.
        """
        var to_destroy: [u64] = []
        var i: i32 = 0
        while i < self.owner_count:
            if self.owner_ports_fixed[i] == port:
                to_destroy = to_destroy.push(self.owner_window_ids[i])
            i = i + 1
        for window_id in to_destroy:
            self.remove_owner(window_id)
        for window_id in to_destroy:
            serial_println("[wm-service] Cleaned up ownership of window {window_id} for disconnected port {port}")
        to_destroy

    fn window_owner_process_id(window_id: u64) -> u64:
        val idx = self.find_owner_index(window_id)
        if idx < 0:
            return 0
        self.owner_process_ids[idx]

    fn window_owner_app_id(window_id: u64) -> text:
        val idx = self.find_owner_index(window_id)
        if idx < 0:
            return ""
        self.owner_app_ids[idx]

    fn window_ids_for_owner_port(port: u64) -> [u64]:
        var ids: [u64] = []
        var i: i32 = 0
        while i < self.owner_count:
            if self.owner_ports_fixed[i] == port:
                ids = ids.push(self.owner_window_ids[i])
            i = i + 1
        ids

    fn window_ids_for_process(process_id: u64) -> [u64]:
        var ids: [u64] = []
        var i: i32 = 0
        while i < self.owner_count:
            if self.owner_process_ids[i] == process_id:
                ids = ids.push(self.owner_window_ids[i])
            i = i + 1
        ids

    fn window_ids_for_app(app_id: text) -> [u64]:
        var ids: [u64] = []
        var i: i32 = 0
        while i < self.owner_count:
            if self.owner_app_ids[i] == app_id:
                ids = ids.push(self.owner_window_ids[i])
            i = i + 1
        ids

    fn window_count_for_owner_port(port: u64) -> i32:
        self.window_ids_for_owner_port(port).len() as i32

    fn window_count_for_process(process_id: u64) -> i32:
        self.window_ids_for_process(process_id).len() as i32

    fn window_count_for_app(app_id: text) -> i32:
        self.window_ids_for_app(app_id).len() as i32

    # -- Shell Integration (called by DesktopShell after applying actions) ----

    me register_window_owner(window_id: WindowId, owner_port: u64):
        """Register ownership of a window after the shell creates it.

        Called by the shell after it calls compositor.create_remote_window()
        and obtains the window_id.
        """
        self.upsert_owner(window_id.value, owner_port, owner_port, "")

    me register_window_owner_with_identity(window_id: WindowId, owner_port: u64, process_id: u64, app_id: text):
        """Register ownership plus launch identity metadata."""
        self.upsert_owner(window_id.value, owner_port, process_id, app_id)

    me set_window_owner_identity(window_id: WindowId, process_id: u64, app_id: text):
        """Update the identity metadata for an already-owned window."""
        val idx = self.find_owner_index(window_id.value)
        if idx < 0:
            self.upsert_owner(window_id.value, 0, process_id, app_id)
            return
        self.owner_process_ids[idx] = process_id
        self.owner_app_ids[idx] = app_id

    fn send_create_reply(dst_port: u64, window_id: WindowId):
        """Send a successful create-window reply with the new window ID.

        Called by the shell after creating the window on its compositor.
        """
        var buf: [u8] = []
        _push_i32(buf, WM_STATUS_OK.value)
        _push_u64(buf, window_id.value)
        _ipc_send(dst_port, self.port_id, buf)

    # -- Reply Helpers -------------------------------------------------------

    fn send_create_response(dst_port: u64, window_id: WindowId, status: WmStatus):
        """Send a COMP_CREATE_WINDOW response: status(i32) | window_id(u64)."""
        var buf: [u8] = []
        _push_i32(buf, status.value)
        _push_u64(buf, window_id.value)
        _ipc_send(dst_port, self.port_id, buf)

    fn send_status_reply(dst_port: u64, status: i32):
        """Send a simple status-only reply."""
        var buf: [u8] = []
        _push_i32(buf, status)
        _ipc_send(dst_port, self.port_id, buf)

    fn send_error_reply(dst_port: u64, status: i32, msg: text):
        """Send an error reply with status + error message."""
        var buf: [u8] = []
        _push_i32(buf, status)
        for ch in msg:
            buf.push(ch.to_u8())
        _ipc_send(dst_port, self.port_id, buf)

    # -- Queries -------------------------------------------------------------

    fn stats() -> text:
        """Return service statistics as text."""
        "WmService: port={self.port_id}, windows={self.world.win_ids.len()}, requests={self.request_count}, running={self.running}"

    fn is_initialized() -> bool:
        self.initialized

    me notify_app_launched(app_name: text, pid: u64):
        """Create a managed window entry for a newly launched app.

        Called by the launcher after posix_spawn succeeds.  Creates a
        placeholder window ownership record so the WM is aware of the
        app before the app's own IPC connect arrives.
        """
        serial_println("[wm-service] App launched: {app_name} (PID {pid})")
        # The actual window surface will be created when the app sends
        # COMP_CREATE_WINDOW via IPC.  Record the PID so we can match
        # the connect request to this launch notification later.
        pass_dn

# ============================================================================
# Standalone helper — callable without a WmService instance
# ============================================================================

fn wm_notify_app_launched(app_name: text, pid: u64):
    """Notify that an app was launched (standalone convenience wrapper).

    Logs the launch event to serial. The WM service will associate the
    PID with a window when the app connects via IPC and sends
    COMP_CREATE_WINDOW.
    """
    serial_println("[wm] App launched: {app_name} (PID {pid})")

# ============================================================================
# Memory Access Helpers
# ============================================================================

extern fn mmio_read8(addr: u64) -> u8
extern fn mmio_read16(addr: u64) -> u16
extern fn mmio_read32(addr: u64) -> u32
extern fn mmio_read64(addr: u64) -> u64

fn _read_u8(addr: u64) -> u8:
    mmio_read8(addr)

fn _read_u32(addr: u64) -> u32:
    mmio_read32(addr)

fn _read_u64(addr: u64) -> u64:
    mmio_read64(addr)

fn _read_i32(addr: u64) -> i32:
    mmio_read32(addr).to_i32()

fn _read_text(addr: u64, len: u32) -> text:
    """Read a text string from memory."""
    var result = ""
    var i: u32 = 0
    while i < len:
        val ch = mmio_read8(addr + i.to_u64())
        if ch == 0:
            return result
        result = result + ch.to_char()
        i = i + 1
    result

# ============================================================================
# Serialization Helpers
# ============================================================================

fn _push_u32(buf: [u8], val: u32):
    buf.push((val & 0xFF).to_u8())
    buf.push(((val >> 8) & 0xFF).to_u8())
    buf.push(((val >> 16) & 0xFF).to_u8())
    buf.push(((val >> 24) & 0xFF).to_u8())

fn _push_i32(buf: [u8], val: i32):
    val u = val.to_u32()
    buf.push((u & 0xFF).to_u8())
    buf.push(((u >> 8) & 0xFF).to_u8())
    buf.push(((u >> 16) & 0xFF).to_u8())
    buf.push(((u >> 24) & 0xFF).to_u8())

fn _push_u64(buf: [u8], val: u64):
    buf.push((val & 0xFF).to_u8())
    buf.push(((val >> 8) & 0xFF).to_u8())
    buf.push(((val >> 16) & 0xFF).to_u8())
    buf.push(((val >> 24) & 0xFF).to_u8())
    buf.push(((val >> 32) & 0xFF).to_u8())
    buf.push(((val >> 40) & 0xFF).to_u8())
    buf.push(((val >> 48) & 0xFF).to_u8())
    buf.push(((val >> 56) & 0xFF).to_u8())

# ============================================================================
# IPC Send Helper
# ============================================================================

fn _ipc_send(dst_port: u64, src_port: u64, data: [u8]):
    """Send reply data via IPC syscall.

    Encodes the data into a buffer and issues SYS_IPC_SEND = 20
    (kernel dispatcher case 20, _handle_ipc_send).
    """
    extern fn unsafe_addr_of(ref: any) -> u64
    val data_ptr = unsafe_addr_of(data)
    val data_len = data.len().to_u64()
    syscall(SYS_IPC_SEND, dst_port, src_port, data_ptr, data_len, 0)
