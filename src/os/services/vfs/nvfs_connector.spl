    if /* complex expr */:
        return Err(/* complex expr */)
    val rel = /* complex expr */
    var driver = conn.driver
    val open_r = /* complex expr */
    if /* complex expr */:
        _log_error(/* complex expr */)
        return Err(/* complex expr */)
    val handle = /* complex expr */
    val trunc_r = /* complex expr */
    if /* complex expr */:
        /* complex expr */
        _log_error(/* complex expr */)
        return Err(/* complex expr */)
    val buf = rt_text_to_bytes(content)
    val write_r = /* complex expr */
    /* complex expr */
    if /* complex expr */:
        _log_error(/* complex expr */)
        return Err(/* complex expr */)
    Ok(())

fn nvfs_vfs_read_bytes(conn: NvfsVfsConnection, path: text) -> Result<[u8], FsError>:
    "Read a complete file as bytes through the NVFS connection."
    val rel_r = _nvfs_relpath(conn, path)
