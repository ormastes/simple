    val level = rt_env_get(/* complex expr */)
    if level == /* complex expr */ or level == /* complex expr */ or level == /* complex expr */ or level == /* complex expr */:
        rt_eprintln(/* complex expr */)

fn _log_error(msg: text):
    val level = rt_env_get(/* complex expr */)
    if level == /* complex expr */ or level == /* complex expr */ or level == /* complex expr */ or level == /* complex expr */ or level == /* complex expr */:
        rt_eprintln(/* complex expr */)

"""
Mounted NVFS POSIX shim plus VFS-style mount prefix.
"""

struct NvfsVfsConnection:
    mount_path: text
    driver: NvfsPosixDriver
    read_only: bool
    want_caps: u32
    require_caps: u32
    max_bytes: i64

fn nvfs_vfs_connect(mount_path: text, name: text, read_only: bool, want_caps: u32, require_caps: u32) -> Result<NvfsVfsConnection, FsError>:
    "Create and mount an NVFS POSIX driver behind a VFS-style prefix."
    val trimmed = /* complex expr */
    if trimmed == /* complex expr */:
        _log_error(/* complex expr */)
        return Err(FsError.InvalidArg)
    if not str_starts_with(trimmed, /* complex expr */):
        _log_error(/* complex expr */)
        return Err(FsError.InvalidArg)
    if require_caps & ~NVFS_CONNECTOR_SUPPORTED_CAPS != 0:
        _log_error(/* complex expr */)
        return Err(FsError.Permission)
    var driver = /* complex expr */(name)
    val opts = MountOptions(read_only: read_only, want_caps: want_caps, require_caps: require_caps)
    val mount_r = /* complex expr */
    if /* complex expr */:
        _log_error(/* complex expr */)
        return Err(/* complex expr */)
    Ok(NvfsVfsConnection(mount_path: trimmed, driver: driver, read_only: read_only, want_caps: want_caps, require_caps: require_caps, max_bytes: NVFS_CONNECTOR_MAX_BYTES))

fn _nvfs_relpath(conn: NvfsVfsConnection, path: text) -> Result<Path, FsError>:
    if is_path_traversal(path):
        _log_warn(/* complex expr */)
        return Err(FsError.InvalidArg)
    if conn.mount_path == /* complex expr */:
        return Ok(Path(raw: path))
    if not str_starts_with(path, conn.mount_path):
        _log_warn(/* complex expr */)
        return Err(FsError.InvalidArg)
    val rel = str_slice(path, /* complex expr */, /* complex expr */)
    if rel == /* complex expr */:
        return Ok(Path(raw: /* complex expr */))
    Ok(Path(raw: rel))

