"""NVFS connector for service-level VFS path semantics.

This module deliberately stays separate from `vfs_init.spl` so x86_64 boot
does not link the examples NVFS implementation into the freestanding kernel.
"""

use std.fs_driver.ops.{FsDriver}
use std.fs_driver.types.{Path, MountOptions, OpenFlags}
use std.fs_driver.error.{FsError}
use common.string_core.{str_starts_with, str_slice}
use common.security.sanitize.{is_path_traversal}
use examples.nvfs.src.posix.fs_driver_impl.{NvfsPosixDriver}

extern fn rt_env_get(key: text) -> text
extern fn rt_eprintln(s: text)
extern fn rt_text_to_bytes(s: text) -> [u8]
extern fn rt_bytes_to_text(data: [u8]) -> text

val NVFS_CONNECTOR_MAX_BYTES: i64 = 16777216   # 16 MiB

# Caps the in-memory POSIX driver can actually satisfy.
# Any bit set in require_caps that is absent here triggers Permission.
val NVFS_CONNECTOR_SUPPORTED_CAPS: u32 = 0x0F

fn _log_warn(msg: text):
    val level = rt_env_get("SIMPLE_LOG")
    if (level == "warn" or level == "info" or
        level == "debug" or level == "trace"):
        rt_eprintln("[WARN] nvfs_connector: {msg}")

fn _log_error(msg: text):
    val level = rt_env_get("SIMPLE_LOG")
    if (level == "error" or level == "warn" or level == "info" or
        level == "debug" or level == "trace"):
        rt_eprintln("[ERROR] nvfs_connector: {msg}")

struct NvfsVfsConnection:
    """Mounted NVFS POSIX shim plus VFS-style mount prefix."""
    mount_path:  text
    driver:      NvfsPosixDriver
    read_only:   bool
    want_caps:   u32
    require_caps: u32
    max_bytes:   i64

fn nvfs_vfs_connect(
    mount_path:  text,
    name:        text,
    read_only:   bool,
    want_caps:   u32,
    require_caps: u32
) -> Result<NvfsVfsConnection, FsError>:
    """Create and mount an NVFS POSIX driver behind a VFS-style prefix."""
    val trimmed = mount_path.trim()
    if trimmed == "":
        _log_error("mount rejected: empty mount path")
        return Err(FsError.InvalidArg)
    if not str_starts_with(trimmed, "/"):
        _log_error("mount rejected: non-absolute mount path '{trimmed}'")
        return Err(FsError.InvalidArg)
    # Reject require_caps bits the in-memory driver cannot satisfy.
    if (require_caps & ~NVFS_CONNECTOR_SUPPORTED_CAPS) != 0:
        _log_error("mount rejected: unsatisfiable require_caps 0x{require_caps}")
        return Err(FsError.Permission)
    var driver = NvfsPosixDriver.new(name)
    val opts = MountOptions(read_only: read_only, want_caps: want_caps, require_caps: require_caps)
    val mount_r = driver.mount(opts)
    if mount_r.is_err():
        _log_error("driver.mount failed for '{trimmed}'")
        return Err(mount_r.unwrap_err())
    Ok(NvfsVfsConnection(
        mount_path:  trimmed,
        driver:      driver,
        read_only:   read_only,
        want_caps:   want_caps,
        require_caps: require_caps,
        max_bytes:   NVFS_CONNECTOR_MAX_BYTES
    ))

fn _nvfs_relpath(conn: NvfsVfsConnection, path: text) -> Result<Path, FsError>:
    if is_path_traversal(path):
        _log_warn("traversal rejected: '{path}'")
        return Err(FsError.InvalidArg)
    if conn.mount_path == "/":
        return Ok(Path(raw: path))
    if not str_starts_with(path, conn.mount_path):
        _log_warn("path outside mount prefix: '{path}' not under '{conn.mount_path}'")
        return Err(FsError.InvalidArg)
    val rel = str_slice(path, conn.mount_path.len(), path.len())
    if rel == "":
        return Ok(Path(raw: "/"))
    Ok(Path(raw: rel))

fn nvfs_vfs_write_text(conn: NvfsVfsConnection, path: text, content: text) -> Result<(), FsError>:
    """Write a complete text file through the NVFS connection."""
    if conn.read_only:
        _log_warn("write rejected on read-only connection: '{path}'")
        return Err(FsError.Permission)
    if content.len() > conn.max_bytes:
        _log_warn("write rejected: content size {content.len()} > max {conn.max_bytes}")
        return Err(FsError.TooLarge)
    val rel_r = _nvfs_relpath(conn, path)
    if rel_r.is_err():
        return Err(rel_r.unwrap_err())
    val rel = rel_r.unwrap()
    var driver = conn.driver
    val open_r = driver.open(rel, OpenFlags.read_write().with_create())
    if open_r.is_err():
        _log_error("open failed for '{path}'")
        return Err(open_r.unwrap_err())
    val handle = open_r.unwrap()
    val trunc_r = driver.ftruncate(handle, 0)
    if trunc_r.is_err():
        driver.close(handle)
        _log_error("ftruncate failed for '{path}'")
        return Err(trunc_r.unwrap_err())
    val buf = rt_text_to_bytes(content)
    val write_r = driver.write(handle, 0, buf)
    driver.close(handle)
    if write_r.is_err():
        _log_error("write failed for '{path}'")
        return Err(write_r.unwrap_err())
    Ok(())

fn nvfs_vfs_read_bytes(conn: NvfsVfsConnection, path: text) -> Result<[u8], FsError>:
    """Read a complete file as bytes through the NVFS connection."""
    val rel_r = _nvfs_relpath(conn, path)
    if rel_r.is_err():
        return Err(rel_r.unwrap_err())
    val rel = rel_r.unwrap()
    var driver = conn.driver
    val stat_r = driver.stat(rel)
    if stat_r.is_err():
        return Err(stat_r.unwrap_err())
    val size = stat_r.unwrap().size.to_i64()
    if size > conn.max_bytes:
        _log_warn("read rejected: file size {size} > max {conn.max_bytes}")
        return Err(FsError.TooLarge)
    if size <= 0:
        return Ok([])
    val open_r = driver.open(rel, OpenFlags.read_only())
    if open_r.is_err():
        _log_error("open failed for '{path}'")
        return Err(open_r.unwrap_err())
    val handle = open_r.unwrap()
    var buf: [u8] = []
    var i: i64 = 0
    while i < size:
        buf.push(0)
        i = i + 1
    val read_r = driver.read(handle, 0, buf)
    driver.close(handle)
    if read_r.is_err():
        _log_error("read failed for '{path}'")
        return Err(read_r.unwrap_err())
    val n = read_r.unwrap()
    if n == size:
        return Ok(buf)
    # Truncate to bytes actually read.
    var out: [u8] = []
    var j: i64 = 0
    while j < n:
        out.push(buf[j])
        j = j + 1
    Ok(out)

fn nvfs_vfs_read_text(conn: NvfsVfsConnection, path: text) -> Result<text, FsError>:
    """Read a complete file as text through the NVFS connection."""
    val bytes_r = nvfs_vfs_read_bytes(conn, path)
    if bytes_r.is_err():
        return Err(bytes_r.unwrap_err())
    Ok(rt_bytes_to_text(bytes_r.unwrap()))

fn nvfs_vfs_file_size(conn: NvfsVfsConnection, path: text) -> Result<i64, FsError>:
    """Return file size for a path through the NVFS connection."""
    val rel_r = _nvfs_relpath(conn, path)
    if rel_r.is_err():
        return Err(rel_r.unwrap_err())
    var driver = conn.driver
    val stat_r = driver.stat(rel_r.unwrap())
    if stat_r.is_err():
        return Err(stat_r.unwrap_err())
    Ok(stat_r.unwrap().size.to_i64())

fn nvfs_vfs_file_exists(conn: NvfsVfsConnection, path: text) -> Result<bool, FsError>:
    """Return whether a path exists through the NVFS connection.

    Ok(true)  — stat succeeded.
    Ok(false) — stat returned NotFound only.
    Err(e)    — any other error (Permission, Transient, etc.).
    """
    val size_r = nvfs_vfs_file_size(conn, path)
    match size_r:
        case Ok(_):
            Ok(true)
        case Err(FsError.NotFound):
            Ok(false)
        case Err(e):
            Err(e)
