extern fn rt_eprintln(s: text)

extern fn rt_text_to_bytes(s: text) -> [u8]

extern fn rt_bytes_to_text(data: [u8]) -> text

val NVFS_CONNECTOR_MAX_BYTES: i64 = 16777216

val NVFS_CONNECTOR_SUPPORTED_CAPS: u32 = 15

