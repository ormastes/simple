fn nvfs_vfs_read_text(conn: NvfsVfsConnection, path: text) -> Result<text, FsError>:
    "Read a complete file as text through the NVFS connection."
    val bytes_r = nvfs_vfs_read_bytes(conn, path)
    if /* complex expr */:
        return Err(/* complex expr */)
    Ok(rt_bytes_to_text(/* complex expr */))

fn nvfs_vfs_file_size(conn: NvfsVfsConnection, path: text) -> Result<i64, FsError>:
    "Return file size for a path through the NVFS connection."
    val rel_r = _nvfs_relpath(conn, path)
    if /* complex expr */:
        return Err(/* complex expr */)
    var driver = conn.driver
    val stat_r = /* complex expr */
    if /* complex expr */:
        return Err(/* complex expr */)
    Ok(/* complex expr */)

fn nvfs_vfs_file_exists(conn: NvfsVfsConnection, path: text) -> Result<bool, FsError>:
    "Return whether a path exists through the NVFS connection.

    Ok(true)  — stat succeeded.
    Ok(false) — stat returned NotFound only.
    Err(e)    — any other error (Permission, Transient, etc.).
    "
    val size_r = nvfs_vfs_file_size(conn, path)
    match size_r:
        case Result::Ok(_):
            Ok(true)
        case Result::Err(FsError::NotFound):
            Ok(false)
        case Result::Err(e):
            Err(e)
