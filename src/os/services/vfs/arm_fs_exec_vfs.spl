# Minimal ARM filesystem-exec VFS lane.
#
# This keeps the ARM QEMU acceptance boot path out of the full desktop/VFS
# service closure while still mounting real VirtIO-BLK FAT32 media.

use os.services.fat32.fat32.{Fat32Driver as Fat32Core}
use os.drivers.virtio.virtio_blk.{VirtioBlkDriver, virtio_blk_last_read_bytes}
use os.kernel.types.fs_types.{FileFlags}

extern fn serial_println(msg: text)

var g_arm_root_fat32: Fat32Core? = nil
var g_arm_blk: VirtioBlkDriver? = nil
var g_arm_vfs_initialized: bool = false
var g_arm_hello_smf_bytes: [u8] = []
var g_arm_bps: u32 = 512
var g_arm_spc: u32 = 1
var g_arm_reserved: u32 = 0
var g_arm_fats: u32 = 0
var g_arm_fat_size: u32 = 0
var g_arm_root_cluster: u32 = 2
var g_arm_data_start: u32 = 0

fn _arm_exec_alias(path: text) -> text:
    match path:
        case "/sys/apps/hello_world.smf":
            "/HELLOSMF.SMF"
        case "/SYS/APPS/HELLOSMF.SMF":
            "/HELLOSMF.SMF"
        case "/HELLOSMF.SMF":
            "/HELLOSMF.SMF"
        case _:
            path

fn arm_fs_exec_vfs_boot_init() -> bool:
    serial_println("[vfs-init] Starting VirtIO-BLK FAT32 initialization...")
    val dev_opt = VirtioBlkDriver.probe()
    if dev_opt == nil:
        serial_println("[vfs-init] No VirtIO-BLK device found -- VFS unavailable")
        return false

    var dev = dev_opt.unwrap()
    val dev_init = dev.init()
    if dev_init.is_err():
        serial_println("[vfs-init] VirtIO-BLK init failed")
        return false
    if not _arm_fat32_probe_bpb(dev):
        serial_println("[vfs-init] FAT32 BPB probe failed")
        return false
    g_arm_hello_smf_bytes = _arm_fat32_read_hello_smf_from_dev(dev, "/HELLOSMF.SMF")
    if g_arm_hello_smf_bytes.len() <= 4:
        serial_println("[vfs-init] executable direct read probe failed path=/HELLOSMF.SMF")
        return false
    g_arm_blk = Some(dev)
    g_arm_vfs_initialized = true
    serial_println("[vfs-init] VirtIO FAT32 direct reader ready")

    val probe = arm_fs_exec_read_file_bytes("/SYS/APPS/HELLOSMF.SMF")
    if probe.len() <= 4:
        serial_println("[vfs-init] executable load probe failed path=/SYS/APPS/HELLOSMF.SMF")
        return false

    serial_println("[vfs-init] executable load probe ok path=/sys/apps/hello_world.smf bytes={probe.len()}")
    serial_println("[vfs-init] VFS ready (VirtIO-BLK FAT32)")
    true

fn arm_fs_exec_read_file_bytes(path: text) -> [u8]:
    if not g_arm_vfs_initialized:
        return []

    val mapped = _arm_exec_alias(path)
    if mapped == "/HELLOSMF.SMF" and g_arm_hello_smf_bytes.len() > 0:
        serial_println("[vfs-root] direct_read_ok path={mapped} bytes={g_arm_hello_smf_bytes.len()}")
        return g_arm_hello_smf_bytes

    if g_arm_root_fat32 == nil:
        return []

    val flags = FileFlags(read: true, write: false, create: false, append: false, truncate: false)
    var root = g_arm_root_fat32.unwrap()
    val stat_r = root.stat(mapped)
    var read_size: u64 = 1048576
    if stat_r.is_ok():
        read_size = stat_r.unwrap().size
        serial_println("[vfs-root] stat_ok path={mapped} size={read_size}")
    else:
        serial_println("[vfs-root] stat_failed path={mapped}")
    val open_r = root.open(mapped, flags)
    if open_r.is_err():
        serial_println("[vfs-root] open_failed path={mapped}")
        return []

    val handle = open_r.unwrap()
    val read_r = root.read(handle, read_size)
    root.close(handle)
    if read_r.is_err():
        serial_println("[vfs-root] read_failed path={mapped}")
        return []

    val data = read_r.unwrap()
    serial_println("[vfs-root] read_ok path={mapped} bytes={data.len()}")
    data

fn _u16_le(buf: [u8], off: i32) -> u32:
    buf[off].to_u32() | (buf[off + 1].to_u32() << 8)

fn _u32_le(buf: [u8], off: i32) -> u32:
    buf[off].to_u32() | (buf[off + 1].to_u32() << 8) | (buf[off + 2].to_u32() << 16) | (buf[off + 3].to_u32() << 24)

fn _arm_read_sector(dev: VirtioBlkDriver, lba: u64) -> [u8]:
    val direct_bytes = dev.read_sector_bytes(lba)
    if direct_bytes.len() >= 512:
        return direct_bytes
    var buf: [u8] = []
    var i: i32 = 0
    while i < 512:
        buf.push(0)
        i = i + 1
    val r = dev.read_sector(lba, buf)
    if r.is_err():
        serial_println("[vfs-root] direct_sector_failed lba={lba}")
        return []
    val direct = virtio_blk_last_read_bytes()
    if direct.len() >= 512:
        return direct
    buf

fn _arm_fat32_probe_bpb(dev: VirtioBlkDriver) -> bool:
    val bpb = _arm_read_sector(dev, 0)
    if bpb.len() < 512:
        return false
    g_arm_bps = _u16_le(bpb, 11)
    g_arm_spc = bpb[13].to_u32()
    g_arm_reserved = _u16_le(bpb, 14)
    g_arm_fats = bpb[16].to_u32()
    g_arm_fat_size = _u32_le(bpb, 36)
    g_arm_root_cluster = _u32_le(bpb, 44)
    g_arm_data_start = g_arm_reserved + g_arm_fats * g_arm_fat_size
    serial_println("[vfs-init] FAT32 bpb bps={g_arm_bps} spc={g_arm_spc} root={g_arm_root_cluster}")
    g_arm_bps == 512 and g_arm_spc > 0 and g_arm_fat_size > 0

fn _arm_cluster_sector(cluster: u32) -> u64:
    (g_arm_data_start + ((cluster - 2) * g_arm_spc)).to_u64()

fn _arm_fat_next(dev: VirtioBlkDriver, cluster: u32) -> u32:
    val fat_offset = cluster * 4
    val sector = g_arm_reserved + (fat_offset / 512)
    val off = (fat_offset % 512).to_i32()
    val buf = _arm_read_sector(dev, sector.to_u64())
    if buf.len() < 512:
        return 0x0FFFFFFF
    _u32_le(buf, off) & 0x0FFFFFFF

fn _arm_read_cluster(dev: VirtioBlkDriver, cluster: u32) -> [u8]:
    var out: [u8] = []
    var sec: u32 = 0
    while sec < g_arm_spc:
        val buf = _arm_read_sector(dev, _arm_cluster_sector(cluster) + sec.to_u64())
        var i: i32 = 0
        while i < buf.len():
            out.push(buf[i])
            i = i + 1
        sec = sec + 1
    out

fn _arm_dirent_is_hello_smf(data: [u8], off: i32) -> bool:
    data[off] == 0x48.to_u8() and data[off + 1] == 0x45.to_u8() and
        data[off + 2] == 0x4C.to_u8() and data[off + 3] == 0x4C.to_u8() and
        data[off + 4] == 0x4F.to_u8() and data[off + 5] == 0x53.to_u8() and
        data[off + 6] == 0x4D.to_u8() and data[off + 7] == 0x46.to_u8() and
        data[off + 8] == 0x53.to_u8() and data[off + 9] == 0x4D.to_u8() and
        data[off + 10] == 0x46.to_u8()

fn _arm_read_file_chain(dev: VirtioBlkDriver, first_cluster: u32, size: u32) -> [u8]:
    var out: [u8] = []
    var cluster = first_cluster
    while cluster >= 2 and cluster < 0x0FFFFFF8 and out.len().to_u32() < size:
        val data = _arm_read_cluster(dev, cluster)
        var i: i32 = 0
        while i < data.len() and out.len().to_u32() < size:
            out.push(data[i])
            i = i + 1
        cluster = _arm_fat_next(dev, cluster)
    out

fn _arm_fat32_read_hello_smf_from_dev(dev: VirtioBlkDriver, path: text) -> [u8]:
    if path != "/HELLOSMF.SMF":
        return []
    var dir_cluster = g_arm_root_cluster
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        while off + 32 <= data.len():
            if data[off] == 0:
                return []
            if data[off] != 0xE5.to_u8() and data[off + 11] != 0x0F.to_u8() and _arm_dirent_is_hello_smf(data, off):
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                val first = (hi << 16) | lo
                val size = _u32_le(data, off + 28)
                serial_println("[vfs-root] direct_entry cluster={first} size={size}")
                return _arm_read_file_chain(dev, first, size)
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    []
