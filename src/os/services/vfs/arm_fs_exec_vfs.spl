        _byte(data, off + 2) == 0x53 and _byte(data, off + 3) == 0x20 and
        _byte(data, off + 4) == 0x20 and _byte(data, off + 5) == 0x20 and
        _byte(data, off + 6) == 0x20 and _byte(data, off + 7) == 0x20 and
