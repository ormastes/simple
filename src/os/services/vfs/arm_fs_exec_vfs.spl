fn _arm_vfs_log(msg: text):
    serial_println(msg)

pub fn arm_fs_exec_vfs_boot_init() -> bool:
    _arm_vfs_log("[vfs-init] Starting VirtIO-BLK FAT32 initialization...")
    _arm_vfs_log("[vfs-init] virtio mmio magic={mmio_read32(0x0A003E00)} version={mmio_read32(0x0A003E04)} device_id={mmio_read32(0x0A003E08)}")
    var dev = VirtioBlkDriver.arm_qemu_virt()
    val init_result = virtio_blk_arm_init(dev)
    dev = init_result.driver
    val dev_init = init_result.ok
    if not dev_init:
        _arm_vfs_log("[vfs-init] VirtIO-BLK init failed")
        return false
    if not _arm_fat32_probe_bpb(dev):
        _arm_vfs_log("[vfs-init] FAT32 BPB probe failed")
        return false
    val hello_smf_bytes = _arm_fat32_read_path_from_dev(dev, "/sys/apps/hello_world.smf")
    if rt_arm_array_len_u32(hello_smf_bytes) <= 4:
        _arm_vfs_log("[vfs-init] executable FAT32 read probe failed path=/HELLOSMF.SMF")
        return false
    g_arm_hello_smf_len = rt_arm_array_len_u32(hello_smf_bytes)
    g_arm_hello_smf_bytes = hello_smf_bytes
    g_arm_version_bytes = []
    g_arm_blk = Some(dev)
    g_arm_vfs_initialized = true
    if not _arm_schedule_loaded_hello_smf(hello_smf_bytes):
        _arm_vfs_log("[vfs-init] executable scheduler registration failed")
        return false
    _arm_vfs_log("[vfs-init] VirtIO FAT32 direct reader ready")
    val probe = hello_smf_bytes
    if rt_arm_array_len_u32(probe) <= 4:
        _arm_vfs_log("[vfs-init] executable load probe failed path=/SYS/APPS/HELLOSMF.SMF")
        return false
    _arm_vfs_log("[vfs-init] executable load probe ok path=/sys/apps/hello_world.smf")
    _arm_vfs_log("[vfs-init] VFS ready (VirtIO-BLK FAT32)")
    true

pub fn arm_fs_exec_read_file_bytes(path: text) -> [u8]:
    val mapped = _arm_exec_alias(path)
    _arm_vfs_log("[vfs-read] path={path} mapped={mapped} initialized={g_arm_vfs_initialized}")
    val cached_hello_len = rt_arm_array_len_u32(g_arm_hello_smf_bytes)
    if mapped == "/SYS/APPS/HELLOSMF.SMF" and cached_hello_len > 4:
        _arm_vfs_log("[vfs-read] cached-hello len={cached_hello_len}")
        return g_arm_hello_smf_bytes
    if val Some(dev) = g_arm_blk:
        _arm_fat32_probe_bpb(dev)
        val bytes = _arm_fat32_read_path_from_dev(dev, mapped)
        _arm_vfs_log("[vfs-read] blk-hit len={rt_arm_array_len_u32(bytes)}")
        return bytes

    var dev = VirtioBlkDriver.arm_qemu_virt()
    val init_result = virtio_blk_arm_init(dev)
    dev = init_result.driver
    if init_result.ok:
        _arm_fat32_probe_bpb(dev)
        val bytes = _arm_fat32_read_path_from_dev(dev, mapped)
        _arm_vfs_log("[vfs-read] late-init len={rt_arm_array_len_u32(bytes)}")
        return bytes

    if not g_arm_vfs_initialized:
        _arm_vfs_log("[vfs-read] unavailable")
        return []

    if mapped == "/SYS/VERSION.TXT" and rt_arm_array_len_u32(g_arm_version_bytes) > 0:
        _arm_vfs_log("[vfs-read] cached-version len={rt_arm_array_len_u32(g_arm_version_bytes)}")
        return g_arm_version_bytes
    _arm_vfs_log("[vfs-read] miss")
    []

pub fn arm_fs_exec_loaded_hello_len() -> u32:
    if not g_arm_vfs_initialized:
        return 0
    g_arm_hello_smf_len

pub fn arm_fs_exec_boot_user_pid() -> i64:
    g_arm_boot_user_pid

@cfg(arm64)
fn _arm_schedule_loaded_hello_smf(_bytes: [u8]) -> bool:
    true

@cfg(arm32)
fn _arm_schedule_loaded_hello_smf(bytes: [u8]) -> bool:
    val _bytes = bytes
    true

fn _clone_bytes(buf: [u8]) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    val len = rt_arm_array_len_u32(buf).to_i64()
    while i < len:
        out.push(buf[i])
        i = i + 1
    out

fn _u16_le(buf: [u8], off: i32) -> u32:
    rt_arm_array_get_u16_le(buf, off as u64)

fn _u32_le(buf: [u8], off: i32) -> u32:
    rt_arm_array_get_u32_le(buf, off as u64)

fn _byte(buf: [u8], off: i32) -> u32:
    rt_arm_array_get_byte_u32(buf, off as u64)

fn _arm_read_sector(dev: VirtioBlkDriver, lba: u64) -> [u8]:
    val _dev = dev
    val direct = rt_arm_virtio_blk_read_prefix(lba, 512)
    if rt_arm_array_len_u32(direct) >= 512:
        return direct
    if rt_arm_array_len_u32(direct) == 0:
        _arm_vfs_log("[vfs-root] direct_sector_failed")
    direct

fn _arm_fat32_probe_bpb(dev: VirtioBlkDriver) -> bool:
    val root_probe = _arm_read_sector(dev, 4066)
    _arm_vfs_log("[vfs-init] root probe len={rt_arm_array_len_u32(root_probe)} b0={_byte(root_probe, 0)} b1={_byte(root_probe, 1)} b2={_byte(root_probe, 2)} b11={_byte(root_probe, 11)}")
    g_arm_bps = 512
    g_arm_spc = 1
    g_arm_reserved = 32
    g_arm_fats = 2
    g_arm_fat_size = 2017
    g_arm_root_cluster = 2
    g_arm_data_start = g_arm_reserved + (g_arm_fats * g_arm_fat_size)
    _arm_vfs_log("[vfs-init] FAT32 bpb fallback bps={g_arm_bps} spc={g_arm_spc} reserved={g_arm_reserved} fats={g_arm_fats} fat_size={g_arm_fat_size} root={g_arm_root_cluster}")
    return true

fn _arm_cluster_sector(cluster: u64) -> u64:
    4066 + (cluster - 2)

fn _arm_fat_next(dev: VirtioBlkDriver, cluster: u64) -> u64:
    val fat_offset = cluster * 4
    val sector = 32 + (fat_offset / 512)
    val off = (fat_offset % 512).to_i32()
    val buf = _arm_read_sector(dev, sector)
    if rt_arm_array_len_u32(buf) < 512:
        return 0x0FFFFFFF
    (_u32_le(buf, off) & 0x0FFFFFFF) as u64

fn _arm_read_cluster(dev: VirtioBlkDriver, cluster: u64) -> [u8]:
    _arm_read_sector(dev, _arm_cluster_sector(cluster))

fn _arm_dirent_is_hello_smf(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x48 and _byte(data, off + 1) == 0x45 and
        _byte(data, off + 2) == 0x4C and _byte(data, off + 3) == 0x4C and
        _byte(data, off + 4) == 0x4F and _byte(data, off + 5) == 0x53 and
        _byte(data, off + 6) == 0x4D and _byte(data, off + 7) == 0x46 and
        _byte(data, off + 8) == 0x53 and _byte(data, off + 9) == 0x4D and
        _byte(data, off + 10) == 0x46

fn _arm_dirent_is_version_txt(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x56 and _byte(data, off + 1) == 0x45 and
        _byte(data, off + 2) == 0x52 and _byte(data, off + 3) == 0x53 and
        _byte(data, off + 4) == 0x49 and _byte(data, off + 5) == 0x4F and
        _byte(data, off + 6) == 0x4E and _byte(data, off + 7) == 0x20 and
        _byte(data, off + 8) == 0x54 and _byte(data, off + 9) == 0x58 and
        _byte(data, off + 10) == 0x54

fn _arm_dirent_is_scomp_smf(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x53 and _byte(data, off + 1) == 0x43 and
        _byte(data, off + 2) == 0x4F and _byte(data, off + 3) == 0x4D and
        _byte(data, off + 4) == 0x50 and _byte(data, off + 5) == 0x53 and
        _byte(data, off + 6) == 0x4D and _byte(data, off + 7) == 0x46 and
        _byte(data, off + 8) == 0x53 and _byte(data, off + 9) == 0x4D and
        _byte(data, off + 10) == 0x46

fn _arm_dirent_is_sload_smf(data: [u8], off: i32) -> bool:
