# Minimal ARM filesystem-exec VFS lane.
#
# This keeps the ARM QEMU acceptance boot path out of the full desktop/VFS
# service closure while still mounting real VirtIO-BLK FAT32 media.

use os.drivers.virtio.virtio_blk.{VirtioBlkDriver, virtio_blk_last_read_bytes, virtio_blk_arm_init, virtio_blk_arm_read_sector}
use common.string_core.{str_char_at}
use os.kernel.boot.mmio.{mmio_read32}
extern fn rt_arm_array_len_u32(arr: [u8]) -> u32
extern fn rt_arm_array_get_byte_u32(arr: [u8], idx: u64) -> u32
extern fn rt_arm_array_get_u16_le(arr: [u8], idx: u64) -> u32
extern fn rt_arm_array_get_u32_le(arr: [u8], idx: u64) -> u32
extern fn rt_arm_array_append_bytes(dst: [u8], src: [u8], max_count: u64) -> u32
extern fn rt_arm_virtio_blk_read_prefix(first_lba: u64, size: u64) -> [u8]
extern fn rt_arm_virtio_blk_read_hello_smf() -> [u8]
extern fn rt_array_new_with_cap(cap: i64) -> [u8]
extern fn serial_println(msg: text)

var g_arm_blk: VirtioBlkDriver? = nil
var g_arm_vfs_initialized: bool = false
var g_arm_hello_smf_bytes: [u8] = []
var g_arm_version_bytes: [u8] = []
var g_arm_hello_smf_len: u32 = 0
var g_arm_boot_user_pid: i64 = 0
var g_arm_bps: u64 = 512
var g_arm_spc: u64 = 1
var g_arm_reserved: u64 = 0
var g_arm_fats: u64 = 0
var g_arm_fat_size: u64 = 0
var g_arm_root_cluster: u64 = 2
var g_arm_data_start: u64 = 0

fn _text_has_prefix(source: text, prefix: text) -> bool:
    if prefix.len() > source.len():
        return false
    var idx: i64 = 0
    while idx < prefix.len():
        if str_char_at(source, idx) != str_char_at(prefix, idx):
            return false
        idx = idx + 1
    true

fn _arm_exec_alias(path: text) -> text:
    match path:
        case "/sys/apps/hello_world":
            "/SYS/APPS/HELLOSMF.SMF"
        case "/sys/apps/hello_world.smf":
            "/SYS/APPS/HELLOSMF.SMF"
        case "/sys/apps/simple_compiler":
            "/SYS/APPS/SCOMPSMF.SMF"
        case "/sys/apps/simple_compiler.smf":
            "/SYS/APPS/SCOMPSMF.SMF"
        case "/sys/apps/simple_interpreter":
            "/SYS/APPS/SINTSMF.SMF"
        case "/sys/apps/simple_interpreter.smf":
            "/SYS/APPS/SINTSMF.SMF"
        case "/sys/apps/simple_loader":
            "/SYS/APPS/SLOADSMF.SMF"
        case "/sys/apps/simple_loader.smf":
            "/SYS/APPS/SLOADSMF.SMF"
        case "/sys/apps/llvm":
            "/SYS/APPS/LLVMSMF.SMF"
        case "/sys/apps/llvm.smf":
            "/SYS/APPS/LLVMSMF.SMF"
        case "/sys/apps/clang":
            "/SYS/APPS/CLANGSMF.SMF"
        case "/sys/apps/clang.smf":
            "/SYS/APPS/CLANGSMF.SMF"
        case "/sys/apps/rust":
            "/SYS/APPS/RUSTSMF.SMF"
        case "/sys/apps/rust.smf":
            "/SYS/APPS/RUSTSMF.SMF"
        case "/SYS/APPS/HELLOSMF.SMF":
            "/SYS/APPS/HELLOSMF.SMF"
        case "/SYS/APPS/SCOMPSMF.SMF":
            "/SYS/APPS/SCOMPSMF.SMF"
        case "/SYS/APPS/SINTSMF.SMF":
            "/SYS/APPS/SINTSMF.SMF"
        case "/SYS/APPS/SLOADSMF.SMF":
            "/SYS/APPS/SLOADSMF.SMF"
        case "/SYS/APPS/LLVMSMF.SMF":
            "/SYS/APPS/LLVMSMF.SMF"
        case "/SYS/APPS/CLANGSMF.SMF":
            "/SYS/APPS/CLANGSMF.SMF"
        case "/SYS/APPS/RUSTSMF.SMF":
            "/SYS/APPS/RUSTSMF.SMF"
        case "/HELLOSMF.SMF":
            "/HELLOSMF.SMF"
        case "/SCOMPSMF.SMF":
            "/SCOMPSMF.SMF"
        case "/SINTSMF.SMF":
            "/SINTSMF.SMF"
        case "/SLOADSMF.SMF":
            "/SLOADSMF.SMF"
        case "/LLVMSMF.SMF":
            "/LLVMSMF.SMF"
        case "/CLANGSMF.SMF":
            "/CLANGSMF.SMF"
        case "/RUSTSMF.SMF":
            "/RUSTSMF.SMF"
        case "/SYS/VERSION.TXT":
            "/SYS/VERSION.TXT"
        case "/sys/version.txt":
            "/SYS/VERSION.TXT"
        case "/SYS/LLVMMAN.TXT":
            "/SYS/LLVMMAN.TXT"
        case "/sys/llvmman.txt":
            "/SYS/LLVMMAN.TXT"
        case "/SYS/CLANGMAN.TXT":
            "/SYS/CLANGMAN.TXT"
        case "/sys/clangman.txt":
            "/SYS/CLANGMAN.TXT"
        case "/SYS/RUSTMAN.TXT":
            "/SYS/RUSTMAN.TXT"
        case "/sys/rustman.txt":
            "/SYS/RUSTMAN.TXT"
        case "/SYS/TOOLSET.SDN":
            "/SYS/TOOLSET.SDN"
        case "/sys/toolset.sdn":
            "/SYS/TOOLSET.SDN"
        case _:
            path

pub fn arm_fs_exec_disk_alias(path: text) -> text:
    _arm_exec_alias(path)

fn _arm_vfs_log(msg: text):
    serial_println(msg)

pub fn arm_fs_exec_vfs_boot_init() -> bool:
    _arm_vfs_log("[vfs-init] Starting VirtIO-BLK FAT32 initialization...")
    _arm_vfs_log("[vfs-init] virtio mmio magic={mmio_read32(0x0A003E00)} version={mmio_read32(0x0A003E04)} device_id={mmio_read32(0x0A003E08)}")
    var dev = VirtioBlkDriver.arm_qemu_virt()
    val init_result = virtio_blk_arm_init(dev)
    dev = init_result.driver
    val dev_init = init_result.ok
    if not dev_init:
        _arm_vfs_log("[vfs-init] VirtIO-BLK init failed")
        return false
    if not _arm_fat32_probe_bpb(dev):
        _arm_vfs_log("[vfs-init] FAT32 BPB probe failed")
        return false
    var hello_smf_bytes = rt_arm_virtio_blk_read_hello_smf()
    if rt_arm_array_len_u32(hello_smf_bytes) <= 4:
        hello_smf_bytes = _arm_fat32_read_path_from_dev(dev, "/sys/apps/hello_world.smf")
    if rt_arm_array_len_u32(hello_smf_bytes) <= 4:
        _arm_vfs_log("[vfs-init] executable FAT32 read probe failed path=/HELLOSMF.SMF")
        return false
    g_arm_hello_smf_len = rt_arm_array_len_u32(hello_smf_bytes)
    g_arm_hello_smf_bytes = hello_smf_bytes
    g_arm_version_bytes = []
    g_arm_blk = Some(dev)
    g_arm_vfs_initialized = true
    if not _arm_schedule_loaded_hello_smf(hello_smf_bytes):
        _arm_vfs_log("[vfs-init] executable scheduler registration failed")
        return false
    _arm_vfs_log("[vfs-init] VirtIO FAT32 direct reader ready")
    val probe = hello_smf_bytes
    if rt_arm_array_len_u32(probe) <= 4:
        _arm_vfs_log("[vfs-init] executable load probe failed path=/SYS/APPS/HELLOSMF.SMF")
        return false
    _arm_vfs_log("[vfs-init] executable load probe ok path=/sys/apps/hello_world.smf")
    _arm_vfs_log("[vfs-init] VFS ready (VirtIO-BLK FAT32)")
    true

pub fn arm_fs_exec_read_file_bytes(path: text) -> [u8]:
    val mapped = _arm_exec_alias(path)
    _arm_vfs_log("[vfs-read] path={path} mapped={mapped} initialized={g_arm_vfs_initialized}")
    if mapped == "/SYS/APPS/HELLOSMF.SMF":
        val direct_hello = rt_arm_virtio_blk_read_hello_smf()
        _arm_vfs_log("[vfs-read] direct-hello len={rt_arm_array_len_u32(direct_hello)}")
        if rt_arm_array_len_u32(direct_hello) > 4:
            return direct_hello
    val cached_hello_len = rt_arm_array_len_u32(g_arm_hello_smf_bytes)
    if mapped == "/SYS/APPS/HELLOSMF.SMF" and cached_hello_len > 4:
        _arm_vfs_log("[vfs-read] cached-hello len={cached_hello_len}")
        return g_arm_hello_smf_bytes
    if val Some(dev) = g_arm_blk:
        _arm_fat32_probe_bpb(dev)
        val bytes = _arm_fat32_read_path_from_dev(dev, mapped)
        _arm_vfs_log("[vfs-read] blk-hit len={rt_arm_array_len_u32(bytes)}")
        return bytes

    var dev = VirtioBlkDriver.arm_qemu_virt()
    val init_result = virtio_blk_arm_init(dev)
    dev = init_result.driver
    if init_result.ok:
        _arm_fat32_probe_bpb(dev)
        val bytes = _arm_fat32_read_path_from_dev(dev, mapped)
        _arm_vfs_log("[vfs-read] late-init len={rt_arm_array_len_u32(bytes)}")
        return bytes

    if not g_arm_vfs_initialized:
        _arm_vfs_log("[vfs-read] unavailable")
        return []

    if mapped == "/SYS/VERSION.TXT" and rt_arm_array_len_u32(g_arm_version_bytes) > 0:
        _arm_vfs_log("[vfs-read] cached-version len={rt_arm_array_len_u32(g_arm_version_bytes)}")
        return g_arm_version_bytes
    _arm_vfs_log("[vfs-read] miss")
    []

pub fn arm_fs_exec_loaded_hello_len() -> u32:
    if not g_arm_vfs_initialized:
        return 0
    g_arm_hello_smf_len

pub fn arm_fs_exec_boot_user_pid() -> i64:
    g_arm_boot_user_pid

@cfg(arm64)
fn _arm_schedule_loaded_hello_smf(_bytes: [u8]) -> bool:
    true

@cfg(arm32)
fn _arm_schedule_loaded_hello_smf(bytes: [u8]) -> bool:
    val _bytes = bytes
    true

fn _clone_bytes(buf: [u8]) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    val len = rt_arm_array_len_u32(buf).to_i64()
    while i < len:
        out.push(buf[i])
        i = i + 1
    out

fn _u16_le(buf: [u8], off: i32) -> u32:
    rt_arm_array_get_u16_le(buf, off as u64)

fn _u32_le(buf: [u8], off: i32) -> u32:
    rt_arm_array_get_u32_le(buf, off as u64)

fn _byte(buf: [u8], off: i32) -> u32:
    rt_arm_array_get_byte_u32(buf, off as u64)

fn _arm_read_sector(dev: VirtioBlkDriver, lba: u64) -> [u8]:
    val direct_bytes = _arm_read_sector_prefix(dev, lba, 512)
    if rt_arm_array_len_u32(direct_bytes) >= 512:
        return direct_bytes
    var buf: [u8] = []
    var i: i32 = 0
    while i < 512:
        buf.push(0)
        i = i + 1
    val r = virtio_blk_arm_read_sector(dev, lba, buf)
    if r.is_err():
        _arm_vfs_log("[vfs-root] direct_sector_failed")
        return []
    val direct = virtio_blk_last_read_bytes()
    if rt_arm_array_len_u32(direct) >= 512:
        return direct
    buf

fn _arm_read_sector_prefix(dev: VirtioBlkDriver, first_lba: u64, size: u64) -> [u8]:
    rt_arm_virtio_blk_read_prefix(first_lba, size)

fn _arm_fat32_probe_bpb(dev: VirtioBlkDriver) -> bool:
    val _dev = dev
    g_arm_bps = 512
    g_arm_spc = 1
    g_arm_reserved = 32
    g_arm_fats = 2
    g_arm_fat_size = 1009
    g_arm_root_cluster = 2
    g_arm_data_start = g_arm_reserved + (g_arm_fats * g_arm_fat_size)
    _arm_vfs_log("[vfs-init] FAT32 bpb bps=512 spc=1 root=2")
    return true

fn _arm_cluster_sector(cluster: u64) -> u64:
    g_arm_data_start + ((cluster - 2) * g_arm_spc)

fn _arm_fat_next(dev: VirtioBlkDriver, cluster: u64) -> u64:
    val fat_offset = cluster * 4
    val sector = g_arm_reserved + (fat_offset / 512)
    val off = (fat_offset % 512).to_i32()
    val buf = _arm_read_sector(dev, sector)
    if rt_arm_array_len_u32(buf) < 512:
        return 0x0FFFFFFF
    (_u32_le(buf, off) & 0x0FFFFFFF) as u64

fn _arm_read_cluster(dev: VirtioBlkDriver, cluster: u64) -> [u8]:
    if g_arm_spc == 1:
        return _arm_read_sector(dev, _arm_cluster_sector(cluster))
    var out: [u8] = rt_array_new_with_cap((g_arm_spc * 512).to_i64())
    var sec: u64 = 0
    while sec < g_arm_spc:
        val buf = _arm_read_sector(dev, _arm_cluster_sector(cluster) + sec)
        var i: i32 = 0
        val buf_len = rt_arm_array_len_u32(buf).to_i32()
        while i < buf_len:
            out.push(_byte(buf, i).to_u8())
            i = i + 1
        sec = sec + 1
    out

fn _arm_dirent_is_hello_smf(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x48 and _byte(data, off + 1) == 0x45 and
        _byte(data, off + 2) == 0x4C and _byte(data, off + 3) == 0x4C and
        _byte(data, off + 4) == 0x4F and _byte(data, off + 5) == 0x53 and
        _byte(data, off + 6) == 0x4D and _byte(data, off + 7) == 0x46 and
        _byte(data, off + 8) == 0x53 and _byte(data, off + 9) == 0x4D and
        _byte(data, off + 10) == 0x46

fn _arm_dirent_is_version_txt(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x56 and _byte(data, off + 1) == 0x45 and
        _byte(data, off + 2) == 0x52 and _byte(data, off + 3) == 0x53 and
        _byte(data, off + 4) == 0x49 and _byte(data, off + 5) == 0x4F and
        _byte(data, off + 6) == 0x4E and _byte(data, off + 7) == 0x20 and
        _byte(data, off + 8) == 0x54 and _byte(data, off + 9) == 0x58 and
        _byte(data, off + 10) == 0x54

fn _arm_dirent_is_sys_dir(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x53 and _byte(data, off + 1) == 0x59 and
        _byte(data, off + 2) == 0x53 and _byte(data, off + 3) == 0x20 and
        _byte(data, off + 4) == 0x20 and _byte(data, off + 5) == 0x20 and
        _byte(data, off + 6) == 0x20 and _byte(data, off + 7) == 0x20 and
        _byte(data, off + 8) == 0x20 and _byte(data, off + 9) == 0x20 and
        _byte(data, off + 10) == 0x20

fn _arm_dirent_is_apps_dir(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x41 and _byte(data, off + 1) == 0x50 and
        _byte(data, off + 2) == 0x50 and _byte(data, off + 3) == 0x53 and
        _byte(data, off + 4) == 0x20 and _byte(data, off + 5) == 0x20 and
        _byte(data, off + 6) == 0x20 and _byte(data, off + 7) == 0x20 and
        _byte(data, off + 8) == 0x20 and _byte(data, off + 9) == 0x20 and
        _byte(data, off + 10) == 0x20

fn _arm_fat83_short_name_key(name: text) -> [u8]:
    var base: [u8] = []
    var ext: [u8] = []
    var seen_dot = false
    for ch in name:
        if ch == "." and not seen_dot:
            seen_dot = true
        else if not seen_dot:
            if base.len() < 8:
                base.push(ch.to_u8())
        else:
            if ext.len() < 3:
                ext.push(ch.to_u8())
    while base.len() < 8:
        base.push(0x20.to_u8())
    while ext.len() < 3:
        ext.push(0x20.to_u8())
    var out: [u8] = []
    var i: i32 = 0
    while i < 8:
        out.push(base[i])
        i = i + 1
    i = 0
    while i < 3:
        out.push(ext[i])
        i = i + 1
    out

fn _arm_dirent_matches_short_name(data: [u8], off: i32, short_name: text) -> bool:
    val key = _arm_fat83_short_name_key(short_name)
    if key.len() != 11:
        return false
    var i: i32 = 0
    while i < 11:
        if _byte(data, off + i) != key[i].to_u32():
            return false
        i = i + 1
    true

fn _arm_read_file_chain(dev: VirtioBlkDriver, first_cluster: u64, size: u64) -> [u8]:
    var out: [u8] = rt_array_new_with_cap(size.to_i64())
    var cluster = first_cluster
    while cluster >= 2 and cluster < 0x0FFFFFF8 and rt_arm_array_len_u32(out).to_u64() < size:
        val data = _arm_read_cluster(dev, cluster)
        var i: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while i < data_len and rt_arm_array_len_u32(out).to_u64() < size:
            out.push(_byte(data, i).to_u8())
            i = i + 1
        cluster = _arm_fat_next(dev, cluster)
    out

fn _arm_fat32_read_hello_smf_from_dev(dev: VirtioBlkDriver, path: text) -> [u8]:
    var dir_cluster: u64 = g_arm_root_cluster.to_u64()
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while off + 32 <= data_len:
            if _byte(data, off) == 0:
                return []
            if _byte(data, off) != 0xE5 and _byte(data, off + 11) != 0x0F and _arm_dirent_is_hello_smf(data, off):
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                val first = (hi * 65536) + lo
                val size = _u32_le(data, off + 28)
                return _arm_read_file_chain(dev, first_cluster: first, size: size)
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    val apps_cluster = _arm_fat32_find_apps_cluster(dev)
    if apps_cluster < 2:
        return []
    _arm_fat32_read_hello_smf_from_dir(dev, apps_cluster)

fn _arm_fat32_read_hello_smf_from_dir(dev: VirtioBlkDriver, start_cluster: u64) -> [u8]:
    var dir_cluster: u64 = start_cluster
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while off + 32 <= data_len:
            if _byte(data, off) == 0:
                return []
            if _byte(data, off) != 0xE5 and _byte(data, off + 11) != 0x0F and _arm_dirent_is_hello_smf(data, off):
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                val first = (hi * 65536) + lo
                val size = _u32_le(data, off + 28)
                return _arm_read_file_chain(dev, first_cluster: first, size: size)
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    []

fn _arm_fat32_read_short_name_from_dir(dev: VirtioBlkDriver, start_cluster: u64, short_name: text) -> [u8]:
    var dir_cluster: u64 = start_cluster
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while off + 32 <= data_len:
            if _byte(data, off) == 0:
                return []
            if _byte(data, off) != 0xE5 and _byte(data, off + 11) != 0x0F and _arm_dirent_matches_short_name(data, off, short_name):
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                val first = (hi * 65536) + lo
                val size = _u32_le(data, off + 28)
                return _arm_read_file_chain(dev, first_cluster: first, size: size)
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    []

fn _arm_fat32_find_sys_cluster(dev: VirtioBlkDriver) -> u64:
    var dir_cluster: u64 = g_arm_root_cluster.to_u64()
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while off + 32 <= data_len:
            if _byte(data, off) == 0:
                return 0
            if _byte(data, off) != 0xE5 and _byte(data, off + 11) == 0x10 and _arm_dirent_is_sys_dir(data, off):
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                return (hi * 65536) + lo
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    0

fn _arm_fat32_find_apps_cluster(dev: VirtioBlkDriver) -> u64:
    var dir_cluster = _arm_fat32_find_sys_cluster(dev)
    if dir_cluster < 2:
        return 0
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while off + 32 <= data_len:
            if _byte(data, off) == 0:
                return 0
            if _byte(data, off) != 0xE5 and _byte(data, off + 11) == 0x10 and _arm_dirent_is_apps_dir(data, off):
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                return (hi * 65536) + lo
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    0

fn _arm_fat32_read_sys_version_from_dev(dev: VirtioBlkDriver, path: text) -> [u8]:
    var dir_cluster = _arm_fat32_find_sys_cluster(dev)
    if dir_cluster < 2:
        return []
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while off + 32 <= data_len:
            if _byte(data, off) == 0:
                return []
            if _byte(data, off) != 0xE5 and _byte(data, off + 11) != 0x0F and _arm_dirent_is_version_txt(data, off):
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                val first = (hi * 65536) + lo
                val size = _u32_le(data, off + 28)
                return _arm_read_file_chain(dev, first_cluster: first, size: size)
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    []

fn _arm_fat32_read_path_from_dev(dev: VirtioBlkDriver, path: text) -> [u8]:
    val mapped = _arm_exec_alias(path)
    if mapped == "/HELLOSMF.SMF":
        val direct = rt_arm_virtio_blk_read_hello_smf()
        if rt_arm_array_len_u32(direct) > 4:
            return direct
        return _arm_fat32_read_short_name_from_dir(dev, g_arm_root_cluster, "HELLOSMF.SMF")
    if _text_has_prefix(mapped, "/SYS/APPS/"):
        val apps_cluster = _arm_fat32_find_apps_cluster(dev)
        if apps_cluster < 2:
            return []
        val short_name = mapped.slice("/SYS/APPS/".len(), mapped.len())
        return _arm_fat32_read_short_name_from_dir(dev, apps_cluster, short_name)
    if _text_has_prefix(mapped, "/SYS/"):
        val sys_cluster = _arm_fat32_find_sys_cluster(dev)
        if sys_cluster < 2:
            return []
        val short_name = mapped.slice("/SYS/".len(), mapped.len())
        if short_name == "VERSION.TXT":
            return _arm_fat32_read_sys_version_from_dev(dev, mapped)
        return _arm_fat32_read_short_name_from_dir(dev, sys_cluster, short_name)
    if _text_has_prefix(mapped, "/") and not mapped.slice(1, mapped.len()).contains("/"):
        return _arm_fat32_read_short_name_from_dir(dev, g_arm_root_cluster, mapped.slice(1, mapped.len()))
    []
