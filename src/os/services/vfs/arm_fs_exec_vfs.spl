        _byte(data, off + 2) == 0x50 and _byte(data, off + 3) == 0x53 and
        _byte(data, off + 4) == 0x20 and _byte(data, off + 5) == 0x20 and
        _byte(data, off + 6) == 0x20 and _byte(data, off + 7) == 0x20 and
        _byte(data, off + 8) == 0x20 and _byte(data, off + 9) == 0x20 and
        _byte(data, off + 10) == 0x20

fn _arm_fat83_short_name_key(name: text) -> [u8]:
    var base: [u8] = []
    var ext: [u8] = []
    var seen_dot = false
    for ch in name:
        if ch == "." and not seen_dot:
            seen_dot = true
        else if not seen_dot:
            if base.len() < 8:
                base.push(ch.to_u8())
        else:
            if ext.len() < 3:
                ext.push(ch.to_u8())
    while base.len() < 8:
        base.push(0x20.to_u8())
    while ext.len() < 3:
        ext.push(0x20.to_u8())
    var out: [u8] = []
    var i: i32 = 0
    while i < 8:
        out.push(base[i])
        i = i + 1
    i = 0
    while i < 3:
        out.push(ext[i])
        i = i + 1
    out

fn _arm_dirent_matches_short_name(data: [u8], off: i32, short_name: text) -> bool:
    match short_name:
        case "HELLOSMF.SMF":
            return _arm_dirent_is_hello_smf(data, off)
        case "SCOMPSMF.SMF":
            return _arm_dirent_is_scomp_smf(data, off)
        case "SINTSMF.SMF":
            return _arm_dirent_is_sint_smf(data, off)
        case "SLOADSMF.SMF":
            return _arm_dirent_is_sload_smf(data, off)
        case "LLVMSMF.SMF":
            return _arm_dirent_is_llvm_smf(data, off)
        case "CLANGSMF.SMF":
            return _arm_dirent_is_clang_smf(data, off)
        case "RUSTSMF.SMF":
            return _arm_dirent_is_rust_smf(data, off)
        case "VERSION.TXT":
            return _arm_dirent_is_version_txt(data, off)
        case "SCOMPMAN.TXT":
            return _arm_dirent_is_scomp_man(data, off)
        case "SLOADMAN.TXT":
            return _arm_dirent_is_sload_man(data, off)
        case "LLVMMAN.TXT":
            return _arm_dirent_is_llvm_man(data, off)
        case "CLANGMAN.TXT":
            return _arm_dirent_is_clang_man(data, off)
        case "RUSTMAN.TXT":
            return _arm_dirent_is_rust_man(data, off)
        case "TOOLSET.SDN":
            return _arm_dirent_is_toolset_sdn(data, off)
        case _:
            ()
    val key = _arm_fat83_short_name_key(short_name)
    if key.len() != 11:
        return false
    var i: i32 = 0
    while i < 11:
        if _byte(data, off + i) != key[i].to_u32():
            return false
        i = i + 1
    true

fn _arm_read_file_chain(dev: VirtioBlkDriver, first_cluster: u64, size: u64) -> [u8]:
    var out: [u8] = rt_array_new_with_cap(size.to_i64())
    var cluster = first_cluster
    while cluster >= 2 and cluster < 0x0FFFFFF8 and rt_arm_array_len_u32(out).to_u64() < size:
        val data = _arm_read_cluster(dev, cluster)
        if first_cluster == 128:
            _arm_vfs_log("[vfs-file-chain] cluster={cluster} data_len={rt_arm_array_len_u32(data)} d0={_byte(data, 0)} d1={_byte(data, 1)} d2={_byte(data, 2)} d3={_byte(data, 3)}")
        val remaining = size - rt_arm_array_len_u32(out).to_u64()
        _ = rt_arm_array_append_bytes(out, data, remaining)
        if first_cluster == 128 and rt_arm_array_len_u32(out) >= 16:
            _arm_vfs_log("[vfs-file-chain] first_cluster={first_cluster} len={rt_arm_array_len_u32(out)} b0={_byte(out, 0)} b1={_byte(out, 1)} b2={_byte(out, 2)} b3={_byte(out, 3)}")
        if first_cluster == 128 and rt_arm_array_len_u32(out) > 4100:
            _arm_vfs_log("[vfs-file-chain] off4096={_byte(out, 4096)} off4097={_byte(out, 4097)} off4098={_byte(out, 4098)} off4099={_byte(out, 4099)}")
        cluster = _arm_fat_next(dev, cluster)
    out

fn _arm_fat32_read_hello_smf_from_dev(dev: VirtioBlkDriver, path: text) -> [u8]:
    val _path = path
    var dir_cluster: u64 = 2
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while off + 32 <= data_len:
            if _byte(data, off) == 0:
                return []
            if _byte(data, off) != 0xE5 and _byte(data, off + 11) != 0x0F and _arm_dirent_is_hello_smf(data, off):
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                val first = (hi * 65536) + lo
                val size = _u32_le(data, off + 28)
                return _arm_read_file_chain(dev, first_cluster: first, size: size)
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    val apps_cluster = _arm_fat32_find_apps_cluster(dev)
    if apps_cluster < 2:
        return []
    _arm_fat32_read_hello_smf_from_dir(dev, apps_cluster)

fn _arm_fat32_read_hello_smf_from_dir(dev: VirtioBlkDriver, start_cluster: u64) -> [u8]:
    var dir_cluster: u64 = start_cluster
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while off + 32 <= data_len:
            if _byte(data, off) == 0:
                return []
            if _byte(data, off) != 0xE5 and _byte(data, off + 11) != 0x0F and _arm_dirent_is_hello_smf(data, off):
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                val first = (hi * 65536) + lo
                val size = _u32_le(data, off + 28)
                return _arm_read_file_chain(dev, first_cluster: first, size: size)
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    []

fn _arm_fat32_read_short_name_from_dir(dev: VirtioBlkDriver, start_cluster: u64, short_name: text) -> [u8]:
    var dir_cluster: u64 = start_cluster
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while off + 32 <= data_len:
            if start_cluster == 2 and short_name == "HELLOSMF.SMF" and (off == 0 or off == 32 or off == 64 or off == 256 or off == 320 or off == 448):
                _arm_vfs_log("[vfs-root-match] off={off} b0={_byte(data, off)} b1={_byte(data, off + 1)} b2={_byte(data, off + 2)} b3={_byte(data, off + 3)} attr={_byte(data, off + 11)}")
            if _byte(data, off) == 0:
                return []
            if _byte(data, off) != 0xE5 and _byte(data, off + 11) != 0x0F and _arm_dirent_matches_short_name(data, off, short_name):
                _arm_vfs_log("[vfs-root-match] hit off={off} name={short_name} hi={_u16_le(data, off + 20)} lo={_u16_le(data, off + 26)} size={_u32_le(data, off + 28)}")
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                val first = (hi * 65536) + lo
                val size = _u32_le(data, off + 28)
                return _arm_read_file_chain(dev, first_cluster: first, size: size)
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    []

fn _arm_fat32_find_sys_cluster(dev: VirtioBlkDriver) -> u64:
    var dir_cluster: u64 = 2
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while off + 32 <= data_len:
            if _byte(data, off) == 0:
                return 0
            if _byte(data, off) != 0xE5 and _byte(data, off + 11) == 0x10 and _arm_dirent_is_sys_dir(data, off):
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                return (hi * 65536) + lo
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    0

fn _arm_fat32_find_apps_cluster(dev: VirtioBlkDriver) -> u64:
    var dir_cluster = _arm_fat32_find_sys_cluster(dev)
    if dir_cluster < 2:
        return 0
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while off + 32 <= data_len:
            if _byte(data, off) == 0:
                return 0
            if _byte(data, off) != 0xE5 and _byte(data, off + 11) == 0x10 and _arm_dirent_is_apps_dir(data, off):
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                return (hi * 65536) + lo
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    0

fn _arm_fat32_read_sys_version_from_dev(dev: VirtioBlkDriver, path: text) -> [u8]:
    var dir_cluster = _arm_fat32_find_sys_cluster(dev)
    if dir_cluster < 2:
        return []
    while dir_cluster >= 2 and dir_cluster < 0x0FFFFFF8:
        val data = _arm_read_cluster(dev, dir_cluster)
        var off: i32 = 0
        val data_len = rt_arm_array_len_u32(data).to_i32()
        while off + 32 <= data_len:
            if _byte(data, off) == 0:
                return []
            if _byte(data, off) != 0xE5 and _byte(data, off + 11) != 0x0F and _arm_dirent_is_version_txt(data, off):
                val hi = _u16_le(data, off + 20)
                val lo = _u16_le(data, off + 26)
                val first = (hi * 65536) + lo
                val size = _u32_le(data, off + 28)
                return _arm_read_file_chain(dev, first_cluster: first, size: size)
            off = off + 32
        dir_cluster = _arm_fat_next(dev, dir_cluster)
    []

fn _arm_fat32_read_path_from_dev(dev: VirtioBlkDriver, path: text) -> [u8]:
    val mapped = _arm_exec_alias(path)
    val short_name = _arm_short_name_for_mapped_path(mapped)
    if mapped == "/HELLOSMF.SMF":
        return _arm_fat32_read_short_name_from_dir(dev, 2, short_name)
    if _text_has_prefix(mapped, "/SYS/APPS/"):
        val apps_cluster = _arm_fat32_find_apps_cluster(dev)
        if apps_cluster >= 2:
            val app_bytes = _arm_fat32_read_short_name_from_dir(dev, apps_cluster, short_name)
            if rt_arm_array_len_u32(app_bytes) > 0:
                return app_bytes
        return _arm_fat32_read_short_name_from_dir(dev, 2, short_name)
    if _text_has_prefix(mapped, "/SYS/"):
        val sys_cluster = _arm_fat32_find_sys_cluster(dev)
        if sys_cluster < 2:
            return []
        if short_name == "VERSION.TXT":
            return _arm_fat32_read_sys_version_from_dev(dev, mapped)
        return _arm_fat32_read_short_name_from_dir(dev, sys_cluster, short_name)
    if _text_has_prefix(mapped, "/") and short_name != "":
        return _arm_fat32_read_short_name_from_dir(dev, 2, short_name)
    []
