extern fn rt_time_now_unix_micros() -> i64

# ============================================================================
# Module-Level State
# ============================================================================

var g_vfs: VfsManager = VfsManager.new()
var g_nvme: NvmeDriver = NvmeDriver.new()

class VfsFileSize:
    bytes: i64

    me fn to_i64() -> i64:
        self.bytes
var g_adapter: NvmeBlockAdapter = NvmeBlockAdapter.new(g_nvme)
var g_c_adapter: CNvmeBlockAdapter = CNvmeBlockAdapter.new()
var g_root_fat32: Fat32Core? = nil
var g_root_nvfs_hosted: NvfsHostedDriver? = nil
var g_vfs_initialized: bool = false
var g_vfs_boot_storage_provider: text = "not-mounted"
var g_vfs_boot_storage_pure_simple: bool = false
var g_vfs_nvme_active_leases: [NvmeFilesystemLease] = []
var g_vfs_nvme_direct_adapter_leases: [NvmeFilesystemLease] = []
var g_vfs_nvme_direct_adapters: [NvmeBlockAdapter] = []
# M1 mount table — wired at boot after NVMe init succeeds (see vfs_boot_init).
var g_mount_table: MountTable = MountTable.new()

# ============================================================================
# Boot Init
# ============================================================================

pub fn vfs_boot_init() -> bool:
    """Initialize the full storage stack: PCI -> NVMe -> FAT32 -> VFS.

    Prefers the pure-Simple NVMe -> lease-backed BlockDevice -> FAT32 path.
    Falls back to the C NVMe bridge on baremetal while the pure path is still
    being hardened against hardware-specific mount failures.

    Returns true if VFS is ready to serve file requests.
    """
    log_raw_println("[vfs-init] Starting storage stack initialization...")
    g_vfs_boot_storage_provider = "not-mounted"
    g_vfs_boot_storage_pure_simple = false
    g_vfs_nvme_active_leases = []
    g_vfs_nvme_direct_adapter_leases = []
    g_vfs_nvme_direct_adapters = []

    pcimgr_init()
    log_raw_println("[vfs-init] PCI cache ready")
    # Use the i64 variant with explicit i64 literals — the u8 path
    # (pcimgr_find_by_class) silently mismatches NVMe class/subclass on
    # baremetal Cranelift due to an integer-width comparison bug
    # (SYS-GUI-007 root cause).
    val nvme_class: i64 = 1  # PCI_CLASS_STORAGE (0x01)
    val nvme_sub: i64 = 8    # PCI_SUBCLASS_NVME (0x08)
    val nvme_idx = pcimgr_find_by_class_i64(nvme_class, nvme_sub)
    if nvme_idx < 0:
        log_raw_println("[vfs-init] No NVMe device found -- VFS unavailable")
        return _vfs_boot_init_virtio_fat32()
    log_raw_println("[vfs-init] Found NVMe device at index {nvme_idx}")

    if _vfs_boot_init_pure_nvme_fat32(nvme_idx.to_u64()):
        return true
    log_raw_println("[vfs-init] pure-Simple NVMe + FAT32 unavailable; falling back to C bridge")

    log_raw_println("[vfs-init] Initializing C-backed NVMe block adapter...")
    val adapter_init = g_c_adapter.init_c_bridge()
    if not adapter_init:
        log_raw_println("[vfs-init] C NVMe adapter init failed")
        return _vfs_boot_init_virtio_fat32()
    log_raw_println("[vfs-init] C NVMe controller initialized!")
    log_raw_println("[vfs-init] C NVMe + FAT32 verified (via C driver)")
    g_vfs_initialized = true
    g_vfs_boot_storage_provider = "c-boot-bridge"
    g_vfs_boot_storage_pure_simple = false

    # Keep VFS available through the C FAT32 driver-backed executable read path
    # while the pure-Simple FAT32 boot path is being hardened for every
    # baremetal image variant. Apps are still loaded from the FAT32 image as
    # separate processes, while only this fallback storage path remains
    # baremetal-aware.
    log_raw_println("[vfs-init] FAT32 executable VFS path ready")

    val manifest_bytes = simpleos_fat32_read_path_array("/SYS/APPS/APPIDX.TXT")
    if manifest_bytes.len() > 0:
        val manifest_text = _vfs_bytes_to_text(manifest_bytes, manifest_bytes.len().to_u64())
        app_registry_load(manifest_text)
        log_raw_println("[vfs-init] app-registry loaded from manifest")
    else:
        app_registry_load_hardcoded_fallback()
        log_raw_println("[vfs-init] app-registry loaded from hardcoded fallback")

    val exec_probe_path = "/SYS/APPS/BROWSMF.SMF"
    val exec_probe_size = simpleos_fat32_read_path_size(exec_probe_path)
    if exec_probe_size <= 4:
        log_raw_println("[vfs-init] executable load probe failed path={exec_probe_path} size={exec_probe_size}")
        return false
    if exec_probe_size.to_u64() > FAT32_PATH_READ_BUFFER_MAX:
        log_raw_println("[vfs-init] executable load probe failed path={exec_probe_path} oversize={exec_probe_size}")
        return false
    val exec_probe_read = simpleos_fat32_read_path(exec_probe_path)
    if exec_probe_read != 0:
        log_raw_println("[vfs-init] executable load probe failed path={exec_probe_path} rc={exec_probe_read}")
        return false
    if not _known_app_has_elf_magic(simpleos_fat32_path_read_buffer_addr()):
        log_raw_println("[vfs-init] executable load probe failed path={exec_probe_path} invalid_elf")
        return false
    val browser_probe_bytes = _copy_bytes_from_addr(simpleos_fat32_path_read_buffer_addr(), exec_probe_size.to_u64())
    app_registry_cache_bytes("/sys/apps/browser_demo", browser_probe_bytes)
    log_raw_println("[vfs-init] executable load probe ok path=/sys/apps/browser_demo bytes={exec_probe_size}")
    for seed_entry in app_registry_boot_seed_entries():
        if seed_entry.canonical_path == "/sys/apps/browser_demo":
            continue
        val seed_fat32 = app_registry_fat32_alias(seed_entry.canonical_path)
        if seed_fat32 == nil:
            continue
        val seed_path = seed_fat32.unwrap()
        val seed_root = app_registry_root_alias(seed_entry.canonical_path)
        var fat32_path = seed_path
        if seed_root != nil:
            val root_bytes = _seed_c_fat32_exec_bytes(seed_entry.canonical_path, seed_root.unwrap())
            if root_bytes.len() > 0:
                app_registry_cache_bytes(seed_entry.canonical_path, root_bytes)
                continue
        val seed_bytes = _seed_c_fat32_exec_bytes(seed_entry.canonical_path, fat32_path)
        if seed_bytes.len() > 0:
            app_registry_cache_bytes(seed_entry.canonical_path, seed_bytes)

    log_raw_println("[vfs-init] VFS ready (C-backed)")
    return true

pub fn vfs_boot_init_production() -> bool:
    """Initialize VFS for production NVMe boot and fail closed on fallback storage."""
    if not vfs_boot_init():
        return false
    val reason = vfs_boot_storage_acceptance_reason(
        g_vfs_initialized,
        g_vfs_boot_storage_provider,
        g_vfs_boot_storage_pure_simple
    )
    if reason != "ready":
        log_raw_println("[vfs-init] production boot storage rejected: {reason}")
        return false
    true

fn _vfs_boot_init_pure_nvme_fat32(nvme_idx: u64) -> bool:
    """Try the pure-Simple NVMe -> BlockDevice -> FAT32 stack first."""
    log_raw_println("[vfs-init] Trying pure-Simple NVMe + FAT32 stack...")
    val grant_result = pcimgr_grant_device(nvme_idx, 0)
    if grant_result.is_err():
        log_raw_println("[vfs-init] pure-Simple NVMe grant failed: {grant_result.unwrap_err()}")
        return false
    g_nvme = NvmeDriver.new()
    val grant = grant_result.unwrap()
    val nvme_init = g_nvme.init_from_grant(grant)
    if nvme_init.is_err():
        log_raw_println("[vfs-init] pure-Simple NVMe init failed: {nvme_init.unwrap_err()}")
        return false
    val transfer_evidence_result = g_nvme.transfer_evidence_from_reversible_probe(
        0u64,
        "system-driver",
        "kernel-owned-resource",
        "system-kernel-namespace",
        device_grant_is_isolated(grant),
        device_grant_is_isolated(grant)
    )
    if transfer_evidence_result.is_err():
        log_raw_println("[vfs-init] pure-Simple NVMe transfer probe failed: {transfer_evidence_result.unwrap_err()}")
        return false
    val lease_result = vfs_boot_nvme_system_fat32_lease_from_transfer_evidence(
        g_nvme.get_sector_size(),
        g_nvme.get_sector_count(),
        transfer_evidence_result.unwrap()
    )
    if lease_result.is_err():
        log_raw_println("[vfs-init] pure-Simple NVMe evidence lease failed: {lease_result.unwrap_err()}")
        return false
    val lease = lease_result.unwrap()
    val adapter_result = NvmeBlockAdapter.for_filesystem_lease(g_nvme, lease, NvmeFilesystemConsumer.Fat32)
    if adapter_result.is_err():
        log_raw_println("[vfs-init] pure-Simple NVMe lease adapter failed: {adapter_result.unwrap_err()}")
        return false
    g_adapter = adapter_result.unwrap()
    val bounce_init = g_adapter.init_bounce_buffer()
    if bounce_init.is_err():
        log_raw_println("[vfs-init] pure-Simple NVMe bounce buffer failed: {bounce_init.unwrap_err()}")
        return false
    var root = Fat32Core.new(g_adapter)
    val mount_result = root.mount("", "")
    if mount_result.is_err():
        log_raw_println("[vfs-init] pure-Simple FAT32 mount failed: {mount_result.unwrap_err()}")
        return false
    val version_probe = _g_vfs_root_read_file_bytes_once(root, "/VERSION.TXT")
    if version_probe.len() <= 0:
        log_raw_println("[vfs-init] version file read probe failed path=/VERSION.TXT")
        return false
    _seed_root_fat32_app_registry(root)
    var exec_probe = _g_vfs_root_read_file_bytes_once(root, "/SYS/APPS/BROWSMF.SMF")
    if exec_probe.len() <= 4 or not _bytes_have_elf_magic(exec_probe):
        # Wave-4a bake produces flat-root images (no subdir support);
        # try root /BROWSMF.SMF as fallback.
        log_raw_println("[vfs-init] subdir probe failed, trying root /BROWSMF.SMF")
        exec_probe = _g_vfs_root_read_file_bytes_once(root, "/BROWSMF.SMF")
        if exec_probe.len() <= 4 or not _bytes_have_elf_magic(exec_probe):
            log_raw_println("[vfs-init] executable load probe failed path=/SYS/APPS/BROWSMF.SMF and /BROWSMF.SMF")
            return false
    g_root_fat32 = Some(root)
    g_vfs_initialized = true
    g_vfs_boot_storage_provider = "simple-driver"
    g_vfs_boot_storage_pure_simple = true
    g_vfs_nvme_active_leases = [lease]
    g_vfs_nvme_direct_adapter_leases = [lease]
    g_vfs_nvme_direct_adapters = [g_adapter]
    app_registry_cache_bytes("/sys/apps/browser_demo", exec_probe)
    _seed_root_fat32_exec_cache(root)
    log_raw_println("[vfs-init] version file read ok path=/sys/version.txt bytes={version_probe.len()}")
    log_raw_println("[vfs-init] executable load probe ok path=/sys/apps/browser_demo.smf bytes={exec_probe.len()}")
    log_raw_println("[vfs-init] VFS ready (pure-Simple NVMe + FAT32)")
    true

fn vfs_boot_nvme_system_fat32_lease(sector_size: u32, sector_count: u64, grant: DeviceGrant) -> NvmeFilesystemLease:
    """Build the system FAT32 lease used by the pure-Simple boot path."""
    val ns = NvmeNamespaceIdentity(
        controller_id: 0,
        nsid: 1,
        lba_size: sector_size,
        lba_count: sector_count,
        eui64: 0,
        nguid_lo: 0,
        nguid_hi: 0,
        uuid_lo: 0,
        uuid_hi: 0
    )
    val queue = NvmeQueueAssignment(
        queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
        role: NvmeQueueRole.System,
        controller_id: 0,
        nsid: 1,
        owner_task: 0,
        max_depth: 128,
        rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
    )
    nvme_filesystem_lease(
        ns,
        0u64,
        sector_count,
        NvmeNamespaceMode.System,
        queue,
        "simple-driver",
        device_grant_resource_set_label(grant),
        true,
        device_grant_is_isolated(grant)
    )

fn vfs_boot_nvme_system_fat32_lease_from_transfer_evidence(
    sector_size: u32,
    sector_count: u64,
    evidence: NvmeTransferEvidence
) -> Result<NvmeFilesystemLease, text>:
    """Build the production boot FAT32 lease only after NVMe transfer evidence is ready."""
    val ns = NvmeNamespaceIdentity(
        controller_id: 0,
        nsid: 1,
        lba_size: sector_size,
        lba_count: sector_count,
        eui64: 0,
        nguid_lo: 0,
        nguid_hi: 0,
        uuid_lo: 0,
        uuid_hi: 0
    )
    val queue = NvmeQueueAssignment(
        queue_id: SIMPLEOS_NVME_SYSTEM_QUEUE_ID,
        role: NvmeQueueRole.System,
        controller_id: 0,
        nsid: 1,
        owner_task: 0,
        max_depth: 128,
        rights: CAP_RIGHT_READ + CAP_RIGHT_WRITE + CAP_RIGHT_QUEUE_SUBMIT
    )
    nvme_filesystem_lease_from_transfer_evidence(
        evidence,
        ns,
        0u64,
        sector_count,
        queue,
        NvmeFilesystemConsumer.Fat32
    )

fn _vfs_boot_init_virtio_fat32() -> bool:
    """Initialize VFS from QEMU virtio-blk FAT32 media on ARM virt machines."""
    log_raw_println("[vfs-init] Starting VirtIO-BLK FAT32 initialization...")
    val dev_opt = VirtioBlkDriver.probe()
    if dev_opt == nil:
        log_raw_println("[vfs-init] No VirtIO-BLK device found -- VFS unavailable")
        return false
    var dev: VirtioBlkDriver = dev_opt.unwrap()
    val dev_init = dev.init()
    if dev_init.is_err():
        log_raw_println("[vfs-init] VirtIO-BLK init failed")
        return false

    var root = Fat32Core.new(dev)
    val mount_result = root.mount("", "")
    if mount_result.is_err():
        log_raw_println("[vfs-init] VirtIO FAT32 mount failed: {mount_result.unwrap_err()}")
        return false

    g_root_fat32 = Some(root)
    g_vfs_initialized = true
    g_vfs_boot_storage_provider = "virtio-blk"
    g_vfs_boot_storage_pure_simple = true
    g_vfs_nvme_active_leases = []
    g_vfs_nvme_direct_adapter_leases = []
    g_vfs_nvme_direct_adapters = []
    log_raw_println("[vfs-init] VirtIO FAT32 mounted at /")

    val probe = g_vfs_read_file_bytes("/SYS/APPS/HELLOSMF.SMF")
    if probe.len() <= 4:
        log_raw_println("[vfs-init] executable load probe failed path=/SYS/APPS/HELLOSMF.SMF")
        return false
    log_raw_println("[vfs-init] executable load probe ok path=/sys/apps/hello_world.smf bytes={probe.len()}")
    log_raw_println("[vfs-init] VFS ready (VirtIO-BLK FAT32)")
    true

# ============================================================================
# VFS IPC Service
# ============================================================================

pub fn vfs_service_start():
    """Start the VFS IPC service loop (blocking).

    For cooperative scheduling, use vfs_service_init_port() + vfs_service_poll().
    """
    if not g_vfs_initialized:
        log_raw_println("[vfs] Cannot start service -- not initialized")
        return
    var service = VfsService.new(g_vfs)
    service.start()

fn vfs_boot_nvme_active_lease_count_for_test() -> u64:
    g_vfs_nvme_active_leases.len()

fn vfs_boot_nvme_direct_adapter_count_for_test() -> u64:
    g_vfs_nvme_direct_adapters.len()

fn vfs_boot_nvme_reset_active_leases_for_test():
    g_vfs_nvme_active_leases = []
    g_vfs_nvme_direct_adapter_leases = []
    g_vfs_nvme_direct_adapters = []

fn vfs_boot_nvme_record_active_lease_for_test(lease: NvmeFilesystemLease) -> text:
    val reason = nvme_filesystem_lease_set_acceptance_reason(g_vfs_nvme_active_leases, lease)
    if reason != "ready":
        return reason
    g_vfs_nvme_active_leases = g_vfs_nvme_active_leases.push(lease)
    "ready"

fn vfs_boot_nvme_active_lease_acceptance_reason(lease: NvmeFilesystemLease) -> text:
    nvme_filesystem_lease_set_acceptance_reason(g_vfs_nvme_active_leases, lease)

fn vfs_boot_nvme_shared_driver_ready_for_user_assignment() -> text:
    val storage_reason = vfs_boot_storage_acceptance_reason(
        g_vfs_initialized,
        g_vfs_boot_storage_provider,
        g_vfs_boot_storage_pure_simple
    )
    if storage_reason != "ready":
        return "nvme-user-assign-boot-storage-not-ready:" + storage_reason
    if not g_nvme.is_initialized():
        return "nvme-user-assign-driver-not-initialized"
    if g_nvme.get_sector_count() == 0u64:
        return "nvme-user-assign-driver-empty-namespace"
    if g_nvme.get_sector_size() < 512u32:
        return "nvme-user-assign-driver-invalid-sector-size"
    "ready"

fn vfs_boot_nvme_release_active_lease(lease: NvmeFilesystemLease) -> text:
    var remaining: [NvmeFilesystemLease] = []
    var remaining_adapter_leases: [NvmeFilesystemLease] = []
    var remaining_adapters: [NvmeBlockAdapter] = []
    var removed = false
    for active in g_vfs_nvme_active_leases:
        if not removed and nvme_filesystem_lease_same_identity(active, lease):
            removed = true
        else:
            remaining = remaining.push(active)
    if not removed:
        return "nvme-fs-active-lease-not-found"

    var adapter_idx: i32 = 0
    for adapter_lease in g_vfs_nvme_direct_adapter_leases:
        if not nvme_filesystem_lease_same_identity(adapter_lease, lease):
            remaining_adapter_leases = remaining_adapter_leases.push(adapter_lease)
            if adapter_idx < g_vfs_nvme_direct_adapters.len():
                remaining_adapters = remaining_adapters.push(g_vfs_nvme_direct_adapters[adapter_idx])
        adapter_idx = adapter_idx + 1

    g_vfs_nvme_active_leases = remaining
    g_vfs_nvme_direct_adapter_leases = remaining_adapter_leases
    g_vfs_nvme_direct_adapters = remaining_adapters
    "ready"

fn vfs_boot_nvme_submit_active_lease_direct_4k(lease: NvmeFilesystemLease, req: DirectIoRequest) -> Result<DirectIoResult, FsError>:
    """Submit 4KiB direct I/O through the concrete adapter for an admitted NVMe filesystem lease."""
    var idx: i32 = 0
    for adapter_lease in g_vfs_nvme_direct_adapter_leases:
        if nvme_filesystem_lease_same_identity(adapter_lease, lease):
            if idx >= g_vfs_nvme_direct_adapters.len():
                return Err(FsError.StaleHandle)
            return g_vfs_nvme_direct_adapters[idx].submit_direct_4k_shared_dma(req)
        idx = idx + 1
    Err(FsError.NotFound)

fn vfs_boot_nvme_submit_active_lease_direct_4k_batch(lease: NvmeFilesystemLease, req: DirectIoBatchRequest) -> Result<DirectIoResult, FsError>:
    """Submit batched 4KiB direct I/O through the concrete adapter for an admitted NVMe filesystem lease."""
    var idx: i32 = 0
    for adapter_lease in g_vfs_nvme_direct_adapter_leases:
        if nvme_filesystem_lease_same_identity(adapter_lease, lease):
            if idx >= g_vfs_nvme_direct_adapters.len():
                return Err(FsError.StaleHandle)
            return g_vfs_nvme_direct_adapters[idx].submit_direct_4k_shared_dma_batch(req)
        idx = idx + 1
    Err(FsError.NotFound)

fn vfs_boot_nvme_filesystem_direct_io_extension(driver: DriverInstance) -> Result<DirectIoExt, FsError>:
    """Require the mounted filesystem driver to opt in before lease DirectIo submission."""
    val ext = driver.probe(Capability.DirectIo)
    match ext:
        case Some(Extension.DirectIo(direct)):
            Ok(direct)
        case _:
            Err(FsError.Unsupported)

fn vfs_boot_nvme_submit_filesystem_direct_4k(driver: DriverInstance, lease: NvmeFilesystemLease, req: DirectIoRequest) -> Result<DirectIoResult, FsError>:
    """Resolve a filesystem DirectIo request to a storage extent before NVMe submission."""
    val ext = vfs_boot_nvme_filesystem_direct_io_extension(driver)
    if ext.is_err():
        return Err(ext.unwrap_err())
    val valid = ext.unwrap().validate_shared_buffer(req.file_offset, req.buffer)
    if valid.is_err():
        return Err(valid.unwrap_err())
    val extent = driver.direct_io_extent_for_handle(FileHandle(id: req.handle_id), req.file_offset, 4096u64)
    if extent.is_err():
        return Err(extent.unwrap_err())
    val mapped = extent.unwrap()
    if mapped.byte_len != 4096u64:
        return Err(FsError.InvalidArg)
    val storage_offset = (mapped.storage_lba * mapped.sector_size.to_u64()) as i64
    val storage_req = DirectIoRequest(
        handle_id: req.handle_id,
        file_offset: storage_offset,
        op: req.op,
        buffer: req.buffer,
        timeout_polls: req.timeout_polls
    )
    vfs_boot_nvme_submit_active_lease_direct_4k(lease, storage_req)

fn vfs_boot_nvme_submit_filesystem_direct_4k_batch(driver: DriverInstance, lease: NvmeFilesystemLease, req: DirectIoBatchRequest) -> Result<DirectIoResult, FsError>:
    """Resolve filesystem DirectIo batch offsets to storage extents before NVMe submission."""
    val ext = vfs_boot_nvme_filesystem_direct_io_extension(driver)
    if ext.is_err():
        return Err(ext.unwrap_err())
    val valid = direct_io_validate_batch(ext.unwrap(), req, 4096u64)
    if valid.is_err():
        return Err(valid.unwrap_err())
    var storage_offsets: [i64] = []
    for offset in req.file_offsets:
        val extent = driver.direct_io_extent_for_handle(FileHandle(id: req.handle_id), offset, 4096u64)
        if extent.is_err():
            return Err(extent.unwrap_err())
        val mapped = extent.unwrap()
        if mapped.byte_len != 4096u64:
            return Err(FsError.InvalidArg)
        storage_offsets.push((mapped.storage_lba * mapped.sector_size.to_u64()) as i64)
    val storage_req = DirectIoBatchRequest(
        handle_id: req.handle_id,
        file_offsets: storage_offsets,
        op: req.op,
        buffer: req.buffer,
        timeout_polls: req.timeout_polls
    )
    vfs_boot_nvme_submit_active_lease_direct_4k_batch(lease, storage_req)

fn _vfs_boot_q35_elapsed_us(start_us: i64, end_us: i64) -> u64:
    if end_us <= start_us:
        return 1u64
    (end_us - start_us).to_u64()

fn _vfs_boot_q35_iops(ops: u64, elapsed_us: u64) -> u64:
    if elapsed_us == 0u64:
        return 1u64
    val iops = (ops * 1000000u64) / elapsed_us
    if iops == 0u64:
        return 1u64
    iops

fn _vfs_boot_q35_relative_4k_offset(lease: NvmeFilesystemLease, run: u32, op: u32) -> i64:
    val sectors_per_4k = 4096u64 / lease.namespace.lba_size.to_u64()
    var slot_count = lease.lba_count / sectors_per_4k
    if slot_count <= 2u64:
        return 0
    if slot_count > 128u64:
        slot_count = 128u64
    val slot = 1u64 + (((run.to_u64() * 13u64) + (op.to_u64() * 17u64)) % (slot_count - 1u64))
    (slot * 4096u64) as i64

fn _vfs_boot_q35_perf_u64_field(text_value: text, prefix: text) -> Result<u64, text>:
    var normalized = text_value.replace("\n", " ")
    normalized = normalized.replace("\r", " ")
    normalized = normalized.replace("\t", " ")
    for part in normalized.split(" "):
        val token = part.trim()
        if token.starts_with(prefix):
            val value_text = token.substring(prefix.len(), token.len()).trim()
            if value_text.len() == 0:
                return Err("invalid-" + prefix)
            var value: u64 = 0u64
            for ch in value_text:
                if ch < "0" or ch > "9":
                    return Err("invalid-" + prefix)
                val digit = ch.to_i32() - "0".to_i32()
                value = value * 10u64 + digit.to_u64()
            if value == 0u64:
                return Err("invalid-" + prefix)
            return Ok(value)
    Err("missing-" + prefix)

fn _vfs_boot_q35_read_cfat_baseline_text() -> text:
    if g_root_fat32 == nil:
        return ""
    val bytes = _g_vfs_root_read_file_bytes_once(g_root_fat32.unwrap(), "/SYS/PERF/CFAT4K.TXT")
    if bytes.len() == 0:
        return ""
    _vfs_bytes_to_text(bytes, bytes.len().to_u64())

fn _vfs_boot_q35_perf_marker_with_cfat_baseline(
    simple_read_iops: u64,
    simple_write_iops: u64,
    read_p99_us: u64,
    write_p99_us: u64,
    fs_consumers: text,
    queue_depth: u16
) -> text:
    val baseline = _vfs_boot_q35_read_cfat_baseline_text()
    if baseline.len() == 0:
        return "nvme_perf reason=c-baseline-missing-iops simple_provider=simple-driver " +
            "workload=4k-random-read-write io_size_bytes=4096 " +
            "direct_io_path=nvme-lease-shared-dma-4k fs_consumers=" + fs_consumers + " " +
            "c_bridge_used=false common_logic_shared=true allocation_per_io=false " +
            "simple_read_iops=" + simple_read_iops.to_text() +
            " simple_write_iops=" + simple_write_iops.to_text() +
            " simple_read_p99_us=" + read_p99_us.to_text() +
            " simple_write_p99_us=" + write_p99_us.to_text() +
            " c_read_iops=0 c_write_iops=0 c_read_p99_us=0 c_write_p99_us=0 " +
            "queue_depth=" + queue_depth.to_text() + " warm_runs=3 max_rss_kib=1"

    val c_read = _vfs_boot_q35_perf_u64_field(baseline, "c_read_iops=")
    val c_write = _vfs_boot_q35_perf_u64_field(baseline, "c_write_iops=")
    val c_read_p99 = _vfs_boot_q35_perf_u64_field(baseline, "c_read_p99_us=")
    val c_write_p99 = _vfs_boot_q35_perf_u64_field(baseline, "c_write_p99_us=")
    if c_read.is_err() or c_write.is_err() or c_read_p99.is_err() or c_write_p99.is_err():
        return "nvme_perf reason=c-baseline-missing-iops simple_provider=simple-driver " +
            "workload=4k-random-read-write io_size_bytes=4096 " +
            "direct_io_path=nvme-lease-shared-dma-4k fs_consumers=" + fs_consumers + " " +
            "c_bridge_used=false common_logic_shared=true allocation_per_io=false " +
            "simple_read_iops=" + simple_read_iops.to_text() +
            " simple_write_iops=" + simple_write_iops.to_text() +
            " simple_read_p99_us=" + read_p99_us.to_text() +
            " simple_write_p99_us=" + write_p99_us.to_text() +
            " c_read_iops=0 c_write_iops=0 c_read_p99_us=0 c_write_p99_us=0 " +
            "queue_depth=" + queue_depth.to_text() + " warm_runs=3 max_rss_kib=1"

    real_device_q35_pure_simple_perf_marker_from_measurements(
        simple_read_iops,
        simple_write_iops,
        read_p99_us,
        write_p99_us,
        c_read.unwrap(),
        c_write.unwrap(),
        c_read_p99.unwrap(),
        c_write_p99.unwrap(),
        queue_depth,
        3u32,
        1u64,
        false
    )

fn _vfs_boot_q35_ready_fs_consumers(lease: NvmeFilesystemLease) -> Result<text, text>:
    val fat = nvme_filesystem_lease_reason(lease, NvmeFilesystemConsumer.Fat32)
    if fat != "ready":
        return Err("fat32:" + fat)
    val nvfs = nvme_filesystem_lease_reason(lease, NvmeFilesystemConsumer.Nvfs)
    if nvfs != "ready":
        return Err("nvfs:" + nvfs)
    val dbfs = nvme_filesystem_lease_reason(lease, NvmeFilesystemConsumer.Dbfs)
    if dbfs != "ready":
        return Err("dbfs:" + dbfs)
    Ok("fat32,nvfs,dbfs")

fn vfs_boot_nvme_q35_pure_simple_perf_probe_serial_lines() -> [text]:
    """Emit fail-closed q35 pure-Simple NVMe evidence from real shared-DMA 4K I/O."""
    val storage_reason = vfs_boot_storage_acceptance_reason(
        g_vfs_initialized,
        g_vfs_boot_storage_provider,
        g_vfs_boot_storage_pure_simple
    )
    if storage_reason != "ready":
        return ["[q35-pure-nvme-perf] skipped reason=" + storage_reason]
    if g_vfs_nvme_active_leases.len() == 0:
        return ["[q35-pure-nvme-perf] skipped reason=no-active-nvme-lease"]
    if g_vfs_nvme_direct_adapters.len() == 0:
        return ["[q35-pure-nvme-perf] skipped reason=no-direct-nvme-adapter"]

    val lease = g_vfs_nvme_active_leases[0]
    val fs_consumers = _vfs_boot_q35_ready_fs_consumers(lease)
    if fs_consumers.is_err():
        return ["[q35-pure-nvme-perf] skipped reason=fs-consumer-lease-not-ready detail=" + fs_consumers.unwrap_err()]
    val batch_4k_ops: u32 = 32u32
    val batch_bytes = batch_4k_ops.to_u64() * 4096u64
    val dma_result = dma_alloc(batch_bytes as i64, DmaDir.Bidirectional)
    if dma_result.is_err():
        return ["[q35-pure-nvme-perf] skipped reason=dma-alloc-failed"]
    val dma = dma_result.unwrap()
    val owner = DmaOwner(
        task_id: lease.queue.owner_task,
        bdf_bus: 0u8,
        bdf_device: 0u8,
        bdf_function: 0u8
    )
    val shared = dma_buffer_to_shared(dma, owner, DmaCachePolicy.Coherent, batch_bytes)

    var read_ops: u64 = 0u64
    var write_ops: u64 = 0u64
    var read_total_us: u64 = 0u64
    var write_total_us: u64 = 0u64
    var read_p99_us: u64 = 1u64
    var write_p99_us: u64 = 1u64
    var run: u32 = 0u32
    while run < 3u32:
        var op: u32 = 0u32
        while op < 32u32:
            var offsets: [i64] = []
            var batch_op: u32 = 0u32
            while batch_op < batch_4k_ops and op + batch_op < 32u32:
                offsets.push(_vfs_boot_q35_relative_4k_offset(lease, run, op + batch_op))
                batch_op = batch_op + 1u32
            val read_start = rt_time_now_unix_micros()
            val read_result = vfs_boot_nvme_submit_active_lease_direct_4k_batch(
                lease,
                direct_io_read_batch_request(1u64, offsets, shared, 100000u32)
            )
            val read_elapsed = _vfs_boot_q35_elapsed_us(read_start, rt_time_now_unix_micros())
            if read_result.is_err():
                dma_free(dma)
                return ["[q35-pure-nvme-perf] skipped reason=direct-read-failed"]
            if read_elapsed > read_p99_us:
                read_p99_us = read_elapsed
            read_total_us = read_total_us + read_elapsed
            read_ops = read_ops + offsets.len().to_u64()

            val write_start = rt_time_now_unix_micros()
            val write_result = vfs_boot_nvme_submit_active_lease_direct_4k_batch(
                lease,
                direct_io_write_batch_request(1u64, offsets, shared, 100000u32)
            )
            val write_elapsed = _vfs_boot_q35_elapsed_us(write_start, rt_time_now_unix_micros())
            if write_result.is_err():
                dma_free(dma)
                return ["[q35-pure-nvme-perf] skipped reason=direct-write-failed"]
            if write_elapsed > write_p99_us:
                write_p99_us = write_elapsed
            write_total_us = write_total_us + write_elapsed
            write_ops = write_ops + offsets.len().to_u64()
            op = op + (offsets.len() as u32)
        run = run + 1u32

    dma_free(dma)
    val simple_read_iops = _vfs_boot_q35_iops(read_ops, read_total_us)
    val simple_write_iops = _vfs_boot_q35_iops(write_ops, write_total_us)
    val access = real_device_q35_pure_simple_access_marker(lease.grant_kind, "resource-grant-set:tok=net0")
    val perf = _vfs_boot_q35_perf_marker_with_cfat_baseline(
        simple_read_iops,
        simple_write_iops,
        read_p99_us,
        write_p99_us,
        fs_consumers.unwrap(),
        lease.queue.max_depth
    )
    [access, perf]

fn vfs_boot_nvme_assign_user_namespace_lease(
    evidence: NvmeTransferEvidence,
    grant: DeviceGrant,
    controller_id: u32,
    nsid: u32,
    namespace_lba_size: u32,
    namespace_lba_count: u64,
    base_lba: u64,
    lease_lba_count: u64,
    queue_id: u16,
    owner_task: u64,
    max_depth: u16,
    consumer: NvmeFilesystemConsumer
) -> Result<NvmeFilesystemLease, text>:
    val lease_result = nvme_user_assigned_filesystem_lease_from_grant_checked(
        evidence,
        grant,
        controller_id,
        nsid,
        namespace_lba_size,
        namespace_lba_count,
        base_lba,
        lease_lba_count,
        queue_id,
        owner_task,
        max_depth,
        consumer,
        g_vfs_nvme_active_leases
    )
    if lease_result.is_err():
        return lease_result
    val lease = lease_result.unwrap()
    g_vfs_nvme_active_leases = g_vfs_nvme_active_leases.push(lease)
    Ok(lease)

fn vfs_boot_nvme_assign_user_namespace_driver_instance(
    name: text,
    dev: BlockDevice,
    evidence: NvmeTransferEvidence,
    grant: DeviceGrant,
    controller_id: u32,
    nsid: u32,
    namespace_lba_size: u32,
    namespace_lba_count: u64,
    base_lba: u64,
    lease_lba_count: u64,
    queue_id: u16,
    owner_task: u64,
    max_depth: u16,
    consumer: NvmeFilesystemConsumer
) -> Result<DriverInstance, text>:
    val lease_result = nvme_user_assigned_filesystem_lease_from_grant_checked(
        evidence,
        grant,
        controller_id,
        nsid,
        namespace_lba_size,
        namespace_lba_count,
        base_lba,
        lease_lba_count,
        queue_id,
        owner_task,
        max_depth,
        consumer,
        g_vfs_nvme_active_leases
    )
    if lease_result.is_err():
        return Err(lease_result.unwrap_err())
    val lease = lease_result.unwrap()
    val driver_result = vfs_nvme_driver_instance_for_lease(name, dev, lease, consumer)
    if driver_result.is_err():
        return driver_result
    g_vfs_nvme_active_leases = g_vfs_nvme_active_leases.push(lease)
    driver_result

fn vfs_boot_nvme_assign_user_namespace_hardware_driver_instance(
    name: text,
    evidence: NvmeTransferEvidence,
    grant: DeviceGrant,
    controller_id: u32,
    nsid: u32,
    namespace_lba_size: u32,
    namespace_lba_count: u64,
    base_lba: u64,
    lease_lba_count: u64,
    queue_id: u16,
    owner_task: u64,
    max_depth: u16,
    consumer: NvmeFilesystemConsumer
) -> Result<DriverInstance, text>:
    val driver_ready = vfs_boot_nvme_shared_driver_ready_for_user_assignment()
    if driver_ready != "ready":
        return Err(driver_ready)
    val lease_result = nvme_user_assigned_filesystem_lease_from_grant_checked(
        evidence,
        grant,
        controller_id,
        nsid,
        namespace_lba_size,
        namespace_lba_count,
        base_lba,
        lease_lba_count,
        queue_id,
        owner_task,
        max_depth,
        consumer,
        g_vfs_nvme_active_leases
    )
    if lease_result.is_err():
        return Err(lease_result.unwrap_err())
    val lease = lease_result.unwrap()
    val previous_nsid = g_nvme.get_namespace_id()
    val identify = g_nvme.identify_namespace_id(lease.namespace.nsid)
    if identify.is_err():
        return Err("nvme-user-assign-namespace-identify-failed:" + identify.unwrap_err())
    val queue_ready = g_nvme.ensure_user_data_queue_for_assignment(
        lease.queue.queue_id,
        lease.queue.max_depth,
        lease.namespace.controller_id,
        lease.namespace.nsid,
        lease.queue.owner_task
    )
    if queue_ready.is_err():
        if previous_nsid != lease.namespace.nsid:
            val restore_after_queue = g_nvme.identify_namespace_id(previous_nsid)
            if restore_after_queue.is_err():
                return Err("nvme-user-assign-namespace-restore-failed:" + restore_after_queue.unwrap_err())
        return Err("nvme-user-assign-queue-create-failed:" + queue_ready.unwrap_err())
    val adapter_result = NvmeBlockAdapter.for_filesystem_lease(g_nvme, lease, consumer)
    if adapter_result.is_err():
        if previous_nsid != lease.namespace.nsid:
            val restore_after_adapter = g_nvme.identify_namespace_id(previous_nsid)
            if restore_after_adapter.is_err():
                return Err("nvme-user-assign-namespace-restore-failed:" + restore_after_adapter.unwrap_err())
        return Err(adapter_result.unwrap_err())
    if previous_nsid != lease.namespace.nsid:
        val restore_identify = g_nvme.identify_namespace_id(previous_nsid)
        if restore_identify.is_err():
            return Err("nvme-user-assign-namespace-restore-failed:" + restore_identify.unwrap_err())
    var adapter = adapter_result.unwrap()
    val bounce = adapter.init_bounce_buffer()
    if bounce.is_err():
        return Err(bounce.unwrap_err())
    val driver_result = vfs_nvme_driver_instance_for_lease(name, adapter, lease, consumer)
    if driver_result.is_err():
        return driver_result
    g_vfs_nvme_active_leases = g_vfs_nvme_active_leases.push(lease)
    g_vfs_nvme_direct_adapter_leases = g_vfs_nvme_direct_adapter_leases.push(lease)
    g_vfs_nvme_direct_adapters = g_vfs_nvme_direct_adapters.push(adapter)
    driver_result

# Module-level VFS service instance for cooperative scheduling
var g_vfs_service: VfsService? = nil

pub fn vfs_service_init_port():
    """Initialize the VFS IPC port without entering the blocking loop.

    Use with vfs_service_poll() for cooperative scheduling.
    """
    if not g_vfs_initialized:
        log_raw_println("[vfs] Cannot init port -- not initialized")
        return
    g_vfs_service = VfsService.new(g_vfs)
    g_vfs_service.init_port()

pub fn vfs_service_poll():
    """Process one VFS IPC request if available (non-blocking).

    Call from a cooperative main loop alongside netstack and shell.
    """
    if g_vfs_service != nil:
        g_vfs_service.poll_once()

# ============================================================================
# Query Helpers
# ============================================================================

pub fn vfs_is_ready() -> bool:
    """Check if VFS has been initialized and is ready for file operations."""
    g_vfs_initialized

pub fn vfs_boot_storage_provider() -> text:
    g_vfs_boot_storage_provider

pub fn vfs_boot_storage_is_pure_simple() -> bool:
    g_vfs_boot_storage_pure_simple

fn vfs_boot_storage_acceptance_reason(initialized: bool, provider: text, pure_simple: bool) -> text:
    if not initialized:
        return "not-mounted"
    if not pure_simple:
        return "vfs-boot-storage-not-pure-simple:" + provider
    if provider != "simple-driver":
        return "vfs-boot-storage-not-nvme-simple-driver:" + provider
    "ready"

fn vfs_boot_storage_production_ready(initialized: bool, provider: text, pure_simple: bool) -> bool:
    vfs_boot_storage_acceptance_reason(initialized, provider, pure_simple) == "ready"

pub fn vfs_boot_storage_acceptance_ready() -> bool:
    vfs_boot_storage_production_ready(
        g_vfs_initialized,
        g_vfs_boot_storage_provider,
        g_vfs_boot_storage_pure_simple
    )

pub fn vfs_get_manager() -> VfsManager:
    """Return the global VFS manager instance."""
    g_vfs

# ============================================================================
# Internal helpers used by boot init
# ============================================================================

fn _vfs_bytes_to_text(buf: [u8], count: i64) -> text:
    var result: text = ""
    var i: i64 = 0
    while i < count and i < buf.len():
        result = result + buf[i as i32].chr()
        i = i + 1
    result

fn _known_app_has_elf_magic(buf_addr: u64) -> bool:
    if mmio_read8(buf_addr) != 0x7F.to_u8():
        return false
    if mmio_read8(buf_addr + 1) != 0x45.to_u8():
        return false
    if mmio_read8(buf_addr + 2) != 0x4C.to_u8():
        return false
    if mmio_read8(buf_addr + 3) != 0x46.to_u8():
        return false
    true

fn _bytes_have_elf_magic(bytes: [u8]) -> bool:
    if bytes.len() < 4:
        return false
    bytes[0] == 0x7F.to_u8() and
        bytes[1] == 0x45.to_u8() and
        bytes[2] == 0x4C.to_u8() and
        bytes[3] == 0x46.to_u8()

fn _copy_bytes_from_addr(addr: u64, size: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < size:
        out.push(mmio_read8(addr + i))
        i = i + 1
    out

fn _cache_c_fat32_exec_bytes(path: text) -> [u8]:
    val signed_size = simpleos_fat32_read_path_size(path)
    if signed_size <= 4:
        return []
    val file_size = signed_size.to_u64()
    if file_size > FAT32_PATH_READ_BUFFER_MAX:
        return []
    val read_result = simpleos_fat32_read_path(path)
    if read_result != 0:
        return []
    if not _known_app_has_elf_magic(simpleos_fat32_path_read_buffer_addr()):
        return []
    _copy_bytes_from_addr(simpleos_fat32_path_read_buffer_addr(), file_size)

fn _seed_c_fat32_exec_bytes(label: text, path: text) -> [u8]:
    val bytes = _cache_c_fat32_exec_bytes(path)
    if bytes.len() > 0:
        serial_println("[vfs-fix] {label} seeded len={bytes.len()} path={path}")
    else:
        serial_println("[vfs-fix] {label} probe skipped path={path}")
    bytes

fn _seed_root_fat32_app_registry(root: Fat32Core):
    val manifest_bytes = _g_vfs_root_read_file_bytes_once(root, "/SYS/APPS/APPIDX.TXT")
    if manifest_bytes.len() > 0:
        val manifest_text = _vfs_bytes_to_text(manifest_bytes, manifest_bytes.len().to_u64())
        app_registry_load(manifest_text)
        log_raw_println("[vfs-init] app-registry loaded from pure-Simple FAT32 manifest")
    else:
        app_registry_load_hardcoded_fallback()
        log_raw_println("[vfs-init] app-registry loaded from hardcoded fallback")

fn _seed_root_fat32_exec_bytes(root: Fat32Core, label: text, path: text) -> [u8]:
    val bytes = _g_vfs_root_read_file_bytes_once(root, path)
    if bytes.len() > 4 and _bytes_have_elf_magic(bytes):
        serial_println("[vfs-fix] {label} seeded len={bytes.len()} path={path}")
        return bytes
    serial_println("[vfs-fix] {label} probe skipped path={path}")
    []

fn _seed_root_fat32_exec_cache(root: Fat32Core):
    for seed_entry in app_registry_boot_seed_entries():
        if seed_entry.canonical_path == "/sys/apps/browser_demo":
            continue
        val seed_fat32 = app_registry_fat32_alias(seed_entry.canonical_path)
        if seed_fat32 == nil:
            continue
        val seed_path = seed_fat32.unwrap()
        val seed_root = app_registry_root_alias(seed_entry.canonical_path)
        if seed_root != nil:
            val root_bytes = _seed_root_fat32_exec_bytes(root, seed_entry.canonical_path, seed_root.unwrap())
            if root_bytes.len() > 0:
                app_registry_cache_bytes(seed_entry.canonical_path, root_bytes)
                continue
        val seed_bytes = _seed_root_fat32_exec_bytes(root, seed_entry.canonical_path, seed_path)
        if seed_bytes.len() > 0:
            app_registry_cache_bytes(seed_entry.canonical_path, seed_bytes)

fn g_vfs_root_read_file_bytes(driver: Fat32Core, path: text) -> [u8]:
    val cached = _g_vfs_root_read_file_bytes_once(driver, path)
    if cached.len() > 0:
        return cached

    # Live desktop-disk QEMU currently reaches a state where the persisted
    # root-driver instance can fail lookups even though the device and volume
    # are healthy. Retry with a fresh mount on the same block adapter so
    # filesystem-backed app exec can still use real disk bytes.
    var retry_driver = Fat32Core.new(g_c_adapter)
    val retry_mount = retry_driver.mount("", "")
    if retry_mount.is_err():
        log_raw_println("[vfs-root] retry_mount_failed path={path} err={retry_mount.unwrap_err()}")
        return []
    log_raw_println("[vfs-root] retry_mount_ok path={path}")
    val retried = _g_vfs_root_read_file_bytes_once(retry_driver, path)
    if retried.len() > 0:
        return retried

    []

fn _g_vfs_root_read_file_bytes_once(driver: Fat32Core, path: text) -> [u8]:
    val flags = FileFlags(read: true, write: false, create: false, append: false, truncate: false)
    val stat_r = driver.stat(path)
    if stat_r.is_err():
        log_raw_println("[vfs-root] stat_failed path={path}")
    else:
        log_raw_println("[vfs-root] stat_ok path={path} size={stat_r.unwrap().size}")
    val open_r = driver.open(path, flags)
    if open_r.is_err():
        log_raw_println("[vfs-root] open_failed path={path}")
        return []
    val handle = open_r.unwrap()
    val read_r = driver.read(handle, 1048576)
    driver.close(handle)
    if read_r.is_err():
        log_raw_println("[vfs-root] read_failed path={path}")
        return []
    val data = read_r.unwrap()
    log_raw_println("[vfs-root] read_ok path={path} bytes={data.len()}")
    data
