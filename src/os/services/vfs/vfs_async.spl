# Async VFS Operations
#
# MDSOC: feature dimension, vfs layer
# Async-by-default filesystem interface using notification-based completion.
# Wraps the sync Filesystem trait with Future-based async variants.
#
# Each async method returns an OsFuture that resolves when the underlying
# sync operation completes. Since NVMe already uses notification-based
# completion internally, the sync operations are effectively async at the
# hardware level -- this layer provides the Future interface for composability
# with the OsExecutor.

use os.async.os_future.{OsFuture, ReadyFuture}
use os.async.os_poll.{OsPoll}
use os.async.os_waker.{OsWaker}
use os.services.vfs.vfs.{Filesystem, SeekWhence}
use os.kernel.types.fs_types.{FileFlags, FsNode, DirEntry}

# ============================================================================
# Async Filesystem Trait
# ============================================================================

trait AsyncFilesystem:
    """Async filesystem interface with notification-based completion.

    Each operation returns an OsFuture that resolves when the underlying
    I/O completes. Implementations may return immediately-ready futures
    (wrapping sync calls) or genuinely async futures backed by DMA
    completion notifications.
    """
    fn open_async(path: text, flags: FileFlags) -> OsFuture<Result<u64, text>>
    fn read_async(handle: u64, size: u64) -> OsFuture<Result<[u8], text>>
    fn write_async(handle: u64, data: [u8]) -> OsFuture<Result<u64, text>>
    fn close_async(handle: u64) -> OsFuture<Result<bool, text>>
    fn stat_async(path: text) -> OsFuture<Result<FsNode, text>>
    fn readdir_async(path: text) -> OsFuture<Result<[DirEntry], text>>
    fn mkdir_async(path: text) -> OsFuture<Result<bool, text>>
    fn unlink_async(path: text) -> OsFuture<Result<bool, text>>
    fn rename_async(old_path: text, new_path: text) -> OsFuture<Result<bool, text>>
    fn seek_async(handle: u64, offset: i64, whence: SeekWhence) -> OsFuture<Result<u64, text>>
    fn fs_name() -> text

# ============================================================================
# Ready Futures — Immediately resolved with a Result value
# ============================================================================
#
# Each variant wraps a specific Result type. The poll() method returns
# Ready on the first call with the stored value.

struct ReadyResultU64:
    """Future immediately ready with Result<u64, text>."""
    value: Result<u64, text>

impl OsFuture<Result<u64, text>> for ReadyResultU64:
    fn poll(waker: OsWaker) -> OsPoll<Result<u64, text>>:
        OsPoll.Ready(value: self.value)

struct ReadyResultBytes:
    """Future immediately ready with Result<[u8], text>."""
    value: Result<[u8], text>

impl OsFuture<Result<[u8], text>> for ReadyResultBytes:
    fn poll(waker: OsWaker) -> OsPoll<Result<[u8], text>>:
        OsPoll.Ready(value: self.value)

struct ReadyResultBool:
    """Future immediately ready with Result<bool, text>."""
    value: Result<bool, text>

impl OsFuture<Result<bool, text>> for ReadyResultBool:
    fn poll(waker: OsWaker) -> OsPoll<Result<bool, text>>:
        OsPoll.Ready(value: self.value)

struct ReadyResultFsNode:
    """Future immediately ready with Result<FsNode, text>."""
    value: Result<FsNode, text>

impl OsFuture<Result<FsNode, text>> for ReadyResultFsNode:
    fn poll(waker: OsWaker) -> OsPoll<Result<FsNode, text>>:
        OsPoll.Ready(value: self.value)

struct ReadyResultDirEntries:
    """Future immediately ready with Result<[DirEntry], text>."""
    value: Result<[DirEntry], text>

impl OsFuture<Result<[DirEntry], text>> for ReadyResultDirEntries:
    fn poll(waker: OsWaker) -> OsPoll<Result<[DirEntry], text>>:
        OsPoll.Ready(value: self.value)

# ============================================================================
# SyncToAsyncAdapter — Wraps sync Filesystem as AsyncFilesystem
# ============================================================================

class SyncToAsyncAdapter:
    """Wraps a sync Filesystem impl into AsyncFilesystem.

    Each operation completes immediately since the underlying FS driver
    already blocks on NVMe notification internally. This adapter provides
    the Future interface for consistency with the async pipeline.

    For genuinely pipelined async I/O (e.g., prefetching multiple clusters
    in parallel), a native AsyncFilesystem implementation would bypass this
    adapter and issue multiple NVMe commands concurrently.
    """
    inner: Filesystem
    name: text

impl SyncToAsyncAdapter:
    static fn new(fs: Filesystem, name: text) -> SyncToAsyncAdapter:
        SyncToAsyncAdapter(inner: fs, name: name)

impl AsyncFilesystem for SyncToAsyncAdapter:
    fn open_async(path: text, flags: FileFlags) -> OsFuture<Result<u64, text>>:
        val result = self.inner.open(path, flags)
        ReadyResultU64(value: result)

    fn read_async(handle: u64, size: u64) -> OsFuture<Result<[u8], text>>:
        val result = self.inner.read(handle, size)
        ReadyResultBytes(value: result)

    fn write_async(handle: u64, data: [u8]) -> OsFuture<Result<u64, text>>:
        val result = self.inner.write(handle, data)
        ReadyResultU64(value: result)

    fn close_async(handle: u64) -> OsFuture<Result<bool, text>>:
        val result = self.inner.close(handle)
        ReadyResultBool(value: result)

    fn stat_async(path: text) -> OsFuture<Result<FsNode, text>>:
        val result = self.inner.stat(path)
        ReadyResultFsNode(value: result)

    fn readdir_async(path: text) -> OsFuture<Result<[DirEntry], text>>:
        val result = self.inner.readdir(path)
        ReadyResultDirEntries(value: result)

    fn mkdir_async(path: text) -> OsFuture<Result<bool, text>>:
        val result = self.inner.mkdir(path)
        ReadyResultBool(value: result)

    fn unlink_async(path: text) -> OsFuture<Result<bool, text>>:
        val result = self.inner.unlink(path)
        ReadyResultBool(value: result)

    fn rename_async(old_path: text, new_path: text) -> OsFuture<Result<bool, text>>:
        val result = self.inner.rename(old_path, new_path)
        ReadyResultBool(value: result)

    fn seek_async(handle: u64, offset: i64, whence: SeekWhence) -> OsFuture<Result<u64, text>>:
        val result = self.inner.seek(handle, offset, whence)
        ReadyResultU64(value: result)

    fn fs_name() -> text:
        self.name
