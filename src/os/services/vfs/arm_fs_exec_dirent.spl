# ARM filesystem-exec VFS — directory entry matchers
#
# Per-file byte-level FAT32 8.3 directory entry matchers and the
# short-name key builder used for dynamic directory scans.

fn _arm_dirent_is_hello_smf(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x48 and _byte(data, off + 1) == 0x45 and
        _byte(data, off + 2) == 0x4C and _byte(data, off + 3) == 0x4C and
        _byte(data, off + 4) == 0x4F and _byte(data, off + 5) == 0x53 and
        _byte(data, off + 6) == 0x4D and _byte(data, off + 7) == 0x46 and
        _byte(data, off + 8) == 0x53 and _byte(data, off + 9) == 0x4D and
        _byte(data, off + 10) == 0x46

fn _arm_dirent_is_version_txt(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x56 and _byte(data, off + 1) == 0x45 and
        _byte(data, off + 2) == 0x52 and _byte(data, off + 3) == 0x53 and
        _byte(data, off + 4) == 0x49 and _byte(data, off + 5) == 0x4F and
        _byte(data, off + 6) == 0x4E and _byte(data, off + 7) == 0x20 and
        _byte(data, off + 8) == 0x54 and _byte(data, off + 9) == 0x58 and
        _byte(data, off + 10) == 0x54

fn _arm_dirent_is_scomp_smf(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x53 and _byte(data, off + 1) == 0x43 and
        _byte(data, off + 2) == 0x4F and _byte(data, off + 3) == 0x4D and
        _byte(data, off + 4) == 0x50 and _byte(data, off + 5) == 0x53 and
        _byte(data, off + 6) == 0x4D and _byte(data, off + 7) == 0x46 and
        _byte(data, off + 8) == 0x53 and _byte(data, off + 9) == 0x4D and
        _byte(data, off + 10) == 0x46

fn _arm_dirent_is_sload_smf(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x53 and _byte(data, off + 1) == 0x4C and
        _byte(data, off + 2) == 0x4F and _byte(data, off + 3) == 0x41 and
        _byte(data, off + 4) == 0x44 and _byte(data, off + 5) == 0x53 and
        _byte(data, off + 6) == 0x4D and _byte(data, off + 7) == 0x46 and
        _byte(data, off + 8) == 0x53 and _byte(data, off + 9) == 0x4D and
        _byte(data, off + 10) == 0x46

fn _arm_dirent_is_sint_smf(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x53 and _byte(data, off + 1) == 0x49 and
        _byte(data, off + 2) == 0x4E and _byte(data, off + 3) == 0x54 and
        _byte(data, off + 4) == 0x53 and _byte(data, off + 5) == 0x4D and
        _byte(data, off + 6) == 0x46 and _byte(data, off + 7) == 0x20 and
        _byte(data, off + 8) == 0x53 and _byte(data, off + 9) == 0x4D and
        _byte(data, off + 10) == 0x46

fn _arm_dirent_is_llvm_smf(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x4C and _byte(data, off + 1) == 0x4C and
        _byte(data, off + 2) == 0x56 and _byte(data, off + 3) == 0x4D and
        _byte(data, off + 4) == 0x53 and _byte(data, off + 5) == 0x4D and
        _byte(data, off + 6) == 0x46 and _byte(data, off + 7) == 0x20 and
        _byte(data, off + 8) == 0x53 and _byte(data, off + 9) == 0x4D and
        _byte(data, off + 10) == 0x46

fn _arm_dirent_is_clang_smf(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x43 and _byte(data, off + 1) == 0x4C and
        _byte(data, off + 2) == 0x41 and _byte(data, off + 3) == 0x4E and
        _byte(data, off + 4) == 0x47 and _byte(data, off + 5) == 0x53 and
        _byte(data, off + 6) == 0x4D and _byte(data, off + 7) == 0x46 and
        _byte(data, off + 8) == 0x53 and _byte(data, off + 9) == 0x4D and
        _byte(data, off + 10) == 0x46

fn _arm_dirent_is_rust_smf(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x52 and _byte(data, off + 1) == 0x55 and
        _byte(data, off + 2) == 0x53 and _byte(data, off + 3) == 0x54 and
        _byte(data, off + 4) == 0x53 and _byte(data, off + 5) == 0x4D and
        _byte(data, off + 6) == 0x46 and _byte(data, off + 7) == 0x20 and
        _byte(data, off + 8) == 0x53 and _byte(data, off + 9) == 0x4D and
        _byte(data, off + 10) == 0x46

fn _arm_dirent_is_scomp_man(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x53 and _byte(data, off + 1) == 0x43 and
        _byte(data, off + 2) == 0x4F and _byte(data, off + 3) == 0x4D and
        _byte(data, off + 4) == 0x50 and _byte(data, off + 5) == 0x4D and
        _byte(data, off + 6) == 0x41 and _byte(data, off + 7) == 0x4E and
        _byte(data, off + 8) == 0x54 and _byte(data, off + 9) == 0x58 and
        _byte(data, off + 10) == 0x54

fn _arm_dirent_is_sload_man(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x53 and _byte(data, off + 1) == 0x4C and
        _byte(data, off + 2) == 0x4F and _byte(data, off + 3) == 0x41 and
        _byte(data, off + 4) == 0x44 and _byte(data, off + 5) == 0x4D and
        _byte(data, off + 6) == 0x41 and _byte(data, off + 7) == 0x4E and
        _byte(data, off + 8) == 0x54 and _byte(data, off + 9) == 0x58 and
        _byte(data, off + 10) == 0x54

fn _arm_dirent_is_llvm_man(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x4C and _byte(data, off + 1) == 0x4C and
        _byte(data, off + 2) == 0x56 and _byte(data, off + 3) == 0x4D and
        _byte(data, off + 4) == 0x4D and _byte(data, off + 5) == 0x41 and
        _byte(data, off + 6) == 0x4E and _byte(data, off + 7) == 0x20 and
        _byte(data, off + 8) == 0x54 and _byte(data, off + 9) == 0x58 and
        _byte(data, off + 10) == 0x54

fn _arm_dirent_is_clang_man(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x43 and _byte(data, off + 1) == 0x4C and
        _byte(data, off + 2) == 0x41 and _byte(data, off + 3) == 0x4E and
        _byte(data, off + 4) == 0x47 and _byte(data, off + 5) == 0x4D and
        _byte(data, off + 6) == 0x41 and _byte(data, off + 7) == 0x4E and
        _byte(data, off + 8) == 0x54 and _byte(data, off + 9) == 0x58 and
        _byte(data, off + 10) == 0x54

fn _arm_dirent_is_rust_man(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x52 and _byte(data, off + 1) == 0x55 and
        _byte(data, off + 2) == 0x53 and _byte(data, off + 3) == 0x54 and
        _byte(data, off + 4) == 0x4D and _byte(data, off + 5) == 0x41 and
        _byte(data, off + 6) == 0x4E and _byte(data, off + 7) == 0x20 and
        _byte(data, off + 8) == 0x54 and _byte(data, off + 9) == 0x58 and
        _byte(data, off + 10) == 0x54

fn _arm_dirent_is_toolset_sdn(data: [u8], off: i32) -> bool:
    _byte(data, off) == 0x54 and _byte(data, off + 1) == 0x4F and
        _byte(data, off + 2) == 0x4F and _byte(data, off + 3) == 0x4C and
        _byte(data, off + 4) == 0x53 and _byte(data, off + 5) == 0x45 and
        _byte(data, off + 6) == 0x54 and _byte(data, off + 7) == 0x20 and
        _byte(data, off + 8) == 0x53 and _byte(data, off + 9) == 0x44 and
        _byte(data, off + 10) == 0x4E

fn _arm_dirent_is_sys_dir(data: [u8], off: i32) -> bool:
    _arm_dirent_matches_literal(data, off, [
        0x53.to_u8(), 0x59.to_u8(), 0x53.to_u8(), 0x20.to_u8(), 0x20.to_u8(),
        0x20.to_u8(), 0x20.to_u8(), 0x20.to_u8(), 0x20.to_u8(), 0x20.to_u8(),
        0x20.to_u8()
    ])

fn _arm_dirent_is_apps_dir(data: [u8], off: i32) -> bool:
    _arm_dirent_matches_literal(data, off, [
        0x41.to_u8(), 0x50.to_u8(), 0x50.to_u8(), 0x53.to_u8(), 0x20.to_u8(),
        0x20.to_u8(), 0x20.to_u8(), 0x20.to_u8(), 0x20.to_u8(), 0x20.to_u8(),
        0x20.to_u8()
    ])

fn _arm_fat83_short_name_key(name: text) -> [u8]:
    var base: [u8] = []
    var ext: [u8] = []
    var seen_dot = false
    for ch in name:
        if ch == "." and not seen_dot:
            seen_dot = true
        else if not seen_dot:
            if base.len() < 8:
                base.push(ch.to_u8())
        else:
            if ext.len() < 3:
                ext.push(ch.to_u8())
    while base.len() < 8:
        base.push(0x20.to_u8())
    while ext.len() < 3:
        ext.push(0x20.to_u8())
    var out: [u8] = []
    var i: i32 = 0
    while i < 8:
        out.push(base[i])
        i = i + 1
    i = 0
    while i < 3:
        out.push(ext[i])
        i = i + 1
    out

fn _arm_dirent_matches_literal(data: [u8], off: i32, expected: [u8]) -> bool:
    if expected.len() != 11:
        return false
    var i: i32 = 0
    while i < 11:
        if _byte(data, off + i) != expected[i].to_u32():
            return false
        i = i + 1
    true

fn _arm_dirent_matches_short_name_bytes(data: [u8], off: i32, short_name: text) -> bool:
    val key = _arm_fat83_short_name_key(short_name)
    if key.len() != 11:
        return false
    var i: i32 = 0
    while i < 11:
        if _byte(data, off + i) != key[i].to_u32():
            return false
        i = i + 1
    true

fn _arm_dirent_matches_short_name(data: [u8], off: i32, short_name: text) -> bool:
    match short_name:
        case "HELLOSMF.SMF":
            return _arm_dirent_matches_literal(data, off, [
                0x48.to_u8(), 0x45.to_u8(), 0x4C.to_u8(), 0x4C.to_u8(), 0x4F.to_u8(),
                0x53.to_u8(), 0x4D.to_u8(), 0x46.to_u8(), 0x53.to_u8(), 0x4D.to_u8(),
                0x46.to_u8()
            ])
        case "SCOMPSMF.SMF":
            return _arm_dirent_matches_literal(data, off, [
                0x53.to_u8(), 0x43.to_u8(), 0x4F.to_u8(), 0x4D.to_u8(), 0x50.to_u8(),
                0x53.to_u8(), 0x4D.to_u8(), 0x46.to_u8(), 0x53.to_u8(), 0x4D.to_u8(),
                0x46.to_u8()
            ])
        case "SINTSMF.SMF":
            return _arm_dirent_matches_literal(data, off, [
                0x53.to_u8(), 0x49.to_u8(), 0x4E.to_u8(), 0x54.to_u8(), 0x53.to_u8(),
                0x4D.to_u8(), 0x46.to_u8(), 0x20.to_u8(), 0x53.to_u8(), 0x4D.to_u8(),
                0x46.to_u8()
            ])
        case "SLOADSMF.SMF":
            return _arm_dirent_matches_literal(data, off, [
                0x53.to_u8(), 0x4C.to_u8(), 0x4F.to_u8(), 0x41.to_u8(), 0x44.to_u8(),
                0x53.to_u8(), 0x4D.to_u8(), 0x46.to_u8(), 0x53.to_u8(), 0x4D.to_u8(),
                0x46.to_u8()
            ])
        case "LLVMSMF.SMF":
            return _arm_dirent_matches_literal(data, off, [
                0x4C.to_u8(), 0x4C.to_u8(), 0x56.to_u8(), 0x4D.to_u8(), 0x53.to_u8(),
                0x4D.to_u8(), 0x46.to_u8(), 0x20.to_u8(), 0x53.to_u8(), 0x4D.to_u8(),
                0x46.to_u8()
            ])
        case "CLANGSMF.SMF":
            return _arm_dirent_matches_literal(data, off, [
                0x43.to_u8(), 0x4C.to_u8(), 0x41.to_u8(), 0x4E.to_u8(), 0x47.to_u8(),
                0x53.to_u8(), 0x4D.to_u8(), 0x46.to_u8(), 0x53.to_u8(), 0x4D.to_u8(),
                0x46.to_u8()
            ])
        case "RUSTSMF.SMF":
            return _arm_dirent_matches_literal(data, off, [
                0x52.to_u8(), 0x55.to_u8(), 0x53.to_u8(), 0x54.to_u8(), 0x53.to_u8(),
                0x4D.to_u8(), 0x46.to_u8(), 0x20.to_u8(), 0x53.to_u8(), 0x4D.to_u8(),
                0x46.to_u8()
            ])
        case "VERSION.TXT":
            return _arm_dirent_matches_literal(data, off, [
                0x56.to_u8(), 0x45.to_u8(), 0x52.to_u8(), 0x53.to_u8(), 0x49.to_u8(),
                0x4F.to_u8(), 0x4E.to_u8(), 0x20.to_u8(), 0x54.to_u8(), 0x58.to_u8(),
                0x54.to_u8()
            ])
        case "SCOMPMAN.TXT":
            return _arm_dirent_matches_literal(data, off, [
                0x53.to_u8(), 0x43.to_u8(), 0x4F.to_u8(), 0x4D.to_u8(), 0x50.to_u8(),
                0x4D.to_u8(), 0x41.to_u8(), 0x4E.to_u8(), 0x54.to_u8(), 0x58.to_u8(),
                0x54.to_u8()
            ])
        case "SLOADMAN.TXT":
            return _arm_dirent_matches_literal(data, off, [
                0x53.to_u8(), 0x4C.to_u8(), 0x4F.to_u8(), 0x41.to_u8(), 0x44.to_u8(),
                0x4D.to_u8(), 0x41.to_u8(), 0x4E.to_u8(), 0x54.to_u8(), 0x58.to_u8(),
                0x54.to_u8()
            ])
        case "LLVMMAN.TXT":
            return _arm_dirent_matches_literal(data, off, [
                0x4C.to_u8(), 0x4C.to_u8(), 0x56.to_u8(), 0x4D.to_u8(), 0x4D.to_u8(),
                0x41.to_u8(), 0x4E.to_u8(), 0x20.to_u8(), 0x54.to_u8(), 0x58.to_u8(),
                0x54.to_u8()
            ])
        case "CLANGMAN.TXT":
            return _arm_dirent_matches_literal(data, off, [
                0x43.to_u8(), 0x4C.to_u8(), 0x41.to_u8(), 0x4E.to_u8(), 0x47.to_u8(),
                0x4D.to_u8(), 0x41.to_u8(), 0x4E.to_u8(), 0x54.to_u8(), 0x58.to_u8(),
                0x54.to_u8()
            ])
        case "RUSTMAN.TXT":
            return _arm_dirent_matches_literal(data, off, [
                0x52.to_u8(), 0x55.to_u8(), 0x53.to_u8(), 0x54.to_u8(), 0x4D.to_u8(),
                0x41.to_u8(), 0x4E.to_u8(), 0x20.to_u8(), 0x54.to_u8(), 0x58.to_u8(),
                0x54.to_u8()
            ])
        case "TOOLSET.SDN":
            return _arm_dirent_matches_literal(data, off, [
                0x54.to_u8(), 0x4F.to_u8(), 0x4F.to_u8(), 0x4C.to_u8(), 0x53.to_u8(),
                0x45.to_u8(), 0x54.to_u8(), 0x20.to_u8(), 0x53.to_u8(), 0x44.to_u8(),
                0x4E.to_u8()
            ])
        case _:
            ()
    _arm_dirent_matches_short_name_bytes(data, off, short_name)
