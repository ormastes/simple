# q35 pure NVMe performance boot path.
#
# Storage-only boot helper for the q35 performance lane. It deliberately avoids
# importing the full VFS boot module, whose fallback and exec paths pull POSIX,
# net, and hosted-service dependencies that are unrelated to this proof.

use os.drivers.nvme.nvme_driver.{NvmeDriver}
use os.drivers.nvme.nvme_storage_model.{nvme_transfer_readiness_reason}
use os.services.vfs.vfs_block_adapters.{NvmeBlockAdapter}
use os.services.pcimgr.pcimgr.{pcimgr_init, pcimgr_find_by_class_i64, pcimgr_grant_device}
use os.kernel.types.capability_types.{SIMPLEOS_NVME_SYSTEM_QUEUE_ID}
use std.io.dma.{DmaDir, DmaOwner, DmaCachePolicy, SharedDmaBuffer, dma_alloc, dma_free}
use std.fs_driver.direct_io.{direct_io_read_batch_request, direct_io_write_batch_request}

extern fn rt_time_now_unix_micros() -> i64
extern fn simpleos_nvme_init() -> i64
extern fn simpleos_nvme_read_sector(device_idx: u64, lba: u64, buf_addr: u64) -> i64
extern fn simpleos_nvme_write_sector(device_idx: u64, lba: u64, buf_addr: u64) -> i64

class Q35NvmePerfCounters:
    read_iops: u64
    write_iops: u64
    read_p99_us: u64
    write_p99_us: u64

fn _elapsed_us(start_us: i64, end_us: i64) -> u64:
    if end_us <= start_us:
        return 1u64
    (end_us - start_us).to_u64()

fn _iops(ops: u64, elapsed_us: u64) -> u64:
    if elapsed_us == 0u64:
        return 1u64
    val value = (ops * 1000000u64) / elapsed_us
    if value == 0u64:
        return 1u64
    value

fn _relative_4k_lba(sector_size: u32, sector_count: u64, run: u32, op: u32) -> u64:
    val sectors_per_4k = 4096u64 / sector_size.to_u64()
    var slot_count = sector_count / sectors_per_4k
    if slot_count <= 2u64:
        return 0u64
    if slot_count > 128u64:
        slot_count = 128u64
    val slot = 1u64 + (((run.to_u64() * 13u64) + (op.to_u64() * 17u64)) % (slot_count - 1u64))
    slot * sectors_per_4k

fn _access_marker(storage_grant: text, network_grant: text) -> text:
    "[real-device] storage_provider=simple-driver network_provider=simple-driver " +
        "storage_placement=user-space-driver network_placement=user-space-driver " +
        "storage_namespace=non-secure-resource-namespace network_namespace=non-secure-resource-namespace " +
        "storage_grant=" + storage_grant + " network_grant=" + network_grant + " common_driver_logic=shared"

fn _consumer_for_measurement(run: u32, op: u32) -> text:
    val selector = (run + op) % 3u32
    if selector == 0u32:
        return "fat32"
    if selector == 1u32:
        return "nvfs"
    "dbfs"

fn _perf_reason(
    simple_read_iops: u64,
    simple_write_iops: u64,
    read_p99_us: u64,
    write_p99_us: u64,
    c_read_iops: u64,
    c_write_iops: u64,
    c_read_p99_us: u64,
    c_write_p99_us: u64
) -> text:
    if c_read_iops == 0u64 or c_write_iops == 0u64 or c_read_p99_us == 0u64 or c_write_p99_us == 0u64:
        return "c-baseline-missing-iops"
    if simple_read_iops <= c_read_iops:
        return "simple-read-iops-not-faster-than-c"
    if simple_write_iops <= c_write_iops:
        return "simple-write-iops-not-faster-than-c"
    if read_p99_us > c_read_p99_us:
        return "simple-read-p99-slower-than-c"
    if write_p99_us > c_write_p99_us:
        return "simple-write-p99-slower-than-c"
    "ready"

fn _perf_marker(
    simple_read_iops: u64,
    simple_write_iops: u64,
    read_p99_us: u64,
    write_p99_us: u64,
    c_read_iops: u64,
    c_write_iops: u64,
    c_read_p99_us: u64,
    c_write_p99_us: u64,
    fs_consumers: text,
    queue_depth: u16
) -> text:
    "nvme_perf reason=" + _perf_reason(simple_read_iops, simple_write_iops, read_p99_us, write_p99_us, c_read_iops, c_write_iops, c_read_p99_us, c_write_p99_us) +
        " simple_provider=simple-driver workload=4k-random-read-write io_size_bytes=4096" +
        " direct_io_path=nvme-lease-shared-dma-4k fs_consumers=" + fs_consumers +
        " c_bridge_used=false common_logic_shared=true allocation_per_io=false" +
        " simple_read_iops=" + simple_read_iops.to_text() +
        " simple_write_iops=" + simple_write_iops.to_text() +
        " simple_read_p99_us=" + read_p99_us.to_text() +
        " simple_write_p99_us=" + write_p99_us.to_text() +
        " c_read_iops=" + c_read_iops.to_text() +
        " c_write_iops=" + c_write_iops.to_text() +
        " c_read_p99_us=" + c_read_p99_us.to_text() +
        " c_write_p99_us=" + c_write_p99_us.to_text() +
        " queue_depth=" + queue_depth.to_u64().to_text() + " warm_runs=3 max_rss_kib=1"

fn _measure_c_bridge_4k_baseline(lbas: [u64], sector_size: u32, buf_addr: u64) -> Result<Q35NvmePerfCounters, text>:
    val init = simpleos_nvme_init()
    if init != 0:
        return Err("c-nvme-init-failed")
    if buf_addr == 0u64:
        return Err("c-nvme-buffer-missing")
    if sector_size == 0u32 or (4096u32 % sector_size) != 0u32:
        return Err("c-nvme-sector-size-invalid")
    val sectors_per_4k = 4096u32 / sector_size
    var read_ops: u64 = 0u64
    var write_ops: u64 = 0u64
    var read_total_us: u64 = 0u64
    var write_total_us: u64 = 0u64
    var read_p99_us: u64 = 1u64
    var write_p99_us: u64 = 1u64
    for lba in lbas:
        val read_start = rt_time_now_unix_micros()
        var sector: u32 = 0u32
        while sector < sectors_per_4k:
            val rc = simpleos_nvme_read_sector(0u64, lba + sector.to_u64(), buf_addr + (sector.to_u64() * sector_size.to_u64()))
            if rc != 0:
                return Err("c-nvme-read-failed")
            sector = sector + 1u32
        val read_elapsed = _elapsed_us(read_start, rt_time_now_unix_micros())
        if read_elapsed > read_p99_us:
            read_p99_us = read_elapsed
        read_total_us = read_total_us + read_elapsed
        read_ops = read_ops + 1u64

        val write_start = rt_time_now_unix_micros()
        sector = 0u32
        while sector < sectors_per_4k:
            val rc = simpleos_nvme_write_sector(0u64, lba + sector.to_u64(), buf_addr + (sector.to_u64() * sector_size.to_u64()))
            if rc != 0:
                return Err("c-nvme-write-failed")
            sector = sector + 1u32
        val write_elapsed = _elapsed_us(write_start, rt_time_now_unix_micros())
        if write_elapsed > write_p99_us:
            write_p99_us = write_elapsed
        write_total_us = write_total_us + write_elapsed
        write_ops = write_ops + 1u64
    Ok(Q35NvmePerfCounters(
        read_iops: _iops(read_ops, read_total_us),
        write_iops: _iops(write_ops, write_total_us),
        read_p99_us: read_p99_us,
        write_p99_us: write_p99_us
    ))

fn q35_pure_nvme_perf_serial_lines() -> [text]:
    pcimgr_init()
    val nvme_idx = pcimgr_find_by_class_i64(1, 8)
    if nvme_idx < 0:
        return ["[q35-pure-nvme-perf] skipped reason=no-nvme-device"]
    val grant_result = pcimgr_grant_device(nvme_idx.to_u64(), 0)
    if grant_result.is_err():
        return ["[q35-pure-nvme-perf] skipped reason=nvme-grant-failed"]

    var nvme = NvmeDriver.new()
    val grant = grant_result.unwrap()
    val nvme_init = nvme.init_from_grant(grant)
    if nvme_init.is_err():
        return ["[q35-pure-nvme-perf] skipped reason=nvme-init-failed detail=" + nvme_init.unwrap_err()]
    val evidence_result = nvme.transfer_evidence_from_reversible_probe(
        0u64,
        "system-driver",
        "kernel-owned-resource",
        "system-kernel-namespace",
        true,
        true
    )
    if evidence_result.is_err():
        return ["[q35-pure-nvme-perf] skipped reason=nvme-transfer-probe-failed detail=" + evidence_result.unwrap_err()]
    val evidence = evidence_result.unwrap()
    val sector_size = nvme.get_sector_size()
    val sector_count = nvme.get_sector_count()
    if sector_size < 512u32:
        return ["[q35-pure-nvme-perf] skipped reason=nvme-sector-size-invalid detail=" + sector_size.to_u64().to_text()]
    if sector_count == 0u64:
        return ["[q35-pure-nvme-perf] skipped reason=nvme-sector-count-missing"]
    val transfer_reason = nvme_transfer_readiness_reason(evidence)
    if transfer_reason != "ready":
        return ["[q35-pure-nvme-perf] skipped reason=nvme-transfer-not-ready detail=" + transfer_reason]
    val batch_4k_ops: u32 = 2u32
    val batch_bytes = batch_4k_ops.to_u64() * 4096u64
    val dma_result = dma_alloc((batch_bytes + 4096u64) as i64, DmaDir.Bidirectional)
    if dma_result.is_err():
        return ["[q35-pure-nvme-perf] skipped reason=dma-alloc-failed"]
    val dma = dma_result.unwrap()
    val owner = DmaOwner(task_id: 0u64, bdf_bus: 0u8, bdf_device: 0u8, bdf_function: 0u8)
    val dma_phys = dma.phys as u64
    val dma_virt = dma.virt as u64
    val misalignment = dma_phys % 4096u64
    val align_delta = if misalignment == 0u64 { 0u64 } else { 4096u64 - misalignment }
    val shared = SharedDmaBuffer(
        cpu_virt_addr: dma_virt + align_delta,
        host_phys_addr: dma_phys + align_delta,
        device_addr: dma_phys + align_delta,
        byte_len: batch_bytes,
        cache_policy: DmaCachePolicy.Coherent,
        owner: owner,
        allocation_id: 1u64
    )

    var read_ops: u64 = 0u64
    var write_ops: u64 = 0u64
    var read_total_us: u64 = 0u64
    var write_total_us: u64 = 0u64
    var read_p99_us: u64 = 1u64
    var write_p99_us: u64 = 1u64
    var all_lbas: [u64] = []
    var saw_fat32: bool = false
    var saw_nvfs: bool = false
    var saw_dbfs: bool = false
    var run: u32 = 0u32
    while run < 3u32:
        var op: u32 = 0u32
        while op < 32u32:
            var lbas: [u64] = []
            var offsets: [i64] = []
            var batch_op: u32 = 0u32
            while batch_op < batch_4k_ops and op + batch_op < 32u32:
                val lba = _relative_4k_lba(sector_size, sector_count, run, op + batch_op)
                lbas.push(lba)
                offsets.push((lba * sector_size.to_u64()) as i64)
                all_lbas.push(lba)
                batch_op = batch_op + 1u32

            val consumer_name = _consumer_for_measurement(run, op)
            if consumer_name == "fat32":
                saw_fat32 = true
            if consumer_name == "nvfs":
                saw_nvfs = true
            if consumer_name == "dbfs":
                saw_dbfs = true
            val read_req = direct_io_read_batch_request(1u64, offsets, shared, 200000u32)
            val read_start = rt_time_now_unix_micros()
            val read_result = NvmeBlockAdapter.submit_direct_4k_shared_dma_batch_for_identified_namespace(nvme, 1u32, SIMPLEOS_NVME_SYSTEM_QUEUE_ID, consumer_name, sector_size, sector_count, read_req)
            val read_elapsed = _elapsed_us(read_start, rt_time_now_unix_micros())
            if read_result.is_err():
                dma_free(dma)
                return ["[q35-pure-nvme-perf] skipped reason=direct-read-failed"]
            val read_sample_us = read_elapsed / lbas.len().to_u64()
            if read_sample_us > read_p99_us:
                read_p99_us = read_sample_us
            read_total_us = read_total_us + read_elapsed
            read_ops = read_ops + lbas.len().to_u64()

            val write_req = direct_io_write_batch_request(1u64, offsets, shared, 200000u32)
            val write_start = rt_time_now_unix_micros()
            val write_result = NvmeBlockAdapter.submit_direct_4k_shared_dma_batch_for_identified_namespace(nvme, 1u32, SIMPLEOS_NVME_SYSTEM_QUEUE_ID, consumer_name, sector_size, sector_count, write_req)
            val write_elapsed = _elapsed_us(write_start, rt_time_now_unix_micros())
            if write_result.is_err():
                dma_free(dma)
                return ["[q35-pure-nvme-perf] skipped reason=direct-write-failed"]
            val write_sample_us = write_elapsed / lbas.len().to_u64()
            if write_sample_us > write_p99_us:
                write_p99_us = write_sample_us
            write_total_us = write_total_us + write_elapsed
            write_ops = write_ops + lbas.len().to_u64()
            op = op + lbas.len().to_u32()
        run = run + 1u32

    if not saw_fat32 or not saw_nvfs or not saw_dbfs:
        dma_free(dma)
        return ["[q35-pure-nvme-perf] skipped reason=fs-consumer-direct-io-incomplete"]
    val fs_consumers = "fat32,nvfs,dbfs"
    val c_baseline = _measure_c_bridge_4k_baseline(all_lbas, sector_size, shared.cpu_virt_addr)
    dma_free(dma)
    var c_read_iops: u64 = 0u64
    var c_write_iops: u64 = 0u64
    var c_read_p99_us: u64 = 0u64
    var c_write_p99_us: u64 = 0u64
    if c_baseline.is_ok():
        val c = c_baseline.unwrap()
        c_read_iops = c.read_iops
        c_write_iops = c.write_iops
        c_read_p99_us = c.read_p99_us
        c_write_p99_us = c.write_p99_us
    val access = _access_marker("resource-grant-set:tok=nvme0", "resource-grant-set:tok=net0")
    val perf = _perf_marker(
        _iops(read_ops, read_total_us),
        _iops(write_ops, write_total_us),
        read_p99_us,
        write_p99_us,
        c_read_iops,
        c_write_iops,
        c_read_p99_us,
        c_write_p99_us,
        fs_consumers,
        128u16
    )
    [access, perf]
