#![allow(unnamed_duplicate_typed_args)]
# Virtual Filesystem — Userspace VFS Service
#
# MDSOC: feature dimension, vfs layer
# Provides unified file access across multiple filesystems.
# Runs as a userspace service, receives requests via kernel IPC.
#
# Port contract: VFS receives open/read/write/close/stat/mkdir/readdir
# from applications and routes to the appropriate filesystem driver.

use os.kernel.types.fs_types.{FileDescriptor, FileFlags, MountPoint, FsNode, FsNodeKind, DirEntry}
use std.nogc_sync_mut.binary_io.{string_to_bytes, bytes_to_string}

# ============================================================================
# VFS Trait — Filesystem Interface
# ============================================================================

trait Filesystem:
    """Interface that all filesystem drivers must implement."""
    fn fs_name() -> text
    fn mount(device: text, options: text) -> Result<bool, text>
    fn unmount() -> Result<bool, text>

    # File operations
    fn open(path: text, flags: FileFlags) -> Result<u64, text>
    fn read(handle: u64, size: u64) -> Result<[u8], text>
    fn write(handle: u64, data: [u8]) -> Result<u64, text>
    fn close(handle: u64) -> Result<bool, text>
    fn seek(handle: u64, offset: i64, whence: SeekWhence) -> Result<u64, text>

    # Metadata
    fn stat(path: text) -> Result<FsNode, text>
    fn chmod(path: text, mode: u16) -> Result<bool, text>

    # Directory operations
    fn mkdir(path: text) -> Result<bool, text>
    fn rmdir(path: text) -> Result<bool, text>
    fn readdir(path: text) -> Result<[DirEntry], text>

    # File management
    fn unlink(path: text) -> Result<bool, text>
    fn rename(old_path: text, new_path: text) -> Result<bool, text>
    fn symlink(target: text, link_path: text) -> Result<bool, text>

enum SeekWhence:
    Set     # From beginning
    Cur     # From current position
    End     # From end

# ============================================================================
# Mount Table
# ============================================================================

val MAX_MOUNTS: i32 = 32

struct MountEntry:
    """Active mount point."""
    point: MountPoint
    fs: Filesystem      # Filesystem driver instance

# ============================================================================
# VFS Manager
# ============================================================================

class VfsManager:
    """Virtual filesystem multiplexer.

    Routes file operations to the correct filesystem based on path prefix.
    Manages mount table and file descriptor table.
    """
    mounts: [MountEntry]
    next_fd: i32

impl VfsManager:
    static fn new() -> VfsManager:
        VfsManager(mounts: [], next_fd: 3)  # 0=stdin, 1=stdout, 2=stderr

    me mount(path: text, fs_type: text, device: text, read_only: bool, fs: Filesystem) -> Result<bool, text>:
        """Mount a filesystem at the given path."""
        if self.mounts.len() >= MAX_MOUNTS:
            return Result.Err("too many mount points")

        val result = fs.mount(device, "")
        if result.is_err():
            return result

        val point = MountPoint(
            path: path,
            fs_type: fs_type,
            device: device,
            read_only: read_only
        )
        self.mounts.push(MountEntry(point: point, fs: fs))
        Result.Ok(true)

    me unmount(path: text) -> Result<bool, text>:
        """Unmount filesystem at path."""
        var i = 0
        while i < self.mounts.len():
            if self.mounts[i].point.path == path:
                val result = self.mounts[i].fs.unmount()
                if result.is_ok():
                    self.mounts.remove(i)
                return result
            i = i + 1
        Result.Err("mount point not found: {path}")

    fn resolve_mount(path: text) -> MountEntry?:
        """Find the filesystem responsible for a path.

        Longest prefix match: /mnt/usb matches before /mnt.
        """
        var best: MountEntry? = nil
        var best_len: i32 = 0

        for entry in self.mounts:
            val prefix = entry.point.path
            if path.starts_with(prefix) and prefix.len() > best_len:
                best = entry
                best_len = prefix.len()
        best

    fn strip_mount_prefix(path: text, mount_path: text) -> text:
        """Remove mount prefix from path to get fs-relative path."""
        if mount_path == "/":
            return path
        val relative = path.slice(mount_path.len())
        if relative.len() == 0:
            "/"
        else:
            relative

    # === File Operations ===

    me open(path: text, flags: FileFlags) -> Result<FileDescriptor, text>:
        """Open a file, returning a file descriptor."""
        val mount = self.resolve_mount(path)
        if mount.?:
            val entry = mount.unwrap()
            val relative = self.strip_mount_prefix(path, entry.point.path)
            val result = entry.fs.open(relative, flags)
            if result.is_ok():
                val handle = result.unwrap()
                val fd = FileDescriptor(
                    fd: self.next_fd,
                    node: handle,
                    offset: 0,
                    flags: flags
                )
                self.next_fd = self.next_fd + 1
                return Result.Ok(fd)
            else:
                return Result.Err(result.unwrap_err())
        Result.Err("no filesystem mounted for path: {path}")

    fn stat(path: text) -> Result<FsNode, text>:
        """Get file/directory metadata."""
        val mount = self.resolve_mount(path)
        if mount.?:
            val entry = mount.unwrap()
            val relative = self.strip_mount_prefix(path, entry.point.path)
            return entry.fs.stat(relative)
        Result.Err("no filesystem mounted for path: {path}")

    fn readdir(path: text) -> Result<[DirEntry], text>:
        """List directory contents."""
        val mount = self.resolve_mount(path)
        if mount.?:
            val entry = mount.unwrap()
            val relative = self.strip_mount_prefix(path, entry.point.path)
            return entry.fs.readdir(relative)
        Result.Err("no filesystem mounted for path: {path}")

    fn mkdir(path: text) -> Result<bool, text>:
        """Create directory."""
        val mount = self.resolve_mount(path)
        if mount.?:
            val entry = mount.unwrap()
            if entry.point.read_only:
                return Result.Err("filesystem is read-only")
            val relative = self.strip_mount_prefix(path, entry.point.path)
            return entry.fs.mkdir(relative)
        Result.Err("no filesystem mounted for path: {path}")

    fn rmdir(path: text) -> Result<bool, text>:
        """Remove an empty directory."""
        val mount = self.resolve_mount(path)
        if mount.?:
            val entry = mount.unwrap()
            if entry.point.read_only:
                return Result.Err("filesystem is read-only")
            val relative = self.strip_mount_prefix(path, entry.point.path)
            return entry.fs.rmdir(relative)
        Result.Err("no filesystem mounted for path: {path}")

    # === Write Operations ===

    me write(handle: u64, data: [u8]) -> Result<u64, text>:
        """Write data to an open file handle.

        Routes to the first mount's filesystem. The handle identifies
        the open file within that filesystem's handle table.
        """
        # The handle was issued by a specific filesystem during open().
        # For simplicity, we route to the first mount. A full implementation
        # would maintain a handle-to-mount mapping.
        if self.mounts.len() == 0:
            return Result.Err("no filesystems mounted")
        val mount = self.mounts[0]
        if mount.point.read_only:
            return Result.Err("filesystem is read-only")
        mount.fs.write(handle, data)

    me unlink(path: text) -> Result<bool, text>:
        """Delete a file."""
        val mount = self.resolve_mount(path)
        if mount.?:
            val entry = mount.unwrap()
            if entry.point.read_only:
                return Result.Err("filesystem is read-only")
            val relative = self.strip_mount_prefix(path, entry.point.path)
            return entry.fs.unlink(relative)
        Result.Err("no filesystem mounted for path: {path}")

    me rename(old_path: text, new_path: text) -> Result<bool, text>:
        """Rename a file or directory."""
        val mount = self.resolve_mount(old_path)
        if mount.?:
            val entry = mount.unwrap()
            if entry.point.read_only:
                return Result.Err("filesystem is read-only")
            val rel_old = self.strip_mount_prefix(old_path, entry.point.path)
            val rel_new = self.strip_mount_prefix(new_path, entry.point.path)
            return entry.fs.rename(rel_old, rel_new)
        Result.Err("no filesystem mounted for path: {old_path}")

    me symlink(target: text, link_path: text) -> Result<bool, text>:
        """Create a symbolic link at link_path pointing to target."""
        val mount = self.resolve_mount(link_path)
        if mount.?:
            val entry = mount.unwrap()
            if entry.point.read_only:
                return Result.Err("filesystem is read-only")
            val rel_link = self.strip_mount_prefix(link_path, entry.point.path)
            return entry.fs.symlink(target, rel_link)
        Result.Err("no filesystem mounted for path: {link_path}")

    me close(handle: u64) -> Result<bool, text>:
        """Close an open file handle."""
        if self.mounts.len() == 0:
            return Result.Err("no filesystems mounted")
        val mount = self.mounts[0]
        mount.fs.close(handle)

    me read(handle: u64, size: u64) -> Result<[u8], text>:
        """Read from an open file handle."""
        if self.mounts.len() == 0:
            return Result.Err("no filesystems mounted")
        val mount = self.mounts[0]
        mount.fs.read(handle, size)

    me seek(handle: u64, offset: i64, whence: SeekWhence) -> Result<u64, text>:
        """Seek within an open file."""
        if self.mounts.len() == 0:
            return Result.Err("no filesystems mounted")
        val mount = self.mounts[0]
        mount.fs.seek(handle, offset, whence)

    # === Path-Based Convenience Methods ===

    me read_text(path: text) -> Result<text, text>:
        """Read entire file contents as text (open → read → close)."""
        val mount = self.resolve_mount(path)
        if not mount.?:
            return Result.Err("no filesystem mounted for path: {path}")
        val entry = mount.unwrap()
        val relative = self.strip_mount_prefix(path, entry.point.path)
        val stat_result = entry.fs.stat(relative)
        if stat_result.is_err():
            return Result.Err(stat_result.unwrap_err())
        val node = stat_result.unwrap()
        val flags = FileFlags(read: true, write: false, append: false, create: false, truncate: false, directory: false)
        val open_result = entry.fs.open(relative, flags)
        if open_result.is_err():
            return Result.Err(open_result.unwrap_err())
        val handle = open_result.unwrap()
        val read_result = entry.fs.read(handle, node.size)
        entry.fs.close(handle)
        if read_result.is_err():
            return Result.Err(read_result.unwrap_err())
        val bytes = read_result.unwrap()
        Ok(bytes_to_string(bytes))

    me write_text(path: text, content: text) -> Result<bool, text>:
        """Write text to a file (open → write → close)."""
        val mount = self.resolve_mount(path)
        if not mount.?:
            return Result.Err("no filesystem mounted for path: {path}")
        val entry = mount.unwrap()
        if entry.point.read_only:
            return Result.Err("filesystem is read-only")
        val relative = self.strip_mount_prefix(path, entry.point.path)
        val flags = FileFlags(read: false, write: true, append: false, create: true, truncate: true, directory: false)
        val open_result = entry.fs.open(relative, flags)
        if open_result.is_err():
            return Result.Err(open_result.unwrap_err())
        val handle = open_result.unwrap()
        val data = string_to_bytes(content)
        val write_result = entry.fs.write(handle, data)
        entry.fs.close(handle)
        if write_result.is_err():
            return Result.Err(write_result.unwrap_err())
        Ok(true)

    me remove(path: text) -> Result<bool, text>:
        """Remove a file (alias for unlink)."""
        self.unlink(path)

# ============================================================================
# Module-Level Convenience Functions
# ============================================================================

fn vfs_mount(manager: VfsManager, path: text, fs: Filesystem) -> Result<bool, text>:
    """Mount a filesystem at the given path with default options.

    Convenience wrapper around VfsManager.mount() that uses sensible
    defaults: fs_type from the filesystem, empty device string, read-write.
    """
    val fs_type = fs.fs_name()
    manager.mount(path, fs_type, "", false, fs)
