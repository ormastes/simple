# C NVMe Block Adapter — development C bridge only
#
# MDSOC: feature dimension, vfs layer, C bridge adapter boundary
#
# Keeps simpleos_nvme_* and simpleos_fat32_* externs out of the pure
# NvmeBlockAdapter module so production pure-Simple imports do not pull the
# C bridge surface into the same module.

use os.services.block_device.{BlockDevice}
use os.kernel.boot.mmio.{mmio_read8, mmio_write8}
use os.kernel.log.klog_api.{log_raw_println}

extern fn simpleos_nvme_init() -> i64
extern fn simpleos_nvme_read_sector(device_idx: u64, lba: u64, buf_addr: u64) -> i64
extern fn simpleos_nvme_write_sector(device_idx: u64, lba: u64, buf_addr: u64) -> i64
extern fn simpleos_fat32_path_read_buffer_addr() -> u64
extern fn simpleos_fat32_read_path(path: text) -> i64
extern fn simpleos_fat32_read_path_size(path: text) -> i64
extern fn simpleos_fat32_read_path_array(path: text) -> [u8]

val FAT32_PATH_READ_BUFFER_MAX: u64 = 4194304

class CNvmeBlockAdapter:
    """Wraps C NVMe bridge as BlockDevice for FAT32."""
    sector_buf_addr: u64
    ready: bool

impl CNvmeBlockAdapter:
    static fn new() -> CNvmeBlockAdapter:
        CNvmeBlockAdapter(
            sector_buf_addr: 0,
            ready: false
        )

    me init_c_bridge() -> bool:
        """Initialize the baremetal C NVMe/FAT32 bridge with primitive status."""
        val init_result = simpleos_nvme_init()
        if init_result < 0:
            return false

        val buf = simpleos_fat32_path_read_buffer_addr()
        if buf == 0:
            return false
        self.sector_buf_addr = buf
        self.ready = true
        log_raw_println("[c-nvme-adapter] Ready, sector buffer at 0x{self.sector_buf_addr}")
        true

    me init() -> Result<bool, text>:
        """Initialize: call the C NVMe bridge and allocate a sector buffer."""
        if not self.init_c_bridge():
            return Result.Err("CNvmeBlockAdapter: C NVMe init failed")
        Result.Ok(true)

impl BlockDevice for CNvmeBlockAdapter:
    me read_sector(lba: u64) -> Result<[u8], text>:
        """Read one sector from NVMe via the C bridge."""
        if not self.ready:
            return Result.Err("CNvmeBlockAdapter: not initialized")

        val result = simpleos_nvme_read_sector(0, lba, self.sector_buf_addr)
        if result < 0:
            return Result.Err("CNvmeBlockAdapter: read_sector failed")

        var buffer: [u8] = []
        var i: u64 = 0
        val ss: u64 = 512
        while i < ss:
            buffer.push(mmio_read8(self.sector_buf_addr + i))
            i = i + 1
        Result.Ok(buffer)

    me write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        """Write one sector to NVMe via the C bridge."""
        if not self.ready:
            return Result.Err("CNvmeBlockAdapter: not initialized")

        var i: u64 = 0
        val ss: u64 = 512
        while i < ss:
            val byte_val: u8 = if i.to_i32() < data.len(): data[i.to_i32()] else: 0
            mmio_write8(self.sector_buf_addr + i, byte_val)
            i = i + 1

        val result = simpleos_nvme_write_sector(0, lba, self.sector_buf_addr)
        if result < 0:
            return Result.Err("CNvmeBlockAdapter: write_sector failed")
        Result.Ok(true)

    me fn sector_size() -> u32:
        val nvme_sector_size: u32 = 512
        nvme_sector_size
