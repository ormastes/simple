#![allow(primitive_api, bare_bool)]
# VFS Boot Initialization — connects FAT32 to NVMe and starts VFS service
#
# MDSOC: feature dimension, vfs layer
# Called during kernel init. Sets up the complete storage stack:
# 1. PCI manager discovers NVMe device
# 2. NVMe driver initialized via C bridge — bypasses auto-stubbed MMIO
# 3. C NVMe adapter reads sectors via direct C bridge
# 4. FAT32 driver reads BPB from NVMe via adapter
# 5. VFS mounts FAT32 at "/"
# 6. VFS service starts listening on IPC port "vfs"

use os.services.vfs.vfs.{VfsManager, Filesystem}
use os.services.vfs.vfs_service.{VfsService}
use os.services.fat32.fat32.{Fat32Driver as Fat32Core}
use os.services.block_device.{BlockDevice}
use os.drivers.virtio.virtio_blk.{VirtioBlkDriver}
use os.drivers.nvme.nvme_driver.{NvmeDriver, DmaAddrs}
use os.services.pcimgr.pcimgr.{pcimgr_init, pcimgr_find_by_class, pcimgr_find_by_class_i64, pcimgr_grant_device}
use os.services.pcimgr.driver_match.{PCI_CLASS_STORAGE, PCI_SUBCLASS_NVME}
use os.kernel.types.device_mem_types.{DeviceGrant}
use os.kernel.boot.mmio.{mmio_read32, mmio_write32, mmio_read64, mmio_read16, mmio_read8, mmio_write8}
use std.fs_driver.mount_table.{MountTable}
use std.fs_driver.instance.{DriverInstance}
use std.fs_driver.types.{Path, MountOptions, OpenFlags}
use os.kernel.types.fs_types.{FileFlags}
use common.string_core.{str_char_at}

extern fn serial_println(msg: text)
extern fn unsafe_addr_of(ref: any) -> u64
extern fn syscall(id: u64, arg0: u64, arg1: u64, arg2: u64, arg3: u64, arg4: u64) -> i64

val SYS_ALLOC_DMA: u64 = 84

# DMA page size for sector I/O buffers
val DMA_PAGE_SIZE: u64 = 4096

# ============================================================================
# C NVMe BlockDevice Adapter
# ============================================================================
#
# Uses the C NVMe driver in baremetal_stubs.c via direct C bridges.
# The C code does all MMIO directly with volatile pointers, avoiding the
# auto-stubbed Simple MMIO wrappers that return 0 while keeping this private
# boot-time path out of the public syscall table.
extern fn simpleos_nvme_init() -> i64
extern fn simpleos_nvme_read_sector(device_idx: u64, lba: u64, buf_addr: u64) -> i64
extern fn simpleos_nvme_write_sector(device_idx: u64, lba: u64, buf_addr: u64) -> i64
extern fn simpleos_fat32_read_known_app(app_id: u64) -> i64
extern fn simpleos_fat32_read_buffer_addr() -> u64
extern fn simpleos_fat32_path_read_buffer_addr() -> u64
extern fn simpleos_fat32_read_known_app_size(app_id: u64) -> i64
extern fn simpleos_fat32_read_known_app_array(app_id: u64) -> [u8]
extern fn simpleos_fat32_read_path(path: text) -> i64
extern fn simpleos_fat32_read_path_size(path: text) -> i64
extern fn simpleos_fat32_read_path_array(path: text) -> [u8]

val KNOWN_APP_ELF_BUFFER_MAX: u64 = 32768
val FAT32_PATH_READ_BUFFER_MAX: u64 = 4194304

var g_vfs_browser_demo_exec_bytes: [u8] = []
var g_vfs_hello_world_exec_bytes: [u8] = []
var g_vfs_file_manager_exec_bytes: [u8] = []
var g_vfs_shell_exec_bytes: [u8] = []
var g_vfs_editor_exec_bytes: [u8] = []

class CNvmeBlockAdapter:
    """Wraps C NVMe bridge as BlockDevice for FAT32."""
    sector_buf_addr: u64    # DMA buffer address for sector transfers
    ready: bool

impl CNvmeBlockAdapter:
    static fn new() -> CNvmeBlockAdapter:
        CNvmeBlockAdapter(
            sector_buf_addr: 0,
            ready: false
        )

    me init_c_bridge() -> bool:
        """Initialize the baremetal C NVMe/FAT32 bridge with primitive status."""
        val init_result = simpleos_nvme_init()
        if init_result < 0:
            return false

        val buf = simpleos_fat32_path_read_buffer_addr()
        if buf == 0:
            return false
        self.sector_buf_addr = buf
        self.ready = true
        serial_println("[c-nvme-adapter] Ready, sector buffer at 0x{self.sector_buf_addr}")
        true

    me init() -> Result<bool, text>:
        """Initialize: call the C NVMe bridge and allocate a sector buffer."""
        if not self.init_c_bridge():
            return Result.Err("CNvmeBlockAdapter: C NVMe init failed")
        Result.Ok(true)

impl BlockDevice for CNvmeBlockAdapter:
    me read_sector(lba: u64, buffer: [u8]) -> Result<bool, text>:
        """Read one sector from NVMe via the C bridge."""
        if not self.ready:
            return Result.Err("CNvmeBlockAdapter: not initialized")

        val result = simpleos_nvme_read_sector(0, lba, self.sector_buf_addr)
        if result < 0:
            return Result.Err("CNvmeBlockAdapter: read_sector failed")

        # Copy from DMA buffer to byte array
        var i: u64 = 0
        val ss: u64 = 512
        while i < ss and i.to_i32() < buffer.len():
            buffer[i.to_i32()] = mmio_read8(self.sector_buf_addr + i)
            i = i + 1
        Result.Ok(true)

    me write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        """Write one sector to NVMe via the C bridge."""
        if not self.ready:
            return Result.Err("CNvmeBlockAdapter: not initialized")

        var i: u64 = 0
        val ss: u64 = 512
        while i < ss:
            val byte_val: u8 = if i.to_i32() < data.len(): data[i.to_i32()] else: 0
            mmio_write8(self.sector_buf_addr + i, byte_val)
            i = i + 1

        val result = simpleos_nvme_write_sector(0, lba, self.sector_buf_addr)
        if result < 0:
            return Result.Err("CNvmeBlockAdapter: write_sector failed")
        Result.Ok(true)

    fn sector_size() -> u32:
        val nvme_sector_size: u32 = 512
        nvme_sector_size

# ============================================================================
# Legacy NVMe-to-BlockDevice Adapter (Pure Simple — kept for non-baremetal)
# ============================================================================
#
# The NVMe driver uses DMA-based sector I/O (physical addresses), while the
# FAT32 driver expects the BlockDevice trait with byte-buffer read/write.
# This adapter bridges the two by allocating a DMA bounce buffer and copying
# data between user-space byte arrays and DMA memory.

class NvmeBlockAdapter:
    """Wraps NvmeDriver to implement BlockDevice for FAT32."""
    nvme: NvmeDriver
    bounce_virt: u64    # Virtual address of DMA bounce buffer
    bounce_phys: u64    # Physical address of DMA bounce buffer
    ready: bool

impl NvmeBlockAdapter:
    static fn new(nvme: NvmeDriver) -> NvmeBlockAdapter:
        NvmeBlockAdapter(
            nvme: nvme,
            bounce_virt: 0,
            bounce_phys: 0,
            ready: false
        )

    me init_bounce_buffer() -> Result<bool, text>:
        """Allocate a DMA bounce buffer for sector transfers."""
        var result_buf = DmaAddrs(virt: 0, phys: 0)
        val result_ptr = unsafe_addr_of(result_buf)
        val virt_result = syscall(SYS_ALLOC_DMA, DMA_PAGE_SIZE, result_ptr, 0, 0, 0)
        if virt_result < 0:
            return Result.Err("NvmeBlockAdapter: DMA bounce buffer alloc failed")
        self.bounce_phys = mmio_read64(result_ptr)
        self.bounce_virt = mmio_read64(result_ptr + 8)
        self.ready = true
        serial_println("[nvme-adapter] Bounce buffer allocated: virt=0x{self.bounce_virt}, phys=0x{self.bounce_phys}")
        Result.Ok(true)

impl BlockDevice for NvmeBlockAdapter:
    me read_sector(lba: u64, buffer: [u8]) -> Result<bool, text>:
        """Read one sector from NVMe into byte buffer via DMA bounce."""
        if not self.ready:
            return Result.Err("NvmeBlockAdapter: not initialized")
        # Zero bounce buffer
        var offset: u64 = 0
        val ss = self.nvme.get_sector_size().to_u64()
        while offset < ss:
            mmio_write32(self.bounce_virt + offset, 0)
            offset = offset + 4

        # Issue NVMe read (1 sector)
        val result = self.nvme.read_sectors(lba, 1, self.bounce_phys)
        if result.is_err():
            return Result.Err(result.unwrap_err())

        # Copy from bounce buffer to byte array
        var i: u64 = 0
        while i < ss and i.to_i32() < buffer.len():
            val byte_val = mmio_read32(self.bounce_virt + i) & 0xFF
            buffer[i.to_i32()] = byte_val.to_u8()
            i = i + 1
        Result.Ok(true)

    me write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        """Write one sector to NVMe from byte buffer via DMA bounce."""
        if not self.ready:
            return Result.Err("NvmeBlockAdapter: not initialized")
        # Copy data into bounce buffer
        val ss = self.nvme.get_sector_size().to_u64()
        var i: u64 = 0
        while i < ss and i.to_i32() < data.len():
            val byte_val = data[i.to_i32()].to_u32()
            mmio_write32(self.bounce_virt + i, byte_val)
            i = i + 1

        # Issue NVMe write (1 sector)
        val result = self.nvme.write_sectors(lba, 1, self.bounce_phys)
        if result.is_err():
            return Result.Err(result.unwrap_err())
        Result.Ok(true)

    fn sector_size() -> u32:
        self.nvme.get_sector_size()

# ============================================================================
# Module-Level State
# ============================================================================

var g_vfs: VfsManager = VfsManager.new()
var g_nvme: NvmeDriver = NvmeDriver.new()
var g_adapter: NvmeBlockAdapter = NvmeBlockAdapter.new(g_nvme)
var g_c_adapter: CNvmeBlockAdapter = CNvmeBlockAdapter.new()
var g_root_fat32: Fat32Core? = nil
var g_vfs_initialized: bool = false
# M1 mount table — wired at boot after NVMe init succeeds (see vfs_boot_init).
var g_mount_table: MountTable = MountTable.new()

# ============================================================================
# Boot Init
# ============================================================================

fn vfs_boot_init() -> bool:
    """Initialize the full storage stack: PCI -> NVMe -> FAT32 -> VFS.

    Uses the C NVMe bridge on baremetal, bypassing the
    auto-stubbed Simple MMIO functions that return 0.

    Returns true if VFS is ready to serve file requests.
    """
    serial_println("[vfs-init] Starting storage stack initialization...")

    pcimgr_init()
    serial_println("[vfs-init] PCI cache ready")
    # Use the i64 variant with explicit i64 literals — the u8 path
    # (pcimgr_find_by_class) silently mismatches NVMe class/subclass on
    # baremetal Cranelift due to an integer-width comparison bug
    # (SYS-GUI-007 root cause).
    val nvme_class: i64 = 1  # PCI_CLASS_STORAGE (0x01)
    val nvme_sub: i64 = 8    # PCI_SUBCLASS_NVME (0x08)
    val nvme_idx = pcimgr_find_by_class_i64(nvme_class, nvme_sub)
    if nvme_idx < 0:
        serial_println("[vfs-init] No NVMe device found -- VFS unavailable")
        return _vfs_boot_init_virtio_fat32()
    serial_println("[vfs-init] Found NVMe device at index {nvme_idx}")

    serial_println("[vfs-init] Initializing C-backed NVMe block adapter...")
    val adapter_init = g_c_adapter.init_c_bridge()
    if not adapter_init:
        serial_println("[vfs-init] C NVMe adapter init failed")
        return _vfs_boot_init_virtio_fat32()
    serial_println("[vfs-init] C NVMe controller initialized!")
    serial_println("[vfs-init] C NVMe + FAT32 verified (via C driver)")
    g_vfs_initialized = true

    # The pure-Simple FAT32 root driver currently exits during mount in a clean
    # baremetal build. Keep VFS available through the C FAT32 driver-backed
    # executable read path below; apps are still loaded from the FAT32 image as
    # separate processes, while only storage driver code remains baremetal-aware.
    serial_println("[vfs-init] FAT32 executable VFS path ready")

    val exec_probe_path = "/BROWSMF.SMF"
    val exec_probe_size = simpleos_fat32_read_path_size(exec_probe_path)
    if exec_probe_size <= 4:
        serial_println("[vfs-init] executable load probe failed path={exec_probe_path} size={exec_probe_size}")
        return false
    if exec_probe_size.to_u64() > FAT32_PATH_READ_BUFFER_MAX:
        serial_println("[vfs-init] executable load probe failed path={exec_probe_path} oversize={exec_probe_size}")
        return false
    val exec_probe_read = simpleos_fat32_read_path(exec_probe_path)
    if exec_probe_read != 0:
        serial_println("[vfs-init] executable load probe failed path={exec_probe_path} rc={exec_probe_read}")
        return false
    if not _known_app_has_elf_magic(simpleos_fat32_path_read_buffer_addr()):
        serial_println("[vfs-init] executable load probe failed path={exec_probe_path} invalid_elf")
        return false
    g_vfs_browser_demo_exec_bytes = simpleos_fat32_read_path_array(exec_probe_path)
    g_vfs_hello_world_exec_bytes = _cache_c_fat32_exec_bytes("/HELLOSMF.SMF")
    g_vfs_file_manager_exec_bytes = _cache_c_fat32_exec_bytes("/FILESMF.SMF")
    g_vfs_shell_exec_bytes = _cache_c_fat32_exec_bytes("/SHELLSMF.SMF")
    g_vfs_editor_exec_bytes = _cache_c_fat32_exec_bytes("/EDITORSM.SMF")
    serial_println("[vfs-init] executable load probe ok path=/sys/apps/browser_demo bytes={exec_probe_size}")

    serial_println("[vfs-init] VFS ready (C-backed)")
    return true

fn _vfs_boot_init_pure_nvme_fat32(nvme_idx: u64) -> bool:
    """Try the pure-Simple NVMe -> BlockDevice -> FAT32 stack first."""
    serial_println("[vfs-init] Trying pure-Simple NVMe + FAT32 stack...")
    val grant_result = pcimgr_grant_device(nvme_idx, 0)
    if grant_result.is_err():
        serial_println("[vfs-init] pure-Simple NVMe grant failed: {grant_result.unwrap_err()}")
        return false
    g_nvme = NvmeDriver.new()
    val nvme_init = g_nvme.init_from_grant(grant_result.unwrap())
    if nvme_init.is_err():
        serial_println("[vfs-init] pure-Simple NVMe init failed: {nvme_init.unwrap_err()}")
        return false
    g_adapter = NvmeBlockAdapter.new(g_nvme)
    val bounce_init = g_adapter.init_bounce_buffer()
    if bounce_init.is_err():
        serial_println("[vfs-init] pure-Simple NVMe bounce buffer failed: {bounce_init.unwrap_err()}")
        return false
    var root = Fat32Core.new(g_adapter)
    val mount_result = root.mount("", "")
    if mount_result.is_err():
        serial_println("[vfs-init] pure-Simple FAT32 mount failed: {mount_result.unwrap_err()}")
        return false
    val version_probe = g_vfs_root_read_file_bytes(root, "/VERSION.TXT")
    if version_probe.len() <= 0:
        serial_println("[vfs-init] version file read probe failed path=/VERSION.TXT")
        return false
    val exec_probe = g_vfs_root_read_file_bytes(root, "/SYS/APPS/BROWSMF.SMF")
    if exec_probe.len() <= 4 or not _bytes_have_elf_magic(exec_probe):
        serial_println("[vfs-init] executable load probe failed path=/SYS/APPS/BROWSMF.SMF")
        return false
    g_root_fat32 = Some(root)
    g_vfs_initialized = true
    serial_println("[vfs-init] version file read ok path=/sys/version.txt bytes={version_probe.len()}")
    serial_println("[vfs-init] executable load probe ok path=/sys/apps/browser_demo.smf bytes={exec_probe.len()}")
    serial_println("[vfs-init] VFS ready (pure-Simple NVMe + FAT32)")
    true

fn _vfs_boot_init_virtio_fat32() -> bool:
    """Initialize VFS from QEMU virtio-blk FAT32 media on ARM virt machines."""
    serial_println("[vfs-init] Starting VirtIO-BLK FAT32 initialization...")
    val dev_opt = VirtioBlkDriver.probe()
    if dev_opt == nil:
        serial_println("[vfs-init] No VirtIO-BLK device found -- VFS unavailable")
        return false
    var dev = dev_opt.unwrap()
    val dev_init = dev.init()
    if dev_init.is_err():
        serial_println("[vfs-init] VirtIO-BLK init failed")
        return false

    var root = Fat32Core.new(dev)
    val mount_result = root.mount("", "")
    if mount_result.is_err():
        serial_println("[vfs-init] VirtIO FAT32 mount failed: {mount_result.unwrap_err()}")
        return false

    g_root_fat32 = Some(root)
    g_vfs_initialized = true
    serial_println("[vfs-init] VirtIO FAT32 mounted at /")

    val probe = g_vfs_read_file_bytes("/SYS/APPS/HELLOSMF.SMF")
    if probe.len() <= 4:
        serial_println("[vfs-init] executable load probe failed path=/SYS/APPS/HELLOSMF.SMF")
        return false
    serial_println("[vfs-init] executable load probe ok path=/sys/apps/hello_world.smf bytes={probe.len()}")
    serial_println("[vfs-init] VFS ready (VirtIO-BLK FAT32)")
    true
# ============================================================================
# VFS IPC Service
# ============================================================================

fn vfs_service_start():
    """Start the VFS IPC service loop (blocking).

    For cooperative scheduling, use vfs_service_init_port() + vfs_service_poll().
    """
    if not g_vfs_initialized:
        serial_println("[vfs] Cannot start service -- not initialized")
        return
    var service = VfsService.new(g_vfs)
    service.start()

# Module-level VFS service instance for cooperative scheduling
var g_vfs_service: VfsService?

fn vfs_service_init_port():
    """Initialize the VFS IPC port without entering the blocking loop.

    Use with vfs_service_poll() for cooperative scheduling.
    """
    if not g_vfs_initialized:
        serial_println("[vfs] Cannot init port -- not initialized")
        return
    g_vfs_service = VfsService.new(g_vfs)
    g_vfs_service.init_port()

fn vfs_service_poll():
    """Process one VFS IPC request if available (non-blocking).

    Call from a cooperative main loop alongside netstack and shell.
    """
    if g_vfs_service != nil:
        g_vfs_service.poll_once()

# ============================================================================
# Query Helpers
# ============================================================================

fn vfs_is_ready() -> bool:
    """Check if VFS has been initialized and is ready for file operations."""
    g_vfs_initialized

fn vfs_get_manager() -> VfsManager:
    """Return the global VFS manager instance."""
    g_vfs

# ============================================================================
# VFS Public Helpers (M2 retrofit) — route callers through g_mount_table
# ============================================================================
#
# These replace direct rt_fat32_* extern calls in entry-point files.
# rt_fat32_* externs remain in files with live callers; prefer g_vfs_* for new code.
# (Full removal pending: tools_verify_entry.spl, shell.spl, launcher.spl, disk_launch_manifest.spl — FR M4.)
#
# Path convention: bare FAT32 names (e.g. "HELLO.TXT") are accepted; a leading
# '/' is prepended when the name does not start with '/'.

fn g_vfs_abs_path(name: text) -> Path:
    """Return an absolute Path for name, prepending '/' if bare."""
    if name.starts_with("/"):
        Path(raw: name)
    else:
        Path(raw: "/" + name)

fn g_vfs_root_path(name: text) -> text:
    if name.starts_with("/"):
        name
    else:
        "/" + name

fn g_vfs_known_app_id(path: text) -> u64:
    if path == "/sys/apps/browser_demo":
        return 1
    if path == "/sys/apps/browser_demo.smf":
        return 1
    if path == "/SYS/APPS/BROWSE~1":
        return 1
    if path == "/SYS/APPS/BROWSMF.SMF":
        return 1
    if path == "/BROWSE~1.ELF":
        return 1
    if path == "/BROWSMF.SMF":
        return 1
    if path == "/sys/apps/file_manager":
        return 2
    if path == "/sys/apps/file_manager.smf":
        return 2
    if path == "/SYS/APPS/FILE_M~1":
        return 2
    if path == "/SYS/APPS/FILESMF.SMF":
        return 2
    if path == "/FILE_M~1.ELF":
        return 2
    if path == "/FILESMF.SMF":
        return 2
    if path == "/sys/apps/hello_world":
        return 3
    if path == "/sys/apps/hello_world.smf":
        return 3
    if path == "/SYS/APPS/HELLO_~1":
        return 3
    if path == "/SYS/APPS/HELLOSMF.SMF":
        return 3
    if path == "/HELLO_~1.ELF":
        return 3
    if path == "/HELLOSMF.SMF":
        return 3
    if path == "/sys/apps/shell":
        return 4
    if path == "/sys/apps/shell.smf":
        return 4
    if path == "/sys/apps/terminal":
        return 4
    if path == "/SYS/APPS/SHELL":
        return 4
    if path == "/SYS/APPS/TERMIN~1":
        return 4
    if path == "/SYS/APPS/SHELLSMF.SMF":
        return 4
    if path == "/TERMIN~1.ELF":
        return 4
    if path == "/SHELLSMF.SMF":
        return 4
    if path == "/sys/apps/editor":
        return 5
    if path == "/sys/apps/editor.smf":
        return 5
    if path == "/SYS/APPS/EDITOR":
        return 5
    if path == "/SYS/APPS/EDITORSM.SMF":
        return 5
    if path == "/EDITOR~1.ELF":
        return 5
    if path == "/EDITORSM.SMF":
        return 5
    0

fn _vfs_exec_disk_alias(path: text) -> text:
    match path:
        case "/sys/apps/browser_demo":
            "/SYS/APPS/BROWSMF.SMF"
        case "/sys/apps/browser_demo.smf":
            "/SYS/APPS/BROWSMF.SMF"
        case "/sys/apps/file_manager":
            "/SYS/APPS/FILESMF.SMF"
        case "/sys/apps/file_manager.smf":
            "/SYS/APPS/FILESMF.SMF"
        case "/sys/apps/hello_world":
            "/SYS/APPS/HELLOSMF.SMF"
        case "/sys/apps/hello_world.smf":
            "/SYS/APPS/HELLOSMF.SMF"
        case "/sys/apps/shell":
            "/SYS/APPS/SHELLSMF.SMF"
        case "/sys/apps/shell.smf":
            "/SYS/APPS/SHELLSMF.SMF"
        case "/sys/apps/editor":
            "/SYS/APPS/EDITORSM.SMF"
        case "/sys/apps/editor.smf":
            "/SYS/APPS/EDITORSM.SMF"
        case _:
            path

fn _vfs_exec_root_disk_alias(path: text) -> text:
    match path:
        case "/sys/apps/browser_demo":
            "/BROWSMF.SMF"
        case "/sys/apps/browser_demo.smf":
            "/BROWSMF.SMF"
        case "/sys/apps/file_manager":
            "/FILESMF.SMF"
        case "/sys/apps/file_manager.smf":
            "/FILESMF.SMF"
        case "/sys/apps/hello_world":
            "/HELLOSMF.SMF"
        case "/sys/apps/hello_world.smf":
            "/HELLOSMF.SMF"
        case "/sys/apps/shell":
            "/SHELLSMF.SMF"
        case "/sys/apps/shell.smf":
            "/SHELLSMF.SMF"
        case "/sys/apps/editor":
            "/EDITORSM.SMF"
        case "/sys/apps/editor.smf":
            "/EDITORSM.SMF"
        case _:
            path

fn _known_app_has_elf_magic(buf_addr: u64) -> bool:
    if mmio_read8(buf_addr) != 0x7F.to_u8():
        return false
    if mmio_read8(buf_addr + 1) != 0x45.to_u8():
        return false
    if mmio_read8(buf_addr + 2) != 0x4C.to_u8():
        return false
    if mmio_read8(buf_addr + 3) != 0x46.to_u8():
        return false
    true

fn _bytes_have_elf_magic(bytes: [u8]) -> bool:
    if bytes.len() < 4:
        return false
    bytes[0] == 0x7F.to_u8() and
        bytes[1] == 0x45.to_u8() and
        bytes[2] == 0x4C.to_u8() and
        bytes[3] == 0x46.to_u8()

fn _cache_c_fat32_exec_bytes(path: text) -> [u8]:
    val signed_size = simpleos_fat32_read_path_size(path)
    if signed_size <= 4:
        return []
    val file_size = signed_size.to_u64()
    if file_size > FAT32_PATH_READ_BUFFER_MAX:
        return []
    val read_result = simpleos_fat32_read_path(path)
    if read_result != 0:
        return []
    if not _known_app_has_elf_magic(simpleos_fat32_path_read_buffer_addr()):
        return []
    simpleos_fat32_read_path_array(path)

fn _cached_known_exec_bytes(path: text) -> [u8]:
    val app_id = g_vfs_known_app_id(path)
    if app_id == 1:
        return _clone_bytes(g_vfs_browser_demo_exec_bytes)
    if app_id == 2:
        return _clone_bytes(g_vfs_file_manager_exec_bytes)
    if app_id == 3:
        return _clone_bytes(g_vfs_hello_world_exec_bytes)
    if app_id == 4:
        return _clone_bytes(g_vfs_shell_exec_bytes)
    if app_id == 5:
        return _clone_bytes(g_vfs_editor_exec_bytes)
    []

fn g_vfs_read_known_app_bytes(path: text) -> [u8]:
    val app_id = g_vfs_known_app_id(path)
    if app_id == 0:
        return []
    val signed_size = simpleos_fat32_read_known_app_size(app_id)
    if signed_size <= 0:
        serial_println("[vfs-root] c_fat32_read_invalid_size path={path} bytes={signed_size}")
        return []
    val file_size = signed_size.to_u64()
    if file_size > KNOWN_APP_ELF_BUFFER_MAX:
        serial_println("[vfs-root] c_fat32_read_invalid_size path={path} bytes={file_size}")
        return []
    val read_result = simpleos_fat32_read_known_app(app_id)
    if read_result != 0:
        serial_println("[vfs-root] c_fat32_read_failed path={path} rc={read_result}")
        return []
    if not _known_app_has_elf_magic(simpleos_fat32_read_buffer_addr()):
        serial_println("[vfs-root] c_fat32_read_invalid_elf path={path}")
        return []
    val out = _copy_bytes_from_addr(simpleos_fat32_read_buffer_addr(), file_size)
    serial_println("[vfs-root] c_fat32_read_ok path={path} bytes={out.len()}")
    _clone_bytes(out)

fn g_vfs_read_fat32_path_bytes(path: text) -> [u8]:
    """Read arbitrary FAT32 bytes through the C-backed QEMU boot bridge."""
    if not g_vfs_initialized:
        return []
    if path == "":
        return []
    val signed_size = simpleos_fat32_read_path_size(path)
    if signed_size <= 0:
        return []
    val file_size = signed_size.to_u64()
    if file_size > FAT32_PATH_READ_BUFFER_MAX:
        serial_println("[vfs-root] c_fat32_path_read_oversize path={path} bytes={file_size}")
        return []
    val read_result = simpleos_fat32_read_path(path)
    if read_result != 0:
        serial_println("[vfs-root] c_fat32_path_read_failed path={path} rc={read_result}")
        return []
    val out = _copy_bytes_from_addr(simpleos_fat32_path_read_buffer_addr(), file_size)
    serial_println("[vfs-root] c_fat32_path_read_ok path={path} bytes={out.len()}")
    _clone_bytes(out)

pub fn g_vfs_read_executable_bytes(name: text) -> [u8]:
    """Read seeded executable bytes, preferring the stable FAT32 path bridge."""
    val cached = _cached_known_exec_bytes(name)
    if cached.len() > 0:
        return cached
    val alias_name = _vfs_exec_disk_alias(name)
    if alias_name != name:
        val alias_cached = _cached_known_exec_bytes(alias_name)
        if alias_cached.len() > 0:
            return alias_cached
        val alias_bytes = g_vfs_read_fat32_path_bytes(alias_name)
        if alias_bytes.len() > 0:
            return alias_bytes
    val root_name = g_vfs_root_path(name)
    val root_alias = _vfs_exec_disk_alias(root_name)
    if root_alias != root_name:
        val root_alias_bytes = g_vfs_read_fat32_path_bytes(root_alias)
        if root_alias_bytes.len() > 0:
            return root_alias_bytes
    val root_disk_alias = _vfs_exec_root_disk_alias(name)
    if root_disk_alias != name:
        val root_disk_bytes = g_vfs_read_fat32_path_bytes(root_disk_alias)
        if root_disk_bytes.len() > 0:
            return root_disk_bytes

    val direct_known = g_vfs_read_known_app_bytes(name)
    if direct_known.len() > 0:
        return direct_known
    val root_known = g_vfs_read_known_app_bytes(root_name)
    if root_known.len() > 0:
        return root_known
    if alias_name != name:
        val alias_known = g_vfs_read_known_app_bytes(alias_name)
        if alias_known.len() > 0:
            return alias_known
    if root_alias != root_name:
        val root_alias_known = g_vfs_read_known_app_bytes(root_alias)
        if root_alias_known.len() > 0:
            return root_alias_known
    if alias_name != name or root_disk_alias != name:
        return []
    g_vfs_read_file_bytes(name)

fn _clone_bytes(buf: [u8]) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < buf.len():
        out.push(buf[i])
        i = i + 1
    out

fn _copy_bytes_from_addr(addr: u64, size: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < size:
        out.push(mmio_read8(addr + i))
        i = i + 1
    out

fn g_vfs_root_read_file_text(driver: Fat32Core, path: text) -> text:
    val flags = FileFlags(read: true, write: false, create: false, append: false, truncate: false)
    val open_r = driver.open(path, flags)
    if open_r.is_err():
        return ""
    val handle = open_r.unwrap()
    val read_r = driver.read(handle, 65536)
    driver.close(handle)
    if read_r.is_err():
        return ""
    val data = read_r.unwrap()
    var result: text = ""
    var i: i32 = 0
    while i < data.len():
        result = result + data[i].to_char()
        i = i + 1
    result

fn _g_vfs_root_read_file_bytes_once(driver: Fat32Core, path: text) -> [u8]:
    val flags = FileFlags(read: true, write: false, create: false, append: false, truncate: false)
    val stat_r = driver.stat(path)
    if stat_r.is_err():
        serial_println("[vfs-root] stat_failed path={path}")
    else:
        serial_println("[vfs-root] stat_ok path={path} size={stat_r.unwrap().size}")
    val open_r = driver.open(path, flags)
    if open_r.is_err():
        serial_println("[vfs-root] open_failed path={path}")
        return []
    val handle = open_r.unwrap()
    val read_r = driver.read(handle, 1048576)
    driver.close(handle)
    if read_r.is_err():
        serial_println("[vfs-root] read_failed path={path}")
        return []
    val data = read_r.unwrap()
    serial_println("[vfs-root] read_ok path={path} bytes={data.len()}")
    data

fn g_vfs_root_read_file_bytes(driver: Fat32Core, path: text) -> [u8]:
    val cached = _g_vfs_root_read_file_bytes_once(driver, path)
    if cached.len() > 0:
        return cached

    # Live desktop-disk QEMU currently reaches a state where the persisted
    # root-driver instance can fail lookups even though the device and volume
    # are healthy. Retry with a fresh mount on the same block adapter so
    # filesystem-backed app exec can still use real disk bytes.
    var retry_driver = Fat32Core.new(g_c_adapter)
    val retry_mount = retry_driver.mount("", "")
    if retry_mount.is_err():
        serial_println("[vfs-root] retry_mount_failed path={path} err={retry_mount.unwrap_err()}")
        return []
    serial_println("[vfs-root] retry_mount_ok path={path}")
    val retried = _g_vfs_root_read_file_bytes_once(retry_driver, path)
    if retried.len() > 0:
        return retried

    []

fn g_vfs_root_file_size(driver: Fat32Core, path: text) -> i64:
    val stat_r = driver.stat(path)
    if stat_r.is_err():
        return -1
    stat_r.unwrap().size.to_i64()

fn g_vfs_root_file_exists(driver: Fat32Core, path: text) -> bool:
    driver.stat(path).is_ok()

fn g_vfs_root_write_file_text(driver: Fat32Core, path: text, content: text) -> bool:
    val flags = FileFlags(read: true, write: true, create: true, append: false, truncate: true)
    val open_r = driver.open(path, flags)
    if open_r.is_err():
        return false
    val handle = open_r.unwrap()
    var buf: [u8] = []
    var i: i32 = 0
    while i < content.len():
        buf.push(str_char_at(content, i.to_i64()).to_u8())
        i = i + 1
    val write_r = driver.write(handle, buf)
    driver.close(handle)
    write_r.is_ok()

fn g_vfs_dispatch_read_file_text(driver: DriverInstance, relpath: Path) -> text:
    """Dispatch read-whole-file-as-text to the correct concrete driver.

    Reads up to 65536 bytes. Returns empty string on any error.
    All four DriverInstance arms are covered to satisfy exhaustive match.
    """
    match driver:
        case Fat32(d):
            val flags = OpenFlags.read_only()
            val open_r = d.open(relpath, flags)
            if open_r.is_err():
                return ""
            val handle = open_r.unwrap()
            var buf: [u8] = []
            var i: i32 = 0
            while i < 65536:
                buf.push(0)
                i = i + 1
            val read_r = d.read(handle, 0, buf)
            d.close(handle)
            if read_r.is_err():
                return ""
            val n = read_r.unwrap()
            if n <= 0:
                return ""
            # Build text from byte array (UTF-8 assumption, ASCII path in FAT32)
            var result: text = ""
            var j: i32 = 0
            while j < n.to_i32():
                result = result + buf[j].to_char()
                j = j + 1
            result
        case Nvfs(d):
            val flags = OpenFlags.read_only()
            val open_r = d.open(relpath, flags)
            if open_r.is_err():
                return ""
            val handle = open_r.unwrap()
            val stat_r = d.fstat(handle)
            if stat_r.is_err():
                d.close(handle)
                return ""
            val size = stat_r.unwrap().size.to_i64()
            if size <= 0:
                d.close(handle)
                return ""
            var buf: [u8] = []
            var i: i64 = 0
            while i < size:
                buf.push(0)
                i = i + 1
            val read_r = d.read(handle, 0, buf)
            d.close(handle)
            if read_r.is_err():
                return ""
            val n = read_r.unwrap()
            var result: text = ""
            var j: i32 = 0
            while j < n.to_i32():
                result = result + buf[j].to_char()
                j = j + 1
            result
        case NvfsPosix(_):
            ""
        case RamFs(_):
            ""

fn g_vfs_dispatch_read_file_bytes(driver: DriverInstance, relpath: Path) -> [u8]:
    """Dispatch read-whole-file-as-bytes to the correct concrete driver.

    Returns an empty byte array on any error. This is used by the kernel
    executable loader so user processes can be loaded from the mounted
    filesystem instead of from resident entrypoint shims.
    """
    match driver:
        case Fat32(d):
            val stat_r = d.stat(relpath)
            if stat_r.is_err():
                return []
            val size = stat_r.unwrap().size.to_i64()
            if size <= 0:
                return []
            val flags = OpenFlags.read_only()
            val open_r = d.open(relpath, flags)
            if open_r.is_err():
                return []
            val handle = open_r.unwrap()
            var buf: [u8] = []
            var i: i64 = 0
            while i < size:
                buf.push(0)
                i = i + 1
            val read_r = d.read(handle, 0, buf)
            d.close(handle)
            if read_r.is_err():
                return []
            val n = read_r.unwrap()
            if n <= 0:
                return []
            if n.to_i32() == buf.len():
                return buf
            var out: [u8] = []
            var j: i32 = 0
            while j < n.to_i32():
                out.push(buf[j])
                j = j + 1
            out
        case Nvfs(d):
            val stat_r = d.stat(relpath)
            if stat_r.is_err():
                return []
            val size = stat_r.unwrap().size.to_i64()
            if size <= 0:
                return []
            val flags = OpenFlags.read_only()
            val open_r = d.open(relpath, flags)
            if open_r.is_err():
                return []
            val handle = open_r.unwrap()
            var buf: [u8] = []
            var i: i64 = 0
            while i < size:
                buf.push(0)
                i = i + 1
            val read_r = d.read(handle, 0, buf)
            d.close(handle)
            if read_r.is_err():
                return []
            val n = read_r.unwrap()
            if n <= 0:
                return []
            if n.to_i32() == buf.len():
                return _clone_bytes(buf)
            var out: [u8] = []
            var j: i32 = 0
            while j < n.to_i32():
                out.push(buf[j])
                j = j + 1
            out
        case NvfsPosix(_):
            []
        case RamFs(_):
            []

fn g_vfs_dispatch_file_size(driver: DriverInstance, relpath: Path) -> i64:
    """Dispatch stat → size to the concrete driver. Returns -1 on error."""
    match driver:
        case Fat32(d):
            val r = d.stat(relpath)
            if r.is_err():
                return -1
            r.unwrap().size.to_i64()
        case Nvfs(d):
            val r = d.stat(relpath)
            if r.is_err():
                return -1
            r.unwrap().size.to_i64()
        case NvfsPosix(_):
            -1
        case RamFs(_):
            -1

fn g_vfs_dispatch_file_exists(driver: DriverInstance, relpath: Path) -> bool:
    """Dispatch stat → exists to the concrete driver."""
    match driver:
        case Fat32(d):
            d.stat(relpath).is_ok()
        case Nvfs(d):
            d.stat(relpath).is_ok()
        case NvfsPosix(_):
            false
        case RamFs(_):
            false

pub fn g_vfs_read_file_text(name: text) -> text:
    """Read an entire file as text via the mount table.

    Accepts bare FAT32 names ("HELLO.TXT") or absolute paths ("/HELLO.TXT").
    Returns empty string on any error (mirrors rt_fat32_read_file_text semantics).
    Prefer this over rt_fat32_read_file_text for all new callers.
    """
    if g_root_fat32 != nil:
        return g_vfs_root_read_file_text(g_root_fat32.unwrap(), g_vfs_root_path(name))
    val abs = g_vfs_abs_path(name)
    val entry_opt = g_mount_table.lookup(abs)
    if not entry_opt.?:
        return ""
    val entry = entry_opt.unwrap()
    # Build relpath by stripping the mount point prefix
    val mp_len = entry.mount_point.len()
    var rel_raw: text = ""
    var ci: i64 = mp_len
    while ci < abs.raw.len():
        rel_raw = rel_raw + str_char_at(abs.raw, ci)
        ci = ci + 1
    # If relpath is empty (mount root was requested), use the name directly
    if rel_raw == "":
        rel_raw = abs.raw
    val relpath = Path(raw: rel_raw)
    g_vfs_dispatch_read_file_text(entry.driver, relpath)

pub fn g_vfs_read_file_bytes(name: text) -> [u8]:
    """Read an entire file as bytes via the mount table.

    Accepts bare FAT32 names ("HELLO.TXT") or absolute paths ("/HELLO.TXT").
    Returns an empty byte array on any error.
    """
    if g_root_fat32 != nil:
        val root_bytes = g_vfs_root_read_file_bytes(g_root_fat32.unwrap(), g_vfs_root_path(name))
        if root_bytes.len() > 0:
            return _clone_bytes(root_bytes)
        val root_alias_name = _vfs_exec_disk_alias(name)
        if root_alias_name != name:
            val root_alias_bytes = g_vfs_root_read_file_bytes(g_root_fat32.unwrap(), g_vfs_root_path(root_alias_name))
            if root_alias_bytes.len() > 0:
                return _clone_bytes(root_alias_bytes)
        val root_name_first = g_vfs_root_path(name)
        val root_alias_first = _vfs_exec_disk_alias(root_name_first)
        if root_alias_first != root_name_first:
            val root_alias_path_bytes = g_vfs_root_read_file_bytes(g_root_fat32.unwrap(), root_alias_first)
            if root_alias_path_bytes.len() > 0:
                return _clone_bytes(root_alias_path_bytes)
    val abs_first = g_vfs_abs_path(name)
    val entry_first_opt = g_mount_table.lookup(abs_first)
    if entry_first_opt.?:
        val entry_first = entry_first_opt.unwrap()
        val mp_len_first = entry_first.mount_point.len()
        var rel_raw_first: text = ""
        var ci_first: i64 = mp_len_first
        while ci_first < abs_first.raw.len():
            rel_raw_first = rel_raw_first + str_char_at(abs_first.raw, ci_first)
            ci_first = ci_first + 1
        if rel_raw_first == "":
            rel_raw_first = abs_first.raw
        val mounted_bytes = g_vfs_dispatch_read_file_bytes(entry_first.driver, Path(raw: rel_raw_first))
        if mounted_bytes.len() > 0:
            return _clone_bytes(mounted_bytes)
    # Compatibility fallback for existing boot media that still expose the
    # transitional C FAT32 bridge.
    val direct_path_bytes = g_vfs_read_fat32_path_bytes(name)
    if direct_path_bytes.len() > 0:
        return direct_path_bytes
    val root_name = g_vfs_root_path(name)
    val root_path_bytes = g_vfs_read_fat32_path_bytes(root_name)
    if root_path_bytes.len() > 0:
        return root_path_bytes
    val alias_name = _vfs_exec_disk_alias(name)
    if alias_name != name:
        val alias_bytes = g_vfs_read_fat32_path_bytes(alias_name)
        if alias_bytes.len() > 0:
            return alias_bytes
    val root_alias = _vfs_exec_disk_alias(root_name)
    if root_alias != root_name:
        val root_alias_bytes = g_vfs_read_fat32_path_bytes(root_alias)
        if root_alias_bytes.len() > 0:
            return root_alias_bytes
    val direct_c_bytes = g_vfs_read_known_app_bytes(name)
    if direct_c_bytes.len() > 0:
        return direct_c_bytes
    val c_bytes = g_vfs_read_known_app_bytes(root_name)
    if c_bytes.len() > 0:
        return c_bytes
    val abs = g_vfs_abs_path(name)
    val entry_opt = g_mount_table.lookup(abs)
    if not entry_opt.?:
        return []
    val entry = entry_opt.unwrap()
    val mp_len = entry.mount_point.len()
    var rel_raw: text = ""
    var ci: i64 = mp_len
    while ci < abs.raw.len():
        rel_raw = rel_raw + str_char_at(abs.raw, ci)
        ci = ci + 1
    if rel_raw == "":
        rel_raw = abs.raw
    val relpath = Path(raw: rel_raw)
    g_vfs_dispatch_read_file_bytes(entry.driver, relpath)

pub fn g_vfs_file_size(name: text) -> i64:
    """Return file size in bytes via the mount table, or -1 on error.

    Accepts bare FAT32 names or absolute paths.
    Prefer this over rt_fat32_file_size for all new callers.
    """
    if g_root_fat32 != nil:
        val root_size_first = g_vfs_root_file_size(g_root_fat32.unwrap(), g_vfs_root_path(name))
        if root_size_first >= 0:
            return root_size_first
        val root_alias_name = _vfs_exec_disk_alias(name)
        if root_alias_name != name:
            val root_alias_size = g_vfs_root_file_size(g_root_fat32.unwrap(), g_vfs_root_path(root_alias_name))
            if root_alias_size >= 0:
                return root_alias_size
        val root_name_first = g_vfs_root_path(name)
        val root_alias_first = _vfs_exec_disk_alias(root_name_first)
        if root_alias_first != root_name_first:
            val root_alias_path_size = g_vfs_root_file_size(g_root_fat32.unwrap(), root_alias_first)
            if root_alias_path_size >= 0:
                return root_alias_path_size
    val abs_first = g_vfs_abs_path(name)
    val entry_first_opt = g_mount_table.lookup(abs_first)
    if entry_first_opt.?:
        val entry_first = entry_first_opt.unwrap()
        val mp_len_first = entry_first.mount_point.len()
        var rel_raw_first: text = ""
        var ci_first: i64 = mp_len_first
        while ci_first < abs_first.raw.len():
            rel_raw_first = rel_raw_first + str_char_at(abs_first.raw, ci_first)
            ci_first = ci_first + 1
        if rel_raw_first == "":
            rel_raw_first = abs_first.raw
        val mounted_size = g_vfs_dispatch_file_size(entry_first.driver, Path(raw: rel_raw_first))
        if mounted_size >= 0:
            return mounted_size
    # Compatibility fallback for transitional C FAT32 bridge readers.
    val direct_size = simpleos_fat32_read_path_size(name)
    if direct_size > 0:
        return direct_size
    val root_name = g_vfs_root_path(name)
    val root_size = simpleos_fat32_read_path_size(root_name)
    if root_size > 0:
        return root_size
    val alias_name = _vfs_exec_disk_alias(name)
    if alias_name != name:
        val alias_size = simpleos_fat32_read_path_size(alias_name)
        if alias_size > 0:
            return alias_size
    val root_alias = _vfs_exec_disk_alias(root_name)
    if root_alias != root_name:
        val root_alias_size = simpleos_fat32_read_path_size(root_alias)
        if root_alias_size > 0:
            return root_alias_size
    val abs = g_vfs_abs_path(name)
    val entry_opt = g_mount_table.lookup(abs)
    if not entry_opt.?:
        return -1
    val entry = entry_opt.unwrap()
    val mp_len = entry.mount_point.len()
    var rel_raw: text = ""
    var ci: i64 = mp_len
    while ci < abs.raw.len():
        rel_raw = rel_raw + str_char_at(abs.raw, ci)
        ci = ci + 1
    if rel_raw == "":
        rel_raw = abs.raw
    val relpath = Path(raw: rel_raw)
    g_vfs_dispatch_file_size(entry.driver, relpath)

# ============================================================================
# VFS Select-File Cursor (FR-SIMPLEOS-M5-001, Option C)
# ============================================================================
#
# Replaces rt_fat32_select_file's static 64-byte name cursor.
# State lives here (service layer), NOT in DriverInstance — drivers stay
# stateless per the MDSOC+ composition-over-state contract.
#
# Usage:
#   g_vfs_select_file("HELLO.TXT")            # remember name
#   g_vfs_write_selected_file_text("content") # write to remembered name
#   g_vfs_clear_selected_file()               # reset cursor

var g_vfs_selected_file: text = ""

pub fn g_vfs_select_file(name: text):
    """Set the VFS cursor to name (bare FAT32 name or absolute path).

    Analogous to the retired rt_fat32_select_file semantics.
    The name is stored as-is; g_vfs_write_selected_file_text uses it
    as the destination path.
    """
    g_vfs_selected_file = name

pub fn g_vfs_get_selected_file() -> text:
    """Return the currently selected file name, or empty string if none."""
    g_vfs_selected_file

pub fn g_vfs_clear_selected_file():
    """Clear the VFS file cursor."""
    g_vfs_selected_file = ""

pub fn g_vfs_write_selected_file_text(content: text) -> bool:
    """Write content to the currently selected file via the mount table.

    Returns true on success, false if no file is selected or write fails.
    Analogous to the retired rt_fat32_write_selected_file_text semantics.
    """
    if g_vfs_selected_file == "":
        return false
    g_vfs_write_file_text(name: g_vfs_selected_file, content: content)

pub fn g_vfs_write_file_text(name: text, content: text) -> bool:
    """Write content as UTF-8 text to name via the mount table.

    Accepts bare FAT32 names or absolute paths.
    Returns true on success, false on any error.
    """
    if g_root_fat32 != nil:
        return g_vfs_root_write_file_text(driver: g_root_fat32.unwrap(), path: g_vfs_root_path(name), content: content)
    val abs = g_vfs_abs_path(name)
    val entry_opt = g_mount_table.lookup(abs)
    if not entry_opt.?:
        return false
    val entry = entry_opt.unwrap()
    val mp_len = entry.mount_point.len()
    var rel_raw: text = ""
    var ci: i64 = mp_len
    while ci < abs.raw.len():
        rel_raw = rel_raw + str_char_at(abs.raw, ci)
        ci = ci + 1
    if rel_raw == "":
        rel_raw = abs.raw
    val relpath = Path(raw: rel_raw)
    g_vfs_dispatch_write_file_text(entry.driver, relpath, content)

fn g_vfs_dispatch_write_file_text(driver: DriverInstance, relpath: Path, content: text) -> bool:
    """Dispatch write-whole-file-as-text to the correct concrete driver.

    All four DriverInstance arms are covered to satisfy exhaustive match.
    Only Fat32 is implemented; others return false (not yet supported).
    """
    match driver:
        case Fat32(d):
            val flags = OpenFlags.read_write()
            val open_r = d.open(relpath, flags)
            if open_r.is_err():
                return false
            val handle = open_r.unwrap()
            var buf: [u8] = []
            var i: i32 = 0
            while i < content.len():
                buf.push(str_char_at(content, i.to_i64()).to_u8())
                i = i + 1
            val write_r = d.write(handle, 0, buf)
            d.close(handle)
            write_r.is_ok()
        case Nvfs(d):
            val flags = OpenFlags.read_write().with_create()
            val open_r = d.open(relpath, flags)
            if open_r.is_err():
                return false
            val handle = open_r.unwrap()
            var buf: [u8] = []
            var i: i32 = 0
            while i < content.len():
                buf.push(str_char_at(content, i.to_i64()).to_u8())
                i = i + 1
            val write_r = d.write(handle, 0, buf)
            d.close(handle)
            write_r.is_ok()
        case NvfsPosix(_):
            false
        case RamFs(_):
            false

pub fn g_vfs_file_exists(name: text) -> bool:
    """Check file existence via the mount table.

    Accepts bare FAT32 names or absolute paths.
    Prefer this over rt_fat32_file_exists for all new callers.
    """
    if g_root_fat32 != nil:
        if g_vfs_root_file_exists(g_root_fat32.unwrap(), g_vfs_root_path(name)):
            return true
        val root_alias_name = _vfs_exec_disk_alias(name)
        if root_alias_name != name and g_vfs_root_file_exists(g_root_fat32.unwrap(), g_vfs_root_path(root_alias_name)):
            return true
        val root_name_first = g_vfs_root_path(name)
        val root_alias_first = _vfs_exec_disk_alias(root_name_first)
        if root_alias_first != root_name_first and g_vfs_root_file_exists(g_root_fat32.unwrap(), root_alias_first):
            return true
    val abs_first = g_vfs_abs_path(name)
    val entry_first_opt = g_mount_table.lookup(abs_first)
    if entry_first_opt.?:
        val entry_first = entry_first_opt.unwrap()
        val mp_len_first = entry_first.mount_point.len()
        var rel_raw_first: text = ""
        var ci_first: i64 = mp_len_first
        while ci_first < abs_first.raw.len():
            rel_raw_first = rel_raw_first + str_char_at(abs_first.raw, ci_first)
            ci_first = ci_first + 1
        if rel_raw_first == "":
            rel_raw_first = abs_first.raw
        if g_vfs_dispatch_file_exists(entry_first.driver, Path(raw: rel_raw_first)):
            return true
    # Compatibility fallback for transitional C FAT32 bridge readers.
    if simpleos_fat32_read_path_size(name) > 0:
        return true
    val root_name = g_vfs_root_path(name)
    if simpleos_fat32_read_path_size(root_name) > 0:
        return true
    val alias_name = _vfs_exec_disk_alias(name)
    if alias_name != name and simpleos_fat32_read_path_size(alias_name) > 0:
        return true
    val root_alias = _vfs_exec_disk_alias(root_name)
    if root_alias != root_name and simpleos_fat32_read_path_size(root_alias) > 0:
        return true
    val abs = g_vfs_abs_path(name)
    val entry_opt = g_mount_table.lookup(abs)
    if not entry_opt.?:
        return false
    val entry = entry_opt.unwrap()
    val mp_len = entry.mount_point.len()
    var rel_raw: text = ""
    var ci: i64 = mp_len
    while ci < abs.raw.len():
        rel_raw = rel_raw + str_char_at(abs.raw, ci)
        ci = ci + 1
    if rel_raw == "":
        rel_raw = abs.raw
    val relpath = Path(raw: rel_raw)
    g_vfs_dispatch_file_exists(entry.driver, relpath)
