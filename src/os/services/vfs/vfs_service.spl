# VFS IPC Service -- User-space filesystem service
#
# MDSOC: feature dimension, vfs layer
# Listens on IPC port 1 for filesystem requests from applications.
# Dispatches to mounted Filesystem implementations via VfsManager.
#
# Wire protocol:
#   Request:  method (u32) | flags (u32) | payload (bytes)
#   Response: status (i32) | payload (bytes)
#
# Payload encoding per method:
#   OPEN:   path (text) \0 flags_u32
#   READ:   fd (u64) | size (u64)
#   WRITE:  fd (u64) | data (bytes)
#   CLOSE:  fd (u64)
#   STAT:   path (text)
#   READDIR: path (text)
#   MKDIR:  path (text)
#   UNLINK: path (text)
#   RENAME: old_path (text) \0 new_path (text)
#   SEEK:   fd (u64) | offset (i64) | whence (u8)
#   MOUNT_LIST: (empty)
#   CHMOD:  path (text) \0 mode (u16)
#   SYMLINK: target (text) \0 link_path (text)

use os.services.vfs.vfs.{VfsManager, Filesystem, SeekWhence}
use os.kernel.types.fs_types.{FileDescriptor, FileFlags, FsNode, FsNodeKind, DirEntry}
use os.kernel.types.ipc_types.{IpcMessage}
use os.async.os_executor.{OsExecutor}
use os.userlib.syscall_raw.{syscall}

extern fn serial_println(msg: text)

# VFS IPC method constants
val VFS_OPEN: u32 = 1
val VFS_READ: u32 = 2
val VFS_WRITE: u32 = 3
val VFS_CLOSE: u32 = 4
val VFS_STAT: u32 = 5
val VFS_READDIR: u32 = 6
val VFS_MKDIR: u32 = 7
val VFS_UNLINK: u32 = 8
val VFS_RENAME: u32 = 9
val VFS_MOUNT_LIST: u32 = 10
val VFS_SEEK: u32 = 11
val VFS_CHMOD: u32 = 12
val VFS_SYMLINK: u32 = 13

# Syscall numbers — canonical values from src/os/kernel/ipc/syscall.spl
# dispatcher cases 20..23. Keep in sync with test/unit/os/kernel/ipc/
# syscall_number_consistency_spec.spl.
val SYS_IPC_SEND: u64 = 20
val SYS_IPC_RECV: u64 = 21
val SYS_IPC_CREATE_PORT: u64 = 22
val SYS_IPC_CONNECT: u64 = 23

# Response status codes
val STATUS_OK: i32 = 0
val STATUS_ERR: i32 = -1
val STATUS_NOT_FOUND: i32 = -2
val STATUS_INVALID: i32 = -3
val STATUS_READ_ONLY: i32 = -4

# ============================================================================
# VFS Service
# ============================================================================

class VfsService:
    """VFS IPC service -- listens on port 1, dispatches to VfsManager.

    The service runs as a cooperative async task within the OS executor.
    Each incoming IPC message is decoded, dispatched to the appropriate
    VfsManager method, and a reply is sent back via IPC.
    """
    vfs: VfsManager
    port_id: u64        # IPC port (1)
    running: bool
    executor: OsExecutor
    request_count: u64

impl VfsService:
    static fn new(vfs: VfsManager) -> VfsService:
        VfsService(
            vfs: vfs,
            port_id: 1,
            running: false,
            executor: OsExecutor.new(),
            request_count: 0
        )

    static fn with_executor(vfs: VfsManager, executor: OsExecutor) -> VfsService:
        """Create with an externally-provided executor for integration."""
        VfsService(
            vfs: vfs,
            port_id: 1,
            running: false,
            executor: executor,
            request_count: 0
        )

    me start():
        """Create IPC port and start blocking service loop."""
        self.init_port()
        self.run_loop()

    me init_port():
        """Create IPC port without entering the blocking loop.

        Call this instead of start() when using cooperative scheduling
        (os_main calls poll_once() in a shared main loop).
        """
        val port = syscall(SYS_IPC_CREATE_PORT, 0, 0, 0, 0, 0)
        if port < 0:
            serial_println("[vfs-service] Failed to create IPC port (error {port})")
            return
        self.port_id = port.to_u64()
        self.running = true
        serial_println("[vfs-service] Listening on IPC port {self.port_id}")

    me run_loop():
        """Main service loop: blocking receive, dispatch, reply. Blocks forever.

        Uses IpcRecv with timeout=-1 (infinite wait). For dedicated task mode.
        """
        while self.running:
            # arg1 = -1 means block until message arrives (cast via to_u64)
            val timeout_blocking: u64 = 0xFFFFFFFFFFFFFFFF  # -1 as unsigned
            val msg_raw = syscall(SYS_IPC_RECV, self.port_id, timeout_blocking, 0, 0, 0)
            if msg_raw < 0:
                continue  # Error — retry
            self.request_count = self.request_count + 1
            self.dispatch_message(msg_raw.to_u64())

    me poll_once():
        """Process one IPC request if available (non-blocking).

        Uses IpcRecv with timeout=0: kernel returns -EAGAIN immediately
        if no message is pending (syscall.spl line 627-629).
        Call from the cooperative main loop in os_main.spl.
        """
        if not self.running:
            return
        # arg1 = 0 means non-blocking: returns -11 (EAGAIN) if no message
        val msg_raw = syscall(SYS_IPC_RECV, self.port_id, 0, 0, 0, 0)
        if msg_raw < 0:
            return  # EAGAIN or error — no message pending
        self.request_count = self.request_count + 1
        self.dispatch_message(msg_raw.to_u64())

    me dispatch_message(msg_addr: u64):
        """Parse an IPC message and dispatch to the appropriate handler.

        The IPC message is an IpcMessage struct at msg_addr. We read
        the method field to determine which handler to invoke.
        """
        # Read IpcMessage fields from memory
        # IpcMessage layout: src_port(8) | dst_port(8) | method(4) | flags(4) | payload_len(4) | cap_count(4)
        val src_port = _read_u64(msg_addr)
        val method = _read_u32(msg_addr + 16)
        val payload_len = _read_u32(msg_addr + 24)
        val payload_addr = msg_addr + 32  # Payload starts after header

        match method:
            VFS_OPEN: self.dispatch_open(src_port, payload_addr, payload_len)
            VFS_READ: self.dispatch_read(src_port, payload_addr, payload_len)
            VFS_WRITE: self.dispatch_write(src_port, payload_addr, payload_len)
            VFS_CLOSE: self.dispatch_close(src_port, payload_addr, payload_len)
            VFS_STAT: self.dispatch_stat(src_port, payload_addr, payload_len)
            VFS_READDIR: self.dispatch_readdir(src_port, payload_addr, payload_len)
            VFS_MKDIR: self.dispatch_mkdir(src_port, payload_addr, payload_len)
            VFS_UNLINK: self.dispatch_unlink(src_port, payload_addr, payload_len)
            VFS_RENAME: self.dispatch_rename(src_port, payload_addr, payload_len)
            VFS_MOUNT_LIST: self.dispatch_mount_list(src_port)
            VFS_SEEK: self.dispatch_seek(src_port, payload_addr, payload_len)
            VFS_CHMOD: self.dispatch_chmod(src_port, payload_addr, payload_len)
            VFS_SYMLINK: self.dispatch_symlink(src_port, payload_addr, payload_len)
            _: self.send_error_reply(src_port, STATUS_INVALID, "unknown VFS method")

    # ========================================================================
    # Dispatch Handlers
    # ========================================================================

    me dispatch_open(src_port: u64, payload_addr: u64, payload_len: u32):
        """Parse OPEN request: path\0flags_u32."""
        val path = _read_text_until_null(payload_addr, payload_len)
        val flags_offset = path.len().to_u32() + 1
        var flags_raw: u32 = 0
        if flags_offset + 4 <= payload_len:
            flags_raw = _read_u32(payload_addr + flags_offset.to_u64())
        val flags = FileFlags(
            read: true,
            write: (flags_raw & 0x02) != 0,
            create: (flags_raw & 0x04) != 0,
            append: (flags_raw & 0x08) != 0,
            truncate: (flags_raw & 0x10) != 0,
            directory: false
        )
        match self.vfs.open(path, flags):
            Result.Ok(fd):
                self.send_u64_reply(src_port, STATUS_OK, fd.fd.to_u64())
            Result.Err(e):
                self.send_error_reply(src_port, STATUS_NOT_FOUND, e)

    me dispatch_read(src_port: u64, payload_addr: u64, payload_len: u32):
        """Parse READ request: fd(u64) | size(u64)."""
        val fd = _read_u64(payload_addr)
        val size = _read_u64(payload_addr + 8)
        # Find the mount for this fd and read
        # For now use the fd's underlying handle directly
        val mount = self.vfs.mounts[0]  # Simplified: use first mount
        match mount.fs.read(fd, size):
            Result.Ok(data):
                self.send_bytes_reply(src_port, STATUS_OK, data)
            Result.Err(e):
                self.send_error_reply(src_port, STATUS_ERR, e)

    me dispatch_write(src_port: u64, payload_addr: u64, payload_len: u32):
        """Parse WRITE request: fd(u64) | data(bytes)."""
        val fd = _read_u64(payload_addr)
        val data_len = payload_len - 8
        var data: [u8] = []
        var i: u32 = 0
        while i < data_len:
            data.push(_read_u8(payload_addr + 8 + i.to_u64()))
            i = i + 1
        val mount = self.vfs.mounts[0]
        match mount.fs.write(fd, data):
            Result.Ok(written):
                self.send_u64_reply(src_port, STATUS_OK, written)
            Result.Err(e):
                self.send_error_reply(src_port, STATUS_ERR, e)

    me dispatch_close(src_port: u64, payload_addr: u64, payload_len: u32):
        """Parse CLOSE request: fd(u64)."""
        val fd = _read_u64(payload_addr)
        val mount = self.vfs.mounts[0]
        match mount.fs.close(fd):
            Result.Ok(v):
                self.send_u64_reply(src_port, STATUS_OK, 1)
            Result.Err(e):
                self.send_error_reply(src_port, STATUS_ERR, e)

    me dispatch_stat(src_port: u64, payload_addr: u64, payload_len: u32):
        """Parse STAT request: path(text)."""
        val path = _read_text(payload_addr, payload_len)
        match self.vfs.stat(path):
            Result.Ok(node):
                # Encode FsNode as: kind(u8) | size(u64) | permissions(u16)
                var reply: [u8] = []
                val kind_val: u8 = match node.kind:
                    FsNodeKind.File: 0
                    FsNodeKind.Directory: 1
                    FsNodeKind.Symlink: 2
                    FsNodeKind.Device: 3
                    FsNodeKind.Pipe: 4
                reply.push(kind_val)
                _push_u64(reply, node.size)
                _push_u16(reply, node.permissions)
                self.send_bytes_reply(src_port, STATUS_OK, reply)
            Result.Err(e):
                self.send_error_reply(src_port, STATUS_NOT_FOUND, e)

    me dispatch_readdir(src_port: u64, payload_addr: u64, payload_len: u32):
        """Parse READDIR request: path(text)."""
        val path = _read_text(payload_addr, payload_len)
        match self.vfs.readdir(path):
            Result.Ok(entries):
                # Encode as newline-separated "kind:name" entries
                var reply_text = ""
                var i = 0
                while i < entries.len():
                    val entry = entries[i]
                    val kind_val: u8 = match entry.node.kind:
                        FsNodeKind.File: 0
                        FsNodeKind.Directory: 1
                        FsNodeKind.Symlink: 2
                        FsNodeKind.Device: 3
                        FsNodeKind.Pipe: 4
                    if i > 0:
                        reply_text = reply_text + "\n"
                    reply_text = reply_text + "{kind_val}:{entry.name}"
                    i = i + 1
                self.send_text_reply(src_port, STATUS_OK, reply_text)
            Result.Err(e):
                self.send_error_reply(src_port, STATUS_NOT_FOUND, e)

    me dispatch_mkdir(src_port: u64, payload_addr: u64, payload_len: u32):
        """Parse MKDIR request: path(text)."""
        val path = _read_text(payload_addr, payload_len)
        match self.vfs.mkdir(path):
            Result.Ok(v):
                self.send_u64_reply(src_port, STATUS_OK, 1)
            Result.Err(e):
                self.send_error_reply(src_port, STATUS_ERR, e)

    me dispatch_unlink(src_port: u64, payload_addr: u64, payload_len: u32):
        """Parse UNLINK request: path(text)."""
        val path = _read_text(payload_addr, payload_len)
        val mount = self.vfs.resolve_mount(path)
        if mount.?:
            val entry = mount.unwrap()
            val relative = self.vfs.strip_mount_prefix(path, entry.point.path)
            match entry.fs.unlink(relative):
                Result.Ok(v):
                    self.send_u64_reply(src_port, STATUS_OK, 1)
                Result.Err(e):
                    self.send_error_reply(src_port, STATUS_ERR, e)
        else:
            self.send_error_reply(src_port, STATUS_NOT_FOUND, "no filesystem for path")

    me dispatch_rename(src_port: u64, payload_addr: u64, payload_len: u32):
        """Parse RENAME request: old_path\0new_path."""
        val old_path = _read_text_until_null(payload_addr, payload_len)
        val new_offset = old_path.len().to_u32() + 1
        val remaining = payload_len - new_offset
        val new_path = _read_text(payload_addr + new_offset.to_u64(), remaining)
        val mount = self.vfs.resolve_mount(old_path)
        if mount.?:
            val entry = mount.unwrap()
            val rel_old = self.vfs.strip_mount_prefix(old_path, entry.point.path)
            val rel_new = self.vfs.strip_mount_prefix(new_path, entry.point.path)
            match entry.fs.rename(rel_old, rel_new):
                Result.Ok(v):
                    self.send_u64_reply(src_port, STATUS_OK, 1)
                Result.Err(e):
                    self.send_error_reply(src_port, STATUS_ERR, e)
        else:
            self.send_error_reply(src_port, STATUS_NOT_FOUND, "no filesystem for path")

    me dispatch_chmod(src_port: u64, payload_addr: u64, payload_len: u32):
        """Parse CHMOD request: path\0mode(u16)."""
        val path = _read_text_until_null(payload_addr, payload_len)
        val mode_offset = path.len().to_u32() + 1
        var mode: u16 = 0
        if mode_offset + 2 <= payload_len:
            mode = _read_u16(payload_addr + mode_offset.to_u64())
        val mount = self.vfs.resolve_mount(path)
        if mount.?:
            val entry = mount.unwrap()
            val relative = self.vfs.strip_mount_prefix(path, entry.point.path)
            match entry.fs.chmod(relative, mode):
                Result.Ok(v):
                    self.send_u64_reply(src_port, STATUS_OK, 1)
                Result.Err(e):
                    self.send_error_reply(src_port, STATUS_ERR, e)
        else:
            self.send_error_reply(src_port, STATUS_NOT_FOUND, "no filesystem for path")

    me dispatch_symlink(src_port: u64, payload_addr: u64, payload_len: u32):
        """Parse SYMLINK request: target\0link_path."""
        val target = _read_text_until_null(payload_addr, payload_len)
        val link_offset = target.len().to_u32() + 1
        val remaining = payload_len - link_offset
        val link_path = _read_text(payload_addr + link_offset.to_u64(), remaining)
        val mount = self.vfs.resolve_mount(link_path)
        if mount.?:
            val entry = mount.unwrap()
            val rel_link = self.vfs.strip_mount_prefix(link_path, entry.point.path)
            match entry.fs.symlink(target, rel_link):
                Result.Ok(v):
                    self.send_u64_reply(src_port, STATUS_OK, 1)
                Result.Err(e):
                    self.send_error_reply(src_port, STATUS_ERR, e)
        else:
            self.send_error_reply(src_port, STATUS_NOT_FOUND, "no filesystem for path")

    me dispatch_mount_list(src_port: u64):
        """Return list of mount points."""
        var reply_text = ""
        var i = 0
        while i < self.vfs.mounts.len():
            val entry = self.vfs.mounts[i]
            if i > 0:
                reply_text = reply_text + "\n"
            reply_text = reply_text + "{entry.point.path} ({entry.point.fs_type} on {entry.point.device})"
            i = i + 1
        self.send_text_reply(src_port, STATUS_OK, reply_text)

    me dispatch_seek(src_port: u64, payload_addr: u64, payload_len: u32):
        """Parse SEEK request: fd(u64) | offset(i64) | whence(u8)."""
        val fd = _read_u64(payload_addr)
        val offset = _read_i64(payload_addr + 8)
        val whence_raw = _read_u8(payload_addr + 16)
        val whence = match whence_raw:
            0: SeekWhence.Set
            1: SeekWhence.Cur
            2: SeekWhence.End
            _: SeekWhence.Set
        val mount = self.vfs.mounts[0]
        match mount.fs.seek(fd, offset, whence):
            Result.Ok(pos):
                self.send_u64_reply(src_port, STATUS_OK, pos)
            Result.Err(e):
                self.send_error_reply(src_port, STATUS_ERR, e)

    # ========================================================================
    # Reply Helpers
    # ========================================================================

    fn send_u64_reply(dst_port: u64, status: i32, value: u64):
        """Send a reply with status + u64 value."""
        var buf: [u8] = []
        _push_i32(buf, status)
        _push_u64(buf, value)
        _ipc_send(dst_port, self.port_id, buf)

    fn send_bytes_reply(dst_port: u64, status: i32, data: [u8]):
        """Send a reply with status + raw bytes."""
        var buf: [u8] = []
        _push_i32(buf, status)
        var i = 0
        while i < data.len():
            buf.push(data[i])
            i = i + 1
        _ipc_send(dst_port, self.port_id, buf)

    fn send_text_reply(dst_port: u64, status: i32, text_val: text):
        """Send a reply with status + text payload."""
        var buf: [u8] = []
        _push_i32(buf, status)
        for ch in text_val:
            buf.push(ch.to_u8())
        _ipc_send(dst_port, self.port_id, buf)

    fn send_error_reply(dst_port: u64, status: i32, msg: text):
        """Send an error reply with status + error message."""
        var buf: [u8] = []
        _push_i32(buf, status)
        for ch in msg:
            buf.push(ch.to_u8())
        _ipc_send(dst_port, self.port_id, buf)

    me stop():
        """Stop the service loop."""
        self.running = false
        serial_println("[vfs-service] Stopped after {self.request_count} requests")

    fn stats() -> text:
        """Return service statistics as text."""
        "VfsService: port={self.port_id}, requests={self.request_count}, running={self.running}"

# ============================================================================
# Memory Access Helpers
# ============================================================================
#
# These read raw values from IPC message buffers in memory.
# Uses mmio_read functions since IPC buffers are in kernel-mapped memory.

extern fn mmio_read8(addr: u64) -> u8
extern fn mmio_read16(addr: u64) -> u16
extern fn mmio_read32(addr: u64) -> u32
extern fn mmio_read64(addr: u64) -> u64

fn _read_u8(addr: u64) -> u8:
    mmio_read8(addr)

fn _read_u16(addr: u64) -> u16:
    mmio_read16(addr)

fn _read_u32(addr: u64) -> u32:
    mmio_read32(addr)

fn _read_u64(addr: u64) -> u64:
    mmio_read64(addr)

fn _read_i64(addr: u64) -> i64:
    mmio_read64(addr).to_i64()

fn _read_text(addr: u64, len: u32) -> text:
    """Read a text string from memory."""
    var result = ""
    var i: u32 = 0
    while i < len:
        val ch = mmio_read8(addr + i.to_u64())
        if ch == 0:
            return result
        result = result + ch.to_char()
        i = i + 1
    result

fn _read_text_until_null(addr: u64, max_len: u32) -> text:
    """Read text from memory until null byte or max_len."""
    var result = ""
    var i: u32 = 0
    while i < max_len:
        val ch = mmio_read8(addr + i.to_u64())
        if ch == 0:
            return result
        result = result + ch.to_char()
        i = i + 1
    result

# ============================================================================
# Serialization Helpers
# ============================================================================

fn _push_u16(buf: [u8], val: u16):
    buf.push((val & 0xFF).to_u8())
    buf.push(((val >> 8) & 0xFF).to_u8())

fn _push_i32(buf: [u8], val: i32):
    val u = val.to_u32()
    buf.push((u & 0xFF).to_u8())
    buf.push(((u >> 8) & 0xFF).to_u8())
    buf.push(((u >> 16) & 0xFF).to_u8())
    buf.push(((u >> 24) & 0xFF).to_u8())

fn _push_u64(buf: [u8], val: u64):
    buf.push((val & 0xFF).to_u8())
    buf.push(((val >> 8) & 0xFF).to_u8())
    buf.push(((val >> 16) & 0xFF).to_u8())
    buf.push(((val >> 24) & 0xFF).to_u8())
    buf.push(((val >> 32) & 0xFF).to_u8())
    buf.push(((val >> 40) & 0xFF).to_u8())
    buf.push(((val >> 48) & 0xFF).to_u8())
    buf.push(((val >> 56) & 0xFF).to_u8())

# ============================================================================
# IPC Send Helper
# ============================================================================

fn _ipc_send(dst_port: u64, src_port: u64, data: [u8]):
    """Send reply data via IPC syscall.

    Encodes the data into a buffer and issues SYS_IPC_SEND = 20
    (kernel dispatcher case 20, _handle_ipc_send).
    """
    # SYS_IPC_SEND = 20: (dst_port, src_port, data_ptr, data_len, 0).
    # The kernel copies data from the caller's buffer to the receiver's buffer.
    extern fn unsafe_addr_of(ref: any) -> u64
    val data_ptr = unsafe_addr_of(data)
    val data_len = data.len().to_u64()
    syscall(SYS_IPC_SEND, dst_port, src_port, data_ptr, data_len, 0)
