# SimpleOS Process Filesystem — VFS `Filesystem`-trait adapter (H4)
"""Adapts the read-only /proc pseudo-filesystem onto the shared VFS
`Filesystem` trait so it composes exactly like FAT32/DBFS through
`VfsManager.mount`.

Like the /dev adapter, this keeps a seed-safe plain PID list rather than
routing through the ECS-backed `ProcfsService` (whose generic ComponentStore
does not lower under the bootstrap-seed interpreter). A compiled kernel boot
can read live task state through the process-manager IPC endpoint that
`ProcfsService` already models.

Exposed nodes:
  * /proc/<pid>            directory
  * /proc/<pid>/status     text view of the task
  * /proc/meminfo          synthetic memory summary

Plan: host_os_completeness H4.
"""

use os.services.vfs.vfs.{Filesystem, SeekWhence}
use os.kernel.types.fs_types.{FileFlags, FsNode, FsNodeKind, DirEntry}

# ---------------------------------------------------------------------------
# Open-handle record
# ---------------------------------------------------------------------------

struct ProcHandle:
    """An open /proc file handle bound to a mount-relative path."""
    id: u64
    rel: text

# Classification codes for a mount-relative /proc path.
val PROC_MISSING: i32 = -1
val PROC_ROOT: i32    = 0
val PROC_PIDDIR: i32  = 1
val PROC_FILE_NODE: i32 = 2

# ---------------------------------------------------------------------------
# ProcFs — Filesystem trait adapter
# ---------------------------------------------------------------------------

class ProcFs:
    """/proc pseudo-filesystem exposed through the `Filesystem` trait.

    Read-only: every mutating trait op fails closed.
    """
    var pids: [u32]
    var handles: [ProcHandle]
    var next_handle: u64

    static fn new() -> ProcFs:
        ProcFs(pids: [1 as u32, 2 as u32], handles: [], next_handle: 1 as u64)

    me seed_pid(pid: u32):
        """Register a live PID so it appears under /proc."""
        for p in self.pids:
            if p == pid:
                return
        self.pids = self.pids + [pid]

    me _has_pid(pid: u32) -> bool:
        for p in self.pids:
            if p == pid:
                return true
        false

    me _handle_rel(handle: u64) -> text:
        for h in self.handles:
            if h.id == handle:
                return h.rel
        ""

    me _classify(rel: text) -> i32:
        if rel == "/" or rel == "":
            return PROC_ROOT
        if rel == "/meminfo":
            return PROC_FILE_NODE
        val parts = rel.split("/")
        if parts.len() == 2:
            val pid = _parse_u32(parts[1])
            if pid > 0 and self._has_pid(pid):
                return PROC_PIDDIR
            return PROC_MISSING
        if parts.len() == 3:
            if parts[2] == "status":
                val pid = _parse_u32(parts[1])
                if pid > 0 and self._has_pid(pid):
                    return PROC_FILE_NODE
            return PROC_MISSING
        PROC_MISSING

    me _content(rel: text) -> text:
        if rel == "/meminfo":
            return _meminfo_text()
        val parts = rel.split("/")
        if parts.len() == 3 and parts[2] == "status":
            return _status_text(_parse_u32(parts[1]))
        ""

# ---------------------------------------------------------------------------
# Filesystem trait impl
# ---------------------------------------------------------------------------

impl Filesystem for ProcFs:
    fn fs_name() -> text:
        "procfs"

    fn mount(device: text, options: text) -> Result<bool, text>:
        Result.Ok(true)

    fn unmount() -> Result<bool, text>:
        self.handles = []
        Result.Ok(true)

    fn open(path: text, flags: FileFlags) -> Result<u64, text>:
        if flags.write or flags.create or flags.append or flags.truncate:
            return Result.Err("EROFS: /proc is read-only")
        val rel = _proc_rel(path)
        val kind = self._classify(rel)
        if kind == PROC_FILE_NODE:
            val h = self.next_handle
            self.next_handle = self.next_handle + (1 as u64)
            self.handles = self.handles + [ProcHandle(id: h, rel: rel)]
            return Result.Ok(h)
        if kind == PROC_ROOT or kind == PROC_PIDDIR:
            return Result.Err("EISDIR: {path}")
        Result.Err("ENOENT: {path}")

    fn read(handle: u64, size: u64) -> Result<[u8], text>:
        val rel = self._handle_rel(handle)
        if rel == "":
            return Result.Err("EBADF")
        Result.Ok(self._content(rel).bytes())

    fn write(handle: u64, data: [u8]) -> Result<u64, text>:
        Result.Err("EROFS: /proc is read-only")

    fn close(handle: u64) -> Result<bool, text>:
        var kept: [ProcHandle] = []
        var removed = false
        for h in self.handles:
            if h.id != handle:
                kept = kept + [h]
            else:
                removed = true
        self.handles = kept
        if removed:
            return Result.Ok(true)
        Result.Err("EBADF")

    fn seek(handle: u64, offset: i64, whence: SeekWhence) -> Result<u64, text>:
        Result.Err("ESPIPE: /proc entries are not seekable")

    fn stat(path: text) -> Result<FsNode, text>:
        val rel = _proc_rel(path)
        val kind = self._classify(rel)
        if kind == PROC_ROOT or kind == PROC_PIDDIR:
            return Result.Ok(_proc_fs_node(FsNodeKind.Directory, 0o555 as u16))
        if kind == PROC_FILE_NODE:
            return Result.Ok(_proc_fs_node(FsNodeKind.File, 0o444 as u16))
        Result.Err("ENOENT: {path}")

    fn chmod(path: text, mode: u16) -> Result<bool, text>:
        Result.Err("EROFS: /proc is read-only")

    fn mkdir(path: text) -> Result<bool, text>:
        Result.Err("EROFS: /proc is read-only")

    fn rmdir(path: text) -> Result<bool, text>:
        Result.Err("EROFS: /proc is read-only")

    fn readdir(path: text) -> Result<[DirEntry], text>:
        val rel = _proc_rel(path)
        val kind = self._classify(rel)
        if kind == PROC_ROOT:
            var entries: [DirEntry] = []
            for p in self.pids:
                entries = entries + [DirEntry(name: _u32_text(p), node: _proc_fs_node(FsNodeKind.Directory, 0o555 as u16))]
            entries = entries + [DirEntry(name: "meminfo", node: _proc_fs_node(FsNodeKind.File, 0o444 as u16))]
            return Result.Ok(entries)
        if kind == PROC_PIDDIR:
            var pid_entries: [DirEntry] = []
            pid_entries = pid_entries + [DirEntry(name: "status", node: _proc_fs_node(FsNodeKind.File, 0o444 as u16))]
            return Result.Ok(pid_entries)
        Result.Err("ENOTDIR: {path}")

    fn unlink(path: text) -> Result<bool, text>:
        Result.Err("EROFS: /proc is read-only")

    fn rename(old_path: text, new_path: text) -> Result<bool, text>:
        Result.Err("EROFS: /proc is read-only")

    fn symlink(target: text, link_path: text) -> Result<bool, text>:
        Result.Err("EROFS: /proc is read-only")

# ---------------------------------------------------------------------------
# Module helpers
# ---------------------------------------------------------------------------

fn _proc_rel(path: text) -> text:
    """Reduce an absolute or already-relative path to a /proc-relative path."""
    if path.starts_with("/proc"):
        val r = path.slice(5)
        if r == "":
            return "/"
        return r
    if path == "":
        return "/"
    path

fn _status_text(pid: u32) -> text:
    "Name:   task{pid}\nState:  R (running)\nPid:    {pid}\nVmRSS:  0 kB\n"

fn _meminfo_text() -> text:
    "MemTotal:       65536 kB\nMemFree:        32768 kB\nMemAvailable:   40960 kB\n"

fn _u32_text(v: u32) -> text:
    "{v}"

fn _proc_fs_node(kind: FsNodeKind, mode: u16) -> FsNode:
    FsNode(
        id: 0 as u64,
        kind: kind,
        size: 0 as u64,
        permissions: mode,
        owner: 0 as u32,
        group: 0 as u32,
        created_ns: 0 as u64,
        modified_ns: 0 as u64)

fn _parse_u32(s: text) -> u32:
    if s == "":
        return 0 as u32
    var i = 0
    val n = s.len()
    var acc: u32 = 0 as u32
    while i < n:
        val d = _digit_val(s[i:i + 1])
        if d < 0:
            break
        acc = (acc * (10 as u32)) + (d as u32)
        i = i + 1
    acc

fn _digit_val(ch: text) -> i32:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    return -1
