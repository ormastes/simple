# FAT32 Write Support
#
# MDSOC: feature dimension, vfs layer
# Extends the FAT32 filesystem with write operations:
# - Cluster allocation (find free clusters in FAT)
# - FAT table updates (mark clusters as used/EOC)
# - Directory entry creation (8.3 names)
# - File data writing
# - File creation and deletion
#
# This module provides Fat32WriteContext which operates on a Fat32Driver's
# block device. The Fat32Driver delegates write/mkdir/unlink to this context.

use os.services.fat32.fat32.{Fat32Driver, Fat32DirEntry, FAT32_ATTR_DIRECTORY, FAT32_ATTR_ARCHIVE, FAT32_ATTR_LFN}
use os.services.block_device.{BlockDevice}

# FAT32 special values
val FAT32_FREE: u32 = 0x00000000
val FAT32_EOC: u32 = 0x0FFFFFF8       # End of cluster chain
val FAT32_BAD: u32 = 0x0FFFFFF7
val FAT32_MASK: u32 = 0x0FFFFFFF      # 28-bit FAT entry mask

# Directory entry constants
val DIR_ENTRY_SIZE: u32 = 32
val DELETED_MARKER: u8 = 0xE5
val END_MARKER: u8 = 0x00

# ============================================================================
# Fat32WriteContext
# ============================================================================

class Fat32WriteContext:
    """Context for FAT32 write operations.

    Holds a reference to the FAT32 driver and a hint for the next free
    cluster. All FAT modifications go through this context to keep the
    cluster allocation state consistent.
    """
    device: BlockDevice
    bytes_per_sector: u32
    sectors_per_cluster: u32
    reserved_sectors: u32
    num_fats: u32
    fat_size: u32           # Sectors per FAT
    data_start_sector: u32
    total_clusters: u32
    next_free_hint: u32     # Hint for next free cluster search

impl Fat32WriteContext:
    static fn new(driver: Fat32Driver) -> Fat32WriteContext:
        """Create a write context from an initialized Fat32Driver."""
        Fat32WriteContext(
            device: driver.device,
            bytes_per_sector: driver.bytes_per_sector,
            sectors_per_cluster: driver.sectors_per_cluster,
            reserved_sectors: driver.reserved_sectors,
            num_fats: driver.num_fats,
            fat_size: driver.fat_size,
            data_start_sector: driver.data_start_sector,
            total_clusters: driver.total_clusters,
            next_free_hint: 2  # Clusters start at 2
        )

    # ========================================================================
    # FAT Table Operations
    # ========================================================================

    me read_fat_entry(cluster: u32) -> Result<u32, text>:
        """Read a FAT table entry for the given cluster.

        Each FAT entry is 4 bytes. Calculate which sector of the FAT
        contains the entry, read that sector, extract the 32-bit value,
        and mask to 28 bits.
        """
        if cluster < 2 or cluster >= self.total_clusters + 2:
            return Result.Err("invalid cluster number: {cluster}")

        val fat_offset = cluster * 4
        val fat_sector = self.reserved_sectors.to_u64() + (fat_offset / self.bytes_per_sector).to_u64()
        val entry_offset = (fat_offset % self.bytes_per_sector).to_i32()

        var buffer: [u8] = []
        var i: u32 = 0
        while i < self.bytes_per_sector:
            buffer.push(0)
            i = i + 1

        val result = self.device.read_sector(fat_sector, buffer)
        if result.is_err():
            return Result.Err("failed to read FAT sector")

        val entry = ((buffer[entry_offset + 3].to_u32() << 24) |
                     (buffer[entry_offset + 2].to_u32() << 16) |
                     (buffer[entry_offset + 1].to_u32() << 8) |
                     buffer[entry_offset].to_u32())
        Result.Ok(entry & FAT32_MASK)

    me write_fat_entry(cluster: u32, value: u32) -> Result<bool, text>:
        """Write a FAT table entry.

        Reads the sector, modifies the 4-byte entry (preserving upper 4 bits),
        and writes the sector back. Updates all FAT copies.
        """
        if cluster < 2 or cluster >= self.total_clusters + 2:
            return Result.Err("invalid cluster number: {cluster}")

        val fat_offset = cluster * 4
        val sector_in_fat = fat_offset / self.bytes_per_sector
        val entry_offset = (fat_offset % self.bytes_per_sector).to_i32()

        # Update each FAT copy
        var fat_idx: u32 = 0
        while fat_idx < self.num_fats:
            val fat_sector = self.reserved_sectors.to_u64() + (fat_idx * self.fat_size).to_u64() + sector_in_fat.to_u64()

            # Read current sector
            var buffer: [u8] = []
            var i: u32 = 0
            while i < self.bytes_per_sector:
                buffer.push(0)
                i = i + 1

            val read_result = self.device.read_sector(fat_sector, buffer)
            if read_result.is_err():
                return Result.Err("failed to read FAT sector for write")

            # Preserve upper 4 bits of existing entry, write lower 28 bits
            val existing = ((buffer[entry_offset + 3].to_u32() << 24) |
                           (buffer[entry_offset + 2].to_u32() << 16) |
                           (buffer[entry_offset + 1].to_u32() << 8) |
                           buffer[entry_offset].to_u32())
            val new_val = (existing & 0xF0000000) | (value & FAT32_MASK)

            buffer[entry_offset] = (new_val & 0xFF).to_u8()
            buffer[entry_offset + 1] = ((new_val >> 8) & 0xFF).to_u8()
            buffer[entry_offset + 2] = ((new_val >> 16) & 0xFF).to_u8()
            buffer[entry_offset + 3] = ((new_val >> 24) & 0xFF).to_u8()

            # Write sector back
            val write_result = self.device.write_sector(fat_sector, buffer)
            if write_result.is_err():
                return Result.Err("failed to write FAT sector")

            fat_idx = fat_idx + 1

        Result.Ok(true)

    # ========================================================================
    # Cluster Allocation
    # ========================================================================

    me allocate_cluster() -> Result<u32, text>:
        """Find and allocate a free cluster. Marks it as EOC in FAT.

        Scans the FAT starting from next_free_hint. Wraps around to
        cluster 2 if the end is reached without finding a free entry.
        """
        var cluster = self.next_free_hint
        val limit = self.total_clusters + 2
        var checked: u32 = 0

        while checked < self.total_clusters:
            if cluster >= limit:
                cluster = 2  # Wrap around
            val entry_result = me read_fat_entry(cluster)
            if entry_result.is_err():
                return Result.Err(entry_result.unwrap_err())
            val entry = entry_result.unwrap()
            if entry == FAT32_FREE:
                # Found free cluster -- mark as EOC
                val write_result = me write_fat_entry(cluster, FAT32_EOC)
                if write_result.is_err():
                    return Result.Err(write_result.unwrap_err())
                self.next_free_hint = cluster + 1
                return Result.Ok(cluster)
            cluster = cluster + 1
            checked = checked + 1

        Result.Err("FAT32: no free clusters available")

    me extend_chain(last_cluster: u32) -> Result<u32, text>:
        """Allocate a new cluster and append it to an existing chain.

        Sets last_cluster's FAT entry to point to the new cluster,
        and sets the new cluster's entry to EOC.
        """
        val new_result = me allocate_cluster()
        if new_result.is_err():
            return new_result
        val new_cluster = new_result.unwrap()

        # Point last cluster to new cluster
        val link_result = me write_fat_entry(last_cluster, new_cluster)
        if link_result.is_err():
            # Attempt to free the allocated cluster
            self.write_fat_entry(new_cluster, FAT32_FREE)
            return Result.Err(link_result.unwrap_err())

        Result.Ok(new_cluster)

    me free_chain(start_cluster: u32) -> Result<bool, text>:
        """Free an entire cluster chain starting at start_cluster.

        Walks the chain and marks each cluster as FAT32_FREE.
        """
        var current = start_cluster
        var max_iter: u32 = 1000000  # Safety limit
        while current >= 2 and current < (self.total_clusters + 2) and max_iter > 0:
            val next_result = self.read_fat_entry(current)
            if next_result.is_err():
                return Result.Err(next_result.unwrap_err())
            val next = next_result.unwrap()

            val free_result = self.write_fat_entry(current, FAT32_FREE)
            if free_result.is_err():
                return Result.Err(free_result.unwrap_err())

            if next >= FAT32_EOC or next < 2:
                break  # End of chain
            current = next
            max_iter = max_iter - 1

        Result.Ok(true)

    me truncate_chain(first_cluster: u32, keep_bytes: u64) -> Result<u32, text>:
        """Shrink a cluster chain to keep_bytes and return the new first cluster.

        A return value of 0 means the file has no allocated clusters.
        """
        if first_cluster < 2:
            if keep_bytes == 0:
                return Result.Ok(0)
            val allocated = self.allocate_cluster()
            if allocated.is_err():
                return Result.Err(allocated.unwrap_err())
            return allocated

        val cluster_size = (self.sectors_per_cluster * self.bytes_per_sector).to_u64()
        if keep_bytes == 0:
            val freed = self.free_chain(first_cluster)
            if freed.is_err():
                return Result.Err(freed.unwrap_err())
            return Result.Ok(0)

        var clusters_to_keep = keep_bytes / cluster_size
        if keep_bytes % cluster_size != 0:
            clusters_to_keep = clusters_to_keep + 1

        var current = first_cluster
        var kept: u64 = 1
        while kept < clusters_to_keep:
            val next_result = self.read_fat_entry(current)
            if next_result.is_err():
                return Result.Err(next_result.unwrap_err())
            val next = next_result.unwrap()
            if next >= FAT32_EOC or next < 2:
                val ext = self.extend_chain(current)
                if ext.is_err():
                    return Result.Err(ext.unwrap_err())
                current = ext.unwrap()
            else:
                current = next
            kept = kept + 1

        val tail_result = self.read_fat_entry(current)
        if tail_result.is_err():
            return Result.Err(tail_result.unwrap_err())
        val tail = tail_result.unwrap()
        if tail >= 2 and tail < FAT32_EOC:
            val freed_tail = self.free_chain(tail)
            if freed_tail.is_err():
                return Result.Err(freed_tail.unwrap_err())

        val mark_eoc = self.write_fat_entry(current, FAT32_EOC)
        if mark_eoc.is_err():
            return Result.Err(mark_eoc.unwrap_err())

        if keep_bytes % cluster_size != 0:
            val data_result = self.read_cluster(current)
            if data_result.is_err():
                return Result.Err(data_result.unwrap_err())
            var data = data_result.unwrap()
            var zero_at = (keep_bytes % cluster_size).to_i32()
            while zero_at < data.len():
                data[zero_at] = 0
                zero_at = zero_at + 1
            val write_result = self.write_cluster_data(current, data)
            if write_result.is_err():
                return Result.Err(write_result.unwrap_err())
        Result.Ok(first_cluster)

    # ========================================================================
    # Cluster Data I/O
    # ========================================================================

    fn cluster_to_sector(cluster: u32) -> u64:
        """Convert cluster number to first LBA sector."""
        val offset = (cluster - 2).to_u64() * self.sectors_per_cluster.to_u64()
        self.data_start_sector.to_u64() + offset

    me read_cluster(cluster: u32) -> Result<[u8], text>:
        """Read all sectors of a cluster into a buffer."""
        val sector = self.cluster_to_sector(cluster)
        val cluster_bytes = self.sectors_per_cluster * self.bytes_per_sector
        var buffer: [u8] = []
        var k: u32 = 0
        while k < cluster_bytes:
            buffer.push(0)
            k = k + 1

        var sec: u32 = 0
        while sec < self.sectors_per_cluster:
            var sec_buf: [u8] = []
            var j: u32 = 0
            while j < self.bytes_per_sector:
                sec_buf.push(0)
                j = j + 1
            val result = self.device.read_sector(sector + sec.to_u64(), sec_buf)
            if result.is_err():
                return Result.Err("failed to read cluster {cluster} sector {sec}")
            j = 0
            while j < self.bytes_per_sector:
                buffer[(sec * self.bytes_per_sector + j).to_i32()] = sec_buf[j.to_i32()]
                j = j + 1
            sec = sec + 1
        Result.Ok(buffer)

    me write_cluster_data(cluster: u32, data: [u8]) -> Result<bool, text>:
        """Write data to a cluster's sectors.

        Writes up to cluster_size bytes. If data is shorter, the
        remaining bytes in the cluster are zero-filled.
        """
        val sector = self.cluster_to_sector(cluster)
        val cluster_bytes = self.sectors_per_cluster * self.bytes_per_sector

        var sec: u32 = 0
        while sec < self.sectors_per_cluster:
            var sec_buf: [u8] = []
            var j: u32 = 0
            while j < self.bytes_per_sector:
                val byte_idx = sec * self.bytes_per_sector + j
                if byte_idx.to_i32() < data.len():
                    sec_buf.push(data[byte_idx.to_i32()])
                else:
                    sec_buf.push(0)
                j = j + 1
            val result = self.device.write_sector(sector + sec.to_u64(), sec_buf)
            if result.is_err():
                return Result.Err("failed to write cluster {cluster} sector {sec}")
            sec = sec + 1
        Result.Ok(true)

    # ========================================================================
    # Directory Entry Operations
    # ========================================================================

    me find_free_dir_slot(dir_cluster: u32) -> Result<DirSlot, text>:
        """Find a free directory entry slot in a directory's cluster chain.

        Returns the cluster and byte offset of the first free (0x00 or 0xE5)
        32-byte directory entry slot. If no free slot exists in the current
        chain, extends the chain with a new cluster.
        """
        var current = dir_cluster
        var max_iter: u32 = 100000
        while current >= 2 and max_iter > 0:
            val data_result = me read_cluster(current)
            if data_result.is_err():
                return Result.Err(data_result.unwrap_err())
            val data = data_result.unwrap()

            val entries_per_cluster = (self.sectors_per_cluster * self.bytes_per_sector) / DIR_ENTRY_SIZE
            var idx: u32 = 0
            while idx < entries_per_cluster:
                val off = (idx * DIR_ENTRY_SIZE).to_i32()
                val first_byte = data[off]
                if first_byte == END_MARKER or first_byte == DELETED_MARKER:
                    return Result.Ok(DirSlot(cluster: current, offset: idx * DIR_ENTRY_SIZE))
                idx = idx + 1

            # Move to next cluster in chain
            val next_result = me read_fat_entry(current)
            if next_result.is_err():
                return Result.Err(next_result.unwrap_err())
            val next = next_result.unwrap()
            if next >= FAT32_EOC or next < 2:
                # No more clusters -- extend the directory
                val ext_result = me extend_chain(current)
                if ext_result.is_err():
                    return Result.Err(ext_result.unwrap_err())
                val new_cluster = ext_result.unwrap()
                # Zero the new cluster
                var zeros: [u8] = []
                var z: u32 = 0
                val cluster_bytes = self.sectors_per_cluster * self.bytes_per_sector
                while z < cluster_bytes:
                    zeros.push(0)
                    z = z + 1
                val wc_result = me write_cluster_data(new_cluster, zeros)
                if wc_result.is_err():
                    return Result.Err(wc_result.unwrap_err())
                return Result.Ok(DirSlot(cluster: new_cluster, offset: 0))
            current = next
            max_iter = max_iter - 1

        Result.Err("directory too deep or corrupted")

    me write_dir_entry(slot: DirSlot, entry: Fat32DirEntry) -> Result<bool, text>:
        """Write a 32-byte directory entry at the given slot."""
        val data_result = me read_cluster(slot.cluster)
        if data_result.is_err():
            return Result.Err(data_result.unwrap_err())
        var data = data_result.unwrap()

        val off = slot.offset.to_i32()
        # Name (11 bytes)
        var i = 0
        while i < 11:
            data[off + i] = entry.name[i]
            i = i + 1
        # Attributes
        data[off + 11] = entry.attr
        data[off + 12] = entry.nt_reserved
        data[off + 13] = entry.create_time_tenth
        # Create time/date
        data[off + 14] = (entry.create_time & 0xFF).to_u8()
        data[off + 15] = ((entry.create_time >> 8) & 0xFF).to_u8()
        data[off + 16] = (entry.create_date & 0xFF).to_u8()
        data[off + 17] = ((entry.create_date >> 8) & 0xFF).to_u8()
        # Access date
        data[off + 18] = (entry.access_date & 0xFF).to_u8()
        data[off + 19] = ((entry.access_date >> 8) & 0xFF).to_u8()
        # Cluster high
        data[off + 20] = (entry.cluster_high & 0xFF).to_u8()
        data[off + 21] = ((entry.cluster_high >> 8) & 0xFF).to_u8()
        # Modify time/date
        data[off + 22] = (entry.modify_time & 0xFF).to_u8()
        data[off + 23] = ((entry.modify_time >> 8) & 0xFF).to_u8()
        data[off + 24] = (entry.modify_date & 0xFF).to_u8()
        data[off + 25] = ((entry.modify_date >> 8) & 0xFF).to_u8()
        # Cluster low
        data[off + 26] = (entry.cluster_low & 0xFF).to_u8()
        data[off + 27] = ((entry.cluster_low >> 8) & 0xFF).to_u8()
        # File size
        data[off + 28] = (entry.file_size & 0xFF).to_u8()
        data[off + 29] = ((entry.file_size >> 8) & 0xFF).to_u8()
        data[off + 30] = ((entry.file_size >> 16) & 0xFF).to_u8()
        data[off + 31] = ((entry.file_size >> 24) & 0xFF).to_u8()

        self.write_cluster_data(slot.cluster, data)

    me create_file(dir_cluster: u32, name: text, is_dir: bool) -> Result<u32, text>:
        """Create a new directory entry and allocate first cluster.

        Returns the first cluster of the new file/directory.
        """
        # Format 8.3 filename
        val name_bytes = format_8_3_name(name)

        # Allocate first cluster for the new file
        val cluster_result = me allocate_cluster()
        if cluster_result.is_err():
            return Result.Err(cluster_result.unwrap_err())
        val first_cluster = cluster_result.unwrap()

        # Zero the allocated cluster
        var zeros: [u8] = []
        var z: u32 = 0
        val cluster_bytes = self.sectors_per_cluster * self.bytes_per_sector
        while z < cluster_bytes:
            zeros.push(0)
            z = z + 1
        val zero_result = me write_cluster_data(first_cluster, zeros)
        if zero_result.is_err():
            self.write_fat_entry(first_cluster, FAT32_FREE)
            return Result.Err(zero_result.unwrap_err())

        # Find free slot in parent directory
        val slot_result = me find_free_dir_slot(dir_cluster)
        if slot_result.is_err():
            self.write_fat_entry(first_cluster, FAT32_FREE)
            return Result.Err(slot_result.unwrap_err())
        val slot = slot_result.unwrap()

        # Build directory entry
        val attr: u8 = if is_dir: FAT32_ATTR_DIRECTORY else: FAT32_ATTR_ARCHIVE
        val entry = Fat32DirEntry(
            name: name_bytes,
            attr: attr,
            nt_reserved: 0,
            create_time_tenth: 0,
            create_time: 0,
            create_date: 0,
            access_date: 0,
            cluster_high: (first_cluster >> 16).to_u16(),
            modify_time: 0,
            modify_date: 0,
            cluster_low: (first_cluster & 0xFFFF).to_u16(),
            file_size: 0
        )

        val write_result = me write_dir_entry(slot, entry)
        if write_result.is_err():
            self.write_fat_entry(first_cluster, FAT32_FREE)
            return Result.Err(write_result.unwrap_err())

        Result.Ok(first_cluster)

    me create_directory(dir_cluster: u32, name: text) -> Result<u32, text>:
        """Create a new directory with . and .. entries.

        Allocates a cluster, writes . (self) and .. (parent) entries,
        then creates the directory entry in the parent.
        """
        val first_cluster_result = me create_file(dir_cluster, name, true)
        if first_cluster_result.is_err():
            return first_cluster_result
        val first_cluster = first_cluster_result.unwrap()

        # Write . entry (points to self)
        val dot_name: [u8] = [0x2E, 0x20, 0x20, 0x20, 0x20, 0x20, 0x20, 0x20, 0x20, 0x20, 0x20]
        val dot_entry = Fat32DirEntry(
            name: dot_name,
            attr: FAT32_ATTR_DIRECTORY,
            nt_reserved: 0, create_time_tenth: 0,
            create_time: 0, create_date: 0, access_date: 0,
            cluster_high: (first_cluster >> 16).to_u16(),
            modify_time: 0, modify_date: 0,
            cluster_low: (first_cluster & 0xFFFF).to_u16(),
            file_size: 0
        )
        val dot_slot = DirSlot(cluster: first_cluster, offset: 0)
        val dot_result = me write_dir_entry(dot_slot, dot_entry)
        if dot_result.is_err():
            return Result.Err(dot_result.unwrap_err())

        # Write .. entry (points to parent)
        val dotdot_name: [u8] = [0x2E, 0x2E, 0x20, 0x20, 0x20, 0x20, 0x20, 0x20, 0x20, 0x20, 0x20]
        val dotdot_entry = Fat32DirEntry(
            name: dotdot_name,
            attr: FAT32_ATTR_DIRECTORY,
            nt_reserved: 0, create_time_tenth: 0,
            create_time: 0, create_date: 0, access_date: 0,
            cluster_high: (dir_cluster >> 16).to_u16(),
            modify_time: 0, modify_date: 0,
            cluster_low: (dir_cluster & 0xFFFF).to_u16(),
            file_size: 0
        )
        val dotdot_slot = DirSlot(cluster: first_cluster, offset: DIR_ENTRY_SIZE)
        val dotdot_result = me write_dir_entry(dotdot_slot, dotdot_entry)
        if dotdot_result.is_err():
            return Result.Err(dotdot_result.unwrap_err())

        Result.Ok(first_cluster)

    me update_file_size(dir_cluster: u32, name: text, new_size: u32) -> Result<bool, text>:
        """Update the file size in its directory entry.

        Searches the directory cluster chain for the matching 8.3 name
        and updates the file_size field.
        """
        val upper_name = name.to_upper()
        var current = dir_cluster
        var max_iter: u32 = 100000
        while current >= 2 and max_iter > 0:
            val data_result = me read_cluster(current)
            if data_result.is_err():
                return Result.Err(data_result.unwrap_err())
            var data = data_result.unwrap()

            val entries_per_cluster = (self.sectors_per_cluster * self.bytes_per_sector) / DIR_ENTRY_SIZE
            var idx: u32 = 0
            while idx < entries_per_cluster:
                val off = (idx * DIR_ENTRY_SIZE).to_i32()
                val first_byte = data[off]
                if first_byte == END_MARKER:
                    return Result.Err("file not found: {name}")
                if first_byte == DELETED_MARKER or data[off + 11] == FAT32_ATTR_LFN:
                    idx = idx + 1
                    continue

                val entry_name = _parse_8_3_name(data, off)
                if entry_name.to_upper() == upper_name:
                    # Update file size (bytes 28-31)
                    data[off + 28] = (new_size & 0xFF).to_u8()
                    data[off + 29] = ((new_size >> 8) & 0xFF).to_u8()
                    data[off + 30] = ((new_size >> 16) & 0xFF).to_u8()
                    data[off + 31] = ((new_size >> 24) & 0xFF).to_u8()
                    return me write_cluster_data(current, data)
                idx = idx + 1

            val next_result = me read_fat_entry(current)
            if next_result.is_err():
                return Result.Err(next_result.unwrap_err())
            val next = next_result.unwrap()
            if next >= FAT32_EOC or next < 2:
                break
            current = next
            max_iter = max_iter - 1

        Result.Err("file not found: {name}")

    me update_file_metadata(dir_cluster: u32, name: text, first_cluster: u32, new_size: u32) -> Result<bool, text>:
        """Update first-cluster and size fields in a directory entry."""
        val upper_name = name.to_upper()
        var current = dir_cluster
        var max_iter: u32 = 100000
        while current >= 2 and max_iter > 0:
            val data_result = me read_cluster(current)
            if data_result.is_err():
                return Result.Err(data_result.unwrap_err())
            var data = data_result.unwrap()

            val entries_per_cluster = (self.sectors_per_cluster * self.bytes_per_sector) / DIR_ENTRY_SIZE
            var idx: u32 = 0
            while idx < entries_per_cluster:
                val off = (idx * DIR_ENTRY_SIZE).to_i32()
                val first_byte = data[off]
                if first_byte == END_MARKER:
                    return Result.Err("file not found: {name}")
                if first_byte == DELETED_MARKER or data[off + 11] == FAT32_ATTR_LFN:
                    idx = idx + 1
                    continue

                val entry_name = _parse_8_3_name(data, off)
                if entry_name.to_upper() == upper_name:
                    data[off + 20] = ((first_cluster >> 16) & 0xFF).to_u8()
                    data[off + 21] = ((first_cluster >> 24) & 0xFF).to_u8()
                    data[off + 26] = (first_cluster & 0xFF).to_u8()
                    data[off + 27] = ((first_cluster >> 8) & 0xFF).to_u8()
                    data[off + 28] = (new_size & 0xFF).to_u8()
                    data[off + 29] = ((new_size >> 8) & 0xFF).to_u8()
                    data[off + 30] = ((new_size >> 16) & 0xFF).to_u8()
                    data[off + 31] = ((new_size >> 24) & 0xFF).to_u8()
                    return me write_cluster_data(current, data)
                idx = idx + 1

            val next_result = me read_fat_entry(current)
            if next_result.is_err():
                return Result.Err(next_result.unwrap_err())
            val next = next_result.unwrap()
            if next >= FAT32_EOC or next < 2:
                break
            current = next
            max_iter = max_iter - 1

        Result.Err("file not found: {name}")

    me delete_file(dir_cluster: u32, name: text) -> Result<bool, text>:
        """Delete a file: free cluster chain and mark directory entry as deleted.

        Finds the directory entry, reads its first cluster, frees the entire
        cluster chain, then marks byte 0 of the entry as 0xE5 (deleted).
        """
        val upper_name = name.to_upper()
        var current = dir_cluster
        var max_iter: u32 = 100000
        while current >= 2 and max_iter > 0:
            val data_result = me read_cluster(current)
            if data_result.is_err():
                return Result.Err(data_result.unwrap_err())
            var data = data_result.unwrap()

            val entries_per_cluster = (self.sectors_per_cluster * self.bytes_per_sector) / DIR_ENTRY_SIZE
            var idx: u32 = 0
            while idx < entries_per_cluster:
                val off = (idx * DIR_ENTRY_SIZE).to_i32()
                val first_byte = data[off]
                if first_byte == END_MARKER:
                    return Result.Err("file not found: {name}")
                if first_byte == DELETED_MARKER or data[off + 11] == FAT32_ATTR_LFN:
                    idx = idx + 1
                    continue

                val entry_name = _parse_8_3_name(data, off)
                if entry_name.to_upper() == upper_name:
                    # Get first cluster
                    val cluster_high = (data[off + 21].to_u32() << 8) | data[off + 20].to_u32()
                    val cluster_low = (data[off + 27].to_u32() << 8) | data[off + 26].to_u32()
                    val first_cluster = (cluster_high << 16) | cluster_low

                    # Free the cluster chain
                    if first_cluster >= 2:
                        val free_result = me free_chain(first_cluster)
                        if free_result.is_err():
                            return Result.Err(free_result.unwrap_err())

                    # Mark directory entry as deleted
                    data[off] = DELETED_MARKER
                    return me write_cluster_data(current, data)
                idx = idx + 1

            val next_result = me read_fat_entry(current)
            if next_result.is_err():
                return Result.Err(next_result.unwrap_err())
            val next = next_result.unwrap()
            if next >= FAT32_EOC or next < 2:
                break
            current = next
            max_iter = max_iter - 1

        Result.Err("file not found: {name}")

    me write_file_data(first_cluster: u32, offset: u64, data: [u8]) -> Result<u64, text>:
        """Write data to a file starting at the given byte offset.

        Walks the cluster chain to find the starting cluster for the offset,
        then writes data across clusters, extending the chain as needed.
        Returns the number of bytes written.
        """
        val cluster_size = (self.sectors_per_cluster * self.bytes_per_sector).to_u64()
        var clusters_to_skip = offset / cluster_size
        var offset_in_cluster = offset % cluster_size
        var bytes_written: u64 = 0
        var data_pos: u64 = 0
        val data_len = data.len().to_u64()

        # Walk to the starting cluster
        var current = first_cluster
        while clusters_to_skip > 0:
            val next_result = me read_fat_entry(current)
            if next_result.is_err():
                return Result.Err(next_result.unwrap_err())
            val next = next_result.unwrap()
            if next >= FAT32_EOC or next < 2:
                # Need to extend chain
                val ext_result = me extend_chain(current)
                if ext_result.is_err():
                    return Result.Err(ext_result.unwrap_err())
                current = ext_result.unwrap()
            else:
                current = next
            clusters_to_skip = clusters_to_skip - 1

        # Write data across clusters
        while data_pos < data_len:
            # Read current cluster data
            val cluster_data_result = me read_cluster(current)
            if cluster_data_result.is_err():
                return Result.Err(cluster_data_result.unwrap_err())
            var cluster_data = cluster_data_result.unwrap()

            # Write bytes into cluster starting at offset_in_cluster
            var pos_in_cluster = offset_in_cluster
            while pos_in_cluster < cluster_size and data_pos < data_len:
                cluster_data[pos_in_cluster.to_i32()] = data[data_pos.to_i32()]
                pos_in_cluster = pos_in_cluster + 1
                data_pos = data_pos + 1
                bytes_written = bytes_written + 1

            # Write modified cluster back
            val write_result = me write_cluster_data(current, cluster_data)
            if write_result.is_err():
                return Result.Err(write_result.unwrap_err())

            # Move to next cluster if more data remains
            if data_pos < data_len:
                val next_result = me read_fat_entry(current)
                if next_result.is_err():
                    return Result.Err(next_result.unwrap_err())
                val next = next_result.unwrap()
                if next >= FAT32_EOC or next < 2:
                    # Extend chain
                    val ext_result = me extend_chain(current)
                    if ext_result.is_err():
                        return Result.Err(ext_result.unwrap_err())
                    current = ext_result.unwrap()
                else:
                    current = next

            offset_in_cluster = 0  # Subsequent clusters start at offset 0

        Result.Ok(bytes_written)

# ============================================================================
# Directory Slot
# ============================================================================

struct DirSlot:
    """Location of a directory entry within a cluster."""
    cluster: u32
    offset: u32     # Byte offset within the cluster

# ============================================================================
# Helper Functions
# ============================================================================

fn format_8_3_name(name: text) -> [u8]:
    """Convert a filename to FAT32 8.3 format (11 bytes, space-padded, uppercase).

    Rules:
    - Name part: up to 8 characters, space-padded
    - Extension: up to 3 characters, space-padded
    - All uppercase
    - Split on last '.' for extension
    """
    var name_part = ""
    var ext_part = ""
    val upper = name.to_upper()

    # Find last dot for extension
    var last_dot: i32 = -1
    var ci = 0
    for ch in upper:
        if ch.to_u8() == 0x2E:  # '.'
            last_dot = ci
        ci = ci + 1

    if last_dot >= 0:
        # Split at last dot
        var j = 0
        for ch in upper:
            if j < last_dot:
                name_part = name_part + ch
            else:
                if j > last_dot:
                    ext_part = ext_part + ch
            j = j + 1
    else:
        name_part = upper

    # Build 11-byte result: 8 name + 3 ext, space-padded
    var result: [u8] = []
    var i = 0
    while i < 8:
        if i < name_part.len():
            # Get i-th character
            var ci2 = 0
            for ch in name_part:
                if ci2 == i:
                    result.push(ch.to_u8())
                ci2 = ci2 + 1
        else:
            result.push(0x20)  # Space
        i = i + 1

    i = 0
    while i < 3:
        if i < ext_part.len():
            var ci3 = 0
            for ch in ext_part:
                if ci3 == i:
                    result.push(ch.to_u8())
                ci3 = ci3 + 1
        else:
            result.push(0x20)  # Space
        i = i + 1

    result

fn _parse_8_3_name(data: [u8], offset: i32) -> text:
    """Parse 8.3 filename from directory entry bytes (same as Fat32Driver.parse_8_3_name)."""
    var name = ""
    var i = 0
    while i < 8:
        val ch = data[offset + i]
        if ch != 0x20 and ch != 0x00:
            name = name + ch.to_char()
        i = i + 1
    var ext = ""
    i = 0
    while i < 3:
        val ch = data[offset + 8 + i]
        if ch != 0x20 and ch != 0x00:
            ext = ext + ch.to_char()
        i = i + 1
    if ext.len() > 0:
        name + "." + ext
    else:
        name
