# SimpleOS Services
#
# Userspace services communicating via kernel IPC:
#   - Init / service manager
#   - VFS (Virtual Filesystem)
#   - FAT32 filesystem driver
#   - Network stack (TCP/IP on IPC port 2)
#   - Logging / journal
#   - PCI manager (device enumeration and driver grant)
#   - Device registry (maps device classes to active driver endpoints)
#   - Display service (GPU/framebuffer owner, surface-based API)
#   - Window manager (IPC-based window creation, focus, resize, input delivery)
#   - Launcher (app registry, shortcut dispatch, app spawning)
#   - LLM MCP server (OS control via MCP tools + widget DSL)

use os.services.display.display_service.{DisplayService}
use os.services.wm.wm_service.{WmService}
use os.services.launcher.launcher.{launcher_start, launcher_launch, launcher_shortcut_dispatch, launcher_get_app_count, launcher_get_app_name, launcher_get_app_icon}
use os.services.init.init_service.{InitService, default_services}
use os.services.pm_service.{PmService}
use os.services.vfs
use os.services.netstack
