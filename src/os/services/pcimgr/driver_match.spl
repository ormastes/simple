# PCI Driver Matching — Maps PCI Class/Vendor to Driver Names
#
# MDSOC: feature dimension, device layer
# Known device class -> driver bindings used by the PCI manager
# to suggest or auto-start driver capsules for discovered devices.
#
# Matching priority:
#   1. Vendor + device ID (exact match, highest priority)
#   2. Class + subclass (generic fallback)

# ============================================================================
# VirtIO Constants
# ============================================================================

val VIRTIO_VENDOR: u16 = 0x1AF4

val VIRTIO_DEV_NET: u16 = 0x1000
val VIRTIO_DEV_BLK: u16 = 0x1001
val VIRTIO_DEV_CONSOLE: u16 = 0x1003
val VIRTIO_DEV_GPU: u16 = 0x1050
val VIRTIO_DEV_INPUT: u16 = 0x1052

# ============================================================================
# PCI Class Constants
# ============================================================================

val PCI_CLASS_STORAGE: u8 = 0x01
val PCI_SUBCLASS_SCSI: u8 = 0x00
val PCI_SUBCLASS_IDE: u8 = 0x01
val PCI_SUBCLASS_SATA: u8 = 0x06
val PCI_SUBCLASS_NVME: u8 = 0x08

val PCI_CLASS_NETWORK: u8 = 0x02
val PCI_CLASS_DISPLAY: u8 = 0x03
val PCI_CLASS_MULTIMEDIA: u8 = 0x04
val PCI_CLASS_BRIDGE: u8 = 0x06
val PCI_CLASS_SERIAL_BUS: u8 = 0x0C
val PCI_SUBCLASS_USB: u8 = 0x03

# ============================================================================
# Driver Name Matching
# ============================================================================

fn match_driver_name(vendor: u16, device_id: u16, class_code: u8, subclass: u8) -> text:
    """Return the driver capsule name for a PCI device, or "" if no match.

    Checked in order: vendor+device first, then class+subclass.
    """
    # VirtIO devices — match by vendor + device ID
    if vendor == VIRTIO_VENDOR:
        if device_id == VIRTIO_DEV_NET:
            return "virtio-net"
        if device_id == VIRTIO_DEV_BLK:
            return "virtio-blk"
        if device_id == VIRTIO_DEV_GPU:
            return "virtio-gpu"
        if device_id == VIRTIO_DEV_CONSOLE:
            return "virtio-console"
        if device_id == VIRTIO_DEV_INPUT:
            return "virtio-input"
        # Unknown VirtIO device — return generic
        return "virtio-unknown"

    # NVMe: class 0x01 subclass 0x08
    if class_code == PCI_CLASS_STORAGE and subclass == PCI_SUBCLASS_NVME:
        return "nvme"

    # SATA: class 0x01 subclass 0x06
    if class_code == PCI_CLASS_STORAGE and subclass == PCI_SUBCLASS_SATA:
        return "ahci"

    # USB: class 0x0C subclass 0x03
    if class_code == PCI_CLASS_SERIAL_BUS and subclass == PCI_SUBCLASS_USB:
        return "usb-hci"

    # Network controller (non-VirtIO)
    if class_code == PCI_CLASS_NETWORK:
        return "generic-net"

    # Display controller (non-VirtIO)
    if class_code == PCI_CLASS_DISPLAY:
        return "generic-display"

    ""  # No matching driver

# ============================================================================
# Helper Predicates
# ============================================================================

fn is_virtio_device(vendor: u16) -> bool:
    """Check if a device is a VirtIO device by vendor ID."""
    vendor == VIRTIO_VENDOR

fn is_storage_device(class_code: u8) -> bool:
    """Check if a device is a mass storage controller."""
    class_code == PCI_CLASS_STORAGE

fn is_network_device(class_code: u8) -> bool:
    """Check if a device is a network controller."""
    class_code == PCI_CLASS_NETWORK

fn is_display_device(class_code: u8) -> bool:
    """Check if a device is a display controller."""
    class_code == PCI_CLASS_DISPLAY

# ============================================================================
# Device Class Descriptions
# ============================================================================

fn device_class_description(class_code: u8, subclass: u8) -> text:
    """Human-readable PCI device class description."""
    if class_code == 0x00:
        return "Unclassified"
    if class_code == 0x01:
        if subclass == 0x00: return "SCSI"
        if subclass == 0x01: return "IDE"
        if subclass == 0x05: return "ATA"
        if subclass == 0x06: return "SATA"
        if subclass == 0x08: return "NVMe"
        return "Storage"
    if class_code == 0x02:
        if subclass == 0x00: return "Ethernet"
        if subclass == 0x80: return "Other Network"
        return "Network"
    if class_code == 0x03:
        if subclass == 0x00: return "VGA"
        if subclass == 0x01: return "XGA"
        if subclass == 0x02: return "3D Controller"
        return "Display"
    if class_code == 0x04:
        return "Multimedia"
    if class_code == 0x05:
        return "Memory Controller"
    if class_code == 0x06:
        if subclass == 0x00: return "Host Bridge"
        if subclass == 0x01: return "ISA Bridge"
        if subclass == 0x04: return "PCI-to-PCI Bridge"
        if subclass == 0x80: return "Other Bridge"
        return "Bridge"
    if class_code == 0x07:
        return "Communication Controller"
    if class_code == 0x08:
        return "System Peripheral"
    if class_code == 0x09:
        return "Input Device"
    if class_code == 0x0A:
        return "Docking Station"
    if class_code == 0x0B:
        return "Processor"
    if class_code == 0x0C:
        if subclass == 0x00: return "FireWire"
        if subclass == 0x03: return "USB"
        if subclass == 0x05: return "SMBus"
        return "Serial Bus"
    if class_code == 0x0D:
        return "Wireless Controller"
    "Unknown (0x{class_code})"
