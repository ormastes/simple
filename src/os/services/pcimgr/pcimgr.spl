# PCI Manager Service — User-Space PCI Bus Manager
#
# MDSOC: feature dimension, device layer
# Enumerates PCI devices at boot and grants device resources
# to driver capsules on request. Runs as a user-space service
# with IPC port "pcimgr".
#
# Syscalls used:
#   80 (DevEnumerate) — discover PCI devices
#   82 (DeviceGrant)  — grant device resources to a driver capsule
#   22 (IpcCreatePort) — create service IPC port
#   21 (IpcRecv)       — receive IPC messages

use os.services.pcimgr.driver_match.{device_class_description, match_driver_name}
use os.kernel.types.device_mem_types.{DeviceGrant, PciBar}
use os.kernel.boot.mmio.{mmio_read32, mmio_read64}
use os.drivers.pci.pci.{pci_read_config, pci_write_config, pci_read_bar}

# ============================================================================
# IPC Method IDs
# ============================================================================

val PCIMGR_ENUMERATE: u32 = 1
val PCIMGR_REQUEST_DEVICE: u32 = 2
val PCIMGR_RELEASE_DEVICE: u32 = 3
val PCIMGR_GET_DEVICE_INFO: u32 = 4

# ============================================================================
# Device Tracking
# ============================================================================

val MAX_TRACKED_DEVICES: u64 = 64

# Device state constants
val DEV_STATE_FREE: u8 = 0
val DEV_STATE_AVAILABLE: u8 = 1
val DEV_STATE_GRANTED: u8 = 2

# Device identity is scanned on demand from config space; only grant ownership
# state is mirrored here.
var dev_count: u64 = 0
var dev_state: [i64; 64] = [0; 64]
var dev_grant_owner: [i64; 64] = [0; 64]  # Task ID that holds the grant

use os.kernel.log.klog_api.{log_raw_println}
extern fn syscall(id: u64, arg0: u64, arg1: u64, arg2: u64, arg3: u64, arg4: u64) -> i64
extern fn serial_println(msg: text)

# ============================================================================
# Initialization — PCI Device Enumeration
# ============================================================================

fn pcimgr_init():
    """Initialize PCI manager through Simple-owned config-space reads."""
    log_raw_println("[pcimgr] Starting Simple PCI config-space enumeration...")
    dev_count = pcimgr_scan_count_config_io()
    log_raw_println("[pcimgr] Populated {dev_count} devices")

fn pcimgr_vendor_present(vendor: u32) -> bool:
    vendor != 0xFFFFu32 and vendor != 0u32

fn pcimgr_function_present(bus: u8, device: u8, func: u8) -> bool:
    val id = pci_read_config(bus, device, func, 0x00)
    pcimgr_vendor_present(id & 0xFFFFu32)

fn pcimgr_pack_target(bus: u8, device: u8, func: u8) -> u64:
    bus.to_u64() | (device.to_u64() << 8) | (func.to_u64() << 16)

fn pcimgr_target_bus(target: u64) -> u8:
    (target & 0xFFu64).to_u8()

fn pcimgr_target_device(target: u64) -> u8:
    ((target >> 8) & 0xFFu64).to_u8()

fn pcimgr_target_func(target: u64) -> u8:
    ((target >> 16) & 0xFFu64).to_u8()

fn pcimgr_scan_count_config_io() -> u64:
    var count: u64 = 0
    var bus: u16 = 0
    while bus < 256u16 and count < MAX_TRACKED_DEVICES:
        var device: u8 = 0
        while device < 32u8 and count < MAX_TRACKED_DEVICES:
            if pcimgr_function_present(bus.to_u8(), device, 0):
                count = count + 1u64
                val header = ((pci_read_config(bus.to_u8(), device, 0, 0x0C) >> 16) & 0xFFu32).to_u8()
                if (header & 0x80) != 0:
                    var func: u8 = 1
                    while func < 8u8 and count < MAX_TRACKED_DEVICES:
                        if pcimgr_function_present(bus.to_u8(), device, func):
                            count = count + 1u64
                        func = func + 1
            device = device + 1
        bus = bus + 1
    count

fn pcimgr_nth_target(dev_idx: u64) -> u64?:
    var ordinal: u64 = 0
    var bus: u16 = 0
    while bus < 256u16 and ordinal < MAX_TRACKED_DEVICES:
        var device: u8 = 0
        while device < 32u8 and ordinal < MAX_TRACKED_DEVICES:
            if pcimgr_function_present(bus.to_u8(), device, 0):
                if ordinal == dev_idx:
                    return pcimgr_pack_target(bus.to_u8(), device, 0)
                ordinal = ordinal + 1u64
                val header = ((pci_read_config(bus.to_u8(), device, 0, 0x0C) >> 16) & 0xFFu32).to_u8()
                if (header & 0x80) != 0:
                    var func: u8 = 1
                    while func < 8u8 and ordinal < MAX_TRACKED_DEVICES:
                        if pcimgr_function_present(bus.to_u8(), device, func):
                            if ordinal == dev_idx:
                                return pcimgr_pack_target(bus.to_u8(), device, func)
                            ordinal = ordinal + 1u64
                        func = func + 1
            device = device + 1
        bus = bus + 1
    nil

# ============================================================================
# Device Lookup
# ============================================================================

fn pcimgr_find_by_class(class_code: u8, subclass: u8) -> i64:
    """Find first device by PCI class/subclass. Returns index or -1.

    Delegates to the i64 variant. Direct `u8 == i64` equality silently
    never matches in the baremetal Cranelift backend (SYS-GUI-007), so
    the real loop lives in pcimgr_find_by_class_i64.
    """
    pcimgr_find_by_class_i64(class_code.to_i64(), subclass.to_i64())

fn pcimgr_find_by_class_i64(class_code: i64, subclass: i64) -> i64:
    """Find first device by PCI class/subclass. Returns index or -1."""
    var i: u64 = 0
    while i < pcimgr_device_count():
        val target = pcimgr_nth_target(i)
        if target.?:
            val bus = pcimgr_target_bus(target)
            val dev = pcimgr_target_device(target)
            val func = pcimgr_target_func(target)
            val class_info = pci_read_config(bus, dev, func, 0x08)
            val cls = ((class_info >> 24) & 0xFFu32).to_i64()
            val sub = ((class_info >> 16) & 0xFFu32).to_i64()
            if cls == class_code and sub == subclass:
                return i as i64
        i = i + 1u64
    -1

fn pcimgr_find_by_vendor(vendor: u16, device_id: u16) -> i64:
    """Find first device by vendor/device ID. Returns index or -1."""
    pcimgr_find_by_vendor_i64(vendor.to_i64(), device_id.to_i64())

fn pcimgr_find_by_vendor_i64(vendor: i64, device_id: i64) -> i64:
    """Find first device by vendor/device ID. Returns index or -1."""
    var i: u64 = 0
    while i < pcimgr_device_count():
        val target = pcimgr_nth_target(i)
        if target.?:
            val id = pci_read_config(pcimgr_target_bus(target), pcimgr_target_device(target), pcimgr_target_func(target), 0x00)
            val ve = (id & 0xFFFFu32).to_i64()
            val di = ((id >> 16) & 0xFFFFu32).to_i64()
            if ve == vendor and di == device_id:
                return i as i64
        i = i + 1u64
    -1

fn pcimgr_device_count() -> u64:
    """Return total number of tracked devices."""
    dev_count

# ============================================================================
# Device Grant / Release
# ============================================================================

fn pcimgr_grant_device(dev_idx: u64, requester_task: u64) -> Result<DeviceGrant, text>:
    """Grant a PCI device from the Simple PCI device table."""
    if dev_idx >= dev_count:
        return Err("invalid device index: {dev_idx}")

    val target = pcimgr_nth_target(dev_idx)
    if not target.?:
        return Err("invalid device index: {dev_idx}")
    val bus_u8 = pcimgr_target_bus(target)
    val dev_u8 = pcimgr_target_device(target)
    val func_u8 = pcimgr_target_func(target)
    val id = pci_read_config(bus_u8, dev_u8, func_u8, 0x00)
    val class_info = pci_read_config(bus_u8, dev_u8, func_u8, 0x08)
    val bus = bus_u8.to_i64()
    val dev = dev_u8.to_i64()
    val func = func_u8.to_i64()
    val cls = ((class_info >> 24) & 0xFFu32).to_i64()
    val sub = ((class_info >> 16) & 0xFFu32).to_i64()
    val vendor = (id & 0xFFFFu32).to_i64()
    val device = ((id >> 16) & 0xFFFFu32).to_i64()
    val bar0 = pcimgr_get_bar(dev_idx, 0)
    val irq = pcimgr_get_irq(dev_idx)
    if bar0.phys_addr == 0 or bar0.size == 0:
        return Err("device {dev_idx} has no BAR0")

    if dev_idx < MAX_TRACKED_DEVICES:
        dev_state[dev_idx] = DEV_STATE_GRANTED
        dev_grant_owner[dev_idx] = requester_task.to_i64()

    log_raw_println("[pcimgr] Granted device [{dev_idx}] to task {requester_task}")
    Ok(DeviceGrant(
        pci_vendor: vendor as u16,
        pci_device: device as u16,
        pci_bus: bus as u8,
        pci_dev: dev as u8,
        pci_func: func as u8,
        pci_class: cls as u8,
        pci_subclass: sub as u8,
        bar0_phys: bar0.phys_addr,
        bar0_size: bar0.size,
        bar0_cap: dev_idx + 1,
        irq_vector: irq as u32,
        irq_notification_id: dev_idx + 1,
        irq_notification_bit: 0,
        irq_cap: dev_idx + 1,
        dma_device_addr: 0,
        dma_host_addr: 0,
        dma_size: 0,
        dma_cap: 0,
        iommu_domain_id: 0,
        iommu_cap: 0
    ))

fn pcimgr_release_device(dev_idx: u64, requester_task: u64) -> Result<bool, text>:
    """Release a previously granted device back to the available pool."""
    if dev_idx >= dev_count:
        return Err("invalid device index: {dev_idx}")
    if dev_state[dev_idx] != DEV_STATE_GRANTED:
        return Err("device {dev_idx} is not currently granted")
    if dev_grant_owner[dev_idx] != requester_task.to_i64():
        return Err("device {dev_idx} is owned by task {dev_grant_owner[dev_idx]}, not {requester_task}")

    dev_state[dev_idx] = DEV_STATE_AVAILABLE
    dev_grant_owner[dev_idx] = 0
    log_raw_println("[pcimgr] Released device [{dev_idx}] from task {requester_task}")
    Ok(true)

# ============================================================================
# Device Info Query
# ============================================================================

fn pcimgr_get_device_class(dev_idx: u64) -> i64:
    """Return class code for a device."""
    if dev_idx >= dev_count:
        return -1
    val target = pcimgr_nth_target(dev_idx)
    if not target.?:
        return -1
    ((pci_read_config(pcimgr_target_bus(target), pcimgr_target_device(target), pcimgr_target_func(target), 0x08) >> 24) & 0xFFu32).to_i64()

fn pcimgr_get_device_subclass(dev_idx: u64) -> i64:
    """Return subclass for a device."""
    if dev_idx >= dev_count:
        return -1
    val target = pcimgr_nth_target(dev_idx)
    if not target.?:
        return -1
    ((pci_read_config(pcimgr_target_bus(target), pcimgr_target_device(target), pcimgr_target_func(target), 0x08) >> 16) & 0xFFu32).to_i64()

fn pcimgr_get_device_vendor(dev_idx: u64) -> i64:
    """Return vendor ID for a device."""
    if dev_idx >= dev_count:
        return -1
    val target = pcimgr_nth_target(dev_idx)
    if not target.?:
        return -1
    (pci_read_config(pcimgr_target_bus(target), pcimgr_target_device(target), pcimgr_target_func(target), 0x00) & 0xFFFFu32).to_i64()

fn pcimgr_get_device_state(dev_idx: u64) -> i64:
    """Return current state of a device slot."""
    if dev_idx >= dev_count:
        return DEV_STATE_FREE
    1  # DEV_STATE_AVAILABLE (all devices available on baremetal)

# ============================================================================
# IPC Service Loop
# ============================================================================

fn pcimgr_start():
    """Start PCI manager service: init devices, create IPC port, enter loop."""
    pcimgr_init()

    # Create IPC port for "pcimgr" service
    val port_result = syscall(22, 0, 0, 0, 0, 0)  # IpcCreatePort
    if port_result < 0:
        log_raw_println("[pcimgr] FATAL: Failed to create IPC port (error {port_result})")
        return

    log_raw_println("[pcimgr] Service ready on IPC port (handle={port_result})")
    val port_handle = port_result.to_u64()

    # Enter service loop
    pcimgr_service_loop(port_handle)

fn pcimgr_service_loop(port_handle: u64):
    """Main service loop — receive IPC messages and dispatch.

    IPC message layout (expected):
      word 0: method ID (PCIMGR_ENUMERATE, etc.)
      word 1: sender task ID
      word 2..N: method-specific arguments
    """
    log_raw_println("[pcimgr] Entering service loop...")

    while true:
        # Block on IPC receive (syscall 21 = IpcRecv)
        val msg_result = syscall(21, port_handle, 0, 0, 0, 0)
        if msg_result < 0:
            log_raw_println("[pcimgr] IPC recv error: {msg_result}")
            continue

        log_raw_println("[pcimgr] Received IPC request (raw={msg_result})")

        # IpcMessage layout (@repr("C")):
        #   offset  0: src_port: u64  (sender task / port)
        #   offset  8: dst_port: u64
        #   offset 16: method: u32
        #   offset 20: flags: u32
        #   offset 24: payload_len: u32
        #   offset 28: cap_count: u32
        #   offset 32: payload words (u64 each)
        val msg_ptr = msg_result as u64
        val sender_task = mmio_read64(msg_ptr)
        val method_id = mmio_read32(msg_ptr + 16) as u32

        match method_id:
            PCIMGR_ENUMERATE:
                val count = pcimgr_device_count()
                log_raw_println("[pcimgr] ENUMERATE: {count} devices")
                syscall(20, sender_task, 0, count, 0, 0)
            PCIMGR_REQUEST_DEVICE:
                val dev_idx = mmio_read64(msg_ptr + 32)
                val grant_result = pcimgr_grant_device(dev_idx, sender_task)
                match grant_result:
                    Ok(g):
                        syscall(20, sender_task, 0, dev_idx, 0, 0)
                    Err(msg):
                        log_raw_println("[pcimgr] REQUEST_DEVICE failed: {msg}")
                        syscall(20, sender_task, 0xFFFF, 0, 0, 0)
            PCIMGR_RELEASE_DEVICE:
                val dev_idx = mmio_read64(msg_ptr + 32)
                val rel_result = pcimgr_release_device(dev_idx, sender_task)
                match rel_result:
                    Ok(ok):
                        syscall(20, sender_task, 0, 0, 0, 0)
                    Err(msg):
                        log_raw_println("[pcimgr] RELEASE_DEVICE failed: {msg}")
                        syscall(20, sender_task, 0xFFFF, 0, 0, 0)
            PCIMGR_GET_DEVICE_INFO:
                val dev_idx = mmio_read64(msg_ptr + 32)
                val cls = pcimgr_get_device_class(dev_idx)
                syscall(20, sender_task, 0, cls as u64, 0, 0)
            _:
                log_raw_println("[pcimgr] Unknown method ID: {method_id}")
                syscall(20, sender_task, 0xFFFF, 0, 0, 0)

# ============================================================================
# PCI Config Space Access
# ============================================================================

fn pcimgr_config_read(dev_idx: u64, offset: u8) -> u32:
    """Read a 32-bit word from PCI configuration space for a tracked device."""
    if dev_idx >= dev_count:
        return 0xFFFFFFFF
    val target = pcimgr_nth_target(dev_idx)
    if not target.?:
        return 0xFFFFFFFF
    pci_read_config(pcimgr_target_bus(target), pcimgr_target_device(target), pcimgr_target_func(target), offset)

fn pcimgr_config_write(dev_idx: u64, offset: u8, value: u32):
    """Write a 32-bit word to PCI configuration space for a tracked device."""
    if dev_idx >= dev_count:
        return
    val target = pcimgr_nth_target(dev_idx)
    if not target.?:
        return
    pci_write_config(pcimgr_target_bus(target), pcimgr_target_device(target), pcimgr_target_func(target), offset, value)

# ============================================================================
# BAR Mapping
# ============================================================================

fn pcimgr_bar_size(dev_idx: u64, bar_num: u8) -> u64:
    """Probe the size of a BAR by writing all-ones and reading back.

    Follows the standard PCI BAR size detection algorithm:
      1. Save original BAR value.
      2. Write 0xFFFFFFFF.
      3. Read back — set address bits are the mask; complement + 1 = size.
      4. Restore original value.
    Returns 0 if the BAR is unimplemented or the device index is invalid.
    """
    if dev_idx >= dev_count:
        return 0
    val target = pcimgr_nth_target(dev_idx)
    if not target.?:
        return 0
    val bus = pcimgr_target_bus(target)
    val dev = pcimgr_target_device(target)
    val func = pcimgr_target_func(target)
    val offset = (0x10 + bar_num.to_u32() * 4).to_u8()
    val original = pci_read_bar(bus, dev, func, bar_num)
    pci_write_config(bus, dev, func, offset, 0xFFFFFFFF)
    val readback = pci_read_bar(bus, dev, func, bar_num)
    pci_write_config(bus, dev, func, offset, original)
    if readback == 0 or readback == 0xFFFFFFFF:
        return 0
    # For memory BARs, mask off the lower 4 attribute bits before inversion
    val mask = readback & 0xFFFFFFF0
    val size = ((mask ^ 0xFFFFFFFF) + 1).to_u64()
    size

fn pcimgr_get_bar(dev_idx: u64, bar_num: u8) -> PciBar:
    """Return a PciBar descriptor for the given device and BAR index (0–5).

    Reads the BAR register directly from config space, probes the size, and
    determines whether the region is MMIO or port I/O.
    Returns a zeroed PciBar if the device index or BAR is invalid.
    """
    if dev_idx >= dev_count:
        return PciBar(index: bar_num, phys_addr: 0, size: 0, is_mmio: false, is_prefetchable: false, cap_token: 0)
    val target = pcimgr_nth_target(dev_idx)
    if not target.?:
        return PciBar(index: bar_num, phys_addr: 0, size: 0, is_mmio: false, is_prefetchable: false, cap_token: 0)
    val bus = pcimgr_target_bus(target)
    val dev = pcimgr_target_device(target)
    val func = pcimgr_target_func(target)
    val raw = pci_read_bar(bus, dev, func, bar_num)
    # Bit 0: 0 = memory space, 1 = I/O space
    val is_mmio = (raw & 1) == 0
    # Bit 3 (memory BARs only): prefetchable
    val is_prefetchable = is_mmio and ((raw & 0x8) != 0)
    val phys_addr = if is_mmio:
        (raw & 0xFFFFFFF0).to_u64()
    else:
        (raw & 0xFFFFFFFC).to_u64()
    val size = pcimgr_bar_size(dev_idx, bar_num)
    PciBar(
        index: bar_num,
        phys_addr: phys_addr,
        size: size,
        is_mmio: is_mmio,
        is_prefetchable: is_prefetchable,
        cap_token: dev_idx + 1
    )

fn pcimgr_get_bar_phys(dev_idx: u64, bar_num: u8) -> u64:
    """Convenience wrapper: return the physical base address of a BAR."""
    val bar = pcimgr_get_bar(dev_idx, bar_num)
    bar.phys_addr

# ============================================================================
# Interrupt Routing
# ============================================================================

fn pcimgr_get_irq(dev_idx: u64) -> u32:
    """Return the IRQ line for a device from PCI config space register 0x3C.

    Reads the interrupt line byte directly from the device.
    Returns 0xFF (no interrupt) when the device index is out of range.
    """
    if dev_idx >= dev_count:
        return 0xFF
    val target = pcimgr_nth_target(dev_idx)
    if not target.?:
        return 0xFF
    val irq_dword = pci_read_config(pcimgr_target_bus(target), pcimgr_target_device(target), pcimgr_target_func(target), 0x3C)
    (irq_dword & 0xFF) as u32

fn pcimgr_irq_vector(dev_idx: u64) -> u32:
    """Return the IRQ vector for a device (IRQ line + base offset 0x20).

    The base offset 0x20 matches the IDT vector assignment used by SimpleOS
    (IRQ 0 → vector 0x20, IRQ 1 → vector 0x21, …). Returns 0 if the IRQ
    line read is 0xFF (device has no interrupt).
    """
    val irq_line = pcimgr_get_irq(dev_idx)
    if irq_line == 0xFF:
        return 0
    irq_line + 0x20

fn pcimgr_route_interrupt(dev_idx: u64, notification_id: u64, notification_bit: u64) -> Result<u32, text>:
    """Register interrupt routing for a PCI device.

    Reads the IRQ line from config space, computes the IDT vector, and
    returns the vector so the caller can arm a notification object.
    The actual kernel-side IRQ route registration is done by the grant
    path (syscall_device.spl). This stub validates the device and returns
    the routing info needed to call irq_route_register from user space.
    Returns Err if the device has no valid interrupt line.
    """
    if dev_idx >= dev_count:
        return Err("invalid device index: {dev_idx}")
    val irq_line = pcimgr_get_irq(dev_idx)
    if irq_line == 0xFF:
        return Err("device {dev_idx} has no interrupt line (IRQ=0xFF)")
    val vector = irq_line + 0x20
    log_raw_println("[pcimgr] Routing IRQ line {irq_line} → vector {vector} for device {dev_idx} (notif_id={notification_id})")
    Ok(vector)

# ============================================================================
# Debug / Utility
# ============================================================================

fn pcimgr_dump_devices():
    """Debug helper: print all tracked devices to serial."""
    serial_println("[pcimgr] === Device Table ({dev_count} devices) ===")
    var i: u64 = 0
    while i < dev_count:
        val target = pcimgr_nth_target(i)
        if not target.?:
            return
        val bus = pcimgr_target_bus(target).to_i64()
        val dev = pcimgr_target_device(target).to_i64()
        val func = pcimgr_target_func(target).to_i64()
        val id = pci_read_config(pcimgr_target_bus(target), pcimgr_target_device(target), pcimgr_target_func(target), 0x00)
        val class_info = pci_read_config(pcimgr_target_bus(target), pcimgr_target_device(target), pcimgr_target_func(target), 0x08)
        val vendor = (id & 0xFFFFu32).to_i64()
        val devid = ((id >> 16) & 0xFFFFu32).to_i64()
        val cls = ((class_info >> 24) & 0xFFu32).to_i64()
        val sub = ((class_info >> 16) & 0xFFu32).to_i64()
        serial_println("[pcimgr]   [{i}] {bus}:{dev}.{func} vendor=0x{vendor} dev=0x{devid} class={cls}.{sub}")
        i = i + 1u64
    serial_println("[pcimgr] === End Device Table ===")
