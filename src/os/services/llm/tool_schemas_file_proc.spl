fn schema_file_search() -> text:
    """Schema for file_search tool."""
    val p_path = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Directory path to search in"))
    )
    val p_pattern = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Filename pattern to match (substring)"))
    )
    val props = "{" + _jp("path", p_path) + "," + _jp("pattern", p_pattern) + "}"
    val required = "[" + _js("path") + "," + _js("pattern") + "]"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "true"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("file_search"))
    result = result + "," + _jp("description", _js("Search files by name pattern in a directory"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_process_list() -> text:
    """Schema for process_list tool."""
    val props = "{}"
    val required = "[]"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "true"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("process_list"))
    result = result + "," + _jp("description", _js("List running processes with PID, name, state, and CPU%"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

