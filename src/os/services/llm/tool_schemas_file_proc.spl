# Tool Schemas — File and Process tools
#
# Schema builder functions for the MCP OS server tool registry.
# File tools: file_read, file_write, file_list, file_search
# Process tools: process_list, process_spawn, process_kill

use os.services.llm.tool_schema_helpers.{llm_tool_property, llm_tool_props0, llm_tool_props1, llm_tool_props2, llm_tool_required0, llm_tool_required1, llm_tool_required2, llm_tool_input_schema, llm_tool_annotations, llm_tool_schema}

fn schema_file_read() -> text:
    """Schema for file_read tool."""
    val props = llm_tool_props1("path", llm_tool_property("string", "Absolute path to the file to read"))
    val schema = llm_tool_input_schema(props, llm_tool_required1("path"))
    val annot = llm_tool_annotations("true", "false", "true")
    return llm_tool_schema("file_read", "Read file contents from the OS filesystem", schema, annot)

fn schema_file_write() -> text:
    """Schema for file_write tool."""
    val props = llm_tool_props2(
        "path", llm_tool_property("string", "Absolute path to the file to write"),
        "content", llm_tool_property("string", "Content to write to the file")
    )
    val schema = llm_tool_input_schema(props, llm_tool_required2("path", "content"))
    val annot = llm_tool_annotations("false", "true", "false")
    return llm_tool_schema("file_write", "Write content to a file on the OS filesystem", schema, annot)

fn schema_file_list() -> text:
    """Schema for file_list tool."""
    val props = llm_tool_props1("path", llm_tool_property("string", "Directory path to list"))
    val schema = llm_tool_input_schema(props, llm_tool_required1("path"))
    val annot = llm_tool_annotations("true", "false", "true")
    return llm_tool_schema("file_list", "List directory contents", schema, annot)

fn schema_file_search() -> text:
    """Schema for file_search tool."""
    val props = llm_tool_props2(
        "path", llm_tool_property("string", "Directory path to search in"),
        "pattern", llm_tool_property("string", "Filename pattern to match (substring)")
    )
    val schema = llm_tool_input_schema(props, llm_tool_required2("path", "pattern"))
    val annot = llm_tool_annotations("true", "false", "true")
    return llm_tool_schema("file_search", "Search files by name pattern in a directory", schema, annot)

fn schema_process_list() -> text:
    """Schema for process_list tool."""
    val schema = llm_tool_input_schema(llm_tool_props0(), llm_tool_required0())
    val annot = llm_tool_annotations("true", "false", "true")
    return llm_tool_schema("process_list", "List running processes with PID, name, state, and CPU%", schema, annot)

fn schema_process_spawn() -> text:
    """Schema for process_spawn tool."""
    val props = llm_tool_props1("binary", llm_tool_property("string", "Path to the binary to execute"))
    val schema = llm_tool_input_schema(props, llm_tool_required1("binary"))
    val annot = llm_tool_annotations("false", "false", "false")
    return llm_tool_schema("process_spawn", "Spawn a new process from a binary path", schema, annot)

fn schema_process_kill() -> text:
    """Schema for process_kill tool."""
    val props = llm_tool_props1("pid", llm_tool_property("number", "PID of the process to kill"))
    val schema = llm_tool_input_schema(props, llm_tool_required1("pid"))
    val annot = llm_tool_annotations("false", "true", "true")
    return llm_tool_schema("process_kill", "Kill a running process by PID", schema, annot)
