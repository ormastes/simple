# Tool Schemas — File and Process tools
#
# Schema builder functions for the MCP OS server tool registry.
# File tools: file_read, file_write, file_list, file_search
# Process tools: process_list, process_spawn, process_kill

fn schema_file_read() -> text:
    """Schema for file_read tool."""
    val p_path = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Absolute path to the file to read"))
    )
    val props = _jo1(_jp("path", p_path))
    val required = "[" + _js("path") + "]"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "true"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("file_read"))
    result = result + "," + _jp("description", _js("Read file contents from the OS filesystem"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_file_write() -> text:
    """Schema for file_write tool."""
    val p_path = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Absolute path to the file to write"))
    )
    val p_content = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Content to write to the file"))
    )
    val props = "{" + _jp("path", p_path) + "," + _jp("content", p_content) + "}"
    val required = "[" + _js("path") + "," + _js("content") + "]"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "false"),
        _jp("destructiveHint", "true"),
        _jp("idempotentHint", "false")
    )
    var result = "{"
    result = result + _jp("name", _js("file_write"))
    result = result + "," + _jp("description", _js("Write content to a file on the OS filesystem"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

