fn schema_system_exec() -> text:
    """Schema for system_exec tool."""
    val p_cmd = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Shell command to execute"))
    )
    val props = _jo1(_jp("command", p_cmd))
    val required = "[" + _js("command") + "]"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "false"),
        _jp("destructiveHint", "true"),
        _jp("idempotentHint", "false")
    )
    var result = "{"
    result = result + _jp("name", _js("system_exec"))
    result = result + "," + _jp("description", _js("Execute a shell command and return output"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result
