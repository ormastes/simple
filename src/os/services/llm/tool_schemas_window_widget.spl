# Tool Schemas — Window and Widget tools
#
# Schema builder functions for the MCP OS server tool registry.
# Window tools: window_create, window_close, window_list, window_focus
# Widget tools: widget_set, widget_read, widget_action

fn schema_window_create() -> text:
    """Schema for window_create tool."""
    val p_title = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Window title"))
    )
    val p_width = _jo2(
        _jp("type", _js("number")),
        _jp("description", _js("Window width in pixels"))
    )
    val p_height = _jo2(
        _jp("type", _js("number")),
        _jp("description", _js("Window height in pixels"))
    )
    val props = "{" + _jp("title", p_title) + "," + _jp("width", p_width) + "," + _jp("height", p_height) + "}"
    val required = "[" + _js("title") + "]"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "false"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "false")
    )
    var result = "{"
    result = result + _jp("name", _js("window_create"))
    result = result + "," + _jp("description", _js("Create a new window with title and dimensions"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_window_close() -> text:
    """Schema for window_close tool."""
    val p_id = _jo2(
        _jp("type", _js("number")),
        _jp("description", _js("Window ID to close"))
    )
    val props = _jo1(_jp("id", p_id))
    val required = "[" + _js("id") + "]"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "false"),
        _jp("destructiveHint", "true"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("window_close"))
    result = result + "," + _jp("description", _js("Close a window by ID"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_window_list() -> text:
    """Schema for window_list tool."""
    val props = "{}"
    val required = "[]"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "true"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("window_list"))
    result = result + "," + _jp("description", _js("List all open windows with ID, title, size, and focus state"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

