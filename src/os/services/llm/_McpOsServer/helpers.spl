# =========================================================================
# Window Tracking
# =========================================================================

fn _extract_arg(args_json: text, key: text) -> text:
    """Simple JSON field extraction for tool arguments.
    Expects flat JSON object like {"key": "value", ...}."""
    val search = "\"" + key + "\""
    val idx = args_json.index_of(search)
    match idx:
        Some(i):
            # Find the colon after the key
            val after_key = args_json[i + search.len():]
            val colon_idx = after_key.index_of(":")
            match colon_idx:
                Some(ci):
                    val after_colon = after_key[ci + 1:].strip()
                    if after_colon.starts_with("\""):
                        # String value: find closing quote
                        val value_start = 1
                        val rest = after_colon[1:]
                        val end_quote = rest.index_of("\"")
                        match end_quote:
                            Some(ei):
                                return rest[0:ei]
                            _:
                                return rest
                    else:
                        # Number or other: read until comma or }
                        var end_idx = after_colon.len()
                        val comma = after_colon.index_of(",")
                        match comma:
                            Some(ci2):
                                end_idx = ci2
                            _:
                                pass_dn
                        val brace = after_colon.index_of("}")
                        match brace:
                            Some(bi):
                                if bi < end_idx:
                                    end_idx = bi
                            _:
                                pass_dn
                        return after_colon[0:end_idx].strip()
                _:
                    return ""
        _:
            return ""

fn _is_truthy(value: text) -> bool:
    val lower = value.lower()
    return lower == "true" or lower == "1" or lower == "yes" or lower == "on"

fn _is_falsy(value: text) -> bool:
    val lower = value.lower()
    return lower == "false" or lower == "0" or lower == "no" or lower == "off"

fn _state_matches_toggle_target(node: UiAccessNode, desired: text) -> bool:
    if _is_truthy(desired):
        return node.selected
    if _is_falsy(desired):
        return not node.selected
    return false

fn _find_surface(snapshot: UiAccessSnapshot, surface_id: text) -> UiAccessSurface?:
    for surface in snapshot.surfaces:
        if surface.surface_id == surface_id:
            return surface
    return nil

fn _node_state_value(node: UiAccessNode, state_key: text) -> text?:
    val lower_key = state_key.lower()
    if lower_key == "canonical_id":
        return node.canonical_id
    if lower_key == "surface_id":
        return node.surface_id
    if lower_key == "widget_id":
        return node.widget_id
    if lower_key == "kind":
        return node.kind
    if lower_key == "visible":
        return if node.visible: "true" else: "false"
    if lower_key == "focused":
        return if node.focused: "true" else: "false"
    if lower_key == "enabled":
        return if node.enabled: "true" else: "false"
    if lower_key == "selected" or lower_key == "checked" or lower_key == "expanded":
        return if node.selected: "true" else: "false"
    if lower_key == "text":
        return node.text
    if lower_key == "actions" or lower_key == "action_names":
        return _join_text(node.action_names, ",")
    return nil

fn _surface_state_value(surface: UiAccessSurface, state_key: text) -> text?:
    val lower_key = state_key.lower()
    if lower_key == "surface_id":
        return surface.surface_id
    if lower_key == "title":
        return surface.title
    if lower_key == "active":
        return if surface.active: "true" else: "false"
    if lower_key == "window_id":
        return surface.window_id
    if lower_key == "app_id":
        return surface.app_id
    if lower_key == "root_canonical_id":
        return surface.root_canonical_id
    return nil

fn _join_text(values: [text], separator: text) -> text:
    var out = ""
    var first = true
    for value in values:
        if first:
            out = value
            first = false
        else:
            out = "{out}{separator}{value}"
    return out

fn _find_window(windows: [WindowInfo], id_str: text) -> WindowInfo?:
    """Find a window by ID string."""
    for w in windows:
        if "{w.id}" == id_str:
            return w
    return nil

fn _snapshot_with_window_metadata(snapshot: UiAccessSnapshot, windows: [WindowInfo]) -> UiAccessSnapshot:
    """Overlay window IDs and titles onto snapshot surfaces when known."""
    var enriched: [UiAccessSurface] = []
    for surface in snapshot.surfaces:
        var window_id = surface.window_id
        var title = surface.title
        for window in windows:
            if window.surface_id == surface.surface_id:
                window_id = "{window.id}"
                if title == "":
                    title = window.title
        enriched = enriched.push(UiAccessSurface(
            surface_id: surface.surface_id,
            title: title,
            active: surface.active,
            window_id: window_id,
            app_id: surface.app_id,
            root_canonical_id: surface.root_canonical_id
        ))
    return UiAccessSnapshot(
        protocol_version: snapshot.protocol_version,
        mode: snapshot.mode,
        active_surface: snapshot.active_surface,
        surfaces: enriched,
        nodes: snapshot.nodes,
        recent_events: snapshot.recent_events
    )

fn _parse_dim_or_default(value: text, default_value: i32) -> i32:
    if value == "":
        return default_value
    return value.to_i32()

fn _fs_node_kind_str(kind: FsNodeKind) -> text:
    """Convert FsNodeKind to display string."""
    match kind:
        File: return "FILE"
        Directory: return "DIR "
        Symlink: return "LINK"
        Device: return "DEV "
        Pipe: return "PIPE"

fn _render_widget_tree_text(node: WidgetNode, depth: i32) -> text:
    """Render a widget tree as indented text for LLM reading."""
    var indent = ""
    var i = 0
    while i < depth:
        indent = "{indent}  "
        i = i + 1
    var out = "{indent}{node.widget_summary()}\n"
    val children = node.children()
    for child in children:
        out = "{out}{_render_widget_tree_text(child, depth + 1)}"
    return out

fn _extract_text_content(node: WidgetNode) -> text:
    """Recursively extract all text content from a widget tree."""
    var out = ""
    val summary = node.widget_summary()
    if summary != "":
        out = "{out}{summary}\n"
    val children = node.children()
    for child in children:
        out = "{out}{_extract_text_content(child)}"
    return out
