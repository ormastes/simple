use std.io_runtime

class NetBackendCapabilities:
    has_portable: bool
    has_sendfile: bool
    has_zero_copy: bool
    has_packet_io: bool
    has_sriov: bool
    has_rdma: bool
    tier: text

    static fn basic() -> NetBackendCapabilities:
        return NetBackendCapabilities(
            has_portable: true,
            has_sendfile: false,
            has_zero_copy: false,
            has_packet_io: false,
            has_sriov: false,
            has_rdma: false,
            tier: "basic"
        )

    static fn accelerated() -> NetBackendCapabilities:
        return NetBackendCapabilities(
            has_portable: true,
            has_sendfile: true,
            has_zero_copy: true,
            has_packet_io: false,
            has_sriov: false,
            has_rdma: false,
            tier: "accelerated"
        )

    static fn hardware() -> NetBackendCapabilities:
        return NetBackendCapabilities(
            has_portable: true,
            has_sendfile: true,
            has_zero_copy: true,
            has_packet_io: true,
            has_sriov: true,
            has_rdma: true,
            tier: "hardware"
        )

    me highest_tier() -> text:
        return self.tier

    me supports_zero_copy() -> bool:
        return self.has_zero_copy

    me capability_count() -> i32:
        var count: i32 = 0
        if self.has_portable:
            count = count + 1
        if self.has_sendfile:
            count = count + 1
        if self.has_zero_copy:
            count = count + 1
        if self.has_packet_io:
            count = count + 1
        if self.has_sriov:
            count = count + 1
        if self.has_rdma:
            count = count + 1
        return count

class IoDriverCapability:
    driver_name: text
    backend_tier: text
    is_available: bool

    static fn create(name: text, tier: text) -> IoDriverCapability:
        return IoDriverCapability(
            driver_name: name,
            backend_tier: tier,
            is_available: true
        )

    static fn unavailable(name: text) -> IoDriverCapability:
        return IoDriverCapability(
            driver_name: name,
            backend_tier: "none",
            is_available: false
        )

    me can_accelerate() -> bool:
        return self.backend_tier != "basic" and self.is_available

class CapabilityReport:
    driver_count: i32
    basic_count: i32
    accel_count: i32
    hw_count: i32

    static fn create(drivers: i32, basic: i32, accel: i32, hw: i32) -> CapabilityReport:
        return CapabilityReport(
            driver_count: drivers,
            basic_count: basic,
            accel_count: accel,
            hw_count: hw
        )

    me has_acceleration() -> bool:
        return self.accel_count > 0 or self.hw_count > 0

    me summary() -> text:
        return "drivers=" + self.driver_count.to_text() + " basic=" + self.basic_count.to_text() + " accel=" + self.accel_count.to_text() + " hw=" + self.hw_count.to_text()

class ThroughputTier:
    tier_name: text
    max_gbps: i32

    static fn from_capabilities(caps: NetBackendCapabilities) -> ThroughputTier:
        if caps.tier == "hardware":
            return ThroughputTier(tier_name: "ultra", max_gbps: 100)
        if caps.tier == "accelerated":
            return ThroughputTier(tier_name: "high", max_gbps: 10)
        return ThroughputTier(tier_name: "low", max_gbps: 1)

    me is_high_perf() -> bool:
        return self.max_gbps >= 10
