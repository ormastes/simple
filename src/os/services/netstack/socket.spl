# Socket -- Application-Facing Network API
#
# MDSOC: feature dimension, network layer
# Provides a POSIX-like socket abstraction over TCP and UDP.
# Sockets are identified by integer file descriptors.

use os.services.netstack.ipv4.{Ipv4Address}

# ============================================================================
# Socket Types
# ============================================================================

enum SocketProtocol:
    """Transport protocol for a socket."""
    Tcp
    Udp

enum SocketState:
    """Socket lifecycle state."""
    Unbound
    Bound
    Listening
    Connecting
    Connected
    Closed

fn socket_state_name(state: SocketState) -> text:
    match state:
        SocketState.Unbound: "UNBOUND"
        SocketState.Bound: "BOUND"
        SocketState.Listening: "LISTENING"
        SocketState.Connecting: "CONNECTING"
        SocketState.Connected: "CONNECTED"
        SocketState.Closed: "CLOSED"

# ============================================================================
# Socket Address
# ============================================================================

struct SockAddr:
    """Socket address: IP + port."""
    ip: Ipv4Address
    port: u16

impl SockAddr:
    static fn any(port: u16) -> SockAddr:
        """Bind to all interfaces on the given port."""
        SockAddr(ip: Ipv4Address.any(), port: port)

    fn to_text() -> text:
        "{self.ip.to_text()}:{self.port}"

    fn equals(other: SockAddr) -> bool:
        self.ip.equals(other.ip) and self.port == other.port

# ============================================================================
# Socket Descriptor
# ============================================================================

struct OsSocket:
    """A single socket with its state and protocol binding."""
    fd: i32
    protocol: SocketProtocol
    local_addr: SockAddr?
    remote_addr: SockAddr?
    state: SocketState
    conn_id: u64           # TCP connection ID (index into netstack connections)
    active: bool           # Whether this socket slot is in use

    # TCP listener state
    backlog: u32           # Max pending connections
    accept_queue: [u64]    # Connection IDs of accepted connections

# ============================================================================
# Socket Table
# ============================================================================

struct SocketTable:
    """Table of all active sockets, indexed by file descriptor."""
    sockets: [OsSocket]
    next_fd: i32

impl SocketTable:
    static fn new() -> SocketTable:
        SocketTable(sockets: [], next_fd: 3)  # Start at 3 (0,1,2 = stdin/out/err)

    me create(protocol: SocketProtocol) -> i32:
        """Create a new socket and return its file descriptor.

        Returns a non-negative fd on success.
        """
        val fd = self.next_fd
        self.next_fd = self.next_fd + 1

        self.sockets.push(OsSocket(
            fd: fd, protocol: protocol,
            local_addr: nil, remote_addr: nil,
            state: SocketState.Unbound,
            conn_id: 0, active: true,
            backlog: 0, accept_queue: []
        ))

        fd

    me bind(fd: i32, addr: SockAddr) -> Result<bool, text>:
        """Bind a socket to a local address.

        The socket must be in Unbound state.
        """
        var idx = self._find_idx(fd)
        if idx < 0:
            return Err("invalid fd: {fd}")

        val i = idx.to_u64()
        if not _is_socket_state(self.sockets[i].state, SocketState.Unbound):
            return Err("socket already bound")

        self.sockets[i] = OsSocket(
            fd: self.sockets[i].fd,
            protocol: self.sockets[i].protocol,
            local_addr: addr,
            remote_addr: self.sockets[i].remote_addr,
            state: SocketState.Bound,
            conn_id: self.sockets[i].conn_id,
            active: true,
            backlog: self.sockets[i].backlog,
            accept_queue: self.sockets[i].accept_queue
        )
        Ok(true)

    me listen(fd: i32, backlog: u32) -> Result<bool, text>:
        """Mark a bound TCP socket as listening for connections."""
        var idx = self._find_idx(fd)
        if idx < 0:
            return Err("invalid fd: {fd}")

        val i = idx.to_u64()
        if not _is_socket_state(self.sockets[i].state, SocketState.Bound):
            return Err("socket not bound")
        if not _is_tcp(self.sockets[i].protocol):
            return Err("listen requires TCP socket")

        self.sockets[i] = OsSocket(
            fd: self.sockets[i].fd,
            protocol: self.sockets[i].protocol,
            local_addr: self.sockets[i].local_addr,
            remote_addr: self.sockets[i].remote_addr,
            state: SocketState.Listening,
            conn_id: self.sockets[i].conn_id,
            active: true,
            backlog: backlog,
            accept_queue: []
        )
        Ok(true)

    me connect(fd: i32, addr: SockAddr) -> Result<bool, text>:
        """Initiate a TCP connection to a remote address.

        For UDP, this sets the default destination address.
        """
        var idx = self._find_idx(fd)
        if idx < 0:
            return Err("invalid fd: {fd}")

        val i = idx.to_u64()
        val sock = self.sockets[i]

        if _is_tcp(sock.protocol):
            if not (_is_socket_state(sock.state, SocketState.Unbound) or
                    _is_socket_state(sock.state, SocketState.Bound)):
                return Err("invalid state for connect: {socket_state_name(sock.state)}")

            self.sockets[i] = OsSocket(
                fd: sock.fd, protocol: sock.protocol,
                local_addr: sock.local_addr, remote_addr: addr,
                state: SocketState.Connecting,
                conn_id: sock.conn_id, active: true,
                backlog: sock.backlog, accept_queue: sock.accept_queue
            )
        else:
            # UDP: just set remote address
            self.sockets[i] = OsSocket(
                fd: sock.fd, protocol: sock.protocol,
                local_addr: sock.local_addr, remote_addr: addr,
                state: SocketState.Connected,
                conn_id: sock.conn_id, active: true,
                backlog: sock.backlog, accept_queue: sock.accept_queue
            )

        Ok(true)

    me set_connected(fd: i32, conn_id: u64):
        """Mark a socket as connected with the given TCP connection ID.

        Called by the netstack service when a connect() or accept() completes.
        """
        var idx = self._find_idx(fd)
        if idx < 0:
            return

        val i = idx.to_u64()
        val sock = self.sockets[i]
        self.sockets[i] = OsSocket(
            fd: sock.fd, protocol: sock.protocol,
            local_addr: sock.local_addr, remote_addr: sock.remote_addr,
            state: SocketState.Connected,
            conn_id: conn_id, active: true,
            backlog: sock.backlog, accept_queue: sock.accept_queue
        )

    me queue_accepted(listener_fd: i32, conn_id: u64):
        """Queue an accepted connection for a listening socket."""
        var idx = self._find_idx(listener_fd)
        if idx < 0:
            return

        val i = idx.to_u64()
        self.sockets[i].accept_queue.push(conn_id)

    me accept(fd: i32) -> Result<i32, text>:
        """Accept a pending connection on a listening TCP socket.

        Returns the fd of the new connected socket, or Err if none pending.
        """
        var idx = self._find_idx(fd)
        if idx < 0:
            return Err("invalid fd: {fd}")

        val i = idx.to_u64()
        val sock = self.sockets[i]

        if not _is_socket_state(sock.state, SocketState.Listening):
            return Err("socket not listening")
        if sock.accept_queue.len() == 0:
            return Err("no pending connections")

        # Dequeue the first connection
        val conn_id = sock.accept_queue[0]
        var new_queue: [u64] = []
        var qi: u64 = 1
        while qi < sock.accept_queue.len():
            new_queue.push(sock.accept_queue[qi])
            qi = qi + 1
        self.sockets[i] = OsSocket(
            fd: sock.fd, protocol: sock.protocol,
            local_addr: sock.local_addr, remote_addr: sock.remote_addr,
            state: sock.state, conn_id: sock.conn_id,
            active: true, backlog: sock.backlog,
            accept_queue: new_queue
        )

        # Create a new socket for the accepted connection
        val new_fd = self.next_fd
        self.next_fd = self.next_fd + 1
        self.sockets.push(OsSocket(
            fd: new_fd, protocol: SocketProtocol.Tcp,
            local_addr: sock.local_addr, remote_addr: nil,
            state: SocketState.Connected,
            conn_id: conn_id, active: true,
            backlog: 0, accept_queue: []
        ))

        Ok(new_fd)

    me send(fd: i32, data: [u8]) -> Result<u64, text>:
        """Placeholder: the actual send is handled by netstack_service via conn_id."""
        var idx = self._find_idx(fd)
        if idx < 0:
            return Err("invalid fd: {fd}")

        val i = idx.to_u64()
        if not _is_socket_state(self.sockets[i].state, SocketState.Connected):
            return Err("socket not connected")

        # Data is passed to the netstack service which manages the TcpConnection
        Ok(data.len())

    me recv(fd: i32, max: u64) -> Result<[u8], text>:
        """Placeholder: the actual recv is handled by netstack_service via conn_id."""
        var idx = self._find_idx(fd)
        if idx < 0:
            return Err("invalid fd: {fd}")

        val i = idx.to_u64()
        if not _is_socket_state(self.sockets[i].state, SocketState.Connected):
            return Err("socket not connected")

        Ok([])  # Actual data comes from TcpConnection.recv_data()

    me close(fd: i32) -> Result<bool, text>:
        """Close a socket and release its resources."""
        var idx = self._find_idx(fd)
        if idx < 0:
            return Err("invalid fd: {fd}")

        val i = idx.to_u64()
        val sock = self.sockets[i]
        self.sockets[i] = OsSocket(
            fd: sock.fd, protocol: sock.protocol,
            local_addr: sock.local_addr, remote_addr: sock.remote_addr,
            state: SocketState.Closed,
            conn_id: sock.conn_id, active: false,
            backlog: 0, accept_queue: []
        )
        Ok(true)

    fn get_socket(fd: i32) -> OsSocket?:
        """Look up a socket by file descriptor."""
        var i: u64 = 0
        while i < self.sockets.len():
            if self.sockets[i].active and self.sockets[i].fd == fd:
                return self.sockets[i]
            i = i + 1
        nil

    fn get_conn_id(fd: i32) -> u64:
        """Get the TCP connection ID for a socket."""
        var i: u64 = 0
        while i < self.sockets.len():
            if self.sockets[i].active and self.sockets[i].fd == fd:
                return self.sockets[i].conn_id
            i = i + 1
        0

    fn find_listener(port: u16) -> OsSocket?:
        """Find a listening socket bound to the given port."""
        var i: u64 = 0
        while i < self.sockets.len():
            val sock = self.sockets[i]
            if sock.active and _is_socket_state(sock.state, SocketState.Listening):
                if sock.local_addr.?:
                    val addr = sock.local_addr.unwrap()
                    if addr.port == port:
                        return sock
            i = i + 1
        nil

    fn _find_idx(fd: i32) -> i32:
        """Find the index of a socket by fd. Returns -1 if not found."""
        var i: u64 = 0
        while i < self.sockets.len():
            if self.sockets[i].active and self.sockets[i].fd == fd:
                return i.to_i32()
            i = i + 1
        -1

# ============================================================================
# Helpers
# ============================================================================

fn _is_socket_state(state: SocketState, expected: SocketState) -> bool:
    _socket_state_tag(state) == _socket_state_tag(expected)

fn _socket_state_tag(state: SocketState) -> u32:
    match state:
        SocketState.Unbound: 0
        SocketState.Bound: 1
        SocketState.Listening: 2
        SocketState.Connecting: 3
        SocketState.Connected: 4
        SocketState.Closed: 5

fn _is_tcp(protocol: SocketProtocol) -> bool:
    match protocol:
        SocketProtocol.Tcp: true
        SocketProtocol.Udp: false
