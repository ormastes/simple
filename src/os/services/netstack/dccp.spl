# DCCP -- Datagram Congestion Control Protocol (RFC 4340)
#
# MDSOC: feature dimension, network transport layer.
# Sibling of tcp.spl / udp.spl. Consumes the foundation ByteReader/ByteWriter
# (big-endian) and the foundation Port directly.
#
# Generic (short) header layout, 12 bytes:
#   src_port(2) dst_port(2) data_offset(1) ccval_cscov(1) checksum(2)
#   res_type_x(1) seq_num(3)
# where:
#   ccval_cscov packs CCVal(4) in the high nibble, CsCov(4) in the low nibble.
#   res_type_x packs Res(3 high bits) Type(4) X(1 low bit). X=0 => short
#     (24-bit) sequence numbers; X=1 (long form) adds a reserved byte + 32 more
#     sequence bits (handled by the long-header helpers).
#
# Checksum is the one's-complement internet checksum over the IPv6/IPv4
# pseudo-header + DCCP header + (CsCov-controlled) payload -- reuses the
# existing internet-checksum machinery; not implemented inline here.
#
# ALPHA ORACLE: no C runtime vendored (Linux DCCP stack is GPL; see design note
# r4_transport_internet.md). Golden byte-layout vectors were derived
# INDEPENDENTLY in a Python sandbox from the RFC 4340 field layout and are
# asserted in dccp_spec.spl.

use std.common.net.byte_cursor.{ByteReader, ByteWriter}
use std.common.net.addr.{Port}

# ============================================================================
# Packet-type constants (integer dispatch, NOT a payload-carrying enum).
# ============================================================================

val DCCP_PKT_REQUEST: u8 = 0
val DCCP_PKT_RESPONSE: u8 = 1
val DCCP_PKT_DATA: u8 = 2
val DCCP_PKT_ACK: u8 = 3
val DCCP_PKT_DATA_ACK: u8 = 4
val DCCP_PKT_CLOSE_REQ: u8 = 5
val DCCP_PKT_CLOSE: u8 = 6
val DCCP_PKT_RESET: u8 = 7
val DCCP_PKT_SYNC: u8 = 8
val DCCP_PKT_SYNC_ACK: u8 = 9

val DCCP_SHORT_HEADER_SIZE: u64 = 12

# ============================================================================
# Generic (short) header
# ============================================================================

struct DccpHeader:
    """DCCP generic short header (12 bytes). seq_num is the 24-bit sequence."""
    src_port: Port
    dst_port: Port
    data_offset: u8        # length of the DCCP header in 32-bit words
    ccval: u8              # 4-bit
    cscov: u8              # 4-bit
    checksum: u16
    res: u8               # 3-bit reserved
    type_: u8             # 4-bit packet type
    x: u8                 # 1-bit extended-seq flag (0 => short form)
    seq_num: u32          # 24-bit

fn dccp_build_header(h: DccpHeader) -> [u8]:
    """Serialize the 12-byte DCCP short header (big-endian)."""
    var w = ByteWriter.new()
    w.write_u16(h.src_port.value)
    w.write_u16(h.dst_port.value)
    w.write_u8(h.data_offset)
    # ccval(4) high | cscov(4) low
    val cc: u8 = (((h.ccval & 0xF) << 4) | (h.cscov & 0xF)).to_u8()
    w.write_u8(cc)
    w.write_u16(h.checksum)
    # res(3) high | type(4) | x(1) low
    val rtx: u8 = (((h.res & 0x7) << 5) | ((h.type_ & 0xF) << 1) | (h.x & 0x1)).to_u8()
    w.write_u8(rtx)
    # 24-bit sequence number
    w.write_u24(h.seq_num & 0xFFFFFF)
    w.to_bytes()

fn dccp_parse_header(data: [u8]) -> Result<DccpHeader, text>:
    """Parse a 12-byte DCCP short header."""
    if data.len() < DCCP_SHORT_HEADER_SIZE:
        return Err("DCCP header too short: {data.len()} < 12")
    var r = ByteReader.new(data)
    val sp = r.read_u16()?
    val dp = r.read_u16()?
    val doff = r.read_u8()?
    val cc = r.read_u8()?
    val ccval: u8 = ((cc >> 4) & 0xF).to_u8()
    val cscov: u8 = (cc & 0xF).to_u8()
    val ck = r.read_u16()?
    val rtx = r.read_u8()?
    val res: u8 = ((rtx >> 5) & 0x7).to_u8()
    val type_: u8 = ((rtx >> 1) & 0xF).to_u8()
    val x: u8 = (rtx & 0x1).to_u8()
    val seq = r.read_u24()?
    # BUG(struct_literal_named_arg_shadowed_by_static_new): Port(value: x) is
    # rejected because Port has a `static fn new(v)`; use Port.new instead.
    Ok(DccpHeader(
        src_port: Port.new(sp), dst_port: Port.new(dp),
        data_offset: doff, ccval: ccval, cscov: cscov,
        checksum: ck, res: res, type_: type_, x: x, seq_num: seq))

# ============================================================================
# Option TLV
# ============================================================================

struct DccpOption:
    """DCCP option. option<32 => single byte (no length/value); else TLV with
    length counting option+length+value."""
    option: u8
    length: u8
    value: [u8]

fn dccp_option_is_single(option: u8) -> bool:
    option < 32

fn dccp_build_option(o: DccpOption) -> [u8]:
    var w = ByteWriter.new()
    w.write_u8(o.option)
    if not dccp_option_is_single(o.option):
        w.write_u8(o.length)
        w.write_bytes(o.value)
    w.to_bytes()

fn dccp_parse_options(data: [u8]) -> Result<[DccpOption], text>:
    """Walk a DCCP option list (no inter-option padding; options self-length)."""
    var out: [DccpOption] = []
    var off: u64 = 0
    while off < data.len():
        val option = data[off]
        if dccp_option_is_single(option):
            out.push(DccpOption(option: option, length: 1, value: []))
            off = off + 1
        else:
            if off + 2 > data.len():
                return Err("DCCP option truncated length")
            val length = data[off + 1]
            if length.to_u64() < 2:
                return Err("DCCP multi-byte option length < 2")
            if off + length.to_u64() > data.len():
                return Err("DCCP option overruns")
            var value: [u8] = []
            var i: u64 = off + 2
            val vend: u64 = off + length.to_u64()
            while i < vend:
                value.push(data[i])
                i = i + 1
            out.push(DccpOption(option: option, length: length, value: value))
            off = off + length.to_u64()
    Ok(out)

# ============================================================================
# Typed subheaders
# ============================================================================

struct DccpRequest:
    """REQUEST (type 0): service_code(4) + options."""
    service_code: u32
    options: [DccpOption]

struct DccpResponse:
    """RESPONSE (type 1): ack_num(48-bit) service_code(4) + options."""
    ack_num: u64
    service_code: u32
    options: [DccpOption]

struct DccpAck:
    """ACK (type 3): ack_num(48-bit) + options."""
    ack_num: u64
    options: [DccpOption]

fn dccp_build_request(req: DccpRequest) -> [u8]:
    """Serialize a REQUEST subheader: service_code(4) + options."""
    var w = ByteWriter.new()
    w.write_u32(req.service_code)
    var i: u64 = 0
    while i < req.options.len():
        w.write_bytes(dccp_build_option(req.options[i]))
        i = i + 1
    w.to_bytes()

fn dccp_parse_request(data: [u8]) -> Result<DccpRequest, text>:
    if data.len() < 4:
        return Err("DCCP REQUEST subheader too short")
    var r = ByteReader.new(data)
    val sc = r.read_u32()?
    val rest = r.read_bytes(r.remaining())?
    val opts = dccp_parse_options(rest)?
    Ok(DccpRequest(service_code: sc, options: opts))

fn dccp_build_response(resp: DccpResponse) -> [u8]:
    """Serialize a RESPONSE subheader: ack(8) + service_code(4) + options."""
    var w = ByteWriter.new()
    w.write_bytes(dccp_build_ack_subheader(resp.ack_num))
    w.write_u32(resp.service_code)
    var i: u64 = 0
    while i < resp.options.len():
        w.write_bytes(dccp_build_option(resp.options[i]))
        i = i + 1
    w.to_bytes()

fn dccp_parse_response(data: [u8]) -> Result<DccpResponse, text>:
    if data.len() < 12:
        return Err("DCCP RESPONSE subheader too short")
    val ack = dccp_parse_ack_subheader(data, 0)?
    var r = ByteReader.new(data)
    r.pos = 8
    val sc = r.read_u32()?
    val rest = r.read_bytes(r.remaining())?
    val opts = dccp_parse_options(rest)?
    Ok(DccpResponse(ack_num: ack, service_code: sc, options: opts))

fn dccp_build_ack(ack: DccpAck) -> [u8]:
    """Serialize an ACK subheader: ack(8) + options."""
    var w = ByteWriter.new()
    w.write_bytes(dccp_build_ack_subheader(ack.ack_num))
    var i: u64 = 0
    while i < ack.options.len():
        w.write_bytes(dccp_build_option(ack.options[i]))
        i = i + 1
    w.to_bytes()

fn dccp_parse_ack(data: [u8]) -> Result<DccpAck, text>:
    if data.len() < 8:
        return Err("DCCP ACK subheader too short")
    val ackn = dccp_parse_ack_subheader(data, 0)?
    var r = ByteReader.new(data)
    r.pos = 8
    val rest = r.read_bytes(r.remaining())?
    val opts = dccp_parse_options(rest)?
    Ok(DccpAck(ack_num: ackn, options: opts))

# Build the ack subheader: reserved(2) + 48-bit ack number (8 bytes total).
fn dccp_build_ack_subheader(ack_num: u64) -> [u8]:
    var w = ByteWriter.new()
    w.write_u16(0)
    w.write_u48(ack_num & 0xFFFFFFFFFFFF)
    w.to_bytes()

fn dccp_parse_ack_subheader(data: [u8], off: u64) -> Result<u64, text>:
    """Parse reserved(2)+ack(6); returns the 48-bit ack number."""
    if off + 8 > data.len():
        return Err("DCCP ack subheader truncated")
    var r = ByteReader.new(data)
    r.pos = off + 2
    val ack = r.read_u48()?
    Ok(ack)
