# Part 1 of src/os/services/netstack/tcp_connection.spl
use os.services.netstack.tcp_connection.*
# TCP Connection -- Per-Connection State Management
#
# MDSOC: feature dimension, network layer
# Implements the full RFC 793 TCP state machine for a single connection.
# Each TcpConnection tracks sequence numbers, buffers, retransmission,
# and drives all state transitions.
#
# State transitions (RFC 793):
#   CLOSED -> LISTEN             (passive open)
#   CLOSED -> SYN_SENT           (active open, send SYN)
#   LISTEN -> SYN_RECEIVED       (recv SYN, send SYN+ACK)
#   SYN_SENT -> ESTABLISHED      (recv SYN+ACK, send ACK)
#   SYN_RECEIVED -> ESTABLISHED  (recv ACK)
#   ESTABLISHED -> FIN_WAIT_1    (close, send FIN)
#   ESTABLISHED -> CLOSE_WAIT    (recv FIN, send ACK)
#   FIN_WAIT_1 -> FIN_WAIT_2    (recv ACK of FIN)
#   FIN_WAIT_1 -> CLOSING       (recv FIN, send ACK)
#   FIN_WAIT_2 -> TIME_WAIT     (recv FIN, send ACK)
#   CLOSE_WAIT -> LAST_ACK      (close, send FIN)
#   CLOSING -> TIME_WAIT        (recv ACK)
#   LAST_ACK -> CLOSED          (recv ACK)
#   TIME_WAIT -> CLOSED         (2MSL timeout)

use os.services.netstack.ipv4.{Ipv4Address}
use os.services.netstack.tcp.{
    TcpState, TcpHeader, TcpSegment,
    TCP_FLAG_FIN, TCP_FLAG_SYN, TCP_FLAG_RST, TCP_FLAG_PSH, TCP_FLAG_ACK,
    TCP_DEFAULT_WINDOW, TCP_MSS, TCP_MAX_RETRIES, TCP_INITIAL_RTO, TCP_TIME_WAIT_MS,
    tcp_build, tcp_has_flag, tcp_state_name,
    seq_lt, seq_lte, seq_gt, seq_gte, seq_between
}
use os.services.netstack.tcp_state_machine.{TcpStateMachine}

val TCP_SEND_BUFFER_CAP: u64 = 65535

# ============================================================================
# Retransmission Entry
# ============================================================================

struct TcpRetransmitEntry:
    """An unacknowledged segment queued for potential retransmission."""
    seq_num: u32
    data: [u8]
    flags: u8        # Original flags (for SYN/FIN retransmit)
    send_time: u64   # Timestamp when sent (ms)
    retries: u32     # Number of retransmission attempts

# ============================================================================
# TCP Connection
# ============================================================================

struct TcpConnection:
    """Per-connection TCP state.

    Tracks the full state machine, sequence numbers, send/receive windows,
    data buffers, and retransmission queue.
    """
    state: TcpState
    local_addr: Ipv4Address
    local_port: u16
    remote_addr: Ipv4Address
    remote_port: u16

    # Sequence numbers
    snd_una: u32        # Oldest unacknowledged sequence number
    snd_nxt: u32        # Next sequence number to send
    snd_wnd: u16        # Send window (advertised by remote)
    rcv_nxt: u32        # Next sequence number expected to receive
    rcv_wnd: u16        # Receive window (our advertised window)
    iss: u32            # Initial send sequence number
    irs: u32            # Initial receive sequence number

    # Buffers
    send_buf: [u8]      # Application data queued for sending
    recv_buf: [u8]      # Received data (ordered, ready for app)
    peer_closed: bool   # FIN observed after all queued receive data is drained
    last_error: text    # Application-visible terminal error, empty when healthy

    # Retransmission
    retransmit_queue: [TcpRetransmitEntry]
    retransmit_attempts: u32
    rto: u64            # Current retransmission timeout (ms)
    srtt: u64           # Smoothed round-trip time (ms)

    # Application notification
    notif_id: u64       # Notification ID for incoming data
    task_id: u64        # Owner task ID

    # Connection ID (assigned by netstack)
    conn_id: u64

    # TIME_WAIT timer
    time_wait_start: u64  # Timestamp when TIME_WAIT began
