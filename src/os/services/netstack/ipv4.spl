# IPv4 -- Internet Protocol Version 4
#
# MDSOC: feature dimension, network layer
# Parses and builds IPv4 packets with header checksum.
# Provides a routing table for next-hop resolution.
#
# Header format (20 bytes minimum, no options):
#   version(4b) ihl(4b) tos(8b) total_length(16b)
#   identification(16b) flags(3b) fragment_offset(13b)
#   ttl(8b) protocol(8b) checksum(16b)
#   src_addr(32b)
#   dst_addr(32b)

val IP_PROTO_ICMP: u8 = 1
val IP_PROTO_TCP: u8 = 6
val IP_PROTO_UDP: u8 = 17
val IPV4_HEADER_MIN: u64 = 20
val IPV4_VERSION: u8 = 4
val IPV4_DEFAULT_TTL: u8 = 64

# ============================================================================
# IPv4 Address
# ============================================================================

struct Ipv4Address:
    """32-bit IPv4 address in host byte order."""
    value: u32

impl Ipv4Address:
    static fn from_bytes(a: u8, b: u8, c: u8, d: u8) -> Ipv4Address:
        """Create from four octets: from_bytes(192, 168, 1, 1)."""
        val v: u32 = (a.to_u32() << 24) | (b.to_u32() << 16) | (c.to_u32() << 8) | d.to_u32()
        Ipv4Address(value: v)

    static fn from_u32(v: u32) -> Ipv4Address:
        Ipv4Address(value: v)

    static fn any() -> Ipv4Address:
        """0.0.0.0 -- binds to all interfaces."""
        Ipv4Address(value: 0)

    static fn broadcast_all() -> Ipv4Address:
        """255.255.255.255 -- limited broadcast."""
        Ipv4Address(value: 0xFFFFFFFF)

    fn to_bytes() -> [u8]:
        """Return as 4 bytes in network order (big-endian)."""
        var result: [u8] = []
        result.push(((self.value >> 24) & 0xFF).to_u8())
        result.push(((self.value >> 16) & 0xFF).to_u8())
        result.push(((self.value >> 8) & 0xFF).to_u8())
        result.push((self.value & 0xFF).to_u8())
        result

    fn to_text() -> text:
        """Format as dotted decimal: 192.168.1.1."""
        val a = (self.value >> 24) & 0xFF
        val b = (self.value >> 16) & 0xFF
        val c = (self.value >> 8) & 0xFF
        val d = self.value & 0xFF
        "{a}.{b}.{c}.{d}"

    fn equals(other: Ipv4Address) -> bool:
        self.value == other.value

    fn is_broadcast() -> bool:
        """Check for 255.255.255.255."""
        self.value == 0xFFFFFFFF

    fn is_loopback() -> bool:
        """Check for 127.x.x.x."""
        ((self.value >> 24) & 0xFF) == 127

    fn in_subnet(network: Ipv4Address, mask: Ipv4Address) -> bool:
        """Check if this address belongs to the given subnet."""
        (self.value & mask.value) == (network.value & mask.value)

# ============================================================================
# IPv4 Header
# ============================================================================

struct Ipv4Header:
    """Parsed IPv4 header fields."""
    version: u8
    ihl: u8            # Header length in 32-bit words (min 5)
    tos: u8            # Type of service / DSCP
    total_length: u16  # Total packet length including header
    identification: u16
    flags: u8          # 3-bit flags (bit 1=DF, bit 2=MF)
    fragment_offset: u16  # 13-bit fragment offset
    ttl: u8
    protocol: u8       # IP_PROTO_ICMP / TCP / UDP
    checksum: u16
    src: Ipv4Address
    dst: Ipv4Address

# ============================================================================
# IPv4 Packet
# ============================================================================

struct Ipv4Packet:
    """Complete IPv4 packet: header + payload."""
    header: Ipv4Header
    payload: [u8]

# ============================================================================
# Parse
# ============================================================================

fn ipv4_parse(data: [u8]) -> Result<Ipv4Packet, text>:
    """Parse an IPv4 packet from raw bytes.

    Validates version, header length, total length, and checksum.
    All multi-byte fields are big-endian (network byte order).
    """
    if data.len() < IPV4_HEADER_MIN:
        return Err("IPv4 packet too short: {data.len()} < {IPV4_HEADER_MIN}")

    # Byte 0: version (high nibble) + IHL (low nibble)
    val version = (data[0] >> 4) & 0x0F
    val ihl = data[0] & 0x0F

    if version != IPV4_VERSION:
        return Err("not IPv4: version={version}")
    if ihl < 5:
        return Err("invalid IHL: {ihl}")

    val header_len: u64 = ihl.to_u64() * 4
    if data.len() < header_len:
        return Err("packet shorter than header length")

    val tos = data[1]
    val total_length: u16 = (data[2].to_u16() << 8) | data[3].to_u16()
    val identification: u16 = (data[4].to_u16() << 8) | data[5].to_u16()

    # Byte 6-7: flags (3 bits) + fragment offset (13 bits)
    val flags_frag: u16 = (data[6].to_u16() << 8) | data[7].to_u16()
    val flags = ((flags_frag >> 13) & 0x07).to_u8()
    val fragment_offset: u16 = flags_frag & 0x1FFF

    val ttl = data[8]
    val protocol = data[9]
    val checksum: u16 = (data[10].to_u16() << 8) | data[11].to_u16()

    # Source IP (bytes 12-15)
    val src_val: u32 = (data[12].to_u32() << 24) | (data[13].to_u32() << 16) |
                       (data[14].to_u32() << 8) | data[15].to_u32()
    val src = Ipv4Address(value: src_val)

    # Destination IP (bytes 16-19)
    val dst_val: u32 = (data[16].to_u32() << 24) | (data[17].to_u32() << 16) |
                       (data[18].to_u32() << 8) | data[19].to_u32()
    val dst = Ipv4Address(value: dst_val)

    # Verify header checksum
    var header_bytes: [u8] = []
    var hi: u64 = 0
    while hi < header_len:
        header_bytes.push(data[hi])
        hi = hi + 1
    val computed = ipv4_checksum(header_bytes)
    if computed != 0:
        return Err("IPv4 header checksum mismatch")

    # Extract payload
    var payload: [u8] = []
    val payload_start = header_len
    val payload_end = if total_length.to_u64() <= data.len(): total_length.to_u64() else: data.len()
    var pi: u64 = payload_start
    while pi < payload_end:
        payload.push(data[pi])
        pi = pi + 1

    Ok(Ipv4Packet(
        header: Ipv4Header(
            version: version, ihl: ihl, tos: tos,
            total_length: total_length, identification: identification,
            flags: flags, fragment_offset: fragment_offset,
            ttl: ttl, protocol: protocol, checksum: checksum,
            src: src, dst: dst
        ),
        payload: payload
    ))

# ============================================================================
# Build
# ============================================================================

fn ipv4_build(src: Ipv4Address, dst: Ipv4Address, protocol: u8, payload: [u8]) -> [u8]:
    """Build a complete IPv4 packet with computed checksum.

    Uses default TTL (64), no options (IHL=5), no fragmentation.
    """
    val total_len: u16 = (IPV4_HEADER_MIN + payload.len()).to_u16()
    var pkt: [u8] = []

    # Byte 0: version=4, IHL=5
    pkt.push(0x45)
    # Byte 1: TOS=0
    pkt.push(0)
    # Bytes 2-3: total length (big-endian)
    pkt.push(((total_len >> 8) & 0xFF).to_u8())
    pkt.push((total_len & 0xFF).to_u8())
    # Bytes 4-5: identification=0
    pkt.push(0)
    pkt.push(0)
    # Bytes 6-7: flags=DF (0x40), fragment_offset=0
    pkt.push(0x40)
    pkt.push(0)
    # Byte 8: TTL
    pkt.push(IPV4_DEFAULT_TTL)
    # Byte 9: protocol
    pkt.push(protocol)
    # Bytes 10-11: checksum placeholder (computed below)
    pkt.push(0)
    pkt.push(0)

    # Bytes 12-15: source IP (big-endian)
    val src_bytes = src.to_bytes()
    pkt.push(src_bytes[0])
    pkt.push(src_bytes[1])
    pkt.push(src_bytes[2])
    pkt.push(src_bytes[3])

    # Bytes 16-19: destination IP (big-endian)
    val dst_bytes = dst.to_bytes()
    pkt.push(dst_bytes[0])
    pkt.push(dst_bytes[1])
    pkt.push(dst_bytes[2])
    pkt.push(dst_bytes[3])

    # Compute header checksum over the 20-byte header
    var header: [u8] = []
    var ci: u64 = 0
    while ci < IPV4_HEADER_MIN:
        header.push(pkt[ci])
        ci = ci + 1
    val cksum = ipv4_checksum(header)
    # Write checksum into bytes 10-11
    pkt[10] = ((cksum >> 8) & 0xFF).to_u8()
    pkt[11] = (cksum & 0xFF).to_u8()

    # Append payload
    var pi: u64 = 0
    while pi < payload.len():
        pkt.push(payload[pi])
        pi = pi + 1

    pkt

# ============================================================================
# Checksum
# ============================================================================

fn ipv4_checksum(header_bytes: [u8]) -> u16:
    """Compute the IPv4 one's-complement checksum.

    The checksum field in the input should be zero when computing,
    or contain the existing checksum when verifying (result should be 0).
    Processes 16-bit words in network byte order (big-endian).
    """
    var sum: u32 = 0
    var i: u64 = 0

    while i + 1 < header_bytes.len():
        val word: u32 = (header_bytes[i].to_u32() << 8) | header_bytes[i + 1].to_u32()
        sum = sum + word
        i = i + 2

    # Handle odd byte
    if i < header_bytes.len():
        sum = sum + (header_bytes[i].to_u32() << 8)

    # Fold 32-bit sum to 16 bits
    while (sum >> 16) > 0:
        sum = (sum & 0xFFFF) + (sum >> 16)

    val result: u16 = (~sum & 0xFFFF).to_u16()
    result

# ============================================================================
# Routing Table
# ============================================================================

struct RouteEntry:
    """A single routing table entry."""
    network: Ipv4Address
    mask: Ipv4Address
    gateway: Ipv4Address
    interface_ip: Ipv4Address

struct RoutingTable:
    """Simple longest-prefix-match routing table."""
    entries: [RouteEntry]
    default_gateway: Ipv4Address?

impl RoutingTable:
    static fn new() -> RoutingTable:
        RoutingTable(entries: [], default_gateway: nil)

    me add_route(network: Ipv4Address, mask: Ipv4Address, gateway: Ipv4Address, iface: Ipv4Address):
        """Add a route entry. Longer masks (more specific) are preferred during lookup."""
        self.entries.push(RouteEntry(
            network: network, mask: mask, gateway: gateway, interface_ip: iface
        ))

    me set_default(gateway: Ipv4Address):
        """Set the default gateway for packets that match no route."""
        self.default_gateway = gateway

    fn lookup(dst: Ipv4Address) -> Ipv4Address?:
        """Look up the next-hop gateway for a destination IP.

        Uses longest prefix match: the route with the most specific
        (longest) mask that matches wins. Falls back to default gateway.
        """
        var best_gateway: Ipv4Address? = nil
        var best_mask: u32 = 0

        var i: u64 = 0
        while i < self.entries.len():
            val entry = self.entries[i]
            if dst.in_subnet(entry.network, entry.mask):
                if entry.mask.value >= best_mask:
                    best_mask = entry.mask.value
                    best_gateway = entry.gateway
            i = i + 1

        if best_gateway.?:
            return best_gateway

        self.default_gateway
