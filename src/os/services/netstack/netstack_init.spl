# Network Stack Boot Initialization
#
# MDSOC: feature dimension, network layer
# Mirrors vfs_init.spl pattern:
# PCI scan -> find VirtIO-net -> grant device -> init driver -> create netstack
#
# Called during kernel init. Sets up the complete network stack:
# 1. PCI manager finds VirtIO-net device
# 2. VirtIO-net driver initializes with DeviceGrant
# 3. NetstackService wraps the driver with TCP/IP protocol layers
# 4. Default IP configured for QEMU user-mode networking
# 5. NetstackService starts listening on IPC port 2

use os.drivers.virtio.virtio_net.{VirtioNetDriver}
use os.services.netstack.netstack_service.{NetstackService}
use os.services.netstack.ipv4.{Ipv4Address}
use os.services.netstack.socket.{SockAddr, SocketProtocol}
use os.services.netstack.tcp_connection.{TcpConnection}
use os.services.pcimgr.pcimgr.{pcimgr_init, pcimgr_find_by_class, pcimgr_find_by_vendor, pcimgr_grant_device, pcimgr_get_device_vendor, pcimgr_get_device_class, pcimgr_get_device_subclass, pcimgr_device_count}
use os.services.pcimgr.driver_match.{PCI_CLASS_NETWORK, PCI_SUBCLASS_ETHERNET, VIRTIO_VENDOR, VIRTIO_DEV_NET}
use os.kernel.types.device_mem_types.{DeviceGrant}

use os.kernel.log.klog_api.{log_raw_println}
extern fn rt_pci_device_count() -> i64
extern fn rt_pci_get_field(index: i64, field: i64) -> i64
extern fn rt_net_init() -> i64
extern fn rt_net_stats() -> i64

# ============================================================================
# QEMU User-Mode Networking Defaults
# ============================================================================
# QEMU's -netdev user,id=net0 provides:
#   Guest IP:  10.0.2.15
#   Gateway:   10.0.2.2
#   DNS:       10.0.2.3
#   Subnet:    255.255.255.0

val QEMU_IP_A: u8 = 10
val QEMU_IP_B: u8 = 0
val QEMU_IP_C: u8 = 2
val QEMU_IP_D: u8 = 15

val QEMU_GW_A: u8 = 10
val QEMU_GW_B: u8 = 0
val QEMU_GW_C: u8 = 2
val QEMU_GW_D: u8 = 2

val QEMU_MASK_A: u8 = 255
val QEMU_MASK_B: u8 = 255
val QEMU_MASK_C: u8 = 255
val QEMU_MASK_D: u8 = 0

# ============================================================================
# Module-Level State
# ============================================================================

var g_netstack: NetstackService? = nil
var g_net_driver: VirtioNetDriver = VirtioNetDriver.new()
var g_net_initialized: bool = false

# ============================================================================
# Boot Init
# ============================================================================

fn net_boot_init() -> bool:
    """Initialize the network stack from PCI discovery.

    Steps:
    1. Find VirtIO-net device via PCI manager
       - Class 0x02 (network controller), subclass 0x00 (Ethernet)
       - Fallback: vendor 0x1AF4 (Red Hat), device 0x1000 (legacy virtio-net)
    2. Grant device resources (BAR0, IRQ, DMA)
    3. Initialize VirtIO-net driver
    4. Create NetstackService with the driver
    5. Configure IP for QEMU user-mode networking:
       - IP: 10.0.2.15, gateway: 10.0.2.2, subnet: 255.255.255.0

    Returns true if network stack is ready.
    """
    log_raw_println("[net-init] Starting network stack initialization...")

    # Step 1: Find VirtIO-net device
    # Search by VirtIO vendor first (precise), then by class (broad).
    # Class-based search finds any NIC (e.g., Intel 82574L), but we need VirtIO.
    log_raw_println("[net-init] Looking for VirtIO-net device (vendor=0x1AF4)...")
    var dev_idx = pcimgr_find_by_vendor(VIRTIO_VENDOR, VIRTIO_DEV_NET)

    if dev_idx < 0:
        # Fallback: find the first network controller, then verify vendor.
        # Compare the vendor in i64 space so we don't trip on narrow-type
        # equality behavior in the baremetal backend.
        dev_idx = pcimgr_find_by_class(PCI_CLASS_NETWORK, PCI_SUBCLASS_ETHERNET)
        if dev_idx >= 0:
            val vendor = pcimgr_get_device_vendor(dev_idx.to_u64())
            val virtio_vendor = VIRTIO_VENDOR.to_i64()
            if vendor != virtio_vendor:
                log_raw_println("[net-init] Found NIC at index {dev_idx} but not VirtIO (vendor=0x{vendor})")
                dev_idx = -1
            else:
                log_raw_println("[net-init] Falling back to Ethernet-class NIC at index {dev_idx} (vendor=0x{vendor})")

    if dev_idx < 0:
        # Last-resort raw PCI cache scan. This bypasses all wrapper code and
        # matches the same C cache that printed the correct device table at boot.
        val count = rt_pci_device_count()
        var scan_idx: i64 = 0
        while scan_idx < count:
            val cls = rt_pci_get_field(scan_idx, 3)
            val sub = rt_pci_get_field(scan_idx, 4)
            if cls == 2 and sub == 0:
                dev_idx = scan_idx
                break
            scan_idx = scan_idx + 1

    if dev_idx < 0:
        log_raw_println("[net-init] No VirtIO-net device found -- network unavailable")
        return false
    log_raw_println("[net-init] Found VirtIO-net device at index {dev_idx}")

    # On baremetal, the C VirtIO-net driver (syscall 90) handles the NIC.
    # Do not assume C boot already did this for every entrypoint.
    log_raw_println("[net-init] Initializing C VirtIO-net driver via rt_net_init")
    val init_rc = rt_net_init()
    if init_rc < 0:
        log_raw_println("[net-init] C network init failed rc={init_rc}")
        return false

    val stats = rt_net_stats()
    if stats < 0:
        log_raw_println("[net-init] C network stats probe failed rc={stats}")
        return false
    log_raw_println("[net-init] C network driver active")

    g_netstack = Some(NetstackService.new(g_net_driver))
    g_net_initialized = true
    log_raw_println("[net-init] Network stack ready (C-backed)")
    true

# ============================================================================
# Network Service Start
# ============================================================================

fn net_service_start():
    """Start the network stack IPC + frame polling loop (blocking).

    Call after net_boot_init() returns true. This enters the
    NetstackService.start() loop which blocks on IPC/frame processing.
    In a real system this would run in its own scheduler task.
    For cooperative scheduling, use net_service_init_port() + net_service_poll().
    """
    if not g_net_initialized:
        log_raw_println("[net-init] Cannot start service -- not initialized")
        return
    if g_netstack == nil:
        log_raw_println("[net-init] Cannot start service -- no netstack instance")
        return
    g_netstack.start()

fn net_service_init_port():
    """Initialize the netstack IPC port without entering the blocking loop.

    Use with net_service_poll() for cooperative scheduling.
    """
    if not g_net_initialized or g_netstack == nil:
        log_raw_println("[net-init] Cannot init port -- not initialized")
        return
    g_netstack.init_port()

fn net_service_poll():
    """Run one tick of the network stack (non-blocking).

    Call from a cooperative main loop alongside VFS and shell.
    """
    if g_net_initialized and g_netstack != nil:
        g_netstack.poll_once()

# ============================================================================
# Query Helpers
# ============================================================================

fn net_is_ready() -> bool:
    """Check if network stack has been initialized and is ready."""
    g_net_initialized

fn net_get_service() -> NetstackService?:
    """Return the global NetstackService instance (nil if not initialized)."""
    g_netstack

fn net_get_driver() -> VirtioNetDriver:
    """Return the global VirtIO-net driver instance."""
    g_net_driver

fn net_tcp_available() -> bool:
    """Return true when the cooperative netstack singleton is available."""
    g_net_initialized and g_netstack != nil

fn net_tcp_bind(ip_value: u32, port: u16, backlog: u32) -> i64:
    """Create, bind, and listen on a TCP socket in the netstack singleton."""
    if g_netstack == nil:
        return -1

    var svc = g_netstack.unwrap()
    val fd = svc.sockets.create(SocketProtocol.Tcp)
    val addr = SockAddr(ip: Ipv4Address.from_u32(ip_value), port: port)
    match svc.sockets.bind(fd, addr):
        Err(_): 
            g_netstack = Some(svc)
            return -1
        Ok(_): pass

    match svc.sockets.listen(fd, backlog):
        Err(_):
            svc.sockets.close(fd)
            g_netstack = Some(svc)
            return -1
        Ok(_): pass

    g_netstack = Some(svc)
    fd.to_i64()

fn net_tcp_accept(fd: i64) -> i64:
    """Poll once and accept a queued TCP connection from the singleton."""
    if g_netstack == nil:
        return -1

    var svc = g_netstack.unwrap()
    svc.poll_once()
    match svc.sockets.accept(fd.to_i32()):
        Ok(client_fd):
            g_netstack = Some(svc)
            client_fd.to_i64()
        Err(_):
            g_netstack = Some(svc)
            -1

fn net_tcp_connect(ip_value: u32, port: u16, wait_ticks: u64) -> i64:
    """Create a TCP socket and drive a bounded blocking connect handshake."""
    if g_netstack == nil:
        return -1

    var svc = g_netstack.unwrap()
    val fd = svc.sockets.create(SocketProtocol.Tcp)
    val remote = SockAddr(ip: Ipv4Address.from_u32(ip_value), port: port)
    match svc.sockets.connect(fd, remote):
        Err(_):
            g_netstack = Some(svc)
            return -1
        Ok(_): pass

    val local_port = svc._alloc_ephemeral_port()
    var conn = TcpConnection.new_client(svc.local_ip, local_port, remote.ip, port)
    conn.conn_id = svc.next_conn_id
    svc.next_conn_id = svc.next_conn_id + 1
    val conn_id = conn.conn_id
    val syn_segments = conn.connect()
    svc.tcp_connections.push(conn)
    val conn_idx = svc.tcp_connections.len() - 1
    svc.sockets.attach_connecting(fd, SockAddr(ip: svc.local_ip, port: local_port), conn_id)
    svc._send_tcp_segments(conn_idx, syn_segments)

    var waited: u64 = 0
    while waited < wait_ticks:
        svc.poll_once()
        val status = svc.sockets.connect_status_by_conn(conn_id)
        if status == "established":
            g_netstack = Some(svc)
            return fd.to_i64()
        if status == "refused" or status == "unreachable":
            g_netstack = Some(svc)
            return -1
        waited = waited + 1

    svc.sockets.mark_connect_failed_by_conn(conn_id, "timeout")
    g_netstack = Some(svc)
    -1

fn net_tcp_read(fd: i64, max: u64) -> [u8]:
    """Poll once and read TCP receive data for a connected socket."""
    if g_netstack == nil:
        return []

    var svc = g_netstack.unwrap()
    svc.poll_once()
    val conn_id = svc.sockets.get_conn_id(fd.to_i32())
    var i: u64 = 0
    while i < svc.tcp_connections.len():
        if svc.tcp_connections[i].conn_id == conn_id:
            val data = svc.tcp_connections[i].recv_data(max)
            g_netstack = Some(svc)
            return data
        i = i + 1

    g_netstack = Some(svc)
    []

fn net_tcp_write(fd: i64, data: [u8]) -> i64:
    """Queue TCP send data and poll once to flush it."""
    if g_netstack == nil:
        return -1

    var svc = g_netstack.unwrap()
    val conn_id = svc.sockets.get_conn_id(fd.to_i32())
    var i: u64 = 0
    while i < svc.tcp_connections.len():
        if svc.tcp_connections[i].conn_id == conn_id:
            match svc.tcp_connections[i].send_data(data):
                Ok(n):
                    svc.flush_tcp_connections()
                    g_netstack = Some(svc)
                    return n.to_i64()
                Err(_):
                    g_netstack = Some(svc)
                    return -1
        i = i + 1

    g_netstack = Some(svc)
    -1

fn net_tcp_close(fd: i64) -> bool:
    """Close a TCP socket and send FIN when a live connection exists."""
    if g_netstack == nil:
        return false

    var svc = g_netstack.unwrap()
    val conn_id = svc.sockets.get_conn_id(fd.to_i32())
    var i: u64 = 0
    while i < svc.tcp_connections.len():
        if svc.tcp_connections[i].conn_id == conn_id:
            val segments = svc.tcp_connections[i].close()
            svc._send_tcp_segments(i, segments)
            break
        i = i + 1
    val closed = svc.sockets.close(fd.to_i32()).is_ok()
    g_netstack = Some(svc)
    closed
