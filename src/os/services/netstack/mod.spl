# Network Stack Module
#
# MDSOC: feature dimension, network layer
# User-space TCP/IP stack for SimpleOS.
# Runs as a service on IPC port 2, owning the VirtIO-net driver in-process.
#
# Layer structure:
#   Ethernet -> ARP / IPv4 -> ICMP / TCP / UDP -> Socket -> Application
#
# Modules:
#   ethernet         - Ethernet II frame parsing and building
#   arp              - ARP protocol and cache table
#   ipv4             - IPv4 packet handling, checksum, routing table
#   icmp             - ICMP echo request/reply
#   udp              - UDP datagram handling and port binding
#   tcp              - TCP segment parsing, flags, checksum, state enum
#   tcp_connection   - Per-connection TCP state machine (RFC 793)
#   socket           - Application-facing socket abstraction
#   netstack_service - Main service entry point and event loop

use os.services.netstack.ethernet.{EthFrame, EthAddress, eth_parse, eth_build, ETHERTYPE_IPV4, ETHERTYPE_ARP}
use os.services.netstack.arp.{ArpTable, ArpPacket, arp_parse, arp_build_request, arp_build_reply}
use os.services.netstack.ipv4.{Ipv4Address, Ipv4Packet, ipv4_parse, ipv4_build, ipv4_checksum, RoutingTable}
use os.services.netstack.icmp.{IcmpPacket, icmp_parse, icmp_build_echo_reply, icmp_build_echo_request}
use os.services.netstack.udp.{UdpDatagram, UdpTable, udp_parse, udp_build}
use os.services.netstack.tcp.{TcpState, TcpSegment, TcpHeader, tcp_parse, tcp_build, tcp_checksum}
use os.services.netstack.tcp_connection.{TcpConnection}
use os.services.netstack.socket.{OsSocket, SocketTable, SockAddr, SocketProtocol}
use os.services.netstack.netstack_service.{NetstackService}
