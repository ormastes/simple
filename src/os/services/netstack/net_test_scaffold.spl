use std.io_runtime

class HttpCapReport:
    backend_tier: text
    zero_copy: bool
    sendfile: bool
    max_connections: i32

    static fn create(tier: text, zc: bool, sf: bool, max_conn: i32) -> HttpCapReport:
        return HttpCapReport(backend_tier: tier, zero_copy: zc, sendfile: sf, max_connections: max_conn)

    me startup_line() -> text:
        return "HTTP server: tier=" + self.backend_tier + " zero_copy=" + self.zero_copy.to_text() + " sendfile=" + self.sendfile.to_text() + " max_conn=" + self.max_connections.to_text()

    me can_use_sendfile() -> bool:
        return self.sendfile

    me throughput_class() -> text:
        if self.zero_copy:
            return "high"
        if self.sendfile:
            return "medium"
        return "low"

class QemuTestPhase:
    phase_name: text
    timeout_ms: i32
    started: bool
    completed: bool
    timed_out: bool

    static fn create(name: text, timeout: i32) -> QemuTestPhase:
        return QemuTestPhase(phase_name: name, timeout_ms: timeout, started: false, completed: false, timed_out: false)

    me start() -> QemuTestPhase:
        return QemuTestPhase(phase_name: self.phase_name, timeout_ms: self.timeout_ms, started: true, completed: self.completed, timed_out: self.timed_out)

    me complete() -> QemuTestPhase:
        return QemuTestPhase(phase_name: self.phase_name, timeout_ms: self.timeout_ms, started: self.started, completed: true, timed_out: self.timed_out)

    me timeout() -> QemuTestPhase:
        return QemuTestPhase(phase_name: self.phase_name, timeout_ms: self.timeout_ms, started: self.started, completed: self.completed, timed_out: true)

    me failure_message() -> text:
        if self.timed_out:
            return "TIMEOUT at phase: " + self.phase_name + " after " + self.timeout_ms.to_text() + "ms"
        return ""

    me is_ok() -> bool:
        return self.completed and self.timed_out == false

class QemuTestRunner:
    p0_name: text
    p0_ok: bool
    p0_timeout: bool
    p1_name: text
    p1_ok: bool
    p1_timeout: bool
    p2_name: text
    p2_ok: bool
    p2_timeout: bool
    total_phases: i32
    clean_exit: bool

    static fn create(p0: QemuTestPhase, p1: QemuTestPhase, p2: QemuTestPhase) -> QemuTestRunner:
        return QemuTestRunner(
            p0_name: p0.phase_name,
            p0_ok: p0.is_ok(),
            p0_timeout: p0.timed_out,
            p1_name: p1.phase_name,
            p1_ok: p1.is_ok(),
            p1_timeout: p1.timed_out,
            p2_name: p2.phase_name,
            p2_ok: p2.is_ok(),
            p2_timeout: p2.timed_out,
            total_phases: 3,
            clean_exit: false)

    me all_passed() -> bool:
        return self.p0_ok and self.p1_ok and self.p2_ok

    me first_failure() -> text:
        if self.p0_ok == false or self.p0_timeout:
            return self.p0_name
        if self.p1_ok == false or self.p1_timeout:
            return self.p1_name
        if self.p2_ok == false or self.p2_timeout:
            return self.p2_name
        return ""

    me terminated_cleanly() -> bool:
        return self.clean_exit

class BenchmarkResult:
    test_name: text
    requests_per_sec: i32
    avg_latency_us: i32
    p99_latency_us: i32
    backend_tier: text

    static fn create(name: text, rps: i32, avg: i32, p99: i32, tier: text) -> BenchmarkResult:
        return BenchmarkResult(test_name: name, requests_per_sec: rps, avg_latency_us: avg, p99_latency_us: p99, backend_tier: tier)

    me meets_baseline(min_rps: i32) -> bool:
        return self.requests_per_sec >= min_rps

    me latency_acceptable(max_p99: i32) -> bool:
        return self.p99_latency_us <= max_p99

    me summary() -> text:
        return self.test_name + ": rps=" + self.requests_per_sec.to_text() + " avg_us=" + self.avg_latency_us.to_text() + " p99_us=" + self.p99_latency_us.to_text() + " tier=" + self.backend_tier
