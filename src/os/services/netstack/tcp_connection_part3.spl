# Part 3 of src/os/services/netstack/tcp_connection.spl
use os.services.netstack.tcp_connection.*
# TCP Connection -- Per-Connection State Management
#
# MDSOC: feature dimension, network layer
# Implements the full RFC 793 TCP state machine for a single connection.
# Each TcpConnection tracks sequence numbers, buffers, retransmission,
# and drives all state transitions.
#
# State transitions (RFC 793):
#   CLOSED -> LISTEN             (passive open)
#   CLOSED -> SYN_SENT           (active open, send SYN)
#   LISTEN -> SYN_RECEIVED       (recv SYN, send SYN+ACK)
#   SYN_SENT -> ESTABLISHED      (recv SYN+ACK, send ACK)
#   SYN_RECEIVED -> ESTABLISHED  (recv ACK)
#   ESTABLISHED -> FIN_WAIT_1    (close, send FIN)
#   ESTABLISHED -> CLOSE_WAIT    (recv FIN, send ACK)
#   FIN_WAIT_1 -> FIN_WAIT_2    (recv ACK of FIN)
#   FIN_WAIT_1 -> CLOSING       (recv FIN, send ACK)
#   FIN_WAIT_2 -> TIME_WAIT     (recv FIN, send ACK)
#   CLOSE_WAIT -> LAST_ACK      (close, send FIN)
#   CLOSING -> TIME_WAIT        (recv ACK)
#   LAST_ACK -> CLOSED          (recv ACK)
#   TIME_WAIT -> CLOSED         (2MSL timeout)

use os.services.netstack.ipv4.{Ipv4Address}
use os.services.netstack.tcp.{
    TcpState, TcpHeader, TcpSegment,
    TCP_FLAG_FIN, TCP_FLAG_SYN, TCP_FLAG_RST, TCP_FLAG_PSH, TCP_FLAG_ACK,
    TCP_DEFAULT_WINDOW, TCP_MSS, TCP_MAX_RETRIES, TCP_INITIAL_RTO, TCP_TIME_WAIT_MS,
    tcp_build, tcp_has_flag, tcp_state_name,
    seq_lt, seq_lte, seq_gt, seq_gte, seq_between
}
use os.services.netstack.tcp_state_machine.{TcpStateMachine}

fn _is_state(state: TcpState, expected: TcpState) -> bool:
    """Compare TCP states by tag value."""
    _state_tag(state) == _state_tag(expected)

fn _state_tag(state: TcpState) -> u32:
    """Return a numeric tag for each TCP state."""
    match state:
        TcpState.Closed: 0
        TcpState.Listen: 1
        TcpState.SynSent: 2
        TcpState.SynReceived: 3
        TcpState.Established: 4
        TcpState.FinWait1: 5
        TcpState.FinWait2: 6
        TcpState.CloseWait: 7
        TcpState.Closing: 8
        TcpState.LastAck: 9
        TcpState.TimeWait: 10
