# igmp.spl
# IGMPv2/v3 -- Internet Group Management Protocol (RFC 3376)
# MDSOC: feature dimension, network layer.
#
# Wire formats:
#   IGMPv2:  type(1) max_resp_time(1) checksum(2) group(4)        = 8 bytes
#   IGMPv3 Query:  type(1) max_resp_code(1) checksum(2) group(4)
#                  flags(1) qqic(1) num_sources(2) sources(4*N)
#   IGMPv3 Report: type(1) reserved(1) checksum(2) reserved2(2)
#                  num_records(2) records...
#
# GroupRecord: record_type(1) aux_data_len(1) num_sources(2)
#              multicast(4) sources(4*N) aux_data(aux_data_len*4)
#
# Integer constants for type/record dispatch -- NOT enums (JIT-safe).
# NOTE: ByteReader is passed by value in fn parameters (copy semantics);
# multi-record parsing is done inline in the report parser to avoid mutation-loss.

use std.common.net.byte_cursor.{ByteReader, ByteWriter}
use std.common.net.addr.{Ipv4Addr, IpAddr, ip_addr_v4, ip_addr_to_bytes}

# ============================================================================
# IGMP type constants (dispatch via if/else, not enum)
# ============================================================================

val IGMP_MEMBERSHIP_QUERY: u8  = 0x11
val IGMP_V1_REPORT: u8         = 0x12
val IGMP_V2_REPORT: u8         = 0x16
val IGMP_V2_LEAVE: u8          = 0x17
val IGMP_V3_REPORT: u8         = 0x22

# ============================================================================
# GroupRecord type constants (shared meaning with MLDv2)
# ============================================================================

val GROUP_RECORD_MODE_IS_INCLUDE:    u8 = 1
val GROUP_RECORD_MODE_IS_EXCLUDE:    u8 = 2
val GROUP_RECORD_CHANGE_TO_INCLUDE:  u8 = 3
val GROUP_RECORD_CHANGE_TO_EXCLUDE:  u8 = 4
val GROUP_RECORD_ALLOW_NEW_SOURCES:  u8 = 5
val GROUP_RECORD_BLOCK_OLD_SOURCES:  u8 = 6

# ============================================================================
# GroupRecord -- shared by IGMPv3 and MLDv2 (multicast/sources as IpAddr)
# ============================================================================

struct GroupRecord:
    """One group record inside an IGMPv3/MLDv2 report."""
    record_type:  u8
    aux_data_len: u8      # units of 32-bit words
    num_sources:  u16
    multicast:    IpAddr  # V4 for IGMP, V6 for MLD
    sources:      [IpAddr]
    aux_data:     [u8]

# ============================================================================
# IGMPv2 message
# ============================================================================

struct IgmpV2Message:
    """IGMPv2 8-byte fixed header (RFC 2236 / 3376 §7)."""
    type_:         u8
    max_resp_time: u8
    checksum:      u16
    group:         Ipv4Addr

fn igmpv2_parse(data: [u8]) -> Result<IgmpV2Message, text>:
    """Parse an IGMPv2 message from raw bytes."""
    if data.len() < 8:
        return Err("IGMPv2 truncated: need 8 bytes, got {data.len()}")
    var r = ByteReader.new(data)
    val t_r = r.read_u8()
    if t_r.is_err():
        return Err("IGMPv2: read type")
    val mr_r = r.read_u8()
    if mr_r.is_err():
        return Err("IGMPv2: read max_resp_time")
    val ck_r = r.read_u16()
    if ck_r.is_err():
        return Err("IGMPv2: read checksum")
    val g_r = r.read_u32()
    if g_r.is_err():
        return Err("IGMPv2: read group")
    Ok(IgmpV2Message(
        type_: t_r.unwrap(),
        max_resp_time: mr_r.unwrap(),
        checksum: ck_r.unwrap(),
        group: Ipv4Addr.from_u32(g_r.unwrap())
    ))

fn igmpv2_build(msg: IgmpV2Message) -> [u8]:
    """Serialize an IGMPv2 message to wire bytes."""
    var w = ByteWriter.new()
    w.write_u8(msg.type_)
    w.write_u8(msg.max_resp_time)
    w.write_u16(msg.checksum)
    w.write_bytes(msg.group.to_bytes())
    w.to_bytes()

# ============================================================================
# IGMPv3 Query
# ============================================================================

struct IgmpV3Query:
    """IGMPv3 Membership Query (type=0x11, RFC 3376 §4.1)."""
    type_:         u8     # 0x11
    max_resp_code: u8
    checksum:      u16
    group:         Ipv4Addr
    flags:         u8     # resv(4) S(1) QRV(3)
    qqic:          u8
    num_sources:   u16
    sources:       [Ipv4Addr]

fn igmpv3_query_parse(data: [u8]) -> Result<IgmpV3Query, text>:
    """Parse an IGMPv3 Query; minimum 12 bytes before sources."""
    if data.len() < 12:
        return Err("IGMPv3 query truncated: need 12 bytes, got {data.len()}")
    var r = ByteReader.new(data)
    val t_r = r.read_u8()
    if t_r.is_err():
        return Err("IGMPv3q: read type")
    val mr_r = r.read_u8()
    if mr_r.is_err():
        return Err("IGMPv3q: read max_resp_code")
    val ck_r = r.read_u16()
    if ck_r.is_err():
        return Err("IGMPv3q: read checksum")
    val g_r = r.read_u32()
    if g_r.is_err():
        return Err("IGMPv3q: read group")
    val fl_r = r.read_u8()
    if fl_r.is_err():
        return Err("IGMPv3q: read flags")
    val qq_r = r.read_u8()
    if qq_r.is_err():
        return Err("IGMPv3q: read qqic")
    val ns_r = r.read_u16()
    if ns_r.is_err():
        return Err("IGMPv3q: read num_sources")
    val nsrc = ns_r.unwrap().to_u64()
    if r.remaining() < nsrc * 4:
        return Err("IGMPv3q: truncated sources")
    var sources: [Ipv4Addr] = []
    var i: u64 = 0
    while i < nsrc:
        val sr = r.read_u32()
        if sr.is_err():
            return Err("IGMPv3q: read source")
        sources.push(Ipv4Addr.from_u32(sr.unwrap()))
        i = i + 1
    Ok(IgmpV3Query(
        type_: t_r.unwrap(),
        max_resp_code: mr_r.unwrap(),
        checksum: ck_r.unwrap(),
        group: Ipv4Addr.from_u32(g_r.unwrap()),
        flags: fl_r.unwrap(),
        qqic: qq_r.unwrap(),
        num_sources: ns_r.unwrap(),
        sources: sources
    ))

fn igmpv3_query_build(q: IgmpV3Query) -> [u8]:
    """Serialize an IGMPv3 Query."""
    var w = ByteWriter.new()
    w.write_u8(q.type_)
    w.write_u8(q.max_resp_code)
    w.write_u16(q.checksum)
    w.write_bytes(q.group.to_bytes())
    w.write_u8(q.flags)
    w.write_u8(q.qqic)
    w.write_u16(q.num_sources)
    var i: u64 = 0
    while i < q.sources.len():
        w.write_bytes(q.sources[i].to_bytes())
        i = i + 1
    w.to_bytes()

# ============================================================================
# GroupRecord build helper (used by both IGMP and MLD encoders)
# ============================================================================

fn igmp_group_record_build(rec: GroupRecord) -> [u8]:
    """Serialize one GroupRecord."""
    var w = ByteWriter.new()
    w.write_u8(rec.record_type)
    w.write_u8(rec.aux_data_len)
    w.write_u16(rec.num_sources)
    w.write_bytes(ip_addr_to_bytes(rec.multicast))
    var i: u64 = 0
    while i < rec.sources.len():
        w.write_bytes(ip_addr_to_bytes(rec.sources[i]))
        i = i + 1
    var j: u64 = 0
    while j < rec.aux_data.len():
        w.write_u8(rec.aux_data[j])
        j = j + 1
    w.to_bytes()

# ============================================================================
# IGMPv3 Report
# IGMPv3 GroupRecord: record_type(1) aux_data_len(1) num_sources(2)
#                     multicast_v4(4) sources(4*N) aux(4*aux_data_len)
# Parsed inline (not via sub-function) to avoid ByteReader copy-semantics trap.
# ============================================================================

struct IgmpV3Report:
    """IGMPv3 Membership Report (type=0x22, RFC 3376 §4.2)."""
    type_:       u8      # 0x22
    checksum:    u16
    num_records: u16
    records:     [GroupRecord]

fn igmpv3_report_parse(data: [u8]) -> Result<IgmpV3Report, text>:
    """Parse an IGMPv3 Report (8 bytes fixed header + variable records)."""
    if data.len() < 8:
        return Err("IGMPv3 report truncated: need 8 bytes, got {data.len()}")
    var r = ByteReader.new(data)
    val t_r = r.read_u8()
    if t_r.is_err():
        return Err("IGMPv3r: read type")
    val _res1 = r.read_u8()
    if _res1.is_err():
        return Err("IGMPv3r: read reserved1")
    val ck_r = r.read_u16()
    if ck_r.is_err():
        return Err("IGMPv3r: read checksum")
    val _res2 = r.read_u16()
    if _res2.is_err():
        return Err("IGMPv3r: read reserved2")
    val nr_r = r.read_u16()
    if nr_r.is_err():
        return Err("IGMPv3r: read num_records")
    val nrec = nr_r.unwrap().to_u64()
    var records: [GroupRecord] = []
    var i: u64 = 0
    # Parse records inline to keep ByteReader cursor advances in scope.
    while i < nrec:
        val rt_r = r.read_u8()
        if rt_r.is_err():
            return Err("IGMPv3r record{i}: read record_type")
        val adl_r = r.read_u8()
        if adl_r.is_err():
            return Err("IGMPv3r record{i}: read aux_data_len")
        val ns_r = r.read_u16()
        if ns_r.is_err():
            return Err("IGMPv3r record{i}: read num_sources")
        val mc_r = r.read_u32()
        if mc_r.is_err():
            return Err("IGMPv3r record{i}: read multicast")
        val nsrc = ns_r.unwrap().to_u64()
        var sources: [IpAddr] = []
        var j: u64 = 0
        while j < nsrc:
            val sr = r.read_u32()
            if sr.is_err():
                return Err("IGMPv3r record{i} source{j}: truncated")
            sources.push(ip_addr_v4(Ipv4Addr.from_u32(sr.unwrap())))
            j = j + 1
        val adl = adl_r.unwrap().to_u64()
        val aux_bytes = adl * 4
        var aux_data: [u8] = []
        if aux_bytes > 0:
            val ax_r = r.read_bytes(aux_bytes)
            if ax_r.is_err():
                return Err("IGMPv3r record{i}: read aux_data")
            aux_data = ax_r.unwrap()
        records.push(GroupRecord(
            record_type: rt_r.unwrap(),
            aux_data_len: adl_r.unwrap(),
            num_sources: ns_r.unwrap(),
            multicast: ip_addr_v4(Ipv4Addr.from_u32(mc_r.unwrap())),
            sources: sources,
            aux_data: aux_data
        ))
        i = i + 1
    Ok(IgmpV3Report(
        type_: t_r.unwrap(),
        checksum: ck_r.unwrap(),
        num_records: nr_r.unwrap(),
        records: records
    ))

fn igmpv3_report_build(rep: IgmpV3Report) -> [u8]:
    """Serialize an IGMPv3 Report."""
    var w = ByteWriter.new()
    w.write_u8(rep.type_)
    w.write_u8(0)
    w.write_u16(rep.checksum)
    w.write_u16(0)
    w.write_u16(rep.num_records)
    var i: u64 = 0
    while i < rep.records.len():
        val rb = igmp_group_record_build(rep.records[i])
        w.write_bytes(rb)
        i = i + 1
    w.to_bytes()
