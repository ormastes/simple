# SimpleOS Monotonic Clock Service (G13)
#
# Provides monotonic tick-based timekeeping, one-shot alarms, periodic
# timers, and timerfd-style primitives for SimpleOS user-space.
#
# ECS-style internals: entities are alarms; components are stored as
# fields on AlarmEntry. When std.ecs lands, migrate to WorldBase +
# ComponentStore.
#
# TODO(mdsoc+): migrate to std.ecs.{WorldBase, ComponentStore, EntityAllocator,
#               Scheduler, ChangeTracker, for_each} when stdlib lands.

# ============================================================================
# Alarm kind constants
# ============================================================================

val ALARM_ONESHOT: u32 = 0
val ALARM_PERIODIC: u32 = 1
val ALARM_TIMERFD: u32 = 2

# ============================================================================
# Entity — minimal ECS entity handle
# ============================================================================

struct Entity:
    """Opaque handle for an alarm entity in the ClockWorld."""
    id: u64

# ============================================================================
# Components (per MDSOC+ ECS spec)
# ============================================================================

struct Deadline:
    """Monotonic tick at which the alarm fires."""
    ticks: u64

struct Period:
    """0 for one-shot, >0 for periodic."""
    ticks: u64

struct Subscriber:
    """Endpoint to notify when the alarm fires."""
    endpoint_id: u64

struct AlarmKind:
    """ALARM_ONESHOT | ALARM_PERIODIC | ALARM_TIMERFD"""
    kind: u32

# ============================================================================
# AlarmEntry — aggregated ECS row (one entity = one row)
# ============================================================================

struct AlarmEntry:
    """One alarm entity with all component values inlined."""
    entity: Entity
    deadline: Deadline
    period: Period
    subscriber: Subscriber
    kind: AlarmKind
    active: bool

# ============================================================================
# ClockWorld — ECS world for clock/alarm state
# ============================================================================

struct ClockWorld:
    """ECS world that owns all alarm entities and their component data.

    TODO(mdsoc+): split into WorldBase + per-component ComponentStore<T>
    when std.ecs lands.
    """
    alarms: [AlarmEntry]
    next_id: u64

# ============================================================================
# Extern — kernel will wire this later
# ============================================================================

extern fn clock_notify(endpoint_id: u64)

# ============================================================================
# System: sys_fire_due_alarms
#
# Iterates over Deadline components, fires subscribers whose deadline
# has been reached, re-arms periodic alarms, removes one-shots.
# ============================================================================

fn sys_fire_due_alarms(world: ClockWorld, tick: u64) -> ClockWorld:
    """ECS system: fire all alarms whose deadline <= tick.

    One-shots are removed after firing.
    Periodic/timerfd alarms have their deadline advanced by Period.ticks.
    """
    var kept: [AlarmEntry] = []
    for alarm in world.alarms:
        if not alarm.active:
            kept = kept.push(alarm)
        elif tick >= alarm.deadline.ticks:
            clock_notify(alarm.subscriber.endpoint_id)
            if alarm.period.ticks > 0:
                val new_deadline = Deadline(ticks: alarm.deadline.ticks + alarm.period.ticks)
                val updated = AlarmEntry(
                    entity: alarm.entity,
                    deadline: new_deadline,
                    period: alarm.period,
                    subscriber: alarm.subscriber,
                    kind: alarm.kind,
                    active: true
                )
                kept = kept.push(updated)
            # one-shots drop out (not pushed to kept)
        else:
            kept = kept.push(alarm)
    ClockWorld(alarms: kept, next_id: world.next_id)

# ============================================================================
# ClockService — public API
# ============================================================================

class ClockService:
    """Monotonic clock service with alarm and timerfd support.

    Owns a ClockWorld (ECS world) internally. The public API is a thin
    shell over ECS system calls.
    """
    world: ClockWorld
    now: u64
    started: bool

impl ClockService:
    static fn new() -> ClockService:
        """Create a fresh ClockService with now=0."""
        ClockService(
            world: ClockWorld(alarms: [], next_id: 1),
            now: 0,
            started: false
        )

    me clock_service_tick() -> u64:
        """Advance now by 1, run sys_fire_due_alarms, return new now."""
        self.now = self.now + 1
        self.world = sys_fire_due_alarms(self.world, self.now)
        self.started = true
        self.now

    fn clock_service_now() -> u64:
        """Return current monotonic tick."""
        self.now

    me clock_arm_oneshot(deadline: u64, subscriber: u64) -> Entity:
        """Arm a one-shot alarm that fires once at the given deadline tick."""
        val eid = Entity(id: self.world.next_id)
        val entry = AlarmEntry(
            entity: eid,
            deadline: Deadline(ticks: deadline),
            period: Period(ticks: 0),
            subscriber: Subscriber(endpoint_id: subscriber),
            kind: AlarmKind(kind: ALARM_ONESHOT),
            active: true
        )
        self.world = ClockWorld(
            alarms: self.world.alarms.push(entry),
            next_id: self.world.next_id + 1
        )
        eid

    me clock_arm_periodic(period: u64, first_deadline: u64, subscriber: u64) -> Entity:
        """Arm a periodic alarm that fires every `period` ticks starting at first_deadline."""
        val eid = Entity(id: self.world.next_id)
        val entry = AlarmEntry(
            entity: eid,
            deadline: Deadline(ticks: first_deadline),
            period: Period(ticks: period),
            subscriber: Subscriber(endpoint_id: subscriber),
            kind: AlarmKind(kind: ALARM_PERIODIC),
            active: true
        )
        self.world = ClockWorld(
            alarms: self.world.alarms.push(entry),
            next_id: self.world.next_id + 1
        )
        eid

    me clock_arm_timerfd(period: u64, first_deadline: u64, subscriber: u64) -> Entity:
        """Arm a timerfd-style alarm (periodic, distinguishable by AlarmKind.TIMERFD)."""
        val eid = Entity(id: self.world.next_id)
        val entry = AlarmEntry(
            entity: eid,
            deadline: Deadline(ticks: first_deadline),
            period: Period(ticks: period),
            subscriber: Subscriber(endpoint_id: subscriber),
            kind: AlarmKind(kind: ALARM_TIMERFD),
            active: true
        )
        self.world = ClockWorld(
            alarms: self.world.alarms.push(entry),
            next_id: self.world.next_id + 1
        )
        eid

    me clock_cancel(alarm: Entity) -> bool:
        """Deactivate an alarm by entity id. Returns true if found."""
        var found = false
        var updated: [AlarmEntry] = []
        for entry in self.world.alarms:
            if entry.entity.id == alarm.id:
                found = true
                val cancelled = AlarmEntry(
                    entity: entry.entity,
                    deadline: entry.deadline,
                    period: entry.period,
                    subscriber: entry.subscriber,
                    kind: entry.kind,
                    active: false
                )
                updated = updated.push(cancelled)
            else:
                updated = updated.push(entry)
        self.world = ClockWorld(alarms: updated, next_id: self.world.next_id)
        found

    fn clock_pending_count() -> i32:
        """Return the count of active (not yet cancelled) alarms."""
        var count: i32 = 0
        for entry in self.world.alarms:
            if entry.active:
                count = count + 1
        count
