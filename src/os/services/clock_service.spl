# SimpleOS Monotonic Clock Service (G13)
#
# Provides monotonic tick-based timekeeping, one-shot alarms, periodic
# timers, and timerfd-style primitives for SimpleOS user-space.
#
# ECS internals: entities are alarms; components live in per-type
# ComponentStore<T> columns owned by ClockWorld.

use std.ecs.entity.{Entity, EntityAllocator}
use std.ecs.component_store.{ComponentStore}
use std.ecs.world.{WorldBase}

# ============================================================================
# Alarm kind constants
# ============================================================================

val ALARM_ONESHOT: u32 = 0
val ALARM_PERIODIC: u32 = 1
val ALARM_TIMERFD: u32 = 2

# ============================================================================
# Components (per MDSOC+ ECS spec)
# ============================================================================

struct Deadline:
    """Monotonic tick at which the alarm fires."""
    ticks: u64

struct Period:
    """0 for one-shot, >0 for periodic."""
    ticks: u64

struct Subscriber:
    """Endpoint to notify when the alarm fires."""
    endpoint_id: u64

struct AlarmKind:
    """ALARM_ONESHOT | ALARM_PERIODIC | ALARM_TIMERFD"""
    kind: u32

# ============================================================================
# ClockWorld — ECS world for clock/alarm state
# ============================================================================

struct ClockWorld:
    """ECS world that owns all alarm entities and their component data."""
    base: WorldBase
    deadlines:   ComponentStore<Deadline>
    periods:     ComponentStore<Period>
    subscribers: ComponentStore<Subscriber>
    kinds:       ComponentStore<AlarmKind>

# ============================================================================
# Extern — kernel will wire this later
# ============================================================================

extern fn clock_notify(endpoint_id: u64)

# ============================================================================
# System: sys_fire_due_alarms
#
# Two-pass: first collect entities to fire, then mutate stores.
# Periodic/timerfd alarms have their deadline advanced; one-shots are removed.
# ============================================================================

fn sys_fire_due_alarms(world: ClockWorld, tick: u64):
    """ECS system: fire all alarms whose deadline <= tick.

    One-shots are removed after firing (despawned from all stores).
    Periodic/timerfd alarms have their deadline advanced by Period.ticks.
    Uses two-pass iteration to avoid swap-with-last aliasing during removal.
    """
    val count = world.deadlines.len()

    # Pass 1: collect entity ids and their deadline data
    var to_fire: [i32] = []
    var i = 0
    while i < count:
        val eid_raw = world.deadlines.entity_at(i)
        val e = Entity(id: eid_raw, generation: 1)
        val slot = world.deadlines.get_slot(e)
        if slot >= 0:
            val dl = world.deadlines.dense[slot]
            if tick >= dl.ticks:
                to_fire = to_fire.push(eid_raw)
        i = i + 1

    # Pass 2: notify and update/remove
    for eid_raw in to_fire:
        val e = Entity(id: eid_raw, generation: 1)
        val sub_slot = world.subscribers.get_slot(e)
        if sub_slot >= 0:
            clock_notify(world.subscribers.dense[sub_slot].endpoint_id)
        val period_slot = world.periods.get_slot(e)
        val is_periodic = period_slot >= 0 and world.periods.dense[period_slot].ticks > 0
        if is_periodic:
            # Advance deadline; keep entity alive
            val dl_slot = world.deadlines.get_slot(e)
            if dl_slot >= 0:
                val old_ticks = world.deadlines.dense[dl_slot].ticks
                val period_ticks = world.periods.dense[period_slot].ticks
                world.deadlines.insert(e, Deadline(ticks: old_ticks + period_ticks), world.base.now())
        else:
            # One-shot: remove from all stores and despawn
            world.deadlines.remove(e)
            world.periods.remove(e)
            world.subscribers.remove(e)
            world.kinds.remove(e)
            world.base.despawn(e)

# ============================================================================
# ClockService — public API
# ============================================================================

class ClockService:
    """Monotonic clock service with alarm and timerfd support.

    Owns a ClockWorld (ECS world) internally. The public API is a thin
    shell over ECS system calls.
    """
    world: ClockWorld
    now: u64
    started: bool

impl ClockService:
    static fn new() -> ClockService:
        """Create a fresh ClockService with now=0."""
        ClockService(
            world: ClockWorld(
                base:        WorldBase.new(),
                deadlines:   ComponentStore.new(),
                periods:     ComponentStore.new(),
                subscribers: ComponentStore.new(),
                kinds:       ComponentStore.new()
            ),
            now: 0,
            started: false
        )

    me clock_service_tick() -> u64:
        """Advance now by 1, run sys_fire_due_alarms, return new now."""
        self.now = self.now + 1
        self.world.base.advance()
        sys_fire_due_alarms(self.world, self.now)
        self.started = true
        self.now

    fn clock_service_now() -> u64:
        """Return current monotonic tick."""
        self.now

    me clock_arm_oneshot(deadline: u64, subscriber: u64) -> Entity:
        """Arm a one-shot alarm that fires once at the given deadline tick."""
        val e = self.world.base.spawn()
        val ecs_tick = self.world.base.now()
        self.world.deadlines.insert(e,   Deadline(ticks: deadline),           ecs_tick)
        self.world.periods.insert(e,     Period(ticks: 0),                    ecs_tick)
        self.world.subscribers.insert(e, Subscriber(endpoint_id: subscriber), ecs_tick)
        self.world.kinds.insert(e,       AlarmKind(kind: ALARM_ONESHOT),      ecs_tick)
        e

    me clock_arm_periodic(period: u64, first_deadline: u64, subscriber: u64) -> Entity:
        """Arm a periodic alarm that fires every `period` ticks starting at first_deadline."""
        val e = self.world.base.spawn()
        val ecs_tick = self.world.base.now()
        self.world.deadlines.insert(e,   Deadline(ticks: first_deadline),     ecs_tick)
        self.world.periods.insert(e,     Period(ticks: period),               ecs_tick)
        self.world.subscribers.insert(e, Subscriber(endpoint_id: subscriber), ecs_tick)
        self.world.kinds.insert(e,       AlarmKind(kind: ALARM_PERIODIC),     ecs_tick)
        e

    me clock_arm_timerfd(period: u64, first_deadline: u64, subscriber: u64) -> Entity:
        """Arm a timerfd-style alarm (periodic, distinguishable by AlarmKind.TIMERFD)."""
        val e = self.world.base.spawn()
        val ecs_tick = self.world.base.now()
        self.world.deadlines.insert(e,   Deadline(ticks: first_deadline),     ecs_tick)
        self.world.periods.insert(e,     Period(ticks: period),               ecs_tick)
        self.world.subscribers.insert(e, Subscriber(endpoint_id: subscriber), ecs_tick)
        self.world.kinds.insert(e,       AlarmKind(kind: ALARM_TIMERFD),      ecs_tick)
        e

    me clock_cancel(alarm: Entity) -> bool:
        """Remove an alarm from all component stores and despawn its entity.
        Returns true if the entity was live (found in deadlines store)."""
        if not self.world.deadlines.contains(alarm):
            return false
        self.world.deadlines.remove(alarm)
        self.world.periods.remove(alarm)
        self.world.subscribers.remove(alarm)
        self.world.kinds.remove(alarm)
        self.world.base.despawn(alarm)
        true

    fn clock_pending_count() -> i32:
        """Return the count of active (not yet cancelled) alarms."""
        self.world.deadlines.len()
