# Grant Broker — Exokernel Lane 4
# MDSOC: feature dimension, device layer
#
# Central broker for dispatching resource grants to driver capsules
# and providing raw-device passthrough for userspace drivers.
#
# Depends on: resource_grant.spl (BarGrant, IrqGrant, DmaGrant types)
# ============================================================================

# ============================================================================
# GrantBroker — Central Resource Dispatch Broker
# Flat layout: max 4 active driver grant sets
# ============================================================================

class GrantBroker:
    """Central broker that tracks active resource grants across drivers."""
    next_token: i64
    # Slot 0
    g0_name: text
    g0_pid: i64
    g0_active: bool
    g0_bar_count: i64
    g0_irq_count: i64
    g0_dma_count: i64
    # Slot 1
    g1_name: text
    g1_pid: i64
    g1_active: bool
    g1_bar_count: i64
    g1_irq_count: i64
    g1_dma_count: i64
    # Slot 2
    g2_name: text
    g2_pid: i64
    g2_active: bool
    g2_bar_count: i64
    g2_irq_count: i64
    g2_dma_count: i64
    # Slot 3
    g3_name: text
    g3_pid: i64
    g3_active: bool
    g3_bar_count: i64
    g3_irq_count: i64
    g3_dma_count: i64

    me register_driver(name: text, pid: i64) -> text:
        """Register a driver for grant tracking. Returns "" or "broker full"."""
        if self.g0_active == false:
            self.g0_name = name
            self.g0_pid = pid
            self.g0_active = true
            self.g0_bar_count = 0
            self.g0_irq_count = 0
            self.g0_dma_count = 0
            return ""
        if self.g1_active == false:
            self.g1_name = name
            self.g1_pid = pid
            self.g1_active = true
            self.g1_bar_count = 0
            self.g1_irq_count = 0
            self.g1_dma_count = 0
            return ""
        if self.g2_active == false:
            self.g2_name = name
            self.g2_pid = pid
            self.g2_active = true
            self.g2_bar_count = 0
            self.g2_irq_count = 0
            self.g2_dma_count = 0
            return ""
        if self.g3_active == false:
            self.g3_name = name
            self.g3_pid = pid
            self.g3_active = true
            self.g3_bar_count = 0
            self.g3_irq_count = 0
            self.g3_dma_count = 0
            return ""
        "broker full"

    me grant_bar(name: text, bar: i64) -> i64:
        """Grant a BAR to the named driver. Returns token or 0 if not found."""
        if self.next_token <= 0:
            return 0
        if self.g0_active and self.g0_name == name:
            val tok = self.next_token
            self.next_token = self.next_token + 1
            self.g0_bar_count = self.g0_bar_count + 1
            return tok
        if self.g1_active and self.g1_name == name:
            val tok = self.next_token
            self.next_token = self.next_token + 1
            self.g1_bar_count = self.g1_bar_count + 1
            return tok
        if self.g2_active and self.g2_name == name:
            val tok = self.next_token
            self.next_token = self.next_token + 1
            self.g2_bar_count = self.g2_bar_count + 1
            return tok
        if self.g3_active and self.g3_name == name:
            val tok = self.next_token
            self.next_token = self.next_token + 1
            self.g3_bar_count = self.g3_bar_count + 1
            return tok
        0

    me grant_irq(name: text, irq: i64) -> i64:
        """Grant an IRQ to the named driver. Returns token or 0 if not found."""
        if self.next_token <= 0:
            return 0
        if self.g0_active and self.g0_name == name:
            val tok = self.next_token
            self.next_token = self.next_token + 1
            self.g0_irq_count = self.g0_irq_count + 1
            return tok
        if self.g1_active and self.g1_name == name:
            val tok = self.next_token
            self.next_token = self.next_token + 1
            self.g1_irq_count = self.g1_irq_count + 1
            return tok
        if self.g2_active and self.g2_name == name:
            val tok = self.next_token
            self.next_token = self.next_token + 1
            self.g2_irq_count = self.g2_irq_count + 1
            return tok
        if self.g3_active and self.g3_name == name:
            val tok = self.next_token
            self.next_token = self.next_token + 1
            self.g3_irq_count = self.g3_irq_count + 1
            return tok
        0

    me grant_dma(name: text, size: i64) -> i64:
        """Grant a DMA buffer to the named driver. Returns token or 0."""
        if self.next_token <= 0:
            return 0
        if self.g0_active and self.g0_name == name:
            val tok = self.next_token
            self.next_token = self.next_token + 1
            self.g0_dma_count = self.g0_dma_count + 1
            return tok
        if self.g1_active and self.g1_name == name:
            val tok = self.next_token
            self.next_token = self.next_token + 1
            self.g1_dma_count = self.g1_dma_count + 1
            return tok
        if self.g2_active and self.g2_name == name:
            val tok = self.next_token
            self.next_token = self.next_token + 1
            self.g2_dma_count = self.g2_dma_count + 1
            return tok
        if self.g3_active and self.g3_name == name:
            val tok = self.next_token
            self.next_token = self.next_token + 1
            self.g3_dma_count = self.g3_dma_count + 1
            return tok
        0

    me revoke_driver(name: text) -> i64:
        """Revoke all grants for a driver. Returns total count revoked."""
        if self.g0_active and self.g0_name == name:
            val count = self.g0_bar_count + self.g0_irq_count + self.g0_dma_count
            self.g0_active = false
            self.g0_bar_count = 0
            self.g0_irq_count = 0
            self.g0_dma_count = 0
            return count
        if self.g1_active and self.g1_name == name:
            val count = self.g1_bar_count + self.g1_irq_count + self.g1_dma_count
            self.g1_active = false
            self.g1_bar_count = 0
            self.g1_irq_count = 0
            self.g1_dma_count = 0
            return count
        if self.g2_active and self.g2_name == name:
            val count = self.g2_bar_count + self.g2_irq_count + self.g2_dma_count
            self.g2_active = false
            self.g2_bar_count = 0
            self.g2_irq_count = 0
            self.g2_dma_count = 0
            return count
        if self.g3_active and self.g3_name == name:
            val count = self.g3_bar_count + self.g3_irq_count + self.g3_dma_count
            self.g3_active = false
            self.g3_bar_count = 0
            self.g3_irq_count = 0
            self.g3_dma_count = 0
            return count
        0

    me stats() -> text:
        """Return a summary of all active driver slots in the broker."""
        var active: i64 = 0
        if self.g0_active:
            active = active + 1
        if self.g1_active:
            active = active + 1
        if self.g2_active:
            active = active + 1
        if self.g3_active:
            active = active + 1
        "GrantBroker[active=" + active.to_text() +
            "/4 next_token=" + self.next_token.to_text() + "]"

impl GrantBroker:
    static fn create() -> GrantBroker:
        """Create an empty grant broker with token counter starting at 1."""
        GrantBroker(
            next_token: 1,
            g0_name: "", g0_pid: 0, g0_active: false,
            g0_bar_count: 0, g0_irq_count: 0, g0_dma_count: 0,
            g1_name: "", g1_pid: 0, g1_active: false,
            g1_bar_count: 0, g1_irq_count: 0, g1_dma_count: 0,
            g2_name: "", g2_pid: 0, g2_active: false,
            g2_bar_count: 0, g2_irq_count: 0, g2_dma_count: 0,
            g3_name: "", g3_pid: 0, g3_active: false,
            g3_bar_count: 0, g3_irq_count: 0, g3_dma_count: 0
        )

# ============================================================================
# RawDeviceGrant — Userspace Driver Passthrough
# ============================================================================

class RawDeviceGrant:
    """Full device passthrough grant for a userspace (VFIO-style) driver."""
    pci_bus: i64
    pci_device: i64
    pci_function: i64
    owner_pid: i64
    granted: bool
    bar_tokens: text
    irq_token: i64
    dma_token: i64

    me grant_passthrough(broker_token: i64) -> text:
        """Grant full passthrough access using the broker token."""
        if broker_token <= 0:
            return "error: invalid broker token"
        self.granted = true
        self.irq_token = broker_token
        self.dma_token = broker_token + 1
        self.bar_tokens = broker_token.to_text()
        "passthrough granted tok=" + broker_token.to_text()

    me has_issued_tokens() -> bool:
        self.granted and self.bar_tokens != "" and self.irq_token > 0 and self.dma_token > 0

    me revoke_passthrough() -> text:
        """Revoke passthrough and clear all tokens."""
        self.granted = false
        self.bar_tokens = ""
        self.irq_token = 0
        self.dma_token = 0
        "passthrough revoked"

    me summary() -> text:
        """Return a human-readable summary of this passthrough grant."""
        val state = if self.granted: "granted" else "pending"
        "RawDeviceGrant[" + state +
            " bus=" + self.pci_bus.to_text() +
            " dev=" + self.pci_device.to_text() +
            " fn=" + self.pci_function.to_text() +
            " pid=" + self.owner_pid.to_text() +
            " irq_tok=" + self.irq_token.to_text() +
            " dma_tok=" + self.dma_token.to_text() + "]"

impl RawDeviceGrant:
    static fn request(bus: i64, dev: i64, func: i64, pid: i64) -> RawDeviceGrant:
        """Create a pending raw device passthrough request."""
        RawDeviceGrant(
            pci_bus: bus,
            pci_device: dev,
            pci_function: func,
            owner_pid: pid,
            granted: false,
            bar_tokens: "",
            irq_token: 0,
            dma_token: 0
        )

# ============================================================================
# ExokernelLaneStatus — Lane Readiness Tracker
# ============================================================================

class ExokernelLaneStatus:
    """Tracks readiness of all exokernel lane components."""
    owner: text
    has_contract: bool
    has_tests: bool
    has_docs: bool
    has_reviewer: bool
    bar_ready: bool
    irq_ready: bool
    dma_ready: bool
    iommu_ready: bool
    broker_ready: bool
    broker_token: i64

    me is_ready() -> bool:
        """Return true only if all readiness flags are set."""
        self.has_contract and
        self.has_tests and
        self.has_docs and
        self.has_reviewer and
        self.bar_ready and
        self.irq_ready and
        self.dma_ready and
        self.iommu_ready and
        self.broker_ready and
        self.broker_token > 0

    me report() -> text:
        """Return a formatted readiness report for this exokernel lane."""
        val ready = if self.is_ready(): "READY" else "NOT READY"
        "ExokernelLane[" + ready + " owner=" + self.owner +
            " contract=" + self.has_contract.to_text() +
            " tests=" + self.has_tests.to_text() +
            " docs=" + self.has_docs.to_text() +
            " reviewer=" + self.has_reviewer.to_text() +
            " bar=" + self.bar_ready.to_text() +
            " irq=" + self.irq_ready.to_text() +
            " dma=" + self.dma_ready.to_text() +
            " iommu=" + self.iommu_ready.to_text() +
            " broker=" + self.broker_ready.to_text() +
            " broker_tok=" + self.broker_token.to_text() + "]"

impl ExokernelLaneStatus:
    static fn create() -> ExokernelLaneStatus:
        """Create a blank (all-false) lane status for Lane 4."""
        ExokernelLaneStatus(
            owner: "lane4-exokernel",
            has_contract: false,
            has_tests: false,
            has_docs: false,
            has_reviewer: false,
            bar_ready: false,
            irq_ready: false,
            dma_ready: false,
            iommu_ready: false,
            broker_ready: false,
            broker_token: 0
        )
