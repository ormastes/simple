# NVFS pmap v3 — 88-byte page-map entry (§V3-5.1 of nvfs_design_v3.md).
#
# v3 extends v2 (80 bytes) by 8 bytes.  The flags field moved from 0x2C to 0x30
# to make room for compress_algo (u8) + reserved_algo_pad (u16) + compressed_len (u32).
# Checksum moved from 0x30 to 0x38.
#
# Layout (all fields little-endian):
#
#   offset  size  field
#   0x00    8     logical        (u64)  — logical page number
#   0x08    8     phys           (i64)  — physical arena id (ArenaId)
#   0x10    8     offset         (u64)  — physical byte offset within arena
#   0x18    8     len            (u64)  — page_generation / CoW generation
#   0x20    8     birth_gen      (u64)  — txg when this pointer was first written
#   0x28    1     checksum_algo  (u8)   — ChecksumAlgo tag (see enum below)
#   0x29    1     compress_algo  (u8)   — NEW v3: CompressAlgo tag (0=None,1=LZ4,2=Zstd3)
#   0x2A    2     reserved_algo_pad     — zero-filled
#   0x2C    4     compressed_len (u32)  — NEW v3: byte length of compressed on-disk data
#                                         (0 when compress_algo=None)
#   0x30    4     flags          (u32)  — bit0=blob_pointer, bit1=evicted (v1/v2 bits)
#   0x34    4     reserved_flags_pad    — zero-filled
#   0x38    32    checksum       (u8[32]) — Merkle checksum of target block (left-padded)
#   Total: 88 bytes
#
# Migration: v2 (80-byte) entries are decoded with algo=0 / compressed_len=0.
#   pmap_entry_decode dispatches on bytes.len(): 80 → v2 path, 88 → v3 path.
#   See nvfs_design_v3.md §V3-7.

use std.fs_driver.error.{FsError}

# ---------------------------------------------------------------------------
# ChecksumAlgo tag
# ---------------------------------------------------------------------------

enum ChecksumAlgo:
    """Checksum algorithm tag stored in pmap entry checksum_algo byte.

    CRC32C   — 4 bytes used; fast, adequate for accidental corruption.
    XXHash64 — 8 bytes used; fast, good non-crypto hash.
    SHA256   — 32 bytes used; cryptographic; required for raw-send auth.
    Blake3   — 32 bytes used; default for new volumes; SIMD-friendly.
    """
    CRC32C
    XXHash64
    SHA256
    Blake3

impl ChecksumAlgo:
    fn tag() -> u8:
        """Return the on-disk tag byte for this algorithm."""
        match self:
            case CRC32C:   0
            case XXHash64: 1
            case SHA256:   2
            case Blake3:   3

    static fn from_tag(tag: u8) -> Result<ChecksumAlgo, FsError>:
        """Decode an on-disk tag byte back to a ChecksumAlgo."""
        if tag == 0:
            return Ok(ChecksumAlgo.CRC32C)
        if tag == 1:
            return Ok(ChecksumAlgo.XXHash64)
        if tag == 2:
            return Ok(ChecksumAlgo.SHA256)
        if tag == 3:
            return Ok(ChecksumAlgo.Blake3)
        Err(FsError.InvalidArg)

# ---------------------------------------------------------------------------
# PmapEntry — one 80-byte pmap record
# ---------------------------------------------------------------------------

struct PmapEntry:
    """v3 pmap entry. Exactly 88 bytes on disk (little-endian).

    logical        — logical page number addressed by this entry.
    phys           — arena id (opaque i64) owning the physical backing.
    offset         — byte offset within the arena.
    len            — CoW generation (page_generation from v1; retained).
    birth_gen      — transaction generation when this pointer was first written.
    checksum_algo  — algorithm used to compute checksum (see ChecksumAlgo).
    compress_algo  — NEW v3: compression algorithm (see CompressAlgo in compression.spl).
    compressed_len — NEW v3: byte length of compressed on-disk data (0 when algo=None).
    checksum       — 32-byte Merkle checksum of the compressed bytes (left-padded zeros).

    v2 compatibility: when decoded from an 80-byte buffer, compress_algo=0 and
    compressed_len=0 are synthesized (no compression; §V3-7 migration path).
    """
    logical:        u64
    phys:           i64
    offset:         u64
    len:            u64
    birth_gen:      u64
    checksum_algo:  u8
    compress_algo:  u8    # NEW v3: CompressAlgo tag; 0=None for v2-decoded entries
    compressed_len: u32   # NEW v3: 0 when compress_algo=None
    checksum:       [u8]  # exactly 32 bytes; [u8;32] not yet supported

# ---------------------------------------------------------------------------
# Encode helpers
# ---------------------------------------------------------------------------

fn _put_u64_le(buf: [u8], off: i64, v: u64):
    """Write v as 8 LE bytes into buf starting at off (in-place push to buf slots)."""
    var i = 0
    var x = v
    while i < 8:
        buf[off + i] = (x & 0xFF) as u8
        x = x / 256
        i = i + 1

fn _put_u32_le(buf: [u8], off: i64, v: u32):
    """Write v as 4 LE bytes into buf starting at off."""
    var i = 0
    var x = v
    while i < 4:
        buf[off + i] = (x & 0xFF) as u8
        x = x / 256
        i = i + 1

fn _get_u64_le(buf: [u8], off: i64) -> u64:
    """Read 8 LE bytes from buf starting at off; return u64."""
    var result: u64 = 0
    var shift: u64 = 1
    var i = 0
    while i < 8:
        result = result + (buf[off + i] as u64) * shift
        shift = shift * 256
        i = i + 1
    result

fn _get_u32_le(buf: [u8], off: i64) -> u32:
    """Read 4 LE bytes from buf starting at off; return u32."""
    var result: u32 = 0
    var shift: u32 = 1
    var i = 0
    while i < 4:
        result = result + (buf[off + i] as u32) * shift
        shift = shift * 256
        i = i + 1
    result

# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

fn pmap_entry_encode(entry: PmapEntry) -> [u8]:
    """Serialize entry to an 88-byte little-endian byte buffer (v3 layout).

    checksum must contain at least 32 bytes; excess bytes are ignored.
    If shorter, remaining checksum bytes are zero-padded.

    v3 layout (§V3-5.1):
      0x00  logical (u64)
      0x08  phys    (i64)
      0x10  offset  (u64)
      0x18  len     (u64)
      0x20  birth_gen (u64)
      0x28  checksum_algo (u8)
      0x29  compress_algo (u8)
      0x2A  reserved_algo_pad (u16) = 0
      0x2C  compressed_len (u32)
      0x30  flags (u32) = 0
      0x34  reserved_flags_pad (u32) = 0
      0x38  checksum (u8[32])
    """
    # Build 88-byte buffer pre-filled with zeros.
    var buf: [u8] = []
    var i = 0
    while i < 88:
        buf.push(0)
        i = i + 1

    # 0x00: logical (u64)
    _put_u64_le(buf, 0, entry.logical)
    # 0x08: phys (i64 stored as u64 bit-cast)
    _put_u64_le(buf, 8, entry.phys as u64)
    # 0x10: offset (u64)
    _put_u64_le(buf, 16, entry.offset)
    # 0x18: len / page_generation (u64)
    _put_u64_le(buf, 24, entry.len)
    # 0x20: birth_gen (u64)
    _put_u64_le(buf, 32, entry.birth_gen)
    # 0x28: checksum_algo (u8)
    buf[40] = entry.checksum_algo
    # 0x29: compress_algo (u8)
    buf[41] = entry.compress_algo
    # 0x2A-0x2B: reserved_algo_pad — already zero
    # 0x2C: compressed_len (u32)
    _put_u32_le(buf, 44, entry.compressed_len)
    # 0x30: flags (u32) — always 0 for now
    _put_u32_le(buf, 48, 0)
    # 0x34: reserved_flags_pad — already zero
    # 0x38: checksum (32 bytes)
    var ci = 0
    while ci < 32:
        if ci < entry.checksum.len():
            buf[56 + ci] = entry.checksum[ci]
        ci = ci + 1

    buf

fn pmap_entry_decode(bytes: [u8]) -> Result<PmapEntry, FsError>:
    """Deserialize a PmapEntry from an 80-byte (v2) or 88-byte (v3) buffer.

    v2 (80 bytes): checksum at 0x30 (offset 48); compress_algo=0, compressed_len=0 synthesized.
    v3 (88 bytes): compress_algo at 0x29, compressed_len at 0x2C, checksum at 0x38 (offset 56).

    Returns Err(InvalidArg) if bytes.len() < 80.
    Returns Err(Corrupt) if checksum_algo tag is unrecognised.

    Migration path (§V3-7): reading a v2 on-disk entry with a v3 decoder yields
    compress_algo=0 (None) and compressed_len=0 — identical semantics to uncompressed.
    """
    val buf_len = bytes.len() as i64
    if buf_len < 80:
        return Err(FsError.InvalidArg)

    val logical   = _get_u64_le(bytes, 0)
    val phys_raw  = _get_u64_le(bytes, 8)
    val offset    = _get_u64_le(bytes, 16)
    val len       = _get_u64_le(bytes, 24)
    val birth_gen = _get_u64_le(bytes, 32)
    val algo_tag  = bytes[40]

    # Validate checksum algo tag
    val _algo_check = ChecksumAlgo.from_tag(algo_tag)?

    if buf_len >= 88:
        # v3 layout: compress_algo at 0x29, compressed_len at 0x2C, checksum at 0x38.
        val compress_algo  = bytes[41]
        val compressed_len = _get_u32_le(bytes, 44)
        # flags at 0x30 (offset 48) — read but not yet exposed
        var checksum: [u8] = []
        var ci = 0
        while ci < 32:
            checksum.push(bytes[56 + ci])
            ci = ci + 1
        return Ok(PmapEntry(
            logical:        logical,
            phys:           phys_raw as i64,
            offset:         offset,
            len:            len,
            birth_gen:      birth_gen,
            checksum_algo:  algo_tag,
            compress_algo:  compress_algo,
            compressed_len: compressed_len,
            checksum:       checksum
        ))

    # v2 layout (80 bytes): checksum at 0x30 (offset 48); synthesize v3 fields.
    # bytes[41..43] reserved — ignored on read
    # bytes[44..47] flags — not yet exposed
    var checksum2: [u8] = []
    var ci2 = 0
    while ci2 < 32:
        checksum2.push(bytes[48 + ci2])
        ci2 = ci2 + 1
    Ok(PmapEntry(
        logical:        logical,
        phys:           phys_raw as i64,
        offset:         offset,
        len:            len,
        birth_gen:      birth_gen,
        checksum_algo:  algo_tag,
        compress_algo:  0,   # v2 → v3 migration: no compression
        compressed_len: 0,
        checksum:       checksum2
    ))

fn pmap_entry_verify(entry: PmapEntry, data: [u8]) -> bool:
    """Recompute checksum of data and compare with entry.checksum.

    Returns true if the stored checksum matches the recomputed one.
    For CRC32C and XXHash64, only the first N bytes of the 32-byte field
    are significant; the rest are expected to be zero-padded.

    N1 implementation: uses the same lightweight polynomial used by
    superblock._crc_of — not the real CRC32C. A real CRC32C/Blake3
    implementation will replace this in N2.
    """
    val stored = entry.checksum
    if stored.len() < 32:
        return false

    # Recompute: sum all data bytes modulo 2^32, store as 4-byte LE in slot [28..31].
    var acc: u64 = 0
    var di = 0
    while di < data.len():
        acc = (acc + data[di] as u64) % 0xFFFFFFFF
        di = di + 1

    # CRC32C / generic: compare only last 4 bytes of checksum field.
    val algo_tag = entry.checksum_algo
    # All algo styles: write result into bytes [28..31] and compare.
    val b0 = (acc & 0xFF) as u8
    val b1 = ((acc / 256) & 0xFF) as u8
    val b2 = ((acc / 65536) & 0xFF) as u8
    val b3 = ((acc / 16777216) & 0xFF) as u8

    # For CRC32C (tag=0): only last 4 bytes matter; first 28 must be zero.
    if algo_tag == 0:
        var ok = true
        var pi = 0
        while pi < 28:
            if stored[pi] != 0:
                ok = false
            pi = pi + 1
        if (not ok):
            return false
        return (stored[28] == b0 and stored[29] == b1 and stored[30] == b2 and stored[31] == b3)

    # For other algos (XXHash64, SHA256, Blake3): full 32-byte compare.
    # N1: we only populate bytes 28-31; bytes 0-27 must be zero.
    var ok2 = true
    var pi2 = 0
    while pi2 < 28:
        if stored[pi2] != 0:
            ok2 = false
        pi2 = pi2 + 1
    if (not ok2):
        return false
    (stored[28] == b0 and stored[29] == b1 and stored[30] == b2 and stored[31] == b3)

fn pmap_entry_checksum_for(data: [u8]) -> [u8]:
    """Compute the N1 CRC32C-style checksum of data; returns 32-byte left-padded buffer.

    Helper used by tests and the driver to build a PmapEntry with a valid checksum.
    """
    var acc: u64 = 0
    var di = 0
    while di < data.len():
        acc = (acc + data[di] as u64) % 0xFFFFFFFF
        di = di + 1

    val b0 = (acc & 0xFF) as u8
    val b1 = ((acc / 256) & 0xFF) as u8
    val b2 = ((acc / 65536) & 0xFF) as u8
    val b3 = ((acc / 16777216) & 0xFF) as u8

    var out: [u8] = []
    var i = 0
    while i < 28:
        out.push(0)
        i = i + 1
    out.push(b0)
    out.push(b1)
    out.push(b2)
    out.push(b3)
    out
