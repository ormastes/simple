"""VfsAppRead — VFS read proof model for tool apps.

Models the vfs-app-read:ok serial marker evidence for each tool app at
/sys/apps/<name>. Source must be generic-vfs (not resident-manifest fallback).
MDSOC: feature dimension, fs_apps layer.
"""

pub class VfsReadProof:
    app_id: text
    source: text
    path: text
    bytes_read: i64
    emitted: bool

    static fn create(app: text) -> VfsReadProof:
        VfsReadProof(
            app_id: app,
            source: "generic-vfs",
            path: "/sys/apps/" + app,
            bytes_read: 0,
            emitted: false
        )

    static fn resident_fallback(app: text) -> VfsReadProof:
        VfsReadProof(
            app_id: app,
            source: "resident-manifest",
            path: "/sys/apps/" + app,
            bytes_read: 0,
            emitted: false
        )

    me record_read(sz: i64) -> VfsReadProof:
        self.bytes_read = sz
        self.emitted = true
        self

    me is_generic_vfs() -> bool:
        self.source == "generic-vfs"

    me is_resident_fallback() -> bool:
        self.source == "resident-manifest"

    me is_valid_proof() -> bool:
        self.emitted and self.is_generic_vfs() and self.bytes_read > 0

    me serial_marker() -> text:
        "[desktop-e2e] vfs-app-read:ok source=" + self.source + " path=" + self.path + " bytes=" + self.bytes_read.to_text()

pub class VfsProofSet:
    count: i64
    p0_app: text
    p0_ok: bool
    p1_app: text
    p1_ok: bool
    p2_app: text
    p2_ok: bool
    p3_app: text
    p3_ok: bool
    p4_app: text
    p4_ok: bool
    p5_app: text
    p5_ok: bool

    static fn create() -> VfsProofSet:
        VfsProofSet(
            count: 0,
            p0_app: "", p0_ok: false,
            p1_app: "", p1_ok: false,
            p2_app: "", p2_ok: false,
            p3_app: "", p3_ok: false,
            p4_app: "", p4_ok: false,
            p5_app: "", p5_ok: false
        )

    me record(proof: VfsReadProof) -> i64:
        val ok = proof.is_valid_proof()
        if self.count == 0:
            self.p0_app = proof.app_id
            self.p0_ok = ok
        if self.count == 1:
            self.p1_app = proof.app_id
            self.p1_ok = ok
        if self.count == 2:
            self.p2_app = proof.app_id
            self.p2_ok = ok
        if self.count == 3:
            self.p3_app = proof.app_id
            self.p3_ok = ok
        if self.count == 4:
            self.p4_app = proof.app_id
            self.p4_ok = ok
        if self.count == 5:
            self.p5_app = proof.app_id
            self.p5_ok = ok
        self.count = self.count + 1
        self.count

    me all_ok() -> bool:
        self.p0_ok and self.p1_ok and self.p2_ok and self.p3_ok and self.p4_ok and self.p5_ok

    me ok_count() -> i64:
        var n = 0
        if self.p0_ok: n = n + 1
        if self.p1_ok: n = n + 1
        if self.p2_ok: n = n + 1
        if self.p3_ok: n = n + 1
        if self.p4_ok: n = n + 1
        if self.p5_ok: n = n + 1
        n
