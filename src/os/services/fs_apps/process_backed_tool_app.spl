"""ProcessBackedToolApp — process-backed launch proof model for tool apps.

Models the process-backed:ok serial marker evidence for each tool app, plus
the specialized proofs required for simple_browser (WM/render) and for
llvm/rust (toolchain-launch:ok).
MDSOC: feature dimension, fs_apps layer.
"""

pub class ProcessBackedProof:
    app_id: text
    pid: i64
    emitted: bool
    is_process_backed: bool

    static fn create(app: text) -> ProcessBackedProof:
        ProcessBackedProof(
            app_id: app,
            pid: 0,
            emitted: false,
            is_process_backed: false
        )

    me record_launch(pid_val: i64) -> ProcessBackedProof:
        self.pid = pid_val
        self.emitted = true
        self.is_process_backed = true
        self

    me is_valid_proof() -> bool:
        self.emitted and self.is_process_backed and self.pid > 0

    me serial_marker() -> text:
        "[desktop-e2e] process-backed:ok app=" + self.app_id + " pid=" + self.pid.to_text()

pub class BrowserProof:
    app_id: text
    pid: i64
    wm_owner_ok: bool
    render_proof_ok: bool
    page_rendered_ok: bool

    static fn create() -> BrowserProof:
        BrowserProof(
            app_id: "simple_browser",
            pid: 0,
            wm_owner_ok: false,
            render_proof_ok: false,
            page_rendered_ok: false
        )

    me record_wm_owner(pid_val: i64) -> BrowserProof:
        self.pid = pid_val
        self.wm_owner_ok = true
        self

    me record_render_proof() -> BrowserProof:
        self.render_proof_ok = true
        self

    me record_page_rendered() -> BrowserProof:
        self.page_rendered_ok = true
        self

    me is_fully_proven() -> bool:
        self.wm_owner_ok and self.render_proof_ok and self.page_rendered_ok

    me wm_marker() -> text:
        "[desktop-e2e] wm-owner:ok app=simple_browser pid=" + self.pid.to_text()

    me render_marker() -> text:
        "[desktop-e2e] render-proof:ok app=simple_browser pid=" + self.pid.to_text()

pub class ToolchainProof:
    app_id: text
    mode: text
    lane: text
    status: text
    tool_path: text
    emitted: bool

    static fn llvm_native_wrapper() -> ToolchainProof:
        ToolchainProof(
            app_id: "llvm",
            mode: "native-wrapper",
            lane: "x86_64-simpleos",
            status: "guest-exec",
            tool_path: "/usr/bin/clang",
            emitted: false
        )

    static fn rust_native_wrapper() -> ToolchainProof:
        ToolchainProof(
            app_id: "rust",
            mode: "native-wrapper",
            lane: "x86_64-simpleos",
            status: "report-and-gate",
            tool_path: "/usr/bin/rustc",
            emitted: false
        )

    me record_launch() -> ToolchainProof:
        self.emitted = true
        self

    me is_valid_proof() -> bool:
        self.emitted and self.mode == "native-wrapper"

    me serial_marker() -> text:
        "[desktop-e2e] toolchain-launch:ok app=" + self.app_id + " mode=" + self.mode + " lane=" + self.lane + " status=" + self.status + " tool=" + self.tool_path
