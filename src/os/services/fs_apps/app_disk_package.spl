"""AppDiskPackage — disk packaging and FAT32 alias model for tool apps.

Models the on-disk presence of a tool app under /sys/apps/<name> including
the canonical path, .smf companion, and FAT32 short-name alias resolution.
MDSOC: feature dimension, fs_apps layer.
"""

pub class AppDiskPackage:
    canonical_name: text
    canonical_path: text
    smf_path: text
    fat32_alias: text
    on_disk: bool
    smf_present: bool

    static fn create(name: text, alias: text) -> AppDiskPackage:
        AppDiskPackage(
            canonical_name: name,
            canonical_path: "/sys/apps/" + name,
            smf_path: "/sys/apps/" + name + ".smf",
            fat32_alias: alias,
            on_disk: false,
            smf_present: false
        )

    me mark_on_disk() -> AppDiskPackage:
        self.on_disk = true
        self

    me mark_smf_present() -> AppDiskPackage:
        self.smf_present = true
        self

    me is_fully_packaged() -> bool:
        self.on_disk and self.smf_present

    me alias_resolves_to_canonical() -> bool:
        self.fat32_alias != "" and self.on_disk

    me canonical_identity() -> text:
        self.canonical_path

pub fn make_simple_browser_package() -> AppDiskPackage:
    AppDiskPackage.create("simple_browser", "sbrowser")

pub fn make_simple_compiler_package() -> AppDiskPackage:
    AppDiskPackage.create("simple_compiler", "scompiler")

pub fn make_simple_interpreter_package() -> AppDiskPackage:
    AppDiskPackage.create("simple_interpreter", "sinterp")

pub fn make_simple_loader_package() -> AppDiskPackage:
    AppDiskPackage.create("simple_loader", "sloader")

pub fn make_llvm_package() -> AppDiskPackage:
    AppDiskPackage.create("llvm", "llvm")

pub fn make_rust_package() -> AppDiskPackage:
    AppDiskPackage.create("rust", "rust")
