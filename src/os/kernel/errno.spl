# SimpleOS kernel errno values
#
# Kernel, service, and sosix layers use these numeric ABI status values
# directly. The POSIX compatibility layer may re-export them, but lower
# SimpleOS layers must not import os.posix just to return ABI errors.

val ESUCCESS: i32 = 0
val EPERM: i32 = 1
val ENOENT: i32 = 2
val ESRCH: i32 = 3
val EINTR: i32 = 4
val EIO: i32 = 5
val ENXIO: i32 = 6
val E2BIG: i32 = 7
val ENOEXEC: i32 = 8
val EBADF: i32 = 9
val ECHILD: i32 = 10
val EAGAIN: i32 = 11
val ENOMEM: i32 = 12
val EACCES: i32 = 13
val EFAULT: i32 = 14
val EBUSY: i32 = 16
val EEXIST: i32 = 17
val EXDEV: i32 = 18
val ENODEV: i32 = 19
val ENOTDIR: i32 = 20
val EISDIR: i32 = 21
val EINVAL: i32 = 22
val ENFILE: i32 = 23
val EMFILE: i32 = 24
val ENOTTY: i32 = 25
val EFBIG: i32 = 27
val ENOSPC: i32 = 28
val ESPIPE: i32 = 29
val EROFS: i32 = 30
val EPIPE: i32 = 32
val ERANGE: i32 = 34
val ENAMETOOLONG: i32 = 36
val ENOSYS: i32 = 38
val ENOTEMPTY: i32 = 39
val ELOOP: i32 = 40
val ENOMSG: i32 = 42
val ENOTSOCK: i32 = 88
val EPROTONOSUPPORT: i32 = 93
val EAFNOSUPPORT: i32 = 97
val EADDRINUSE: i32 = 98
val ENETUNREACH: i32 = 101
val ECONNRESET: i32 = 104
val ENOTCONN: i32 = 107
val ETIMEDOUT: i32 = 110
val ECONNREFUSED: i32 = 111
val EINPROGRESS: i32 = 115

val EWOULDBLOCK: i32 = 11
