# ---------------------------------------------------------------------------
# Module-level singletons — populated once at boot by shim_init().
# No get_global_* accessors exist yet in the kernel; these vars serve that
# role for the shim layer.  Reentrancy: safe for single-core baremetal;
# multi-core will need spinlocks (Wave 10E).
# ---------------------------------------------------------------------------
var g_shim_scheduler: Scheduler = Scheduler.new_bootstrap()
var g_shim_ipc: IpcManager = IpcManager.new()
var g_shim_klog: KernelLog = KernelLog.new(256)

# ---------------------------------------------------------------------------
# DCE keepalive: force the compiler to retain all spl_handle_* functions
# even though they're only reached from C code via the weak-override link.
# Without this, --entry-closure DCE drops the whole file.
# ---------------------------------------------------------------------------
@allow(primitive_api)
fn _shim_keepalive() -> u64:
    """Returns the sum of function addresses for every spl_handle_* exported
    by this module. The function itself is never called at runtime — we just
    want the compiler to treat these functions as reachable from shim_init."""
    var total: u64 = 0
    total = total + (spl_handle_debug_write as u64)
    total = total + (spl_handle_exit as u64)
    total = total + (spl_handle_yield as u64)
    total = total + (spl_handle_spawn as u64)
    total = total + (spl_handle_wait as u64)
    total = total + (spl_handle_getpid as u64)
    total = total + (spl_handle_list_tasks as u64)
    total = total + (spl_handle_get_task_info as u64)
    total = total + (spl_handle_signal as u64)
    total = total + (spl_handle_set_priority as u64)
    total = total + (spl_handle_get_parent_pid as u64)
    total = total + (spl_handle_mmap as u64)
    total = total + (spl_handle_munmap as u64)
    total = total + (spl_handle_mprotect as u64)
    total = total + (spl_handle_spawn_binary as u64)
    total = total + (spl_handle_enter_user_blocking as u64)
    total = total + (spl_handle_ipc_send as u64)
    total = total + (spl_handle_ipc_recv as u64)
    total = total + (spl_handle_ipc_create_port as u64)
    total = total + (spl_handle_ipc_connect as u64)
    total = total + (spl_handle_notification_create as u64)
    total = total + (spl_handle_notification_signal as u64)
    total = total + (spl_handle_notification_wait as u64)
    total = total + (spl_handle_notification_poll as u64)
    total = total + (spl_handle_notification_destroy as u64)
    total = total + (spl_handle_notification_wait_any as u64)
    total = total + (spl_handle_file_open as u64)
    total = total + (spl_handle_file_read as u64)
    total = total + (spl_handle_file_write as u64)
    total = total + (spl_handle_file_close as u64)
    total = total + (spl_handle_file_stat as u64)
    total = total + (spl_handle_file_mkdir as u64)
    total = total + (spl_handle_file_readdir as u64)
    total = total + (spl_handle_mount as u64)
    total = total + (spl_handle_unmount as u64)
    total = total + (spl_handle_unlink as u64)
    total = total + (spl_handle_pledge as u64)
    total = total + (spl_handle_unveil as u64)
    total = total + (spl_handle_cap_grant as u64)
    total = total + (spl_handle_ftruncate as u64)
    total = total + (spl_handle_rename as u64)
    total = total + (spl_handle_rmdir as u64)
    total = total + (spl_handle_lseek as u64)
    total = total + (spl_handle_getcwd as u64)
    total = total + (spl_handle_chdir as u64)
    total = total + (spl_handle_clock_gettime as u64)
    total = total + (spl_handle_sleep as u64)
    total = total + (spl_handle_fork as u64)
    total = total + (spl_handle_exec as u64)
    total = total + (spl_handle_waitpid as u64)
    total = total + (spl_handle_pipe as u64)
    total = total + (spl_handle_dup2 as u64)
    total = total + (spl_handle_dup as u64)
    total = total + (spl_handle_poll as u64)
    total = total + (spl_handle_fcntl as u64)
    total = total + (spl_handle_net_socket as u64)
    total = total + (spl_handle_net_bind as u64)
    total = total + (spl_handle_net_listen as u64)
    total = total + (spl_handle_net_connect as u64)
    total = total + (spl_handle_net_accept as u64)
    total = total + (spl_handle_net_send_to as u64)
    total = total + (spl_handle_net_recv_from as u64)
    total = total + (spl_handle_net_if_config as u64)
    total = total + (spl_handle_dev_enumerate as u64)
    total = total + (spl_handle_dev_get_info as u64)
    total = total + (spl_handle_map_bar as u64)
    total = total + (spl_handle_alloc_dma as u64)
    total = total + (spl_handle_free_dma as u64)
    total = total + (spl_handle_log_write as u64)
    total = total + (spl_handle_log_read as u64)
    total = total + (spl_handle_sysinfo as u64)
    total = total + (spl_handle_get_hostname as u64)
    total = total + (spl_handle_set_hostname as u64)
    total = total + (spl_handle_device_grant as u64)
    total = total + (spl_handle_privctl as u64)
    total = total + (spl_handle_mem_grant as u64)
    total = total + (spl_handle_mem_revoke as u64)
    total = total + (spl_handle_safecopy_from as u64)
    total = total + (spl_handle_safecopy_to as u64)
    total = total + (spl_handle_brk as u64)
    total = total + (spl_handle_system_reboot as u64)
    total = total + (spl_handle_sys_mmap as u64)
    total = total + (spl_handle_sys_munmap as u64)
    total = total + (spl_handle_schedule as u64)
    total = total + (spl_handle_schedctl as u64)
    total

@export("C", name: "shim_init")
fn shim_init(sched: Scheduler, ipc: IpcManager, klog: KernelLog):
    """Boot-time initializer.  Call once before any SYSCALL can arrive."""
    g_shim_scheduler = sched
    g_shim_ipc = ipc
    g_shim_klog = klog
    # Keep the keepalive reference alive under DCE. The compiler treats
    # the assignment's RHS as used even if we ignore the result.
    val _keepalive = _shim_keepalive()

# ---------------------------------------------------------------------------
# Helper: pack six u64 values into a SyscallArgs with a known syscall id.
# ---------------------------------------------------------------------------
fn _make_args(id: u64, a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> SyscallArgs:
    SyscallArgs(id: id, arg0: a0, arg1: a1, arg2: a2, arg3: a3, arg4: a4, arg5: a5)

# ===========================================================================
# syscall 60 — debug_write   [IMPLEMENTED]
#
# a0 = byte value to write to the debug serial port
# a1..a5 unused
# returns 0 on success
# ===========================================================================
@allow(primitive_api)
@export("C", name: "spl_handle_debug_write")
fn spl_handle_debug_write(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_debug_write stub.

    Unpacks a0 (byte to write) into a SyscallArgs and delegates to the
    arch-cfg'd _handle_debug_write() in syscall.spl, which emits the byte
    via COM1 port I/O (x86_64) or MMIO UART (other arches).
    """
    val args = _make_args(60, a0, a1, a2, a3, a4, a5)
    val result = _handle_debug_write(args)
    result.value

# ===========================================================================
# syscall 0 — exit   [IMPLEMENTED]
#
# a0 = exit code (i64 cast from u64)
# a1..a5 unused
# does not return (scheduler terminates current task)
# ===========================================================================
@export("C", name: "spl_handle_exit")
fn spl_handle_exit(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_exit stub.

    Forwards to _handle_exit() in syscall.spl.
    Syscall number 0: terminate the calling task with the given exit code.
    """
    val args = _make_args(0, a0, a1, a2, a3, a4, a5)
    val result = _handle_exit(args, g_shim_scheduler, g_shim_ipc)
    result.value

# ===========================================================================
# syscall 1 — yield   [IMPLEMENTED]
#
# a0..a5 unused
# returns 0
# ===========================================================================
@export("C", name: "spl_handle_yield")
fn spl_handle_yield(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_yield stub.

    Forwards to _handle_yield() in syscall.spl.
    Syscall number 1: voluntarily yield the CPU to the scheduler.
    """
    val result = _handle_yield(g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 2 — spawn   [IMPLEMENTED]
#
# a0 = pointer to executable path string (user VA)
# a1 = path length
# a2..a5 unused
# returns new task ID on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_spawn")
fn spl_handle_spawn(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_spawn stub.

    Forwards to _handle_spawn() in syscall.spl.
    Syscall number 2: create a new task from an in-memory image.
    """
    val args = _make_args(2, a0, a1, a2, a3, a4, a5)
    val result = _handle_spawn(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 3 — wait   [IMPLEMENTED]
#
# a0 = target task ID to wait on (0 = any child)
# a1..a5 unused
# returns exit code of waited task, or negative errno
# ===========================================================================
@export("C", name: "spl_handle_wait")
fn spl_handle_wait(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_wait stub.

    Forwards to _handle_wait() in syscall.spl.
    Syscall number 3: block until the specified child task exits.
    """
    val args = _make_args(3, a0, a1, a2, a3, a4, a5)
    val result = _handle_wait(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 4 — getpid   [IMPLEMENTED]
#
# a0..a5 unused
# returns current task ID as i64
# ===========================================================================
@export("C", name: "spl_handle_getpid")
fn spl_handle_getpid(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_getpid stub.

    Forwards to _handle_getpid() in syscall.spl.
    Syscall number 4: return the current task's process ID.
