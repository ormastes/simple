# ===========================================================================
@export("C", name: "spl_handle_mprotect")
fn spl_handle_mprotect(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_mprotect stub.

    Forwards to _handle_memory_protect() in syscall.spl.
    Syscall number 12: change memory protection on a mapped region.
