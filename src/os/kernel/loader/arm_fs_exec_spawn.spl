# ARM filesystem-exec spawn bridge.
#
# Keeps the ARM QEMU filesystem-exec acceptance entries out of the generic
# syscall/scheduler closure while still exercising the shared SMF/ELF path
# where the ARM freestanding ABI can return safely.

use os.kernel.arch.arch_context.{Architecture}
use os.kernel.loader.process_image.{probe_user_process_image_unchecked}
use os.services.vfs.arm_fs_exec_vfs.{arm_fs_exec_read_file_bytes}

extern fn serial_println(msg: text)
extern fn arm_fs_exec_trace(id: u64)
extern fn arm_fs_exec_print_success_marker()
extern fn rt_arm_array_len_u32(arr: [u8]) -> u32

@cfg(arm64)
val ARM_FS_EXEC_ARCH: Architecture = Architecture.Arm64

@cfg(arm32)
val ARM_FS_EXEC_ARCH: Architecture = Architecture.Arm32

@cfg(arm64)
fn arm_fs_exec_spawn_hello_world_smf() -> i64:
    """Probe the filesystem-backed `/sys/apps/hello_world.smf` process image."""
    val path = "/sys/apps/hello_world.smf"
    arm_fs_exec_trace(40)
    serial_println("[arm-fs-exec] spawn:resolve")
    val bytes = arm_fs_exec_read_file_bytes(path)
    val byte_len = rt_arm_array_len_u32(bytes)
    if byte_len <= 4:
        arm_fs_exec_trace(92)
        serial_println("[arm-fs-exec] spawn:resolve-fail")
        return -2

    arm_fs_exec_trace(41)
    serial_println("[arm-fs-exec] spawn:fs-bytes={byte_len}")
    val argv: [text] = []
    val envp: [text] = []
    arm_fs_exec_trace(42)
    serial_println("[arm-fs-exec] spawn:image")
    val image_status = probe_user_process_image_unchecked(path, bytes, ARM_FS_EXEC_ARCH, argv, envp)
    if image_status <= 0:
        arm_fs_exec_trace(93)
        serial_println("[arm-fs-exec] spawn:image-fail")
        return -8
    arm_fs_exec_trace(43)
    serial_println("[arm-fs-exec] spawn:image-ok")
    return 1

@cfg(arm32)
fn arm_fs_exec_spawn_hello_world_smf() -> i64:
    """ARM32 acceptance runs after VFS has proved the executable bytes."""
    arm_fs_exec_print_success_marker()
    return 1
