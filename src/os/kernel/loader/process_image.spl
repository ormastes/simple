#![allow(unnamed_duplicate_typed_args)]
# Kernel Process Image Builder — ELF Load Plan to UserProcessImage
#
# Phase-3 additions:
#   * Replaces the fixed 64 KB user stack with stack_builder.compute_stack_size(),
#     which scales with binary size and caps at 128 MB.
#   * Populates UserProcessImage.initial_sp and .initial_stack_bytes via
#     stack_builder.build_initial_stack() so libc `_start` can recover argc,
#     argv, envp, and the auxv vector per the System V ABI.

use os.kernel.arch.arch_context.{Architecture}
use os.kernel.loader.elf_loader.{
    load_user_executable,
    elf_image_entry, elf_image_segments,
    elf_segment_file_offset, elf_segment_file_size, elf_segment_virt_addr,
    elf_segment_mem_size, elf_segment_flags, elf_segment_align
}
use os.kernel.loader.smf.{smf_has_header, smf_extract_executable_stub}
use os.kernel.loader.stack_builder.{
    build_initial_stack, compute_stack_size, AuxEntry,
    stack_build_result_sp, stack_build_result_bytes
}
use os.kernel.types.task_types.{UserLoadSegment, UserProcessImage}

extern fn serial_println(msg: text)
extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]

val X86_64_USER_STACK_TOP: u64 = 0x00007FFFFFFFF000
val RV64_USER_STACK_TOP: u64 = 0x0000004000000000
val RV32_USER_STACK_TOP: u64 = 0x0000000081000000

fn _byte_at(data: [u8], offset: u64) -> u8:
    rt_bytes_u8_at(data, offset.to_i64()).to_u8()

fn _has_elf_magic(data: [u8]) -> bool:
    if data.len() < 4:
        return false
    _byte_at(data, 0) == 0x7F.to_u8() and
    _byte_at(data, 1) == 0x45.to_u8() and
    _byte_at(data, 2) == 0x4C.to_u8() and
    _byte_at(data, 3) == 0x46.to_u8()

fn _slice_bytes(data: [u8], offset: u64, size: u64) -> [u8]:
    var out: [u8] = rt_array_new_with_cap(size.to_i64())
    var i: u64 = 0
    while i < size:
        out.push(_byte_at(data, offset + i))
        i = i + 1
    out

fn _default_stack_top(arch: Architecture) -> Result<u64, text>:
    match arch:
        case Architecture.X86_64:
            Ok(X86_64_USER_STACK_TOP)
        case Architecture.Riscv64:
            Ok(RV64_USER_STACK_TOP)
        case Architecture.Riscv32:
            Ok(RV32_USER_STACK_TOP)
        case _:
            Err("unsupported architecture for process image")

fn _normalise_executable_bytes(data: [u8]) -> Result<[u8], text>:
    """Unwrap supported executable containers to the native image bytes."""
    if _has_elf_magic(data):
        return Ok(data)
    if smf_has_header(data):
        return smf_extract_executable_stub(data)
    Ok(data)

fn build_user_process_image(
    path: text,
    data: [u8],
    arch: Architecture,
    argv: [text],
    envp: [text]
) -> Result<UserProcessImage, text>:
    """Load an ELF and build a user process image.

    `argv`/`envp` flow in from the spawn syscall. If the caller has no
    explicit argv (legacy path), it passes `[]` and we seed argv with the
    binary path so libc `_start` still observes argv[0].
    """
    serial_println("[process-image] build enter")
    val native_data = _normalise_executable_bytes(data)?
    serial_println("[process-image] normalised")
    val elf = load_user_executable(native_data, arch)?
    serial_println("[process-image] elf parsed")
    val entry = elf_image_entry(elf)
    serial_println("[process-image] entry ready")
    val stack_top = _default_stack_top(arch)?
    serial_println("[process-image] stack top ready")
    val stack_size = compute_stack_size(data.len() as u64)
    serial_println("[process-image] stack size ready")

    var effective_argv: [text] = argv
    if effective_argv.len() == 0:
        effective_argv = [path]

    var segments: [UserLoadSegment] = []
    for seg in elf_image_segments(elf):
        serial_println("[process-image] segment begin")
        val file_offset = elf_segment_file_offset(seg)
        val file_size = elf_segment_file_size(seg)
        serial_println("[process-image] segment metadata")
        segments.push(UserLoadSegment(
            virt_addr: elf_segment_virt_addr(seg),
            mem_size: elf_segment_mem_size(seg),
            file_size: file_size,
            flags: elf_segment_flags(seg),
            align: elf_segment_align(seg),
            data: _slice_bytes(native_data, file_offset, file_size)
        ))
        serial_println("[process-image] segment pushed")

    val extra_aux: [AuxEntry] = [AuxEntry(aux_type: 9, value: entry)]  # AT_ENTRY
    serial_println("[process-image] aux ready")
    val stack_frame = build_initial_stack(stack_top, effective_argv, envp, extra_aux)
    serial_println("[process-image] stack frame ready")

    Ok(UserProcessImage(
        binary_path: path,
        entry: entry,
        stack_top: stack_top,
        stack_size: stack_size,
        argv: effective_argv,
        envp: envp,
        segments: segments,
        file_bytes: native_data,
        initial_sp: stack_build_result_sp(stack_frame),
        initial_stack_bytes: stack_build_result_bytes(stack_frame)
    ))
