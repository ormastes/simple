# Kernel Process Image Builder — ELF Load Plan to UserProcessImage

use os.kernel.arch.arch_context.{Architecture}
use os.kernel.loader.elf_loader.{load_riscv_executable}
use os.kernel.types.task_types.{UserLoadSegment, UserProcessImage}

val RV64_USER_STACK_TOP: u64 = 0x0000004000000000
val RV32_USER_STACK_TOP: u64 = 0x0000000081000000
val DEFAULT_USER_STACK_SIZE: u64 = 64 * 1024

fn _slice_bytes(data: [u8], offset: u64, size: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < size:
        out.push(data[(offset + i) as i64])
        i = i + 1
    out

fn _default_stack_top(arch: Architecture) -> Result<u64, text>:
    match arch:
        case Architecture.Riscv64:
            Ok(RV64_USER_STACK_TOP)
        case Architecture.Riscv32:
            Ok(RV32_USER_STACK_TOP)
        case _:
            Err("unsupported architecture for process image")

fn build_user_process_image(path: text, data: [u8], arch: Architecture) -> Result<UserProcessImage, text>:
    val elf = load_riscv_executable(data, arch)?
    val stack_top = _default_stack_top(arch)?
    var segments: [UserLoadSegment] = []
    for seg in elf.segments:
        segments.push(UserLoadSegment(
            virt_addr: seg.virt_addr,
            mem_size: seg.mem_size,
            file_size: seg.file_size,
            flags: seg.flags,
            align: seg.align,
            data: _slice_bytes(data, seg.file_offset, seg.file_size)
        ))

    Ok(UserProcessImage(
        binary_path: path,
        entry: elf.entry,
        stack_top: stack_top,
        stack_size: DEFAULT_USER_STACK_SIZE,
        argv: [path],
        envp: [],
        segments: segments
    ))
