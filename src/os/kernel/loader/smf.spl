# SMF Loader — minimal Simple Module Format loader for kernel use
#
# SMF v1.1 places a 128-byte header trailer at EOF-128.
# Magic bytes: [83, 77, 70, 0]  ("SMF\0") at bytes[len-128..len-124].
# Entry-point is a u64 LE at offset 44 within that 128-byte trailer.
#
# SMF executable support is envelope-first: if the package carries a native
# executable stub, the kernel delegates that embedded image to the ELF loader.
# Native SMF code-section mapping remains a later stage.

use os.kernel.types.vmspace_types.{ProcessVmSpace}
use os.kernel.loader.elf64.{elf64_load}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]

# SMF magic "SMF\0"
val SMF64_MAGIC_0: u8 = 83    # 'S'
val SMF64_MAGIC_1: u8 = 77    # 'M'
val SMF64_MAGIC_2: u8 = 70    # 'F'
val SMF64_MAGIC_3: u8 = 0     # '\0'

val SMF_HEADER_TRAILER_SIZE: i64 = 128
val SMF_ENTRY_POINT_OFFSET: i64  = 44  # offset within trailer
val SMF_STUB_SIZE_OFFSET: i64    = 52  # offset within trailer
val SMF_DATA_OFFSET_OFFSET: i64  = 56  # offset within trailer

# ============================================================================
# Structs
# ============================================================================

struct SmfHeader:
    """Parsed fields from the 128-byte SMF trailer."""
    magic_ok:        bool   # True if magic validated
    entry_point:     i64    # Entry-point vaddr (from trailer offset 44)
    header_offset:   i64    # Absolute offset of parsed header
    stub_size:       i64    # v1.1 executable stub size
    smf_data_offset: i64    # v1.1 offset where SMF payload begins

# ============================================================================
# Internal helpers
# ============================================================================

fn _smf_byte_at(data: [u8], off: i64) -> u8:
    rt_bytes_u8_at(data, off).to_u8()

fn _smf_read_u64_le(data: [u8], off: i64) -> i64:
    val b0 = _smf_byte_at(data, off)     as i64
    val b1 = _smf_byte_at(data, off + 1) as i64
    val b2 = _smf_byte_at(data, off + 2) as i64
    val b3 = _smf_byte_at(data, off + 3) as i64
    val b4 = _smf_byte_at(data, off + 4) as i64
    val b5 = _smf_byte_at(data, off + 5) as i64
    val b6 = _smf_byte_at(data, off + 6) as i64
    val b7 = _smf_byte_at(data, off + 7) as i64
    b0 | (b1 << 8) | (b2 << 16) | (b3 << 24) | (b4 << 32) | (b5 << 40) | (b6 << 48) | (b7 << 56)

fn _smf_read_u32_le(data: [u8], off: i64) -> i64:
    val b0 = _smf_byte_at(data, off)     as i64
    val b1 = _smf_byte_at(data, off + 1) as i64
    val b2 = _smf_byte_at(data, off + 2) as i64
    val b3 = _smf_byte_at(data, off + 3) as i64
    b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

fn _smf_magic_at(bytes: [u8], off: i64) -> bool:
    if off < 0:
        return false
    if off + 4 > bytes.len():
        return false
    (_smf_byte_at(bytes, off) == SMF64_MAGIC_0 and
     _smf_byte_at(bytes, off + 1) == SMF64_MAGIC_1 and
     _smf_byte_at(bytes, off + 2) == SMF64_MAGIC_2 and
     _smf_byte_at(bytes, off + 3) == SMF64_MAGIC_3)

fn smf_header_offset(bytes: [u8]) -> i64:
    """Return header offset, preferring the v1.1 EOF-128 trailer.

    Returns -1 when neither the trailer nor legacy offset 0 contains SMF magic.
    """
    if bytes.len() < 4:
        return -1
    if bytes.len() >= SMF_HEADER_TRAILER_SIZE:
        val trailer = bytes.len() - SMF_HEADER_TRAILER_SIZE
        if _smf_magic_at(bytes, trailer):
            return trailer
    if _smf_magic_at(bytes, 0):
        return 0
    -1

# ============================================================================
# Public API
# ============================================================================

fn smf_check_magic(bytes: [u8]) -> bool:
    """Return true if `bytes` starts with the SMF magic 'SMF\\0'."""
    _smf_magic_at(bytes, 0)

fn smf_has_header(bytes: [u8]) -> bool:
    """Return true if bytes contain a supported SMF header location."""
    smf_header_offset(bytes) >= 0

fn smf_parse_header(bytes: [u8]) -> SmfHeader?:
    """Validate SMF magic and return a parsed header.

    Full SMF v1.1 files carry the 128-byte trailer at EOF-128. Legacy test
    fixtures and archive slices can still use offset 0.
    """
    val off = smf_header_offset(bytes)
    if off < 0:
        return nil
    if off + SMF_HEADER_TRAILER_SIZE > bytes.len():
        return nil
    val entry = _smf_read_u64_le(bytes, off + SMF_ENTRY_POINT_OFFSET)
    val stub_size = _smf_read_u32_le(bytes, off + SMF_STUB_SIZE_OFFSET)
    val smf_data_offset = _smf_read_u32_le(bytes, off + SMF_DATA_OFFSET_OFFSET)
    Some(SmfHeader(
        magic_ok: true,
        entry_point: entry,
        header_offset: off,
        stub_size: stub_size,
        smf_data_offset: smf_data_offset
    ))

fn _smf_has_elf_magic(bytes: [u8]) -> bool:
    if bytes.len() < 4:
        return false
    _smf_byte_at(bytes, 0) == 0x7F.to_u8() and _smf_byte_at(bytes, 1) == 0x45.to_u8() and _smf_byte_at(bytes, 2) == 0x4C.to_u8() and _smf_byte_at(bytes, 3) == 0x46.to_u8()

fn _smf_copy_range(bytes: [u8], off: i64, size: i64) -> [u8]:
    var out: [u8] = rt_array_new_with_cap(size)
    var i: i64 = 0
    while i < size:
        out.push(_smf_byte_at(bytes, off + i))
        i = i + 1
    out

fn smf_extract_executable_stub(bytes: [u8]) -> Result<[u8], text>:
    """Return the embedded native executable stub from an SMF envelope.

    Current SimpleOS support intentionally treats SMF as a package envelope
    around a normal executable. Only ELF stubs are accepted; native SMF
    code-section mapping remains owned by a later mapper implementation.
    """
    val hdr_opt = smf_parse_header(bytes)
    if hdr_opt == nil:
        return Err("invalid SMF header")
    val hdr = hdr_opt.unwrap()
    if hdr.stub_size <= 0:
        return Err("SMF has no executable stub")
    if hdr.stub_size > hdr.header_offset:
        return Err("SMF executable stub exceeds package payload")
    val stub = _smf_copy_range(bytes, 0, hdr.stub_size)
    if not _smf_has_elf_magic(stub):
        return Err("SMF executable stub is not ELF")
    Ok(stub)

fn smf_load(bytes: [u8], space: ProcessVmSpace) -> i64:
    """Map an SMF image into `space` and return its entry-point.

    This stage supports SMF packages that carry an ELF executable stub. Native
    SMF code-section mapping still returns -ENOSYS until the shared-object
    mapper lands.
    """
    if not smf_has_header(bytes):
        return -8   # -ENOEXEC
    val stub = smf_extract_executable_stub(bytes)
    if stub.is_err():
        return -38  # -ENOSYS — native SMF mapping deferred
    elf64_load(stub.unwrap(), space)
