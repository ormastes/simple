# Built-in Binary Registry — Kernel Launch Contract
#
# Resolves well-known service/app binary paths to built-in entrypoints so the
# kernel can honor `spawn_binary(path, ...)` before full ELF-backed exec lands.

use os.apps.editor.editor.{editor_remote_main}
use os.apps.hello_world.hello_world.{hello_world_remote_main}
use os.apps.file_manager.file_manager.{file_manager_remote_main}
use os.apps.shell.shell_app.{shell_remote_main}

fn _resident_binary_entry():
    """Minimal resident task body for built-in services/apps.

    This keeps spawned tasks alive under the current scheduler until the
    ELF-backed userspace path replaces the built-in registry.
    """
    while true:
        pass_do_nothing

fn resolve_builtin_binary(path: text) -> u64?:
    match path:
        case "/sys/services/vfs":
            Some(_resident_binary_entry as u64)
        case "/sys/services/net":
            Some(_resident_binary_entry as u64)
        case "/sys/services/compositor":
            Some(_resident_binary_entry as u64)
        case "/sys/services/llm_mcp":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/desktop":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/terminal":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/shell":
            Some(shell_remote_main as u64)
        case "/sys/apps/editor":
            Some(editor_remote_main as u64)
        case "/sys/apps/file_manager":
            Some(file_manager_remote_main as u64)
        case "/sys/apps/sysmon":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/settings":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/calculator":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/memo":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/file_explorer":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/paint":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/clock":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/calendar":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/screenshot":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/image_viewer":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/disk_manager":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/log_viewer":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/pkg":
            Some(_resident_binary_entry as u64)
        case "/sys/apps/hello_world":
            Some(hello_world_remote_main as u64)
        case _:
            nil
