# PATH-style resolution for sshd-driven ring-3 exec (clang_as_general_fs_exec
# Phase 2, Lane A). Resolves a bare command name (argv[0], e.g. "clang") to
# an absolute path (e.g. "/usr/bin/clang") by probing a small, fixed PATH
# directory list.
#
# Existence probe = `simpleos_fat32_stream_open(path) >= 0`: the SAME
# non-destructive open the real exec path already relies on (returns the file
# size on success, -1 on miss; baremetal_stubs.c only touches the shared
# `_fat_stream` cursor state on SUCCESS, and any later real spawn re-opens
# its path anyway, cleanly resetting that cursor). No dedicated C stub
# needed. Deliberately a direct extern (matching every other freestanding
# exec-path consumer, e.g. x86_64_fs_exec_spawn.spl): a trait-object/`class`
# FS seam was tried here first and produced ring-0 corruption fault-loops
# under the freestanding kernel target -- class construction + dynamic trait
# dispatch are not proven freestanding-safe, while direct externs are. When
# a second root filesystem needs exec resolution, generalize the ONE call in
# `_fs_exec_path_exists` (e.g. per-fs @cfg variants), not the resolver
# logic.
#
# `cmd` here is always a DYNAMICALLY built string (tokenized at runtime from
# the decoded SSH command bytes), so per-char text predicates
# (`char_at`/`starts_with`) are unreliable on the x64 freestanding path (see
# doc/08_tracking/bug/x64_freestanding_text_char_at_starts_with.md) — the
# slash-detection below uses the proven-safe raw [u8] byte-array accessor
# pair instead (same pattern as sshd.spl's `_sshd_tokenize_command`).
#
# FREESTANDING DISCIPLINE: module-level `val`/`var` ARRAY initializers do
# NOT run under freestanding native-build (see e.g.
# examples/09_embedded/simple_os/arch/x86_64/fs_exec_general_ring3_entry.spl
# module docstring) -- a module-level `val DIRS: [text] = [...]` reads as
# garbage at runtime and faults on `.len()`. So: the PATH list is a
# function, and the memoization cache arrays are lazily initialized behind a
# bool flag (scalar module vars land in zeroed .bss, so `false` IS reliable).
#
# Must be called from a SHALLOW stack frame (e.g. the sshd accept loop), not
# from the deep ssh_session.spl packet-handling call stack — matching the
# existing constraint on the real spawn calls (see sshd.spl's
# `_sshd_run_pending_exec` note on kernel-stack overflow deep in the session
# call stack).

extern fn serial_println(msg: text)
extern fn rt_string_to_byte_array(s: text) -> [u8]
extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn simpleos_fat32_stream_open(path: text) -> i64

fn _fs_exec_path_exists(path: text) -> bool:
    simpleos_fat32_stream_open(path) >= 0

fn _fs_exec_path_dirs() -> [text]:
    """Fixed PATH search order. No env-carried PATH yet (sshd exec requests
    don't transmit one) -- static default matches the envp PATH= value sshd
    sets at spawn time (see sshd.spl's `_sshd_default_envp`)."""
    ["/bin", "/usr/bin", "/usr/local/bin"]

# Module-level memoization cache: resolved name -> absolute path. Linear scan
# over a small [text] pair list -- no hashmap needed, this only ever holds a
# handful of distinct command names per boot (see project rule: keep search
# optimization tiny). Lazily initialized (see FREESTANDING DISCIPLINE above).
var g_fs_exec_cache_ready: bool = false
var g_fs_exec_cache_name: [text] = []
var g_fs_exec_cache_path: [text] = []

fn _fs_exec_cache_ensure():
    if not g_fs_exec_cache_ready:
        g_fs_exec_cache_name = []
        g_fs_exec_cache_path = []
        g_fs_exec_cache_ready = true

fn _fs_exec_cache_lookup(name: text) -> text:
    _fs_exec_cache_ensure()
    var i: u64 = 0u64
    while i < g_fs_exec_cache_name.len():
        if g_fs_exec_cache_name[i] == name:
            return g_fs_exec_cache_path[i]
        i = i + 1u64
    ""

fn _fs_exec_cache_store(name: text, path: text):
    _fs_exec_cache_ensure()
    g_fs_exec_cache_name.push(name)
    g_fs_exec_cache_path.push(path)

fn _fs_exec_contains_slash(cmd: text) -> bool:
    val bytes = rt_string_to_byte_array(cmd)
    var i: i64 = 0
    val n = bytes.len().to_i64()
    while i < n:
        if rt_bytes_u8_at(bytes, i) == 47:   # '/'
            return true
        i = i + 1
    false

pub fn fs_exec_resolve(cmd: text) -> text:
    """Resolve `cmd` (argv[0]) to an absolute path.

    - `cmd` contains '/' -> returned as-is (absolute/relative path form).
    - else probed as "<dir>/<cmd>" over _fs_exec_path_dirs(), first hit
      wins, cached for subsequent lookups (logs
      "[fs-exec] path-cache hit <name>").
    - not found anywhere -> "" (caller treats as exit 127 "command not found").
    """
    if cmd.length == 0u64:
        return ""
    if _fs_exec_contains_slash(cmd):
        return cmd
    val cached = _fs_exec_cache_lookup(cmd)
    if cached.length > 0u64:
        serial_println("[fs-exec] path-cache hit {cmd}")
        return cached
    val dirs = _fs_exec_path_dirs()
    var i: u64 = 0u64
    while i < dirs.len():
        val candidate = dirs[i] + "/" + cmd
        if _fs_exec_path_exists(candidate):
            _fs_exec_cache_store(cmd, candidate)
            serial_println("[fs-exec] path-resolve {cmd} -> {candidate}")
            return candidate
        i = i + 1u64
    serial_println("[fs-exec] path-resolve {cmd} -> not-found")
    ""
