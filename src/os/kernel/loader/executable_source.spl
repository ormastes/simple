# Kernel Executable Source — Path-to-Bytes Lookup
#
# Resolves binary paths to executable bytes. Resolution order:
#   1. If the path starts with `/` and an initramfs blob is set, decompress
#      the zstd+cpio archive and look up the file.
#   2. On ENOENT from the initramfs, fall back to the two inlined RV32/RV64
#      proof-of-concept ELF stubs used for early boot smoke tests.
#   3. Everything else: return Err("ENOENT: ...") so callers surface -2.

use os.kernel.arch.arch_context.{Architecture}
use os.kernel.loader.zstd_decompress.{zstd_decompress}
use os.kernel.loader.cpio_newc.{CpioEntry, cpio_parse, cpio_lookup}

extern fn serial_println(msg: text)
extern fn rt_string_from_byte_array(arr: [u8]) -> text

val RV64_PROOF_BINARY_PATH: text = "/sys/apps/rv64_user_proof"
val RV32_PROOF_BINARY_PATH: text = "/sys/apps/rv32_user_proof"

# POSIX-ish errno string prefixes. The kernel error channel is `text`, so we
# encode the numeric code in the message so callers can classify without
# parsing free-form prose.
val ERR_ENOENT: text = "ENOENT: -2"
val ERR_EINVAL: text = "EINVAL: -22"
val ERR_EBADF: text = "EBADF: -9"
val ERR_ENOSPC: text = "ENOSPC: -28"

# ----------------------------------------------------------------------------
# Synthetic initramfs override — test-only injection point.
#
# Real kernel boots must go through the initramfs reader (`_initramfs_read_file`).
# Specs that need to assert "VFS path X returns bytes Y" inject a synthetic
# entry via `_set_synthetic_initramfs_for_test`; the production reader remains
# untouched. The override is cleared with `_clear_synthetic_initramfs_for_test`.
# ----------------------------------------------------------------------------

struct SyntheticEntry:
    path: text
    bytes: [u8]

var g_synthetic_entries: [SyntheticEntry] = []
var g_synthetic_vfs_entries: [SyntheticEntry] = []

# Real initramfs blob, set by the boot chain via set_initramfs_blob().
var g_initramfs_blob: [u8]? = nil

# Cached parsed cpio entries — populated on first lookup from a real blob.
var g_cpio_entries: [CpioEntry] = []
var g_cpio_decoded: bool = false

fn _desktop_app_short_alias(path: text) -> text?:
    """Return the FAT32 short-name alias for seeded desktop app binaries."""
    match path:
        case "/sys/apps/browser_demo":
            Some("/SYS/APPS/BROWSE~1")
        case "/sys/apps/browser_demo.smf":
            Some("/SYS/APPS/BROWSMF.SMF")
        case "/sys/apps/hello_world":
            Some("/SYS/APPS/HELLO_~1")
        case "/sys/apps/hello_world.smf":
            Some("/SYS/APPS/HELLOSMF.SMF")
        case "/sys/apps/file_manager":
            Some("/SYS/APPS/FILE_M~1")
        case "/sys/apps/file_manager.smf":
            Some("/SYS/APPS/FILESMF.SMF")
        case "/sys/apps/shell.smf":
            Some("/SYS/APPS/SHELLSMF.SMF")
        case "/sys/apps/editor.smf":
            Some("/SYS/APPS/EDITORSM.SMF")
        case _:
            nil

fn _desktop_app_root_elf_alias(path: text) -> text?:
    """Return the root-level 8.3 ELF alias currently present on seeded images.

    `make_os_disk.shs` copies the temporary staging tree recursively into the
    FAT32 image, so the built ELF artifacts are currently present at the image
    root as well as under the canonical app paths. Keep this as a filesystem
    fallback only; the launcher and app model still use `/sys/apps/...`.
    """
    match path:
        case "/sys/apps/browser_demo":
            Some("/BROWSE~1.ELF")
        case "/sys/apps/browser_demo.smf":
            Some("/BROWSMF.SMF")
        case "/sys/apps/hello_world":
            Some("/HELLO_~1.ELF")
        case "/sys/apps/hello_world.smf":
            Some("/HELLOSMF.SMF")
        case "/sys/apps/file_manager":
            Some("/FILE_M~1.ELF")
        case "/sys/apps/file_manager.smf":
            Some("/FILESMF.SMF")
        case "/sys/apps/shell":
            Some("/TERMIN~1.ELF")
        case "/sys/apps/shell.smf":
            Some("/SHELLSMF.SMF")
        case "/sys/apps/editor":
            Some("/EDITOR~1.ELF")
        case "/sys/apps/editor.smf":
            Some("/EDITORSM.SMF")
        case _:
            nil

fn _path_bytes_to_text(path_bytes: [u8]) -> text:
    rt_string_from_byte_array(path_bytes)

fn _exec_vfs_read_file_bytes(path: text) -> [u8]:
    use os.services.vfs.vfs_init.{g_vfs_read_file_bytes}
    g_vfs_read_file_bytes(path)

fn _canonical_seeded_path_from_bytes(path_bytes: [u8]) -> text?:
    match _path_bytes_to_text(path_bytes):
        case "/sys/apps/browser_demo":
            Some("/sys/apps/browser_demo")
        case "/sys/apps/hello_world":
            Some("/sys/apps/hello_world")
        case "/sys/apps/file_manager":
            Some("/sys/apps/file_manager")
        case "/sys/apps/shell":
            Some("/sys/apps/shell")
        case "/sys/apps/editor":
            Some("/sys/apps/editor")
        case _:
            nil

fn canonical_seeded_path_from_bytes(path_bytes: [u8]) -> text?:
    """Expose the stable syscall-byte canonicalization used by app exec."""
    _canonical_seeded_path_from_bytes(path_bytes)

fn _set_synthetic_initramfs_for_test(path: text, bytes: [u8]):
    """Test hook: register a synthetic initramfs entry resolvable by path."""
    g_synthetic_entries.push(SyntheticEntry(path: path, bytes: bytes))

fn _clear_synthetic_initramfs_for_test():
    """Test hook: drop all synthetic entries installed during the test."""
    g_synthetic_entries = []

fn _set_synthetic_vfs_file_for_test(path: text, bytes: [u8]):
    """Test hook: register a synthetic VFS entry resolvable by absolute path."""
    g_synthetic_vfs_entries.push(SyntheticEntry(path: path, bytes: bytes))

fn _clear_synthetic_vfs_for_test():
    """Test hook: drop all synthetic VFS entries installed during the test."""
    g_synthetic_vfs_entries = []

fn set_initramfs_blob(blob: [u8]):
    """Set the raw initramfs image (zstd-compressed cpio) from the boot chain."""
    g_initramfs_blob = blob
    # Reset cache so it is re-decoded from the new blob on next lookup.
    g_cpio_decoded = false
    g_cpio_entries = []

fn _lookup_synthetic(path: text) -> Result<[u8], text>:
    for entry in g_synthetic_entries:
        if entry.path == path:
            return Ok(entry.bytes)
    Err(ERR_ENOENT)

fn _lookup_synthetic_vfs(path: text) -> Result<[u8], text>:
    for entry in g_synthetic_vfs_entries:
        if entry.path == path:
            return Ok(entry.bytes)
    Err(ERR_ENOENT)

fn _path_bytes_to_text(bytes: [u8]) -> text:
    rt_string_from_byte_array(bytes)

# ----------------------------------------------------------------------------
# In-kernel initramfs reader.
#
# Production signature: `_initramfs_read_file(path) -> Result<[u8], text>`.
# Consults the synthetic test map first; falls back to the real initramfs blob
# (zstd-decompressed and cpio-parsed) if one has been installed via
# set_initramfs_blob(). Returns ENOENT when the file is not found.
# ----------------------------------------------------------------------------

fn _initramfs_read_file(path: text) -> Result<[u8], text>:
    serial_println("[exec-source] initramfs enter path={path}")
    # First consult the synthetic test map — this is the injection point used
    # by specs and is a no-op in production.
    val synthetic = _lookup_synthetic(path)
    if synthetic.is_ok():
        serial_println("[exec-source] initramfs synthetic-hit path={path}")
        return synthetic

    # Real initramfs path: decompress + parse on first access, then cache.
    val blob = g_initramfs_blob
    if blob == nil:
        serial_println("[exec-source] initramfs no-blob path={path}")
        return Err(ERR_ENOENT)

    if not g_cpio_decoded:
        serial_println("[exec-source] initramfs decompress path={path}")
        val decomp = zstd_decompress(blob.unwrap())
        if decomp.is_err():
            serial_println("[exec-source] initramfs decompress-fail path={path}")
            return Err(decomp.err().unwrap())
        g_cpio_entries = cpio_parse(decomp.unwrap())
        g_cpio_decoded = true

    val found = cpio_lookup(g_cpio_entries, path)
    if found == nil:
        serial_println("[exec-source] initramfs miss path={path}")
        return Err(ERR_ENOENT)
    serial_println("[exec-source] initramfs hit path={path}")
    Ok(found.unwrap())

fn _push_u16_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf

fn _push_u32_le(buf: [u8], value: i64) -> [u8]:
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf

fn _push_u64_le(buf: [u8], value: i64) -> [u8]:
    var out = buf
    out = _push_u32_le(out, value & 0xFFFFFFFF)
    out = _push_u32_le(out, (value >> 32) & 0xFFFFFFFF)
    out

fn _minimal_rv64_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = _push_u16_le(bytes, 2)
    bytes = _push_u16_le(bytes, 243)
    bytes = _push_u32_le(bytes, 1)
    bytes = _push_u64_le(bytes, 0x400000)
    bytes = _push_u64_le(bytes, 64)
    bytes = _push_u64_le(bytes, 0)
    bytes = _push_u32_le(bytes, 0)
    bytes = _push_u16_le(bytes, 64)
    bytes = _push_u16_le(bytes, 56)
    bytes = _push_u16_le(bytes, 1)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u32_le(bytes, 1)
    bytes = _push_u32_le(bytes, 5)
    bytes = _push_u64_le(bytes, 0x1000)
    bytes = _push_u64_le(bytes, 0x400000)
    bytes = _push_u64_le(bytes, 0x400000)
    bytes = _push_u64_le(bytes, 32)
    bytes = _push_u64_le(bytes, 32)
    bytes = _push_u64_le(bytes, 0x1000)
    # Update segment sizes: 8 instructions * 4 bytes = 32 bytes of code
    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())

    # Instruction 1: li a7, 60  (addi a7, zero, 60) — SYS_DEBUG_WRITE
    # Encoding: imm[11:0]=60=0x3C, rs1=x0, funct3=000, rd=x17(a7), opcode=0010011
    # = 0x03C00893
    bytes.push(0x93.to_u8())
    bytes.push(0x08.to_u8())
    bytes.push(0xC0.to_u8())
    bytes.push(0x03.to_u8())

    # Instruction 2: li a0, 0x50  (addi a0, zero, 80) — 'P' ASCII
    # = 0x05000513
    bytes.push(0x13.to_u8())
    bytes.push(0x05.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x05.to_u8())

    # Instruction 3: ecall — trap to kernel
    # = 0x00000073
    bytes.push(0x73.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())

    # Instruction 4: li a7, 4  (addi a7, zero, 4) — SYS_GETPID
    # = 0x00400893
    bytes.push(0x93.to_u8())
    bytes.push(0x08.to_u8())
    bytes.push(0x40.to_u8())
    bytes.push(0x00.to_u8())

    # Instruction 5: ecall — getpid
    # = 0x00000073
    bytes.push(0x73.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())

    # Instruction 6: li a7, 0  (addi a7, zero, 0) — SYS_EXIT
    # = 0x00000893
    bytes.push(0x93.to_u8())
    bytes.push(0x08.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())

    # Instruction 7: li a0, 0  (addi a0, zero, 0) — exit code 0
    # = 0x00000513
    bytes.push(0x13.to_u8())
    bytes.push(0x05.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())

    # Instruction 8: ecall — exit
    # = 0x00000073
    bytes.push(0x73.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())

    bytes

fn _minimal_rv32_exec() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    bytes = _push_u16_le(bytes, 2)
    bytes = _push_u16_le(bytes, 243)
    bytes = _push_u32_le(bytes, 1)
    bytes = _push_u32_le(bytes, 0x80000000)
    bytes = _push_u32_le(bytes, 52)
    bytes = _push_u32_le(bytes, 0)
    bytes = _push_u32_le(bytes, 0)
    bytes = _push_u16_le(bytes, 52)
    bytes = _push_u16_le(bytes, 32)
    bytes = _push_u16_le(bytes, 1)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u16_le(bytes, 0)
    bytes = _push_u32_le(bytes, 1)
    bytes = _push_u32_le(bytes, 0x100)
    bytes = _push_u32_le(bytes, 0x80000000)
    bytes = _push_u32_le(bytes, 0x80000000)
    bytes = _push_u32_le(bytes, 4)
    bytes = _push_u32_le(bytes, 4)
    bytes = _push_u32_le(bytes, 5)
    bytes = _push_u32_le(bytes, 0x1000)
    while bytes.len() < 0x104:
        bytes.push(0.to_u8())
    bytes.push(0x13.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes

fn _legacy_stub_bytes(path: text, arch: Architecture) -> Result<[u8], text>:
    if path != RV64_PROOF_BINARY_PATH and path != RV32_PROOF_BINARY_PATH:
        return Err(ERR_ENOENT)
    match arch:
        case Architecture.Riscv64:
            Ok(_minimal_rv64_exec())
        case Architecture.Riscv32:
            Ok(_minimal_rv32_exec())
        case _:
            Err("unsupported architecture for executable source")

fn _vfs_read_file(path: text) -> Result<[u8], text>:
    val synthetic = _lookup_synthetic_vfs(path)
    if synthetic.is_ok():
        return synthetic

    # Desktop app paths are long logical names, but the FAT32 disk fixture is
    # 8.3. Try the known executable aliases before the generic mount-table
    # fallback so a long-path miss cannot trap in the legacy retry path.
    val alias = _desktop_app_short_alias(path)
    if alias != nil:
        val alias_path = alias.unwrap()
        val alias_bytes = _exec_vfs_read_file_bytes(alias_path)
        if alias_bytes.len() > 0:
            serial_println("[exec-source] vfs_alias_hit path={path} alias={alias_path} bytes={alias_bytes.len()}")
            return Ok(alias_bytes)
        serial_println("[exec-source] vfs_alias_miss path={path} alias={alias_path}")
    val root_alias = _desktop_app_root_elf_alias(path)
    if root_alias != nil:
        val root_alias_path = root_alias.unwrap()
        val root_alias_bytes = _exec_vfs_read_file_bytes(root_alias_path)
        if root_alias_bytes.len() > 0:
            serial_println("[exec-source] vfs_root_alias_hit path={path} alias={root_alias_path} bytes={root_alias_bytes.len()}")
            return Ok(root_alias_bytes)
        serial_println("[exec-source] vfs_root_alias_miss path={path} alias={root_alias_path}")
    val bytes = _exec_vfs_read_file_bytes(path)
    if bytes.len() > 0:
        serial_println("[exec-source] vfs_hit path={path} bytes={bytes.len()}")
        return Ok(bytes)
    serial_println("[exec-source] vfs_miss path={path}")
    Err(ERR_ENOENT)

fn resolve_executable_bytes(path: text, arch: Architecture) -> Result<[u8], text>:
    """Resolve a binary path to executable bytes.

    1. Paths beginning with '/' are first looked up via the in-kernel
       initramfs reader (`_initramfs_read_file`).
    2. If the initramfs reports ENOENT, fall back to the two inlined RV32/RV64
       proof-of-concept stubs used for early boot smoke tests.
    3. Otherwise return ENOENT.
    """
    serial_println("[exec-source] resolve enter path={path}")
    if path.len() == 0:
        return Err(ERR_EINVAL)

    if path.starts_with("/"):
        serial_println("[exec-source] resolve absolute path={path}")
        val initramfs_result = _initramfs_read_file(path)
        serial_println("[exec-source] resolve initramfs returned path={path}")
        if initramfs_result.is_ok():
            return initramfs_result
        val vfs_result = _vfs_read_file(path)
        serial_println("[exec-source] resolve vfs returned path={path}")
        if vfs_result.is_ok():
            return vfs_result

    # Reader said ENOENT — try the boot-test fallback.
    serial_println("[exec-source] resolve legacy-fallback path={path}")
    _legacy_stub_bytes(path, arch)

fn resolve_executable_bytes_from_path_bytes(path_bytes: [u8], arch: Architecture) -> Result<[u8], text>:
    """Resolve executable bytes from raw path bytes.

    The x86 desktop syscall lane uses this to avoid passing `text` across the
    syscall->loader boundary on baremetal, where the current backend can lose
    the string payload even though the copied user bytes are correct.
    """
    val canonical = _canonical_seeded_path_from_bytes(path_bytes)
    if canonical != nil:
        return resolve_executable_bytes(canonical.unwrap(), arch)
    resolve_executable_bytes(_path_bytes_to_text(path_bytes), arch)

fn resolve_executable_size(path: text, arch: Architecture) -> Result<u64, text>:
    """Return the size in bytes of the executable at `path`.

    Used by Phase 2/3 for pre-allocation sizing without materialising the
    full byte buffer twice. Current implementation resolves the bytes and
    returns their length; a future optimisation can query the initramfs
    metadata directly once decompression is wired.
    """
    val bytes_result = resolve_executable_bytes(path, arch)
    if bytes_result.is_err():
        return Err(bytes_result.err().unwrap())
    Ok(bytes_result.unwrap().len().to_u64())
