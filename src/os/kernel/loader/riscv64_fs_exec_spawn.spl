# RISC-V 64 filesystem-exec scheduler bridge.

use os.kernel.arch.arch_context.{Architecture}
use os.kernel.arch.user_entry_bridge.{dispatch_fs_exec_user_handoff}
use os.kernel.loader.fs_exec_spawn.{fs_exec_prepare_spawn}

extern fn serial_println(msg: text)

pub fn riscv64_fs_exec_spawn_ring3(path: text, argv: [text], envp: [text]) -> i64:
    """Prepare one filesystem image and block until its RV64 user task exits."""
    val prepared = fs_exec_prepare_spawn(path, argv, envp)
    if prepared.pid <= 0:
        return prepared.pid
    serial_println("[fs-exec] spawn:pid={prepared.pid} path={path}")
    dispatch_fs_exec_user_handoff(Architecture.Riscv64, prepared.pid as u64, prepared.scheduler)
