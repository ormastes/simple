#![allow(unnamed_duplicate_typed_args)]
# Segment Mapper — PT_LOAD → User Address Space
#
# Phase 2 of the external-toolchain loader pipeline. Consumes the
# `UserLoadSegment` list produced by `elf_loader` and populates the
# freshly-created user address space with correctly-permissioned pages
# containing the file-backed bytes plus BSS zeroing.
#
# Ownership contract:
#   - elf_loader.spl  — parses ELF, produces UserLoadSegment list.
#   - vmm.spl         — owns the page-table primitives (Phase 1).
#   - segment_mapper  — this file; glue between the two.
#
# Phase 1 is introducing an `AddressSpace` wrapper type. Until it lands,
# the address-space handle is the raw PML4 physical address as a u64
# (matching `TaskControlBlock.address_space`). When Phase 1 merges,
# swap `u64` for `AddressSpace` and update the call site in scheduler.

use os.kernel.types.task_types.{
    UserLoadSegment, AddressSpace,
    user_load_segment_virt_addr, user_load_segment_mem_size,
    user_load_segment_file_size, user_load_segment_data,
    user_load_segment_flags
}
use os.kernel.types.memory_types.{VirtAddr, PhysAddr, PageFrame, VmFlags, phys_addr_value}
use os.kernel.memory.user_address_space.{alloc_user_page_frame, map_user_page_in}
use os.kernel.memory.vmm.{vmm_copy_bytes_to_phys, vmm_zero_phys_range}

# ============================================================================
# ELF program-header permission bits (PF_*)
# ============================================================================

val PF_X: u32 = 1
val PF_W: u32 = 2
val PF_R: u32 = 4

val PAGE_SIZE: u64 = 4096

# ============================================================================
# Diagnostics
# ============================================================================

extern fn serial_println(msg: text)

# ============================================================================
# Helpers
# ============================================================================

fn _page_align_down(addr: u64) -> u64:
    """Round a u64 down to the nearest page boundary."""
    addr & (~(PAGE_SIZE - 1))

fn _page_align_up(addr: u64) -> u64:
    """Round a u64 up to the next page boundary (no-op if already aligned)."""
    (addr + PAGE_SIZE - 1) & (~(PAGE_SIZE - 1))

fn _flags_from_pf(flags: u32) -> VmFlags:
    """Derive a user-space `VmFlags` from ELF PF_* bits.

    Unknown / zero flags fall back to read-only user pages with a warning.
    """
    val r = (flags & PF_R) != 0
    val w = (flags & PF_W) != 0
    val x = (flags & PF_X) != 0

    if not r and not w and not x:
        serial_println("[segmap] WARN: PT_LOAD segment has no PF_* flags; defaulting to R only")
        # VM_PRESENT | VM_USER | VM_NO_EXECUTE — read-only user page.
        return VmFlags(bits: 1 | 4 | 32)

    var bits: u32 = 1 | 4     # VM_PRESENT | VM_USER
    if w:
        bits = bits | 2       # VM_WRITABLE
    if not x:
        bits = bits | 32      # VM_NO_EXECUTE
    VmFlags(bits: bits)

fn _copy_segment_page(page_phys: u64, page_va: u64, seg_va: u64, file_size: u64, mem_size: u64, src: [u8]):
    """Copy one mapped segment page without retaining all page frames.

    The copy is split into a file-backed range (`rt_memcpy`) and a BSS tail
    (`rt_memset`). The previous implementation looped byte-by-byte, which
    induced ~5 allocations per byte through `rt_bytes_u8_at` and caused the
    syscall 13 "enqueue stall" investigated in
    doc/08_tracking/bug/syscall13_enqueue_stall_2026-04-21.md.
    """
    val page_end = page_va + PAGE_SIZE
    val seg_end = seg_va + mem_size
    var copy_start = page_va
    if copy_start < seg_va:
        copy_start = seg_va
    var copy_end = page_end
    if copy_end > seg_end:
        copy_end = seg_end
    if copy_start >= copy_end:
        return

    val page_off = copy_start - page_va
    val seg_off = copy_start - seg_va
    val total = copy_end - copy_start

    var file_len: u64 = 0
    if seg_off < file_size:
        val remaining_file = file_size - seg_off
        file_len = if total < remaining_file: total else: remaining_file
    val zero_len = total - file_len

    if file_len > 0:
        vmm_copy_bytes_to_phys(page_phys + page_off, src, seg_off, file_len)
    if zero_len > 0:
        vmm_zero_phys_range(page_phys + page_off + file_len, zero_len)

fn _copy_stack_page(page_phys: u64, page_va: u64, frame_start: u64, stack_top: u64, stack_bytes: [u8]):
    """Copy the initial stack bytes that overlap one mapped stack page."""
    if stack_bytes.len() == 0:
        return

    val page_end = page_va + PAGE_SIZE
    var copy_start = page_va
    if copy_start < frame_start:
        copy_start = frame_start
    var copy_end = page_end
    if copy_end > stack_top:
        copy_end = stack_top
    if copy_start >= copy_end:
        return

    val page_off = copy_start - page_va
    val src_off = copy_start - frame_start
    val len = copy_end - copy_start
    vmm_copy_bytes_to_phys(page_phys + page_off, stack_bytes, src_off, len)

# ============================================================================
# Public API
# ============================================================================

fn map_segment(as_handle: AddressSpace, seg: UserLoadSegment, file_bytes: [u8]) -> Result<i32, text>:
    """Map a single PT_LOAD segment into the target address space.

    Steps:
      1. Page-align virt_addr down and memsz up.
      2. Allocate one physical frame per page from the PMM.
      3. Map each page with PF_*-derived permissions.
      4. Copy file-backed bytes in, zero the BSS tail.

    `as_handle` is the Phase-1 AddressSpace wrapper; the underlying root
    is `as_handle.phys_root` (matches TCB.address_space for legacy code).
    """
    val _root = as_handle.phys_root
    val file_size = user_load_segment_file_size(seg)
    val mem_size = user_load_segment_mem_size(seg)
    if file_size > mem_size:
        serial_println("[segmap] file_size exceeds mem_size")
        return Err("segment file_size exceeds mem_size")
    if mem_size == 0:
        return Ok(0)

    val virt_addr = user_load_segment_virt_addr(seg)
    val va_start = _page_align_down(virt_addr)
    val va_end = _page_align_up(virt_addr + mem_size)
    val vm_flags = _flags_from_pf(user_load_segment_flags(seg))

    var va = va_start
    while va < va_end:
        val opt_frame = alloc_user_page_frame()
        if opt_frame == nil:
            serial_println("[segmap] frame alloc failed for PT_LOAD")
            return Err("alloc_user_page_frame failed while mapping PT_LOAD")
        val frame = opt_frame
        val phys = PhysAddr(addr: frame.pfn * PAGE_SIZE)
        val virt = VirtAddr(addr: va)
        val ok = map_user_page_in(as_handle, virt, phys, vm_flags)
        if not ok:
            serial_println("[segmap] map_user_page_in failed for PT_LOAD")
            return Err("map_user_page_in failed for PT_LOAD page")
        _copy_segment_page(phys_addr_value(phys), va, virt_addr, file_size, mem_size, user_load_segment_data(seg))
        va = va + PAGE_SIZE

    Ok(1)

fn map_stack(as_handle: AddressSpace, stack_top: u64, stack_size: u64, stack_bytes: [u8]) -> Result<i32, text>:
    """Map the user stack and copy the serialized initial stack frame."""
    if stack_size == 0:
        return Err("stack_size must be nonzero")
    if (stack_bytes.len() as u64) > stack_size:
        return Err("initial stack frame exceeds stack size")
    if stack_top < stack_size:
        return Err("stack range underflows")

    val frame_start = stack_top - (stack_bytes.len() as u64)
    val stack_bottom = stack_top - stack_size
    if frame_start < stack_bottom:
        return Err("initial stack frame below stack range")

    # Map only the initial stack-frame pages. The remaining stack range stays
    # reserved for demand growth once user page-fault handling is active.
    val va_start = _page_align_down(frame_start)
    val va_end = _page_align_up(stack_top)
    val flags = VmFlags.user_rw()

    var mapped: i32 = 0
    var va = va_start
    while va < va_end:
        val opt_frame = alloc_user_page_frame()
        if opt_frame == nil:
            return Err("alloc_user_page_frame failed while mapping user stack")
        val frame = opt_frame
        val phys = PhysAddr(addr: frame.pfn * PAGE_SIZE)
        val ok = map_user_page_in(as_handle, VirtAddr(addr: va), phys, flags)
        if not ok:
            return Err("map_user_page_in failed for user stack page")
        _copy_stack_page(phys_addr_value(phys), va, frame_start, stack_top, stack_bytes)
        mapped = mapped + 1
        va = va + PAGE_SIZE

    Ok(mapped)

@cfg(arm64)
fn stage_raw_image(as_handle: AddressSpace, file_bytes: [u8]) -> i32:
    """Stage raw executable bytes into direct-load frames.

    ARM64 fs-exec can produce a valid SMF process image before PT_LOAD segment
    extraction is available in the freestanding closure. This loader path
    still proves that the filesystem bytes are copied into RAM owned by the
    process image instead of stopping at metadata-only scheduler registration.
    """
    extern fn rt_arm_stage_raw_image(dst_phys: u64, bytes: [u8]) -> i32
    if as_handle.phys_root == 0:
        serial_println("[segmap] raw stage failed: no address-space root")
        return -1
    val total = file_bytes.len() as u64
    if total == 0:
        serial_println("[segmap] raw stage failed: empty image")
        return -2

    val image_base = as_handle.phys_root + 0x100000
    val staged = rt_arm_stage_raw_image(image_base, file_bytes)
    if staged <= 0:
        serial_println("[segmap] raw stage failed: runtime copy")
        return -12
    serial_println("[segmap] raw stage ok bytes={total} root={as_handle.phys_root}")
    staged

@cfg(arm64)
fn stage_elf64_load_image(as_handle: AddressSpace, file_bytes: [u8]) -> i32:
    """Stage ELF64 PT_LOAD contents into the ARM64 direct-load arena."""
    extern fn rt_arm_stage_elf64_load_image(dst_phys: u64, bytes: [u8]) -> i32
    extern fn rt_arm64_user_as_map_elf64(root: u64, dst_phys: u64, bytes: [u8]) -> i32
    extern fn rt_arm64_user_as_ttbr0_probe(root: u64) -> i32
    if as_handle.phys_root == 0:
        serial_println("[segmap] elf stage failed: no address-space root")
        return -1
    val image_base = as_handle.phys_root + 0x100000
    val staged = rt_arm_stage_elf64_load_image(image_base, file_bytes)
    if staged <= 0:
        return staged
    val mapped = rt_arm64_user_as_map_elf64(as_handle.phys_root, image_base, file_bytes)
    if mapped <= 0:
        serial_println("[segmap] arm64 user page table failed root={as_handle.phys_root}")
        return -13
    serial_println("[segmap] arm64 user page table ok root={as_handle.phys_root}")
    val ttbr0_probe = rt_arm64_user_as_ttbr0_probe(as_handle.phys_root)
    if ttbr0_probe == 1:
        serial_println("[segmap] arm64 ttbr0 probe ok")
    else:
        if ttbr0_probe == 2:
            serial_println("[segmap] arm64 ttbr0 probe deferred mmu-on")
        else:
            serial_println("[segmap] arm64 ttbr0 probe failed")
            return -14
    serial_println("[segmap] elf stage ok root={as_handle.phys_root}")
    staged

@cfg(arm64)
fn direct_load_entry_point(as_handle: AddressSpace, file_bytes: [u8], entry: u64) -> u64:
    """Return the physical entry address for the ARM64 direct-load arena."""
    extern fn rt_arm_elf64_direct_entry(dst_phys: u64, bytes: [u8], entry: u64) -> u64
    val resolved = rt_arm_elf64_direct_entry(as_handle.phys_root + 0x100000, file_bytes, entry)
    if resolved == 0:
        return entry
    resolved

@cfg(arm64)
fn verify_direct_load_entry(as_handle: AddressSpace, file_bytes: [u8], entry: u64) -> bool:
    """Check that the staged direct-load entry bytes match the ELF source."""
    extern fn rt_arm_elf64_direct_entry(dst_phys: u64, bytes: [u8], entry: u64) -> u64
    extern fn rt_arm_elf64_direct_entry_bytes_ok(dst_phys: u64, bytes: [u8], entry: u64) -> i32
    extern fn rt_arm64_user_as_translate(root: u64, virt: u64) -> u64
    val image_base = as_handle.phys_root + 0x100000
    val direct_entry = rt_arm_elf64_direct_entry(image_base, file_bytes, entry)
    val table_entry = rt_arm64_user_as_translate(as_handle.phys_root, entry)
    if direct_entry == 0 or table_entry != direct_entry:
        serial_println("[segmap] direct entry page table mismatch")
        return false
    serial_println("[segmap] direct entry page table ok")
    val ok = rt_arm_elf64_direct_entry_bytes_ok(image_base, file_bytes, entry)
    if ok == 1:
        serial_println("[segmap] direct entry bytes ok")
        return true
    serial_println("[segmap] direct entry bytes mismatch")
    false

@cfg(arm32)
fn stage_raw_image(as_handle: AddressSpace, file_bytes: [u8]) -> i32:
    val _as_handle = as_handle
    val _file_bytes = file_bytes
    -1

@cfg(arm32)
fn stage_elf64_load_image(as_handle: AddressSpace, file_bytes: [u8]) -> i32:
    val _as_handle = as_handle
    val _file_bytes = file_bytes
