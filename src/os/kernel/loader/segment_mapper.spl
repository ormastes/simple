    val _as_handle = as_handle
    val _file_bytes = file_bytes
    entry

@cfg(arm32)
fn verify_direct_load_entry(as_handle: AddressSpace, file_bytes: [u8], entry: u64) -> bool:
    val _as_handle = as_handle
    val _file_bytes = file_bytes
    val _entry = entry
    true

