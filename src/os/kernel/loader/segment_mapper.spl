fn map_all(as_handle: AddressSpace, segments: [UserLoadSegment], file_bytes: [u8]) -> Result<i32, text>:
    """Map every PT_LOAD segment in order; abort on first error.

    Returns Ok(number-of-segments-mapped) on success, Err otherwise.
    No-op (returns Ok(0)) when `segments` is empty.
    """
    var i: i64 = 0
    var mapped: i32 = 0
    while i < segments.len():
        val seg = segments[i]
        val r = map_segment(as_handle, seg, file_bytes)
        match r:
            case Ok(_):
                mapped = mapped + 1
            case Err(msg):
                return Err(msg)
        i = i + 1
    Ok(mapped)

fn highest_loaded_address(segments: [UserLoadSegment]) -> u64:
    """Return the page-aligned upper bound of the mapped image.

    Useful for placing the user stack below it, or for seeding an initial
    program break. Returns 0 when there are no segments.
    """
    var hi: u64 = 0
    var i: i64 = 0
    while i < segments.len():
        val seg = segments[i]
        val end = user_load_segment_virt_addr(seg) + user_load_segment_mem_size(seg)
        if end > hi:
            hi = end
        i = i + 1
    if hi == 0:
        return 0
    _page_align_up(hi)
