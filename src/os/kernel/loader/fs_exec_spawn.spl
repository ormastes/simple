pub struct FsExecPrepareResult:
    scheduler: Scheduler
    pid: i64
    entry: i64

fn _fs_exec_new_bootstrap_scheduler() -> Scheduler:
    """Create the one-CPU scheduler state fs-exec needs without importing the full scheduler hub."""
    # NOTE: module-level `pub val MAX_TASKS`/`PRIORITY_LEVELS` (scheduler_types.spl)
    # read as 0 on baremetal LLVM/cranelift targets — BSS clearing wipes
    # runtime-initialized globals. A 0 bound makes the loops below run zero times,
    # leaving `tasks`/`queues` empty so `tasks[0]` is an OOB garbage read that
    # mis-reports the bootstrap slot as busy. Use function-local literal bounds
    # (mirroring the canonical scheduler_types.spl values) to stay correct on bare metal.
    val local_max_tasks: i32 = 256
    val local_priority_levels: i32 = 5
    var tasks: [TaskControlBlock?] = []
    var i = 0
    while i < local_max_tasks:
        tasks.push(nil)
        i = i + 1
    var queues: [ReadyQueue] = []
    var p = 0
    while p < local_priority_levels:
        queues.push(ReadyQueue.new())
        p = p + 1
    Scheduler(
        tasks: tasks,
        current: TaskId(id: 0),
        current_by_cpu: [TaskId(id: 0)],
        preempt_pending_by_cpu: [nil],
        ready_queues: queues,
        cpu_runqueues: [CpuRunQueue.new(0 as u32)],
        topology: scheduler_flat_topology(1 as u32),
        rt_runtime_ns_by_cpu: [0],
        rt_period_ns_by_cpu: [0],
        rt_consumed_ns_by_cpu: [0],
        rt_replenish_ns_by_cpu: [0],
        rt_throttled_by_cpu: [false],
        deadline_remaining_ns_by_slot: [],
        deadline_period_start_ns_by_slot: [],
        deadline_miss_count_by_slot: [],
        deadline_overrun_count_by_slot: [],
        rt_base_priority_by_slot: [],
        trace_events: [],
        trace_head: 0,
        trace_count: 0,
        tick_count: 0,
        next_task_id: 1,
        green_execution_state: green_carrier_execution_state_new(1)
    )

pub fn fs_exec_read_executable_bytes(path: text) -> [u8]:
    """Read executable bytes through the active target's filesystem bridge."""
    _fs_exec_read_bytes(path)

@cfg(arm64)
fn _fs_exec_segment_count_for_log(image) -> i32:
    if user_process_image_entry(image) == 0:
        return 0
    1

@cfg(arm32)
fn _fs_exec_segment_count_for_log(image) -> i32:
    user_process_image_segment_count(image)

@cfg(riscv64)
fn _fs_exec_segment_count_for_log(image) -> i32:
    user_process_image_segment_count(image)

@cfg(riscv32)
fn _fs_exec_segment_count_for_log(image) -> i32:
    user_process_image_segment_count(image)

@cfg(x86_64)
fn _fs_exec_segment_count_for_log(image) -> i32:
    user_process_image_segment_count(image)

@cfg(x86)
fn _fs_exec_segment_count_for_log(image) -> i32:
    user_process_image_segment_count(image)

pub fn fs_exec_prepare_spawn_from_bytes(path: text, bytes: [u8], arch: Architecture, argv: [text], envp: [text]) -> FsExecPrepareResult:
    """Build a user image from already-resolved executable bytes and register a bootstrap task."""
    val byte_len = _byte_len(bytes)
    serial_println("[fs-exec] spawn:bytes path={path} len={byte_len}")
    if byte_len <= 4:
        serial_println("[fs-exec] spawn:resolve-fail path={path}")
        return FsExecPrepareResult(scheduler: _fs_exec_new_bootstrap_scheduler(), pid: -2, entry: 0)

    val image = build_user_process_image_unchecked(path, bytes, arch, argv, envp)
    serial_println(
        "[fs-exec] spawn:image entry={user_process_image_entry(image)} segments={_fs_exec_segment_count_for_log(image)}"
    )
    if user_process_image_entry(image) == 0:
        serial_println("[fs-exec] spawn:image-fail path={path}")
        return FsExecPrepareResult(scheduler: _fs_exec_new_bootstrap_scheduler(), pid: -8, entry: 0)

    var scheduler = _fs_exec_new_bootstrap_scheduler()
    # Boot/init compat wrapper (see cspace_spawn.spawn_full): FS-exec bootstrap
    # spawn still grants ambient authority until per-image SpawnSpec recipes are
    # wired here. Named + greppable so the ambient grant stays auditable.
    val scheduler_result: SchedulerBootstrapUserTaskResult = scheduler_create_bootstrap_user_task_pid(
        scheduler, image, TaskPriority.Normal, spawn_full()
    )
    scheduler = scheduler_result.scheduler
    val pid = scheduler_result.pid
    if pid == 0:
        serial_println("[fs-exec] spawn:scheduler-fail path={path}")
        return FsExecPrepareResult(scheduler: scheduler, pid: -12, entry: 0)

    serial_println(
        "[fs-exec] spawn:prepared path={path} pid={pid} entry={user_process_image_entry(image)} segments={_fs_exec_segment_count_for_log(image)}"
    )
    FsExecPrepareResult(scheduler: scheduler, pid: pid as i64, entry: user_process_image_entry(image) as i64)

pub fn fs_exec_prepare_spawn(path: text, argv: [text], envp: [text]) -> FsExecPrepareResult:
    """Resolve bytes, build an image, and register a bootstrap user task."""
    serial_println("[fs-exec] spawn:resolve path={path}")
    val bytes = _fs_exec_read_bytes(path)
    fs_exec_prepare_spawn_from_bytes(path, bytes, _fs_exec_active_arch(), argv, envp)

pub fn fs_exec_spawn(path: text, argv: [text], envp: [text]) -> i64:
    """Load a filesystem executable, register it, and perform the arch handoff."""
    fs_exec_spawn_as(0, path, argv, envp)

pub fn fs_exec_spawn_ring3(path: text, argv: [text], envp: [text]) -> i64:
    """Load a filesystem executable through the active arch's live user-mode handoff."""
    _fs_exec_spawn_ring3_active(path, argv, envp)

pub fn fs_exec_spawn_as(caller: i64, path: text, argv: [text], envp: [text]) -> i64:
    """Capability-gated spawn: checks FileExec + ProcessSpawn before loading.

    caller == 0 is the kernel-origin sentinel (bypasses capability check).
    Returns the new PID on success, or a negative errno on failure.
    """
    val gate = exec_cap_check(caller, path)
    if gate != 0:
        serial_println("[fs-exec] spawn:denied caller={caller} path={path} err={gate}")
        return gate as i64
    val prepared = fs_exec_prepare_spawn(path, argv, envp)
    if prepared.pid <= 0:
        return prepared.pid
    serial_println("[fs-exec] spawn:pid={prepared.pid} path={path}")
    prepared.pid
