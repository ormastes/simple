# Shared filesystem-exec scheduler bridge.
#
# Keeps executable-byte resolution, process-image construction, scheduler task
# creation, and common status mapping in one place. Per-arch differences are
# reduced to the active architecture selection, byte-source bridge, and the
# optional live handoff hook.

use os.kernel.arch.arch_context.{Architecture}
use os.kernel.loader.process_image.{build_user_process_image_unchecked}
use os.kernel.scheduler.scheduler.{Scheduler, scheduler_create_bootstrap_user_task_pid}
use os.kernel.types.capability_types.{CapabilitySet}
use os.kernel.types.task_types.{TaskPriority, user_process_image_entry, user_process_image_segment_count}

extern fn rt_arm_array_len_u32(arr: [u8]) -> u32
extern fn serial_println(msg: text)

use os.kernel.arch.arm64.user_entry.{dispatch_enter_user_blocking_probe as fs_exec_dispatch_arm64_probe}
use os.kernel.arch.riscv64.user_entry.{dispatch_enter_user_blocking_probe as fs_exec_dispatch_riscv64_probe}
use os.kernel.arch.x86_64.user_entry.{dispatch_enter_user_blocking as fs_exec_dispatch_x86_64}

@cfg(arm64)
use os.services.vfs.arm_fs_exec_vfs.{arm_fs_exec_read_file_bytes}

@cfg(arm32)
use os.services.vfs.arm_fs_exec_vfs.{arm_fs_exec_read_file_bytes}

@cfg(x86_64)
use os.services.vfs.vfs_init.{g_vfs_read_executable_bytes}

@cfg(x86)
use os.services.vfs.vfs_init.{g_vfs_read_executable_bytes}

@cfg(riscv64)
use os.services.vfs.vfs_init.{g_vfs_read_executable_bytes}

@cfg(riscv32)
use os.services.vfs.vfs_init.{g_vfs_read_executable_bytes}

@cfg(x86_64)
fn _fs_exec_active_arch() -> Architecture:
    Architecture.X86_64

@cfg(x86)
fn _fs_exec_active_arch() -> Architecture:
    Architecture.X86

@cfg(arm64)
fn _fs_exec_active_arch() -> Architecture:
    Architecture.Arm64

@cfg(arm32)
fn _fs_exec_active_arch() -> Architecture:
    Architecture.Arm32

@cfg(riscv64)
fn _fs_exec_active_arch() -> Architecture:
    Architecture.Riscv64

@cfg(riscv32)
fn _fs_exec_active_arch() -> Architecture:
    Architecture.Riscv32

@cfg(arm64)
fn _fs_exec_read_bytes(path: text) -> [u8]:
    arm_fs_exec_read_file_bytes(path)

@cfg(arm32)
fn _fs_exec_read_bytes(path: text) -> [u8]:
    arm_fs_exec_read_file_bytes(path)

@cfg(x86_64)
fn _fs_exec_read_bytes(path: text) -> [u8]:
    g_vfs_read_executable_bytes(path)

@cfg(x86)
fn _fs_exec_read_bytes(path: text) -> [u8]:
    g_vfs_read_executable_bytes(path)

@cfg(riscv64)
fn _fs_exec_read_bytes(path: text) -> [u8]:
    g_vfs_read_executable_bytes(path)

@cfg(riscv32)
fn _fs_exec_read_bytes(path: text) -> [u8]:
    g_vfs_read_executable_bytes(path)

fn _fs_exec_dispatch_user_handoff(pid: u64, scheduler: Scheduler) -> i64:
    match _fs_exec_active_arch():
        case Architecture.Arm64:
            fs_exec_dispatch_arm64_probe(pid, scheduler)
        case Architecture.Riscv64:
            fs_exec_dispatch_riscv64_probe(pid, scheduler)
        case Architecture.X86_64:
            fs_exec_dispatch_x86_64(pid, scheduler)
        case _:
            0

pub struct FsExecPrepareResult:
    scheduler: Scheduler
    pid: i64

pub fn fs_exec_read_executable_bytes(path: text) -> [u8]:
    """Read executable bytes through the active target's filesystem bridge."""
    _fs_exec_read_bytes(path)

pub fn fs_exec_prepare_spawn(path: text, argv: [text], envp: [text]) -> FsExecPrepareResult:
    """Resolve bytes, build an image, and register a bootstrap user task."""
    serial_println("[fs-exec] spawn:resolve path={path}")
    val bytes = _fs_exec_read_bytes(path)
    val byte_len = rt_arm_array_len_u32(bytes)
    serial_println("[fs-exec] spawn:bytes path={path} len={byte_len}")
    if byte_len <= 4:
        serial_println("[fs-exec] spawn:resolve-fail path={path}")
        return FsExecPrepareResult(scheduler: Scheduler.new_bootstrap(), pid: -2)

    val image = build_user_process_image_unchecked(path, bytes, _fs_exec_active_arch(), argv, envp)
    serial_println(
        "[fs-exec] spawn:image entry={user_process_image_entry(image)} segments={user_process_image_segment_count(image)}"
    )
    if user_process_image_entry(image) == 0:
        serial_println("[fs-exec] spawn:image-fail path={path}")
        return FsExecPrepareResult(scheduler: Scheduler.new_bootstrap(), pid: -8)

    var scheduler = Scheduler.new_bootstrap()
    val scheduler_result = scheduler_create_bootstrap_user_task_pid(
        scheduler, image, TaskPriority.Normal, CapabilitySet.full()
    )
    scheduler = scheduler_result.0
    val pid = scheduler_result.1
    if pid == 0:
        serial_println("[fs-exec] spawn:scheduler-fail path={path}")
        return FsExecPrepareResult(scheduler: scheduler, pid: -12)

    FsExecPrepareResult(scheduler: scheduler, pid: pid as i64)

pub fn fs_exec_spawn(path: text, argv: [text], envp: [text]) -> i64:
    """Load a filesystem executable, register it, and perform the arch handoff."""
    val prepared = fs_exec_prepare_spawn(path, argv, envp)
    if prepared.pid <= 0:
        return prepared.pid

    val handoff = _fs_exec_dispatch_user_handoff(prepared.pid as u64, prepared.scheduler)
    if handoff != 0:
        serial_println("[fs-exec] spawn:handoff-fail path={path} pid={prepared.pid}")
        return -16

    serial_println("[fs-exec] spawn:pid={prepared.pid} path={path}")
    prepared.pid
