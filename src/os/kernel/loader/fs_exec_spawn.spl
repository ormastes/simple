# Shared filesystem-exec scheduler bridge.
#
# Keeps executable-byte resolution, process-image construction, scheduler task
# creation, and common status mapping in one place. Per-arch differences are
# reduced to the active architecture selection, byte-source bridge, and the
# optional live handoff hook.

use os.kernel.arch.arch_context.{Architecture}
use os.kernel.loader.process_image.{build_user_process_image_unchecked}
use os.kernel.loader.cap_exec_gate.{exec_cap_check}
use os.kernel.scheduler.scheduler_types.{
    Scheduler, SchedulerBootstrapUserTaskResult,
    TaskControlBlock, ReadyQueue, CpuRunQueue
}
use os.kernel.scheduler.green_carrier.{green_carrier_execution_state_new}
use os.kernel.scheduler.scheduler_arm_bootstrap.{scheduler_create_bootstrap_user_task_pid}
use os.kernel.ipc.cspace_spawn.{spawn_full}
use os.kernel.types.task_types.{TaskId, TaskPriority, scheduler_flat_topology, user_process_image_entry, user_process_image_segment_count}

@cfg(arm64)
extern fn rt_arm_array_len_u32(arr: [u8]) -> u32
extern fn serial_println(msg: text)

@cfg(x86_64)
use os.kernel.loader.x86_64_fs_exec_spawn.{x86_64_fs_exec_spawn}

# `fs_exec_prepare_spawn_from_bytes` is a shared cross-arch bridge (x86_64,
# arm64, riscv, ...). Only the arm64 freestanding ABI hands out raw
# (untagged) array pointers that need the `rt_arm_array_len_u32` raw-safe
# length probe (see byte_utils.spl / process_image.spl `_byte_len` for the
# same per-arch split); every other arch's arrays are plain tagged values
# where `.len()` is correct. Calling the arm64-only extern unconditionally
# breaks on any target where the interpreter/runtime doesn't implement it
# (e.g. `bin/simple test` on x86_64: "unknown extern function: rt_arm_array_len_u32").
@cfg(arm64)
fn _byte_len(data: [u8]) -> u32:
    rt_arm_array_len_u32(data)

@cfg(arm32)
fn _byte_len(data: [u8]) -> u32:
    data.len() as u32

@cfg(riscv64)
fn _byte_len(data: [u8]) -> u32:
    data.len() as u32

@cfg(riscv32)
fn _byte_len(data: [u8]) -> u32:
    data.len() as u32

@cfg(x86_64)
fn _byte_len(data: [u8]) -> u32:
    data.len() as u32

@cfg(x86)
fn _byte_len(data: [u8]) -> u32:
    data.len() as u32

