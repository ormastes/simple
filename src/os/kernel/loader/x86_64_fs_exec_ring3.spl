# x86_64 filesystem-exec ring-3 control-transfer handoff.
#
# The GENERAL spawn (x86_64_fs_exec_spawn_as -> fs_exec_prepare_spawn_from_bytes
# -> build_user_process_image_unchecked) builds a UserProcessImage but never maps
# its segments into a live address space and never transfers control to ring 3 —
# only the one-shot smoke kernel did that, for a hardcoded blob. This module is
# the missing handoff: it maps a general-built UserProcessImage into a fresh user
# address space and iretq's to CPL3, reusing the ring-3 primitives that are
# actually present and proven in this checkout (create_user_address_space +
# vmm_clone_kernel_low_identity + vmm_map_page_in + vmm_copy_bytes_to_phys +
# arch_x86_64_enter_user_task — the same set ring3_smoke_entry.spl uses).
#
# Freestanding discipline (native-build does NOT run module-level `val`
# initializers — see ring3_smoke_entry.spl and the module-val note below):
#   * every constant here is FUNCTION-LOCAL,
#   * zero-arg accessors are always called with explicit parens,
#   * no `[u8]` array literals,
#   * PT_LOAD segments + the entry point are parsed INLINE from image.file_bytes
#     (a plain [u8] copy of the ELF that is always valid) via the module-val-free
#     byte_utils readers.
#
# Why not image.segments / image.entry / image.initial_sp directly? The shared
# elf_loader.spl (parse), stack_builder.spl (SysV frame) and process_image.spl
# (X86_64_USER_STACK_TOP) chains all key on module-level `val`s that read garbage
# under freestanding native-build, so those STRUCTURED fields are unreliable here.
# `image.file_bytes` is the reliable channel; the structured fields are logged for
# diagnosis but not trusted. Fixing that freestanding module-val bug so the whole
# general path is usable freestanding is tracked as a separate blocker.

use os.kernel.memory.vmm_address_space.{
    create_user_address_space, vmm_map_user_low_page,
    vmm_clone_kernel_low_private, vmm_zero_phys_range
}
use os.kernel.types.memory_types.{VmFlags, VirtAddr, PhysAddr}
use os.kernel.types.task_types.{
    TaskContext, AddressSpace, UserProcessImage,
    user_process_image_entry, user_process_image_segment_count,
    user_process_image_file_bytes, user_process_image_initial_sp,
    user_process_image_stack_top, user_process_image_initial_stack_bytes
}
use os.kernel.arch.x86_64.context.{arch_x86_64_enter_user_task}
use os.kernel.boot.mmio.{mmio_read8, mmio_read16, mmio_read32, mmio_read64, mmio_write8}

extern fn serial_println(msg: text)
extern fn pmm_alloc_page_raw() -> u64
extern fn simpleos_fat32_stream_read_at(file_off: u64, dst: u64, len: u64) -> i64
extern fn rt_text_to_bytes(s: text) -> [u8]
# Multi-command SSH: rt_x86_enter_user_first saves a kernel savepoint before
# iretq'ing to CPL3; on the ring-3 program's exit(2) syscall the kernel longjmps
# back here (so arch_x86_64_enter_user_task RETURNS) and stashes the exit status.
# rax is clobbered by the intervening serial_println calls, so read it explicitly.
extern fn rt_x86_ring3_exit_rc() -> i64

# Little-endian scalar reads straight off the identity-mapped RAW file buffer.
# The [u8] channel (byte_utils/read_*_le over image.file_bytes) reads boxed
# RuntimeValues stride-1 under freestanding native-build → phoff=16 garbage; the
# raw buffer holds the unboxed on-disk bytes, so mmio reads decode correctly
# (mirrors fs_elf_exec_smoke_entry.spl's _rd*).
fn _rd8(base: u64, off: u64)  -> u64: (mmio_read8(base + off)) as u64
fn _rd16(base: u64, off: u64) -> u64: (mmio_read16(base + off)) as u64
fn _rd32(base: u64, off: u64) -> u64: (mmio_read32(base + off)) as u64
fn _rd64(base: u64, off: u64) -> u64: mmio_read64(base + off)

fn _wr64(addr: u64, value: u64):
    var i: u64 = 0
    while i < 8:
        mmio_write8(addr + i, ((value >> (i * 8)) & 0xFF) as u8)
        i = i + 1

fn _text_z_size(value: text) -> u64:
    (rt_text_to_bytes(value).len() as u64) + 1

fn _write_text_z(phys: u64, offset: u64, value: text) -> u64:
    val raw = rt_text_to_bytes(value)
    var i: i64 = 0
    while i < raw.len():
        mmio_write8(phys + offset + (i as u64), raw[i])
        i = i + 1
    mmio_write8(phys + offset + (raw.len() as u64), 0 as u8)
    (raw.len() as u64) + 1

fn _build_sysv_stack_frame(stack_phys: u64, stack_top: u64, binary_path: text, argv: [text], envp: [text]) -> u64:
    """Build a bounded one-page argc/argv/envp/auxv frame; return zero on overflow."""
    val PAGE: u64 = 4096
    val ALIGN_MASK: u64 = 0xFFFFFFFFFFFFFFF0
    val MAX_ITEMS: i64 = 64
    val AT_PAGESZ: u64 = 6
    val AT_EXECFN: u64 = 31
    val AT_NULL: u64 = 0
    if argv.len() > MAX_ITEMS or envp.len() > MAX_ITEMS:
        return 0

    var strings_size = _text_z_size(binary_path)
    if strings_size > PAGE:
        return 0
    var i: i64 = 0
    while i < argv.len():
        val item_size = _text_z_size(argv[i])
        if item_size > PAGE - strings_size:
            return 0
        strings_size = strings_size + item_size
        i = i + 1
    var e: i64 = 0
    while e < envp.len():
        val item_size = _text_z_size(envp[e])
        if item_size > PAGE - strings_size:
            return 0
        strings_size = strings_size + item_size
        e = e + 1

    val argc: u64 = (argv.len() as u64) + 1
    val envc: u64 = envp.len() as u64
    # argc, argv+NULL, envp+NULL, then AT_PAGESZ, AT_EXECFN, AT_NULL pairs.
    val fixed_slots: u64 = 1 + argc + 1 + envc + 1 + 6
    val fixed_size = fixed_slots * 8
    if fixed_size > PAGE or strings_size > PAGE - fixed_size:
        return 0

    val user_rsp = (stack_top - fixed_size - strings_size) & ALIGN_MASK
    val page_base = stack_top - PAGE
    if user_rsp < page_base:
        return 0
    val frame_off = user_rsp - page_base
    var slot: u64 = 0
    _wr64(stack_phys + frame_off + (slot * 8), argc)
    slot = slot + 1

    var string_off = frame_off + fixed_size
    val execfn_addr = page_base + string_off
    _wr64(stack_phys + frame_off + (slot * 8), execfn_addr)
    slot = slot + 1
    string_off = string_off + _write_text_z(stack_phys, string_off, binary_path)
    i = 0
    while i < argv.len():
        _wr64(stack_phys + frame_off + (slot * 8), page_base + string_off)
        slot = slot + 1
        string_off = string_off + _write_text_z(stack_phys, string_off, argv[i])
        i = i + 1
    _wr64(stack_phys + frame_off + (slot * 8), 0)
    slot = slot + 1

    e = 0
    while e < envp.len():
        _wr64(stack_phys + frame_off + (slot * 8), page_base + string_off)
        slot = slot + 1
        string_off = string_off + _write_text_z(stack_phys, string_off, envp[e])
        e = e + 1
    _wr64(stack_phys + frame_off + (slot * 8), 0)
    slot = slot + 1
    _wr64(stack_phys + frame_off + (slot * 8), AT_PAGESZ)
    _wr64(stack_phys + frame_off + ((slot + 1) * 8), PAGE)
    _wr64(stack_phys + frame_off + ((slot + 2) * 8), AT_EXECFN)
    _wr64(stack_phys + frame_off + ((slot + 3) * 8), execfn_addr)
    _wr64(stack_phys + frame_off + ((slot + 4) * 8), AT_NULL)
    _wr64(stack_phys + frame_off + ((slot + 5) * 8), 0)
    user_rsp

# Map every PT_LOAD of the ELF held in the raw buffer `blob` into `space` at its
# p_vaddr, page by page (one frame per page, so segments sharing a page are mapped
# once with the UNION of their perms). Each frame is zeroed (BSS) before the
# file-backed range of every covering segment is streamed from the opened file.
# Per-page perms: user_rw if any covering PT_LOAD is writable, else user_rx.
# Returns 1 on success, 0 on failure.
fn _map_pt_loads(space: AddressSpace, blob: u64, file_len: u64, stream_file: bool) -> i64:
    val PAGE: u64 = 4096
    val PT_LOAD: u64 = 1
    val PF_W: u64 = 2

    val phoff = _rd64(blob, 32)
    val phentsize = _rd16(blob, 54)
    val phnum = _rd16(blob, 56)
    serial_println("[spawn] phoff={phoff} phentsize={phentsize} phnum={phnum}")
    if phnum == 0 or phentsize < 56:
        serial_println("[spawn] FAIL no program headers")
        return 0
    # Bound the phdr table + each segment's file range against the known file size,
    # so a corrupt/oversized phdr can't drive mmio reads past the raw buffer into
    # adjacent kernel memory (info-leak / fault) — the raw buffer carries no length.
    if phoff < 64 or phoff > file_len or phnum > ((file_len - phoff) / phentsize):
        serial_println("[spawn] FAIL phdr table OOB phoff={phoff} phnum={phnum} phentsize={phentsize} file_len={file_len}")
        return 0

    var lo: u64 = 0xFFFFFFFFFFFFFFFF
    var hi: u64 = 0
    var i: u64 = 0
    while i < phnum:
        val ph = phoff + (i * phentsize)
        if _rd32(blob, ph) == PT_LOAD:
            val foff = _rd64(blob, ph + 8)
            val fsz = _rd64(blob, ph + 32)
            if foff > file_len or fsz > file_len - foff:
                serial_println("[spawn] FAIL segment file range OOB foff={foff} fsz={fsz} file_len={file_len}")
                return 0
            val sv = _rd64(blob, ph + 16)
            val memsz = _rd64(blob, ph + 40)
            val U64_MAX: u64 = 0xFFFFFFFFFFFFFFFF
            if fsz > memsz or memsz > U64_MAX - sv or fsz > U64_MAX - sv:
                serial_println("[spawn] FAIL segment address overflow sv={sv} fsz={fsz} memsz={memsz}")
                return 0
            val se = sv + memsz
            if se > U64_MAX - (PAGE - 1):
                serial_println("[spawn] FAIL segment page range overflow sv={sv} se={se}")
                return 0
            if sv < lo:
                lo = sv
            if se > hi:
                hi = se
        i = i + 1
    if hi == 0:
        serial_println("[spawn] FAIL no PT_LOAD segments")
        return 0

    val lo_page = lo & (~(PAGE - 1))
    val hi_page = (hi + PAGE - 1) & (~(PAGE - 1))
    serial_println("[spawn] image span lo=0x{lo_page} hi=0x{hi_page}")

    var va: u64 = lo_page
    while va < hi_page:
        val phys = pmm_alloc_page_raw()
        if phys == 0:
            serial_println("[spawn] FAIL frame alloc va=0x{va}")
            return 0
        vmm_zero_phys_range(phys, PAGE)

        var writable = false
        var j: u64 = 0
        while j < phnum:
            val ph = phoff + (j * phentsize)
            if _rd32(blob, ph) == PT_LOAD:
                val sv = _rd64(blob, ph + 16)
                val se = sv + _rd64(blob, ph + 40)
                val overlaps = (sv < (va + PAGE)) and (se > va)
                if overlaps and ((_rd32(blob, ph + 4) & PF_W) != 0):
                    writable = true
            j = j + 1

        val flags = if writable: VmFlags.user_rw() else: VmFlags.user_rx()
        if not vmm_map_user_low_page(space, VirtAddr(addr: va), PhysAddr(addr: phys), flags):
            serial_println("[spawn] FAIL map page va=0x{va}")
            return 0

        var k: u64 = 0
        while k < phnum:
            val ph = phoff + (k * phentsize)
            if _rd32(blob, ph) == PT_LOAD:
                val sv = _rd64(blob, ph + 16)
                val foff = _rd64(blob, ph + 8)
                val fsz = _rd64(blob, ph + 32)
                var copy_start = va
                if copy_start < sv:
                    copy_start = sv
                var copy_end = va + PAGE
                val sfe = sv + fsz
                if copy_end > sfe:
                    copy_end = sfe
                if copy_start < copy_end:
                    val clen = copy_end - copy_start
                    val file_pos = foff + (copy_start - sv)
                    val dst = phys + (copy_start - va)
                    if stream_file:
                        val read_len = simpleos_fat32_stream_read_at(file_pos, dst, clen)
                        if read_len < 0 or (read_len as u64) != clen:
                            serial_println("[spawn] FAIL short PT_LOAD read off={file_pos} want={clen} got={read_len}")
                            return 0
                    else:
                        var t: u64 = 0
                        while t < clen:
                            mmio_write8(dst + t, mmio_read8(blob + file_pos + t))
                            t = t + 1
            k = k + 1

        va = va + PAGE

    serial_println("[spawn] PT_LOAD segments mapped")
    1

fn _x86_64_fs_exec_enter_ring3(binary_path: text, blob: u64, file_len: u64, stream_file: bool, argv: [text], envp: [text]) -> i64:
    # Parse the ELF from the identity-mapped RAW file buffer `blob` (mmio), NOT the
    # [u8] image.file_bytes channel — freestanding native-build stores [u8] as boxed
    # RuntimeValues so byte_utils reads stride-1 garbage (phoff=16). Guard that the
    # buffer still holds our ELF (survived pmm/vmm/builder) before trusting it.
    if blob == 0:
        serial_println("[spawn] FAIL raw blob address is 0")
        return -5
    if _rd32(blob, 0) != 0x464C457F:
        serial_println("[spawn] FAIL blob not ELF (clobbered/wrong file) w0={_rd32(blob, 0)}")
        return -5
    if _rd8(blob, 4) != 2:
        serial_println("[spawn] FAIL not ELFCLASS64 class={_rd8(blob, 4)}")
        return -5

    # Trustworthy entry: ELF e_entry @ offset 24, read straight from the raw buffer.
    val entry = _rd64(blob, 24)
    serial_println("[spawn] parsed entry=0x{entry}")

    val space = create_user_address_space()
    if space.phys_root == 0 or space.phys_root == 1:
        serial_println("[spawn] FAIL user-AS synthetic root={space.phys_root}")
        return -1
    # PRIVATE low-half clone: gives this AS its own PML4[0] PDPT so PT_LOADs at
    # low VAs (clang links at 0x10000000, PML4[0]) can install private 4K user
    # pages — vmm_map_user_low_page splits the shared kernel 2MiB identity page
    # copy-on-map instead of corrupting the kernel's tables. Safe for the PML4[1]
    # fixture/stack VAs too (fresh tables, no privatization triggers).
    if not vmm_clone_kernel_low_private(space.phys_root):
        serial_println("[spawn] FAIL clone kernel low private root={space.phys_root}")
        return -1
    serial_println("[spawn] user AS ready (private low) root={space.phys_root}")

    if _map_pt_loads(space, blob, file_len, stream_file) == 0:
        serial_println("[spawn] FAIL segment mapping")
        return -2

    # User stack: a bounded RW low-canonical region in the process-private page
    # tables. The top page carries the populated SysV binary_path/argv/envp frame;
    # the remaining 31 pages provide immediate stack growth without assuming a
    # particular ELF link address.
    val PAGE: i64 = 4096
    val STACK_TOP: i64 = 0x8000200000
    val STACK_PAGES: i64 = 32
    var top_phys: u64 = 0
    var p: i64 = 0
    while p < STACK_PAGES:
        val sva = STACK_TOP - ((p + 1) * PAGE)
        val sph = pmm_alloc_page_raw()
        if sph == 0:
            serial_println("[spawn] FAIL stack alloc p={p}")
            return -3
        vmm_zero_phys_range(sph, PAGE.to_u64())
        if not vmm_map_user_low_page(space, VirtAddr(addr: sva.to_u64()), PhysAddr(addr: sph), VmFlags.user_rw()):
            serial_println("[spawn] FAIL stack map p={p}")
            return -4
        # Capture the TOP stack page's physical address (p==0: sva==STACK_TOP-PAGE
        # ==top_page_base). Low-canonical phys is identity-mapped in the kernel, so
        # kernel-context mmio writes to top_phys land in the user stack — exactly
        # how _map_pt_loads copies segment bytes (mmio_write8(phys+off,…)).
        if p == 0:
            top_phys = sph
        p = p + 1

    # Keep the initial frame in the mapped top page. The bounded builder writes
    # binary_path as argv[0], caller argv/envp strings, NULL terminators, and auxv.
    val PAGE_U: u64 = 4096
    val STACK_TOP_U: u64 = 0x8000200000
    val TOP_PAGE_BASE_U: u64 = STACK_TOP_U - PAGE_U
    val user_rsp_u = _build_sysv_stack_frame(top_phys, STACK_TOP_U, binary_path, argv, envp)
    if user_rsp_u == 0:
        serial_println("[spawn] FAIL argv/envp exceed one-page startup bound")
        return -4
    val frame_off: u64 = user_rsp_u - TOP_PAGE_BASE_U
    val argc_rb = _rd64(top_phys + frame_off, 0)
    val expected_argc = (argv.len() as u64) + 1
    serial_println("[spawn] frame argc readback={argc_rb} expected={expected_argc}")
    if argc_rb != expected_argc:
        return -4
    serial_println("[spawn] user stack mapped top=0x{STACK_TOP} pages={STACK_PAGES} rsp=0x{user_rsp_u}")

    val ctx = TaskContext(
        rax: 0, rbx: 0, rcx: 0, rdx: 0,
        rsi: 0, rdi: 0, rbp: 0, rsp: user_rsp_u,
        r8: 0, r9: 0, r10: 0, r11: 0,
        r12: 0, r13: 0, r14: 0, r15: 0,
        rip: entry,
        rflags: 0x3002,
        cs: 0x2b,
        ss: 0x23,
        fpu_state: 0
    )
    serial_println("[spawn] entering user cs=0x2b iopl=3 rip=0x{entry} rsp=0x{user_rsp_u}")
    arch_x86_64_enter_user_task(ctx, space.phys_root)

    # Multi-command SSH: control lands HERE when the ring-3 program exits — the
    # exit(2) syscall longjmps back through rt_x86_enter_user_first's savepoint,
    # so arch_x86_64_enter_user_task returns instead of QEMU halting. Surface the
    # program's exit status up to the sshd accept loop, which then accepts the
    # next connection/command in the same boot.
    #
    # Remaining gap: the user address space built above is abandoned (its PML4 +
    # PT_LOAD/stack frames leak); each spawn calls create_user_address_space()
    # fresh with fresh pmm frames, so a later command's ELF load cannot be
    # corrupted by this one's mappings — but the frames are not reclaimed.
    val exit_rc = rt_x86_ring3_exit_rc()
    serial_println("[spawn] ring3 program exited rc={exit_rc} (kernel resumed)")
    exit_rc

pub fn x86_64_fs_exec_enter_stream_ring3(binary_path: text, header_blob: u64, file_len: u64, argv: [text], envp: [text]) -> i64:
    """Stream an opened filesystem ELF into a fresh user address space."""
    serial_println("[spawn] stream path={binary_path} file_len={file_len}")
    _x86_64_fs_exec_enter_ring3(binary_path, header_blob, file_len, true, argv, envp)

pub fn x86_64_fs_exec_enter_image_ring3(image: UserProcessImage, blob: u64, argv: [text], envp: [text]) -> i64:
    """Map a general-built UserProcessImage into a fresh user AS and enter ring 3."""
    val fb = user_process_image_file_bytes(image)
    val img_entry = user_process_image_entry(image)
    val seg_count = user_process_image_segment_count(image)
    val builder_sp = user_process_image_initial_sp(image)
    val builder_top = user_process_image_stack_top(image)
    val stk_bytes = user_process_image_initial_stack_bytes(image)
    serial_println("[spawn] image path={image.binary_path} entry=0x{img_entry} segments={seg_count} builder_top=0x{builder_top} builder_sp=0x{builder_sp} stk_bytes={stk_bytes.len()} file_len={fb.len()}")
    _x86_64_fs_exec_enter_ring3(image.binary_path, blob, fb.len().to_u64(), false, argv, envp)
