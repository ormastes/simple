# x86_64 filesystem-exec ring-3 control-transfer handoff.
#
# The GENERAL spawn (x86_64_fs_exec_spawn_as -> fs_exec_prepare_spawn_from_bytes
# -> build_user_process_image_unchecked) builds a UserProcessImage but never maps
# its segments into a live address space and never transfers control to ring 3 —
# only the one-shot smoke kernel did that, for a hardcoded blob. This module is
# the missing handoff: it maps a general-built UserProcessImage into a fresh user
# address space and iretq's to CPL3, reusing the ring-3 primitives that are
# actually present and proven in this checkout (create_user_address_space +
# vmm_clone_kernel_low_identity + vmm_map_page_in + vmm_copy_bytes_to_phys +
# arch_x86_64_enter_user_task — the same set ring3_smoke_entry.spl uses).
#
# Freestanding discipline (native-build does NOT run module-level `val`
# initializers — see ring3_smoke_entry.spl and the module-val note below):
#   * every constant here is FUNCTION-LOCAL,
#   * zero-arg accessors are always called with explicit parens,
#   * no `[u8]` array literals,
#   * PT_LOAD segments + the entry point are parsed INLINE from image.file_bytes
#     (a plain [u8] copy of the ELF that is always valid) via the module-val-free
#     byte_utils readers.
#
# Why not image.segments / image.entry / image.initial_sp directly? The shared
# elf_loader.spl (parse), stack_builder.spl (SysV frame) and process_image.spl
# (X86_64_USER_STACK_TOP) chains all key on module-level `val`s that read garbage
# under freestanding native-build, so those STRUCTURED fields are unreliable here.
# `image.file_bytes` is the reliable channel; the structured fields are logged for
# diagnosis but not trusted. Fixing that freestanding module-val bug so the whole
# general path is usable freestanding is tracked as a separate blocker.

use os.kernel.memory.vmm_address_space.{
    create_user_address_space, vmm_map_page_in,
    vmm_clone_kernel_low_identity, vmm_zero_phys_range
}
use os.kernel.types.memory_types.{VmFlags, VirtAddr, PhysAddr}
use os.kernel.types.task_types.{
    TaskContext, AddressSpace, UserProcessImage,
    user_process_image_entry, user_process_image_segment_count,
    user_process_image_file_bytes, user_process_image_initial_sp,
    user_process_image_stack_top, user_process_image_initial_stack_bytes
}
use os.kernel.arch.x86_64.context.{arch_x86_64_enter_user_task}
use os.kernel.boot.mmio.{mmio_read8, mmio_read16, mmio_read32, mmio_read64, mmio_write8}

extern fn serial_println(msg: text)
extern fn pmm_alloc_page_raw() -> u64
extern fn rt_text_to_bytes(s: text) -> [u8]
# Decode a single boxed [u8] element. Under freestanding native-build [u8]
# arrays store 8-byte boxed RuntimeValues, so plain `arr[i]` reads stride-1
# garbage (ELF magic 0x7F arrives as 0xF8=127<<3); rt_bytes_u8_at decodes +
# bounds-checks (mirrors byte_utils.byte_at).
extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

# Little-endian scalar reads straight off the identity-mapped RAW file buffer.
# The [u8] channel (byte_utils/read_*_le over image.file_bytes) reads boxed
# RuntimeValues stride-1 under freestanding native-build → phoff=16 garbage; the
# raw buffer holds the unboxed on-disk bytes, so mmio reads decode correctly
# (mirrors fs_elf_exec_smoke_entry.spl's _rd*).
fn _rd8(base: u64, off: u64)  -> u64: (mmio_read8(base + off)) as u64
fn _rd16(base: u64, off: u64) -> u64: (mmio_read16(base + off)) as u64
fn _rd32(base: u64, off: u64) -> u64: (mmio_read32(base + off)) as u64
fn _rd64(base: u64, off: u64) -> u64: mmio_read64(base + off)

fn _wr64(addr: u64, value: u64):
    var i: u64 = 0
    while i < 8:
        mmio_write8(addr + i, ((value >> (i * 8)) & 0xFF) as u8)
        i = i + 1

# Translate a virtual stack address to a physical address WITHIN the top stack
# page only. The SysV initial frame is tiny (argc/argv/envp/auxv plus the
# argv[0] path string — ~74 bytes for the argv=[]/path case) and always fits in
# one page, so we translate via a plain `top_phys: u64` (captured at the mapping
# loop) instead of threading the boxed `[u64] stk_phys` array through the hot
# write path. Freestanding native-build stores array elements as boxed
# RuntimeValues, so `stk_phys[i]` read back a shifted/garbage phys — the same
# array-boxing hazard the rest of this module avoids by using raw mmio. Returns
# 0 (a phys of 0 never occurs for an in-bounds vaddr since top_phys != 0) when
# vaddr falls outside the top page.
fn _top_phys_for_vaddr(top_phys: u64, stack_top: u64, vaddr: u64) -> u64:
    val PAGE: u64 = 4096
    val top_page_base = stack_top - PAGE
    if vaddr < top_page_base or vaddr >= stack_top:
        return 0
    top_phys + (vaddr - top_page_base)

fn _stack_write8(top_phys: u64, stack_top: u64, vaddr: u64, value: u8) -> bool:
    val phys = _top_phys_for_vaddr(top_phys, stack_top, vaddr)
    if phys == 0:
        return false
    mmio_write8(phys, value)
    true

fn _stack_write64(top_phys: u64, stack_top: u64, vaddr: u64, value: u64) -> bool:
    val phys = _top_phys_for_vaddr(top_phys, stack_top, vaddr)
    if phys == 0:
        return false
    _wr64(phys, value)
    true

# Write a NUL-terminated string. Each byte is decoded via rt_bytes_u8_at — plain
# `raw[i]` on a boxed [u8] reads stride-1 garbage under freestanding native-build.
fn _stack_write_cstr(top_phys: u64, stack_top: u64, vaddr: u64, s: text) -> bool:
    val raw = rt_text_to_bytes(s)
    val n = raw.len()
    var i: i64 = 0
    while i < n:
        val b = ((rt_bytes_u8_at(raw, i)) & 0xFF) as u8
        if not _stack_write8(top_phys, stack_top, vaddr + i.to_u64(), b):
            return false
        i = i + 1
    _stack_write8(top_phys, stack_top, vaddr + n.to_u64(), 0 as u8)

# NOTE (M2 blocker — DEFERRED, kept intentionally; do not delete): this frame
# builder and its write helpers (_top_phys_for_vaddr / _stack_write8 /
# _stack_write64 / _stack_write_cstr) are currently UNUSED — the M1 handoff
# bypasses them and uses a bare STACK_TOP-16 rsp (see the call site in
# x86_64_fs_exec_enter_image_ring3). Reason: under freestanding native-build the
# phys translation is broken — _top_phys_for_vaddr/_stack_write64 returned 0 for
# an IN-RANGE vaddr (QEMU: "argv-frame fail: write64 min argc" on rsp0=
# 0x80001FFFE0, which is inside [top_page_base=0x80001FF000, stack_top=
# 0x8000200000)), so the very first _stack_write64 aborted. Suspect u64 parameter
# passing or the `vaddr < top_page_base or vaddr >= stack_top` range comparison
# mis-compiling in freestanding native-build (the same module-val / boxing hazard
# class this module elsewhere avoids by reading via raw mmio). Real-argv programs
# (M2) need this translation fixed before the SysV frame can be written.
#
# Build a SysV-ABI initial stack (argc, argv[], NULL, envp[], NULL, auxv AT_NULL)
# growing down from stack_top, entirely within the top stack page. A distinct
# serial diagnostic precedes every early return so a QEMU run pinpoints the
# failing step. Returns 0 on failure, otherwise a 16-byte-aligned user rsp.
#
# EMPTY-ARGV FAST PATH (argv=[]/envp=[]): build a MINIMAL argc=0 frame using
# ONLY _stack_write64 — no rt_text_to_bytes, no _stack_write_cstr. The ring-3
# verification payload ignores argc/argv/rsp entirely (it only emits FDR via
# `out` + exits via syscall 60), and rt_text_to_bytes(image.binary_path) on a
# freestanding struct-field text is unreliable — the [u8]/text conversion drove
# the cstr write out of bounds ("[spawn] argv-frame fail: cstr"). Sidestepping
# text conversion both unblocks ring-3 AND isolates the bug: if the minimal path
# ALSO fails it emits a "write64 min ..." diag, proving the phys translation
# itself is broken (deeper) rather than cstr/text-conversion-specific.
# NOTE: an argv=[] launch of a REAL program (M2) should still synthesise argc=1
# with argv[0]=binary_path; that needs the freestanding rt_text_to_bytes(struct
# field) path fixed — tracked as the M2 follow-up. Real launches pass argv (the
# full string path below), so this fast path only covers the empty verification
# case.
fn _build_sysv_stack_frame(top_phys: u64, stack_top: u64, binary_path: text, argv: [text], envp: [text]) -> u64:
    val PAGE: u64 = 4096
    val AT_NULL: u64 = 0
    val top_page_base = stack_top - PAGE

    if argv.len() == 0 and envp.len() == 0:
        var rsp0 = (stack_top - 32) & (~(15.to_u64()))
        if rsp0 < top_page_base:
            serial_println("[spawn] argv-frame fail: min rsp<base")
            return 0
        if not _stack_write64(top_phys, stack_top, rsp0, 0):
            serial_println("[spawn] argv-frame fail: write64 min argc")
            return 0
        if not _stack_write64(top_phys, stack_top, rsp0 + 8, 0):
            serial_println("[spawn] argv-frame fail: write64 min argv-null")
            return 0
        if not _stack_write64(top_phys, stack_top, rsp0 + 16, 0):
            serial_println("[spawn] argv-frame fail: write64 min envp-null")
            return 0
        if not _stack_write64(top_phys, stack_top, rsp0 + 24, 0):
            serial_println("[spawn] argv-frame fail: write64 min aux-null")
            return 0
        serial_println("[spawn] argv-frame minimal ok rsp=0x{rsp0}")
        return rsp0

    var argc: i64 = argv.len()
    if argc == 0:
        argc = 1

    var top = stack_top
    var argv_addrs: [u64] = []
    var a: i64 = 0
    while a < argc:
        var arg_s: text = binary_path
        if argv.len() != 0:
            arg_s = argv[a]
        val raw = rt_text_to_bytes(arg_s)
        val n = raw.len()
        if n < 0 or n.to_u64() >= PAGE:
            serial_println("[spawn] argv-frame fail: cstr-len n={n}")
            return 0
        top = top - (n.to_u64() + 1.to_u64())
        if top < top_page_base:
            serial_println("[spawn] argv-frame fail: argv-oob")
            return 0
        if not _stack_write_cstr(top_phys, stack_top, top, arg_s):
            serial_println("[spawn] argv-frame fail: cstr")
            return 0
        argv_addrs.push(top)
        a = a + 1

    var envp_addrs: [u64] = []
    var e: i64 = 0
    while e < envp.len():
        val es = envp[e]
        val raw2 = rt_text_to_bytes(es)
        val n2 = raw2.len()
        if n2 < 0 or n2.to_u64() >= PAGE:
            serial_println("[spawn] argv-frame fail: envp-len n={n2}")
            return 0
        top = top - (n2.to_u64() + 1.to_u64())
        if top < top_page_base:
            serial_println("[spawn] argv-frame fail: envp-oob")
            return 0
        if not _stack_write_cstr(top_phys, stack_top, top, es):
            serial_println("[spawn] argv-frame fail: envp")
            return 0
        envp_addrs.push(top)
        e = e + 1

    val fixed_slots = 1.to_u64() + argv_addrs.len().to_u64() + 1.to_u64() + envp_addrs.len().to_u64() + 1.to_u64() + 2.to_u64()
    var rsp = top - (fixed_slots * 8)
    rsp = rsp & (~(15.to_u64()))
    if rsp < top_page_base:
        serial_println("[spawn] argv-frame fail: rsp<base")
        return 0

    var slot = rsp
    if not _stack_write64(top_phys, stack_top, slot, argv_addrs.len().to_u64()):
        serial_println("[spawn] argv-frame fail: write64 argc")
        return 0
    slot = slot + 8
    var ap: i64 = 0
    while ap < argv_addrs.len():
        if not _stack_write64(top_phys, stack_top, slot, argv_addrs[ap]):
            serial_println("[spawn] argv-frame fail: write64 argv")
            return 0
        slot = slot + 8
        ap = ap + 1
    if not _stack_write64(top_phys, stack_top, slot, AT_NULL):
        serial_println("[spawn] argv-frame fail: write64 argv-null")
        return 0
    slot = slot + 8

    var ep: i64 = 0
    while ep < envp_addrs.len():
        if not _stack_write64(top_phys, stack_top, slot, envp_addrs[ep]):
            serial_println("[spawn] argv-frame fail: write64 envp")
            return 0
        slot = slot + 8
        ep = ep + 1
    if not _stack_write64(top_phys, stack_top, slot, 0):
        serial_println("[spawn] argv-frame fail: write64 envp-null")
        return 0
    slot = slot + 8

    if not _stack_write64(top_phys, stack_top, slot, 0):
        serial_println("[spawn] argv-frame fail: write64 aux0")
        return 0
    slot = slot + 8
    if not _stack_write64(top_phys, stack_top, slot, 0):
        serial_println("[spawn] argv-frame fail: write64 aux1")
        return 0
    rsp

# Map every PT_LOAD of the ELF held in the raw buffer `blob` into `space` at its
# p_vaddr, page by page (one frame per page, so segments sharing a page are mapped
# once with the UNION of their perms). Each frame is zeroed (BSS) before the
# file-backed range of every covering segment is copied in from `blob` via mmio.
# Per-page perms: user_rw if any covering PT_LOAD is writable, else user_rx.
# Returns 1 on success, 0 on failure.
fn _map_pt_loads(space: AddressSpace, blob: u64, file_len: u64) -> i64:
    val PAGE: u64 = 4096
    val PT_LOAD: u64 = 1
    val PF_W: u64 = 2

    val phoff = _rd64(blob, 32)
    val phentsize = _rd16(blob, 54)
    val phnum = _rd16(blob, 56)
    serial_println("[spawn] phoff={phoff} phentsize={phentsize} phnum={phnum}")
    if phnum == 0:
        serial_println("[spawn] FAIL no program headers")
        return 0
    # Bound the phdr table + each segment's file range against the known file size,
    # so a corrupt/oversized phdr can't drive mmio reads past the raw buffer into
    # adjacent kernel memory (info-leak / fault) — the raw buffer carries no length.
    val ph_table_end = phoff + (phnum * phentsize)
    if phoff < 64 or ph_table_end > file_len:
        serial_println("[spawn] FAIL phdr table OOB phoff={phoff} end={ph_table_end} file_len={file_len}")
        return 0

    var lo: u64 = 0xFFFFFFFFFFFFFFFF
    var hi: u64 = 0
    var i: u64 = 0
    while i < phnum:
        val ph = phoff + (i * phentsize)
        if _rd32(blob, ph) == PT_LOAD:
            val foff = _rd64(blob, ph + 8)
            val fsz = _rd64(blob, ph + 32)
            if foff + fsz > file_len:
                serial_println("[spawn] FAIL segment file range OOB foff={foff} fsz={fsz} file_len={file_len}")
                return 0
            val sv = _rd64(blob, ph + 16)
            val se = sv + _rd64(blob, ph + 40)
            if sv < lo:
                lo = sv
            if se > hi:
                hi = se
        i = i + 1
    if hi == 0:
        serial_println("[spawn] FAIL no PT_LOAD segments")
        return 0

    val lo_page = lo & (~(PAGE - 1))
    val hi_page = (hi + PAGE - 1) & (~(PAGE - 1))
    serial_println("[spawn] image span lo=0x{lo_page} hi=0x{hi_page}")

    var va: u64 = lo_page
    while va < hi_page:
        val phys = pmm_alloc_page_raw()
        if phys == 0:
            serial_println("[spawn] FAIL frame alloc va=0x{va}")
            return 0
        vmm_zero_phys_range(phys, PAGE)

        var writable = false
        var j: u64 = 0
        while j < phnum:
            val ph = phoff + (j * phentsize)
            if _rd32(blob, ph) == PT_LOAD:
                val sv = _rd64(blob, ph + 16)
                val se = sv + _rd64(blob, ph + 40)
                val overlaps = (sv < (va + PAGE)) and (se > va)
                if overlaps and ((_rd32(blob, ph + 4) & PF_W) != 0):
                    writable = true
            j = j + 1

        val flags = if writable: VmFlags.user_rw() else: VmFlags.user_rx()
        if not vmm_map_page_in(space, VirtAddr(addr: va), PhysAddr(addr: phys), flags):
            serial_println("[spawn] FAIL map page va=0x{va}")
            return 0

        var k: u64 = 0
        while k < phnum:
            val ph = phoff + (k * phentsize)
            if _rd32(blob, ph) == PT_LOAD:
                val sv = _rd64(blob, ph + 16)
                val foff = _rd64(blob, ph + 8)
                val fsz = _rd64(blob, ph + 32)
                var copy_start = va
                if copy_start < sv:
                    copy_start = sv
                var copy_end = va + PAGE
                val sfe = sv + fsz
                if copy_end > sfe:
                    copy_end = sfe
                if copy_start < copy_end:
                    var t: u64 = 0
                    val clen = copy_end - copy_start
                    while t < clen:
                        mmio_write8(phys + (copy_start - va) + t, mmio_read8(blob + foff + (copy_start - sv) + t))
                        t = t + 1
            k = k + 1

        va = va + PAGE

    serial_println("[spawn] PT_LOAD segments mapped")
    1

pub fn x86_64_fs_exec_enter_image_ring3(image: UserProcessImage, blob: u64, argv: [text], envp: [text]) -> i64:
    """Map a general-built UserProcessImage into a fresh user AS and enter ring 3.

    Reuses the ring3_smoke primitive sequence. Does not return on success (the
    program runs at CPL3 and exits QEMU); returns a negative code on failure.
    """
    val fb = user_process_image_file_bytes(image)
    val img_entry = user_process_image_entry(image)
    val seg_count = user_process_image_segment_count(image)
    val builder_sp = user_process_image_initial_sp(image)
    val builder_top = user_process_image_stack_top(image)
    val stk_bytes = user_process_image_initial_stack_bytes(image)

    # Required acceptance marker: REAL segment count from the general image, plus
    # the builder-reported fields (so a freestanding-broken builder is visible).
    serial_println("[spawn] image path={image.binary_path} entry=0x{img_entry} segments={seg_count} builder_top=0x{builder_top} builder_sp=0x{builder_sp} stk_bytes={stk_bytes.len()} file_len={fb.len()}")

    # Parse the ELF from the identity-mapped RAW file buffer `blob` (mmio), NOT the
    # [u8] image.file_bytes channel — freestanding native-build stores [u8] as boxed
    # RuntimeValues so byte_utils reads stride-1 garbage (phoff=16). Guard that the
    # buffer still holds our ELF (survived pmm/vmm/builder) before trusting it.
    if blob == 0:
        serial_println("[spawn] FAIL raw blob address is 0")
        return -5
    if _rd32(blob, 0) != 0x464C457F:
        serial_println("[spawn] FAIL blob not ELF (clobbered/wrong file) w0={_rd32(blob, 0)}")
        return -5
    if _rd8(blob, 4) != 2:
        serial_println("[spawn] FAIL not ELFCLASS64 class={_rd8(blob, 4)}")
        return -5

    # Trustworthy entry: ELF e_entry @ offset 24, read straight from the raw buffer.
    val entry = _rd64(blob, 24)
    serial_println("[spawn] parsed entry=0x{entry}")

    val space = create_user_address_space()
    if space.phys_root == 0 or space.phys_root == 1:
        serial_println("[spawn] FAIL user-AS synthetic root={space.phys_root}")
        return -1
    vmm_clone_kernel_low_identity(space.phys_root)
    serial_println("[spawn] user AS ready root={space.phys_root}")

    if _map_pt_loads(space, blob, fb.len().to_u64()) == 0:
        serial_println("[spawn] FAIL segment mapping")
        return -2

    # User stack: a small RW region growing down from a FUNCTION-LOCAL literal top
    # (the builder's stack_top is module-val-bound and unreliable freestanding).
    # The SysV argv frame (build_initial_stack) is likewise unreliable here; the
    # verification payload ignores argv, so a valid mapped stack + a 16-aligned
    # rsp is the ring-3 contract.
    #
    # STACK_TOP must sit in the SAME low-canonical region as the mapped ELF image
    # (fsexec_hello links at 0x8000000000). The prior 0x00007FFFFFFFF000 top lands
    # in PML4[255] — a subtree the fresh user AS never populates under
    # vmm_clone_kernel_low_identity, so the very first push post-iretq took a #PF.
    # 0x8000200000 shares the PML4[1]/PDPT/PD subtree of the proven code mapping
    # (same region the FS-exec smoke uses). Keep the region SMALL (32 pages, top
    # at 0x80001E0000) so it stays clear of the code page at 0x8000000000 — the
    # smoke's 8 MiB (2048 pages) would grow down to 0x7FFFA00000 and clobber it.
    val PAGE: i64 = 4096
    val STACK_TOP: i64 = 0x8000200000
    val STACK_PAGES: i64 = 32
    var p: i64 = 0
    while p < STACK_PAGES:
        val sva = STACK_TOP - ((p + 1) * PAGE)
        val sph = pmm_alloc_page_raw()
        if sph == 0:
            serial_println("[spawn] FAIL stack alloc p={p}")
            return -3
        vmm_zero_phys_range(sph, PAGE.to_u64())
        if not vmm_map_page_in(space, VirtAddr(addr: sva.to_u64()), PhysAddr(addr: sph), VmFlags.user_rw()):
            serial_println("[spawn] FAIL stack map p={p}")
            return -4
        p = p + 1
    # M1: use the PROVEN bare 16-aligned rsp in the mapped top page. The SysV
    # frame builder (_build_sysv_stack_frame) is intentionally BYPASSED here: its
    # _top_phys_for_vaddr/_stack_write64 translation returns 0 for an in-range
    # vaddr under freestanding native-build (QEMU: "argv-frame fail: write64 min
    # argc" on the very first write of rsp0=0x80001FFFE0, which IS inside
    # [top_page_base, stack_top) — a u64 param-passing / range-comparison bug in
    # the helper; see the NOTE on _build_sysv_stack_frame). The FSEXEC payload
    # ignores argv/argc/rsp contents entirely, and the pre-regression handoff
    # proved a bare rsp runs to FSEXEC_OK. STACK_TOP=0x8000200000, so STACK_TOP-16
    # = 0x80001FFFF0 is 16-byte aligned and sits in the mapped top page.
    # Real-argv frames (M2) require the translation bug fixed first.
    val user_rsp: i64 = STACK_TOP - 16
    serial_println("[spawn] user stack mapped top=0x{STACK_TOP} pages={STACK_PAGES} rsp=0x{user_rsp}")

    val ctx = TaskContext(
        rax: 0, rbx: 0, rcx: 0, rdx: 0,
        rsi: 0, rdi: 0, rbp: 0, rsp: user_rsp.to_u64(),
        r8: 0, r9: 0, r10: 0, r11: 0,
        r12: 0, r13: 0, r14: 0, r15: 0,
        rip: entry,
        rflags: 0x3002,
        cs: 0x2b,
        ss: 0x23,
        fpu_state: 0
    )
    serial_println("[spawn] entering user cs=0x2b iopl=3 rip=0x{entry} rsp=0x{user_rsp}")
    arch_x86_64_enter_user_task(ctx, space.phys_root)

    serial_println("[spawn] returned from user (unexpected)")
    -9
