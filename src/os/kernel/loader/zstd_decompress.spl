use std.common.compress.types.{CompressionError}
use std.common.compress.zstd.{zstd_decompress_frame}

fn _compression_error_text(error: CompressionError) -> text:
    error.message()

fn zstd_decompress(compressed: [u8]) -> Result<[u8], text>:
    val result = zstd_decompress_frame(compressed)
    if result.is_err():
        return Err(_compression_error_text(result.unwrap_err()))
    Ok(result.unwrap())
