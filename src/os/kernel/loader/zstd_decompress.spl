use common.compress.{CompressionCodec, CompressionError, decompress_bytes}

fn _compression_error_text(error: CompressionError) -> text:
    match error:
        CompressionError.InvalidHeader(message): message
        CompressionError.UnsupportedFeature(message): message
        CompressionError.TruncatedInput(message): message
        CompressionError.ChecksumMismatch(message): message
        CompressionError.CorruptStream(message): message
        CompressionError.SizeLimitExceeded(limit): "zstd size limit exceeded: " + limit.to_string()

fn zstd_decompress(compressed: [u8]) -> Result<[u8], text>:
    val result = decompress_bytes(compressed, Some(CompressionCodec.zstd))
    if result.is_err():
        return Err(_compression_error_text(result.unwrap_err()))
    Ok(result.unwrap())
