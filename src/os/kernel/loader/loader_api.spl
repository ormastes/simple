# Kernel Loader API — single public entry-point for process image loading
#
# Services-layer PM calls loader_exec() with a path, argv, envp, and a
# ProcessVmSpace prepared by the memory manager.  loader_exec sniffs the
# binary magic and dispatches to elf64_load or smf_load.
# argv/envp setup is handled by stack_builder → process_image.

use os.kernel.loader.elf64.{elf64_parse_header, elf64_program_headers, elf64_load, elf64_has_magic, PT_LOAD64}
use os.kernel.arch.arch_context.{Architecture}
use os.kernel.loader.smf.{smf_has_header, smf_load, smf_extract_library_stub, smf_extract_library_stub_for_arch}
use os.kernel.loader.dylib_registry.{
    dylib_registry_register,
    dylib_registry_open,
    dylib_registry_symbol,
    dylib_registry_symbol_is_process_callable,
    dylib_registry_mark_mapped,
    dylib_registry_close
}
use os.kernel.types.vmspace_types.{ProcessVmSpace}

extern fn rt_file_read_bytes(path: text) -> [u8]

# ============================================================================
# Internal dispatch (testable without file I/O)
# ============================================================================

fn loader_dispatch(bytes: [u8], space: ProcessVmSpace) -> i64:
    """Sniff magic and dispatch to the appropriate loader.

    Returns entry-point vaddr on success, or negative errno:
      -2  (-ENOENT)   empty byte slice (caller should check before calling)
      -8  (-ENOEXEC)  unknown format
    """
    if bytes.len() == 0:
        return -2
    # ELF64 magic: 0x7F 'E' 'L' 'F'
    if elf64_has_magic(bytes):
        val hdr_opt = elf64_parse_header(bytes)
        if hdr_opt == nil:
            return -8
        return elf64_load(bytes, space)
    # SMF v1.1 trailer or legacy offset-0 magic: 'S' 'M' 'F' '\0'
    if smf_has_header(bytes):
        return smf_load(bytes, space)
    -8  # -ENOEXEC — unknown format

fn loader_dynopen_bytes(path: text, bytes: [u8]) -> i64:
    """Register a dynamic library image and return a kernel dynload handle.

    This is the public kernel-loader dynload entrypoint for callers that have
    already resolved the path to bytes. ELF shared objects and role-2 SMF
    library envelopes are validated by the registry.
    """
    if bytes.len() == 0:
        return -2
    dylib_registry_register(path, bytes)

fn loader_dynopen_smf_library_bytes_for_arch(path: text, bytes: [u8], arch: Architecture) -> i64:
    """Validate and register a role-2 SMF library for a SimpleOS architecture."""
    if path == "":
        return -22
    if bytes.len() == 0:
        return -2
    val stub = smf_extract_library_stub_for_arch(bytes, arch)
    if stub.is_err():
        return -8
    loader_dynopen_bytes(path, bytes)

fn loader_dynopen_path(path: text) -> i64:
    """Read and register a dynamic library image by path."""
    if path == "":
        return -22
    val bytes = rt_file_read_bytes(path)
    if bytes.len() == 0:
        return -2
    loader_dynopen_bytes(path, bytes)

fn _loader_dynlib_native_bytes(bytes: [u8]) -> [u8]:
    if elf64_has_magic(bytes):
        return bytes
    if smf_has_header(bytes):
        val stub = smf_extract_library_stub(bytes)
        if stub.is_ok():
            return stub.unwrap()
    []

fn _loader_dynlib_load_segment_count(bytes: [u8]) -> i64:
    val hdr_opt = elf64_parse_header(bytes)
    if hdr_opt == nil:
        return 0
    val phdrs = elf64_program_headers(bytes, hdr_opt.unwrap())
    var count = 0
    var i = 0
    while i < phdrs.len():
        if phdrs[i].p_type == PT_LOAD64:
            count = count + 1
        i = i + 1
    count

fn loader_dynopen_mapped_bytes(path: text, bytes: [u8], space: ProcessVmSpace) -> i64:
    """Register and map a dynamic library image into a process VM space.

    The returned handle supports symbol lookup and records executable mapped
    ranges so callers can distinguish process-callable symbols from unresolved
    or unmapped symbol values.
    """
    val native = _loader_dynlib_native_bytes(bytes)
    if native.len() == 0:
        return -8
    if _loader_dynlib_load_segment_count(native) == 0:
        return -8

    val handle = loader_dynopen_bytes(path, bytes)
    if handle < 0:
        return handle

    val mapped = elf64_load(native, space)
    if mapped < 0:
        loader_dynclose(handle)
        return mapped

    val mark_rc = dylib_registry_mark_mapped(handle)
    if mark_rc < 0:
        loader_dynclose(handle)
        return mark_rc

    handle

fn loader_dynopen_mapped_path(path: text, space: ProcessVmSpace) -> i64:
    """Read, register, and map a dynamic library image by path."""
    if path == "":
        return -22
    val bytes = rt_file_read_bytes(path)
    if bytes.len() == 0:
        return -2
    loader_dynopen_mapped_bytes(path, bytes, space)

fn loader_dynopen_registered(path: text) -> i64:
    """Retain an already-registered dynamic library by path."""
    dylib_registry_open(path)

fn loader_dynsym(handle: i64, name: text) -> i64:
    """Resolve a symbol from a kernel dynload handle."""
    dylib_registry_symbol(handle, name)

fn loader_dynsym_is_process_callable(handle: i64, name: text) -> bool:
    """Return whether a resolved dynload symbol is process-callable."""
    dylib_registry_symbol_is_process_callable(handle, name)

fn loader_dynclose(handle: i64) -> i64:
    """Close one reference to a kernel dynload handle."""
    dylib_registry_close(handle)

# ============================================================================
# Exported C-ABI entry-point
# ============================================================================

@export("C")
fn loader_exec(path: text, argv: [text], envp: [text], space: ProcessVmSpace) -> i64:
    """Load the binary at `path` into `space` and return its entry-point vaddr.

    Returns negative errno on failure:
      -2  (-ENOENT)   file not found or empty
      -8  (-ENOEXEC)  not a recognised binary format
      -38 (-ENOSYS)   format recognised but loader not yet fully implemented
    """
    val bytes = rt_file_read_bytes(path)
    if bytes.len() == 0:
        return -2
    loader_dispatch(bytes, space)
