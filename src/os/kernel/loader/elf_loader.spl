#![allow(unnamed_duplicate_typed_args)]
# Kernel ELF Loader — User Executable Validation
#
# Parses RV32/RV64 and x86_64 ELF executables and produces a load plan for
# PT_LOAD segments. This slice validates and plans mapping only; it does not
# yet allocate address spaces or copy bytes into userspace memory.

use os.kernel.arch.arch_context.{Architecture}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

val ELF_MAGIC_0: u8 = 0x7F
val ELF_MAGIC_1: u8 = 0x45
val ELF_MAGIC_2: u8 = 0x4C
val ELF_MAGIC_3: u8 = 0x46

val ELFCLASS32: u8 = 1
val ELFCLASS64: u8 = 2
val ELFDATA2LSB: u8 = 1
val EV_CURRENT: u8 = 1

val ET_EXEC: i64 = 2
val EM_ARM: i64 = 40
val EM_X86_64: i64 = 62
val EM_AARCH64: i64 = 183
val EM_RISCV: i64 = 243
val PT_LOAD: i64 = 1

val ELF32_EHDR_SIZE: i64 = 52
val ELF64_EHDR_SIZE: i64 = 64
val ELF32_PHDR_SIZE: i64 = 32
val ELF64_PHDR_SIZE: i64 = 56

enum ElfClass:
    Elf32
    Elf64

struct ElfLoadSegment:
    file_offset: u64
    file_size: u64
    virt_addr: u64
    mem_size: u64
    flags: u32
    align: u64

struct ElfImage:
    class_: ElfClass
    entry: u64
    segments: [ElfLoadSegment]

fn elf_segment_file_offset(segment: ElfLoadSegment) -> u64:
    segment.file_offset

fn elf_segment_file_size(segment: ElfLoadSegment) -> u64:
    segment.file_size

fn elf_segment_virt_addr(segment: ElfLoadSegment) -> u64:
    segment.virt_addr

fn elf_segment_mem_size(segment: ElfLoadSegment) -> u64:
    segment.mem_size

fn elf_segment_flags(segment: ElfLoadSegment) -> u32:
    segment.flags

fn elf_segment_align(segment: ElfLoadSegment) -> u64:
    segment.align

fn elf_image_entry(image: ElfImage) -> u64:
    image.entry

fn elf_image_segments(image: ElfImage) -> [ElfLoadSegment]:
    image.segments

fn _byte_at(data: [u8], offset: i64) -> u8:
    rt_bytes_u8_at(data, offset).to_u8()

fn _read_u16_le(data: [u8], offset: i64) -> i64:
    val b0 = _byte_at(data, offset) as i64
    val b1 = _byte_at(data, offset + 1) as i64
    b0 | (b1 << 8)

fn _read_u32_le(data: [u8], offset: i64) -> i64:
    val b0 = _byte_at(data, offset) as i64
    val b1 = _byte_at(data, offset + 1) as i64
    val b2 = _byte_at(data, offset + 2) as i64
    val b3 = _byte_at(data, offset + 3) as i64
    b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

fn _read_u64_le(data: [u8], offset: i64) -> i64:
    val b0 = _byte_at(data, offset) as i64
    val b1 = _byte_at(data, offset + 1) as i64
    val b2 = _byte_at(data, offset + 2) as i64
    val b3 = _byte_at(data, offset + 3) as i64
    val b4 = _byte_at(data, offset + 4) as i64
    val b5 = _byte_at(data, offset + 5) as i64
    val b6 = _byte_at(data, offset + 6) as i64
    val b7 = _byte_at(data, offset + 7) as i64
    b0 | (b1 << 8) | (b2 << 16) | (b3 << 24) | (b4 << 32) | (b5 << 40) | (b6 << 48) | (b7 << 56)

fn _check_range(data: [u8], offset: i64, size: i64) -> bool:
    if offset < 0 or size < 0:
        return false
    val end_ = offset + size
    if end_ < offset:
        return false
    end_ <= data.len()

fn _expected_class(arch: Architecture) -> ElfClass?:
    match arch:
        Architecture.X86_64: Some(ElfClass.Elf64)
        Architecture.Arm64: Some(ElfClass.Elf64)
        Architecture.Arm32: Some(ElfClass.Elf32)
        Architecture.Riscv64: Some(ElfClass.Elf64)
        Architecture.Riscv32: Some(ElfClass.Elf32)
        _: nil

fn _expected_machine(arch: Architecture) -> i64?:
    match arch:
        Architecture.X86_64: Some(EM_X86_64)
        Architecture.Arm64: Some(EM_AARCH64)
        Architecture.Arm32: Some(EM_ARM)
        Architecture.Riscv64: Some(EM_RISCV)
        Architecture.Riscv32: Some(EM_RISCV)
        _: nil

fn _validate_ident(data: [u8]) -> Result<ElfClass, text>:
    if data.len() < 16:
        return Err("ELF too small for ident")
    if _byte_at(data, 0) != ELF_MAGIC_0 or _byte_at(data, 1) != ELF_MAGIC_1 or _byte_at(data, 2) != ELF_MAGIC_2 or _byte_at(data, 3) != ELF_MAGIC_3:
        return Err("invalid ELF magic")
    val class_byte = _byte_at(data, 4)
    if _byte_at(data, 5) != ELFDATA2LSB:
        return Err("only little-endian ELF is supported")
    if _byte_at(data, 6) != EV_CURRENT:
        return Err("unsupported ELF version")
    if class_byte == ELFCLASS32:
        return Ok(ElfClass.Elf32)
    if class_byte == ELFCLASS64:
        return Ok(ElfClass.Elf64)
    Err("unsupported ELF class {class_byte}")

fn _validate_common_header(
    data: [u8],
    arch: Architecture,
    expected: ElfClass,
    actual: ElfClass
) -> Result<(), text>:
    if actual != expected:
        return Err("ELF class does not match target architecture")
    val expected_machine_opt = _expected_machine(arch)
    if expected_machine_opt == nil:
        return Err("unsupported architecture for ELF loading")
    val expected_machine = expected_machine_opt
    match actual:
        case ElfClass.Elf32:
            if not _check_range(data, 0, ELF32_EHDR_SIZE):
                return Err("truncated ELF32 header")
            val e_type = _read_u16_le(data, 16)
            val e_machine = _read_u16_le(data, 18)
            val e_version = _read_u32_le(data, 20)
            val e_ehsize = _read_u16_le(data, 40)
            if e_type != ET_EXEC:
                return Err("only ET_EXEC ELF32 images are supported")
            if e_machine != expected_machine:
                return Err("ELF32 machine is not the expected target architecture")
            if e_version != EV_CURRENT:
                return Err("unsupported ELF32 version")
            if e_ehsize != ELF32_EHDR_SIZE:
                return Err("unexpected ELF32 header size")
        case ElfClass.Elf64:
            if not _check_range(data, 0, ELF64_EHDR_SIZE):
                return Err("truncated ELF64 header")
            val e_type = _read_u16_le(data, 16)
            val e_machine = _read_u16_le(data, 18)
            val e_version = _read_u32_le(data, 20)
            val e_ehsize = _read_u16_le(data, 52)
            if e_type != ET_EXEC:
                return Err("only ET_EXEC ELF64 images are supported")
            if e_machine != expected_machine:
                return Err("ELF64 machine is not the expected target architecture")
            if e_version != EV_CURRENT:
                return Err("unsupported ELF64 version")
            if e_ehsize != ELF64_EHDR_SIZE:
                return Err("unexpected ELF64 header size")
    Ok(())

fn _parse_elf32(data: [u8]) -> Result<ElfImage, text>:
    val entry = _read_u32_le(data, 24) as u64
    val phoff = _read_u32_le(data, 28)
    val phentsize = _read_u16_le(data, 42)
    val phnum = _read_u16_le(data, 44)
    if phentsize != ELF32_PHDR_SIZE:
        return Err("unexpected ELF32 program header size")
    if phnum <= 0:
        return Err("ELF32 image has no program headers")
    if not _check_range(data, phoff, phentsize * phnum):
        return Err("ELF32 program header table is truncated")

    var segments: [ElfLoadSegment] = []
    var idx = 0
    while idx < phnum:
        val off = phoff + (idx * phentsize)
        val p_type = _read_u32_le(data, off)
        if p_type == PT_LOAD:
            val p_offset = _read_u32_le(data, off + 4)
            val p_vaddr = _read_u32_le(data, off + 8)
            val p_filesz = _read_u32_le(data, off + 16)
            val p_memsz = _read_u32_le(data, off + 20)
            val p_flags = _read_u32_le(data, off + 24)
            val p_align = _read_u32_le(data, off + 28)
            if p_filesz > p_memsz:
                return Err("ELF32 PT_LOAD filesz exceeds memsz")
            if not _check_range(data, p_offset, p_filesz):
                return Err("ELF32 PT_LOAD bytes are truncated")
            segments.push(ElfLoadSegment(
                file_offset: p_offset as u64,
                file_size: p_filesz as u64,
                virt_addr: p_vaddr as u64,
                mem_size: p_memsz as u64,
                flags: p_flags as u32,
                align: p_align as u64
            ))
        idx = idx + 1
    if segments.len() == 0:
        return Err("ELF32 image has no PT_LOAD segments")
    Ok(ElfImage(class_: ElfClass.Elf32, entry: entry, segments: segments))

fn _parse_elf64(data: [u8]) -> Result<ElfImage, text>:
    val entry = _read_u64_le(data, 24) as u64
    val phoff = _read_u64_le(data, 32)
    val phentsize = _read_u16_le(data, 54)
    val phnum = _read_u16_le(data, 56)
    if phentsize != ELF64_PHDR_SIZE:
        return Err("unexpected ELF64 program header size")
    if phnum <= 0:
        return Err("ELF64 image has no program headers")
    if not _check_range(data, phoff, phentsize * phnum):
        return Err("ELF64 program header table is truncated")

    var segments: [ElfLoadSegment] = []
    var idx = 0
    while idx < phnum:
        val off = phoff + (idx * phentsize)
        val p_type = _read_u32_le(data, off)
        if p_type == PT_LOAD:
            val p_flags = _read_u32_le(data, off + 4)
            val p_offset = _read_u64_le(data, off + 8)
            val p_vaddr = _read_u64_le(data, off + 16)
            val p_filesz = _read_u64_le(data, off + 32)
            val p_memsz = _read_u64_le(data, off + 40)
            val p_align = _read_u64_le(data, off + 48)
            if p_filesz > p_memsz:
                return Err("ELF64 PT_LOAD filesz exceeds memsz")
            if not _check_range(data, p_offset, p_filesz):
                return Err("ELF64 PT_LOAD bytes are truncated")
            segments.push(ElfLoadSegment(
                file_offset: p_offset as u64,
                file_size: p_filesz as u64,
                virt_addr: p_vaddr as u64,
                mem_size: p_memsz as u64,
                flags: p_flags as u32,
                align: p_align as u64
            ))
        idx = idx + 1
    if segments.len() == 0:
        return Err("ELF64 image has no PT_LOAD segments")
    Ok(ElfImage(class_: ElfClass.Elf64, entry: entry, segments: segments))

fn load_user_executable(data: [u8], arch: Architecture) -> Result<ElfImage, text>:
    val expected_opt = _expected_class(arch)
    if expected_opt == nil:
        return Err("unsupported architecture for ELF loading")
    val expected = expected_opt
    val class_ = _validate_ident(data)?
    _validate_common_header(data, arch, expected, class_)? 
    match class_:
        case ElfClass.Elf32:
            _parse_elf32(data)
        case ElfClass.Elf64:
            _parse_elf64(data)

fn load_riscv_executable(data: [u8], arch: Architecture) -> Result<ElfImage, text>:
    load_user_executable(data, arch)

fn load_user_executable_unchecked(data: [u8], arch: Architecture) -> ElfImage:
    match arch:
        case Architecture.Arm32:
            _parse_elf32(data).unwrap()
        case _:
            _parse_elf64(data).unwrap()
