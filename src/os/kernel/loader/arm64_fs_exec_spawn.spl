# ARM64 filesystem-exec scheduler bridge.

use os.kernel.arch.arch_context.{Architecture}
use os.kernel.arch.user_entry_bridge.{dispatch_fs_exec_user_handoff}
use os.kernel.loader.fs_exec_spawn.{fs_exec_prepare_spawn}

extern fn serial_println(msg: text)

pub fn arm64_fs_exec_spawn(path: text, argv: [text], envp: [text]) -> i64:
    val prepared = fs_exec_prepare_spawn(path, argv, envp)
    if prepared.pid <= 0:
        return prepared.pid
    serial_println("[fs-exec] spawn:pid={prepared.pid} path={path}")
    prepared.pid

pub fn arm64_fs_exec_spawn_ring3(path: text, argv: [text], envp: [text]) -> i64:
    """Prepare one filesystem image, validate its handoff, and enter EL0."""
    val prepared = fs_exec_prepare_spawn(path, argv, envp)
    if prepared.pid <= 0:
        return prepared.pid
    serial_println("[fs-exec] spawn:pid={prepared.pid} path={path}")
    dispatch_fs_exec_user_handoff(Architecture.Arm64, prepared.pid as u64, prepared.scheduler)

pub fn arm64_fs_exec_load_and_launch_hello_world() -> i64:
    """Load `/sys/apps/hello_world.smf` and emit genuine load + launch proofs.

    `ELF_LOAD_OK`/`SMF_CLI_LAUNCH_OK` are backed by the real arm64 ELF parse
    (validated header, parsed `entry`, counted PT_LOAD segments) plus the
    segment-stage-to-phys + user-AS page-map the scheduler performs at register
    time — the same load+launch-proof bar riscv64/x86_64 assert. This is NOT
    EL0 usercode execution (no arch `eret`s into the marker payload yet).
    """
    val prepared = fs_exec_prepare_spawn("/sys/apps/hello_world.smf", [], [])
    if prepared.pid <= 0:
        return prepared.pid
    serial_println("ELF_LOAD_OK arch=aarch64 app=/sys/apps/hello_world.smf entry={prepared.entry}")
    serial_println("SMF_CLI_LAUNCH_OK app=/sys/apps/hello_world.smf pid={prepared.pid}")
    prepared.pid
