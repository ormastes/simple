# x86_64 filesystem-exec scheduler bridge.
use os.kernel.arch.arch_context.{Architecture}
use os.kernel.boot.mmio.{mmio_read16, mmio_read32, mmio_read64}
use os.kernel.loader.smf.{smf_has_header, smf_extract_executable_stub_for_arch, smf_extract_executable_stub_unchecked, smf_executable_entry_point_for_arch}
use os.kernel.loader.fs_exec_spawn.{fs_exec_prepare_spawn_from_bytes}
use os.kernel.loader.cap_exec_gate.{exec_cap_check}
use os.kernel.loader.process_image.{build_user_process_image_unchecked}
use os.kernel.loader.x86_64_fs_exec_ring3.{x86_64_fs_exec_enter_image_ring3, x86_64_fs_exec_enter_stream_ring3, x86_64_fs_exec_enter_stream_heap_ring3}

extern fn serial_println(msg: text)
extern fn simpleos_fat32_path_read_buffer_addr() -> u64
extern fn simpleos_fat32_stream_open(path: text) -> i64
extern fn simpleos_fat32_stream_read_at(file_off: u64, dst: u64, len: u64) -> i64
extern fn rt_bytes_from_raw(ptr: i64, len: i64) -> [u8]
# Per-spawn RAM file-table reset (baremetal_stubs.c). Without it a SECOND
# ring-3 exec in the same boot inherits the first run's fd slots and the
# one-shot output slot -> O_CREAT open fails -EMFILE, and the exit dump
# re-persists the previous run's stale output object.
extern fn simpleos_bare_exec_reset()

fn _x86_64_raw_header_is_elf(buf: u64) -> bool:
    (mmio_read32(buf) as u64) == 0x464C457F.to_u64() and mmio_read16(buf + 4) == 0x0102 and mmio_read16(buf + 18) == 62

fn _x86_64_open_streaming_elf(path: text) -> (i64, u64):
    """Open `path` and retain only its bounded ELF header/program-header prefix."""
    val ELF_HEADER_LEN: u64 = 64
    val HEADER_BUFFER_CAP: u64 = 4194304
    val fsize = simpleos_fat32_stream_open(path)
    if fsize < 64:
        return (0, 0.to_u64())
    val buf = simpleos_fat32_path_read_buffer_addr()
    if buf == 0.to_u64():
        return (0, 0.to_u64())
    val header_read = simpleos_fat32_stream_read_at(0.to_u64(), buf, ELF_HEADER_LEN)
    if header_read != 64 or not _x86_64_raw_header_is_elf(buf):
        return (0, 0.to_u64())
    if mmio_read16(buf + 52) < 64 or mmio_read16(buf + 54) < 56:
        return (0, 0.to_u64())
    val phoff = mmio_read64(buf + 32)
    val phentsize = mmio_read16(buf + 54) as u64
    val phnum = mmio_read16(buf + 56) as u64
    val file_len = fsize as u64
    if phnum == 0 or phoff > file_len or phnum > ((file_len - phoff) / phentsize):
        return (0, 0.to_u64())
    var prefix_len = phoff + (phnum * phentsize)
    if prefix_len < 65536 and prefix_len < file_len:
        prefix_len = if file_len < 65536: file_len else: 65536
    if prefix_len > HEADER_BUFFER_CAP:
        return (0, 0.to_u64())
    val prefix_read = simpleos_fat32_stream_read_at(0.to_u64(), buf, prefix_len)
    if prefix_read < 0 or (prefix_read as u64) != prefix_len:
        return (0, 0.to_u64())
    (fsize, buf)

fn _x86_64_read_spawn_bytes_and_blob(path: text) -> ([u8], u64):
    val fsize = simpleos_fat32_stream_open(path)
    if fsize <= 4 or fsize > 4194304:
        return ([], 0.to_u64())
    val buf = simpleos_fat32_path_read_buffer_addr()
    if buf == 0.to_u64():
        return ([], 0.to_u64())
    val n = simpleos_fat32_stream_read_at(0.to_u64(), buf, fsize.to_u64())
    if n <= 0:
        return ([], 0.to_u64())
    if not _x86_64_raw_header_is_elf(buf):
        return ([], 0.to_u64())
    (rt_bytes_from_raw(buf as i64, fsize), buf)

pub fn x86_64_fs_exec_handoff_blob_ready(byte_len: i64, raw_blob: u64) -> bool:
    byte_len > 4 and raw_blob != 0.to_u64()

pub fn x86_64_fs_exec_spawn(path: text, argv: [text], envp: [text]) -> i64:
    """Spawn an x86_64 executable from the filesystem (kernel-origin caller)."""
    x86_64_fs_exec_spawn_as(0, path, argv, envp)

pub fn x86_64_fs_exec_spawn_as(caller: i64, path: text, argv: [text], envp: [text]) -> i64:
    """Capability-gated x86_64 spawn.

    caller == 0 is the kernel-origin sentinel (bypasses capability check).
    Returns the new PID on success, or a negative errno on failure.
    """
    val gate = exec_cap_check(caller, path)
    if gate != 0:
        serial_println("[fs-exec] x86_64:denied caller={caller} path={path} err={gate}")
        return gate as i64
    serial_println("[fs-exec] spawn:resolve path={path}")
    simpleos_bare_exec_reset()

    # Raw ELF files use the opened path's stream directly. Only the bounded header
    # prefix is resident; PT_LOAD bytes are read into their destination frames.
    # hdr_prefix = the exact resident byte count _x86_64_open_streaming_elf read
    # (ELF header + full phdr table) — the handoff bounds its phdr parse to it.
    val (stream_len, header_blob) = _x86_64_open_streaming_elf(path)
    if stream_len > 0:
        val hdr_prefix = mmio_read64(header_blob + 32) + ((mmio_read16(header_blob + 56) as u64) * (mmio_read16(header_blob + 54) as u64))
        return x86_64_fs_exec_enter_stream_ring3(path, header_blob, hdr_prefix, stream_len as u64, argv, envp)

    val (bytes, raw_blob) = _x86_64_read_spawn_bytes_and_blob(path)
    serial_println("[fs-exec] spawn:bytes path={path} len={bytes.len()}")
    if bytes.len() <= 4:
        serial_println("[fs-exec] spawn:resolve-fail path={path}")
        return -2

    var stub_bytes_len = bytes.len()
    var entry = 0
    if smf_has_header(bytes):
        val stub_result = smf_extract_executable_stub_for_arch(bytes, Architecture.X86_64)
        if stub_result.is_err():
            val legacy_stub = smf_extract_executable_stub_unchecked(bytes)
            if legacy_stub.len() <= 4:
                serial_println("[fs-exec] spawn:smf-fail path={path} err={stub_result.unwrap_err()}")
                return -3
            serial_println("[fs-exec] spawn:smf-legacy-ok path={path} err={stub_result.unwrap_err()} stub_bytes={legacy_stub.len()}")
            stub_bytes_len = legacy_stub.len()
        else:
            stub_bytes_len = stub_result.unwrap().len()
        val entry_result = smf_executable_entry_point_for_arch(bytes, Architecture.X86_64)
        entry = if entry_result.is_err(): 0 else: entry_result.unwrap()
    val prepared = fs_exec_prepare_spawn_from_bytes(path, bytes, Architecture.X86_64, argv, envp)
    if prepared.pid <= 0:
        return prepared.pid
    val pid = prepared.pid
    serial_println("[fs-exec] spawn:image path={path} entry={entry} segments=1 stub_bytes={stub_bytes_len} argv_count={argv.len()} env_count={envp.len()} pid={pid}")

    # Ring-3 control transfer: rebuild the general UserProcessImage from the same
    # resident FAT-read bytes, map its PT_LOAD segments into a fresh user address
    # space, and iretq to CPL3 (argv/envp are already threaded through the image
    # builder's build_initial_stack — no separate argv path here). This is the
    # map+enter sequence proven by the FS-exec smoke, lifted into the general
    # spawn. Does not return on success: the process runs at ring 3 and exits.
    val image = build_user_process_image_unchecked(path, bytes, Architecture.X86_64, argv, envp)
    val handoff_rc = if x86_64_fs_exec_handoff_blob_ready(bytes.len(), raw_blob):
        x86_64_fs_exec_enter_image_ring3(image, raw_blob, argv, envp)
    else:
        -5
    serial_println("[fs-exec] x86_64:handoff-return path={path} rc={handoff_rc}")
    # The handoff only RETURNS on failure (on success it iretq's to ring 3 and the
    # process exits). Reaching here means it did NOT execute — surface the failure
    # (docstring: "negative errno on failure") instead of a phantom-success pid. The
    # blob=0 cache-only paths still fail closed; FAT-backed paths pass the exact
    # resident read buffer that produced `bytes`.
    if handoff_rc < 0:
        return handoff_rc
    pid

pub fn x86_64_fs_exec_spawn_heap(path: text, argv: [text], envp: [text]) -> i64:
    """Stream-open `path` and enter it via the HEAP ring-3 handoff (opt-in 64
    MiB anonymous user heap, for real libc programs like clang). ALWAYS
    streams — never preloads — so payloads far larger than the 4 MiB static
    path-read buffer (clang is 124.6 MB) can run. No preload short-circuit and
    no legacy resident-bytes fallback: this is the minimal streaming-only path
    (Phase 2e Inc 1), mirroring the proven boot-time clang-stream entry
    (examples/09_embedded/simple_os/arch/x86_64/fs_exec_clang_stream_ring3_entry.spl)
    but callable from the sshd deferred-exec shallow frame."""
    serial_println("[fs-exec] heap:resolve path={path}")
    simpleos_bare_exec_reset()
    val (stream_len, header_blob) = _x86_64_open_streaming_elf(path)
    if stream_len <= 0:
        serial_println("[fs-exec] heap:stream-open-fail path={path} rc={stream_len}")
        return -2
    val hdr_prefix = mmio_read64(header_blob + 32) + ((mmio_read16(header_blob + 56) as u64) * (mmio_read16(header_blob + 54) as u64))
    serial_println("[fs-exec] heap:stream-open-ok path={path} len={stream_len} hdr_prefix={hdr_prefix}")
    x86_64_fs_exec_enter_stream_heap_ring3(path, header_blob, hdr_prefix, stream_len as u64, argv, envp)

fn x86_64_fs_exec_spawn_hello_world_smf() -> i64:
    """Backward-compat wrapper: spawn /sys/apps/hello_world.smf."""
    x86_64_fs_exec_spawn("/SYS/APPS/HELLOSMF.SMF", [], [])
