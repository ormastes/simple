# x86_64 filesystem-exec scheduler bridge.
use os.kernel.loader.fs_exec_spawn.{fs_exec_spawn}

pub fn x86_64_fs_exec_spawn(path: text, argv: [text], envp: [text]) -> i64:
    fs_exec_spawn(path, argv, envp)

fn x86_64_fs_exec_spawn_hello_world_smf() -> i64:
    """Backward-compat wrapper: spawn /sys/apps/hello_world.smf."""
    x86_64_fs_exec_spawn("/sys/apps/hello_world.smf", [], [])
