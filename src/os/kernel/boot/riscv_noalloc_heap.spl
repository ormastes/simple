# RISC-V noalloc heap window.
#
# Raw bump allocation over the upper RAM heap reservation. This is a
# freestanding-safe heap surface, not the hosted rt_alloc value ABI.

val NOALLOC_HEAP_ALIGN: u64 = 8

var g_riscv_noalloc_heap_ready: bool = false
var g_riscv_noalloc_heap_base: u64 = 0
var g_riscv_noalloc_heap_limit: u64 = 0
var g_riscv_noalloc_heap_next: u64 = 0
var g_riscv_noalloc_heap_used: u64 = 0

extern fn rt_riscv_uart_put(byte: u64)

fn _uart_put(byte: u64):
    rt_riscv_uart_put(byte)

fn _crlf():
    _uart_put(13)
    _uart_put(10)

fn _line_heap_ok():
    _uart_put(72)  # H
    _uart_put(69)  # E
    _uart_put(65)  # A
    _uart_put(80)  # P
    _uart_put(32)  # space
    _uart_put(79)  # O
    _uart_put(75)  # K
    _crlf()

fn _line_heap_fail():
    _uart_put(72)  # H
    _uart_put(69)  # E
    _uart_put(65)  # A
    _uart_put(80)  # P
    _uart_put(32)  # space
    _uart_put(70)  # F
    _uart_put(65)  # A
    _uart_put(73)  # I
    _uart_put(76)  # L
    _crlf()

fn _align_heap(value: u64) -> u64:
    ((value + NOALLOC_HEAP_ALIGN - 1) / NOALLOC_HEAP_ALIGN) * NOALLOC_HEAP_ALIGN

fn riscv_noalloc_heap_init(heap_start: u64, heap_size: u64) -> bool:
    if heap_size < NOALLOC_HEAP_ALIGN:
        _line_heap_fail()
        return false
    val base = heap_start
    val heap_end = base + heap_size
    if heap_end <= base:
        _line_heap_fail()
        return false

    g_riscv_noalloc_heap_base = base
    g_riscv_noalloc_heap_limit = heap_end
    g_riscv_noalloc_heap_next = base
    g_riscv_noalloc_heap_used = 0
    g_riscv_noalloc_heap_ready = true
    _line_heap_ok()
    true

fn riscv_noalloc_heap_alloc(size: u64) -> u64:
    if not g_riscv_noalloc_heap_ready:
        return 0
    if size < 1:
        return 0
    val bytes = _align_heap(size)
    val next = _align_heap(g_riscv_noalloc_heap_next)
    if next + bytes > g_riscv_noalloc_heap_limit:
        return 0
    g_riscv_noalloc_heap_next = next + bytes
    g_riscv_noalloc_heap_used = g_riscv_noalloc_heap_used + bytes
    next

fn riscv_noalloc_heap_is_ready() -> bool:
    g_riscv_noalloc_heap_ready

fn riscv_noalloc_heap_used() -> u64:
    g_riscv_noalloc_heap_used
