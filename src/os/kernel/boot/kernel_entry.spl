# SimpleOS Kernel Entry — Minimal Boot
#
# The absolute minimum: init log → serial, print message, halt.
# Uses Multiboot2 via existing crt0.s → runtime_minimal.c → __simple_main()
#
# Build: bin/simple native-build --entry src/os/kernel/boot/kernel_entry.spl -o build/simpleos.elf
# Run:   qemu-system-x86_64 -kernel build/simpleos.elf -serial stdio -display none

use os.kernel.log.klog_api.{log_init_serial, log_raw_println, LOG_INFO}

fn main():
    """Entry point called by runtime_minimal.c → __simple_main()."""
    log_init_serial(LOG_INFO)
    log_raw_println("Hello from SimpleOS")
    log_raw_println("Kernel booted via Multiboot2 on x86_64")
    log_raw_println("Serial output working on COM1 at 115200 baud")

    # Halt — cli + hlt loop
    # In a real kernel, we'd continue to memory_init() etc.
    log_raw_println("Halting.")
