# Volatile MMIO for OS kernel (64-bit addresses)
#
# Wraps the C runtime volatile access functions.
# These guarantee reads/writes are not optimized away by the compiler.

extern fn rt_mmio_read_u64(addr: u64) -> u64
extern fn rt_mmio_write_u64(addr: u64, value: u64)
extern fn rt_mmio_read_u32(addr: u64) -> u32
extern fn rt_mmio_write_u32(addr: u64, value: u32)
extern fn rt_mmio_read_u16(addr: u64) -> u16
extern fn rt_mmio_write_u16(addr: u64, value: u16)
extern fn rt_mmio_read_u8(addr: u64) -> u8
extern fn rt_mmio_write_u8(addr: u64, value: u8)
extern fn rt_invlpg(addr: u64)

class _MmioByteRegion:
    base: u64
    values: [u8]

impl _MmioByteRegion:
    fn contains(addr: u64) -> bool:
        addr >= self.base and addr < self.base + (self.values.len() as u64)

    fn can_append(addr: u64) -> bool:
        addr == self.base + (self.values.len() as u64)

    fn read(addr: u64) -> u8:
        self.values[(addr - self.base) as i64]

    me write(addr: u64, value: u8):
        if self.can_append(addr):
            me.values.push(value)
        else:
            me.values[(addr - self.base) as i64] = value

class _MmioWordRegion:
    base: u64
    values: [u64]

impl _MmioWordRegion:
    fn contains(addr: u64) -> bool:
        addr >= self.base and ((addr - self.base) % 8) == 0 and ((addr - self.base) / 8) < (self.values.len() as u64)

    fn can_append(addr: u64) -> bool:
        addr == self.base + (self.values.len() as u64) * 8

    fn read(addr: u64) -> u64:
        self.values[((addr - self.base) / 8) as i64]

    me write(addr: u64, value: u64):
        if self.can_append(addr):
            me.values.push(value)
        else:
            me.values[((addr - self.base) / 8) as i64] = value

var _mmio_test_mode: bool = false
var _mmio_test_bytes: [_MmioByteRegion] = []
var _mmio_test_words: [_MmioWordRegion] = []
var _mmio_test_addr16: [u64] = []
var _mmio_test_value16: [u16] = []
var _mmio_test_addr32: [u64] = []
var _mmio_test_value32: [u32] = []

fn _mmio_test_find(addresses: [u64], addr: u64) -> i64:
    var i: i64 = 0
    while i < addresses.len():
        if addresses[i] == addr:
            return i
        i = i + 1
    -1

fn _mmio_test_read8(addr: u64) -> u8:
    var i: i64 = 0
    while i < _mmio_test_bytes.len():
        if _mmio_test_bytes[i].contains(addr):
            return _mmio_test_bytes[i].read(addr)
        i = i + 1
    0

fn _mmio_test_write8(addr: u64, value: u8):
    var i: i64 = 0
    while i < _mmio_test_bytes.len():
        if _mmio_test_bytes[i].contains(addr) or _mmio_test_bytes[i].can_append(addr):
            _mmio_test_bytes[i].write(addr, value)
            return
        i = i + 1
    _mmio_test_bytes.push(_MmioByteRegion(base: addr, values: [value]))

fn _mmio_test_read64(addr: u64) -> u64:
    var i: i64 = 0
    while i < _mmio_test_words.len():
        if _mmio_test_words[i].contains(addr):
            return _mmio_test_words[i].read(addr)
        i = i + 1
    0

fn _mmio_test_write64(addr: u64, value: u64):
    var i: i64 = 0
    while i < _mmio_test_words.len():
        if _mmio_test_words[i].contains(addr) or _mmio_test_words[i].can_append(addr):
            _mmio_test_words[i].write(addr, value)
            return
        i = i + 1
    _mmio_test_words.push(_MmioWordRegion(base: addr, values: [value]))

fn mmio_reset_for_test():
    _mmio_test_mode = true
    _mmio_test_bytes = []
    _mmio_test_words = []
    _mmio_test_addr16 = []
    _mmio_test_value16 = []
    _mmio_test_addr32 = []
    _mmio_test_value32 = []

fn mmio_test_mode_enabled() -> bool:
    _mmio_test_mode

fn mmio_invalidate_tlb(addr: u64):
    if _mmio_test_mode:
        return
    rt_invlpg(addr)

fn mmio_read64(addr: u64) -> u64:
    """Read 64-bit value from memory-mapped register."""
    if _mmio_test_mode:
        return _mmio_test_read64(addr)
    rt_mmio_read_u64(addr)

fn mmio_write64(addr: u64, value: u64):
    """Write 64-bit value to memory-mapped register."""
    if _mmio_test_mode:
        _mmio_test_write64(addr, value)
        return
    rt_mmio_write_u64(addr, value)

fn mmio_read32(addr: u64) -> u32:
    """Read 32-bit value from memory-mapped register."""
    if _mmio_test_mode:
        val index = _mmio_test_find(_mmio_test_addr32, addr)
        if index < 0: return 0
        return _mmio_test_value32[index]
    rt_mmio_read_u32(addr)

fn mmio_write32(addr: u64, value: u32):
    """Write 32-bit value to memory-mapped register."""
    if _mmio_test_mode:
        val index = _mmio_test_find(_mmio_test_addr32, addr)
        if index < 0:
            _mmio_test_addr32.push(addr)
            _mmio_test_value32.push(value)
        else:
            _mmio_test_value32[index] = value
        return
    rt_mmio_write_u32(addr, value)

fn mmio_read16(addr: u64) -> u16:
    """Read 16-bit value from memory-mapped register."""
    if _mmio_test_mode:
        val index = _mmio_test_find(_mmio_test_addr16, addr)
        if index < 0: return 0
        return _mmio_test_value16[index]
    rt_mmio_read_u16(addr)

fn mmio_write16(addr: u64, value: u16):
    """Write 16-bit value to memory-mapped register."""
    if _mmio_test_mode:
        val index = _mmio_test_find(_mmio_test_addr16, addr)
        if index < 0:
            _mmio_test_addr16.push(addr)
            _mmio_test_value16.push(value)
        else:
            _mmio_test_value16[index] = value
        return
    rt_mmio_write_u16(addr, value)

fn mmio_read8(addr: u64) -> u8:
    """Read 8-bit value from memory-mapped register."""
    if _mmio_test_mode:
        return _mmio_test_read8(addr)
    rt_mmio_read_u8(addr)

fn mmio_write8(addr: u64, value: u8):
    """Write 8-bit value to memory-mapped register."""
    if _mmio_test_mode:
        _mmio_test_write8(addr, value)
        return
    rt_mmio_write_u8(addr, value)
