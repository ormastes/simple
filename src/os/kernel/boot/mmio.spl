# Volatile MMIO for OS kernel (64-bit addresses)
#
# Wraps the C runtime volatile access functions.
# These guarantee reads/writes are not optimized away by the compiler.

use os.kernel.boot.mmio_hardware.{
    hardware_mmio_read64, hardware_mmio_write64,
    hardware_mmio_read32, hardware_mmio_write32,
    hardware_mmio_read16, hardware_mmio_write16,
    hardware_mmio_read8, hardware_mmio_write8
}

extern fn rt_invlpg(addr: u64)

var _mmio_test_mode: bool = false
var _mmio_test_value8: Dict<u64, u8> = {}
var _mmio_test_value64: Dict<u64, u64> = {}
var _mmio_test_value16: Dict<u64, u16> = {}
var _mmio_test_value32: Dict<u64, u32> = {}

fn _mmio_test_read8(addr: u64) -> u8:
    _mmio_test_value8.get(addr) ?? 0

fn _mmio_test_write8(addr: u64, value: u8):
    _mmio_test_value8[addr] = value

fn _mmio_test_read64(addr: u64) -> u64:
    _mmio_test_value64.get(addr) ?? 0

fn _mmio_test_write64(addr: u64, value: u64):
    _mmio_test_value64[addr] = value

fn mmio_reset_for_test():
    _mmio_test_mode = true
    _mmio_test_value8 = {}
    _mmio_test_value64 = {}
    _mmio_test_value16 = {}
    _mmio_test_value32 = {}

fn mmio_test_mode_enabled() -> bool:
    _mmio_test_mode

fn mmio_disable_test_mode():
    """Pin the MMIO layer to the real-hardware path.

    Freestanding native builds skip module-level initializers, so the
    `var _mmio_test_mode: bool = false` default above never executes and the flag
    reads garbage (often non-zero = true) out of un-zeroed .bss. That routes every
    `mmio_read*/write*` through the empty test table, so they return nil/0 — which
    silently breaks the ring-3 ELF-magic checks that read the resident blob via
    `mmio_read*`. Boot entries must call this once, before any MMIO, to force the
    flag off deterministically.
    """
    _mmio_test_mode = false

fn mmio_invalidate_tlb(addr: u64):
    if _mmio_test_mode:
        return
    rt_invlpg(addr)

fn mmio_read64(addr: u64) -> u64:
    """Read 64-bit value from memory-mapped register."""
    if _mmio_test_mode:
        return _mmio_test_read64(addr)
    hardware_mmio_read64(addr)

fn mmio_write64(addr: u64, value: u64):
    """Write 64-bit value to memory-mapped register."""
    if _mmio_test_mode:
        _mmio_test_write64(addr, value)
        return
    hardware_mmio_write64(addr, value)

fn mmio_read32(addr: u64) -> u32:
    """Read 32-bit value from memory-mapped register."""
    if _mmio_test_mode:
        return _mmio_test_value32.get(addr) ?? 0
    hardware_mmio_read32(addr)

fn mmio_write32(addr: u64, value: u32):
    """Write 32-bit value to memory-mapped register."""
    if _mmio_test_mode:
        _mmio_test_value32[addr] = value
        return
    hardware_mmio_write32(addr, value)

fn mmio_read16(addr: u64) -> u16:
    """Read 16-bit value from memory-mapped register."""
    if _mmio_test_mode:
        return _mmio_test_value16.get(addr) ?? 0
    hardware_mmio_read16(addr)

fn mmio_write16(addr: u64, value: u16):
    """Write 16-bit value to memory-mapped register."""
    if _mmio_test_mode:
        _mmio_test_value16[addr] = value
        return
    hardware_mmio_write16(addr, value)

fn mmio_read8(addr: u64) -> u8:
    """Read 8-bit value from memory-mapped register."""
    if _mmio_test_mode:
        return _mmio_test_read8(addr)
    hardware_mmio_read8(addr)

fn mmio_write8(addr: u64, value: u8):
    """Write 8-bit value to memory-mapped register."""
    if _mmio_test_mode:
        _mmio_test_write8(addr, value)
        return
    hardware_mmio_write8(addr, value)
