# Boot filesystem freestanding-safe probe/mount slice.
#
# This module is the production boundary between the freestanding RISC-V kernel
# and the hosted VFS/process-launch path.  It MUST NOT import:
#   - os.userlib.process (spawn_binary)
#   - os.kernel.loader.* (load_user_executable, build_user_process_image)
#   - os.kernel.arch.arch_context (current_architecture)
#   - os.services.vfs.vfs_init (NvfsHostedDriver, app_registry_load, Fat32Driver)
#   - std.fs_driver.nvfs_hosted_driver
#
# The safe import boundary:
#   - log_raw_println (extern, freestanding)
#   - CNvmeBlockAdapterFs from c_nvme_adapter (C NVMe bridge only, freestanding copy)
#   - nvfs_superblock (BlockDevice-level NVFS probe, no hosted driver)
#   - dbfs_engine.superblock (BlockDevice-level DBFS probe, no hosted driver)
#
# MDSOC: feature dimension, kernel boot layer.

use os.kernel.log.klog_api.{log_raw_println}
use os.kernel.boot.c_nvme_adapter.{CNvmeBlockAdapterFs}
use os.drivers.user_space_driver_contract.{user_space_driver_all_direct_access_reason}
use std.fs_driver.nvfs_superblock.{
    nvfs_superblock_set_device, nvfs_superblock_probe_disk, nvfs_superblock_read_from_disk
}
use std.db.dbfs_engine.superblock.{
    dbfs_superblock_set_device, dbfs_superblock_probe_disk, dbfs_superblock_read_from_disk
}

# ============================================================================
# Mount-result enum — no spawn, no PID, no hosted state
# ============================================================================

enum FsMountType:
    Nvfs
    Dbfs
    None_

struct FsMountResult:
    mounted:  bool
    fs_type:  FsMountType
    provider: text
    pure_simple: bool

struct BootStorageAcceptanceEvidence:
    result: FsMountResult
    pci_resource_grant_ready: bool
    storage_transfer_ready: bool
    superblock_from_real_sector: bool
    non_secure_namespace: bool
    storage_grant_kind: text
    driver_placement: text
    common_driver_logic_shared: bool
    iommu_or_broker: bool

var _fs_mount_done: bool = false
var _fs_mount_type: FsMountType = FsMountType.None_

fn fs_mount_done() -> bool:
    _fs_mount_done

fn fs_mount_type() -> FsMountType:
    _fs_mount_type

# ============================================================================
# Freestanding probe/mount — entry point for os_main
# ============================================================================

fn boot_fs_mount_freestanding() -> Result<FsMountResult, text>:
    """Probe NVFS then DBFS via the C NVMe bridge.
    Records mount state in module-level vars.
    Does NOT launch any user process.
    Safe to call from os_main in a freestanding RV64 closure."""
    log_raw_println("[boot-fs-mount] Starting freestanding filesystem probe...")

    # Try NVFS first
    val nvfs_ok = _probe_nvfs()
    if nvfs_ok:
        _fs_mount_done = true
        _fs_mount_type = FsMountType.Nvfs
        log_raw_println("[boot-fs-mount] NVFS root superblock confirmed")
        return Ok(FsMountResult(mounted: true, fs_type: FsMountType.Nvfs, provider: "c-boot-bridge", pure_simple: false))

    # Try DBFS
    val dbfs_ok = _probe_dbfs()
    if dbfs_ok:
        _fs_mount_done = true
        _fs_mount_type = FsMountType.Dbfs
        log_raw_println("[boot-fs-mount] DBFS root superblock confirmed")
        return Ok(FsMountResult(mounted: true, fs_type: FsMountType.Dbfs, provider: "c-boot-bridge", pure_simple: false))

    log_raw_println("[boot-fs-mount] No NVFS or DBFS superblock found")
    _fs_mount_done = false
    _fs_mount_type = FsMountType.None_
    Err("boot-fs-mount: no freestanding-safe root filesystem found")

fn boot_fs_mount_freestanding_production() -> Result<FsMountResult, text>:
    """Production freestanding root probe: fail closed on C-backed storage."""
    val mount_r = boot_fs_mount_freestanding()
    if mount_r.is_err():
        return mount_r
    val result = mount_r.unwrap()
    val reason = boot_fs_mount_acceptance_reason(result)
    if reason != "ready":
        _fs_mount_done = false
        _fs_mount_type = FsMountType.None_
        log_raw_println("[boot-fs-mount] production storage rejected: {reason}")
        return Err(reason)
    Ok(result)

fn boot_fs_mount_provider_is_pure_simple(provider: text) -> bool:
    provider == "simple-driver"

fn boot_fs_mount_acceptance_reason(result: FsMountResult) -> text:
    if not result.mounted:
        return "not-mounted"
    if result.pure_simple and boot_fs_mount_provider_is_pure_simple(result.provider):
        return "ready"
    "boot-storage-not-pure-simple:" + result.provider

fn boot_storage_acceptance_evidence(
    result: FsMountResult,
    pci_resource_grant_ready: bool,
    storage_transfer_ready: bool,
    superblock_from_real_sector: bool,
    non_secure_namespace: bool,
    storage_grant_kind: text,
    driver_placement: text,
    common_driver_logic_shared: bool,
    iommu_or_broker: bool
) -> BootStorageAcceptanceEvidence:
    BootStorageAcceptanceEvidence(
        result: result,
        pci_resource_grant_ready: pci_resource_grant_ready,
        storage_transfer_ready: storage_transfer_ready,
        superblock_from_real_sector: superblock_from_real_sector,
        non_secure_namespace: non_secure_namespace,
        storage_grant_kind: storage_grant_kind,
        driver_placement: driver_placement,
        common_driver_logic_shared: common_driver_logic_shared,
        iommu_or_broker: iommu_or_broker
    )

fn boot_storage_acceptance_reason(e: BootStorageAcceptanceEvidence) -> text:
    if not e.result.mounted:
        return "not-mounted"
    if e.result.fs_type == FsMountType.None_:
        return "missing-root-filesystem"
    if not e.result.pure_simple:
        return "boot-storage-not-pure-simple:" + e.result.provider
    if not boot_fs_mount_provider_is_pure_simple(e.result.provider):
        return "boot-storage-not-pure-simple:" + e.result.provider
    if not e.pci_resource_grant_ready:
        return "missing-boot-storage-pci-grant"
    if not e.storage_transfer_ready:
        return "missing-boot-storage-transfer"
    if not e.superblock_from_real_sector:
        return "missing-real-sector-superblock-probe"
    if not e.non_secure_namespace:
        return "missing-boot-storage-non-secure-namespace"
    val direct_access_reason = user_space_driver_all_direct_access_reason(
        "nvme",
        e.driver_placement,
        e.storage_grant_kind,
        "non-secure-resource-namespace",
        e.common_driver_logic_shared,
        e.iommu_or_broker,
        e.result.provider
    )
    if direct_access_reason != "ready":
        return "boot-storage-direct-access:" + direct_access_reason
    "ready"

fn boot_storage_acceptance_ready(e: BootStorageAcceptanceEvidence) -> bool:
    boot_storage_acceptance_reason(e) == "ready"

# ============================================================================
# Internal helpers — freestanding only, no hosted symbols
# ============================================================================

fn _make_c_adapter() -> CNvmeBlockAdapterFs:
    CNvmeBlockAdapterFs(sector_buf_addr: 0, ready: false)

fn _probe_nvfs() -> bool:
    log_raw_println("[boot-fs-mount] Probing NVMe for NVFS superblock...")
    var adapter = _make_c_adapter()
    val init_ok = adapter.init_c_bridge()
    if not init_ok:
        log_raw_println("[boot-fs-mount] NVMe adapter init failed — no NVFS")
        return false

    nvfs_superblock_set_device(adapter)

    val found = nvfs_superblock_probe_disk()
    if not found:
        log_raw_println("[boot-fs-mount] No NVFS superblock at LBA 0")
        return false

    val sb = nvfs_superblock_read_from_disk()
    log_raw_println("[boot-fs-mount] NVFS superblock confirmed: gen={sb.mount_generation}")
    true

fn _probe_dbfs() -> bool:
    log_raw_println("[boot-fs-mount] Probing NVMe for DBFS superblock...")
    var adapter = _make_c_adapter()
    val init_ok = adapter.init_c_bridge()
    if not init_ok:
        log_raw_println("[boot-fs-mount] NVMe adapter init failed — no DBFS")
        return false

    dbfs_superblock_set_device(adapter)

    val found = dbfs_superblock_probe_disk()
    if not found:
        log_raw_println("[boot-fs-mount] No DBFS superblock at LBA 2")
        return false

    val sb = dbfs_superblock_read_from_disk()
    log_raw_println("[boot-fs-mount] DBFS superblock confirmed: gen={sb.mount_generation}")
    true
