# Freestanding-safe C NVMe block adapter for the boot filesystem mount path.
#
# This is a freestanding-safe duplicate of CNvmeBlockAdapter from
# os.services.vfs.vfs_block_adapters.  That module co-locates CNvmeBlockAdapter
# with NvmeBlockAdapter, which imports os.drivers.nvme.nvme_driver.{NvmeDriver}.
# The module-level `use` of NvmeDriver causes the linker to pull syscall-based
# DMA allocation into the freestanding closure even if NvmeBlockAdapter is never
# instantiated.
#
# This module imports ONLY:
#   - std.fs_driver.block_device (BlockDevice trait)
#   - os.kernel.boot.mmio      (mmio_read8, mmio_write8)
#   - os.kernel.log.klog_api   (log_raw_println)
#
# No NvmeDriver, no syscall, no pcimgr.  Safe for os_main entry-closure builds
# targeting riscv64gc-unknown-none.
#
# MDSOC: feature dimension, kernel boot layer.

use os.services.block_device.{BlockDevice}
use os.kernel.boot.mmio.{mmio_read8, mmio_write8}
use os.kernel.log.klog_api.{log_raw_println}

extern fn simpleos_nvme_init() -> i64
extern fn simpleos_nvme_read_sector(device_idx: u64, lba: u64, buf_addr: u64) -> i64
extern fn simpleos_nvme_write_sector(device_idx: u64, lba: u64, buf_addr: u64) -> i64
extern fn simpleos_fat32_path_read_buffer_addr() -> u64

# CNvmeBlockAdapter (freestanding copy)
#
# Wraps the baremetal C NVMe bridge (simpleos_nvme_*) as a BlockDevice.
# Renamed CNvmeBlockAdapterFs to distinguish from the hosted version in
# vfs_block_adapters.spl and to make freestanding-safe import explicit.

class CNvmeBlockAdapterFs:
    """Freestanding-safe C NVMe bridge adapter for boot filesystem probe/mount."""
    sector_buf_addr: u64
    ready: bool

impl CNvmeBlockAdapterFs:
    static fn new() -> CNvmeBlockAdapterFs:
        CNvmeBlockAdapterFs(sector_buf_addr: 0, ready: false)

    me init_c_bridge() -> bool:
        """Initialize the baremetal C NVMe/FAT32 bridge."""
        val init_result = simpleos_nvme_init()
        if init_result < 0:
            return false
        val buf = simpleos_fat32_path_read_buffer_addr()
        if buf == 0:
            return false
        self.sector_buf_addr = buf
        self.ready = true
        log_raw_println("[c-nvme-adapter-fs] Ready, sector buffer at 0x{self.sector_buf_addr}")
        true

    me init() -> Result<bool, text>:
        """Initialize: call the C NVMe bridge."""
        if not self.init_c_bridge():
            return Result.Err("CNvmeBlockAdapterFs: C NVMe init failed")
        Result.Ok(true)

impl BlockDevice for CNvmeBlockAdapterFs:
    me read_sector(lba: u64, buffer: [u8]) -> Result<bool, text>:
        """Read one sector from NVMe via the C bridge."""
        if not self.ready:
            return Result.Err("CNvmeBlockAdapterFs: not initialized")
        val result = simpleos_nvme_read_sector(0, lba, self.sector_buf_addr)
        if result < 0:
            return Result.Err("CNvmeBlockAdapterFs: read_sector failed")
        var i: u64 = 0
        val ss: u64 = 512
        while i < ss and i.to_i32() < buffer.len():
            buffer[i.to_i32()] = mmio_read8(self.sector_buf_addr + i)
            i = i + 1
        Result.Ok(true)

    me write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        """Write one sector to NVMe via the C bridge."""
        if not self.ready:
            return Result.Err("CNvmeBlockAdapterFs: not initialized")
        var i: u64 = 0
        val ss: u64 = 512
        while i < ss:
            val byte_val: u8 = if i.to_i32() < data.len(): data[i.to_i32()] else: 0
            mmio_write8(self.sector_buf_addr + i, byte_val)
            i = i + 1
        val result = simpleos_nvme_write_sector(0, lba, self.sector_buf_addr)
        if result < 0:
            return Result.Err("CNvmeBlockAdapterFs: write_sector failed")
        Result.Ok(true)

    me fn sector_size() -> u32:
        val nvme_sector_size: u32 = 512
        nvme_sector_size
