# Shared 16550 UART MMIO helpers for bare-metal kernels.

use os.kernel.boot.mmio.{mmio_read8, mmio_write8}

val UART16550_RBR: u64 = 0x00
val UART16550_THR: u64 = 0x00
val UART16550_DLL: u64 = 0x00
val UART16550_IER: u64 = 0x01
val UART16550_DLH: u64 = 0x01
val UART16550_FCR: u64 = 0x02
val UART16550_LCR: u64 = 0x03
val UART16550_MCR: u64 = 0x04
val UART16550_LSR: u64 = 0x05

val UART16550_LSR_DATA_READY: u8 = 0x01
val UART16550_LSR_THR_EMPTY: u8 = 0x20

val UART16550_LCR_DLAB: u8 = 0x80
val UART16550_LCR_8N1: u8 = 0x03
val UART16550_FCR_ENABLE_RESET_14: u8 = 0xC7
val UART16550_MCR_DTR_RTS_OUT2: u8 = 0x0B

fn uart16550_mmio_init(base: u64):
    """Initialize a memory-mapped 16550 UART for 115200 8N1 output."""
    mmio_write8(base + UART16550_IER, 0x00)
    mmio_write8(base + UART16550_LCR, UART16550_LCR_DLAB)
    mmio_write8(base + UART16550_DLL, 0x01)
    mmio_write8(base + UART16550_DLH, 0x00)
    mmio_write8(base + UART16550_LCR, UART16550_LCR_8N1)
    mmio_write8(base + UART16550_FCR, UART16550_FCR_ENABLE_RESET_14)
    mmio_write8(base + UART16550_MCR, UART16550_MCR_DTR_RTS_OUT2)

fn uart16550_mmio_write_byte(base: u64, byte: u8):
    """Write one byte, blocking until the TX holding register is empty."""
    while (mmio_read8(base + UART16550_LSR) & UART16550_LSR_THR_EMPTY) == 0:
        pass_do_nothing
    mmio_write8(base + UART16550_THR, byte)

fn uart16550_mmio_read_byte(base: u64) -> u8?:
    """Read one byte if RX data is available."""
    if (mmio_read8(base + UART16550_LSR) & UART16550_LSR_DATA_READY) != 0:
        return mmio_read8(base + UART16550_RBR)
    nil
