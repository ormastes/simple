# RISC-V Boot Memory Initialization
#
# MDSOC: feature dimension, memory layer
# Initializes PMM and heap for RISC-V QEMU virt boot.
# Uses identity mapping (SATP=Bare mode, no virtual memory).
# Called from boot_main before os_main / init_riscv_services.

use os.kernel.memory.pmm.{pmm_init_identity_range}
use os.kernel.memory.heap.{heap_init}
use os.kernel.types.memory_types.{VirtAddr}
use os.kernel.log.klog_api.{log_raw_println}

# ============================================================================
# QEMU virt memory map constants (from riscv_common/platform.spl)
# ============================================================================

# RAM starts at 0x80000000, 128MB total
val RISCV_RAM_BASE: u64 = 0x80000000
val RISCV_RAM_SIZE: u64 = 128 * 1024 * 1024   # 128 MiB

# Kernel occupies the first 2MB of RAM (conservative estimate)
val RISCV_KERNEL_START: u64 = 0x80000000
val RISCV_KERNEL_END: u64   = 0x80200000

# Heap carved from upper RAM: last 16MB of the 128MB region
val RISCV_HEAP_SIZE: u64  = 16 * 1024 * 1024   # 16 MiB
val RISCV_HEAP_START: u64 = RISCV_RAM_BASE + RISCV_RAM_SIZE - RISCV_HEAP_SIZE

# ============================================================================
# Public API
# ============================================================================

fn riscv_boot_mem_init() -> bool:
    """Initialize physical memory and heap for RISC-V boot.

    Uses identity mapping (SATP=Bare mode). PMM tracks the full 128MB
    QEMU virt RAM region. Heap is carved from the upper 16MB.

    Returns true if both PMM and heap initialized successfully.
    """
    log_raw_println("[riscv-mem] Initializing RISC-V boot memory...")
    log_raw_println("[riscv-mem] RAM: 0x{RISCV_RAM_BASE} - 0x{RISCV_RAM_BASE + RISCV_RAM_SIZE}")
    log_raw_println("[riscv-mem] Kernel: 0x{RISCV_KERNEL_START} - 0x{RISCV_KERNEL_END}")
    log_raw_println("[riscv-mem] Heap: 0x{RISCV_HEAP_START} size={RISCV_HEAP_SIZE / 1024}KB")

    # Step 1: Initialize PMM with identity-mapped memory bounds
    # TODO(B2): pmm_init_identity_range marks pages 256..ram_base/4096 as free,
    # which includes MMIO space below 0x80000000 (UART, PLIC, CLINT).
    # Safe while only the heap bump allocator is used, but pmm_alloc_page
    # could return MMIO pages. Fix by reserving MMIO ranges in PMM.
    val pmm_ok = pmm_init_identity_range(
        RISCV_RAM_BASE + RISCV_RAM_SIZE,
        RISCV_KERNEL_START,
        RISCV_KERNEL_END
    )
    if not pmm_ok:
        log_raw_println("[riscv-mem] PMM init FAILED")
        return false
    log_raw_println("[riscv-mem] PMM initialized")

    # Step 2: Initialize heap from upper RAM
    # Identity mapped: virtual addr == physical addr (SATP=Bare)
    val heap_start = VirtAddr(addr: RISCV_HEAP_START)
    heap_init(heap_start, RISCV_HEAP_SIZE)
    log_raw_println("[riscv-mem] Heap initialized")

    log_raw_println("[riscv-mem] Memory initialization complete")
    true
