# RISC-V noalloc boot handoff.
#
# This module is deliberately byte-only: no text, arrays, formatting, Option,
# Result, heap, PMM bitmap, or log facade. It gives the RISC-V boot ELF a real
# cross-module handoff point while the hosted value/runtime ABI is still absent.

val UART0_BASE: u64 = 0x10000000
val RISCV_RAM_BASE: u64 = 0x80000000
val RISCV_RAM_SIZE: u64 = 128 * 1024 * 1024
val RISCV_KERNEL_RESERVED_END: u64 = 0x80200000
val RISCV_HEAP_SIZE: u64 = 16 * 1024 * 1024
val RISCV_HEAP_START: u64 = RISCV_RAM_BASE + RISCV_RAM_SIZE - RISCV_HEAP_SIZE

var g_riscv_boot_hart_id: u64 = 0
var g_riscv_boot_dtb_addr: u64 = 0
var g_riscv_ram_base: u64 = 0
var g_riscv_ram_size: u64 = 0
var g_riscv_heap_start: u64 = 0
var g_riscv_heap_end: u64 = 0
var g_riscv_noalloc_handoff_ready: bool = false

extern fn rt_riscv_uart_put(byte: u64)

fn _uart_put(byte: u64):
    rt_riscv_uart_put(byte)

fn _crlf():
    _uart_put(13)
    _uart_put(10)

fn _line_mem():
    _uart_put(77)  # M
    _uart_put(69)  # E
    _uart_put(77)  # M
    _uart_put(32)  # space
    _uart_put(79)  # O
    _uart_put(75)  # K
    _crlf()

fn _line_idle():
    _uart_put(79)  # O
    _uart_put(83)  # S
    _uart_put(32)  # space
    _uart_put(73)  # I
    _uart_put(68)  # D
    _uart_put(76)  # L
    _uart_put(69)  # E
    _crlf()

fn riscv_noalloc_handoff(hart_id: u64, dtb_addr: u64):
    g_riscv_boot_hart_id = hart_id
    g_riscv_boot_dtb_addr = dtb_addr
    g_riscv_ram_base = RISCV_RAM_BASE
    g_riscv_ram_size = RISCV_RAM_SIZE
    g_riscv_heap_start = RISCV_HEAP_START
    g_riscv_heap_end = RISCV_HEAP_START + RISCV_HEAP_SIZE
    g_riscv_noalloc_handoff_ready = true
    _line_mem()

fn riscv_noalloc_boot_idle():
    _line_idle()

fn riscv_noalloc_handoff_is_ready() -> bool:
    g_riscv_noalloc_handoff_ready

fn riscv_noalloc_heap_start() -> u64:
    g_riscv_heap_start

fn riscv_noalloc_heap_end() -> u64:
    g_riscv_heap_end
