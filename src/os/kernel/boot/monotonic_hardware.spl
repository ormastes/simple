# Narrow boot-time monotonic clock owner for freestanding evidence paths.

extern fn rt_time_now_unix_micros() -> i64

val _BOOT_MONOTONIC_MAX_US: i64 = 9223372036854775807

fn boot_monotonic_prepare():
    # x86 establishes its TSC origin lazily; ARM/RISC-V already expose uptime.
    val _ = rt_time_now_unix_micros()

fn boot_monotonic_now_us() -> i64:
    val now = rt_time_now_unix_micros()
    if now > 0: now else: 0

fn boot_monotonic_elapsed_us(start_us: i64, end_us: i64) -> i64:
    if start_us <= 0 or end_us < start_us:
        return 0
    if end_us == start_us:
        return 1
    end_us - start_us

fn boot_monotonic_deadline_us(start_us: i64, budget_us: i64) -> i64:
    if start_us <= 0 or budget_us <= 0 or start_us > _BOOT_MONOTONIC_MAX_US - budget_us:
        return 0
    start_us + budget_us

export boot_monotonic_prepare, boot_monotonic_now_us, boot_monotonic_elapsed_us, boot_monotonic_deadline_us
