# HTTP Baremetal -- kernel-native HTTP transport for SimpleOS boot, running
# the REAL Simple web server's pure-logic pipeline (std.nogc_sync_mut.http_server):
# HttpStatus/HttpResponse (types.spl), parse_request_line (parser.spl),
# path_is_safe (router.spl), serialize_response (response.spl), and
# mime_from_path (mime.spl) are reused verbatim — this file does not
# reimplement HTTP status text, response framing, path-traversal checks, or
# MIME lookup.
#
# NOT reused: SimpleHttpServer (server.spl) — it imports
# std.concurrent.thread.thread_spawn_with_args, a threading dependency this
# single-core freestanding boot core cannot provide. Also not reused:
# parse_request/parse_request_with_limits (parser.spl) and write_response/
# write_error (response.spl) — they take a std.nogc_sync_mut.io.tcp.TcpStream
# parameter (a hosted OS-socket wrapper, not proven under
# x86_64-unknown-none). Router (router.spl)'s pattern-matching registration
# is also not wired in: this boot server only ever answers two fixed routes
# (GET / and GET /files/<name>), so route dispatch below is a small,
# explicitly-named hand-written seam rather than a Router instance — wiring
# a real Router is straightforward follow-up if more routes are needed.
#
# This transport binds/accepts/reads/writes via the true per-socket rt_net_*
# primitives (rt_net_socket/bind/listen/accept/send_bytes/recv_bytes/close —
# the same primitives sshd's own rt_boot_tcp_* convenience wrappers are built
# on; see src/os/apps/sshd/sshd.spl), NOT rt_io_tcp_bind/
# os.kernel.boot.tcp_baremetal_min: that path's underlying rt_boot_tcp_bind(addr)
# ignores its addr argument and always binds port 22 on this backend (see
# examples/09_embedded/simple_os/arch/x86_64/boot/baremetal_stubs.c
# rt_boot_tcp_bind), and its accept/read/write convenience functions share
# ONE single global listener/client slot process-wide — so it cannot coexist
# with sshd's own listener on a different port in the same boot image.
#
# GET /files/<name> reads through the switchable VFS hub
# (os.services.vfs.vfs_init.g_vfs_read_file_bytes / g_vfs_file_exists),
# which routes to whatever filesystem driver is mounted at boot (FAT32
# today, DBFS once Lane C1's DbFsDriver root mount lands) — no
# filesystem-specific token appears in this file.

use os.services.database.simple_db_service.{simple_db_execute_http_request, simple_db_http_request}
use os.services.vfs.vfs_init.{g_vfs_read_file_bytes, g_vfs_file_exists}
use os.kernel.net.http_route.{http_classify_request, HttpRoute, HttpRouteKind}
use std.nogc_sync_mut.http_server.types.{HttpResponse, HttpStatus}
use std.nogc_sync_mut.http_server.response.{serialize_response}
use std.nogc_sync_mut.http_server.mime.{mime_from_path}
use std.nogc_sync_mut.http_server.parser.{content_length_from_text}
use os.tls13.server.{tls13_accept, Tls13ServerConfig, Tls13AcceptResult, Tls13ServerContext}
use os.tls13.record13.{RecordKey, record13_encrypt_for_suite, record13_decrypt_for_suite, RecordResult}

extern fn log_raw_println(msg: text)
extern fn rt_net_socket(proto: i64) -> i64
extern fn rt_net_bind(sock_fd: i64, port_num: i64) -> i64
extern fn rt_net_listen(sock_fd: i64, backlog: i64) -> i64
extern fn rt_net_accept(sock_fd: i64) -> i64
extern fn rt_net_send_bytes(sock_fd: i64, data: [u8]) -> i64
extern fn rt_net_recv_bytes(sock_fd: i64, max_len: i64) -> [u8]
extern fn rt_net_close(sock_fd: i64) -> i64
extern fn rt_string_from_byte_array(arr: [u8]) -> text
extern fn rt_string_to_byte_array(s: text) -> [u8]

val HTTP_STATUS_BODY: text = "{\"status\":\"ok\",\"server\":\"SimpleOS\"}\n"

# HTTP_PORT: no env/config-read facility exists at this boot tier (checked
# alongside sshd/dbd's own boot services -- they hardcode their ports the
# same way). Left as a fixed constant per the lane guide rather than
# inventing a config system; a follow-up can wire this once the boot tier
# gets a general env facility.
val HTTP_PORT: i64 = 8080

# Recv-loop limits (Item 3 hardening). Previously a single fixed
# rt_net_recv_bytes(client, 4096) call assumed the whole request arrived in
# one read, silently truncating anything split across TCP segments.
val HTTP_RECV_CHUNK_SIZE: i64 = 4096      # per-recv() read size
val HTTP_MAX_REQUEST_BYTES: i64 = 65536   # total cap across headers+body
val HTTP_MAX_RECV_ITERATIONS: i64 = 64    # bounded recv() calls per request
val HTTP_MAX_KEEPALIVE_REQUESTS: i64 = 32 # requests served per connection

# rt_net_accept error-code convention (see baremetal_stubs.c rt_net_accept):
# ENCODE_INT(-11) = EAGAIN ("no pending connection", expected/benign);
# any other negative value is a real socket error worth logging.
val HTTP_ACCEPT_EAGAIN: i64 = -11

# Decode helper mirroring sshd's decode_net_runtime_i32/fd (see sshd.spl):
# the direct baremetal net runtime returns ENCODE_INT(value) for successes.
fn _http_decode_i64(raw: i64) -> i64:
    if raw > 7:
        return raw >> 3
    raw

fn _http_encode(resp: HttpResponse) -> [u8]:
    rt_string_to_byte_array(serialize_response(resp))

fn _http_serve_file(file_path: text) -> [u8]:
    if not g_vfs_file_exists(file_path):
        return _http_encode(HttpResponse(status: HttpStatus.NotFound, headers: [], body: "ERR file not found\n"))
    val bytes = g_vfs_read_file_bytes(file_path)
    if bytes.len() == 0:
        return _http_encode(HttpResponse(status: HttpStatus.NotFound, headers: [], body: "ERR file not found\n"))
    val content_type = mime_from_path(file_path)
    _http_encode(HttpResponse(status: HttpStatus.Ok, headers: [("Content-Type", content_type)], body: rt_string_from_byte_array(bytes)))

fn _http_route(request: text) -> [u8]:
    if simple_db_http_request(request):
        return rt_string_to_byte_array(simple_db_execute_http_request(request))
    # Route decision comes from the pure, spec-tested classifier (which reuses
    # the real parse_request_line + path_is_safe); the transport only does I/O.
    val route = http_classify_request(request)
    match route.kind:
        HttpRouteKind.BadRequest:
            _http_encode(HttpResponse(status: HttpStatus.BadRequest, headers: [], body: "ERR malformed request\n"))
        HttpRouteKind.NotFound:
            _http_encode(HttpResponse(status: HttpStatus.NotFound, headers: [], body: "ERR route not found\n"))
        HttpRouteKind.Status:
            _http_encode(HttpResponse(status: HttpStatus.Ok, headers: [("Content-Type", "application/json")], body: HTTP_STATUS_BODY))
        HttpRouteKind.File:
            _http_serve_file(route.file_path)

pub fn http_bind_baremetal() -> i64:
    """Bind and listen on the boot HTTP port. Returns the listener fd, or < 0
    on failure.

    Extracted so a combined multi-service boot entry can bind once and
    round-robin http_accept_and_handle_once() alongside other listeners
    (sshd, dbd) on the same single boot core.
    """
    val sock_raw = rt_net_socket(1)
    val sock_fd = _http_decode_i64(sock_raw)
    if sock_fd < 0:
        log_raw_println("[http_baremetal] ERROR: socket failed")
        return sock_fd
    val bind_rc = _http_decode_i64(rt_net_bind(sock_fd, HTTP_PORT))
    if bind_rc < 0:
        log_raw_println("[http_baremetal] ERROR: bind failed")
        return bind_rc
    val listen_rc = _http_decode_i64(rt_net_listen(sock_fd, 8))
    if listen_rc < 0:
        log_raw_println("[http_baremetal] ERROR: listen failed")
        return listen_rc
    sock_fd

# ============================================================================
# Recv accumulation (Item 3 hardening)
# ============================================================================

pub struct HttpRecvAccum:
    """Pure (socket-free) HTTP request accumulation state.

    Feed raw recv() chunks one at a time via http_recv_accum_feed; check
    .complete / .error after each feed. Deliberately holds no socket
    reference so it is directly unit-testable with hand-fed text chunks
    (headers split mid-line, body split across chunks, oversize input)."""
    buffer: text
    header_end: i64      # index of the \r\n\r\n separator once found, else -1
    content_length: i64  # Content-Length value once known, else -1
    complete: bool
    error: text

pub fn http_recv_accum_new() -> HttpRecvAccum:
    HttpRecvAccum(buffer: "", header_end: -1, content_length: -1, complete: false, error: "")

fn _http_content_length_from_headers(header_text: text) -> i64:
    """Scan raw CRLF-joined header lines for a Content-Length value.
    Reuses the shared, spec-tested content_length_from_text parser
    (std.nogc_sync_mut.http_server.parser) instead of reimplementing digit
    validation. Returns 0 if absent or invalid (no body expected)."""
    for line in header_text.split("\r\n"):
        val colon = line.index_of(":")
        if colon > 0:
            val name = line.substring(0, colon).trim().lower()
            if name == "content-length":
                val value = line.substring(colon + 1, line.len()).trim()
                val parsed = content_length_from_text(value)
                if parsed >= 0:
                    return parsed
    0

pub fn http_recv_accum_feed(state: HttpRecvAccum, chunk: text, max_total: i64) -> HttpRecvAccum:
    """Append one already-decoded recv() chunk and re-check completion.

    Accumulates until the header terminator (\\r\\n\\r\\n) is seen, then --
    if Content-Length is present -- keeps accumulating until the full body
    has arrived. Rejects (via .error) once the running total exceeds
    max_total, so a slow-loris-style unbounded body cannot exhaust boot
    memory. Pure: no sockets, so testable standalone."""
    if state.complete or state.error != "":
        return state
    val buffer = state.buffer + chunk
    if buffer.len() > max_total:
        return HttpRecvAccum(buffer: buffer, header_end: state.header_end,
                              content_length: state.content_length,
                              complete: false, error: "request too large")
    var header_end = state.header_end
    var content_length = state.content_length
    if header_end < 0:
        val found = buffer.index_of("\r\n\r\n")
        if found >= 0:
            header_end = found
            content_length = _http_content_length_from_headers(buffer.substring(0, header_end))
    if header_end >= 0:
        val body_start = header_end + 4
        val have = buffer.len() - body_start
        val need = if content_length > 0: content_length else: 0
        if have >= need:
            return HttpRecvAccum(buffer: buffer, header_end: header_end,
                                  content_length: content_length, complete: true, error: "")
    HttpRecvAccum(buffer: buffer, header_end: header_end,
                  content_length: content_length, complete: false, error: "")

fn _http_recv_request(client: i64) -> (text, text):
    """Drive http_recv_accum against the real socket with a bounded recv
    loop (replaces the old single fixed-size rt_net_recv_bytes call).

    Returns (request_text, error). error is "" on a complete request,
    else a short reason: "closed" (peer closed before sending anything),
    "request too large" (exceeded HTTP_MAX_REQUEST_BYTES), or "incomplete"
    (hit the bounded iteration cap without completing)."""
    var state = http_recv_accum_new()
    var iterations = 0
    while iterations < HTTP_MAX_RECV_ITERATIONS:
        if state.complete:
            return (state.buffer, "")
        if state.error != "":
            return (state.buffer, state.error)
        val chunk_bytes = rt_net_recv_bytes(client, HTTP_RECV_CHUNK_SIZE)
        if chunk_bytes.len() == 0:
            if state.buffer == "":
                return ("", "closed")
            break
        val chunk = rt_string_from_byte_array(chunk_bytes)
        state = http_recv_accum_feed(state, chunk, HTTP_MAX_REQUEST_BYTES)
        iterations = iterations + 1
    if state.complete:
        return (state.buffer, "")
    if state.error != "":
        return (state.buffer, state.error)
    (state.buffer, "incomplete")

fn _http_request_wants_close(request: text) -> bool:
    """Check the request's Connection header to decide whether to keep the
    connection open for another request.

    This boot server's keep-alive contract is deliberately simple (not full
    HTTP/1.1 semantics): closes after each request unless the client sends
    an explicit `Connection: keep-alive`."""
    val header_end = request.index_of("\r\n\r\n")
    val header_text = if header_end >= 0: request.substring(0, header_end) else: request
    for line in header_text.split("\r\n"):
        val colon = line.index_of(":")
        if colon > 0:
            val name = line.substring(0, colon).trim().lower()
            if name == "connection":
                val value = line.substring(colon + 1, line.len()).trim().lower()
                return value != "keep-alive"
    true

pub fn http_accept_and_handle_once(listener: i64) -> bool:
    """Accept a pending connection and handle up to
    HTTP_MAX_KEEPALIVE_REQUESTS requests on it (honoring
    `Connection: keep-alive`), then close.

    Differentiates "no pending connection" (EAGAIN, expected on every poll
    when nothing is waiting) from a real accept() failure: only the latter
    is logged, so the boot log isn't spammed once per idle poll."""
    val raw_client = rt_net_accept(listener)
    val client = _http_decode_i64(raw_client)
    if client < 0:
        if client != HTTP_ACCEPT_EAGAIN:
            log_raw_println("[http_baremetal] ERROR: accept failed")
        return false
    var handled = 0
    while handled < HTTP_MAX_KEEPALIVE_REQUESTS:
        val recv_result = _http_recv_request(client)
        val request = recv_result.0
        val recv_error = recv_result.1
        if recv_error != "" or request == "":
            break
        rt_net_send_bytes(client, _http_route(request))
        handled = handled + 1
        if _http_request_wants_close(request):
            break
    rt_net_close(client)
    true

# ============================================================================
# TLS 1.3 wrap (Item 1)
# ============================================================================
#
# HTTP_TLS_ENABLED defaults false: os.tls13's server path requires a
# Tls13ServerConfig(cert_chain, server_pkcs8, ...), but no server
# certificate/private key is wireable at this boot tier -- there is no key
# store and no config-read facility (the same constraint that pins HTTP_PORT
# above). The transport below is structurally complete and gated behind this
# flag; once a boot-tier cert-provisioning path exists, flip this to true and
# call http_accept_and_handle_once_tls(listener, config) from the accept loop
# in place of the plaintext http_accept_and_handle_once.
#
# The security-critical, non-socket logic -- framing an HTTP response into a
# TLS 1.3 application_data record and reassembling decrypted request bytes --
# is factored into the pure http_tls_encrypt_app_record /
# http_tls_decrypt_app_record seam so it is unit-testable over a byte buffer
# with no live socket (see test/01_unit/os/kernel/boot/http_baremetal_tls_spec.spl).
val HTTP_TLS_ENABLED: bool = false

# Real content type for a TLS 1.3 application_data record (RFC 8446 §5).
val HTTP_TLS_APPLICATION_DATA: u8 = 0x17

pub struct HttpTlsSession:
    """Per-connection TLS 1.3 application-data record state (socket-free).

    Holds the established application-traffic keys from a completed handshake
    plus the two directional sequence counters. Deliberately holds no socket
    reference: http_tls_encrypt_app_record / http_tls_decrypt_app_record are
    pure over this state and the returned (advanced) session, so record framing
    is testable with hand-built keys and no network."""
    cipher_suite: u16
    server_key: RecordKey
    client_key: RecordKey
    client_seq: u64
    server_seq: u64

pub struct HttpTlsSendResult:
    """Result of encrypting one outbound record: the wire bytes plus the
    session with server_seq advanced (return-the-object -- the caller must use
    .session for the next send)."""
    record: [u8]
    session: HttpTlsSession

pub struct HttpTlsRecvResult:
    """Result of decrypting one inbound record: the plaintext + real content
    type on success, or ok=false with a reason on AEAD/format failure. On
    failure the sequence is left unchanged (fail-closed)."""
    ok: bool
    content_type: i64
    data: [u8]
    error: text
    session: HttpTlsSession

pub fn http_tls_session_from_context(ctx: Tls13ServerContext) -> HttpTlsSession:
    """Build a record-layer session from the application keys a completed
    tls13_accept produced."""
    HttpTlsSession(
        cipher_suite: ctx.cipher_suite,
        server_key: RecordKey(key: ctx.server_app_key, iv: ctx.server_app_iv),
        client_key: RecordKey(key: ctx.client_app_key, iv: ctx.client_app_iv),
        client_seq: ctx.client_seq,
        server_seq: ctx.server_seq
    )

pub fn http_tls_encrypt_app_record(session: HttpTlsSession, plaintext: [u8]) -> HttpTlsSendResult:
    """Encrypt one plaintext buffer into a TLS 1.3 application_data record and
    advance server_seq. Reuses the spec-tested os.tls13.record13 AEAD layer;
    adds no crypto of its own."""
    val record = record13_encrypt_for_suite(session.cipher_suite, session.server_key, session.server_seq, HTTP_TLS_APPLICATION_DATA, plaintext)
    val next = HttpTlsSession(
        cipher_suite: session.cipher_suite,
        server_key: session.server_key,
        client_key: session.client_key,
        client_seq: session.client_seq,
        server_seq: session.server_seq + 1u64
    )
    HttpTlsSendResult(record: record, session: next)

pub fn http_tls_decrypt_app_record(session: HttpTlsSession, raw_record: [u8]) -> HttpTlsRecvResult:
    """Decrypt one raw TLS 1.3 record into plaintext and advance client_seq.
    On AEAD-auth or format failure, returns ok=false with the reason and leaves
    the sequence unchanged so a tampered record cannot desync the counter."""
    match record13_decrypt_for_suite(session.cipher_suite, session.client_key, session.client_seq, raw_record):
        case RecordResult.Ok(ct, data):
            val next = HttpTlsSession(
                cipher_suite: session.cipher_suite,
                server_key: session.server_key,
                client_key: session.client_key,
                client_seq: session.client_seq + 1u64,
                server_seq: session.server_seq
            )
            HttpTlsRecvResult(ok: true, content_type: ct, data: data, error: "", session: next)
        case RecordResult.Err(msg):
            HttpTlsRecvResult(ok: false, content_type: 0, data: [], error: msg, session: session)

fn _http_tls_read_exact(client: i64, n: i64) -> [u8]:
    """Read exactly n bytes from the socket, looping recv() until satisfied or
    the peer closes. Returns fewer than n bytes only on close/error."""
    var out: [u8] = []
    var iterations = 0
    while out.len().to_i64() < n and iterations < HTTP_MAX_RECV_ITERATIONS:
        val want = n - out.len().to_i64()
        val chunk = rt_net_recv_bytes(client, want)
        if chunk.len() == 0:
            break
        var k = 0
        while k < chunk.len().to_i64():
            out.push(chunk[k.to_u64()])
            k = k + 1
        iterations = iterations + 1
    out

fn _http_tls_read_record(client: i64) -> [u8]:
    """Read exactly one TLS record (5-byte header + length-prefixed payload)
    off the socket. Returns [] on close or a truncated/short read."""
    val header = _http_tls_read_exact(client, 5)
    if header.len().to_i64() < 5:
        return []
    val payload_len = ((header[3u64].to_i64() & 0xFF) << 8) | (header[4u64].to_i64() & 0xFF)
    var out: [u8] = []
    var i = 0
    while i < 5:
        out.push(header[i.to_u64()])
        i = i + 1
    if payload_len <= 0:
        return out
    val payload = _http_tls_read_exact(client, payload_len)
    if payload.len().to_i64() < payload_len:
        return []
    var j = 0
    while j < payload.len().to_i64():
        out.push(payload[j.to_u64()])
        j = j + 1
    out

fn _http_tls_recv_request(client: i64, session: HttpTlsSession) -> (text, text, HttpTlsSession):
    """Decrypt inbound TLS records and feed their application_data payloads
    into the SAME HttpRecvAccum used by the plaintext path, until a complete
    HTTP request is assembled. Returns (request_text, error, advanced_session);
    error is "" on success, else "closed"/"incomplete"/a decrypt reason."""
    var st = http_recv_accum_new()
    var sess = session
    var iterations = 0
    while iterations < HTTP_MAX_RECV_ITERATIONS:
        if st.complete:
            return (st.buffer, "", sess)
        if st.error != "":
            return (st.buffer, st.error, sess)
        val record = _http_tls_read_record(client)
        if record.len() == 0:
            if st.buffer == "":
                return ("", "closed", sess)
            break
        val dec = http_tls_decrypt_app_record(sess, record)
        sess = dec.session
        if not dec.ok:
            return (st.buffer, dec.error, sess)
        # Only application_data (0x17 = 23) carries HTTP; skip post-handshake
        # messages (tickets/key_update) that share the same wire content type.
        if dec.content_type == 23:
            val chunk = rt_string_from_byte_array(dec.data)
            st = http_recv_accum_feed(st, chunk, HTTP_MAX_REQUEST_BYTES)
        iterations = iterations + 1
    if st.complete:
        return (st.buffer, "", sess)
    if st.error != "":
        return (st.buffer, st.error, sess)
    (st.buffer, "incomplete", sess)

fn _http_tls_serve_connection(client: i64, ctx: Tls13ServerContext):
    """Run the keep-alive request loop over an established TLS session:
    decrypt request, route through the SAME _http_route classifier the
    plaintext path uses, encrypt the response back."""
    var session = http_tls_session_from_context(ctx)
    var handled = 0
    while handled < HTTP_MAX_KEEPALIVE_REQUESTS:
        val req = _http_tls_recv_request(client, session)
        val request = req.0
        val recv_error = req.1
        session = req.2
        if recv_error != "" or request == "":
            break
        val send = http_tls_encrypt_app_record(session, _http_route(request))
        session = send.session
        rt_net_send_bytes(client, send.record)
        handled = handled + 1
        if _http_request_wants_close(request):
            break

pub fn http_accept_and_handle_once_tls(listener: i64, config: Tls13ServerConfig) -> bool:
    """TLS 1.3 counterpart to http_accept_and_handle_once: accept a pending
    connection, run the os.tls13 server handshake over it, then serve requests
    inside the encrypted record layer. On handshake failure it logs and closes
    the socket (never hangs). Returns false only on the benign EAGAIN "nothing
    pending" poll, mirroring the plaintext accept path."""
    val raw_client = rt_net_accept(listener)
    val client = _http_decode_i64(raw_client)
    if client < 0:
        if client != HTTP_ACCEPT_EAGAIN:
            log_raw_println("[http_baremetal] ERROR: accept failed")
        return false
    match tls13_accept(client, config):
        case Tls13AcceptResult.Failed(reason):
            log_raw_println("[http_baremetal] TLS handshake failed, closing connection")
        case Tls13AcceptResult.Accepted(ctx):
            _http_tls_serve_connection(client, ctx)
    rt_net_close(client)
    true

fn start_http_server_baremetal():
    """Start a minimal single-core HTTP loop on the boot core."""
    log_raw_println("[http_baremetal] Starting minimal HTTP loop...")

    val listener = http_bind_baremetal()
    if listener < 0:
        return

    log_raw_println("[http_baremetal] Listening on 0.0.0.0:8080")
    log_raw_println("[http] serving on 0.0.0.0:8080")
    if HTTP_TLS_ENABLED:
        # Reserved for when a boot-tier certificate/key becomes provisionable:
        # the loop below would call http_accept_and_handle_once_tls(listener,
        # config). No such config source exists yet, so we stay on plaintext.
        log_raw_println("[http_baremetal] TLS requested but no boot-tier certificate is provisioned; serving plaintext")
    while true:
        http_accept_and_handle_once(listener)
