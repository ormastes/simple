# Raw volatile MMIO owner for production and freestanding entry closures.

extern fn rt_volatile_read_u64(addr: u64) -> u64
extern fn rt_volatile_write_u64(addr: u64, value: u64)
extern fn rt_volatile_read_u32(addr: u64) -> u32
extern fn rt_volatile_write_u32(addr: u64, value: u32)
extern fn rt_volatile_read_u16(addr: u64) -> u16
extern fn rt_volatile_write_u16(addr: u64, value: u16)
extern fn rt_volatile_read_u8(addr: u64) -> u8
extern fn rt_volatile_write_u8(addr: u64, value: u8)
extern fn rt_memory_barrier()
fn mmio_read64(addr: u64) -> u64: rt_volatile_read_u64(addr)
fn mmio_write64(addr: u64, value: u64): rt_volatile_write_u64(addr, value)
fn mmio_read32(addr: u64) -> u32: rt_volatile_read_u32(addr)
fn mmio_write32(addr: u64, value: u32): rt_volatile_write_u32(addr, value)
fn mmio_read16(addr: u64) -> u16: rt_volatile_read_u16(addr)
fn mmio_write16(addr: u64, value: u16): rt_volatile_write_u16(addr, value)
fn mmio_read8(addr: u64) -> u8: rt_volatile_read_u8(addr)
fn mmio_write8(addr: u64, value: u8): rt_volatile_write_u8(addr, value)
fn mmio_memory_barrier(): rt_memory_barrier()

# Unaliased owner names for entry-closure builds. Project AST merging does not
# preserve module-local `use ... as ...` bindings through native type checking.
fn hardware_mmio_read64(addr: u64) -> u64: rt_volatile_read_u64(addr)
fn hardware_mmio_write64(addr: u64, value: u64): rt_volatile_write_u64(addr, value)
fn hardware_mmio_read32(addr: u64) -> u32: rt_volatile_read_u32(addr)
fn hardware_mmio_write32(addr: u64, value: u32): rt_volatile_write_u32(addr, value)
fn hardware_mmio_read16(addr: u64) -> u16: rt_volatile_read_u16(addr)
fn hardware_mmio_write16(addr: u64, value: u16): rt_volatile_write_u16(addr, value)
fn hardware_mmio_read8(addr: u64) -> u8: rt_volatile_read_u8(addr)
fn hardware_mmio_write8(addr: u64, value: u8): rt_volatile_write_u8(addr, value)
