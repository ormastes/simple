# RISC-V noalloc boot log.
#
# Byte-only UART log markers for the freestanding boot closure. This avoids the
# hosted log facade because formatted text currently pulls runtime helpers.

var g_riscv_noalloc_log_ready: bool = false
var g_riscv_noalloc_log_events: u64 = 0

extern fn rt_riscv_uart_put(byte: u64)

fn _uart_put(byte: u64):
    rt_riscv_uart_put(byte)

fn _crlf():
    _uart_put(13)
    _uart_put(10)

fn _line_log_ok():
    _uart_put(76)  # L
    _uart_put(79)  # O
    _uart_put(71)  # G
    _uart_put(32)  # space
    _uart_put(79)  # O
    _uart_put(75)  # K
    _crlf()

fn _line_boot_ok():
    _uart_put(66)  # B
    _uart_put(79)  # O
    _uart_put(79)  # O
    _uart_put(84)  # T
    _uart_put(32)  # space
    _uart_put(79)  # O
    _uart_put(75)  # K
    _crlf()

fn riscv_noalloc_log_init():
    g_riscv_noalloc_log_ready = true
    g_riscv_noalloc_log_events = 0
    _line_log_ok()

fn riscv_noalloc_log_boot_ok():
    if not g_riscv_noalloc_log_ready:
        return
    g_riscv_noalloc_log_events = g_riscv_noalloc_log_events + 1
    _line_boot_ok()

fn riscv_noalloc_log_is_ready() -> bool:
    g_riscv_noalloc_log_ready

fn riscv_noalloc_log_event_count() -> u64:
    g_riscv_noalloc_log_events
