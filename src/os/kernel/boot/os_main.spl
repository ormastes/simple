# os_main — kernel entry after memory init
#
# MDSOC: feature dimension, kernel boot layer
# Called from arch-specific boot_main after PMM + heap are initialized.
# Boot sequence:
#   1. Mount root filesystem (NVFS → DBFS → FAT32 fallback)
#   2. Launch init process from root FS
#   3. Initialize services (PCI, network, display)
#   4. Start HTTP server or cooperative poll loop

use os.kernel.boot.riscv_services.{
    init_riscv_services_with_network, riscv_network_ready
}
use os.kernel.boot.http_baremetal.{start_http_server_baremetal}
use os.kernel.log.klog_api.{log_raw_println}

fn os_main():
    log_raw_println("")
    log_raw_println("=== SimpleOS Boot ===")
    log_raw_println("")

    log_raw_println("[os_main] Calling init_riscv_services_with_network()...")
    init_riscv_services_with_network()
    log_raw_println("[os_main] Service initialization returned")

    if riscv_network_ready():
        log_raw_println("[os_main] Starting baremetal HTTP server...")
        start_http_server_baremetal()
        log_raw_println("[os_main] HTTP server returned")
    else:
        log_raw_println("[os_main] HTTP server deferred: network unavailable")

    log_raw_println("[os_main] Entering boot idle loop")
    idle_loop()

fn idle_loop():
    """Idle loop reached when no inline service owns the boot core."""
    while true:
        pass
