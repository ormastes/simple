# os_main — kernel entry after memory init
#
# MDSOC: feature dimension, kernel boot layer
# Called from arch-specific boot_main after PMM + heap are initialized.
# Boot sequence:
#   1. Mount root filesystem (NVFS → DBFS → FAT32 fallback)
#   2. Launch init process from root FS
#   3. Initialize services (PCI, network, display)
#   4. Start HTTP server or cooperative poll loop

use os.kernel.boot.riscv_services.{
    init_riscv_services_with_network
}
use os.kernel.boot.http_baremetal.{start_http_server_baremetal}
use os.kernel.boot.boot_fs_mount.{boot_fs_mount_freestanding_production}

extern fn log_raw_println(msg: text)
extern fn rt_net_stats() -> i64

fn os_main() -> bool:
    """Run shared kernel boot (services + root FS mount).

    Returns true when the serial management shell should be run by the
    arch-specific boot_main (no network → UART fallback). Returns false
    (and never actually returns) when an inline service like the baremetal
    HTTP server owns the core.

    Arch-neutral by design: the UART shell itself is wired by each arch's
    boot_main (rv64/rv32 console), so the right console is used without a
    runtime arch check and os_main carries no arch-specific import."""
    log_raw_println("")
    log_raw_println("=== SimpleOS Boot ===")
    log_raw_println("")

    log_raw_println("[os_main] Calling init_riscv_services_with_network()...")
    init_riscv_services_with_network()
    log_raw_println("[os_main] Service initialization returned")

    log_raw_println("[os_main] Probing root filesystem (freestanding)...")
    val mount_r = boot_fs_mount_freestanding_production()
    if mount_r.is_err():
        log_raw_println("[os_main] Root filesystem unavailable: {mount_r.unwrap_err()}")
    else:
        val mount_info = mount_r.unwrap()
        if mount_info.mounted:
            log_raw_println("[os_main] Root filesystem mounted")
        else:
            log_raw_println("[os_main] Root filesystem probe returned not-mounted")

    if rt_net_stats() == 0:
        log_raw_println("[os_main] Starting baremetal HTTP server...")
        start_http_server_baremetal()
        log_raw_println("[os_main] HTTP server returned")
        log_raw_println("[os_main] Entering boot idle loop")
        idle_loop()
        return false
    log_raw_println("[os_main] HTTP server deferred: network unavailable")
    log_raw_println("[os_main] Requesting UART management shell (telnet/ssh-over-serial fallback)")
    return true

fn idle_loop():
    """Idle loop reached when no inline service owns the boot core."""
    while true:
        pass
