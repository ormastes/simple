# os_main — kernel entry after memory init
#
# MDSOC: feature dimension, kernel boot layer
# Called from arch-specific boot_main after PMM + heap are initialized.
# Initializes all services (PCI, network, display) then launches the
# HTTP server (B5) or falls back to cooperative network polling.

use os.kernel.boot.riscv_services.{init_riscv_services_with_network, riscv_network_ready}
use os.services.netstack.netstack_init.{net_service_init_port, net_service_poll}
use os.kernel.net.http_baremetal.{start_http_server_baremetal}
use os.kernel.log.klog_api.{log_raw_println}

fn os_main():
    log_raw_println("")
    log_raw_println("=== SimpleOS Boot ===")
    log_raw_println("")

    # Initialize RISC-V services (PCI scan, network probe, display).
    # NOTE: uses init_riscv_services_with_network() instead of init_all_services()
    # because the latter initializes BGA display via x86 I/O ports (0x01CE),
    # which would crash on RISC-V.
    log_raw_println("[os_main] Calling init_riscv_services_with_network()...")
    init_riscv_services_with_network()
    log_raw_println("[os_main] Service initialization returned")

    # Initialize netstack cooperative port if network is available
    if riscv_network_ready():
        log_raw_println("[os_main] Network ready -- initializing cooperative netstack port")
        net_service_init_port()
    else:
        log_raw_println("[os_main] Network unavailable -- skipping netstack")

    # B5: Launch HTTP server inline on the boot core.
    # The Worker's event loop replaces the cooperative poll loop —
    # it drives the IoDriver (driver_shim) which polls the netstack.
    # If the server exits (shutdown), fall through to idle poll loop.
    if riscv_network_ready():
        log_raw_println("[os_main] Starting HTTP server (B5 inline mode)...")
        start_http_server_baremetal()
        log_raw_println("[os_main] HTTP server exited, falling back to poll loop")
    else:
        log_raw_println("[os_main] No network -- skipping HTTP server")

    log_raw_println("[os_main] Entering cooperative network poll loop (idle)")

    # Fallback cooperative network poll loop.
    # Reached if: (a) network unavailable, or (b) HTTP server exits.
    # Drives netstack frame processing + IPC without blocking.
    network_poll_loop()

fn network_poll_loop():
    """Cooperative main loop: poll network stack each tick.

    Runs forever. net_service_poll() is non-blocking — processes
    one batch of incoming frames and IPC requests per call.
    On RISC-V this is the idle loop; wfi is in the asm halt stub.
    """
    while true:
        net_service_poll()
