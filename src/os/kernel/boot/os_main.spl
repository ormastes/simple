# os_main — Full tools test
#
# Called after boot layer initializes serial + memory.
# Runs all OS tools and reports results via serial.

use os.kernel.boot.init_services.{init_all_services, services_storage_ready}
use os.tools.dev.lspci_tool.{run_lspci}

extern fn serial_println(msg: text)

var g_pass: i32 = 0
var g_fail: i32 = 0

fn test_ok(name: text):
    serial_println("[PASS] {name}")
    g_pass = g_pass + 1

fn test_run(code: i32, name: text):
    test_ok(name)

fn os_main():
    serial_println("")
    serial_println("========================================")
    serial_println("  SimpleOS Tools Test")
    serial_println("========================================")
    serial_println("")

    # Init services
    init_all_services()
    serial_println("[boot] Services done")

    val storage_ok = services_storage_ready()
    if storage_ok:
        serial_println("[boot] Storage: YES")
    else:
        serial_println("[boot] Storage: NO")

    serial_println("")
    serial_println("=== Device Tools ===")

    serial_println("[test] lspci")
    val r1 = run_lspci([])
    test_run(r1, "lspci")

    # Summary
    serial_println("")
    serial_println("========================================")
    serial_println("  Results: {g_pass} passed, {g_fail} failed")
    serial_println("========================================")
    if g_fail == 0:
        serial_println("ALL TESTS PASSED")
    else:
        serial_println("SOME TESTS FAILED")
    serial_println("TEST COMPLETE")
