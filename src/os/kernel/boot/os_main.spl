# SimpleOS Full-Stack Boot Entry
#
# MDSOC: feature dimension, kernel layer
# Called after kernel initialization (memory, scheduler, interrupts ready).
# Chains: PCI -> drivers -> services -> applications
#
# Boot sequence:
# 1. Initialize POSIX compatibility layer
# 2. Initialize all services (storage, network)
# 3. Start service IPC ports (cooperative mode)
# 4. Run cooperative main loop: VFS poll + netstack poll + shell input

use os.kernel.boot.init_services.{init_all_services, services_storage_ready, services_network_ready}
use os.services.vfs.vfs_init.{vfs_service_init_port, vfs_service_poll, g_vfs}
use os.services.netstack.netstack_init.{net_service_init_port, net_service_poll, net_is_ready}
use os.apps.shell.shell_app.{ShellApp}
use os.posix.mod.{posix_init}

extern fn serial_println(msg: text)

# ============================================================================
# Boot Entry Point
# ============================================================================

fn os_main():
    """SimpleOS full-stack boot sequence.

    Called once from kernel_entry after hardware initialization
    (GDT, IDT, page tables, scheduler, IPC) is complete.

    Uses cooperative scheduling: a single main loop polls VFS IPC,
    netstack frames/IPC, and shell input each iteration. This avoids
    needing a preemptive task scheduler for service loops.
    """
    serial_println("")
    serial_println("=== SimpleOS Boot ===")
    serial_println("")

    # Step 1: Initialize POSIX compatibility layer
    posix_init()
    serial_println("[boot] POSIX layer initialized")

    # Step 2: Initialize all services (storage, network)
    init_all_services()

    # Step 3: Report service status
    serial_println("")
    if services_storage_ready():
        serial_println("[boot] Storage: OK (FAT32 on NVMe)")
    else:
        serial_println("[boot] Storage: FAILED")

    if services_network_ready():
        serial_println("[boot] Network: OK (VirtIO-net + TCP/IP)")
    else:
        serial_println("[boot] Network: FAILED (continuing without network)")

    # Step 4: Start service IPC ports (non-blocking init)
    if services_storage_ready():
        vfs_service_init_port()
        serial_println("[boot] VFS IPC service port initialized")

    if services_network_ready():
        net_service_init_port()
        serial_println("[boot] Netstack IPC service port initialized")

    serial_println("")
    serial_println("[boot] All services ready")
    serial_println("[boot] Entering cooperative main loop")
    serial_println("")

    # Step 5: Create shell (foreground application)
    var shell = ShellApp.with_vfs(g_vfs)
    shell.show_prompt()

    # Step 6: Cooperative main loop
    # Each iteration:
    #   a) Poll VFS service for IPC requests
    #   b) Poll netstack for frames + IPC
    #   c) Check shell for input + process command
    # This runs all services in a single thread without a scheduler.
    var running = true
    while running:
        # Poll VFS service (handles file open/read/write IPC from POSIX layer)
        if services_storage_ready():
            vfs_service_poll()

        # Poll network stack (handles frames + socket IPC)
        if services_network_ready():
            net_service_poll()

        # Poll shell for input (non-blocking check)
        # ShellApp.run() blocks — for cooperative mode, we need
        # to check if input is available and process one command
        val has_input = shell.check_input()
        if has_input:
            val should_continue = shell.process_pending()
            if not should_continue:
                running = false

    serial_println("")
    serial_println("[boot] Shell exited. Halting.")
