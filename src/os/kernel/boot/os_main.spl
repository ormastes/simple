# Minimal os_main — storage test only
use os.kernel.boot.init_services.{init_all_services, services_storage_ready}
use os.kernel.log.klog_api.{log_raw_println}

fn os_main():
    log_raw_println("")
    log_raw_println("=== SimpleOS Storage Test ===")
    log_raw_println("")
    log_raw_println("[test] Calling init_all_services()...")
    init_all_services()
    log_raw_println("[test] init_all_services() returned")
    if services_storage_ready():
        log_raw_println("[test] Storage: OK")
    else:
        log_raw_println("[test] Storage: FAILED")
    log_raw_println("[test] TEST COMPLETE")
