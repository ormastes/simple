# FAT32 kernel filesystem driver — IF-07 wave-4a/4b/4c.
#
# Wave-4a: BPB parse + cluster-to-lba arithmetic + real mount().
# Wave-4b: readdir("/") via stashed root-dir data; read_cluster_chain (guarded, cycle-safe).
# Wave-4c: open() + stat() for root-dir 8.3 names; read() wired through cluster-chain walk.

# -- Error codes ---------------------------------------------------------------

val EINVAL: i32 = -22   # bad signature
val EIO: i32    = -5    # wrong FS type
val ENOSYS: i32 = -38   # not implemented
val ENOENT: i32 = -2    # file not found

# -- BPB boot sector signature -------------------------------------------------

val FAT32_BOOT_SIG_0: u8 = 0x55
val FAT32_BOOT_SIG_1: u8 = 0xAA

# -- Public types --------------------------------------------------------------

struct FileHandle:
    """Open-file token returned by Fat32Filesystem.open()."""
    fd: u64                 # Opaque descriptor
    start_cluster: u32      # First cluster of the file
    current_cluster: u32    # Cluster cursor for sequential reads
    offset: u64             # Byte offset within file
    file_size: u64          # Total file size in bytes
    is_open: bool           # True when handle is valid

struct FileStat:
    """Minimal file metadata returned by Fat32Filesystem.stat()."""
    size: u64
    is_dir: bool
    mtime: u64              # POSIX seconds since epoch

struct Fat32Bpb:
    """BIOS Parameter Block — parsed from the first 512-byte sector."""
    bytes_per_sector: u16
    sectors_per_cluster: u8
    reserved_sectors: u16
    num_fats: u8
    total_sectors_32: u32
    fat_size_32: u32
    root_cluster: u32
    fs_info_sector: u16
    bs_fat_type_label: [u8]     # 8 bytes: "FAT32   "
    bs_boot_signature: u8
    bs_volume_id: u32
    bs_volume_label: [u8]       # 11 bytes
    bs_fat32_signature: [u8]    # 2 bytes: 0x55 0xAA

# -- Pure BPB parser -----------------------------------------------------------

fn parse_bpb(sector0: [u8]) -> Result<Fat32Bpb, i32>:
    """Parse the 512-byte boot sector into a Fat32Bpb.

    Returns Err(EINVAL=-22) for a missing 0x55AA signature.
    Returns Err(EIO=-5) if the FS-type label is not 'FAT32   '.
    """
    # Validate boot sector signature at bytes 510-511
    val sig0 = sector0[510]
    val sig1 = sector0[511]
    if sig0 != FAT32_BOOT_SIG_0 or sig1 != FAT32_BOOT_SIG_1:
        return Err(EINVAL)

    # Validate FAT32 type label at offset 82 (8 bytes: "FAT32   ")
    val l0 = sector0[82]
    val l1 = sector0[83]
    val l2 = sector0[84]
    val l3 = sector0[85]
    val l4 = sector0[86]
    if (l0 != 0x46 or l1 != 0x41 or l2 != 0x54 or
        l3 != 0x33 or l4 != 0x32):
        return Err(EIO)

    val bpb = Fat32Bpb(
        bytes_per_sector:   (sector0[12].to_u16() << 8) | sector0[11].to_u16(),
        sectors_per_cluster: sector0[13],
        reserved_sectors:   (sector0[15].to_u16() << 8) | sector0[14].to_u16(),
        num_fats:           sector0[16],
        total_sectors_32:   ((sector0[35].to_u32() << 24) | (sector0[34].to_u32() << 16) | (sector0[33].to_u32() << 8) | sector0[32].to_u32()),
        fat_size_32:        ((sector0[39].to_u32() << 24) | (sector0[38].to_u32() << 16) | (sector0[37].to_u32() << 8) | sector0[36].to_u32()),
        root_cluster:       ((sector0[47].to_u32() << 24) | (sector0[46].to_u32() << 16) | (sector0[45].to_u32() << 8) | sector0[44].to_u32()),
        fs_info_sector:     (sector0[49].to_u16() << 8) | sector0[48].to_u16(),
        bs_fat_type_label:  [sector0[82], sector0[83], sector0[84], sector0[85],
                             sector0[86], sector0[87], sector0[88], sector0[89]],
        bs_boot_signature:  sector0[66],
        bs_volume_id:       ((sector0[70].to_u32() << 24) | (sector0[69].to_u32() << 16) | (sector0[68].to_u32() << 8) | sector0[67].to_u32()),
        bs_volume_label:    [sector0[71], sector0[72], sector0[73], sector0[74],
                             sector0[75], sector0[76], sector0[77], sector0[78],
                             sector0[79], sector0[80], sector0[81]],
        bs_fat32_signature: [sector0[510], sector0[511]]
    )
    Ok(bpb)

# -- Cluster arithmetic --------------------------------------------------------

fn cluster_to_lba(bpb: Fat32Bpb, cluster: u32) -> u64:
    """Convert a cluster number to an absolute LBA sector.

    Formula: reserved_sectors + num_fats*fat_size_32 + (cluster-2)*sectors_per_cluster
    """
    val fat_region  = bpb.reserved_sectors.to_u64() + bpb.num_fats.to_u64() * bpb.fat_size_32.to_u64()
    val data_offset = (cluster - 2u32).to_u64() * bpb.sectors_per_cluster.to_u64()
    fat_region + data_offset

# -- LFN (long-filename) helpers ----------------------------------------------
# LFN slots use attr=0x0F and store UCS-2 code units across three regions of the
# 32-byte entry: bytes 1-10 (5 chars), 14-25 (6 chars), 28-31 (2 chars).
# Slots are stored in reverse sequence: the slot with the LAST 13 chars of the
# name is stored first physically (highest sequence + 0x40 last-bit). Walking
# forward through the directory we encounter highest-seq → lowest-seq → 8.3.

fn fat32_decode_lfn_code_unit(entry_data: [u8], offset: i32) -> text:
    val lo = entry_data[offset]
    val hi = entry_data[offset + 1]
    if hi == 0x00u8 and lo == 0x00u8:
        return ""               # NUL terminator
    if hi == 0xFFu8 and lo == 0xFFu8:
        return ""               # padding past terminator
    if hi != 0x00u8:
        return "?"              # non-ASCII (BMP code unit > 0xFF)
    lo.chr()

fn fat32_parse_lfn_slot(entry_data: [u8], offset: i32) -> text:
    var name = ""
    val c1 = fat32_decode_lfn_code_unit(entry_data, offset + 1)
    if c1 != "":
        name = name + c1
    val c2 = fat32_decode_lfn_code_unit(entry_data, offset + 3)
    if c2 != "":
        name = name + c2
    val c3 = fat32_decode_lfn_code_unit(entry_data, offset + 5)
    if c3 != "":
        name = name + c3
    val c4 = fat32_decode_lfn_code_unit(entry_data, offset + 7)
    if c4 != "":
        name = name + c4
    val c5 = fat32_decode_lfn_code_unit(entry_data, offset + 9)
    if c5 != "":
        name = name + c5
    val c6 = fat32_decode_lfn_code_unit(entry_data, offset + 14)
    if c6 != "":
        name = name + c6
    val c7 = fat32_decode_lfn_code_unit(entry_data, offset + 16)
    if c7 != "":
        name = name + c7
    val c8 = fat32_decode_lfn_code_unit(entry_data, offset + 18)
    if c8 != "":
        name = name + c8
    val c9 = fat32_decode_lfn_code_unit(entry_data, offset + 20)
    if c9 != "":
        name = name + c9
    val c10 = fat32_decode_lfn_code_unit(entry_data, offset + 22)
    if c10 != "":
        name = name + c10
    val c11 = fat32_decode_lfn_code_unit(entry_data, offset + 24)
    if c11 != "":
        name = name + c11
    val c12 = fat32_decode_lfn_code_unit(entry_data, offset + 28)
    if c12 != "":
        name = name + c12
    val c13 = fat32_decode_lfn_code_unit(entry_data, offset + 30)
    if c13 != "":
        name = name + c13
    name

# -- Driver state --------------------------------------------------------------

class Fat32Filesystem:
    """FAT32 filesystem over a block device (IF-07).

    Wave-4a: mount() parses BPB and stores geometry.
    Wave-4b: readdir("/") via stashed root-dir data; next_cluster + read_cluster_chain public for wave-4c.
    Wave-4c: open/read/stat for root-dir 8.3 names.
    """
    device_id: u64          # BlockDevice handle assigned by bus registration
    bpb_parsed: bool        # True once mount() has validated the BPB
    cluster_size: u32       # Bytes per cluster (512 * sectors-per-cluster)
    fat_start_sector: u32   # First sector of the FAT region
    data_start_sector: u32  # First sector of the cluster-heap region
    root_cluster: u32       # First cluster of root directory
    sectors_per_cluster: u32
    bytes_per_sector: u32
    data_clusters: u32      # Total data clusters (fuel bound for chain walk)
    root_dir_data: [u8]     # First cluster of root dir, stashed at mount

impl Fat32Filesystem:
    static fn new(device_id: u64) -> Fat32Filesystem:
        """Create a driver bound to the given block device."""
        Fat32Filesystem(
            device_id: device_id,
            bpb_parsed: false,
            cluster_size: 0u32,
            fat_start_sector: 0u32,
            data_start_sector: 0u32,
            root_cluster: 0u32,
            sectors_per_cluster: 0u32,
            bytes_per_sector: 512u32,
            data_clusters: 0u32,
            root_dir_data: []
        )

    fn mount(self, dev: BlockDevice) -> Result<(), i32>:
        """Read sector 0, validate BPB, populate geometry fields."""
        val read_result = dev.read_sector(0u64)
        if read_result.is_err():
            return Err(EIO)
        val buf = read_result.unwrap()

        val bpb_result = parse_bpb(buf)
        if bpb_result.is_err():
            return Err(bpb_result.unwrap_err())

        val bpb = bpb_result.unwrap()
        self.bpb_parsed          = true
        self.fat_start_sector    = bpb.reserved_sectors.to_u32()
        self.data_start_sector   = (bpb.reserved_sectors.to_u32() + bpb.num_fats.to_u32() * bpb.fat_size_32)
        self.cluster_size        = bpb.sectors_per_cluster.to_u32() * bpb.bytes_per_sector.to_u32()
        self.root_cluster        = bpb.root_cluster
        self.sectors_per_cluster = bpb.sectors_per_cluster.to_u32()
        self.bytes_per_sector    = bpb.bytes_per_sector.to_u32()
        # Fuel for cluster-chain walk: total data sectors / sectors-per-cluster.
        # A valid chain can never contain more clusters than this.
        if bpb.total_sectors_32 > self.data_start_sector and self.sectors_per_cluster > 0u32:
            self.data_clusters = (bpb.total_sectors_32 - self.data_start_sector) / self.sectors_per_cluster
        else:
            self.data_clusters = 0u32

        # Stash root dir cluster sectors for readdir (wave-4b shortcut)
        val root_lba = cluster_to_lba(bpb, bpb.root_cluster)
        var sec_idx: u32 = 0
        while sec_idx < bpb.sectors_per_cluster.to_u32():
            var sec_buf: [u8] = []
            var bi = 0
            while bi < 512:
                sec_buf.push(0u8)
                bi = bi + 1
            val r = dev.read_sector(root_lba + sec_idx.to_u64(), sec_buf)
            if r.is_err():
                return Err(EIO)
            var ci = 0
            while ci < 512:
                self.root_dir_data.push(sec_buf[ci])
                ci = ci + 1
            sec_idx = sec_idx + 1

        Ok(())

    fn unmount(self) -> i32:
        """Flush dirty FAT sectors and release the block device."""
        ENOSYS

    fn open(self, path: text) -> Result<FileHandle, i32>:
        """Open a root-dir 8.3 file by path (wave-4c, root-dir only).

        Accepts paths of the form "/NAME.EXT". Walks stashed root-dir
        entries to find the matching 8.3 name. Returns ENOENT(-2) if
        not found.
        """
        val entry_result = self._find_root_entry(path)
        if entry_result.is_err():
            return Err(entry_result.unwrap_err())
        val entry_opt = entry_result.unwrap()
        if not entry_opt.?:
            return Err(ENOENT)
        val off = entry_opt.unwrap()
        val cluster_high = (self.root_dir_data[off + 21].to_u32() << 8) | self.root_dir_data[off + 20].to_u32()
        val cluster_low  = (self.root_dir_data[off + 27].to_u32() << 8) | self.root_dir_data[off + 26].to_u32()
        val start = (cluster_high << 16) | cluster_low
        val fsize = ((self.root_dir_data[off + 31].to_u32() << 24) | (self.root_dir_data[off + 30].to_u32() << 16) |
                     (self.root_dir_data[off + 29].to_u32() << 8)  |  self.root_dir_data[off + 28].to_u32())
        Ok(FileHandle(
            fd: 0u64,
            start_cluster: start,
            current_cluster: start,
            offset: 0u64,
            file_size: fsize.to_u64(),
            is_open: true
        ))

    fn read(self, dev: BlockDevice, h: FileHandle, buf: [u8]) -> Result<u64, i32>:
        """Read up to buf.len() bytes from the file described by h (wave-4c).

        Walks the FAT32 cluster chain via read_cluster_chain(dev,
        h.start_cluster), then reads each cluster's sectors from dev,
        assembling file bytes in chain order.  Truncates at h.file_size
        so the caller never sees cluster padding past the real EOF.

        Updates h.offset. Returns the number of bytes actually copied into buf.
        Returns Ok(0) when already at EOF or buf is empty.
        Returns Err(EIO=-5) on any block-device or chain-walk failure.
        """
        val remaining = h.file_size - h.offset
        var to_read = buf.len().to_u64()
        if remaining < to_read:
            to_read = remaining
        if to_read == 0u64:
            return Ok(0u64)

        # Walk the full chain from the file's start cluster.
        val chain_result = self.read_cluster_chain(dev, h.start_cluster)
        if chain_result.is_err():
            return Err(EIO)
        val chain = chain_result.unwrap()
        if chain.len() == 0:
            return Ok(0u64)

        val cluster_bytes = self.cluster_size.to_u64()
        val spc = self.sectors_per_cluster.to_u64()
        val bps = self.bytes_per_sector.to_u64()

        # Determine which cluster in the chain h.offset falls into,
        # and the byte offset within that cluster.
        var cluster_idx: u64 = h.offset / cluster_bytes
        var byte_in_cluster: u64 = h.offset % cluster_bytes

        var copied: u64 = 0u64
        while copied < to_read and cluster_idx.to_i32() < chain.len():
            val cluster = chain[cluster_idx.to_i32()]
            # Compute the LBA of the first sector of this cluster.
            val first_sector = self.data_start_sector.to_u64() + (cluster - 2u32).to_u64() * spc
            # Within this cluster, start reading from byte_in_cluster.
            var sec_off: u64 = byte_in_cluster / bps
            var byte_in_sec: u64 = byte_in_cluster % bps
            while copied < to_read and sec_off < spc:
                val lba = first_sector + sec_off
                val sec_result = dev.read_sector(lba)
                if sec_result.is_err():
                    return Err(EIO)
                val sec = sec_result.unwrap()
                while copied < to_read and byte_in_sec < bps:
                    buf[copied.to_i32()] = sec[byte_in_sec.to_i32()]
                    copied = copied + 1u64
                    byte_in_sec = byte_in_sec + 1u64
                sec_off = sec_off + 1u64
                byte_in_sec = 0u64
            cluster_idx = cluster_idx + 1u64
            byte_in_cluster = 0u64

        h.offset = h.offset + copied
        Ok(copied)

    fn stat(self, path: text) -> Result<FileStat, i32>:
        """Return metadata for a root-dir 8.3 path (wave-4c).

        Returns ENOENT(-2) if not found.
        """
        val entry_result = self._find_root_entry(path)
        if entry_result.is_err():
            return Err(entry_result.unwrap_err())
        val entry_opt = entry_result.unwrap()
        if not entry_opt.?:
            return Err(ENOENT)
        val off = entry_opt.unwrap()
        val fsize = ((self.root_dir_data[off + 31].to_u32() << 24) | (self.root_dir_data[off + 30].to_u32() << 16) |
                     (self.root_dir_data[off + 29].to_u32() << 8)  |  self.root_dir_data[off + 28].to_u32())
        Ok(FileStat(
            size: fsize.to_u64(),
            is_dir: false,
            mtime: 0u64
        ))

    fn _find_root_entry(self, path: text) -> Result<i32?, i32>:
        """Walk stashed root_dir_data to find 8.3 entry matching path.

        Returns Ok(Some(byte_offset)) on match, Ok(None) if not found.
        Path must start with '/' followed by an 8.3 name.
        """
        # Strip leading '/'
        var name = path
        if name.len() > 0 and name[0].to_u8() == 0x2Fu8:
            name = name.slice(1, name.len())
        val upper = name.upper()
        val total_entries = self.root_dir_data.len() / 32
        var idx = 0
        var lfn_name = ""
        while idx < total_entries:
            val off = idx * 32
            val first_byte = self.root_dir_data[off]
            if first_byte == 0x00u8:
                return Ok(nil)   # end of directory
            if first_byte == 0xE5u8:
                lfn_name = ""           # orphan any pending LFN
                idx = idx + 1
                continue                # deleted entry
            val attr = self.root_dir_data[off + 11]
            if attr == 0x0Fu8:
                # Walk highest-seq → lowest-seq: prepend each fragment.
                val fragment = fat32_parse_lfn_slot(self.root_dir_data, off)
                lfn_name = fragment + lfn_name
                idx = idx + 1
                continue
            # 8.3 entry. Match accumulated LFN first (the long name),
            # then fall back to the 8.3 short name.
            if lfn_name.len() > 0 and lfn_name.upper() == upper:
                return Ok(off)
            # Build 8.3 name string
            var entry_name = ""
            var ni = 0
            while ni < 8:
                val ch = self.root_dir_data[off + ni]
                if ch != 0x20u8 and ch != 0x00u8:
                    entry_name = entry_name + ch.chr()
                ni = ni + 1
            var ext = ""
            var ei = 0
            while ei < 3:
                val ch = self.root_dir_data[off + 8 + ei]
                if ch != 0x20u8 and ch != 0x00u8:
                    ext = ext + ch.chr()
                ei = ei + 1
            if ext.len() > 0:
                entry_name = entry_name + "." + ext
            if entry_name.upper() == upper:
                return Ok(off)
            lfn_name = ""
            idx = idx + 1
        Ok(nil)

    fn _read_fat_entry(self, dev: BlockDevice, cluster: u32) -> Result<u32, text>:
        """Read the 28-bit FAT32 entry for cluster from the FAT region on dev."""
        val fat_offset = cluster * 4u32
        val fat_sector = self.fat_start_sector.to_u64() + (fat_offset / self.bytes_per_sector).to_u64()
        val entry_off  = (fat_offset % self.bytes_per_sector).to_i32()
        val sec_result = dev.read_sector(fat_sector)
        if sec_result.is_err():
            return Err("fat32: failed to read FAT sector for cluster {cluster}")
        val sec = sec_result.unwrap()
        val raw = ((sec[entry_off + 3].to_u32() << 24) |
                   (sec[entry_off + 2].to_u32() << 16) |
                   (sec[entry_off + 1].to_u32() << 8)  |
                    sec[entry_off].to_u32()) & 0x0FFFFFFFu32
        Ok(raw)

    fn read_cluster_chain(self, dev: BlockDevice, start: u32) -> Result<[u32], text>:
        """Walk FAT chain from start cluster; return ordered cluster list.

        Collects data cluster numbers until EOC (FAT entry >= 0x0FFFFFF8).
        Returns Err on:
          - start cluster < 2 (invalid)
          - FREE (0x00000000) or BAD (0x0FFFFFF7) FAT entry mid-chain
          - fuel exhaustion (> data_clusters steps) — cycle/corruption guard

        Mirrors chainWalkGuarded in src/verification/fat32/Fat32/Basic.lean.
        Fuel = self.data_clusters; a valid chain cannot exceed this count.
        """
        if start < 2u32:
            return Err("fat32: invalid start cluster {start}")
        var chain: [u32] = []
        var current = start
        var fuel = self.data_clusters
        while current >= 2u32:
            # Cycle / length guard — checked before consuming the current cluster
            if fuel == 0u32:
                return Err("fat32: cluster chain exceeds volume cluster count (cycle?)")
            fuel = fuel - 1u32
            # Append current data cluster
            chain.push(current)
            # Read FAT entry for current cluster to find next
            val next_result = self._read_fat_entry(dev, current)
            if next_result.is_err():
                return next_result
            val next = next_result.unwrap()
            # EOC: >= 0x0FFFFFF8 — current was the last data cluster
            if next >= 0x0FFFFFF8u32:
                return Ok(chain)
            # BAD cluster marker mid-chain — corruption
            if next == 0x0FFFFFF7u32:
                return Err("fat32: bad-cluster marker in chain from {start}")
            # FREE cluster mid-chain — corruption
            if next == 0x00000000u32:
                return Err("fat32: free-cluster entry mid-chain from {start}")
            # Valid next cluster; continue walk
            current = next
        Ok(chain)

    fn write(self, fd: u64, offset: u64, length: u64) -> i64:
        """Write — wave-4d."""
        val _fd = fd
        val _o = offset
        val _l = length
        ENOSYS.to_i64()

    fn close(self, fd: u64) -> i32:
        """Close — wave-4d."""
        val _fd = fd
        ENOSYS

    static fn make_for_chain_test(fat_start_sector: u32, bytes_per_sector: u32, data_clusters: u32) -> Fat32Filesystem:
        """Create a pre-configured Fat32Filesystem for read_cluster_chain unit tests.

        Sets geometry fields directly; caller supplies a mock BlockDevice to
        read_cluster_chain.  Not for production use.
        """
        Fat32Filesystem(
            device_id:           0u64,
            bpb_parsed:          true,
            cluster_size:        bytes_per_sector,
            fat_start_sector:    fat_start_sector,
            data_start_sector:   fat_start_sector + 8u32,
            root_cluster:        2u32,
            sectors_per_cluster: 1u32,
            bytes_per_sector:    bytes_per_sector,
            data_clusters:       data_clusters,
            root_dir_data:       []
        )

    static fn make_for_read_test(fat_start_sector: u32, data_start_sector: u32, bytes_per_sector: u32, sectors_per_cluster: u32, data_clusters: u32) -> Fat32Filesystem:
        """Create a pre-configured Fat32Filesystem for read() unit tests.

        Allows explicit data_start_sector and sectors_per_cluster so callers
        can place data sectors at known LBAs.  Caller supplies a mock
        BlockDevice to read().  Not for production use.
        """
        Fat32Filesystem(
            device_id:           0u64,
            bpb_parsed:          true,
            cluster_size:        bytes_per_sector * sectors_per_cluster,
            fat_start_sector:    fat_start_sector,
            data_start_sector:   data_start_sector,
            root_cluster:        2u32,
            sectors_per_cluster: sectors_per_cluster,
            bytes_per_sector:    bytes_per_sector,
            data_clusters:       data_clusters,
            root_dir_data:       []
        )
