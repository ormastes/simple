# FAT32 kernel filesystem driver — IF-07 wave-3 scaffold.
#
# Implements Filesystem over a BlockDevice. This is a scaffold: mount /
# open / read / write return not-implemented errors. Wave-4 fills in:
#   - BPB parsing from sector 0 (validate 0xAA55 signature)
#   - FAT cluster-chain walking for sequential read/write
#   - Short-name 8.3 + LFN directory entry decoding
#   - Write-back of dirty FAT sectors via BlockDevice.write_sector

# -- Public types -----------------------------------------------------------

struct FileHandle:
    """Open-file token returned by Fat32Filesystem.open()."""
    fd: u64                 # Opaque descriptor; wave-4 uses it as a table key

struct FileStat:
    """Minimal file metadata returned by Fat32Filesystem.stat()."""
    size: u64
    is_dir: bool
    mtime: u64              # POSIX seconds since epoch

# -- Driver state -----------------------------------------------------------

class Fat32Filesystem:
    """FAT32 filesystem over a block device (IF-07).

    Wave-3 scaffold: all ops return 'not implemented' errors. The type
    names and method shapes match the IF-07 contract so userspace and
    higher kernel layers can be linked now against stable signatures.
    """
    device_id: u64          # BlockDevice handle assigned by bus registration
    bpb_parsed: bool        # True once mount() has validated the BPB
    cluster_size: u32       # Bytes per cluster (512 * sectors-per-cluster)
    fat_start_sector: u32   # First sector of the FAT region
    data_start_sector: u32  # First sector of the cluster-heap region

impl Fat32Filesystem:
    static fn new(device_id: u64) -> Fat32Filesystem:
        """Create a driver bound to the given block device."""
        Fat32Filesystem(
            device_id: device_id,
            bpb_parsed: false,
            cluster_size: 0u32,
            fat_start_sector: 0u32,
            data_start_sector: 0u32
        )

    fn mount(self) -> i32:
        """Read sector 0, validate BPB, populate geometry fields.

        Returns 0 on success or a negative errno on failure.
        Wave-3 scaffold: returns -38 (ENOSYS).
        """
        -38

    fn unmount(self) -> i32:
        """Flush dirty FAT sectors and release the block device.

        Wave-3 scaffold: returns -38.
        """
        -38

    fn open(self, path: Text, flags: i32) -> i32:
        """Open a file by path; populates FileHandle into an out-param.

        Returns fd on success (>=0) or negative errno.
        Wave-3 scaffold: returns -38.
        """
        val _p = path
        val _f = flags
        -38

    fn read(self, fd: u64, offset: u64, length: u64) -> i64:
        """Read up to `length` bytes at `offset` into a driver buffer.

        Returns bytes read on success or negative errno.
        Wave-3 scaffold: returns -38.
        """
        val _fd = fd
        val _o = offset
        val _l = length
        -38

    fn write(self, fd: u64, offset: u64, length: u64) -> i64:
        """Write up to `length` bytes at `offset` from a driver buffer.

        Returns bytes written on success or negative errno.
        Wave-3 scaffold: returns -38.
        """
        val _fd = fd
        val _o = offset
        val _l = length
        -38

    fn close(self, fd: u64) -> i32:
        """Release an open file descriptor.

        Wave-3 scaffold: returns -38.
        """
        val _fd = fd
        -38

    fn stat(self, path: Text) -> i32:
        """Fetch metadata for a path.

        Returns 0 on success; fills an out-param FileStat in wave-4.
        Wave-3 scaffold: returns -38.
        """
        val _p = path
        -38
