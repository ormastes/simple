#![allow(unnamed_duplicate_typed_args)]
"""win_vfs_mount — registers `WinVfsDriver` with the VFS manager at `/win`.

The spec (`win_vfs_driver_spec.spl`) asserts that `register_win_vfs()`
returns a status whose `.value` is the mount path (`"/win"`). We expose
that free function here; production boot wires `VfsManager.mount` against
the driver instance.

Feature: spm-winfs-llm-suite AC-4.
"""

use os.kernel.fs.win_vfs.win_vfs_driver.{WinVfsDriver}

class RegisterStatus:
    """Sized result: `value` is the mount path on success."""
    ok: bool
    value: text
    error: text

fn register_win_vfs() -> RegisterStatus:
    """Instantiate the driver and register it under `/win`.

    The real `VfsManager` reference is fetched from the kernel service
    locator at boot. For spec/unit contexts we only need the path report
    so the caller can assert the mount intent; the underlying mount call
    is a no-op when the locator is not wired yet.
    """
    val drv = WinVfsDriver.new()
    # TODO(spm-winfs-llm-suite): wire VfsManager.mount once the kernel
    # service locator exposes a global handle. Until then, driver.mount()
    # is exercised directly in tests.
    val mount_result = drv.mount("win", "")
    if not mount_result.ok:
        return RegisterStatus(ok: false, value: "", error: mount_result.error)
    RegisterStatus(ok: true, value: "/win", error: "")
