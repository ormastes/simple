# VmSpace Types — L4-style address space objects
#
# All fields use primitive types for baremetal ABI safety.
# Page flags use bitfield pattern from bitfield.spl.

use os.kernel.types.bitfield.{bits_get, bits_set, bit_get, bit_set, bit_clear}

# ============================================================================
# VMA Kind constants
# ============================================================================

val VMA_ANON: u32   = 0    # Anonymous (zero-filled) mapping
val VMA_FILE: u32   = 1    # File-backed mapping
val VMA_SHARED: u32 = 2    # Shared mapping (no COW on fork)

# VMA permission + attribute flags (OR-able)
val VMA_READ:  u32 = 1     # Pages are readable
val VMA_WRITE: u32 = 2     # Pages are writable
val VMA_EXEC:  u32 = 4     # Pages are executable
val VMA_COW:   u32 = 8     # Copy-on-write (fork child pages)

# ============================================================================
# Virtual Memory Area
# ============================================================================

struct VmArea:
    """One contiguous virtual address range with uniform protection and kind.

    `backing` is a file-handle integer for VMA_FILE mappings, or 0 for anon.
    `backing_offset` is the byte offset into the file for the area's start.
    """
    start:          u64    # First virtual byte of the area (page-aligned)
    len:            u64    # Length in bytes (page-aligned)
    kind:           u32    # VMA_ANON / VMA_FILE / VMA_SHARED
    flags:          u32    # Bitfield of VMA_READ | VMA_WRITE | VMA_EXEC | VMA_COW
    backing:        u64    # File handle (VMA_FILE) or 0
    backing_offset: u64    # Offset into file

# ============================================================================
# Process-level virtual address space (extends VmSpace with VMA list)
# ============================================================================

val MAX_VMAS: u64 = 256    # Maximum VMAs per address space

struct ProcessVmSpace:
    """Per-process virtual address space with VMA tracking.

    `pml4` is the physical address of the x86_64 PML4 (== CR3 value).
    `vma_count` tracks how many entries in `areas` are live.
    `areas` is a fixed-capacity array; index [0..vma_count) are valid.
    """
    pml4:      u64                    # Page-table root (physical, for CR3)
    id:        u64                    # Monotonic address-space id
    vma_count: u64                    # Number of live VMAs
    areas:     [VmArea]               # Live VMAs (unsorted)

# Page flag bits (OR-able via bitfield ops)
val PAGE_READ: u64 = 1
val PAGE_WRITE: u64 = 2
val PAGE_EXECUTE: u64 = 4
val PAGE_USER: u64 = 8
val PAGE_DEVICE: u64 = 16
val PAGE_DMA_COHERENT: u64 = 32

fn page_flags_rwx() -> u64:
    """Read + Write + Execute (kernel text)."""
    PAGE_READ | PAGE_WRITE | PAGE_EXECUTE

fn page_flags_rw_user() -> u64:
    """Read + Write + User (user data)."""
    PAGE_READ | PAGE_WRITE | PAGE_USER

fn page_flags_rx_user() -> u64:
    """Read + Execute + User (user code)."""
    PAGE_READ | PAGE_EXECUTE | PAGE_USER

fn page_flags_device() -> u64:
    """Device MMIO (uncacheable, kernel-only)."""
    PAGE_READ | PAGE_WRITE | PAGE_DEVICE

struct VmSpace:
    id: u64
    # Architecture-specific page table root physical address
    page_table_root: u64
    ref_count: u32
    asid: u16

struct PageMapping:
    virt_addr: u64
    phys_addr: u64
    size: u64
    flags: u64      # bitfield of PAGE_* constants

struct MapRegion:
    virt_start: u64
    phys_start: u64
    size: u64
    flags: u64

struct VmSpaceCreateParams:
    clone_kernel_mappings: bool
