# VmSpace Types — L4-style address space objects
#
# A VmSpace represents an address space (page table root + mappings).
# Multiple threads can share a VmSpace (lightweight threading).
# VmSpaces are separate from Tasks — the kernel creates/maps/destroys them
# via capability-checked syscalls.

use os.kernel.types.memory_types.{PhysAddr, VirtAddr}

struct VmSpaceId:
    id: u64

# Page mapping flags
enum PageFlags:
    Read
    Write
    Execute
    User
    Device       # uncacheable, for MMIO regions
    DmaCoherent  # cache-coherent DMA mapping

# A single page mapping within a VmSpace
struct PageMapping:
    virt: VirtAddr
    phys: PhysAddr
    size: u64         # page size (4K, 2M, 1G)
    flags: [PageFlags]

# VmSpace — an address space
struct VmSpace:
    id: VmSpaceId
    # Architecture-specific page table root (PML4 phys addr on x86_64, satp on RISC-V)
    page_table_root: PhysAddr
    # Reference count — how many threads use this space
    ref_count: u32
    # ASID for TLB tagging (architecture-specific)
    asid: u16

# VmSpace creation parameters
struct VmSpaceCreateParams:
    # Whether to clone the kernel half of the current address space
    clone_kernel_mappings: bool

# Region descriptor for mapping requests
struct MapRegion:
    virt_start: VirtAddr
    phys_start: PhysAddr
    size: u64
    flags: [PageFlags]
