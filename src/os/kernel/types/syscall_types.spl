# Syscall Types — Entity Dimension
#
# System call interface types.

enum SyscallId:
    """System call identifiers."""
    # Process
    Exit = 0
    Yield = 1
    Spawn = 2
    Wait = 3
    GetPid = 4

    # Memory
    Mmap = 10
    Munmap = 11
    Mprotect = 12

    # IPC
    IpcSend = 20
    IpcRecv = 21
    IpcCreatePort = 22
    IpcConnect = 23

    # File (routed to VFS service via IPC)
    Open = 30
    Read = 31
    Write = 32
    Close = 33
    Stat = 34
    Mkdir = 35
    Readdir = 36

    # Security
    Pledge = 40
    Unveil = 41
    CapGrant = 42

    # Time
    ClockGetTime = 50
    Sleep = 51

    # Debug
    DebugWrite = 60     # Serial output

@repr("C")
struct SyscallArgs:
    """Arguments passed via registers on syscall entry."""
    id: u64         # rax: syscall number
    arg0: u64       # rdi
    arg1: u64       # rsi
    arg2: u64       # rdx
    arg3: u64       # r10
    arg4: u64       # r8
    arg5: u64       # r9

@repr("C")
struct SyscallResult:
    """Return value in rax after syscall."""
    value: i64      # >= 0 success, < 0 error code
