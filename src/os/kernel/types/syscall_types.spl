# Syscall Types — Entity Dimension
#
# System call interface types.

enum SyscallId:
    """System call identifiers."""
    # Process
    Exit = 0
    Yield = 1
    Spawn = 2
    Wait = 3
    GetPid = 4

    # Memory
    Mmap = 10
    Munmap = 11
    Mprotect = 12
    SpawnBinary = 13

    # IPC
    IpcSend = 20
    IpcRecv = 21
    IpcCreatePort = 22
    IpcConnect = 23

    # Notification (L4-style async events)
    NotificationCreate = 24
    NotificationSignal = 25
    NotificationWait = 26
    NotificationPoll = 27
    NotificationDestroy = 28

    # File (routed to VFS service via IPC)
    Open = 30
    Read = 31
    Write = 32
    Close = 33
    Stat = 34
    Mkdir = 35
    Readdir = 36

    # Security
    Pledge = 40
    Unveil = 41
    CapGrant = 42

    # Process (extended)
    ListTasks = 5       # List all tasks → [TaskInfoBuf]
    GetTaskInfo = 6     # Single task info by PID
    Signal = 7          # Send signal to task
    SetPriority = 8     # Change task priority
    GetParentPid = 9    # Get parent task ID

    # Memory
    Mmap = 10
    Munmap = 11
    Mprotect = 12

    # IPC
    IpcSend = 20
    IpcRecv = 21
    IpcCreatePort = 22
    IpcConnect = 23

    # File (routed to VFS service via IPC)
    Open = 30
    Read = 31
    Write = 32
    Close = 33
    Stat = 34
    Mkdir = 35
    Readdir = 36
    Mount = 37          # Mount filesystem
    Unmount = 38        # Unmount filesystem
    Unlink = 39         # Remove file
    Rename = 44         # Rename file or directory
    Rmdir = 45          # Remove directory
    Lseek = 46          # Reposition file offset
    Getcwd = 47         # Get current working directory
    Chdir = 48          # Change working directory
    Ftruncate = 43      # Truncate open file descriptor to length

    # Notification (L4-style async events)
    NotificationCreate = 24
    NotificationSignal = 25
    NotificationWait = 26
    NotificationPoll = 27
    NotificationDestroy = 28

    # Security
    Pledge = 40
    Unveil = 41
    CapGrant = 42

    # Time
    ClockGetTime = 50
    Sleep = 51

    # Debug
    DebugWrite = 60     # Serial output
    Pipe = 62           # pipe(int fd[2])
    Dup2 = 63           # dup2(oldfd, newfd)
    Dup = 64            # dup(oldfd)
    Poll = 68           # poll(struct pollfd*, nfds, timeout_ms)
    Fcntl = 69          # descriptor/status flag control

    # Network
    NetSocket = 70
    NetBind = 71
    NetListen = 72
    NetConnect = 73
    NetAccept = 74
    NetSendTo = 75
    NetRecvFrom = 76
    NetIfConfig = 77    # Interface config get/set

    # Device
    DevEnumerate = 80   # List PCI/USB devices
    DevGetInfo = 81     # Single device info
    DeviceGrant = 82    # Grant device resources to a driver capsule

    # Logging
    LogWrite = 90       # Write structured log entry
    LogRead = 91        # Read log entries (journal)

    # System info
    SysInfo = 95        # Query system info (mem/cpu/uptime)
    GetHostname = 96
    SetHostname = 97

    # Privilege + SPM (spm-winfs-llm-suite — AC-3 / AC-4)
    SysPrivCheck = 110          # Hierarchical privilege check via privilege_bridge
    SysWinRegister = 111        # Register a WindowRecord with SPM
    SysApprovalRequest = 112    # Brokered approval prompt
    SysSpmSend = 113            # Generic SPM RPC: send
    SysSpmListen = 114          # Generic SPM RPC: listen / accept

    # SOSIX immutable process sharing
    DatasetCreate = 120
    DatasetCreateFromFile = 121
    DatasetWrite = 122
    DatasetSeal = 123
    DatasetMap = 124
    DatasetUnmap = 125
    DatasetClose = 126
    QueueCreate = 127
    QueueSend = 128
    QueueRecv = 129
    QueuePoll = 130
    QueueClose = 131

# ============================================================================
# Signal Types
# ============================================================================

enum SignalKind:
    """Signal types for inter-process signaling."""
    Term = 0        # Terminate (default, catchable)
    Kill = 1        # Force kill (uncatchable)
    Stop = 2        # Suspend task
    Cont = 3        # Resume suspended task
    Int = 4         # Interrupt (Ctrl+C)
    Hup = 5         # Hangup

# ============================================================================
# System Info Types
# ============================================================================

enum SysInfoKind:
    """Types of system information queries."""
    Memory = 0      # Returns total/free/used pages
    CpuCount = 1
    Uptime = 2      # Nanoseconds since boot
    TickCount = 3

# ============================================================================
# Userspace-Visible Structs
# ============================================================================

@repr("C")
struct TaskInfoBuf:
    """Task info returned by ListTasks/GetTaskInfo syscalls."""
    pid: u64
    parent_pid: u64
    state: u8           # 0=Ready, 1=Running, 2=Blocked, 3=Zombie
    priority: u8         # 0=RT, 1=High, 2=Normal, 3=Low, 4=Idle
    memory_pages: u64
    cpu_ticks: u64
    name_len: u32
    name: [u8]           # Variable-length name bytes

fn new_task_info_buf() -> TaskInfoBuf:
    """Factory for cross-module construction."""
    TaskInfoBuf(pid: 0, parent_pid: 0, state: 0, priority: 0, memory_pages: 0, cpu_ticks: 0, name_len: 0, name: [])

@repr("C")
struct DeviceInfoBuf:
    """PCI device info returned by DevEnumerate/DevGetInfo."""
    bus: u8
    device: u8
    func: u8
    vendor_id: u16
    device_id: u16
    class_code: u8
    subclass: u8
    prog_if: u8
    irq_line: u8

fn new_device_info_buf() -> DeviceInfoBuf:
    """Factory for cross-module construction (struct constructors are not callable cross-module)."""
    DeviceInfoBuf(bus: 0, device: 0, func: 0, vendor_id: 0, device_id: 0, class_code: 0, subclass: 0, prog_if: 0, irq_line: 0)

@repr("C")
struct NetIfInfo:
    """Network interface info returned by NetIfConfig."""
    index: u32
    name: text
    mac: [u8]
    ipv4_addr: u32
    ipv4_mask: u32
    ipv4_gateway: u32
    flags: u32          # UP, BROADCAST, LOOPBACK, etc.
    mtu: u32

fn new_net_if_info() -> NetIfInfo:
    """Factory for cross-module construction."""
    NetIfInfo(index: 0, name: "", mac: [], ipv4_addr: 0, ipv4_mask: 0, ipv4_gateway: 0, flags: 0, mtu: 0)

@repr("C")
struct KLogEntry:
    """Kernel log entry for the journal."""
    timestamp_ns: u64
    level: u8           # 0=Emergency..7=Debug
    facility: u16
    pid: u64
    message: text

@repr("C")
struct MemInfoBuf:
    """Memory info returned by SysInfo(Memory)."""
    total_pages: u64
    free_pages: u64
    used_pages: u64
    page_size: u32

fn new_mem_info_buf() -> MemInfoBuf:
    """Factory for cross-module construction."""
    MemInfoBuf(total_pages: 0, free_pages: 0, used_pages: 0, page_size: 0)

@repr("C")
struct SyscallArgs:
    """Arguments passed via registers on syscall entry."""
    id: u64         # syscall number
    arg0: u64
    arg1: u64
    arg2: u64
    arg3: u64
    arg4: u64
    arg5: u64

@repr("C")
struct SyscallResult:
    """Return value in rax after syscall."""
    value: i64      # >= 0 success, < 0 error code

enum SyscallTrapDisposition:
    """How the architecture trap path should leave syscall dispatch."""
    ReturnToCaller = 0
    BlockCurrent = 1
    ScheduleNext = 2
    NoReturn = 3

@repr("C")
struct SyscallDispatchResult:
    """Syscall result plus trap-control disposition for architecture entry."""
    result: SyscallResult
    disposition: SyscallTrapDisposition

fn syscall_dispatch_return(value: i64) -> SyscallDispatchResult:
    SyscallDispatchResult(
        result: SyscallResult(value: value),
        disposition: SyscallTrapDisposition.ReturnToCaller
    )

fn syscall_dispatch_with(value: i64, disposition: SyscallTrapDisposition) -> SyscallDispatchResult:
    SyscallDispatchResult(
        result: SyscallResult(value: value),
        disposition: disposition
    )
