# Notification Types — L4-style lightweight async event signaling
#
# A Notification is a single-word bitmask that threads can signal and wait on.
# Unlike endpoints (which transfer messages), notifications just set bits.
# A thread can wait on a notification OR an endpoint (via WaitSet).
#
# Use cases:
# - IRQ delivery to user-space drivers
# - Timer events
# - Inter-thread signaling without full IPC overhead
# - Event multiplexing with wait_any()

struct NotificationId:
    id: u64

# Notification object — kernel-managed bitmask
struct Notification:
    id: NotificationId
    # 64-bit word: each bit represents a distinct event
    bits: u64
    # Thread waiting on this notification (nil if none)
    waiter: u64?

# Signal operation: OR new bits into the notification word
# If a thread is waiting, wake it with the accumulated bits
fn notification_signal_bits(bits: u64) -> u64:
    """Bits to OR into the notification word."""
    bits

# Common notification bit assignments for device drivers
val NOTIFY_IRQ: u64 = 1          # bit 0: hardware interrupt
val NOTIFY_TIMER: u64 = 2        # bit 1: timer expiry
val NOTIFY_IPC_READY: u64 = 4    # bit 2: IPC endpoint has message
val NOTIFY_DMA_COMPLETE: u64 = 8 # bit 3: DMA transfer done
val NOTIFY_SHUTDOWN: u64 = 16    # bit 4: shutdown request
