# Device Memory Types — Exokernel-style device resource grants
#
# The kernel exposes raw device resources to user-space drivers via
# capability-protected grants. A DeviceGrant bundles everything a
# driver needs: BAR mappings, IRQ object, DMA window, optional IOMMU domain.
#
# Design principle: kernel provides PROTECTION, drivers provide MANAGEMENT.
# The kernel never implements "disk", "network", or "GPU" policy.

use os.kernel.types.capability_types.{CapabilityToken}

# PCI Bus/Device/Function identifier
struct PciBdf:
    bus: u8
    device: u8
    function: u8

# PCI BAR (Base Address Register) mapping
struct PciBar:
    index: u8        # BAR number (0-5)
    phys_addr: u64   # physical address
    size: u64        # region size in bytes
    is_mmio: bool    # true = MMIO, false = I/O port
    is_prefetchable: bool
    # Capability token granting access to this BAR
    cap: CapabilityToken

# IRQ object — kernel-managed interrupt routing
struct IrqObject:
    # IRQ number (legacy) or MSI/MSI-X vector
    vector: u32
    # Notification to signal when IRQ fires
    notification_id: u64
    # Notification bit to set
    notification_bit: u64
    # Capability token
    cap: CapabilityToken

# DMA window — pinned physical memory for device DMA
struct DmaWindow:
    # Physical address visible to the device
    device_addr: u64
    # Physical address in host memory
    host_addr: u64
    # Size in bytes
    size: u64
    # Direction
    direction: DmaDirection
    # Capability token
    cap: CapabilityToken

enum DmaDirection:
    ToDevice
    FromDevice
    Bidirectional

# IOMMU domain — device isolation boundary
struct IommuDomain:
    domain_id: u32
    # Capability token for managing this domain
    cap: CapabilityToken

# PCI Function — complete device identity
struct PciFunction:
    bdf: PciBdf
    vendor_id: u16
    device_id: u16
    class_code: u8
    subclass: u8
    prog_if: u8
    revision: u8

# Device Grant — everything a user-space driver needs
#
# Pattern:
#   fn driver_main(grant: DeviceGrant):
#       val regs = mmio_map(grant.bars[0])
#       while true:
#           match wait_any([grant.irq, control_port]):
#               Event.Irq(_): handle_irq(regs)
#               Event.Msg(msg): handle_control(msg)
struct DeviceGrant:
    # PCI identity
    pci: PciFunction
    # BAR mappings (up to 6)
    bars: [PciBar]
    # IRQ object (legacy or MSI-X vector 0)
    irq: IrqObject
    # DMA window for bulk transfers
    dma_window: DmaWindow?
    # IOMMU domain for device isolation
    iommu_domain: IommuDomain?
    # Additional MSI-X vectors (beyond the primary IRQ)
    msix_vectors: [IrqObject]
