# Memory Types — Entity Dimension
#
# Physical and virtual memory types used by boot, memory, and scheduler layers.

@repr("C")
struct PhysAddr:
    """Physical memory address."""
    addr: u64

@repr("C")
struct VirtAddr:
    """Virtual memory address."""
    addr: u64

@repr("C")
struct PageFrame:
    """Physical page frame number (4KB aligned)."""
    pfn: u64

impl PageFrame:
    fn to_phys_addr() -> PhysAddr:
        PhysAddr(addr: self.pfn * 4096)

    static fn from_phys_addr(pa: PhysAddr) -> PageFrame:
        PageFrame(pfn: pa.addr / 4096)

@repr("C")
struct VmMap:
    """Virtual memory mapping entry."""
    virt: VirtAddr
    phys: PhysAddr
    size: u64
    flags: VmFlags

@repr("C")
struct VmFlags:
    """Page table entry flags."""
    present: bool
    writable: bool
    user: bool
    write_through: bool
    cache_disable: bool
    no_execute: bool

impl VmFlags:
    static fn kernel_rw() -> VmFlags:
        VmFlags(present: true, writable: true, user: false,
                write_through: false, cache_disable: false, no_execute: false)

    static fn kernel_ro() -> VmFlags:
        VmFlags(present: true, writable: false, user: false,
                write_through: false, cache_disable: false, no_execute: false)

    static fn kernel_rx() -> VmFlags:
        VmFlags(present: true, writable: false, user: false,
                write_through: false, cache_disable: false, no_execute: false)

    static fn user_rw() -> VmFlags:
        VmFlags(present: true, writable: true, user: true,
                write_through: false, cache_disable: false, no_execute: true)

    static fn user_rx() -> VmFlags:
        VmFlags(present: true, writable: false, user: true,
                write_through: false, cache_disable: false, no_execute: false)

    static fn mmio() -> VmFlags:
        VmFlags(present: true, writable: true, user: false,
                write_through: true, cache_disable: true, no_execute: true)
