# Thread Types — L4-style execution context separate from address space
#
# Thread is an execution context within a VmSpace. Multiple threads can
# share the same VmSpace. Thread owns: saved registers, kernel stack,
# scheduling state. Does NOT own: page tables, capabilities, file descriptors.
#
# All fields use primitive types (u64, u32, u8, bool) for baremetal ABI safety.

# Thread states (matching existing TaskState enum values)
val THREAD_STATE_READY: u8 = 0
val THREAD_STATE_RUNNING: u8 = 1
val THREAD_STATE_BLOCKED: u8 = 2
val THREAD_STATE_ZOMBIE: u8 = 3

# Block reasons
val BLOCK_ENDPOINT_RECV: u8 = 0
val BLOCK_ENDPOINT_SEND: u8 = 1
val BLOCK_NOTIFICATION: u8 = 2
val BLOCK_SLEEP: u8 = 3
val BLOCK_PAGE_FAULT: u8 = 4

# Priority levels (matching existing TaskPriority)
val PRIORITY_REALTIME: u8 = 0
val PRIORITY_HIGH: u8 = 1
val PRIORITY_NORMAL: u8 = 2
val PRIORITY_LOW: u8 = 3
val PRIORITY_IDLE: u8 = 4

# Thread Control Block — all primitive fields
struct Thread:
    id: u64
    vmspace_id: u64
    state: u8
    priority: u8
    time_slice_remaining: u64
    # Saved CPU context
    pc: u64
    sp: u64
    flags: u64
    # General-purpose registers stored in a separate array
    # (architecture manages the actual save/restore)
    context_ptr: u64
    # Stacks
    kernel_stack_base: u64
    kernel_stack_size: u64
    # Blocking
    block_reason: u8
    block_target_id: u64
    # Fault handler endpoint (0 = none)
    fault_handler_endpoint: u64

struct ThreadCreateParams:
    vmspace_id: u64
    entry_point: u64
    stack_pointer: u64
    priority: u8
    fault_handler_endpoint: u64
