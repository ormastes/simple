# http route classification — pure, socket-free, VFS-free routing decision.
#
# Reuses the REAL Simple web server pipeline
# (std.nogc_sync_mut.http_server): parse_request_line (parser.spl) parses the
# request line and path_is_safe (router.spl) is the traversal check. This
# module adds ONLY the three-route decision the boot server needs (GET /,
# GET /health, and GET /files/<name>); it does not reimplement request-line parsing or the
# path-traversal check.
#
# It is pure (no rt_net_* externs, no VFS): the transport
# (src/os/kernel/boot/http_baremetal.spl, src/os/kernel/net/http_baremetal.spl)
# supplies the socket and does the VFS read for the File case, and specs drive
# http_classify_request() directly. That keeps route/hardening behavior
# verifiable with `simple run <spec>` without a network or a mounted disk.

use std.nogc_sync_mut.http_server.parser.{parse_request_line}
use std.nogc_sync_mut.http_server.router.{path_is_safe}

enum HttpRouteKind:
    Status        # GET /             -> root HTML
    Health        # GET /health       -> status JSON
    File          # GET /files/<name> -> serve a file from the mounted root
    BadRequest    # malformed request line -> 400
    NotFound      # unknown route / unsafe path / missing file -> 404

struct HttpRoute:
    kind: HttpRouteKind
    file_path: text   # only meaningful when kind == File

fn _name_has_control_byte(name: text) -> bool:
    """True if `name` carries any ASCII control byte (< 0x20, or DEL 0x7F).

    path_is_safe() already rejects NUL; this closes the rest of the control
    range so a raw CR/LF (or other control byte) injected into a /files
    segment fails closed here instead of riding through as a "safe" filename
    and becoming a response-header-injection vector downstream. Indexes a
    `.bytes()` array (reliable) rather than per-char text predicates."""
    val bs = name.bytes()
    var i = 0
    while i < bs.len():
        val b = bs[i]
        if b < 32 or b == 127:
            return true
        i = i + 1
    false

pub fn http_classify_request(request: text) -> HttpRoute:
    """Classify a raw HTTP request into a route decision.

    Fails closed: any malformed/oversized-without-terminator request line
    (missing method/path, non-HTTP/1.x version, non-absolute path) yields
    BadRequest; anything not GET /, GET /health, or
    GET /files/<safe-single-segment> yields
    NotFound.
    """
    val line_end = request.find("\r\n")
    val line = if line_end >= 0: request.slice(0, line_end) else: request
    val parsed = parse_request_line(line)
    val method = parsed.0
    val path = parsed.1
    val version = parsed.2
    if not version.starts_with("HTTP/1.") or path.len() == 0 or not path.starts_with("/"):
        return HttpRoute(kind: HttpRouteKind.BadRequest, file_path: "")
    if method != "GET":
        return HttpRoute(kind: HttpRouteKind.NotFound, file_path: "")
    if path == "/health":
        return HttpRoute(kind: HttpRouteKind.Health, file_path: "")
    if path == "/":
        return HttpRoute(kind: HttpRouteKind.Status, file_path: "")
    if path.starts_with("/files/"):
        val name = path.slice(7, path.len())
        if name.len() == 0 or name.len() > 200:
            return HttpRoute(kind: HttpRouteKind.NotFound, file_path: "")
        # Single flat segment only, and reuse the real web server's traversal
        # check so "..%2f", encoded dot-dot, "//", NUL, etc. all fail closed.
        if name.find("/") >= 0:
            return HttpRoute(kind: HttpRouteKind.NotFound, file_path: "")
        if _name_has_control_byte(name):
            return HttpRoute(kind: HttpRouteKind.NotFound, file_path: "")
        if not path_is_safe(path):
            return HttpRoute(kind: HttpRouteKind.NotFound, file_path: "")
        return HttpRoute(kind: HttpRouteKind.File, file_path: "/" + name)
    HttpRoute(kind: HttpRouteKind.NotFound, file_path: "")
