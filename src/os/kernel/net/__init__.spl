# Kernel Network Shim Module
#
# MDSOC: feature dimension, network layer
# Bridges std.io.tcp extern functions (rt_io_tcp_*) to the SimpleOS
# netstack service. Provides fd tracking and address parsing.
#
# Modules:
#   tcp_shim_state  - Module-level fd table and address parsing
#   tcp_shim        - rt_io_tcp_* extern implementations

use os.kernel.net.tcp_shim_state.{
    ShimFdEntry, shim_alloc_fd, shim_get, shim_set, shim_remove,
    parse_host_port
}
use os.kernel.net.tcp_shim.{
    rt_io_tcp_bind, rt_io_tcp_accept, rt_io_tcp_accept_timeout,
    rt_io_tcp_connect, rt_io_tcp_connect_timeout,
    rt_io_tcp_read, rt_io_tcp_read_line,
    rt_io_tcp_write, rt_io_tcp_write_text,
    rt_io_tcp_flush, rt_io_tcp_close,
    rt_io_tcp_local_addr, rt_io_tcp_peer_addr,
    rt_io_tcp_set_nodelay, rt_io_tcp_set_read_timeout,
    rt_io_tcp_set_write_timeout, rt_io_tcp_shutdown
}
