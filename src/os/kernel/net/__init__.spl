# Kernel Network Shim Module
#
# MDSOC: feature dimension, network layer
# Bridges std.io.tcp extern functions (rt_io_tcp_*) and rt_driver_* extern
# functions to the SimpleOS netstack service. Provides fd tracking, address
# parsing, IoDriver completion shims, baremetal TLS certificate embedding,
# thread stubs for single-core inline mode, and the HTTP server launcher.
#
# Modules:
#   tcp_shim_state      - Module-level fd table and address parsing
#   tcp_shim            - rt_io_tcp_* + rt_socket_* @export("C") implementations (B2/B5)
#   driver_shim_state   - Per-handle IoDriver state (pending/completed queues)
#   driver_shim         - rt_driver_* @export("C") implementations (B3)
#   embedded_certs      - DER-encoded self-signed certificate and key (B4)
#   tls_shim            - Baremetal TLS stubs (file I/O, time, entropy) (B4)
#   thread_shim         - spl_thread_*/spl_mutex_*/spl_condvar_* stubs (B5)
#   http_baremetal      - Inline HTTP server launcher (B5)
#                         (all shim modules loaded by runtime linker, not
#                          re-exported here)

use os.kernel.net.tcp_shim_state.{
    ShimFdEntry, shim_alloc_fd, shim_get, shim_set, shim_remove,
    parse_host_port, HostPort, make_sock_addr, sock_addr_to_text
}

use os.kernel.net.driver_shim_state.{
    PendingOp, CompletedOp, BaremetalDriver,
    OP_TYPE_ACCEPT, OP_TYPE_RECV, OP_TYPE_SEND, OP_TYPE_TIMEOUT,
    driver_create, driver_get, driver_destroy
}

use os.kernel.net.embedded_certs.{
    get_embedded_cert_der, get_embedded_key_der, has_embedded_certs
}

use os.kernel.net.tls_shim.{
    BaremetalTlsInfo, get_baremetal_tls_info
}

use os.kernel.net.http_baremetal.{
    start_http_server_baremetal
}
