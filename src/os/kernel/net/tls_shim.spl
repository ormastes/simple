# TLS SFFI Stubs (baremetal @export("C") implementations)
# ============================================================================
#
# Each function here implements the matching extern declared in
# src/lib/nogc_sync_mut/io/tls_sffi.spl for the SimpleOS baremetal target.
# All stubs fail closed: no live TLS stack exists yet.
# Follow-up: wire to a rustls-based netstack when TCP shim gains packet I/O.

# --- TLS Client ---

@export("C")
fn rt_tls_client_connect(host: text, port: i64) -> i64:
    """Open a TLS client connection to host:port.

    Baremetal stub: no network stack available. Always returns -1.
    TODO: delegate to NetstackService TLS client when live stack lands.
    """
    -1

@export("C")
fn rt_tls_client_connect_with_sni(host: text, port: i64, server_name: text) -> i64:
    """Open a TLS client connection with explicit SNI hostname.

    Baremetal stub: no network stack available. Always returns -1.
    """
    -1

@export("C")
fn rt_tls_client_write(conn: i64, data: text) -> i64:
    """Write data to a TLS client connection.

    Baremetal stub: no live connection. Returns -1 (0 bytes written).
    """
    -1

@export("C")
fn rt_tls_client_read(conn: i64, max_bytes: i64) -> text:
    """Read up to max_bytes from a TLS client connection.

    Baremetal stub: no live connection. Returns empty string.
    """
    ""

@export("C")
fn rt_tls_client_close(conn: i64) -> bool:
    """Close a TLS client connection.

    Baremetal stub: no live connection to close. Always returns false.
    """
    false

