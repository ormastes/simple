    TLS_CIPHER_PLACEHOLDER

@export("C")
fn rt_tls_get_negotiated_alpn(conn: i64) -> text:
    """Return the negotiated ALPN protocol string for a connection.

    Baremetal stub: no live connection. Returns empty string.
    """
    ""

@export("C")
fn rt_tls_is_handshake_complete(conn: i64) -> bool:
    """Return true when the TLS handshake is complete on a connection.

    Baremetal stub: no live connection. Returns false.
    """
    false

