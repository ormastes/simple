# TCP Shim -- Netstack-backed TCP externs for SimpleOS.
#
# MDSOC: feature dimension, network layer
# Status: fail-closed until the live NetstackService singleton is available.
#
# Architecture:
#   - Each function maps shim fds to real netstack socket fds.
#   - bind/connect fail when the netstack is unavailable; no fake fds are issued.
#   - read/write fail or return no data when no real socket exists.
#   - Socket option setters (nodelay, timeouts) store flags faithfully.
#
# Each rt_io_tcp_* function here implements the extern declared in
# src/lib/nogc_sync_mut/io/tcp.spl.

use os.kernel.net.tcp_shim_state.{
    ShimFdEntry, shim_alloc_fd, shim_get, shim_set, shim_remove,
    parse_host_port, make_sock_addr, sock_addr_to_text, HostPort
}
use os.services.netstack.netstack_init.{
    net_tcp_available, net_tcp_bind, net_tcp_accept, net_tcp_connect,
    net_tcp_read, net_tcp_write, net_tcp_close
}

extern fn rt_text_to_bytes(s: text) -> [u8]

fn tcp_shim_link_anchor() -> bool:
    """Force this module into freestanding boot closures that need rt_io_tcp_* exports."""
    true

# ============================================================================
# TCP Listener Functions
# ============================================================================

@export("C")
fn rt_io_tcp_bind(addr: text) -> i64:
    """Create a TCP listener socket, bind to addr, and start listening.

    Returns a shim fd (>= 100) on success, or -1 on failure.
    Requires a live NetstackService. No fake listener is created when the
    network stack is unavailable.
    """
    val hp = parse_host_port(addr)
    if hp == nil:
        return -1

    if not net_tcp_available():
        return -1

    val os_fd = net_tcp_bind(hp.unwrap().ip.value, hp.unwrap().port, 128u32).to_i32()
    if os_fd < 0:
        return -1

    # Allocate shim fd and track
    val shim_fd = shim_alloc_fd()
    val entry = ShimFdEntry(
        fd: shim_fd, os_fd: os_fd,
        bound_addr: addr, peer_addr_text: "",
        is_listening: true, nonblocking: false,
        nodelay: false, read_timeout_ms: -1, write_timeout_ms: -1
    )
    shim_set(shim_fd, entry)
    shim_fd

@export("C")
fn rt_io_tcp_accept(fd: i64) -> i64:
    """Accept incoming connection on a listener (blocking).

    Returns -1 when no completed netstack accept is available.
    """
    val entry = shim_get(fd)
    if entry == nil:
        return -1

    val e = entry.unwrap()
    if not e.is_listening:
        return -1

    if net_tcp_available():
        val client_os_fd = net_tcp_accept(e.os_fd.to_i64())
        if client_os_fd < 0:
            return -1

        val shim_fd = shim_alloc_fd()
        val client_entry = ShimFdEntry(
            fd: shim_fd, os_fd: client_os_fd.to_i32(),
            bound_addr: e.bound_addr, peer_addr_text: "",
            is_listening: false, nonblocking: e.nonblocking,
            nodelay: e.nodelay, read_timeout_ms: e.read_timeout_ms,
            write_timeout_ms: e.write_timeout_ms
        )
        shim_set(shim_fd, client_entry)
        return shim_fd

    -1

@export("C")
fn rt_io_tcp_accept_timeout(fd: i64, ms: i64) -> i64:
    """Accept with timeout.

    Returns -1 on timeout or when the netstack is unavailable.
    """
    val entry = shim_get(fd)
    if entry == nil:
        return -1

    val e = entry.unwrap()
    if not e.is_listening:
        return -1

    if net_tcp_available():
        var waited: i64 = 0
        while waited <= ms:
            val client_fd = rt_io_tcp_accept(fd)
            if client_fd >= 0:
                return client_fd
            waited = waited + 1
        return -1

    -1

# ============================================================================
# TCP Stream Functions
# ============================================================================

@export("C")
fn rt_io_tcp_connect(addr: text) -> i64:
    """Connect to a remote address (blocking).

    Requires a live NetstackService. No fake connection fd is created when
    the network stack is unavailable.
    """
    val hp = parse_host_port(addr)
    if hp == nil:
        return -1

    if not net_tcp_available():
        return -1

    val os_fd = net_tcp_connect(hp.unwrap().ip.value, hp.unwrap().port, 2000u64).to_i32()
    if os_fd < 0:
        return -1

    val shim_fd = shim_alloc_fd()
    val entry = ShimFdEntry(
        fd: shim_fd, os_fd: os_fd,
        bound_addr: "", peer_addr_text: addr,
        is_listening: false, nonblocking: false,
        nodelay: false, read_timeout_ms: -1, write_timeout_ms: -1
    )
    shim_set(shim_fd, entry)
    shim_fd

@export("C")
fn rt_io_tcp_connect_timeout(addr: text, ms: i64) -> i64:
    """Connect with timeout.

    B2 stub: delegates to rt_io_tcp_connect (no real timeout).
    """
    rt_io_tcp_connect(addr)

# ============================================================================
# Read / Write
# ============================================================================

@export("C")
fn rt_io_tcp_read(fd: i64, size: i64) -> [u8]:
    """Read up to size bytes from a connected TCP stream.

    Returns empty if the fd is invalid or the netstack is unavailable.
    """
    val entry = shim_get(fd)
    if entry == nil:
        return []

    if net_tcp_available():
        return net_tcp_read(entry.unwrap().os_fd.to_i64(), size.to_u64())

    []

@export("C")
fn rt_io_tcp_read_line(fd: i64) -> text?:
    """Read a single line (up to newline) from a TCP stream.

    B2 stub: no real recv buffer. Returns nil (EOF).
    """
    val entry = shim_get(fd)
    if entry == nil:
        return nil

    # TODO: wire to real TcpConnection recv_data, accumulate until newline
    nil

@export("C")
fn rt_io_tcp_write(fd: i64, data: [u8]) -> i64:
    """Write bytes to a connected TCP stream.

    Returns -1 if the fd is invalid or the netstack is unavailable.
    """
    val entry = shim_get(fd)
    if entry == nil:
        return -1

    if net_tcp_available():
        return net_tcp_write(entry.unwrap().os_fd.to_i64(), data)

    -1

@export("C")
fn rt_io_tcp_write_text(fd: i64, data: text) -> i64:
    """Write text to a connected TCP stream.

    Returns -1 if the fd is invalid or the netstack is unavailable.
    """
    val entry = shim_get(fd)
    if entry == nil:
        return -1

    if net_tcp_available():
        return net_tcp_write(entry.unwrap().os_fd.to_i64(), rt_text_to_bytes(data))

    -1

@export("C")
fn rt_io_tcp_flush(fd: i64) -> bool:
    """Flush the TCP send buffer.

    Returns false when the fd is invalid or the netstack is unavailable.
    """
    val entry = shim_get(fd)
    if entry == nil:
        return false

    net_tcp_available()

@export("C")
fn rt_io_tcp_close(fd: i64) -> bool:
    """Close a TCP socket (listener or stream).

    B2 stub: removes from shim fd table. No real FIN sent.
    """
    val entry = shim_get(fd)
    if entry == nil:
        return false

    if net_tcp_available():
        val closed = net_tcp_close(entry.unwrap().os_fd.to_i64())
        if not closed:
            return false
    shim_remove(fd)
    true

# ============================================================================
# Metadata / Options
# ============================================================================

@export("C")
fn rt_io_tcp_local_addr(fd: i64) -> text?:
    """Get the local bound address as "A.B.C.D:port"."""
    val entry = shim_get(fd)
    if entry == nil:
        return nil

    val e = entry.unwrap()
    if e.bound_addr.len() > 0:
        return e.bound_addr

    nil

@export("C")
fn rt_io_tcp_peer_addr(fd: i64) -> text?:
    """Get the remote peer address as "A.B.C.D:port"."""
    val entry = shim_get(fd)
    if entry == nil:
        return nil

    val e = entry.unwrap()
    if e.peer_addr_text.len() > 0:
        return e.peer_addr_text

    nil

@export("C")
fn rt_io_tcp_set_nodelay(fd: i64, enabled: bool) -> bool:
    """Set TCP_NODELAY (disable Nagle's algorithm).

    Stores the flag in shim state. Always succeeds.
    """
    val entry = shim_get(fd)
    if entry == nil:
        return false

    val e = entry.unwrap()
    val updated = ShimFdEntry(
        fd: e.fd, os_fd: e.os_fd,
        bound_addr: e.bound_addr, peer_addr_text: e.peer_addr_text,
        is_listening: e.is_listening, nonblocking: e.nonblocking,
        nodelay: enabled, read_timeout_ms: e.read_timeout_ms,
        write_timeout_ms: e.write_timeout_ms
    )
    shim_set(fd, updated)
    true

@export("C")
fn rt_io_tcp_set_read_timeout(fd: i64, ms: i64?) -> bool:
    """Set read timeout in milliseconds. nil means no timeout."""
    val entry = shim_get(fd)
    if entry == nil:
        return false

    val e = entry.unwrap()
    val timeout_val = if ms.?: ms.unwrap() else: -1
    val updated = ShimFdEntry(
        fd: e.fd, os_fd: e.os_fd,
        bound_addr: e.bound_addr, peer_addr_text: e.peer_addr_text,
        is_listening: e.is_listening, nonblocking: e.nonblocking,
        nodelay: e.nodelay, read_timeout_ms: timeout_val,
        write_timeout_ms: e.write_timeout_ms
    )
    shim_set(fd, updated)
    true

@export("C")
fn rt_io_tcp_set_write_timeout(fd: i64, ms: i64?) -> bool:
    """Set write timeout in milliseconds. nil means no timeout."""
    val entry = shim_get(fd)
    if entry == nil:
        return false

    val e = entry.unwrap()
    val timeout_val = if ms.?: ms.unwrap() else: -1
    val updated = ShimFdEntry(
        fd: e.fd, os_fd: e.os_fd,
        bound_addr: e.bound_addr, peer_addr_text: e.peer_addr_text,
        is_listening: e.is_listening, nonblocking: e.nonblocking,
        nodelay: e.nodelay, read_timeout_ms: e.read_timeout_ms,
        write_timeout_ms: timeout_val
    )
    shim_set(fd, updated)
    true

@export("C")
fn rt_io_tcp_shutdown(fd: i64, how: i64) -> bool:
    """Shutdown one or both directions of a TCP stream.

    how: 0=Read, 1=Write, 2=Both.
    B2 stub: records intent, no real FIN sent.
    """
    val entry = shim_get(fd)
    if entry == nil:
        return false

    # TODO: wire to real TcpConnection close for write/both shutdown
    true

# ============================================================================
# Socket Option Stubs (B5)
# ============================================================================
# These rt_socket_* functions are imported by std.http_server.worker
# via std.net.ffi. On baremetal, they store flags in shim state.

@export("C")
fn rt_socket_set_nonblocking(fd: i64, enabled: bool) -> bool:
    """Set socket to non-blocking mode.

    Baremetal stub: records the flag in shim state. The IoDriver
    shim (driver_shim) handles non-blocking semantics internally.
    """
    val entry = shim_get(fd)
    if entry == nil:
        return false

    val e = entry.unwrap()
    val updated = ShimFdEntry(
        fd: e.fd, os_fd: e.os_fd,
        bound_addr: e.bound_addr, peer_addr_text: e.peer_addr_text,
        is_listening: e.is_listening, nonblocking: enabled,
        nodelay: e.nodelay, read_timeout_ms: e.read_timeout_ms,
        write_timeout_ms: e.write_timeout_ms
    )
    shim_set(fd, updated)
    true

@export("C")
fn rt_socket_set_reuseport(fd: i64, enabled: bool) -> bool:
    """Set SO_REUSEPORT on a socket.

    Baremetal stub: no-op (single listener, single core). Always succeeds.
    """
    val entry = shim_get(fd)
    if entry == nil:
        return false
    true

@export("C")
fn rt_socket_set_reuseaddr(fd: i64, enabled: bool) -> bool:
    """Set SO_REUSEADDR on a socket.

    Baremetal stub: no-op (no address reuse concerns on baremetal).
    Always succeeds.
    """
    val entry = shim_get(fd)
    if entry == nil:
        return false
    true
