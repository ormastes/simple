# Embedded Certificates -- Baremetal TLS Material Gate
#
# MDSOC: feature dimension, security layer
# Status: offline-generated self-signed Ed25519 certificate material embedded.
#
# The certificate is self-signed for CN=simpleos. The private key is PKCS#8 DER
# using the repo's Ed25519 runtime-compatible key shape.

fn _hex_digit(c: text) -> i64:
    if c == "0": return 0
    if c == "1": return 1
    if c == "2": return 2
    if c == "3": return 3
    if c == "4": return 4
    if c == "5": return 5
    if c == "6": return 6
    if c == "7": return 7
    if c == "8": return 8
    if c == "9": return 9
    if c == "a": return 10
    if c == "A": return 10
    if c == "b": return 11
    if c == "B": return 11
    if c == "c": return 12
    if c == "C": return 12
    if c == "d": return 13
    if c == "D": return 13
    if c == "e": return 14
    if c == "E": return 14
    if c == "f": return 15
    if c == "F": return 15
    -1

fn _hex_to_bytes(s: text) -> [u8]:
    if (s.len() % 2) != 0:
        return []
    var out: [u8] = []
    var i: u64 = 0
    while i < s.len():
        val hi = _hex_digit(s[i])
        val lo = _hex_digit(s[i + 1])
        if hi < 0 or lo < 0:
            return []
        out.push((hi * 16 + lo).to_u8())
        i = i + 2
    out

fn get_embedded_cert_der() -> [u8]:
    """Return DER-encoded X.509 self-signed certificate bytes.

    Generated offline with OpenSSL as Ed25519, DER SHA-256:
    eb4b84a12e8417b172aa9cc0a3f30704b3670f7e568ccbc18c0ca15210197c35.
    """
    _hex_to_bytes(
        ""
    )

fn get_embedded_key_der() -> [u8]:
    """Return DER-encoded Ed25519 private key bytes.

    Runtime-compatible PKCS#8 DER, SHA-256:
    76ff09b700b80f6e85dae9a4342bdbd7fe69f318fc40d497146b4a3d9ec35b24.
    """
    _hex_to_bytes("302e020100300506032b6570042204201f80192e224a71dddf8c082c7690db9fdf583f3d4e02a19b77d0f8692f2ea40c")

fn has_embedded_certs() -> bool:
    """Return true when embedded certificate and key bytes are present."""
    get_embedded_cert_der().len() > 0 and get_embedded_key_der().len() > 0
