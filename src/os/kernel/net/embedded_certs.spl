# Embedded Certificates -- Self-Signed Certs for Baremetal TLS
#
# MDSOC: feature dimension, security layer
# Status: B4 stub -- provides placeholder DER-encoded certificate and
#         private key bytes for baremetal environments where filesystem-based
#         certificate loading is unavailable.
#
# Architecture:
#   - get_embedded_cert_der() returns a DER-encoded X.509 certificate.
#   - get_embedded_key_der() returns a DER-encoded private key.
#   - has_embedded_certs() returns true when embedded certs are available.
#   - Placeholder bytes are used; replace with real offline-generated
#     self-signed certificate and key for production baremetal deployments.

# ============================================================================
# Placeholder Certificate (DER-encoded X.509 self-signed)
# ============================================================================
#
# This is a minimal placeholder. In production, generate a real self-signed
# certificate offline with:
#   openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 \
#     -keyout key.pem -out cert.pem -days 3650 -nodes -subj "/CN=simpleos"
# Then convert to DER and embed the raw bytes here.

fn get_embedded_cert_der() -> [u8]:
    """Return DER-encoded X.509 self-signed certificate bytes.

    B4 placeholder: returns a minimal recognizable byte sequence.
    The first bytes [0x30, 0x82] are the ASN.1 SEQUENCE tag typical of
    DER-encoded X.509 certificates. The rest is a placeholder body.
    Replace with a real offline-generated self-signed certificate.
    """
    var cert: [u8] = []
    # ASN.1 SEQUENCE header (0x30 0x82 = long-form length follows)
    cert.push(0x30)
    cert.push(0x82)
    # Placeholder length (2 bytes, big-endian) -- not a real cert length
    cert.push(0x00)
    cert.push(0x20)
    # Placeholder body: "simpleos-cert-placeholder" as bytes
    # s=0x73 i=0x69 m=0x6D p=0x70 l=0x6C e=0x65 o=0x6F s=0x73
    cert.push(0x73)
    cert.push(0x69)
    cert.push(0x6D)
    cert.push(0x70)
    cert.push(0x6C)
    cert.push(0x65)
    cert.push(0x6F)
    cert.push(0x73)
    # dash 0x2D
    cert.push(0x2D)
    # c=0x63 e=0x65 r=0x72 t=0x74
    cert.push(0x63)
    cert.push(0x65)
    cert.push(0x72)
    cert.push(0x74)
    # dash 0x2D
    cert.push(0x2D)
    # p=0x70 l=0x6C a=0x61 c=0x63 e=0x65 h=0x68 o=0x6F l=0x6C d=0x64 e=0x65 r=0x72
    cert.push(0x70)
    cert.push(0x6C)
    cert.push(0x61)
    cert.push(0x63)
    cert.push(0x65)
    cert.push(0x68)
    cert.push(0x6F)
    cert.push(0x6C)
    cert.push(0x64)
    cert.push(0x65)
    cert.push(0x72)
    # Padding to 32 bytes body
    cert.push(0x00)
    cert.push(0x00)
    cert.push(0x00)
    cert.push(0x00)
    cert.push(0x00)
    cert

# ============================================================================
# Placeholder Private Key (DER-encoded PKCS#8)
# ============================================================================

fn get_embedded_key_der() -> [u8]:
    """Return DER-encoded private key bytes.

    B4 placeholder: returns a minimal recognizable byte sequence.
    The first bytes [0x30, 0x82] are the ASN.1 SEQUENCE tag typical of
    PKCS#8 DER-encoded private keys. The rest is a placeholder body.
    Replace with a real offline-generated private key.
    """
    var key: [u8] = []
    # ASN.1 SEQUENCE header
    key.push(0x30)
    key.push(0x82)
    # Placeholder length (2 bytes)
    key.push(0x00)
    key.push(0x20)
    # Placeholder body: "simpleos-key-placeholder-" as bytes
    # s=0x73 i=0x69 m=0x6D p=0x70 l=0x6C e=0x65 o=0x6F s=0x73
    key.push(0x73)
    key.push(0x69)
    key.push(0x6D)
    key.push(0x70)
    key.push(0x6C)
    key.push(0x65)
    key.push(0x6F)
    key.push(0x73)
    # dash 0x2D
    key.push(0x2D)
    # k=0x6B e=0x65 y=0x79
    key.push(0x6B)
    key.push(0x65)
    key.push(0x79)
    # dash 0x2D
    key.push(0x2D)
    # p=0x70 l=0x6C a=0x61 c=0x63 e=0x65 h=0x68 o=0x6F l=0x6C d=0x64 e=0x65 r=0x72
    key.push(0x70)
    key.push(0x6C)
    key.push(0x61)
    key.push(0x63)
    key.push(0x65)
    key.push(0x68)
    key.push(0x6F)
    key.push(0x6C)
    key.push(0x64)
    key.push(0x65)
    key.push(0x72)
    # Padding
    key.push(0x2D)
    key.push(0x00)
    key.push(0x00)
    key.push(0x00)
    key.push(0x00)
    key

# ============================================================================
# Query
# ============================================================================

fn has_embedded_certs() -> bool:
    """Return true when embedded certificates are available.

    Always true for the baremetal build. Callers use this to decide between
    filesystem-based cert loading (hosted OS) and embedded certs (baremetal).
    """
    true
