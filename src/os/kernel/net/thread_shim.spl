# Thread Shim -- Baremetal Thread Stubs for Single-Core Inline Mode
#
# MDSOC: feature dimension, concurrency layer
# Status: B5 stub -- satisfies spl_thread_* extern linkage so the stdlib
#         thread_sffi and http_server modules compile against SimpleOS.
#         All thread operations are no-ops or return single-core defaults.
#
# Architecture:
#   - spl_thread_create returns -1 (thread creation unsupported).
#     The HTTP server bypasses HttpServer.start() and runs Worker.run()
#     inline on the boot core.
#   - spl_thread_join/detach return true (no-op success).
#   - spl_thread_cpu_count returns 1 (single-core baremetal).
#   - spl_thread_sleep busy-waits using the fake timer.
#   - spl_thread_yield is a no-op.
#   - Mutex/condvar stubs provide single-threaded semantics:
#     locks always succeed, waits return immediately.

use os.kernel.log.klog_api.{log_raw_println}

# ============================================================================
# Thread Management Stubs
# ============================================================================

@export("C")
fn spl_thread_create(entry_point: i64, arg: i64) -> i64:
    """Spawn a new OS thread.

    Baremetal stub: thread creation is not supported on single-core.
    Returns -1 to signal failure. Callers should fall back to
    inline execution.
    """
    log_raw_println("[thread_shim] spl_thread_create called -- returning -1 (single-core)")
    -1

@export("C")
fn spl_thread_join(handle: i64) -> bool:
    """Wait for a thread to complete.

    Baremetal stub: no threads to join. Always returns true.
    """
    true

@export("C")
fn spl_thread_detach(handle: i64) -> bool:
    """Detach a thread.

    Baremetal stub: no threads to detach. Always returns true.
    """
    true

@export("C")
fn spl_thread_current_id() -> i64:
    """Get current thread ID.

    Baremetal stub: always returns 0 (boot core).
    """
    0

extern fn rt_time_now_ms() -> i64

@export("C")
fn spl_thread_sleep(millis: i64):
    """Sleep the current thread for millis milliseconds.

    Baremetal stub: busy-wait loop against the fake monotonic clock
    from tls_shim. Each rt_time_now_ms() call advances the clock by
    1ms, so this loop exits after approximately millis iterations.
    On real hardware this would use a timer interrupt or WFI.
    """
    if millis <= 0:
        return

    val start = rt_time_now_ms()
    while (rt_time_now_ms() - start) < millis:
        pass_dn

@export("C")
fn spl_thread_yield():
    """Yield CPU to other threads.

    Baremetal stub: no-op on single-core. On RISC-V this could
    issue a WFI or pause hint, but there are no other threads
    to yield to.
    """
    pass_dn

@export("C")
fn spl_thread_cpu_count() -> i64:
    """Get number of available CPU cores.

    Baremetal stub: returns 1 (single-core).
    """
    1

# ============================================================================
# Mutex Stubs (single-threaded: always succeed)
# ============================================================================

var g_next_mutex_handle: i64 = 1

@export("C")
fn spl_mutex_create() -> i64:
    """Create a mutex.

    Baremetal stub: allocates a handle number. No real locking needed.
    """
    val handle = g_next_mutex_handle
    g_next_mutex_handle = g_next_mutex_handle + 1
    handle

@export("C")
fn spl_mutex_lock(handle: i64) -> bool:
    """Lock a mutex (blocking).

    Baremetal stub: always succeeds (single-threaded, no contention).
    """
    true

@export("C")
fn spl_mutex_try_lock(handle: i64) -> bool:
    """Try to lock a mutex (non-blocking).

    Baremetal stub: always succeeds.
    """
    true

@export("C")
fn spl_mutex_unlock(handle: i64) -> bool:
    """Unlock a mutex.

    Baremetal stub: always succeeds.
    """
    true

@export("C")
fn spl_mutex_destroy(handle: i64):
    """Destroy a mutex.

    Baremetal stub: no-op.
    """
    pass_dn

# ============================================================================
# Condition Variable Stubs (single-threaded: immediate return)
# ============================================================================

var g_next_condvar_handle: i64 = 1

@export("C")
fn spl_condvar_create() -> i64:
    """Create a condition variable.

    Baremetal stub: allocates a handle number.
    """
    val handle = g_next_condvar_handle
    g_next_condvar_handle = g_next_condvar_handle + 1
    handle

@export("C")
fn spl_condvar_wait(cv_handle: i64, mutex_handle: i64) -> bool:
    """Wait on a condition variable.

    Baremetal stub: returns immediately (single-threaded, no other
    thread to signal).
    """
    true

@export("C")
fn spl_condvar_wait_timeout(cv_handle: i64, mutex_handle: i64, timeout_ms: i64) -> bool:
    """Wait on a condition variable with timeout.

    Baremetal stub: returns immediately (timeout).
    """
    false

@export("C")
fn spl_condvar_signal(handle: i64) -> bool:
    """Signal one waiting thread.

    Baremetal stub: no-op (no waiters).
    """
    true

@export("C")
fn spl_condvar_broadcast(handle: i64) -> bool:
    """Signal all waiting threads.

    Baremetal stub: no-op (no waiters).
    """
    true

@export("C")
fn spl_condvar_destroy(handle: i64):
    """Destroy a condition variable.

    Baremetal stub: no-op.
    """
    pass_dn
