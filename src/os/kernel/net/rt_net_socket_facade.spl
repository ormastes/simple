use lib.common.string_core.{char_from_code}

extern fn rt_net_init() -> i64
extern fn rt_net_tx_test() -> i64
extern fn rt_net_rx_ready() -> i64
extern fn rt_net_stats() -> i64
extern fn serial_println(msg: text)
extern fn rt_boot_tcp_bind(addr: text) -> i64
extern fn rt_boot_tcp_bind_port(port: i64) -> i64
extern fn rt_boot_tcp_accept_timeout(fd: i64, ms: i64) -> i64
extern fn rt_boot_tcp_write_text(fd: i64, data: text) -> i64
extern fn rt_boot_tcp_write_bytes(fd: i64, data: [u8]) -> i64
extern fn rt_boot_tcp_send_ssh_banner(fd: i64) -> i64
extern fn rt_boot_tcp_read_bytes(max_len: i64) -> [u8]
extern fn rt_boot_tcp_read_ssh_plain_packet_payload(fd: i64) -> [u8]
extern fn rt_boot_tcp_read_ssh_encrypted_packet(fd: i64) -> [u8]
extern fn rt_boot_tcp_take_version_text(fd: i64) -> text
extern fn rt_boot_tcp_take_version_bytes(fd: i64) -> [u8]
extern fn rt_boot_tcp_close(fd: i64) -> i64
extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_thread_sleep(ms: i64) -> i64

struct RtNetSocketEntry:
    fd: i64
    port: u16
    os_fd: i32
    listening: bool

var _rt_net_sockets: [RtNetSocketEntry] = []
var _rt_net_next_fd: i64 = 1000
var _rt_net_port_inited: bool = false
var _rt_net_last_plain_payload: [u8] = []
var _rt_net_last_plain_payload_len_value: u64 = 0
var _rt_net_bound_listener_fd: i64 = -1
var _rt_net_bound_listener_port: u16 = 0u16

fn _decode_riscv_status(raw: i64) -> i64:
    val wrapped_negative_floor = 1i64 << 60
    val wrapped_negative_span = 1i64 << 61
    if raw >= wrapped_negative_floor:
        return raw - wrapped_negative_span
    raw

fn rt_net_socket_facade_link_anchor() -> bool:
    true

fn _rt_net_bind_and_listen_impl(sock_fd: i64, port_num: i64) -> i64:
    val entry = _rt_net_find(sock_fd)
    val current = match entry:
        Some(found):
            found
        nil:
            return -1
    if not _rt_net_ensure_ready():
        return -1
    _rt_net_bound_listener_fd = sock_fd
    _rt_net_bound_listener_port = port_num.to_u16()
    var os_fd = current.os_fd
    if os_fd < 0:
        val bind_addr =
            if _rt_net_bound_listener_port == 2222u16:
                "0.0.0.0:2222"
            else:
                "0.0.0.0:0"
        os_fd = rt_boot_tcp_bind(bind_addr).to_i32()
        if os_fd < 0:
            return -1
    val updated = RtNetSocketEntry(
        fd: current.fd,
        port: _rt_net_bound_listener_port,
        os_fd: os_fd,
        listening: true
    )
    _rt_net_set(updated)
    0

fn rt_net_bind_and_listen(sock_fd: i64, port_num: i64) -> i64:
    _rt_net_bind_and_listen_impl(sock_fd, port_num)

@export("C", name: "rt_net_bind_and_listen")
fn rt_net_bind_and_listen_c(sock_fd: i64, port_num: i64) -> i64:
    _rt_net_bind_and_listen_impl(sock_fd, port_num)

fn rt_net_last_ssh_plain_payload_len() -> i64:
    _rt_net_last_plain_payload_len_value.to_i64()

fn rt_net_last_ssh_plain_payload_slice(start: i64, length: i64) -> [u8]:
    _rt_net_last_plain_payload.slice(start.to_u64(), (start + length).to_u64())

fn _rt_net_ensure_ready() -> bool:
    if _rt_net_port_inited:
        return true
    val init_rc = _decode_riscv_status(rt_net_init())
    if init_rc < 0:
        return false
    val tx_rc = _decode_riscv_status(rt_net_tx_test())
    if tx_rc < 0:
        return false
    val rx_rc = _decode_riscv_status(rt_net_rx_ready())
    if rx_rc < 0:
        return false
    val stats_rc = _decode_riscv_status(rt_net_stats())
    if stats_rc < 0:
        return false
    _rt_net_port_inited = true
    true

fn _rt_net_find(fd: i64) -> RtNetSocketEntry?:
    var i: u64 = 0
    while i < _rt_net_sockets.len():
        if _rt_net_sockets[i].fd == fd:
            return _rt_net_sockets[i]
        i = i + 1
    nil

fn _rt_net_set(entry: RtNetSocketEntry):
    var i: u64 = 0
    while i < _rt_net_sockets.len():
        if _rt_net_sockets[i].fd == entry.fd:
            _rt_net_sockets[i] = entry
            return
        i = i + 1
    _rt_net_sockets = _rt_net_sockets.push(entry)

fn _rt_net_remove(fd: i64):
    var next: [RtNetSocketEntry] = []
    var i: u64 = 0
    while i < _rt_net_sockets.len():
        if _rt_net_sockets[i].fd != fd:
            next.push(_rt_net_sockets[i])
        i = i + 1
    _rt_net_sockets = next

fn _rt_net_read_exact(os_fd: i64, want: u64) -> [u8]:
    if os_fd < 0:
        return []
    var out: [u8] = []
    var empty_reads: u64 = 0
    while out.len() < want:
        val chunk = rt_boot_tcp_read_bytes((want - out.len()).to_i64())
        if chunk.len() == 0:
            empty_reads = empty_reads + 1
            if empty_reads > 1000:
                return []
            rt_thread_sleep(1)
            pass_dn
        else:
            empty_reads = 0
            var i: u64 = 0
            while i < chunk.len():
                out.push(chunk[i])
                i = i + 1
    out

fn _rt_net_byte_u32(data: [u8], idx: u64) -> u32:
    (rt_bytes_u8_at(data, idx.to_i64()) & 0xFF) as u32

fn _rt_net_trim_crlf(data: [u8]) -> [u8]:
    var end = data.len()
    while end > 0:
        val ch = data[end - 1]
        if ch == '\n' or ch == '\r':
            end = end - 1
        else:
            break
    data.slice(0, end)

fn _rt_net_ascii_bytes_to_text(data: [u8]) -> text:
    var out = ""
    var i: u64 = 0
    while i < data.len():
        out = out + char_from_code(data[i].to_i64())
        i = i + 1
    out

fn _rt_net_bytes_to_text(data: [u8]) -> text:
    var out = ""
    var i: u64 = 0
    while i < data.len():
        out = out + char_from_code(data[i].to_i64())
        i = i + 1
    out

@export("C", name: "rt_net_socket")
fn rt_net_socket(proto: i64) -> i64:
    if proto != 1:
        return -1
    val fd = _rt_net_next_fd
    _rt_net_next_fd = _rt_net_next_fd + 1
    _rt_net_sockets = _rt_net_sockets.push(RtNetSocketEntry(fd: fd, port: 0u16, os_fd: -1, listening: false))
    fd

@export("C", name: "rt_net_bind")
fn rt_net_bind(sock_fd: i64, port_num: i64) -> i64:
    val entry = _rt_net_find(sock_fd)
    if entry == nil:
        return -1
    _rt_net_bound_listener_fd = sock_fd
    _rt_net_bound_listener_port = port_num.to_u16()
    0

@export("C", name: "rt_net_listen")
fn rt_net_listen(sock_fd: i64, backlog: i64) -> i64:
    val entry = _rt_net_find(sock_fd)
    val current = match entry:
        Some(found):
            found
        nil:
            return -1
    if not _rt_net_ensure_ready():
        return -1
    val listen_port =
        if _rt_net_bound_listener_fd == sock_fd and _rt_net_bound_listener_port != 0u16:
            _rt_net_bound_listener_port
        else:
            current.port
    var os_fd = current.os_fd
    if os_fd < 0:
        os_fd = rt_boot_tcp_bind_port(listen_port.to_i64()).to_i32()
        if os_fd < 0:
            return -1
    val updated = RtNetSocketEntry(
        fd: current.fd,
        port: listen_port,
        os_fd: os_fd,
        listening: true
    )
    _rt_net_set(updated)
    0

@export("C", name: "rt_net_accept")
fn rt_net_accept(sock_fd: i64) -> i64:
    val entry = _rt_net_find(sock_fd)
    val current = match entry:
        Some(found):
            found
        nil:
            return -1
    if not current.listening:
        return -1
    if not _rt_net_ensure_ready():
        return -1
    val client_os_fd = rt_boot_tcp_accept_timeout(current.os_fd.to_i64(), 1)
    if client_os_fd < 0:
        return -1
    val fd = _rt_net_next_fd
    _rt_net_next_fd = _rt_net_next_fd + 1
    _rt_net_sockets = _rt_net_sockets.push(RtNetSocketEntry(fd: fd, port: current.port, os_fd: client_os_fd.to_i32(), listening: false))
    fd

@export("C", name: "rt_net_close")
fn rt_net_close(sock_fd: i64) -> i64:
    val entry = _rt_net_find(sock_fd)
    val current = match entry:
        Some(found):
            found
        nil:
            if sock_fd == 100 or sock_fd == 200:
                return rt_boot_tcp_close(sock_fd)
            return -1
    if current.os_fd >= 0:
        val closed = rt_boot_tcp_close(current.os_fd.to_i64())
        if closed != 0:
            return -1
    _rt_net_remove(sock_fd)
    0

@export("C", name: "rt_net_send_bytes")
fn rt_net_send_bytes(sock_fd: i64, data: [u8]) -> i64:
    serial_println("[rt-net] send fn sock_fd={sock_fd} len={data.len()}")
    if sock_fd == 200:
        serial_println("[rt-net] send raw-fast len={data.len()}")
        val rc = rt_boot_tcp_write_bytes(sock_fd, data)
        serial_println("[rt-net] send raw-fast rc={rc}")
        return rc
    val entry = _rt_net_find(sock_fd)
    val current = match entry:
        Some(found):
            found
        nil:
            return -1
    if current.os_fd < 0:
        return -1
    if not _rt_net_ensure_ready():
        return -1
    rt_boot_tcp_write_bytes(current.os_fd.to_i64(), data)

@export("C", name: "rt_net_send_ssh_banner")
fn rt_net_send_ssh_banner(sock_fd: i64) -> i64:
    serial_println("[rt-net] banner send fn sock_fd={sock_fd}")
    if sock_fd == 200:
        val raw_rc = rt_boot_tcp_send_ssh_banner(sock_fd)
        serial_println("[rt-net] banner send raw-fast rc={raw_rc}")
        return raw_rc
    val entry = _rt_net_find(sock_fd)
    val current = match entry:
        Some(found):
            found
        nil:
            return -1
    if current.os_fd < 0:
        return -1
    if not _rt_net_ensure_ready():
        return -1
    val rc = rt_boot_tcp_send_ssh_banner(current.os_fd.to_i64())
    serial_println("[rt-net] banner send direct rc={rc}")
    rc

@export("C", name: "rt_net_recv_bytes")
fn rt_net_recv_bytes(sock_fd: i64, max_len: i64) -> [u8]:
    val entry = _rt_net_find(sock_fd)
    val current = match entry:
        Some(found):
            found
        nil:
            if sock_fd == 200:
                return rt_boot_tcp_read_bytes(max_len)
            return []
    if current.os_fd < 0:
        return []
    if not _rt_net_ensure_ready():
        return []
    rt_boot_tcp_read_bytes(max_len)

@export("C", name: "rt_net_recv_version_text")
fn rt_net_recv_version_text(sock_fd: i64) -> text:
    serial_println("[rt-net] version recv fn sock_fd={sock_fd}")
    if sock_fd == 200:
        serial_println("[rt-net] version recv raw-fast")
        val text = rt_boot_tcp_take_version_text(sock_fd)
        serial_println("[rt-net] version recv raw-fast done text={text}")
        return text
    val entry = _rt_net_find(sock_fd)
    if entry == nil:
        serial_println("[rt-net] version recv branch=nil")
        if sock_fd != 200:
            return ""
        serial_println("[rt-net] version raw recv start")
        val text = rt_boot_tcp_take_version_text(sock_fd)
        serial_println("[rt-net] version raw recv done text={text}")
        return text
    else:
        val current = match entry:
            Some(found):
                found
            nil:
                return ""
        serial_println("[rt-net] version recv branch=entry os_fd={current.os_fd}")
        if current.os_fd < 0:
            return ""
        if not _rt_net_ensure_ready():
            return ""
    var line: [u8] = []
    while true:
        val chunk = rt_boot_tcp_read_bytes(1)
        if chunk.len() == 0:
            break
        line.push(chunk[0])
        if chunk[0] == '\n':
            break
    if line.len() == 0:
        return ""
    _rt_net_ascii_bytes_to_text(_rt_net_trim_crlf(line))

@export("C", name: "rt_net_recv_version_bytes")
fn rt_net_recv_version_bytes(sock_fd: i64) -> [u8]:
    if sock_fd == 200:
        return rt_boot_tcp_take_version_bytes(sock_fd)
    []

@export("C", name: "rt_net_recv_ssh_plain_packet_payload")
fn rt_net_recv_ssh_plain_packet_payload(sock_fd: i64) -> [u8]:
    serial_println("[rt-net] plain recv fn sock_fd={sock_fd}")
    if sock_fd == 200:
        serial_println("[rt-net] plain recv raw-fast")
        val payload = rt_boot_tcp_read_ssh_plain_packet_payload(sock_fd)
        _rt_net_last_plain_payload = payload
        _rt_net_last_plain_payload_len_value = payload.len()
        if payload.len() > 512u64:
            serial_println("[rt-net] plain recv payload len=large")
        else:
            serial_println("[rt-net] plain recv payload len={_rt_net_last_plain_payload_len_value}")
        return payload
    val entry = _rt_net_find(sock_fd)
    val os_fd =
        if entry == nil:
            if sock_fd == 200:
                serial_println("[rt-net] plain recv raw-fast")
                sock_fd
            else:
                return []
        else:
            val socket_entry = match entry:
                Some(found):
                    found
                nil:
                    return []
            if socket_entry.os_fd < 0:
                return []
            if not _rt_net_ensure_ready():
                return []
            socket_entry.os_fd.to_i64()
    serial_println("[rt-net] plain recv header start os_fd={os_fd}")
    val header = _rt_net_read_exact(os_fd, 5u64)
    serial_println("[rt-net] plain recv header len={header.len()}")
    if header.len() != 5:
        return []
    val packet_len =
        (_rt_net_byte_u32(header, 0u64) << 24) |
        (_rt_net_byte_u32(header, 1u64) << 16) |
        (_rt_net_byte_u32(header, 2u64) << 8) |
        _rt_net_byte_u32(header, 3u64)
    val padding_len = _rt_net_byte_u32(header, 4u64)
    serial_println("[rt-net] plain recv framed packet_len={packet_len} padding_len={padding_len}")
    if packet_len < 1u32 or padding_len + 1u32 > packet_len:
        return []
    val remaining = _rt_net_read_exact(os_fd, (packet_len - 1u32).to_u64())
    serial_println("[rt-net] plain recv body len={remaining.len()}")
    if remaining.len() != (packet_len - 1u32).to_u64():
        return []
    if remaining.len() > 512u64:
        _rt_net_last_plain_payload = []
        _rt_net_last_plain_payload_len_value = 0
        serial_println("[rt-net] plain recv payload len=large")
        return remaining
    if packet_len == 44u32 and padding_len == 6u32 and remaining.len() >= 37u64:
        _rt_net_last_plain_payload_len_value = 37u64
        serial_println("[rt-net] plain recv payload len=37")
        _rt_net_last_plain_payload = remaining
        return remaining
    var payload_limit = remaining.len()
    var pad_left: u32 = padding_len
    while pad_left > 0u32:
        if payload_limit == 0:
            return []
        payload_limit = payload_limit - 1
        pad_left = pad_left - 1u32
    _rt_net_last_plain_payload_len_value = payload_limit
    serial_println("[rt-net] plain recv payload len={_rt_net_last_plain_payload_len_value}")
    _rt_net_last_plain_payload = remaining
    var payload: [u8] = []
    var i: u64 = 0
    while i < _rt_net_last_plain_payload_len_value:
        payload.push(_rt_net_last_plain_payload[i])
        i = i + 1
    payload

@export("C", name: "rt_net_recv_ssh_encrypted_packet")
fn rt_net_recv_ssh_encrypted_packet(sock_fd: i64) -> [u8]:
    serial_println("[rt-net] encrypted recv fn sock_fd={sock_fd}")
    if sock_fd == 200:
        return rt_boot_tcp_read_ssh_encrypted_packet(sock_fd)
    val entry = _rt_net_find(sock_fd)
    val os_fd =
        if entry == nil:
            if sock_fd == 200:
                sock_fd
            else:
                return []
        else:
            val socket_entry = match entry:
                Some(found):
                    found
                nil:
                    return []
            if socket_entry.os_fd < 0:
                return []
            if not _rt_net_ensure_ready():
                return []
            socket_entry.os_fd.to_i64()
    val header = _rt_net_read_exact(os_fd, 4u64)
    if header.len() != 4u64:
        return []
    val packet_len =
        (_rt_net_byte_u32(header, 0u64) << 24) |
        (_rt_net_byte_u32(header, 1u64) << 16) |
        (_rt_net_byte_u32(header, 2u64) << 8) |
        _rt_net_byte_u32(header, 3u64)
    if packet_len < 1u32 or packet_len > 262144u32:
        return []
    val rest_len = packet_len.to_u64() + 16u64
    val rest = _rt_net_read_exact(os_fd, rest_len)
    if rest.len() != rest_len:
        return []
    var packet: [u8] = []
    var i: u64 = 0
    while i < header.len():
        packet.push(header[i])
        i = i + 1
    i = 0
    while i < rest.len():
        packet.push(rest[i])
        i = i + 1
    packet
