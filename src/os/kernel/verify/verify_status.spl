use std.io_runtime

class VerifyResult:
    check_name: text
    lane: text
    status: text
    detail: text

    static fn pass_check(name: text, lane: text) -> VerifyResult:
        return VerifyResult(check_name: name, lane: lane, status: "pass", detail: "")

    static fn fail_check(name: text, lane: text, detail: text) -> VerifyResult:
        return VerifyResult(check_name: name, lane: lane, status: "fail", detail: detail)

    static fn skip_check(name: text, lane: text, detail: text) -> VerifyResult:
        return VerifyResult(check_name: name, lane: lane, status: "skip", detail: detail)

    me is_pass() -> bool:
        return self.status == "pass"

    me is_fail() -> bool:
        return self.status == "fail"

class StatusReport:
    r0_name: text
    r0_status: text
    r1_name: text
    r1_status: text
    r2_name: text
    r2_status: text
    r3_name: text
    r3_status: text
    r4_name: text
    r4_status: text
    total: i32
    pass_count: i32
    fail_count: i32
    skip_count: i32

    static fn from_five(r0: VerifyResult, r1: VerifyResult, r2: VerifyResult, r3: VerifyResult, r4: VerifyResult) -> StatusReport:
        var pc: i32 = 0
        var fc: i32 = 0
        var sc: i32 = 0
        if r0.status == "pass":
            pc = pc + 1
        if r0.status == "fail":
            fc = fc + 1
        if r0.status == "skip":
            sc = sc + 1
        if r1.status == "pass":
            pc = pc + 1
        if r1.status == "fail":
            fc = fc + 1
        if r1.status == "skip":
            sc = sc + 1
        if r2.status == "pass":
            pc = pc + 1
        if r2.status == "fail":
            fc = fc + 1
        if r2.status == "skip":
            sc = sc + 1
        if r3.status == "pass":
            pc = pc + 1
        if r3.status == "fail":
            fc = fc + 1
        if r3.status == "skip":
            sc = sc + 1
        if r4.status == "pass":
            pc = pc + 1
        if r4.status == "fail":
            fc = fc + 1
        if r4.status == "skip":
            sc = sc + 1
        return StatusReport(
            r0_name: r0.check_name,
            r0_status: r0.status,
            r1_name: r1.check_name,
            r1_status: r1.status,
            r2_name: r2.check_name,
            r2_status: r2.status,
            r3_name: r3.check_name,
            r3_status: r3.status,
            r4_name: r4.check_name,
            r4_status: r4.status,
            total: 5,
            pass_count: pc,
            fail_count: fc,
            skip_count: sc
        )

    me all_passed() -> bool:
        return self.fail_count == 0

    me has_failures() -> bool:
        return self.fail_count > 0

    me summary() -> text:
        return "total=" + self.total.to_text() + " pass=" + self.pass_count.to_text() + " fail=" + self.fail_count.to_text() + " skip=" + self.skip_count.to_text()

class VerifyStatus:
    kernel_pass: i32
    kernel_fail: i32
    desktop_pass: i32
    desktop_fail: i32
    tooling_pass: i32
    tooling_fail: i32
    reporting_pass: i32
    reporting_fail: i32

    static fn create(kp: i32, kf: i32, dp: i32, df: i32, tp: i32, tf: i32, rp: i32, rf: i32) -> VerifyStatus:
        return VerifyStatus(
            kernel_pass: kp,
            kernel_fail: kf,
            desktop_pass: dp,
            desktop_fail: df,
            tooling_pass: tp,
            tooling_fail: tf,
            reporting_pass: rp,
            reporting_fail: rf
        )

    me total_pass() -> i32:
        return self.kernel_pass + self.desktop_pass + self.tooling_pass + self.reporting_pass

    me total_fail() -> i32:
        return self.kernel_fail + self.desktop_fail + self.tooling_fail + self.reporting_fail

    me is_green() -> bool:
        return self.total_fail() == 0

    me worst_lane() -> text:
        var worst: text = "kernel"
        var worst_count: i32 = self.kernel_fail
        if self.desktop_fail > worst_count:
            worst = "desktop"
            worst_count = self.desktop_fail
        if self.tooling_fail > worst_count:
            worst = "tooling"
            worst_count = self.tooling_fail
        if self.reporting_fail > worst_count:
            worst = "reporting"
            worst_count = self.reporting_fail
        return worst
