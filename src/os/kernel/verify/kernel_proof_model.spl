use std.io_runtime

class TrapFrame:
    pc: i64
    cause: i32
    privilege: text
    regs_saved: bool

    static fn create(pc: i64, cause: i32, priv_level: text) -> TrapFrame:
        return TrapFrame(pc: pc, cause: cause, privilege: priv_level, regs_saved: true)

    me preserves_registers() -> bool:
        return self.regs_saved

    me is_syscall() -> bool:
        return self.cause == 8

class SyscallDispatch:
    syscall_id: i32
    caller_pc: i64
    return_pc: i64
    privilege_before: text
    privilege_after: text

    static fn create(sid: i32, caller: i64) -> SyscallDispatch:
        return SyscallDispatch(
            syscall_id: sid,
            caller_pc: caller,
            return_pc: caller + 4,
            privilege_before: "user",
            privilege_after: "user"
        )

    me returns_to_caller() -> bool:
        return self.return_pc == self.caller_pc + 4

    me no_privilege_escalation() -> bool:
        return self.privilege_after == self.privilege_before

class CapGrant:
    cap_id: i32
    owner: text
    target: text
    permission: text
    is_revoked: bool

    static fn create(cid: i32, owner: text, target: text, perm: text) -> CapGrant:
        return CapGrant(cap_id: cid, owner: owner, target: target, permission: perm, is_revoked: false)

    me revoke() -> CapGrant:
        return CapGrant(cap_id: self.cap_id, owner: self.owner, target: self.target, permission: self.permission, is_revoked: true)

    me is_valid() -> bool:
        return self.is_revoked == false

class AuthorizationCheck:
    cap_id: i32
    requester: text
    required_perm: text
    granted_perm: text
    authorized: bool

    static fn check_grant(cap: CapGrant, requester: text, required: text) -> AuthorizationCheck:
        val auth = cap.is_valid() and cap.owner == requester and cap.permission == required
        return AuthorizationCheck(
            cap_id: cap.cap_id,
            requester: requester,
            required_perm: required,
            granted_perm: cap.permission,
            authorized: auth
        )

    me no_escalation() -> bool:
        return self.granted_perm == self.required_perm or self.authorized == false

class SchedState:
    task_id: i32
    state: text
    context_saved: bool

    static fn ready(tid: i32) -> SchedState:
        return SchedState(task_id: tid, state: "ready", context_saved: false)

    static fn running(tid: i32) -> SchedState:
        return SchedState(task_id: tid, state: "running", context_saved: false)

    me to_blocked() -> SchedState:
        return SchedState(task_id: self.task_id, state: "blocked", context_saved: true)

    me to_zombie() -> SchedState:
        return SchedState(task_id: self.task_id, state: "zombie", context_saved: self.context_saved)

    me is_runnable() -> bool:
        return self.state == "ready" or self.state == "running"

class LifecycleTransition:
    from_state: text
    to_state: text
    is_valid: bool
    context_preserved: bool

    static fn transition(from: text, to: text) -> LifecycleTransition:
        val valid = (from == "ready" and to == "running") or
                    (from == "running" and to == "blocked") or
                    (from == "running" and to == "zombie") or
                    (from == "blocked" and to == "ready")
        val ctx_preserved = from == "running" and to == "blocked"
        return LifecycleTransition(
            from_state: from,
            to_state: to,
            is_valid: valid,
            context_preserved: ctx_preserved
        )

    me no_zombie_runnable() -> bool:
        return (self.from_state == "zombie" and (self.to_state == "ready" or self.to_state == "running")) == false
