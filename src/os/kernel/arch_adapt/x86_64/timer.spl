# x86_64 Timer Adapter
#
# Thin wrapper layer over the concrete x86_64 timer module.

use os.kernel.arch.x86_64.timer.{X86Timer}

fn timer_init(frequency_hz: u64):
    """Initialize the x86_64 timer backend."""
    var timer = X86Timer()
    timer.init()
    if frequency_hz > 0:
        timer.set_periodic(1000000 / frequency_hz)

fn timer_set_deadline(delay_us: u64):
    """Program an x86_64 one-shot timer deadline."""
    var timer = X86Timer()
    timer.set_oneshot(delay_us)

fn timer_current_ticks() -> u64:
    """Return the x86_64 timer tick counter."""
    var timer = X86Timer()
    timer.current_ticks()

fn timer_ticks_per_second() -> u64:
    """Return the x86_64 timer tick rate."""
    var timer = X86Timer()
    timer.ticks_per_second()

