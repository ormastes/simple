# x86_64 Interrupt Adapter
#
# Thin wrapper layer over the concrete x86_64 interrupt module.

use os.kernel.arch.x86_64.interrupt.{X86Interrupt}

fn interrupt_init():
    """Initialize the x86_64 interrupt subsystem."""
    var interrupt = X86Interrupt()
    interrupt.init()

fn interrupt_acknowledge(irq: u32):
    """Acknowledge the provided x86_64 IRQ."""
    var interrupt = X86Interrupt()
    interrupt.send_eoi(irq as u64)

fn interrupt_enable_irq(irq: u32):
    """Unmask one x86_64 IRQ line."""
    var interrupt = X86Interrupt()
    interrupt.set_irq_mask(irq as u64, false)

fn interrupt_disable_irq(irq: u32):
    """Mask one x86_64 IRQ line."""
    var interrupt = X86Interrupt()
    interrupt.set_irq_mask(irq as u64, true)

fn interrupt_set_handler(vector: u32, handler_addr: u64):
    """Install an x86_64 IDT entry for the provided vector."""
    var interrupt = X86Interrupt()
    interrupt.register_handler(vector as u64, handler_addr)

fn interrupt_set_priority(irq: u32, priority: u32):
    """Record the current no-op x86_64 IRQ priority surface."""
    pass_dn

