# x86_64 Context Adapter
#
# Thin wrapper layer over the concrete x86_64 context-switch module.

use os.kernel.arch.arch_context.{ArchContext}
use os.kernel.arch.x86_64.context.{X86ContextSwitch}

fn context_save() -> ArchContext:
    """Save the current x86_64 CPU state into an ArchContext placeholder."""
    var context = X86ContextSwitch()
    val x86_ctx = context.create(0, 0, false)
    ArchContext.X86_64(ctx: x86_ctx)

fn context_restore(ctx: ArchContext):
    """Restore x86_64 CPU state from an ArchContext."""
    match ctx:
        ArchContext.X86_64(x86_ctx):
            var context = X86ContextSwitch()
            val from_ctx = context.create(0, 0, false)
            context.switch(from_ctx, x86_ctx)
        _:
            pass_dn

fn context_init(entry: u64, stack: u64, arg: u64) -> ArchContext:
    """Create a new x86_64 execution context."""
    var context = X86ContextSwitch()
    var x86_ctx = context.create(entry, stack, false)
    x86_ctx.rdi = arg
    ArchContext.X86_64(ctx: x86_ctx)
