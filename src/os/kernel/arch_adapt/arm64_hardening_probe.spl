# ARM64 hardening evidence adapter for boot-time serial probes.

use os.kernel.arch.arm64.canary.{canary_init, canary_value}
use os.kernel.arch_adapt.hardening_types.{HardeningReport}

extern fn rt_arm64_read_sctlr() -> u64

fn arm64_hardening_boot_canary_marker() -> text:
    canary_init(0)
    "[harden] canary arch=aarch64 value=" + canary_value().to_text()

pub fn arm64_hardening_probe_full() -> HardeningReport:
    """Probe ARM64 hardening features at boot time via SCTLR_EL1.

    SCTLR_EL1 bits:
      WXN  (bit 19) — Write eXecute Never: writable pages cannot be executed (NX proxy)
      nTWE (bit 18) — no-Trap WFE: used as SMEP proxy (EL0 WFE trapping)
      WP   (bit 6 of SCTLR, SA / stack-align) — not a direct WP; mapped via
           checking that SCTLR.M (MMU enable, bit 0) is set as the WP equivalent.

    All bit-position constants are function-local (baremetal BSS-zero safety).
    """
    val sctlr = rt_arm64_read_sctlr()

    val wxn_bit: u64  = 19
    val ntwe_bit: u64 = 18
    val mmu_bit: u64  = 0
    val bit_one: u64  = 1

    val nx   = (sctlr >> wxn_bit)  & bit_one != 0
    val smep = (sctlr >> ntwe_bit) & bit_one != 0
    # MMU enabled means page-table write protection is enforced.
    val wp   = (sctlr >> mmu_bit)  & bit_one != 0

    canary_init(0)
    val canary_val = canary_value()

    HardeningReport(
        nx: nx,
        smep: smep,
        smap: false,
        wp: wp,
        aslr_seed: sctlr,
        canary: canary_val,
        arch: "arm64"
    )
