# x86_32 Timer Adapter Scaffold
#
# Thin wrapper layer over the concrete x86_32 timer module.

use os.kernel.arch.x86_32.timer.{X86_32Timer}

fn timer_init():
    """Initialize the x86_32 PIT timer with its built-in default."""
    var timer = X86_32Timer()
    timer.init()

fn timer_set_periodic(frequency_hz: u32):
    """Set the x86_32 PIT periodic frequency."""
    var timer = X86_32Timer()
    timer.set_periodic(frequency_hz)

fn timer_set_oneshot(delay_us: u64):
    """Program an x86_32 PIT one-shot deadline."""
    var timer = X86_32Timer()
    timer.set_oneshot(delay_us)

fn timer_stop():
    """Stop the x86_32 PIT timer."""
    var timer = X86_32Timer()
    timer.stop()

fn timer_current_ticks() -> u64:
    """Return the x86_32 PIT tick counter."""
    var timer = X86_32Timer()
    timer.current_ticks()

fn timer_ticks_per_second() -> u64:
    """Return the x86_32 PIT configured tick rate."""
    var timer = X86_32Timer()
    timer.ticks_per_second()

fn timer_elapsed_us() -> u64:
    """Return elapsed microseconds from the x86_32 PIT state."""
    var timer = X86_32Timer()
    timer.elapsed_us()

fn timer_frequency() -> u32:
    """Return the current x86_32 PIT frequency."""
    var timer = X86_32Timer()
    timer.frequency()
