# x86_32 Arch Adapter Root
#
# Aggregates the x86_32 adapter surface under one module namespace.

use os.kernel.arch.x86_32.console.{X86_32Console}
use os.kernel.arch.x86_32.boot.{X86_32Boot}
use os.kernel.arch.x86_32.cpu.{X86_32Cpu}
use os.kernel.arch.x86_32.paging.{X86_32Paging}
use os.kernel.arch.x86_32.interrupt.{X86_32Interrupt}
use os.kernel.arch.x86_32.timer.{X86_32Timer}
use os.kernel.arch.x86_32.context.{X86_32ContextSwitch}

struct X86_32HalAdapter:
    """x86_32 adapter aggregate for portable kernel HAL call sites."""
    console: X86_32Console
    boot: X86_32Boot
    cpu: X86_32Cpu
    paging: X86_32Paging
    interrupt: X86_32Interrupt
    timer: X86_32Timer
    context: X86_32ContextSwitch

fn create_x86_32_hal_adapter() -> X86_32HalAdapter:
    """Create an x86_32 adapter aggregate."""
    X86_32HalAdapter(
        console: X86_32Console(),
        boot: X86_32Boot(),
        cpu: X86_32Cpu(),
        paging: X86_32Paging(),
        interrupt: X86_32Interrupt(),
        timer: X86_32Timer(),
        context: X86_32ContextSwitch()
    )

