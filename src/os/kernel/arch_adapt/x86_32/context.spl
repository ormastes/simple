# x86_32 Context Adapter Scaffold
#
# Thin wrapper layer over the concrete x86_32 context-switch module.

use os.kernel.arch.arch_context.{X86Context}
use os.kernel.arch.x86_32.context.{X86_32ContextSwitch}

fn context_init():
    """Initialize the x86_32 context-switch subsystem."""
    var context = X86_32ContextSwitch()
    context.init()

fn context_create(entry_point: u32, stack_top: u32, user_mode: bool) -> X86Context:
    """Create a new x86_32 execution context."""
    var context = X86_32ContextSwitch()
    context.create(entry_point, stack_top, user_mode)

fn context_switch(from_ctx: X86Context, to_ctx: X86Context):
    """Switch between two x86_32 execution contexts."""
    var context = X86_32ContextSwitch()
    context.switch(from_ctx, to_ctx)

fn context_save_fpu(ctx: X86Context):
    """Save x86_32 FPU state for the provided context."""
    var context = X86_32ContextSwitch()
    context.save_fpu(ctx)

fn context_restore_fpu(ctx: X86Context):
    """Restore x86_32 FPU state for the provided context."""
    var context = X86_32ContextSwitch()
    context.restore_fpu(ctx)
