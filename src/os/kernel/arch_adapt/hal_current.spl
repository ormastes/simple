# Current-Target HAL Adapter Surface
#
# Presents a stable current-target module surface so arch/hal.spl can later
# import one adapter module instead of concrete x86_64 leaf modules.

use os.kernel.boot.ports.{BootOutputPort}
use os.kernel.types.memory_types.{PhysAddr, VirtAddr, VmFlags}
use os.kernel.arch.arch_context.{ArchContext}
use os.kernel.arch_adapt.x86_64.boot.{boot_parse_boot_info}
use os.kernel.arch_adapt.x86_64.console.{console_init, console_write_byte, console_write, console_writeln}
use os.kernel.arch_adapt.x86_64.cpu.{
    cpu_disable_interrupts,
    cpu_enable_interrupts,
    cpu_halt,
    cpu_halt_loop,
    cpu_flush_tlb,
    cpu_flush_tlb_all,
    cpu_id,
    cpu_address_width,
    cpu_system_reset
}
use os.kernel.arch_adapt.x86_64.paging.{
    paging_init,
    paging_map,
    paging_unmap,
    paging_translate,
    paging_create_address_space,
    paging_switch_address_space,
    paging_levels
}
use os.kernel.arch_adapt.x86_64.interrupt.{
    interrupt_init,
    interrupt_enable_irq,
    interrupt_disable_irq,
    interrupt_acknowledge,
    interrupt_set_handler,
    interrupt_set_priority
}
use os.kernel.arch_adapt.x86_64.timer.{
    timer_init,
    timer_set_deadline,
    timer_current_ticks,
    timer_ticks_per_second
}
use os.kernel.arch_adapt.x86_64.context.{context_save, context_restore, context_init}

struct CurrentHalAdapter:
    """Current-target HAL adapter facade.

    The active target is x86_64 today. This marker struct gives callers a
    single type to import when they want to bind against the current adapter.
    """
    pass_dn

fn create_current_hal_adapter() -> CurrentHalAdapter:
    """Create the current-target adapter marker."""
    CurrentHalAdapter()

fn hal_console_init():
    """Initialize the current-target early console."""
    console_init()

fn hal_console_write_byte(b: u8):
    """Write one byte to the current-target early console."""
    console_write_byte(b)

fn hal_console_write(msg: text):
    """Write text to the current-target early console."""
    console_write(msg)

fn hal_console_writeln(msg: text):
    """Write text plus newline to the current-target early console."""
    console_writeln(msg)

fn hal_parse_boot_info() -> BootOutputPort:
    """Parse bootloader state through the current-target adapter."""
    boot_parse_boot_info()

fn hal_disable_interrupts():
    """Disable maskable interrupts on the current target."""
    cpu_disable_interrupts()

fn hal_enable_interrupts():
    """Enable maskable interrupts on the current target."""
    cpu_enable_interrupts()

fn hal_halt():
    """Halt the current CPU until the next interrupt."""
    cpu_halt()

fn hal_halt_loop():
    """Disable interrupts and halt forever."""
    cpu_halt_loop()

fn _hal_system_reset_arch() -> i64:
    """Request a machine reset through the current-target backend."""
    cpu_system_reset()

fn hal_flush_tlb(addr: u64):
    """Invalidate one TLB entry on the current target."""
    cpu_flush_tlb(addr)

fn hal_flush_tlb_all():
    """Flush the active address-space TLB state."""
    cpu_flush_tlb_all()

fn hal_cpu_id() -> u64:
    """Return the current logical CPU id."""
    cpu_id()

fn hal_address_width() -> u32:
    """Return the architectural virtual-address width in bits."""
    cpu_address_width()

fn hal_paging_init(boot_info: BootOutputPort):
    """Initialize paging through the current-target adapter."""
    paging_init(boot_info)

fn hal_paging_map(virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool:
    """Map one virtual page through the current-target paging backend."""
    paging_map(virt, phys, flags)

fn hal_paging_unmap(virt: VirtAddr) -> bool:
    """Unmap one virtual page through the current-target paging backend."""
    paging_unmap(virt)

fn hal_paging_translate(virt: VirtAddr) -> PhysAddr?:
    """Translate one virtual address through the current-target paging backend."""
    paging_translate(virt)

fn hal_paging_create_address_space() -> u64:
    """Create a new address-space root through the current-target backend."""
    paging_create_address_space()

fn hal_paging_switch_address_space(root_phys: u64):
    """Switch the active address-space root."""
    paging_switch_address_space(root_phys)

fn hal_paging_levels() -> u32:
    """Return the number of paging levels on the current target."""
    paging_levels()

fn hal_interrupt_init():
    """Initialize interrupt delivery on the current target."""
    interrupt_init()

fn hal_interrupt_enable_irq(irq: u32):
    """Enable one IRQ line on the current target."""
    interrupt_enable_irq(irq)

fn hal_interrupt_disable_irq(irq: u32):
    """Disable one IRQ line on the current target."""
    interrupt_disable_irq(irq)

fn hal_interrupt_acknowledge(irq: u32):
    """Acknowledge one interrupt on the current target."""
    interrupt_acknowledge(irq)

fn hal_interrupt_set_handler(irq: u32, handler: u64):
    """Install one interrupt handler on the current target."""
    interrupt_set_handler(irq, handler)

fn hal_interrupt_set_priority(irq: u32, priority: u32):
    """Adjust one interrupt priority on the current target."""
    interrupt_set_priority(irq, priority)

fn hal_timer_init(frequency_hz: u64):
    """Initialize the timer backend for the current target."""
    timer_init(frequency_hz)

fn hal_timer_set_deadline(ticks: u64):
    """Program a one-shot timer deadline on the current target."""
    timer_set_deadline(ticks)

fn hal_timer_current_ticks() -> u64:
    """Read timer ticks from the current-target backend."""
    timer_current_ticks()

fn hal_timer_ticks_per_second() -> u64:
    """Return timer frequency from the current-target backend."""
    timer_ticks_per_second()

fn hal_context_save() -> ArchContext:
    """Capture context in the current-target arch format."""
    context_save()

fn hal_context_restore(ctx: ArchContext):
    """Restore context through the current-target backend."""
    context_restore(ctx)

fn hal_context_init(entry: u64, stack: u64, arg: u64) -> ArchContext:
    """Create a new task context through the current-target backend."""
    context_init(entry, stack, arg)

