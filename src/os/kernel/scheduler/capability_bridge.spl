use os.kernel.types.task_types.{TaskId}

var g_scheduler_cap_task_ids: [u64] = []

pub fn cap_init_task_record(task: TaskId, full: bool):
    """Record scheduler-created task ids without requiring a runtime extern.

    The scheduler TCB owns the authoritative CapabilitySet for scheduling and
    process creation. The IPC CapabilityManager has explicit init paths for
    syscall capability checks. This bridge keeps scheduler creation pure Simple
    and idempotent where older split modules expected an extern hook.
    """
    var i = 0
    while i < g_scheduler_cap_task_ids.len():
        if g_scheduler_cap_task_ids[i] == task.id:
            return
        i = i + 1
    g_scheduler_cap_task_ids.push(task.id)

pub fn cap_task_record_count_for_test() -> i32:
    g_scheduler_cap_task_ids.len()

pub fn cap_clear_task_records_for_test():
    g_scheduler_cap_task_ids = []
