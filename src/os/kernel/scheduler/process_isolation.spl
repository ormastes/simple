# Process Isolation Levels — Scheduler Layer

# ============================================================================
# IsolationLevel
# ============================================================================

struct IsolationLevel:
    level_name: text
    level_ord: i64
    can_see_all_pids: bool
    can_access_host_fs: bool
    can_raw_net: bool
    can_load_modules: bool
    can_debug_others: bool

impl IsolationLevel:
    static fn none() -> IsolationLevel:
        IsolationLevel(level_name: "none", level_ord: 0, can_see_all_pids: true, can_access_host_fs: true, can_raw_net: true, can_load_modules: true, can_debug_others: true)

    static fn namespace() -> IsolationLevel:
        IsolationLevel(level_name: "namespace", level_ord: 1, can_see_all_pids: false, can_access_host_fs: true, can_raw_net: true, can_load_modules: true, can_debug_others: true)

    static fn container() -> IsolationLevel:
        IsolationLevel(level_name: "container", level_ord: 2, can_see_all_pids: false, can_access_host_fs: false, can_raw_net: false, can_load_modules: true, can_debug_others: false)

    static fn sandbox() -> IsolationLevel:
        IsolationLevel(level_name: "sandbox", level_ord: 3, can_see_all_pids: false, can_access_host_fs: false, can_raw_net: false, can_load_modules: false, can_debug_others: false)

    static fn from_name(name: text) -> IsolationLevel:
        if name == "none": return IsolationLevel.none()
        if name == "namespace": return IsolationLevel.namespace()
        if name == "container": return IsolationLevel.container()
        IsolationLevel.sandbox()

    me is_more_restrictive(other_ord: i64) -> bool:
        self.level_ord > other_ord

    me permits(capability: text) -> bool:
        if capability == "see_all_pids": return self.can_see_all_pids
        if capability == "host_fs": return self.can_access_host_fs
        if capability == "raw_net": return self.can_raw_net
        if capability == "load_modules": return self.can_load_modules
        if capability == "debug_others": return self.can_debug_others
        false

    me summary() -> text:
        "level=" + self.level_name + " ord=" + self.level_ord.to_text() +
        " pids=" + self.can_see_all_pids.to_text() +
        " host_fs=" + self.can_access_host_fs.to_text() +
        " raw_net=" + self.can_raw_net.to_text() +
        " modules=" + self.can_load_modules.to_text() +
        " debug=" + self.can_debug_others.to_text()

# ============================================================================
# ProcessIsolationPolicy
# ============================================================================

struct ProcessIsolationPolicy:
    pid: i64
    isolation: IsolationLevel
    granted_caps: text
    denied_caps: text
    parent_pid: i64
    inherit_isolation: bool

impl ProcessIsolationPolicy:
    static fn create(pid: i64, iso: IsolationLevel) -> ProcessIsolationPolicy:
        ProcessIsolationPolicy(pid: pid, isolation: iso, granted_caps: "", denied_caps: "", parent_pid: -1, inherit_isolation: false)

    me grant_cap(cap: text) -> text:
        if self.granted_caps == "": return cap
        self.granted_caps + "," + cap

    me deny_cap(cap: text) -> text:
        if self.denied_caps == "": return cap
        self.denied_caps + "," + cap

    me _contains(list: text, cap: text) -> bool:
        if list == "": return false
        if list == cap: return true
        if list.starts_with(cap + ","): return true
        if list.ends_with("," + cap): return true
        list.contains("," + cap + ",")

    me check_access(cap: text) -> text:
        if self._contains(self.denied_caps, cap): return "denied:" + cap
        if self._contains(self.granted_caps, cap): return ""
        if self.isolation.permits(cap): return ""
        "denied:" + cap

    me escalation_allowed(target_level: text) -> bool:
        var target = IsolationLevel.from_name(target_level)
        target.level_ord > self.isolation.level_ord

    me summary() -> text:
        "pid=" + self.pid.to_text() + " isolation=" + self.isolation.level_name +
        " granted=[" + self.granted_caps + "] denied=[" + self.denied_caps + "]" +
        " parent=" + self.parent_pid.to_text() + " inherit=" + self.inherit_isolation.to_text()

# ============================================================================
# IsolationEnforcer
# ============================================================================

struct IsolationEnforcer:
    violation_count: i64
    last_violation_pid: i64
    last_violation_cap: text

impl IsolationEnforcer:
    static fn create() -> IsolationEnforcer:
        IsolationEnforcer(violation_count: 0, last_violation_pid: -1, last_violation_cap: "")

    me enforce(policy: ProcessIsolationPolicy, requested_cap: text) -> text:
        var result = policy.check_access(requested_cap)
        if result == "": return ""
        self.violation_count = self.violation_count + 1
        self.last_violation_pid = policy.pid
        self.last_violation_cap = requested_cap
        "VIOLATION:" + policy.pid.to_text() + ":" + requested_cap

    me stats() -> text:
        "violations=" + self.violation_count.to_text() +
        " last_pid=" + self.last_violation_pid.to_text() +
        " last_cap=" + self.last_violation_cap

# ============================================================================
# NamespaceMapping
# ============================================================================

struct NamespaceMapping:
    ns_id: i64
    ns_type: text
    owner_pid: i64
    member_count: i64

impl NamespaceMapping:
    static fn create(id: i64, ns_type: text, owner: i64) -> NamespaceMapping:
        NamespaceMapping(ns_id: id, ns_type: ns_type, owner_pid: owner, member_count: 1)

    me add_member() -> i64:
        self.member_count = self.member_count + 1
        self.member_count

    me remove_member() -> i64:
        if self.member_count > 0: self.member_count = self.member_count - 1
        self.member_count

    me summary() -> text:
        "ns_id=" + self.ns_id.to_text() + " type=" + self.ns_type +
        " owner=" + self.owner_pid.to_text() + " members=" + self.member_count.to_text()

# ============================================================================
# NamespaceRegistry — flat, max 8 slots
# ============================================================================

struct NamespaceRegistry:
    count: i64
    next_id: i64
    n0_id: i64   n0_type: text   n0_owner: i64   n0_members: i64
    n1_id: i64   n1_type: text   n1_owner: i64   n1_members: i64
    n2_id: i64   n2_type: text   n2_owner: i64   n2_members: i64
    n3_id: i64   n3_type: text   n3_owner: i64   n3_members: i64
    n4_id: i64   n4_type: text   n4_owner: i64   n4_members: i64
    n5_id: i64   n5_type: text   n5_owner: i64   n5_members: i64
    n6_id: i64   n6_type: text   n6_owner: i64   n6_members: i64
    n7_id: i64   n7_type: text   n7_owner: i64   n7_members: i64

impl NamespaceRegistry:
    static fn create() -> NamespaceRegistry:
        NamespaceRegistry(
            count: 0, next_id: 1,
            n0_id: -1, n0_type: "", n0_owner: -1, n0_members: 0,
            n1_id: -1, n1_type: "", n1_owner: -1, n1_members: 0,
            n2_id: -1, n2_type: "", n2_owner: -1, n2_members: 0,
            n3_id: -1, n3_type: "", n3_owner: -1, n3_members: 0,
            n4_id: -1, n4_type: "", n4_owner: -1, n4_members: 0,
            n5_id: -1, n5_type: "", n5_owner: -1, n5_members: 0,
            n6_id: -1, n6_type: "", n6_owner: -1, n6_members: 0,
            n7_id: -1, n7_type: "", n7_owner: -1, n7_members: 0
        )

    me _id_at(slot: i64) -> i64:
        if slot == 0: return self.n0_id
        if slot == 1: return self.n1_id
        if slot == 2: return self.n2_id
        if slot == 3: return self.n3_id
        if slot == 4: return self.n4_id
        if slot == 5: return self.n5_id
        if slot == 6: return self.n6_id
        if slot == 7: return self.n7_id
        -1

    me _owner_at(slot: i64) -> i64:
        if slot == 0: return self.n0_owner
        if slot == 1: return self.n1_owner
        if slot == 2: return self.n2_owner
        if slot == 3: return self.n3_owner
        if slot == 4: return self.n4_owner
        if slot == 5: return self.n5_owner
        if slot == 6: return self.n6_owner
        if slot == 7: return self.n7_owner
        -1

    me _write_slot(slot: i64, id: i64, ns_type: text, owner: i64):
        if slot == 0: self.n0_id = id   self.n0_type = ns_type   self.n0_owner = owner   self.n0_members = 1
        if slot == 1: self.n1_id = id   self.n1_type = ns_type   self.n1_owner = owner   self.n1_members = 1
        if slot == 2: self.n2_id = id   self.n2_type = ns_type   self.n2_owner = owner   self.n2_members = 1
        if slot == 3: self.n3_id = id   self.n3_type = ns_type   self.n3_owner = owner   self.n3_members = 1
        if slot == 4: self.n4_id = id   self.n4_type = ns_type   self.n4_owner = owner   self.n4_members = 1
        if slot == 5: self.n5_id = id   self.n5_type = ns_type   self.n5_owner = owner   self.n5_members = 1
        if slot == 6: self.n6_id = id   self.n6_type = ns_type   self.n6_owner = owner   self.n6_members = 1
        if slot == 7: self.n7_id = id   self.n7_type = ns_type   self.n7_owner = owner   self.n7_members = 1

    me add(ns_type: text, owner: i64) -> i64:
        if self.count >= 8: return -1
        var slot = 0
        while slot < 8:
            if self._id_at(slot) == -1:
                var new_id = self.next_id
                self._write_slot(slot, new_id, ns_type, owner)
                self.count = self.count + 1
                self.next_id = self.next_id + 1
                return new_id
            slot = slot + 1
        -1

    me find_for_pid(pid: i64) -> i64:
        var slot = 0
        while slot < 8:
            if self._owner_at(slot) == pid:
                var found = self._id_at(slot)
                if found == -1:
                    slot = slot + 1
                    continue
                return found
            slot = slot + 1
        -1

    me stats() -> text:
        "count=" + self.count.to_text() + "/8 next_id=" + self.next_id.to_text()
