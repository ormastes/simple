# ARM/freestanding bootstrap user-task helper.
#
# Contains scheduler_create_bootstrap_user_task_pid, a module-level free
# function that avoids weak dot-method dispatch stubs on ARM freestanding
# builds. Callers import this file directly instead of scheduler.spl to
# avoid pulling in the full impl block just for this entry point.
#
# Split from scheduler.spl to keep the hub under 800 lines.

use os.kernel.types.task_types.{
    TaskId, TaskState, TaskPriority, TaskContext,
    UserProcessImage, AddressSpace,
    default_task_schedule, default_task_isolation,
    user_process_image_entry, user_process_image_stack_top,
    user_process_image_stack_size, user_process_image_segments,
    user_process_image_file_bytes, user_process_image_initial_sp,
    user_process_image_initial_stack_bytes
}
use os.kernel.types.capability_types.{CapabilitySet}
use os.kernel.memory.user_address_space.{create_user_address_space, destroy_user_address_space}
use os.kernel.loader.segment_mapper.{verify_direct_load_entry}
use os.kernel.scheduler.scheduler_types.{
    TaskControlBlock, TIME_SLICE_TICKS,
    _address_space_can_map, _scheduler_mapped_entry,
    _map_user_process_image, _initial_user_task_context,
    _priority_to_index,
    Scheduler, SchedulerBootstrapUserTaskResult,
    scheduler_next_task_id_take
}

extern fn cap_init_task_record(task: TaskId, full: bool)
extern fn serial_println(msg: text)

@cfg(arm64)
extern fn rt_arm64_record_user_handoff(entry: u64, sp: u64, ttbr0_root: u64)

@cfg(arm64)
fn _record_bootstrap_user_handoff(entry: u64, sp: u64, ttbr0_root: u64):
    rt_arm64_record_user_handoff(entry, sp, ttbr0_root)

@cfg(arm32)
fn _record_bootstrap_user_handoff(entry: u64, sp: u64, ttbr0_root: u64):
    val _entry = entry
    val _sp = sp
    val _ttbr0_root = ttbr0_root

@cfg(riscv64)
fn _record_bootstrap_user_handoff(entry: u64, sp: u64, ttbr0_root: u64):
    val _entry = entry
    val _sp = sp
    val _ttbr0_root = ttbr0_root

@cfg(riscv32)
fn _record_bootstrap_user_handoff(entry: u64, sp: u64, ttbr0_root: u64):
    val _entry = entry
    val _sp = sp
    val _ttbr0_root = ttbr0_root

@cfg(x86_64)
fn _record_bootstrap_user_handoff(entry: u64, sp: u64, ttbr0_root: u64):
    val _entry = entry
    val _sp = sp
    val _ttbr0_root = ttbr0_root

@cfg(x86)
fn _record_bootstrap_user_handoff(entry: u64, sp: u64, ttbr0_root: u64):
    val _entry = entry
    val _sp = sp
    val _ttbr0_root = ttbr0_root

pub fn scheduler_create_bootstrap_user_task_pid(
    scheduler_in: Scheduler,
    image: UserProcessImage,
    priority: TaskPriority,
    caps: CapabilitySet
) -> SchedulerBootstrapUserTaskResult:
    """ARM fs-exec helper that avoids weak dot-method dispatch stubs."""
    var scheduler = scheduler_in
    if scheduler.tasks[0] != nil:
        serial_println("[scheduler-arm] slot-busy")
        return SchedulerBootstrapUserTaskResult(scheduler: scheduler, pid: 0)
    val entry = user_process_image_entry(image)
    val stack_top = user_process_image_stack_top(image)
    val stack_size = user_process_image_stack_size(image)
    val user_sp = user_process_image_initial_sp(image) & 0xFFFFFFFFFFFFFFF0
    val initial_stack_bytes = user_process_image_initial_stack_bytes(image)
    val segments = user_process_image_segments(image)
    val file_bytes = user_process_image_file_bytes(image)
    serial_println("[scheduler-arm] image entry={entry} stack_top={stack_top}")
    if stack_top == 0 or stack_size == 0 or user_sp == 0:
        serial_println("[scheduler-arm] invalid-image")
        return SchedulerBootstrapUserTaskResult(scheduler: scheduler, pid: 0)
    if (initial_stack_bytes.len() as u64) > stack_size:
        serial_println("[scheduler-arm] initial-stack-too-large")
        return SchedulerBootstrapUserTaskResult(scheduler: scheduler, pid: 0)
    val user_as: AddressSpace = create_user_address_space()
    serial_println("[scheduler-arm] address-space root={user_as.phys_root} id={user_as.id}")
    val map_result = if _address_space_can_map(user_as):
        _map_user_process_image(user_as, segments, file_bytes, stack_top, stack_size, initial_stack_bytes)
    else:
        0
    if map_result < 0:
        destroy_user_address_space(user_as)
        serial_println("[scheduler-arm] map-failed")
        return SchedulerBootstrapUserTaskResult(scheduler: scheduler, pid: 0)
    val mapped_entry = _scheduler_mapped_entry(user_as, file_bytes, entry)
    serial_println("[scheduler-arm] mapped-entry={mapped_entry}")
    if mapped_entry != entry:
        if not verify_direct_load_entry(user_as, file_bytes, entry):
            destroy_user_address_space(user_as)
            return SchedulerBootstrapUserTaskResult(scheduler: scheduler, pid: 0)
    val user_ctx = _initial_user_task_context(mapped_entry, user_sp)
    val user_next_id = scheduler_next_task_id_take()
    val id = TaskId(id: user_next_id)
    serial_println("[scheduler-arm] pid={user_next_id}")
    val tcb = TaskControlBlock(
        id: id, name: "bootstrap-user",
        state: TaskState.Ready, priority: priority, is_user: true,
        entry_point: mapped_entry, context: user_ctx, user_context: Some(user_ctx),
        address_space: user_as.phys_root, kernel_stack: 0, user_stack: stack_top,
        capabilities: caps, parent: nil,
        schedule: default_task_schedule(priority),
        isolation: default_task_isolation(user_as.id),
        assigned_cpu: 0u32, exit_code: 0, ticks_remaining: TIME_SLICE_TICKS
    )
    scheduler.tasks[0] = tcb
    _record_bootstrap_user_handoff(mapped_entry, user_sp, user_as.phys_root)
    cap_init_task_record(id, true)
    val queue_idx = _priority_to_index(priority)
    serial_println("[scheduler-arm] queue-idx={queue_idx}")
    scheduler.ready_queues[queue_idx].enqueue(id)
    val cpu = 0u32
    scheduler.cpu_runqueues[cpu as i64].enqueue(id, tcb.schedule)
    serial_println("[scheduler-arm] success pid={user_next_id}")
    SchedulerBootstrapUserTaskResult(scheduler: scheduler, pid: user_next_id)
