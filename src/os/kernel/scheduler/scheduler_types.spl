# Scheduler Supporting Types — structs, ready queues, CPU run queues,
# and architecture-specific context helpers.
#
# Split from scheduler.spl to keep the hub file under 800 lines.

use os.kernel.types.task_types.{
    TaskId, TaskState, TaskPriority, TaskContext, BlockReason,
    UserProcessImage, AddressSpace,
    SchedulerPolicy, TaskScheduleConfig, TaskIsolationProfile,
    SchedulerTopology,
    scheduler_flat_topology,
    scheduler_detect_platform_topology, default_task_schedule, default_task_isolation,
    user_process_image_entry, user_process_image_stack_top,
    user_process_image_stack_size, user_process_image_segments,
    user_process_image_file_bytes, user_process_image_initial_sp,
    user_process_image_initial_stack_bytes
}
use os.kernel.types.capability_types.{CapabilitySet}
use os.kernel.arch.arch_context.{Architecture}
use os.kernel.memory.user_address_space.{create_user_address_space, destroy_user_address_space}
use os.kernel.loader.segment_mapper.{map_all, map_stack, stage_raw_image, stage_elf64_load_image, direct_load_entry_point, verify_direct_load_entry}
use os.kernel.log.klog_api.{log_raw_println}
use os.kernel.scheduler.green_carrier.{GreenCarrierExecutionState, GreenCarrierParallelismState}

# ============================================================================
# Configuration
# ============================================================================

pub val MAX_TASKS: i32 = 256
pub val PRIORITY_LEVELS: i32 = 5      # Realtime, High, Normal, Low, Idle
pub val TIME_SLICE_TICKS: u64 = 10    # Ticks per time slice before preemption
pub val SCHED_TICK_NS: u64 = 10000000 # Accounting tick used by fair scheduling
pub val DEADLINE_BANDWIDTH_SCALE: u64 = 1000000
pub val DEADLINE_CPU_BANDWIDTH_CAP: u64 = 800000
pub val DEFAULT_SCHED_CPUS: u32 = 32u32
pub val SCHED_TRACE_CAPACITY: i32 = 128
pub val SCHED_RT_BASE_PRIORITY_UNSET: i64 = 9223372036854775807

# Module-level task-id counter shared across all task-creation paths.
var g_scheduler_next_task_id: u64 = 1

pub fn scheduler_next_task_id_take() -> u64:
    var next_id = g_scheduler_next_task_id
    if next_id == 0 or next_id >= 0x40000000:
        log_raw_println("[scheduler] create_task: normalized next_task_id")
        next_id = 1
    g_scheduler_next_task_id = next_id + 1
    next_id

@cfg(x86_64)
pub fn sched_exec_arch() -> Architecture:
    Architecture.X86_64

@cfg(x86)
pub fn sched_exec_arch() -> Architecture:
    Architecture.X86

@cfg(arm64)
pub fn sched_exec_arch() -> Architecture:
    Architecture.Arm64

@cfg(arm32)
pub fn sched_exec_arch() -> Architecture:
    Architecture.Arm32

@cfg(riscv64)
pub fn sched_exec_arch() -> Architecture:
    Architecture.Riscv64

@cfg(riscv32)
pub fn sched_exec_arch() -> Architecture:
    Architecture.Riscv32

# ============================================================================
# Task Control Block
# ============================================================================

@repr("C")
pub struct TaskControlBlock:
    """Full task state held by the scheduler."""
    id: TaskId
    name: text
    state: TaskState
    priority: TaskPriority
    is_user: bool
    entry_point: u64
    context: TaskContext
    user_context: TaskContext?
    address_space: u64
    kernel_stack: u64
    user_stack: u64
    capabilities: CapabilitySet
    parent: TaskId?
    schedule: TaskScheduleConfig
    isolation: TaskIsolationProfile
    assigned_cpu: u32
    exit_code: i32
    ticks_remaining: u64

pub struct WaitCollectResult:
    """Result of collecting child exit state for waitpid-compatible syscalls."""
    pid: u64
    status: i32
    error: i32

pub fn wait_collect_result_pid(result: WaitCollectResult) -> u64:
    result.pid

pub fn wait_collect_result_status(result: WaitCollectResult) -> i32:
    result.status

pub fn wait_collect_result_error(result: WaitCollectResult) -> i32:
    result.error

pub fn task_control_pid(task: TaskControlBlock) -> u64:
    task.id.id

pub fn task_control_parent_pid(task: TaskControlBlock) -> u64:
    if task.parent == nil:
        return 0
    task.parent.unwrap().id

pub fn task_control_memory_pages(task: TaskControlBlock) -> u64:
    if task.address_space == 0:
        return 0
    1

pub fn task_control_name(task: TaskControlBlock) -> text:
    task.name

pub fn task_control_state_code(task: TaskControlBlock) -> u8:
    match task.state:
        case TaskState.Ready: 0u8
        case TaskState.Running: 1u8
        case TaskState.Blocked(reason): 2u8
        case TaskState.Zombie: 3u8

pub fn task_control_priority_code(task: TaskControlBlock) -> u8:
    match task.priority:
        case TaskPriority.Realtime: 0u8
        case TaskPriority.High: 1u8
        case TaskPriority.Normal: 2u8
        case TaskPriority.Low: 3u8
        case TaskPriority.Idle: 4u8

pub fn task_control_ticks_remaining(task: TaskControlBlock) -> u64:
    task.ticks_remaining

pub enum SchedulerPreemptionReason:
    """Reason a wakeup requests cross-task preemption."""
    None
    EarlierVirtualDeadline
    HigherSchedulerClass
    IdlePull

pub struct SchedulerPreemptionDecision:
    """Result returned by CPU-aware unblock paths."""
    should_preempt: bool
    cpu: u32
    task: TaskId
    reason: SchedulerPreemptionReason

pub enum SchedulerTraceKind:
    """Bounded scheduler trace event classes."""
    DeadlineAdmit
    DeadlineReplenish
    DeadlineOverrun
    DeadlineMiss
    RtThrottle
    WakePreempt
    IdlePull

pub struct SchedulerTraceEvent:
    """One compact scheduler diagnostic event."""
    tick: u64
    task: TaskId
    cpu: u32
    kind: SchedulerTraceKind
    value: u64

pub struct PiMutex:
    """Small scheduler-owned priority-inheritance mutex used by RT tests."""
    owner: TaskId?
    waiters: [TaskId]

impl PiMutex:
    static fn new() -> PiMutex:
        PiMutex(owner: nil, waiters: [])

# ============================================================================
# Arch helpers
# ============================================================================

pub fn _address_space_can_map(space: AddressSpace) -> bool:
    """Return true when the VMM handed us a real page-table root."""
    space.phys_root != 0 and space.phys_root != 1

@cfg(arm64)
pub fn _scheduler_uses_direct_load_arena() -> bool:
    true

@cfg(arm32)
pub fn _scheduler_uses_direct_load_arena() -> bool:
    false

@cfg(riscv64)
pub fn _scheduler_uses_direct_load_arena() -> bool:
    false

@cfg(riscv32)
pub fn _scheduler_uses_direct_load_arena() -> bool:
    false

@cfg(x86_64)
pub fn _scheduler_uses_direct_load_arena() -> bool:
    false

@cfg(x86)
pub fn _scheduler_uses_direct_load_arena() -> bool:
    false

@cfg(arm64)
pub fn _scheduler_mapped_entry(user_as: AddressSpace, file_bytes: [u8], entry: u64) -> u64:
    direct_load_entry_point(user_as, file_bytes, entry)

@cfg(arm32)
pub fn _scheduler_mapped_entry(user_as: AddressSpace, file_bytes: [u8], entry: u64) -> u64:
    val _user_as = user_as
    val _file_bytes = file_bytes
    entry

@cfg(riscv64)
pub fn _scheduler_mapped_entry(user_as: AddressSpace, file_bytes: [u8], entry: u64) -> u64:
    val _user_as = user_as
    val _file_bytes = file_bytes
    entry

@cfg(riscv32)
pub fn _scheduler_mapped_entry(user_as: AddressSpace, file_bytes: [u8], entry: u64) -> u64:
    val _user_as = user_as
    val _file_bytes = file_bytes
    entry

@cfg(x86_64)
pub fn _scheduler_mapped_entry(user_as: AddressSpace, file_bytes: [u8], entry: u64) -> u64:
    val _user_as = user_as
    val _file_bytes = file_bytes
    entry

@cfg(x86)
pub fn _scheduler_mapped_entry(user_as: AddressSpace, file_bytes: [u8], entry: u64) -> u64:
    val _user_as = user_as
    val _file_bytes = file_bytes
    entry

pub fn _map_user_process_image(
    space: AddressSpace,
    segments: [UserLoadSegment],
    file_bytes: [u8],
    stack_top: u64,
    stack_size: u64,
    initial_stack_bytes: [u8]
) -> i32:
    """Map PT_LOAD segments and the initial stack for a user process image."""
    if not _address_space_can_map(space):
        log_raw_println("[scheduler] map_user_process_image: synthetic address space root={space.phys_root} id={space.id}")
        return 0
    if _scheduler_uses_direct_load_arena():
        var staged = stage_elf64_load_image(space, file_bytes)
        if staged <= 0:
            staged = stage_raw_image(space, file_bytes)
        if staged <= 0:
            log_raw_println("[scheduler] map_user_process_image: arm64 direct-load stage failed root={space.phys_root}")
            return -12
        log_raw_println("[scheduler] map_user_process_image: arm64 direct-load ok root={space.phys_root} staged={staged} id={space.id}")
        return 0
    if stack_top == 0 or stack_size == 0:
        log_raw_println("[scheduler] map_user_process_image: invalid stack shape")
        return -22
    if (initial_stack_bytes.len() as u64) > stack_size:
        log_raw_println("[scheduler] map_user_process_image: initial stack too large")
        return -22

    val seg_result = map_all(space, segments, file_bytes)
    if seg_result.is_err():
        log_raw_println("[scheduler] map_user_process_image: segment map failed root={space.phys_root}")
        return -12
    val stack_result = map_stack(space, stack_top, stack_size, initial_stack_bytes)
    if stack_result.is_err():
        log_raw_println("[scheduler] map_user_process_image: stack map failed")
        return -12
    0

pub fn scheduler_user_context_for_arch(arch: Architecture, entry: u64, user_sp: u64) -> TaskContext:
    """Create the scheduler's portable user-context record for an architecture."""
    val x86_stack = user_sp & 0xFFFFFFFFFFFFFFF0
    val arm32_stack = user_sp & 0xFFFFFFF8
    match arch:
        case Architecture.Arm64:
            TaskContext(
                rax: 0, rbx: 0,
                rcx: 0, rdx: 0,
                rsi: 0, rdi: 0,
                rbp: 0, rsp: user_sp,
                r8: 0, r9: 0,
                r10: 0, r11: 0,
                r12: 0, r13: 0,
                r14: 0, r15: 0,
                rip: entry,
                rflags: 0,
                cs: 0,
                ss: 0,
                fpu_state: 0
            )
        case Architecture.Arm32:
            TaskContext(
                rax: 0, rbx: 0,
                rcx: 0, rdx: 0,
                rsi: 0, rdi: 0,
                rbp: 0, rsp: arm32_stack,
                r8: 0, r9: 0,
                r10: 0, r11: 0,
                r12: 0, r13: arm32_stack,
                r14: entry, r15: entry,
                rip: entry,
                rflags: 0x10,
                cs: 0,
                ss: 0,
                fpu_state: 0
            )
        case Architecture.Riscv64:
            TaskContext(
                rax: 0, rbx: 0,
                rcx: 0, rdx: 0,
                rsi: 0, rdi: 0,
                rbp: 0, rsp: user_sp,
                r8: 0, r9: 0,
                r10: 0, r11: 0,
                r12: 0, r13: 0,
                r14: 0, r15: 0,
                rip: entry,
                rflags: 0,
                cs: 0,
                ss: 0,
                fpu_state: 0
            )
        case Architecture.Riscv32:
            TaskContext(
                rax: 0, rbx: 0,
                rcx: 0, rdx: 0,
                rsi: 0, rdi: 0,
                rbp: 0, rsp: user_sp,
                r8: 0, r9: 0,
                r10: 0, r11: 0,
                r12: 0, r13: 0,
                r14: 0, r15: 0,
                rip: entry,
                rflags: 0,
                cs: 0,
                ss: 0,
                fpu_state: 0
            )
        case Architecture.X86_64:
            TaskContext(
                rax: 0, rbx: 0,
                rcx: 0, rdx: 0,
                rsi: 0, rdi: 0,
                rbp: x86_stack, rsp: x86_stack,
                r8: 0, r9: 0,
                r10: 0, r11: 0,
                r12: 0, r13: 0,
                r14: 0, r15: 0,
                rip: entry,
                rflags: 0x202,
                cs: 0x2B,
                ss: 0x23,
                fpu_state: 0
            )
        case Architecture.X86:
            TaskContext(
                rax: 0, rbx: 0,
                rcx: 0, rdx: 0,
                rsi: 0, rdi: 0,
                rbp: x86_stack, rsp: x86_stack,
                r8: 0, r9: 0,
                r10: 0, r11: 0,
                r12: 0, r13: 0,
                r14: 0, r15: 0,
                rip: entry,
                rflags: 0x202,
                cs: 0x1B,
                ss: 0x23,
                fpu_state: 0
            )

pub fn _initial_user_task_context(entry: u64, user_sp: u64) -> TaskContext:
    scheduler_user_context_for_arch(sched_exec_arch(), entry: entry, user_sp: user_sp)

# ============================================================================
# Ready Queue — Per-Priority FIFO
# ============================================================================

pub struct ReadyQueue:
    """Per-priority FIFO queue of task IDs."""
    entries: [u64]
    head: i32
    tail: i32
    count: i32
    capacity: i32

impl ReadyQueue:
    static fn new() -> ReadyQueue:
        """Create an empty ready queue."""
        var entries: [u64] = []
        var i = 0
        while i < MAX_TASKS:
            entries.push(0)
            i = i + 1
        ReadyQueue(
            entries: entries,
            head: 0,
            tail: 0,
            count: 0,
            capacity: MAX_TASKS
        )

    me enqueue(task_id: TaskId):
        if self.count >= self.capacity:
            return
        self.entries[self.tail] = task_id.id
        self.tail = (self.tail + 1) % self.capacity
        self.count = self.count + 1

    me dequeue() -> TaskId?:
        if self.count == 0:
            return nil
        val id_val = self.entries[self.head]
        self.head = (self.head + 1) % self.capacity
        self.count = self.count - 1
        TaskId(id: id_val)

    me remove(task_id: TaskId):
        var new_entries: [u64] = []
        var i = 0
        while i < MAX_TASKS:
            new_entries.push(0)
            i = i + 1
        var new_tail = 0
        var scan = self.head
        var scanned = 0
        while scanned < self.count:
            val idx = scan % self.capacity
            val entry_id = self.entries[idx]
            if entry_id != task_id.id:
                new_entries[new_tail] = entry_id
                new_tail = new_tail + 1
            scan = scan + 1
            scanned = scanned + 1
        self.entries = new_entries
        self.head = 0
        self.tail = new_tail
        self.count = new_tail

    fn is_empty() -> bool:
        self.count == 0

    fn len() -> i32:
        self.count

# ============================================================================
# Per-CPU Run Queue
# ============================================================================

pub struct CpuRunQueue:
    """Per-CPU run queues separated by scheduler class."""
    cpu_id: u32
    deadline_queue: ReadyQueue
    rt_queue: ReadyQueue
    fair_queue: ReadyQueue
    background_queue: ReadyQueue
    idle_queue: ReadyQueue
    runnable_count: i32
    weighted_load: i64
    latency_debt: i64
    migration_pressure: i64
    cache_hot_wakeups: u64

impl CpuRunQueue:
    static fn new(cpu_id: u32) -> CpuRunQueue:
        CpuRunQueue(
            cpu_id: cpu_id,
            deadline_queue: ReadyQueue.new(),
            rt_queue: ReadyQueue.new(),
            fair_queue: ReadyQueue.new(),
            background_queue: ReadyQueue.new(),
            idle_queue: ReadyQueue.new(),
            runnable_count: 0,
            weighted_load: 0,
            latency_debt: 0,
            migration_pressure: 0,
            cache_hot_wakeups: 0
        )

    me enqueue(task_id: TaskId, config: TaskScheduleConfig):
        match config.policy:
            case Deadline:
                self.deadline_queue.enqueue(task_id)
            case RtFifo:
                self.rt_queue.enqueue(task_id)
            case RtRoundRobin:
                self.rt_queue.enqueue(task_id)
            case Background:
                self.background_queue.enqueue(task_id)
            case Idle:
                self.idle_queue.enqueue(task_id)
            case Internal:
                self.rt_queue.enqueue(task_id)
            case Fair:
                self.fair_queue.enqueue(task_id)
        self.runnable_count = self.runnable_count + 1
        self.weighted_load = self.weighted_load + config.weight

    me remove(task_id: TaskId, config: TaskScheduleConfig):
        val before = (
            self.deadline_queue.count + self.rt_queue.count +
            self.fair_queue.count + self.background_queue.count +
            self.idle_queue.count
        )
        self.deadline_queue.remove(task_id)
        self.rt_queue.remove(task_id)
        self.fair_queue.remove(task_id)
        self.background_queue.remove(task_id)
        self.idle_queue.remove(task_id)
        val after = (
            self.deadline_queue.count + self.rt_queue.count +
            self.fair_queue.count + self.background_queue.count +
            self.idle_queue.count
        )
        if after < before and self.runnable_count > 0:
            self.runnable_count = self.runnable_count - 1
            if self.weighted_load >= config.weight:
                self.weighted_load = self.weighted_load - config.weight
            else:
                self.weighted_load = 0

# ============================================================================
# Priority Mapping helpers
# ============================================================================

pub fn _priority_to_index(priority: TaskPriority) -> i32:
    """Map TaskPriority enum to ready queue index (0 = highest)."""
    match priority:
        case Realtime: 0
        case High: 1
        case Normal: 2
        case Low: 3
        case Idle: 4

pub fn _affinity_allows_cpu(mask: u64, cpu: u32) -> bool:
    """Return true when an affinity mask permits a CPU id."""
    if mask == 0:
        return true
    if cpu >= 64u32:
        return false
    val bit = 1u64 << cpu
    (mask & bit) != 0

pub fn _deadline_util(runtime_ns: u64, period_ns: u64) -> u64:
    """Convert runtime/period into fixed-point deadline bandwidth."""
    if period_ns == 0:
        return 0
    (runtime_ns * DEADLINE_BANDWIDTH_SCALE) / period_ns

pub fn _account_task_tick(task: TaskControlBlock) -> TaskControlBlock:
    """Advance fair/background virtual runtime for one scheduler tick."""
    match task.schedule.policy:
        case Fair:
            _account_fair_tick(task)
        case Background:
            _account_fair_tick(task)
        case _:
            task

pub fn _account_fair_tick(task: TaskControlBlock) -> TaskControlBlock:
    """Apply simple weighted vruntime accounting for a fair-class tick."""
    var updated = task
    var config = updated.schedule
    val weight = if config.weight > 0: config.weight else: 1
    val scaled_delta = ((SCHED_TICK_NS as i64) * 1024) / weight
    config.vruntime = config.vruntime + scaled_delta
    config.virtual_deadline = config.vruntime + config.requested_slice_ns.to_i64()
    if config.lag > 0:
        if config.lag > scaled_delta:
            config.lag = config.lag - scaled_delta
        else:
            config.lag = 0
    updated.schedule = config
    updated

# ============================================================================
# Scheduler struct and bootstrap result
# (Defined here so scheduler_exec.spl and scheduler_arm_bootstrap.spl can
#  import Scheduler without a circular dependency on scheduler.spl.)
# ============================================================================

pub class Scheduler:
    """Priority-based preemptive scheduler."""
    tasks: [TaskControlBlock?]
    current: TaskId
    current_by_cpu: [TaskId]
    preempt_pending_by_cpu: [TaskId?]
    ready_queues: [ReadyQueue]
    cpu_runqueues: [CpuRunQueue]
    topology: SchedulerTopology
    rt_runtime_ns_by_cpu: [u64]
    rt_period_ns_by_cpu: [u64]
    rt_consumed_ns_by_cpu: [u64]
    rt_replenish_ns_by_cpu: [u64]
    rt_throttled_by_cpu: [bool]
    deadline_remaining_ns_by_slot: [u64]
    deadline_period_start_ns_by_slot: [u64]
    deadline_miss_count_by_slot: [u64]
    deadline_overrun_count_by_slot: [u64]
    rt_base_priority_by_slot: [i64]
    trace_events: [SchedulerTraceEvent]
    trace_head: i32
    trace_count: i32
    tick_count: u64
    next_task_id: u64
    green_execution_state: GreenCarrierExecutionState
    green_parallelism_state: GreenCarrierParallelismState

pub struct SchedulerBootstrapUserTaskResult:
    scheduler: Scheduler
    pid: u64
