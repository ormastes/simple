# SimpleOS Green Carrier Bridge Contract
#
# Pure scheduler-facing bridge from logical green tasks to SimpleOS carrier
# run-queue enqueue and remote wake intent. This module deliberately records
# decisions only; concrete run-queue insertion and APIC/IPI delivery remain in
# the lower scheduler and SMP layers.

use os.kernel.scheduler.green_task.{
    green_task_new,
    green_task_unpark,
    green_task_is_runnable,
    green_task_is_parked,
    green_task_is_done,
    GreenTaskRecord
}
use os.kernel.types.task_types.{TaskId}
use os.kernel.smp.smp.{smp_send_ipi}

pub val GREEN_CARRIER_RESCHEDULE_IPI: u32 = 0x1u32

pub struct GreenCarrierEnqueueDecision:
    """Run-queue enqueue and wake intent for a logical green task."""
    task: GreenTaskRecord
    target_cpu: i64
    should_enqueue: bool
    should_send_ipi: bool
    ipi_reason: text
    reason: text

pub struct GreenCarrierRunQueueState:
    """Concrete SimpleOS green-task queue state keyed by carrier CPU."""
    queued_task_ids: [i64]
    queued_cpus: [i64]
    queue_depth_by_cpu: [i64]
    capacity: i64
    dropped_count: i64

pub struct GreenCarrierApplyResult:
    """Result of applying a carrier enqueue decision to queue and SMP state."""
    queues: GreenCarrierRunQueueState
    decision: GreenCarrierEnqueueDecision
    enqueued: bool
    ipi_sent: bool
    ipi_reason_mask: u32
    reason: text

pub struct GreenCarrierDispatchResult:
    """Result of selecting queued green work for a carrier CPU."""
    queues: GreenCarrierRunQueueState
    task_id: i64
    cpu: i64
    dispatched: bool
    reason: text

pub struct GreenCarrierSchedulerIntent:
    """Typed scheduler-facing intent produced from green carrier dispatch."""
    task: TaskId
    cpu: u32
    should_run: bool
    should_context_switch: bool
    reason: text

pub struct GreenCarrierExecutionState:
    """Scheduler-visible execution state for green carrier CPUs."""
    current_task_by_cpu: [u64]
    context_switches_by_cpu: [i64]
    total_context_switches: i64
    rejected_intents: i64

pub struct GreenCarrierExecutionResult:
    """Result of applying scheduler intent to green execution state."""
    state: GreenCarrierExecutionState
    task: TaskId
    cpu: u32
    applied: bool
    reason: text

pub struct GreenCarrierFixedStepResult:
    """Freestanding-safe one-step green carrier result for fixed CPU slots."""
    task_id: i64
    target_cpu: i64
    enqueued: bool
    ipi_sent: bool
    ipi_reason_mask: u32
    dispatched: bool
    current_task: u64
    context_switches: i64
    total_context_switches: i64

fn green_carrier_fixed_cpu_allowed(affinity_mask: i64, cpu: i64) -> bool:
    if cpu < 0:
        false
    elif affinity_mask == 0:
        true
    else:
        (affinity_mask & (1 << cpu)) != 0

fn green_carrier_fixed_load_for_cpu(cpu: i64, load0: i64, load1: i64, load2: i64, load3: i64) -> i64:
    if cpu == 0:
        load0
    elif cpu == 1:
        load1
    elif cpu == 2:
        load2
    elif cpu == 3:
        load3
    else:
        0

fn green_carrier_fixed_normalized_cpu_count(cpu_count: i64) -> i64:
    if cpu_count < 1:
        1
    elif cpu_count > 4:
        4
    else:
        cpu_count

fn green_carrier_fixed_first_allowed_cpu(cpu_count: i64, affinity_mask: i64) -> i64:
    if cpu_count > 0 and green_carrier_fixed_cpu_allowed(affinity_mask, 0):
        0
    elif cpu_count > 1 and green_carrier_fixed_cpu_allowed(affinity_mask, 1):
        1
    elif cpu_count > 2 and green_carrier_fixed_cpu_allowed(affinity_mask, 2):
        2
    elif cpu_count > 3 and green_carrier_fixed_cpu_allowed(affinity_mask, 3):
        3
    else:
        0

pub fn green_carrier_fixed_spawn_cpu(cpu_count: i64, affinity_mask: i64, load0: i64, load1: i64, load2: i64, load3: i64) -> i64:
    """Pick a green carrier CPU without heap/text state for freestanding guests."""
    val normalized_cpu_count = green_carrier_fixed_normalized_cpu_count(cpu_count)
    var best_cpu = green_carrier_fixed_first_allowed_cpu(normalized_cpu_count, affinity_mask)
    var best_load = green_carrier_fixed_load_for_cpu(best_cpu, load0, load1, load2, load3)
    var candidate = 1
    while candidate < normalized_cpu_count:
        val candidate_load = green_carrier_fixed_load_for_cpu(candidate, load0, load1, load2, load3)
        if green_carrier_fixed_cpu_allowed(affinity_mask, candidate) and candidate_load < best_load:
            best_cpu = candidate
            best_load = candidate_load
        candidate = candidate + 1
    best_cpu

pub fn green_carrier_fixed_run_task(task_id: i64, cpu_count: i64, affinity_mask: i64, load0: i64, load1: i64, load2: i64, load3: i64, current_cpu: i64) -> GreenCarrierFixedStepResult:
    """Run one fixed-slot green carrier enqueue/dispatch step without heap use."""
    val target_cpu = green_carrier_fixed_spawn_cpu(cpu_count, affinity_mask, load0, load1, load2, load3)
    val should_ipi = green_carrier_should_send_ipi(current_cpu, target_cpu, true)
    val ipi_sent = if should_ipi: smp_send_ipi(target_cpu as u32, GREEN_CARRIER_RESCHEDULE_IPI) else: false
    GreenCarrierFixedStepResult(
        task_id: task_id,
        target_cpu: target_cpu,
        enqueued: true,
        ipi_sent: ipi_sent,
        ipi_reason_mask: if ipi_sent: GREEN_CARRIER_RESCHEDULE_IPI else: 0u32,
        dispatched: true,
        current_task: task_id as u64,
        context_switches: 1,
        total_context_switches: 1
    )

pub fn green_carrier_should_send_ipi(current_cpu: i64, target_cpu: i64, should_enqueue: bool) -> bool:
    """Request a wake IPI only for remote runnable enqueue decisions."""
    should_enqueue and target_cpu != current_cpu

fn green_carrier_ipi_reason(current_cpu: i64, target_cpu: i64, should_enqueue: bool) -> text:
    if green_carrier_should_send_ipi(current_cpu, target_cpu, should_enqueue):
        "remote_reschedule"
    else:
        ""

fn green_carrier_enqueue_reason(current_cpu: i64, target_cpu: i64) -> text:
    if target_cpu == current_cpu:
        "local_run_queue"
    else:
        "remote_run_queue"

fn green_carrier_decision(task: GreenTaskRecord, target_cpu: i64, should_enqueue: bool, current_cpu: i64, reason: text) -> GreenCarrierEnqueueDecision:
    GreenCarrierEnqueueDecision(
        task: task,
        target_cpu: target_cpu,
        should_enqueue: should_enqueue,
        should_send_ipi: green_carrier_should_send_ipi(current_cpu, target_cpu, should_enqueue),
        ipi_reason: green_carrier_ipi_reason(current_cpu, target_cpu, should_enqueue),
        reason: reason
    )

fn green_carrier_normalized_cpu_count(cpu_count: i64) -> i64:
    if cpu_count < 1:
        1
    elif cpu_count > 32:
        32
    else:
        cpu_count

pub fn green_carrier_run_queues_new(cpu_count: i64, capacity: i64) -> GreenCarrierRunQueueState:
    """Create bounded carrier queues for scheduler-visible green tasks."""
    val normalized_cpu_count = green_carrier_normalized_cpu_count(cpu_count)
    var queue_depth_by_cpu: [i64] = []
    var i = 0
    while i < normalized_cpu_count:
        queue_depth_by_cpu.push(0)
        i = i + 1
    GreenCarrierRunQueueState(
        queued_task_ids: [],
        queued_cpus: [],
        queue_depth_by_cpu: queue_depth_by_cpu,
        capacity: if capacity < 1: 1 else: capacity,
        dropped_count: 0
    )

pub fn green_carrier_queue_depth(queues: GreenCarrierRunQueueState, cpu: i64) -> i64:
    """Return the number of green tasks queued for a carrier CPU."""
    if cpu < 0 or cpu >= queues.queue_depth_by_cpu.len():
        0
    else:
        queues.queue_depth_by_cpu[cpu]

fn green_carrier_queue_push(queues: GreenCarrierRunQueueState, task_id: i64, cpu: i64) -> GreenCarrierRunQueueState:
    if cpu < 0 or cpu >= queues.queue_depth_by_cpu.len():
        GreenCarrierRunQueueState(
            queued_task_ids: queues.queued_task_ids,
            queued_cpus: queues.queued_cpus,
            queue_depth_by_cpu: queues.queue_depth_by_cpu,
            capacity: queues.capacity,
            dropped_count: queues.dropped_count + 1
        )
    elif queues.queued_task_ids.len() >= queues.capacity:
        GreenCarrierRunQueueState(
            queued_task_ids: queues.queued_task_ids,
            queued_cpus: queues.queued_cpus,
            queue_depth_by_cpu: queues.queue_depth_by_cpu,
            capacity: queues.capacity,
            dropped_count: queues.dropped_count + 1
        )
    else:
        var queued_task_ids = queues.queued_task_ids
        var queued_cpus = queues.queued_cpus
        queued_task_ids.push(task_id)
        queued_cpus.push(cpu)
        GreenCarrierRunQueueState(
            queued_task_ids: queued_task_ids,
            queued_cpus: queued_cpus,
            queue_depth_by_cpu: green_carrier_increment_queue_depth(queues.queue_depth_by_cpu, cpu),
            capacity: queues.capacity,
            dropped_count: queues.dropped_count
        )

fn green_carrier_increment_queue_depth(queue_depth_by_cpu: [i64], cpu: i64) -> [i64]:
    var next_depth = queue_depth_by_cpu
    val depth_len = next_depth.len()
    if cpu >= 0 and cpu < depth_len:
        next_depth[cpu] = next_depth[cpu] + 1
    next_depth

fn green_carrier_decrement_queue_depth(queue_depth_by_cpu: [i64], cpu: i64) -> [i64]:
    var next_depth = queue_depth_by_cpu
    val depth_len = next_depth.len()
    if cpu >= 0 and cpu < depth_len and next_depth[cpu] > 0:
        next_depth[cpu] = next_depth[cpu] - 1
    next_depth

fn green_carrier_first_queued_index_for_cpu(queues: GreenCarrierRunQueueState, cpu: i64) -> i64:
    var i = 0
    val task_len = queues.queued_task_ids.len()
    val cpu_len = queues.queued_cpus.len()
    val scan_len = if task_len < cpu_len: task_len else: cpu_len
    while i < scan_len:
        if queues.queued_cpus[i] == cpu:
            return i
        i = i + 1
    -1

fn green_carrier_remove_queued_index(queues: GreenCarrierRunQueueState, remove_index: i64) -> GreenCarrierRunQueueState:
    var queued_task_ids: [i64] = []
    var queued_cpus: [i64] = []
    var i = 0
    val task_len = queues.queued_task_ids.len()
    val cpu_len = queues.queued_cpus.len()
    val scan_len = if task_len < cpu_len: task_len else: cpu_len
    while i < scan_len:
        if i != remove_index:
            queued_task_ids.push(queues.queued_task_ids[i])
            queued_cpus.push(queues.queued_cpus[i])
        i = i + 1
    GreenCarrierRunQueueState(
        queued_task_ids: queued_task_ids,
        queued_cpus: queued_cpus,
        queue_depth_by_cpu: green_carrier_decrement_queue_depth(queues.queue_depth_by_cpu, queues.queued_cpus[remove_index]),
        capacity: queues.capacity,
        dropped_count: queues.dropped_count
    )

pub fn green_carrier_dispatch_next(queues: GreenCarrierRunQueueState, cpu: i64) -> GreenCarrierDispatchResult:
    """Select the next queued green task for one carrier CPU."""
    if cpu < 0 or cpu >= queues.queue_depth_by_cpu.len():
        GreenCarrierDispatchResult(
            queues: queues,
            task_id: -1,
            cpu: cpu,
            dispatched: false,
            reason: "invalid_cpu"
        )
    else:
        val idx = green_carrier_first_queued_index_for_cpu(queues, cpu)
        if idx < 0:
            GreenCarrierDispatchResult(
                queues: queues,
                task_id: -1,
                cpu: cpu,
                dispatched: false,
                reason: "queue_empty"
            )
        else:
            val task_id = queues.queued_task_ids[idx]
            GreenCarrierDispatchResult(
                queues: green_carrier_remove_queued_index(queues, idx),
                task_id: task_id,
                cpu: cpu,
                dispatched: true,
                reason: "dispatched"
            )

pub fn green_carrier_scheduler_intent(dispatch: GreenCarrierDispatchResult) -> GreenCarrierSchedulerIntent:
    """Convert green carrier dispatch into a typed scheduler execution intent."""
    if not dispatch.dispatched:
        GreenCarrierSchedulerIntent(
            task: TaskId(id: 0),
            cpu: if dispatch.cpu < 0: 0u32 else: dispatch.cpu as u32,
            should_run: false,
            should_context_switch: false,
            reason: dispatch.reason
        )
    elif dispatch.task_id < 0 or dispatch.cpu < 0:
        GreenCarrierSchedulerIntent(
            task: TaskId(id: 0),
            cpu: 0u32,
            should_run: false,
            should_context_switch: false,
            reason: "invalid_dispatch"
        )
    else:
        GreenCarrierSchedulerIntent(
            task: TaskId(id: dispatch.task_id as u64),
            cpu: dispatch.cpu as u32,
            should_run: true,
            should_context_switch: true,
            reason: "green_task_ready"
        )

pub fn green_carrier_execution_state_new(cpu_count: i64) -> GreenCarrierExecutionState:
    """Create empty green execution state for carrier CPUs."""
    val normalized_cpu_count = green_carrier_normalized_cpu_count(cpu_count)
    var current_task_by_cpu: [u64] = []
    var context_switches_by_cpu: [i64] = []
    var i = 0
    while i < normalized_cpu_count:
        current_task_by_cpu.push(0)
        context_switches_by_cpu.push(0)
        i = i + 1
    GreenCarrierExecutionState(
        current_task_by_cpu: current_task_by_cpu,
        context_switches_by_cpu: context_switches_by_cpu,
        total_context_switches: 0,
        rejected_intents: 0
    )

pub fn green_carrier_extend_execution_state(state: GreenCarrierExecutionState, cpu_count: i64) -> GreenCarrierExecutionState:
    """Return execution state with slots for at least cpu_count carrier CPUs."""
    val normalized_cpu_count = green_carrier_normalized_cpu_count(cpu_count)
    var current_task_by_cpu = state.current_task_by_cpu
    var context_switches_by_cpu = state.context_switches_by_cpu
    var current_len = current_task_by_cpu.len()
    while current_len < normalized_cpu_count:
        current_task_by_cpu.push(0)
        current_len = current_len + 1
    var switch_len = context_switches_by_cpu.len()
    while switch_len < normalized_cpu_count:
        context_switches_by_cpu.push(0)
        switch_len = switch_len + 1
    GreenCarrierExecutionState(
        current_task_by_cpu: current_task_by_cpu,
        context_switches_by_cpu: context_switches_by_cpu,
        total_context_switches: state.total_context_switches,
        rejected_intents: state.rejected_intents
    )

pub fn green_carrier_current_task_on_cpu(state: GreenCarrierExecutionState, cpu: i64) -> u64:
    """Return current green task id recorded for a carrier CPU."""
    if cpu < 0 or cpu >= state.current_task_by_cpu.len():
        0
    else:
        state.current_task_by_cpu[cpu]

pub fn green_carrier_context_switches_on_cpu(state: GreenCarrierExecutionState, cpu: i64) -> i64:
    """Return context-switch intents applied to one carrier CPU."""
    if cpu < 0 or cpu >= state.context_switches_by_cpu.len():
        0
    else:
        state.context_switches_by_cpu[cpu]

fn green_carrier_mark_current_task(current_task_by_cpu: [u64], cpu: i64, task_id: u64) -> [u64]:
    var next_current = current_task_by_cpu
    if cpu >= 0 and cpu < next_current.len():
        next_current[cpu] = task_id
    next_current

fn green_carrier_increment_switch_count(context_switches_by_cpu: [i64], cpu: i64) -> [i64]:
    var next_switches = context_switches_by_cpu
    if cpu >= 0 and cpu < next_switches.len():
        next_switches[cpu] = next_switches[cpu] + 1
    next_switches

pub fn green_carrier_apply_scheduler_intent(state: GreenCarrierExecutionState, intent: GreenCarrierSchedulerIntent) -> GreenCarrierExecutionResult:
    """Apply a green scheduler intent to execution state."""
    val cpu = intent.cpu as i64
    if not intent.should_run or not intent.should_context_switch:
        GreenCarrierExecutionResult(
            state: GreenCarrierExecutionState(
                current_task_by_cpu: state.current_task_by_cpu,
                context_switches_by_cpu: state.context_switches_by_cpu,
                total_context_switches: state.total_context_switches,
                rejected_intents: state.rejected_intents + 1
            ),
            task: intent.task,
            cpu: intent.cpu,
            applied: false,
            reason: intent.reason
        )
    elif cpu < 0 or cpu >= state.current_task_by_cpu.len():
        GreenCarrierExecutionResult(
            state: GreenCarrierExecutionState(
                current_task_by_cpu: state.current_task_by_cpu,
                context_switches_by_cpu: state.context_switches_by_cpu,
                total_context_switches: state.total_context_switches,
                rejected_intents: state.rejected_intents + 1
            ),
            task: intent.task,
            cpu: intent.cpu,
            applied: false,
            reason: "invalid_cpu"
        )
    else:
        GreenCarrierExecutionResult(
            state: GreenCarrierExecutionState(
                current_task_by_cpu: green_carrier_mark_current_task(state.current_task_by_cpu, cpu, intent.task.id),
                context_switches_by_cpu: green_carrier_increment_switch_count(state.context_switches_by_cpu, cpu),
                total_context_switches: state.total_context_switches + 1,
                rejected_intents: state.rejected_intents
            ),
            task: intent.task,
            cpu: intent.cpu,
            applied: true,
            reason: "context_switch_recorded"
        )

pub fn green_carrier_apply_enqueue(queues: GreenCarrierRunQueueState, decision: GreenCarrierEnqueueDecision) -> GreenCarrierApplyResult:
    """Apply a carrier decision to green run queues and SMP reschedule IPIs."""
    if not decision.should_enqueue:
        return GreenCarrierApplyResult(
            queues: queues,
            decision: decision,
            enqueued: false,
            ipi_sent: false,
            ipi_reason_mask: 0u32,
            reason: decision.reason
        )
    val next_queues = green_carrier_queue_push(queues, decision.task.task_id, decision.target_cpu)
    val enqueued = next_queues.dropped_count == queues.dropped_count
    if not enqueued:
        return GreenCarrierApplyResult(
            queues: next_queues,
            decision: decision,
            enqueued: false,
            ipi_sent: false,
            ipi_reason_mask: 0u32,
            reason: "queue_rejected"
        )
    if decision.should_send_ipi:
        val sent = smp_send_ipi(decision.target_cpu as u32, GREEN_CARRIER_RESCHEDULE_IPI)
        GreenCarrierApplyResult(
            queues: next_queues,
            decision: decision,
            enqueued: true,
            ipi_sent: sent,
            ipi_reason_mask: if sent: GREEN_CARRIER_RESCHEDULE_IPI else: 0u32,
            reason: if sent: "queued_remote_reschedule" else: "queued_without_ipi"
        )
    else:
        GreenCarrierApplyResult(
            queues: next_queues,
            decision: decision,
            enqueued: true,
            ipi_sent: false,
            ipi_reason_mask: 0u32,
            reason: "queued_local"
        )

pub fn green_carrier_enqueue_task(task: GreenTaskRecord, current_cpu: i64) -> GreenCarrierEnqueueDecision:
    """Convert a runnable green task into a carrier run-queue decision."""
    if green_task_is_runnable(task):
        green_carrier_decision(
            task: task,
            target_cpu: task.assigned_cpu,
            should_enqueue: true,
            current_cpu: current_cpu,
            reason: green_carrier_enqueue_reason(current_cpu, task.assigned_cpu)
        )
    elif green_task_is_parked(task):
        green_carrier_decision(
            task: task,
            target_cpu: task.assigned_cpu,
            should_enqueue: false,
            current_cpu: current_cpu,
            reason: "task_parked"
        )
    elif green_task_is_done(task):
        green_carrier_decision(
            task: task,
            target_cpu: task.assigned_cpu,
            should_enqueue: false,
            current_cpu: current_cpu,
            reason: "task_done"
        )
    else:
        green_carrier_decision(
            task: task,
            target_cpu: task.assigned_cpu,
            should_enqueue: false,
            current_cpu: current_cpu,
            reason: "task_not_runnable"
        )

pub fn green_carrier_spawn_task(task_id: i64, cpu_count: i64, affinity_mask: i64, load0: i64, load1: i64, load2: i64, load3: i64, current_cpu: i64) -> GreenCarrierEnqueueDecision:
    """Create a logical green task and return its first carrier enqueue."""
    val task = green_task_new(task_id, cpu_count, affinity_mask, load0, load1, load2, load3)
    green_carrier_enqueue_task(task, current_cpu)

pub fn green_carrier_unpark_task(task: GreenTaskRecord, waker_cpu: i64, home_load: i64, waker_load: i64, wake_affine_threshold: i64, current_cpu: i64) -> GreenCarrierEnqueueDecision:
    """Wake a parked green task and produce the matching carrier enqueue."""
    val wake = green_task_unpark(task, waker_cpu, home_load, waker_load, wake_affine_threshold)
    if wake.should_enqueue:
        green_carrier_decision(
            task: wake.task,
            target_cpu: wake.task.assigned_cpu,
            should_enqueue: true,
            current_cpu: current_cpu,
            reason: wake.placement.reason
        )
    else:
        green_carrier_decision(
            task: wake.task,
            target_cpu: wake.task.assigned_cpu,
            should_enqueue: false,
            current_cpu: current_cpu,
            reason: wake.placement.reason
        )

pub fn green_carrier_channel_wake_task(task: GreenTaskRecord, receiver_task_id: i64, unparked: bool, waker_cpu: i64, home_load: i64, waker_load: i64, wake_affine_threshold: i64, current_cpu: i64) -> GreenCarrierEnqueueDecision:
    """Convert a green-channel send wake into the normal carrier enqueue path."""
    if not unparked:
        green_carrier_decision(
            task: task,
            target_cpu: task.assigned_cpu,
            should_enqueue: false,
            current_cpu: current_cpu,
            reason: "channel_no_receiver"
        )
    elif receiver_task_id != task.task_id:
        green_carrier_decision(
            task: task,
            target_cpu: task.assigned_cpu,
            should_enqueue: false,
            current_cpu: current_cpu,
            reason: "channel_receiver_mismatch"
        )
    else:
        green_carrier_unpark_task(
            task,
            waker_cpu,
            home_load,
            waker_load,
            wake_affine_threshold,
            current_cpu
        )
