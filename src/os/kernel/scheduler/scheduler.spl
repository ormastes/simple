# Preemptive Scheduler — Computation Dimension
#
# Priority-based preemptive scheduler with round-robin within same priority.
# Fixed-size task table (MAX_TASKS slots). Timer interrupt drives preemption.
#
# Consumes: SchedulerInputPort (interrupts, memory)
# Produces: SchedulerOutputPort (task lifecycle, blocking)

use os.kernel.types.task_types.{TaskId, TaskState, TaskPriority, TaskContext, BlockReason, UserProcessImage, AddressSpace}
use os.kernel.types.capability_types.{CapabilitySet}
use os.kernel.arch.x86_64.context.{X86ContextSwitch}
use os.kernel.memory.vmm.{create_user_address_space}
use os.kernel.loader.segment_mapper.{map_all}

# ============================================================================
# Configuration
# ============================================================================

val MAX_TASKS: i32 = 256
val PRIORITY_LEVELS: i32 = 5      # Realtime, High, Normal, Low, Idle
val TIME_SLICE_TICKS: u64 = 10    # Ticks per time slice before preemption

# ============================================================================
# Task Control Block
# ============================================================================

@repr("C")
struct TaskControlBlock:
    """Full task state held by the scheduler.

    Contains saved CPU context, address space root, stack pointers,
    capability set, and parent linkage. One per active task.
    """
    id: TaskId
    state: TaskState
    priority: TaskPriority
    is_user: bool
    entry_point: u64
    context: TaskContext             # Saved CPU state
    user_context: TaskContext?       # x86_64 user-mode handoff state
    address_space: u64              # PML4 physical address
    kernel_stack: u64               # Kernel stack top
    user_stack: u64                 # User stack top
    capabilities: CapabilitySet     # Security capabilities
    parent: TaskId?                 # Parent task (nil for init)
    exit_code: i32
    ticks_remaining: u64            # Time slice countdown

# ============================================================================
# Ready Queue — Per-Priority FIFO
# ============================================================================

struct ReadyQueue:
    """Per-priority FIFO queue of task IDs.

    Flattened array with head/tail indices. Fixed capacity MAX_TASKS.
    """
    entries: [u64]      # Task ID values
    head: i32
    tail: i32
    count: i32
    capacity: i32

impl ReadyQueue:
    static fn new() -> ReadyQueue:
        """Create an empty ready queue."""
        var entries: [u64] = []
        var i = 0
        while i < MAX_TASKS:
            entries.push(0)
            i = i + 1
        ReadyQueue(
            entries: entries,
            head: 0,
            tail: 0,
            count: 0,
            capacity: MAX_TASKS
        )

    me enqueue(task_id: TaskId):
        """Add a task to the back of the queue."""
        if self.count >= self.capacity:
            return  # Queue full, drop silently (should not happen)
        self.entries[self.tail] = task_id.id
        self.tail = (self.tail + 1) % self.capacity
        self.count = self.count + 1

    me dequeue() -> TaskId?:
        """Remove and return the task at the front of the queue."""
        if self.count == 0:
            return nil
        val id_val = self.entries[self.head]
        self.head = (self.head + 1) % self.capacity
        self.count = self.count - 1
        TaskId(id: id_val)

    me remove(task_id: TaskId):
        """Remove a specific task from the queue (linear scan).

        Used when blocking a task that is in the ready queue.
        Rebuilds the queue without the target task.
        """
        var new_entries: [u64] = []
        var i = 0
        while i < MAX_TASKS:
            new_entries.push(0)
            i = i + 1
        var new_tail = 0
        var scan = self.head
        var scanned = 0
        while scanned < self.count:
            val idx = scan % self.capacity
            val entry_id = self.entries[idx]
            if entry_id != task_id.id:
                new_entries[new_tail] = entry_id
                new_tail = new_tail + 1
            scan = scan + 1
            scanned = scanned + 1
        self.entries = new_entries
        self.head = 0
        self.tail = new_tail
        self.count = new_tail

    fn is_empty() -> bool:
        self.count == 0

    fn len() -> i32:
        self.count

# ============================================================================
# Scheduler
# ============================================================================

class Scheduler:
    """Priority-based preemptive scheduler.

    Maintains a fixed-size task table (nil = empty slot) and per-priority
    ready queues. Timer interrupts drive preemption: each tick decrements
    the current task's remaining time slice, and when it expires the
    scheduler picks the next highest-priority ready task.

    Within the same priority level, tasks are scheduled round-robin.
    """
    tasks: [TaskControlBlock?]          # Fixed-size task table
    current: TaskId                     # Currently running task
    ready_queues: [ReadyQueue]          # One per priority level
    tick_count: u64                     # Global tick counter
    next_task_id: u64                   # Monotonic task ID allocator

impl Scheduler:
    static fn new() -> Scheduler:
        """Create a scheduler with empty task table and ready queues."""
        # Initialize task slots to nil
        var tasks: [TaskControlBlock?] = []
        var i = 0
        while i < MAX_TASKS:
            tasks.push(nil)
            i = i + 1

        # Initialize per-priority ready queues
        var queues: [ReadyQueue] = []
        var p = 0
        while p < PRIORITY_LEVELS:
            queues.push(ReadyQueue.new())
            p = p + 1

        Scheduler(
            tasks: tasks,
            current: TaskId(id: 0),
            ready_queues: queues,
            tick_count: 0,
            next_task_id: 1         # 0 is reserved for idle/kernel
        )

    # -- Task Lifecycle ------------------------------------------------------

    me create_task(entry: u64, priority: TaskPriority, caps: CapabilitySet) -> TaskId:
        """Create a new task and add it to the ready queue.

        Allocates a slot in the task table, initializes the context
        with the entry point, and enqueues in the appropriate
        priority-level ready queue.

        Returns the new task's ID.
        """
        val id = TaskId(id: self.next_task_id)
        self.next_task_id = self.next_task_id + 1

        # Find an empty slot
        val slot = self._find_empty_slot()
        if slot < 0:
            # No slots available — return invalid ID
            return TaskId(id: 0)

        # Build initial context: RIP = entry point, RFLAGS = interrupts enabled (IF=1)
        val ctx = TaskContext(
            rax: 0, rbx: 0, rcx: 0, rdx: 0,
            rsi: 0, rdi: 0, rbp: 0, rsp: 0,
            r8: 0, r9: 0, r10: 0, r11: 0,
            r12: 0, r13: 0, r14: 0, r15: 0,
            rip: entry,
            rflags: 0x202,      # IF=1, reserved bit 1 set
            cs: 0x23,           # User code segment (ring 3)
            ss: 0x1B,           # User data segment (ring 3)
            fpu_state: 0
        )

        val tcb = TaskControlBlock(
            id: id,
            state: TaskState.Ready,
            priority: priority,
            is_user: false,
            entry_point: entry,
            context: ctx,
            user_context: nil,
            address_space: 0,
            kernel_stack: 0,
            user_stack: 0,
            capabilities: caps,
            parent: Some(self.current),
            exit_code: 0,
            ticks_remaining: TIME_SLICE_TICKS
        )

        self.tasks[slot] = tcb

        # Enqueue in the appropriate ready queue
        val queue_idx = _priority_to_index(priority)
        self.ready_queues[queue_idx].enqueue(id)

        id

    me create_user_task(image: UserProcessImage, priority: TaskPriority, caps: CapabilitySet) -> TaskId:
        """Create a transitional user task from a user process image.

        The scheduler keeps the legacy TaskContext slot for compatibility, but
        the x86_64 user-mode handoff is represented explicitly in user_context.
        """
        val id = TaskId(id: self.next_task_id)
        self.next_task_id = self.next_task_id + 1

        val slot = self._find_empty_slot()
        if slot < 0:
            return TaskId(id: 0)

        val user_sp = image.initial_sp & 0xFFFFFFFFFFFFFFF0
        val arch_user_ctx = X86ContextSwitch.create(image.entry, user_sp, true)
        val user_ctx = TaskContext(
            rax: arch_user_ctx.rax, rbx: arch_user_ctx.rbx,
            rcx: arch_user_ctx.rcx, rdx: arch_user_ctx.rdx,
            rsi: arch_user_ctx.rsi, rdi: arch_user_ctx.rdi,
            rbp: arch_user_ctx.rbp, rsp: arch_user_ctx.rsp,
            r8: arch_user_ctx.r8, r9: arch_user_ctx.r9,
            r10: arch_user_ctx.r10, r11: arch_user_ctx.r11,
            r12: arch_user_ctx.r12, r13: arch_user_ctx.r13,
            r14: arch_user_ctx.r14, r15: arch_user_ctx.r15,
            rip: arch_user_ctx.rip,
            rflags: arch_user_ctx.rflags,
            cs: arch_user_ctx.cs,
            ss: arch_user_ctx.ss,
            fpu_state: arch_user_ctx.fpu_state
        )

        val user_as: AddressSpace = create_user_address_space()

        # Phase 2: populate the user address space with PT_LOAD pages before
        # enqueueing. On failure we return TaskId(id: 0) to match the existing
        # error-signalling convention (see _find_empty_slot above).
        val map_result = map_all(user_as, image.segments, image.file_bytes)
        match map_result:
            case Err(_):
                return TaskId(id: 0)
            case Ok(_):
                ()

        val tcb = TaskControlBlock(
            id: id,
            state: TaskState.Ready,
            priority: priority,
            is_user: true,
            entry_point: image.entry,
            context: user_ctx,
            user_context: Some(user_ctx),
            address_space: user_as.phys_root,
            kernel_stack: 0,
            user_stack: image.stack_top,
            capabilities: caps,
            parent: Some(self.current),
            exit_code: 0,
            ticks_remaining: TIME_SLICE_TICKS
        )

        self.tasks[slot] = tcb

        val queue_idx = _priority_to_index(priority)
        self.ready_queues[queue_idx].enqueue(id)

        id

    fn get_user_context(self, task_id: TaskId) -> TaskContext?:
        """Retrieve the x86_64 user-mode context for a task, if it exists."""
        val slot = self._find_slot(task_id)
        if slot < 0:
            return nil
        val tcb = self.tasks[slot]
        if tcb == nil:
            return nil
        tcb.user_context

    me exit_task(code: i32):
        """Exit the currently running task.

        Sets state to Zombie and exit code. The task is NOT placed back
        in a ready queue. Parent can collect via Wait syscall.
        """
        val current_slot = self._find_slot(self.current)
        if current_slot < 0:
            return
        val tcb = self.tasks[current_slot]
        if tcb == nil:
            return
        var task = tcb
        task.state = TaskState.Zombie
        task.exit_code = code
        self.tasks[current_slot] = task

    me yield_current():
        """Voluntarily yield the current task's time slice.

        Moves the current task to Ready state and enqueues it at the
        back of its priority-level ready queue.
        """
        val current_slot = self._find_slot(self.current)
        if current_slot < 0:
            return
        val tcb = self.tasks[current_slot]
        if tcb == nil:
            return
        var task = tcb
        task.state = TaskState.Ready
        task.ticks_remaining = TIME_SLICE_TICKS
        self.tasks[current_slot] = task

        val queue_idx = _priority_to_index(task.priority)
        self.ready_queues[queue_idx].enqueue(self.current)

    me block_task(id: TaskId, reason: BlockReason):
        """Block a task, removing it from the ready queue.

        The task will not be scheduled until unblock_task() is called.
        """
        val slot = self._find_slot(id)
        if slot < 0:
            return
        val tcb = self.tasks[slot]
        if tcb == nil:
            return
        var task = tcb
        task.state = TaskState.Blocked(reason: reason)
        self.tasks[slot] = task

        # Remove from ready queue
        val queue_idx = _priority_to_index(task.priority)
        self.ready_queues[queue_idx].remove(id)

    me unblock_task(id: TaskId):
        """Unblock a previously blocked task.

        Sets state back to Ready and enqueues in the appropriate
        priority-level ready queue.
        """
        val slot = self._find_slot(id)
        if slot < 0:
            return
        val tcb = self.tasks[slot]
        if tcb == nil:
            return
        var task = tcb
        task.state = TaskState.Ready
        task.ticks_remaining = TIME_SLICE_TICKS
        self.tasks[slot] = task

        val queue_idx = _priority_to_index(task.priority)
        self.ready_queues[queue_idx].enqueue(id)

    # -- Scheduling ----------------------------------------------------------

    me schedule() -> TaskContext:
        """Pick the next task to run.

        Scans ready queues from highest priority (Realtime=0) to lowest
        (Idle=4). Within a priority level, tasks are dequeued round-robin
        (FIFO).

        Sets the chosen task to Running and returns its saved context
        for restoration by the context switch stub.

        If no task is ready, returns the idle task context (task 0).
        """
        # Find the highest-priority non-empty queue
        var p = 0
        while p < PRIORITY_LEVELS:
            val next_id = self.ready_queues[p].dequeue()
            if next_id != nil:
                val task_id = next_id
                val slot = self._find_slot(task_id)
                if slot >= 0:
                    val tcb = self.tasks[slot]
                    if tcb != nil:
                        var task = tcb
                        task.state = TaskState.Running
                        task.ticks_remaining = TIME_SLICE_TICKS
                        self.tasks[slot] = task
                        self.current = task_id
                        return task.context
            p = p + 1

        # No ready tasks — return idle context (task 0)
        val idle_tcb = self.tasks[0]
        if idle_tcb != nil:
            return idle_tcb.context
        # Absolute fallback: empty context (should never happen)
        TaskContext(
            rax: 0, rbx: 0, rcx: 0, rdx: 0,
            rsi: 0, rdi: 0, rbp: 0, rsp: 0,
            r8: 0, r9: 0, r10: 0, r11: 0,
            r12: 0, r13: 0, r14: 0, r15: 0,
            rip: 0, rflags: 0x202,
            cs: 0x08, ss: 0x10, fpu_state: 0
        )

    me timer_tick(ctx: TaskContext) -> TaskContext:
        """Handle APIC timer interrupt.

        Saves the interrupted task's context, decrements time slice.
        If the time slice expires, the current task is preempted and
        schedule() picks the next task. Otherwise returns the same
        context to resume.
        """
        self.tick_count = self.tick_count + 1

        # Save the interrupted context into the current task's TCB
        val current_slot = self._find_slot(self.current)
        if current_slot < 0:
            return self.schedule()
        val tcb = self.tasks[current_slot]
        if tcb == nil:
            return self.schedule()

        var task = tcb
        task.context = ctx

        # Decrement time slice
        if task.ticks_remaining > 0:
            task.ticks_remaining = task.ticks_remaining - 1

        if task.ticks_remaining == 0:
            # Time slice expired — preempt
            task.state = TaskState.Ready
            task.ticks_remaining = TIME_SLICE_TICKS
            self.tasks[current_slot] = task

            val queue_idx = _priority_to_index(task.priority)
            self.ready_queues[queue_idx].enqueue(self.current)

            return self.schedule()

        # Time slice not expired — continue running
        self.tasks[current_slot] = task
        ctx

    # -- Queries -------------------------------------------------------------

    fn get_current() -> TaskId:
        """Return the currently running task's ID."""
        self.current

    fn get_task(id: TaskId) -> TaskControlBlock?:
        """Look up a task by ID."""
        val slot = self._find_slot(id)
        if slot < 0:
            return nil
        self.tasks[slot]

    fn get_tick_count() -> u64:
        """Return the global tick counter."""
        self.tick_count

    # -- IF-02 Fork/Exec Contract (wave-3 scaffolds) -------------------------
    # Real COW page-table clone + ELF load arrive in wave 4.

    me clone_task(parent_id: TaskId) -> TaskId:
        """Clone parent task into new child task (IF-02).

        Wave-4 scaffold: looks up parent TCB, allocates a fresh TaskId,
        copies registers/priority/parent linkage, marks child Ready,
        and enqueues it. Page-table COW arrives in wave-4b.
        """
        val parent_slot = self._find_slot(parent_id)
        if parent_slot < 0:
            return TaskId(id: 0)
        val parent_tcb = self.tasks[parent_slot]
        if parent_tcb == nil:
            return TaskId(id: 0)
        val parent = parent_tcb

        val child_id = TaskId(id: self.next_task_id)
        self.next_task_id = self.next_task_id + 1

        val child_slot = self._find_empty_slot()
        if child_slot < 0:
            return TaskId(id: 0)

        # TODO(wave-4b): shallow-clone page tables with COW bit set via MmuCtx.cow_clone()

        val child = TaskControlBlock(
            id: child_id,
            state: TaskState.Ready,
            priority: parent.priority,
            is_user: parent.is_user,
            entry_point: parent.entry_point,
            context: parent.context,
            user_context: parent.user_context,
            address_space: parent.address_space,
            kernel_stack: parent.kernel_stack,
            user_stack: parent.user_stack,
            capabilities: parent.capabilities,
            parent: Some(parent_id),
            exit_code: 0,
            ticks_remaining: TIME_SLICE_TICKS
        )

        self.tasks[child_slot] = child

        val queue_idx = _priority_to_index(child.priority)
        self.ready_queues[queue_idx].enqueue(child_id)

        child_id

    fn exec_into(task_id: TaskId, argv: [Text], envp: [Text]) -> i32:
        """Replace task image with ELF at argv[0] (IF-02).

        Wave-3 scaffold returns -38 (ENOSYS). Wave-4 parses ELF, maps
        PT_LOAD segments into the task's address space, resets RIP/RSP,
        and wires argv/envp onto the new stack.
        """
        val _t = task_id
        val _a = argv
        val _e = envp
        -38

    fn wait_for(parent_id: TaskId, child_id: TaskId) -> i32:
        """Block parent until child exits, return exit status (IF-02).

        Wave-3 scaffold returns -10 (ECHILD). Wave-4 will suspend the
        parent on a wait-queue and wake it from the child's exit path.
        """
        val _p = parent_id
        val _c = child_id
        -10

    # -- Internal Helpers ----------------------------------------------------

    fn _find_slot(id: TaskId) -> i32:
        """Find the slot index for a given task ID. Returns -1 if not found."""
        var i = 0
        while i < MAX_TASKS:
            val tcb = self.tasks[i]
            if tcb != nil:
                val task = tcb
                if task.id.id == id.id:
                    return i
            i = i + 1
        -1

    fn _find_empty_slot() -> i32:
        """Find the first empty slot. Returns -1 if full."""
        var i = 0
        while i < MAX_TASKS:
            if self.tasks[i] == nil:
                return i
            i = i + 1
        -1

# ============================================================================
# Priority Mapping
# ============================================================================

fn _priority_to_index(priority: TaskPriority) -> i32:
    """Map TaskPriority enum to ready queue index (0 = highest)."""
    match priority:
        case Realtime: 0
        case High: 1
        case Normal: 2
        case Low: 3
        case Idle: 4
