# Preemptive Scheduler — Computation Dimension
#
# Priority-based preemptive scheduler with round-robin within same priority.
# Fixed-size task table (MAX_TASKS slots). Timer interrupt drives preemption.
#
# Consumes: SchedulerInputPort (interrupts, memory)
# Produces: SchedulerOutputPort (task lifecycle, blocking)

use os.kernel.types.task_types.{
    TaskId, TaskState, TaskPriority, TaskContext, BlockReason,
    UserProcessImage, AddressSpace,
    SchedulerPolicy, TaskScheduleConfig, TaskIsolationProfile,
    default_task_schedule, default_task_isolation
}
use os.kernel.types.capability_types.{CapabilitySet}
use os.kernel.arch.x86_64.context.{X86ContextSwitch}
use os.kernel.memory.vmm.{create_user_address_space, vmm_cow_clone_pages}
use os.kernel.loader.segment_mapper.{map_all}

# Forward declaration: implemented by IpcManager wiring in kernel main.
# Called after every task creation so the capability subsystem has an
# explicit record for the new task instead of relying on default-ALLOW.
extern fn cap_init_task_record(task: TaskId, full: bool)

# ============================================================================
# Configuration
# ============================================================================

val MAX_TASKS: i32 = 256
val PRIORITY_LEVELS: i32 = 5      # Realtime, High, Normal, Low, Idle
val TIME_SLICE_TICKS: u64 = 10    # Ticks per time slice before preemption

# ============================================================================
# Task Control Block
# ============================================================================

@repr("C")
struct TaskControlBlock:
    """Full task state held by the scheduler.

    Contains saved CPU context, address space root, stack pointers,
    capability set, and parent linkage. One per active task.
    """
    id: TaskId
    state: TaskState
    priority: TaskPriority
    is_user: bool
    entry_point: u64
    context: TaskContext             # Saved CPU state
    user_context: TaskContext?       # x86_64 user-mode handoff state
    address_space: u64              # PML4 physical address
    kernel_stack: u64               # Kernel stack top
    user_stack: u64                 # User stack top
    capabilities: CapabilitySet     # Security capabilities
    parent: TaskId?                 # Parent task (nil for init)
    schedule: TaskScheduleConfig    # Class metadata + fair/deadline accounting
    isolation: TaskIsolationProfile # Process isolation metadata
    assigned_cpu: u32               # CPU whose run queue owns this task
    exit_code: i32
    ticks_remaining: u64            # Time slice countdown

# ============================================================================
# Ready Queue — Per-Priority FIFO
# ============================================================================

struct ReadyQueue:
    """Per-priority FIFO queue of task IDs.

    Flattened array with head/tail indices. Fixed capacity MAX_TASKS.
    """
    entries: [u64]      # Task ID values
    head: i32
    tail: i32
    count: i32
    capacity: i32

impl ReadyQueue:
    static fn new() -> ReadyQueue:
        """Create an empty ready queue."""
        var entries: [u64] = []
        var i = 0
        while i < MAX_TASKS:
            entries.push(0)
            i = i + 1
        ReadyQueue(
            entries: entries,
            head: 0,
            tail: 0,
            count: 0,
            capacity: MAX_TASKS
        )

    me enqueue(task_id: TaskId):
        """Add a task to the back of the queue."""
        if self.count >= self.capacity:
            return  # Queue full, drop silently (should not happen)
        self.entries[self.tail] = task_id.id
        self.tail = (self.tail + 1) % self.capacity
        self.count = self.count + 1

    me dequeue() -> TaskId?:
        """Remove and return the task at the front of the queue."""
        if self.count == 0:
            return nil
        val id_val = self.entries[self.head]
        self.head = (self.head + 1) % self.capacity
        self.count = self.count - 1
        TaskId(id: id_val)

    me remove(task_id: TaskId):
        """Remove a specific task from the queue (linear scan).

        Used when blocking a task that is in the ready queue.
        Rebuilds the queue without the target task.
        """
        var new_entries: [u64] = []
        var i = 0
        while i < MAX_TASKS:
            new_entries.push(0)
            i = i + 1
        var new_tail = 0
        var scan = self.head
        var scanned = 0
        while scanned < self.count:
            val idx = scan % self.capacity
            val entry_id = self.entries[idx]
            if entry_id != task_id.id:
                new_entries[new_tail] = entry_id
                new_tail = new_tail + 1
            scan = scan + 1
            scanned = scanned + 1
        self.entries = new_entries
        self.head = 0
        self.tail = new_tail
        self.count = new_tail

    fn is_empty() -> bool:
        self.count == 0

    fn len() -> i32:
        self.count

struct CpuRunQueue:
    """Per-CPU run queues separated by scheduler class.

    Deadline and RT queues are carried as metadata lanes in v1 so schedctl and
    compiler policy can round-trip those classes without enabling full EDF/CBS
    admission yet. Fair/background are the default runnable lanes.
    """
    cpu_id: u32
    deadline_queue: ReadyQueue
    rt_queue: ReadyQueue
    fair_queue: ReadyQueue
    background_queue: ReadyQueue
    idle_queue: ReadyQueue
    runnable_count: i32
    weighted_load: i64
    latency_debt: i64
    migration_pressure: i64
    cache_hot_wakeups: u64

impl CpuRunQueue:
    static fn new(cpu_id: u32) -> CpuRunQueue:
        CpuRunQueue(
            cpu_id: cpu_id,
            deadline_queue: ReadyQueue.new(),
            rt_queue: ReadyQueue.new(),
            fair_queue: ReadyQueue.new(),
            background_queue: ReadyQueue.new(),
            idle_queue: ReadyQueue.new(),
            runnable_count: 0,
            weighted_load: 0,
            latency_debt: 0,
            migration_pressure: 0,
            cache_hot_wakeups: 0
        )

    me enqueue(task_id: TaskId, config: TaskScheduleConfig):
        match config.policy:
            case Deadline:
                self.deadline_queue.enqueue(task_id)
            case RtFifo:
                self.rt_queue.enqueue(task_id)
            case RtRoundRobin:
                self.rt_queue.enqueue(task_id)
            case Background:
                self.background_queue.enqueue(task_id)
            case Idle:
                self.idle_queue.enqueue(task_id)
            case Internal:
                self.rt_queue.enqueue(task_id)
            case Fair:
                self.fair_queue.enqueue(task_id)
        self.runnable_count = self.runnable_count + 1
        self.weighted_load = self.weighted_load + config.weight

    me remove(task_id: TaskId, config: TaskScheduleConfig):
        val before = (
            self.deadline_queue.count + self.rt_queue.count +
            self.fair_queue.count + self.background_queue.count +
            self.idle_queue.count
        )
        self.deadline_queue.remove(task_id)
        self.rt_queue.remove(task_id)
        self.fair_queue.remove(task_id)
        self.background_queue.remove(task_id)
        self.idle_queue.remove(task_id)
        val after = (
            self.deadline_queue.count + self.rt_queue.count +
            self.fair_queue.count + self.background_queue.count +
            self.idle_queue.count
        )
        if after < before and self.runnable_count > 0:
            self.runnable_count = self.runnable_count - 1
            if self.weighted_load >= config.weight:
                self.weighted_load = self.weighted_load - config.weight
            else:
                self.weighted_load = 0

# ============================================================================
# Scheduler
# ============================================================================

class Scheduler:
    """Priority-based preemptive scheduler.

    Maintains a fixed-size task table (nil = empty slot) and per-priority
    ready queues. Timer interrupts drive preemption: each tick decrements
    the current task's remaining time slice, and when it expires the
    scheduler picks the next highest-priority ready task.

    Within the same priority level, tasks are scheduled round-robin.
    """
    tasks: [TaskControlBlock?]          # Fixed-size task table
    current: TaskId                     # Currently running task
    ready_queues: [ReadyQueue]          # One per priority level
    cpu_runqueues: [CpuRunQueue]        # One run queue per logical CPU
    tick_count: u64                     # Global tick counter
    next_task_id: u64                   # Monotonic task ID allocator

impl Scheduler:
    static fn new() -> Scheduler:
        """Create a scheduler with empty task table and ready queues."""
        # Initialize task slots to nil
        var tasks: [TaskControlBlock?] = []
        var i = 0
        while i < MAX_TASKS:
            tasks.push(nil)
            i = i + 1

        # Initialize per-priority ready queues
        var queues: [ReadyQueue] = []
        var p = 0
        while p < PRIORITY_LEVELS:
            queues.push(ReadyQueue.new())
            p = p + 1

        var cpu_queues: [CpuRunQueue] = []
        var cpu = 0u32
        while cpu < 32u32:
            cpu_queues.push(CpuRunQueue.new(cpu))
            cpu = cpu + 1u32

        Scheduler(
            tasks: tasks,
            current: TaskId(id: 0),
            ready_queues: queues,
            cpu_runqueues: cpu_queues,
            tick_count: 0,
            next_task_id: 1         # 0 is reserved for idle/kernel
        )

    # -- Task Lifecycle ------------------------------------------------------

    me create_task(entry: u64, priority: TaskPriority, caps: CapabilitySet) -> TaskId:
        """Create a new task and add it to the ready queue.

        Allocates a slot in the task table, initializes the context
        with the entry point, and enqueues in the appropriate
        priority-level ready queue.

        Returns the new task's ID.
        """
        val id = TaskId(id: self.next_task_id)
        self.next_task_id = self.next_task_id + 1

        # Find an empty slot
        val slot = self._find_empty_slot()
        if slot < 0:
            # No slots available — return invalid ID
            return TaskId(id: 0)

        # Build initial context: RIP = entry point, RFLAGS = interrupts enabled (IF=1)
        val ctx = TaskContext(
            rax: 0, rbx: 0, rcx: 0, rdx: 0,
            rsi: 0, rdi: 0, rbp: 0, rsp: 0,
            r8: 0, r9: 0, r10: 0, r11: 0,
            r12: 0, r13: 0, r14: 0, r15: 0,
            rip: entry,
            rflags: 0x202,      # IF=1, reserved bit 1 set
            cs: 0x23,           # User code segment (ring 3)
            ss: 0x1B,           # User data segment (ring 3)
            fpu_state: 0
        )

        val tcb = TaskControlBlock(
            id: id,
            state: TaskState.Ready,
            priority: priority,
            is_user: false,
            entry_point: entry,
            context: ctx,
            user_context: nil,
            address_space: 0,
            kernel_stack: 0,
            user_stack: 0,
            capabilities: caps,
            parent: Some(self.current),
            schedule: default_task_schedule(priority),
            isolation: default_task_isolation(0),
            assigned_cpu: 0u32,
            exit_code: 0,
            ticks_remaining: TIME_SLICE_TICKS
        )

        self.tasks[slot] = tcb

        # Register capability record so cap_check finds an explicit entry
        # instead of falling through to the (now-removed) default-ALLOW path.
        cap_init_task_record(id, true)

        self._enqueue_ready(id)

        id

    me create_user_task(image: UserProcessImage, priority: TaskPriority, caps: CapabilitySet) -> TaskId:
        """Create a transitional user task from a user process image.

        The scheduler keeps the legacy TaskContext slot for compatibility, but
        the x86_64 user-mode handoff is represented explicitly in user_context.
        """
        val id = TaskId(id: self.next_task_id)
        self.next_task_id = self.next_task_id + 1

        val slot = self._find_empty_slot()
        if slot < 0:
            return TaskId(id: 0)

        val user_sp = image.initial_sp & 0xFFFFFFFFFFFFFFF0
        val arch_user_ctx = X86ContextSwitch.create(image.entry, user_sp, true)
        val user_ctx = TaskContext(
            rax: arch_user_ctx.rax, rbx: arch_user_ctx.rbx,
            rcx: arch_user_ctx.rcx, rdx: arch_user_ctx.rdx,
            rsi: arch_user_ctx.rsi, rdi: arch_user_ctx.rdi,
            rbp: arch_user_ctx.rbp, rsp: arch_user_ctx.rsp,
            r8: arch_user_ctx.r8, r9: arch_user_ctx.r9,
            r10: arch_user_ctx.r10, r11: arch_user_ctx.r11,
            r12: arch_user_ctx.r12, r13: arch_user_ctx.r13,
            r14: arch_user_ctx.r14, r15: arch_user_ctx.r15,
            rip: arch_user_ctx.rip,
            rflags: arch_user_ctx.rflags,
            cs: arch_user_ctx.cs,
            ss: arch_user_ctx.ss,
            fpu_state: arch_user_ctx.fpu_state
        )

        val user_as: AddressSpace = create_user_address_space()

        # User address-space mapping is deferred with execution enqueueing.
        # The FAT32-backed process image is retained in the TCB metadata path;
        # mapping it before the x86_64 handoff is stable currently faults in
        # baremetal QEMU.

        val tcb = TaskControlBlock(
            id: id,
            state: TaskState.Ready,
            priority: priority,
            is_user: true,
            entry_point: image.entry,
            context: user_ctx,
            user_context: Some(user_ctx),
            address_space: user_as.phys_root,
            kernel_stack: 0,
            user_stack: image.stack_top,
            capabilities: caps,
            parent: Some(self.current),
            schedule: default_task_schedule(priority),
            isolation: default_task_isolation(user_as.id),
            assigned_cpu: 0u32,
            exit_code: 0,
            ticks_remaining: TIME_SLICE_TICKS
        )

        self.tasks[slot] = tcb

        # Register capability record so cap_check finds an explicit entry
        # instead of falling through to the (now-removed) default-ALLOW path.
        cap_init_task_record(id, true)

        self._enqueue_ready(id)

        id

    fn get_user_context(self, task_id: TaskId) -> TaskContext?:
        """Retrieve the x86_64 user-mode context for a task, if it exists."""
        val slot = self._find_slot(task_id)
        if slot < 0:
            return nil
        val tcb = self.tasks[slot]
        if tcb == nil:
            return nil
        tcb.user_context

    me exit_task(code: i32):
        """Exit the currently running task.

        Sets state to Zombie and exit code. The task is NOT placed back
        in a ready queue. Parent can collect via Wait syscall.
        """
        val current_slot = self._find_slot(self.current)
        if current_slot < 0:
            return
        val tcb = self.tasks[current_slot]
        if tcb == nil:
            return
        var task = tcb
        task.state = TaskState.Zombie
        task.exit_code = code
        self.tasks[current_slot] = task

    me yield_current():
        """Voluntarily yield the current task's time slice.

        Moves the current task to Ready state and enqueues it at the
        back of its priority-level ready queue.
        """
        val current_slot = self._find_slot(self.current)
        if current_slot < 0:
            return
        val tcb = self.tasks[current_slot]
        if tcb == nil:
            return
        var task = tcb
        task.state = TaskState.Ready
        task.ticks_remaining = TIME_SLICE_TICKS
        self.tasks[current_slot] = task

        self._enqueue_ready(self.current)

    me block_task(id: TaskId, reason: BlockReason):
        """Block a task, removing it from the ready queue.

        The task will not be scheduled until unblock_task() is called.
        """
        val slot = self._find_slot(id)
        if slot < 0:
            return
        val tcb = self.tasks[slot]
        if tcb == nil:
            return
        var task = tcb
        task.state = TaskState.Blocked(reason: reason)
        self.tasks[slot] = task

        self._remove_ready(id)

    me unblock_task(id: TaskId):
        """Unblock a previously blocked task.

        Sets state back to Ready and enqueues in the appropriate
        priority-level ready queue.
        """
        val slot = self._find_slot(id)
        if slot < 0:
            return
        val tcb = self.tasks[slot]
        if tcb == nil:
            return
        var task = tcb
        task.state = TaskState.Ready
        task.ticks_remaining = TIME_SLICE_TICKS
        self.tasks[slot] = task

        self._enqueue_ready(id)

    # -- Scheduling ----------------------------------------------------------

    me schedule() -> TaskContext:
        """Pick the next task to run.

        Scans ready queues from highest priority (Realtime=0) to lowest
        (Idle=4). Within a priority level, tasks are dequeued round-robin
        (FIFO).

        Sets the chosen task to Running and returns its saved context
        for restoration by the context switch stub.

        If no task is ready, returns the idle task context (task 0).
        """
        self.schedule_on_cpu(0u32)

    me schedule_on_cpu(cpu_id: u32) -> TaskContext:
        """Pick the next task to run on a specific CPU run queue."""
        val cpu = self._normalize_cpu(cpu_id)
        val next_id = self._pick_next_on_cpu(cpu)
        if next_id != nil:
            val task_id = next_id
            self._remove_ready(task_id)
            val slot = self._find_slot(task_id)
            if slot >= 0:
                val tcb = self.tasks[slot]
                if tcb != nil:
                    var task = tcb
                    task.state = TaskState.Running
                    task.ticks_remaining = TIME_SLICE_TICKS
                    self.tasks[slot] = task
                    self.current = task_id
                    return task.context

        # No ready tasks — return idle context (task 0)
        val idle_tcb = self.tasks[0]
        if idle_tcb != nil:
            return idle_tcb.context
        # Absolute fallback: empty context (should never happen)
        TaskContext(
            rax: 0, rbx: 0, rcx: 0, rdx: 0,
            rsi: 0, rdi: 0, rbp: 0, rsp: 0,
            r8: 0, r9: 0, r10: 0, r11: 0,
            r12: 0, r13: 0, r14: 0, r15: 0,
            rip: 0, rflags: 0x202,
            cs: 0x08, ss: 0x10, fpu_state: 0
        )

    me timer_tick(ctx: TaskContext) -> TaskContext:
        """Handle APIC timer interrupt.

        Saves the interrupted task's context, decrements time slice.
        If the time slice expires, the current task is preempted and
        schedule() picks the next task. Otherwise returns the same
        context to resume.
        """
        self.tick_count = self.tick_count + 1

        # Save the interrupted context into the current task's TCB
        val current_slot = self._find_slot(self.current)
        if current_slot < 0:
            return self.schedule()
        val tcb = self.tasks[current_slot]
        if tcb == nil:
            return self.schedule()

        var task = tcb
        task.context = ctx

        # Decrement time slice
        if task.ticks_remaining > 0:
            task.ticks_remaining = task.ticks_remaining - 1

        if task.ticks_remaining == 0:
            # Time slice expired — preempt
            task.state = TaskState.Ready
            task.ticks_remaining = TIME_SLICE_TICKS
            self.tasks[current_slot] = task

            self._enqueue_ready(self.current)

            return self.schedule()

        # Time slice not expired — continue running
        self.tasks[current_slot] = task
        ctx

    # -- Queries -------------------------------------------------------------

    fn get_current() -> TaskId:
        """Return the currently running task's ID."""
        self.current

    fn get_task(id: TaskId) -> TaskControlBlock?:
        """Look up a task by ID."""
        val slot = self._find_slot(id)
        if slot < 0:
            return nil
        self.tasks[slot]

    fn get_tick_count() -> u64:
        """Return the global tick counter."""
        self.tick_count

    fn tick_count() -> u64:
        """Compatibility alias for syscall handlers that predate get_tick_count."""
        self.tick_count

    me set_priority(id: TaskId, priority: TaskPriority) -> bool:
        """Change a task's legacy priority and default scheduler config."""
        val slot = self._find_slot(id)
        if slot < 0:
            return false
        val tcb = self.tasks[slot]
        if tcb == nil:
            return false

        val was_ready = match tcb.state:
            case TaskState.Ready: true
            case _: false
        if was_ready:
            self._remove_ready(id)

        var task = tcb
        task.priority = priority
        task.schedule = default_task_schedule(priority)
        self.tasks[slot] = task

        if was_ready:
            self._enqueue_ready(id)
        true

    me set_schedule_config(id: TaskId, config: TaskScheduleConfig) -> bool:
        """Update scheduler policy metadata for schedctl/compiler integration."""
        val slot = self._find_slot(id)
        if slot < 0:
            return false
        val tcb = self.tasks[slot]
        if tcb == nil:
            return false

        val was_ready = match tcb.state:
            case TaskState.Ready: true
            case _: false
        if was_ready:
            self._remove_ready(id)

        var new_config = config
        val selected_cpu = self._select_cpu_for_config(new_config)
        new_config.home_cpu = selected_cpu

        var task = tcb
        task.schedule = new_config
        task.assigned_cpu = selected_cpu
        self.tasks[slot] = task

        if was_ready:
            self._enqueue_ready(id)
        true

    fn cpu_runnable_count(cpu_id: u32) -> i32:
        """Return runnable task count for one CPU run queue."""
        val cpu = self._normalize_cpu(cpu_id)
        self.cpu_runqueues[cpu as i64].runnable_count

    me restrict_isolation(id: TaskId, allow_network: bool, max_memory_pages: u64, max_threads: u32) -> bool:
        """Monotonically restrict task isolation metadata."""
        val slot = self._find_slot(id)
        if slot < 0:
            return false
        val tcb = self.tasks[slot]
        if tcb == nil:
            return false

        var task = tcb
        var profile = task.isolation
        profile.sandboxed = true
        if not allow_network:
            profile.allow_network = false
        if max_memory_pages > 0:
            if profile.max_memory_pages == 0 or max_memory_pages < profile.max_memory_pages:
                profile.max_memory_pages = max_memory_pages
        if max_threads > 0u32:
            if profile.max_threads == 0u32 or max_threads < profile.max_threads:
                profile.max_threads = max_threads
        profile.capability_generation = profile.capability_generation + 1
        task.isolation = profile
        self.tasks[slot] = task
        true

    me rebalance_once() -> bool:
        """Move one fair/background task from the busiest CPU to the idlest CPU."""
        var busiest = 0u32
        var idlest = 0u32
        var max_load = -1
        var min_load = 2147483647
        var cpu = 0u32
        while (cpu as i64) < self.cpu_runqueues.len():
            val load = self.cpu_runqueues[cpu as i64].runnable_count
            if load > max_load:
                max_load = load
                busiest = cpu
            if load < min_load:
                min_load = load
                idlest = cpu
            cpu = cpu + 1u32

        if max_load - min_load <= 1:
            return false

        val candidate = self._pick_migration_candidate(busiest, idlest)
        if candidate == nil:
            return false

        val task_id = candidate.unwrap()
        self._remove_ready(task_id)
        val slot = self._find_slot(task_id)
        if slot < 0:
            return false
        val tcb = self.tasks[slot]
        if tcb == nil:
            return false

        var task = tcb
        var config = task.schedule
        config.home_cpu = idlest
        task.schedule = config
        task.assigned_cpu = idlest
        self.tasks[slot] = task
        self._enqueue_ready(task_id)
        true

    # -- IF-02 Fork/Exec Contract (wave-3 scaffolds) -------------------------
    # Real COW page-table clone + ELF load arrive in wave 4.

    me clone_task(parent_id: TaskId) -> TaskId:
        """Clone parent task into new child task (IF-02).

        Wave-4 scaffold: looks up parent TCB, allocates a fresh TaskId,
        copies registers/priority/parent linkage, marks child Ready,
        and enqueues it. Page-table COW arrives in wave-4b.
        """
        val parent_slot = self._find_slot(parent_id)
        if parent_slot < 0:
            return TaskId(id: 0)
        val parent_tcb = self.tasks[parent_slot]
        if parent_tcb == nil:
            return TaskId(id: 0)
        val parent = parent_tcb

        val child_id = TaskId(id: self.next_task_id)
        self.next_task_id = self.next_task_id + 1

        val child_slot = self._find_empty_slot()
        if child_slot < 0:
            return TaskId(id: 0)

        val child_as = vmm_cow_clone_pages(parent.address_space)

        val child = TaskControlBlock(
            id: child_id,
            state: TaskState.Ready,
            priority: parent.priority,
            is_user: parent.is_user,
            entry_point: parent.entry_point,
            context: parent.context,
            user_context: parent.user_context,
            address_space: child_as,
            kernel_stack: parent.kernel_stack,
            user_stack: parent.user_stack,
            capabilities: parent.capabilities,
            parent: Some(parent_id),
            schedule: parent.schedule,
            isolation: default_task_isolation(child_as),
            assigned_cpu: parent.assigned_cpu,
            exit_code: 0,
            ticks_remaining: TIME_SLICE_TICKS
        )

        self.tasks[child_slot] = child

        # Register capability record for the cloned child task.
        cap_init_task_record(child_id, true)

        self._enqueue_ready(child_id)

        child_id

    fn exec_into(task_id: TaskId, argv: [Text], envp: [Text]) -> i32:
        """Replace task image with ELF at argv[0] (IF-02).

        Wave-3 scaffold returns -38 (ENOSYS). Wave-4 parses ELF, maps
        PT_LOAD segments into the task's address space, resets RIP/RSP,
        and wires argv/envp onto the new stack.
        """
        val _t = task_id
        val _a = argv
        val _e = envp
        -38

    fn wait_for(parent_id: TaskId, child_id: TaskId) -> i32:
        """Block parent until child exits, return exit status (IF-02).

        Wave-3 scaffold returns -10 (ECHILD). Wave-4 will suspend the
        parent on a wait-queue and wake it from the child's exit path.
        """
        val _p = parent_id
        val _c = child_id
        -10

    # -- Internal Helpers ----------------------------------------------------

    me _enqueue_ready(id: TaskId):
        """Put a ready task into both legacy and per-CPU run queues."""
        val slot = self._find_slot(id)
        if slot < 0:
            return
        val tcb = self.tasks[slot]
        if tcb == nil:
            return
        val task = tcb
        val queue_idx = _priority_to_index(task.priority)
        self.ready_queues[queue_idx].enqueue(id)

        val cpu = self._normalize_cpu(task.assigned_cpu)
        var rq = self.cpu_runqueues[cpu as i64]
        rq.enqueue(id, task.schedule)
        self.cpu_runqueues[cpu as i64] = rq

    me _remove_ready(id: TaskId):
        """Remove a task from all ready queues."""
        val slot = self._find_slot(id)
        if slot < 0:
            return
        val tcb = self.tasks[slot]
        if tcb == nil:
            return
        val task = tcb

        var p = 0
        while p < PRIORITY_LEVELS:
            self.ready_queues[p].remove(id)
            p = p + 1

        val cpu = self._normalize_cpu(task.assigned_cpu)
        var rq = self.cpu_runqueues[cpu as i64]
        rq.remove(id, task.schedule)
        self.cpu_runqueues[cpu as i64] = rq

    me _pick_fifo_from(queue_name: text, cpu: u32) -> TaskId?:
        """Pick from fixed-order class queues on a CPU."""
        var rq = self.cpu_runqueues[cpu as i64]
        var picked: TaskId? = nil
        if queue_name == "deadline":
            picked = rq.deadline_queue.dequeue()
        elif queue_name == "idle":
            picked = rq.idle_queue.dequeue()
        if picked != nil:
            val task_id = picked.unwrap()
            val slot = self._find_slot(task_id)
            if slot >= 0:
                val tcb = self.tasks[slot]
                if tcb != nil:
                    val task = tcb
                    if rq.runnable_count > 0:
                        rq.runnable_count = rq.runnable_count - 1
                    if rq.weighted_load >= task.schedule.weight:
                        rq.weighted_load = rq.weighted_load - task.schedule.weight
                    else:
                        rq.weighted_load = 0
            self.cpu_runqueues[cpu as i64] = rq
        picked

    me _pick_rt_from(cpu: u32) -> TaskId?:
        """Pick the runnable RT task with the highest static priority."""
        var rq = self.cpu_runqueues[cpu as i64]
        var q = rq.rt_queue
        if q.count == 0:
            return nil

        var best: TaskId? = nil
        var best_priority: i64 = 9223372036854775807
        var scan = q.head
        var scanned = 0
        while scanned < q.count:
            val idx = scan % q.capacity
            val candidate = TaskId(id: q.entries[idx])
            val slot = self._find_slot(candidate)
            if slot >= 0:
                val tcb = self.tasks[slot]
                if tcb != nil:
                    val task = tcb
                    if task.schedule.priority < best_priority:
                        best = candidate
                        best_priority = task.schedule.priority
            scan = scan + 1
            scanned = scanned + 1

        if best == nil:
            best = q.dequeue()
        else:
            q.remove(best.unwrap())

        rq.rt_queue = q
        if best != nil:
            val task_id = best.unwrap()
            val slot = self._find_slot(task_id)
            if slot >= 0:
                val tcb = self.tasks[slot]
                if tcb != nil:
                    val task = tcb
                    if rq.runnable_count > 0:
                        rq.runnable_count = rq.runnable_count - 1
                    if rq.weighted_load >= task.schedule.weight:
                        rq.weighted_load = rq.weighted_load - task.schedule.weight
                    else:
                        rq.weighted_load = 0
        self.cpu_runqueues[cpu as i64] = rq
        best

    me _pick_fair_from(cpu: u32, background: bool) -> TaskId?:
        """Pick earliest eligible virtual deadline from fair/background lane."""
        var rq = self.cpu_runqueues[cpu as i64]
        var q = if background: rq.background_queue else: rq.fair_queue
        if q.count == 0:
            return nil

        var best: TaskId? = nil
        var best_deadline: i64 = 9223372036854775807
        var scan = q.head
        var scanned = 0
        while scanned < q.count:
            val idx = scan % q.capacity
            val candidate = TaskId(id: q.entries[idx])
            val slot = self._find_slot(candidate)
            if slot >= 0:
                val tcb = self.tasks[slot]
                if tcb != nil:
                    val task = tcb
                    val eligible = task.schedule.lag >= 0
                    if eligible and task.schedule.virtual_deadline < best_deadline:
                        best = candidate
                        best_deadline = task.schedule.virtual_deadline
            scan = scan + 1
            scanned = scanned + 1

        if best == nil:
            best = q.dequeue()
        else:
            q.remove(best.unwrap())

        if background:
            rq.background_queue = q
        else:
            rq.fair_queue = q
        if best != nil:
            val task_id = best.unwrap()
            val slot = self._find_slot(task_id)
            if slot >= 0:
                val tcb = self.tasks[slot]
                if tcb != nil:
                    val task = tcb
                    if rq.runnable_count > 0:
                        rq.runnable_count = rq.runnable_count - 1
                    if rq.weighted_load >= task.schedule.weight:
                        rq.weighted_load = rq.weighted_load - task.schedule.weight
                    else:
                        rq.weighted_load = 0
        self.cpu_runqueues[cpu as i64] = rq
        best

    me _pick_next_on_cpu(cpu: u32) -> TaskId?:
        """Class-order pick for one CPU run queue."""
        val dl = self._pick_fifo_from("deadline", cpu)
        if dl != nil:
            return dl
        val rt = self._pick_rt_from(cpu)
        if rt != nil:
            return rt
        val fair = self._pick_fair_from(cpu, false)
        if fair != nil:
            return fair
        val bg = self._pick_fair_from(cpu, true)
        if bg != nil:
            return bg
        self._pick_fifo_from("idle", cpu)

    fn _pick_migration_candidate(from_cpu: u32, to_cpu: u32) -> TaskId?:
        """Find a fair/background task that can move between two CPU queues."""
        val cpu = self._normalize_cpu(from_cpu)
        val target = self._normalize_cpu(to_cpu)
        val rq = self.cpu_runqueues[cpu as i64]
        val fair = self._scan_migration_queue(rq.fair_queue, target)
        if fair != nil:
            return fair
        self._scan_migration_queue(rq.background_queue, target)

    fn _scan_migration_queue(queue: ReadyQueue, to_cpu: u32) -> TaskId?:
        """Return the first queued task whose affinity allows the target CPU."""
        var scan = queue.head
        var scanned = 0
        while scanned < queue.count:
            val idx = scan % queue.capacity
            val candidate = TaskId(id: queue.entries[idx])
            val slot = self._find_slot(candidate)
            if slot >= 0:
                val tcb = self.tasks[slot]
                if tcb != nil:
                    val task = tcb
                    if _affinity_allows_cpu(task.schedule.affinity_mask, to_cpu):
                        return candidate
            scan = scan + 1
            scanned = scanned + 1
        nil

    fn _select_cpu_for_config(config: TaskScheduleConfig) -> u32:
        """Choose the least-loaded allowed CPU, preferring the requested home CPU."""
        val requested = self._normalize_cpu(config.home_cpu)
        if _affinity_allows_cpu(config.affinity_mask, requested):
            return requested

        var best = 0u32
        var best_load = 2147483647
        var cpu = 0u32
        while (cpu as i64) < self.cpu_runqueues.len():
            if _affinity_allows_cpu(config.affinity_mask, cpu):
                val load = self.cpu_runqueues[cpu as i64].runnable_count
                if load < best_load:
                    best_load = load
                    best = cpu
            cpu = cpu + 1u32
        best

    fn _normalize_cpu(cpu_id: u32) -> u32:
        """Clamp an external CPU id into the configured run-queue range."""
        if self.cpu_runqueues.len() == 0:
            return 0u32
        if (cpu_id as i64) >= self.cpu_runqueues.len():
            return 0u32
        cpu_id

    fn _find_slot(id: TaskId) -> i32:
        """Find the slot index for a given task ID. Returns -1 if not found."""
        var i = 0
        while i < MAX_TASKS:
            val tcb = self.tasks[i]
            if tcb != nil:
                val task = tcb
                if task.id.id == id.id:
                    return i
            i = i + 1
        -1

    fn _find_empty_slot() -> i32:
        """Find the first empty slot. Returns -1 if full."""
        var i = 0
        while i < MAX_TASKS:
            if self.tasks[i] == nil:
                return i
            i = i + 1
        -1

# ============================================================================
# Priority Mapping
# ============================================================================

fn _priority_to_index(priority: TaskPriority) -> i32:
    """Map TaskPriority enum to ready queue index (0 = highest)."""
    match priority:
        case Realtime: 0
        case High: 1
        case Normal: 2
        case Low: 3
        case Idle: 4

fn _affinity_allows_cpu(mask: u64, cpu: u32) -> bool:
    """Return true when an affinity mask permits a CPU id."""
    if cpu >= 64u32:
        return false
    val bit = 1u64 << cpu
    (mask & bit) != 0
