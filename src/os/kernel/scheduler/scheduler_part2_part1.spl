# Module-level task-id counter shared across all task-creation paths.
impl Scheduler:
    static fn new() -> Scheduler:
        Scheduler.new_with_cpu_count(DEFAULT_SCHED_CPUS)

    static fn new_with_cpu_count(cpu_count: u32) -> Scheduler:
        val detected_topology = scheduler_detect_platform_topology(cpu_count)
        Scheduler.new_with_topology(detected_topology)

    static fn new_bootstrap() -> Scheduler:
        Scheduler.new_with_topology(scheduler_flat_topology(1u32))

    static fn new_with_topology(detected_topology: SchedulerTopology) -> Scheduler:
        sched_new_with_topology_impl(detected_topology)

    # -- Task Lifecycle -------------------------------------------------------

    me create_task(entry: u64, priority: TaskPriority, caps: CapabilitySet) -> TaskId:
        val (id, new_tasks) = sched_create_task_impl(self.tasks, self.current, entry, priority, caps)
        self.tasks = new_tasks
        if id.id != 0:
            self._enqueue_ready(id)
        id

    me create_user_task_pid(image: UserProcessImage, priority: TaskPriority, caps: CapabilitySet) -> u64:
        val (pid, new_tasks, slot) = sched_create_user_task_pid_impl(self.tasks, self.current, image, priority, caps)
        self.tasks = new_tasks
        if pid != 0 and slot >= 0:
            self._enqueue_ready_at_slot(TaskId(id: pid), slot)
        pid

    me create_user_task(image: UserProcessImage, priority: TaskPriority, caps: CapabilitySet) -> TaskId:
        TaskId(id: self.create_user_task_pid(image, priority, caps))

    me create_bootstrap_user_task_pid(image: UserProcessImage, priority: TaskPriority, caps: CapabilitySet) -> u64:
        val (pid, new_tasks) = sched_create_bootstrap_user_task_pid_impl(self.tasks, image, priority, caps)
        self.tasks = new_tasks
        if pid != 0:
            self._enqueue_ready_at_slot(TaskId(id: pid), 0)
        pid

    me _enqueue_ready_at_slot(id: TaskId, slot: i32):
        if slot < 0:
            return
        val tcb = self.tasks[slot]
        if tcb == nil:
            return
        val task = tcb
        val queue_idx = _priority_to_index(task.priority)
        self.ready_queues[queue_idx].enqueue(id)
        val cpu = self._normalize_cpu(task.assigned_cpu)
        var rq = self.cpu_runqueues[cpu as i64]
        rq.enqueue(id, task.schedule)
        self.cpu_runqueues[cpu as i64] = rq

    fn get_user_context(self, task_id: TaskId) -> TaskContext?:
        val slot = self._find_slot(task_id)
        if slot < 0:
            return nil
        val tcb = self.tasks[slot]
        if tcb == nil:
            return nil
        tcb.user_context

    me exit_task(code: i32):
        self.exit_task_by_id(self.current, code)

    me exit_task_by_id(id: TaskId, code: i32):
        val new_tasks = sched_exit_task_by_id_with_code_impl(self.tasks, id, code)
        self.tasks = new_tasks
        self._remove_ready(id)
        self._wake_exit_waiters(id)

    me yield_current():
        val current_slot = self._find_slot(self.current)
        if current_slot < 0:
            return
        val tcb = self.tasks[current_slot]
        if tcb == nil:
            return
        var task = tcb
        task.state = TaskState.Ready
        task.ticks_remaining = TIME_SLICE_TICKS
        self.tasks[current_slot] = task
        self._enqueue_ready(self.current)

    me block_task(id: TaskId, reason: BlockReason):
        val new_tasks = sched_block_task_impl(self.tasks, id, reason)
        self.tasks = new_tasks
        self._remove_ready(id)

    me unblock_task(id: TaskId):
        self.unblock_task_on_cpu(id, self._current_cpu_hint())

    me unblock_task_on_cpu(id: TaskId, waker_cpu: u32) -> SchedulerPreemptionDecision:
        val new_tasks = sched_unblock_task_impl(self.tasks, id)
        val slot = _find_slot_in(new_tasks, id)
        if slot < 0:
            return SchedulerPreemptionDecision(
                should_preempt: false, cpu: self._normalize_cpu(waker_cpu),
                task: id, reason: SchedulerPreemptionReason.None
            )
        self.tasks = new_tasks
        val wake_cpu = self._normalize_cpu(waker_cpu)
        self._enqueue_woken_ready(id, wake_cpu)
        self._maybe_rebalance_after_wake(wake_cpu)
        var selected_cpu = wake_cpu
        val updated = self.get_task(id)
        if updated != nil:
            selected_cpu = updated.unwrap().assigned_cpu
        val decision = sched_wakeup_preemption_decision(self.tasks, self.current_by_cpu, id, selected_cpu)
        if decision.should_preempt:
            self.preempt_pending_by_cpu[selected_cpu as i64] = Some(id)
            self._trace(SchedulerTraceKind.WakePreempt, id, selected_cpu, 1)
        decision

    me wake_expired_sleepers(now_ns: u64) -> u32:
        val (new_tasks, to_unblock, woken) = sched_wake_expired_sleepers_impl(self.tasks, now_ns)
        self.tasks = new_tasks
        for tid in to_unblock:
            self.unblock_task(tid)
        woken

    # -- Scheduling -----------------------------------------------------------

    me schedule() -> TaskContext:
        self.schedule_on_cpu(0u32)

    me schedule_on_cpu(cpu_id: u32) -> TaskContext:
        val cpu = self._normalize_cpu(cpu_id)
        val next_id = self._pick_next_on_cpu(cpu)
        if next_id != nil:
            val task_id = next_id
            self._remove_ready(task_id)
            val slot = self._find_slot(task_id)
            if slot >= 0:
                val tcb = self.tasks[slot]
                if tcb != nil:
                    var task = tcb
                    task.state = TaskState.Running
                    task.ticks_remaining = TIME_SLICE_TICKS
                    self.tasks[slot] = task
                    val old_tid_v = self.current.id as i64
                    self.current = task_id
                    self.current_by_cpu[cpu as i64] = task_id
                    self.preempt_pending_by_cpu[cpu as i64] = nil
                    replay_hook_schedule(old_tid_v, task_id.id as i64, self.tick_count as i64)
                    return task.context
        val idle_tcb = self.tasks[0]
        if idle_tcb != nil:
            return idle_tcb.context
        TaskContext(
            rax: 0, rbx: 0, rcx: 0, rdx: 0, rsi: 0, rdi: 0, rbp: 0, rsp: 0,
            r8: 0, r9: 0, r10: 0, r11: 0, r12: 0, r13: 0, r14: 0, r15: 0,
            rip: 0, rflags: 0x202, cs: 0x08, ss: 0x10, fpu_state: 0
        )

    me timer_tick(ctx: TaskContext) -> TaskContext:
        self.tick_count = self.tick_count + 1
        self.wake_expired_sleepers(self.tick_count * SCHED_TICK_NS)
        val current_slot = self._find_slot(self.current)
        if current_slot < 0:
            return self.schedule()
        val tcb = self.tasks[current_slot]
        if tcb == nil:
            return self.schedule()
        var task = tcb
        task.context = ctx
        task = _account_task_tick(task)
        task = self._account_realtime_tick(task, 0u32)
        task = self._account_deadline_tick(task, current_slot, 0u32)
        val still_running = match task.state:
            case TaskState.Running: true
            case _: false
        if not still_running:
            self.tasks[current_slot] = task
            return self.schedule()
        if task.ticks_remaining > 0:
            task.ticks_remaining = task.ticks_remaining - 1
        if task.ticks_remaining == 0:
            task.state = TaskState.Ready
            task.ticks_remaining = TIME_SLICE_TICKS
            self.tasks[current_slot] = task
            self._enqueue_ready(self.current)
            self._maybe_rebalance_after_wake(task.assigned_cpu)
            return self.schedule()
        self.tasks[current_slot] = task
        ctx

    # -- Queries --------------------------------------------------------------

    fn get_current() -> TaskId:
        self.current

    fn get_task(id: TaskId) -> TaskControlBlock?:
        val slot = self._find_slot(id)
        if slot < 0:
            return nil
        self.tasks[slot]

    fn get_user_handoff_task(pid_hint: u64) -> TaskControlBlock?:
        var best: TaskControlBlock? = nil
        var best_pid: u64 = 0
        var i = 0
        while i < MAX_TASKS:
            val tcb = self.tasks[i]
            if tcb != nil:
                val task = tcb
                val wanted = if pid_hint == 0: true else: task.id.id == pid_hint
                if wanted and task.is_user and task.user_context != nil:
                    if pid_hint != 0:
                        return task
                    if task.id.id > best_pid:
                        best_pid = task.id.id
                        best = task
            i = i + 1
        best

    fn active_task_count() -> i32:
        var count = 0
        var i = 0
        while i < MAX_TASKS:
            if self.tasks[i] != nil:
                count = count + 1
            i = i + 1
        count

    fn task_id_at_active_index(index: i32) -> u64:
        if index < 0:
            return 0
        var seen = 0
        var i = 0
        while i < MAX_TASKS:
            val tcb = self.tasks[i]
            if tcb != nil:
                if seen == index:
                    return tcb.id.id
                seen = seen + 1
            i = i + 1
        0

    me set_task_name(id: TaskId, name: text) -> bool:
        val (new_tasks, ok) = sched_set_task_name_impl(self.tasks, id, name)
        self.tasks = new_tasks
        ok

    fn get_tick_count() -> u64:
        self.tick_count

    fn tick_count() -> u64:
        self.tick_count

    me set_priority(id: TaskId, priority: TaskPriority) -> bool:
        val slot = self._find_slot(id)
        if slot < 0:
            return false
        val tcb = self.tasks[slot]
        if tcb == nil:
            return false
        val was_ready = match tcb.state:
            case TaskState.Ready: true
            case _: false
        if was_ready:
            self._remove_ready(id)
        var task = tcb
        task.priority = priority
        task.schedule = default_task_schedule(priority)
        self.tasks[slot] = task
        if was_ready:
            self._enqueue_ready(id)
        true

    me set_schedule_config(id: TaskId, config: TaskScheduleConfig) -> bool:
        val slot = self._find_slot(id)
        if slot < 0:
            return false
        val tcb = self.tasks[slot]
        if tcb == nil:
            return false
        val was_ready = match tcb.state:
            case TaskState.Ready: true
            case _: false
        if was_ready:
            self._remove_ready(id)
        var new_config = config
        val selected_cpu = sched_select_cpu_for_config(self.cpu_runqueues, new_config)
        new_config.home_cpu = selected_cpu
        var task = tcb
        task.schedule = new_config
        task.assigned_cpu = selected_cpu
        self.tasks[slot] = task
        if was_ready:
            self._enqueue_ready(id)
        true

    me admit_deadline(id: TaskId, runtime_ns: u64, period_ns: u64, deadline_ns: u64, affinity_mask: u64) -> i32:
        if runtime_ns == 0 or period_ns == 0 or deadline_ns == 0:
            return -22
        if runtime_ns > deadline_ns or deadline_ns > period_ns:
            return -22
        val slot = self._find_slot(id)
        if slot < 0:
            return -3
        val tcb = self.tasks[slot]
        if tcb == nil:
            return -3
        val selected_cpu = sched_select_deadline_cpu(
            self.tasks, self.cpu_runqueues,
            self.deadline_remaining_ns_by_slot,
            runtime_ns, period_ns, affinity_mask, id)
        if selected_cpu < 0:
            return -28
        val was_ready = match tcb.state:
            case TaskState.Ready: true
            case _: false
        if was_ready:
            self._remove_ready(id)
        var task = tcb
        var config = task.schedule
        config.policy = SchedulerPolicy.Deadline
        config.weight = 4096
        config.priority = -1
        config.requested_slice_ns = runtime_ns
        config.runtime_ns = runtime_ns
        config.period_ns = period_ns
        config.deadline_ns = deadline_ns
        config.lag = 0
        config.affinity_mask = if affinity_mask > 0: affinity_mask else: 0xFFFFFFFFFFFFFFFF
        config.home_cpu = selected_cpu.to_u32()
        config.virtual_deadline = ((self.tick_count * SCHED_TICK_NS) + deadline_ns).to_i64()
        task.schedule = config
        task.assigned_cpu = selected_cpu.to_u32()
        self.tasks[slot] = task
        self.deadline_remaining_ns_by_slot[slot] = runtime_ns
        self.deadline_period_start_ns_by_slot[slot] = self.tick_count * SCHED_TICK_NS
        self.deadline_miss_count_by_slot[slot] = 0
        self.deadline_overrun_count_by_slot[slot] = 0
        self._trace(SchedulerTraceKind.DeadlineAdmit, id, selected_cpu.to_u32(), runtime_ns)
        if was_ready:
            self._enqueue_ready(id)
        0

    fn cpu_runnable_count(cpu_id: u32) -> i32:
        val cpu = self._normalize_cpu(cpu_id)
        self.cpu_runqueues[cpu as i64].runnable_count

    fn topology_cpu_count() -> u32:
        self.topology.cpu_count

    fn topology_domain_count() -> i32:
        self.topology.domains.len()

    fn topology_domain(index: i32) -> SchedulerDomain?:
        if index < 0 or index >= self.topology.domains.len():
            return nil
        Some(self.topology.domains[index])

    me set_topology(topology: SchedulerTopology) -> bool:
        if topology.cpu_count == 0u32:
            return false
        self.topology = topology
        var cpu = self.cpu_runqueues.len() as u32
        while cpu < self.topology.cpu_count:
            self.cpu_runqueues.push(CpuRunQueue.new(cpu))
            self.current_by_cpu.push(TaskId(id: 0))
            self.preempt_pending_by_cpu.push(nil)
            self.rt_runtime_ns_by_cpu.push(0)
            self.rt_period_ns_by_cpu.push(0)
            self.rt_consumed_ns_by_cpu.push(0)
            self.rt_replenish_ns_by_cpu.push(0)
            self.rt_throttled_by_cpu.push(false)
            cpu = cpu + 1u32
        self.green_execution_state = green_carrier_extend_execution_state(
            self.green_execution_state,
            self.topology.cpu_count as i64
        )
        self.green_parallelism_state = green_carrier_parallelism_for_topology(
            self.green_parallelism_state,
            self.topology.cpu_count as i64
        )
        true

    fn get_current_on_cpu(cpu_id: u32) -> TaskId:
        val cpu = self._normalize_cpu(cpu_id)
        self.current_by_cpu[cpu as i64]

    me apply_green_scheduler_intent(intent: GreenCarrierSchedulerIntent) -> GreenCarrierExecutionResult:
        if intent.should_run and intent.should_context_switch and (intent.cpu as i64) >= self.green_parallelism_state.active_limit:
            val rejected = green_carrier_reject_scheduler_intent(
                self.green_execution_state,
                intent,
                "inactive_green_carrier"
            )
            self.green_execution_state = rejected.state
            return rejected
        val result = green_carrier_apply_scheduler_intent(self.green_execution_state, intent)
        self.green_execution_state = result.state
        result

    fn green_current_task_on_cpu(cpu_id: u32) -> u64:
        val cpu = self._normalize_cpu(cpu_id)
        green_carrier_current_task_on_cpu(self.green_execution_state, cpu as i64)

    fn green_context_switches_on_cpu(cpu_id: u32) -> i64:
        val cpu = self._normalize_cpu(cpu_id)
        green_carrier_context_switches_on_cpu(self.green_execution_state, cpu as i64)

    fn green_rejected_intents() -> i64:
        self.green_execution_state.rejected_intents

    me set_green_carrier_parallelism(requested_limit: i64) -> GreenCarrierParallelismState:
        val next_state = green_carrier_set_parallelism(self.green_parallelism_state, requested_limit)
        self.green_parallelism_state = next_state
        next_state

    fn green_carrier_parallelism_requested() -> i64:
        self.green_parallelism_state.requested_limit

    fn green_carrier_parallelism_limit() -> i64:
        self.green_parallelism_state.active_limit

    fn green_carrier_parallelism_reason() -> text:
        self.green_parallelism_state.reason

    fn rebalance_green_carrier_queues(queues: GreenCarrierRunQueueState, decision: GreenWorkerRebalanceDecision) -> GreenCarrierRebalanceResult:
        green_carrier_apply_rebalance_decision(queues, decision, self.green_parallelism_state.active_limit)

    fn rebalance_green_carrier_queues_from_depth(queues: GreenCarrierRunQueueState, rebalance_threshold: i64) -> GreenCarrierRebalanceResult:
        val decision = green_worker_rebalance_decision(
            self.topology.cpu_count as i64,
            green_carrier_queue_depth(queues, 0),
            green_carrier_queue_depth(queues, 1),
            green_carrier_queue_depth(queues, 2),
            green_carrier_queue_depth(queues, 3),
            rebalance_threshold
        )
        self.rebalance_green_carrier_queues(queues, decision)

    fn _green_rebalance_active_target_cpu(queues: GreenCarrierRunQueueState) -> i64:
        val active_limit = self.green_parallelism_state.active_limit
        if active_limit < 1:
            return -1
        var target_cpu = 0
        var target_depth = green_carrier_queue_depth(queues, 0)
        var cpu = 1
        while cpu < active_limit:
            val depth = green_carrier_queue_depth(queues, cpu)
            if depth < target_depth:
                target_depth = depth
                target_cpu = cpu
            cpu = cpu + 1
        target_cpu

    fn _green_rebalance_inactive_source_cpu(queues: GreenCarrierRunQueueState) -> i64:
        var cpu = self.green_parallelism_state.active_limit
        val cpu_count = self.topology.cpu_count as i64
        while cpu < cpu_count:
            if green_carrier_queue_depth(queues, cpu) > 0:
                return cpu
            cpu = cpu + 1
        -1

    fn rebalance_green_carrier_queues_until_stable(queues: GreenCarrierRunQueueState, max_moves: i64) -> GreenCarrierRebalancePassResult:
        if max_moves < 1:
            return GreenCarrierRebalancePassResult(
                queues: queues,
                moved_workers: 0,
                last_task_id: -1,
                last_from_cpu: -1,
                last_to_cpu: -1,
                reason: "move_budget_empty"
            )
        var current = queues
        var moved_workers = 0
        var last_task_id = -1
        var last_from_cpu = -1
        var last_to_cpu = -1
        while moved_workers < max_moves:
            val source_cpu = self._green_rebalance_inactive_source_cpu(current)
            if source_cpu < 0:
                return GreenCarrierRebalancePassResult(
                    queues: current,
                    moved_workers: moved_workers,
                    last_task_id: last_task_id,
                    last_from_cpu: last_from_cpu,
                    last_to_cpu: last_to_cpu,
                    reason: if moved_workers > 0: "inactive_sources_drained" else: "no_inactive_work"
                )
            val target_cpu = self._green_rebalance_active_target_cpu(current)
            if target_cpu < 0:
                return GreenCarrierRebalancePassResult(
                    queues: current,
                    moved_workers: moved_workers,
                    last_task_id: last_task_id,
                    last_from_cpu: last_from_cpu,
                    last_to_cpu: last_to_cpu,
                    reason: "no_active_carrier"
                )
            val moved = green_carrier_rebalance_one(current, source_cpu, target_cpu, self.green_parallelism_state.active_limit)
            if not moved.moved:
                return GreenCarrierRebalancePassResult(
                    queues: moved.queues,
                    moved_workers: moved_workers,
                    last_task_id: last_task_id,
                    last_from_cpu: last_from_cpu,
                    last_to_cpu: last_to_cpu,
                    reason: moved.reason
                )
            current = moved.queues
            moved_workers = moved_workers + 1
            last_task_id = moved.task_id
            last_from_cpu = moved.from_cpu
            last_to_cpu = moved.to_cpu
        GreenCarrierRebalancePassResult(
            queues: current,
            moved_workers: moved_workers,
            last_task_id: last_task_id,
            last_from_cpu: last_from_cpu,
            last_to_cpu: last_to_cpu,
            reason: "move_budget_exhausted"
        )

    me run_green_carrier_once(queues: GreenCarrierRunQueueState, cpu: i64) -> GreenCarrierRunStepResult:
        val dispatch = green_carrier_dispatch_next_with_limit(
            queues,
            cpu,
            self.green_parallelism_state.active_limit
        )
        val execution = self.apply_green_scheduler_intent(green_carrier_scheduler_intent(dispatch))
        GreenCarrierRunStepResult(
            queues: dispatch.queues,
            dispatch: dispatch,
            execution: execution,
            ran: execution.applied,
            reason: execution.reason
        )

    me run_green_carrier_active_pass(queues: GreenCarrierRunQueueState, rebalance_move_budget: i64) -> GreenCarrierRunPassResult:
        val rebalance = self.rebalance_green_carrier_queues_until_stable(queues, rebalance_move_budget)
        var current = rebalance.queues
        var attempted_carriers = 0
        var ran_workers = 0
        var last_cpu = -1
        var last_task_id = -1
        var carrier_limit = self.green_parallelism_state.active_limit
        if carrier_limit > current.queue_depth_by_cpu.len():
            carrier_limit = current.queue_depth_by_cpu.len()
        if carrier_limit < 1:
            return GreenCarrierRunPassResult(
                queues: current,
                rebalance: rebalance,
                ran_workers: 0,
                attempted_carriers: 0,
                last_cpu: -1,
                last_task_id: -1,
                reason: "no_active_carrier"
            )
        var cpu = 0
        while cpu < carrier_limit:
            val step = self.run_green_carrier_once(current, cpu)
            current = step.queues
            attempted_carriers = attempted_carriers + 1
            if step.ran:
                ran_workers = ran_workers + 1
                last_cpu = cpu
                last_task_id = step.dispatch.task_id
            cpu = cpu + 1
        GreenCarrierRunPassResult(
            queues: current,
            rebalance: rebalance,
            ran_workers: ran_workers,
            attempted_carriers: attempted_carriers,
            last_cpu: last_cpu,
            last_task_id: last_task_id,
            reason: if ran_workers > 0: "active_pass_ran" else: "no_active_work"
        )

    me run_green_carrier_until_blocked_or_budget(queues: GreenCarrierRunQueueState, rebalance_move_budget: i64, max_passes: i64) -> GreenCarrierRunLoopResult:
        if max_passes < 1:
            return GreenCarrierRunLoopResult(
                queues: queues,
                attempted_passes: 0,
                ran_passes: 0,
                ran_workers: 0,
                attempted_carriers: 0,
                last_task_id: -1,
                reason: "pass_budget_empty"
            )
        var current = queues
        var attempted_passes = 0
        var ran_passes = 0
        var ran_workers = 0
        var attempted_carriers = 0
        var last_task_id = -1
        while attempted_passes < max_passes:
            val pass_result = self.run_green_carrier_active_pass(current, rebalance_move_budget)
            current = pass_result.queues
            attempted_passes = attempted_passes + 1
            attempted_carriers = attempted_carriers + pass_result.attempted_carriers
            if pass_result.ran_workers < 1:
                return GreenCarrierRunLoopResult(
                    queues: current,
                    attempted_passes: attempted_passes,
                    ran_passes: ran_passes,
                    ran_workers: ran_workers,
                    attempted_carriers: attempted_carriers,
                    last_task_id: last_task_id,
                    reason: "no_active_work"
                )
            ran_passes = ran_passes + 1
            ran_workers = ran_workers + pass_result.ran_workers
            last_task_id = pass_result.last_task_id
        GreenCarrierRunLoopResult(
            queues: current,
            attempted_passes: attempted_passes,
            ran_passes: ran_passes,
            ran_workers: ran_workers,
            attempted_carriers: attempted_carriers,
            last_task_id: last_task_id,
            reason: "run_budget_exhausted"
        )

    me run_green_channel_wake_pass(queues: GreenCarrierRunQueueState, task: GreenTaskRecord, receiver_task_id: i64, unparked: bool, waker_cpu: i64, home_load: i64, waker_load: i64, wake_affine_threshold: i64, current_cpu: i64, rebalance_move_budget: i64) -> GreenCarrierWakeRunResult:
        val decision = green_carrier_channel_wake_task(
            task,
            receiver_task_id,
            unparked,
            waker_cpu,
            home_load,
            waker_load,
            wake_affine_threshold,
            current_cpu
        )
        val applied = green_carrier_apply_enqueue(queues, decision)
        if not applied.enqueued:
            val rebalance = GreenCarrierRebalancePassResult(
                queues: applied.queues,
                moved_workers: 0,
                last_task_id: -1,
                last_from_cpu: -1,
                last_to_cpu: -1,
                reason: "wake_not_enqueued"
            )
            val pass_result = GreenCarrierRunPassResult(
                queues: applied.queues,
                rebalance: rebalance,
                ran_workers: 0,
                attempted_carriers: 0,
                last_cpu: -1,
                last_task_id: -1,
                reason: applied.reason
            )
            return GreenCarrierWakeRunResult(
                queues: applied.queues,
                apply: applied,
                pass_result: pass_result,
                enqueued: false,
                ran: false,
                reason: applied.reason
            )
        val pass_result = self.run_green_carrier_active_pass(applied.queues, rebalance_move_budget)
        GreenCarrierWakeRunResult(
            queues: pass_result.queues,
            apply: applied,
            pass_result: pass_result,
            enqueued: true,
            ran: pass_result.ran_workers > 0,
            reason: pass_result.reason
        )

    fn preempt_pending_on_cpu(cpu_id: u32) -> TaskId?:
        val cpu = self._normalize_cpu(cpu_id)
        self.preempt_pending_by_cpu[cpu as i64]

    me idle_balance_once(cpu_id: u32) -> bool:
        val target = self._normalize_cpu(cpu_id)
        if self.cpu_runqueues[target as i64].runnable_count > 0:
            return false
        var busiest = target
        var max_load = 0
        var cpu = 0u32
        while (cpu as i64) < self.cpu_runqueues.len():
            val load = self.cpu_runqueues[cpu as i64].runnable_count
            if load > max_load:
                max_load = load
                busiest = cpu
            cpu = cpu + 1u32
        if max_load <= 0:
            return false
        val candidate = sched_pick_migration_candidate(self.tasks, self.cpu_runqueues, busiest, target)
        if candidate == nil:
            return false
        val task_id = candidate.unwrap()
        self._remove_ready(task_id)
        val slot = self._find_slot(task_id)
        if slot < 0:
            return false
        val tcb = self.tasks[slot]
        if tcb == nil:
            return false
        var task = tcb
        var config = task.schedule
        config.home_cpu = target
        task.schedule = config
        task.assigned_cpu = target
        self.tasks[slot] = task
        self._enqueue_ready(task_id)
        self.preempt_pending_by_cpu[target as i64] = Some(task_id)
        self._trace(SchedulerTraceKind.IdlePull, task_id, target, max_load as u64)
        true

    me configure_rt_bandwidth(cpu_id: u32, runtime_ns: u64, period_ns: u64) -> i32:
        if runtime_ns == 0 or period_ns == 0 or runtime_ns > period_ns:
            return -22
        val cpu = self._normalize_cpu(cpu_id)
        self.rt_runtime_ns_by_cpu[cpu as i64] = runtime_ns
        self.rt_period_ns_by_cpu[cpu as i64] = period_ns
        self.rt_consumed_ns_by_cpu[cpu as i64] = 0
        self.rt_replenish_ns_by_cpu[cpu as i64] = (self.tick_count * SCHED_TICK_NS) + period_ns
        self.rt_throttled_by_cpu[cpu as i64] = false
        0
