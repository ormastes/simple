# Scheduler Algorithm — free-function implementations for scheduling decisions,
# queue picking, load balancing, RT/deadline accounting, and context switching.
#
# Split from scheduler.spl to keep the hub under 800 lines.

use os.kernel.types.task_types.{
    TaskId, TaskState, TaskPriority, TaskContext, BlockReason,
    SchedulerPolicy, TaskScheduleConfig, SchedulerTopology
}
use os.kernel.log.klog_api.{log_raw_println}
use os.kernel.scheduler.scheduler_types.{
    TaskControlBlock, SchedulerPreemptionDecision, SchedulerPreemptionReason,
    SchedulerTraceEvent, SchedulerTraceKind,
    ReadyQueue, CpuRunQueue,
    MAX_TASKS, PRIORITY_LEVELS, TIME_SLICE_TICKS, SCHED_TICK_NS,
    SCHED_TRACE_CAPACITY, DEADLINE_BANDWIDTH_SCALE, DEADLINE_CPU_BANDWIDTH_CAP,
    _priority_to_index, _affinity_allows_cpu, _deadline_util,
    _account_task_tick, _account_fair_tick
}
use os.kernel.replay.hooks.{replay_hook_schedule}

# ============================================================================
# Scheduler-class rank
# ============================================================================

pub fn sched_class_rank(policy: SchedulerPolicy) -> i32:
    """Lower rank means stronger scheduling class for preemption tests."""
    match policy:
        case Internal: 0
        case Deadline: 1
        case RtFifo: 2
        case RtRoundRobin: 2
        case Fair: 3
        case Background: 4
        case Idle: 5

# ============================================================================
# Wakeup preemption decision
# ============================================================================

pub fn sched_wakeup_preemption_decision(
    tasks: [TaskControlBlock?],
    current_by_cpu: [TaskId],
    id: TaskId,
    cpu: u32
) -> SchedulerPreemptionDecision:
    """Compare a woken task with the task currently running on its CPU."""
    val running = current_by_cpu[cpu as i64]
    if running.id == 0:
        return SchedulerPreemptionDecision(
            should_preempt: true, cpu: cpu, task: id,
            reason: SchedulerPreemptionReason.IdlePull
        )
    val woken_slot = _find_slot_in_alg(tasks, id)
    val running_slot = _find_slot_in_alg(tasks, running)
    if woken_slot < 0 or running_slot < 0:
        return SchedulerPreemptionDecision(
            should_preempt: false, cpu: cpu, task: id,
            reason: SchedulerPreemptionReason.None
        )
    val woken_tcb = tasks[woken_slot]
    val running_tcb = tasks[running_slot]
    if woken_tcb == nil or running_tcb == nil:
        return SchedulerPreemptionDecision(
            should_preempt: false, cpu: cpu, task: id,
            reason: SchedulerPreemptionReason.None
        )
    val woken = woken_tcb
    val current = running_tcb
    val woken_rank = sched_class_rank(woken.schedule.policy)
    val running_rank = sched_class_rank(current.schedule.policy)
    if woken_rank < running_rank:
        return SchedulerPreemptionDecision(
            should_preempt: true, cpu: cpu, task: id,
            reason: SchedulerPreemptionReason.HigherSchedulerClass
        )
    if woken_rank == running_rank:
        if (woken.schedule.policy == SchedulerPolicy.Fair or
            woken.schedule.policy == SchedulerPolicy.Background):
            if (woken.schedule.lag >= 0 and
                woken.schedule.virtual_deadline < current.schedule.virtual_deadline):
                return SchedulerPreemptionDecision(
                    should_preempt: true, cpu: cpu, task: id,
                    reason: SchedulerPreemptionReason.EarlierVirtualDeadline
                )
    SchedulerPreemptionDecision(
        should_preempt: false, cpu: cpu, task: id,
        reason: SchedulerPreemptionReason.None
    )

# ============================================================================
# RT accounting
# ============================================================================

pub fn sched_replenish_rt(
    rt_runtime_ns_by_cpu: [u64],
    rt_period_ns_by_cpu: [u64],
    rt_consumed_ns_by_cpu: [u64],
    rt_replenish_ns_by_cpu: [u64],
    rt_throttled_by_cpu: [bool],
    tick_count: u64,
    cpu: u32
) -> ([u64], [bool]):
    """Replenish a CPU RT budget when its period expires. Returns (rt_replenish, rt_throttled)."""
    val runtime = rt_runtime_ns_by_cpu[cpu as i64]
    val period = rt_period_ns_by_cpu[cpu as i64]
    if runtime == 0 or period == 0:
        return (rt_replenish_ns_by_cpu, rt_throttled_by_cpu)
    val now = tick_count * SCHED_TICK_NS
    var new_replenish = rt_replenish_ns_by_cpu
    var new_throttled = rt_throttled_by_cpu
    if new_replenish[cpu as i64] == 0:
        new_replenish[cpu as i64] = now + period
        return (new_replenish, new_throttled)
    if now >= new_replenish[cpu as i64]:
        var new_consumed = rt_consumed_ns_by_cpu
        new_consumed[cpu as i64] = 0
        new_throttled[cpu as i64] = false
        new_replenish[cpu as i64] = now + period
    (new_replenish, new_throttled)

pub fn sched_rt_budget_available(rt_runtime_ns_by_cpu: [u64], rt_throttled_by_cpu: [bool], cpu: u32) -> bool:
    val runtime = rt_runtime_ns_by_cpu[cpu as i64]
    if runtime == 0:
        return true
    not rt_throttled_by_cpu[cpu as i64]

# ============================================================================
# Deadline accounting
# ============================================================================

pub fn sched_replenish_deadline_slot(
    tasks: [TaskControlBlock?],
    deadline_remaining_ns_by_slot: [u64],
    deadline_period_start_ns_by_slot: [u64],
    deadline_miss_count_by_slot: [u64],
    tick_count: u64,
    slot: i32
) -> ([u64], [u64], [u64]):
    """Replenish CBS runtime. Returns (remaining, period_start, miss_count)."""
    val tcb = tasks[slot]
    if tcb == nil:
        return (deadline_remaining_ns_by_slot, deadline_period_start_ns_by_slot, deadline_miss_count_by_slot)
    val task = tcb
    if task.schedule.policy != SchedulerPolicy.Deadline:
        return (deadline_remaining_ns_by_slot, deadline_period_start_ns_by_slot, deadline_miss_count_by_slot)
    val period = task.schedule.period_ns
    if period == 0:
        return (deadline_remaining_ns_by_slot, deadline_period_start_ns_by_slot, deadline_miss_count_by_slot)
    val now = tick_count * SCHED_TICK_NS
    var new_remaining = deadline_remaining_ns_by_slot
    var new_start = deadline_period_start_ns_by_slot
    var new_miss = deadline_miss_count_by_slot
    if new_start[slot] == 0:
        new_start[slot] = now
        new_remaining[slot] = task.schedule.runtime_ns
        return (new_remaining, new_start, new_miss)
    if now >= new_start[slot] + period:
        if new_remaining[slot] == 0:
            new_miss[slot] = new_miss[slot] + 1
        new_start[slot] = now
        new_remaining[slot] = task.schedule.runtime_ns
    (new_remaining, new_start, new_miss)

# ============================================================================
# CPU selection helpers
# ============================================================================

pub fn sched_normalize_cpu(cpu_runqueues_len: i64, cpu_id: u32) -> u32:
    if cpu_runqueues_len == 0:
        return 0u32
    if (cpu_id as i64) >= cpu_runqueues_len:
        return 0u32
    cpu_id

pub fn sched_select_wake_cpu(
    tasks: [TaskControlBlock?],
    cpu_runqueues: [CpuRunQueue],
    task: TaskControlBlock,
    waker_cpu: u32,
    wake_affine_threshold: i32
) -> u32:
    """Choose a wake CPU using affinity first, then conservative load spread."""
    val cpu_count = cpu_runqueues.len() as i64
    val wake_cpu = sched_normalize_cpu(cpu_count, waker_cpu)
    val home_cpu = sched_normalize_cpu(cpu_count, task.schedule.home_cpu)
    if _affinity_allows_cpu(task.schedule.affinity_mask, wake_cpu):
        val wake_load = cpu_runqueues[wake_cpu as i64].runnable_count
        val home_load = cpu_runqueues[home_cpu as i64].runnable_count
        if wake_load <= home_load + wake_affine_threshold:
            return wake_cpu
    if _affinity_allows_cpu(task.schedule.affinity_mask, home_cpu):
        return home_cpu
    sched_least_loaded_allowed_cpu(cpu_runqueues, task.schedule.affinity_mask)

pub fn sched_least_loaded_allowed_cpu(cpu_runqueues: [CpuRunQueue], affinity_mask: u64) -> u32:
    var best = 0u32
    var best_load = 2147483647
    var cpu = 0u32
    while (cpu as i64) < cpu_runqueues.len():
        if _affinity_allows_cpu(affinity_mask, cpu):
            val load = cpu_runqueues[cpu as i64].runnable_count
            if load < best_load:
                best = cpu
                best_load = load
        cpu = cpu + 1u32
    best

pub fn sched_load_spread(cpu_runqueues: [CpuRunQueue]) -> i32:
    var max_load = -1
    var min_load = 2147483647
    var cpu = 0u32
    while (cpu as i64) < cpu_runqueues.len():
        val load = cpu_runqueues[cpu as i64].runnable_count
        if load > max_load:
            max_load = load
        if load < min_load:
            min_load = load
        cpu = cpu + 1u32
    max_load - min_load

pub fn sched_select_cpu_for_config(cpu_runqueues: [CpuRunQueue], config: TaskScheduleConfig) -> u32:
    val requested = sched_normalize_cpu(cpu_runqueues.len() as i64, config.home_cpu)
    if _affinity_allows_cpu(config.affinity_mask, requested):
        return requested
    var best = 0u32
    var best_load = 2147483647
    var cpu = 0u32
    while (cpu as i64) < cpu_runqueues.len():
        if _affinity_allows_cpu(config.affinity_mask, cpu):
            val load = cpu_runqueues[cpu as i64].runnable_count
            if load < best_load:
                best_load = load
                best = cpu
        cpu = cpu + 1u32
    best

# ============================================================================
# Migration candidate selection
# ============================================================================

pub fn sched_scan_migration_queue(tasks: [TaskControlBlock?], queue: ReadyQueue, to_cpu: u32) -> TaskId?:
    var scan = queue.head
    var scanned = 0
    while scanned < queue.count:
        val idx = scan % queue.capacity
        val candidate = TaskId(id: queue.entries[idx])
        val slot = _find_slot_in_alg(tasks, candidate)
        if slot >= 0:
            val tcb = tasks[slot]
            if tcb != nil:
                val task = tcb
                if _affinity_allows_cpu(task.schedule.affinity_mask, to_cpu):
                    return candidate
        scan = scan + 1
        scanned = scanned + 1
    nil

pub fn sched_pick_migration_candidate(tasks: [TaskControlBlock?], cpu_runqueues: [CpuRunQueue], from_cpu: u32, to_cpu: u32) -> TaskId?:
    val cpu_count = cpu_runqueues.len() as i64
    val cpu = sched_normalize_cpu(cpu_count, from_cpu)
    val target = sched_normalize_cpu(cpu_count, to_cpu)
    val rq = cpu_runqueues[cpu as i64]
    val fair = sched_scan_migration_queue(tasks, rq.fair_queue, target)
    if fair != nil:
        return fair
    sched_scan_migration_queue(tasks, rq.background_queue, target)

# ============================================================================
# Deadline CPU selection
# ============================================================================

pub fn sched_select_deadline_cpu(
    tasks: [TaskControlBlock?],
    cpu_runqueues: [CpuRunQueue],
    deadline_remaining_ns_by_slot: [u64],
    runtime_ns: u64,
    period_ns: u64,
    affinity_mask: u64,
    task_id: TaskId
) -> i32:
    val requested_util = _deadline_util(runtime_ns, period_ns)
    if requested_util == 0:
        return -22
    var best = -1
    var best_util = DEADLINE_CPU_BANDWIDTH_CAP + 1
    var cpu = 0u32
    while (cpu as i64) < cpu_runqueues.len():
        if _affinity_allows_cpu(affinity_mask, cpu):
            val used = sched_deadline_cpu_util(tasks, cpu, task_id)
            if used + requested_util <= DEADLINE_CPU_BANDWIDTH_CAP:
                if used < best_util:
                    best_util = used
                    best = cpu as i32
        cpu = cpu + 1u32
    best

pub fn sched_deadline_cpu_util(tasks: [TaskControlBlock?], cpu: u32, exclude_task: TaskId) -> u64:
    var total = 0u64
    var i = 0
    while i < MAX_TASKS:
        val tcb = tasks[i]
        if tcb != nil:
            val task = tcb
            val active = match task.state:
                case TaskState.Zombie: false
                case _: true
            if (active and task.id.id != exclude_task.id and
                task.assigned_cpu == cpu and
                task.schedule.policy == SchedulerPolicy.Deadline):
                total = total + _deadline_util(task.schedule.runtime_ns, task.schedule.period_ns)
        i = i + 1
    total

# ============================================================================
# Pick-next helpers
# ============================================================================

pub fn sched_pick_rt_best(tasks: [TaskControlBlock?], cpu_runqueues: [CpuRunQueue], cpu: u32) -> (TaskId?, [CpuRunQueue]):
    """Pick the highest-priority RT task. Returns (picked, updated_runqueues)."""
    var new_rqs = cpu_runqueues
    var rq = new_rqs[cpu as i64]
    var q = rq.rt_queue
    if q.count == 0:
        return (nil, new_rqs)

    var best: TaskId? = nil
    var best_priority: i64 = 9223372036854775807
    var scan = q.head
    var scanned = 0
    while scanned < q.count:
        val idx = scan % q.capacity
        val candidate = TaskId(id: q.entries[idx])
        val slot = _find_slot_in_alg(tasks, candidate)
        if slot >= 0:
            val tcb = tasks[slot]
            if tcb != nil:
                val task = tcb
                if task.schedule.priority < best_priority:
                    best = candidate
                    best_priority = task.schedule.priority
        scan = scan + 1
        scanned = scanned + 1

    if best == nil:
        best = q.dequeue()
    else:
        q.remove(best.unwrap())

    rq.rt_queue = q
    if best != nil:
        val task_id = best.unwrap()
        val slot = _find_slot_in_alg(tasks, task_id)
        if slot >= 0:
            val tcb = tasks[slot]
            if tcb != nil:
                val task = tcb
                if rq.runnable_count > 0:
                    rq.runnable_count = rq.runnable_count - 1
                if rq.weighted_load >= task.schedule.weight:
                    rq.weighted_load = rq.weighted_load - task.schedule.weight
                else:
                    rq.weighted_load = 0
    new_rqs[cpu as i64] = rq
    (best, new_rqs)

pub fn sched_pick_deadline_best(
    tasks: [TaskControlBlock?],
    cpu_runqueues: [CpuRunQueue],
    deadline_remaining_ns_by_slot: [u64],
    cpu: u32
) -> (TaskId?, [CpuRunQueue]):
    """Pick the earliest-deadline admitted task. Returns (picked, updated_runqueues)."""
    var new_rqs = cpu_runqueues
    var rq = new_rqs[cpu as i64]
    var q = rq.deadline_queue
    if q.count == 0:
        return (nil, new_rqs)

    var best: TaskId? = nil
    var best_deadline: i64 = 9223372036854775807
    var scan = q.head
    var scanned = 0
    while scanned < q.count:
        val idx = scan % q.capacity
        val candidate = TaskId(id: q.entries[idx])
        val slot = _find_slot_in_alg(tasks, candidate)
        if slot >= 0:
            val tcb = tasks[slot]
            if tcb != nil:
                val task = tcb
                if deadline_remaining_ns_by_slot[slot] > 0 and task.schedule.virtual_deadline < best_deadline:
                    best = candidate
                    best_deadline = task.schedule.virtual_deadline
        scan = scan + 1
        scanned = scanned + 1

    if best == nil:
        rq.deadline_queue = q
        new_rqs[cpu as i64] = rq
        return (nil, new_rqs)
    q.remove(best.unwrap())
    rq.deadline_queue = q
    if best != nil:
        val task_id = best.unwrap()
        val slot = _find_slot_in_alg(tasks, task_id)
        if slot >= 0:
            val tcb = tasks[slot]
            if tcb != nil:
                val task = tcb
                if rq.runnable_count > 0:
                    rq.runnable_count = rq.runnable_count - 1
                if rq.weighted_load >= task.schedule.weight:
                    rq.weighted_load = rq.weighted_load - task.schedule.weight
                else:
                    rq.weighted_load = 0
    new_rqs[cpu as i64] = rq
    (best, new_rqs)

pub fn sched_pick_fair_best(
    tasks: [TaskControlBlock?],
    cpu_runqueues: [CpuRunQueue],
    cpu: u32,
    background: bool
) -> (TaskId?, [CpuRunQueue]):
    """Pick earliest eligible virtual deadline from fair/background lane."""
    var new_rqs = cpu_runqueues
    var rq = new_rqs[cpu as i64]
    var q = if background: rq.background_queue else: rq.fair_queue
    if q.count == 0:
        return (nil, new_rqs)

    var best: TaskId? = nil
    var best_deadline: i64 = 9223372036854775807
    var scan = q.head
    var scanned = 0
    while scanned < q.count:
        val idx = scan % q.capacity
        val candidate = TaskId(id: q.entries[idx])
        val slot = _find_slot_in_alg(tasks, candidate)
        if slot >= 0:
            val tcb = tasks[slot]
            if tcb != nil:
                val task = tcb
                val eligible = task.schedule.lag >= 0
                if eligible and task.schedule.virtual_deadline < best_deadline:
                    best = candidate
                    best_deadline = task.schedule.virtual_deadline
        scan = scan + 1
        scanned = scanned + 1

    if best == nil:
        best = q.dequeue()
    else:
        q.remove(best.unwrap())

    if background:
        rq.background_queue = q
    else:
        rq.fair_queue = q
    if best != nil:
        val task_id = best.unwrap()
        val slot = _find_slot_in_alg(tasks, task_id)
        if slot >= 0:
            val tcb = tasks[slot]
            if tcb != nil:
                val task = tcb
                if rq.runnable_count > 0:
                    rq.runnable_count = rq.runnable_count - 1
                if rq.weighted_load >= task.schedule.weight:
                    rq.weighted_load = rq.weighted_load - task.schedule.weight
                else:
                    rq.weighted_load = 0
    new_rqs[cpu as i64] = rq
    (best, new_rqs)

# ============================================================================
# Internal slot scan (local copy to avoid circular dependency)
# ============================================================================

fn _find_slot_in_alg(tasks: [TaskControlBlock?], id: TaskId) -> i32:
    var i = 0
    while i < MAX_TASKS:
        val tcb = tasks[i]
        if tcb != nil:
            val task = tcb
            if task.id.id == id.id:
                return i
        i = i + 1
    -1
