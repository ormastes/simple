# Block-device-backed swap slots. Policy and VMM remain separate owners.

use std.fs_driver.block_device.{BlockDevice}
use os.kernel.memory.memory_swap.{MemorySwapResult, MemorySwapStats, memory_swap_checksum}

struct MemorySwapBlockSlot:
    slot_id: u64
    allocation_id: u64
    page_index: u64
    byte_length: u64
    checksum: u64
    occupied: bool

class MemorySwapBlockStore:
    enabled: bool
    device: BlockDevice
    base_lba: u64
    sector_size: u64
    sectors_per_slot: u64
    capacity_slots: u64
    slots: [MemorySwapBlockSlot]
    writes: u64
    reads: u64
    releases: u64
    errors: u64
    fail_releases_for_test: u64

fn _memory_swap_block_failure(reason: text) -> MemorySwapResult:
    MemorySwapResult(ok: false, reason: reason, slot_id: 0, allocation_id: 0, page_index: 0, bytes: [])

fn memory_swap_block_store_new(enabled: bool, device: BlockDevice, base_lba: u64, capacity_slots: u64, page_size: u64) -> MemorySwapBlockStore:
    val sector_size = device.sector_size() as u64
    val sectors_per_slot = if sector_size > 0: (page_size + sector_size - 1) / sector_size else: 0
    MemorySwapBlockStore(
        enabled: enabled,
        device: device,
        base_lba: base_lba,
        sector_size: sector_size,
        sectors_per_slot: sectors_per_slot,
        capacity_slots: capacity_slots,
        slots: [],
        writes: 0,
        reads: 0,
        releases: 0,
        errors: 0,
        fail_releases_for_test: 0
    )

impl MemorySwapBlockStore:

    me fail_next_release_for_test():
        me.fail_releases_for_test = me.fail_releases_for_test + 1

    me _find_free_slot() -> i64:
        var i: i64 = 0
        while i < me.slots.len():
            if not me.slots[i].occupied:
                return i
            i = i + 1
        if (me.slots.len() as u64) < me.capacity_slots:
            return me.slots.len()
        -1

    me _slot_lba(slot_id: u64, sector_offset: u64) -> u64:
        me.base_lba + (slot_id - 1) * me.sectors_per_slot + sector_offset

    me write(allocation_id: u64, page_index: u64, bytes: [u8]) -> MemorySwapResult:
        if not me.enabled:
            me.errors = me.errors + 1
            return _memory_swap_block_failure("swap-disabled")
        if allocation_id == 0 or bytes.len() == 0 or me.sector_size == 0 or me.sectors_per_slot == 0:
            me.errors = me.errors + 1
            return _memory_swap_block_failure("invalid-state")
        if (bytes.len() as u64) > me.sector_size * me.sectors_per_slot:
            me.errors = me.errors + 1
            return _memory_swap_block_failure("page-too-large")
        val index = me._find_free_slot()
        if index < 0:
            me.errors = me.errors + 1
            return _memory_swap_block_failure("swap-full")
        val slot_id = (index as u64) + 1

        var sector_offset: u64 = 0
        var copied: u64 = 0
        while sector_offset < me.sectors_per_slot:
            var sector: [u8] = []
            var i: u64 = 0
            while i < me.sector_size:
                if copied < (bytes.len() as u64):
                    sector.push(bytes[copied as i64])
                    copied = copied + 1
                else:
                    sector.push(0)
                i = i + 1
            val written = me.device.write_sector(me._slot_lba(slot_id, sector_offset), sector)
            if written.is_err() or not written.unwrap():
                me.errors = me.errors + 1
                return _memory_swap_block_failure("swap-io")
            sector_offset = sector_offset + 1

        val slot = MemorySwapBlockSlot(
            slot_id: slot_id,
            allocation_id: allocation_id,
            page_index: page_index,
            byte_length: bytes.len() as u64,
            checksum: memory_swap_checksum(bytes),
            occupied: true
        )
        if index == me.slots.len():
            me.slots.push(slot)
        else:
            me.slots[index] = slot
        me.writes = me.writes + 1
        MemorySwapResult(ok: true, reason: "ok", slot_id: slot_id, allocation_id: allocation_id, page_index: page_index, bytes: [])

    me read(slot_id: u64, allocation_id: u64, page_index: u64) -> MemorySwapResult:
        if not me.enabled:
            me.errors = me.errors + 1
            return _memory_swap_block_failure("swap-disabled")
        if slot_id == 0 or slot_id > (me.slots.len() as u64):
            me.errors = me.errors + 1
            return _memory_swap_block_failure("missing-slot")
        val slot = me.slots[(slot_id - 1) as i64]
        if not slot.occupied:
            me.errors = me.errors + 1
            return _memory_swap_block_failure("missing-slot")
        if slot.allocation_id != allocation_id or slot.page_index != page_index:
            me.errors = me.errors + 1
            return _memory_swap_block_failure("stale-mapping")

        var bytes: [u8] = []
        var sector_offset: u64 = 0
        while sector_offset < me.sectors_per_slot and (bytes.len() as u64) < slot.byte_length:
            val read = me.device.read_sector(me._slot_lba(slot_id, sector_offset))
            if read.is_err():
                me.errors = me.errors + 1
                return _memory_swap_block_failure("swap-io")
            val sector = read.unwrap()
            var i: i64 = 0
            while i < sector.len() and (bytes.len() as u64) < slot.byte_length:
                bytes.push(sector[i])
                i = i + 1
            sector_offset = sector_offset + 1
        if (bytes.len() as u64) != slot.byte_length or memory_swap_checksum(bytes) != slot.checksum:
            me.errors = me.errors + 1
            return _memory_swap_block_failure("swap-checksum")
        me.reads = me.reads + 1
        MemorySwapResult(ok: true, reason: "ok", slot_id: slot_id, allocation_id: allocation_id, page_index: page_index, bytes: bytes)

    me release(slot_id: u64, allocation_id: u64) -> MemorySwapResult:
        if me.fail_releases_for_test > 0:
            me.fail_releases_for_test = me.fail_releases_for_test - 1
            me.errors = me.errors + 1
            return _memory_swap_block_failure("swap-io")
        if slot_id == 0 or slot_id > (me.slots.len() as u64):
            me.errors = me.errors + 1
            return _memory_swap_block_failure("missing-slot")
        val index = (slot_id - 1) as i64
        val slot = me.slots[index]
        if not slot.occupied:
            me.errors = me.errors + 1
            return _memory_swap_block_failure("missing-slot")
        if slot.allocation_id != allocation_id:
            me.errors = me.errors + 1
            return _memory_swap_block_failure("not-owner")
        me.slots[index] = MemorySwapBlockSlot(slot_id: slot_id, allocation_id: 0, page_index: 0, byte_length: 0, checksum: 0, occupied: false)
        me.releases = me.releases + 1
        MemorySwapResult(ok: true, reason: "ok", slot_id: slot_id, allocation_id: allocation_id, page_index: slot.page_index, bytes: [])

    me snapshot() -> MemorySwapStats:
        var occupied: u64 = 0
        var i: i64 = 0
        while i < me.slots.len():
            if me.slots[i].occupied:
                occupied = occupied + 1
            i = i + 1
        MemorySwapStats(capacity_slots: me.capacity_slots, occupied_slots: occupied, writes: me.writes, reads: me.reads, releases: me.releases, errors: me.errors)
