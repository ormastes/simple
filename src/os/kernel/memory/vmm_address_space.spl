# VMM address space management — split from vmm.spl.
# Contains address space creation/destruction, page-in mapping,
# COW helpers, phase-2 bulk copy APIs, and the ProcessVmSpace constructor.

use os.kernel.types.memory_types.{PhysAddr, VirtAddr, PageFrame, VmFlags, VM_NO_EXECUTE, phys_addr_value, virt_addr_value}
use os.kernel.types.task_types.{AddressSpace}
use os.kernel.types.vmspace_types.{VmArea, ProcessVmSpace}
use os.kernel.boot.mmio.{mmio_read8, mmio_write8, mmio_read64, mmio_write64}
use os.kernel.memory.pmm.{pmm_free_page, pmm_free_page_raw, pmm_ref_page, pmm_put_page}
use os.kernel.log.klog_api.{log_raw_println}
use os.kernel.memory.vmm_core.{
    PAGE_SIZE, ENTRIES_PER_TABLE,
    PTE_PRESENT, PTE_WRITABLE, PTE_USER, PTE_HUGE_PAGE, PTE_ADDR_MASK,
    g_vmm, g_next_as_id, vmm_kernel_pml4_phys, vmm_manager_snapshot,
    _phys_to_virt, _alloc_table_page, _read_pte, _write_pte,
    _pte_is_present, _pte_phys_addr, _ensure_table_entry,
    _pml4_index, _pdpt_index, _pd_index, _pt_index,
    _flags_to_pte_bits, _load_cr3, _read_cr3, vmm_map_page, _vmm_invalidate_tlb,
    VirtMemManager
}
use os.kernel.arch_adapt.x86_64.paging.{paging_switch_address_space}

extern fn rt_memcpy(dest: i64, src: i64, len: i64)
extern fn rt_memset(dest: i64, value: i64, len: i64) -> i64
extern fn unsafe_addr_of(ref: any) -> u64

var g_staged_user_as_root: u64 = 0u64
var g_staged_user_as_id: u64 = 0u64

# ============================================================================
# Address Space Management
# ============================================================================

fn vmm_create_address_space() -> u64:
    """Create a new address space (PML4) for a process.

    Allocates a fresh PML4 and copies the kernel mappings
    (upper-half entries 256..511) from the kernel PML4.
    Returns the physical address of the new PML4, or 0 on failure.
    """
    val new_pml4_phys = _alloc_table_page()
    if new_pml4_phys == 0:
        return 0

    val new_pml4_virt = _phys_to_virt(new_pml4_phys)
    val kernel_pml4_virt = _phys_to_virt(vmm_kernel_pml4_phys())

    # Copy kernel-space entries (upper half: indices 256..511)
    # This ensures kernel is mapped in every address space
    var i: u64 = 256
    while i < ENTRIES_PER_TABLE:
        val entry = _read_pte(kernel_pml4_virt, i)
        _write_pte(new_pml4_virt, i, entry)
        i = i + 1

    new_pml4_phys

# ============================================================================
# Per-Process Address Space API (Phase 1)
# ============================================================================

fn create_user_address_space() -> AddressSpace:
    """Allocate a fresh per-process address space.

    Allocates a new PML4 page, copies the kernel-half entries (indices
    256..511) from the kernel PML4 so the kernel remains mapped in every
    user address space, and returns an `AddressSpace` handle carrying the
    physical root and a monotonic id.

    If the PMM is not yet online (e.g. early boot before `vmm_init`
    completes) the allocation returns 0; in that case we fall back to
    `phys_root = 1` (the legacy sentinel) and log a single line so the
    kernel keeps booting instead of panicking.
    """
    if vmm_kernel_pml4_phys() == 0:
        log_raw_println("[VMM] create_user_address_space: VMM not initialized — legacy AS=1")
        return AddressSpace(phys_root: 1, id: 0)

    val phys = vmm_create_address_space()
    if phys == 0:
        log_raw_println("[VMM] create_user_address_space: alloc failed — legacy AS=1")
        return AddressSpace(phys_root: 1, id: 0)

    val id = g_next_as_id
    g_next_as_id = g_next_as_id + 1
    AddressSpace(phys_root: phys, id: id)

fn stage_user_address_space_scalars() -> i64:
    g_staged_user_as_root = 0u64
    g_staged_user_as_id = 0u64
    if vmm_kernel_pml4_phys() == 0:
        g_staged_user_as_root = 1u64
        return 1
    val phys = vmm_create_address_space()
    if phys == 0:
        g_staged_user_as_root = 1u64
        return 1
    g_staged_user_as_root = phys
    g_staged_user_as_id = g_next_as_id
    g_next_as_id = g_next_as_id + 1
    1

fn staged_user_address_space_root() -> u64: g_staged_user_as_root
fn staged_user_address_space_id() -> u64: g_staged_user_as_id

fn vmm_clone_kernel_low_identity(user_phys_root: u64):
    """Copy PML4 entry 0 (low identity, kernel image + stacks < 512GB) from the
    kernel PML4 into a user PML4.

    The x86_64 kernel runs identity-mapped in the lower half (hhdm=0, loaded at
    1MB), so it lives in PML4[0]. `create_user_address_space` only clones the
    upper half (256..511). Without this, the `mov cr3` inside
    `rt_x86_enter_user_first` would unmap the running kernel code, GDT, TSS,
    syscall-entry trampoline and kernel stack — an instant triple-fault. Cloning
    PML4[0] shares the kernel's low identity PDPT unchanged; user pages are mapped
    at PML4[1]+ (>= 512GB) so they never write into this shared subtree."""
    if user_phys_root == 0 or user_phys_root == 1:
        return
    if vmm_kernel_pml4_phys() == 0:
        return
    val kernel_pml4_virt = _phys_to_virt(vmm_kernel_pml4_phys())
    val user_pml4_virt = _phys_to_virt(user_phys_root)
    val entry = _read_pte(kernel_pml4_virt, 0)
    _write_pte(user_pml4_virt, 0, entry)

fn _clone_table(src_virt: u64) -> u64:
    """Allocate a fresh table page and copy all 512 entries from src_virt.
    Returns the new table's PHYSICAL address, or 0 on allocation failure."""
    val new_phys = _alloc_table_page()
    if new_phys == 0:
        return 0
    val new_virt = _phys_to_virt(new_phys)
    var i: u64 = 0
    while i < ENTRIES_PER_TABLE:
        _write_pte(new_virt, i, _read_pte(src_virt, i))
        i = i + 1
    new_phys

fn vmm_clone_kernel_low_private(user_phys_root: u64) -> bool:
    """Like vmm_clone_kernel_low_identity, but gives the user AS a PRIVATE
    PML4[0] PDPT (copy of the kernel's low-identity PDPT). The copied PDPT
    entries still point at the SHARED kernel PDs — vmm_map_user_low_page
    privatizes deeper levels copy-on-map. This keeps the kernel image, GDT,
    TSS and syscall trampoline mapped after `mov cr3` while letting user
    PT_LOADs at low VAs (e.g. clang_static at 0x40000000, PML4[0]) install
    private 4K user mappings without corrupting the kernel's page tables."""
    if user_phys_root == 0 or user_phys_root == 1:
        return false
    if vmm_kernel_pml4_phys() == 0:
        return false
    val kernel_pml4_virt = _phys_to_virt(vmm_kernel_pml4_phys())
    val kentry = _read_pte(kernel_pml4_virt, 0)
    if not _pte_is_present(kentry):
        return false
    val kpdpt_virt = _phys_to_virt(_pte_phys_addr(kentry))
    val new_pdpt_phys = _clone_table(kpdpt_virt)
    if new_pdpt_phys == 0:
        return false
    val user_pml4_virt = _phys_to_virt(user_phys_root)
    _write_pte(user_pml4_virt, 0, new_pdpt_phys | PTE_PRESENT | PTE_WRITABLE | PTE_USER)
    true

fn _privatize_entry(table_virt: u64, index: u64) -> u64:
    """Ensure table_virt[index] points at a PRIVATE next-level table this AS
    owns, privatizing shared kernel structure copy-on-map:
      - not present            -> allocate fresh (zeroed) table
      - present, US=0, not PS  -> shared kernel table: clone all 512 entries
      - present, US=0, PS set  -> kernel 2MiB identity page: split into a
                                  private PT of 512 4K kernel-perm entries
      - present, US=1          -> already private (created by this walk)
    Returns the next-level table's VIRTUAL address, or 0 on failure.
    Convention: private intermediate entries carry PTE_USER; boot/kernel
    structure never does (crt0.s builds tables with P|W only)."""
    val entry = _read_pte(table_virt, index)
    if not _pte_is_present(entry):
        val new_phys = _alloc_table_page()
        if new_phys == 0:
            return 0
        _write_pte(table_virt, index, new_phys | PTE_PRESENT | PTE_WRITABLE | PTE_USER)
        return _phys_to_virt(new_phys)
    if (entry & PTE_USER) != 0:
        return _phys_to_virt(_pte_phys_addr(entry))
    if (entry & PTE_HUGE_PAGE) != 0:
        # Split a kernel 2MiB identity page into a private PT: 512 4K entries
        # reproducing the identity mapping with the kernel's P|W perms (US=0),
        # so CPL0 access through this AS is unchanged until pages are overridden.
        val PAGE: u64 = 4096
        val base = entry & 0x000FFFFFFFE00000
        val pt_phys = _alloc_table_page()
        if pt_phys == 0:
            return 0
        val pt_virt = _phys_to_virt(pt_phys)
        var j: u64 = 0
        while j < ENTRIES_PER_TABLE:
            _write_pte(pt_virt, j, (base + (j * PAGE)) | PTE_PRESENT | PTE_WRITABLE)
            j = j + 1
        _write_pte(table_virt, index, pt_phys | PTE_PRESENT | PTE_WRITABLE | PTE_USER)
        return pt_virt
    # Shared kernel table (US=0, not huge): clone it.
    val src_virt = _phys_to_virt(_pte_phys_addr(entry))
    val clone_phys = _clone_table(src_virt)
    if clone_phys == 0:
        return 0
    _write_pte(table_virt, index, clone_phys | PTE_PRESENT | PTE_WRITABLE | PTE_USER)
    _phys_to_virt(clone_phys)

fn vmm_map_user_low_page(space: AddressSpace, virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool:
    """Map a 4KB user page in an explicit AS, privatizing any shared kernel
    low-half structure (and splitting 2MiB identity pages) along the walk.
    Requires the AS was prepared with vmm_clone_kernel_low_private. Safe for
    user-half VAs too (fresh tables, no privatization triggers), so exec
    loaders can use it for every user mapping regardless of VA."""
    if space.phys_root == 0 or space.phys_root == 1:
        return false
    val vaddr = virt_addr_value(virt)
    val paddr = phys_addr_value(phys)
    # W^X: never map a writable page executable (same rule as vmm_map_page_in).
    var safe_flags = flags
    if flags.writable() and not flags.no_execute():
        safe_flags = VmFlags(bits: flags.bits | VM_NO_EXECUTE)

    val pml4_virt = _phys_to_virt(space.phys_root)
    val pdpt_virt = _privatize_entry(pml4_virt, _pml4_index(vaddr))
    if pdpt_virt == 0:
        return false
    val pd_virt = _privatize_entry(pdpt_virt, _pdpt_index(vaddr))
    if pd_virt == 0:
        return false
    val pt_virt = _privatize_entry(pd_virt, _pd_index(vaddr))
    if pt_virt == 0:
        return false
    val pte_flags = _flags_to_pte_bits(safe_flags)
    _write_pte(pt_virt, _pt_index(vaddr), (paddr & PTE_ADDR_MASK) | pte_flags)
    true

fn _clone_cow_table(src_phys: u64, level: u32) -> u64:
    """Clone one user page-table level and retain shared data leaves."""
    val new_phys = _alloc_table_page()
    if new_phys == 0:
        return 0
    val src_virt = _phys_to_virt(src_phys)
    val new_virt = _phys_to_virt(new_phys)
    var i: u64 = 0
    while i < ENTRIES_PER_TABLE:
        val entry = _read_pte(src_virt, i)
        if _pte_is_present(entry):
            val is_leaf = level == 0 or ((level == 2 or level == 1) and (entry & PTE_HUGE_PAGE) != 0)
            if is_leaf:
                if (entry & PTE_USER) != 0:
                    _write_pte(new_virt, i, entry & ~PTE_WRITABLE)
                    pmm_ref_page(_pte_phys_addr(entry))
                else:
                    _write_pte(new_virt, i, entry)
            elif (entry & PTE_USER) == 0:
                # Supervisor-only branches are shared kernel structure.
                _write_pte(new_virt, i, entry)
            else:
                val child_phys = _clone_cow_table(_pte_phys_addr(entry), level - 1)
                if child_phys == 0:
                    _free_cow_clone_table(new_phys, level)
                    return 0
                _write_pte(new_virt, i, child_phys | (entry & ~PTE_ADDR_MASK))
        i = i + 1
    new_phys

fn _free_cow_clone_table(table_phys: u64, level: u32):
    """Free a partial clone without directly freeing shared data frames."""
    val table_virt = _phys_to_virt(table_phys)
    var limit: u64 = ENTRIES_PER_TABLE
    if level == 3:
        limit = 256
    var i: u64 = 0
    while i < limit:
        val entry = _read_pte(table_virt, i)
        if _pte_is_present(entry):
            val is_leaf = level == 0 or ((level == 2 or level == 1) and (entry & PTE_HUGE_PAGE) != 0)
            if is_leaf:
                if (entry & PTE_USER) != 0:
                    pmm_put_page(_pte_phys_addr(entry))
            elif (entry & PTE_USER) != 0:
                _free_cow_clone_table(_pte_phys_addr(entry), level - 1)
        i = i + 1
    pmm_free_page_raw(table_phys)

fn vmm_cow_clone_pages(pml4_phys: u64) -> u64:
    """Deep-clone the user page-table structure for copy-on-write."""
    if pml4_phys == 0 or pml4_phys == 1:
        return 0
    val new_pml4_phys = _alloc_table_page()
    if new_pml4_phys == 0:
        return 0

    val new_pml4_virt = _phys_to_virt(new_pml4_phys)
    val src_pml4_virt = _phys_to_virt(pml4_phys)

    # User-half (0..255): clone every intermediate table privately.
    var i: u64 = 0
    while i < 256:
        val entry = _read_pte(src_pml4_virt, i)
        if _pte_is_present(entry):
            if (entry & PTE_USER) == 0:
                _write_pte(new_pml4_virt, i, entry)
            else:
                val child_phys = _clone_cow_table(_pte_phys_addr(entry), 2)
                if child_phys == 0:
                    _free_cow_clone_table(new_pml4_phys, 3)
                    return 0
                _write_pte(new_pml4_virt, i, child_phys | (entry & ~PTE_ADDR_MASK))
        i = i + 1

    # The copied leaves are already read-only; now make the source match them.
    _cow_clear_writable_recursive(pml4_phys, 3)
    if (_read_cr3() & PTE_ADDR_MASK) == (pml4_phys & PTE_ADDR_MASK):
        _load_cr3(pml4_phys)

    # Kernel-half (256..511): shared unchanged
    i = 256
    while i < ENTRIES_PER_TABLE:
        val entry = _read_pte(src_pml4_virt, i)
        _write_pte(new_pml4_virt, i, entry)
        i = i + 1

    new_pml4_phys

fn destroy_user_address_space(space: AddressSpace):
    """Release page-table pages owned by a user address space.

    Frees intermediate user-half page table pages (PDPT/PD/PT) via
    `_free_user_half_subtree`, then frees the PML4 page itself.
    Kernel-half entries (indices 256..511) are shared and are never freed.
    """
    if space.phys_root == 0 or space.phys_root == 1:
        return

    val pml4_virt = _phys_to_virt(space.phys_root)
    _free_user_half_subtree(pml4_virt)
    val frame = PageFrame.from_phys_addr(PhysAddr(addr: space.phys_root))
    pmm_free_page(frame)

fn activate_user_address_space(space: AddressSpace):
    """Install a user address space on the current CPU."""
    if space.phys_root == 0 or space.phys_root == 1:
        return
    paging_switch_address_space(space.phys_root)

fn vmm_map_framebuffer(fb_phys: PhysAddr, fb_virt: VirtAddr, size: u64):
    """Map framebuffer as write-combining, non-executable memory."""
    val flags = VmFlags.mmio()
    val page_count = (size + PAGE_SIZE - 1) / PAGE_SIZE

    var i: u64 = 0
    while i < page_count:
        val offset = i * PAGE_SIZE
        val virt = VirtAddr(addr: virt_addr_value(fb_virt) + offset)
        val phys = PhysAddr(addr: phys_addr_value(fb_phys) + offset)
        vmm_map_page(virt, phys, flags)
        i = i + 1

    log_raw_println("[VMM] Mapped framebuffer: {page_count} pages at virt 0x{virt_addr_value(fb_virt)}")

fn vmm_map_nvme_bar_high():
    """Install the NVMe MMIO BAR at an EXCLUSIVE higher-half slot in the kernel
    PML4 (g_vmm): VA 0xFFFFC00000000000 (PML4[384]) -> phys 0xC000000000.

    The 64-bit q35 NVMe BAR is boot-mapped in boot_pml4[1] (crt0.s) at its
    physical 0xC000000000, but PML4[1] is never cloned into user address spaces
    (vmm_create_address_space copies only PML4[256..511] + PML4[0]). So under a
    user cr3 the BAR is not-present and a ring-0 NVMe access faults. Mapping it
    at a higher-half slot here makes create_user_address_space carry the entry
    into every user AS FOR FREE via the existing PML4[256..511] copy loop — no
    new per-AS copy logic. Call once after vmm_init and before the first
    create_user_address_space.

    KEEP VA/phys in sync with crt0.s (boot_pml4[384]) and baremetal_stubs.c
    (_nvme.bar0 + syscall-83 MapBar, NVME_BAR_VIRT_BASE / NVME_BAR_PHYS_BASE)."""
    val phys_base: u64 = 0xC000000000
    val virt_base: u64 = 0xFFFFC00000000000
    val map_len: u64 = 0x10000          # 64 KiB: covers CAP/CC/CSTS + doorbells
    val flags = VmFlags.mmio()
    var off: u64 = 0
    while off < map_len:
        val virt = VirtAddr(addr: virt_base + off)
        val phys = PhysAddr(addr: phys_base + off)
        val _ok = vmm_map_page(virt, phys, flags)
        off = off + PAGE_SIZE
    log_raw_println("[VMM] NVMe BAR mapped at higher-half 0x{virt_base} -> phys 0x{phys_base} (PML4[384])")

# ============================================================================
# VMM Query Interface
# ============================================================================

fn vmm_get_manager() -> VirtMemManager:
    """Get reference to the global VMM."""
    vmm_manager_snapshot()

# ============================================================================
# Phase-2 VMM APIs
# ============================================================================

fn vmm_copy_bytes_to_phys(dst_phys: u64, src: [u8], src_offset: u64, len: u64):
    """Bulk-copy `len` bytes from `src[src_offset..]` to physical `dst_phys` via HHDM."""
    if len == 0:
        return
    val dst_virt = _phys_to_virt(dst_phys)
    val src_hdr = unsafe_addr_of(src)
    val src_data = mmio_read64(src_hdr)
    rt_memcpy(dst_virt.to_i64(), (src_data + src_offset).to_i64(), len.to_i64())

fn vmm_zero_phys_range(dst_phys: u64, len: u64):
    """Zero `len` bytes at physical `dst_phys` via HHDM. Used for BSS tails."""
    if len == 0:
        return
    val dst_virt = _phys_to_virt(dst_phys)
    val _ = rt_memset(dst_virt.to_i64(), 0, len.to_i64())

fn vmm_map_page_in(space: AddressSpace, virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool:
    """Map a 4KB page in an explicit address space without switching CR3."""
    if space.phys_root == 0 or space.phys_root == 1:
        return false

    val vaddr = virt_addr_value(virt)
    val paddr = phys_addr_value(phys)
    # W^X: never map a writable page executable — force NX. Accessors are
    # called with explicit `()`; property-style access is miscompiled under
    # native cranelift freestanding codegen (see _flags_to_pte_bits).
    var safe_flags = flags
    if flags.writable() and not flags.no_execute():
        safe_flags = VmFlags(bits: flags.bits | VM_NO_EXECUTE)

    val pml4_virt = _phys_to_virt(space.phys_root)

    val pdpt_virt = _ensure_table_entry(pml4_virt, _pml4_index(vaddr))
    if pdpt_virt == 0:
        return false

    val pd_virt = _ensure_table_entry(pdpt_virt, _pdpt_index(vaddr))
    if pd_virt == 0:
        return false

    val pt_virt = _ensure_table_entry(pd_virt, _pd_index(vaddr))
    if pt_virt == 0:
        return false

    val pte_flags = _flags_to_pte_bits(safe_flags)
    val entry = (paddr & PTE_ADDR_MASK) | pte_flags
    _write_pte(pt_virt, _pt_index(vaddr), entry)

    true

fn vmm_read_pte_in(space: AddressSpace, virt: VirtAddr) -> u64:
    """Read the leaf PTE from an explicit address space."""
    if space.phys_root == 0 or space.phys_root == 1:
        return 0

    val vaddr = virt_addr_value(virt)
    val pml4_virt = _phys_to_virt(space.phys_root)
    val pml4_entry = _read_pte(pml4_virt, _pml4_index(vaddr))
    if not _pte_is_present(pml4_entry):
        return 0

    val pdpt_virt = _phys_to_virt(_pte_phys_addr(pml4_entry))
    val pdpt_entry = _read_pte(pdpt_virt, _pdpt_index(vaddr))
    if not _pte_is_present(pdpt_entry):
        return 0
    if (pdpt_entry & PTE_HUGE_PAGE) != 0:
        return pdpt_entry

    val pd_virt = _phys_to_virt(_pte_phys_addr(pdpt_entry))
    val pd_entry = _read_pte(pd_virt, _pd_index(vaddr))
    if not _pte_is_present(pd_entry):
        return 0
    if (pd_entry & PTE_HUGE_PAGE) != 0:
        return pd_entry

    val pt_virt = _phys_to_virt(_pte_phys_addr(pd_entry))
    _read_pte(pt_virt, _pt_index(vaddr))

fn vmm_replace_pte_in(space: AddressSpace, virt: VirtAddr, expected_pte: u64, replacement_pte: u64) -> bool:
    """Replace one exact 4KB leaf PTE in an explicit address space."""
    if space.phys_root == 0 or space.phys_root == 1:
        return false

    val vaddr = virt_addr_value(virt)
    val pml4_virt = _phys_to_virt(space.phys_root)
    val pml4_entry = _read_pte(pml4_virt, _pml4_index(vaddr))
    if not _pte_is_present(pml4_entry):
        return false

    val pdpt_virt = _phys_to_virt(_pte_phys_addr(pml4_entry))
    val pdpt_entry = _read_pte(pdpt_virt, _pdpt_index(vaddr))
    if not _pte_is_present(pdpt_entry) or (pdpt_entry & PTE_HUGE_PAGE) != 0:
        return false

    val pd_virt = _phys_to_virt(_pte_phys_addr(pdpt_entry))
    val pd_entry = _read_pte(pd_virt, _pd_index(vaddr))
    if not _pte_is_present(pd_entry) or (pd_entry & PTE_HUGE_PAGE) != 0:
        return false

    val pt_virt = _phys_to_virt(_pte_phys_addr(pd_entry))
    val leaf_index = _pt_index(vaddr)
    if _read_pte(pt_virt, leaf_index) != expected_pte:
        return false
    _write_pte(pt_virt, leaf_index, replacement_pte)
    _vmm_invalidate_tlb(vaddr)
    true

fn vmm_unmap_page_in(space: AddressSpace, virt: VirtAddr) -> bool:
    """Detach a 4KB leaf PTE from an explicit address space."""
    val pte = vmm_read_pte_in(space, virt)
    if (pte & PTE_PRESENT) == 0:
        return false
    vmm_replace_pte_in(space, virt, pte, 0)

fn _cow_clear_writable_recursive(table_phys: u64, level: u32):
    """Recursively clear PTE_WRITABLE on all leaf PTEs in the user half."""
    val table_virt = _phys_to_virt(table_phys)
    var limit: u64 = ENTRIES_PER_TABLE
    if level == 3:
        limit = 256
    var i: u64 = 0
    while i < limit:
        val entry = _read_pte(table_virt, i)
        if _pte_is_present(entry):
            val is_leaf = level == 0 or ((level == 2 or level == 1) and (entry & PTE_HUGE_PAGE) != 0)
            if is_leaf:
                if (entry & PTE_USER) != 0:
                    _write_pte(table_virt, i, entry & ~PTE_WRITABLE)
            elif (entry & PTE_USER) != 0:
                val child_phys = _pte_phys_addr(entry)
                _cow_clear_writable_recursive(child_phys, level - 1)
        i = i + 1

fn _free_user_half_subtree(pml4_virt: u64):
    """Free private tables and put shared user leaf frames."""
    var i: u64 = 0
    while i < 256:
        val entry = _read_pte(pml4_virt, i)
        if _pte_is_present(entry) and (entry & PTE_USER) != 0:
            _free_cow_clone_table(_pte_phys_addr(entry), 2)
        i = i + 1

# ============================================================================
# ProcessVmSpace constructor helper
# ============================================================================

fn vmm_new_process_space(pml4: u64, id: u64) -> ProcessVmSpace:
    """Create an empty ProcessVmSpace wrapping an existing PML4."""
    ProcessVmSpace(
        pml4: pml4,
        id: id,
        vma_count: 0,
        areas: []
    )
