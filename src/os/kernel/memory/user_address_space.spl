# Architecture-neutral user address-space adapter.
#
# Scheduler and segment mapping code use this layer so ARM filesystem-exec
# lanes do not depend directly on the x86 PML4 VMM entrypoints.

use os.kernel.types.task_types.{AddressSpace}
use os.kernel.types.memory_types.{VirtAddr, PhysAddr, PageFrame, VmFlags}
use os.kernel.memory.vmm.{
    create_user_address_space as vmm_create_user_address_space,
    destroy_user_address_space as vmm_destroy_user_address_space,
    vmm_map_page_in
}
use os.kernel.memory.pmm.{pmm_alloc_page}

# NOTE(cross-arch import leak): riscv64 paging imports live INSIDE the
# @cfg(riscv64) fn bodies below. The seed's cfg strip does not strip
# @cfg-gated top-level `use` lines, so a top-level import here pulls
# riscv64 paging (with RV64-only `sfence.vma` inline asm) into every
# x86_64 kernel build and breaks the inline-asm C compile.

var g_user_as_next_id: u64 = 1
val ARM64_FS_EXEC_FRAME_BASE: u64 = 0x52000000
var g_arm64_fs_exec_frame_next: u64 = ARM64_FS_EXEC_FRAME_BASE
val ARM64_FS_EXEC_FRAME_END: u64 = 0x57000000

@cfg(not(baremetal))
@export("C")
fn rt_arm64_user_as_create() -> u64:
    1u64

@cfg(not(baremetal))
@export("C")
fn rt_arm64_user_as_map_page(root: u64, virt: u64, phys: u64, flags_bits: u32) -> i32:
    val _root = root
    val _virt = virt
    val _phys = phys
    val _flags_bits = flags_bits
    0

fn _next_user_as_id() -> u64:
    val id = g_user_as_next_id
    g_user_as_next_id = g_user_as_next_id + 1
    id

@cfg(arm64)
fn create_user_address_space() -> AddressSpace:
    extern fn rt_arm64_user_as_create() -> u64
    val root = rt_arm64_user_as_create()
    AddressSpace(phys_root: root, id: _next_user_as_id())

@cfg(arm64)
fn destroy_user_address_space(space: AddressSpace):
    # ARM64 fs-exec currently uses boot-lifetime address spaces. Reclaiming
    # the table tree requires an ARM64 root walker; leave it owned until reset.
    val _space = space

@cfg(arm64)
fn map_user_page_in(space: AddressSpace, virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool:
    extern fn rt_arm64_user_as_map_page(root: u64, virt: u64, phys: u64, flags_bits: u32) -> i32
    rt_arm64_user_as_map_page(space.phys_root, virt.addr, phys.addr, flags.bits) == 1

@cfg(arm64)
fn alloc_user_page_frame() -> PageFrame?:
    val frame = pmm_alloc_page()
    if frame != nil:
        return frame
    if g_arm64_fs_exec_frame_next < ARM64_FS_EXEC_FRAME_BASE or g_arm64_fs_exec_frame_next >= ARM64_FS_EXEC_FRAME_END:
        g_arm64_fs_exec_frame_next = ARM64_FS_EXEC_FRAME_BASE
    if g_arm64_fs_exec_frame_next + 4096 <= ARM64_FS_EXEC_FRAME_END:
        val phys = g_arm64_fs_exec_frame_next
        g_arm64_fs_exec_frame_next = g_arm64_fs_exec_frame_next + 4096
        return PageFrame(pfn: phys / 4096)
    nil

@cfg(arm32)
fn create_user_address_space() -> AddressSpace:
    vmm_create_user_address_space()

@cfg(arm32)
fn destroy_user_address_space(space: AddressSpace):
    vmm_destroy_user_address_space(space)

@cfg(arm32)
fn map_user_page_in(space: AddressSpace, virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool:
    vmm_map_page_in(space, virt, phys, flags)

@cfg(arm32)
fn alloc_user_page_frame() -> PageFrame?:
    pmm_alloc_page()

@cfg(riscv64)
fn create_user_address_space() -> AddressSpace:
    use os.kernel.arch.riscv64.paging.{vmm_create_address_space as rv64_vmm_create_address_space}
    AddressSpace(phys_root: rv64_vmm_create_address_space(), id: _next_user_as_id())

@cfg(riscv64)
fn destroy_user_address_space(space: AddressSpace):
    # ponytail: retain boot-lifetime roots until the Sv39 owner has a safe table-tree walker.
    val _space = space

@cfg(riscv64)
fn map_user_page_in(space: AddressSpace, virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool:
    use os.kernel.arch.riscv64.paging.{riscv64_vmm_map_page_in}
    riscv64_vmm_map_page_in(space.phys_root, virt, phys, flags)

@cfg(riscv64)
fn alloc_user_page_frame() -> PageFrame?:
    pmm_alloc_page()

@cfg(riscv32)
fn create_user_address_space() -> AddressSpace:
    vmm_create_user_address_space()

@cfg(riscv32)
fn destroy_user_address_space(space: AddressSpace):
    vmm_destroy_user_address_space(space)

@cfg(riscv32)
fn map_user_page_in(space: AddressSpace, virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool:
    vmm_map_page_in(space, virt, phys, flags)

@cfg(riscv32)
fn alloc_user_page_frame() -> PageFrame?:
    pmm_alloc_page()

@cfg(x86_64)
fn create_user_address_space() -> AddressSpace:
    vmm_create_user_address_space()

@cfg(x86_64)
fn destroy_user_address_space(space: AddressSpace):
    vmm_destroy_user_address_space(space)

@cfg(x86_64)
fn map_user_page_in(space: AddressSpace, virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool:
    vmm_map_page_in(space, virt, phys, flags)

@cfg(x86_64)
fn alloc_user_page_frame() -> PageFrame?:
    pmm_alloc_page()

@cfg(x86)
fn create_user_address_space() -> AddressSpace:
    vmm_create_user_address_space()

@cfg(x86)
fn destroy_user_address_space(space: AddressSpace):
    vmm_destroy_user_address_space(space)

@cfg(x86)
fn map_user_page_in(space: AddressSpace, virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool:
    vmm_map_page_in(space, virt, phys, flags)

@cfg(x86)
fn alloc_user_page_frame() -> PageFrame?:
    pmm_alloc_page()
