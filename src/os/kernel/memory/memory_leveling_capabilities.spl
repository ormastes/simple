# Truthful memory-leveling capability reports for evidence environments.

struct MemoryLevelingCapabilities:
    environment: text
    swap_round_trip: bool
    contiguous_dma: bool
    scatter_gather_dma: bool
    virtio_gpu_backing: bool
    virtio_nic_buffers: bool
    coherent_dma: bool
    explicit_cache_maintenance: bool
    iommu_isolation: bool
    gpu_physical_migration: bool
    nic_physical_migration: bool
    gpudirect: bool
    rdma_paging: bool

fn memory_leveling_qemu_capabilities() -> MemoryLevelingCapabilities:
    MemoryLevelingCapabilities(
        environment: "qemu-virtio",
        swap_round_trip: true,
        contiguous_dma: true,
        scatter_gather_dma: true,
        virtio_gpu_backing: true,
        virtio_nic_buffers: true,
        coherent_dma: true,
        explicit_cache_maintenance: false,
        iommu_isolation: false,
        gpu_physical_migration: false,
        nic_physical_migration: false,
        gpudirect: false,
        rdma_paging: false
    )

fn memory_leveling_unknown_hardware_capabilities() -> MemoryLevelingCapabilities:
    MemoryLevelingCapabilities(
        environment: "unknown-hardware",
        swap_round_trip: false,
        contiguous_dma: false,
        scatter_gather_dma: false,
        virtio_gpu_backing: false,
        virtio_nic_buffers: false,
        coherent_dma: false,
        explicit_cache_maintenance: false,
        iommu_isolation: false,
        gpu_physical_migration: false,
        nic_physical_migration: false,
        gpudirect: false,
        rdma_paging: false
    )

fn memory_leveling_can_migrate_gpu(capabilities: MemoryLevelingCapabilities) -> bool:
    capabilities.gpu_physical_migration and capabilities.coherent_dma

fn memory_leveling_can_migrate_nic(capabilities: MemoryLevelingCapabilities) -> bool:
    capabilities.nic_physical_migration and capabilities.iommu_isolation
