# SimpleOS allocation registry, ownership state, bounded pressure, and stats.

use std.memory_leveling.{
    SimpleMemoryPlacementConfig,
    MemoryTier,
    MemoryDomain,
    MemoryPageState,
    MemoryLevelingPolicy,
    MemoryAllocation,
    MemoryLevelingStats,
    MEMORY_DOMAIN_CPU,
    MEMORY_DOMAIN_GPU,
    MEMORY_DOMAIN_NIC,
    MEMORY_DOMAIN_DMA,
    MEMORY_PAGE_STATE_CPU_OWNED,
    MEMORY_PAGE_STATE_SYNCING_FOR_DEVICE,
    MEMORY_PAGE_STATE_DEVICE_OWNED,
    MEMORY_PAGE_STATE_SYNCING_FOR_CPU,
    MEMORY_PAGE_STATE_MIGRATING,
    MEMORY_PAGE_STATE_SWAPPED,
    MEMORY_PAGE_STATE_RELEASED,
    MEMORY_DMA_DIRECTION_BIDIRECTIONAL,
    MEMORY_DMA_DIRECTION_TO_DEVICE,
    MEMORY_DMA_DIRECTION_FROM_DEVICE,
    MEMORY_DMA_DIRECTION_NONE,
    memory_tier_cpu_cold,
    memory_tier_dma_pinned,
    memory_tier_swap_backed,
    memory_page_state,
    memory_allocation_from_intent,
    memory_leveling_stats_empty
}

const MEMORY_LEVELING_MAX_PRESSURE_CANDIDATES: u64 = 64

struct SimpleOsMemoryLevelingConfig:
    physical_capacity_bytes: u64
    cpu_capacity_bytes: u64
    cpu_reserved_bytes: u64
    cpu_low_watermark_bytes: u64
    cpu_high_watermark_bytes: u64
    gpu_capacity_bytes: u64
    gpu_reserved_bytes: u64
    nic_capacity_bytes: u64
    nic_reserved_bytes: u64
    dma_capacity_bytes: u64
    dma_reserved_bytes: u64
    swap_capacity_bytes: u64
    pressure_batch_limit: u64
    cooldown_epochs: u64
    swap_enabled: bool
    device_safety_enabled: bool

struct MemoryLevelingCandidate:
    allocation_id: u64
    generation: u64

struct MemoryLevelingOperation:
    ok: bool
    reason: text
    allocation_id: u64
    state: text

struct MemoryRuntimeMapping:
    allocation_id: u64
    owner_id: u64
    virt_addr: u64
    page_index: u64
    byte_length: u64

struct MemoryPressureReport:
    level: text
    inspected: u64
    selected: u64
    skipped: u64
    candidate_ids: [u64]

class MemoryLevelingManager:
    config: SimpleOsMemoryLevelingConfig
    allocations: [MemoryAllocation]
    generations: [u64]
    candidates: [MemoryLevelingCandidate]
    stats: MemoryLevelingStats
    next_allocation_id: u64
    epoch: u64
    pressure_level: text
    runtime_mappings: [MemoryRuntimeMapping]

fn simpleos_memory_leveling_config_default() -> SimpleOsMemoryLevelingConfig:
    SimpleOsMemoryLevelingConfig(
        physical_capacity_bytes: 1024 * 1024 * 1024,
        cpu_capacity_bytes: 1024 * 1024 * 1024,
        cpu_reserved_bytes: 64 * 1024 * 1024,
        cpu_low_watermark_bytes: 128 * 1024 * 1024,
        cpu_high_watermark_bytes: 256 * 1024 * 1024,
        gpu_capacity_bytes: 0,
        gpu_reserved_bytes: 0,
        nic_capacity_bytes: 64 * 1024 * 1024,
        nic_reserved_bytes: 4 * 1024 * 1024,
        dma_capacity_bytes: 64 * 1024 * 1024,
        dma_reserved_bytes: 4 * 1024 * 1024,
        swap_capacity_bytes: 2 * 1024 * 1024 * 1024,
        pressure_batch_limit: MEMORY_LEVELING_MAX_PRESSURE_CANDIDATES,
        cooldown_epochs: 2,
        swap_enabled: true,
        device_safety_enabled: true
    )

fn simpleos_memory_leveling_config_for_physical_capacity(capacity_bytes: u64) -> SimpleOsMemoryLevelingConfig:
    var config = simpleos_memory_leveling_config_default()
    if capacity_bytes == 0:
        return config
    config.physical_capacity_bytes = capacity_bytes
    config.cpu_capacity_bytes = capacity_bytes
    config.cpu_reserved_bytes = capacity_bytes / 16
    config.cpu_low_watermark_bytes = capacity_bytes / 8
    config.cpu_high_watermark_bytes = capacity_bytes / 4
    config.nic_capacity_bytes = if config.nic_capacity_bytes < capacity_bytes / 4: config.nic_capacity_bytes else: capacity_bytes / 4
    config.nic_reserved_bytes = config.nic_capacity_bytes / 16
    config.dma_capacity_bytes = if config.dma_capacity_bytes < capacity_bytes / 4: config.dma_capacity_bytes else: capacity_bytes / 4
    config.dma_reserved_bytes = config.dma_capacity_bytes / 16
    config

fn simpleos_memory_leveling_config_validate(config: SimpleOsMemoryLevelingConfig) -> text:
    if config.physical_capacity_bytes == 0 or config.cpu_capacity_bytes == 0:
        return "invalid-capacity"
    if config.cpu_reserved_bytes > config.cpu_capacity_bytes or config.gpu_reserved_bytes > config.gpu_capacity_bytes or config.nic_reserved_bytes > config.nic_capacity_bytes or config.dma_reserved_bytes > config.dma_capacity_bytes:
        return "invalid-reservation"
    val reserved = config.cpu_reserved_bytes + config.gpu_reserved_bytes + config.nic_reserved_bytes + config.dma_reserved_bytes
    if reserved > config.physical_capacity_bytes:
        return "invalid-reservation"
    if config.cpu_low_watermark_bytes > config.cpu_high_watermark_bytes or config.cpu_high_watermark_bytes > config.cpu_capacity_bytes:
        return "invalid-watermark"
    if config.swap_enabled and config.swap_capacity_bytes == 0:
        return "invalid-swap-capacity"
    "ok"

fn memory_leveling_manager_new(config: SimpleOsMemoryLevelingConfig) -> MemoryLevelingManager:
    MemoryLevelingManager(
        config: config,
        allocations: [],
        generations: [],
        candidates: [],
        stats: memory_leveling_stats_empty(),
        next_allocation_id: 1,
        epoch: 0,
        pressure_level: "normal",
        runtime_mappings: []
    )

impl MemoryLevelingManager:
    me runtime_mapping_add(mapping: MemoryRuntimeMapping):
        me.runtime_mappings = me.runtime_mappings.push(mapping)

    me runtime_mapping(allocation_id: u64) -> MemoryRuntimeMapping?:
        for mapping in me.runtime_mappings:
            if mapping.allocation_id == allocation_id:
                return Some(mapping)
        nil

    me runtime_mapping_at(virt_addr: u64) -> MemoryRuntimeMapping?:
        for mapping in me.runtime_mappings:
            if mapping.virt_addr == virt_addr:
                return Some(mapping)
        nil

    me runtime_mapping_remove(allocation_id: u64):
        var next: [MemoryRuntimeMapping] = []
        for mapping in me.runtime_mappings:
            if mapping.allocation_id != allocation_id:
                next = next.push(mapping)
        me.runtime_mappings = next

fn _memory_leveling_operation(ok: bool, reason: text, allocation_id: u64, state: text) -> MemoryLevelingOperation:
    MemoryLevelingOperation(ok: ok, reason: reason, allocation_id: allocation_id, state: state)

fn _memory_leveling_updated(source: MemoryAllocation, tier: MemoryTier, state: MemoryPageState, pin_count: u64, in_flight_count: u64, mapping_count: u64, dma_direction: text, coherent: bool, access_epoch: u64, cooldown_epoch: u64, reclaimable: bool, swap_slot_id: u64) -> MemoryAllocation:
    MemoryAllocation(
        allocation_id: source.allocation_id,
        byte_length: source.byte_length,
        page_count: source.page_count,
        owner_id: source.owner_id,
        owner: source.owner,
        domain: source.domain,
        tier: tier,
        state: state,
        pin_count: pin_count,
        in_flight_count: in_flight_count,
        mapping_count: mapping_count,
        dma_direction: dma_direction,
        coherent: coherent,
        access_epoch: access_epoch,
        cooldown_epoch: cooldown_epoch,
        reclaimable: reclaimable,
        contiguous: source.contiguous,
        physical_base: source.physical_base,
        swap_slot_id: swap_slot_id
    )

fn _memory_leveling_batch_limit(config: SimpleOsMemoryLevelingConfig) -> u64:
    if config.pressure_batch_limit == 0:
        return 1
    if config.pressure_batch_limit > MEMORY_LEVELING_MAX_PRESSURE_CANDIDATES:
        return MEMORY_LEVELING_MAX_PRESSURE_CANDIDATES
    config.pressure_batch_limit

fn _memory_leveling_direction_matches(allocation_direction: text, requested_direction: text) -> bool:
    if requested_direction == MEMORY_DMA_DIRECTION_NONE:
        return false
    if allocation_direction == MEMORY_DMA_DIRECTION_BIDIRECTIONAL:
        return true
    allocation_direction == requested_direction

fn _memory_leveling_map_device_direction(allocation: MemoryAllocation, direction: text) -> bool:
    _memory_leveling_direction_matches(allocation.dma_direction, direction)

fn placement_tier_for_cpu(allocation: MemoryAllocation) -> MemoryTier:
    # Swap candidates are cold CPU allocations; hot refault promotion is a
    # separate policy decision.
    val _allocation_id = allocation.allocation_id
    memory_tier_cpu_cold()

impl MemoryLevelingManager:

    me _find(allocation_id: u64) -> i64:
        var i: i64 = 0
        while i < me.allocations.len():
            if me.allocations[i].allocation_id == allocation_id:
                return i
            i = i + 1
        -1

    me _domain_bytes(domain_name: text) -> u64:
        if domain_name == MEMORY_DOMAIN_CPU:
            return me.stats.cpu_bytes
        if domain_name == MEMORY_DOMAIN_GPU:
            return me.stats.gpu_bytes
        if domain_name == MEMORY_DOMAIN_NIC:
            return me.stats.nic_bytes
        if domain_name == MEMORY_DOMAIN_DMA:
            return me.stats.dma_bytes
        0

    me _domain_capacity(domain_name: text) -> u64:
        if domain_name == MEMORY_DOMAIN_CPU:
            return me.config.cpu_capacity_bytes
        if domain_name == MEMORY_DOMAIN_GPU:
            return me.config.gpu_capacity_bytes
        if domain_name == MEMORY_DOMAIN_NIC:
            return me.config.nic_capacity_bytes
        if domain_name == MEMORY_DOMAIN_DMA:
            return me.config.dma_capacity_bytes
        0

    me _resident_bytes() -> u64:
        me.stats.cpu_bytes + me.stats.gpu_bytes + me.stats.nic_bytes + me.stats.dma_bytes

    me _unfilled_device_reservations(domain_name: text) -> u64:
        var reserved: u64 = 0
        if domain_name != MEMORY_DOMAIN_GPU and me.stats.gpu_bytes < me.config.gpu_reserved_bytes:
            reserved = reserved + (me.config.gpu_reserved_bytes - me.stats.gpu_bytes)
        if domain_name != MEMORY_DOMAIN_NIC and me.stats.nic_bytes < me.config.nic_reserved_bytes:
            reserved = reserved + (me.config.nic_reserved_bytes - me.stats.nic_bytes)
        if domain_name != MEMORY_DOMAIN_DMA and me.stats.dma_bytes < me.config.dma_reserved_bytes:
            reserved = reserved + (me.config.dma_reserved_bytes - me.stats.dma_bytes)
        reserved

    me _unfilled_cpu_reservation(domain_name: text) -> u64:
        if domain_name == MEMORY_DOMAIN_CPU or me.stats.cpu_bytes >= me.config.cpu_reserved_bytes:
            return 0
        me.config.cpu_reserved_bytes - me.stats.cpu_bytes

    me _admission_reason(domain_name: text, byte_length: u64) -> text:
        val used = me._domain_bytes(domain_name)
        val capacity = me._domain_capacity(domain_name)
        if capacity == 0 or byte_length > capacity or used > capacity - byte_length:
            return "domain-capacity"
        val resident = me._resident_bytes()
        val protected_bytes = me._unfilled_device_reservations(domain_name) + me._unfilled_cpu_reservation(domain_name)
        if byte_length > me.config.physical_capacity_bytes or resident > me.config.physical_capacity_bytes - byte_length or protected_bytes > me.config.physical_capacity_bytes - resident - byte_length:
            return "reservation-protected"
        "ok"

    me _add_domain_bytes(domain_name: text, byte_length: u64):
        if domain_name == MEMORY_DOMAIN_CPU:
            me.stats.cpu_bytes = me.stats.cpu_bytes + byte_length
        elif domain_name == MEMORY_DOMAIN_GPU:
            me.stats.gpu_bytes = me.stats.gpu_bytes + byte_length
        elif domain_name == MEMORY_DOMAIN_NIC:
            me.stats.nic_bytes = me.stats.nic_bytes + byte_length
        elif domain_name == MEMORY_DOMAIN_DMA:
            me.stats.dma_bytes = me.stats.dma_bytes + byte_length

    me _subtract_domain_bytes(domain_name: text, byte_length: u64):
        if domain_name == MEMORY_DOMAIN_CPU and me.stats.cpu_bytes >= byte_length:
            me.stats.cpu_bytes = me.stats.cpu_bytes - byte_length
        elif domain_name == MEMORY_DOMAIN_GPU and me.stats.gpu_bytes >= byte_length:
            me.stats.gpu_bytes = me.stats.gpu_bytes - byte_length
        elif domain_name == MEMORY_DOMAIN_NIC and me.stats.nic_bytes >= byte_length:
            me.stats.nic_bytes = me.stats.nic_bytes - byte_length
        elif domain_name == MEMORY_DOMAIN_DMA and me.stats.dma_bytes >= byte_length:
            me.stats.dma_bytes = me.stats.dma_bytes - byte_length

    me _enqueue(index: i64):
        val allocation = me.allocations[index]
        if allocation.domain.name != MEMORY_DOMAIN_CPU or not allocation.reclaimable:
            return
        me.generations[index] = me.generations[index] + 1
        me.candidates.push(MemoryLevelingCandidate(allocation_id: allocation.allocation_id, generation: me.generations[index]))
        me.stats.candidate_count = me.stats.candidate_count + 1

    me request(placement: SimpleMemoryPlacementConfig, policy: MemoryLevelingPolicy, byte_length: u64, page_count: u64, owner_id: u64) -> MemoryLevelingOperation:
        val config_reason = simpleos_memory_leveling_config_validate(me.config)
        if config_reason != "ok":
            me.stats.failure_count = me.stats.failure_count + 1
            return _memory_leveling_operation(false, config_reason, 0, "failed")
        if byte_length == 0 or page_count == 0 or owner_id == 0:
            me.stats.failure_count = me.stats.failure_count + 1
            return _memory_leveling_operation(false, "invalid-request", 0, "failed")
        val domain_name = placement.intent.placement
        val admission = me._admission_reason(domain_name, byte_length)
        if admission != "ok":
            me.stats.failure_count = me.stats.failure_count + 1
            return _memory_leveling_operation(false, admission, 0, "failed")

        val allocation_id = me.next_allocation_id
        me.next_allocation_id = me.next_allocation_id + 1
        var allocation = memory_allocation_from_intent(allocation_id, byte_length, page_count, placement.intent)
        allocation.owner_id = owner_id
        allocation.tier = placement.preferred_tier
        allocation.reclaimable = placement.movable and policy.movable and policy.swap_allowed and allocation.state.name == MEMORY_PAGE_STATE_CPU_OWNED
        me.allocations.push(allocation)
        me.generations.push(0)
        me.stats.allocation_count = me.stats.allocation_count + 1
        me.stats.byte_count = me.stats.byte_count + byte_length
        me._add_domain_bytes(allocation.domain.name, byte_length)
        val index = me.allocations.len() - 1
        me._enqueue(index)
        _memory_leveling_operation(true, "ok", allocation_id, allocation.state.name)

    me register_device_buffer(allocation_id: u64, owner_id: u64, byte_length: u64, page_count: u64, domain: MemoryDomain, tier: MemoryTier, dma_direction: text, coherent: bool, contiguous: bool, physical_base: u64, permanent_pin: bool) -> MemoryLevelingOperation:
        val config_reason = simpleos_memory_leveling_config_validate(me.config)
        if config_reason != "ok":
            me.stats.failure_count = me.stats.failure_count + 1
            return _memory_leveling_operation(false, config_reason, allocation_id, "failed")
        if owner_id == 0 or byte_length == 0 or page_count == 0 or (allocation_id != 0 and me._find(allocation_id) >= 0):
            return _memory_leveling_operation(false, "invalid-request", allocation_id, "failed")
        val admission = me._admission_reason(domain.name, byte_length)
        if admission != "ok":
            me.stats.failure_count = me.stats.failure_count + 1
            return _memory_leveling_operation(false, admission, allocation_id, "failed")
        var resolved_allocation_id = allocation_id
        if resolved_allocation_id == 0:
            resolved_allocation_id = me.next_allocation_id
            me.next_allocation_id = me.next_allocation_id + 1
        val pin_count: u64 = if permanent_pin: 1 else: 0
        val cpu_owned = memory_page_state(MEMORY_PAGE_STATE_CPU_OWNED, false, false)
        val allocation = MemoryAllocation(
            allocation_id: resolved_allocation_id,
            byte_length: byte_length,
            page_count: page_count,
            owner_id: owner_id,
            owner: "simpleos-device",
            domain: domain,
            tier: tier,
            state: cpu_owned,
            pin_count: pin_count,
            in_flight_count: 0,
            mapping_count: 0,
            dma_direction: dma_direction,
            coherent: coherent,
            access_epoch: me.epoch,
            cooldown_epoch: 0,
            reclaimable: false,
            contiguous: contiguous,
            physical_base: physical_base,
            swap_slot_id: 0
        )
        me.allocations.push(allocation)
        me.generations.push(0)
        if resolved_allocation_id >= me.next_allocation_id:
            me.next_allocation_id = resolved_allocation_id + 1
        me.stats.allocation_count = me.stats.allocation_count + 1
        me.stats.byte_count = me.stats.byte_count + byte_length
        me.stats.pin_count = me.stats.pin_count + pin_count
        me._add_domain_bytes(domain.name, byte_length)
        _memory_leveling_operation(true, "ok", resolved_allocation_id, cpu_owned.name)

    me get(allocation_id: u64) -> MemoryAllocation?:
        val index = me._find(allocation_id)
        if index < 0:
            return nil
        Some(me.allocations[index])

    me pin(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id:
            return _memory_leveling_operation(false, "not-owner", allocation_id, allocation.state.name)
        if allocation.state.name == MEMORY_PAGE_STATE_RELEASED or allocation.state.name == MEMORY_PAGE_STATE_SWAPPED:
            return _memory_leveling_operation(false, "invalid-state", allocation_id, allocation.state.name)
        me.allocations[index] = _memory_leveling_updated(allocation, allocation.tier, allocation.state, allocation.pin_count + 1, allocation.in_flight_count, allocation.mapping_count, allocation.dma_direction, allocation.coherent, allocation.access_epoch, allocation.cooldown_epoch, false, allocation.swap_slot_id)
        me.stats.pin_count = me.stats.pin_count + 1
        _memory_leveling_operation(true, "ok", allocation_id, allocation.state.name)

    me unpin(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id:
            return _memory_leveling_operation(false, "not-owner", allocation_id, allocation.state.name)
        if allocation.pin_count == 0:
            return _memory_leveling_operation(false, "pin-underflow", allocation_id, allocation.state.name)
        val reclaimable = allocation.pin_count == 1 and allocation.mapping_count == 0 and allocation.in_flight_count == 0 and allocation.state.name == MEMORY_PAGE_STATE_CPU_OWNED
        me.allocations[index] = _memory_leveling_updated(allocation, allocation.tier, allocation.state, allocation.pin_count - 1, allocation.in_flight_count, allocation.mapping_count, allocation.dma_direction, allocation.coherent, allocation.access_epoch, allocation.cooldown_epoch, reclaimable, allocation.swap_slot_id)
        me.stats.pin_count = me.stats.pin_count - 1
        if reclaimable:
            me._enqueue(index)
        _memory_leveling_operation(true, "ok", allocation_id, allocation.state.name)

    me map_device(allocation_id: u64, owner_id: u64, direction: text, coherent: bool) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id:
            return _memory_leveling_operation(false, "not-owner", allocation_id, allocation.state.name)
        if allocation.state.name != MEMORY_PAGE_STATE_CPU_OWNED or direction == MEMORY_DMA_DIRECTION_NONE:
            return _memory_leveling_operation(false, "invalid-state", allocation_id, allocation.state.name)
        if not _memory_leveling_map_device_direction(allocation, direction):
            return _memory_leveling_operation(false, "invalid-direction", allocation_id, allocation.state.name)
        val syncing = memory_page_state(MEMORY_PAGE_STATE_SYNCING_FOR_DEVICE, false, false)
        me.allocations[index] = _memory_leveling_updated(allocation, allocation.tier, syncing, allocation.pin_count, allocation.in_flight_count, allocation.mapping_count + 1, direction, coherent, allocation.access_epoch, allocation.cooldown_epoch, false, allocation.swap_slot_id)
        me.stats.mapping_count = me.stats.mapping_count + 1
        me.stats.transition_count = me.stats.transition_count + 1
        _memory_leveling_operation(true, "ok", allocation_id, syncing.name)

    me sync_for_device(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id:
            return _memory_leveling_operation(false, "not-owner", allocation_id, allocation.state.name)
        if allocation.state.name != MEMORY_PAGE_STATE_SYNCING_FOR_DEVICE or allocation.mapping_count == 0:
            return _memory_leveling_operation(false, "sync-required", allocation_id, allocation.state.name)
        val owned = memory_page_state(MEMORY_PAGE_STATE_DEVICE_OWNED, true, false)
        me.allocations[index] = _memory_leveling_updated(allocation, allocation.tier, owned, allocation.pin_count, allocation.in_flight_count, allocation.mapping_count, allocation.dma_direction, allocation.coherent, allocation.access_epoch, allocation.cooldown_epoch, false, allocation.swap_slot_id)
        me.stats.transition_count = me.stats.transition_count + 1
        _memory_leveling_operation(true, "ok", allocation_id, owned.name)

    me begin_in_flight(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id or allocation.state.name != MEMORY_PAGE_STATE_DEVICE_OWNED:
            return _memory_leveling_operation(false, "invalid-state", allocation_id, allocation.state.name)
        me.allocations[index] = _memory_leveling_updated(allocation, allocation.tier, allocation.state, allocation.pin_count, allocation.in_flight_count + 1, allocation.mapping_count, allocation.dma_direction, allocation.coherent, allocation.access_epoch, allocation.cooldown_epoch, false, allocation.swap_slot_id)
        me.stats.in_flight_count = me.stats.in_flight_count + 1
        _memory_leveling_operation(true, "ok", allocation_id, allocation.state.name)

    me complete_in_flight(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id or allocation.in_flight_count == 0:
            return _memory_leveling_operation(false, "in-flight-underflow", allocation_id, allocation.state.name)
        me.allocations[index] = _memory_leveling_updated(allocation, allocation.tier, allocation.state, allocation.pin_count, allocation.in_flight_count - 1, allocation.mapping_count, allocation.dma_direction, allocation.coherent, allocation.access_epoch, allocation.cooldown_epoch, false, allocation.swap_slot_id)
        me.stats.in_flight_count = me.stats.in_flight_count - 1
        _memory_leveling_operation(true, "ok", allocation_id, allocation.state.name)

    me sync_for_cpu(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id or allocation.state.name != MEMORY_PAGE_STATE_DEVICE_OWNED:
            return _memory_leveling_operation(false, "invalid-state", allocation_id, allocation.state.name)
        if allocation.in_flight_count > 0:
            return _memory_leveling_operation(false, "in-flight", allocation_id, allocation.state.name)
        val syncing = memory_page_state(MEMORY_PAGE_STATE_SYNCING_FOR_CPU, true, false)
        me.allocations[index] = _memory_leveling_updated(allocation, allocation.tier, syncing, allocation.pin_count, 0, allocation.mapping_count, allocation.dma_direction, allocation.coherent, allocation.access_epoch, allocation.cooldown_epoch, false, allocation.swap_slot_id)
        me.stats.transition_count = me.stats.transition_count + 1
        _memory_leveling_operation(true, "ok", allocation_id, syncing.name)

    me unmap_device(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id or allocation.state.name != MEMORY_PAGE_STATE_SYNCING_FOR_CPU or allocation.mapping_count == 0:
            return _memory_leveling_operation(false, "invalid-state", allocation_id, allocation.state.name)
        val cpu_owned = memory_page_state(MEMORY_PAGE_STATE_CPU_OWNED, false, true)
        val mappings = allocation.mapping_count - 1
        val reclaimable = mappings == 0 and allocation.pin_count == 0
        me.allocations[index] = _memory_leveling_updated(allocation, allocation.tier, cpu_owned, allocation.pin_count, 0, mappings, allocation.dma_direction, true, allocation.access_epoch, allocation.cooldown_epoch, reclaimable, allocation.swap_slot_id)
        me.stats.mapping_count = me.stats.mapping_count - 1
        me.stats.transition_count = me.stats.transition_count + 1
        if reclaimable:
            me._enqueue(index)
        _memory_leveling_operation(true, "ok", allocation_id, cpu_owned.name)

    me release(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id:
            return _memory_leveling_operation(false, "not-owner", allocation_id, allocation.state.name)
        if allocation.pin_count > 0 or allocation.in_flight_count > 0 or allocation.mapping_count > 0 or allocation.state.name == MEMORY_PAGE_STATE_DEVICE_OWNED or allocation.state.name == MEMORY_PAGE_STATE_MIGRATING:
            return _memory_leveling_operation(false, "protected", allocation_id, allocation.state.name)
        if allocation.state.name == MEMORY_PAGE_STATE_RELEASED:
            return _memory_leveling_operation(false, "released", allocation_id, allocation.state.name)
        val released = memory_page_state(MEMORY_PAGE_STATE_RELEASED, false, false)
        me.allocations[index] = _memory_leveling_updated(allocation, allocation.tier, released, 0, 0, 0, MEMORY_DMA_DIRECTION_NONE, true, allocation.access_epoch, allocation.cooldown_epoch, false, 0)
        me.stats.allocation_count = me.stats.allocation_count - 1
        me.stats.byte_count = me.stats.byte_count - allocation.byte_length
        if allocation.state.name == MEMORY_PAGE_STATE_SWAPPED:
            if me.stats.swap_bytes >= allocation.byte_length:
                me.stats.swap_bytes = me.stats.swap_bytes - allocation.byte_length
        else:
            me._subtract_domain_bytes(allocation.domain.name, allocation.byte_length)
        me.stats.transition_count = me.stats.transition_count + 1
        _memory_leveling_operation(true, "ok", allocation_id, released.name)

    me prepare_swap(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id:
            return _memory_leveling_operation(false, "not-owner", allocation_id, allocation.state.name)
        if not me.config.swap_enabled:
            return _memory_leveling_operation(false, "swap-disabled", allocation_id, allocation.state.name)
        if not allocation.reclaimable or allocation.pin_count > 0 or allocation.in_flight_count > 0 or allocation.mapping_count > 0 or allocation.state.name != MEMORY_PAGE_STATE_CPU_OWNED:
            return _memory_leveling_operation(false, "protected", allocation_id, allocation.state.name)
        val migrating = memory_page_state(MEMORY_PAGE_STATE_MIGRATING, false, false)
        me.allocations[index] = _memory_leveling_updated(allocation, allocation.tier, migrating, 0, 0, 0, MEMORY_DMA_DIRECTION_NONE, true, allocation.access_epoch, allocation.cooldown_epoch, false, 0)
        me.stats.transition_count = me.stats.transition_count + 1
        _memory_leveling_operation(true, "ok", allocation_id, migrating.name)

    me commit_swap(allocation_id: u64, owner_id: u64, slot_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id or allocation.state.name != MEMORY_PAGE_STATE_MIGRATING or slot_id == 0:
            return _memory_leveling_operation(false, "invalid-state", allocation_id, allocation.state.name)
        val swapped = memory_page_state(MEMORY_PAGE_STATE_SWAPPED, false, false)
        me.allocations[index] = _memory_leveling_updated(allocation, memory_tier_swap_backed(), swapped, 0, 0, 0, MEMORY_DMA_DIRECTION_NONE, true, allocation.access_epoch, allocation.cooldown_epoch, false, slot_id)
        me._subtract_domain_bytes(allocation.domain.name, allocation.byte_length)
        me.stats.swap_bytes = me.stats.swap_bytes + allocation.byte_length
        me.stats.swap_write_count = me.stats.swap_write_count + 1
        me.stats.transition_count = me.stats.transition_count + 1
        _memory_leveling_operation(true, "ok", allocation_id, swapped.name)

    me rollback_swap(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id or allocation.state.name != MEMORY_PAGE_STATE_MIGRATING or allocation.swap_slot_id != 0:
            return _memory_leveling_operation(false, "invalid-state", allocation_id, allocation.state.name)
        val cpu_owned = memory_page_state(MEMORY_PAGE_STATE_CPU_OWNED, false, true)
        me.allocations[index] = _memory_leveling_updated(allocation, placement_tier_for_cpu(allocation), cpu_owned, 0, 0, 0, MEMORY_DMA_DIRECTION_NONE, true, allocation.access_epoch, allocation.cooldown_epoch, true, 0)
        me.stats.transition_count = me.stats.transition_count + 1
        me._enqueue(index)
        _memory_leveling_operation(true, "ok", allocation_id, cpu_owned.name)

    me prepare_restore(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id or allocation.state.name != MEMORY_PAGE_STATE_SWAPPED or allocation.swap_slot_id == 0:
            return _memory_leveling_operation(false, "invalid-state", allocation_id, allocation.state.name)
        val admission = me._admission_reason(allocation.domain.name, allocation.byte_length)
        if admission != "ok":
            me.stats.failure_count = me.stats.failure_count + 1
            return _memory_leveling_operation(false, admission, allocation_id, allocation.state.name)
        val migrating = memory_page_state(MEMORY_PAGE_STATE_MIGRATING, false, false)
        me.allocations[index] = _memory_leveling_updated(allocation, allocation.tier, migrating, 0, 0, 0, MEMORY_DMA_DIRECTION_NONE, true, allocation.access_epoch, allocation.cooldown_epoch, false, allocation.swap_slot_id)
        me.stats.transition_count = me.stats.transition_count + 1
        _memory_leveling_operation(true, "ok", allocation_id, migrating.name)

    me commit_restore(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id or allocation.state.name != MEMORY_PAGE_STATE_MIGRATING or allocation.swap_slot_id == 0:
            return _memory_leveling_operation(false, "invalid-state", allocation_id, allocation.state.name)
        val cpu_owned = memory_page_state(MEMORY_PAGE_STATE_CPU_OWNED, false, true)
        val cooldown = me.epoch + me.config.cooldown_epochs
        me.allocations[index] = _memory_leveling_updated(allocation, placement_tier_for_cpu(allocation), cpu_owned, 0, 0, 0, MEMORY_DMA_DIRECTION_NONE, true, me.epoch, cooldown, true, 0)
        if me.stats.swap_bytes >= allocation.byte_length:
            me.stats.swap_bytes = me.stats.swap_bytes - allocation.byte_length
        me._add_domain_bytes(allocation.domain.name, allocation.byte_length)
        me.stats.swap_read_count = me.stats.swap_read_count + 1
        me.stats.refault_count = me.stats.refault_count + 1
        me.stats.transition_count = me.stats.transition_count + 1
        me._enqueue(index)
        _memory_leveling_operation(true, "ok", allocation_id, cpu_owned.name)

    me rollback_restore(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id or allocation.state.name != MEMORY_PAGE_STATE_MIGRATING or allocation.swap_slot_id == 0:
            return _memory_leveling_operation(false, "invalid-state", allocation_id, allocation.state.name)
        val swapped = memory_page_state(MEMORY_PAGE_STATE_SWAPPED, false, false)
        me.allocations[index] = _memory_leveling_updated(allocation, memory_tier_swap_backed(), swapped, 0, 0, 0, MEMORY_DMA_DIRECTION_NONE, true, allocation.access_epoch, allocation.cooldown_epoch, false, allocation.swap_slot_id)
        me.stats.failure_count = me.stats.failure_count + 1
        _memory_leveling_operation(true, "rolled-back", allocation_id, swapped.name)

    me touch(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val index = me._find(allocation_id)
        if index < 0:
            return _memory_leveling_operation(false, "not-found", allocation_id, "failed")
        val allocation = me.allocations[index]
        if allocation.owner_id != owner_id:
            return _memory_leveling_operation(false, "not-owner", allocation_id, allocation.state.name)
        me.epoch = me.epoch + 1
        val cooldown = me.epoch + me.config.cooldown_epochs
        me.allocations[index] = _memory_leveling_updated(allocation, allocation.tier, allocation.state, allocation.pin_count, allocation.in_flight_count, allocation.mapping_count, allocation.dma_direction, allocation.coherent, me.epoch, cooldown, allocation.reclaimable, allocation.swap_slot_id)
        me.stats.refault_count = me.stats.refault_count + 1
        _memory_leveling_operation(true, "ok", allocation_id, allocation.state.name)

    me apply_pressure(level: text) -> MemoryPressureReport:
        me.pressure_level = level
        me.epoch = me.epoch + 1
        val limit = _memory_leveling_batch_limit(me.config)
        var inspected: u64 = 0
        var selected: u64 = 0
        var skipped: u64 = 0
        var selected_ids: [u64] = []
        var queue_index: i64 = 0
        while queue_index < me.candidates.len() and inspected < limit:
            val candidate = me.candidates[queue_index]
            inspected = inspected + 1
            val index = me._find(candidate.allocation_id)
            if index < 0 or candidate.generation != me.generations[index]:
                skipped = skipped + 1
            else:
                val allocation = me.allocations[index]
                if not me.config.swap_enabled or not allocation.reclaimable or allocation.pin_count > 0 or allocation.in_flight_count > 0 or allocation.mapping_count > 0 or allocation.state.name != MEMORY_PAGE_STATE_CPU_OWNED or allocation.cooldown_epoch > me.epoch:
                    skipped = skipped + 1
                    if allocation.cooldown_epoch > me.epoch:
                        me.stats.cooldown_count = me.stats.cooldown_count + 1
                else:
                    selected_ids.push(allocation.allocation_id)
                    selected = selected + 1
            queue_index = queue_index + 1
        var remaining: [MemoryLevelingCandidate] = []
        while queue_index < me.candidates.len():
            remaining.push(me.candidates[queue_index])
            queue_index = queue_index + 1
        me.candidates = remaining
        me.stats.skipped_count = me.stats.skipped_count + skipped
        MemoryPressureReport(level: level, inspected: inspected, selected: selected, skipped: skipped, candidate_ids: selected_ids)

    me snapshot() -> MemoryLevelingStats:
        me.stats
