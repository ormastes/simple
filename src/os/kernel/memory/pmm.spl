# Physical Memory Manager — Memory Layer (Layer 1)
#
# Bitmap-based page frame allocator.
# Each bit represents one 4KB physical page frame.
# 1 = allocated, 0 = free.
#
# Initialized from BootOutputPort memory map.
# Provides pmm_alloc_page / pmm_free_page for the VMM and upper layers.

use os.kernel.types.memory_types.{PhysAddr, PageFrame}
use os.kernel.boot.ports.{BootOutputPort, BootMemoryRegion, MemoryRegionKind}
use os.kernel.boot.mmio.{mmio_read8, mmio_write8, mmio_read64, mmio_write64}

# ============================================================================
# Constants
# ============================================================================

val PAGE_SIZE: u64 = 4096
val BITS_PER_BYTE: u64 = 8

# Maximum physical memory supported: 4GB = 1,048,576 pages = 128KB bitmap
val MAX_PHYS_PAGES: u64 = 1048576
val BITMAP_SIZE_BYTES: u64 = 131072      # MAX_PHYS_PAGES / 8

# ============================================================================
# Physical Memory Manager
# ============================================================================

struct PhysMemManager:
    """Bitmap-based physical page frame allocator.

    Each bit in the bitmap represents one 4KB page.
    Bit = 1 means allocated, bit = 0 means free.
    """
    bitmap_addr: u64        # Virtual address of the bitmap
    total_pages: u64        # Total tracked page frames
    free_pages: u64         # Number of free page frames
    last_alloc_index: u64   # Hint for next-fit search optimization

impl PhysMemManager:
    fn total_memory() -> u64:
        """Total tracked physical memory in bytes."""
        self.total_pages * PAGE_SIZE

    fn free_memory() -> u64:
        """Free physical memory in bytes."""
        self.free_pages * PAGE_SIZE

    fn used_pages() -> u64:
        """Number of allocated page frames."""
        self.total_pages - self.free_pages

# ============================================================================
# Bitmap Helpers
# ============================================================================

fn _bitmap_set_addr(bitmap_addr: u64, page_index: u64):
    """Mark a page as allocated (set bit to 1)."""
    val byte_index = page_index / BITS_PER_BYTE
    val bit_offset = page_index % BITS_PER_BYTE
    val addr = bitmap_addr + byte_index
    val current = mmio_read8(addr)
    val mask = (1 as u8) << (bit_offset as u8)
    mmio_write8(addr, current | mask)

fn _bitmap_clear_addr(bitmap_addr: u64, page_index: u64):
    """Mark a page as free (clear bit to 0)."""
    val byte_index = page_index / BITS_PER_BYTE
    val bit_offset = page_index % BITS_PER_BYTE
    val addr = bitmap_addr + byte_index
    val current = mmio_read8(addr)
    val mask = (1 as u8) << (bit_offset as u8)
    mmio_write8(addr, current & (~mask))

fn _bitmap_test_addr(bitmap_addr: u64, page_index: u64) -> bool:
    """Test if a page is allocated (bit is 1)."""
    val byte_index = page_index / BITS_PER_BYTE
    val bit_offset = page_index % BITS_PER_BYTE
    val addr = bitmap_addr + byte_index
    val current = mmio_read8(addr)
    val mask = (1 as u8) << (bit_offset as u8)
    (current & mask) != 0

fn _bitmap_set(manager: PhysMemManager, page_index: u64):
    _bitmap_set_addr(manager.bitmap_addr, page_index)

fn _bitmap_clear(manager: PhysMemManager, page_index: u64):
    _bitmap_clear_addr(manager.bitmap_addr, page_index)

fn _bitmap_test(manager: PhysMemManager, page_index: u64) -> bool:
    _bitmap_test_addr(manager.bitmap_addr, page_index)

fn _bitmap_clear_all(bitmap_addr: u64, size_bytes: u64):
    """Clear entire bitmap (mark all pages as allocated initially)."""
    var i: u64 = 0
    while i < size_bytes:
        mmio_write8(bitmap_addr + i, 0xFF)  # All allocated
        i = i + 1

fn _bitmap_initialize_free_with_reserved_prefix(bitmap_addr: u64, size_bytes: u64, reserved_pages: u64):
    var i: u64 = 0
    while i < size_bytes:
        mmio_write8(bitmap_addr + i, 0)
        i = i + 1

    val full_reserved_bytes = reserved_pages / BITS_PER_BYTE
    i = 0
    while i < full_reserved_bytes:
        mmio_write8(bitmap_addr + i, 0xFF)
        i = i + 1
    val remaining_bits = reserved_pages % BITS_PER_BYTE
    if remaining_bits > 0:
        val mask = ((1 as u16) << (remaining_bits as u8)) - 1
        mmio_write8(bitmap_addr + full_reserved_bytes, mask as u8)

# ============================================================================
# PMM Initialization
# ============================================================================

# Global PMM instance
var g_pmm: PhysMemManager = PhysMemManager(
    bitmap_addr: 0,
    total_pages: 0,
    free_pages: 0,
    last_alloc_index: 0
)
var _pmm_bitmap_addr: u64 = 0
var _pmm_total_pages: u64 = 0
var _pmm_free_pages: u64 = 0
var _pmm_last_alloc_index: u64 = 0

fn _pmm_snapshot() -> PhysMemManager:
    PhysMemManager(bitmap_addr: _pmm_bitmap_addr, total_pages: _pmm_total_pages, free_pages: _pmm_free_pages, last_alloc_index: _pmm_last_alloc_index)

fn _pmm_set_state(bitmap_addr: u64, total_pages: u64, free_pages: u64, last_alloc_index: u64):
    _pmm_bitmap_addr = bitmap_addr
    _pmm_total_pages = total_pages
    _pmm_free_pages = free_pages
    _pmm_last_alloc_index = last_alloc_index

# Forward declaration for serial debug
use os.kernel.log.klog_api.{log_raw_println}

fn pmm_init(boot_info: BootOutputPort):
    """Initialize PMM from boot memory map.

    1. Find a usable region large enough for the bitmap
    2. Place bitmap there and mark it as allocated
    3. Walk memory map marking usable pages as free
    4. Mark kernel, bootloader, and reserved regions as allocated
    """
    log_raw_println("[PMM] Initializing physical memory manager...")

    # Step 1: Determine total physical memory extent
    var max_addr: u64 = 0
    for region in boot_info.memory_map:
        val region_end = region.base.addr + region.size
        if region_end > max_addr:
            max_addr = region_end

    val total_pages = max_addr / PAGE_SIZE
    val bitmap_bytes = (total_pages + 7) / BITS_PER_BYTE

    log_raw_println("[PMM] Physical memory extent: 0x{max_addr}")
    log_raw_println("[PMM] Total pages: {total_pages}")
    log_raw_println("[PMM] Bitmap size: {bitmap_bytes} bytes")

    # Step 2: Find a usable region for the bitmap
    # We need a usable region that can hold the bitmap and is not the kernel
    var bitmap_addr: u64 = 0
    for region in boot_info.memory_map:
        val is_usable = match region.kind:
            MemoryRegionKind.Usable: true
            _: false
        if is_usable:
            if region.size >= bitmap_bytes:
                # Use start of this region for bitmap
                bitmap_addr = region.base.addr
                break

    if bitmap_addr == 0:
        log_raw_println("[PMM] FATAL: No suitable region for bitmap")
        return

    log_raw_println("[PMM] Bitmap placed at physical 0x{bitmap_addr}")

    # Step 3: Initialize the bitmap — mark everything as allocated first
    _bitmap_clear_all(bitmap_addr, bitmap_bytes)

    # Initialize global PMM
    g_pmm = PhysMemManager(
        bitmap_addr: bitmap_addr,
        total_pages: total_pages,
        free_pages: 0,
        last_alloc_index: 0
    )
    _pmm_set_state(bitmap_addr, total_pages, 0, 0)

    # Step 4: Walk memory map, mark usable regions as free
    for region in boot_info.memory_map:
        val is_usable = match region.kind:
            MemoryRegionKind.Usable: true
            _: false
        if is_usable:
            val start_page = region.base.addr / PAGE_SIZE
            val page_count = region.size / PAGE_SIZE
            var p: u64 = 0
            while p < page_count:
                _bitmap_clear_addr(_pmm_bitmap_addr, start_page + p)
                _pmm_free_pages = _pmm_free_pages + 1
                p = p + 1

    # Step 5: Re-mark the bitmap region itself as allocated
    val bitmap_start_page = bitmap_addr / PAGE_SIZE
    val bitmap_page_count = (bitmap_bytes + PAGE_SIZE - 1) / PAGE_SIZE
    var bp: u64 = 0
    while bp < bitmap_page_count:
        val page_idx = bitmap_start_page + bp
        if not _bitmap_test_addr(_pmm_bitmap_addr, page_idx):
            _bitmap_set_addr(_pmm_bitmap_addr, page_idx)
            _pmm_free_pages = _pmm_free_pages - 1
        bp = bp + 1

    # Step 6: Mark kernel region as allocated
    val kernel_start_page = boot_info.kernel_phys_base.addr / PAGE_SIZE
    val kernel_page_count = (boot_info.kernel_size + PAGE_SIZE - 1) / PAGE_SIZE
    var kp: u64 = 0
    while kp < kernel_page_count:
        val page_idx = kernel_start_page + kp
        if not _bitmap_test_addr(_pmm_bitmap_addr, page_idx):
            _bitmap_set_addr(_pmm_bitmap_addr, page_idx)
            _pmm_free_pages = _pmm_free_pages - 1
        kp = kp + 1

    # Step 7: Always reserve the first 1MB (real mode, BIOS, legacy)
    var low_page: u64 = 0
    while low_page < 256:  # 256 pages = 1MB
        if not _bitmap_test_addr(_pmm_bitmap_addr, low_page):
            _bitmap_set_addr(_pmm_bitmap_addr, low_page)
            _pmm_free_pages = _pmm_free_pages - 1
        low_page = low_page + 1

    # Step 8: Seed refcounts from the final allocation bitmap.
    _pmm_initialize_refcounts()

    log_raw_println("[PMM] Refcount slab: {total_pages} entries ({total_pages * 2 / 1024}KB)")
    log_raw_println("[PMM] Initialization complete")
    log_raw_println("[PMM] Free pages: {_pmm_free_pages}")

fn _align_up(value: u64, align: u64) -> u64:
    if align == 0:
        return value
    ((value + align - 1) / align) * align

fn _reserve_page_if_free(page_idx: u64):
    if page_idx >= _pmm_total_pages:
        return
    if not _bitmap_test_addr(_pmm_bitmap_addr, page_idx):
        _bitmap_set_addr(_pmm_bitmap_addr, page_idx)
        if _pmm_free_pages > 0:
            _pmm_free_pages = _pmm_free_pages - 1

fn _reserve_page_range(start_page: u64, page_count: u64):
    var p: u64 = 0
    while p < page_count:
        _reserve_page_if_free(start_page + p)
        p = p + 1

fn pmm_init_identity_range(total_memory: u64, kernel_start: u64, kernel_end: u64) -> bool:
    """Initialize PMM from scalar identity-mapped boot memory bounds.

    This is for direct boot lanes that already identity-map physical memory but
    do not yet have a safe BootOutputPort object bridge.
    """
    log_raw_println("[PMM] Initializing scalar identity memory manager...")
    if total_memory <= PAGE_SIZE or kernel_end <= kernel_start:
        log_raw_println("[PMM] scalar init failed: invalid bounds")
        return false

    val total_pages = total_memory / PAGE_SIZE
    val bitmap_bytes = (total_pages + 7) / BITS_PER_BYTE
    val bitmap_addr = _align_up(kernel_end, PAGE_SIZE)
    val bitmap_end = bitmap_addr + bitmap_bytes
    if bitmap_end > total_memory:
        log_raw_println("[PMM] scalar init failed: bitmap outside memory")
        return false

    # The direct-boot identity contract reserves one contiguous prefix:
    # firmware/low memory, kernel, then the bitmap itself. Initialize the
    # bitmap by bytes instead of issuing one MMIO read/write per physical page.
    val reserved_pages = _align_up(bitmap_end, PAGE_SIZE) / PAGE_SIZE
    _bitmap_initialize_free_with_reserved_prefix(bitmap_addr, bitmap_bytes, reserved_pages)
    _pmm_set_state(bitmap_addr, total_pages, total_pages - reserved_pages, reserved_pages)
    _pmm_initialize_identity_refcounts(reserved_pages)

    log_raw_println("[PMM] scalar init complete")
    true

# ============================================================================
# Page Allocation
# ============================================================================

fn _pmm_alloc_page_address() -> u64:
    if _pmm_free_pages == 0:
        return 0

    # Next-fit search: start from last allocation hint
    var index = _pmm_last_alloc_index
    var checked: u64 = 0

    while checked < _pmm_total_pages:
        if not _bitmap_test_addr(_pmm_bitmap_addr, index):
            # Found free page
            _bitmap_set_addr(_pmm_bitmap_addr, index)
            _pmm_free_pages = _pmm_free_pages - 1
            _pmm_last_alloc_index = index + 1
            if _pmm_last_alloc_index >= _pmm_total_pages:
                _pmm_last_alloc_index = 0
            _pmm_set_refcount(index, 1)
            return index * PAGE_SIZE

        index = index + 1
        if index >= _pmm_total_pages:
            index = 0
        checked = checked + 1

    0

fn pmm_alloc_page() -> PageFrame?:
    """Allocate a single 4KB page frame."""
    val address = _pmm_alloc_page_address()
    if address == 0:
        return nil
    PageFrame(pfn: address / PAGE_SIZE)

fn _pmm_free_page_index(index: u64):
    if index >= _pmm_total_pages:
        return
    if (g_page_refcounts.len() as u64) > index:
        g_page_refcounts[index as i32] = 0
    if _bitmap_test_addr(_pmm_bitmap_addr, index):
        _bitmap_clear_addr(_pmm_bitmap_addr, index)
        _pmm_free_pages = _pmm_free_pages + 1

fn pmm_free_page(frame: PageFrame):
    """Free a single 4KB page frame.

    Marks the page as available. Double-free is silently ignored.
    """
    _pmm_free_page_index(frame.pfn)

fn pmm_alloc_pages(count: u64) -> PhysAddr?:
    """Allocate contiguous physical pages.

    Searches for a run of 'count' consecutive free pages.
    Returns physical address of the first page, or nil if not available.
    """
    if count == 0:
        return nil
    if _pmm_free_pages < count:
        return nil

    # Linear scan for contiguous free run
    var start: u64 = 0
    while start + count <= _pmm_total_pages:
        var found = true
        var offset: u64 = 0
        while offset < count:
            if _bitmap_test_addr(_pmm_bitmap_addr, start + offset):
                # Page is allocated, skip past it
                start = start + offset + 1
                found = false
                break
            offset = offset + 1

        if found:
            # Mark all pages as allocated
            var i: u64 = 0
            while i < count:
                _bitmap_set_addr(_pmm_bitmap_addr, start + i)
                _pmm_set_refcount(start + i, 1)
                i = i + 1
            _pmm_free_pages = _pmm_free_pages - count
            return PhysAddr(addr: start * PAGE_SIZE)

    # No contiguous run found
    nil

fn pmm_free_page_range(base_phys: PhysAddr, count: u64):
    """Free a contiguous range previously returned by pmm_alloc_pages."""
    var offset: u64 = 0
    while offset < count:
        val phys = PhysAddr(addr: base_phys.addr + offset * PAGE_SIZE)
        pmm_free_page(PageFrame.from_phys_addr(phys))
        offset = offset + 1

# ============================================================================
# PMM Query Interface
# ============================================================================

fn pmm_get_manager() -> PhysMemManager:
    """Get reference to the global PMM (for VMM init)."""
    _pmm_snapshot()

fn pmm_total_pages() -> u64:
    """Total number of tracked page frames."""
    _pmm_total_pages

fn pmm_free_pages() -> u64:
    """Number of free page frames."""
    _pmm_free_pages

fn pmm_total_memory() -> u64:
    """Total tracked physical memory in bytes."""
    _pmm_total_pages * PAGE_SIZE

fn pmm_free_memory() -> u64:
    """Free physical memory in bytes."""
    _pmm_free_pages * PAGE_SIZE

# ============================================================================
# Page Reference Counting (COW support)
# ============================================================================
#
# A parallel array of u16 reference counts, one per physical page frame.
# Index into the array is the page frame number (pfn).
# Managed independently of the alloc bitmap: a page with refcount > 1 is
# shared; the bitmap still tracks whether it is allocated at all.
#
# Limits: MAX_PHYS_PAGES entries × 2 bytes = 2MB of BSS. Acceptable.

var g_page_refcounts: [u16] = []

fn _pmm_set_refcount(index: u64, count: u16):
    while (g_page_refcounts.len() as u64) <= index:
        g_page_refcounts.push(0)
    g_page_refcounts[index as i32] = count

fn _pmm_initialize_refcounts():
    var counts: [u16] = []
    var index: u64 = 0
    while index < _pmm_total_pages:
        val count: u16 = if _bitmap_test_addr(_pmm_bitmap_addr, index): 1 else 0
        counts.push(count)
        index = index + 1
    g_page_refcounts = counts

fn _pmm_initialize_identity_refcounts(reserved_pages: u64):
    var counts: [u16] = []
    var index: u64 = 0
    while index < reserved_pages:
        counts.push(1)
        index = index + 1
    g_page_refcounts = counts

fn pmm_ref_page(pa: u64):
    """Increment reference count for the page containing physical address `pa`.

    Safe to call multiple times (COW clone increments parent page refs so both
    parent and child share the same physical frame until a write fault occurs).
    No-op if the pfn is out of range.
    """
    val pfn = pa / PAGE_SIZE
    if pfn >= _pmm_total_pages:
        return
    # Grow refcount array lazily to total_pages length if needed.
    # In baremetal this is only called after pmm_init so total_pages is stable.
    while (g_page_refcounts.len() as u64) <= pfn:
        g_page_refcounts.push(0)
    val cur = g_page_refcounts[pfn as i32]
    if cur < 65535:
        g_page_refcounts[pfn as i32] = cur + 1

fn pmm_unref_page(pa: u64) -> u16:
    """Decrement reference count for the page containing physical address `pa`.

    Returns the new reference count. When the count reaches 0 the caller
    should call `pmm_free_page` to return the frame to the allocator.
    No-op (returns 0) if the pfn is out of range or refcount is already 0.
    """
    val pfn = pa / PAGE_SIZE
    if pfn >= _pmm_total_pages:
        return 0
    if (g_page_refcounts.len() as u64) <= pfn:
        return 0
    val cur = g_page_refcounts[pfn as i32]
    if cur == 0:
        return 0
    val next = cur - 1
    g_page_refcounts[pfn as i32] = next
    next

fn pmm_put_page(pa: u64):
    """Drop one owner or mapping and free the frame on the last drop."""
    if pmm_get_refcount(pa) == 0:
        return
    val remaining = pmm_unref_page(pa)
    if remaining == 0:
        pmm_free_page_raw(pa)

fn pmm_get_refcount(pa: u64) -> u16:
    """Read the current reference count for the page at physical address `pa`."""
    val pfn = pa / PAGE_SIZE
    if pfn >= _pmm_total_pages:
        return 0
    if (g_page_refcounts.len() as u64) <= pfn:
        return 0
    g_page_refcounts[pfn as i32]

fn pmm_alloc_page_raw() -> u64:
    """Allocate a page and return its physical address (u64), or 0 on failure.

    This is the scalar ABI owner used by freestanding bootstrap paths.
    """
    _pmm_alloc_page_address()

fn pmm_free_page_raw(pa: u64):
    """Free a page by physical address. Counterpart to `pmm_alloc_page_raw`."""
    _pmm_free_page_index(pa / PAGE_SIZE)
