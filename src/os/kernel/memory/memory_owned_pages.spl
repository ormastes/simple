# Transactional ownership of anonymous pages mapped by memory syscalls.

use os.kernel.types.memory_types.{VirtAddr, VmFlags}
use os.kernel.types.task_types.{AddressSpace}
use os.kernel.memory.vmm.{vmm_map_page, vmm_active_root, vmm_read_pte_in, vmm_replace_pte_in, PAGE_SIZE, PTE_PRESENT, PTE_ADDR_MASK}
use os.kernel.memory.pmm.{pmm_alloc_page, pmm_free_page, pmm_put_page}

struct MemoryOwnedPageDetach:
    virt_addr: u64
    original_pte: u64

struct MemoryOwnedPagesDetachTxn:
    address_space_root: u64
    pages: [MemoryOwnedPageDetach]

struct MemoryOwnedPagesDetachResult:
    ok: bool
    reason: text
    txn: MemoryOwnedPagesDetachTxn

fn memory_owned_pages_detach_in(base_addr: u64, page_count: u64, address_space_root: u64) -> MemoryOwnedPagesDetachResult:
    val empty = MemoryOwnedPagesDetachTxn(address_space_root: address_space_root, pages: [])
    if address_space_root == 0 or address_space_root == 1:
        return MemoryOwnedPagesDetachResult(ok: false, reason: "invalid-root", txn: empty)
    val space = AddressSpace(phys_root: address_space_root, id: 0)
    var pages: [MemoryOwnedPageDetach] = []
    var offset: u64 = 0
    while offset < page_count:
        val virt = VirtAddr(addr: base_addr + offset * PAGE_SIZE)
        val pte = vmm_read_pte_in(space, virt)
        if (pte & PTE_PRESENT) != 0:
            pages.push(MemoryOwnedPageDetach(virt_addr: virt.addr, original_pte: pte))
        offset = offset + 1

    var index: i64 = 0
    while index < pages.len():
        val page = pages[index]
        if not vmm_replace_pte_in(space, VirtAddr(addr: page.virt_addr), page.original_pte, 0):
            var restore_index = index - 1
            while restore_index >= 0:
                val detached = pages[restore_index]
                if not vmm_replace_pte_in(space, VirtAddr(addr: detached.virt_addr), 0, detached.original_pte):
                    return MemoryOwnedPagesDetachResult(ok: false, reason: "rollback-failed", txn: MemoryOwnedPagesDetachTxn(address_space_root: address_space_root, pages: pages))
                restore_index = restore_index - 1
            return MemoryOwnedPagesDetachResult(ok: false, reason: "detach-failed", txn: empty)
        index = index + 1
    MemoryOwnedPagesDetachResult(ok: true, reason: "ok", txn: MemoryOwnedPagesDetachTxn(address_space_root: address_space_root, pages: pages))

fn memory_owned_pages_restore(txn: MemoryOwnedPagesDetachTxn) -> bool:
    val space = AddressSpace(phys_root: txn.address_space_root, id: 0)
    var index = txn.pages.len() - 1
    while index >= 0:
        val page = txn.pages[index]
        if not vmm_replace_pte_in(space, VirtAddr(addr: page.virt_addr), 0, page.original_pte):
            return false
        index = index - 1
    true

fn memory_owned_pages_finalize(txn: MemoryOwnedPagesDetachTxn):
    for page in txn.pages:
        pmm_put_page(page.original_pte & PTE_ADDR_MASK)

fn memory_release_owned_pages(base_addr: u64, page_count: u64) -> bool:
    val detached = memory_owned_pages_detach_in(base_addr, page_count, vmm_active_root())
    if not detached.ok:
        return false
    memory_owned_pages_finalize(detached.txn)
    true

fn memory_map_owned_pages(base_addr: u64, page_count: u64, flags: VmFlags) -> bool:
    var offset: u64 = 0
    while offset < page_count:
        val opt_frame = pmm_alloc_page()
        if val Some(frame) = opt_frame:
            val virt = VirtAddr(addr: base_addr + offset * PAGE_SIZE)
            if not vmm_map_page(virt, frame.to_phys_addr(), flags):
                pmm_free_page(frame)
                memory_release_owned_pages(base_addr, offset)
                return false
        else:
            memory_release_owned_pages(base_addr, offset)
            return false
        offset = offset + 1
    true
