# Installed swap coordinator used by the page-fault owner.

use std.fs_driver.block_device.{BlockDevice}
use os.kernel.memory.memory_swap_block.{memory_swap_block_store_new}
use os.kernel.memory.memory_swap_coordinator.{MemorySwapCoordinator, memory_swap_coordinator_new}
use os.kernel.memory.memory_leveling_manager.{MemoryPressureReport}
use os.kernel.memory.memory_leveling_runtime.{MemoryLevelingRuntimeResult, memory_leveling_runtime_apply_pressure, memory_leveling_runtime_manager, memory_leveling_runtime_mapping, memory_leveling_runtime_mapping_at, memory_leveling_runtime_forget_mapping, memory_leveling_runtime_replace_manager}
use os.kernel.memory.pmm.{pmm_free_memory}
use os.kernel.types.memory_types.{VirtAddr}
use os.kernel.memory.vmm.{PTE_PRESENT, vmm_read_pte}

struct MemorySwapPressureResult:
    report: MemoryPressureReport
    swapped: u64
    failed: u64

var _memory_swap_runtime_coordinator: MemorySwapCoordinator? = nil
var _memory_swap_runtime_last_fault_reason: text = "none"
var _memory_swap_runtime_last_fault_state: text = "none"

fn memory_swap_runtime_install(coordinator: MemorySwapCoordinator):
    _memory_swap_runtime_coordinator = Some(coordinator)

fn memory_swap_runtime_install_block_device(device: BlockDevice, base_lba: u64, capacity_slots: u64) -> text:
    var manager = memory_leveling_runtime_manager()
    if not manager.config.swap_enabled:
        return "swap-disabled"
    if capacity_slots == 0:
        return "invalid-swap-capacity"
    val configured_slots = manager.config.swap_capacity_bytes / 4096
    val effective_slots = if capacity_slots < configured_slots: capacity_slots else: configured_slots
    if effective_slots == 0:
        return "invalid-swap-capacity"
    val store = memory_swap_block_store_new(true, device, base_lba, effective_slots, 4096)
    memory_swap_runtime_install(memory_swap_coordinator_new(manager, store))
    "ok"

fn memory_swap_runtime_clear_for_test():
    _memory_swap_runtime_coordinator = nil
    _memory_swap_runtime_last_fault_reason = "none"
    _memory_swap_runtime_last_fault_state = "none"

fn memory_swap_runtime_last_fault_reason() -> text:
    _memory_swap_runtime_last_fault_reason

fn memory_swap_runtime_last_fault_state() -> text:
    _memory_swap_runtime_last_fault_state

fn memory_swap_runtime_pmm_pressure_level(free_bytes: u64) -> text:
    val manager = memory_leveling_runtime_manager()
    if free_bytes <= manager.config.cpu_low_watermark_bytes:
        return "critical"
    if free_bytes < manager.config.cpu_high_watermark_bytes:
        return "elevated"
    "normal"

fn memory_swap_runtime_poll_pmm_pressure() -> MemorySwapPressureResult:
    val level = memory_swap_runtime_pmm_pressure_level(pmm_free_memory())
    if level == "normal":
        return MemorySwapPressureResult(
            report: MemoryPressureReport(level: level, inspected: 0, selected: 0, skipped: 0, candidate_ids: []),
            swapped: 0,
            failed: 0
        )
    memory_swap_runtime_apply_pressure(level)

fn memory_swap_runtime_release_range(virt_addr: u64, byte_length: u64, owner_id: u64) -> MemoryLevelingRuntimeResult:
    val end_addr = virt_addr + ((byte_length + 4095) / 4096) * 4096
    var manager = memory_leveling_runtime_manager()
    var released_ids: [u64] = []
    var page_addr = virt_addr
    while page_addr < end_addr:
        match memory_leveling_runtime_mapping_at(page_addr):
            Some(mapping):
                if mapping.owner_id != owner_id:
                    return MemoryLevelingRuntimeResult(ok: false, reason: "not-owner", allocation_ids: released_ids)
                var release_reason = "ok"
                match _memory_swap_runtime_coordinator:
                    Some(coordinator):
                        if coordinator.has_swapped_mapping(mapping.allocation_id):
                            val released = coordinator.release_swapped(mapping.allocation_id, owner_id)
                            release_reason = released.reason
                            manager = coordinator.manager
                            memory_leveling_runtime_replace_manager(manager)
                            _memory_swap_runtime_coordinator = Some(coordinator)
                        else:
                            val released = manager.release(mapping.allocation_id, owner_id)
                            release_reason = released.reason
                    None:
                        val released = manager.release(mapping.allocation_id, owner_id)
                        release_reason = released.reason
                if release_reason != "ok":
                    return MemoryLevelingRuntimeResult(ok: false, reason: release_reason, allocation_ids: released_ids)
                memory_leveling_runtime_forget_mapping(mapping.allocation_id)
                released_ids.push(mapping.allocation_id)
            None: pass
        page_addr = page_addr + 4096
    memory_leveling_runtime_replace_manager(manager)
    MemoryLevelingRuntimeResult(ok: true, reason: "ok", allocation_ids: released_ids)

fn memory_swap_runtime_handle_fault(virt_addr: u64) -> i32:
    match _memory_swap_runtime_coordinator:
        Some(coordinator):
            val restored = coordinator.restore_faulting_page(virt_addr)
            val restore_reason = restored.reason
            val restore_state = restored.state
            val page_addr = (virt_addr / 4096) * 4096
            val pte = vmm_read_pte(VirtAddr(addr: page_addr))
            val return_code: i32 = if coordinator.last_restore_code == 0 and (pte & PTE_PRESENT) != 0: 0 else: -1
            _memory_swap_runtime_last_fault_reason = restore_reason
            _memory_swap_runtime_last_fault_state = restore_state
            memory_leveling_runtime_replace_manager(coordinator.manager)
            _memory_swap_runtime_coordinator = Some(coordinator)
            return return_code
        None:
            _memory_swap_runtime_last_fault_reason = "not-installed"
            _memory_swap_runtime_last_fault_state = "none"
            return -1

fn memory_swap_runtime_apply_pressure(level: text) -> MemorySwapPressureResult:
    val report = memory_leveling_runtime_apply_pressure(level)
    val current_manager = memory_leveling_runtime_manager()
    var swapped: u64 = 0
    var failed: u64 = 0
    match _memory_swap_runtime_coordinator:
        Some(coordinator):
            coordinator.manager = current_manager
            var i: i64 = 0
            while i < report.candidate_ids.len():
                val allocation_id = report.candidate_ids[i]
                match memory_leveling_runtime_mapping(allocation_id):
                    Some(mapping):
                        val result = coordinator.swap_out_page(mapping.allocation_id, mapping.owner_id, mapping.virt_addr, mapping.page_index, mapping.byte_length)
                        if result.ok:
                            swapped = swapped + 1
                        else:
                            failed = failed + 1
                            _ = coordinator.manager.requeue_candidate(allocation_id)
                    None:
                        failed = failed + 1
                        _ = coordinator.manager.requeue_candidate(allocation_id)
                i = i + 1
            memory_leveling_runtime_replace_manager(coordinator.manager)
            _memory_swap_runtime_coordinator = Some(coordinator)
        None:
            failed = report.selected
            var i: i64 = 0
            while i < report.candidate_ids.len():
                _ = current_manager.requeue_candidate(report.candidate_ids[i])
                i = i + 1
            memory_leveling_runtime_replace_manager(current_manager)
    MemorySwapPressureResult(report: report, swapped: swapped, failed: failed)
