# VMM VMA operations, mmap/munmap, COW clone, and demand paging — split from vmm.spl.
# Contains VMA internal helpers, vma_add/find/remove/split, vmm_mmap/munmap,
# vmm_cow_clone, COW/anon/file fault handlers, file backing cache, pt_set_ro,
# and vmm_copy_to_user.

use os.kernel.types.memory_types.{PhysAddr, VirtAddr, VmFlags}
use os.kernel.types.task_types.{AddressSpace}
use os.kernel.types.vmspace_types.{VmArea, ProcessVmSpace}
use os.kernel.boot.mmio.{mmio_read8, mmio_write8, mmio_read64, mmio_write64}
use os.kernel.memory.vmm_core.{
    PAGE_SIZE, VMM_KERNEL_SPACE_START, VMM_MAX_VMAS,
    VMM_VMA_ANON, VMM_VMA_FILE, VMM_VMA_SHARED, VMM_VMA_EXEC, VMM_VMA_COW,
    PTE_PRESENT, PTE_WRITABLE, PTE_ADDR_MASK, PTE_HUGE_PAGE,
    g_next_as_id,
    _phys_to_virt, _read_pte, _write_pte, _pte_is_present, _pte_phys_addr,
    _pml4_index, _pdpt_index, _pd_index, _pt_index,
    _vmm_invalidate_tlb
}
use os.kernel.memory.vmm_address_space.{
    vmm_map_page_in, vmm_read_pte_in, vmm_unmap_page_in, vmm_replace_pte_in,
    vmm_cow_clone_pages
}
use os.kernel.memory.pmm.{pmm_alloc_page_raw, pmm_free_page_raw, pmm_put_page}

struct VmmCowCloneResult:
    ok: bool
    parent: ProcessVmSpace
    child: ProcessVmSpace

struct VmmMunmapResult:
    code: i32
    space: ProcessVmSpace

# ============================================================================
# VMA Internal Helpers
# ============================================================================

fn _vma_overlaps(a: VmArea, start: u64, end: u64) -> bool:
    """Return true if VmArea `a` overlaps the range [start, end)."""
    val a_end = a.start + a.len
    (a.start < end) and (a_end > start)

fn _vma_end(a: VmArea) -> u64:
    a.start + a.len

fn _align_down(addr: u64, align: u64) -> u64:
    (addr / align) * align

fn _align_up(addr: u64, align: u64) -> u64:
    ((addr + align - 1) / align) * align

# ============================================================================
# VMA Operations
# ============================================================================

fn vma_add(space: ProcessVmSpace, area: VmArea) -> i32:
    """Append a VmArea to the address space, rejecting overlaps.

    Returns 0 on success, -EEXIST (-17) if the range overlaps an existing VMA,
    -ENOMEM (-12) if the VMA table is full.
    """
    if space.vma_count >= VMM_MAX_VMAS:
        return -12  # -ENOMEM

    val new_end = area.start + area.len
    var i: i32 = 0
    while (i as u64) < space.vma_count:
        val existing = space.areas[i]
        if _vma_overlaps(existing, area.start, new_end):
            return -17  # -EEXIST
        i = i + 1

    space.areas.push(area)
    space.vma_count = space.vma_count + 1
    0

fn vma_find(space: ProcessVmSpace, vaddr: u64) -> VmArea?:
    """Find the VmArea containing `vaddr`, or nil if none."""
    var i: i32 = 0
    while (i as u64) < space.vma_count:
        val area = space.areas[i]
        val area_end = area.start + area.len
        if (vaddr >= area.start) and (vaddr < area_end):
            return area
        i = i + 1
    nil

fn vma_remove(space: ProcessVmSpace, vaddr: u64, len: u64) -> ProcessVmSpace:
    """Remove or split VMAs that intersect [vaddr, vaddr+len).

    Implements the POSIX munmap semantic:
    - A VMA fully covered by the range is deleted.
    - A VMA partially overlapping at the start is trimmed from the right.
    - A VMA partially overlapping at the end is trimmed from the left.
    - A VMA split down the middle produces a tail fragment re-inserted
      at the end of the array (low-overhead; order is not guaranteed).
    Returns the updated value. Never fails (a missing range is ignored).
    """
    var updated = space
    val range_end = vaddr + len
    var i: i32 = 0
    while (i as u64) < updated.vma_count:
        val area = updated.areas[i]
        val area_end = area.start + area.len
        if not _vma_overlaps(area, vaddr, range_end):
            i = i + 1
        else:
            # Remove this entry by swapping with the last live entry
            val last_idx = (updated.vma_count - 1) as i32
            updated.areas[i] = updated.areas[last_idx]
            updated.vma_count = updated.vma_count - 1
            # Pop the trailing slot
            if updated.areas.len() > (updated.vma_count as i32):
                updated.areas.pop()

            # Re-insert surviving fragments
            if area.start < vaddr:
                # Left fragment: [area.start .. vaddr)
                val left = VmArea(
                    start: area.start,
                    len: vaddr - area.start,
                    kind: area.kind,
                    flags: area.flags,
                    backing: area.backing,
                    backing_offset: area.backing_offset
                )
                updated.areas.push(left)
                updated.vma_count = updated.vma_count + 1
            if area_end > range_end:
                # Right fragment: [range_end .. area_end)
                val right_offset = range_end - area.start
                val right = VmArea(
                    start: range_end,
                    len: area_end - range_end,
                    kind: area.kind,
                    flags: area.flags,
                    backing: area.backing,
                    backing_offset: area.backing_offset + right_offset
                )
                updated.areas.push(right)
                updated.vma_count = updated.vma_count + 1
            # Do NOT advance i — the slot now holds a different (swapped) entry
    updated

fn vmm_teardown_user_space(space: ProcessVmSpace):
    """Tear down all user-space VMAs in the given address space."""
    var current = space
    var i: i32 = 0
    while (i as u64) < current.vma_count:
        val area = current.areas[i]
        if area.start < VMM_KERNEL_SPACE_START:
            val unmapped = vmm_munmap_result(current, area.start, area.len)
            if unmapped.code != 0:
                return
            current = unmapped.space
        else:
            i = i + 1
    # Reset the VMA list to empty.
    while current.areas.len() > 0:
        current.areas.pop()
    current.vma_count = 0

fn vma_split(space: ProcessVmSpace, vaddr: u64) -> i32:
    """Split whichever VMA contains `vaddr` at that address."""
    var i: i32 = 0
    while (i as u64) < space.vma_count:
        val area = space.areas[i]
        val area_end = area.start + area.len
        if (vaddr > area.start) and (vaddr < area_end):
            # Replace area[i] with left half
            val left = VmArea(
                start: area.start,
                len: vaddr - area.start,
                kind: area.kind,
                flags: area.flags,
                backing: area.backing,
                backing_offset: area.backing_offset
            )
            space.areas[i] = left

            # Append right half
            val right_offset = vaddr - area.start
            val right = VmArea(
                start: vaddr,
                len: area_end - vaddr,
                kind: area.kind,
                flags: area.flags,
                backing: area.backing,
                backing_offset: area.backing_offset + right_offset
            )
            space.areas.push(right)
            space.vma_count = space.vma_count + 1
            return 0
        i = i + 1
    -22  # -EINVAL

# ============================================================================
# Hint-address picker for vmm_mmap
# ============================================================================

val VMM_USER_HINT_BASE: u64 = 0x0000000000400000   # 4MB — below kernel
val VMM_USER_HINT_LIMIT: u64 = 0x0000800000000000  # Top of lower canonical half

fn _pick_free_vaddr(space: ProcessVmSpace, len: u64) -> u64:
    """Find the lowest page-aligned address in user range with no VMA overlap."""
    var candidate = VMM_USER_HINT_BASE
    while candidate + len <= VMM_USER_HINT_LIMIT:
        val cand_end = candidate + len
        var overlap = false
        var i: i32 = 0
        while (i as u64) < space.vma_count:
            val area = space.areas[i]
            if _vma_overlaps(area, candidate, cand_end):
                # Skip past this VMA
                candidate = _align_up(_vma_end(area), PAGE_SIZE)
                overlap = true
                break
            i = i + 1
        if not overlap:
            return candidate
    0

# ============================================================================
# Public mmap / munmap API
# ============================================================================

fn vmm_mmap(
    space: ProcessVmSpace,
    vaddr: u64,
    len: u64,
    flags: u32,
    kind: u32,
    backing: u64,
    backing_offset: u64
) -> i64:
    """Reserve a virtual address range in `space` and add a VMA."""
    if len == 0:
        return -22  # -EINVAL

    val aligned_len = _align_up(len, PAGE_SIZE)

    var chosen: u64 = vaddr
    if chosen == 0:
        chosen = _pick_free_vaddr(space, aligned_len)
        if chosen == 0:
            return -12  # -ENOMEM
    else:
        chosen = _align_down(chosen, PAGE_SIZE)

    val area = VmArea(
        start: chosen,
        len: aligned_len,
        kind: kind,
        flags: flags,
        backing: backing,
        backing_offset: backing_offset
    )
    val rc = vma_add(space, area)
    if rc != 0:
        return rc as i64

    chosen as i64

fn vmm_munmap_result(space: ProcessVmSpace, vaddr: u64, len: u64) -> VmmMunmapResult:
    """Unmap [vaddr, vaddr+len) from `space`."""
    if len == 0:
        return VmmMunmapResult(code: -22, space: space)  # -EINVAL
    var updated = space

    val aligned_start = _align_down(vaddr, PAGE_SIZE)
    val aligned_len   = _align_up(len, PAGE_SIZE)
    val aligned_end   = aligned_start + aligned_len

    val as_handle = AddressSpace(phys_root: updated.pml4, id: updated.id)
    var detached_vaddrs: [u64] = []
    var detached_ptes: [u64] = []
    var pg = aligned_start
    while pg < aligned_end:
        val virt = VirtAddr(addr: pg)
        val pte = vmm_read_pte_in(as_handle, virt)
        if (pte & PTE_PRESENT) != 0:
            if not vmm_unmap_page_in(as_handle, virt):
                # Restore detached pages before returning; ownership has not
                # been released yet, so rollback only remaps the old frames.
                var ri: i32 = 0
                while (ri as u64) < detached_ptes.len():
                    val old_pte = detached_ptes[ri]
                    if not vmm_replace_pte_in(
                        as_handle,
                        VirtAddr(addr: detached_vaddrs[ri]),
                        0,
                        old_pte
                    ):
                        return VmmMunmapResult(code: -5, space: updated)  # -EIO
                    ri = ri + 1
                return VmmMunmapResult(code: -14, space: updated)  # -EFAULT
            detached_vaddrs.push(pg)
            detached_ptes.push(pte)
        pg = pg + PAGE_SIZE

    # PTE ownership is detached successfully; release each leaf exactly once.
    var fi: i32 = 0
    while (fi as u64) < detached_ptes.len():
        val pa = detached_ptes[fi] & PTE_ADDR_MASK
        if pa != 0:
            pmm_put_page(pa)
        fi = fi + 1

    # Metadata changes are committed only after all PTE/frame ownership work.
    updated = vma_remove(updated, aligned_start, aligned_len)
    VmmMunmapResult(code: 0, space: updated)

fn vmm_munmap(space: ProcessVmSpace, vaddr: u64, len: u64) -> i32:
    vmm_munmap_result(space, vaddr, len).code

fn vmm_remove_vma_metadata(space: ProcessVmSpace, vaddr: u64, len: u64) -> ProcessVmSpace:
    var updated = space
    if len != 0:
        updated = vma_remove(updated, _align_down(vaddr, PAGE_SIZE), _align_up(len, PAGE_SIZE))
    updated

# ============================================================================
# Copy-on-Write: fork clone
# ============================================================================

fn vmm_cow_clone_result(parent_space: ProcessVmSpace) -> VmmCowCloneResult:
    """Create a COW child and return the parent's updated VMA metadata."""
    val child_pml4 = vmm_cow_clone_pages(parent_space.pml4)
    if child_pml4 == 0:
        return VmmCowCloneResult(
            ok: false,
            parent: parent_space,
            child: ProcessVmSpace(pml4: 0, id: 0, vma_count: 0, areas: [])
        )

    var updated_parent = parent_space
    var child = ProcessVmSpace(
        pml4: child_pml4,
        id: g_next_as_id,
        vma_count: 0,
        areas: []
    )
    g_next_as_id = g_next_as_id + 1

    # Clone VMA list, setting VMM_VMA_COW on all writable VMAs
    var i: i32 = 0
    while (i as u64) < parent_space.vma_count:
        val src = parent_space.areas[i]
        var child_flags = src.flags
        if (src.flags & 2) != 0:
            child_flags = child_flags | VMM_VMA_COW
        val cloned = VmArea(
            start: src.start,
            len: src.len,
            kind: src.kind,
            flags: child_flags,
            backing: src.backing,
            backing_offset: src.backing_offset
        )
        child.areas.push(cloned)
        child.vma_count = child.vma_count + 1

        # Also mark parent VMA as COW so the parent faults on next write
        if (src.flags & 2) != 0:
            var parent_flags = src.flags | VMM_VMA_COW
            updated_parent.areas[i] = VmArea(
                start: src.start,
                len: src.len,
                kind: src.kind,
                flags: parent_flags,
                backing: src.backing,
                backing_offset: src.backing_offset
            )

        i = i + 1

    VmmCowCloneResult(ok: true, parent: updated_parent, child: child)

fn vmm_cow_clone(parent_space: ProcessVmSpace) -> ProcessVmSpace:
    """Compatibility wrapper returning the child or an invalid root on failure."""
    vmm_cow_clone_result(parent_space).child

# ============================================================================
# COW page fault handler
# ============================================================================

fn vmm_handle_cow_fault(space: ProcessVmSpace, fault_vaddr: u64) -> i32:
    """Handle a COW write fault at `fault_vaddr` in `space`."""
    val area_opt = vma_find(space, fault_vaddr)
    if val Some(area) = area_opt:
        if (area.flags & VMM_VMA_COW) == 0:
            return -22  # -EINVAL — not a COW mapping

        # Allocate replacement page
        val new_pa = pmm_alloc_page_raw()
        if new_pa == 0:
            return -12  # -ENOMEM

        # Copy old page content via HHDM
        val page_base = _align_down(fault_vaddr, PAGE_SIZE)
        val as_handle = AddressSpace(phys_root: space.pml4, id: space.id)
        val old_pte = vmm_read_pte_in(as_handle, VirtAddr(addr: page_base))
        val old_pa = old_pte & PTE_ADDR_MASK
        if old_pa != 0:
            val old_virt = _phys_to_virt(old_pa)
            val new_virt = _phys_to_virt(new_pa)
            var byte_idx: u64 = 0
            while byte_idx < PAGE_SIZE:
                val b = mmio_read64(old_virt + byte_idx)
                mmio_write64(new_virt + byte_idx, b)
                byte_idx = byte_idx + 8

        if (old_pte & PTE_PRESENT) == 0:
            pmm_free_page_raw(new_pa)
            return -14  # -EFAULT

        # Preserve the entire old leaf PTE while changing only its frame and RW bit.
        val replacement_pte = (new_pa & PTE_ADDR_MASK) | ((old_pte & ~PTE_ADDR_MASK) | PTE_WRITABLE)
        val mapped = vmm_replace_pte_in(
            as_handle,
            VirtAddr(addr: page_base),
            old_pte,
            replacement_pte
        )
        if not mapped:
            pmm_free_page_raw(new_pa)
            return -12  # -ENOMEM

        # Drop the reference on the old page (may free it if last holder)
        if old_pa != 0:
            pmm_put_page(old_pa)

        return 0

    -22  # -EINVAL — address not in any VMA

# ============================================================================
# Demand-paging fault handlers
# ============================================================================

fn vmm_handle_anon_fault(space: ProcessVmSpace, vaddr: u64) -> i32:
    """Demand-page handler for anonymous (zero-filled) fault at `vaddr`."""
    val page_base = _align_down(vaddr, PAGE_SIZE)
    val area_opt = vma_find(space, vaddr)
    if val Some(area) = area_opt:
        if area.kind != VMM_VMA_ANON:
            return -22  # -EINVAL — wrong handler for this VMA kind

        val pa = pmm_alloc_page_raw()
        if pa == 0:
            return -12  # -ENOMEM

        # Zero the page via HHDM
        val new_virt = _phys_to_virt(pa)
        var zi: u64 = 0
        while zi < PAGE_SIZE:
            mmio_write64(new_virt + zi, 0)
            zi = zi + 8

        # Build PTE flags from VMA permission bits
        var flag_bits: u32 = 1  # VM_PRESENT always
        if (area.flags & 2) != 0:
            flag_bits = flag_bits | 2   # VM_WRITABLE
        flag_bits = flag_bits | 4       # VM_USER
        if (area.flags & VMM_VMA_EXEC) == 0 or (area.flags & 2) != 0:
            flag_bits = flag_bits | 32  # VM_NO_EXECUTE

        val as_handle = AddressSpace(phys_root: space.pml4, id: space.id)
        val map_flags = VmFlags(bits: flag_bits)
        val mapped = vmm_map_page_in(
            as_handle,
            VirtAddr(addr: page_base),
            PhysAddr(addr: pa),
            map_flags
        )
        if not mapped:
            pmm_free_page_raw(pa)
            return -12  # -ENOMEM

        return 0

    -22  # -EINVAL — address not in any VMA

fn vmm_handle_file_fault(space: ProcessVmSpace, vaddr: u64) -> i32:
    """Demand-page handler for file-backed fault at `vaddr`."""
    val page_base = _align_down(vaddr, PAGE_SIZE)
    val area_opt = vma_find(space, vaddr)
    if val Some(area) = area_opt:
        if area.kind != VMM_VMA_FILE:
            return -22
        val cached = _file_cache_lookup(area.backing)
        if cached.len() == 0 as i64:
            return -2   # -ENOENT — backing not cached
        val pa = pmm_alloc_page_raw()
        if pa == 0:
            return -12
        val file_offset = area.backing_offset + (page_base - area.start)
        val new_virt = _phys_to_virt(pa)
        var bi: u64 = 0
        while bi < PAGE_SIZE:
            val src_off = file_offset + bi
            if (src_off as i64) < cached.len():
                mmio_write8(new_virt + bi, cached[src_off as i64])
            else:
                mmio_write8(new_virt + bi, 0 as u8)
            bi = bi + 1
        var flag_bits: u32 = 1
        if (area.flags & 2) != 0:
            flag_bits = flag_bits | 2
        flag_bits = flag_bits | 4
        if (area.flags & VMM_VMA_EXEC) == 0:
            flag_bits = flag_bits | 32
        val as_handle = AddressSpace(phys_root: space.pml4, id: space.id)
        val map_flags = VmFlags(bits: flag_bits)
        val mapped = vmm_map_page_in(as_handle, VirtAddr(addr: page_base), PhysAddr(addr: pa), map_flags)
        if not mapped:
            pmm_free_page_raw(pa)
            return -12
        return 0
    -22

var _file_cache_handles: [u64] = []
var _file_cache_bytes: [[u8]] = []

fn vmm_cache_file_backing(handle: u64, bytes: [u8]):
    """Cache file content for a backing handle so demand faults can read it."""
    var i = 0
    val n = _file_cache_handles.len()
    while i < n:
        if _file_cache_handles[i] == handle:
            _file_cache_bytes[i] = bytes
            return
        i = i + 1
    _file_cache_handles = _file_cache_handles + [handle]
    _file_cache_bytes = _file_cache_bytes + [bytes]

fn _file_cache_lookup(handle: u64) -> [u8]:
    var i = 0
    val n = _file_cache_handles.len()
    while i < n:
        if _file_cache_handles[i] == handle:
            return _file_cache_bytes[i]
        i = i + 1
    [] as [u8]

# ============================================================================
# Page-table helper: mark a virtual page read-only
# ============================================================================

fn pt_set_ro(pml4: u64, vaddr: u64):
    """Clear PTE_WRITABLE on the leaf PTE for `vaddr` in the page table
    rooted at `pml4`. Used by vmm_cow_clone to make shared pages read-only."""
    val pml4_virt = _phys_to_virt(pml4)
    val pml4_entry = _read_pte(pml4_virt, _pml4_index(vaddr))
    if not _pte_is_present(pml4_entry):
        return

    val pdpt_virt = _phys_to_virt(_pte_phys_addr(pml4_entry))
    val pdpt_entry = _read_pte(pdpt_virt, _pdpt_index(vaddr))
    if not _pte_is_present(pdpt_entry):
        return

    val pd_virt = _phys_to_virt(_pte_phys_addr(pdpt_entry))
    val pd_entry = _read_pte(pd_virt, _pd_index(vaddr))
    if not _pte_is_present(pd_entry):
        return

    if (pd_entry & PTE_HUGE_PAGE) != 0:
        _write_pte(pd_virt, _pd_index(vaddr), pd_entry & ~PTE_WRITABLE)
        _vmm_invalidate_tlb(vaddr)
        return

    val pt_virt = _phys_to_virt(_pte_phys_addr(pd_entry))
    val pt_entry = _read_pte(pt_virt, _pt_index(vaddr))
    if _pte_is_present(pt_entry):
        _write_pte(pt_virt, _pt_index(vaddr), pt_entry & ~PTE_WRITABLE)
        _vmm_invalidate_tlb(vaddr)

# ============================================================================
# ELF segment copy-to-user
# ============================================================================

fn vmm_copy_to_user(space: ProcessVmSpace, vaddr: u64, src_bytes: [u8], src_offset: u64, copy_len: u64, total_len: u64, flags: VmFlags) -> i32:
    val as_handle = AddressSpace(phys_root: space.pml4, id: space.id)
    var page_offset: u64 = 0
    while page_offset < total_len:
        val cur_vaddr = vaddr + page_offset
        val page_base = _align_down(cur_vaddr, PAGE_SIZE)
        val in_page_off = cur_vaddr - page_base

        val pa = pmm_alloc_page_raw()
        if pa == 0:
            return -12

        val page_virt = _phys_to_virt(pa)
        var zi: u64 = 0
        while zi < PAGE_SIZE:
            mmio_write64(page_virt + zi, 0)
            zi = zi + 8

        val page_end = page_base + PAGE_SIZE
        val data_start = vaddr
        val data_end = vaddr + copy_len
        val overlap_start = if cur_vaddr > data_start: cur_vaddr else: data_start
        val overlap_end = if page_end < data_end: page_end else: data_end

        if overlap_end > overlap_start:
            val dest_off = overlap_start - page_base
            val src_off = src_offset + (overlap_start - data_start)
            var bi: u64 = 0
            val count = overlap_end - overlap_start
            while bi < count:
                val byte_val = src_bytes[(src_off + bi) as i64]
                mmio_write8(page_virt + dest_off + bi, byte_val)
                bi = bi + 1

        val mapped = vmm_map_page_in(
            as_handle,
            VirtAddr(addr: page_base),
            PhysAddr(addr: pa),
            flags
        )
        if not mapped:
            pmm_free_page_raw(pa)
            return -12

        val remaining_in_page = PAGE_SIZE - in_page_off
        page_offset = page_offset + remaining_in_page

    0
