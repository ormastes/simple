#![allow(unnamed_duplicate_typed_args)]
# Kernel Heap — Memory Layer (Layer 1)
#
# heap_init() maps physical pages for the heap region, initialises
# the mimalloc size-class tables, and injects a PMM-backed OS page
# provider so that mi_malloc_raw can hand out real virtual addresses.
#
# heap_alloc / heap_free delegate to mi_malloc_raw / mi_free_raw.
# When the OS page provider stub returns 0 (pre-boot or interpreter
# mode), heap_alloc returns nil — same behaviour as OOM.
#
# Tracked: doc/08_tracking/todo/mimalloc_kernel_heap_blocker_2026-04-24.md

use os.kernel.types.memory_types.{PhysAddr, VirtAddr, VmFlags, PageFrame}
use nogc_sync_mut.mimalloc.{mimalloc_init, mimalloc_set_os_page_alloc, mi_malloc_raw, mi_free_raw, MiHeap}

# ============================================================================
# Constants
# ============================================================================

val HEAP_ALIGNMENT: u64 = 16            # 16-byte alignment (SSE requirement)

# ============================================================================
# Kernel Heap Metadata
# ============================================================================

struct KernelHeap:
    """Metadata for the kernel heap region (query/diagnostics only).

    Allocation is handled by mimalloc via mi_malloc_raw.
    """
    base: u64               # Virtual start of heap region
    size: u64               # Total heap size in bytes
    total_allocated: u64    # Bytes currently allocated (approximate)
    total_free: u64         # Bytes currently free (approximate)
    alloc_count: u64        # Number of active allocations

# ============================================================================
# Global Heap Instance
# ============================================================================

var g_heap: KernelHeap = KernelHeap(
    base: 0,
    size: 0,
    total_allocated: 0,
    total_free: 0,
    alloc_count: 0
)

# Forward declarations
extern fn serial_println(msg: text)
extern fn vmm_map_page(virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool
extern fn pmm_alloc_page() -> PageFrame?

# ============================================================================
# Alignment Helper
# ============================================================================

fn _align_up_64(value: u64, alignment: u64) -> u64:
    """Align value up to alignment boundary (alignment must be power of 2)."""
    (value + alignment - 1) & ~(alignment - 1)

# ============================================================================
# Heap Initialization — OS page provider + heap_init
# ============================================================================

fn _kernel_page_alloc(size: usize) -> usize:
    """OS page provider for mimalloc. Allocates physical pages from PMM and
    returns their virtual address (identity-mapped for kernel heap region).
    Returns 0 on failure (mimalloc treats 0 as allocation failure).
    """
    val page_size: u64 = 4096
    val needed_pages = ((size as u64) + page_size - 1) / page_size
    val flags = VmFlags.kernel_rw()

    # Allocate the first page to anchor the virtual address
    val first_frame = pmm_alloc_page()
    if val Some(f) = first_frame:
        val base_phys = f.to_phys_addr()
        val base_virt = VirtAddr(addr: base_phys.addr)   # identity-mapped
        vmm_map_page(base_virt, base_phys, flags)

        # Map additional pages if multi-page allocation
        var i: u64 = 1
        while i < needed_pages:
            val extra_frame = pmm_alloc_page()
            if val Some(ef) = extra_frame:
                val virt = VirtAddr(addr: base_phys.addr + (i * page_size))
                vmm_map_page(virt, ef.to_phys_addr(), flags)
            i = i + 1

        return base_virt.addr as usize
    0

fn heap_init(start: VirtAddr, size: u64):
    """Initialize the kernel heap.

    Maps physical pages for the heap region, initialises mimalloc, and
    wires the PMM-backed OS page provider so that heap_alloc delegates
    to mi_malloc_raw for all allocations.

    Args:
        start: Virtual address of heap start (must be page-aligned)
        size:  Heap size in bytes (must be > 0)
    """
    serial_println("[HEAP] Initializing kernel heap...")
    serial_println("[HEAP] Base: 0x{start.addr} Size: {size} bytes ({size / 1024}KB)")

    if size == 0:
        serial_println("[HEAP] FATAL: Heap size is zero")
        return

    val base = start.addr

    # Map heap pages to physical memory
    _map_heap_region(base, size)

    # Initialise mimalloc size-class tables
    mimalloc_init(MiHeap(size_classes: [], pages_by_class: []))

    # Inject PMM-backed OS page provider — must happen after pmm_init
    mimalloc_set_os_page_alloc(_kernel_page_alloc)

    g_heap = KernelHeap(
        base: base,
        size: size,
        total_allocated: 0,
        total_free: size,
        alloc_count: 0
    )

    serial_println("[HEAP] Initialization complete (mimalloc delegate active), {size} bytes available")

fn _map_heap_region(base: u64, size: u64):
    """Map heap virtual pages to physical frames."""
    val page_size: u64 = 4096
    val page_count = (size + page_size - 1) / page_size
    val flags = VmFlags.kernel_rw()

    var i: u64 = 0
    while i < page_count:
        val virt = VirtAddr(addr: base + (i * page_size))
        val frame = pmm_alloc_page()
        if val Some(f) = frame:
            val phys = f.to_phys_addr()
            vmm_map_page(virt, phys, flags)
        else:
            serial_println("[HEAP] WARNING: Could not allocate page for heap")
        i = i + 1

# ============================================================================
# Heap Allocation
# ============================================================================

fn heap_alloc(size: u64) -> VirtAddr?:
    """Allocate memory from the kernel heap via mimalloc.

    Delegates to mi_malloc_raw which uses the PMM-backed OS page provider
    injected during heap_init. Returns 16-byte aligned virtual address.
    Returns nil if the OS page provider returns 0 (OOM or stub mode).

    Args:
        size: Requested allocation size in bytes
    """
    if size == 0:
        return nil

    val aligned_size = _align_up_64(size, HEAP_ALIGNMENT)
    val addr = mi_malloc_raw(aligned_size as usize)
    if addr == 0:
        return nil

    g_heap.total_allocated = g_heap.total_allocated + aligned_size
    if g_heap.total_free >= aligned_size:
        g_heap.total_free = g_heap.total_free - aligned_size
    g_heap.alloc_count = g_heap.alloc_count + 1

    Some(VirtAddr(addr: addr as u64))

# ============================================================================
# Heap Deallocation
# ============================================================================

fn heap_free(addr: VirtAddr):
    """Free a heap allocation previously returned by heap_alloc.

    Delegates to mi_free_raw. The size is unknown at this call site
    (mimalloc tracks it via size-class bookkeeping). Passes 0 as the
    size hint; mi_free_raw uses the class-index lookup to recover it.

    Args:
        addr: Virtual address previously returned by heap_alloc
    """
    if addr.addr == 0:
        return

    mi_free_raw(addr.addr as usize, 0)

    if g_heap.alloc_count > 0:
        g_heap.alloc_count = g_heap.alloc_count - 1

# ============================================================================
# Heap Query Interface
# ============================================================================

fn heap_total_allocated() -> u64:
    """Total bytes currently allocated."""
    g_heap.total_allocated

fn heap_total_free() -> u64:
    """Total bytes currently free (approximate; updated per heap_alloc call)."""
    g_heap.total_free

fn heap_alloc_count() -> u64:
    """Number of active allocations."""
    g_heap.alloc_count
