#![allow(unnamed_duplicate_typed_args)]
# Kernel Heap — Memory Layer (Layer 1)
#
# mimalloc-backed kernel heap. heap_alloc/heap_free delegate to
# mi_malloc_raw/mi_free_raw. The OS page provider (_kernel_pmm_page_alloc)
# is a bump allocator inside the pre-mapped heap region — one 4 KiB page
# consumed per alloc regardless of size until sub-page bucketing lands.
#
# FIXME(AC-6 follow-up): Implement MiPage.base + offset arithmetic in
# mimalloc.spl so small/medium allocs share a single PMM page rather than
# each consuming one. Tracked:
# doc/08_tracking/todo/mimalloc_kernel_heap_blocker_2026-04-24.md

use os.kernel.types.memory_types.{PhysAddr, VirtAddr, VmFlags}
use nogc_sync_mut.mimalloc.{MiHeap, mimalloc_init, mimalloc_set_os_page_alloc, mi_malloc_raw, mi_free_raw}

# ============================================================================
# Kernel Heap
# ============================================================================

struct KernelHeap:
    """Kernel heap state tracking. Allocation is handled by mimalloc via
    mi_malloc_raw; this struct records bookkeeping totals only.
    """
    base: u64           # Virtual start of heap region
    size: u64           # Total heap size
    total_allocated: u64    # Bytes currently allocated (approximate)
    total_free: u64         # Bytes currently free (approximate)
    alloc_count: u64        # Number of active allocations

# ============================================================================
# Global Heap Instance
# ============================================================================

var g_heap: KernelHeap = KernelHeap(
    base: 0,
    size: 0,
    total_allocated: 0,
    total_free: 0,
    alloc_count: 0
)

# Bump pointer within the pre-mapped heap region (used by _kernel_pmm_page_alloc)
var _g_bump_ptr: u64 = 0
var _g_bump_end: u64 = 0

# Forward declarations
extern fn serial_println(msg: text)
extern fn vmm_map_page(virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool
extern fn pmm_alloc_page() -> PageFrame?

use os.kernel.types.memory_types.{PageFrame}

# ============================================================================
# OS page provider for mimalloc — bump allocator inside pre-mapped heap region
#
# NOTE(AC-6 follow-up): Every mi_malloc_raw call, regardless of requested
# size, consumes PAGE_SIZE bytes from the bump region. This is a deliberate
# temporary regression accepted when landing the mimalloc wiring. Sub-page
# bucketing (MiPage.base + offset arithmetic) will fix this.
# ============================================================================

val _HEAP_PAGE_SIZE: u64 = 4096

fn _kernel_pmm_page_alloc(size: usize) -> usize:
    """Bump allocator within the pre-mapped heap virtual region.

    Returns the next aligned slot of at least PAGE_SIZE bytes, or 0 on
    exhaustion. In interpreter/stub mode _g_bump_end == 0, so returns 0.
    """
    if _g_bump_ptr == 0 or _g_bump_end == 0:
        return 0
    val pages_needed = (size as u64 + _HEAP_PAGE_SIZE - 1) / _HEAP_PAGE_SIZE
    val alloc_bytes = pages_needed * _HEAP_PAGE_SIZE
    if _g_bump_ptr + alloc_bytes > _g_bump_end:
        return 0
    val addr = _g_bump_ptr
    _g_bump_ptr = _g_bump_ptr + alloc_bytes
    addr as usize

# ============================================================================
# Heap Initialization
# ============================================================================

fn heap_init(start: VirtAddr, size: u64):
    """Initialize the kernel heap.

    Maps the heap virtual region to physical pages, sets up the bump
    allocator, initialises mimalloc, and injects the OS page provider.
    The caller must ensure the virtual address range is available.

    Args:
        start: Virtual address of heap start (must be page-aligned)
        size:  Heap size in bytes (must be >= 4096)
    """
    serial_println("[HEAP] Initializing kernel heap...")
    serial_println("[HEAP] Base: 0x{start.addr} Size: {size} bytes ({size / 1024}KB)")

    val heap_min: u64 = 4096
    if size < heap_min:
        serial_println("[HEAP] FATAL: Heap too small")
        return

    val base = start.addr

    # Map heap pages to physical memory
    _map_heap_region(base, size)

    # Initialize global heap tracking
    g_heap = KernelHeap(
        base: base,
        size: size,
        total_allocated: 0,
        total_free: size,
        alloc_count: 0
    )

    # Set up bump region for the mimalloc OS page provider
    _g_bump_ptr = base
    _g_bump_end = base + size

    # Wire mimalloc as the backing allocator
    mimalloc_init(MiHeap(size_classes: [], pages_by_class: []))
    mimalloc_set_os_page_alloc(_kernel_pmm_page_alloc)

    serial_println("[HEAP] Initialization complete (mimalloc), {size} bytes available")

fn _map_heap_region(base: u64, size: u64):
    """Map heap virtual pages to physical frames."""
    val page_size: u64 = 4096
    val page_count = (size + page_size - 1) / page_size
    val flags = VmFlags.kernel_rw()

    var i: u64 = 0
    while i < page_count:
        val virt = VirtAddr(addr: base + (i * page_size))
        val frame = pmm_alloc_page()
        if val Some(f) = frame:
            val phys = f.to_phys_addr()
            vmm_map_page(virt, phys, flags)
        else:
            serial_println("[HEAP] WARNING: Could not allocate page for heap")
        i = i + 1

# ============================================================================
# Heap Allocation
# ============================================================================

fn heap_alloc(size: u64) -> VirtAddr?:
    """Allocate memory from the kernel heap via mimalloc.

    Delegates to mi_malloc_raw which uses the pre-mapped bump region.
    Returns nil if allocation fails (exhausted or not yet initialized).

    Args:
        size: Requested allocation size in bytes
    """
    if size == 0:
        return nil

    val addr = mi_malloc_raw(size as usize)
    if addr == 0:
        return nil

    g_heap.total_allocated = g_heap.total_allocated + size
    if g_heap.total_free >= size:
        g_heap.total_free = g_heap.total_free - size
    g_heap.alloc_count = g_heap.alloc_count + 1

    Some(VirtAddr(addr: addr as u64))

# ============================================================================
# Heap Deallocation
# ============================================================================

fn heap_free(addr: VirtAddr):
    """Free a heap allocation.

    Delegates to mi_free_raw. Page reclaim is not yet implemented in
    mi_free_raw — the bump region is not reclaimed. This is acceptable
    until sub-page bucketing lands (AC-6 follow-up).

    Args:
        addr: Virtual address previously returned by heap_alloc
    """
    if addr.addr == 0:
        return

    # Validate: address must be within heap range
    if addr.addr < g_heap.base:
        serial_println("[HEAP] WARNING: free() on address below heap")
        return
    if addr.addr >= g_heap.base + g_heap.size:
        serial_println("[HEAP] WARNING: free() on address above heap")
        return

    mi_free_raw(addr.addr as usize, 0)

    if g_heap.alloc_count > 0:
        g_heap.alloc_count = g_heap.alloc_count - 1

# ============================================================================
# Heap Query Interface
# ============================================================================

fn heap_total_allocated() -> u64:
    """Total bytes currently allocated."""
    g_heap.total_allocated

fn heap_total_free() -> u64:
    """Total bytes currently free."""
    g_heap.total_free

fn heap_alloc_count() -> u64:
    """Number of active allocations."""
    g_heap.alloc_count

fn heap_integrity_check() -> bool:
    """Basic sanity check: allocated <= total heap size."""
    g_heap.total_allocated <= g_heap.size
