# GPU/NIC/DMA lifecycle extensions for the memory-leveling registry.

use std.memory_leveling.{
    MEMORY_DMA_DIRECTION_BIDIRECTIONAL,
    memory_domain,
    memory_tier_dma_pinned,
    memory_tier_gpu_coherent,
    memory_tier_nic_buffer
}
use os.kernel.memory.memory_leveling_manager.{MemoryLevelingManager, MemoryLevelingOperation}

impl MemoryLevelingManager:

    me register_gpu_queue(allocation_id: u64, owner_id: u64, byte_length: u64, physical_base: u64) -> MemoryLevelingOperation:
        me.register_device_buffer(allocation_id, owner_id, byte_length, (byte_length + 4095) / 4096, memory_domain("gpu", true), memory_tier_dma_pinned(), MEMORY_DMA_DIRECTION_BIDIRECTIONAL, true, true, physical_base, true)

    me register_gpu_backing(allocation_id: u64, owner_id: u64, byte_length: u64, physical_base: u64, contiguous: bool) -> MemoryLevelingOperation:
        me.register_device_buffer(allocation_id, owner_id, byte_length, (byte_length + 4095) / 4096, memory_domain("gpu", true), memory_tier_gpu_coherent(), MEMORY_DMA_DIRECTION_BIDIRECTIONAL, true, contiguous, physical_base, true)

    me register_nic_ring(allocation_id: u64, owner_id: u64, byte_length: u64, physical_base: u64) -> MemoryLevelingOperation:
        me.register_device_buffer(allocation_id, owner_id, byte_length, (byte_length + 4095) / 4096, memory_domain("nic", true), memory_tier_dma_pinned(), MEMORY_DMA_DIRECTION_BIDIRECTIONAL, true, true, physical_base, true)

    me register_nic_buffer(allocation_id: u64, owner_id: u64, byte_length: u64, physical_base: u64, contiguous: bool) -> MemoryLevelingOperation:
        me.register_device_buffer(allocation_id, owner_id, byte_length, (byte_length + 4095) / 4096, memory_domain("nic", true), memory_tier_nic_buffer(), MEMORY_DMA_DIRECTION_BIDIRECTIONAL, true, contiguous, physical_base, false)

    me device_submit(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val mapped = me.map_device(allocation_id, owner_id, MEMORY_DMA_DIRECTION_BIDIRECTIONAL, true)
        if not mapped.ok:
            return mapped
        val synchronized = me.sync_for_device(allocation_id, owner_id)
        if not synchronized.ok:
            return synchronized
        me.begin_in_flight(allocation_id, owner_id)

    me device_complete(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        val completed = me.complete_in_flight(allocation_id, owner_id)
        if not completed.ok:
            return completed
        val synchronized = me.sync_for_cpu(allocation_id, owner_id)
        if not synchronized.ok:
            val rolled_back = me.begin_in_flight(allocation_id, owner_id)
            if not rolled_back.ok:
                return _memory_leveling_operation(false, "rollback-failed", allocation_id, synchronized.state)
            return _memory_leveling_operation(false, synchronized.reason, allocation_id, completed.state)
        synchronized

    me device_unmap(allocation_id: u64, owner_id: u64) -> MemoryLevelingOperation:
        me.unmap_device(allocation_id, owner_id)

fn memory_leveling_device_migration_unavailable(allocation_id: u64) -> MemoryLevelingOperation:
    MemoryLevelingOperation(ok: false, reason: "migration-unavailable", allocation_id: allocation_id, state: "device-owned")
