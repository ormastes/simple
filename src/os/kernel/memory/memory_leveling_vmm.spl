# Transactional VMM mapping replacement for memory leveling.

use os.kernel.types.memory_types.{
    PhysAddr, VirtAddr, VmFlags,
    VM_PRESENT, VM_WRITABLE, VM_USER, VM_WRITE_THROUGH, VM_CACHE_DISABLE, VM_NO_EXECUTE
}
use os.kernel.types.task_types.{AddressSpace}
use os.kernel.memory.vmm.{
    PAGE_SIZE,
    PTE_PRESENT, PTE_WRITABLE, PTE_USER, PTE_WRITE_THROUGH, PTE_CACHE_DISABLE,
    PTE_NO_EXECUTE, PTE_ADDR_MASK,
    vmm_active_root, vmm_read_pte_in, vmm_replace_pte_in, vmm_phys_to_virt
}
use os.kernel.boot.mmio.{mmio_read8, mmio_write8}

struct MemoryVmmMoveTxn:
    address_space_root: u64
    virt_addr: u64
    source_phys_addr: u64
    destination_phys_addr: u64
    source_pte: u64
    flags: VmFlags
    prepared: bool
    committed: bool

struct MemoryVmmMoveResult:
    ok: bool
    reason: text
    txn: MemoryVmmMoveTxn

struct MemoryVmmSwapTxn:
    address_space_root: u64
    virt_addr: u64
    source_phys_addr: u64
    source_pte: u64
    flags: VmFlags
    prepared: bool
    committed: bool

struct MemoryVmmSwapResult:
    ok: bool
    reason: text
    txn: MemoryVmmSwapTxn

fn _memory_vmm_empty_txn() -> MemoryVmmMoveTxn:
    MemoryVmmMoveTxn(
        address_space_root: 0,
        virt_addr: 0,
        source_phys_addr: 0,
        destination_phys_addr: 0,
        source_pte: 0,
        flags: VmFlags(bits: 0),
        prepared: false,
        committed: false
    )

fn _memory_vmm_result(ok: bool, reason: text, txn: MemoryVmmMoveTxn) -> MemoryVmmMoveResult:
    MemoryVmmMoveResult(ok: ok, reason: reason, txn: txn)

fn memory_vmm_flags_from_pte(pte: u64) -> VmFlags:
    var bits: u32 = 0
    if (pte & PTE_PRESENT) != 0:
        bits = bits | VM_PRESENT
    if (pte & PTE_WRITABLE) != 0:
        bits = bits | VM_WRITABLE
    if (pte & PTE_USER) != 0:
        bits = bits | VM_USER
    if (pte & PTE_WRITE_THROUGH) != 0:
        bits = bits | VM_WRITE_THROUGH
    if (pte & PTE_CACHE_DISABLE) != 0:
        bits = bits | VM_CACHE_DISABLE
    if (pte & PTE_NO_EXECUTE) != 0:
        bits = bits | VM_NO_EXECUTE
    VmFlags(bits: bits)

fn memory_vmm_prepare_move(virt_addr: u64, destination_phys_addr: u64) -> MemoryVmmMoveResult:
    memory_vmm_prepare_move_in(virt_addr, destination_phys_addr, vmm_active_root())

fn memory_vmm_prepare_move_in(virt_addr: u64, destination_phys_addr: u64, address_space_root: u64) -> MemoryVmmMoveResult:
    if virt_addr == 0 or (virt_addr % PAGE_SIZE) != 0 or destination_phys_addr == 0 or (destination_phys_addr % PAGE_SIZE) != 0:
        return _memory_vmm_result(false, "invalid-alignment", _memory_vmm_empty_txn())
    if address_space_root == 0 or address_space_root == 1:
        return _memory_vmm_result(false, "invalid-root", _memory_vmm_empty_txn())
    val pte = vmm_read_pte_in(AddressSpace(phys_root: address_space_root, id: 0), VirtAddr(addr: virt_addr))
    memory_vmm_prepare_move_from_pte_in(virt_addr, destination_phys_addr, pte, address_space_root)

fn memory_vmm_prepare_move_from_pte(virt_addr: u64, destination_phys_addr: u64, pte: u64) -> MemoryVmmMoveResult:
    memory_vmm_prepare_move_from_pte_in(virt_addr, destination_phys_addr, pte, vmm_active_root())

fn memory_vmm_prepare_move_from_pte_in(virt_addr: u64, destination_phys_addr: u64, pte: u64, address_space_root: u64) -> MemoryVmmMoveResult:
    if virt_addr == 0 or (virt_addr % PAGE_SIZE) != 0 or destination_phys_addr == 0 or (destination_phys_addr % PAGE_SIZE) != 0:
        return _memory_vmm_result(false, "invalid-alignment", _memory_vmm_empty_txn())
    if address_space_root == 0 or address_space_root == 1:
        return _memory_vmm_result(false, "invalid-root", _memory_vmm_empty_txn())
    if (pte & PTE_PRESENT) == 0:
        return _memory_vmm_result(false, "source-not-present", _memory_vmm_empty_txn())
    val source_phys_addr = pte & PTE_ADDR_MASK
    if source_phys_addr == destination_phys_addr:
        return _memory_vmm_result(false, "same-frame", _memory_vmm_empty_txn())
    val txn = MemoryVmmMoveTxn(
        address_space_root: address_space_root,
        virt_addr: virt_addr,
        source_phys_addr: source_phys_addr,
        destination_phys_addr: destination_phys_addr,
        source_pte: pte,
        flags: memory_vmm_flags_from_pte(pte),
        prepared: true,
        committed: false
    )
    _memory_vmm_result(true, "ok", txn)

fn memory_vmm_commit_move(txn: MemoryVmmMoveTxn) -> MemoryVmmMoveResult:
    if not txn.prepared or txn.committed:
        return _memory_vmm_result(false, "invalid-state", txn)
    if txn.address_space_root == 0 or txn.address_space_root == 1:
        return _memory_vmm_result(false, "invalid-root", txn)
    val space = AddressSpace(phys_root: txn.address_space_root, id: 0)
    val replacement = (txn.destination_phys_addr & PTE_ADDR_MASK) | (txn.source_pte & ~PTE_ADDR_MASK)
    if not vmm_replace_pte_in(space, VirtAddr(addr: txn.virt_addr), txn.source_pte, replacement):
        return _memory_vmm_result(false, "stale-mapping", txn)
    var committed = txn
    committed.committed = true
    _memory_vmm_result(true, "ok", committed)

fn memory_vmm_rollback_move(txn: MemoryVmmMoveTxn) -> MemoryVmmMoveResult:
    if not txn.prepared:
        return _memory_vmm_result(false, "invalid-state", txn)
    if not txn.committed:
        return _memory_vmm_result(true, "no-change", txn)
    if txn.address_space_root == 0 or txn.address_space_root == 1:
        return _memory_vmm_result(false, "invalid-root", txn)
    val space = AddressSpace(phys_root: txn.address_space_root, id: 0)
    val destination_pte = (txn.destination_phys_addr & PTE_ADDR_MASK) | (txn.source_pte & ~PTE_ADDR_MASK)
    if not vmm_replace_pte_in(space, VirtAddr(addr: txn.virt_addr), destination_pte, txn.source_pte):
        return _memory_vmm_result(false, "stale-mapping", txn)
    var rolled_back = txn
    rolled_back.committed = false
    _memory_vmm_result(true, "rolled-back", rolled_back)

fn memory_vmm_finalize_move(txn: MemoryVmmMoveTxn) -> Result<PhysAddr, text>:
    if not txn.prepared or not txn.committed:
        return Err("invalid-state")
    if txn.address_space_root == 0 or txn.address_space_root == 1:
        return Err("invalid-root")
    val current = vmm_read_pte_in(AddressSpace(phys_root: txn.address_space_root, id: 0), VirtAddr(addr: txn.virt_addr))
    val destination_pte = (txn.destination_phys_addr & PTE_ADDR_MASK) | (txn.source_pte & ~PTE_ADDR_MASK)
    if current != destination_pte:
        return Err("stale-mapping")
    Ok(PhysAddr(addr: txn.source_phys_addr))

fn _memory_vmm_empty_swap_txn() -> MemoryVmmSwapTxn:
    MemoryVmmSwapTxn(address_space_root: 0, virt_addr: 0, source_phys_addr: 0, source_pte: 0, flags: VmFlags(bits: 0), prepared: false, committed: false)

fn _memory_vmm_swap_result(ok: bool, reason: text, txn: MemoryVmmSwapTxn) -> MemoryVmmSwapResult:
    MemoryVmmSwapResult(ok: ok, reason: reason, txn: txn)

fn memory_vmm_prepare_swap(virt_addr: u64) -> MemoryVmmSwapResult:
    memory_vmm_prepare_swap_in(virt_addr, vmm_active_root())

fn memory_vmm_prepare_swap_in(virt_addr: u64, address_space_root: u64) -> MemoryVmmSwapResult:
    if virt_addr == 0 or (virt_addr % PAGE_SIZE) != 0:
        return _memory_vmm_swap_result(false, "invalid-alignment", _memory_vmm_empty_swap_txn())
    if address_space_root == 0 or address_space_root == 1:
        return _memory_vmm_swap_result(false, "invalid-root", _memory_vmm_empty_swap_txn())
    val pte = vmm_read_pte_in(AddressSpace(phys_root: address_space_root, id: 0), VirtAddr(addr: virt_addr))
    if (pte & PTE_PRESENT) == 0:
        return _memory_vmm_swap_result(false, "source-not-present", _memory_vmm_empty_swap_txn())
    val txn = MemoryVmmSwapTxn(
        address_space_root: address_space_root,
        virt_addr: virt_addr,
        source_phys_addr: pte & PTE_ADDR_MASK,
        source_pte: pte,
        flags: memory_vmm_flags_from_pte(pte),
        prepared: true,
        committed: false
    )
    _memory_vmm_swap_result(true, "ok", txn)

fn memory_vmm_commit_swap(txn: MemoryVmmSwapTxn) -> MemoryVmmSwapResult:
    if not txn.prepared or txn.committed:
        return _memory_vmm_swap_result(false, "invalid-state", txn)
    if txn.address_space_root == 0 or txn.address_space_root == 1:
        return _memory_vmm_swap_result(false, "invalid-root", txn)
    val space = AddressSpace(phys_root: txn.address_space_root, id: 0)
    if not vmm_replace_pte_in(space, VirtAddr(addr: txn.virt_addr), txn.source_pte, 0):
        return _memory_vmm_swap_result(false, "stale-mapping", txn)
    var committed = txn
    committed.committed = true
    _memory_vmm_swap_result(true, "ok", committed)

fn memory_vmm_rollback_swap(txn: MemoryVmmSwapTxn) -> MemoryVmmSwapResult:
    if not txn.prepared:
        return _memory_vmm_swap_result(false, "invalid-state", txn)
    if not txn.committed:
        return _memory_vmm_swap_result(true, "no-change", txn)
    if txn.address_space_root == 0 or txn.address_space_root == 1:
        return _memory_vmm_swap_result(false, "invalid-root", txn)
    if not vmm_replace_pte_in(AddressSpace(phys_root: txn.address_space_root, id: 0), VirtAddr(addr: txn.virt_addr), 0, txn.source_pte):
        return _memory_vmm_swap_result(false, "rollback-failed", txn)
    var rolled_back = txn
    rolled_back.committed = false
    _memory_vmm_swap_result(true, "rolled-back", rolled_back)

fn memory_vmm_restore_swap(txn: MemoryVmmSwapTxn, destination_phys_addr: u64) -> bool:
    if not txn.prepared or not txn.committed or txn.address_space_root == 0 or txn.address_space_root == 1 or destination_phys_addr == 0 or (destination_phys_addr % PAGE_SIZE) != 0:
        return false
    val space = AddressSpace(phys_root: txn.address_space_root, id: 0)
    val replacement = (destination_phys_addr & PTE_ADDR_MASK) | (txn.source_pte & ~PTE_ADDR_MASK)
    vmm_replace_pte_in(space, VirtAddr(addr: txn.virt_addr), 0, replacement)

fn memory_vmm_read_physical(phys_addr: u64, byte_length: u64) -> [u8]:
    var bytes: [u8] = []
    val base = vmm_phys_to_virt(phys_addr)
    var i: u64 = 0
    while i < byte_length:
        bytes.push(mmio_read8(base + i))
        i = i + 1
    bytes

fn memory_vmm_write_physical(phys_addr: u64, bytes: [u8]):
    val base = vmm_phys_to_virt(phys_addr)
    var i: i64 = 0
    while i < bytes.len():
        mmio_write8(base + (i as u64), bytes[i])
        i = i + 1
