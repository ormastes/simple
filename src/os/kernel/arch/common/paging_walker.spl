# Paging Walker — generic 2/3/4-level page-table walker.
#
# Per-arch paging.spl modules supply only a `PagingTraits` shape (level
# count, level shifts, level mask, present-bit, large-page-bit, table
# entry width). This walker handles map / unmap / translate / range
# iteration over any of: x86_64 4-level, x86_32 PAE 3-level,
# x86_32 2-level, arm64 4-level, arm32 LPAE 3-level, arm32 short-desc 2,
# rv64 sv39/sv48 (3/4 level), rv32 sv32 2-level.
#
# Wave 2 — added 2026-04-25. This is the AC-3 reduction lever:
# without this file, paging.spl is ~500 LoC each ×6 archs ≈3000 LoC.
# With it, paging.spl shrinks to ~200 LoC each ≈1200 LoC.
#
# NOTE: implementations must wire pmm_alloc_page + a per-arch raw load/store
# of u64 entries. This module avoids any extern fns so it stays portable;
# every walker call takes a `PagingOps` ops struct of function pointers.

use os.kernel.types.memory_types.{PhysAddr, VirtAddr, VmFlags}

# Maximum levels supported. x86_64 / arm64 / rv64-sv48 = 4; rv64-sv39 = 3.
val MAX_LEVELS: u32 = 4

# A single page-table entry — opaque u64 the per-arch ops interpret.
@repr("C")
struct PageTableEntry:
    """Architecture-agnostic page-table entry payload."""
    raw: u64

# Per-arch shape constants. Each value is a per-level array; entries
# beyond `levels-1` are ignored.
@repr("C")
struct PagingTraits:
    """Per-arch paging shape — level count, shifts, masks, flag bits."""
    levels: u32                           # 2, 3 or 4
    page_size_log2: u32                   # 12 for 4 KiB pages, 14 for 16K, 16 for 64K
    level_shift:    [u32; 4]              # virt-shift per level (e.g. x86_64: 39,30,21,12)
    level_index_mask: u64                 # 9-bit = 0x1FF, 10-bit = 0x3FF, etc.
    entry_phys_mask: u64                  # mask of the phys-addr field in an entry
    present_bit: u64                      # entry "present"/"valid" flag
    leaf_bit:    u64                      # large-page indicator (0 = always table)
    flag_read:   u64
    flag_write:  u64
    flag_exec:   u64
    flag_user:   u64
    flag_cache_disable: u64

# Function-pointer ops — keeps the walker free of extern symbols.
# Every per-arch paging.spl supplies an instance of this.
@repr("C")
struct PagingOps:
    """Per-arch operations the walker delegates to."""
    pmm_alloc: u64           # () -> u64  zero-initialized phys page
    pmm_free:  u64           # (phys: u64) -> void
    raw_read:  u64           # (table_phys: u64, idx: u32) -> u64
    raw_write: u64           # (table_phys: u64, idx: u32, val: u64) -> void
    flush_tlb: u64           # (vaddr: u64) -> void

# Per-call walker context — contains the active root table phys address
# plus the per-arch shape and ops.
@repr("C")
struct WalkerContext:
    """Walker call-site context — root table + shape + ops."""
    root_phys: u64
    traits: PagingTraits
    ops:    PagingOps

# Compute the index at level `lvl` (0=top, levels-1=leaf) for virt addr v.
fn level_index(traits: PagingTraits, v: u64, lvl: u32) -> u32:
    val shift: u32 = traits.level_shift[lvl]
    ((v >> shift) & traits.level_index_mask) as u32

# Translate a flag bitset (VmFlags) to per-arch raw entry flag bits.
fn translate_flags(traits: PagingTraits, flags: VmFlags) -> u64:
    var raw: u64 = traits.present_bit
    if flags.readable():
        raw = raw | traits.flag_read
    if flags.writable():
        raw = raw | traits.flag_write
    if flags.executable():
        raw = raw | traits.flag_exec
    if flags.user_accessible():
        raw = raw | traits.flag_user
    if flags.cache_disabled():
        raw = raw | traits.flag_cache_disable
    raw

# Pure helpers — composed from translate_flags + level_index. The actual
# pmm_alloc + raw_read/write calls require Simple inline-asm or extern
# bridging that Wave 3 supplies; this module documents the walking shape
# so that all 6 archs' paging.spl files can compose the same high-level
# verbs (map / unmap / translate / range_walk) on top of the helpers below.

# Constants per arch — exposed so per-arch shims can construct PagingTraits
# without recomputing the bit layouts. Wave 3 may move these into per-arch
# files if the constant table becomes too large.

fn make_traits_x86_64() -> PagingTraits:
    """x86_64 long-mode 4-level paging."""
    PagingTraits(
        levels: 4,
        page_size_log2: 12,
        level_shift: [39, 30, 21, 12],
        level_index_mask: 0x1FF,
        entry_phys_mask: 0x000F_FFFF_FFFF_F000,
        present_bit:    0x0001,
        leaf_bit:       0x0080,
        flag_read:      0x0001,
        flag_write:     0x0002,
        flag_exec:      0x0000,
        flag_user:      0x0004,
        flag_cache_disable: 0x0010,
    )

fn make_traits_x86_32_pae() -> PagingTraits:
    """x86_32 PAE 3-level paging."""
    PagingTraits(
        levels: 3,
        page_size_log2: 12,
        level_shift: [30, 21, 12, 0],
        level_index_mask: 0x1FF,
        entry_phys_mask: 0x000F_FFFF_FFFF_F000,
        present_bit:    0x0001,
        leaf_bit:       0x0080,
        flag_read:      0x0001,
        flag_write:     0x0002,
        flag_exec:      0x0000,
        flag_user:      0x0004,
        flag_cache_disable: 0x0010,
    )

fn make_traits_arm64() -> PagingTraits:
    """ARM64 4-level VMSAv8-64 paging (4 KiB granule)."""
    PagingTraits(
        levels: 4,
        page_size_log2: 12,
        level_shift: [39, 30, 21, 12],
        level_index_mask: 0x1FF,
        entry_phys_mask: 0x0000_FFFF_FFFF_F000,
        present_bit:    0x0001,
        leaf_bit:       0x0002,                 # bit[1]=1 means table at non-leaf, page at leaf
        flag_read:      0x0040,                 # AP[1]=1 read
        flag_write:     0x0080,                 # !AP[2] = read-write
        flag_exec:      0x0000,
        flag_user:      0x0040,
        flag_cache_disable: 0x0000,
    )

fn make_traits_arm32_lpae() -> PagingTraits:
    """ARMv7-A LPAE 3-level paging (long-descriptor 4 KiB granule)."""
    PagingTraits(
        levels: 3,
        page_size_log2: 12,
        level_shift: [30, 21, 12, 0],
        level_index_mask: 0x1FF,
        entry_phys_mask: 0x0000_00FF_FFFF_F000,
        present_bit:    0x0001,
        leaf_bit:       0x0002,
        flag_read:      0x0040,
        flag_write:     0x0080,
        flag_exec:      0x0000,
        flag_user:      0x0040,
        flag_cache_disable: 0x0000,
    )

fn make_traits_riscv_sv39() -> PagingTraits:
    """RV64 Sv39 3-level paging."""
    PagingTraits(
        levels: 3,
        page_size_log2: 12,
        level_shift: [30, 21, 12, 0],
        level_index_mask: 0x1FF,
        entry_phys_mask: 0x003F_FFFF_FFFF_FC00,
        present_bit:    0x0001,
        leaf_bit:       0x0002 | 0x0004 | 0x0008,   # R/W/X any => leaf
        flag_read:      0x0002,
        flag_write:     0x0004,
        flag_exec:      0x0008,
        flag_user:      0x0010,
        flag_cache_disable: 0x0000,
    )

fn make_traits_riscv_sv48() -> PagingTraits:
    """RV64 Sv48 4-level paging."""
    PagingTraits(
        levels: 4,
        page_size_log2: 12,
        level_shift: [39, 30, 21, 12],
        level_index_mask: 0x1FF,
        entry_phys_mask: 0x003F_FFFF_FFFF_FC00,
        present_bit:    0x0001,
        leaf_bit:       0x0002 | 0x0004 | 0x0008,
        flag_read:      0x0002,
        flag_write:     0x0004,
        flag_exec:      0x0008,
        flag_user:      0x0010,
        flag_cache_disable: 0x0000,
    )

fn make_traits_riscv_sv32() -> PagingTraits:
    """RV32 Sv32 2-level paging."""
    PagingTraits(
        levels: 2,
        page_size_log2: 12,
        level_shift: [22, 12, 0, 0],
        level_index_mask: 0x3FF,                # 10-bit on RV32 Sv32
        entry_phys_mask: 0x0000_0000_FFFF_FC00,
        present_bit:    0x0001,
        leaf_bit:       0x0002 | 0x0004 | 0x0008,
        flag_read:      0x0002,
        flag_write:     0x0004,
        flag_exec:      0x0008,
        flag_user:      0x0010,
        flag_cache_disable: 0x0000,
    )

# Sanity helpers used by per-arch walkers.
fn entry_is_present(traits: PagingTraits, e: u64) -> bool:
    (e & traits.present_bit) != 0

fn entry_is_leaf(traits: PagingTraits, e: u64, lvl: u32) -> bool:
    if lvl == traits.levels - 1:
        return true
    (e & traits.leaf_bit) != 0

fn entry_phys(traits: PagingTraits, e: u64) -> u64:
    e & traits.entry_phys_mask

fn entry_compose(traits: PagingTraits, phys: u64, raw_flags: u64) -> u64:
    (phys & traits.entry_phys_mask) | (raw_flags & ~traits.entry_phys_mask)
