# Architecture Dispatch — Compile-Time Arch Selection
#
# Provides get_hal() which returns the active architecture's HAL implementation.
# Only one architecture is active per compilation target — the compiler eliminates
# dead code for other architectures.
#
# Import this module to access the HAL:
#   use os.kernel.arch.{get_hal, get_console, get_arch}

use os.kernel.arch.arch_context.{Architecture, ArchContext}
use os.kernel.arch.hal.{HalConsole, HalBoot, HalCpu, HalPaging, HalInterrupt, HalTimer, HalContext}

# Import all architecture implementations
use os.kernel.arch.x86_64.mod.{X86_64Hal, create_x86_64_hal}
use os.kernel.arch.x86_64.console.{X86Console}
use os.kernel.arch.x86_64.boot.{X86Boot}
use os.kernel.arch.x86_64.cpu.{X86Cpu}

# Architecture detection — set by compiler based on target triple
# For now, default to x86_64
fn get_arch() -> Architecture:
    """Get the compile-time target architecture."""
    # TODO: Replace with compile-time target detection when available
    Architecture.X86_64

fn get_console() -> X86Console:
    """Get the console implementation for the current architecture.

    This is available before full HAL initialization for early debug output.
    """
    X86Console()

fn get_boot() -> X86Boot:
    """Get the boot implementation for the current architecture."""
    X86Boot()

fn get_cpu() -> X86Cpu:
    """Get the CPU primitives for the current architecture."""
    X86Cpu()

fn get_hal() -> X86_64Hal:
    """Get the complete HAL for the current architecture."""
    create_x86_64_hal()
