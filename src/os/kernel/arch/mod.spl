# Architecture Dispatch — compile-time target identity only.
#
# Import-closure bugs in the native SimpleOS kernel build mean this module
# cannot safely import every arch's concrete HAL implementation. The public
# kernel HAL surface lives in `os.kernel.arch.hal`; this file provides only
# the active target identity without pulling foreign-arch asm or runtime
# shims into one build.

use os.kernel.arch.arch_context.{Architecture}

@cfg(x86_64)
val CURRENT_ARCH: Architecture = Architecture.X86_64

@cfg(x86)
val CURRENT_ARCH: Architecture = Architecture.X86

@cfg(arm64)
val CURRENT_ARCH: Architecture = Architecture.Arm64

@cfg(arm32)
val CURRENT_ARCH: Architecture = Architecture.Arm32

@cfg(riscv64)
val CURRENT_ARCH: Architecture = Architecture.Riscv64

@cfg(riscv32)
val CURRENT_ARCH: Architecture = Architecture.Riscv32

fn get_arch() -> Architecture:
    """Return the compile-time target architecture selected by `@cfg`."""
    CURRENT_ARCH

fn get_arch_name() -> text:
    """Return the short kernel arch slug used by docs and build lanes."""
    match CURRENT_ARCH:
        Architecture.X86_64: "x86_64"
        Architecture.X86: "x86_32"
        Architecture.Arm64: "arm64"
        Architecture.Arm32: "arm32"
        Architecture.Riscv64: "riscv64"
        Architecture.Riscv32: "riscv32"
