# x86_32 Trap Model — Pure int 0x80 Syscall Marshalling
#
# Defines the register contract for the future i386 trap-entry assembly.

use os.kernel.arch.arch_context.{X86Context}
use os.kernel.types.syscall_types.{SyscallArgs, SyscallResult}

val X86_32_INT80_SIZE: u32 = 2

fn x86_32_syscall_args_from_context(ctx: X86Context) -> SyscallArgs:
    """Map i386 int 0x80 registers into the portable syscall argument shape.

    Contract:
    - eax: syscall number
    - ebx, ecx, edx, esi, edi, ebp: arguments 0..5
    """
    SyscallArgs(
        id: ctx.eax as u64,
        arg0: ctx.ebx as u64,
        arg1: ctx.ecx as u64,
        arg2: ctx.edx as u64,
        arg3: ctx.esi as u64,
        arg4: ctx.edi as u64,
        arg5: ctx.ebp as u64
    )

fn x86_32_apply_syscall_result(ctx: X86Context, result: SyscallResult) -> X86Context:
    """Return an updated i386 context after syscall dispatch."""
    var updated = ctx
    updated.eax = result.value as u32
    updated.eip = ctx.eip + X86_32_INT80_SIZE
    updated
