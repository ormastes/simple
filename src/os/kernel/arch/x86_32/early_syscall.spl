# Freestanding i386 early syscall ABI.
#
# This module is intentionally smaller than x86_32.interrupt.spl. Live i386
# boot probes can import it without pulling hosted Scheduler/IpcManager/KLog
# state or the full SOSIX syscall hub into the freestanding link.

fn x86_32_install_early_syscall_runtime():
    """Install the freestanding early syscall runtime used by live boot probes."""
    pass

fn x86_32_early_syscall_runtime_installed() -> bool:
    """Report whether the freestanding early syscall runtime is installed."""
    true

fn x86_32_dispatch_installed_syscall_abi(id: u32, arg0: u32, arg1: u32, arg2: u32, arg3: u32, arg4: u32, arg5: u32) -> i32:
    """C ABI reached by the live int 0x80 probe handler."""
    _ = arg2
    _ = arg3
    _ = arg4
    _ = arg5
    if id == 2u32:
        return x86_32_early_spawn_process(arg0)
    if id == 4u32:
        return 0
    if id == 5u32:
        return 2
    if id == 6u32:
        if arg0 == 0u32:
            return 0
        return 0
    if id == 13u32:
        return x86_32_early_spawn_shell(arg0, arg1)
    if id == 15u32:
        return x86_32_early_brk(arg0)
    if id == 16u32:
        return 0
    -38

fn x86_32_early_spawn_process(entry: u32) -> i32:
    """Allocate a synthetic early-process pid for i386 trap-path validation."""
    if entry == 0u32:
        return -22
    1001

fn x86_32_early_spawn_shell(app_id: u32, priority: u32) -> i32:
    """Validate the Shell app-id spawn path without importing the full VFS lane."""
    _ = priority
    if app_id != 4u32:
        return -2
    1002

fn x86_32_early_brk(requested: u32) -> i32:
    _ = requested
    1
