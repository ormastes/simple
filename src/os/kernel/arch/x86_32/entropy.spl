# x86_32 early-boot entropy mixer.

@cfg(x86)
extern fn rt_rdrand() -> u64
extern fn rt_time_now_unix_micros() -> i64

fn _mix64(x: u64) -> u64:
    var v = x ^ (x >> 30)
    v = v * 0xBF58476D1CE4E5B9
    v = v ^ (v >> 27)
    v = v * 0x94D049BB133111EB
    v ^ (v >> 31)

fn entropy_seed_u64() -> u64:
    _mix64(rt_rdrand() ^ rt_time_now_unix_micros().to_u64() ^ 0x5838365F3332)
