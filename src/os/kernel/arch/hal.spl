    ctx_switch.restore(ctx)

@cfg(x86_64)
fn hal_context_init(entry: u64, stack: u64, arg: u64) -> ArchContext:
    """Create new task context — x86_64 set rip=entry, rsp=stack, rdi=arg."""
    var ctx_switch = X86ContextSwitch()
    var x86_ctx = ctx_switch.create(entry, stack, false)
    # Pass arg as first parameter (rdi in System V ABI)
    x86_ctx.rdi = arg
    ArchContext.X86_64(ctx: x86_ctx)

@cfg(arm64)
fn hal_context_init(entry: u64, stack: u64, arg: u64) -> ArchContext:
    """Create task context — arch: arm64 set elr=entry, sp=stack, x0=arg."""
    var ctx_switch = Arm64ContextSwitch()
    val arm_ctx = ctx_switch.create_kernel_with_arg(entry, stack, arg)
    ArchContext.Arm64(ctx: arm_ctx)

@cfg(arm32)
fn hal_context_init(entry: u64, stack: u64, arg: u64) -> ArchContext:
    """Create task context — arch: arm32 set pc=entry, sp=stack, r0=arg."""
    var ctx_switch = Arm32ContextSwitch()
    val arm_ctx = ctx_switch.create_kernel_with_arg(entry as u32, stack as u32, arg as u32)
    ArchContext.Arm32(ctx: arm_ctx)

@cfg(riscv64)
fn hal_context_init(entry: u64, stack: u64, arg: u64) -> ArchContext:
    """Create task context — arch: riscv64 set sepc=entry, sp=stack, a0=arg."""
    var ctx_switch = Rv64ContextSwitch()
    ctx_switch.context_init(entry, stack, arg)

@cfg(riscv32)
