@cfg(x86_64)
fn hal_context_save() -> ArchContext:
    """Save current CPU state — x86_64 GPRs + rflags + segments.

    Note: A true register save requires inline assembly or a dedicated
    save trampoline. This function creates a minimal context suitable
    for use as the 'from' side of context_switch, where the switch
    assembly itself saves the live registers into this slot.
    The returned context is a placeholder that context_switch will
    overwrite with actual register values.
    """
    var ctx_switch = X86ContextSwitch()
    val x86_ctx = ctx_switch.create(0, 0, false)
    ArchContext.X86_64(ctx: x86_ctx)

@cfg(arm64)
fn hal_context_save() -> ArchContext:
    """Save CPU state — arch: arm64 x0..x30 + sp + elr + spsr."""
    var ctx_switch = Arm64ContextSwitch()
    val arm_ctx = ctx_switch.save_current()
    ArchContext.Arm64(ctx: arm_ctx)

@cfg(arm32)
fn hal_context_save() -> ArchContext:
    """Save CPU state — arch: arm32 r0..r15 + cpsr."""
    var ctx_switch = Arm32ContextSwitch()
    val arm_ctx = ctx_switch.save_current()
    ArchContext.Arm32(ctx: arm_ctx)

@cfg(riscv64)
fn hal_context_save() -> ArchContext:
    """Save CPU state — arch: riscv64 x1..x31 + sepc + sstatus."""
    var ctx_switch = Rv64ContextSwitch()
    ctx_switch.save()

@cfg(riscv32)
fn hal_context_save() -> ArchContext:
    """Save CPU state — arch: riscv32 x1..x31 + sepc + sstatus."""
    var ctx_switch = Rv32ContextSwitch()
    ctx_switch.save()

@cfg(x86_64)
fn hal_context_restore(ctx: ArchContext):
    """Restore CPU state — x86_64 load GPRs + rflags + segments."""
    match ctx:
        ArchContext.X86_64(x86_ctx):
            var ctx_switch = X86ContextSwitch()
            # Create a dummy "from" context; switch loads "to" context
            val dummy = ctx_switch.create(0, 0, false)
            ctx_switch.switch(dummy, x86_ctx)
        _:
            pass_todo("context_restore: architecture mismatch")

@cfg(arm64)
fn hal_context_restore(ctx: ArchContext):
    """Restore CPU state — arch: arm64."""
    match ctx:
        ArchContext.Arm64(arm_ctx):
            var ctx_switch = Arm64ContextSwitch()
            ctx_switch.restore(arm_ctx)
        _:
            pass_do_nothing

@cfg(arm32)
fn hal_context_restore(ctx: ArchContext):
    """Restore CPU state — arch: arm32."""
    match ctx:
        ArchContext.Arm32(arm_ctx):
            var ctx_switch = Arm32ContextSwitch()
            ctx_switch.restore(arm_ctx)
        _:
            pass_do_nothing

@cfg(riscv64)
fn hal_context_restore(ctx: ArchContext):
