# CPU (8 functions)
# ============================================================================

@cfg(x86_64)
fn hal_disable_interrupts():
    """Disable maskable interrupts — x86_64 CLI instruction."""
    cli()

@cfg(arm64)
fn hal_disable_interrupts():
    """Disable interrupts — arch: arm64 MSR DAIF set."""
    daif_set(DAIF_ALL)

@cfg(arm32)
fn hal_disable_interrupts():
    """Disable interrupts — arch: arm32 CPSID if."""
    var cpu = Arm32Cpu()
    cpu.cpu_disable_interrupts()

@cfg(riscv64)
fn hal_disable_interrupts():
    """Disable interrupts — arch: riscv64 csrc sstatus.SIE."""
    csrc_sstatus(SSTATUS_SIE)

@cfg(riscv32)
fn hal_disable_interrupts():
    """Disable interrupts — arch: riscv32 clear sstatus.SIE."""
    val status = rv32_csrr_sstatus()
    rv32_csrw_sstatus(status & (~RV32_SSTATUS_SIE))

@cfg(x86_64)
fn hal_enable_interrupts():
    """Enable maskable interrupts — x86_64 STI instruction."""
    sti()

@cfg(arm64)
fn hal_enable_interrupts():
    """Enable interrupts — arch: arm64 MSR DAIF clear."""
    daif_clr(DAIF_I | DAIF_F)

@cfg(arm32)
fn hal_enable_interrupts():
    """Enable interrupts — arch: arm32 CPSIE if."""
    var cpu = Arm32Cpu()
    cpu.cpu_enable_interrupts()

@cfg(riscv64)
fn hal_enable_interrupts():
    """Enable interrupts — arch: riscv64 csrs sstatus.SIE."""
    csrs_sstatus(SSTATUS_SIE)

@cfg(riscv32)
fn hal_enable_interrupts():
    """Enable interrupts — arch: riscv32 set sstatus.SIE."""
    val status = rv32_csrr_sstatus()
    rv32_csrw_sstatus(status | RV32_SSTATUS_SIE)

@cfg(x86_64)
fn hal_halt():
    """Halt CPU until next interrupt — x86_64 HLT instruction."""
    hlt()

@cfg(arm64)
fn hal_halt():
    """Halt CPU — arch: arm64 WFI (Wait For Interrupt)."""
    wfi()

@cfg(arm32)
fn hal_halt():
    """Halt CPU — arch: arm32 WFI (Wait For Interrupt)."""
    var cpu = Arm32Cpu()
    cpu.cpu_halt()

@cfg(riscv64)
fn hal_halt():
    """Halt CPU — arch: riscv64 WFI instruction."""
    rv64_wfi()

@cfg(riscv32)
fn hal_halt():
    """Halt CPU — arch: riscv32 WFI instruction."""
    rv32_wfi()

@cfg(x86_64)
fn hal_halt_loop():
    """Halt CPU in infinite loop — x86_64 CLI; HLT loop."""
    halt_loop()

@cfg(arm64)
fn hal_halt_loop():
    """Halt loop — arch: arm64 disable interrupts + WFI loop."""
    daif_set(DAIF_ALL)
    while true:
        wfi()

@cfg(arm32)
fn hal_halt_loop():
    """Halt loop — arch: arm32 disable interrupts + WFI loop."""
    var cpu = Arm32Cpu()
    cpu.cpu_halt_loop()

@cfg(riscv64)
fn hal_halt_loop():
    """Halt loop — arch: riscv64 disable interrupts + WFI loop."""
    csrc_sstatus(SSTATUS_SIE)
    while true:
        rv64_wfi()

@cfg(riscv32)
fn hal_halt_loop():
    """Halt loop — arch: riscv32 disable interrupts + WFI loop."""
    val status = rv32_csrr_sstatus()
    rv32_csrw_sstatus(status & (~RV32_SSTATUS_SIE))
    while true:
        rv32_wfi()

# ============================================================================
# Power Control
# ============================================================================

var _hal_reset_test_mode: u64 = 0
var _hal_reset_requested_for_test: u64 = 0

fn hal_reset_set_test_mode(enabled: bool):
    """Enable a test-only reset latch so syscall tests cannot reset QEMU."""
    if enabled:
        _hal_reset_test_mode = 1
        _hal_reset_requested_for_test = 0
    else:
        _hal_reset_test_mode = 0
        _hal_reset_requested_for_test = 0

fn hal_reset_requested_for_test() -> bool:
    """Return whether hal_system_reset() was requested while test mode was active."""
    _hal_reset_requested_for_test != 0

fn hal_system_reset() -> i64:
    """Request a machine reset through the active architecture backend.

    Returns 0 only in test mode. On real hardware/QEMU the backend should not
    return; if it does, callers receive -38 to match ENOSYS-style syscall
    fallback behavior.
    """
    if _hal_reset_test_mode != 0:
        _hal_reset_requested_for_test = 1
        return 0
    _hal_system_reset_arch()

@cfg(x86_64)
fn _hal_system_reset_arch() -> i64:
    """Reset x86_64 via the reset control register."""
    x86_64_reboot()
    -38

@cfg(x86)
fn _hal_system_reset_arch() -> i64:
    """Reset x86_32 via the reset control register."""
    x86_32_reboot()
    -38

@cfg(arm64)
fn _hal_system_reset_arch() -> i64:
    """ARM64 reset needs PSCI wiring; report unsupported until that backend exists."""
    -38

@cfg(arm32)
fn _hal_system_reset_arch() -> i64:
    """ARM32 reset needs platform firmware wiring; report unsupported until that backend exists."""
    -38

@cfg(riscv64)
fn _hal_system_reset_arch() -> i64:
    """Reset RISC-V 64 via SBI SRST cold reboot."""
    rv64_system_reset(1u32, 0u32)
    -38

@cfg(riscv32)
fn _hal_system_reset_arch() -> i64:
    """Reset RISC-V 32 via SBI SRST cold reboot."""
    rv32_system_reset(1u32, 0u32)
    -38

@cfg(x86_64)
fn hal_flush_tlb(addr: u64):
    """Flush TLB entry for virtual address — x86_64 INVLPG instruction."""
    invlpg(addr)

@cfg(arm64)
fn hal_flush_tlb(addr: u64):
    """Flush TLB — arch: arm64 TLBI VAE1IS."""
    tlbi_vae1(addr)
    dsb()
    isb()

@cfg(arm32)
fn hal_flush_tlb(addr: u64):
    """Flush TLB — arch: arm32 MCR TLBIMVA."""
    var cpu = Arm32Cpu()
    cpu.cpu_flush_tlb(addr)

@cfg(riscv64)
fn hal_flush_tlb(addr: u64):
    """Flush TLB — arch: riscv64 SFENCE.VMA for single address."""
    sfence_vma_addr(addr)

@cfg(riscv32)
fn hal_flush_tlb(addr: u64):
    """Flush TLB — arch: riscv32 SFENCE.VMA for single address."""
    rv32_sfence_vma(addr as u32, 0)

@cfg(x86_64)
fn hal_flush_tlb_all():
    """Flush entire TLB — x86_64 reload CR3."""
    val cr3 = read_cr3()
    write_cr3(cr3)

@cfg(arm64)
fn hal_flush_tlb_all():
    """Flush entire TLB — arch: arm64 TLBI ALLE1IS."""
    tlbi_alle1()
    dsb()
    isb()

@cfg(arm32)
fn hal_flush_tlb_all():
    """Flush entire TLB — arch: arm32 MCR TLBIALL."""
    var cpu = Arm32Cpu()
    cpu.cpu_flush_tlb_all()

@cfg(riscv64)
fn hal_flush_tlb_all():
    """Flush entire TLB — arch: riscv64 SFENCE.VMA zero,zero."""
    sfence_vma()

@cfg(riscv32)
fn hal_flush_tlb_all():
    """Flush entire TLB — arch: riscv32 SFENCE.VMA zero,zero."""
    rv32_sfence_vma_all()

@cfg(x86_64)
fn hal_cpu_id() -> u64:
    """Return current CPU ID — x86_64 APIC ID (0 for single-CPU)."""
    0

@cfg(arm64)
fn hal_cpu_id() -> u64:
    """Return CPU ID — arch: arm64 MPIDR_EL1 Aff0 field."""
    mrs_mpidr_el1() & 0xFF

@cfg(arm32)
fn hal_cpu_id() -> u64:
    """Return CPU ID — arch: arm32 MPIDR affinity."""
    val cpu = Arm32Cpu()
    cpu.cpu_id()

@cfg(riscv64)
fn hal_cpu_id() -> u64:
    """Return hart ID — arch: riscv64 tp register (set by OpenSBI)."""
    read_tp()

@cfg(riscv32)
fn hal_cpu_id() -> u64:
    """Return hart ID — arch: riscv32 (hart 0, single-hart)."""
    0

@cfg(x86_64)
fn hal_address_width() -> u32:
    """Return virtual address width — 48 bits (canonical x86_64)."""
    48

@cfg(arm64)
fn hal_address_width() -> u32:
    """Return address width — arch: arm64 (48-bit VA with 4-level 4KB granule)."""
    48

@cfg(arm32)
fn hal_address_width() -> u32:
    """Return address width — arch: arm32 (32 bits, LPAE extends to 40)."""
    val cpu = Arm32Cpu()
    cpu.cpu_address_width() as u32

@cfg(riscv64)
fn hal_address_width() -> u32:
    """Return address width — arch: riscv64 Sv39 (39-bit VA)."""
    39

@cfg(riscv32)
fn hal_address_width() -> u32:
    """Return address width — arch: riscv32 Sv32=32."""
    32

# ============================================================================
# Paging (7 functions)
# ============================================================================

@cfg(x86_64)
fn hal_paging_init(boot_info: BootOutputPort):
    """Initialize 4-level page tables — x86_64 PML4, identity-map 4GB."""
    # Extract PMM and HHDM offset from boot_info for vmm_init
    # The PMM should already be initialized before paging_init is called.
    # We pass a default PhysMemManager; the real PMM is wired via extern.
    vmm_init(PhysMemManager(), boot_info.hhdm_offset)

