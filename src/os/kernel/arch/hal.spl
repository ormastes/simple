@cfg(x86_64)
fn hal_parse_boot_info() -> BootOutputPort:
    """Parse Limine boot protocol responses on x86_64."""
    val boot = X86Boot()
    boot.parse_hhdm()
    boot.build_boot_output()

@cfg(arm64)
fn hal_parse_boot_info() -> BootOutputPort:
    """Parse boot info — arch: arm64 DTB (Device Tree Blob)."""
    val boot = Arm64Boot()
    boot.parse_boot_info()

@cfg(arm32)
fn hal_parse_boot_info() -> BootOutputPort:
    """Parse boot info — arch: arm32 DTB (Device Tree Blob)."""
    val boot = Arm32Boot()
    boot.build_boot_output()

@cfg(riscv64)
fn hal_parse_boot_info() -> BootOutputPort:
    """Parse boot info — arch: riscv64 OpenSBI + DTB."""
    val boot = Rv64Boot()
    boot.parse_boot_info()

@cfg(riscv32)
fn hal_parse_boot_info() -> BootOutputPort:
    """Parse boot info — arch: riscv32 hardcoded QEMU virt layout."""
    val boot = Rv32Boot()
    boot.build_boot_output()

