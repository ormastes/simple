# riscv32 arch imports
use os.kernel.arch.riscv32.console.{uart_init as rv32_uart_init, uart_write_byte as rv32_uart_write_byte, uart_write as rv32_uart_write, uart_writeln as rv32_uart_writeln}
use os.kernel.arch.riscv32.boot.{Rv32Boot}
use os.kernel.arch.riscv32.cpu.{wfi as rv32_wfi, sfence_vma as rv32_sfence_vma, sfence_vma_all as rv32_sfence_vma_all, csrr_sstatus as rv32_csrr_sstatus, csrw_sstatus as rv32_csrw_sstatus, SSTATUS_SIE as RV32_SSTATUS_SIE}
use os.kernel.arch.riscv32.sbi.{sbi_system_reset as rv32_system_reset}
use os.kernel.arch.riscv32.paging.{Rv32Paging, vmm_init as rv32_vmm_init, vmm_map_page as rv32_vmm_map_page, vmm_unmap_page as rv32_vmm_unmap_page, vmm_translate as rv32_vmm_translate, vmm_create_address_space as rv32_vmm_create_address_space, vmm_switch_address_space as rv32_vmm_switch_address_space}
use os.kernel.arch.riscv32.interrupt.{Rv32Interrupt}
use os.kernel.arch.riscv32.timer.{Rv32Timer}
use os.kernel.arch.riscv32.context.{Rv32ContextSwitch}

# ============================================================================
# Traits (interface definitions)
# ============================================================================

trait HalConsole:
    """Early serial console output — first thing initialized at boot."""
    fn console_init()
    fn console_write_byte(b: u8)
    fn console_write(msg: text)
    fn console_writeln(msg: text)

trait HalBoot:
    """Boot protocol parsing — extracts memory map, framebuffer, etc."""
    fn parse_boot_info() -> BootOutputPort

trait HalCpu:
    """CPU control primitives — interrupt toggling, halt, TLB flush."""
    fn cpu_disable_interrupts()
    fn cpu_enable_interrupts()
    fn cpu_halt()
    fn cpu_halt_loop()
    fn cpu_flush_tlb(vaddr: u64)
    fn cpu_flush_tlb_all()
    fn cpu_id() -> u64
    fn cpu_address_width() -> u32

trait HalPower:
    """Machine-level power controls exposed through syscall-safe facades."""
    fn system_reset() -> i64

trait HalPaging:
    """Page table management — map, unmap, translate virtual addresses."""
    fn paging_init(boot_info: BootOutputPort)
    fn paging_map(virt: VirtAddr, phys: PhysAddr, flags: VmFlags) -> bool
    fn paging_unmap(virt: VirtAddr) -> bool
    fn paging_translate(virt: VirtAddr) -> PhysAddr?
    fn paging_create_address_space() -> u64
    fn paging_switch_address_space(root_phys: u64)
    fn paging_levels() -> u32

trait HalInterrupt:
    """Interrupt controller — IRQ enable/disable, acknowledge, handler registration."""
    fn interrupt_init()
    fn interrupt_enable_irq(irq: u32)
    fn interrupt_disable_irq(irq: u32)
    fn interrupt_acknowledge(irq: u32)
    fn interrupt_set_handler(irq: u32, handler: u64)
    fn interrupt_set_priority(irq: u32, priority: u32)

trait HalTimer:
    """Preemption timer — periodic tick or one-shot deadline for scheduling."""
    fn timer_init(frequency_hz: u64)
    fn timer_set_deadline(ticks: u64)
    fn timer_current_ticks() -> u64
    fn timer_ticks_per_second() -> u64

trait HalContext:
    """Context switching — save/restore/initialize CPU register state."""
    fn context_save() -> ArchContext
    fn context_restore(ctx: ArchContext)
    fn context_init(entry: u64, stack: u64, arg: u64) -> ArchContext
    # Reserved for FP/SIMD extended save (Wave 3 may implement per arch).
    # Default: NotImplemented. Implementing archs override this.
    fn context_save_extended(buf: ExtendedCtx) -> Result<i32, HalError>:
        Result.Err(HalError.NotImplemented)

# ============================================================================
# Hardening / runtime-glue traits — added 2026-04-25 for AC-3 + AC-5.
# Wave 1 declares signatures only. Per-arch impls land in Wave 3 under
# arch/<arch>/{entropy,cstart,syscall_entry,canary,barrier,cache}.spl.
# HalSmp/HalPerCpu are SHAPE-ONLY this round — bodies deferred.
# ============================================================================

enum HalError:
    """Generic HAL error class. Per-trait specializations may add variants."""
    NotImplemented
    Unsupported
    InvalidArgument
    DeviceFault
    NoEntropy
    OutOfRange

enum CstartError:
    """C-runtime startup errors raised from cstart_init / setjmp / longjmp."""
    NotImplemented
    BootArgsInvalid
    StackUnaligned
    BssZeroFailed
    EnvSetupFailed

trait HalEntropy:
    """Best-effort early entropy source for canary seeding and KASLR.
    Per-arch: x86=RDRAND/RDSEED, arm64=RNDR (probed) else CNTVCT,
    arm32=CNTVCT+DTB mix, riscv=sbi_get_random else cycle+time+instret."""
    fn hal_random_seed_u64() -> u64

trait HalCstart:
    """C-runtime startup — replaces simpleos_crt0.S / simpleos_setjmp.S.
    Per-arch impls in arch/<arch>/cstart.spl."""
    fn cstart_init(boot_args: BootArgs) -> Result<i32, CstartError>
    fn setjmp(buf: JmpBuf) -> i32
    fn longjmp(buf: JmpBuf, val: i32) -> i32     # noreturn — i32 placeholder
    fn exit(code: i32) -> i32                     # noreturn — i32 placeholder

trait HalSyscall:
    """Syscall vector install + dispatch — single cap-check site.
    Args: syscall number + up to 6 register args (System-V / AAPCS / RV)."""
    fn install_vector() -> Result<i32, HalError>
    fn dispatch(no: u64, a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64

trait HalCanary:
    """Stack canary seeded from HalEntropy. Replaces 0xDEADBEEF constant."""
    fn canary_init(seed: u64)
    fn canary_value() -> u64
    fn canary_fail() -> i32                       # noreturn — i32 placeholder

trait HalBarrier:
    """Memory barriers — load/store/full + iomem read/write.
    Mandatory for ARM/RISC-V; x86 is mostly TSO but iomem still needs MFENCE."""
    fn load_barrier()
    fn store_barrier()
    fn full_barrier()
    fn iomem_read_barrier()
    fn iomem_write_barrier()

trait HalCache:
    """Cache maintenance — sync I-cache after JIT, clean/invalidate D-cache for DMA."""
    fn sync_icache(start: usize, len: usize)
    fn dcache_clean(start: usize, len: usize)
    fn dcache_invalidate(start: usize, len: usize)

trait HalSmp:
    """Multi-CPU bring-up + IPI. SHAPE ONLY — implementations deferred post-AC-4."""
    fn cpu_count() -> u32
    fn cpu_start(idx: u32, entry: u64) -> Result<i32, HalError>
    fn ipi(target: u32, vec: u8)

trait HalPerCpu:
    """Per-CPU storage base register. SHAPE ONLY — implementations deferred."""
    fn percpu_set_base(addr: usize)
    fn percpu_get_base() -> usize

