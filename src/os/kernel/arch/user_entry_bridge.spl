# Shared user-entry bridge for arch-neutral kernel code.
#
# This keeps direct `use os.kernel.arch.<arch>.user_entry` imports inside the
# `arch/` tree so loader/syscall code can route through one stable façade
# without reintroducing concrete arch imports outside the HAL boundary.

use os.kernel.arch.arch_context.{Architecture}
use os.kernel.scheduler.scheduler_types.{Scheduler}

@cfg(x86_64)
use os.kernel.arch.x86_64.user_entry.{dispatch_enter_user_blocking as dispatch_x86_64_enter_user}

# NOTE(cross-arch import leak): the arm64/riscv64 `use` lines below live
# INSIDE their @cfg'd fn bodies, not at top level. The seed's cfg strip
# does not strip @cfg-gated top-level `use` lines (is_top_level_global_decl
# matches only let/val/var/const/static), so a top-level @cfg(riscv64) use
# pulls the whole riscv64 module tree — including RV64-only inline asm —
# into every x86_64 kernel build and breaks it at clang. Discovery strips
# wrong-arch @cfg fn variants BEFORE dep collection, so a fn-local use is
# correctly dropped for other arches and still resolved on its own arch.
@cfg(x86_64)
fn dispatch_enter_user_blocking(pid_hint: u64, scheduler: Scheduler) -> i64:
    """Arch-owned EnterUserBlocking bridge used by the syscall shim."""
    dispatch_x86_64_enter_user(pid_hint, scheduler)

@cfg(arm64)
fn dispatch_enter_user_blocking(pid_hint: u64, scheduler: Scheduler) -> i64:
    """Arch-owned EnterUserBlocking bridge used by the syscall shim."""
    let _ = pid_hint
    let _ = scheduler
    -38

@cfg(riscv64)
fn dispatch_enter_user_blocking(pid_hint: u64, scheduler: Scheduler) -> i64:
    """Arch-owned EnterUserBlocking bridge used by the syscall shim."""
    use os.kernel.arch.riscv64.user_entry.{dispatch_enter_user_blocking as dispatch_rv64_enter_user}
    dispatch_rv64_enter_user(pid_hint, scheduler)

@cfg(x86)
fn dispatch_enter_user_blocking(_pid_hint: u64, _scheduler: Scheduler) -> i64:
    -38

@cfg(arm32)
fn dispatch_enter_user_blocking(_pid_hint: u64, _scheduler: Scheduler) -> i64:
    -38

@cfg(riscv32)
fn dispatch_enter_user_blocking(_pid_hint: u64, _scheduler: Scheduler) -> i64:
    -38

@cfg(x86_64)
fn dispatch_fs_exec_user_handoff(arch: Architecture, pid_hint: u64, scheduler: Scheduler) -> i64:
    """Route filesystem-exec handoff through the family-owned entry bridge."""
    match arch:
        Architecture.X86_64:
            dispatch_x86_64_enter_user(pid_hint, scheduler)
        case _:
            0

@cfg(arm64)
fn dispatch_fs_exec_user_handoff(arch: Architecture, pid_hint: u64, scheduler: Scheduler) -> i64:
    """Route filesystem-exec handoff through the family-owned entry bridge."""
    use os.kernel.arch.arm64.user_entry.{dispatch_enter_user_blocking_live as dispatch_arm64_enter_user}
    match arch:
        Architecture.Arm64:
            dispatch_arm64_enter_user(pid_hint, scheduler)
        case _:
            -38

@cfg(riscv64)
fn dispatch_fs_exec_user_handoff(arch: Architecture, pid_hint: u64, scheduler: Scheduler) -> i64:
    """Route filesystem-exec handoff through the family-owned entry bridge."""
    use os.kernel.arch.riscv64.user_entry.{dispatch_enter_user_blocking as dispatch_rv64_enter_user}
    match arch:
        Architecture.Riscv64:
            dispatch_rv64_enter_user(pid_hint, scheduler)
        case _:
            -38

@cfg(x86)
fn dispatch_fs_exec_user_handoff(_arch: Architecture, _pid_hint: u64, _scheduler: Scheduler) -> i64:
    0

@cfg(arm32)
fn dispatch_fs_exec_user_handoff(_arch: Architecture, _pid_hint: u64, _scheduler: Scheduler) -> i64:
    0

@cfg(riscv32)
fn dispatch_fs_exec_user_handoff(_arch: Architecture, _pid_hint: u64, _scheduler: Scheduler) -> i64:
    0
