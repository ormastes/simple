"""Cortex-M33 NVIC — minimal interrupt controller setup.

ARMv8-M Mainline NVIC at 0xE000E100. Provides enable/disable/priority
for external IRQs. SysTick and fault handlers are in the vector table.
"""

use os.kernel.boot.mmio.{mmio_read32, mmio_write32}

fn nvic_iser_addr(irq: u32) -> u64:
    0xE000E100 + ((irq / 32) * 4) as u64

fn nvic_icer_addr(irq: u32) -> u64:
    0xE000E180 + ((irq / 32) * 4) as u64

fn nvic_ipr_addr(irq: u32) -> u64:
    0xE000E400 + (irq as u64)

fn nvic_enable_irq(irq: u32):
    val reg = nvic_iser_addr(irq)
    val bit = 1 << (irq % 32)
    mmio_write32(reg, bit)

fn nvic_disable_irq(irq: u32):
    val reg = nvic_icer_addr(irq)
    val bit = 1 << (irq % 32)
    mmio_write32(reg, bit)

fn nvic_set_priority(irq: u32, priority: u8):
    val reg = nvic_ipr_addr(irq)
    mmio_write32(reg, priority as u32)

fn nvic_system_reset():
    val aircr: u64 = 0xE000ED0C
    val key: u32 = 0x05FA0004
    mmio_write32(aircr, key)

fn enable_interrupts():
    unsafe:
        asm volatile:
            "cpsie i"

fn disable_interrupts():
    unsafe:
        asm volatile:
            "cpsid i"
