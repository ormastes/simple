"""Cortex-M33 (ARMv8-M Mainline) HAL Implementation — Module Root.

Aggregates all Cortex-M33-specific HAL implementations.
Each submodule wraps architecture-specific primitives behind
a HAL-compatible interface for the kernel's portable layers.

Target: QEMU MPS2-AN505 (Cortex-M33)
  - CMSDK APB UART at 0x40004000
  - NVIC at 0xE000E100
  - RAM at 0x20000000 (4 MB)

Future target: Arduino UNO Q (STM32U585, Cortex-M33)
  - STM32 USART at 0x40013800
  - 786 KB SRAM, 2 MB flash
"""

use os.kernel.arch.cortex_m33.console.{
    Cm33Console,
    uart_init,
    uart_write_byte,
    uart_write,
    uart_writeln,
    uart_read_byte
}

use os.kernel.arch.cortex_m33.interrupt.{
    nvic_enable_irq,
    nvic_disable_irq,
    nvic_set_priority,
    nvic_system_reset,
    enable_interrupts,
    disable_interrupts
}

use os.kernel.arch.cortex_m33.boot.{
    reset_handler,
    boot_main,
    vector_table
}

use os.kernel.arch.cortex_m33.shell_lite.{
    shell_main
}

fn arch_name() -> text:
    "cortex-m33"

fn arch_bits() -> i32:
    32

fn arch_endian() -> text:
    "little"

fn arch_has_mmu() -> bool:
    false

fn arch_has_mpu() -> bool:
    true
