"""MPS2-AN505 Platform Constants — QEMU Cortex-M33 (ARMv8-M Mainline).

Memory map for ARM MPS2 FPGA image AN505 (SSE-200 IoT Kit):
  0x00000000 - 0x00400000  SSRAM1 code (4 MB, aliased from 0x10000000)
  0x20000000 - 0x20400000  SSRAM2+3 data (4 MB)
  0x40004000 - 0x40004FFF  CMSDK APB UART0 (serial stdio)
  0x40005000 - 0x40005FFF  CMSDK APB UART1
  0xE000E000 - 0xE000EFFF  NVIC / System Control Block
"""

fn flash_base() -> u32:
    0x00000000

fn flash_size() -> u32:
    0x00400000

fn ram_base() -> u32:
    0x20000000

fn ram_size() -> u32:
    0x00400000

fn stack_top() -> u32:
    0x20400000

fn uart0_base() -> u32:
    0x40004000

fn uart1_base() -> u32:
    0x40005000

fn nvic_base() -> u32:
    0xE000E100

fn scb_base() -> u32:
    0xE000ED00

fn systick_base() -> u32:
    0xE000E010
