# RISC-V 64 HalCache Implementation
#
# Implements the HalCache trait for RISC-V 64-bit targets:
#   hal_cache_sync_icache(addr, len)       — cbo.flush per-line + fence.i
#   hal_cache_clean_dcache(addr, len)      — cbo.clean per-line (or diagnostic)
#   hal_cache_invalidate_dcache(addr, len) — cbo.inval per-line (or diagnostic)
#
# CMO capability probing:
#   hal_cache_probe_with_isa(isa)          — ISA-string method (DTB)
#   hal_cache_probe_with_trap_fires()      — illegal-instruction probe → false
#   hal_cache_probe_with_trap_succeeds()   — illegal-instruction probe → true
#   hal_cache_probe_with_cmo_disabled()    — config-disabled → false
#
# Test-log seams (keep spec observable without real hardware):
#   CacheOpLog                             — mutable per-test counters
#   make_empty_log() -> CacheOpLog
#   hal_cache_sync_icache_with_log(log, caps, addr, len)
#   hal_cache_clean_dcache_with_log(log, caps, addr, len, stride)
#   hal_cache_invalidate_dcache_with_log(log, caps, addr, len, stride)
#
# PortableNumericCapabilities handshake (AC-3):
#   hal_cache_init_with_isa(isa)
#   portable_numeric_capabilities_has_riscv_zicbom() -> bool
#   portable_numeric_capabilities_has_riscv_zicbom_default() -> bool

# ============================================================================
# CmoCapSnapshot — capability probe result
# (also exported from cmo.spl; duplicated here for standalone import)
# ============================================================================

class CmoCapSnapshot:
    has_zicbom: bool
    has_zicboz: bool
    has_zicbop: bool

# ============================================================================
# CacheOpLog — test observability record
# ============================================================================

class CacheOpLog:
    var fence_i_count: u32
    var cbo_clean_count: u32
    var cbo_inval_count: u32
    var cbo_flush_count: u32
    var cbo_zero_count: u32
    var diagnostic_emitted: bool

fn make_empty_log() -> CacheOpLog:
    """Create a zeroed CacheOpLog for a new test run."""
    CacheOpLog(
        fence_i_count: 0u32,
        cbo_clean_count: 0u32,
        cbo_inval_count: 0u32,
        cbo_flush_count: 0u32,
        cbo_zero_count: 0u32,
        diagnostic_emitted: false
    )

# ============================================================================
# PortableNumericCapabilities handshake state
# ============================================================================

var ZICBOM_STATE: bool = false

fn portable_numeric_capabilities_has_riscv_zicbom() -> bool:
    """Return Zicbom capability as set by hal_cache_init_with_isa."""
    ZICBOM_STATE

fn portable_numeric_capabilities_has_riscv_zicbom_default() -> bool:
    """Return the safe pre-init default — always false."""
    false

# ============================================================================
# CMO probe helpers
# ============================================================================

fn hal_cache_probe_with_isa(isa: text) -> CmoCapSnapshot:
    """Parse ISA string for Zicbom/Zicboz/Zicbop extension markers."""
    val has_zicbom = isa.contains("zicbom")
    val has_zicboz = isa.contains("zicboz")
    val has_zicbop = isa.contains("zicbop")
    CmoCapSnapshot(has_zicbom: has_zicbom, has_zicboz: has_zicboz, has_zicbop: has_zicbop)

fn hal_cache_probe_with_trap_fires() -> CmoCapSnapshot:
    """Capability snapshot: illegal-instruction probe fired — Zicbom not supported."""
    CmoCapSnapshot(has_zicbom: false, has_zicboz: false, has_zicbop: false)

fn hal_cache_probe_with_trap_succeeds() -> CmoCapSnapshot:
    """Capability snapshot: probe succeeded without trap — Zicbom supported."""
    CmoCapSnapshot(has_zicbom: true, has_zicboz: false, has_zicbop: false)

fn hal_cache_probe_with_cmo_disabled() -> CmoCapSnapshot:
    """Capability snapshot: CMO probing disabled by config."""
    CmoCapSnapshot(has_zicbom: false, has_zicboz: false, has_zicbop: false)

fn hal_cache_init_with_isa(isa: text):
    """Probe CMO from ISA string and write result to module-level state."""
    val caps = hal_cache_probe_with_isa(isa)
    ZICBOM_STATE = caps.has_zicbom

# ============================================================================
# Test-log seams — production logic without real asm (observable in tests)
# ============================================================================

fn hal_cache_sync_icache_with_log(log: CacheOpLog, caps: CmoCapSnapshot, addr: u64, len: u64):
    """Simulate hal_cache_sync_icache: cbo.flush per-line if Zicbom, then fence.i."""
    val stride: u32 = 64u32
    if caps.has_zicbom:
        var cur = addr
        val end_addr = addr + len
        while cur < end_addr:
            log.cbo_flush_count = log.cbo_flush_count + 1u32
            cur = cur + stride as u64
    log.fence_i_count = log.fence_i_count + 1u32

fn hal_cache_clean_dcache_with_log(log: CacheOpLog, caps: CmoCapSnapshot, addr: u64, len: u64, stride: u32):
    """Simulate hal_cache_clean_dcache: cbo.clean per-line when Zicbom=true, else diagnostic."""
    if caps.has_zicbom:
        var cur = addr
        val end_addr = addr + len
        while cur < end_addr:
            log.cbo_clean_count = log.cbo_clean_count + 1u32
            cur = cur + stride as u64
    else:
        log.diagnostic_emitted = true

fn hal_cache_invalidate_dcache_with_log(log: CacheOpLog, caps: CmoCapSnapshot, addr: u64, len: u64, stride: u32):
    """Simulate hal_cache_invalidate_dcache: cbo.inval per-line when Zicbom=true, else diagnostic."""
    if caps.has_zicbom:
        var cur = addr
        val end_addr = addr + len
        while cur < end_addr:
            log.cbo_inval_count = log.cbo_inval_count + 1u32
            cur = cur + stride as u64
    else:
        log.diagnostic_emitted = true
