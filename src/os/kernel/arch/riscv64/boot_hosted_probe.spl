# Temporary hosted-handoff probe entry for RISC-V freestanding link diagnostics.

use os.kernel.boot.riscv_boot_mem.{riscv_boot_mem_init}
use os.kernel.boot.os_main.{os_main}

@section(".text.entry")
@naked
fn _start():
    asm volatile:
        "mv      s0, a0"
        "mv      s1, a1"
        "la      sp, _stack_top"
        "la      t0, _sbss"
        "la      t1, _ebss"
        ".Lprobe_bss_loop:"
        "bgeu    t0, t1, .Lprobe_bss_done"
        "sd      zero, 0(t0)"
        "addi    t0, t0, 8"
        "j       .Lprobe_bss_loop"
        ".Lprobe_bss_done:"
        "mv      a0, s0"
        "mv      a1, s1"
        "call    kernel__arch__riscv64__boot_hosted_probe__boot_main"
        ".Lprobe_halt:"
        "wfi"
        "j       .Lprobe_halt"

fn boot_main(hart_id: u64, dtb_addr: u64):
    riscv_boot_mem_init()
    os_main()
