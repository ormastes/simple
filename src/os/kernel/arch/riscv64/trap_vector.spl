# RISC-V 64 Trap Vector — embedded assembly
#
# Keeps the RV64 trap and first user-entry ABI in Simple source while preserving
# the exact register save/restore contract consumed by interrupt.spl.

@section(".text.trap")
@naked
fn _rv64_trap_vector():
    """S-mode trap entrypoint installed in stvec."""
    asm volatile:
        "csrrw   sp, sscratch, sp"
        "bnez    sp, .Lrv64_from_user"
        "csrr    sp, sscratch"
        ".Lrv64_from_user:"
        "addi    sp, sp, -272"
        "sd      t0, 32(sp)"
        "csrr    t0, sscratch"
        "beqz    t0, .Lrv64_save_smode_sp"
        "sd      t0, 8(sp)"
        "csrw    sscratch, zero"
        "j       .Lrv64_sp_saved"
        ".Lrv64_save_smode_sp:"
        "addi    t0, sp, 272"
        "sd      t0, 8(sp)"
        ".Lrv64_sp_saved:"
        "sd      ra, 0(sp)"
        "sd      gp, 16(sp)"
        "sd      tp, 24(sp)"
        "sd      t1, 40(sp)"
        "sd      t2, 48(sp)"
        "sd      s0, 56(sp)"
        "sd      s1, 64(sp)"
        "sd      a0, 72(sp)"
        "sd      a1, 80(sp)"
        "sd      a2, 88(sp)"
        "sd      a3, 96(sp)"
        "sd      a4, 104(sp)"
        "sd      a5, 112(sp)"
        "sd      a6, 120(sp)"
        "sd      a7, 128(sp)"
        "sd      s2, 136(sp)"
        "sd      s3, 144(sp)"
        "sd      s4, 152(sp)"
        "sd      s5, 160(sp)"
        "sd      s6, 168(sp)"
        "sd      s7, 176(sp)"
        "sd      s8, 184(sp)"
        "sd      s9, 192(sp)"
        "sd      s10, 200(sp)"
        "sd      s11, 208(sp)"
        "sd      t3, 216(sp)"
        "sd      t4, 224(sp)"
        "sd      t5, 232(sp)"
        "sd      t6, 240(sp)"
        "csrr    t0, sepc"
        "sd      t0, 248(sp)"
        "csrr    t0, sstatus"
        "sd      t0, 256(sp)"
        "csrr    t0, scause"
        "sd      t0, 264(sp)"
        "mv      a0, sp"
        "call    rv64_dispatch_trap_frame_ptr"
        "bnez    a0, .Lrv64_trap_fatal"
        "ld      t0, 248(sp)"
        "csrw    sepc, t0"
        "ld      t0, 256(sp)"
        "csrw    sstatus, t0"
        "ld      ra, 0(sp)"
        "ld      gp, 16(sp)"
        "ld      tp, 24(sp)"
        "ld      t1, 40(sp)"
        "ld      t2, 48(sp)"
        "ld      s0, 56(sp)"
        "ld      s1, 64(sp)"
        "ld      a0, 72(sp)"
        "ld      a1, 80(sp)"
        "ld      a2, 88(sp)"
        "ld      a3, 96(sp)"
        "ld      a4, 104(sp)"
        "ld      a5, 112(sp)"
        "ld      a6, 120(sp)"
        "ld      a7, 128(sp)"
        "ld      s2, 136(sp)"
        "ld      s3, 144(sp)"
        "ld      s4, 152(sp)"
        "ld      s5, 160(sp)"
        "ld      s6, 168(sp)"
        "ld      s7, 176(sp)"
        "ld      s8, 184(sp)"
        "ld      s9, 192(sp)"
        "ld      s10, 200(sp)"
        "ld      s11, 208(sp)"
        "ld      t3, 216(sp)"
        "ld      t4, 224(sp)"
        "ld      t5, 232(sp)"
        "ld      t6, 240(sp)"
        "csrr    t0, sstatus"
        "andi    t0, t0, 0x100"
        "bnez    t0, .Lrv64_return_smode"
        "addi    t0, sp, 272"
        "csrw    sscratch, t0"
        "ld      t0, 32(sp)"
        "ld      sp, 8(sp)"
        "sret"
        ".Lrv64_return_smode:"
        "csrw    sscratch, zero"
        "ld      t0, 32(sp)"
        "ld      sp, 8(sp)"
        "sret"
        ".Lrv64_trap_fatal:"
        "wfi"
        "j       .Lrv64_trap_fatal"

@section(".text.trap")
@naked
fn _rv64_enter_user(ctx_addr: u64):
    """First entry into U-mode from an in-memory Riscv64Context."""
    asm volatile:
        "ld      t0, 248(a0)"
        "csrw    sepc, t0"
        "ld      t0, 256(a0)"
        "csrw    sstatus, t0"
        "csrw    sscratch, sp"
        "ld      ra, 0(a0)"
        "ld      gp, 16(a0)"
        "ld      tp, 24(a0)"
        "ld      t0, 32(a0)"
        "ld      t1, 40(a0)"
        "ld      t2, 48(a0)"
        "ld      s0, 56(a0)"
        "ld      s1, 64(a0)"
        "ld      a1, 80(a0)"
        "ld      a2, 88(a0)"
        "ld      a3, 96(a0)"
        "ld      a4, 104(a0)"
        "ld      a5, 112(a0)"
        "ld      a6, 120(a0)"
        "ld      a7, 128(a0)"
        "ld      s2, 136(a0)"
        "ld      s3, 144(a0)"
        "ld      s4, 152(a0)"
        "ld      s5, 160(a0)"
        "ld      s6, 168(a0)"
        "ld      s7, 176(a0)"
        "ld      s8, 184(a0)"
        "ld      s9, 192(a0)"
        "ld      s10, 200(a0)"
        "ld      s11, 208(a0)"
        "ld      t3, 216(a0)"
        "ld      t4, 224(a0)"
        "ld      t5, 232(a0)"
        "ld      t6, 240(a0)"
        "ld      sp, 8(a0)"
        "ld      a0, 72(a0)"
        "sret"
