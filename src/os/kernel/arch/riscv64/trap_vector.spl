# RISC-V 64 Trap Vector — embedded assembly
#
# Keeps the RV64 trap and first user-entry ABI in Simple source while preserving
# the exact register save/restore contract consumed by interrupt.spl.

@section(".text.trap")
@naked
fn _rv64_trap_vector():
    """S-mode trap entrypoint installed in stvec."""
    asm volatile:
        "csrrw   sp, sscratch, sp"
        "bnez    sp, .Lrv64_from_user"
        "csrr    sp, sscratch"
        ".Lrv64_from_user:"
        "addi    sp, sp, -544"
        "sd      t0, 32(sp)"
        "sd      t1, 40(sp)"
        "csrr    t0, sstatus"
        "sd      t0, 256(sp)"
        "li      t1, 0x6000"
        "and     t0, t0, t1"
        "beqz    t0, .Lrv64_fp_saved"
        "fsd     f0, 272(sp)"
        "fsd     f1, 280(sp)"
        "fsd     f2, 288(sp)"
        "fsd     f3, 296(sp)"
        "fsd     f4, 304(sp)"
        "fsd     f5, 312(sp)"
        "fsd     f6, 320(sp)"
        "fsd     f7, 328(sp)"
        "fsd     f8, 336(sp)"
        "fsd     f9, 344(sp)"
        "fsd     f10, 352(sp)"
        "fsd     f11, 360(sp)"
        "fsd     f12, 368(sp)"
        "fsd     f13, 376(sp)"
        "fsd     f14, 384(sp)"
        "fsd     f15, 392(sp)"
        "fsd     f16, 400(sp)"
        "fsd     f17, 408(sp)"
        "fsd     f18, 416(sp)"
        "fsd     f19, 424(sp)"
        "fsd     f20, 432(sp)"
        "fsd     f21, 440(sp)"
        "fsd     f22, 448(sp)"
        "fsd     f23, 456(sp)"
        "fsd     f24, 464(sp)"
        "fsd     f25, 472(sp)"
        "fsd     f26, 480(sp)"
        "fsd     f27, 488(sp)"
        "fsd     f28, 496(sp)"
        "fsd     f29, 504(sp)"
        "fsd     f30, 512(sp)"
        "fsd     f31, 520(sp)"
        "frcsr   t0"
        "sw      t0, 528(sp)"
        # Never run compiled kernel code with a user-controlled rounding mode.
        "csrw    fcsr, zero"
        ".Lrv64_fp_saved:"
        "csrr    t0, sscratch"
        "beqz    t0, .Lrv64_save_smode_sp"
        "sd      t0, 8(sp)"
        "csrw    sscratch, zero"
        "j       .Lrv64_sp_saved"
        ".Lrv64_save_smode_sp:"
        "addi    t0, sp, 544"
        "sd      t0, 8(sp)"
        ".Lrv64_sp_saved:"
        "sd      ra, 0(sp)"
        "sd      gp, 16(sp)"
        "sd      tp, 24(sp)"
        "sd      t2, 48(sp)"
        "sd      s0, 56(sp)"
        "sd      s1, 64(sp)"
        "sd      a0, 72(sp)"
        "sd      a1, 80(sp)"
        "sd      a2, 88(sp)"
        "sd      a3, 96(sp)"
        "sd      a4, 104(sp)"
        "sd      a5, 112(sp)"
        "sd      a6, 120(sp)"
        "sd      a7, 128(sp)"
        "sd      s2, 136(sp)"
        "sd      s3, 144(sp)"
        "sd      s4, 152(sp)"
        "sd      s5, 160(sp)"
        "sd      s6, 168(sp)"
        "sd      s7, 176(sp)"
        "sd      s8, 184(sp)"
        "sd      s9, 192(sp)"
        "sd      s10, 200(sp)"
        "sd      s11, 208(sp)"
        "sd      t3, 216(sp)"
        "sd      t4, 224(sp)"
        "sd      t5, 232(sp)"
        "sd      t6, 240(sp)"
        "csrr    t0, sepc"
        "sd      t0, 248(sp)"
        "csrr    t0, sstatus"
        "sd      t0, 256(sp)"
        "csrr    t0, scause"
        "sd      t0, 264(sp)"
        "mv      a0, sp"
        "call    rv64_dispatch_trap_frame_ptr"
        "bnez    a0, .Lrv64_trap_fatal"
        "ld      t0, 248(sp)"
        "csrw    sepc, t0"
        "ld      t0, 256(sp)"
        "csrw    sstatus, t0"
        "li      t1, 0x6000"
        "and     t0, t0, t1"
        "beqz    t0, .Lrv64_fp_restored"
        "fld     f0, 272(sp)"
        "fld     f1, 280(sp)"
        "fld     f2, 288(sp)"
        "fld     f3, 296(sp)"
        "fld     f4, 304(sp)"
        "fld     f5, 312(sp)"
        "fld     f6, 320(sp)"
        "fld     f7, 328(sp)"
        "fld     f8, 336(sp)"
        "fld     f9, 344(sp)"
        "fld     f10, 352(sp)"
        "fld     f11, 360(sp)"
        "fld     f12, 368(sp)"
        "fld     f13, 376(sp)"
        "fld     f14, 384(sp)"
        "fld     f15, 392(sp)"
        "fld     f16, 400(sp)"
        "fld     f17, 408(sp)"
        "fld     f18, 416(sp)"
        "fld     f19, 424(sp)"
        "fld     f20, 432(sp)"
        "fld     f21, 440(sp)"
        "fld     f22, 448(sp)"
        "fld     f23, 456(sp)"
        "fld     f24, 464(sp)"
        "fld     f25, 472(sp)"
        "fld     f26, 480(sp)"
        "fld     f27, 488(sp)"
        "fld     f28, 496(sp)"
        "fld     f29, 504(sp)"
        "fld     f30, 512(sp)"
        "fld     f31, 520(sp)"
        "lw      t0, 528(sp)"
        "csrw    fcsr, t0"
        ".Lrv64_fp_restored:"
        "ld      ra, 0(sp)"
        "ld      gp, 16(sp)"
        "ld      tp, 24(sp)"
        "ld      t1, 40(sp)"
        "ld      t2, 48(sp)"
        "ld      s0, 56(sp)"
        "ld      s1, 64(sp)"
        "ld      a0, 72(sp)"
        "ld      a1, 80(sp)"
        "ld      a2, 88(sp)"
        "ld      a3, 96(sp)"
        "ld      a4, 104(sp)"
        "ld      a5, 112(sp)"
        "ld      a6, 120(sp)"
        "ld      a7, 128(sp)"
        "ld      s2, 136(sp)"
        "ld      s3, 144(sp)"
        "ld      s4, 152(sp)"
        "ld      s5, 160(sp)"
        "ld      s6, 168(sp)"
        "ld      s7, 176(sp)"
        "ld      s8, 184(sp)"
        "ld      s9, 192(sp)"
        "ld      s10, 200(sp)"
        "ld      s11, 208(sp)"
        "ld      t3, 216(sp)"
        "ld      t4, 224(sp)"
        "ld      t5, 232(sp)"
        "ld      t6, 240(sp)"
        "csrr    t0, sstatus"
        "andi    t0, t0, 0x100"
        "bnez    t0, .Lrv64_return_smode"
        "addi    t0, sp, 544"
        "csrw    sscratch, t0"
        "ld      t0, 32(sp)"
        "ld      sp, 8(sp)"
        "sret"
        ".Lrv64_return_smode:"
        "csrw    sscratch, zero"
        "ld      t0, 32(sp)"
        "ld      sp, 8(sp)"
        "sret"
        ".Lrv64_trap_fatal:"
        "wfi"
        "j       .Lrv64_trap_fatal"

@section(".text.trap")
@naked
fn _rv64_enter_user(ctx_addr: u64) -> i64:
    """Enter U-mode and return the exit code through one saved kernel frame."""
    asm volatile:
        # Save one complete kernel Riscv64Context immediately above every
        # future live trap frame. 544 bytes preserves the 16-byte stack ABI.
        "addi    sp, sp, -544"
        "sd      ra, 0(sp)"
        "sd      gp, 16(sp)"
        "sd      tp, 24(sp)"
        "sd      t0, 32(sp)"
        "sd      t1, 40(sp)"
        "sd      t2, 48(sp)"
        "sd      s0, 56(sp)"
        "sd      s1, 64(sp)"
        "sd      a0, 72(sp)"
        "sd      a1, 80(sp)"
        "sd      a2, 88(sp)"
        "sd      a3, 96(sp)"
        "sd      a4, 104(sp)"
        "sd      a5, 112(sp)"
        "sd      a6, 120(sp)"
        "sd      a7, 128(sp)"
        "sd      s2, 136(sp)"
        "sd      s3, 144(sp)"
        "sd      s4, 152(sp)"
        "sd      s5, 160(sp)"
        "sd      s6, 168(sp)"
        "sd      s7, 176(sp)"
        "sd      s8, 184(sp)"
        "sd      s9, 192(sp)"
        "sd      s10, 200(sp)"
        "sd      s11, 208(sp)"
        "sd      t3, 216(sp)"
        "sd      t4, 224(sp)"
        "sd      t5, 232(sp)"
        "sd      t6, 240(sp)"
        "csrr    t0, sstatus"
        "li      t1, 0x6000"
        "and     t1, t0, t1"
        "ori     t0, t1, 0x120"
        "sd      t0, 256(sp)"
        "beqz    t1, .Lrv64_kernel_fp_saved"
        "fsd     f0, 272(sp)"
        "fsd     f1, 280(sp)"
        "fsd     f2, 288(sp)"
        "fsd     f3, 296(sp)"
        "fsd     f4, 304(sp)"
        "fsd     f5, 312(sp)"
        "fsd     f6, 320(sp)"
        "fsd     f7, 328(sp)"
        "fsd     f8, 336(sp)"
        "fsd     f9, 344(sp)"
        "fsd     f10, 352(sp)"
        "fsd     f11, 360(sp)"
        "fsd     f12, 368(sp)"
        "fsd     f13, 376(sp)"
        "fsd     f14, 384(sp)"
        "fsd     f15, 392(sp)"
        "fsd     f16, 400(sp)"
        "fsd     f17, 408(sp)"
        "fsd     f18, 416(sp)"
        "fsd     f19, 424(sp)"
        "fsd     f20, 432(sp)"
        "fsd     f21, 440(sp)"
        "fsd     f22, 448(sp)"
        "fsd     f23, 456(sp)"
        "fsd     f24, 464(sp)"
        "fsd     f25, 472(sp)"
        "fsd     f26, 480(sp)"
        "fsd     f27, 488(sp)"
        "fsd     f28, 496(sp)"
        "fsd     f29, 504(sp)"
        "fsd     f30, 512(sp)"
        "fsd     f31, 520(sp)"
        "frcsr   t0"
        "sw      t0, 528(sp)"
        ".Lrv64_kernel_fp_saved:"
        "addi    t0, sp, 544"
        "sd      t0, 8(sp)"
        "la      t0, .Lrv64_enter_user_return"
        "sd      t0, 248(sp)"
        "li      t0, 0x525636344B524554"
        "sd      t0, 264(sp)"

        # The user context carries SIE=0. Write it before publishing the saved
        # kernel SP in sscratch so no S-mode interrupt can consume the handoff.
        "ld      t0, 248(a0)"
        "csrw    sepc, t0"
        "ld      t0, 256(a0)"
        "csrw    sstatus, t0"
        "li      t1, 0x6000"
        "and     t0, t0, t1"
        "beqz    t0, .Lrv64_user_fp_loaded"
        "fld     f0, 272(a0)"
        "fld     f1, 280(a0)"
        "fld     f2, 288(a0)"
        "fld     f3, 296(a0)"
        "fld     f4, 304(a0)"
        "fld     f5, 312(a0)"
        "fld     f6, 320(a0)"
        "fld     f7, 328(a0)"
        "fld     f8, 336(a0)"
        "fld     f9, 344(a0)"
        "fld     f10, 352(a0)"
        "fld     f11, 360(a0)"
        "fld     f12, 368(a0)"
        "fld     f13, 376(a0)"
        "fld     f14, 384(a0)"
        "fld     f15, 392(a0)"
        "fld     f16, 400(a0)"
        "fld     f17, 408(a0)"
        "fld     f18, 416(a0)"
        "fld     f19, 424(a0)"
        "fld     f20, 432(a0)"
        "fld     f21, 440(a0)"
        "fld     f22, 448(a0)"
        "fld     f23, 456(a0)"
        "fld     f24, 464(a0)"
        "fld     f25, 472(a0)"
        "fld     f26, 480(a0)"
        "fld     f27, 488(a0)"
        "fld     f28, 496(a0)"
        "fld     f29, 504(a0)"
        "fld     f30, 512(a0)"
        "fld     f31, 520(a0)"
        "lw      t0, 528(a0)"
        "csrw    fcsr, t0"
        ".Lrv64_user_fp_loaded:"
        "csrw    sscratch, sp"
        "ld      ra, 0(a0)"
        "ld      gp, 16(a0)"
        "ld      tp, 24(a0)"
        "ld      t0, 32(a0)"
        "ld      t1, 40(a0)"
        "ld      t2, 48(a0)"
        "ld      s0, 56(a0)"
        "ld      s1, 64(a0)"
        "ld      a1, 80(a0)"
        "ld      a2, 88(a0)"
        "ld      a3, 96(a0)"
        "ld      a4, 104(a0)"
        "ld      a5, 112(a0)"
        "ld      a6, 120(a0)"
        "ld      a7, 128(a0)"
        "ld      s2, 136(a0)"
        "ld      s3, 144(a0)"
        "ld      s4, 152(a0)"
        "ld      s5, 160(a0)"
        "ld      s6, 168(a0)"
        "ld      s7, 176(a0)"
        "ld      s8, 184(a0)"
        "ld      s9, 192(a0)"
        "ld      s10, 200(a0)"
        "ld      s11, 208(a0)"
        "ld      t3, 216(a0)"
        "ld      t4, 224(a0)"
        "ld      t5, 232(a0)"
        "ld      t6, 240(a0)"
        "ld      sp, 8(a0)"
        "ld      a0, 72(a0)"
        "sret"
        ".Lrv64_enter_user_return:"
        "ret"
