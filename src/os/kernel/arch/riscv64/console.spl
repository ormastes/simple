# RISC-V 64 Serial Console — 16550 UART via MMIO
#
# Implements early serial output over MMIO-mapped 16550 UART.
# QEMU virt machine maps UART0 at 0x10000000.
#
# This is the RISC-V 64-bit console implementation.
# Uses MMIO (not port I/O like x86), falling back to SBI console
# putchar for the earliest boot messages before UART is configured.
#
# 16550 UART registers (byte-width, MMIO at UART_BASE):
#   +0x00: RBR/THR — Receive Buffer / Transmitter Holding Register
#                     (also Divisor Latch Low when DLAB=1)
#   +0x01: IER     — Interrupt Enable Register
#                     (also Divisor Latch High when DLAB=1)
#   +0x02: IIR/FCR — Interrupt ID / FIFO Control Register
#   +0x03: LCR     — Line Control Register
#   +0x04: MCR     — Modem Control Register
#   +0x05: LSR     — Line Status Register (bit 5 = THR empty)

use os.kernel.arch.riscv.console_common.{RISCV_VIRT_UART_BASE, riscv_uart_init, riscv_uart_read_byte, riscv_uart_write_byte, riscv_uart_write, riscv_uart_writeln}
use os.kernel.arch.riscv64.sbi.{sbi_console_putchar}
use os.kernel.arch.riscv64.shell_lite.{rv64_shell_banner, rv64_shell_prompt, rv64_shell_dispatch, rv64_shell_format_dir_entries}
use os.apps.sshd.ssh_auth.{SshUserDb, sshd_create_default_users}
use os.services.vfs.vfs_write_ops.{g_vfs_readdir}
use os.kernel.loader.fs_exec_spawn.{fs_exec_spawn}

# ============================================================================
# UART MMIO Base Address (QEMU virt)
# ============================================================================

val UART_BASE: u64 = RISCV_VIRT_UART_BASE

# ============================================================================
# Rv64Console
# ============================================================================

struct Rv64Console:
    """RISC-V 64-bit serial console via MMIO-mapped 16550 UART.

    Provides early debug output before framebuffer or full terminal
    drivers are available. Uses memory-mapped I/O at the standard
    QEMU virt UART0 address 0x10000000.
    """
    pass_dn

var g_uart_ready: bool = false

# ============================================================================
# UART Initialization
# ============================================================================

fn _uart_init():
    """Initialize 16550 UART at 115200 baud, 8N1, FIFO enabled.

    QEMU virt provides a 16550-compatible UART. The clock is typically
    1.8432 MHz, giving divisor = 1 for 115200 baud.
    In practice QEMU ignores the baud rate, but we configure it
    correctly for real hardware compatibility.
    """
    if g_uart_ready:
        return

    g_uart_ready = riscv_uart_init(UART_BASE, g_uart_ready)

# ============================================================================
# UART Output
# ============================================================================

fn _uart_write_byte(byte: u8):
    """Write one byte to UART, blocking until THR is empty."""
    riscv_uart_write_byte(UART_BASE, byte)

fn _uart_write(msg: text):
    """Write string to UART console."""
    if not g_uart_ready:
        _uart_init()
    riscv_uart_write(UART_BASE, msg)

fn _uart_writeln(msg: text):
    """Write string followed by CR+LF to UART console."""
    if not g_uart_ready:
        _uart_init()
    riscv_uart_writeln(UART_BASE, msg)

# ============================================================================
# UART Input
# ============================================================================

fn _uart_read_byte() -> u8?:
    """Read a byte from UART if available, or return nil."""
    riscv_uart_read_byte(UART_BASE)

# ============================================================================
# Rv64Console Implementation
# ============================================================================

impl Rv64Console:
    fn init():
        """Initialize UART0 at 115200 baud, 8N1."""
        _uart_init()

    fn write_byte(byte: u8):
        """Write one byte to UART, blocking until ready."""
        if not g_uart_ready:
            # Fallback to SBI before UART is configured
            sbi_console_putchar(byte)
            return
        _uart_write_byte(byte)

    fn write(msg: text):
        """Write string to serial console."""
        _uart_write(msg)

    fn writeln(msg: text):
        """Write string followed by CR+LF to serial console."""
        _uart_writeln(msg)

    fn read_byte() -> u8?:
        """Read a byte from UART if available."""
        _uart_read_byte()

    fn base_address() -> u64:
        """Return the MMIO base address for this console."""
        UART_BASE

# ============================================================================
# Module-Level Convenience Functions
# ============================================================================

fn serial_init():
    """Initialize UART0 serial port (module-level convenience)."""
    _uart_init()

fn serial_write_byte(byte: u8):
    """Write one byte to UART (module-level convenience)."""
    if not g_uart_ready:
        sbi_console_putchar(byte)
        return
    _uart_write_byte(byte)

fn serial_write(msg: text):
    """Write string to UART (module-level convenience)."""
    _uart_write(msg)

fn serial_writeln(msg: text):
    """Write string + newline to UART (module-level convenience)."""
    _uart_writeln(msg)

fn serial_read_byte() -> i64:
    """Read one UART byte, or -1 when none is available (non-blocking)."""
    match _uart_read_byte():
        case Some(v): (v as i64)
        case _: -1

# ============================================================================
# Serial management shell — UART telnet/ssh fallback when network is down
# ============================================================================

fn serial_shell_main(network_ok: i64):
    """Interactive UART command loop — the management fallback transport.

    Reaches an operator over the serial line (directly or via the host-side
    telnet-over-serial bridge) when no network NIC is available. Pure command
    handling lives in os.kernel.arch.riscv64.shell_lite (unit-tested).
    """
    _uart_init()
    _uart_writeln(rv64_shell_banner())

    if not _serial_login():
        _uart_writeln("login denied - management shell unavailable")
        loop:
            pass

    var buf: [u8] = []
    _uart_write(rv64_shell_prompt())

    loop:
        val ch = serial_read_byte()
        if ch < 0:
            continue

        val byte = ch as u8

        if byte == 0x0D or byte == 0x0A:
            _uart_write_byte(0x0D)
            _uart_write_byte(0x0A)
            if buf.len() > 0:
                val line = _bytes_to_text(buf)
                if line == "ls":
                    # real directory enumeration via the VFS, not a static manifest
                    val listing = _shell_ls()
                    if listing.len() > 0:
                        _uart_writeln(listing)
                else if line.starts_with("launch "):
                    # exec an on-filesystem tool via the real ELF FS-exec loader
                    val lresp = _shell_launch(line)
                    if lresp.len() > 0:
                        _uart_writeln(lresp)
                else:
                    val resp = rv64_shell_dispatch(line, network_ok)
                    if resp.len() > 0:
                        _uart_writeln(resp)
                buf = []
            _uart_write(rv64_shell_prompt())
            continue

        if byte == 0x7F or byte == 0x08:
            if buf.len() > 0:
                buf.pop()
                _uart_write_byte(0x08)
                _uart_write_byte(0x20)
                _uart_write_byte(0x08)
            continue

        if buf.len() < 128:
            buf.push(byte)
            _uart_write_byte(byte)

fn _bytes_to_text(buf: [u8]) -> text:
    # rt_string_from_byte_array is linked in the RV64 freestanding runtime
    # (freestanding_runtime.c:827, used by the kernel loader). Avoid
    # rt_string_from_char — it is NOT linked on this target (would call 0x0).
    extern fn rt_string_from_byte_array(arr: [u8]) -> text
    rt_string_from_byte_array(buf)

# ============================================================================
# Serial login gate — credential check before the management shell
# ============================================================================

fn _read_serial_line(echo_on: bool) -> text:
    """Read one CR/LF-terminated line from UART. Suppresses echo when echo_on
    is false (used for the password prompt). 128-byte cap, backspace aware."""
    var buf: [u8] = []
    loop:
        val ch = serial_read_byte()
        if ch < 0:
            continue
        val byte = ch as u8
        if byte == 0x0D or byte == 0x0A:
            _uart_write_byte(0x0D)
            _uart_write_byte(0x0A)
            return _bytes_to_text(buf)
        if byte == 0x7F or byte == 0x08:
            if buf.len() > 0:
                buf.pop()
                if echo_on:
                    _uart_write_byte(0x08)
                    _uart_write_byte(0x20)
                    _uart_write_byte(0x08)
            continue
        if buf.len() < 128:
            buf.push(byte)
            if echo_on:
                _uart_write_byte(byte)
    ""

# Real serial login gate: reuses the SSH daemon's credential store
# (sshd_create_default_users -> SshUserDb) with its constant-time password
# compare, so serial and SSH enforce a single user database (root/simpleos,
# user/password by default). No duplicated inline credentials.
fn _serial_login() -> bool:
    val db = sshd_create_default_users()
    val max_attempts: i64 = 3
    var attempts: i64 = 0
    while attempts < max_attempts:
        _uart_write("login: ")
        val user = _read_serial_line(true)
        _uart_write("password: ")
        val pw = _read_serial_line(false)
        if db.authenticate_password(user, pw):
            return true
        _uart_writeln("login incorrect")
        attempts = attempts + 1
    false

# `ls` — enumerate the mounted root filesystem via the real VFS readdir and
# format entry names through the pure shell_lite formatter.
fn _shell_ls() -> text:
    rv64_shell_format_dir_entries(g_vfs_readdir("/"))

# `launch <path> [args...]` — exec an on-filesystem tool (clang/llvm/rust or the
# pure-Simple compiler/interpreter/loader at /sys/apps/<name>) through the real
# ELF FS-exec loader. argv[0] is the path; trailing tokens become argv[1..].
# Returns a one-line pid/errno status to the UART.
fn _shell_launch(line: text) -> text:
    val parts = line.split(" ")
    if parts.len() < 2 or parts[1].len() == 0:
        return "usage: launch <path> [args...]"
    val path = parts[1]
    var argv: [text] = [path]
    var i: u64 = 2
    while i < parts.len():
        argv.push(parts[i])
        i = i + 1
    val pid = fs_exec_spawn(path, argv, [])
    if pid > 0:
        return "launched " + path + " pid=" + pid.to_text()
    return "launch failed errno=" + pid.to_text()
