# RISC-V 64 User Entry Bridge
#
# Validates the scheduler handoff, enters U-mode through the canonical Sv39
# root, and blocks until the trap vector resumes the saved kernel frame.

use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.types.task_types.{TaskContext}
use os.kernel.arch.riscv64.trap_model.{create_rv64_user_context}
use os.kernel.arch.riscv64.interrupt.{Rv64Interrupt}
use os.kernel.arch.riscv64.paging.{vmm_switch_address_space}
use os.kernel.arch.riscv64.cpu.{csrr_satp, csrw_satp, sfence_vma}
use os.kernel.log.klog_api.{log_raw_println}

extern fn _rv64_enter_user(ctx_addr: u64) -> i64

fn dispatch_enter_user_blocking_probe(pid_hint: u64, scheduler: Scheduler) -> i64:
    """Validate the target RV64 user-task handoff state for fs-exec launch."""
    log_raw_println("[rv64-user] dispatch_enter_user_blocking_probe enter")
    var sched = scheduler

    val tcb = sched.get_user_handoff_task(pid_hint)
    if tcb == nil:
        log_raw_println("[rv64-user] handoff task not found pid_hint={pid_hint}")
        return -22

    val task = tcb.unwrap()
    val target_pid = task.id.id
    if not task.is_user:
        log_raw_println("[rv64-user] task is not a user task pid={target_pid}")
        return -22

    val uctx = task.user_context
    if uctx == nil:
        log_raw_println("[rv64-user] task has no user_context pid={target_pid}")
        return -22

    val ctx: TaskContext = uctx.unwrap()
    val satp_root = task.address_space
    if ctx.rip == 0 or ctx.rsp == 0 or satp_root == 0 or (satp_root & 0xFFF) != 0:
        log_raw_println("[rv64-user] invalid handoff frame pid={target_pid} rip={ctx.rip} sp={ctx.rsp} satp={satp_root}")
        return -14

    log_raw_println("[rv64-user] handoff probe ok pid={target_pid} rip={ctx.rip} satp={satp_root}")
    0

fn dispatch_enter_user_blocking(pid_hint: u64, scheduler: Scheduler) -> i64:
    """Enter one scheduled RV64 user task and return its exit status."""
    val probe_rc = dispatch_enter_user_blocking_probe(pid_hint, scheduler)
    if probe_rc != 0:
        return probe_rc

    var sched = scheduler
    val tcb = sched.get_user_handoff_task(pid_hint)
    if tcb == nil:
        return -22
    val task = tcb.unwrap()
    val user_context = task.user_context
    if user_context == nil:
        return -22
    val portable: TaskContext = user_context.unwrap()

    sched.schedule()
    val selected = sched.get_current()
    if selected != task.id:
        log_raw_println("[rv64-user] scheduler selected wrong task expected={task.id.id} actual={selected.id}")
        return -16
    if not Rv64Interrupt.install_scheduler(sched):
        log_raw_println("[rv64-user] trap runtime is not installed")
        return -38

    var rv_context = create_rv64_user_context(portable.rip, portable.rsp, 0)
    val kernel_satp = csrr_satp()
    vmm_switch_address_space(task.address_space)

    var exit_code: i64 = -1
    unsafe:
        exit_code = _rv64_enter_user(&rv_context as u64)

    csrw_satp(kernel_satp)
    sfence_vma()
    exit_code
