# RISC-V 64 Syscall Dispatch
#
# RV64 currently needs the small syscall surface used by the proof userspace
# path. Keeping it arch-local avoids linking the x86/desktop POSIX syscall
# stack into the RISC-V kernel image.

use os.kernel.arch.riscv64.console.{serial_write_byte}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.ipc.ipc.{IpcManager}
use os.kernel.log.klog.{KernelLog}
use os.kernel.types.syscall_types.{SyscallArgs, SyscallResult}

fn rv64_syscall_handler(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager, klog: KernelLog) -> SyscallResult:
    match args.id:
        case 0:
            SyscallResult(value: 0)
        case 4:
            var sched = scheduler
            val current = sched.get_current()
            SyscallResult(value: current.id.id as i64)
        case 60:
            serial_write_byte((args.arg0 & 0xFF).to_u8())
            SyscallResult(value: 0)
        case _:
            SyscallResult(value: -38)
