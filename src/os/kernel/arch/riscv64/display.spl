"""Scalar RISC-V VirtIO scanout facade for freestanding production frames."""

extern fn rt_riscv_noalloc_pmm_init_default() -> bool
extern fn rt_display_init() -> i64
extern fn rt_display_framebuffer_address() -> u64
extern fn rt_display_width() -> i64
extern fn rt_display_height() -> i64
extern fn rt_display_pitch() -> i64
extern fn rt_display_bpp() -> i64
extern fn rt_display_present() -> i64

fn riscv64_display_boot_memory_initialize() -> bool:
    rt_riscv_noalloc_pmm_init_default()

fn riscv64_display_initialize() -> bool:
    rt_display_init() == 0

fn riscv64_display_framebuffer_address() -> u64:
    rt_display_framebuffer_address()

fn riscv64_display_width() -> u32:
    rt_display_width().to_u32()

fn riscv64_display_height() -> u32:
    rt_display_height().to_u32()

fn riscv64_display_pitch() -> u32:
    rt_display_pitch().to_u32()

fn riscv64_display_bpp() -> u32:
    rt_display_bpp().to_u32()

fn riscv64_display_present() -> bool:
    rt_display_present() == 0

export riscv64_display_boot_memory_initialize, riscv64_display_initialize,
    riscv64_display_framebuffer_address, riscv64_display_width,
    riscv64_display_height, riscv64_display_pitch, riscv64_display_bpp,
    riscv64_display_present
