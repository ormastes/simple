# RISC-V 64 Trap-Frame Layout Contract
#
# Defines the memory layout used when a low-level RV64 trap vector saves a
# full supervisor trap frame for the Simple-level dispatcher. The structure
# layout matches `os.kernel.arch.arch_context.Riscv64Context`.

val RV64_TRAP_FRAME_SLOT_BYTES: u64 = 8
val RV64_TRAP_FRAME_FIELD_COUNT: u64 = 34
val RV64_TRAP_FRAME_SIZE_BYTES: u64 = RV64_TRAP_FRAME_FIELD_COUNT * RV64_TRAP_FRAME_SLOT_BYTES

val RV64_TRAP_RA_OFFSET: u64 = 0 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_SP_OFFSET: u64 = 1 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_GP_OFFSET: u64 = 2 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_TP_OFFSET: u64 = 3 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_T0_OFFSET: u64 = 4 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_T1_OFFSET: u64 = 5 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_T2_OFFSET: u64 = 6 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_S0_OFFSET: u64 = 7 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_S1_OFFSET: u64 = 8 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_A0_OFFSET: u64 = 9 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_A1_OFFSET: u64 = 10 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_A2_OFFSET: u64 = 11 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_A3_OFFSET: u64 = 12 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_A4_OFFSET: u64 = 13 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_A5_OFFSET: u64 = 14 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_A6_OFFSET: u64 = 15 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_A7_OFFSET: u64 = 16 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_S2_OFFSET: u64 = 17 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_S3_OFFSET: u64 = 18 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_S4_OFFSET: u64 = 19 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_S5_OFFSET: u64 = 20 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_S6_OFFSET: u64 = 21 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_S7_OFFSET: u64 = 22 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_S8_OFFSET: u64 = 23 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_S9_OFFSET: u64 = 24 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_S10_OFFSET: u64 = 25 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_S11_OFFSET: u64 = 26 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_T3_OFFSET: u64 = 27 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_T4_OFFSET: u64 = 28 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_T5_OFFSET: u64 = 29 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_T6_OFFSET: u64 = 30 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_SEPC_OFFSET: u64 = 31 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_SSTATUS_OFFSET: u64 = 32 * RV64_TRAP_FRAME_SLOT_BYTES
val RV64_TRAP_SCAUSE_OFFSET: u64 = 33 * RV64_TRAP_FRAME_SLOT_BYTES

fn rv64_trap_frame_field_offsets() -> [u64]:
    """Return the ordered RV64 trap-frame field offsets.

    This keeps the future assembly vector and unit tests keyed off one
    source of truth instead of duplicated numeric literals.
    """
    [
        RV64_TRAP_RA_OFFSET,
        RV64_TRAP_SP_OFFSET,
        RV64_TRAP_GP_OFFSET,
        RV64_TRAP_TP_OFFSET,
        RV64_TRAP_T0_OFFSET,
        RV64_TRAP_T1_OFFSET,
        RV64_TRAP_T2_OFFSET,
        RV64_TRAP_S0_OFFSET,
        RV64_TRAP_S1_OFFSET,
        RV64_TRAP_A0_OFFSET,
        RV64_TRAP_A1_OFFSET,
        RV64_TRAP_A2_OFFSET,
        RV64_TRAP_A3_OFFSET,
        RV64_TRAP_A4_OFFSET,
        RV64_TRAP_A5_OFFSET,
        RV64_TRAP_A6_OFFSET,
        RV64_TRAP_A7_OFFSET,
        RV64_TRAP_S2_OFFSET,
        RV64_TRAP_S3_OFFSET,
        RV64_TRAP_S4_OFFSET,
        RV64_TRAP_S5_OFFSET,
        RV64_TRAP_S6_OFFSET,
        RV64_TRAP_S7_OFFSET,
        RV64_TRAP_S8_OFFSET,
        RV64_TRAP_S9_OFFSET,
        RV64_TRAP_S10_OFFSET,
        RV64_TRAP_S11_OFFSET,
        RV64_TRAP_T3_OFFSET,
        RV64_TRAP_T4_OFFSET,
        RV64_TRAP_T5_OFFSET,
        RV64_TRAP_T6_OFFSET,
        RV64_TRAP_SEPC_OFFSET,
        RV64_TRAP_SSTATUS_OFFSET,
        RV64_TRAP_SCAUSE_OFFSET
    ]
