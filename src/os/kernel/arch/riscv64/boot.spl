# RISC-V 64 Boot Entry — S-Mode via OpenSBI
#
# First-stage hardware entry for RV64 native-build. Keep this module minimal:
# no text formatting, arrays, DTB parsing, or HAL construction. Higher-level
# boot metadata lives in boot_info.spl.

use os.kernel.boot.riscv_noalloc_handoff.{riscv_noalloc_handoff, riscv_noalloc_boot_idle}
use os.kernel.boot.riscv_noalloc_pmm.{riscv_noalloc_pmm_init}
use os.kernel.boot.riscv_noalloc_heap.{riscv_noalloc_heap_init}
use os.kernel.boot.riscv_noalloc_log.{riscv_noalloc_log_init, riscv_noalloc_log_boot_ok}
use os.kernel.boot.riscv_noalloc_services.{riscv_noalloc_services_init}
use os.kernel.boot.riscv_boot_mem.{riscv_boot_mem_init}
use os.kernel.boot.os_main.{os_main}

val UART_BASE: u64 = 0x10000000

extern fn rt_riscv_uart_put(byte: u64)

@section(".text.entry")
@naked
fn _start():
    asm volatile:
        "mv      s0, a0"
        "mv      s1, a1"
        "la      sp, _stack_top"
        "la      t0, _sbss"
        "la      t1, _ebss"
        ".Lrv64_bss_loop:"
        "bgeu    t0, t1, .Lrv64_bss_done"
        "sd      zero, 0(t0)"
        "addi    t0, t0, 8"
        "j       .Lrv64_bss_loop"
        ".Lrv64_bss_done:"
        "mv      a0, s0"
        "mv      a1, s1"
        "call    kernel__arch__riscv64__boot__boot_main"
        ".Lrv64_boot_halt:"
        "wfi"
        "j       .Lrv64_boot_halt"

fn _uart_put(byte: u64):
    rt_riscv_uart_put(byte)

fn _boot_banner():
    _uart_put(83)
    _uart_put(105)
    _uart_put(109)
    _uart_put(112)
    _uart_put(108)
    _uart_put(101)
    _uart_put(79)
    _uart_put(83)
    _uart_put(32)
    _uart_put(82)
    _uart_put(86)
    _uart_put(54)
    _uart_put(52)
    _uart_put(13)
    _uart_put(10)

fn boot_main(hart_id: u64, dtb_addr: u64):
    _boot_banner()
    riscv_noalloc_log_init()
    riscv_noalloc_handoff(hart_id, dtb_addr)
    riscv_noalloc_pmm_init(0x80000000, 134217728, 0x80400000, 0x87000000)
    riscv_noalloc_heap_init(0x87000000, 16777216)
    riscv_noalloc_services_init(true)
    riscv_noalloc_log_boot_ok()
    if riscv_boot_mem_init():
        os_main()
    riscv_noalloc_boot_idle()
