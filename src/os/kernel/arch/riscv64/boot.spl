#![allow(unnamed_duplicate_typed_args)]
# RISC-V 64 Boot Entry — S-Mode via OpenSBI
#
# First-stage hardware entry for RV64 native-build. Keep this module minimal:
# no text formatting, arrays, DTB parsing, or HAL construction. Higher-level
# boot metadata lives in boot_info.spl.

val UART_BASE: u64 = 0x10000000

@section(".text.entry")
@naked
fn _start():
    asm volatile:
        "mv      s0, a0"
        "mv      s1, a1"
        "la      sp, _stack_top"
        "la      t0, _sbss"
        "la      t1, _ebss"
        ".Lrv64_bss_loop:"
        "bgeu    t0, t1, .Lrv64_bss_done"
        "sd      zero, 0(t0)"
        "addi    t0, t0, 8"
        "j       .Lrv64_bss_loop"
        ".Lrv64_bss_done:"
        "mv      a0, s0"
        "mv      a1, s1"
        "call    os__kernel__arch__riscv64__boot__boot_main"
        ".Lrv64_boot_halt:"
        "wfi"
        "j       .Lrv64_boot_halt"

fn _uart_put(byte: u64):
    asm volatile:
        "li      t0, 0x10000000"
        "sb      a0, 0(t0)"

fn _boot_banner():
    _uart_put(83)
    _uart_put(105)
    _uart_put(109)
    _uart_put(112)
    _uart_put(108)
    _uart_put(101)
    _uart_put(79)
    _uart_put(83)
    _uart_put(32)
    _uart_put(82)
    _uart_put(86)
    _uart_put(54)
    _uart_put(52)
    _uart_put(13)
    _uart_put(10)

fn boot_main(hart_id: u64, dtb_addr: u64):
    _boot_banner()
