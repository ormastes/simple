#![allow(unnamed_duplicate_typed_args)]
# RISC-V 64 Boot Entry — S-Mode via OpenSBI
#
# First-stage hardware entry for RV64 native-build. Keep this module minimal:
# no text formatting, arrays, DTB parsing, or HAL construction. Higher-level
# boot metadata lives in boot_info.spl.

val UART_BASE: u64 = 0x10000000

@section(".text.entry")
@naked
fn _start():
    """RISC-V 64 S-mode hardware entry, implemented in Simple embedded asm."""
    asm volatile:
        "mv      s0, a0"
        "mv      s1, a1"
        "la      sp, _stack_top"
        "la      t0, _sbss"
        "la      t1, _ebss"
        ".Lrv64_bss_loop:"
        "bgeu    t0, t1, .Lrv64_bss_done"
        "sd      zero, 0(t0)"
        "addi    t0, t0, 8"
        "j       .Lrv64_bss_loop"
        ".Lrv64_bss_done:"
        "mv      a0, s0"
        "mv      a1, s1"
        "call    os__kernel__arch__riscv64__boot__boot_main"
        ".Lrv64_boot_halt:"
        "wfi"
        "j       .Lrv64_boot_halt"

fn _uart_put(byte: u8):
    val value = byte as u64
    asm volatile:
        "li      t0, 0x10000000"
        "sb      a0, 0(t0)"

fn _boot_banner():
    _uart_put(0x53u8)
    _uart_put(0x69u8)
    _uart_put(0x6Du8)
    _uart_put(0x70u8)
    _uart_put(0x6Cu8)
    _uart_put(0x65u8)
    _uart_put(0x4Fu8)
    _uart_put(0x53u8)
    _uart_put(0x20u8)
    _uart_put(0x52u8)
    _uart_put(0x56u8)
    _uart_put(0x36u8)
    _uart_put(0x34u8)
    _uart_put(0x0Du8)
    _uart_put(0x0Au8)

fn boot_main(hart_id: u64, dtb_addr: u64):
    """Minimal S-mode boot main called from embedded _start."""
    _boot_banner()
