# RISC-V 64 Boot Entry — S-Mode via OpenSBI
#
# First-stage hardware entry for RV64 native-build. Keep this module minimal:
# no text formatting, arrays, DTB parsing, or HAL construction. Higher-level
# boot metadata lives in boot_info.spl.

use os.kernel.boot.riscv_noalloc_handoff.{riscv_noalloc_handoff, riscv_noalloc_boot_idle}
use os.kernel.boot.riscv_noalloc_heap.{riscv_noalloc_heap_init}
use os.kernel.boot.riscv_noalloc_log.{riscv_noalloc_log_init, riscv_noalloc_log_boot_ok}
use os.kernel.boot.riscv_noalloc_services.{riscv_noalloc_services_init}
use os.kernel.boot.os_main.{os_main}
use os.kernel.arch.arch_context.{Architecture}
use os.kernel.arch_adapt.riscv64_hardening_probe.{riscv64_hardening_boot_canary_marker}
use os.kernel.security.sandbox_boot_apply.{sandbox_boot_apply_embedded_riscv64}

extern fn log_raw_println(msg: text)

val UART_BASE: u64 = 0x10000000

extern fn rt_riscv_uart_put(byte: u64)
extern fn rt_riscv_qemu_ram_base() -> u64
extern fn rt_riscv_qemu_ram_size() -> u64
extern fn rt_riscv_qemu_reserved_end() -> u64
extern fn rt_riscv_qemu_heap_start() -> u64
extern fn rt_riscv_qemu_heap_size() -> u64
extern fn rt_riscv_noalloc_pmm_init(ram_base: u64, ram_size: u64, reserved_end: u64, heap_start: u64) -> bool

@section(".text.entry")
@naked
fn _start():
    asm volatile:
        "mv      s0, a0"
        "mv      s1, a1"
        "la      sp, _stack_top"
        "la      t0, _sbss"
        "la      t1, _ebss"
        ".Lrv64_bss_loop:"
        "bgeu    t0, t1, .Lrv64_bss_done"
        "sd      zero, 0(t0)"
        "addi    t0, t0, 8"
        "j       .Lrv64_bss_loop"
        ".Lrv64_bss_done:"
        "mv      a0, s0"
        "mv      a1, s1"
        "call    os__kernel__arch__riscv64__boot__boot_main"
        ".Lrv64_boot_halt:"
        "wfi"
        "j       .Lrv64_boot_halt"

fn _uart_put(byte: u64):
    rt_riscv_uart_put(byte)

fn _boot_banner():
    _uart_put(83)
    _uart_put(105)
    _uart_put(109)
    _uart_put(112)
    _uart_put(108)
    _uart_put(101)
    _uart_put(79)
    _uart_put(83)
    _uart_put(32)
    _uart_put(82)
    _uart_put(86)
    _uart_put(54)
    _uart_put(52)
    _uart_put(13)
    _uart_put(10)

fn boot_main(hart_id: u64, dtb_addr: u64):
    _boot_banner()
    riscv_noalloc_log_init()
    riscv_noalloc_handoff(hart_id, dtb_addr)
    rt_riscv_noalloc_pmm_init(
        rt_riscv_qemu_ram_base(),
        rt_riscv_qemu_ram_size(),
        rt_riscv_qemu_reserved_end(),
        rt_riscv_qemu_heap_start()
    )
    riscv_noalloc_heap_init(rt_riscv_qemu_heap_start(), rt_riscv_qemu_heap_size())
    riscv_noalloc_services_init(true)
    log_raw_println(riscv64_hardening_boot_canary_marker())
    val sandbox_boot_write_count = sandbox_boot_apply_embedded_riscv64()
    if sandbox_boot_write_count > 0:
        log_raw_println("[SECURITY] RISC-V sandbox PMP boot plan installed")
    riscv_noalloc_log_boot_ok()
    os_main()
    riscv_noalloc_boot_idle()
