class HostedScenario:
    scenario_name: text
    arch: text
    machine_type: text
    cpu_model: text
    memory_mb: int

    me is_rv64() -> bool:
        return self.arch == "rv64"

    me to_text() -> text:
        return "scenario:" + self.scenario_name + " arch=" + self.arch + " machine=" + self.machine_type + " mem=" + self.memory_mb.to_text() + "MB"

    me with_memory(mb: int) -> HostedScenario:
        return HostedScenario(scenario_name: self.scenario_name, arch: self.arch, machine_type: self.machine_type, cpu_model: self.cpu_model, memory_mb: mb)

    static fn default_rv64() -> HostedScenario:
        return HostedScenario(scenario_name: "rv64-hosted", arch: "rv64", machine_type: "virt", cpu_model: "rv64", memory_mb: 256)


class TargetRegistration:
    target_triple: text
    is_hosted: bool
    boot_mode: text
    kernel_path: text

    me is_hosted_mode() -> bool:
        return self.boot_mode == "hosted"

    me is_baremetal() -> bool:
        return self.boot_mode == "baremetal"

    me to_text() -> text:
        return "target:" + self.target_triple + " mode=" + self.boot_mode

    static fn hosted(triple: text, kpath: text) -> TargetRegistration:
        return TargetRegistration(target_triple: triple, is_hosted: true, boot_mode: "hosted", kernel_path: kpath)

    static fn baremetal(triple: text, kpath: text) -> TargetRegistration:
        return TargetRegistration(target_triple: triple, is_hosted: false, boot_mode: "baremetal", kernel_path: kpath)


class ScenarioConfig:
    scenario: HostedScenario
    registration: TargetRegistration
    is_valid: bool
    config_version: int

    me is_ready() -> bool:
        return self.is_valid and self.registration.is_hosted_mode()

    me validate() -> ScenarioConfig:
        val valid = self.scenario.memory_mb > 0 and self.registration.target_triple != ""
        return ScenarioConfig(scenario: self.scenario, registration: self.registration, is_valid: valid, config_version: self.config_version)

    me to_text() -> text:
        return self.scenario.to_text() + " | " + self.registration.to_text()

    static fn create(s: HostedScenario, r: TargetRegistration) -> ScenarioConfig:
        return ScenarioConfig(scenario: s, registration: r, is_valid: false, config_version: 1)


class ScenarioReport:
    config: ScenarioConfig
    status: text
    message: text
    check_count: int

    me is_pending() -> bool:
        return self.status == "pending"

    me mark_ready() -> ScenarioReport:
        return ScenarioReport(config: self.config, status: "ready", message: self.message, check_count: self.check_count)

    me mark_failed(msg: text) -> ScenarioReport:
        return ScenarioReport(config: self.config, status: "failed", message: msg, check_count: self.check_count)

    me to_text() -> text:
        return "report: " + self.status + " checks=" + self.check_count.to_text()

    static fn create(cfg: ScenarioConfig) -> ScenarioReport:
        return ScenarioReport(config: cfg, status: "pending", message: "", check_count: 0)
