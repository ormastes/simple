# Hardware board manifest for RISC-V 64 FPGA platform.
#
# Provides compile-time default configuration for a VexRiscv-SMP / Rocket
# softcore on Kria K26 (XCZU5EV) ML Carrier Card. No file I/O — pure constants for
# early boot before any filesystem is available.

struct BoardConfig:
    board_id:    text
    reset_pc:    u64
    ram_base:    u64
    ram_size:    u64
    uart_base:   u64
    uart_baud:   u64
    timer_base:  u64
    plic_base:   u64
    hart_count:  u64
    timebase_hz: u64

fn default_board_config() -> BoardConfig:
    """Compile-time constant config for xck26-ml-carrier (fallback if no SDN)."""
    BoardConfig {
        board_id:    "xck26-ml-carrier",
        reset_pc:    0x80000000,
        ram_base:    0x80000000,
        ram_size:    0x04000000,
        uart_base:   0x10000000,
        uart_baud:   115200,
        timer_base:  0x02000000,
        plic_base:   0x0C000000,
        hart_count:  1,
        timebase_hz: 10000000
    }

fn load_board_config() -> BoardConfig:
    """Production entry: returns default_board_config() until filesystem is available."""
    default_board_config()
