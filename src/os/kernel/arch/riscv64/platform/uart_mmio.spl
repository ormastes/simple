# FPGA platform UART driver — manifest-aware wrapper over uart16550_mmio.
#
# Delegates register access to os.kernel.boot.uart16550_mmio.  Does not
# duplicate register constants.  All functions are noalloc-safe (no heap
# allocation).

use os.kernel.boot.uart16550_mmio.{
    uart16550_mmio_init,
    uart16550_mmio_write_byte,
    uart16550_mmio_read_byte
}
use os.kernel.boot.mmio.{mmio_write8}

# 16550 register offsets (referenced only for baud-divisor programming)
val _UART_IER: u64 = 0x01
val _UART_LCR: u64 = 0x03
val _UART_DLL: u64 = 0x00
val _UART_DLH: u64 = 0x01
val _UART_FCR: u64 = 0x02
val _UART_MCR: u64 = 0x04

val _UART_LCR_DLAB: u8   = 0x80
val _UART_LCR_8N1: u8    = 0x03
val _UART_FCR_RESET: u8  = 0xC7
val _UART_MCR_DTR: u8    = 0x0B

fn uart_mmio_init(base: u64, baud: u64):
    """Initialize NS16550-compatible UART at base address for the given baud rate.

    When baud matches the uart16550_mmio_init default (115200) the shared
    initialiser is used directly.  For other rates the divisor is computed
    from the FPGA UART input clock (assumed 1.8432 MHz, divisor = clock /
    (baud * 16)) and programmed via DLAB.
    """
    if baud == 115200:
        uart16550_mmio_init(base)
        return
    # Compute baud divisor: UART clock assumed 1843200 Hz (standard 16x)
    val divisor = 1843200 / (baud * 16)
    val dll = (divisor & 0xFF) as u8
    val dlh = ((divisor >> 8) & 0xFF) as u8
    mmio_write8(base + _UART_IER, 0x00)
    mmio_write8(base + _UART_LCR, _UART_LCR_DLAB)
    mmio_write8(base + _UART_DLL, dll)
    mmio_write8(base + _UART_DLH, dlh)
    mmio_write8(base + _UART_LCR, _UART_LCR_8N1)
    mmio_write8(base + _UART_FCR, _UART_FCR_RESET)
    mmio_write8(base + _UART_MCR, _UART_MCR_DTR)

fn uart_mmio_putchar(base: u64, ch: u8):
    """Write single byte, blocking until TX holding register is empty."""
    uart16550_mmio_write_byte(base, ch)

fn uart_mmio_getchar(base: u64) -> u8?:
    """Read single byte if RX data ready; nil otherwise."""
    uart16550_mmio_read_byte(base)

fn uart_mmio_puts(base: u64, msg: text):
    """Write string byte-by-byte to UART (noalloc-safe)."""
    for i in 0..msg.len():
        val ch = msg.char_at(i)
        uart16550_mmio_write_byte(base, ch as u8)

fn uart_mmio_puts_hex(base: u64, label: text, val_: u64):
    """Write 'label=0xVALUE\\n' for boot diagnostics."""
    uart_mmio_puts(base, label)
    uart_mmio_puts(base, "=0x")
    var shift: i64 = 60
    while shift >= 0:
        val nibble = ((val_ >> (shift as u64)) & 0x0F) as u8
        val ch: u8 = if nibble < 10: (0x30 + nibble) as u8 else: (0x57 + nibble) as u8
        uart16550_mmio_write_byte(base, ch)
        shift = shift - 4
    uart16550_mmio_write_byte(base, 0x0A)
