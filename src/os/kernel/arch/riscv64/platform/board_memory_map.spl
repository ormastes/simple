# RiscvBoardMemoryMap — trait contract for platform-dependent address constants.
#
# This trait defines the memory layout interface for RISC-V FPGA/QEMU boards.
# Concrete implementations are free-function modules (e.g. kria_memory_map.spl,
# litex_memory_map.spl) that export prefixed functions matching this contract.
#
# NOTE: class X: Trait header conformance is not used here — Simple baremetal
# code uses module-level free functions. Each board module exports functions
# with the board prefix (kria_*, litex_*) returning function-local hex vals.
# Dynamic dispatch through a stored trait object is avoided in M-mode baremetal
# because module-level vars are zeroed by BSS clearing before runtime-init.

trait RiscvBoardMemoryMap:
    """Address layout contract for a RISC-V FPGA or QEMU target board.

    Each method returns a physical address or size as u64.
    Implementations MUST use function-local val with hex literals so that
    BSS clearing does not zero the constants before they are read.
    """
    fn uart_base() -> u64
    fn ram_base() -> u64
    fn ram_size() -> u64
    fn heap_start() -> u64
    fn heap_size() -> u64
    fn clint_base() -> u64
    fn plic_base() -> u64
    fn board_name() -> text
