# Top-level FPGA platform capsule for RISC-V 64.
#
# Loads board configuration, initializes UART and CLINT timer, and
# provides a typed platform handle.  No SBI, DTB, or virtio assumptions —
# pure FPGA baremetal.

use os.kernel.arch.riscv64.platform.manifest.{BoardConfig, load_board_config}
use os.kernel.arch.riscv64.platform.uart_mmio.{uart_mmio_init, uart_mmio_puts}
use os.kernel.arch.riscv64.platform.timer_mmio.{timer_mmio_init}

struct FpgaPlatform:
    config: BoardConfig

fn fpga_platform_init() -> FpgaPlatform:
    """Load default board config, initialize UART and timer, return platform handle."""
    val cfg = load_board_config()
    uart_mmio_init(cfg.uart_base, cfg.uart_baud)
    timer_mmio_init(cfg.timer_base)
    uart_mmio_puts(cfg.uart_base, "SIMPLE-RV64-FPGA-BOOT entry\r\n")
    FpgaPlatform { config: cfg }

fn fpga_platform_probe() -> BoardConfig:
    """Return the compile-time board configuration."""
    load_board_config()
