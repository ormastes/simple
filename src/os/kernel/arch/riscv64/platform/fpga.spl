# Top-level FPGA platform capsule for RISC-V 64.
#
# Noalloc-safe platform init for M-mode baremetal.
# Uses rt_riscv_uart_put directly — module-level vals in uart16550_mmio
# are zero in baremetal (no static constructors), so the shared UART
# driver's busy-wait reads wrong registers.

extern fn rt_riscv_uart_put(byte: u64)

fn _put(byte: u64):
    rt_riscv_uart_put(byte)

fn _platform_banner():
    _put(80)   # P
    _put(76)   # L
    _put(65)   # A
    _put(84)   # T
    _put(32)   # space
    _put(79)   # O
    _put(75)   # K
    _put(13)
    _put(10)

fn fpga_platform_init():
    """Noalloc-safe platform init for K26 FPGA."""
    _platform_banner()
