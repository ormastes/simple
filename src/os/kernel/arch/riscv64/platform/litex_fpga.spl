# LiteX FPGA platform capsule for DE10-Nano / LiteX softcore targets.
#
# Noalloc-safe platform init for M-mode baremetal on LiteX.
# Uses rt_riscv_uart_put directly — LiteX UART at 0xf0001000.
# Composes LitexFpgaMemoryMap address constants (function-local hex vals).

use os.kernel.arch.riscv64.platform.litex_memory_map.{litex_uart_base, litex_board_name}

extern fn rt_riscv_uart_put(byte: u64)

fn _litex_put(byte: u64):
    rt_riscv_uart_put(byte)

fn _litex_crlf():
    _litex_put(13)
    _litex_put(10)

fn _litex_platform_banner():
    _litex_put(76)   # L
    _litex_put(73)   # I
    _litex_put(84)   # T
    _litex_put(69)   # E
    _litex_put(88)   # X
    _litex_put(32)   # space
    _litex_put(79)   # O
    _litex_put(75)   # K
    _litex_crlf()

fn litex_platform_init():
    """Noalloc-safe platform init for DE10-Nano / LiteX FPGA."""
    _litex_platform_banner()

fn litex_fpga_platform_init():
    """Compatibility wrapper for the named LiteX FPGA platform API."""
    litex_platform_init()

fn litex_fpga_uart_put(byte: u64):
    """Compatibility wrapper for UART output on LiteX FPGA."""
    _litex_put(byte)

fn litex_fpga_timer_init():
    """Timer init placeholder for the current noalloc LiteX platform."""
    pass

fn litex_fpga_platform_name() -> text:
    """Return the LiteX FPGA platform identifier."""
    litex_board_name()
