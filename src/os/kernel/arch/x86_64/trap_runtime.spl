# x86_64 Trap Runtime Bundle
#
# Owns the kernel runtime objects needed to dispatch traps/syscalls and to
# schedule user tasks on baremetal. This mirrors the RV64 trap-runtime bundle
# so the x86_64 bootstrap path can install one object instead of threading
# separate globals through every entrypoint.

use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.ipc.ipc.{IpcManager}
use os.kernel.log.klog.{KernelLog}

struct X86TrapRuntime:
    scheduler: Scheduler
    ipc: IpcManager
    klog: KernelLog

impl X86TrapRuntime:
    static fn new(scheduler: Scheduler, ipc: IpcManager, klog: KernelLog) -> X86TrapRuntime:
        X86TrapRuntime(
            scheduler: scheduler,
            ipc: ipc,
            klog: klog
        )

    static fn bootstrap(log_capacity: u64) -> X86TrapRuntime:
        """Create the minimal early-boot runtime bundle for x86_64."""
        X86TrapRuntime(
            scheduler: Scheduler.new(),
            ipc: IpcManager.new(),
            klog: KernelLog.new(log_capacity)
        )
