# x86_64 User Entry Validation
#
# Pure validation for the syscall-14 handoff state. This module deliberately
# avoids importing the architecture enter bridge so hosted specs can exercise
# the handoff contract without executing or linking the ring transition path.

use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.types.task_types.{TaskContext}

pub struct X86UserEntryHandoffValidation:
    ok: bool
    error: text
    pid: u64
    context: TaskContext?
    cr3: u64

pub fn validate_enter_user_blocking_handoff(pid_hint: u64, scheduler: Scheduler) -> X86UserEntryHandoffValidation:
    """Validate syscall-14 handoff state without executing the ring transition."""
    var sched = scheduler

    val tcb = sched.get_user_handoff_task(pid_hint)
    if tcb == nil:
        return X86UserEntryHandoffValidation(
            ok: false,
            error: "handoff task not found",
            pid: pid_hint,
            context: nil,
            cr3: 0u64
        )

    val task = tcb
    val target_pid = task.id.id
    if not task.is_user:
        return X86UserEntryHandoffValidation(
            ok: false,
            error: "task is not a user task",
            pid: target_pid,
            context: nil,
            cr3: task.address_space
        )

    val uctx = task.user_context
    if uctx == nil:
        return X86UserEntryHandoffValidation(
            ok: false,
            error: "task has no user_context",
            pid: target_pid,
            context: nil,
            cr3: task.address_space
        )

    X86UserEntryHandoffValidation(
        ok: true,
        error: "",
        pid: target_pid,
        context: uctx,
        cr3: task.address_space
    )
