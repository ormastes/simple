# x86_64 User Entry Bridge
#
# Owns the ring-3 handoff path so the architecture-neutral syscall dispatcher
# does not pull x86 context-switch code into other kernel targets.

use os.kernel.arch.x86_64.context.{arch_x86_64_enter_user_task}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.types.task_types.{TaskId}

extern fn serial_println(msg: text)

fn dispatch_enter_user_blocking(pid_hint: u64, scheduler: Scheduler) -> i64:
    """Syscall 14: EnterUserBlocking — look up a user TCB and jump to ring-3."""
    serial_println("[syscall14] dispatch_enter_user_blocking enter")
    var sched = scheduler

    val tcb = sched.get_user_handoff_task(pid_hint)
    if tcb == nil:
        serial_println("[syscall14] handoff task not found pid_hint={pid_hint}")
        return -22

    val task = tcb
    val target_pid = task.id.id
    if not task.is_user:
        serial_println("[syscall14] task is not a user task pid={target_pid}")
        return -22

    val uctx = task.user_context
    if uctx == nil:
        serial_println("[syscall14] task has no user_context pid={target_pid}")
        return -22

    val ctx = uctx.unwrap()
    val cr3 = task.address_space
    serial_println("[syscall14] entering ring-3 pid={target_pid} rip={ctx.rip} cr3={cr3}")
    arch_x86_64_enter_user_task(ctx, cr3)
    -22
