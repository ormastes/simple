# x86_64 User Entry Bridge
#
# Owns the ring-3 handoff path so the architecture-neutral syscall dispatcher
# does not pull x86 context-switch code into other kernel targets.

use os.kernel.arch.x86_64.context.{arch_x86_64_enter_user_task}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.types.task_types.{TaskContext}
use os.kernel.arch.x86_64.user_entry_validation.{validate_enter_user_blocking_handoff}

fn dispatch_enter_user_blocking(pid_hint: u64, scheduler: Scheduler) -> i64:
    """Syscall 14: EnterUserBlocking — look up a user TCB and jump to ring-3."""
    val validation = validate_enter_user_blocking_handoff(pid_hint, scheduler)
    if not validation.ok:
        return -22

    val ctx: TaskContext = validation.context.unwrap()
    arch_x86_64_enter_user_task(ctx, validation.cr3)
    -22
