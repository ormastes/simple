# x86_64 User Entry Bridge
#
# Owns the ring-3 handoff path so the architecture-neutral syscall dispatcher
# does not pull x86 context-switch code into other kernel targets.

use os.kernel.arch.x86_64.context.{arch_x86_64_enter_user_task}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.types.task_types.{TaskId, TaskContext}

use os.kernel.log.klog_api.{log_raw_println}

pub struct X86UserEntryHandoffValidation:
    ok: bool
    error: text
    pid: u64
    context: TaskContext?
    cr3: u64

pub fn validate_enter_user_blocking_handoff(pid_hint: u64, scheduler: Scheduler) -> X86UserEntryHandoffValidation:
    """Validate syscall-14 handoff state without executing the ring transition."""
    var sched = scheduler

    val tcb = sched.get_user_handoff_task(pid_hint)
    if tcb == nil:
        return X86UserEntryHandoffValidation(
            ok: false,
            error: "handoff task not found",
            pid: pid_hint,
            context: nil,
            cr3: 0u64
        )

    val task = tcb.unwrap()
    val target_pid = task.id.id
    if not task.is_user:
        return X86UserEntryHandoffValidation(
            ok: false,
            error: "task is not a user task",
            pid: target_pid,
            context: nil,
            cr3: task.address_space
        )

    val uctx = task.user_context
    if uctx == nil:
        return X86UserEntryHandoffValidation(
            ok: false,
            error: "task has no user_context",
            pid: target_pid,
            context: nil,
            cr3: task.address_space
        )

    X86UserEntryHandoffValidation(
        ok: true,
        error: "",
        pid: target_pid,
        context: uctx,
        cr3: task.address_space
    )

fn dispatch_enter_user_blocking(pid_hint: u64, scheduler: Scheduler) -> i64:
    """Syscall 14: EnterUserBlocking — look up a user TCB and jump to ring-3."""
    log_raw_println("[syscall14] dispatch_enter_user_blocking enter")

    val validation = validate_enter_user_blocking_handoff(pid_hint, scheduler)
    if not validation.ok:
        log_raw_println("[syscall14] {validation.error} pid_hint={pid_hint} pid={validation.pid}")
        return -22

    val ctx: TaskContext = validation.context.unwrap()
    log_raw_println("[syscall14] entering ring-3 pid={validation.pid} rip={ctx.rip} cr3={validation.cr3}")
    arch_x86_64_enter_user_task(ctx, validation.cr3)
    -22
