# x86_64 Serial Console — COM1 via Port I/O
#
# Implements early serial output over x86 I/O ports.
# COM1 at 0x3F8, 115200 baud, 8N1 configuration.
#
# This is the x86_64-specific console implementation.
# Other architectures use MMIO-based UARTs instead.

use os.kernel.arch.x86.com1_common.{X86_COM1_BASE, x86_com1_init, x86_com1_write_byte, x86_com1_write, x86_com1_writeln}

# ============================================================================
# X86Console
# ============================================================================

struct X86Console:
    """x86_64 serial console via COM1 port I/O.

    Provides early debug output before framebuffer or full terminal
    drivers are available. Uses legacy x86 I/O port instructions
    (in/out) at the standard COM1 address 0x3F8.
    """
    pass_dn

var g_serial_ready: bool = false

impl X86Console:
    fn init():
        """Initialize COM1 serial port at 115200 baud, 8N1."""
        if g_serial_ready:
            return

        g_serial_ready = x86_com1_init(g_serial_ready)

    fn write_byte(byte: u8):
        """Write one byte to COM1, blocking until transmit ready."""
        x86_com1_write_byte(byte)

    fn write(msg: text):
        """Write string to serial console."""
        if not g_serial_ready:
            self.init()
        x86_com1_write(msg)

    fn writeln(msg: text):
        """Write string followed by CR+LF to serial console."""
        if not g_serial_ready:
            self.init()
        x86_com1_writeln(msg)

    fn base_port() -> u16:
        """Return the base I/O port address for this console."""
        X86_COM1_BASE

# ============================================================================
# Module-Level Convenience Functions
# ============================================================================

fn serial_init():
    """Initialize COM1 serial port (module-level convenience)."""
    var console = X86Console()
    console.init()

fn serial_write_byte(byte: u8):
    """Write one byte to COM1 (module-level convenience)."""
    val console = X86Console()
    console.write_byte(byte)

fn serial_write(msg: text):
    """Write string to COM1 (module-level convenience)."""
    val console = X86Console()
    console.write(msg)

fn serial_writeln(msg: text):
    """Write string + newline to COM1 (module-level convenience)."""
    val console = X86Console()
    console.writeln(msg)
