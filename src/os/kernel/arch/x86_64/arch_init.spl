# x86_64 early arch initialisation — Wave 7C
#
# Single call-site: invoke arch_x86_64_early_init() as the FIRST thing in
# every kernel entry point (os_main, desktop_e2e_main, future entries).
# Idempotent by design so duplicate calls from different entry paths are safe.
#
# Strategy: patch crt0's _fault_handler in-memory with a jmp rel32 to
# _rich_fault_entry (C, baremetal_stubs.c). All 256 IDT vectors already point
# at _fault_handler, so one 5-byte patch upgrades ALL fault output instantly.
# _rich_fault_entry is a proper naked ISR stub (iretq recovery) so recoverable
# faults continue normally after printing the rich frame.

# rt_install_rich_fault_hook — C helper in baremetal_stubs.c.
# Overwrites the first 5 bytes of crt0's _fault_handler with jmp rel32
# to _rich_fault_entry. Heap-free, no IDT reload needed.
extern fn rt_install_rich_fault_hook()

extern fn serial_println(msg: text)

# Use u64 sentinel — bool=false stores as 0x3 (NIL tag) which is non-zero,
# causing the idempotency guard to fire prematurely. u64=0 is truly zero.
var _arch_init_count: u64 = 0

fn arch_x86_64_early_init():
    """Perform one-time x86_64 early arch init: install rich fault hook.

    Patches crt0's _fault_handler with a jmp to _rich_fault_entry so all
    256 IDT vectors produce full register frames instead of terse FAULT@.
    _rich_fault_entry uses iretq so recoverable faults continue normally.

    Idempotent — subsequent calls return immediately without re-running.
    Must be called BEFORE any code that can fault (memory, drivers, etc.).
    """
    if _arch_init_count > 0:
        return
    _arch_init_count = 1

    serial_println("[arch-init] installing rich fault hook")
    # Patch _fault_handler -> _rich_fault_entry: 5-byte jmp rel32.
    # All 256 IDT vectors point at _fault_handler, so this upgrades
    # ALL fault output without touching crt0.s or the IDT.
    rt_install_rich_fault_hook()
    serial_println("[arch-init] rich fault hook installed")
