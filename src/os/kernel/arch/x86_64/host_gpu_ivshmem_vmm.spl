use common.gpu.simpleos_host_gpu_protocol.{SIMPLEOS_HOST_GPU_REGION_BYTES}
use os.kernel.ipc.host_gpu_ivshmem_map.{map_qemu_host_gpu_ivshmem_bar2, qemu_host_gpu_ivshmem_window_base}
use os.kernel.memory.vmm.{PAGE_SIZE, vmm_map_page, vmm_unmap_page}
use os.kernel.types.memory_types.{PhysAddr, VirtAddr, VmFlags}

fn map_qemu_host_gpu_ivshmem_bar2_active_vmm() -> u64:
    val base = qemu_host_gpu_ivshmem_window_base(map_qemu_host_gpu_ivshmem_bar2())
    if base == 0u64:
        return 0u64
    var offset: u64 = 0u64
    while offset < SIMPLEOS_HOST_GPU_REGION_BYTES.to_u64():
        if not vmm_map_page(VirtAddr(addr: base + offset), PhysAddr(addr: base + offset), VmFlags.mmio()):
            var rollback: u64 = 0u64
            while rollback < offset:
                val _unmapped = vmm_unmap_page(VirtAddr(addr: base + rollback))
                rollback = rollback + PAGE_SIZE
            return 0u64
        offset = offset + PAGE_SIZE
    base

export map_qemu_host_gpu_ivshmem_bar2_active_vmm
