# x86_64 Timer HAL — APIC Timer / PIT / TSC
#
# Timer subsystem for the x86_64 kernel.
# x86_64 provides multiple timer sources:
#   - Local APIC timer (preferred, per-CPU) — used for periodic scheduling
#   - PIT (8254, legacy fallback) — used for APIC calibration
#   - TSC (timestamp counter) — used for fine-grained measurement
#
# The APIC timer is the primary timer. PIT channel 2 is used only during
# calibration (done in apic.spl). TSC provides high-resolution ticks.
#
# Delegates to existing modules:
#   - os.kernel.interrupts.apic  (APIC timer init, periodic, one-shot, stop)
#   - std.baremetal.x86.io       (PIT port I/O for direct PIT mode)

use os.kernel.interrupts.apic.{apic_init, apic_set_timer, apic_stop_timer,
    apic_calibrated_ticks_per_ms, apic_write, apic_read,
    APIC_REG_TIMER_LVT, APIC_REG_TIMER_INIT, APIC_REG_TIMER_CURRENT,
    APIC_REG_TIMER_DIV, TIMER_PERIODIC, TIMER_ONE_SHOT, TIMER_MASKED,
    TIMER_DIV_16}
use os.kernel.interrupts.idt.{VEC_TIMER}
use std.baremetal.x86.io.{outb, inb, io_wait}
use os.kernel.acpi.clock_sources.{acpi_hpet_present, acpi_pmtmr_port,
    acpi_set_rsdp, PMTMR_FREQ, pmtmr_read, hpet_read_counter,
    hpet_read_capabilities, hpet_enable}

# ============================================================================
# Constants
# ============================================================================

# PIT (8254) I/O ports
val PIT_CHANNEL0_DATA: i32 = 0x40
val PIT_CHANNEL2_DATA: i32 = 0x42
val PIT_COMMAND: i32        = 0x43

# PIT base frequency: 1,193,182 Hz
val PIT_FREQUENCY: u64 = 1193182

# PIT command bytes
val PIT_CMD_CH0_PERIODIC: i32 = 0x36   # Channel 0, lobyte/hibyte, mode 3 (square wave)
val PIT_CMD_CH0_ONESHOT: i32  = 0x30   # Channel 0, lobyte/hibyte, mode 0 (one-shot)

# PIC master data port for IRQ 0 masking
val PIC1_DATA: i32 = 0x21

# ============================================================================
# Module State
# ============================================================================

# TSC frequency (ticks per second), calibrated at init
var tsc_frequency: u64 = 0

# TSC value at init time (for elapsed computation)
var tsc_at_init: u64 = 0

# ============================================================================
# X86Timer
# ============================================================================

struct X86Timer:
    """x86_64 timer management (APIC timer / PIT / TSC).

    Uses APIC timer as primary source for periodic scheduling interrupts.
    PIT channel 2 is used during calibration (handled by apic.spl).
    TSC provides high-resolution tick counting.
    """
    pass_dn

impl X86Timer:
    fn init():
        """Initialize timer hardware.

        Delegates APIC timer calibration to apic_init() which uses PIT
        channel 2 to measure the APIC timer frequency. Also calibrates
        TSC frequency by measuring TSC ticks over a known PIT interval.
        """
        # APIC init (includes PIC disable + APIC timer calibration via PIT ch2)
        apic_init()

        # Calibrate TSC: measure TSC ticks over ~10ms using PIT channel 2
        tsc_at_init = _read_tsc()
        _calibrate_tsc()

    fn set_periodic(interval_us: u64):
        """Set timer to fire periodically at the given interval (microseconds).

        Configures the APIC timer in periodic mode. The timer vector is
        VEC_TIMER (32), which routes to the IDT handler table.
        """
        if interval_us == 0:
            return
        # Convert microseconds to Hz: hz = 1_000_000 / interval_us
        val hz = 1000000 / interval_us
        # Minimum 1 Hz to avoid divide-by-zero in apic_set_timer
        val effective_hz = if hz == 0: 1 else: hz
        apic_set_timer(effective_hz as u32)

    fn set_oneshot(delay_us: u64):
        """Set timer for a one-shot firing after the given delay (microseconds).

        Configures the APIC timer in one-shot mode. When the count reaches
        zero, a single interrupt fires on VEC_TIMER.
        """
        if delay_us == 0:
            return
        # Calculate ticks: calibrated_ticks_per_ms * delay_us / 1000
        var ticks_per_ms = apic_calibrated_ticks_per_ms as u64
        if ticks_per_ms == 0:
            ticks_per_ms = 1000000  # fallback ~1 GHz bus

        val ticks = ticks_per_ms * delay_us / 1000

        # Set divider
        apic_write(APIC_REG_TIMER_DIV, TIMER_DIV_16)

        # Configure Timer LVT: one-shot mode, mapped to VEC_TIMER
        val lvt_value = TIMER_ONE_SHOT | (VEC_TIMER as u32)
        apic_write(APIC_REG_TIMER_LVT, lvt_value)

        # Set initial count — timer starts counting down immediately
        apic_write(APIC_REG_TIMER_INIT, ticks as u32)

    fn stop():
        """Stop the current timer (mask APIC timer LVT and zero count)."""
        apic_stop_timer()

    fn current_ticks() -> u64:
        """Read current tick count via the x86 TSC (RDTSC instruction).

        Returns the 64-bit Time Stamp Counter value. TSC increments at
        a fixed rate on modern CPUs (invariant TSC).
        """
        _read_tsc()

    fn ticks_per_second() -> u64:
        """Return calibrated TSC frequency in ticks per second.

        If TSC calibration has not been performed, returns a fallback
        estimate based on the APIC timer calibration.
        """
        if tsc_frequency > 0:
            return tsc_frequency
        # Fallback: derive from APIC calibration (ticks_per_ms * 1000)
        # The APIC runs at bus frequency; TSC is typically faster, but
        # this gives a reasonable approximation.
        val apic_tps = (apic_calibrated_ticks_per_ms as u64) * 1000
        if apic_tps > 0:
            return apic_tps
        # Last resort: assume 1 GHz
        1000000000

    fn elapsed_us() -> u64:
        """Return microseconds elapsed since timer init.

        Computed from TSC delta and calibrated TSC frequency.
        """
        val now = _read_tsc()
        val delta = now - tsc_at_init
        val freq = tsc_frequency
        if freq == 0:
            return 0
        # delta * 1_000_000 / freq
        # To avoid overflow on large deltas, divide first then correct:
        val seconds = delta / freq
        val remainder = delta - (seconds * freq)
        (seconds * 1000000) + (remainder * 1000000 / freq)

# ============================================================================
# rt_time_now_ns — C-ABI export for bench harness and Simple runtime
# ============================================================================

@export("C", name: "rt_time_now_ns")
fn rt_time_now_ns() -> i64:
    """Return monotonic nanoseconds since timer init (TSC-based).

    Calibration math: TSC ticks → ns
      sec      = delta / tsc_frequency
      rem      = delta % tsc_frequency
      ns       = sec * 1_000_000_000 + rem * 1_000_000_000 / tsc_frequency

    Overflow-safe: at 4 GHz TSC, delta/tsc_frequency divides out the
    large part before the ×1e9 multiply, keeping rem < tsc_frequency.
    """
    if tsc_frequency == 0:
        return 0
    val now = _read_tsc()
    val delta = now - tsc_at_init
    val freq = tsc_frequency
    val sec = (delta / freq) as i64
    val rem = (delta - (delta / freq * freq)) as i64
    sec * 1000000000 + rem * 1000000000 / (freq as i64)

# ============================================================================
# TSC Read — RDTSC instruction
# ============================================================================

fn _read_tsc() -> u64:
    """Read the 64-bit Time Stamp Counter via RDTSC.
    Returns EDX:EAX combined into a single u64."""
    var lo: u64 = 0
    var hi: u64 = 0
    asm """
        rdtsc
        mov {lo}, rax
        mov {hi}, rdx
    """
    (hi << 32) | (lo & 0xFFFFFFFF)

# ============================================================================
# Clock source selection — HPET → PMTMR → PIT fallback chain
# FR-BENCH-CLOCK-002
# ============================================================================

# Clock source names (returned by _choose_clock_source)
val CLOCK_SRC_HPET:  str = "HPET"
val CLOCK_SRC_PMTMR: str = "PMTMR"
val CLOCK_SRC_PIT:   str = "PIT"

fn _choose_clock_source(hpet_base: u64?, pmtmr_port: u32?) -> str:
    """Return the best available TSC calibration reference source.

    Priority: HPET (MMIO, ~100 MHz) > PMTMR (port I/O, 3.58 MHz) > PIT ch2.
    Takes pre-discovered values so callers (including tests) can pass fixtures.
    """
    if hpet_base != nil:
        return CLOCK_SRC_HPET
    if pmtmr_port != nil:
        return CLOCK_SRC_PMTMR
    CLOCK_SRC_PIT

# ============================================================================
# TSC Calibration
# ============================================================================

fn _calibrate_tsc():
    """Calibrate TSC frequency.

    Probe order (FR-BENCH-CLOCK-002): HPET → PMTMR → PIT channel 2.

    HPET and PMTMR branches are structurally wired but functionally no-ops
    until FR-SIMPLEOS-ACPI-001 (ACPI table walk) is implemented — both
    acpi_hpet_present() and acpi_pmtmr_port() return nil until then.
    PIT ch2 path is unchanged from FR-BENCH-CLOCK-001.
    """
    val hpet_base  = acpi_hpet_present()
    val pmtmr_prt  = acpi_pmtmr_port()
    val src        = _choose_clock_source(hpet_base, pmtmr_prt)

    if src == CLOCK_SRC_HPET:
        _calibrate_tsc_hpet(hpet_base as u64)
        return
    if src == CLOCK_SRC_PMTMR:
        _calibrate_tsc_pmtmr(pmtmr_prt as u32)
        return
    _calibrate_tsc_pit()

fn _calibrate_tsc_hpet(hpet_virt: u64):
    """Calibrate TSC using HPET MMIO counter as reference.

    STUB: hpet_virt is always 0 until FR-SIMPLEOS-ACPI-001 provides a real
    HPET MMIO address. When ACPI is available:
    1. Enable HPET counter via hpet_enable().
    2. Read capabilities to get COUNTER_CLK_PERIOD (femtoseconds/tick).
    3. Spin for N HPET ticks (e.g. equivalent of ~10ms).
    4. Compute TSC frequency from TSC delta and elapsed real time.

    Until implemented, falls through to PIT calibration.
    """
    # STUB — ACPI HPET not yet mapped; fall back to PIT
    _calibrate_tsc_pit()

fn _calibrate_tsc_pmtmr(port: u32):
    """Calibrate TSC using PMTMR (3.579545 MHz PM timer) as reference.

    STUB: port is always 0 until FR-SIMPLEOS-ACPI-001 provides a real FADT
    PM_TMR_BLK port. When ACPI is available:
    1. Read PMTMR start value via pmtmr_read(port).
    2. Spin for ~10ms worth of PMTMR ticks (35795 ticks at 3.579545 MHz).
    3. Compute TSC frequency from TSC delta and known PMTMR frequency.

    Until implemented, falls through to PIT calibration.
    """
    # STUB — ACPI PMTMR port not yet discovered; fall back to PIT
    _calibrate_tsc_pit()

fn _calibrate_tsc_pit():
    """Calibrate TSC frequency using PIT channel 2.

    Method:
    1. Program PIT channel 2 for a ~10ms countdown (count = 11932)
    2. Read TSC before and after the PIT expires
    3. Compute TSC frequency = delta_tsc * 100 (since 10ms = 1/100 sec)
    """
    # PIT channel 2 count for ~10ms: 1193182 * 10 / 1000 = 11932
    val pit_count: i32 = 11932

    # Read and configure PIT channel 2 gate (port 0x61)
    var gate = inb(0x61)
    gate = (gate & 0xFD) | 0x01    # Clear bit 1 (gate off), set bit 0

    outb(0x61, gate)

    # PIT channel 2: mode 0 (terminal count), binary, lobyte/hibyte
    outb(PIT_COMMAND, 0xB0)

    # Write count: lobyte then hibyte
    val lo_count = pit_count & 0xFF
    val hi_count = (pit_count >> 8) & 0xFF
    outb(PIT_CHANNEL2_DATA, lo_count)
    outb(PIT_CHANNEL2_DATA, hi_count)

    # Read TSC start
    val tsc_start = _read_tsc()

    # Enable PIT channel 2 gate (set bit 0)
    gate = inb(0x61)
    gate = gate | 0x01
    outb(0x61, gate)

    # Wait for PIT channel 2 output (bit 5 of port 0x61) to go high
    var status = inb(0x61)
    while (status & 0x20) == 0:
        status = inb(0x61)

    # Read TSC end
    val tsc_end = _read_tsc()

    # Compute frequency: delta represents ~10ms, so freq = delta * 100
    val delta = tsc_end - tsc_start
    tsc_frequency = delta * 100

    # Disable PIT channel 2 gate
    gate = inb(0x61)
    gate = gate & 0xFC
    outb(0x61, gate)
