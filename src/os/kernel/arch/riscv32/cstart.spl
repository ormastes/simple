# RISC-V 32 bare-metal cstart bridge.

use os.kernel.arch.arch_context.{BootArgs, JmpBuf}
use os.kernel.arch.hal.{CstartError}
use os.runtime.baremetal.runtime_minimal.{main as baremetal_main, __spl_exit}

fn cstart_init(boot_args: BootArgs) -> Result<i32, CstartError>:
    Result.Ok(baremetal_main(boot_args.argc as i32, boot_args.argv_addr))

fn setjmp(buf: JmpBuf) -> i32:
    match buf:
        JmpBuf.Rv32(_): 0
        case _:
            0

fn longjmp(_buf: JmpBuf, value: i32) -> i32:
    val normalized = if value == 0: 1 else: value
    __spl_exit(normalized)
    -1

fn exit(code: i32) -> i32:
    __spl_exit(code)
    -1
