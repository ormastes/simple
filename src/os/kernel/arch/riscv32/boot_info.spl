# RISC-V 32 Boot Info — Direct QEMU virt Metadata
#
# High-level boot metadata lives here rather than in boot.spl so the freestanding
# entry build stays linkable while tests and HAL code still get a structured boot
# contract.

use os.kernel.types.memory_types.{PhysAddr, VirtAddr}
use os.kernel.boot.ports.{BootOutputPort, BootMemoryRegion, FramebufferInfo, MemoryRegionKind}
use os.kernel.boot.dtb_parser.{DtbDeviceInfo}
use os.kernel.arch.arch_context.{Architecture}

val QEMU_RAM_BASE: u64 = 0x80000000
val QEMU_RAM_SIZE: u64 = 128 * 1024 * 1024
val QEMU_KERNEL_BASE: u64 = 0x80000000
val QEMU_UART_BASE: u64 = 0x10000000
val QEMU_PLIC_BASE: u64 = 0x0C000000
val QEMU_CLINT_BASE: u64 = 0x02000000
val DEFAULT_KERNEL_SIZE: u64 = 4 * 1024 * 1024

struct Rv32Boot:
    """RISC-V 32-bit M-mode boot metadata provider for QEMU virt."""
    direct_boot: bool

var g_hart_id: u32 = 0
var g_dtb_addr: u32 = 0
var g_dtb_info: DtbDeviceInfo = DtbDeviceInfo(
    uart_base: 0, uart_size: 0,
    plic_base: 0, plic_size: 0,
    clint_base: 0, clint_size: 0,
    ram_base: 0, ram_size: 0,
    hart_count: 0, valid: false
)

fn _uart_base() -> u64:
    if g_dtb_info.valid and g_dtb_info.uart_base != 0:
        return g_dtb_info.uart_base
    QEMU_UART_BASE

fn _plic_base() -> u64:
    if g_dtb_info.valid and g_dtb_info.plic_base != 0:
        return g_dtb_info.plic_base
    QEMU_PLIC_BASE

fn _clint_base() -> u64:
    if g_dtb_info.valid and g_dtb_info.clint_base != 0:
        return g_dtb_info.clint_base
    QEMU_CLINT_BASE

fn _ram_base() -> u64:
    if g_dtb_info.valid and g_dtb_info.ram_base != 0:
        return g_dtb_info.ram_base
    QEMU_RAM_BASE

fn _ram_size() -> u64:
    if g_dtb_info.valid and g_dtb_info.ram_size != 0:
        return g_dtb_info.ram_size
    QEMU_RAM_SIZE

fn _save_boot_args(hart_id: u32, dtb_addr: u32):
    g_hart_id = hart_id
    g_dtb_addr = dtb_addr
    g_dtb_info = DtbDeviceInfo(
        uart_base: 0, uart_size: 0,
        plic_base: 0, plic_size: 0,
        clint_base: 0, clint_size: 0,
        ram_base: 0, ram_size: 0,
        hart_count: 0, valid: false
    )

fn _build_memory_map() -> [BootMemoryRegion]:
    var regions: [BootMemoryRegion] = []
    val ram_base = _ram_base()
    val ram_size = _ram_size()
    val kernel_base = QEMU_KERNEL_BASE

    regions.push(BootMemoryRegion(
        base: PhysAddr(addr: kernel_base),
        size: DEFAULT_KERNEL_SIZE,
        kind: MemoryRegionKind.Kernel
    ))

    val usable_start = kernel_base + DEFAULT_KERNEL_SIZE
    val usable_end = ram_base + ram_size
    if usable_end > usable_start:
        regions.push(BootMemoryRegion(
            base: PhysAddr(addr: usable_start),
            size: usable_end - usable_start,
            kind: MemoryRegionKind.Usable
        ))
    regions

fn _build_boot_output() -> BootOutputPort:
    val memory_map = _build_memory_map()
    val framebuffer = FramebufferInfo(
        addr: PhysAddr(addr: 0),
        width: 0,
        height: 0,
        pitch: 0,
        bpp: 0
    )
    BootOutputPort(
        memory_map: memory_map,
        framebuffer: framebuffer,
        rsdp_addr: nil,
        kernel_phys_base: PhysAddr(addr: QEMU_KERNEL_BASE),
        kernel_virt_base: VirtAddr(addr: QEMU_KERNEL_BASE),
        kernel_size: DEFAULT_KERNEL_SIZE,
        serial_base: _uart_base(),
        serial_is_mmio: true,
        arch: Architecture.Riscv32,
        hhdm_offset: 0
    )

fn rv32_boot_save_boot_args(hart_id: u32, dtb_addr: u32):
    _save_boot_args(hart_id, dtb_addr)

fn rv32_boot_parse_boot_info() -> BootOutputPort:
    _build_boot_output()

fn rv32_boot_hart_id() -> u32:
    g_hart_id

fn rv32_boot_dtb_address() -> u32:
    g_dtb_addr

fn rv32_boot_dtb_valid() -> bool:
    g_dtb_info.valid

fn rv32_boot_uart_base() -> u64:
    _uart_base()

fn rv32_boot_ram_base() -> u64:
    _ram_base()

fn rv32_boot_ram_size() -> u64:
    _ram_size()

impl Rv32Boot:
    fn save_boot_params(hart_id: u32, dtb_addr: u32):
        _save_boot_args(hart_id, dtb_addr)

    fn build_boot_output() -> BootOutputPort:
        _build_boot_output()

    fn hart_id() -> u32:
        g_hart_id

    fn dtb_addr() -> u32:
        g_dtb_addr

    fn dtb_valid() -> bool:
        g_dtb_info.valid

    fn kernel_load_addr() -> u64:
        QEMU_KERNEL_BASE

    fn uart_base() -> u64:
        _uart_base()

    fn plic_base() -> u64:
        _plic_base()

    fn clint_base() -> u64:
        _clint_base()

    fn ram_base() -> u64:
        _ram_base()

    fn ram_size() -> u64:
        _ram_size()
