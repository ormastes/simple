# RISC-V 32 Boot Entry — M-Mode Direct Boot (no OpenSBI)
#
# Keep this module freestanding and minimal so `simple os build --arch=riscv32`
# can native-build a real bootable ELF without pulling runtime formatting,
# arrays, or boot metadata construction into the first-stage entry object.
#
# Boot chain: _start → boot_main → noalloc boot services → os_main

use os.kernel.boot.riscv_noalloc_handoff.{riscv_noalloc_handoff, riscv_noalloc_boot_idle}
use os.kernel.boot.riscv_noalloc_heap.{riscv_noalloc_heap_init}
use os.kernel.boot.riscv_noalloc_log.{riscv_noalloc_log_init, riscv_noalloc_log_boot_ok}
use os.kernel.boot.riscv_noalloc_services.{riscv_noalloc_services_init}
use os.kernel.boot.os_main.{os_main}

extern fn rt_riscv_uart_put(byte: u64)
extern fn rt_riscv_qemu_heap_start() -> u64
extern fn rt_riscv_qemu_heap_size() -> u64
extern fn rt_riscv_noalloc_pmm_init_default() -> bool
extern fn rt_rv32_smp_online_count() -> u64
extern fn rt_rv32_boot_optional_nvme_fw_selftest() -> i64

@section(".text.entry")
@naked
fn _start():
    asm volatile:
        "mv      s0, a0"
        "mv      s1, a1"
        # Every hart atomically checks in (rv32imac has the A extension). The
        # counter lives outside [_sbss,_ebss] so hart 0's BSS clear cannot wipe it.
        "la      t2, _smp_online_count"
        "li      t1, 1"
        "amoadd.w zero, t1, (t2)"
        # Only hart 0 runs the primary boot; secondary harts park in WFI so they
        # do not race the BSS clear / heap init.
        "csrr    t0, mhartid"
        "bnez    t0, .Lrv32_secondary_park"
        "la      sp, _stack_top"
        "la      t0, _sbss"
        "la      t1, _ebss"
        ".Lrv32_bss_loop:"
        "bgeu    t0, t1, .Lrv32_bss_done"
        "sw      zero, 0(t0)"
        "addi    t0, t0, 4"
        "j       .Lrv32_bss_loop"
        ".Lrv32_bss_done:"
        "mv      a0, s0"
        "mv      a1, s1"
        "call    os__kernel__arch__riscv32__boot__boot_main"
        ".Lrv32_boot_halt:"
        "wfi"
        "j       .Lrv32_boot_halt"
        ".Lrv32_secondary_park:"
        "wfi"
        "j       .Lrv32_secondary_park"

fn _uart_put(byte: u32):
    rt_riscv_uart_put(byte as u64)

fn _crlf():
    _uart_put(13)
    _uart_put(10)

fn _line_simpleos_rv32():
    _uart_put(83)
    _uart_put(105)
    _uart_put(109)
    _uart_put(112)
    _uart_put(108)
    _uart_put(101)
    _uart_put(79)
    _uart_put(83)
    _uart_put(32)
    _uart_put(82)
    _uart_put(86)
    _uart_put(51)
    _uart_put(50)
    _crlf()

fn _line_uart_initialized():
    _uart_put(91)
    _uart_put(66)
    _uart_put(79)
    _uart_put(79)
    _uart_put(84)
    _uart_put(93)
    _uart_put(32)
    _uart_put(85)
    _uart_put(65)
    _uart_put(82)
    _uart_put(84)
    _uart_put(32)
    _uart_put(105)
    _uart_put(110)
    _uart_put(105)
    _uart_put(116)
    _uart_put(105)
    _uart_put(97)
    _uart_put(108)
    _uart_put(105)
    _uart_put(122)
    _uart_put(101)
    _uart_put(100)
    _crlf()

fn _line_riscv32():
    _uart_put(91)
    _uart_put(66)
    _uart_put(79)
    _uart_put(79)
    _uart_put(84)
    _uart_put(93)
    _uart_put(32)
    _uart_put(82)
    _uart_put(73)
    _uart_put(83)
    _uart_put(67)
    _uart_put(45)
    _uart_put(86)
    _uart_put(32)
    _uart_put(51)
    _uart_put(50)
    _crlf()

fn _line_memory_map():
    _uart_put(91)
    _uart_put(66)
    _uart_put(79)
    _uart_put(79)
    _uart_put(84)
    _uart_put(93)
    _uart_put(32)
    _uart_put(77)
    _uart_put(101)
    _uart_put(109)
    _uart_put(111)
    _uart_put(114)
    _uart_put(121)
    _uart_put(32)
    _uart_put(109)
    _uart_put(97)
    _uart_put(112)
    _uart_put(32)
    _uart_put(112)
    _uart_put(97)
    _uart_put(114)
    _uart_put(115)
    _uart_put(101)
    _uart_put(100)
    _crlf()

fn _line_ram_base():
    _uart_put(91)
    _uart_put(66)
    _uart_put(79)
    _uart_put(79)
    _uart_put(84)
    _uart_put(93)
    _uart_put(32)
    _uart_put(82)
    _uart_put(65)
    _uart_put(77)
    _uart_put(32)
    _uart_put(97)
    _uart_put(116)
    _uart_put(32)
    _uart_put(48)
    _uart_put(120)
    _uart_put(56)
    _uart_put(48)
    _uart_put(48)
    _uart_put(48)
    _uart_put(48)
    _uart_put(48)
    _uart_put(48)
    _uart_put(48)
    _crlf()

fn _line_boot_complete():
    _uart_put(91)
    _uart_put(66)
    _uart_put(79)
    _uart_put(79)
    _uart_put(84)
    _uart_put(93)
    _uart_put(32)
    _uart_put(98)
    _uart_put(111)
    _uart_put(111)
    _uart_put(116)
    _uart_put(32)
    _uart_put(99)
    _uart_put(111)
    _uart_put(109)
    _uart_put(112)
    _uart_put(108)
    _uart_put(101)
    _uart_put(116)
    _uart_put(101)
    _crlf()

# Print "[BOOT] SMP harts: N" — N is the number of harts that checked in via the
# atomic counter in _start. Proves multi-core boot (each core ran real code).
fn _line_smp(n: u64):
    _uart_put(91)   # [
    _uart_put(66)   # B
    _uart_put(79)   # O
    _uart_put(79)   # O
    _uart_put(84)   # T
    _uart_put(93)   # ]
    _uart_put(32)
    _uart_put(83)   # S
    _uart_put(77)   # M
    _uart_put(80)   # P
    _uart_put(32)
    _uart_put(104)  # h
    _uart_put(97)   # a
    _uart_put(114)  # r
    _uart_put(116)  # t
    _uart_put(115)  # s
    _uart_put(58)   # :
    _uart_put(32)
    _uart_put((48 + (n as u32)))   # '0'+N (N is small)
    _crlf()

# Briefly spin so secondary harts have a window to atomically check in, then
# return the count. Re-reads the extern counter every iteration so the loop is
# not optimized away and exits early once all 3 harts are online.
fn _smp_wait_online() -> u64:
    var c: u64 = rt_rv32_smp_online_count()
    var i: u64 = 0
    while c < 3 and i < 2000000:
        c = rt_rv32_smp_online_count()
        i = i + 1
    c

fn _qemu_exit_success():
    asm volatile:
        "lui     t0, 0x100"
        "li      t1, 0x5555"
        "sw      t1, 0(t0)"

fn boot_main(_hart_id: u32, _dtb_addr: u32):
    _line_simpleos_rv32()
    _line_uart_initialized()
    _line_riscv32()
    _line_memory_map()
    _line_ram_base()
    _line_boot_complete()
    # Hart census early, before subsystem init: each core checked in atomically
    # in _start, so this proves multi-core boot regardless of later subsystems.
    _line_smp(_smp_wait_online())
    riscv_noalloc_log_init()
    rt_rv32_boot_optional_nvme_fw_selftest()
    riscv_noalloc_handoff(_hart_id as u64, _dtb_addr as u64)
    rt_riscv_noalloc_pmm_init_default()
    riscv_noalloc_heap_init(rt_riscv_qemu_heap_start(), rt_riscv_qemu_heap_size())
    riscv_noalloc_services_init(true)
    riscv_noalloc_log_boot_ok()
    os_main()
    # Fall through to wfi halt if os_main ever returns
    _qemu_exit_success()
    riscv_noalloc_boot_idle()
