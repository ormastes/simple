# RISC-V 32 Boot Entry — M-Mode Direct Boot (no OpenSBI)
#
# Keep this module freestanding and minimal so `simple os build --arch=riscv32`
# can native-build a real bootable ELF without pulling runtime formatting,
# arrays, or boot metadata construction into the first-stage entry object.

@section(".text.entry")
@naked
fn _start():
    asm volatile:
        "mv      s0, a0"
        "mv      s1, a1"
        "la      sp, _stack_top"
        "la      t0, _sbss"
        "la      t1, _ebss"
        ".Lrv32_bss_loop:"
        "bgeu    t0, t1, .Lrv32_bss_done"
        "sw      zero, 0(t0)"
        "addi    t0, t0, 4"
        "j       .Lrv32_bss_loop"
        ".Lrv32_bss_done:"
        "mv      a0, s0"
        "mv      a1, s1"
        "call    os__kernel__arch__riscv32__boot__boot_main"
        ".Lrv32_boot_halt:"
        "wfi"
        "j       .Lrv32_boot_halt"

fn _uart_put(byte: u32):
    asm volatile:
        "li      t0, 0x10000000"
        "sb      a0, 0(t0)"

fn _crlf():
    _uart_put(13)
    _uart_put(10)

fn _line_simpleos_rv32():
    _uart_put(83)
    _uart_put(105)
    _uart_put(109)
    _uart_put(112)
    _uart_put(108)
    _uart_put(101)
    _uart_put(79)
    _uart_put(83)
    _uart_put(32)
    _uart_put(82)
    _uart_put(86)
    _uart_put(51)
    _uart_put(50)
    _crlf()

fn _line_uart_initialized():
    _uart_put(91)
    _uart_put(66)
    _uart_put(79)
    _uart_put(79)
    _uart_put(84)
    _uart_put(93)
    _uart_put(32)
    _uart_put(85)
    _uart_put(65)
    _uart_put(82)
    _uart_put(84)
    _uart_put(32)
    _uart_put(105)
    _uart_put(110)
    _uart_put(105)
    _uart_put(116)
    _uart_put(105)
    _uart_put(97)
    _uart_put(108)
    _uart_put(105)
    _uart_put(122)
    _uart_put(101)
    _uart_put(100)
    _crlf()

fn _line_riscv32():
    _uart_put(91)
    _uart_put(66)
    _uart_put(79)
    _uart_put(79)
    _uart_put(84)
    _uart_put(93)
    _uart_put(32)
    _uart_put(82)
    _uart_put(73)
    _uart_put(83)
    _uart_put(67)
    _uart_put(45)
    _uart_put(86)
    _uart_put(32)
    _uart_put(51)
    _uart_put(50)
    _crlf()

fn _line_memory_map():
    _uart_put(91)
    _uart_put(66)
    _uart_put(79)
    _uart_put(79)
    _uart_put(84)
    _uart_put(93)
    _uart_put(32)
    _uart_put(77)
    _uart_put(101)
    _uart_put(109)
    _uart_put(111)
    _uart_put(114)
    _uart_put(121)
    _uart_put(32)
    _uart_put(109)
    _uart_put(97)
    _uart_put(112)
    _uart_put(32)
    _uart_put(112)
    _uart_put(97)
    _uart_put(114)
    _uart_put(115)
    _uart_put(101)
    _uart_put(100)
    _crlf()

fn _line_ram_base():
    _uart_put(91)
    _uart_put(66)
    _uart_put(79)
    _uart_put(79)
    _uart_put(84)
    _uart_put(93)
    _uart_put(32)
    _uart_put(82)
    _uart_put(65)
    _uart_put(77)
    _uart_put(32)
    _uart_put(97)
    _uart_put(116)
    _uart_put(32)
    _uart_put(48)
    _uart_put(120)
    _uart_put(56)
    _uart_put(48)
    _uart_put(48)
    _uart_put(48)
    _uart_put(48)
    _uart_put(48)
    _uart_put(48)
    _uart_put(48)
    _crlf()

fn _line_boot_complete():
    _uart_put(91)
    _uart_put(66)
    _uart_put(79)
    _uart_put(79)
    _uart_put(84)
    _uart_put(93)
    _uart_put(32)
    _uart_put(98)
    _uart_put(111)
    _uart_put(111)
    _uart_put(116)
    _uart_put(32)
    _uart_put(99)
    _uart_put(111)
    _uart_put(109)
    _uart_put(112)
    _uart_put(108)
    _uart_put(101)
    _uart_put(116)
    _uart_put(101)
    _crlf()

fn _qemu_exit_success():
    asm volatile:
        "lui     t0, 0x100"
        "li      t1, 0x5555"
        "sw      t1, 0(t0)"

fn boot_main(_hart_id: u32, _dtb_addr: u32):
    _line_simpleos_rv32()
    _line_uart_initialized()
    _line_riscv32()
    _line_memory_map()
    _line_ram_base()
    _line_boot_complete()
    _qemu_exit_success()
