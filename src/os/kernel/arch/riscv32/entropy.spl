# RISC-V 32 early-boot entropy mixer.

extern fn rt_time_now_unix_micros() -> i64
use os.kernel.arch.riscv32.timer.{Rv32Timer}
use os.kernel.arch.riscv32.boot_info.{rv32_boot_dtb_address, rv32_boot_hart_id}

fn _mix64(x: u64) -> u64:
    var v = x ^ (x >> 30)
    v = v * 0xBF58476D1CE4E5B9
    v = v ^ (v >> 27)
    v = v * 0x94D049BB133111EB
    v ^ (v >> 31)

fn entropy_seed_u64() -> u64:
    # No standard SBI sbi_get_random source is available in the current
    # QEMU/OpenSBI path. Mix mtime plus boot DTB/hart metadata as the RV32
    # cycle+time+instret-class fallback until a true random source exists.
    var timer = Rv32Timer()
    _mix64(
        timer.elapsed_us() ^
        rt_time_now_unix_micros().to_u64() ^
        (rv32_boot_dtb_address() as u64) ^
        (rv32_boot_hart_id() as u64) ^
        0x52563332
    )
