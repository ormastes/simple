# ARM32 early-boot entropy mixer.

extern fn rt_time_now_unix_micros() -> i64
use os.kernel.arch.arm32.timer.{Arm32Timer}

fn _mix64(x: u64) -> u64:
    var v = x ^ (x >> 30)
    v = v * 0xBF58476D1CE4E5B9
    v = v ^ (v >> 27)
    v = v * 0x94D049BB133111EB
    v ^ (v >> 31)

fn entropy_seed_u64() -> u64:
    # ARM32 QEMU virt passes a DTB in r2, but this current boot surface still
    # uses hardcoded QEMU metadata. Mix CNTVCT plus runtime time until DTB
    # parsing is wired into the ARM32 boot-info path.
    var timer = Arm32Timer()
    _mix64(timer.current_ticks() ^ rt_time_now_unix_micros().to_u64() ^ 0x41524D3332)
