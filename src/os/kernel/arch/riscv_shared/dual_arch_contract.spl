class ArchDescriptor:
    xlen: i32
    isa_string: text
    abi: text
    mmu_mode: text
    has_m_ext: bool
    has_a_ext: bool
    has_f_ext: bool
    has_d_ext: bool
    has_c_ext: bool

    me is_rv32() -> bool:
        return xlen == 32

    me is_rv64() -> bool:
        return xlen == 64

    me is_gc() -> bool:
        return has_m_ext and has_a_ext and has_f_ext and has_d_ext and has_c_ext

    me linux_capable() -> bool:
        return (xlen == 32 and mmu_mode == "Sv32") or (xlen == 64 and mmu_mode == "Sv39")

    static fn rv32gc() -> ArchDescriptor:
        return ArchDescriptor {
            xlen: 32,
            isa_string: "rv32imafdc",
            abi: "ilp32d",
            mmu_mode: "Sv32",
            has_m_ext: true,
            has_a_ext: true,
            has_f_ext: true,
            has_d_ext: true,
            has_c_ext: true
        }

    static fn rv64gc() -> ArchDescriptor:
        return ArchDescriptor {
            xlen: 64,
            isa_string: "rv64imafdc",
            abi: "lp64d",
            mmu_mode: "Sv39",
            has_m_ext: true,
            has_a_ext: true,
            has_f_ext: true,
            has_d_ext: true,
            has_c_ext: true
        }

    static fn rv32i_only() -> ArchDescriptor:
        return ArchDescriptor {
            xlen: 32,
            isa_string: "rv32i",
            abi: "ilp32",
            mmu_mode: "none",
            has_m_ext: false,
            has_a_ext: false,
            has_f_ext: false,
            has_d_ext: false,
            has_c_ext: false
        }


class DualArchContract:
    rv32_isa: text
    rv32_abi: text
    rv32_mmu: text
    rv32_linux: bool
    rv64_isa: text
    rv64_abi: text
    rv64_mmu: text
    rv64_linux: bool
    shared_extensions: text

    me both_linux_capable() -> bool:
        return rv32_linux and rv64_linux

    me any_linux_capable() -> bool:
        return rv32_linux or rv64_linux

    me is_symmetric() -> bool:
        return rv32_linux == rv64_linux

    static fn gc_contract() -> DualArchContract:
        return DualArchContract {
            rv32_isa: "rv32imafdc",
            rv32_abi: "ilp32d",
            rv32_mmu: "Sv32",
            rv32_linux: true,
            rv64_isa: "rv64imafdc",
            rv64_abi: "lp64d",
            rv64_mmu: "Sv39",
            rv64_linux: true,
            shared_extensions: "imafdc"
        }

    static fn rv64_only() -> DualArchContract:
        return DualArchContract {
            rv32_isa: "rv32i",
            rv32_abi: "ilp32",
            rv32_mmu: "none",
            rv32_linux: false,
            rv64_isa: "rv64imafdc",
            rv64_abi: "lp64d",
            rv64_mmu: "Sv39",
            rv64_linux: true,
            shared_extensions: "imafdc"
        }


class Rv32HardwareTree:
    cpu_count: i32
    ram_mb: i32
    has_uart: bool
    has_timer: bool
    has_plic: bool
    boot_rom_addr: i32
    boot_rom_size: i32

    me is_linux_minimal() -> bool:
        return ram_mb >= 32 and has_timer and has_plic

    me has_console() -> bool:
        return has_uart

    static fn qemu_virt() -> Rv32HardwareTree:
        return Rv32HardwareTree {
            cpu_count: 1,
            ram_mb: 128,
            has_uart: true,
            has_timer: true,
            has_plic: true,
            boot_rom_addr: 4096,
            boot_rom_size: 32768
        }

    static fn minimal() -> Rv32HardwareTree:
        return Rv32HardwareTree {
            cpu_count: 1,
            ram_mb: 32,
            has_uart: true,
            has_timer: true,
            has_plic: false,
            boot_rom_addr: 4096,
            boot_rom_size: 4096
        }


class QemuVirtContract:
    machine_type: text
    cpu_model: text
    memory_mb: i32
    kernel_path: text
    dtb_path: text
    append_args: text
    device_count: i32

    me is_rv32() -> bool:
        return cpu_model.starts_with("rv32")

    me is_rv64() -> bool:
        return cpu_model.starts_with("rv64")

    me has_kernel() -> bool:
        return kernel_path != ""

    me has_dtb() -> bool:
        return dtb_path != ""

    static fn rv32_linux(kernel: text, dtb: text) -> QemuVirtContract:
        return QemuVirtContract {
            machine_type: "virt",
            cpu_model: "rv32gc",
            memory_mb: 128,
            kernel_path: kernel,
            dtb_path: dtb,
            append_args: "console=ttyS0",
            device_count: 3
        }

    static fn rv64_linux(kernel: text, dtb: text) -> QemuVirtContract:
        return QemuVirtContract {
            machine_type: "virt",
            cpu_model: "rv64gc",
            memory_mb: 256,
            kernel_path: kernel,
            dtb_path: dtb,
            append_args: "console=ttyS0",
            device_count: 3
        }


fn main():
    print("dual_arch_contract loaded")
