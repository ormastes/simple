# L4-style fast IPC primitives.
#
# These helpers model the register-message and bounded buffer-slot pieces that
# are cheap enough to benchmark in pure Simple before wiring them into syscall
# or scheduler paths.

struct L4InlineMessage32:
    method_id: u32
    payload_len: u32
    badge: u32
    r0: u32
    r1: u32
    r2: u32
    r3: u32
    r4: u32
    r5: u32
    r6: u32
    r7: u32

struct L4InlineMessage64:
    method_id: u32
    payload_len: u32
    badge: u32
    r0: u64
    r1: u64
    r2: u64
    r3: u64
    r4: u64
    r5: u64
    r6: u64
    r7: u64

class L4BufferPool:
    states: [u64]
    owners: [u64]
    msg_lens: [u64]
    slot_count: u64

impl L4BufferPool:
    static fn new(slot_count: u64) -> L4BufferPool:
        var states: [u64] = []
        var owners: [u64] = []
        var msg_lens: [u64] = []
        var i: u64 = 0
        while i < slot_count:
            states.push(0)
            owners.push(0)
            msg_lens.push(0)
            i = i + 1
        L4BufferPool(states: states, owners: owners, msg_lens: msg_lens, slot_count: slot_count)

    me transfer_4096(counter: i64, sender: u64, receiver: u64) -> u64:
        if self.slot_count == 0:
            return 0
        val idx = (counter.to_u64() % self.slot_count).to_i32()
        self.states[idx] = 2
        self.owners[idx] = sender
        self.msg_lens[idx] = 4096
        self.owners[idx] = receiver
        self.states[idx] = 3
        val checksum = self.owners[idx] + self.msg_lens[idx] + self.states[idx]
        self.states[idx] = 0
        self.owners[idx] = 0
        self.msg_lens[idx] = 0
        checksum

fn l4_inline_message32_from_counter(i: i64) -> L4InlineMessage32:
    val word = (i % 65536).to_u32()
    L4InlineMessage32(
        method_id: (i % 1024).to_u32(),
        payload_len: 32,
        badge: 9,
        r0: word,
        r1: word + 1,
        r2: word + 2,
        r3: word + 3,
        r4: word + 4,
        r5: word + 5,
        r6: word + 6,
        r7: word + 7
    )

fn l4_inline_message64_from_counter(i: i64) -> L4InlineMessage64:
    val word = i.to_u64()
    L4InlineMessage64(
        method_id: (i % 1024).to_u32(),
        payload_len: 32,
        badge: 9,
        r0: word,
        r1: word + 1,
        r2: word + 2,
        r3: word + 3,
        r4: word + 4,
        r5: word + 5,
        r6: word + 6,
        r7: word + 7
    )

fn l4_inline_checksum32(msg: L4InlineMessage32) -> u64:
    msg.method_id.to_u64() + msg.payload_len.to_u64() + msg.r0.to_u64() + msg.r7.to_u64()

fn l4_inline_checksum64(msg: L4InlineMessage64) -> u64:
    msg.method_id.to_u64() + msg.payload_len.to_u64() + msg.r0 + msg.r7 + 32

fn l4_inline_round_trip_32bit(i: i64) -> u64:
    l4_inline_checksum32(l4_inline_message32_from_counter(i))

fn l4_inline_round_trip_64bit(i: i64) -> u64:
    l4_inline_checksum64(l4_inline_message64_from_counter(i))

fn l4_inline_round_trip_32bit_index(i: i64) -> u64:
    val word = (i & 65535).to_u32()
    val method = (i & 1023).to_u32()
    method.to_u64() + 32 + word.to_u64() + (word + 7).to_u64()

fn l4_inline_round_trip_64bit_index(i: i64) -> u64:
    val word = i.to_u64()
    val method = (i & 1023).to_u32()
    method.to_u64() + 32 + word + (word + 7) + 32
