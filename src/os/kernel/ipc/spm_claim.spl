"""SPM claim authorization and port rebind policy."""

use os.kernel.ipc.spm_port.{spm_port_claim}
use os.kernel.privilege.privilege_bridge.{bridge_lookup, two_gate_check}

fn spm_claim_authorized(task_id: u64) -> bool:
    """Return true when `task_id` may claim the SPM port."""
    val mirror = bridge_lookup(task_id)
    two_gate_check(mirror, "id.system.spm.claim".bytes())

fn spm_claim_for_task(task_id: u64) -> i64:
    """Evaluate the full sys_spm_claim decision for an already-known task id."""
    if not spm_claim_authorized(task_id):
        return -1 as i64
    spm_port_claim(task_id)
