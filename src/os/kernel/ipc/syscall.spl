var _hostname: text = "simpleos"

fn _handle_sysinfo(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Query system information.

    Args:
      arg0: SysInfoKind (0=Memory, 1=CpuCount, 2=Uptime, 3=TickCount)
    """
    match args.arg0:
        case 0:     # Memory
            # In a real kernel, query PMM for page stats.
            SyscallResult(value: 0)
        case 1:     # CpuCount
            SyscallResult(value: 1)     # Single CPU for now
        case 2:     # Uptime (placeholder)
            SyscallResult(value: 0)
        case 3:     # TickCount
            val count = scheduler.tick_count()
            SyscallResult(value: count.to_i64())
        case _:
            SyscallResult(value: -22)   # EINVAL

fn _handle_get_hostname() -> SyscallResult:
    """Return the hostname length. Hostname copied to userspace buffer."""
