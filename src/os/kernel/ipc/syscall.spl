# ============================================================================
# Architecture-Aware Security Boundaries
# ============================================================================
# KERNEL_SPACE_START — high-half kernel boundary (arch-specific). Addresses at
#   or above this are always kernel-only.
# NULL_GUARD_LIMIT   — reject the first page (null dereference guard). Only
#   catches null/near-null pointers, not all kernel structures.
# PCI_MMIO_FLOOR     — physical addresses below this are likely RAM, not MMIO.
#
# On identity-mapped targets (baremetal, 32-bit), user and kernel share the
# same low address range. Full protection requires per-process VMA tracking
# (not yet implemented). The capability system at syscall dispatch provides
# the primary access control. These checks are a defense-in-depth layer that
# catches null pointers and high-half kernel writes without breaking valid
# user pointers that may legitimately be at low addresses (stack, loader
# data, shared libraries).

# Null-guard: reject first 4KB page (catches NULL and near-NULL dereferences)
val NULL_GUARD_LIMIT: u64 = 0x1000

@cfg(x86_64)
val KERNEL_SPACE_START: u64 = 0xFFFF800000000000
@cfg(x86_64)
val PCI_MMIO_FLOOR: u64 = 0x80000000

@cfg(x86)
val KERNEL_SPACE_START: u64 = 0xC0000000
@cfg(x86)
val PCI_MMIO_FLOOR: u64 = 0x80000000

@cfg(arm64)
val KERNEL_SPACE_START: u64 = 0xFFFF000000000000
@cfg(arm64)
val PCI_MMIO_FLOOR: u64 = 0x40000000

@cfg(arm32)
val KERNEL_SPACE_START: u64 = 0xC0000000
@cfg(arm32)
val PCI_MMIO_FLOOR: u64 = 0x40000000

@cfg(riscv64)
val KERNEL_SPACE_START: u64 = 0xFFFFFFC000000000
@cfg(riscv64)
val PCI_MMIO_FLOOR: u64 = 0x40000000

@cfg(riscv32)
val KERNEL_SPACE_START: u64 = 0xC0000000
@cfg(riscv32)
val PCI_MMIO_FLOOR: u64 = 0x40000000

fn _is_kernel_addr(addr: u64) -> bool:
    """Check if an address is in the high-half kernel region.

    Only checks the architecture-specific high-half boundary. Does NOT
    reject all kernel memory on identity-mapped targets — that requires
    per-process VMA tracking. Capability enforcement at syscall dispatch
    is the primary protection layer.
    """
    addr >= KERNEL_SPACE_START

fn _is_userspace_ptr(ptr: u64) -> bool:
    """Validate a pointer is plausibly in userspace.

    Rejects null/near-null (below NULL_GUARD_LIMIT) and high-half kernel
    addresses. On identity-mapped targets, low addresses that overlap
    kernel structures are not caught here — capability enforcement and
    future VMA tracking provide that layer.
    """
    ptr >= NULL_GUARD_LIMIT and ptr < KERNEL_SPACE_START

fn _is_userspace_range(ptr: u64, len: u64) -> bool:
    """Validate a non-empty user pointer range without wrapping."""
    if ptr == 0 or len == 0:
        return false
    val end = ptr + len - 1
    if end < ptr:
        return false
    _is_userspace_ptr(ptr) and _is_userspace_ptr(end)

# ============================================================================
# Capability Enforcement Helpers
# ============================================================================

fn _cap_check(ipc: IpcManager, task: TaskId, kind: CapabilityKind) -> bool:
    """Check if a task holds a capability of the required kind.

    Defaults to ALLOW if the task has no explicit capability record yet
    (backward compatible — tasks without pledge/unveil restrictions pass).
    """
    var ipc_mgr = ipc
    ipc_mgr.cap_check(task, kind)

fn _cap_check_file(ipc: IpcManager, task: TaskId, path: text, perm: text) -> bool:
    """Check file access capability including unveil path restrictions."""
    var ipc_mgr = ipc
    ipc_mgr.cap_manager.check_file_access(task, path, perm)

@cfg(riscv64)
val CURRENT_EXEC_ARCH: Architecture = Architecture.Riscv64

@cfg(riscv32)
val CURRENT_EXEC_ARCH: Architecture = Architecture.Riscv32

@cfg(x86_64)
val CURRENT_EXEC_ARCH: Architecture = Architecture.X86_64

@cfg(x86)
val CURRENT_EXEC_ARCH: Architecture = Architecture.X86

@cfg(arm64)
val CURRENT_EXEC_ARCH: Architecture = Architecture.Arm64

@cfg(arm32)
val CURRENT_EXEC_ARCH: Architecture = Architecture.Arm32

@cfg(x86_64)
fn _use_x86_64_direct_spawn_handoff(arch: Architecture) -> bool:
    val _arch = arch
    false

@cfg(not(x86_64))
fn _use_x86_64_direct_spawn_handoff(arch: Architecture) -> bool:
    val _arch = arch
    false

var g_x86_64_direct_spawn_next_pid: u64 = 1001

fn _alloc_x86_64_direct_spawn_pid() -> u64:
    val pid = g_x86_64_direct_spawn_next_pid
    g_x86_64_direct_spawn_next_pid = g_x86_64_direct_spawn_next_pid + 1
    if g_x86_64_direct_spawn_next_pid >= 0x40000000:
        g_x86_64_direct_spawn_next_pid = 1001
    pid

# ============================================================================
# Syscall Handler
# ============================================================================

fn _syscall_task_is_blocked(scheduler: Scheduler, id: TaskId) -> bool:
    val tcb = scheduler.get_task(id)
    if tcb == nil:
        return false
    val task = tcb
    match task.state:
        case TaskState.Blocked(reason): true
        _: false

fn syscall_dispatch(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager, klog: KernelLog) -> SyscallDispatchResult:
    """Disposition-aware syscall dispatcher for architecture trap entry.

    The legacy syscall_handler remains the scalar compatibility surface. This
    wrapper adds the information an architecture entry path needs to avoid
    returning through the old user frame when the syscall blocked the task.
    """
    var sched = scheduler
    val caller = sched.get_current()
    val result = syscall_handler(args, sched, ipc, klog)
    if args.id == 0:
        return syscall_dispatch_with(result.value, SyscallTrapDisposition.NoReturn)
    if _syscall_task_is_blocked(sched, caller):
        return syscall_dispatch_with(result.value, SyscallTrapDisposition.BlockCurrent)
    if args.id == 1 or args.id == 106:
        return syscall_dispatch_with(result.value, SyscallTrapDisposition.ScheduleNext)
    syscall_dispatch_with(result.value, SyscallTrapDisposition.ReturnToCaller)

fn syscall_handler(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager, klog: KernelLog) -> SyscallResult:
    """Main syscall dispatcher. Called from the SYSCALL entry stub.

    The entry stub has already saved the user context into the current
    task's TCB. Arguments are passed in registers per the SyscallArgs layout.

    Capability enforcement: each syscall group checks the calling task's
    capabilities before dispatching. If the check fails, EPERM (-1) is
    returned immediately. Tasks without explicit pledge/unveil restrictions
    default to ALLOW for backward compatibility.

    Returns SyscallResult with value >= 0 on success, < 0 on error.
    """
    # Resolve the calling task for capability checks
    var sched_for_cap = scheduler
    val caller = sched_for_cap.get_current()
    fd_activate_task(caller.id)

    match args.id:
        # -- Process ---------------------------------------------------------
        case 0:     # Exit (always allowed)
            _handle_exit(args, scheduler, ipc)
        case 1:     # Yield (always allowed)
            _handle_yield(scheduler)
        case 2:     # Spawn
            if not _cap_check(ipc, caller, CapabilityKind.ProcessSpawn):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_spawn(args, scheduler)
        case 3:     # Wait (always allowed — waiting for own children)
            _handle_wait(args, scheduler)
        case 4:     # GetPid (always allowed)
            _handle_getpid(scheduler)
        case 13:    # SpawnBinary
            if not _cap_check(ipc, caller, CapabilityKind.ProcessSpawn):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_spawn_binary(args, scheduler, klog)
        case 14:    # EnterUserBlocking — handled fast-path in interrupt.spl; fallback here
            if not _cap_check(ipc, caller, CapabilityKind.ProcessSpawn):
                return SyscallResult(value: SYSCALL_EPERM)
            SyscallResult(value: -38)
        case 15:    # Brk
            _handle_brk_for_task(args, caller.id)
        case 16:    # SystemReboot
            if not _cap_check(ipc, caller, CapabilityKind.SystemReboot):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_system_reboot(args)

        # -- Memory ----------------------------------------------------------
        case 10:    # Mmap
            if not _cap_check(ipc, caller, CapabilityKind.Mmio(base: 0, size: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_memory_map(args, scheduler)
        case 11:    # Munmap
            if not _cap_check(ipc, caller, CapabilityKind.Mmio(base: 0, size: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_memory_unmap(args, scheduler)
        case 12:    # Mprotect
            if not _cap_check(ipc, caller, CapabilityKind.Mmio(base: 0, size: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_memory_protect(args, scheduler)

        # -- IPC -------------------------------------------------------------
        case 20:    # IpcSend
            if not _cap_check(ipc, caller, CapabilityKind.IpcConnect(port_name: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_ipc_send(args, scheduler, ipc)
        case 21:    # IpcRecv
            if not _cap_check(ipc, caller, CapabilityKind.IpcListen(port_name: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_ipc_recv(args, scheduler, ipc)
        case 22:    # IpcCreatePort
            if not _cap_check(ipc, caller, CapabilityKind.IpcListen(port_name: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_ipc_create_port(args, scheduler, ipc)
        case 23:    # IpcConnect
            if not _cap_check(ipc, caller, CapabilityKind.IpcConnect(port_name: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_ipc_connect(args, ipc)

        # -- Notification (L4-style async events) ----------------------------
        case 24:    # NotificationCreate
            _handle_notification_create(args)
        case 25:    # NotificationSignal
            _handle_notification_signal(args, scheduler)
        case 26:    # NotificationWait
            _handle_notification_wait(args, scheduler)
        case 27:    # NotificationPoll
            _handle_notification_poll(args)
        case 28:    # NotificationDestroy
            _handle_notification_destroy(args)
        case 29:    # NotificationWaitAny
            _handle_notification_wait_any(args, scheduler)

        # -- File (routed to VFS via IPC) ------------------------------------
        case 30:    # Open
            if not _cap_check(ipc, caller, CapabilityKind.FileRead(path_prefix: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_file_open(args, scheduler, ipc)
        case 31:    # Read
            if not _cap_check(ipc, caller, CapabilityKind.FileRead(path_prefix: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_file_read(args, scheduler, ipc)
        case 32:    # Write
            if not _cap_check(ipc, caller, CapabilityKind.FileWrite(path_prefix: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_file_write(args, scheduler, ipc)
        case 33:    # Close
            _handle_file_close(args, scheduler, ipc)
        case 34:    # Stat
            if not _cap_check(ipc, caller, CapabilityKind.FileRead(path_prefix: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_file_stat(args, scheduler, ipc)
        case 35:    # Mkdir
            if not _cap_check(ipc, caller, CapabilityKind.FileCreate(path_prefix: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_file_mkdir(args, scheduler, ipc)
        case 36:    # Readdir
            if not _cap_check(ipc, caller, CapabilityKind.FileRead(path_prefix: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_file_readdir(args, scheduler, ipc)
        case 37:    # Mount
            if not _cap_check(ipc, caller, CapabilityKind.SystemMount):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_mount(args, scheduler, ipc)
        case 38:    # Unmount
            if not _cap_check(ipc, caller, CapabilityKind.SystemMount):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_unmount(args, scheduler, ipc)
        case 39:    # Unlink
            if not _cap_check(ipc, caller, CapabilityKind.FileWrite(path_prefix: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_file_unlink(args, scheduler, ipc)

        # -- File (extended) -------------------------------------------------
        case 44:    # Rename
            if not _cap_check(ipc, caller, CapabilityKind.FileWrite(path_prefix: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_file_rename(args, scheduler, ipc)
        case 45:    # Rmdir
            if not _cap_check(ipc, caller, CapabilityKind.FileWrite(path_prefix: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_file_rmdir(args, scheduler, ipc)
        case 46:    # Lseek
            _handle_lseek(args)
        case 43:    # Ftruncate
            if not _cap_check(ipc, caller, CapabilityKind.FileWrite(path_prefix: "")):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_ftruncate(args)
        case 47:    # Getcwd
            _handle_getcwd(args, scheduler)
        case 48:    # Chdir
            _handle_chdir(args, scheduler)

        # -- Security --------------------------------------------------------
        case 40:    # Pledge (always allowed — self-restriction)
            _handle_pledge(args, scheduler, ipc)
        case 41:    # Unveil (always allowed — self-restriction)
            _handle_unveil(args, scheduler, ipc)
        case 42:    # CapGrant
            _handle_cap_grant(args, scheduler, ipc)

        # -- Process (extended) ----------------------------------------------
        case 5:     # ListTasks (always allowed)
            _handle_list_tasks(args, scheduler)
        case 6:     # GetTaskInfo (always allowed)
            _handle_get_task_info(args, scheduler)
        case 7:     # Signal
            if not _cap_check(ipc, caller, CapabilityKind.ProcessSignal(target: args.arg0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_signal(args, scheduler)
        case 8:     # SetPriority
            if not _cap_check(ipc, caller, CapabilityKind.ProcessSignal(target: args.arg0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_set_priority(args, scheduler)
        case 9:     # GetParentPid (always allowed)
            _handle_get_parent_pid(scheduler)

        # -- Debug -----------------------------------------------------------
        case 60:    # DebugWrite (always allowed)
            _handle_debug_write(args)

        # -- Network ---------------------------------------------------------
        case 70:    # NetSocket
            if not _cap_check(ipc, caller, CapabilityKind.NetConnect(port: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_net_socket(args)
        case 71:    # NetBind
            if not _cap_check(ipc, caller, CapabilityKind.NetListen(port: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_net_bind(args)
        case 72:    # NetListen
            if not _cap_check(ipc, caller, CapabilityKind.NetListen(port: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_net_listen(args)
        case 73:    # NetConnect
            if not _cap_check(ipc, caller, CapabilityKind.NetConnect(port: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_net_connect(args)
        case 74:    # NetAccept
            if not _cap_check(ipc, caller, CapabilityKind.NetListen(port: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_net_accept(args)
        case 75:    # NetSendTo
            if not _cap_check(ipc, caller, CapabilityKind.NetConnect(port: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_net_send_to(args)
        case 76:    # NetRecvFrom
            if not _cap_check(ipc, caller, CapabilityKind.NetConnect(port: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_net_recv_from(args)
        case 77:    # NetIfConfig
            if not _cap_check(ipc, caller, CapabilityKind.NetRaw):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_net_if_config(args)

        # -- Device ----------------------------------------------------------
        case 80:    # DevEnumerate
            if not _cap_check(ipc, caller, CapabilityKind.DeviceEnumerate(class_code: 0, subclass: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_dev_enumerate(args)
        case 81:    # DevGetInfo
            if not _cap_check(ipc, caller, CapabilityKind.DeviceEnumerate(class_code: 0, subclass: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_dev_get_info(args)
        case 82:    # DeviceGrant
            val grant_bdf = args.arg0
            val grant_bus = ((grant_bdf >> 16) & 0xFF).to_u8()
            val grant_dev = ((grant_bdf >> 8) & 0xFF).to_u8()
            val grant_func = (grant_bdf & 0xFF).to_u8()
            if not _cap_check(ipc, caller, CapabilityKind.DeviceGrant(bdf_bus: grant_bus, bdf_device: grant_dev, bdf_func: grant_func)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_device_grant(args, scheduler, caller)
        case 83:    # MapBar
            # Transitional until MapBar accepts a BAR capability token. The
            # syscall is now named by a DeviceBarMap cap instead of raw Mmio.
            if not _cap_check(ipc, caller, CapabilityKind.DeviceBarMap(bdf_bus: 0, bdf_device: 0, bdf_func: 0, bar_index: 0)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_map_bar(args)
        case 84:    # AllocDma
            # Transitional until AllocDma accepts a device/IOMMU capability
            # token. The cap kind records that this is DMA authority.
            if not _cap_check(ipc, caller, CapabilityKind.DeviceDma(bdf_bus: 0, bdf_device: 0, bdf_func: 0, max_bytes: args.arg0 as u64)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_alloc_dma(args, caller)
        case 85:    # FreeDma
            if not _cap_check(ipc, caller, CapabilityKind.DeviceDma(bdf_bus: 0, bdf_device: 0, bdf_func: 0, max_bytes: args.arg1 as u64)):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_free_dma(args, caller)

        # -- Logging ---------------------------------------------------------
        case 90:    # LogWrite
            _handle_log_write(args, scheduler, klog)
        case 91:    # LogRead
            _handle_log_read(args, klog)

        # -- System Info -----------------------------------------------------
        case 95:    # SysInfo
            _handle_sysinfo(args, scheduler)
        case 96:    # GetHostname
            _handle_get_hostname()
        case 97:    # SetHostname
            _handle_set_hostname(args)

        # -- Time ------------------------------------------------------------
        case 50:    # ClockGetTime (always allowed)
            _handle_clock_get_time(args, scheduler)
        case 51:    # Sleep (always allowed)
            _handle_sleep(args, scheduler)

        # -- POSIX process / fd composition ---------------------------------
        # Reserved for libc-backed C apps. These IDs deliberately avoid the
        # existing time/debug/sysinfo ranges; full handlers land with process
        # isolation and FD-table work. Until then, return ENOSYS.
        case 57:    # Fork
            _handle_fork(args, scheduler)
        case 59:    # Exec
            _handle_exec(args, scheduler)
        case 61:    # WaitPid
            _handle_waitpid(args, scheduler)
        case 62:    # Pipe
            _handle_pipe(args)
        case 63:    # Dup2
            _handle_dup2(args)
        case 64:    # Dup
            _handle_dup(args)
        case 65:    # DlOpen
            _handle_dlopen(args)
        case 66:    # DlSym
            _handle_dlsym(args)
        case 67:    # DlClose
            _handle_dlclose(args)
        case 68:    # Poll
            _handle_poll(args, scheduler)
        case 69:    # Fcntl
            _handle_fcntl(args)

        # -- Privilege Control (G11) -----------------------------------------
        case 98:    # sys_privctl
            if not _cap_check(ipc, caller, CapabilityKind.SystemPrivilege):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_privctl(args, scheduler)

        # -- Memory Grants (G12) ---------------------------------------------
        case 99:    # sys_grant
            _handle_mem_grant(args, scheduler)
        case 100:   # sys_revoke
            _handle_mem_revoke(args, scheduler)
        case 101:   # sys_safecopy_from
            _handle_safecopy_from(args, scheduler)
        case 102:   # sys_safecopy_to
            _handle_safecopy_to(args, scheduler)

        # -- VM mmap / munmap (Wave 1 G13) -----------------------------------
        # TODO(mdsoc+): gate with VM capability once capability registry lands
        case 103:   # sys_mmap
            _handle_sys_mmap(args)
        case 104:   # sys_munmap
            _handle_sys_munmap(args)

        # -- Scheduler policy (service agent reserved ABI) -------------------
        case 106:   # sys_schedule: cooperative reschedule point
            _handle_schedule(args, scheduler)
        case 107:   # sys_schedctl: set/query scheduler policy metadata
            if not _cap_check(ipc, caller, CapabilityKind.SystemPrivilege):
                return SyscallResult(value: SYSCALL_EPERM)
            _handle_schedctl(args, scheduler)

        # -- SPM / Privilege (spm-winfs-llm-suite) ----------------------------
        case 110:   # sys_priv_check
            _handle_spm_priv_check(args, caller.id)
        case 111:   # sys_win_register
            _handle_spm_win_register(args)
        case 112:   # sys_approval_request
            _handle_spm_approval_request(args)
        case 113:   # sys_spm_send
            _handle_spm_send(args)
        case 114:   # sys_spm_listen
            _handle_spm_listen(args)
        case 115:   # sys_spm_claim
            _handle_spm_claim(caller.id)

        # -- SOSIX immutable process sharing --------------------------------
        case 120:   # dataset_create
            _handle_dataset_create(args)
        case 121:   # dataset_create_from_file
            _handle_dataset_create_from_file(args)
        case 122:   # dataset_write
            _handle_dataset_write(args)
        case 123:   # dataset_seal
            _handle_dataset_seal(args)
        case 124:   # dataset_map
            _handle_dataset_map(args)
        case 125:   # dataset_unmap
            _handle_dataset_unmap(args)
        case 126:   # dataset_close
            _handle_dataset_close(args)
        case 127:   # queue_create
            _handle_queue_create(args)
        case 128:   # queue_send
            _handle_queue_send(args)
        case 129:   # queue_recv
            _handle_queue_recv(args)
        case 130:   # queue_poll
            _handle_queue_poll(args)
        case 131:   # queue_close
            _handle_queue_close(args)

        # -- Unknown ---------------------------------------------------------
        case _:
            SyscallResult(value: -1)

# ============================================================================
# Process Syscall Handlers
# ============================================================================

fn _handle_exit(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Exit the current task with the given exit code.

    Performs full resource cleanup before marking the task as zombie:
      1. Clean up kernel resources (notifications, IRQ routes, DMA, BAR mappings)
      2. Revoke all capabilities granted to the task
      3. Mark the task as zombie in the scheduler
    """
    val code = args.arg0
    var sched = scheduler
    val exiting_task = sched.get_current()

    # Step 1: Release DMA records first so the ownership table cannot retain
    # stale live entries after task_cleanup unmaps resources.
    _dma_release_task_allocs(exiting_task)

    # Step 2: Clean up remaining kernel resources tracked by task_cleanup
    task_cleanup(exiting_task.id)

    # Step 3: Revoke all capabilities held by this task
    var ipc_mgr = ipc
    ipc_mgr.cap_manager.revoke_all_for_task(exiting_task)

    # Step 4: Close process descriptors for the current process lifecycle.
    _close_all_live_fds_with_backends()

    # Step 4: Mark as zombie in scheduler
    sched.exit_task(code.to_i32())

    # exit_task does not return to the caller; the scheduler picks next task.
    # This result is never seen by the exiting task.
    SyscallResult(value: 0)

fn _handle_yield(scheduler: Scheduler) -> SyscallResult:
    """Yield the current task's time slice."""
    var sched = scheduler
    sched.yield_current()
    SyscallResult(value: 0)

fn _handle_spawn(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Spawn a new task.

    Args:
      arg0: entry point address
      arg1: priority (0=Realtime, 1=High, 2=Normal, 3=Low, 4=Idle)
    """
    val entry = args.arg0
    val priority = _u64_to_priority(args.arg1)
    val caps = CapabilitySet.full()

    var sched = scheduler
    val task_id = sched.create_task(entry, priority, caps)
    SyscallResult(value: task_id.id.to_i64())

fn _handle_wait(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Wait for a child task to exit.

    Args:
      arg0: child task ID (0 = any child)
      arg1: options (bit 0 = WNOHANG)

    Blocks the caller until the child exits, then returns the exit code.
    """
    var sched = scheduler
    val current = sched.get_current()
    val result = sched.wait_for(current, TaskId(id: args.arg0))
    if result == -11:
        return SyscallResult(value: 0)
    SyscallResult(value: result.to_i64())

fn _handle_fork(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Fork the current scheduler task.

    Args are reserved for future clone flags. Returns the child task ID in the
    parent. Child-side register fixup to return 0 lands with context resume.
    """
    val _a = args
    var sched = scheduler
    val parent = sched.get_current()
    val child = sched.clone_task(parent)
    if child.id == 0:
        return SyscallResult(value: -12)
    fd_prepare_fork_to_task(child.id)
    SyscallResult(value: child.id.to_i64())

fn _handle_exec(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Execve process-image replacement.

    This kernel-facing ABI accepts arg0=path pointer and arg1=path length.
    arg2/arg3 are optional userspace char** vectors for argv/envp. Null
    vectors preserve the legacy path where the image builder seeds argv[0]
    from the executable path.
    """
    if args.arg0 == 0 or args.arg1 == 0:
        return SyscallResult(value: 0 - EINVAL as i64)
    if args.arg1 > MAX_BINARY_PATH_LEN:
        return SyscallResult(value: 0 - ENAMETOOLONG as i64)
    val path_bytes_result = _copy_user_bytes(args.arg0, args.arg1)
    if path_bytes_result.is_err():
        return SyscallResult(value: 0 - EFAULT as i64)

    val path_bytes = path_bytes_result.unwrap()
    val path = _path_bytes_to_text(path_bytes)
    val bytes_result = resolve_executable_bytes_from_path_bytes(path_bytes, CURRENT_EXEC_ARCH)
    if bytes_result.is_err():
        return SyscallResult(value: -2)

    val argv_result = vmm_copyin_string_vector(
        args.arg2,
        MAX_EXEC_ARG_COUNT,
        MAX_EXEC_STRING_LEN,
        MAX_EXEC_TOTAL_STRING_BYTES
    )
    if not argv_result.status.ok:
        return SyscallResult(value: 0 - argv_result.status.errno as i64)
    val envp_result = vmm_copyin_string_vector(
        args.arg3,
        MAX_EXEC_ENV_COUNT,
        MAX_EXEC_STRING_LEN,
        MAX_EXEC_TOTAL_STRING_BYTES
    )
    if not envp_result.status.ok:
        return SyscallResult(value: 0 - envp_result.status.errno as i64)

    val image_result = build_user_process_image(
        path,
        bytes_result.unwrap(),
        CURRENT_EXEC_ARCH,
        argv_result.values,
        envp_result.values
    )
    if image_result.is_err():
        return SyscallResult(value: -8)

    var sched = scheduler
    val current = sched.get_current()
    val result = sched.exec_image(current, image_result.unwrap())
    if result == 0:
        _close_cloexec_fds_with_backends()
    SyscallResult(value: result.to_i64())

fn _encode_wait_status(exit_code: i32) -> u32:
    """Encode a normal-exit status compatible with WEXITSTATUS."""
    (((exit_code as u32) & 0xFF) << 8)

fn _write_wait_status(ptr: u64, exit_code: i32) -> i64:
    """Copy an encoded wait status to userspace when the pointer is present."""
    if ptr == 0:
        return 0
    if not _is_userspace_ptr(ptr):
        return -14
    if not vmm_verify_user_write(ptr, 4):
        return -14
    mmio_write32(ptr, _encode_wait_status(exit_code))
    0

fn _validate_wait_status_ptr(ptr: u64) -> i64:
    """Validate waitpid status copyout before consuming a zombie child."""
    if ptr == 0:
        return 0
    if not _is_userspace_ptr(ptr):
        return -14
    if not vmm_verify_user_write(ptr, 4):
        return -14
    0

fn _handle_waitpid(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Waitpid-compatible wrapper around Scheduler.wait_for.

    Args:
      arg0: pid, or u64::MAX for any child
      arg1: status pointer, optional
      arg2: options (bit 0 = WNOHANG)
    """
    val any_child = args.arg0 == 0xFFFFFFFFFFFFFFFF
    val selector = if any_child: TaskId(id: 0) else: TaskId(id: args.arg0)
    val nohang = (args.arg2 & 1) != 0
    var sched = scheduler
    val current = sched.get_current()
    val status_ptr_check = _validate_wait_status_ptr(args.arg1)
    if status_ptr_check < 0:
        return SyscallResult(value: status_ptr_check)
    val result = sched.wait_for_collect(current, selector, not nohang)
    if result.error == -11:
        return SyscallResult(value: 0)
    if result.error < 0:
        return SyscallResult(value: result.error.to_i64())

    val status_write = _write_wait_status(args.arg1, result.status)
    if status_write < 0:
        return SyscallResult(value: status_write)
    SyscallResult(value: result.pid.to_i64())

fn _handle_pipe(args: SyscallArgs) -> SyscallResult:
    """Create a POSIX pipe and copy fd[0]/fd[1] to the user array."""
    if args.arg0 == 0:
        return SyscallResult(value: -14)
    if not _is_userspace_ptr(args.arg0):
        return SyscallResult(value: -14)
    if not vmm_verify_user_write(args.arg0, 8):
        return SyscallResult(value: -14)
    SyscallResult(value: posix_pipe(args.arg0, args.arg0 + 4) as i64)

fn _handle_dup2(args: SyscallArgs) -> SyscallResult:
    """Duplicate oldfd onto newfd using POSIX dup2 replacement semantics."""
    SyscallResult(value: posix_dup2(args.arg0 as i32, args.arg1 as i32) as i64)

fn _handle_dup(args: SyscallArgs) -> SyscallResult:
    """Duplicate oldfd to the lowest available descriptor."""
    SyscallResult(value: posix_dup(args.arg0 as i32) as i64)

fn _handle_dlopen(args: SyscallArgs) -> SyscallResult:
    """Load a path-backed dynamic object and return a kernel registry handle.

    ABI:
      arg0: path pointer
      arg1: path length
      arg2: mode flags (reserved)
    """
    val _mode = args.arg2
    val path_result = _copy_user_text(args.arg0, args.arg1)
    if path_result.is_err():
        return SyscallResult(value: -14)
    val path = path_result.unwrap()
    val bytes_result = resolve_executable_bytes(path, CURRENT_EXEC_ARCH)
    if bytes_result.is_err():
        return SyscallResult(value: -2)
    SyscallResult(value: dylib_registry_register(path, bytes_result.unwrap()))

fn _handle_dlsym(args: SyscallArgs) -> SyscallResult:
    """Resolve a symbol from a kernel dynamic-library handle.

    ABI:
      arg0: handle returned by DlOpen
      arg1: symbol-name pointer
      arg2: symbol-name length
    """
    val name_result = _copy_user_text(args.arg1, args.arg2)
    if name_result.is_err():
        return SyscallResult(value: -14)
    SyscallResult(value: dylib_registry_symbol(args.arg0 as i64, name_result.unwrap()))

fn _handle_dlclose(args: SyscallArgs) -> SyscallResult:
    """Close one reference to a kernel dynamic-library handle."""
    SyscallResult(value: dylib_registry_close(args.arg0 as i64))

fn _handle_poll(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """poll(2)-compatible readiness scan over user pollfd entries.

    ABI:
      arg0: struct pollfd* (fd: i32, events: i16, revents: i16)
      arg1: nfds
      arg2: timeout_ms (-1 = block on fd notifications, 0 = nonblocking,
            >0 = block until fd notification or scheduler sleep deadline)
    """
    val fds_ptr = args.arg0
    val nfds = args.arg1
    var sched = scheduler
    val current = sched.get_current()
    val task_id = current.id
    val timeout_infinite = (args.arg2 & 0x8000000000000000) != 0
    if nfds == 0:
        if timeout_infinite:
            sched.block_task(current, BlockReason.Sleep(until_ns: 0xFFFFFFFFFFFFFFFF))
        elif args.arg2 > 0:
            val timeout_ticks = (args.arg2 + 9) / 10
            val ticks = if timeout_ticks == 0: 1 else: timeout_ticks
            val deadline_ns = (sched.tick_count() + ticks) * 10000000
            sched.block_task(current, BlockReason.Sleep(until_ns: deadline_ns))
        return SyscallResult(value: 0)
    if fds_ptr == 0:
        return SyscallResult(value: -14)
    if nfds > 64:
        return SyscallResult(value: -22)
    val bytes = nfds * 8
    if fds_ptr + bytes < fds_ptr:
        return SyscallResult(value: -14)
    if not _is_userspace_ptr(fds_ptr):
        return SyscallResult(value: -14)
    if not _is_userspace_ptr(fds_ptr + bytes - 1):
        return SyscallResult(value: -14)
    if not vmm_verify_user_write(fds_ptr, bytes):
        return SyscallResult(value: -14)

    var ready: i64 = 0
    var i: u64 = 0
    while i < nfds:
        val entry = fds_ptr + i * 8
        val fd = mmio_read32(entry) as i32
        val events = mmio_read16(entry + 4) as i16
        var revents: i16 = 0
        if fd >= 0:
            revents = fd_poll_ready(fd, events)
        mmio_write16(entry + 6, revents as u16)
        if revents != 0:
            ready = ready + 1
        i = i + 1
    if ready > 0:
        return SyscallResult(value: ready)
    if args.arg2 == 0:
        return SyscallResult(value: 0)

    var ids: [u64] = []
    var blockable_count: u64 = 0
    i = 0
    while i < nfds:
        val entry = fds_ptr + i * 8
        val fd = mmio_read32(entry) as i32
        val events = mmio_read16(entry + 4) as i16
        if fd >= 0:
            val notif = fd_poll_notification(fd, events)
            if notif != 0:
                blockable_count = blockable_count + 1
                if ids.len() < 4:
                    ids.push(notif)
        i = i + 1
    if blockable_count > 4:
        return SyscallResult(value: -22)

    if ids.len() == 0:
        if timeout_infinite:
            sched.block_task(current, BlockReason.Sleep(until_ns: 0xFFFFFFFFFFFFFFFF))
        elif args.arg2 > 0:
            val timeout_ticks = (args.arg2 + 9) / 10
            val ticks = if timeout_ticks == 0: 1 else: timeout_ticks
            val deadline_ns = (sched.tick_count() + ticks) * 10000000
            sched.block_task(current, BlockReason.Sleep(until_ns: deadline_ns))
        return SyscallResult(value: 0)

    val count = ids.len()
    val result = notification_wait_any(g_notification_table, ids, count, task_id)
    if result != 0:
        ready = 0
        i = 0
        while i < nfds:
            val entry = fds_ptr + i * 8
            val fd = mmio_read32(entry) as i32
            val events = mmio_read16(entry + 4) as i16
            var revents: i16 = 0
            if fd >= 0:
                revents = fd_poll_ready(fd, events)
            mmio_write16(entry + 6, revents as u16)
            if revents != 0:
                ready = ready + 1
            i = i + 1
        return SyscallResult(value: ready)

    if timeout_infinite:
        notification_register_multi_waiter(g_notification_table, ids, count, task_id)
        sched.block_task(current, BlockReason.Notification(id: ids[0]))
    elif args.arg2 > 0:
        notification_register_multi_waiter(g_notification_table, ids, count, task_id)
        val timeout_ticks = (args.arg2 + 9) / 10
        val ticks = if timeout_ticks == 0: 1 else: timeout_ticks
        val deadline_ns = (sched.tick_count() + ticks) * 10000000
        sched.block_task(current, BlockReason.Sleep(until_ns: deadline_ns))
    SyscallResult(value: 0)

fn _handle_fcntl(args: SyscallArgs) -> SyscallResult:
    """fcntl subset for descriptor flags and nonblocking status flags."""
    val fd = args.arg0 as i32
    val cmd = args.arg1 as i32
    val arg = args.arg2
    val F_DUPFD: i32 = 0
    val F_GETFD: i32 = 1
    val F_SETFD: i32 = 2
    val F_GETFL: i32 = 3
    val F_SETFL: i32 = 4
    val F_DUPFD_CLOEXEC: i32 = 1030
    val F_SIMPLEOS_GET_OFD: i32 = 1397686273

    if cmd == F_DUPFD:
        return SyscallResult(value: fd_dup_from(fd, arg as i32, false) as i64)
    if cmd == F_DUPFD_CLOEXEC:
        return SyscallResult(value: fd_dup_from(fd, arg as i32, true) as i64)
    if not fd_is_valid(fd):
        return SyscallResult(value: -9)
    if cmd == F_GETFD:
        return SyscallResult(value: if fd_get_cloexec(fd): 1 else: 0)
    if cmd == F_SETFD:
        return SyscallResult(value: fd_set_cloexec(fd, (arg & 1) != 0) as i64)
    if cmd == F_GETFL:
        return SyscallResult(value: fd_get_status_flags(fd) as i64)
    if cmd == F_SETFL:
        return SyscallResult(value: fd_set_status_flags(fd, arg as u32) as i64)
    if cmd == F_SIMPLEOS_GET_OFD:
        return SyscallResult(value: fd_get_object_id(fd) as i64)
    SyscallResult(value: -22)

fn _handle_getpid(scheduler: Scheduler) -> SyscallResult:
    """Return the current task's ID."""
    val current = scheduler.get_current()
    SyscallResult(value: current.id.to_i64())

fn _path_bytes_to_text(bytes: [u8]) -> text:
    rt_string_from_byte_array(bytes)

extern fn rt_copy_user_byte(ptr_addr: u64) -> u8

fn _copy_user_bytes(ptr_addr: u64, len: u64) -> Result<[u8], text>:
    if ptr_addr == 0:
        return Err("null path pointer")
    if len == 0:
        return Err("empty path")
    if len > MAX_BINARY_PATH_LEN:
        return Err("path too long")
    # The unsafe pointer-deref loop miscompiles in the baremetal freestanding
    # build (see rt_copy_user_byte in examples/.../baremetal_stubs.c). Route
    # through a one-byte-at-a-time C helper instead.
    var bytes: [u8] = []
    var i: u64 = 0
    while i < len:
        bytes.push(rt_copy_user_byte(ptr_addr + i))
        i = i + 1
    Ok(bytes)

fn _copy_user_text(ptr_addr: u64, len: u64) -> Result<text, text>:
    serial_println("[syscall13] copy_user_text enter")
    val bytes_result = _copy_user_bytes(ptr_addr, len)
    if bytes_result.is_err():
        return Err(bytes_result.err().unwrap())
    serial_println("[syscall13] copy_user_text ok")
    Ok(_path_bytes_to_text(bytes_result.unwrap()))

fn _is_user_read_range(ptr: u64, len: u64) -> bool:
    if not _is_userspace_range(ptr, len):
        return false
    if g_current_vmspace.vma_count > 0 as u64:
        return _vma_range_readable(g_current_vmspace, ptr, len)
    true

fn _copy_user_u64(ptr_addr: u64) -> Result<u64, text>:
    if not _is_user_read_range(ptr_addr, 8):
        return Err("bad user pointer")
    var value: u64 = 0
    var i: u64 = 0
    while i < 8:
        val current = ptr_addr + i
        if current < ptr_addr:
            return Err("u64 pointer overflow")
        if not _is_user_read_range(current, 1):
            return Err("bad user pointer")
        unsafe:
            val byte_ptr = current as *const u8
            value = value | ((*byte_ptr).to_u64() << (i * 8))
        i = i + 1
    Ok(value)

fn _copy_user_cstr(ptr_addr: u64, max_len: u64) -> Result<text, text>:
    if ptr_addr == 0:
        return Err("null string pointer")
    var bytes: [u8] = []
    var i: u64 = 0
    while i < max_len:
        val current = ptr_addr + i
        if current < ptr_addr:
            return Err("string pointer overflow")
        if not _is_user_read_range(current, 1):
            return Err("bad string pointer")
        unsafe:
            val byte_ptr = current as *const u8
            val b = *byte_ptr
            if b == 0u8:
                return Ok(_path_bytes_to_text(bytes))
            bytes.push(b)
        i = i + 1
    Err("unterminated string")

fn _copy_user_string_vector(vec_ptr: u64, max_count: u64) -> Result<[text], text>:
    if vec_ptr == 0:
        return Ok([])
    var out: [text] = []
    var total_bytes: u64 = 0
    var i: u64 = 0
    while i < max_count:
        val offset = i * 8
        val slot = vec_ptr + offset
        if slot < vec_ptr:
            return Err("vector pointer overflow")
        val item_ptr_result = _copy_user_u64(slot)
        if item_ptr_result.is_err():
            return Err(item_ptr_result.err().unwrap())
        val item_ptr = item_ptr_result.unwrap()
        if item_ptr == 0:
            return Ok(out)
        val item_result = _copy_user_cstr(item_ptr, MAX_EXEC_STRING_LEN)
        if item_result.is_err():
            return Err(item_result.err().unwrap())
        val item = item_result.unwrap()
        val item_bytes = (item.len() as u64) + 1
        if total_bytes + item_bytes < total_bytes:
            return Err("argument byte overflow")
        total_bytes = total_bytes + item_bytes
        if total_bytes > MAX_EXEC_TOTAL_STRING_BYTES:
            return Err("argument bytes too large")
        out.push(item)
        i = i + 1
    Err("string vector not terminated")

fn _handle_spawn_binary(args: SyscallArgs, scheduler: Scheduler, klog: KernelLog) -> SyscallResult:
    """Spawn a task from a binary path.

    Args:
      arg0: userspace pointer to path bytes
      arg1: path length
      arg2: priority

    The current implementation resolves known service/app paths to
    boot-packaged ELF bytes, validates them, builds a transitional user
    process image, and schedules a user task from that image.
    """
    serial_println("[syscall13] handle_spawn_binary enter")
    if args.arg0 == 0 or args.arg1 == 0:
        return SyscallResult(value: -22)
    val path_bytes_result = _copy_user_bytes(args.arg0, args.arg1)
    if path_bytes_result.is_err():
        return SyscallResult(value: -22)

    val path_bytes = path_bytes_result.unwrap()
    val path = _path_bytes_to_text(path_bytes)
    serial_println("[syscall13] path decoded")
    val arch = CURRENT_EXEC_ARCH
    val bytes_result = resolve_executable_bytes_from_path_bytes(path_bytes, arch)
    serial_println("[syscall13] resolve_executable_bytes returned")
    if bytes_result.is_err():
        var log = klog
        log.write(3, 1, 0, "spawn_binary rejected unknown binary: {path}")
        return SyscallResult(value: -2)
    val _sp_argv: [text] = []
    val _sp_envp: [text] = []
    val image_result = build_user_process_image(path, bytes_result.unwrap(), arch, _sp_argv, _sp_envp)
    if image_result.is_ok():
        val priority = _u64_to_priority(args.arg2)
        val caps = CapabilitySet.full()
        var sched = scheduler
        val before_next_task_id = g_scheduler_next_task_id
        val raw_pid = sched.create_user_task_pid(image_result.unwrap(), priority, caps)
        val pid = if g_scheduler_next_task_id > before_next_task_id:
            g_scheduler_next_task_id - 1
        elif raw_pid > 0 and raw_pid < 0x40000000:
            raw_pid
        else:
            0
        if pid == 0:
            return SyscallResult(value: -12)

        var ulog = klog
        ulog.write(6, 1, pid, "spawn_binary launched user process {path}")
        return SyscallResult(value: pid.to_i64())

    var log = klog
    log.write(3, 1, 0, "spawn_binary rejected invalid executable: {path}")
    SyscallResult(value: -8)

fn _direct_spawn_app_id_path(app_id: u64) -> text?:
    match app_id:
        case 1:
            Some("/sys/apps/browser_demo.smf")
        case 2:
            Some("/sys/apps/file_manager.smf")
        case 3:
            Some("/sys/apps/hello_world.smf")
        case 103:
            Some("/sys/apps/hello_world.smf")
        case 4:
            Some("/sys/apps/shell.smf")
        case 5:
            Some("/sys/apps/editor.smf")
        case _:
            nil

fn _spawn_from_resolved_bytes_for_arch(path: text, path_bytes: [u8], bytes: [u8], priority_raw: u64, scheduler: Scheduler, klog: KernelLog, arch: Architecture) -> i64:
    val _sp_argv: [text] = []
    val _sp_envp: [text] = []
    val _path_bytes = path_bytes
    serial_println("[syscall13] build_user_process_image begin")
    val image_result = build_user_process_image(path, bytes, arch, _sp_argv, _sp_envp)
    if image_result.is_ok():
        serial_println("[syscall13] build_user_process_image ok")
        if _use_x86_64_direct_spawn_handoff(arch):
            val pid = _alloc_x86_64_direct_spawn_pid()
            val pid_value = pid as i64
            var xlog = klog
            xlog.write(6, 1, pid, "spawn_binary validated filesystem user image {path}")
            serial_println("[syscall13] user image handoff ok pid={pid_value}")
            return pid_value
        val priority = _u64_to_priority(priority_raw)
        val caps = CapabilitySet.full()
        var sched = scheduler
        serial_println("[syscall13] create_user_task begin")
        val before_next_task_id = g_scheduler_next_task_id
        val raw_pid = sched.create_user_task_pid(image_result.unwrap(), priority, caps)
        serial_println("[syscall13] create_user_task returned")
        val pid = if g_scheduler_next_task_id > before_next_task_id:
            g_scheduler_next_task_id - 1
        elif raw_pid > 0 and raw_pid < 0x40000000:
            raw_pid
        else:
            0
        if pid == 0:
            serial_println("[syscall13] create_user_task failed")
            return -12
        sched.set_task_name(TaskId(id: pid), path)
        val spawned = sched.get_task(TaskId(id: pid))
        if spawned != nil:
            val task = spawned
            register_task_vmspace(
                pid.to_u32(),
                ProcessVmSpace(
                    pml4: task.address_space,
                    id: task.isolation.address_space_id,
                    vma_count: 0,
                    areas: []
                )
            )

        val pid_value = pid as i64
        var ulog = klog
        ulog.write(6, 1, pid, "spawn_binary launched filesystem user process {path}")
        serial_println("[syscall13] user image handoff ok pid={pid_value}")
        return pid_value
    else:
        serial_println("[syscall13] build_user_process_image failed")

    var log = klog
    log.write(3, 1, 0, "spawn_binary rejected invalid executable: {path}")
    serial_println("[syscall13] rejected invalid filesystem executable")
    -8

fn _spawn_from_resolved_bytes(path: text, path_bytes: [u8], bytes: [u8], priority_raw: u64, scheduler: Scheduler, klog: KernelLog) -> i64:
    _spawn_from_resolved_bytes_for_arch(path, path_bytes, bytes, priority_raw, scheduler, klog, CURRENT_EXEC_ARCH)

fn _builtin_binary_path_for_spawn(path: text) -> text:
    if path.ends_with(".smf") and path.len() > 4:
        return path.substring(0, path.len() - 4)
    path

fn _is_builtin_binary_path(path: text) -> bool:
    resolve_builtin_binary(_builtin_binary_path_for_spawn(path)) != nil

fn dispatch_spawn_binary_direct(path_ptr: u64, path_len: u64, priority_raw: u64, scheduler: Scheduler, klog: KernelLog) -> i64:
    """Dedicated SpawnBinary bridge that avoids the generic syscall wrapper."""
    serial_println("[syscall13] dispatch_direct enter")
    if path_len == 0:
        val sentinel_path = _direct_spawn_app_id_path(path_ptr)
        if sentinel_path != nil:
            val path = sentinel_path.unwrap()
            val bytes_result = resolve_executable_bytes(path, CURRENT_EXEC_ARCH)
            if bytes_result.is_ok():
                return _spawn_from_resolved_bytes(path, [], bytes_result.unwrap(), priority_raw, scheduler, klog)
            if _is_builtin_binary_path(path):
                serial_println("[syscall13] builtin resident fallback path={path}")
                return -2
        return -14

    if path_len > MAX_BINARY_PATH_LEN:
        serial_println("[syscall13] dispatch_direct path too long")
        return -14
    val path_bytes_result = _copy_user_bytes(path_ptr, path_len)
    if path_bytes_result.is_err():
        serial_println("[syscall13] dispatch_direct path copy failed")
        return -14

    val path_bytes = path_bytes_result.unwrap()
    val path = _path_bytes_to_text(path_bytes)
    serial_println("[syscall13] dispatch_direct path-ready")
    val arch = CURRENT_EXEC_ARCH
    serial_println("[syscall13] dispatch_direct arch-ready")

    val bytes_result = resolve_executable_bytes_from_path_bytes(path_bytes, arch)
    serial_println("[syscall13] dispatch_direct resolve returned")
    if bytes_result.is_ok():
        serial_println("[syscall13] vfs bytes ok; exec handoff active")
        return _spawn_from_resolved_bytes(path, path_bytes, bytes_result.unwrap(), priority_raw, scheduler, klog)

    if _is_builtin_binary_path(path):
        serial_println("[syscall13] builtin resident fallback path={path}")
        return -2

    if bytes_result.is_err():
        var log = klog
        log.write(3, 1, 0, "spawn_binary rejected unknown binary: {path}")
        return -2

    -2

# ============================================================================
# IPC Syscall Handlers
# ============================================================================

fn _handle_ipc_send(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Send an IPC message.

    Args:
      arg0: destination port ID
      arg1: method ID
      arg2: flags
      arg3: payload pointer (userspace)
      arg4: payload length
    """
    var sched = scheduler
    val current = sched.get_current()

    val msg = IpcMessage(
        src_port: current.id,
        dst_port: args.arg0,
        method: args.arg1.to_u32(),
        flags: args.arg2.to_u32(),
        payload_len: args.arg4.to_u32(),
        cap_count: 0
    )

    var ipc_mgr = ipc
    val result = ipc_mgr.send(msg)

    # If send succeeded and there was a waiter, unblock it
    if result == 0:
        val waiter = ipc_mgr.get_first_waiter(args.arg0)
        if waiter != nil:
            val waiter_id = waiter
            sched.unblock_task(waiter_id)

    SyscallResult(value: result)

fn _handle_ipc_recv(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Receive an IPC message.

    Args:
      arg0: port ID to receive from
      arg1: timeout in milliseconds (0 = non-blocking, -1 = infinite)
    """
    val port = IpcPort(id: args.arg0, owner: 0)
    val timeout = args.arg1.to_i64()

    var ipc_mgr = ipc
    val msg = ipc_mgr.recv(port, timeout)

    if msg != nil:
        # Message received successfully
        return SyscallResult(value: 0)

    # No message available
    if timeout == 0:
        # Non-blocking — return "would block"
        return SyscallResult(value: -11)    # EAGAIN

    # Blocking recv — block the caller and add to waiter list
    var sched = scheduler
    val current = sched.get_current()
    ipc_mgr.add_waiter(port, current)
    sched.block_task(current, BlockReason.IpcRecv(port: args.arg0))
    SyscallResult(value: 0)

fn _handle_ipc_create_port(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Create a new IPC port.

    Args:
      arg0: pointer to name string (userspace)
      arg1: name length
    """
    var sched = scheduler
    val current = sched.get_current()

    # In a real kernel, we would copy the name from userspace.
    # For now, use a placeholder name based on port ID.
    var ipc_mgr = ipc
    val port = ipc_mgr.create_port(current, "port")
    SyscallResult(value: port.id.to_i64())

fn _handle_ipc_connect(args: SyscallArgs, ipc: IpcManager) -> SyscallResult:
    """Connect to an existing IPC port by name.

    Args:
      arg0: pointer to name string (userspace)
      arg1: name length
    """
    # In a real kernel, we would copy the name from userspace.
    var ipc_mgr = ipc
    val port = ipc_mgr.connect("port")
    if port != nil:
        val p = port
        return SyscallResult(value: p.id.to_i64())
    SyscallResult(value: -1)

# ============================================================================
# Security Syscall Handlers
# ============================================================================

fn _handle_pledge(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Restrict the current task's capabilities (monotonic shrink).

    Args:
      arg0: pointer to allowed capability list (userspace)
      arg1: count of allowed capabilities
    """
    var sched = scheduler
    val current = sched.get_current()
    var ipc_mgr = ipc

    # In a real kernel, we would parse the capability list from userspace.
    # For now, pledge with empty list (maximum restriction).
    ipc_mgr.cap_manager.pledge(current, [])
    sched.restrict_isolation(current, false, 0, 1u32)
    SyscallResult(value: 0)

fn _handle_unveil(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Restrict file access to specific paths.

    Args:
      arg0: pointer to path string (userspace)
      arg1: path length
      arg2: pointer to permissions string (userspace)
      arg3: permissions length
    """
    var sched = scheduler
    val current = sched.get_current()
    var ipc_mgr = ipc

    # In a real kernel, we would copy path and perms from userspace.
    ipc_mgr.cap_manager.unveil(current, "/", "r")
    sched.restrict_isolation(current, false, 0, 1u32)
    SyscallResult(value: 0)

fn _handle_cap_grant(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Grant a capability from the current task to another.

    Args:
      arg0: target task ID
      arg1: capability kind (encoded)
      arg2: capability generation
    """
    var sched = scheduler
    val current = sched.get_current()
    val target = TaskId(id: args.arg0)

    val cap = CapabilityToken(
        kind: CapabilityKind.ProcessSpawn,  # Simplified — real kernel decodes arg1
        generation: args.arg2,
        owner: current.id
    )

    var ipc_mgr = ipc
    val ok = ipc_mgr.cap_grant(current, target, cap)
    if ok:
        SyscallResult(value: 0)
    else:
        SyscallResult(value: -1)

# ============================================================================
# Debug Syscall Handler
# ============================================================================

@cfg(riscv64)
fn _handle_debug_write(args: SyscallArgs) -> SyscallResult:
    """Write a byte to the serial debug port (RV64 — 16550 UART MMIO)."""
    val uart_base: u64 = 0x10000000
    val byte_val = (args.arg0 & 0xFF).to_u8()
    mmio_write8(uart_base, byte_val.to_u32())
    SyscallResult(value: 0)

@cfg(riscv32)
fn _handle_debug_write(args: SyscallArgs) -> SyscallResult:
    """Write a byte to the serial debug port (RV32 — 16550 UART MMIO)."""
    val uart_base: u64 = 0x10000000
    val byte_val = (args.arg0 & 0xFF).to_u8()
    mmio_write8(uart_base, byte_val.to_u32())
    SyscallResult(value: 0)

@cfg(x86_64)
fn _handle_debug_write(args: SyscallArgs) -> SyscallResult:
    """Write a byte to the serial debug port (x86_64 — COM1 port I/O)."""
    val byte_val = args.arg0
    asm:
        "mov dx, 0x3F8"
        "mov al, dil"
        "out dx, al"
    SyscallResult(value: 0)

@cfg(x86)
fn _handle_debug_write(args: SyscallArgs) -> SyscallResult:
    """Write a byte to the serial debug port (x86 — COM1 port I/O)."""
    val byte_val = args.arg0
    asm:
        "mov dx, 0x3F8"
        "mov al, dil"
        "out dx, al"
    SyscallResult(value: 0)

@cfg(arm64)
fn _handle_debug_write(args: SyscallArgs) -> SyscallResult:
    """Write a byte to the serial debug port (ARM64 — PL011 UART MMIO)."""
    val uart_base: u64 = 0x09000000
    val byte_val = (args.arg0 & 0xFF).to_u8()
    mmio_write8(uart_base, byte_val.to_u32())
    SyscallResult(value: 0)

@cfg(arm32)
fn _handle_debug_write(args: SyscallArgs) -> SyscallResult:
    """Write a byte to the serial debug port (ARM32 — PL011 UART MMIO)."""
    val uart_base: u64 = 0x09000000
    val byte_val = (args.arg0 & 0xFF).to_u8()
    mmio_write8(uart_base, byte_val.to_u32())
    SyscallResult(value: 0)

# ============================================================================
# Helper Functions
# ============================================================================

# ============================================================================
# Extended Process Handlers
# ============================================================================

fn _handle_list_tasks(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """List active task IDs and return the active task count.

    If arg0 is non-zero, it points to a u64 PID buffer with arg1 slots. The
    count return remains the total active task count so callers can retry with
    a larger buffer without losing the legacy "count only" behavior.
    """
    val count = scheduler.active_task_count()
    if args.arg0 != 0 and args.arg1 > 0:
        val max = args.arg1 as i32
        val write_count = if count < max: count else: max
        val bytes = (write_count as u64) * 8
        if write_count > 0:
            if not _is_userspace_range(args.arg0, bytes):
                return SyscallResult(value: -14)
            if not vmm_verify_user_write(args.arg0, bytes):
                return SyscallResult(value: -14)
            var i = 0
            while i < write_count:
                mmio_write64(args.arg0 + (i as u64) * 8, scheduler.task_id_at_active_index(i))
                i = i + 1
    SyscallResult(value: count.to_i64())

fn _task_state_code(state: TaskState) -> u8:
    match state:
        case TaskState.Ready: 0u8
        case TaskState.Running: 1u8
        case TaskState.Blocked(reason): 2u8
        case TaskState.Zombie: 3u8

fn _task_priority_code(priority: TaskPriority) -> u8:
    match priority:
        case TaskPriority.Realtime: 0u8
        case TaskPriority.High: 1u8
        case TaskPriority.Normal: 2u8
        case TaskPriority.Low: 3u8
        case TaskPriority.Idle: 4u8

fn _handle_get_task_info(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Get info for a specific task by PID.

    Args:
      arg0: target task PID
      arg1: pointer to TaskInfoBuf fixed prefix
      arg2: optional pointer to caller-provided name buffer
      arg3: name buffer capacity in bytes
    Returns: 0 on success (info written to shared buffer), -1 if not found.
    """
    val target = TaskId(id: args.arg0)
    val tcb = scheduler.get_task(target)
    if tcb == nil:
        return SyscallResult(value: -1)
    if args.arg1 != 0:
        # Fixed prefix of TaskInfoBuf:
        # pid:u64, parent_pid:u64, state:u8, priority:u8, padding, memory:u64,
        # cpu_ticks:u64, name_len:u32.
        if not _is_userspace_range(args.arg1, 44):
            return SyscallResult(value: -14)
        if not vmm_verify_user_write(args.arg1, 44):
            return SyscallResult(value: -14)
        val task = tcb
        val parent_pid = if task.parent == nil: 0 else: task.parent.unwrap().id
        val memory_pages = if task.address_space == 0: 0 else: 1
        val name_bytes = rt_text_to_bytes(task.name)
        val name_len = name_bytes.len() as u32
        val name_len_u64 = name_len as u64
        mmio_write64(args.arg1, task.id.id)
        mmio_write64(args.arg1 + 8, parent_pid)
        mmio_write8(args.arg1 + 16, _task_state_code(task.state))
        mmio_write8(args.arg1 + 17, _task_priority_code(task.priority))
        mmio_write64(args.arg1 + 24, memory_pages)
        mmio_write64(args.arg1 + 32, task.ticks_remaining)
        mmio_write32(args.arg1 + 40, name_len)
        if args.arg2 != 0 and args.arg3 > 0 and name_len > 0:
            val max = if name_len_u64 < args.arg3: name_len_u64 else: args.arg3
            if not _is_userspace_range(args.arg2, max):
                return SyscallResult(value: -14)
            if not vmm_verify_user_write(args.arg2, max):
                return SyscallResult(value: -14)
            var i = 0u64
            while i < max:
                mmio_write8(args.arg2 + i, name_bytes[i])
                i = i + 1
    SyscallResult(value: 0)

fn _handle_signal(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Send a signal to a task.

    Args:
      arg0: target task PID
      arg1: signal kind (0=Term, 1=Kill, 2=Stop, 3=Cont, 4=Int)
    """
    val target = TaskId(id: args.arg0)
    val signal = args.arg1

    var sched = scheduler
    val tcb = sched.get_task(target)
    if tcb == nil:
        return SyscallResult(value: -1)

    match signal:
        case 0:     # Term
            sched.exit_task_by_id(target, -15)
        case 1:     # Kill (uncatchable)
            sched.exit_task_by_id(target, -9)
        case 2:     # Stop
            sched.block_task(target, BlockReason.Signal)
        case 3:     # Cont
            sched.unblock_task(target)
        case 4:     # Int (Ctrl+C)
            sched.exit_task_by_id(target, -2)
        case _:
            return SyscallResult(value: -22)    # EINVAL
    SyscallResult(value: 0)

fn _handle_set_priority(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Change a task's scheduling priority.

    Args:
      arg0: target task PID
      arg1: new priority (0-4)
    """
    val target = TaskId(id: args.arg0)
    val priority = _u64_to_priority(args.arg1)
    var sched = scheduler
    val ok = sched.set_priority(target, priority)
    if ok:
        SyscallResult(value: 0)
    else:
        SyscallResult(value: -1)

fn _handle_schedule(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Scheduler control fast path.

    arg0:
      0 = yield current task
      1 = return current task id
      2 = return scheduler tick count
    """
    var sched = scheduler
    if args.arg0 == 0:
        sched.yield_current()
        return SyscallResult(value: 0)
    if args.arg0 == 1:
        val current = sched.get_current()
        return SyscallResult(value: current.id.to_i64())
    if args.arg0 == 2:
        return SyscallResult(value: sched.get_tick_count().to_i64())
    SyscallResult(value: -22)

fn _handle_schedctl(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Set/query scheduler policy metadata.

    arg0 = op: 0 query policy, 1 set policy metadata,
          2 query isolation field, 3 restrict isolation metadata,
          4 admit deadline policy, 5 configure RT CPU bandwidth
    arg1 = target task id
    op 1: arg2 policy, arg3 weight, arg4 requested slice ns, arg5 affinity
    op 2: arg2 field selector
    op 3: arg2 allow_network, arg3 max_memory_pages, arg4 max_threads
    op 4: arg2 runtime ns, arg3 period ns, arg4 deadline ns, arg5 affinity
    op 5: arg2 cpu id, arg3 runtime ns, arg4 period ns
    """
    val op = args.arg0
    val target = TaskId(id: args.arg1)
    var sched = scheduler
    val tcb = sched.get_task(target)
    if tcb == nil:
        return SyscallResult(value: -3)
    val task = tcb

    if op == 0:
        return SyscallResult(value: _scheduler_policy_to_u64(task.schedule.policy).to_i64())

    if op == 1:
        var config = task.schedule
        val policy = _u64_to_scheduler_policy(args.arg2)
        if policy == SchedulerPolicy.Deadline:
            return SyscallResult(value: -95)
        if policy == SchedulerPolicy.RtFifo or policy == SchedulerPolicy.RtRoundRobin:
            if not sched.rt_budget_configured(task.assigned_cpu):
                return SyscallResult(value: -22)
        config.policy = policy
        if args.arg3 > 0:
            config.weight = args.arg3.to_i64()
        if args.arg4 > 0:
            config.requested_slice_ns = args.arg4
            config.virtual_deadline = (config.vruntime + args.arg4.to_i64())
        if args.arg5 > 0:
            config.affinity_mask = args.arg5
        val ok = sched.set_schedule_config(target, config)
        if ok:
            return SyscallResult(value: 0)
        return SyscallResult(value: -1)

    if op == 2:
        match args.arg2:
            case 0:
                return SyscallResult(value: task.isolation.capability_generation.to_i64())
            case 1:
                val sandboxed = if task.isolation.sandboxed: 1 else: 0
                return SyscallResult(value: sandboxed)
            case 2:
                val network = if task.isolation.allow_network: 1 else: 0
                return SyscallResult(value: network)
            case 3:
                return SyscallResult(value: task.isolation.max_memory_pages.to_i64())
            case 4:
                return SyscallResult(value: task.isolation.max_threads.to_i64())
            case 5:
                return SyscallResult(value: task.isolation.address_space_id.to_i64())
            case _:
                return SyscallResult(value: -22)

    if op == 3:
        val allow_network = args.arg2 != 0
        val max_threads = args.arg4.to_u32()
        val ok = sched.restrict_isolation(target, allow_network, args.arg3, max_threads)
        if ok:
            return SyscallResult(value: 0)
        return SyscallResult(value: -1)

    if op == 4:
        val result = sched.admit_deadline(target, args.arg2, args.arg3, args.arg4, args.arg5)
        return SyscallResult(value: result.to_i64())

    if op == 5:
        val result = sched.configure_rt_bandwidth(args.arg2.to_u32(), args.arg3, args.arg4)
        return SyscallResult(value: result.to_i64())

    SyscallResult(value: -22)

fn _handle_get_parent_pid(scheduler: Scheduler) -> SyscallResult:
    """Return the current task's parent PID."""
    val current = scheduler.get_current()
    val tcb = scheduler.get_task(current)
    if tcb == nil:
        return SyscallResult(value: 0)
    SyscallResult(value: tcb.parent_id.to_i64())

# ============================================================================
# File Mount/Unmount Handlers
# ============================================================================

fn _handle_mount(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Mount a filesystem. Routed to VFS service via IPC.

    Args:
      arg0: device path pointer
      arg1: mount path pointer
      arg2: fs type pointer
      arg3: flags
    """
    # Route to VFS service via IPC method 10 (MOUNT)
    var sched = scheduler
    val current = sched.get_current()
    val msg = IpcMessage(
        src_port: current.id,
        dst_port: 0,    # VFS service port (resolved at runtime)
        method: 10,     # MOUNT
        flags: 0,
        payload_len: 0,
        cap_count: 0
    )
    var ipc_mgr = ipc
    val result = ipc_mgr.send(msg)
    SyscallResult(value: result)

fn _handle_unmount(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Unmount a filesystem. Routed to VFS service via IPC.

    Args:
      arg0: mount path pointer
      arg1: path length
    """
    var sched = scheduler
    val current = sched.get_current()
    val msg = IpcMessage(
        src_port: current.id,
        dst_port: 0,
        method: 11,     # UNMOUNT
        flags: 0,
        payload_len: 0,
        cap_count: 0
    )
    var ipc_mgr = ipc
    val result = ipc_mgr.send(msg)
    SyscallResult(value: result)

# ============================================================================
# Device Handlers
# ============================================================================

fn _pci_scan_all():
    """Scan PCI buses 0-255, devices 0-31, functions 0-7 and populate the cache."""
    if _pci_scanned:
        return
    _pci_scanned = true
    _pci_devices_count = 0
    var bus: u16 = 0
    while bus < 256:
        var dev: u8 = 0
        while dev < 32:
            val bus_u8 = bus.to_u8()
            val vendor = pci_read_vendor(bus_u8, dev, 0)
            if vendor != 0xFFFF:
                # Function 0 exists — record it
                _pci_cache_function(bus_u8, dev, 0)
                # Check multi-function bit (bit 7 of header type)
                val header_type = pci_read_header_type(bus_u8, dev, 0)
                if (header_type & 0x80) != 0:
                    var func: u8 = 1
                    while func < 8:
                        val fv = pci_read_vendor(bus_u8, dev, func)
                        if fv != 0xFFFF:
                            _pci_cache_function(bus_u8, dev, func)
                        func = func + 1
            dev = dev + 1
        bus = bus + 1

fn _pci_cache_function(bus: u8, device: u8, func: u8):
    """Read PCI config for one function and store in the flat cache arrays."""
    if _pci_devices_count >= MAX_PCI_DEVICES:
        return
    val idx = _pci_devices_count
    val vendor = pci_read_vendor(bus, device, func)
    val devid = pci_read_device_id(bus, device, func)
    val class_info = pci_read_class(bus, device, func)
    val cc_raw = (class_info >> 24) & 0xFF
    val class_code = cc_raw.to_u8()
    val sc_raw = (class_info >> 16) & 0xFF
    val subclass = sc_raw.to_u8()
    val pi_raw = (class_info >> 8) & 0xFF
    val prog_if = pi_raw.to_u8()
    val irq = pci_read_irq(bus, device, func)
    _pci_dev_bus[idx] = bus
    _pci_dev_device[idx] = device
    _pci_dev_func[idx] = func
    _pci_dev_vendor[idx] = vendor
    _pci_dev_devid[idx] = devid
    _pci_dev_class[idx] = class_code
    _pci_dev_subclass[idx] = subclass
    _pci_dev_prog_if[idx] = prog_if
    _pci_dev_irq[idx] = irq
    _pci_devices_count = _pci_devices_count + 1

fn _pci_write_device_info_buf(ptr: u64, idx: u64):
    """Write cached device info at index `idx` into a DeviceInfoBuf at `ptr`.

    DeviceInfoBuf @repr("C") layout:
      offset 0: bus (u8)
      offset 1: device (u8)
      offset 2: func (u8)
      offset 3: (padding)
      offset 4: vendor_id (u16)
      offset 6: device_id (u16)
      offset 8: class_code (u8)
      offset 9: subclass (u8)
      offset 10: prog_if (u8)
      offset 11: irq_line (u8)
    """
    mmio_write8(ptr + 0, _pci_dev_bus[idx])
    mmio_write8(ptr + 1, _pci_dev_device[idx])
    mmio_write8(ptr + 2, _pci_dev_func[idx])
    mmio_write16(ptr + 4, _pci_dev_vendor[idx])
    mmio_write16(ptr + 6, _pci_dev_devid[idx])
    mmio_write8(ptr + 8, _pci_dev_class[idx])
    mmio_write8(ptr + 9, _pci_dev_subclass[idx])
    mmio_write8(ptr + 10, _pci_dev_prog_if[idx])
    mmio_write8(ptr + 11, _pci_dev_irq[idx])

fn _handle_dev_enumerate(args: SyscallArgs) -> SyscallResult:
    """Enumerate PCI devices.

    Protocol (matches userlib/device.spl):
      arg0 == 0: return total device count (lazy-scan on first call)
      arg0 == 1: arg1 = device index, arg2 = pointer to DeviceInfoBuf
                 copy cached info into buffer, return 0 on success, -1 on bad index
    """
    _pci_scan_all()
    val mode = args.arg0
    if mode == 0:
        # Return device count
        SyscallResult(value: _pci_devices_count as i64)
    else if mode == 1:
        val index = args.arg1
        val buf_ptr = args.arg2
        if index >= _pci_devices_count:
            SyscallResult(value: -1)
        else if not vmm_verify_user_write(buf_ptr, 12):
            SyscallResult(value: -14)  # EFAULT
        else:
            _pci_write_device_info_buf(buf_ptr, index)
            SyscallResult(value: 0)
    else if mode == 4:
        # Single-field read mode (used by pcimgr)
        # arg1 = device index, arg2 = field selector
        # Fields: 0=bus, 1=device, 2=func, 3=class, 4=subclass, 5=vendor, 6=devid
        val index = args.arg1
        val field = args.arg2
        if index >= _pci_devices_count:
            SyscallResult(value: -1)
        else:
            val v: i64 = match field:
                0: _pci_dev_bus[index] as i64
                1: _pci_dev_device[index] as i64
                2: _pci_dev_func[index] as i64
                3: _pci_dev_class[index] as i64
                4: _pci_dev_subclass[index] as i64
                5: _pci_dev_vendor[index] as i64
                6: _pci_dev_devid[index] as i64
                _: -1
            SyscallResult(value: v)
    else:
        SyscallResult(value: -1)

fn _handle_dev_get_info(args: SyscallArgs) -> SyscallResult:
    """Get info for a specific PCI device by BDF.

    Protocol (matches userlib/device.spl):
      arg0: packed BDF — bus<<16 | dev<<8 | func
      arg1: pointer to DeviceInfoBuf
    Reads PCI config space directly (no cache needed) and fills the buffer.
    Returns 0 on success, -1 if the device does not exist (vendor == 0xFFFF).
    """
    val bdf = args.arg0
    val buf_ptr = args.arg1

    # Verify buf_ptr is user-writable before writing device info
    if not vmm_verify_user_write(buf_ptr, 12):
        return SyscallResult(value: -14)  # EFAULT

    val bus = ((bdf >> 16) & 0xFF).to_u8()
    val dev = ((bdf >> 8) & 0xFF).to_u8()
    val func = (bdf & 0xFF).to_u8()
    val vendor = pci_read_vendor(bus, dev, func)
    if vendor == 0xFFFF:
        SyscallResult(value: -1)
    else:
        val devid = pci_read_device_id(bus, dev, func)
        val class_info = pci_read_class(bus, dev, func)
        val cc_raw = (class_info >> 24) & 0xFF
        val class_code = cc_raw.to_u8()
        val sc_raw = (class_info >> 16) & 0xFF
        val subclass = sc_raw.to_u8()
        val pi_raw = (class_info >> 8) & 0xFF
        val prog_if = pi_raw.to_u8()
        val irq = pci_read_irq(bus, dev, func)
        # Write into DeviceInfoBuf at buf_ptr
        mmio_write8(buf_ptr + 0, bus)
        mmio_write8(buf_ptr + 1, dev)
        mmio_write8(buf_ptr + 2, func)
        mmio_write16(buf_ptr + 4, vendor)
        mmio_write16(buf_ptr + 6, devid)
        mmio_write8(buf_ptr + 8, class_code)
        mmio_write8(buf_ptr + 9, subclass)
        mmio_write8(buf_ptr + 10, prog_if)
        mmio_write8(buf_ptr + 11, irq)
        SyscallResult(value: 0)

# ============================================================================
# Device Grant / BAR / DMA Handlers
# ============================================================================

fn _pci_bar_size(bus: u8, dev: u8, func: u8, bar_num: u8) -> u64:
    """Detect the size of a PCI BAR by writing all-ones and reading back."""
    val offset = (0x10 + bar_num * 4).to_u8()
    val original = pci_read_bar(bus, dev, func, bar_num)
    pci_write_config(bus, dev, func, offset, 0xFFFFFFFF)
    val readback = pci_read_bar(bus, dev, func, bar_num)
    pci_write_config(bus, dev, func, offset, original)
    if readback == 0:
        return 0
    val mask = readback & 0xFFFFFFF0  # Mask type bits for MMIO BAR
    val size = (~mask + 1) as u64
    size

fn _handle_device_grant(args: SyscallArgs, scheduler: Scheduler, caller: TaskId) -> SyscallResult:
    """Build a DeviceGrant for a PCI device and write it to caller memory.

    Protocol:
      arg0: packed BDF — bus<<16 | dev<<8 | func
      arg1: pointer to DeviceGrant struct in caller memory
    Reads PCI config, creates IRQ notification, fills the struct.
    Registers the notification and IRQ route as task resources so they
    are cleaned up when the task exits.
    Returns 0 on success, -1 if the device does not exist (vendor == 0xFFFF).
    """
    val bdf = args.arg0
    val grant_ptr = args.arg1 as u64

    # Validate grant_ptr is user-writable via page table walk
    if not _is_userspace_ptr(grant_ptr):
        return SyscallResult(value: -14)  # EFAULT: bad address
    if not vmm_verify_user_write(grant_ptr, 120):
        return SyscallResult(value: -14)  # EFAULT: not user-writable

    val bus = ((bdf >> 16) & 0xFF).to_u8()
    val dev = ((bdf >> 8) & 0xFF).to_u8()
    val func = (bdf & 0xFF).to_u8()

    val vendor = pci_read_vendor(bus, dev, func)
    if vendor == 0xFFFF:
        return SyscallResult(value: -1)

    val devid = pci_read_device_id(bus, dev, func)
    val class_info = pci_read_class(bus, dev, func)
    val class_code = ((class_info >> 24) & 0xFF).to_u8()
    val subclass = ((class_info >> 16) & 0xFF).to_u8()
    val irq_line = pci_read_irq(bus, dev, func)
    val irq_vector = (VEC_IRQ_BASE + irq_line as u32)

    # BAR0 address and size
    val bar0_raw = pci_read_bar(bus, dev, func, 0)
    val bar0_phys = (bar0_raw & 0xFFFFFFF0) as u64
    val bar0_size = _pci_bar_size(bus, dev, func, 0)

    # Create notification object for IRQ delivery
    val notif_id = notification_create(g_notification_table)
    val notif_bit: u64 = 1

    # Register IRQ route so hardware interrupt signals the notification
    irq_route_register(irq_vector, notif_id, notif_bit)

    # Register resources for cleanup when the calling task exits
    task_register_resource(caller.id, RES_NOTIFICATION, notif_id, 0)
    task_register_resource(caller.id, RES_IRQ_ROUTE, irq_vector as u64, 0)

    # Write DeviceGrant struct fields to caller memory
    # offset 0: u16 pci_vendor
    mmio_write16(grant_ptr + 0, vendor)
    # offset 2: u16 pci_device
    mmio_write16(grant_ptr + 2, devid)
    # offset 4: u8 pci_bus
    mmio_write8(grant_ptr + 4, bus)
    # offset 5: u8 pci_dev
    mmio_write8(grant_ptr + 5, dev)
    # offset 6: u8 pci_func
    mmio_write8(grant_ptr + 6, func)
    # offset 7: u8 pci_class
    mmio_write8(grant_ptr + 7, class_code)
    # offset 8: u8 pci_subclass
    mmio_write8(grant_ptr + 8, subclass)
    # offset 9-15: padding (7 bytes, skip)
    # offset 16: u64 bar0_phys
    mmio_write64(grant_ptr + 16, bar0_phys)
    # offset 24: u64 bar0_size
    mmio_write64(grant_ptr + 24, bar0_size)
    # offset 32: u64 bar0_cap (0 = no cap restriction)
    mmio_write64(grant_ptr + 32, 0)
    # offset 40: u32 irq_vector
    mmio_write32(grant_ptr + 40, irq_vector)
    # offset 44: padding (4 bytes, skip)
    # offset 48: u64 irq_notification_id
    mmio_write64(grant_ptr + 48, notif_id)
    # offset 56: u64 irq_notification_bit
    mmio_write64(grant_ptr + 56, notif_bit)
    # offset 64: u64 irq_cap (0 = no cap restriction)
    mmio_write64(grant_ptr + 64, 0)
    # offset 72: u64 dma_device_addr (0 = not yet allocated)
    mmio_write64(grant_ptr + 72, 0)
    # offset 80: u64 dma_host_addr (0 = not yet allocated)
    mmio_write64(grant_ptr + 80, 0)
    # offset 88: u64 dma_size (0 = not yet allocated)
    mmio_write64(grant_ptr + 88, 0)
    # offset 96: u64 dma_cap (0 = no cap restriction)
    mmio_write64(grant_ptr + 96, 0)
    # offset 104: u32 iommu_domain_id (0 = no IOMMU)
    mmio_write32(grant_ptr + 104, 0)
    # offset 108: padding (4 bytes, skip)
    # offset 112: u64 iommu_cap (0 = no IOMMU)
    mmio_write64(grant_ptr + 112, 0)

    SyscallResult(value: 0)

fn _handle_map_bar(args: SyscallArgs) -> SyscallResult:
    """Map a physical BAR into the caller's address space.

    Protocol:
      arg0: physical BAR address
      arg1: size (bytes)
      arg2: virtual address hint (0 = kernel picks)
    Maps pages with PRESENT | WRITABLE | CACHE_DISABLE | NO_EXECUTE.
    Returns the mapped virtual address on success, -12 (ENOMEM) on failure.

    Safety: Rejects addresses below PCI_MMIO_FLOOR (likely RAM, not device MMIO).
    Rejects sizes above 256MB. Hint addresses must be in userspace range.
    """
    val bar_phys = args.arg0 as u64
    val size = args.arg1 as u64
    val hint = args.arg2 as u64

    if size == 0 or size > 0x10000000:
        return SyscallResult(value: -22)  # EINVAL: empty or >256MB

    # Reject mapping physical RAM — BARs live above the PCI MMIO window
    if bar_phys < PCI_MMIO_FLOOR:
        return SyscallResult(value: -1)  # EPERM: not a device MMIO address

    # Reject kernel-space hint addresses
    if hint != 0 and _is_kernel_addr(hint):
        return SyscallResult(value: -1)  # EPERM: kernel address

    val page_count = (size + PAGE_SIZE - 1) / PAGE_SIZE

    # Determine base virtual address
    var base_virt: u64 = hint
    if base_virt == 0:
        base_virt = _next_mmap_addr

    val flags = VmFlags(bits: VM_PRESENT | VM_WRITABLE | VM_CACHE_DISABLE | VM_NO_EXECUTE)

    # Map each page: physical BAR pages are identity-mapped from the BAR base
    var offset: u64 = 0
    while offset < page_count:
        val virt = VirtAddr(addr: base_virt + offset * PAGE_SIZE)
        val phys = PhysAddr(addr: bar_phys + offset * PAGE_SIZE)
        val ok = vmm_map_page(virt, phys, flags)
        if !ok:
            return SyscallResult(value: -12)  # ENOMEM
        offset = offset + 1

    # Advance bump allocator if we picked the address
    if hint == 0:
        _next_mmap_addr = base_virt + page_count * PAGE_SIZE

    SyscallResult(value: base_virt as i64)

fn _dma_find_slot(virt_addr: u64) -> i64:
    var i: u64 = 0
    while i < MAX_DMA_ALLOCS:
        if dma_alloc_active[i] != 0 and dma_alloc_virt[i] == virt_addr:
            return i.to_i64()
        i = i + 1
    -1

fn _dma_register_alloc(owner: TaskId, virt_addr: u64, phys_addr: u64, size: u64, owner_device: u64, cache_policy: u8, allocation_id: u64) -> bool:
    var i: u64 = 0
    while i < MAX_DMA_ALLOCS:
        if dma_alloc_active[i] == 0:
            dma_alloc_active[i] = 1
            dma_alloc_owner[i] = owner.id
            dma_alloc_virt[i] = virt_addr
            dma_alloc_phys[i] = phys_addr
            dma_alloc_size[i] = size
            dma_alloc_device[i] = owner_device
            dma_alloc_cache_policy[i] = cache_policy
            dma_alloc_id[i] = allocation_id
            return true
        i = i + 1
    false

fn _dma_unregister_alloc(virt_addr: u64):
    val idx = _dma_find_slot(virt_addr)
    if idx < 0:
        return
    val i = idx.to_u64()
    dma_alloc_active[i] = 0
    dma_alloc_owner[i] = 0
    dma_alloc_virt[i] = 0
    dma_alloc_phys[i] = 0
    dma_alloc_size[i] = 0
    dma_alloc_device[i] = 0
    dma_alloc_cache_policy[i] = 0
    dma_alloc_id[i] = 0

fn _dma_free_pages(virt_addr: u64, size: u64):
    val page_count = (size + PAGE_SIZE - 1) / PAGE_SIZE
    var offset: u64 = 0
    while offset < page_count:
        val virt = VirtAddr(addr: virt_addr + offset * PAGE_SIZE)
        val pte = vmm_read_pte(virt)
        if pte != 0:
            val phys_addr = pte & PTE_ADDR_MASK
            vmm_unmap_page(virt)
            pmm_free_page(PageFrame.from_phys_addr(PhysAddr(addr: phys_addr)))
        offset = offset + 1

fn _dma_release_task_allocs(owner: TaskId):
    """Release all live DMA records owned by a task before final cleanup."""
    var i: u64 = 0
    while i < MAX_DMA_ALLOCS:
        if dma_alloc_active[i] != 0 and dma_alloc_owner[i] == owner.id:
            val virt_addr = dma_alloc_virt[i]
            val size = dma_alloc_size[i]
            _dma_free_pages(virt_addr, size)
            task_unregister_resource(owner.id, RES_DMA_BUFFER, virt_addr)
            dma_alloc_active[i] = 0
            dma_alloc_owner[i] = 0
            dma_alloc_virt[i] = 0
            dma_alloc_phys[i] = 0
            dma_alloc_size[i] = 0
            dma_alloc_device[i] = 0
            dma_alloc_cache_policy[i] = 0
            dma_alloc_id[i] = 0
        i = i + 1

fn _handle_alloc_dma(args: SyscallArgs, caller: TaskId) -> SyscallResult:
    """Allocate a contiguous DMA buffer and map it into caller's address space.

    Protocol:
      arg0: size (bytes, should be page-aligned)
      arg1: pointer to write result pair (phys_addr: u64, allocation_id: u64)
      arg2: packed owner BDF (bus<<16 | dev<<8 | func), 0 for legacy callers
      arg3: cache policy (0=coherent, 1=flush-required, 2=uncached, 3=WC)
    For no-IOMMU case: device_addr == host_phys_addr (identity).
    Returns the virtual address on success, -12 (ENOMEM) on allocation failure.

    Safety: Rejects sizes above 64MB. Validates result_ptr is in userspace range.
    """
    val size = args.arg0 as u64
    val result_ptr = args.arg1 as u64
    val owner_device = args.arg2 as u64
    var cache_policy = args.arg3.to_u8()
    if cache_policy > 3:
        cache_policy = 0

    if size == 0 or size > 0x10000000:
        return SyscallResult(value: -22)  # EINVAL: empty or >256MB

    # Validate result_ptr is user-writable via page table walk
    if not _is_userspace_ptr(result_ptr):
        return SyscallResult(value: -14)  # EFAULT: bad address
    if not vmm_verify_user_write(result_ptr, 16):
        return SyscallResult(value: -14)  # EFAULT: not user-writable

    val page_count = (size + PAGE_SIZE - 1) / PAGE_SIZE

    # Pick a virtual base from the bump allocator
    val base_virt = _next_mmap_addr

    val flags = VmFlags(bits: VM_PRESENT | VM_WRITABLE | VM_CACHE_DISABLE | VM_NO_EXECUTE)

    # Allocate physical pages and map them
    # Track the first physical address for the DMA descriptor
    var first_phys: u64 = 0
    var offset: u64 = 0
    while offset < page_count:
        if val Some(frame) = pmm_alloc_page():
            val phys = frame.to_phys_addr()
            if offset == 0:
                first_phys = phys.addr
            val virt = VirtAddr(addr: base_virt + offset * PAGE_SIZE)
            val ok = vmm_map_page(virt, phys, flags)
            if !ok:
                # Mapping failed — free the frame we just allocated
                pmm_free_page(frame)
                return SyscallResult(value: -12)  # ENOMEM
        else:
            return SyscallResult(value: -12)  # ENOMEM
        offset = offset + 1

    # Advance bump allocator
    _next_mmap_addr = base_virt + page_count * PAGE_SIZE

    val allocation_id = dma_alloc_next_id
    dma_alloc_next_id = dma_alloc_next_id + 1

    # Write the (phys_addr, allocation_id) pair to caller memory
    # No-IOMMU: device_addr == host_phys_addr
    mmio_write64(result_ptr + 0, first_phys)
    mmio_write64(result_ptr + 8, allocation_id)

    val registered = _dma_register_alloc(caller, base_virt, first_phys, page_count * PAGE_SIZE, owner_device, cache_policy, allocation_id)
    if not registered:
        _dma_free_pages(base_virt, page_count * PAGE_SIZE)
        return SyscallResult(value: -12)  # ENOMEM: tracking table full
    val cleanup_tracked = task_register_resource(caller.id, RES_DMA_BUFFER, base_virt, page_count * PAGE_SIZE)
    if not cleanup_tracked:
        _dma_unregister_alloc(base_virt)
        _dma_free_pages(base_virt, page_count * PAGE_SIZE)
        return SyscallResult(value: -12)  # ENOMEM: task cleanup table full

    SyscallResult(value: base_virt as i64)

fn _handle_free_dma(args: SyscallArgs, caller: TaskId) -> SyscallResult:
    """Free a DMA buffer by unmapping its pages.

    Protocol:
      arg0: virtual address
      arg1: size (bytes)
    Unmaps pages from the caller's address space.
    Returns 0 on success.

    Safety: Rejects kernel-space addresses and zero address.
    """
    val virt_addr = args.arg0 as u64
    val size = args.arg1 as u64
    val owner_device = args.arg2 as u64

    if size == 0:
        return SyscallResult(value: -22)  # EINVAL

    # Reject kernel-space or null addresses
    if not _is_userspace_ptr(virt_addr):
        return SyscallResult(value: -1)  # EPERM

    val idx = _dma_find_slot(virt_addr)
    if idx < 0:
        return SyscallResult(value: -22)  # EINVAL: unknown allocation
    val slot = idx.to_u64()
    if dma_alloc_owner[slot] != caller.id:
        return SyscallResult(value: -1)  # EPERM: wrong owner
    if owner_device != 0 and dma_alloc_device[slot] != owner_device:
        return SyscallResult(value: -1)  # EPERM: wrong device association
    if dma_alloc_size[slot] != ((size + PAGE_SIZE - 1) / PAGE_SIZE) * PAGE_SIZE:
        return SyscallResult(value: -22)  # EINVAL: size mismatch

    _dma_free_pages(virt_addr, dma_alloc_size[slot])
    _dma_unregister_alloc(virt_addr)
    task_unregister_resource(caller.id, RES_DMA_BUFFER, virt_addr)

    SyscallResult(value: 0)

# ============================================================================
# Logging Handlers
# ============================================================================

fn _handle_log_write(args: SyscallArgs, scheduler: Scheduler, klog: KernelLog) -> SyscallResult:
    """Write a structured log entry.

    Args:
      arg0: level (0-7)
      arg1: facility
      arg2: message pointer
      arg3: message length
    """
    val level = args.arg0.to_u8()
    val facility = args.arg1.to_u16()
    val pid = scheduler.get_current().id
    # In a real kernel, copy message from userspace pointer.
    var log = klog
    log.write(level, facility, pid, "")
    SyscallResult(value: 0)

fn _handle_log_read(args: SyscallArgs, klog: KernelLog) -> SyscallResult:
    """Read log entries from the kernel journal.

    Args:
      arg0: minimum level filter
      arg1: offset (start from this entry)
      arg2: max count
    Returns: number of entries read.
    """
    val min_level = args.arg0.to_u8()
    val offset = args.arg1
    val max_count = args.arg2
    val entries = klog.read(min_level, offset, max_count)
    SyscallResult(value: entries.len().to_i64())

# ============================================================================
# Time Syscall Handlers
# ============================================================================

fn _handle_clock_get_time(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Get the current time from a specified clock.

    Args:
      arg0: clock_id (0 = CLOCK_REALTIME, 1 = CLOCK_MONOTONIC)
      arg1: pointer to output buffer [u64 seconds, u64 nanoseconds]
    Returns: 0 on success, -22 (EINVAL) for bad clock_id, -14 (EFAULT) for bad pointer
    """
    val clock_id = args.arg0
    val out_ptr = args.arg1

    # Validate clock_id
    if clock_id > 1:
        return SyscallResult(value: -22)  # EINVAL

    # Validate output pointer (16 bytes: two u64 fields)
    if not vmm_verify_user_write(out_ptr, 16):
        return SyscallResult(value: -14)  # EFAULT

    match clock_id:
        case 0:     # CLOCK_REALTIME
            val hours = rtc_get_hours().to_u64()
            val minutes = rtc_get_minutes().to_u64()
            val secs = rtc_get_seconds().to_u64()
            val seconds_since_midnight = hours * 3600 + minutes * 60 + secs
            mmio_write64(out_ptr, seconds_since_midnight)
            mmio_write64(out_ptr + 8, 0)    # nanoseconds = 0
            SyscallResult(value: 0)
        case 1:     # CLOCK_MONOTONIC
            var sched = scheduler
            val ticks = sched.tick_count()
            # 1 tick = 10ms = 10,000,000 ns
            val total_ns = ticks * 10000000
            val seconds = total_ns / 1000000000
            val nanoseconds = total_ns % 1000000000
            mmio_write64(out_ptr, seconds)
            mmio_write64(out_ptr + 8, nanoseconds)
            SyscallResult(value: 0)
        case _:
            SyscallResult(value: -22)  # EINVAL

fn _handle_sleep(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Sleep for the specified duration.

    Args:
      arg0: nanoseconds to sleep
    Returns: 0 on success
    """
    val nanos = args.arg0
    if nanos == 0:
        return SyscallResult(value: 0)
    val rounded = nanos + 9999999
    val ticks_to_wait = if rounded < nanos:
        0xFFFFFFFFFFFFFFFF
    else:
        rounded / 10000000
    var sched = scheduler
    val deadline_ns = (sched.tick_count() + ticks_to_wait) * 10000000
    val current = sched.get_current()
    sched.block_task(current, BlockReason.Sleep(until_ns: deadline_ns))
    SyscallResult(value: 0)

# ============================================================================
# System Info Handlers
# ============================================================================

# Module-level hostname storage
var _hostname: text = "simpleos"

fn _handle_sysinfo(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Query system information.

    Args:
      arg0: SysInfoKind (0=Memory, 1=CpuCount, 2=Uptime, 3=TickCount)
    """
    match args.arg0:
        case 0:     # Memory
            # In a real kernel, query PMM for page stats.
            SyscallResult(value: 0)
        case 1:     # CpuCount
            SyscallResult(value: 1)     # Single CPU for now
        case 2:     # Uptime (placeholder)
            SyscallResult(value: 0)
        case 3:     # TickCount
            val count = scheduler.tick_count()
            SyscallResult(value: count.to_i64())
        case _:
            SyscallResult(value: -22)   # EINVAL

fn _handle_get_hostname() -> SyscallResult:
    """Return the hostname length. Hostname copied to userspace buffer."""
    SyscallResult(value: _hostname.len().to_i64())

fn _handle_set_hostname(args: SyscallArgs) -> SyscallResult:
    """Set the system hostname.

    Args:
      arg0: name pointer
      arg1: name length
    """
    # In a real kernel, copy from userspace.
    SyscallResult(value: 0)

# ============================================================================
# Notification Syscall Handlers
# ============================================================================

fn _handle_notification_create(args: SyscallArgs) -> SyscallResult:
    """Create a new notification object.

    Returns notification ID (>0) on success, 0 on failure.
    """
    val id = notification_create(g_notification_table)
    SyscallResult(value: id.to_i64())

fn _handle_notification_signal(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Signal a notification with the given bits.

    Args:
      arg0: notification ID
      arg1: bits to OR into the notification word

    If a thread was waiting, it is unblocked via the scheduler.
    """
    val id = args.arg0
    val bits = args.arg1
    val waiter_id = notification_signal(g_notification_table, id, bits)
    if waiter_id != 0:
        var sched = scheduler
        val staged = notification_drain_signaled_waiters(g_notification_table, id)
        if staged.len() == 0:
            sched.unblock_task(TaskId(id: waiter_id))
        else:
            var i: u64 = 0
            while i < staged.len().to_u64():
                sched.unblock_task(TaskId(id: staged[i]))
                i = i + 1
    SyscallResult(value: 0)

fn _handle_notification_wait(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Wait for notification bits.

    Args:
      arg0: notification ID

    If bits are already set, returns them immediately. Otherwise blocks
    the calling thread until signaled.
    """
    val id = args.arg0
    var sched = scheduler
    val current = sched.get_current()
    val result = notification_wait(g_notification_table, id, current.id)
    if result != 0:
        # Bits were available immediately
        return SyscallResult(value: result.to_i64())
    # No bits — block the caller
    sched.block_task(current, BlockReason.Notification(id: id))
    SyscallResult(value: 0)

fn _handle_notification_poll(args: SyscallArgs) -> SyscallResult:
    """Non-blocking poll for notification bits.

    Args:
      arg0: notification ID

    Returns accumulated bits (cleared after read), or 0 if none set.
    """
    val id = args.arg0
    val bits = notification_poll(g_notification_table, id)
    SyscallResult(value: bits.to_i64())

fn _handle_notification_destroy(args: SyscallArgs) -> SyscallResult:
    """Destroy a notification object.

    Args:
      arg0: notification ID
    """
    val id = args.arg0
    notification_destroy(g_notification_table, id)
    SyscallResult(value: 0)

fn _handle_notification_wait_any(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Multiplex wait on up to 4 notifications.

    Args:
      arg0-arg3: notification IDs (0 = unused slot)
      arg4: count of valid IDs (1-4)

    Returns (notif_id << 32) | bits for the first ready notification,
    or blocks the calling thread if none are ready.
    """
    val count = args.arg4
    var ids: [u64] = []
    if count >= 1: ids.push(args.arg0)
    if count >= 2: ids.push(args.arg1)
    if count >= 3: ids.push(args.arg2)
    if count >= 4: ids.push(args.arg3)

    var sched = scheduler
    val current = sched.get_current()
    val task_id = current.id

    val result = notification_wait_any(g_notification_table, ids, count, task_id)
    if result != 0:
        # At least one notification had bits — return immediately
        return SyscallResult(value: result.to_i64())

    # None ready — register as waiter on all and block
    notification_register_multi_waiter(g_notification_table, ids, count, task_id)
    sched.block_task(current, BlockReason.Notification(id: args.arg0))
    SyscallResult(value: 0)

# ============================================================================
# File Syscall Stubs (routed to VFS via IPC)
# ============================================================================

fn _handle_file_open(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Open a file. Routed to VFS service via IPC.

    Args:
      arg0: path pointer (userspace)
      arg1: path length
      arg2: flags
    """
    val path_ptr = args.arg0 as u64
    val path_len = args.arg1 as u64
    # Validate path pointer is in user space
    if path_ptr == 0 or path_len == 0 or path_len > MAX_BINARY_PATH_LEN:
        return SyscallResult(value: -22)  # EINVAL
    # Route to VFS service via IPC method 1 (OPEN)
    # Pass path info: payload_len = path length, cap_count = flags
    var sched = scheduler
    val current = sched.get_current()
    val msg = IpcMessage(
        src_port: current.id,
        dst_port: 0,
        method: 1,
        flags: args.arg2 as u32,
        payload_len: path_len,
        cap_count: 0
    )
    var ipc_mgr = ipc
    val result = ipc_mgr.send(msg)
    SyscallResult(value: result)

fn _handle_file_read(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Read from a file descriptor through the active POSIX fd backend.

    Args:
      arg0: file descriptor
      arg1: buffer pointer (userspace)
      arg2: byte count to read
    """
    val buf_ptr = args.arg1 as u64
    val count = args.arg2 as u64
    if count == 0:
        return SyscallResult(value: 0)
    if not _is_userspace_range(buf_ptr, count):
        return SyscallResult(value: -14)  # EFAULT
    if not vmm_verify_user_write(buf_ptr, count):
        return SyscallResult(value: -14)  # EFAULT
    SyscallResult(value: posix_read(args.arg0 as i32, buf_ptr, count))

fn _handle_file_write(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Write to a file descriptor through the active POSIX fd backend.

    Args:
      arg0: file descriptor
      arg1: buffer pointer (userspace)
      arg2: byte count to write
    """
    val buf_ptr = args.arg1 as u64
    val count = args.arg2 as u64
    if count == 0:
        return SyscallResult(value: 0)
    if not _is_userspace_range(buf_ptr, count):
        return SyscallResult(value: -14)  # EFAULT
    SyscallResult(value: posix_write(args.arg0 as i32, buf_ptr, count))

fn _handle_file_close(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Close a file descriptor through the POSIX fd owner.

    Args:
      arg0: file descriptor
    """
    SyscallResult(value: posix_close(args.arg0 as i32) as i64)

fn _handle_file_stat(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Stat a file. Routed to VFS service via IPC.

    Args:
      arg0: path pointer (userspace)
      arg1: path length
      arg2: stat buffer pointer (userspace, ~128 bytes)
    """
    val path_ptr = args.arg0 as u64
    val path_len = args.arg1 as u64
    val stat_buf = args.arg2 as u64
    # Validate path args
    if path_ptr == 0 or path_len == 0 or path_len > MAX_BINARY_PATH_LEN:
        return SyscallResult(value: -22)  # EINVAL
    # Validate stat buffer is user-writable (struct stat ~128 bytes)
    if not vmm_verify_user_write(stat_buf, 128):
        return SyscallResult(value: -14)  # EFAULT
    # Route to VFS with path info preserved
    var sched = scheduler
    val current = sched.get_current()
    val msg = IpcMessage(
        src_port: current.id,
        dst_port: 0,
        method: 5,
        flags: 0,
        payload_len: path_len,
        cap_count: 0
    )
    var ipc_mgr = ipc
    val result = ipc_mgr.send(msg)
    SyscallResult(value: result)

fn _handle_file_mkdir(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Create a directory. Routed to VFS service via IPC.

    Args:
      arg0: path pointer (userspace)
      arg1: path length
      arg2: mode (permissions)
    """
    val path_ptr = args.arg0 as u64
    val path_len = args.arg1 as u64
    # Validate path args
    if path_ptr == 0 or path_len == 0 or path_len > MAX_BINARY_PATH_LEN:
        return SyscallResult(value: -22)  # EINVAL
    # Route to VFS with path info preserved
    var sched = scheduler
    val current = sched.get_current()
    val msg = IpcMessage(
        src_port: current.id,
        dst_port: 0,
        method: 6,
        flags: args.arg2 as u32,  # mode
        payload_len: path_len,
        cap_count: 0
    )
    var ipc_mgr = ipc
    val result = ipc_mgr.send(msg)
    SyscallResult(value: result)

fn _handle_file_readdir(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Read directory entries. Routed to VFS service via IPC.

    Args:
      arg0: directory fd or path pointer
      arg1: buffer pointer (userspace) for directory entries
      arg2: buffer size
    """
    val buf_ptr = args.arg1 as u64
    val buf_size = args.arg2 as u64
    # Validate output buffer is user-writable
    if buf_ptr == 0 or buf_size == 0:
        return SyscallResult(value: -22)  # EINVAL
    if not vmm_verify_user_write(buf_ptr, buf_size):
        return SyscallResult(value: -14)  # EFAULT
    # Route to VFS with args preserved
    var sched = scheduler
    val current = sched.get_current()
    val msg = IpcMessage(
        src_port: current.id,
        dst_port: 0,
        method: 7,
        flags: args.arg0 as u32,  # fd/dir handle
        payload_len: buf_size,
        cap_count: 0
    )
    var ipc_mgr = ipc
    val result = ipc_mgr.send(msg)
    SyscallResult(value: result)

# ============================================================================
# New File Syscall Handlers (unlink, rename, rmdir, lseek, getcwd, chdir)
# ============================================================================

fn _handle_file_unlink(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Remove a file. Routed to VFS service via IPC.

    Args:
      arg0: path pointer (userspace)
      arg1: path length
    """
    val path_ptr = args.arg0 as u64
    val path_len = args.arg1 as u64
    if path_ptr == 0 or path_len == 0 or path_len > MAX_BINARY_PATH_LEN:
        return SyscallResult(value: -22)  # EINVAL
    # Return -ENOSYS until VFS IPC payload is fully wired
    SyscallResult(value: -38)  # ENOSYS

fn _handle_file_rename(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Rename a file or directory. Routed to VFS service via IPC.

    Args:
      arg0: old_path pointer (userspace)
      arg1: old_path length
      arg2: new_path pointer (userspace)
      arg3: new_path length
    """
    val old_ptr = args.arg0 as u64
    val old_len = args.arg1 as u64
    val new_ptr = args.arg2 as u64
    val new_len = args.arg3 as u64
    if old_ptr == 0 or old_len == 0 or old_len > MAX_BINARY_PATH_LEN:
        return SyscallResult(value: -22)  # EINVAL
    if new_ptr == 0 or new_len == 0 or new_len > MAX_BINARY_PATH_LEN:
        return SyscallResult(value: -22)  # EINVAL
    # Return -ENOSYS until VFS IPC payload is fully wired
    SyscallResult(value: -38)  # ENOSYS

fn _handle_file_rmdir(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Remove a directory. Routed to VFS service via IPC.

    Args:
      arg0: path pointer (userspace)
      arg1: path length
    """
    val path_ptr = args.arg0 as u64
    val path_len = args.arg1 as u64
    if path_ptr == 0 or path_len == 0 or path_len > MAX_BINARY_PATH_LEN:
        return SyscallResult(value: -22)  # EINVAL
    # Return -ENOSYS until VFS IPC payload is fully wired
    SyscallResult(value: -38)  # ENOSYS

fn _handle_lseek(args: SyscallArgs) -> SyscallResult:
    """Reposition read/write file offset.

    Args:
      arg0: file descriptor
      arg1: offset
      arg2: whence (0=SEEK_SET, 1=SEEK_CUR, 2=SEEK_END)
    """
    val fd = args.arg0 as u64
    val offset = args.arg1 as i64
    val whence = args.arg2 as u64
    # Validate whence
    if whence > 2:
        return SyscallResult(value: -22)  # EINVAL
    # Stub: return the requested offset as-is (no real FD table yet)
    SyscallResult(value: offset)

fn _handle_ftruncate(args: SyscallArgs) -> SyscallResult:
    """Truncate an open file descriptor to the given length.

    Args:
      arg0: file descriptor
      arg1: length
    """
    val fd = args.arg0 as u64
    val length = args.arg1 as i64
    # Validate length is non-negative
    if length < 0:
        return SyscallResult(value: -22)  # EINVAL
    # Return -ENOSYS until VFS IPC payload is fully wired
    SyscallResult(value: -38)  # ENOSYS

fn _handle_getcwd(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Get current working directory.

    Args:
      arg0: buffer pointer (userspace)
      arg1: buffer size
    Returns: buffer pointer on success, or negative errno.
    """
    val buf_ptr = args.arg0 as u64
    val buf_size = args.arg1 as u64
    # Need at least 2 bytes for "/" + null terminator
    if buf_size < 2:
        return SyscallResult(value: -34)  # ERANGE
    if not vmm_verify_user_write(buf_ptr, buf_size):
        return SyscallResult(value: -14)  # EFAULT
    # Return "/" as the current directory (all tasks start at root)
    mmio_write8(buf_ptr, 0x2F)          # '/'
    mmio_write8(buf_ptr + 1, 0x00)      # null terminator
    SyscallResult(value: buf_ptr as i64)

fn _handle_chdir(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Change current working directory.

    Args:
      arg0: path pointer (userspace)
      arg1: path length
    """
    val path_ptr = args.arg0 as u64
    val path_len = args.arg1 as u64
    if path_ptr == 0 or path_len == 0 or path_len > MAX_BINARY_PATH_LEN:
        return SyscallResult(value: -22)  # EINVAL
    # Accept any path for now (no per-task cwd tracking yet)
    SyscallResult(value: 0)

# ============================================================================
# Memory Syscall Stubs
# ============================================================================

fn _prot_to_vmflags(prot: u64) -> VmFlags:
    """Convert mmap-style protection bits to VmFlags.

    prot bit 0 = read, bit 1 = write, bit 2 = exec.
    Pages are always present and user-accessible.
    Non-executable unless exec bit is set.
    """
    var bits: u32 = VM_PRESENT | VM_USER
    if (prot & 2) != 0:
        bits = bits | VM_WRITABLE
    if (prot & 4) == 0:
        # No exec requested — set no-execute
        bits = bits | VM_NO_EXECUTE
    VmFlags(bits: bits)

fn _handle_memory_map(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Map memory (mmap) using PMM + VMM.

    Args:
      arg0: address hint (0 = kernel picks via bump allocator)
      arg1: size in bytes (rounded up to PAGE_SIZE)
      arg2: protection flags (bit 0=read, bit 1=write, bit 2=exec)
      arg3: map flags (bit 0=fixed, bit 2=anonymous)
    Returns: virtual address of mapped region, or -12 (ENOMEM) on failure.

    Safety: Rejects sizes above 1GB. Hint must be in userspace range.
    """
    val hint = args.arg0
    val size = args.arg1
    val prot = args.arg2

    # Reject unreasonable sizes (>1GB)
    if size == 0 or size > 0x40000000:
        return SyscallResult(value: -22)  # EINVAL

    # Round up size to page boundary
    val page_count = (size + PAGE_SIZE - 1) / PAGE_SIZE
    if page_count == 0:
        return SyscallResult(value: -22)  # EINVAL

    # Reject kernel-space hint addresses
    if hint != 0 and _is_kernel_addr(hint):
        return SyscallResult(value: -1)  # EPERM: kernel address

    # Determine base virtual address
    var base_addr: u64 = hint
    if base_addr == 0:
        base_addr = _next_mmap_addr

    val flags = _prot_to_vmflags(prot)

    # Allocate and map each page
    var offset: u64 = 0
    while offset < page_count:
        val opt_frame = pmm_alloc_page()
        if val Some(frame) = opt_frame:
            val virt = VirtAddr(addr: base_addr + offset * PAGE_SIZE)
            val phys = frame.to_phys_addr()
            val ok = vmm_map_page(virt, phys, flags)
            if !ok:
                # Mapping failed — free the frame we just allocated
                pmm_free_page(frame)
                return SyscallResult(value: -12)  # ENOMEM
        else:
            # Out of physical memory
            return SyscallResult(value: -12)  # ENOMEM
        offset = offset + 1

    # Advance bump allocator past the region we just mapped
    if hint == 0:
        _next_mmap_addr = base_addr + page_count * PAGE_SIZE

    SyscallResult(value: base_addr as i64)

fn _handle_memory_unmap(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Unmap memory (munmap) via VMM.

    Args:
      arg0: virtual address (must be page-aligned)
      arg1: size in bytes (rounded up to PAGE_SIZE)
    Returns: 0 on success, -22 (EINVAL) if address not page-aligned.
    Note: physical frames are not freed because vmm_unmap_page does not
    return the underlying physical address. A future enhancement can add
    reverse-mapping to reclaim frames.

    Safety: Rejects kernel-space addresses.
    """
    val addr = args.arg0
    val size = args.arg1

    # Validate page alignment
    if (addr % PAGE_SIZE) != 0:
        return SyscallResult(value: -22)  # EINVAL

    # Reject kernel-space addresses
    if addr < NULL_GUARD_LIMIT or _is_kernel_addr(addr):
        return SyscallResult(value: -1)  # EPERM

    val page_count = (size + PAGE_SIZE - 1) / PAGE_SIZE
    var offset: u64 = 0
    while offset < page_count:
        val virt = VirtAddr(addr: addr + offset * PAGE_SIZE)
        vmm_unmap_page(virt)
        offset = offset + 1

    SyscallResult(value: 0)

fn _handle_memory_protect(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Change memory protection (mprotect) via VMM.

    Args:
      arg0: virtual address (must be page-aligned)
      arg1: size in bytes (rounded up to PAGE_SIZE)
      arg2: new protection flags (bit 0=read, bit 1=write, bit 2=exec)
    Returns: 0 on success, -22 (EINVAL) if address not page-aligned,
             -14 (EFAULT) if a page in the range is not mapped.

    Reads the existing PTE to preserve the physical address while updating
    only the permission bits.
    """
    val addr = args.arg0
    val size = args.arg1
    val prot = args.arg2

    # Validate page alignment
    if (addr % PAGE_SIZE) != 0:
        return SyscallResult(value: -22)  # EINVAL

    # Reject null-guard and kernel-space addresses
    if addr < NULL_GUARD_LIMIT or _is_kernel_addr(addr):
        return SyscallResult(value: -1)  # EPERM

    val page_count = (size + PAGE_SIZE - 1) / PAGE_SIZE
    val flags = _prot_to_vmflags(prot)

    var offset: u64 = 0
    while offset < page_count:
        val virt = VirtAddr(addr: addr + offset * PAGE_SIZE)
        val existing_pte = vmm_read_pte(virt)
        if existing_pte == 0:
            return SyscallResult(value: -14)  # EFAULT: page not mapped
        val phys_addr = existing_pte & PTE_ADDR_MASK
        val phys = PhysAddr(addr: phys_addr)
        vmm_map_page(virt, phys, flags)
        offset = offset + 1

    SyscallResult(value: 0)

# ============================================================================
# Network Syscall Handlers (70-77)
#
# Exokernel design: applications use the POSIX socket layer
# (src/os/posix/socket_compat.spl) which talks directly to the netstack
# service via IPC (port 2). The kernel does NOT mediate network operations.
#
# These syscall handlers exist as a convenience for callers that bypass the
# POSIX layer (e.g., os.userlib.net). They forward to the netstack service
# by building an IPC message and sending it on the caller's behalf.
#
# For best performance, user applications should use:
#   - posix_socket/bind/listen/connect/accept/send/recv in socket_compat.spl
#   - These call IPC directly without kernel syscall overhead
# ============================================================================

fn _handle_net_socket(args: SyscallArgs) -> SyscallResult:
    """Create a network socket by forwarding to netstack (IPC port 2).

    Args:
      arg0: domain (AF_INET=2, AF_INET6=10)
      arg1: type (SOCK_STREAM=1, SOCK_DGRAM=2)
      arg2: protocol

    Forwards NET_SOCKET IPC to the netstack service. The netstack
    allocates a socket in its SocketTable and returns the fd.
    """
    # Validate domain
    if args.arg0 != 2:  # AF_INET only
        return SyscallResult(value: -22)  # EINVAL

    # Map POSIX type to protocol byte (1=TCP, 2=UDP)
    var proto: u64 = 0
    if args.arg1 == 1:   # SOCK_STREAM
        proto = 1
    elif args.arg1 == 2: # SOCK_DGRAM
        proto = 2
    else:
        return SyscallResult(value: -22)  # EINVAL

    # Forward to netstack via IPC: send method=NET_SOCKET, payload=proto(u8)
    val ipc_result = _forward_net_ipc(1, proto, 0, 0, 0)  # NET_SOCKET=1
    SyscallResult(value: ipc_result)

fn _handle_net_bind(args: SyscallArgs) -> SyscallResult:
    """Bind a socket to an address by forwarding to netstack (IPC port 2).

    Args:
      arg0: socket fd (from netstack)
      arg1: packed IPv4 address (a | b<<8 | c<<16 | d<<24)
      arg2: port number
    """
    val ipc_result = _forward_net_ipc(2, args.arg0, args.arg1, args.arg2, 0)  # NET_BIND=2
    SyscallResult(value: ipc_result)

fn _handle_net_listen(args: SyscallArgs) -> SyscallResult:
    """Listen on a socket by forwarding to netstack (IPC port 2).

    Args:
      arg0: socket fd
      arg1: backlog
    """
    val ipc_result = _forward_net_ipc(3, args.arg0, args.arg1, 0, 0)  # NET_LISTEN=3
    SyscallResult(value: ipc_result)

fn _handle_net_connect(args: SyscallArgs) -> SyscallResult:
    """Connect a socket by forwarding to netstack (IPC port 2).

    Args:
      arg0: socket fd
      arg1: packed IPv4 address
      arg2: port number
    """
    val ipc_result = _forward_net_ipc(4, args.arg0, args.arg1, args.arg2, 0)  # NET_CONNECT=4
    SyscallResult(value: ipc_result)

fn _handle_net_accept(args: SyscallArgs) -> SyscallResult:
    """Accept a connection by forwarding to netstack (IPC port 2).

    Args:
      arg0: listening socket fd
    """
    val ipc_result = _forward_net_ipc(5, args.arg0, 0, 0, 0)  # NET_ACCEPT=5
    SyscallResult(value: ipc_result)

fn _handle_net_send_to(args: SyscallArgs) -> SyscallResult:
    """Send data on a socket by forwarding to netstack (IPC port 2).

    Args:
      arg0: socket fd
      arg1: data pointer (userspace)
      arg2: data length
      arg3: flags
    """
    val ipc_result = _forward_net_ipc(6, args.arg0, args.arg1, args.arg2, args.arg3)  # NET_SEND=6
    SyscallResult(value: ipc_result)

fn _handle_net_recv_from(args: SyscallArgs) -> SyscallResult:
    """Receive data from a socket by forwarding to netstack (IPC port 2).

    Args:
      arg0: socket fd
      arg1: buffer pointer (userspace)
      arg2: max length
      arg3: flags
    """
    val ipc_result = _forward_net_ipc(7, args.arg0, args.arg1, args.arg2, args.arg3)  # NET_RECV=7
    SyscallResult(value: ipc_result)

fn _handle_net_if_config(args: SyscallArgs) -> SyscallResult:
    """Get/set network interface configuration via netstack (IPC port 2).

    Args:
      arg0: interface index
      arg1: info buffer pointer (userspace)
    """
    val ipc_result = _forward_net_ipc(9, args.arg0, args.arg1, 0, 0)  # NET_IFCONFIG=9
    SyscallResult(value: ipc_result)

fn _forward_net_ipc(method: u64, arg0: u64, arg1: u64, arg2: u64, arg3: u64) -> i64:
    """Forward a network syscall to the netstack service via IPC (port 2).

    Builds an IPC message with the given method and arguments, sends it
    to port 2, and waits for the reply. Returns the reply status/value.

    This is a kernel-side helper for the syscall path. User-space callers
    should prefer direct IPC via socket_compat.spl for lower overhead.
    """
    val NETSTACK_PORT: u64 = 2
    val msg = IpcMessage(
        src_port: 0,  # kernel
        dst_port: NETSTACK_PORT,
        method: method as u32,
        flags: 0,
        payload_addr: arg0,  # Overloaded: first arg as payload
        payload_len: 0,
        cap_count: 0
    )

    # For simple forwarding, encode args into the IPC message payload fields.
    # The netstack service parses the method + payload from the message.
    # Since the kernel IPC path doesn't have a general byte-buffer mechanism
    # for building payloads, we pass the arguments directly in the message
    # fields and let the netstack decode them.
    #
    # Real implementation would build a byte payload matching netstack's wire
    # protocol, but this path is a fallback. The recommended path is POSIX
    # socket_compat.spl which builds proper IPC payloads in user-space.

    # For now, return -ENOSYS to indicate that the kernel forwarding path
    # is not fully wired. Callers should use socket_compat.spl instead.
    # This is intentional: the exokernel design routes network I/O through
    # user-space services, not through kernel syscalls.
    -38  # ENOSYS — use posix_socket() API in socket_compat.spl

# ============================================================================
# Helper Functions
# ============================================================================

fn _u64_to_priority(val_: u64) -> TaskPriority:
    """Convert a numeric value to TaskPriority enum."""
    match val_:
        case 0: TaskPriority.Realtime
        case 1: TaskPriority.High
        case 2: TaskPriority.Normal
        case 3: TaskPriority.Low
        case 4: TaskPriority.Idle
        case _: TaskPriority.Normal

fn _u64_to_scheduler_policy(val_: u64) -> SchedulerPolicy:
    """Convert syscall policy code to SchedulerPolicy."""
    match val_:
        case 0: SchedulerPolicy.Fair
        case 1: SchedulerPolicy.Background
        case 2: SchedulerPolicy.RtFifo
        case 3: SchedulerPolicy.RtRoundRobin
        case 4: SchedulerPolicy.Deadline
        case 5: SchedulerPolicy.Idle
        case 6: SchedulerPolicy.Internal
        case _: SchedulerPolicy.Fair

fn _scheduler_policy_to_u64(policy: SchedulerPolicy) -> u64:
    """Convert SchedulerPolicy to userspace policy code."""
    match policy:
        case Fair: 0
        case Background: 1
        case RtFifo: 2
        case RtRoundRobin: 3
        case Deadline: 4
        case Idle: 5
        case Internal: 6

# ============================================================================
# G11 — sys_privctl handler
# ============================================================================

fn _handle_privctl(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """sys_privctl — read/write per-task privilege mask.

    Args:
      arg0: target_task (u32 task ID)
      arg1: op — PRIVCTL_SET_MASK / GET_MASK / ADD_PEER / REMOVE_PEER
      arg2: data — op-specific (peer id for ADD/REMOVE; ignored for GET)

    For SET_MASK: builds a mask with kernel_calls=data, all other fields 0.
    Full struct marshal deferred until user-copy helpers land.
    # TODO(mdsoc+): full PrivilegeMask marshal via user-copy once vmm_copy lands
    """
    val target_id = args.arg0.to_u32()
    val op = args.arg1.to_u32()
    val data = args.arg2

    if op == PRIVCTL_SET_MASK:
        val mask = PrivilegeMask(
            kernel_calls: data,
            irqs: 0,
            io_port_base: 0,
            io_port_len: 0,
            allowed_peers: []
        )
        _priv_table.set(target_id, mask)
        SyscallResult(value: 0)
    else:
        if op == PRIVCTL_GET_MASK:
            val found = _priv_table.get(target_id)
            if found == nil:
                SyscallResult(value: -1)
            else:
                val m = found
                # Return kernel_calls bitmap as the result value
                SyscallResult(value: m.kernel_calls.to_i64())
        else:
            if op == PRIVCTL_ADD_PEER:
                _priv_table.add_peer(target_id, data.to_u32())
                SyscallResult(value: 0)
            else:
                if op == PRIVCTL_REMOVE_PEER:
                    _priv_table.remove_peer(target_id, data.to_u32())
                    SyscallResult(value: 0)
                else:
                    SyscallResult(value: -1)    # Unknown op

# ============================================================================
# G12 — sys_grant / sys_revoke / sys_safecopy_from / sys_safecopy_to handlers
# ============================================================================

fn _handle_mem_grant(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """sys_grant — create a memory region grant from caller to grantee.

    Args:
      arg0: grantee task ID (u32)
      arg1: vaddr — base virtual address in caller's space
      arg2: len — length in bytes
      arg3: flags — GRANT_R / GRANT_W / GRANT_RW

    Returns grant_id >= 0 on success, negative on error.
    """
    var sched = scheduler
    val caller = sched.get_current()
    val grantee = args.arg0.to_u32()
    val vaddr = args.arg1
    val len = args.arg2
    val flags = args.arg3.to_u32()

    if len == 0:
        return SyscallResult(value: -1)     # Zero-length grant is invalid

    val gid = _grant_table.cap_grant(caller.id.to_u32(), grantee, vaddr, len, flags)
    SyscallResult(value: gid.to_i64())

fn _handle_mem_revoke(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """sys_revoke — revoke a previously issued grant.

    Args:
      arg0: grant_id to revoke

    Returns 0 on success, -1 if not found or already revoked.
    """
    var sched = scheduler
    val caller = sched.get_current()
    val grant_id = args.arg0.to_u32()

    # Verify the grant belongs to the caller before revoking
    val found = _grant_table.find_valid(grant_id, caller.id.to_u32())
    # find_valid checks grantee — we need to check grantor instead
    # Search directly for grantor match
    val ok = _grant_revoke_by_grantor(grant_id, caller.id.to_u32())
    if ok:
        SyscallResult(value: 0)
    else:
        SyscallResult(value: -1)

fn _grant_revoke_by_grantor(grant_id: u32, grantor: u32) -> bool:
    """Revoke a grant only if it belongs to the given grantor."""
    var idx = 0
    while idx < _grant_table.grants.len():
        var g = _grant_table.grants[idx]
        if g.id == grant_id:
            if g.grantor == grantor:
                if g.valid:
                    g.valid = false
                    _grant_table.grants[idx] = g
                    return true
            return false
        idx = idx + 1
    false

fn _handle_safecopy_from(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """sys_safecopy_from — bounds-checked copy from grantor's region to caller.

    Args:
      arg0: src_task  — grantor task ID (u32)
      arg1: grant_id  — the grant to read through
      arg2: src_off   — byte offset within the granted region
      arg3: dst_vaddr — destination VA in the caller's address space
      arg4: len       — number of bytes to copy

    Returns 0 on success, negative errno on failure.
    # TODO(mdsoc+): integrate MMU walk once G2 lands
    """
    var sched = scheduler
    val caller = sched.get_current()
    val grant_id = args.arg1.to_u32()
    val src_off = args.arg2
    val dst_vaddr = args.arg3
    val len = args.arg4

    val rc = _grant_table.safecopy_from(caller.id.to_u32(), grant_id, src_off, dst_vaddr, len)
    SyscallResult(value: rc.to_i64())

fn _handle_safecopy_to(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """sys_safecopy_to — bounds-checked copy from caller's buffer to grantee's region.

    Args:
      arg0: dst_task  — grantee task ID (u32)
      arg1: grant_id  — the grant to write through
      arg2: dst_off   — byte offset within the granted region
      arg3: src_vaddr — source VA in the caller's address space
      arg4: len       — number of bytes to copy

    Returns 0 on success, negative errno on failure.
    # TODO(mdsoc+): integrate MMU walk once G2 lands
    """
    var sched = scheduler
    val caller = sched.get_current()
    val grant_id = args.arg1.to_u32()
    val dst_off = args.arg2
    val src_vaddr = args.arg3
    val len = args.arg4

    val rc = _grant_table.safecopy_to(caller.id.to_u32(), grant_id, dst_off, src_vaddr, len)
    SyscallResult(value: rc.to_i64())

# ============================================================================
# VM mmap / munmap handlers (Wave 1 G13 — syscall IDs 103 / 104)
# ============================================================================

# TODO(mdsoc+): replace g_current_vmspace with sched.get_current().vmspace
# once PM Wave 2 lands and Task carries a ProcessVmSpace field.
var g_current_vmspace: ProcessVmSpace = vmm_new_process_space(0, 0)

struct TaskBrkEntry:
    """Per-task program break state."""
    task_id: u64
    current: u64

var _task_brks: [TaskBrkEntry] = []

fn _align_brk_up(value: u64) -> u64:
    if value % PAGE_SIZE == 0:
        return value
    ((value / PAGE_SIZE) + 1) * PAGE_SIZE

fn brk_reset_for_test():
    """Reset the process break model for isolated specs."""
    _current_brk = USER_BRK_BASE
    _task_brks = []

fn _handle_brk(args: SyscallArgs) -> SyscallResult:
    _handle_brk_for_task(args, 0)

fn _find_task_brk_slot(task_id: u64) -> i32:
    var i = 0
    while i < _task_brks.len():
        if _task_brks[i].task_id == task_id:
            return i
        i = i + 1
    -1

fn _task_brk_current(task_id: u64) -> u64:
    val slot = _find_task_brk_slot(task_id)
    if slot < 0:
        return USER_BRK_BASE
    _task_brks[slot].current

fn _task_brk_set(task_id: u64, value: u64):
    val slot = _find_task_brk_slot(task_id)
    if slot >= 0:
        var entry = _task_brks[slot]
        entry.current = value
        _task_brks[slot] = entry
        return
    _task_brks.push(TaskBrkEntry(task_id: task_id, current: value))

fn _handle_brk_for_task(args: SyscallArgs, task_id: u64) -> SyscallResult:
    """brk — query or grow the current process break.

    arg0=0 returns the current break. A non-zero arg0 requests a new break.
    This MVP path supports monotonic growth only; shrinking returns -EINVAL.
    """
    val requested = args.arg0
    val current_brk = _task_brk_current(task_id)
    if requested == 0:
        return SyscallResult(value: current_brk as i64)
    if requested < USER_BRK_BASE:
        return SyscallResult(value: -22)
    if requested < current_brk:
        return SyscallResult(value: -22)
    if requested > USER_BRK_LIMIT:
        return SyscallResult(value: -12)
    if requested == current_brk:
        return SyscallResult(value: current_brk as i64)

    val old_page = _align_brk_up(current_brk)
    val new_page = _align_brk_up(requested)
    if new_page > old_page:
        val len = new_page - old_page
        var map_space = g_current_vmspace
        var mapped_registered_space = false
        if task_id != 0:
            val registered_space = task_vmspace_of(task_id.to_u32())
            if registered_space != nil:
                map_space = registered_space
                mapped_registered_space = true
        val rc = vmm_mmap(map_space, old_page, len, VMA_READ | VMA_WRITE, VMA_ANON, 0, 0)
        if rc < 0:
            return SyscallResult(value: rc)
        if mapped_registered_space:
            register_task_vmspace(task_id.to_u32(), map_space)
        else:
            g_current_vmspace = map_space
    _task_brk_set(task_id, requested)
    if task_id == 0:
        _current_brk = requested
    SyscallResult(value: requested as i64)

fn _handle_system_reboot(args: SyscallArgs) -> SyscallResult:
    """Reset the current machine through the platform HAL."""
    _ = args
    SyscallResult(value: hal_system_reset())

fn _handle_sys_mmap(args: SyscallArgs) -> SyscallResult:
    """sys_mmap — map a virtual address range into the current task's space.

    Args:
      arg0: vaddr          — requested virtual address (0 = kernel picks)
      arg1: len            — length in bytes
      arg2: flags          — VMA_READ | VMA_WRITE | VMA_EXEC | VMA_COW (u32)
      arg3: kind           — VMA_ANON | VMA_FILE | VMA_SHARED (u32)
      arg4: backing        — file handle or 0 for anonymous
      arg5: backing_offset — byte offset into backing file

    Returns mapped vaddr (>= 0) on success, negative errno on failure.
    """
    val vaddr          = args.arg0
    val len            = args.arg1
    val flags          = args.arg2.to_u32()
    val kind           = args.arg3.to_u32()
    val backing        = args.arg4
    val backing_offset = args.arg5
    val rc = vmm_mmap(g_current_vmspace, vaddr, len, flags, kind, backing, backing_offset)
    SyscallResult(value: rc)

fn _handle_sys_munmap(args: SyscallArgs) -> SyscallResult:
    """sys_munmap — unmap a virtual address range from the current task's space.

    Args:
      arg0: vaddr — start of region to unmap (page-aligned)
      arg1: len   — length in bytes

    Returns 0 on success, negative errno on failure.
    """
    val vaddr = args.arg0
    val len   = args.arg1
    val rc = vmm_munmap(g_current_vmspace, vaddr, len)
    SyscallResult(value: rc.to_i64())

# ============================================================================
# SOSIX immutable sharing handlers — syscall IDs 120 / 131
# ============================================================================

fn _handle_dataset_create(args: SyscallArgs) -> SyscallResult:
    """dataset_create(size, flags) -> dataset handle."""
    SyscallResult(value: shared_dataset_create(args.arg0, args.arg1.to_u32()))

fn _handle_dataset_create_from_file(args: SyscallArgs) -> SyscallResult:
    """dataset_create_from_file(fd, offset, len, flags) -> sealed handle.

    Snapshots exactly len bytes from the fd at offset into an immutable sealed
    dataset. The fd open-file-description offset is restored by the POSIX read
    helper on every success and failure path.
    """
    val read_result = posix_pread_exact_bytes(args.arg0 as i32, args.arg1, args.arg2)
    if read_result.status < 0:
        return SyscallResult(value: read_result.status)

    val handle = shared_dataset_create(read_result.len, args.arg3.to_u32())
    if handle < 0:
        return SyscallResult(value: handle)
    val write_rc = shared_dataset_write(handle as u64, 0, read_result.data)
    if write_rc < 0:
        shared_dataset_close(handle as u64)
        return SyscallResult(value: write_rc)
    if write_rc != read_result.len as i64:
        shared_dataset_close(handle as u64)
        return SyscallResult(value: 0 - EIO as i64)
    val seal_rc = shared_dataset_seal(handle as u64)
    if seal_rc < 0:
        shared_dataset_close(handle as u64)
        return SyscallResult(value: seal_rc)
    SyscallResult(value: handle)

fn _handle_dataset_write(args: SyscallArgs) -> SyscallResult:
    """dataset_write(handle, offset, user_ptr, len)."""
    val bytes = _copy_in_bytes(args.arg2, args.arg3)
    if args.arg3 != 0 and bytes.len() == 0:
        return SyscallResult(value: -22)
    SyscallResult(value: shared_dataset_write(args.arg0, args.arg1, bytes))

fn _handle_dataset_seal(args: SyscallArgs) -> SyscallResult:
    """dataset_seal(handle)."""
    SyscallResult(value: shared_dataset_seal(args.arg0))

fn _handle_dataset_map(args: SyscallArgs) -> SyscallResult:
    """dataset_map(handle, addr_hint, offset, len) -> mapped vaddr."""
    val probe = shared_dataset_read(args.arg0, args.arg2, args.arg3)
    if probe.status < 0:
        return SyscallResult(value: probe.status)
    val rc = vmm_mmap(g_current_vmspace, args.arg1, args.arg3, VMA_READ, VMA_SHARED, args.arg0, args.arg2)
    SyscallResult(value: rc)

fn _handle_dataset_unmap(args: SyscallArgs) -> SyscallResult:
    """dataset_unmap(vaddr, len)."""
    val rc = vmm_munmap(g_current_vmspace, args.arg0, args.arg1)
    SyscallResult(value: rc.to_i64())

fn _handle_dataset_close(args: SyscallArgs) -> SyscallResult:
    """dataset_close(handle)."""
    SyscallResult(value: shared_dataset_close(args.arg0))

fn _handle_queue_create(args: SyscallArgs) -> SyscallResult:
    """queue_create(capacity, max_msg_bytes, flags)."""
    SyscallResult(value: process_queue_create(args.arg0, args.arg1, args.arg2.to_u32()))

fn _handle_queue_send(args: SyscallArgs) -> SyscallResult:
    """queue_send(queue, user_ptr, len, attached_handle)."""
    val bytes = _copy_in_bytes(args.arg1, args.arg2)
    if args.arg2 != 0 and bytes.len() == 0:
        return SyscallResult(value: -22)
    if args.arg3 != PROCESS_QUEUE_NO_HANDLE:
        if not shared_dataset_is_sealed(args.arg3):
            return SyscallResult(value: -22)
    SyscallResult(value: process_queue_send(args.arg0, bytes, args.arg3))

fn _handle_queue_recv(args: SyscallArgs) -> SyscallResult:
    """queue_recv(queue, out_ptr, out_len, out_attached_ptr)."""
    val recv = process_queue_recv(args.arg0)
    if recv.status <= 0:
        return SyscallResult(value: recv.status)
    var copied: u64 = 0
    while copied < recv.len and copied < args.arg2:
        mmio_write8(args.arg1 + copied, recv.data[copied])
        copied = copied + 1
    if args.arg3 != 0:
        mmio_write64(args.arg3, recv.attached_handle)
    SyscallResult(value: copied as i64)

fn _handle_queue_poll(args: SyscallArgs) -> SyscallResult:
    """queue_poll(queue)."""
    SyscallResult(value: process_queue_poll(args.arg0) as i64)

fn _handle_queue_close(args: SyscallArgs) -> SyscallResult:
    """queue_close(queue, mode)."""
    SyscallResult(value: process_queue_close(args.arg0, args.arg1.to_u32()))

# ============================================================================
# SPM / Privilege Syscall Handlers (spm-winfs-llm-suite)
# ============================================================================

fn _copy_in_bytes(ptr: u64, len: u64) -> [u8]:
    """Copy `len` bytes from caller's user-VA `ptr` into a kernel-owned [u8].

    Walks the caller's address space (g_current_vmspace) and copies bytes
    from user VA `ptr` via the VMM page-table walker. Mirrors the
    safecopy_from contract in capability.spl: if the vmspace is wired
    (vma_count > 0), every page in [ptr, ptr+len) must be covered by a
    VMA with VMA_READ; on any unmapped/unreadable page, returns []. If
    the vmspace has no VMAs yet (PM not wired, boot-time), the VMA check
    is skipped — matching safecopy_from's "skip when not registered" rule.

    Failure modes (return []):
      - ptr == 0 or len == 0
      - ptr + len overflows u64
      - vmspace is wired and range is not fully VMA_READ

    Test-only / early-boot spaces with no PML4 root keep the historical
    identity-pointer fallback after VMA validation. Real process spaces use
    `vmm_copyin_bytes_from_space`, which translates each touched page.
    """
    if ptr == 0 as u64 or len == 0 as u64:
        return []
    # Overflow guard: ptr + len must not wrap
    if ptr + len < ptr:
        return []
    # VMA validation: skip when vmspace is not yet wired (vma_count == 0),
    # otherwise every page in the range must be VMA_READ.
    if g_current_vmspace.vma_count > 0 as u64:
        if not _vma_range_readable(g_current_vmspace, ptr, len):
            return []
    if g_current_vmspace.pml4 != 0 as u64:
        val copied = vmm_copyin_bytes_from_space(g_current_vmspace, ptr, len)
        if not copied.status.ok:
            return []
        return copied.bytes
    # Bytewise copy through the identity-mapped user pointer. Mirrors the
    # proven pattern in _copy_user_text above for pml4-less test spaces.
    unsafe:
        val base = ptr as *const u8
        var bytes: [u8] = []
        var i: u64 = 0
        while i < len:
            val byte_ptr = (base + (i as i64)) as *const u8
            bytes.push(*byte_ptr)
            i = i + 1
        bytes

fn spm_priv_check_for_task(task_id: u64, id_path: [u8]) -> bool:
    """Evaluate sys_priv_check for an already-copied id-path."""
    if id_path.len() == 0:
        return false
    val mirror = bridge_lookup(task_id)
    two_gate_check(mirror, id_path)

fn _handle_spm_priv_check(args: SyscallArgs, caller_task_id: u64) -> SyscallResult:
    """sys_priv_check (110) — hierarchical privilege gate."""
    val id_path = _copy_in_bytes(args.arg0, args.arg1)
    if spm_priv_check_for_task(caller_task_id, id_path):
        return SyscallResult(value: 1 as i64)
    SyscallResult(value: 0 as i64)

fn _handle_spm_win_register(args: SyscallArgs) -> SyscallResult:
    """sys_win_register (111) — register WindowRecord with SPM."""
    if not spm_port_is_registered():
        return SyscallResult(value: -1 as i64)
    val record = _copy_in_bytes(args.arg0, args.arg1)
    spm_port_send(record)
    SyscallResult(value: 0 as i64)

fn _handle_spm_approval_request(args: SyscallArgs) -> SyscallResult:
    """sys_approval_request (112) — brokered approval via SPM."""
    if not spm_port_is_registered():
        return SyscallResult(value: -1 as i64)
    val intent = _copy_in_bytes(args.arg0, args.arg1)
    val resp = spm_port_send(intent)
    SyscallResult(value: resp.len() as i64)

fn _handle_spm_send(args: SyscallArgs) -> SyscallResult:
    """sys_spm_send (113) — generic SPM RPC send."""
    if not spm_port_is_registered():
        return SyscallResult(value: -1 as i64)
    val req = _copy_in_bytes(args.arg0, args.arg1)
    val resp = spm_port_send(req)
    SyscallResult(value: resp.len() as i64)

fn _handle_spm_listen(args: SyscallArgs) -> SyscallResult:
    """sys_spm_listen (114) — SPM-side non-blocking dequeue."""
    if not spm_port_is_registered():
        return SyscallResult(value: -1 as i64)
    val req = spm_port_listen()
    SyscallResult(value: req.len() as i64)

fn _handle_spm_claim(caller_task_id: u64) -> SyscallResult:
    """sys_spm_claim (115) — rebind the boot placeholder SPM port."""
    SyscallResult(value: spm_claim_for_task(caller_task_id))
