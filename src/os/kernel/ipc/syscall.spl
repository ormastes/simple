# ============================================================================
# Helper Functions
# ============================================================================

fn _u64_to_priority(val_: u64) -> TaskPriority:
    """Convert a numeric value to TaskPriority enum."""
    match val_:
        case 0: TaskPriority.Realtime
        case 1: TaskPriority.High
        case 2: TaskPriority.Normal
        case 3: TaskPriority.Low
        case 4: TaskPriority.Idle
        case _: TaskPriority.Normal
