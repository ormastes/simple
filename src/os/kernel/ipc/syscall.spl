var dma_alloc_next_id: u64 = 1

fn _close_all_live_fds_with_backends() -> u32:
    """Close every live descriptor through the backend-aware POSIX path."""
    var closed: u32 = 0u32
    var i: u64 = 0
    while i < MAX_FDS:
        if fd_is_valid(i as i32):
            posix_close(i as i32)
            closed = closed + 1u32
        i = i + 1
    closed

fn _close_cloexec_fds_with_backends() -> u32:
    """Apply exec close-on-exec cleanup through backend-aware close."""
    var closed: u32 = 0u32
    var i: u64 = 0
    while i < MAX_FDS:
        if fd_is_valid(i as i32) and fd_get_cloexec(i as i32):
            posix_close(i as i32)
            closed = closed + 1u32
        i = i + 1
    closed

