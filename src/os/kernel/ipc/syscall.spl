    var sched = scheduler
    val current = sched.get_current()
    val msg = IpcMessage(
        src_port: current.id,
        dst_port: 0,
        method: 11,     # UNMOUNT
        flags: 0,
        payload_len: 0,
        cap_count: 0
    )
    var ipc_mgr = ipc
    val result = ipc_mgr.send(msg)
    SyscallResult(value: result)

