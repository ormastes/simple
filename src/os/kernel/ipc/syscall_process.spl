# Process Syscall Handlers — split from syscall.spl.
# Contains _handle_exit, _handle_yield, _handle_spawn, _handle_wait,
# _handle_fork, _handle_exec, _handle_waitpid, _handle_pipe, _handle_dup2,
# _handle_dup, _handle_dlopen, _handle_dlsym, _handle_dlclose,
# _handle_poll, _handle_fcntl, _handle_getpid,
# and copy-from-user helpers.

use os.kernel.types.syscall_types.{SyscallArgs, SyscallResult}
use os.kernel.types.task_types.{TaskId, TaskPriority, BlockReason}
use os.kernel.ipc.cspace_spawn.{spawn_full}
use os.kernel.types.vmspace_types.{ProcessVmSpace}
use os.kernel.scheduler.scheduler.{Scheduler, wait_collect_result_pid, wait_collect_result_status, wait_collect_result_error}
use os.kernel.ipc.ipc.{IpcManager}
use os.kernel.ipc.notif_global.{g_notification_table}
use os.kernel.ipc.notification.{notification_wait_any, notification_register_multi_waiter}
use os.kernel.log.klog.{KernelLog, klog_write}
use os.kernel.log.klog_api.{log_raw_println}
use os.kernel.loader.executable_source.{resolve_executable_bytes, resolve_executable_bytes_from_path_bytes}
use os.kernel.loader.app_registry.{app_registry_lookup, app_registry_cached_boot_app_id}
use os.kernel.loader.builtin_binary_registry.{resolve_builtin_binary}
use os.kernel.loader.process_image.{build_user_process_image}
use os.kernel.loader.loader_api.{loader_dynopen_bytes, loader_dynsym, loader_dynclose}
use os.kernel.arch.arch_context.{Architecture}
use os.kernel.memory.vmm.{vmm_new_process_space, vmm_teardown_user_space, vmm_verify_user_write, vmm_copyin_string_vector, vmm_copyin_packed_string_vector, vmm_copyin_bytes_from_space, vmm_copy_string_vector_result_ok, vmm_copy_string_vector_result_errno, vmm_copy_string_vector_result_values}
use os.kernel.boot.mmio.{mmio_read16, mmio_read32, mmio_write16, mmio_write32}
use os.kernel.ipc.capability.{register_task_vmspace, task_vmspace_of}
use os.kernel.pipe_compat.{posix_pipe}
use os.kernel.fd_io.{posix_close, posix_dup, posix_dup2, posix_lseek}
use os.kernel.fd_table.{fd_prepare_fork_to_task, fd_dup_from, fd_is_valid, fd_get_cloexec, fd_set_cloexec, fd_get_status_flags, fd_set_status_flags, fd_get_object_id, fd_poll_ready, fd_poll_notification, MAX_FDS}
use os.kernel.errno.{EACCES, EFAULT, EINVAL, ENAMETOOLONG}
use os.kernel.ipc.syscall.{_u64_to_priority, g_scheduler_next_task_id, CURRENT_EXEC_ARCH, MAX_BINARY_PATH_LEN, MAX_EXEC_ARG_COUNT, MAX_EXEC_ENV_COUNT, MAX_EXEC_STRING_LEN, MAX_EXEC_TOTAL_STRING_BYTES, _is_userspace_ptr, _is_userspace_range, g_current_vmspace, _use_x86_64_direct_spawn_handoff, _alloc_x86_64_direct_spawn_pid}
use os.kernel.ipc.syscall_device.{_dma_release_task_allocs}
use os.kernel.lifecycle.task_cleanup.{task_cleanup}
use os.kernel.ipc.capability.{_vma_range_readable}
use os.kernel.types.task_types.{TaskState}
use os.ai_cli_js_node_contract.{AiCliManifest, ai_cli_process_spawn_decision}
extern fn rt_string_from_byte_array(arr: [u8]) -> text
extern fn rt_copy_user_byte(ptr_addr: u64) -> u8

# ============================================================================
# Process Syscall Handlers
# ============================================================================

var g_ai_cli_process_manifest: AiCliManifest? = nil

fn _close_all_live_fds_with_backends() -> u32:
    """Close every live descriptor through the backend-aware POSIX path."""
    var closed: u32 = 0u32
    var i: u64 = 0
    while i < MAX_FDS:
        if fd_is_valid(i as i32):
            posix_close(i as i32)
            closed = closed + 1u32
        i = i + 1
    closed

fn _close_cloexec_fds_with_backends() -> u32:
    """Apply exec close-on-exec cleanup through backend-aware close."""
    var closed: u32 = 0u32
    var i: u64 = 0
    while i < MAX_FDS:
        if fd_is_valid(i as i32) and fd_get_cloexec(i as i32):
            posix_close(i as i32)
            closed = closed + 1u32
        i = i + 1
    closed

fn set_ai_cli_process_manifest_for_test(manifest: AiCliManifest):
    g_ai_cli_process_manifest = manifest

fn clear_ai_cli_process_manifest_for_test():
    g_ai_cli_process_manifest = nil

fn _process_grant_denial_reason_for_path(path: text) -> text:
    if not g_ai_cli_process_manifest.?:
        return ""
    val manifest = g_ai_cli_process_manifest
    val decision = ai_cli_process_spawn_decision(manifest, "spawn", path)
    if decision.allowed:
        return ""
    decision.reason

fn _process_grant_errno_for_path(path: text, klog: KernelLog) -> i64:
    val reason = _process_grant_denial_reason_for_path(path)
    if reason == "":
        return 0
    var log = klog
    klog_write(log, 3, 1, 0, "process grant denied path={path} reason={reason}")
    0 - EACCES as i64

fn _handle_exit(args: SyscallArgs, scheduler: Scheduler, ipc: IpcManager) -> SyscallResult:
    """Exit the current task with the given exit code.

    Performs full resource cleanup before marking the task as zombie:
      1. Clean up kernel resources (notifications, IRQ routes, DMA, BAR mappings)
      2. Revoke all capabilities granted to the task
      3. Mark the task as zombie in the scheduler
    """
    val code = args.arg0
    var sched = scheduler
    val exiting_task = sched.get_current()

    # Step 1: Release DMA records first so the ownership table cannot retain
    # stale live entries after task_cleanup unmaps resources.
    _dma_release_task_allocs(exiting_task)

    # Step 2: Clean up remaining kernel resources tracked by task_cleanup
    task_cleanup(exiting_task.id)

    # Step 3: Revoke all capabilities held by this task
    var ipc_mgr = ipc
    ipc_mgr.cap_manager.revoke_all_for_task(exiting_task)

    # Step 4: Close process descriptors for the current process lifecycle.
    _close_all_live_fds_with_backends()

    # Step 4: Mark as zombie in scheduler
    sched.exit_task(code.to_i32())

    # exit_task does not return to the caller; the scheduler picks next task.
    # This result is never seen by the exiting task.
    SyscallResult(value: 0)

fn _handle_yield(scheduler: Scheduler) -> SyscallResult:
    """Yield the current task's time slice."""
    var sched = scheduler
    sched.yield_current()
    SyscallResult(value: 0)

fn _handle_spawn(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Spawn a new task.

    Args:
      arg0: entry point address
      arg1: priority (0=Realtime, 1=High, 2=Normal, 3=Low, 4=Idle)
    """
    val entry = args.arg0
    val priority = _u64_to_priority(args.arg1)
    # Boot/init compat: raw entry-address spawn still needs ambient authority
    # until the AT_SIMPLE_CSPACE injection ABI lands (P3). Route through the
    # named spawn_full() wrapper so the ambient grant stays auditable — the
    # least-authority default lives in spawn_with_cspace (cspace_spawn.spl).
    val caps = spawn_full()

    var sched = scheduler
    val task_id = sched.create_task(entry, priority, caps)
    SyscallResult(value: task_id.id.to_i64())

fn _handle_wait(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Wait for a child task to exit.

    Args:
      arg0: child task ID (0 = any child)
      arg1: options (bit 0 = WNOHANG)

    Blocks the caller until the child exits, then returns the exit code.
    """
    var sched = scheduler
    val current = sched.get_current()
    val result = sched.wait_for(current, TaskId(id: args.arg0))
    if result == -11:
        return SyscallResult(value: 0)
    SyscallResult(value: result.to_i64())

fn _handle_fork(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Fork the current scheduler task.

    Args are reserved for future clone flags. Returns the child task ID in the
    parent. Child-side register fixup to return 0 lands with context resume.
    """
    val _a = args
    var sched = scheduler
    val parent = sched.get_current()
    val child = sched.clone_task(parent)
    if child.id == 0:
        return SyscallResult(value: -12)
    fd_prepare_fork_to_task(child.id)
    SyscallResult(value: child.id.to_i64())

fn _handle_exec(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Execve process-image replacement.

    This kernel-facing ABI accepts arg0=path pointer and arg1=path length.
    arg2/arg3 are optional userspace char** vectors for argv/envp. Null
    vectors preserve the legacy path where the image builder seeds argv[0]
    from the executable path.
    """
    if args.arg0 == 0 or args.arg1 == 0:
        return SyscallResult(value: 0 - EINVAL as i64)
    if args.arg1 > MAX_BINARY_PATH_LEN:
        return SyscallResult(value: 0 - ENAMETOOLONG as i64)
    val path_bytes_result = _copy_user_bytes(args.arg0, args.arg1)
    if path_bytes_result.is_err():
        return SyscallResult(value: 0 - EFAULT as i64)

    val path_bytes = path_bytes_result.unwrap()
    val path = _path_bytes_to_text(path_bytes)
    val grant_errno = _process_grant_errno_for_path(path, KernelLog.new(16))
    if grant_errno < 0:
        return SyscallResult(value: grant_errno)
    val bytes_result = resolve_executable_bytes_from_path_bytes(path_bytes, CURRENT_EXEC_ARCH)
    if bytes_result.is_err():
        return SyscallResult(value: -2)

    val argv_result = vmm_copyin_string_vector(
        args.arg2,
        MAX_EXEC_ARG_COUNT,
        MAX_EXEC_STRING_LEN,
        MAX_EXEC_TOTAL_STRING_BYTES
    )
    if not vmm_copy_string_vector_result_ok(argv_result):
        return SyscallResult(value: 0 - vmm_copy_string_vector_result_errno(argv_result) as i64)
    val envp_result = vmm_copyin_string_vector(
        args.arg3,
        MAX_EXEC_ENV_COUNT,
        MAX_EXEC_STRING_LEN,
        MAX_EXEC_TOTAL_STRING_BYTES
    )
    if not vmm_copy_string_vector_result_ok(envp_result):
        return SyscallResult(value: 0 - vmm_copy_string_vector_result_errno(envp_result) as i64)

    val image_result = build_user_process_image(
        path,
        bytes_result.unwrap(),
        CURRENT_EXEC_ARCH,
        vmm_copy_string_vector_result_values(argv_result),
        vmm_copy_string_vector_result_values(envp_result)
    )
    if image_result.is_err():
        return SyscallResult(value: -8)

    var sched = scheduler
    val current = sched.get_current()
    val result = sched.exec_image(current, image_result.unwrap())
    if result == 0:
        _close_cloexec_fds_with_backends()
        val old_space = task_vmspace_of(current.id.to_u32())
        if old_space != nil:
            vmm_teardown_user_space(old_space.unwrap())
        val exec_space = vmm_new_process_space(0, 0)
        register_task_vmspace(current.id.to_u32(), exec_space)
    SyscallResult(value: result.to_i64())

fn _encode_wait_status(exit_code: i32) -> u32:
    """Encode a normal-exit status compatible with WEXITSTATUS."""
    (((exit_code as u32) & 0xFF) << 8)

fn _write_wait_status(ptr: u64, exit_code: i32) -> i64:
    """Copy an encoded wait status to userspace when the pointer is present."""
    if ptr == 0:
        return 0
    if not _is_userspace_ptr(ptr):
        return -14
    if not vmm_verify_user_write(ptr, 4):
        return -14
    mmio_write32(ptr, _encode_wait_status(exit_code))
    0

fn _validate_wait_status_ptr(ptr: u64) -> i64:
    """Validate waitpid status copyout before consuming a zombie child."""
    if ptr == 0:
        return 0
    if not _is_userspace_ptr(ptr):
        return -14
    if not vmm_verify_user_write(ptr, 4):
        return -14
    0

fn _handle_waitpid(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """Waitpid-compatible wrapper around Scheduler.wait_for.

    Args:
      arg0: pid, or u64::MAX for any child
      arg1: status pointer, optional
      arg2: options (bit 0 = WNOHANG)
    """
    val any_child = args.arg0 == 0xFFFFFFFFFFFFFFFF
    val selector = if any_child: TaskId(id: 0) else: TaskId(id: args.arg0)
    val nohang = (args.arg2 & 1) != 0
    var sched = scheduler
    val current = sched.get_current()
    val status_ptr_check = _validate_wait_status_ptr(args.arg1)
    if status_ptr_check < 0:
        return SyscallResult(value: status_ptr_check)
    val result = sched.wait_for_collect(current, selector, not nohang)
    val result_error = wait_collect_result_error(result)
    if result_error == -11:
        return SyscallResult(value: 0)
    if result_error < 0:
        return SyscallResult(value: result_error.to_i64())

    val status_write = _write_wait_status(args.arg1, wait_collect_result_status(result))
    if status_write < 0:
        return SyscallResult(value: status_write)
    SyscallResult(value: wait_collect_result_pid(result).to_i64())

fn _handle_pipe(args: SyscallArgs) -> SyscallResult:
    """Create a POSIX pipe and copy fd[0]/fd[1] to the user array."""
    if args.arg0 == 0:
        return SyscallResult(value: -14)
    if not _is_userspace_ptr(args.arg0):
        return SyscallResult(value: -14)
    if not vmm_verify_user_write(args.arg0, 8):
        return SyscallResult(value: -14)
    SyscallResult(value: posix_pipe(args.arg0, args.arg0 + 4) as i64)

fn _handle_dup2(args: SyscallArgs) -> SyscallResult:
    """Duplicate oldfd onto newfd using POSIX dup2 replacement semantics."""
    SyscallResult(value: posix_dup2(args.arg0 as i32, args.arg1 as i32) as i64)

fn _handle_dup(args: SyscallArgs) -> SyscallResult:
    """Duplicate oldfd to the lowest available descriptor."""
    SyscallResult(value: posix_dup(args.arg0 as i32) as i64)

fn _handle_dlopen(args: SyscallArgs) -> SyscallResult:
    """Load a path-backed dynamic object and return a kernel registry handle.

    ABI:
      arg0: path pointer
      arg1: path length
      arg2: mode flags (reserved)
    """
    val _mode = args.arg2
    val path_result = _copy_user_text(args.arg0, args.arg1)
    if path_result.is_err():
        return SyscallResult(value: -14)
    val path = path_result.unwrap()
    val bytes_result = resolve_executable_bytes(path, CURRENT_EXEC_ARCH)
    if bytes_result.is_err():
        return SyscallResult(value: -2)
    SyscallResult(value: loader_dynopen_bytes(path, bytes_result.unwrap()))

fn _handle_dlsym(args: SyscallArgs) -> SyscallResult:
    """Resolve a symbol from a kernel dynamic-library handle.

    ABI:
      arg0: handle returned by DlOpen
      arg1: symbol-name pointer
      arg2: symbol-name length
    """
    val name_result = _copy_user_text(args.arg1, args.arg2)
    if name_result.is_err():
        return SyscallResult(value: -14)
    SyscallResult(value: loader_dynsym(args.arg0 as i64, name_result.unwrap()))

fn _handle_dlclose(args: SyscallArgs) -> SyscallResult:
    """Close one reference to a kernel dynamic-library handle."""
    SyscallResult(value: loader_dynclose(args.arg0 as i64))

fn _handle_poll(args: SyscallArgs, scheduler: Scheduler) -> SyscallResult:
    """poll(2)-compatible readiness scan over user pollfd entries.

    ABI:
      arg0: struct pollfd* (fd: i32, events: i16, revents: i16)
      arg1: nfds
      arg2: timeout_ms (-1 = block on fd notifications, 0 = nonblocking,
            >0 = block until fd notification or scheduler sleep deadline)
    """
    val fds_ptr = args.arg0
    val nfds = args.arg1
    var sched = scheduler
    val current = sched.get_current()
    val task_id = current.id
    val timeout_infinite = (args.arg2 & 0x8000000000000000) != 0
    if nfds == 0:
        if timeout_infinite:
            sched.block_task(current, BlockReason.Sleep(until_ns: 0xFFFFFFFFFFFFFFFF))
        elif args.arg2 > 0:
            val timeout_ticks = (args.arg2 + 9) / 10
            val ticks = if timeout_ticks == 0: 1 else: timeout_ticks
            val deadline_ns = (sched.tick_count() + ticks) * 10000000
            sched.block_task(current, BlockReason.Sleep(until_ns: deadline_ns))
        return SyscallResult(value: 0)
    if fds_ptr == 0:
        return SyscallResult(value: -14)
    if nfds > 64:
        return SyscallResult(value: -22)
    val bytes = nfds * 8
    if fds_ptr + bytes < fds_ptr:
        return SyscallResult(value: -14)
    if not _is_userspace_ptr(fds_ptr):
        return SyscallResult(value: -14)
    if not _is_userspace_ptr(fds_ptr + bytes - 1):
        return SyscallResult(value: -14)
    if not vmm_verify_user_write(fds_ptr, bytes):
        return SyscallResult(value: -14)

    var ready: i64 = 0
    var i: u64 = 0
    while i < nfds:
        val entry = fds_ptr + i * 8
        val fd = mmio_read32(entry) as i32
        val events = mmio_read16(entry + 4) as i16
        var revents: i16 = 0
        if fd >= 0:
            revents = fd_poll_ready(fd, events)
        mmio_write16(entry + 6, revents as u16)
        if revents != 0:
            ready = ready + 1
        i = i + 1
    if ready > 0:
        return SyscallResult(value: ready)
    if args.arg2 == 0:
        return SyscallResult(value: 0)

    var ids: [u64] = []
    var blockable_count: u64 = 0
    i = 0
    while i < nfds:
        val entry = fds_ptr + i * 8
        val fd = mmio_read32(entry) as i32
        val events = mmio_read16(entry + 4) as i16
        if fd >= 0:
            val notif = fd_poll_notification(fd, events)
            if notif != 0:
                blockable_count = blockable_count + 1
                if ids.len() < 4:
                    ids.push(notif)
        i = i + 1
    if blockable_count > 4:
        return SyscallResult(value: -22)

    if ids.len() == 0:
        if timeout_infinite:
            sched.block_task(current, BlockReason.Sleep(until_ns: 0xFFFFFFFFFFFFFFFF))
        elif args.arg2 > 0:
            val timeout_ticks = (args.arg2 + 9) / 10
            val ticks = if timeout_ticks == 0: 1 else: timeout_ticks
            val deadline_ns = (sched.tick_count() + ticks) * 10000000
            sched.block_task(current, BlockReason.Sleep(until_ns: deadline_ns))
        return SyscallResult(value: 0)

    val count = ids.len()
    val result = notification_wait_any(g_notification_table, ids, count, task_id)
    if result != 0:
        ready = 0
        i = 0
        while i < nfds:
            val entry = fds_ptr + i * 8
            val fd = mmio_read32(entry) as i32
            val events = mmio_read16(entry + 4) as i16
            var revents: i16 = 0
            if fd >= 0:
                revents = fd_poll_ready(fd, events)
            mmio_write16(entry + 6, revents as u16)
            if revents != 0:
                ready = ready + 1
            i = i + 1
        return SyscallResult(value: ready)

    if timeout_infinite:
        notification_register_multi_waiter(g_notification_table, ids, count, task_id)
        sched.block_task(current, BlockReason.Notification(id: ids[0]))
    elif args.arg2 > 0:
        notification_register_multi_waiter(g_notification_table, ids, count, task_id)
        val timeout_ticks = (args.arg2 + 9) / 10
        val ticks = if timeout_ticks == 0: 1 else: timeout_ticks
        val deadline_ns = (sched.tick_count() + ticks) * 10000000
        sched.block_task(current, BlockReason.Sleep(until_ns: deadline_ns))
    SyscallResult(value: 0)

fn _handle_fcntl(args: SyscallArgs) -> SyscallResult:
    """fcntl subset for descriptor flags and nonblocking status flags."""
    val fd = args.arg0 as i32
    val cmd = args.arg1 as i32
    val arg = args.arg2
    val F_DUPFD: i32 = 0
    val F_GETFD: i32 = 1
    val F_SETFD: i32 = 2
    val F_GETFL: i32 = 3
    val F_SETFL: i32 = 4
    val F_DUPFD_CLOEXEC: i32 = 1030
    val F_SIMPLEOS_GET_OFD: i32 = 1397686273

    if cmd == F_DUPFD:
        return SyscallResult(value: fd_dup_from(fd, arg as i32, false) as i64)
    if cmd == F_DUPFD_CLOEXEC:
        return SyscallResult(value: fd_dup_from(fd, arg as i32, true) as i64)
    if not fd_is_valid(fd):
        return SyscallResult(value: -9)
    if cmd == F_GETFD:
        return SyscallResult(value: if fd_get_cloexec(fd): 1 else: 0)
    if cmd == F_SETFD:
        return SyscallResult(value: fd_set_cloexec(fd, (arg & 1) != 0) as i64)
    if cmd == F_GETFL:
        return SyscallResult(value: fd_get_status_flags(fd) as i64)
    if cmd == F_SETFL:
        return SyscallResult(value: fd_set_status_flags(fd, arg as u32) as i64)
    if cmd == F_SIMPLEOS_GET_OFD:
        return SyscallResult(value: fd_get_object_id(fd) as i64)
    SyscallResult(value: -22)

fn _handle_getpid(scheduler: Scheduler) -> SyscallResult:
    """Return the current task's ID."""
    val current = scheduler.get_current()
    SyscallResult(value: current.id.to_i64())

# ============================================================================
# Copy-from-user helpers (used by spawn/exec/dlopen only)
# ============================================================================

fn _path_bytes_to_text(bytes: [u8]) -> text:
    rt_string_from_byte_array(bytes)

fn _copy_user_bytes(ptr_addr: u64, len: u64) -> Result<[u8], text>:
    if ptr_addr == 0:
        return Err("null path pointer")
    if len == 0:
        return Err("empty path")
    if len > MAX_BINARY_PATH_LEN:
        return Err("path too long")
    var bytes: [u8] = []
    var i: u64 = 0
    while i < len:
        bytes.push(rt_copy_user_byte(ptr_addr + i))
        i = i + 1
    Ok(bytes)

fn _copy_user_text(ptr_addr: u64, len: u64) -> Result<text, text>:
    log_raw_println("[syscall13] copy_user_text enter")
    val bytes_result = _copy_user_bytes(ptr_addr, len)
    if bytes_result.is_err():
        return Err(bytes_result.err().unwrap())
    log_raw_println("[syscall13] copy_user_text ok")
    Ok(_path_bytes_to_text(bytes_result.unwrap()))

fn _is_user_read_range(ptr: u64, len: u64) -> bool:
    if not _is_userspace_range(ptr, len):
        return false
    if g_current_vmspace.vma_count > 0 as u64:
        return _vma_range_readable(g_current_vmspace, ptr, len)
    true

fn _copy_user_u64(ptr_addr: u64) -> Result<u64, text>:
    if not _is_user_read_range(ptr_addr, 8):
        return Err("bad user pointer")
    var value: u64 = 0
    var i: u64 = 0
    while i < 8:
        val current = ptr_addr + i
        if current < ptr_addr:
            return Err("u64 pointer overflow")
        if not _is_user_read_range(current, 1):
            return Err("bad user pointer")
        val b = rt_copy_user_byte(current)
        value = value | (b.to_u64() << (i * 8))
        i = i + 1
    Ok(value)

fn _copy_user_cstr(ptr_addr: u64, max_len: u64) -> Result<text, text>:
    if ptr_addr == 0:
        return Err("null string pointer")
    var bytes: [u8] = []
    var i: u64 = 0
    while i < max_len:
        val current = ptr_addr + i
        if current < ptr_addr:
            return Err("string pointer overflow")
        if not _is_user_read_range(current, 1):
            return Err("bad string pointer")
        val b = rt_copy_user_byte(current)
        if b == 0u8:
            return Ok(_path_bytes_to_text(bytes))
        bytes.push(b)
        i = i + 1
    Err("unterminated string")

fn _copy_user_string_vector(vec_ptr: u64, max_count: u64) -> Result<[text], text>:
    if vec_ptr == 0:
        return Ok([])
    var out: [text] = []
    var total_bytes: u64 = 0
    var i: u64 = 0
    while i < max_count:
        val offset = i * 8
        val slot = vec_ptr + offset
        if slot < vec_ptr:
            return Err("vector pointer overflow")
        val item_ptr_result = _copy_user_u64(slot)
        if item_ptr_result.is_err():
            return Err(item_ptr_result.err().unwrap())
        val item_ptr = item_ptr_result.unwrap()
        if item_ptr == 0:
            return Ok(out)
        val item_result = _copy_user_cstr(item_ptr, MAX_EXEC_STRING_LEN)
        if item_result.is_err():
            return Err(item_result.err().unwrap())
        val item = item_result.unwrap()
        val item_bytes = (item.len() as u64) + 1
        if total_bytes + item_bytes < total_bytes:
            return Err("argument byte overflow")
        total_bytes = total_bytes + item_bytes
        if total_bytes > MAX_EXEC_TOTAL_STRING_BYTES:
            return Err("argument bytes too large")
        out.push(item)
        i = i + 1
    Err("string vector not terminated")

fn _handle_spawn_binary(args: SyscallArgs, scheduler: Scheduler, klog: KernelLog) -> SyscallResult:
    """Spawn a task from a binary path.

    Args:
      arg0: userspace pointer to path bytes
      arg1: path length
      arg2: argv packed-buffer base, or legacy priority
      arg3: envp packed-buffer base
      arg4: argv pointer-table offset
      arg5: envp pointer-table offset
    """
    log_raw_println("[syscall13] handle_spawn_binary enter")
    if args.arg0 == 0 or args.arg1 == 0:
        return SyscallResult(value: -22)
    val path_bytes_result = _copy_user_bytes(args.arg0, args.arg1)
    if path_bytes_result.is_err():
        return SyscallResult(value: -22)

    val path_bytes = path_bytes_result.unwrap()
    val path = _path_bytes_to_text(path_bytes)
    log_raw_println("[syscall13] path decoded")
    val grant_errno = _process_grant_errno_for_path(path, klog)
    if grant_errno < 0:
        return SyscallResult(value: grant_errno)
    val arch = CURRENT_EXEC_ARCH
    val bytes_result = resolve_executable_bytes_from_path_bytes(path_bytes, arch)
    log_raw_println("[syscall13] resolve_executable_bytes returned")
    if bytes_result.is_err():
        var log = klog
        klog_write(log, 3, 1, 0, "spawn_binary rejected unknown binary: {path}")
        return SyscallResult(value: -2)
    var sp_argv: [text] = []
    var sp_envp: [text] = []
    var priority_raw = args.arg2
    if args.arg4 != 0:
        val argv_result = vmm_copyin_packed_string_vector(
            args.arg2,
            args.arg4,
            MAX_EXEC_ARG_COUNT,
            MAX_EXEC_STRING_LEN,
            MAX_EXEC_TOTAL_STRING_BYTES
        )
        if not vmm_copy_string_vector_result_ok(argv_result):
            return SyscallResult(value: 0 - vmm_copy_string_vector_result_errno(argv_result) as i64)
        val envp_result = vmm_copyin_packed_string_vector(
            args.arg3,
            args.arg5,
            MAX_EXEC_ENV_COUNT,
            MAX_EXEC_STRING_LEN,
            MAX_EXEC_TOTAL_STRING_BYTES
        )
        if not vmm_copy_string_vector_result_ok(envp_result):
            return SyscallResult(value: 0 - vmm_copy_string_vector_result_errno(envp_result) as i64)
        sp_argv = vmm_copy_string_vector_result_values(argv_result)
        sp_envp = vmm_copy_string_vector_result_values(envp_result)
        priority_raw = 0
    val image_result = build_user_process_image(path, bytes_result.unwrap(), arch, sp_argv, sp_envp)
    if image_result.is_ok():
        val priority = _u64_to_priority(priority_raw)
        # Boot/init compat wrapper (see spawn_full); migrates to a per-image
        # SpawnSpec pouch once the injection ABI is wired at boot.
        val caps = spawn_full()
        var sched = scheduler
        val before_next_task_id = g_scheduler_next_task_id
        val raw_pid = sched.create_user_task_pid(image_result.unwrap(), priority, caps)
        val pid = if g_scheduler_next_task_id > before_next_task_id:
            g_scheduler_next_task_id - 1
        elif raw_pid > 0 and raw_pid < 0x40000000:
            raw_pid
        else:
            0
        if pid == 0:
            return SyscallResult(value: -12)

        val child_space = vmm_new_process_space(0, 0)
        register_task_vmspace(pid.to_u32(), child_space)
        return SyscallResult(value: pid.to_i64())

    var log = klog
    klog_write(log, 3, 1, 0, "spawn_binary rejected invalid executable: {path}")
    SyscallResult(value: -8)

fn _direct_spawn_app_id_path(app_id: u64) -> text?:
    val canonical = _legacy_app_id_to_name(app_id)
    if canonical == nil:
        return nil
    val entry = app_registry_lookup(canonical.unwrap())
    if entry == nil:
        # Registry not populated (early boot / hosted unit tests): fall back
        # to the legacy canonical path. Grant checks and executable
        # resolution still gate the spawn downstream, so nothing is weakened.
        return canonical
    Some(entry.unwrap().canonical_path)

fn _legacy_app_id_to_name(app_id: u64) -> text?:
    # NOTE: written as if/elif because interpreter `match` on a u64 parameter
    # against integer literal cases fails to match across module boundaries
    # (returns the default arm); `==` comparisons work. Known interpreter bug —
    # see doc/08_tracking bug entry for interp u64 match dispatch.
    if app_id == 1:
        Some("/sys/apps/browser_demo")
    elif app_id == 2:
        Some("/sys/apps/file_manager")
    elif app_id == 3:
        Some("/sys/apps/hello_world")
    elif app_id == 103:
        Some("/sys/apps/hello_world")
    elif app_id == 4:
        Some("/sys/apps/shell")
    elif app_id == 5:
        Some("/sys/apps/editor")
    elif app_id == 12:
        Some("/sys/apps/clang")
    else:
        nil

pub struct SpawnBinaryDirectState:
    """Explicit runtime-state threading result for direct SpawnBinary dispatch.

    Scheduler instances have value semantics across call boundaries, so the
    task created by create_user_task_pid only exists in the callee's copy.
    Callers must adopt the returned scheduler (mirrors IpcSyscallState)."""
    pid: i64
    scheduler: Scheduler

fn _spawn_from_resolved_bytes_for_arch_state(path: text, path_bytes: [u8], bytes: [u8], priority_raw: u64, scheduler: Scheduler, klog: KernelLog, arch: Architecture) -> SpawnBinaryDirectState:
    val _path_bytes = path_bytes
    val priority = _u64_to_priority(priority_raw)
    # Boot/init compat wrapper (see spawn_full); migrates to a per-image
    # SpawnSpec pouch once the injection ABI is wired at boot.
    val caps = spawn_full()
    var sched = scheduler
    log_raw_println("[syscall13] staged create_user_task begin")
    val pid = sched.create_user_task_from_bytes_pid(path, bytes, arch, priority, caps)
    log_raw_println("[syscall13] staged create_user_task returned pid={pid}")
    if pid == 0:
        var log = klog
        klog_write(log, 3, 1, 0, "spawn_binary rejected invalid executable: {path}")
        return SpawnBinaryDirectState(pid: -8, scheduler: sched)
    SpawnBinaryDirectState(pid: pid as i64, scheduler: sched)

fn _spawn_from_resolved_bytes_for_arch(path: text, path_bytes: [u8], bytes: [u8], priority_raw: u64, scheduler: Scheduler, klog: KernelLog, arch: Architecture) -> i64:
    _spawn_from_resolved_bytes_for_arch_state(path, path_bytes, bytes, priority_raw, scheduler, klog, arch).pid

fn _spawn_from_resolved_bytes_state(path: text, path_bytes: [u8], bytes: [u8], priority_raw: u64, scheduler: Scheduler, klog: KernelLog) -> SpawnBinaryDirectState:
    _spawn_from_resolved_bytes_for_arch_state(path, path_bytes, bytes, priority_raw, scheduler, klog, CURRENT_EXEC_ARCH)

fn _builtin_binary_path_for_spawn(path: text) -> text:
    if path.ends_with(".smf") and path.len() > 4:
        return path.substring(0, path.len() - 4)
    path

fn _is_builtin_binary_path(path: text) -> bool:
    resolve_builtin_binary(_builtin_binary_path_for_spawn(path)) != nil

pub fn dispatch_spawn_binary_direct_state(path_ptr: u64, path_len: u64, priority_raw: u64, scheduler: Scheduler, klog: KernelLog) -> SpawnBinaryDirectState:
    """SpawnBinary bridge returning updated scheduler state for cross-module callers.

    Mirrors syscall_handler_ipc_state: callers outside this module must thread
    the returned scheduler back into their globals instead of relying on
    in-place mutation of the passed instance."""
    log_raw_println("[syscall13] dispatch_direct enter")
    if path_len == 0:
        var path = ""
        if path_ptr == 1u64:
            path = "/sys/apps/browser_demo"
        elif path_ptr == 2u64:
            path = "/sys/apps/file_manager"
        elif path_ptr == 3u64 or path_ptr == 103u64:
            path = "/sys/apps/hello_world"
        elif path_ptr == 4u64:
            path = "/sys/apps/shell"
        elif path_ptr == 5u64:
            path = "/sys/apps/editor"
        elif path_ptr == 12u64:
            path = "/sys/apps/clang"
        if path == "":
            return SpawnBinaryDirectState(pid: -14, scheduler: scheduler)
        val grant_errno = _process_grant_errno_for_path(path, klog)
        if grant_errno < 0:
            return SpawnBinaryDirectState(pid: grant_errno, scheduler: scheduler)
        val boot_bytes = app_registry_cached_boot_app_id(path_ptr)
        if boot_bytes.len() > 4:
            return _spawn_from_resolved_bytes_state(path, [], boot_bytes, priority_raw, scheduler, klog)
        val bytes_result = resolve_executable_bytes(path, CURRENT_EXEC_ARCH)
        if bytes_result.is_ok():
            return _spawn_from_resolved_bytes_state(path, [], bytes_result.unwrap(), priority_raw, scheduler, klog)
        if _is_builtin_binary_path(path):
            log_raw_println("[syscall13] builtin resident fallback path={path}")
            return SpawnBinaryDirectState(pid: -2, scheduler: scheduler)
        return SpawnBinaryDirectState(pid: -14, scheduler: scheduler)

    if path_len > MAX_BINARY_PATH_LEN:
        log_raw_println("[syscall13] dispatch_direct path too long")
        return SpawnBinaryDirectState(pid: -14, scheduler: scheduler)
    val path_bytes_result = _copy_user_bytes(path_ptr, path_len)
    if path_bytes_result.is_err():
        log_raw_println("[syscall13] dispatch_direct path copy failed")
        return SpawnBinaryDirectState(pid: -14, scheduler: scheduler)

    val path_bytes = path_bytes_result.unwrap()
    val path = _path_bytes_to_text(path_bytes)
    log_raw_println("[syscall13] dispatch_direct path-ready len={path_len} path={path}")
    val grant_errno = _process_grant_errno_for_path(path, klog)
    if grant_errno < 0:
        return SpawnBinaryDirectState(pid: grant_errno, scheduler: scheduler)
    val arch = CURRENT_EXEC_ARCH
    log_raw_println("[syscall13] dispatch_direct arch-ready")

    val bytes_result = resolve_executable_bytes_from_path_bytes(path_bytes, arch)
    log_raw_println("[syscall13] dispatch_direct resolve returned")
    if bytes_result.is_ok():
        log_raw_println("[syscall13] vfs bytes ok; exec handoff active")
        return _spawn_from_resolved_bytes_state(path, path_bytes, bytes_result.unwrap(), priority_raw, scheduler, klog)

    if _is_builtin_binary_path(path):
        log_raw_println("[syscall13] builtin resident fallback path={path}")
        return SpawnBinaryDirectState(pid: -2, scheduler: scheduler)

    if bytes_result.is_err():
        var log = klog
        klog_write(log, 3, 1, 0, "spawn_binary rejected unknown binary: {path}")
        return SpawnBinaryDirectState(pid: -2, scheduler: scheduler)

    SpawnBinaryDirectState(pid: -2, scheduler: scheduler)

fn dispatch_spawn_binary_direct(path_ptr: u64, path_len: u64, priority_raw: u64, scheduler: Scheduler, klog: KernelLog) -> i64:
    """Dedicated SpawnBinary bridge that avoids the generic syscall wrapper.

    Result-only legacy entrypoint: the scheduler mutation is NOT visible to
    the caller (value semantics). Use dispatch_spawn_binary_direct_state when
    the spawned task must survive in the caller's scheduler."""
    dispatch_spawn_binary_direct_state(path_ptr, path_len, priority_raw, scheduler, klog).pid
