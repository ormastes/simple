# Kernel process queue manager.
#
# Bounded FIFO message queues used by process-level IPC. Handles are table slot
# indexes, so handle 0 is valid when slot 0 is active. Attachments use an
# explicit sentinel instead of overloading handle 0.

use os.posix.errno.{EAGAIN, EBADF, EINVAL, ENOMEM, EPIPE}

val PROCESS_QUEUE_MAX_QUEUES: u64 = 64
val PROCESS_QUEUE_MAX_CAPACITY: u64 = 64
val PROCESS_QUEUE_MAX_MSG_BYTES: u64 = 256
val PROCESS_QUEUE_SLOT_COUNT: u64 = 4096
val PROCESS_QUEUE_STORAGE_BYTES: u64 = 1048576

val PROCESS_QUEUE_NO_HANDLE: u64 = 0xFFFFFFFFFFFFFFFF

val PROCESS_QUEUE_POLL_READ: u32 = 1
val PROCESS_QUEUE_POLL_WRITE: u32 = 4
val PROCESS_QUEUE_POLL_ERR: u32 = 8
val PROCESS_QUEUE_POLL_HUP: u32 = 16

val PROCESS_QUEUE_CLOSE_SEND: u32 = 1
val PROCESS_QUEUE_CLOSE_RECV: u32 = 2

struct ProcessQueueRecv:
    """Receive result for one bounded process-queue message."""
    status: i64
    len: u64
    attached_handle: u64
    data: [u8]

var process_queue_active: [bool; 64]
var process_queue_closed_send: [bool; 64]
var process_queue_closed_recv: [bool; 64]
var process_queue_capacity: [u64; 64]
var process_queue_max_msg_bytes: [u64; 64]
var process_queue_head: [u64; 64]
var process_queue_tail: [u64; 64]
var process_queue_count: [u64; 64]
var process_queue_generation: [u64; 64]
var process_queue_flags: [u32; 64]
var process_queue_slot_len: [u64; 4096]
var process_queue_slot_attached: [u64; 4096]
var process_queue_bytes: [u8; 1048576]

fn process_queue_init():
    """Reset the kernel process queue table."""
    var q: u64 = 0
    while q < PROCESS_QUEUE_MAX_QUEUES:
        process_queue_active[q] = false
        process_queue_closed_send[q] = false
        process_queue_closed_recv[q] = false
        process_queue_capacity[q] = 0
        process_queue_max_msg_bytes[q] = 0
        process_queue_head[q] = 0
        process_queue_tail[q] = 0
        process_queue_count[q] = 0
        process_queue_generation[q] = process_queue_generation[q] + 1
        process_queue_flags[q] = 0
        q = q + 1

    var slot: u64 = 0
    while slot < PROCESS_QUEUE_SLOT_COUNT:
        process_queue_slot_len[slot] = 0
        process_queue_slot_attached[slot] = PROCESS_QUEUE_NO_HANDLE
        slot = slot + 1

    var i: u64 = 0
    while i < PROCESS_QUEUE_STORAGE_BYTES:
        process_queue_bytes[i] = 0
        i = i + 1

fn _process_queue_valid(queue: u64) -> bool:
    if queue >= PROCESS_QUEUE_MAX_QUEUES:
        return false
    process_queue_active[queue]

fn _process_queue_slot(queue: u64, logical_slot: u64) -> u64:
    queue * PROCESS_QUEUE_MAX_CAPACITY + logical_slot

fn _process_queue_slot_base(slot: u64) -> u64:
    slot * PROCESS_QUEUE_MAX_MSG_BYTES

fn process_queue_create(capacity: u64, max_msg_bytes: u64, flags: u32) -> i64:
    """Create a bounded MPMC process queue and return its handle."""
    if capacity == 0 or capacity > PROCESS_QUEUE_MAX_CAPACITY:
        return 0 - EINVAL as i64
    if max_msg_bytes == 0 or max_msg_bytes > PROCESS_QUEUE_MAX_MSG_BYTES:
        return 0 - EINVAL as i64

    var q: u64 = 0
    while q < PROCESS_QUEUE_MAX_QUEUES:
        if not process_queue_active[q]:
            process_queue_active[q] = true
            process_queue_closed_send[q] = false
            process_queue_closed_recv[q] = false
            process_queue_capacity[q] = capacity
            process_queue_max_msg_bytes[q] = max_msg_bytes
            process_queue_head[q] = 0
            process_queue_tail[q] = 0
            process_queue_count[q] = 0
            process_queue_generation[q] = process_queue_generation[q] + 1
            process_queue_flags[q] = flags

            var logical: u64 = 0
            while logical < capacity:
                val slot = _process_queue_slot(q, logical)
                process_queue_slot_len[slot] = 0
                process_queue_slot_attached[slot] = PROCESS_QUEUE_NO_HANDLE
                logical = logical + 1

            return q as i64
        q = q + 1

    0 - ENOMEM as i64

fn process_queue_send(queue: u64, bytes: [u8], attached_handle: u64) -> i64:
    """Enqueue one FIFO message."""
    if not _process_queue_valid(queue):
        return 0 - EBADF as i64
    if process_queue_closed_send[queue] or process_queue_closed_recv[queue]:
        return 0 - EPIPE as i64
    if bytes.len() > process_queue_max_msg_bytes[queue]:
        return 0 - EINVAL as i64
    if process_queue_count[queue] >= process_queue_capacity[queue]:
        return 0 - EAGAIN as i64

    val tail = process_queue_tail[queue]
    val slot = _process_queue_slot(queue, tail)
    val base = _process_queue_slot_base(slot)

    var i: u64 = 0
    while i < bytes.len():
        process_queue_bytes[base + i] = bytes[i]
        i = i + 1

    process_queue_slot_len[slot] = bytes.len()
    process_queue_slot_attached[slot] = attached_handle
    process_queue_tail[queue] = (tail + 1) % process_queue_capacity[queue]
    process_queue_count[queue] = process_queue_count[queue] + 1
    bytes.len() as i64

fn process_queue_recv(queue: u64) -> ProcessQueueRecv:
    """Dequeue one FIFO message, or report EAGAIN/EOF."""
    if not _process_queue_valid(queue):
        return ProcessQueueRecv(status: 0 - EBADF as i64, len: 0, attached_handle: PROCESS_QUEUE_NO_HANDLE, data: [])
    if process_queue_closed_recv[queue]:
        return ProcessQueueRecv(status: 0 - EBADF as i64, len: 0, attached_handle: PROCESS_QUEUE_NO_HANDLE, data: [])
    if process_queue_count[queue] == 0:
        if process_queue_closed_send[queue]:
            return ProcessQueueRecv(status: 0, len: 0, attached_handle: PROCESS_QUEUE_NO_HANDLE, data: [])
        return ProcessQueueRecv(status: 0 - EAGAIN as i64, len: 0, attached_handle: PROCESS_QUEUE_NO_HANDLE, data: [])

    val head = process_queue_head[queue]
    val slot = _process_queue_slot(queue, head)
    val base = _process_queue_slot_base(slot)
    val msg_len = process_queue_slot_len[slot]
    var out: [u8] = []

    var i: u64 = 0
    while i < msg_len:
        out.push(process_queue_bytes[base + i])
        process_queue_bytes[base + i] = 0
        i = i + 1

    val attached = process_queue_slot_attached[slot]
    process_queue_slot_len[slot] = 0
    process_queue_slot_attached[slot] = PROCESS_QUEUE_NO_HANDLE
    process_queue_head[queue] = (head + 1) % process_queue_capacity[queue]
    process_queue_count[queue] = process_queue_count[queue] - 1

    ProcessQueueRecv(status: msg_len as i64, len: msg_len, attached_handle: attached, data: out)

fn process_queue_poll(queue: u64) -> u32:
    """Return readiness bits for a process queue."""
    if not _process_queue_valid(queue):
        return PROCESS_QUEUE_POLL_ERR | PROCESS_QUEUE_POLL_HUP

    var bits: u32 = 0
    if process_queue_count[queue] > 0:
        bits = bits | PROCESS_QUEUE_POLL_READ
    if not process_queue_closed_send[queue] and process_queue_count[queue] < process_queue_capacity[queue]:
        bits = bits | PROCESS_QUEUE_POLL_WRITE
    if process_queue_closed_send[queue] or process_queue_closed_recv[queue]:
        bits = bits | PROCESS_QUEUE_POLL_HUP
    bits

fn process_queue_close(queue: u64, mode: u32) -> i64:
    """Close send side, receive side, or both sides when mode is zero."""
    if not _process_queue_valid(queue):
        return 0 - EBADF as i64
    if mode == 0:
        process_queue_closed_send[queue] = true
        process_queue_closed_recv[queue] = true
        return 0
    if (mode & PROCESS_QUEUE_CLOSE_SEND) != 0:
        process_queue_closed_send[queue] = true
    if (mode & PROCESS_QUEUE_CLOSE_RECV) != 0:
        process_queue_closed_recv[queue] = true
    0

fn process_queue_len(queue: u64) -> i64:
    """Return the current queued message count."""
    if not _process_queue_valid(queue):
        return 0 - EBADF as i64
    process_queue_count[queue] as i64
