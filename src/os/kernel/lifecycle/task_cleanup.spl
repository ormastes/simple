#![allow(unnamed_duplicate_typed_args)]
# Task Exit Cleanup — Resource Reclamation
#
# When a task exits (syscall 0) or is killed, this module reclaims
# all kernel resources it held: notifications, IRQ routes, DMA buffers,
# and BAR mappings.
#
# Each resource granted to a task must be registered here via
# task_register_resource() so that task_cleanup() can release it.

use os.kernel.ipc.notif_global.{g_notification_table}
use os.kernel.ipc.notification.{notification_destroy}
use os.kernel.interrupts.irq_routing.{irq_route_unregister}
use os.kernel.memory.vmm.{vmm_unmap_page, PAGE_SIZE}
use os.kernel.memory.pmm.{pmm_free_page}
use os.kernel.types.memory_types.{PageFrame, VirtAddr}
use os.kernel.types.task_types.{TaskId}

extern fn serial_println(msg: text)

# ============================================================================
# Constants
# ============================================================================

val MAX_TASKS: u64 = 256
val MAX_RESOURCES_PER_TASK: u64 = 16
val TOTAL_RESOURCE_SLOTS: u64 = 4096   # MAX_TASKS * MAX_RESOURCES_PER_TASK

# Resource types
val RES_NONE: u8 = 0
val RES_NOTIFICATION: u8 = 1
val RES_IRQ_ROUTE: u8 = 2
val RES_DMA_BUFFER: u8 = 3
val RES_BAR_MAPPING: u8 = 4

# ============================================================================
# Per-Task Resource Tracking (flat arrays for baremetal ABI)
# ============================================================================

# Flat 2D layout: task T, slot S -> index = T * MAX_RESOURCES_PER_TASK + S
var task_res_type: [u8; 4096]       # resource type (RES_*)
var task_res_id: [u64; 4096]        # resource ID (notification ID, IRQ vector, etc.)
var task_res_aux: [u64; 4096]       # auxiliary data (size for DMA/BAR, phys addr, etc.)
var task_res_count: [u64; 256]      # number of resources registered per task

# ============================================================================
# Resource Registration
# ============================================================================

fn task_register_resource(task_id: u64, res_type: u8, res_id: u64, aux: u64) -> bool:
    """Register a resource owned by a task for cleanup on exit.

    Args:
      task_id:  owning task ID
      res_type: one of RES_NOTIFICATION, RES_IRQ_ROUTE, RES_DMA_BUFFER, RES_BAR_MAPPING
      res_id:   resource identifier (notification ID, IRQ vector, virtual address, etc.)
      aux:      auxiliary data (size in bytes for mappings, physical address for DMA, etc.)

    Returns true on success, false if the task or slot is full.
    """
    if task_id >= MAX_TASKS:
        serial_println("[cleanup] ERROR: task_id {task_id} exceeds MAX_TASKS")
        return false

    val count = task_res_count[task_id]
    if count >= MAX_RESOURCES_PER_TASK:
        serial_println("[cleanup] ERROR: task {task_id} resource slots full ({count}/{MAX_RESOURCES_PER_TASK})")
        return false

    val idx = task_id * MAX_RESOURCES_PER_TASK + count
    task_res_type[idx] = res_type
    task_res_id[idx] = res_id
    task_res_aux[idx] = aux
    task_res_count[task_id] = count + 1
    true

# ============================================================================
# Task Cleanup
# ============================================================================

fn task_cleanup(task_id: u64):
    """Clean up all resources owned by a task.

    Called when a task exits or is killed. Iterates the resource table
    and releases each resource type appropriately:
      - RES_NOTIFICATION: destroy the notification object
      - RES_IRQ_ROUTE:    unregister the IRQ vector route
      - RES_DMA_BUFFER:   unmap virtual pages and free physical frames
      - RES_BAR_MAPPING:  unmap virtual pages (no frame free — device MMIO)
    """
    if task_id >= MAX_TASKS:
        return

    val count = task_res_count[task_id]
    if count == 0:
        return

    serial_println("[cleanup] Cleaning up task {task_id} ({count} resources)...")

    var i: u64 = 0
    while i < count:
        val idx = task_id * MAX_RESOURCES_PER_TASK + i
        val rtype = task_res_type[idx]
        val rid = task_res_id[idx]
        val raux = task_res_aux[idx]

        match rtype:
            RES_NOTIFICATION:
                serial_println("[cleanup]   Destroying notification {rid}")
                notification_destroy(g_notification_table, rid)

            RES_IRQ_ROUTE:
                serial_println("[cleanup]   Unregistering IRQ route vector={rid}")
                irq_route_unregister(rid.to_u32())

            RES_DMA_BUFFER:
                serial_println("[cleanup]   Freeing DMA buffer virt=0x{rid} size=0x{raux}")
                _unmap_and_free_pages(rid, raux)

            RES_BAR_MAPPING:
                serial_println("[cleanup]   Unmapping BAR virt=0x{rid} size=0x{raux}")
                _unmap_pages(rid, raux)

            _:
                serial_println("[cleanup]   Unknown resource type {rtype}, skipping")

        # Clear the slot
        task_res_type[idx] = RES_NONE
        task_res_id[idx] = 0
        task_res_aux[idx] = 0
        i = i + 1

    task_res_count[task_id] = 0
    serial_println("[cleanup] Task {task_id} cleanup complete")

# ============================================================================
# Internal Helpers
# ============================================================================

fn _unmap_pages(virt_base: u64, size: u64):
    """Unmap virtual pages without freeing physical frames (for MMIO/BAR)."""
    var offset: u64 = 0
    while offset < size:
        val vaddr = VirtAddr(addr: virt_base + offset)
        vmm_unmap_page(vaddr)
        offset = offset + PAGE_SIZE

fn _unmap_and_free_pages(virt_base: u64, size: u64):
    """Unmap virtual pages and free the backing physical frames (for DMA)."""
    var offset: u64 = 0
    while offset < size:
        val vaddr = VirtAddr(addr: virt_base + offset)
        # Unmap returns the physical frame info via the page table entry.
        # For simplicity, we unmap first; the PMM tracks free frames separately.
        vmm_unmap_page(vaddr)
        # Free the physical page frame. The frame address is virt_base + offset
        # only for identity-mapped DMA regions; for non-identity mappings the
        # kernel would need to walk the page table. Phase 1 assumes identity map.
        val frame = PageFrame(addr: virt_base + offset)
        pmm_free_page(frame)
        offset = offset + PAGE_SIZE

fn task_resource_count(task_id: u64) -> u64:
    """Return the number of resources currently registered for a task."""
    if task_id >= MAX_TASKS:
        return 0
    task_res_count[task_id]
