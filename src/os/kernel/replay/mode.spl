# SimpleOS Kernel Replay — Mode Control
#
# Global replay mode as atomic integer. Off = 0 is the fast path:
# every hook function checks this first with a single load + branch.

# ============================================================================
# Replay Mode Enum
# ============================================================================

enum KernelReplayMode:
    Off           # Normal execution, no recording overhead
    Record        # Run normally, write event log
    Replay        # Use event log as authority
    Verify        # Run real operation and compare against log
    ChaosRecord   # Randomize scheduler/timing, record exact choices

impl KernelReplayMode:
    fn to_i32() -> i32:
        match self:
            case KernelReplayMode.Off: 0
            case KernelReplayMode.Record: 1
            case KernelReplayMode.Replay: 2
            case KernelReplayMode.Verify: 3
            case KernelReplayMode.ChaosRecord: 4

    static fn from_i32(v: i32) -> KernelReplayMode:
        match v:
            case 1: KernelReplayMode.Record
            case 2: KernelReplayMode.Replay
            case 3: KernelReplayMode.Verify
            case 4: KernelReplayMode.ChaosRecord
            case _: KernelReplayMode.Off

    fn to_text() -> text:
        match self:
            case KernelReplayMode.Off: "off"
            case KernelReplayMode.Record: "record"
            case KernelReplayMode.Replay: "replay"
            case KernelReplayMode.Verify: "verify"
            case KernelReplayMode.ChaosRecord: "chaos-record"

# ============================================================================
# Global State
# ============================================================================

var g_replay_mode: i32 = 0

fn replay_mode() -> KernelReplayMode:
    KernelReplayMode.from_i32(g_replay_mode)

fn replay_set_mode(mode: KernelReplayMode):
    g_replay_mode = mode.to_i32()

fn replay_is_off() -> bool:
    g_replay_mode == 0

fn replay_is_recording() -> bool:
    g_replay_mode == 1 or g_replay_mode == 4

fn replay_is_replaying() -> bool:
    g_replay_mode == 2

fn replay_is_verifying() -> bool:
    g_replay_mode == 3
