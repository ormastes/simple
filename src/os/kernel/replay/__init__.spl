# SimpleOS Kernel — Deterministic Replay Subsystem
#
# Records nondeterministic events (syscalls, scheduling, interrupts,
# timer reads, IPC) for deterministic replay. Off mode has zero cost
# (single atomic load + branch per hook site).

export KernelReplayMode, replay_mode, replay_set_mode, replay_is_off, replay_is_recording
export EventKind, ReplayEntry
export replay_log_event, replay_read_next, replay_peek_next
export replay_buffer_init, replay_buffer_reset, replay_event_count, replay_buffer_len
export replay_hook_schedule, replay_hook_syscall_enter, replay_hook_syscall_exit
export replay_hook_irq, replay_hook_ipc_send, replay_hook_ipc_recv
export replay_hook_timer_read, replay_hook_thread_create, replay_hook_thread_exit
export replay_hook_random_read, replay_hook_checkpoint
