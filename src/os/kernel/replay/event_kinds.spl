# SimpleOS Kernel Replay — compatibility exports.
#
# Replay record types are owned by the NoGC replay backend library so
# SimpleOS depends on `std.nogc_sync_mut.replay`, not the reverse.

use std.nogc_sync_mut.replay.event_kinds.{EventKind, ReplayEntry}

pub use EventKind
pub use ReplayEntry

# ============================================================================
# Schedule Event Payload Layout
# ============================================================================
#   payload_a = old_tid
#   payload_b = new_tid
#   payload_c = reason (i64 encoding of ScheduleReason)
#   payload_d = preempt_count

# ============================================================================
# Syscall Event Payload Layout
# ============================================================================
#   SyscallEnter:
#     payload_a = syscall_number
#     payload_b = arg0
#     payload_c = arg1
#     payload_d = arg2
#   SyscallExit:
#     payload_a = syscall_number
#     payload_b = return_value
#     payload_c = 0
#     payload_d = 0

# ============================================================================
# Interrupt Event Payload Layout
# ============================================================================
#   payload_a = irq_vector
#   payload_b = delivery_time (logical)
#   payload_c = controller_state_hash
#   payload_d = 0

# ============================================================================
# Timer Read Event Payload Layout
# ============================================================================
#   payload_a = clock_source_id
#   payload_b = value
#   payload_c = 0
#   payload_d = 0

# ============================================================================
# Thread Create/Exit Payload Layout
# ============================================================================
#   ThreadCreate:
#     payload_a = parent_tid
#     payload_b = child_tid
#     payload_c = entry_addr
#     payload_d = 0
#   ThreadExit:
#     payload_a = exit_code
#     payload_b = 0
#     payload_c = 0
#     payload_d = 0

# ============================================================================
# IPC Send/Receive Payload Layout
# ============================================================================
#   payload_a = src_or_dst_task_id
#   payload_b = port_id
#   payload_c = message_length
#   payload_d = 0
