"""
x86_64 FS-Loaded Tool Apps — llvm/rust native-wrapper marker shape.

llvm and rust remain wrapper frontends for x86_64 lane completion.
They must still emit both canonical VFS-read proof and process-backed launch
proof, plus their required toolchain-launch:ok markers.

Per plan acceptance contract:
  llvm:  mode=native-wrapper, tool=/usr/bin/clang
  rust:  mode=native-wrapper, status=report-and-gate, tool=/usr/bin/rustc, aux=/usr/bin/cargo

MDSOC: os layer — marker shape definitions, no spawn or IPC.
"""

pub val TOOLCHAIN_LANE_X86_64: text = "x86_64-simpleos"
pub val TOOLCHAIN_MODE_NATIVE_WRAPPER: text = "native-wrapper"

pub val LLVM_TOOL_PATH: text = "/usr/bin/clang"
pub val RUST_TOOL_PATH: text = "/usr/bin/rustc"
pub val RUST_AUX_PATH: text = "/usr/bin/cargo"

pub val LLVM_STATUS_GUEST_EXEC: text = "guest-exec"
pub val RUST_STATUS_REPORT_AND_GATE: text = "report-and-gate"

# Expected toolchain-launch marker fragment for llvm.
pub fn llvm_toolchain_launch_fragment() -> text:
    "[desktop-e2e] toolchain-launch:ok app=llvm mode={TOOLCHAIN_MODE_NATIVE_WRAPPER} lane={TOOLCHAIN_LANE_X86_64} status={LLVM_STATUS_GUEST_EXEC} tool={LLVM_TOOL_PATH}"

# Expected toolchain-launch marker fragment for rust.
pub fn rust_toolchain_launch_fragment() -> text:
    "[desktop-e2e] toolchain-launch:ok app=rust mode={TOOLCHAIN_MODE_NATIVE_WRAPPER} lane={TOOLCHAIN_LANE_X86_64} status={RUST_STATUS_REPORT_AND_GATE} tool={RUST_TOOL_PATH} aux={RUST_AUX_PATH}"

# Returns true if serial output contains the llvm toolchain-launch proof.
pub fn serial_has_llvm_toolchain_proof(serial_output: text) -> bool:
    serial_output.contains(llvm_toolchain_launch_fragment())

# Returns true if serial output contains the rust toolchain-launch proof.
pub fn serial_has_rust_toolchain_proof(serial_output: text) -> bool:
    serial_output.contains(rust_toolchain_launch_fragment())

# Returns true if both toolchain wrappers have their required markers.
pub fn serial_has_all_toolchain_wrapper_proof(serial_output: text) -> bool:
    serial_has_llvm_toolchain_proof(serial_output) and
    serial_has_rust_toolchain_proof(serial_output)

# Returns "ok" if both toolchain markers present, else "missing:<app>" for the first absent.
pub fn toolchain_wrapper_gate(serial_output: text) -> text:
    if not serial_has_llvm_toolchain_proof(serial_output):
        return "missing:llvm"
    if not serial_has_rust_toolchain_proof(serial_output):
        return "missing:rust"
    "ok"
