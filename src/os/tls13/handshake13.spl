#![allow(unnamed_duplicate_typed_args)]
# TLS 1.3 Handshake Message Encoder/Decoder (pure, no crypto)
#
# Implements ClientHello construction and server-side handshake parsing
# for TLS 1.3 per RFC 8446.  No cryptographic operations are performed here;
# all byte manipulation is pure Simple.
#
# Reference: RFC 8446 (TLS 1.3)

val TLS13_ASCII_PRINTABLE: text = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_array_new_with_cap(cap: i64) -> [u8]
extern fn rt_bytes_to_text(data: [u8]) -> text

fn _tls_hs_debug(msg: text):
    val _unused = msg.len()

fn _byte_buf(cap: u64) -> [u8]:
    rt_array_new_with_cap(cap.to_i64())

fn _push_byte(buf: [u8], byte_val: i64) -> [u8]:
    buf.push(byte_val.to_u8())
    buf

fn _u8_at(data: [u8], offset: u64) -> u8:
    rt_bytes_u8_at(data, offset.to_i64()).to_u8()

# ============================================================================
# Handshake Message Types
# ============================================================================

val HS_CLIENT_HELLO: u8         = 1
val HS_SERVER_HELLO: u8         = 2
val HS_ENCRYPTED_EXTENSIONS: u8 = 8
val HS_CERTIFICATE: u8          = 11
val HS_CERTIFICATE_REQUEST: u8  = 13
val HS_CERTIFICATE_VERIFY: u8   = 15
val HS_FINISHED: u8             = 20

# ============================================================================
# Extension Types
# ============================================================================

val EXT_SNI: u16                    = 0
val EXT_MAX_FRAGMENT_LENGTH: u16    = 1
val EXT_SUPPORTED_GROUPS: u16       = 10
val EXT_SIG_ALGS: u16               = 13
val EXT_ALPN: u16                   = 16
val EXT_SUPPORTED_VERSIONS: u16     = 43
val EXT_EARLY_DATA: u16             = 42
val EXT_COOKIE: u16                 = 44
val EXT_KEY_SHARE: u16              = 51

# ============================================================================
# HelloRetryRequest magic random (RFC 8446 §4.1.3)
# Equals SHA-256("HelloRetryRequest"). A ServerHello whose `random` field
# matches this constant is actually a HelloRetryRequest re-using ServerHello
# wire format — clients MUST treat it as HRR per §4.1.4.
# ============================================================================

val HRR_MAGIC: [u8] = [
    0xCFu8, 0x21u8, 0xADu8, 0x74u8, 0xE5u8, 0x9Au8, 0x61u8, 0x11u8,
    0xBEu8, 0x1Du8, 0x8Cu8, 0x02u8, 0x1Eu8, 0x65u8, 0xB8u8, 0x91u8,
    0xC2u8, 0xA2u8, 0x11u8, 0x16u8, 0x7Au8, 0xBBu8, 0x8Cu8, 0x5Eu8,
    0x07u8, 0x9Eu8, 0x09u8, 0xE2u8, 0xC8u8, 0xA8u8, 0x33u8, 0x9Cu8
]

# ============================================================================
# Cipher Suites and Groups
# ============================================================================

val CIPHER_AES_128_GCM_SHA256: u16       = 0x1301
val CIPHER_AES_256_GCM_SHA384: u16       = 0x1302
val CIPHER_CHACHA20_POLY1305_SHA256: u16 = 0x1303
val GROUP_X25519: u16              = 0x001D
val GROUP_SECP256R1: u16           = 0x0017
val SIG_ED25519: u16               = 0x0807
# Decode-recognised TLS 1.3 SignatureScheme codes (RFC 8446 §4.2.3) for
# which we do NOT yet have a verify primitive in tree. These are NOT
# advertised by `_build_ext_sig_algs` — advertising would let the peer
# pick a scheme we cannot verify, breaking the handshake. Named here so
# parser/log sites can refer to them by symbol; dispatch in
# `cert_verify.spl` returns a typed Err for both. See FR
# `doc/08_tracking/feature_request/ecdsa_p384_p521_runtime_primitives_2026-05-02.md`.
val SIG_ECDSA_SECP384R1_SHA384: u16 = 0x0503
val SIG_ECDSA_SECP521R1_SHA512: u16 = 0x0603

# ============================================================================
# Data Classes
# ============================================================================

class ServerHello13:
    """Decoded ServerHello message fields needed by the TLS 1.3 state machine."""
    random: [u8]       # 32 bytes
    cipher_suite: u16
    x25519_pub: [u8]   # 32 bytes from key_share extension (empty if absent)
    p256_pub: [u8]     # 65 bytes uncompressed `04 || X || Y` from key_share (empty if absent)

class ParsedHandshake:
    """Raw parsed handshake envelope: type byte + body bytes."""
    msg_type: u8
    body: [u8]

class CertVerifyFields:
    """Fields from a CertificateVerify message (Simple lacks tuple returns)."""
    algorithm: u16
    signature: [u8]

class CertificateRequest13:
    """Decoded TLS 1.3 CertificateRequest subset used by the client."""
    request_context: [u8]
    sig_algs: [u16]

class EncryptedExtensions13:
    """Decoded TLS 1.3 EncryptedExtensions message (RFC 8446 §4.3.1).

    Fields are populated only when the corresponding extension is present:
      - server_name_acknowledged: true if EXT_SNI(0) was seen with empty data
        (RFC 6066 server's SNI ack MUST be empty).
      - max_fragment_length: 0 if absent; otherwise the single byte the server
        echoed (RFC 6066 §4 enum 1..4 mapping to 2^9 .. 2^12).
      - selected_alpn: empty text if absent; otherwise the single ProtocolName
        the server selected from the client's offered list (RFC 7301 §3.1).
      - supported_groups: informational per RFC 8446 §4.2.7.
    """
    server_name_acknowledged: bool
    max_fragment_length: u8
    selected_alpn: text
    supported_groups: [u16]

enum EncryptedExtensionsResult:
    Ok(value: EncryptedExtensions13)
    Err(reason: text)

class HelloRetryRequest13:
    """Decoded TLS 1.3 HelloRetryRequest (RFC 8446 §4.1.4).

    HRR re-uses ServerHello wire format but signals retry by setting `random`
    to the canonical HRR_MAGIC constant. The body the client cares about:
      - cipher_suite: server's chosen suite (must match in CH2).
      - selected_group: NamedGroup the server picked from the key_share extension;
        the client MUST send a fresh key_share for this group in CH2.
      - cookie: opaque server-supplied cookie that must be echoed verbatim in CH2,
        empty if absent.
    """
    cipher_suite: u16
    selected_group: u16
    cookie: [u8]

enum HrrResult:
    Ok(value: HelloRetryRequest13)
    Err(reason: text)

# ============================================================================
# Private Byte Helpers
# ============================================================================

fn _u16_be(data: [u8], offset: u64) -> u16:
    """Read a big-endian u16 from data at offset."""
    ((_u8_at(data, offset).to_u16() << 8) | _u8_at(data, offset + 1).to_u16()).to_u16()

fn _u24_be(data: [u8], offset: u64) -> u64:
    """Read a big-endian 24-bit value from data at offset."""
    (_u8_at(data, offset).to_u64() << 16) |
        (_u8_at(data, offset + 1).to_u64() << 8) |
        _u8_at(data, offset + 2).to_u64()

fn _put_u16_be(val: u16) -> [u8]:
    """Encode a u16 as 2 big-endian bytes."""
    var out: [u8] = _byte_buf(2)
    out = _push_byte(out, ((val.to_u32() >> 8) & 0xFF).to_i64())
    out = _push_byte(out, (val.to_u32() & 0xFF).to_i64())
    out

fn _put_u24_be(val: u64) -> [u8]:
    """Encode a u64 value (low 24 bits) as 3 big-endian bytes."""
    var out: [u8] = _byte_buf(3)
    out = _push_byte(out, ((val >> 16) & 0xFF).to_i64())
    out = _push_byte(out, ((val >> 8) & 0xFF).to_i64())
    out = _push_byte(out, (val & 0xFF).to_i64())
    out

fn _text_to_bytes(s: text) -> [u8]:
    """Convert a text string to a UTF-8 byte array."""
    var result: [u8] = []
    val chars = s.split("")
    for ch in chars:
        if ch != "":
            var idx: i64 = 0
            var found = false
            while idx < TLS13_ASCII_PRINTABLE.len() and not found:
                if TLS13_ASCII_PRINTABLE[idx:idx + 1] == ch:
                    result.push((idx + 32).to_u8())
                    found = true
                idx = idx + 1
    result

fn _serverhello_x25519_pub(data: [u8]) -> [u8]:
    if data.len() < 40:
        return []
    val session_id_len = _u8_at(data, 34).to_u64()
    var offset = 35u64 + session_id_len + 2u64 + 1u64
    if offset + 2 > data.len():
        return []
    val extensions_len = _u16_be(data, offset).to_u64()
    offset = offset + 2
    val extensions_end = offset + extensions_len

    while offset + 4 <= extensions_end and offset + 4 <= data.len():
        val ext_type = _u16_be(data, offset)
        offset = offset + 2
        val ext_len = _u16_be(data, offset).to_u64()
        offset = offset + 2
        if offset + ext_len > data.len():
            return []
        if ext_type == EXT_KEY_SHARE and ext_len >= 4:
            val group = _u16_be(data, offset)
            val key_len = _u16_be(data, offset + 2).to_u64()
            val key_start = offset + 4
            if group == GROUP_X25519 and key_len == 32 and key_start + key_len <= data.len():
                var out: [u8] = _byte_buf(key_len)
                var i: u64 = 0
                while i < key_len:
                    out = _push_byte(out, _u8_at(data, key_start + i).to_u64().to_i64())
                    i = i + 1
                return out
        offset = offset + ext_len
    []

fn _serverhello_p256_pub(data: [u8]) -> [u8]:
    """Extract the server's secp256r1 (P-256) public from a ServerHello body's
    key_share extension. Returns 65 bytes `04 || X || Y` per RFC 8446 §4.2.8.2
    + RFC 8422 §5.4, or `[]` if no P-256 KeyShareEntry is present.

    Mirrors `_serverhello_x25519_pub` but matches `group == GROUP_SECP256R1`
    and `key_len == 65`. Used by the HRR-after-CH2 connect-flow path that
    closes W5-A AC-7 (P-256 ECDHE → handshake_secret integration).
    """
    if data.len() < 40:
        return []
    val session_id_len = _u8_at(data, 34).to_u64()
    var offset = 35u64 + session_id_len + 2u64 + 1u64
    if offset + 2 > data.len():
        return []
    val extensions_len = _u16_be(data, offset).to_u64()
    offset = offset + 2
    val extensions_end = offset + extensions_len

    while offset + 4 <= extensions_end and offset + 4 <= data.len():
        val ext_type = _u16_be(data, offset)
        offset = offset + 2
        val ext_len = _u16_be(data, offset).to_u64()
        offset = offset + 2
        if offset + ext_len > data.len():
            return []
        if ext_type == EXT_KEY_SHARE and ext_len >= 4:
            val group = _u16_be(data, offset)
            val key_len = _u16_be(data, offset + 2).to_u64()
            val key_start = offset + 4
            if group == GROUP_SECP256R1 and key_len == 65 and key_start + key_len <= data.len():
                var out: [u8] = _byte_buf(key_len)
                var i: u64 = 0
                while i < key_len:
                    out = _push_byte(out, _u8_at(data, key_start + i).to_u64().to_i64())
                    i = i + 1
                return out
        offset = offset + ext_len
    []

fn _append_into(out: [u8], src: [u8]):
    """Append src bytes into out in place."""
    _tls_hs_debug("_append_into out={out.len()} src={src.len()}")
    var i: u64 = 0
    while i < src.len():
        out = _push_byte(out, _u8_at(src, i).to_u64().to_i64())
        i = i + 1

fn _append_bytes(a: [u8], b: [u8]) -> [u8]:
    """Concatenate two byte arrays."""
    var out: [u8] = _byte_buf(a.len() + b.len())
    _append_into(out, a)
    _append_into(out, b)
    out

# ============================================================================
# Extension Builders (private)
# ============================================================================

fn _build_ext_supported_versions() -> [u8]:
    """Build supported_versions extension: only TLS 1.3 (0x0304)."""
    # Extension type: 43 (0x002B)
    val ext_type = _put_u16_be(EXT_SUPPORTED_VERSIONS)
    # versions list: 1 version = 2 bytes, prefixed with 1-byte count
    var versions: [u8] = _byte_buf(3)
    versions = _push_byte(versions, 0x02)  # 2 bytes follow
    versions = _push_byte(versions, 0x03)  # TLS 1.3 major
    versions = _push_byte(versions, 0x04)  # TLS 1.3 minor
    # extension data length = 3 bytes
    val ext_len = _put_u16_be(versions.len().to_u16())
    var out: [u8] = _byte_buf(7)
    _append_into(out, ext_type)
    _append_into(out, ext_len)
    _append_into(out, versions)
    out

fn _build_key_share_entry(group: u16, key: [u8]) -> [u8]:
    """Build a single KeyShareEntry: group(2) + key_exchange<0..2^16-1>."""
    val group_bytes = _put_u16_be(group)
    val key_len_bytes = _put_u16_be(key.len().to_u16())
    var entry: [u8] = _byte_buf(key.len() + 4)
    _append_into(entry, group_bytes)
    _append_into(entry, key_len_bytes)
    _append_into(entry, key)
    entry

fn _build_ext_key_share(x25519_pub: [u8]) -> [u8]:
    """Build key_share extension with a single X25519 entry.

    Kept for back-compat with callers that haven't been updated to advertise
    multiple groups. New code should call `_build_ext_key_share_dual`.
    """
    val entry = _build_key_share_entry(GROUP_X25519, x25519_pub)
    # client_shares list length (2 bytes)
    val list_len = _put_u16_be(entry.len().to_u16())
    var client_shares: [u8] = _byte_buf(entry.len() + 2)
    _append_into(client_shares, list_len)
    _append_into(client_shares, entry)
    # extension type + length
    val ext_type = _put_u16_be(EXT_KEY_SHARE)
    val ext_len = _put_u16_be(client_shares.len().to_u16())
    var out: [u8] = _byte_buf(client_shares.len() + 4)
    _append_into(out, ext_type)
    _append_into(out, ext_len)
    _append_into(out, client_shares)
    out

fn _build_ext_key_share_dual(x25519_pub: [u8], p256_pub: [u8]) -> [u8]:
    """Build key_share extension with X25519 + secp256r1 entries.

    RFC 8446 §4.2.8 says the client may include shares for any subset of the
    groups it advertised in `supported_groups`; the server picks one. We keep
    X25519 first so it remains the preferred choice when the server has no
    explicit preference.

    `p256_pub` MUST be the 65-byte uncompressed SEC1 point (`04 || X || Y`)
    per RFC 8422 §5.4. An empty `p256_pub` reverts to the X25519-only form
    (used by callers that haven't yet wired in a P-256 ephemeral).
    """
    if p256_pub.len() == 0:
        return _build_ext_key_share(x25519_pub)
    val entry_x = _build_key_share_entry(GROUP_X25519, x25519_pub)
    val entry_p = _build_key_share_entry(GROUP_SECP256R1, p256_pub)
    var entries: [u8] = _byte_buf(entry_x.len() + entry_p.len())
    _append_into(entries, entry_x)
    _append_into(entries, entry_p)
    val list_len = _put_u16_be(entries.len().to_u16())
    var client_shares: [u8] = _byte_buf(entries.len() + 2)
    _append_into(client_shares, list_len)
    _append_into(client_shares, entries)
    val ext_type = _put_u16_be(EXT_KEY_SHARE)
    val ext_len = _put_u16_be(client_shares.len().to_u16())
    var out: [u8] = _byte_buf(client_shares.len() + 4)
    _append_into(out, ext_type)
    _append_into(out, ext_len)
    _append_into(out, client_shares)
    out

fn _build_ext_sni(host: text) -> [u8]:
    """Build server_name extension for the given hostname."""
    val host_bytes = _text_to_bytes(host)
    val host_len = _put_u16_be(host_bytes.len().to_u16())
    # server_name entry: type(1=host_name) + length(2) + name
    var sn_entry: [u8] = _byte_buf(host_bytes.len() + 3)
    sn_entry = _push_byte(sn_entry, 0x00)  # name_type = host_name
    _append_into(sn_entry, host_len)
    _append_into(sn_entry, host_bytes)
    # server_name_list length
    val list_len = _put_u16_be(sn_entry.len().to_u16())
    var sn_list: [u8] = _byte_buf(sn_entry.len() + 2)
    _append_into(sn_list, list_len)
    _append_into(sn_list, sn_entry)
    # extension type + length
    val ext_type = _put_u16_be(EXT_SNI)
    val ext_len = _put_u16_be(sn_list.len().to_u16())
    var out: [u8] = _byte_buf(sn_list.len() + 4)
    _append_into(out, ext_type)
    _append_into(out, ext_len)
    _append_into(out, sn_list)
    out

fn _build_ext_sig_algs() -> [u8]:
    """Build signature_algorithms extension: Ed25519 only."""
    # algorithms list: 1 algorithm = 2 bytes, prefixed with 2-byte list length
    val alg_bytes = _put_u16_be(SIG_ED25519)
    val list_len = _put_u16_be(alg_bytes.len().to_u16())
    var alg_list: [u8] = _byte_buf(4)
    _append_into(alg_list, list_len)
    _append_into(alg_list, alg_bytes)
    val ext_type = _put_u16_be(EXT_SIG_ALGS)
    val ext_len = _put_u16_be(alg_list.len().to_u16())
    var out: [u8] = _byte_buf(8)
    _append_into(out, ext_type)
    _append_into(out, ext_len)
    _append_into(out, alg_list)
    out

fn _build_ext_supported_groups() -> [u8]:
    """Build supported_groups extension: X25519 + secp256r1.

    Order matters per RFC 8446 §4.2.7: most-preferred first. X25519 stays
    preferred; secp256r1 is the fallback when the server lacks X25519.
    """
    val x25519_be = _put_u16_be(GROUP_X25519)
    val p256_be = _put_u16_be(GROUP_SECP256R1)
    var groups: [u8] = _byte_buf(4)
    _append_into(groups, x25519_be)
    _append_into(groups, p256_be)
    val list_len = _put_u16_be(groups.len().to_u16())
    var group_list: [u8] = _byte_buf(groups.len() + 2)
    _append_into(group_list, list_len)
    _append_into(group_list, groups)
    val ext_type = _put_u16_be(EXT_SUPPORTED_GROUPS)
    val ext_len = _put_u16_be(group_list.len().to_u16())
    var out: [u8] = _byte_buf(group_list.len() + 4)
    _append_into(out, ext_type)
    _append_into(out, ext_len)
    _append_into(out, group_list)
    out

# ============================================================================
# Public: Build ClientHello
# ============================================================================

fn build_client_hello_bytes(random: [u8], x25519_pub: [u8], sni_host: text) -> [u8]:
    """Encode a minimal TLS 1.3 ClientHello message (X25519 only).

    Back-compat shim that keeps callers from before the secp256r1 landing
    working unchanged. New callers that have a P-256 ephemeral should use
    `build_client_hello_bytes_with_p256` to advertise both key_shares.
    """
    build_client_hello_bytes_with_p256(random, x25519_pub, [], sni_host)

fn build_client_hello_bytes_with_p256(random: [u8], x25519_pub: [u8], p256_pub: [u8], sni_host: text) -> [u8]:
    """Encode a minimal TLS 1.3 ClientHello message (X25519 + secp256r1).

    Wire format (RFC 8446 §4.1.2):
      HandshakeType(1) + length(3) + legacy_version(2) + random(32) +
      legacy_session_id_len(1) + legacy_session_id(32 zeros) +
      cipher_suites_len(2) + cipher_suites(6) +
      compression_methods_len(1) + compression_methods(1) +
      extensions_len(2) + extensions(...)

    Args:
        random: 32 bytes of client random.
        x25519_pub: 32 bytes X25519 public key.
        p256_pub: 65 bytes uncompressed SEC1 P-256 point `04 || X || Y`,
                  or empty to advertise X25519 only.
        sni_host: Server name for SNI extension.

    Returns: Complete handshake-layer bytes (type + 3-byte length + body).
    """
    _tls_hs_debug("build_client_hello_bytes random={random.len()} key={x25519_pub.len()} p256={p256_pub.len()} host={sni_host} host_len={sni_host.len()}")
    # Legacy version: TLS 1.2 for compatibility
    var body: [u8] = _byte_buf(192)
    body = _push_byte(body, 0x03)  # legacy_version high
    body = _push_byte(body, 0x03)  # legacy_version low

    # random (32 bytes)
    _append_into(body, random)

    # legacy_session_id: 32 zero bytes (length-prefixed)
    body = _push_byte(body, 0x20)  # session_id length = 32
    var i: u64 = 0
    while i < 32:
        body = _push_byte(body, 0x00)
        i = i + 1

    # cipher_suites: TLS_AES_128_GCM_SHA256 (0x1301) + TLS_AES_256_GCM_SHA384 (0x1302)
    # + TLS_CHACHA20_POLY1305_SHA256 (0x1303)
    # RFC 8446 §9.1 — 0x1301 MUST; 0x1302 SHOULD; 0x1303 SHOULD.
    body = _push_byte(body, 0x00)  # cipher_suites length high = 0
    body = _push_byte(body, 0x06)  # cipher_suites length low  = 6 (3 suites x 2 bytes)
    body = _push_byte(body, 0x13)  # TLS_AES_128_GCM_SHA256 high
    body = _push_byte(body, 0x01)  # TLS_AES_128_GCM_SHA256 low
    body = _push_byte(body, 0x13)  # TLS_AES_256_GCM_SHA384 high
    body = _push_byte(body, 0x02)  # TLS_AES_256_GCM_SHA384 low
    body = _push_byte(body, 0x13)  # TLS_CHACHA20_POLY1305_SHA256 high
    body = _push_byte(body, 0x03)  # TLS_CHACHA20_POLY1305_SHA256 low

    # legacy compression methods: one method = null (0x00)
    body = _push_byte(body, 0x01)  # length = 1
    body = _push_byte(body, 0x00)  # null compression

    # Build extensions
    var exts: [u8] = _byte_buf(160)
    val ext_sv = _build_ext_supported_versions()
    _tls_hs_debug("ext_sv={ext_sv.len()}")
    val ext_ks = _build_ext_key_share_dual(x25519_pub, p256_pub)
    _tls_hs_debug("ext_ks={ext_ks.len()}")
    val ext_sni = _build_ext_sni(sni_host)
    _tls_hs_debug("ext_sni={ext_sni.len()}")
    val ext_sa = _build_ext_sig_algs()
    _tls_hs_debug("ext_sa={ext_sa.len()}")
    val ext_sg = _build_ext_supported_groups()
    _tls_hs_debug("ext_sg={ext_sg.len()}")
    _append_into(exts, ext_sv)
    _append_into(exts, ext_ks)
    _append_into(exts, ext_sni)
    _append_into(exts, ext_sa)
    _append_into(exts, ext_sg)

    # extensions length prefix (2 bytes)
    val exts_len_bytes = _put_u16_be(exts.len().to_u16())
    _append_into(body, exts_len_bytes)
    _append_into(body, exts)

    # Handshake header: type(1) + length(3)
    val body_len = _put_u24_be(body.len().to_u64())
    var out: [u8] = _byte_buf(body.len() + 4)
    out = _push_byte(out, HS_CLIENT_HELLO)
    _append_into(out, body_len)
    _append_into(out, body)
    out

# ============================================================================
# Public: Parse Handshake Header
# ============================================================================

fn parse_handshake_header(data: [u8]) -> ParsedHandshake:
    """Parse the 4-byte handshake envelope (type + 3-byte length) and return body.

    Args:
        data: Raw bytes starting at the handshake message.

    Returns: ParsedHandshake with msg_type and body slice.
    """
    if data.len() < 4:
        return ParsedHandshake(msg_type: 0u8, body: [])
    val msg_type = _u8_at(data, 0)
    val raw_body_len = _u24_be(data, 1)
    val available_body_len = data.len() - 4
    val body_len = if raw_body_len < available_body_len { raw_body_len } else { available_body_len }
    var body: [u8] = _byte_buf(body_len)
    var i: u64 = 0
    while i < body_len:
        body = _push_byte(body, _u8_at(data, 4 + i).to_u64().to_i64())
        i = i + 1
    ParsedHandshake(msg_type: msg_type, body: body)

# ============================================================================
# Public: Parse ServerHello
# ============================================================================

fn parse_server_hello(data: [u8]) -> ServerHello13:
    """Parse a ServerHello body (after the handshake header).

    Reads: legacy_version(2), random(32), session_id(var), cipher_suite(2),
    compression(1), extensions — locates key_share for X25519 public key.

    Args:
        data: ServerHello body bytes (not including the 4-byte handshake header).

    Returns: ServerHello13 with random, cipher_suite, and x25519_pub.
    """
    _tls_hs_debug("parse_server_hello len={data.len()}")
    if data.len() < 38:
        return ServerHello13(random: _byte_buf(0), cipher_suite: 0u16, x25519_pub: _byte_buf(0), p256_pub: _byte_buf(0))

    var random: [u8] = _byte_buf(32)
    var i: u64 = 0
    while i < 32:
        _push_byte(random, _u8_at(data, 2 + i).to_u64().to_i64())
        i = i + 1

    val session_id_len = _u8_at(data, 34).to_u64()
    _tls_hs_debug("serverhello session_id_len={session_id_len} offset=34")
    ServerHello13(
        random: random,
        cipher_suite: _u16_be(data, 35u64 + session_id_len),
        x25519_pub: _serverhello_x25519_pub(data),
        p256_pub: _serverhello_p256_pub(data))

# ============================================================================
# Public: Parse EncryptedExtensions (RFC 8446 §4.3.1)
# ============================================================================
# Returns EncryptedExtensionsResult.{Ok(EncryptedExtensions13)|Err(text)}.
# Wiring into tls13_connect_io_with_config (per-connection ALPN/MFL state)
# is a follow-up; this parser is callable by handshake-state code today.

fn _ee_seen_contains(seen: [u16], t: u16) -> bool:
    var i: u64 = 0
    while i < seen.len():
        if seen[i] == t:
            return true
        i = i + 1
    false

fn _ee_parse_alpn(ext_data: [u8]) -> EncryptedExtensionsResult:
    """Parse RFC 7301 ProtocolNameList { ProtocolName protocol_name_list<2..2^16-1>; }.

    Server MUST select exactly one ProtocolName (RFC 7301 §3.2).
    """
    if ext_data.len() < 3:
        return EncryptedExtensionsResult.Err(reason: "decode_error: alpn truncated")
    val list_len = _u16_be(ext_data, 0).to_u64()
    if list_len + 2 != ext_data.len():
        return EncryptedExtensionsResult.Err(reason: "decode_error: alpn list length mismatch")
    if list_len < 2:
        return EncryptedExtensionsResult.Err(reason: "illegal_parameter: alpn list too short")
    val name_len = _u8_at(ext_data, 2).to_u64()
    if name_len < 1:
        return EncryptedExtensionsResult.Err(reason: "illegal_parameter: alpn empty ProtocolName")
    if 1 + name_len != list_len:
        # More than one ProtocolName, or trailing garbage — server MUST select exactly one.
        return EncryptedExtensionsResult.Err(reason: "illegal_parameter: alpn must contain exactly one ProtocolName")
    if 3 + name_len > ext_data.len():
        return EncryptedExtensionsResult.Err(reason: "decode_error: alpn name truncated")
    var name_bytes: [u8] = _byte_buf(name_len)
    var i: u64 = 0
    while i < name_len:
        name_bytes = _push_byte(name_bytes, _u8_at(ext_data, 3 + i).to_u64().to_i64())
        i = i + 1
    EncryptedExtensionsResult.Ok(value: EncryptedExtensions13(
        server_name_acknowledged: false,
        max_fragment_length: 0u8,
        selected_alpn: rt_bytes_to_text(name_bytes),
        supported_groups: []))

fn parse_encrypted_extensions(body: [u8]) -> EncryptedExtensionsResult:
    """Parse a TLS 1.3 EncryptedExtensions message body (RFC 8446 §4.3.1).

    Wire format:
        struct { Extension extensions<0..2^16-1>; } EncryptedExtensions;
        struct { ExtensionType type; opaque data<0..2^16-1>; } Extension;

    Recognized extensions:
      - server_name (0): RFC 6066 — server's SNI ack MUST be empty.
      - max_fragment_length (1): RFC 6066 — extension_data is exactly 1 byte.
      - supported_groups (10): RFC 8446 §4.2.7 — informational; recorded.
      - application_layer_protocol_negotiation (16): RFC 7301 — single name.
      - early_data (42): RFC 8446 §4.2.10 — empty in EE = server accepts 0-RTT.
        We do not implement 0-RTT yet, so reject as unsupported_extension.

    Unknown extensions are ignored per RFC 8446 §4.2 ("Unknown extensions
    MUST be ignored by the receiver").  Duplicate extension_type entries are
    rejected with illegal_parameter per RFC 8446 §4.2.

    Args:
        body: EncryptedExtensions body bytes (after the 4-byte handshake header).

    Returns:
        EncryptedExtensionsResult.Ok(EncryptedExtensions13) on success.
        EncryptedExtensionsResult.Err(text) on malformed/illegal input.
    """
    if body.len() < 2:
        return EncryptedExtensionsResult.Err(reason: "decode_error: EE body too short for extensions length")
    val outer_len = _u16_be(body, 0).to_u64()
    # The outer length MUST equal body.len() - 2 exactly per RFC 8446 §4.3.1.
    if outer_len + 2 != body.len():
        return EncryptedExtensionsResult.Err(reason: "decode_error: EE outer length does not span body")

    var server_name_ack: bool = false
    var mfl: u8 = 0u8
    var alpn: text = ""
    var groups: [u16] = []
    var seen: [u16] = []

    var offset: u64 = 2
    val end: u64 = body.len()

    while offset < end:
        if offset + 4 > end:
            return EncryptedExtensionsResult.Err(reason: "decode_error: EE extension header truncated")
        val ext_type = _u16_be(body, offset)
        val ext_len = _u16_be(body, offset + 2).to_u64()
        val data_start = offset + 4
        if data_start + ext_len > end:
            return EncryptedExtensionsResult.Err(reason: "decode_error: EE extension data truncated")

        if _ee_seen_contains(seen, ext_type):
            return EncryptedExtensionsResult.Err(reason: "illegal_parameter: duplicate extension")
        seen.push(ext_type)

        # Slice extension_data
        var ext_data: [u8] = _byte_buf(ext_len)
        var k: u64 = 0
        while k < ext_len:
            ext_data = _push_byte(ext_data, _u8_at(body, data_start + k).to_u64().to_i64())
            k = k + 1

        if ext_type == EXT_SNI:
            # RFC 6066: server's SNI ack MUST be empty.
            if ext_data.len() != 0:
                return EncryptedExtensionsResult.Err(reason: "illegal_parameter: server_name in EE must be empty")
            server_name_ack = true
        elif ext_type == EXT_MAX_FRAGMENT_LENGTH:
            # RFC 6066 §4: extension_data is exactly one MaxFragmentLength enum byte.
            if ext_data.len() != 1:
                return EncryptedExtensionsResult.Err(reason: "illegal_parameter: max_fragment_length must be 1 byte")
            mfl = _u8_at(ext_data, 0)
        elif ext_type == EXT_SUPPORTED_GROUPS:
            # RFC 8446 §4.2.7: NamedGroupList named_group_list<2..2^16-1>.
            if ext_data.len() < 4:
                return EncryptedExtensionsResult.Err(reason: "decode_error: supported_groups truncated")
            val sg_list_len = _u16_be(ext_data, 0).to_u64()
            if sg_list_len + 2 != ext_data.len() or (sg_list_len % 2) != 0:
                return EncryptedExtensionsResult.Err(reason: "decode_error: supported_groups list length")
            var gi: u64 = 0
            while gi < sg_list_len:
                groups.push(_u16_be(ext_data, 2 + gi))
                gi = gi + 2
        elif ext_type == EXT_ALPN:
            val alpn_res = _ee_parse_alpn(ext_data)
            if val EncryptedExtensionsResult.Err(reason) = alpn_res:
                return EncryptedExtensionsResult.Err(reason: reason)
            if val EncryptedExtensionsResult.Ok(value) = alpn_res:
                alpn = value.selected_alpn
        elif ext_type == EXT_EARLY_DATA:
            # RFC 8446 §4.2.10: empty in EE means server accepts 0-RTT.
            # We do not implement 0-RTT; reject unconditionally so callers
            # don't silently believe early data was negotiated.
            return EncryptedExtensionsResult.Err(reason: "unsupported_extension: early_data not implemented")
        else:
            # RFC 8446 §4.2: unknown extensions MUST be ignored.
            pass_dn

        offset = data_start + ext_len

    EncryptedExtensionsResult.Ok(value: EncryptedExtensions13(
        server_name_acknowledged: server_name_ack,
        max_fragment_length: mfl,
        selected_alpn: alpn,
        supported_groups: groups))

# ============================================================================
# Public: HelloRetryRequest detection + parse (RFC 8446 §4.1.4)
# ============================================================================
#
# HelloRetryRequest is wire-format-identical to ServerHello, but the `random`
# field equals SHA-256("HelloRetryRequest") = HRR_MAGIC. Client behaviour
# (§4.1.4):
#   - Validate supported_versions == 0x0304 (TLS 1.3).
#   - Honour the server's chosen group via the key_share extension.
#   - Echo the cookie extension verbatim if present.
#   - MUST abort if it has already received an HRR in this handshake.
#   - MUST abort if the chosen group equals one we already sent in CH1.
#   - MUST abort if legacy_compression_method != 0x00.
# Transcript hash gets a synthetic message_hash replacement per §4.4.1 — see
# build_hrr_synthetic_message_hash() below.

fn is_hello_retry_request(sh: ServerHello13) -> bool:
    """Return true if the parsed ServerHello is actually a HelloRetryRequest.

    A HRR is signalled by the ServerHello.random field equalling the canonical
    SHA-256("HelloRetryRequest") constant (HRR_MAGIC). 32-byte memcmp.
    """
    if sh.random.len() != 32:
        return false
    var i: u64 = 0
    while i < 32:
        if _u8_at(sh.random, i) != _u8_at(HRR_MAGIC, i):
            return false
        i = i + 1
    true

fn _hrr_find_selected_group(extensions: [u8]) -> u16:
    """Locate the key_share extension and return its `selected_group` u16.

    In HRR, the key_share extension carries only `selected_group` (2 bytes),
    NOT a full KeyShareEntry — RFC 8446 §4.2.8. Returns 0 if absent.
    """
    var offset: u64 = 0
    val end = extensions.len().to_u64()
    while offset + 4 <= end:
        val ext_type = _u16_be(extensions, offset)
        val ext_len = _u16_be(extensions, offset + 2).to_u64()
        val data_start = offset + 4
        if data_start + ext_len > end:
            return 0u16
        if ext_type == EXT_KEY_SHARE and ext_len == 2:
            return _u16_be(extensions, data_start)
        offset = data_start + ext_len
    0u16

fn _hrr_extract_cookie(extensions: [u8]) -> [u8]:
    """Return the cookie extension's opaque cookie field, or empty if absent.

    Cookie wire format (RFC 8446 §4.2.2):
      struct { opaque cookie<1..2^16-1>; } Cookie;
    so extension_data is u16 length prefix + cookie bytes.
    """
    var offset: u64 = 0
    val end = extensions.len().to_u64()
    while offset + 4 <= end:
        val ext_type = _u16_be(extensions, offset)
        val ext_len = _u16_be(extensions, offset + 2).to_u64()
        val data_start = offset + 4
        if data_start + ext_len > end:
            return []
        if ext_type == EXT_COOKIE and ext_len >= 2:
            val cookie_len = _u16_be(extensions, data_start).to_u64()
            if cookie_len + 2 != ext_len:
                return []
            var out: [u8] = _byte_buf(cookie_len)
            var i: u64 = 0
            while i < cookie_len:
                out = _push_byte(out, _u8_at(extensions, data_start + 2 + i).to_u64().to_i64())
                i = i + 1
            return out
        offset = data_start + ext_len
    []

fn _hrr_supported_versions_is_tls13(extensions: [u8]) -> bool:
    """Check that supported_versions extension is present and equals 0x0304.

    In HRR/ServerHello, supported_versions extension_data is exactly the 2-byte
    selected_version (RFC 8446 §4.2.1).
    """
    var offset: u64 = 0
    val end = extensions.len().to_u64()
    while offset + 4 <= end:
        val ext_type = _u16_be(extensions, offset)
        val ext_len = _u16_be(extensions, offset + 2).to_u64()
        val data_start = offset + 4
        if data_start + ext_len > end:
            return false
        if ext_type == EXT_SUPPORTED_VERSIONS:
            if ext_len != 2:
                return false
            return _u16_be(extensions, data_start) == 0x0304u16
        offset = data_start + ext_len
    false

fn parse_hello_retry_request(body: [u8]) -> HrrResult:
    """Parse a HelloRetryRequest body (after the 4-byte handshake header).

    Wire format mirrors ServerHello:
      legacy_version(2) + random(32) + session_id_len(1) + session_id(...) +
      cipher_suite(2) + legacy_compression_method(1) +
      extensions_len(2) + extensions(...)

    Validates per RFC 8446 §4.1.4:
      - random == HRR_MAGIC.
      - legacy_compression_method == 0x00.
      - supported_versions extension present and == 0x0304.
      - key_share extension present (yields selected_group).

    Returns HrrResult.Ok(HelloRetryRequest13) or HrrResult.Err(reason).
    """
    if body.len() < 38:
        return HrrResult.Err(reason: "decode_error: HRR truncated")

    # Confirm the magic random — defensive check, callers normally already
    # gated via is_hello_retry_request().
    var i: u64 = 0
    while i < 32:
        if _u8_at(body, 2 + i) != _u8_at(HRR_MAGIC, i):
            return HrrResult.Err(reason: "illegal_parameter: HRR random mismatch")
        i = i + 1

    val session_id_len = _u8_at(body, 34).to_u64()
    if 35u64 + session_id_len + 3u64 > body.len().to_u64():
        return HrrResult.Err(reason: "decode_error: HRR truncated session_id")

    val cipher_suite = _u16_be(body, 35u64 + session_id_len)
    val compression = _u8_at(body, 35u64 + session_id_len + 2u64)
    if compression != 0x00u8:
        return HrrResult.Err(reason: "illegal_parameter: HRR compression must be 0x00")

    var ext_offset = 35u64 + session_id_len + 3u64
    if ext_offset + 2 > body.len().to_u64():
        return HrrResult.Err(reason: "decode_error: HRR missing extensions length")
    val extensions_len = _u16_be(body, ext_offset).to_u64()
    ext_offset = ext_offset + 2
    if ext_offset + extensions_len > body.len().to_u64():
        return HrrResult.Err(reason: "decode_error: HRR extensions truncated")

    # Slice extensions block out for sub-parsers.
    var extensions: [u8] = _byte_buf(extensions_len)
    var k: u64 = 0
    while k < extensions_len:
        extensions = _push_byte(extensions, _u8_at(body, ext_offset + k).to_u64().to_i64())
        k = k + 1

    if not _hrr_supported_versions_is_tls13(extensions):
        return HrrResult.Err(reason: "illegal_parameter: HRR supported_versions must be TLS 1.3")

    val selected_group = _hrr_find_selected_group(extensions)
    if selected_group == 0u16:
        return HrrResult.Err(reason: "missing_extension: HRR key_share absent")

    val cookie = _hrr_extract_cookie(extensions)

    HrrResult.Ok(value: HelloRetryRequest13(
        cipher_suite: cipher_suite,
        selected_group: selected_group,
        cookie: cookie))

# ============================================================================
# Public: Synthetic message_hash for HRR transcript replacement (RFC 8446 §4.4.1)
# ============================================================================
#
# When HRR is received, the running transcript hash MUST be replaced by:
#
#     Hash(message_hash || 0x00 0x00 Hash.length || Hash(ClientHello1)) ||
#     HelloRetryRequest || ... || Mn
#
# The synthetic prefix injected into the transcript is the bytes:
#
#     handshake_type=message_hash(254) || length(3 bytes BE) || Hash(CH1)
#
# For SHA-256, length = 32 = 0x000020 → final prefix is 36 bytes:
#     0xfe 0x00 0x00 0x20 || Hash(CH1)
#
# Callers replace the existing CH1 transcript with this synthetic message_hash
# and then continue appending HRR + CH2 + ... normally.

val HS_MESSAGE_HASH: u8 = 254  # 0xfe — RFC 8446 §4.4.1

fn build_hrr_synthetic_message_hash(ch1_hash: [u8]) -> [u8]:
    """Build the synthetic message_hash bytes for HRR transcript replacement.

    Layout (RFC 8446 §4.4.1):
      type(1=0xfe) + length(3, big-endian) + Hash(ClientHello1)

    For SHA-256 the result is exactly 36 bytes (4-byte handshake header +
    32-byte hash). For other hashes the length is hash-size dependent.

    Args:
        ch1_hash: Hash(ClientHello1), must equal the negotiated hash output
            length (32 bytes for SHA-256).

    Returns: Synthetic message_hash bytes ready to feed back into a fresh
        Transcript via transcript_add().
    """
    val hash_len = ch1_hash.len().to_u64()
    var out: [u8] = _byte_buf(hash_len + 4)
    out = _push_byte(out, HS_MESSAGE_HASH.to_i64())
    # 3-byte big-endian length
    out = _push_byte(out, ((hash_len >> 16) & 0xFF).to_i64())
    out = _push_byte(out, ((hash_len >> 8) & 0xFF).to_i64())
    out = _push_byte(out, (hash_len & 0xFF).to_i64())
    var i: u64 = 0
    while i < hash_len:
        out = _push_byte(out, _u8_at(ch1_hash, i).to_u64().to_i64())
        i = i + 1
    out

# ============================================================================
# Public: Build ClientHello2 (RFC 8446 §4.1.2 after HRR)
# ============================================================================
#
# CH2 differs from CH1 in:
#   - Same client_random (carried by the client across the retry).
#   - key_share contains a fresh ephemeral keypair for the group HRR picked.
#   - Echo HRR's cookie extension verbatim if present.
#   - Drop pre_shared_key if it was incompatible (caller's responsibility;
#     this module never emits PSK extensions yet).

fn _build_ext_cookie(cookie: [u8]) -> [u8]:
    """Build the cookie extension echoing HRR's cookie verbatim.

    Wire (RFC 8446 §4.2.2): opaque cookie<1..2^16-1>; — i.e. u16 length + bytes.
    Returns an empty array if cookie is empty (caller should skip emission).
    """
    if cookie.len() == 0:
        return []
    val ext_type = _put_u16_be(EXT_COOKIE)
    val cookie_len = _put_u16_be(cookie.len().to_u16())
    # extension_data = u16 length + cookie
    var ext_data: [u8] = _byte_buf(cookie.len() + 2)
    _append_into(ext_data, cookie_len)
    _append_into(ext_data, cookie)
    val ext_len = _put_u16_be(ext_data.len().to_u16())
    var out: [u8] = _byte_buf(ext_data.len() + 4)
    _append_into(out, ext_type)
    _append_into(out, ext_len)
    _append_into(out, ext_data)
    out

fn build_client_hello2_bytes(random: [u8], x25519_pub: [u8], sni_host: text, cookie: [u8]) -> [u8]:
    """Build a TLS 1.3 ClientHello2 retrying after a HelloRetryRequest (X25519 only).

    Back-compat shim — see `build_client_hello2_bytes_with_p256`.
    """
    build_client_hello2_bytes_with_p256(random, x25519_pub, [], sni_host, cookie)

fn build_client_hello2_bytes_with_p256(random: [u8], x25519_pub: [u8], p256_pub: [u8], sni_host: text, cookie: [u8]) -> [u8]:
    """Build a TLS 1.3 ClientHello2 (X25519 + secp256r1) retrying after HRR.

    Mirrors build_client_hello_bytes_with_p256 but additionally emits the
    cookie extension if `cookie` is non-empty. The caller is responsible
    for:
      - Reusing the SAME `random` value sent in CH1 (RFC 8446 §4.1.2).
      - Generating FRESH ephemeral keypair(s) for the HRR-selected group.

    Args:
        random: 32 bytes of client random — MUST equal CH1's random.
        x25519_pub: 32 bytes X25519 public key for the new ephemeral.
        p256_pub: 65 bytes uncompressed SEC1 P-256 point or empty.
        sni_host: SNI hostname (echoed unchanged from CH1).
        cookie: HRR cookie to echo verbatim, or empty if HRR omitted it.

    Returns: Complete handshake-layer ClientHello2 bytes (type + 3-byte length + body).
    """
    var body: [u8] = _byte_buf(192)
    body = _push_byte(body, 0x03)
    body = _push_byte(body, 0x03)
    _append_into(body, random)

    body = _push_byte(body, 0x20)
    var i: u64 = 0
    while i < 32:
        body = _push_byte(body, 0x00)
        i = i + 1

    body = _push_byte(body, 0x00)
    body = _push_byte(body, 0x02)
    body = _push_byte(body, 0x13)
    body = _push_byte(body, 0x01)

    body = _push_byte(body, 0x01)
    body = _push_byte(body, 0x00)

    var exts: [u8] = _byte_buf(160)
    val ext_sv = _build_ext_supported_versions()
    val ext_ks = _build_ext_key_share_dual(x25519_pub, p256_pub)
    val ext_sni = _build_ext_sni(sni_host)
    val ext_sa = _build_ext_sig_algs()
    val ext_sg = _build_ext_supported_groups()
    _append_into(exts, ext_sv)
    _append_into(exts, ext_ks)
    _append_into(exts, ext_sni)
    _append_into(exts, ext_sa)
    _append_into(exts, ext_sg)
    if cookie.len() > 0:
        val ext_cookie = _build_ext_cookie(cookie)
        _append_into(exts, ext_cookie)

    val exts_len_bytes = _put_u16_be(exts.len().to_u16())
    _append_into(body, exts_len_bytes)
    _append_into(body, exts)

    val body_len = _put_u24_be(body.len().to_u64())
    var out: [u8] = _byte_buf(body.len() + 4)
    out = _push_byte(out, HS_CLIENT_HELLO)
    _append_into(out, body_len)
    _append_into(out, body)
    out

# ============================================================================
# Public: HRR connect-flow integration helper (RFC 8446 §4.1.4 + §4.4.1)
# ============================================================================
#
# `process_hrr_after_serverhello` is the pure decision routine the connect
# flow calls when a ServerHello carries the HRR_MAGIC. It enforces the
# §4.1.4 rejections ("only one HRR per handshake", "HRR must switch group")
# and produces the ClientHello2 bytes plus the new transcript seed
# (synthetic message_hash || HRR-handshake-bytes) per §4.4.1.
#
# The function is intentionally I/O-free so it can be unit-tested directly
# without a TCP socket. The connect flow does the actual `_io_send` of the
# returned `client_hello2_bytes` and the subsequent `_io_recv_record` for
# ServerHello2.
#
# Note: today's connect flow always advertises an X25519 key_share in CH1
# (it may also advertise a P-256 key_share once a P-256 ephemeral is
# generated up-front). Therefore the §4.1.4 same-group rejection currently
# fires whenever the server picks GROUP_X25519 from CH1. Routing the
# P-256 case to `build_client_hello2_bytes_with_p256` is retained for the
# future when CH1 may offer P-256-only key_share or add new groups.

enum HrrFlowResult:
    Ok(value: HrrFlowOk)
    Reject(reason: text)

class HrrFlowOk:
    """Result of HRR processing: bytes to send + transcript seed for §4.4.1."""
    client_hello2_bytes: [u8]    # handshake-layer CH2 (type+len+body)
    selected_group: u16          # HRR's NamedGroup pick (for P-256 deferral)
    transcript_seed: [u8]        # synthetic_message_hash || hrr_hs_bytes
    hrr_hs_bytes: [u8]           # HRR handshake-layer bytes (for caller debug)

fn process_hrr_after_serverhello(
        sh_hs_bytes: [u8],
        sh_body: [u8],
        ch1_random: [u8],
        ch1_x25519_pub: [u8],
        ch1_hash: [u8],
        new_x25519_pub: [u8],
        new_p256_pub: [u8],
        sni_host: text,
        seen_hrr: bool,
        ch1_offered_x25519: bool,
        ch1_offered_p256: bool) -> HrrFlowResult:
    """Decide CH2 + transcript seed when a ServerHello is actually a HRR.

    Args:
        sh_hs_bytes: full HRR handshake-layer bytes (type + 3-len + body).
        sh_body: the body slice (legacy_version onwards) — passed to
                 parse_hello_retry_request.
        ch1_random: 32-byte client_random reused verbatim in CH2.
        ch1_x25519_pub: CH1's X25519 public share (for same-group check).
        ch1_hash: SHA-256 hash of CH1 handshake-layer bytes (for synthetic
                  message_hash per §4.4.1).
        new_x25519_pub: fresh X25519 public share to put in CH2 if HRR
                        selected GROUP_X25519. Empty if not regenerated.
        new_p256_pub: fresh P-256 uncompressed point if HRR selected
                      GROUP_SECP256R1. Empty otherwise.
        sni_host: SNI hostname (echoed unchanged from CH1).
        seen_hrr: false on first HRR (Ok path); true on a second HRR
                  (rejected per §4.1.4).
        ch1_offered_x25519: whether CH1 advertised a key_share for X25519
                            (used for same-group rejection).
        ch1_offered_p256: whether CH1 advertised a key_share for P-256
                          (used for same-group rejection).

    Returns:
        HrrFlowResult.Ok(HrrFlowOk{...}) on success — caller MUST send
        client_hello2_bytes wrapped in a plaintext record, then replace its
        transcript with `transcript_seed`.

        HrrFlowResult.Reject(reason: ...) on a §4.1.4 violation. Caller
        MUST close the connection with an alert.
    """
    if seen_hrr:
        # §4.1.4: "If a client receives a second HelloRetryRequest in the
        # same connection ... it MUST abort the handshake with an
        # unexpected_message alert."
        return HrrFlowResult.Reject(reason: "unexpected_message: second HRR in connection")

    val parsed = parse_hello_retry_request(sh_body)
    var hrr: HelloRetryRequest13 = HelloRetryRequest13(cipher_suite: 0u16, selected_group: 0u16, cookie: [])
    if val HrrResult.Ok(value) = parsed:
        hrr = value
    else:
        if val HrrResult.Err(reason) = parsed:
            return HrrFlowResult.Reject(reason: reason)

    # §4.1.4: "Clients MUST abort the handshake with an
    # `illegal_parameter` alert if the HelloRetryRequest would not result
    # in any change in the ClientHello." — i.e. the selected_group MUST
    # NOT match a group whose key_share was already in CH1.
    if hrr.selected_group == GROUP_X25519 and ch1_offered_x25519:
        return HrrFlowResult.Reject(reason: "illegal_parameter: HRR selected_group equals CH1 key_share group (X25519)")
    if hrr.selected_group == GROUP_SECP256R1 and ch1_offered_p256:
        return HrrFlowResult.Reject(reason: "illegal_parameter: HRR selected_group equals CH1 key_share group (secp256r1)")

    # §4.1.4: server's selected_group MUST be one the client advertised
    # in supported_groups. Today client advertises {X25519, secp256r1}.
    if hrr.selected_group != GROUP_X25519 and hrr.selected_group != GROUP_SECP256R1:
        return HrrFlowResult.Reject(reason: "illegal_parameter: HRR selected_group not in client supported_groups")

    # Build CH2 with a fresh key_share for the chosen group.
    val ch2 = if hrr.selected_group == GROUP_SECP256R1 {
        build_client_hello2_bytes_with_p256(ch1_random, [], new_p256_pub, sni_host, hrr.cookie)
    } else {
        # GROUP_X25519 path is currently unreachable from the live connect
        # flow because CH1 advertises X25519 (so it would have been rejected
        # above as same-group). It is retained for tests and for future
        # configurations where CH1 may omit X25519 from key_share.
        build_client_hello2_bytes(ch1_random, new_x25519_pub, sni_host, hrr.cookie)
    }

    # §4.4.1: "When the server responds to a ClientHello with a
    # HelloRetryRequest, the value of ClientHello1 is replaced with a
    # special synthetic handshake message of handshake type
    # `message_hash` containing Hash(ClientHello1)."
    val synth = build_hrr_synthetic_message_hash(ch1_hash)
    var seed: [u8] = _byte_buf(synth.len() + sh_hs_bytes.len())
    _append_into(seed, synth)
    _append_into(seed, sh_hs_bytes)

    HrrFlowResult.Ok(value: HrrFlowOk(
        client_hello2_bytes: ch2,
        selected_group: hrr.selected_group,
        transcript_seed: seed,
        hrr_hs_bytes: sh_hs_bytes,
    ))

# ============================================================================
# Public: Parse Certificate Body
# ============================================================================

fn parse_certificate_body(body: [u8]) -> [u8]:
    """Extract the first certificate DER from a Certificate message body.

    Structure (RFC 8446 §4.4.2):
      request_context_len(1) + request_context(...) +
      cert_list_len(3) +
      [  cert_data_len(3) + cert_data(...) + extensions_len(2) + extensions(...) ]*

    Args:
        body: Certificate message body bytes.

    Returns: First certificate DER bytes.
    """
    # Skip request_context
    val ctx_len = _u8_at(body, 0).to_u64()
    var offset: u64 = 1 + ctx_len

    # cert_list length (3 bytes, but we only need the first entry)
    offset = offset + 3

    # First cert_data length (3 bytes)
    val cert_len = _u24_be(body, offset)
    offset = offset + 3

    # Copy cert DER
    var cert: [u8] = _byte_buf(cert_len)
    var i: u64 = 0
    while i < cert_len:
        cert = _push_byte(cert, _u8_at(body, offset + i).to_u64().to_i64())
        i = i + 1
    cert

fn parse_certificate_chain_body(body: [u8]) -> [[u8]]:
    """Extract the full certificate chain from a Certificate message body."""
    val ctx_len = _u8_at(body, 0).to_u64()
    var offset: u64 = 1 + ctx_len
    val cert_list_len = _u24_be(body, offset)
    offset = offset + 3
    val cert_list_end = offset + cert_list_len

    var chain: [[u8]] = []
    while offset + 3 <= cert_list_end:
        val cert_len = _u24_be(body, offset)
        offset = offset + 3

        var cert: [u8] = _byte_buf(cert_len)
        var i: u64 = 0
        while i < cert_len:
            cert = _push_byte(cert, _u8_at(body, offset + i).to_u64().to_i64())
            i = i + 1
        chain.push(cert)
        offset = offset + cert_len

        if offset + 2 > cert_list_end:
            return chain
        val ext_len = _u16_be(body, offset).to_u64()
        offset = offset + 2 + ext_len
    chain

fn parse_certificate_request(body: [u8]) -> CertificateRequest13:
    """Parse a TLS 1.3 CertificateRequest body.

    Extracts the request context and any signature_algorithms extension values.
    Unknown extensions are ignored.
    """
    val ctx_len = _u8_at(body, 0).to_u64()
    var request_context: [u8] = _byte_buf(ctx_len)
    var i: u64 = 0
    while i < ctx_len:
        request_context = _push_byte(request_context, _u8_at(body, 1 + i).to_u64().to_i64())
        i = i + 1

    var sig_algs: [u16] = []
    var offset: u64 = 1 + ctx_len
    val exts_len = _u16_be(body, offset).to_u64()
    offset = offset + 2
    val exts_end = offset + exts_len

    while offset + 4 <= exts_end:
        val ext_type = _u16_be(body, offset)
        offset = offset + 2
        val ext_len = _u16_be(body, offset).to_u64()
        offset = offset + 2

        if ext_type == EXT_SIG_ALGS and ext_len >= 2:
            val list_len = _u16_be(body, offset).to_u64()
            var list_pos: u64 = offset + 2
            val list_end = list_pos + list_len
            while list_pos + 2 <= list_end:
                sig_algs.push(_u16_be(body, list_pos))
                list_pos = list_pos + 2

        offset = offset + ext_len

    CertificateRequest13(request_context: request_context, sig_algs: sig_algs)

# ============================================================================
# Public: Parse CertificateVerify
# ============================================================================

fn parse_certificate_verify(body: [u8]) -> CertVerifyFields:
    """Parse a CertificateVerify message body.

    Structure (RFC 8446 §4.4.3):
      algorithm(2) + signature_len(2) + signature(...)

    Args:
        body: CertificateVerify body bytes.

    Returns: CertVerifyFields with algorithm and signature.
    """
    val algorithm = _u16_be(body, 0)
    val sig_len = _u16_be(body, 2).to_u64()
    var signature: [u8] = _byte_buf(sig_len)
    var i: u64 = 0
    while i < sig_len:
        signature = _push_byte(signature, _u8_at(body, 4 + i).to_u64().to_i64())
        i = i + 1
    CertVerifyFields(algorithm: algorithm, signature: signature)

# ============================================================================
# Public: Parse Finished
# ============================================================================

fn parse_finished_body(body: [u8]) -> [u8]:
    """Return the verify_data from a Finished message body.

    The body of a Finished message is exactly the verify_data (RFC 8446 §4.4.4).

    Args:
        body: Finished message body bytes.

    Returns: verify_data bytes.
    """
    var out: [u8] = _byte_buf(body.len())
    var i: u64 = 0
    while i < body.len():
        out = _push_byte(out, _u8_at(body, i).to_u64().to_i64())
        i = i + 1
    out

# ============================================================================
# Public: Build Finished Message
# ============================================================================

fn build_finished_bytes(verify_data: [u8]) -> [u8]:
    """Encode a Finished handshake message.

    Wire format: type(0x14) + 3-byte length + verify_data

    Args:
        verify_data: HMAC-based verify_data (32 bytes for SHA-256).

    Returns: Complete handshake-layer Finished bytes.
    """
    val body_len = _put_u24_be(verify_data.len().to_u64())
    var out: [u8] = _byte_buf(verify_data.len() + 4)
    out = _push_byte(out, HS_FINISHED)
    _append_into(out, body_len)
    _append_into(out, verify_data)
    out

fn build_certificate_bytes(request_context: [u8], cert_chain: [[u8]]) -> [u8]:
    """Build a TLS 1.3 Certificate handshake message."""
    var body: [u8] = _byte_buf(256)
    body = _push_byte(body, request_context.len().to_i64())
    _append_into(body, request_context)

    var cert_list: [u8] = _byte_buf(512)
    var cert_idx: u64 = 0
    while cert_idx < cert_chain.len():
        val cert_der = cert_chain[cert_idx]
        _append_into(cert_list, _put_u24_be(cert_der.len().to_u64()))
        _append_into(cert_list, cert_der)
        cert_list = _push_byte(cert_list, 0x00)
        cert_list = _push_byte(cert_list, 0x00)
        cert_idx = cert_idx + 1

    _append_into(body, _put_u24_be(cert_list.len().to_u64()))
    _append_into(body, cert_list)

    val body_len = _put_u24_be(body.len().to_u64())
    var out: [u8] = _byte_buf(body.len() + 4)
    out = _push_byte(out, HS_CERTIFICATE)
    _append_into(out, body_len)
    _append_into(out, body)
    out

fn build_certificate_verify_bytes(algorithm: u16, signature: [u8]) -> [u8]:
    """Build a TLS 1.3 CertificateVerify handshake message."""
    var body: [u8] = _byte_buf(signature.len() + 4)
    _append_into(body, _put_u16_be(algorithm))
    _append_into(body, _put_u16_be(signature.len().to_u16()))
    _append_into(body, signature)

    val body_len = _put_u24_be(body.len().to_u64())
    var out: [u8] = _byte_buf(body.len() + 4)
    out = _push_byte(out, HS_CERTIFICATE_VERIFY)
    _append_into(out, body_len)
    _append_into(out, body)
    out

# ============================================================================
# early_data extension — RFC 8446 §4.2.10
#
# Wire format:
#   ClientHello / EncryptedExtensions: empty body (extension_data zero-length)
#   NewSessionTicket: uint32 max_early_data_size
# ============================================================================

class EarlyDataExtension:
    """Server-side max_early_data_size carried on NewSessionTicket (§4.2.10)."""
    max_early_data_size: u32

class EarlyDataDecodeResult:
    ext: EarlyDataExtension
    ok: bool
    reason: text

fn build_ext_early_data_client() -> [u8]:
    """early_data extension for ClientHello — empty body. type(2)+length(2)=0."""
    [0x00u8, 0x2au8, 0x00u8, 0x00u8]

fn build_ext_early_data_ee() -> [u8]:
    """early_data extension for EncryptedExtensions — empty body."""
    [0x00u8, 0x2au8, 0x00u8, 0x00u8]

fn build_ext_early_data_nst(max_early_data_size: u32) -> [u8]:
    """early_data extension for NewSessionTicket: type(2)+length(2)=4+u32."""
    var out: [u8] = []
    out.push(0x00u8)
    out.push(0x2au8)
    out.push(0x00u8)
    out.push(0x04u8)
    out.push(((max_early_data_size >> 24) & 0xFF).to_u8())
    out.push(((max_early_data_size >> 16) & 0xFF).to_u8())
    out.push(((max_early_data_size >> 8) & 0xFF).to_u8())
    out.push((max_early_data_size & 0xFF).to_u8())
    out

fn decode_ext_early_data_nst(body: [u8]) -> EarlyDataDecodeResult:
    """Decode a NewSessionTicket early_data extension body (4 bytes)."""
    if body.len() != 4:
        return EarlyDataDecodeResult(
            ext: EarlyDataExtension(max_early_data_size: 0u32),
            ok: false,
            reason: "decode_error: early_data NST body must be 4 bytes",
        )
    val b0 = body[0].to_u32()
    val b1 = body[1].to_u32()
    val b2 = body[2].to_u32()
    val b3 = body[3].to_u32()
    val v: u32 = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
    EarlyDataDecodeResult(
        ext: EarlyDataExtension(max_early_data_size: v),
        ok: true,
        reason: "",
    )

fn decode_ext_early_data_client(body: [u8]) -> EarlyDataDecodeResult:
    """Decode a ClientHello/EE early_data body — MUST be empty per §4.2.10."""
    if body.len() != 0:
        return EarlyDataDecodeResult(
            ext: EarlyDataExtension(max_early_data_size: 0u32),
            ok: false,
            reason: "illegal_parameter: early_data CH/EE body must be empty",
        )
    EarlyDataDecodeResult(
        ext: EarlyDataExtension(max_early_data_size: 0u32),
        ok: true,
        reason: "",
    )

# ============================================================================
# psk_key_exchange_modes extension — RFC 8446 §4.2.9
#
# Wire format:
#   uint8 ke_modes_len
#   PskKeyExchangeMode ke_modes[ke_modes_len]
# Values: 0 = psk_ke (no DHE), 1 = psk_dhe_ke (PSK + DHE — default).
# ============================================================================

fn build_ext_psk_key_exchange_modes(modes: [u8]) -> [u8]:
    """psk_key_exchange_modes extension (§4.2.9). type(2)+len(2)+u8 count+modes."""
    var ext_data: [u8] = []
    ext_data.push((modes.len() & 0xFF).to_u8())
    var i: u64 = 0
    val n = modes.len().to_u64()
    while i < n:
        ext_data.push(modes[i.to_i64()])
        i = i + 1
    var out: [u8] = []
    out.push(0x00u8)
    out.push(0x2du8)
    out.push(((ext_data.len() >> 8) & 0xFF).to_u8())
    out.push((ext_data.len() & 0xFF).to_u8())
    var j: u64 = 0
    val m = ext_data.len().to_u64()
    while j < m:
        out.push(ext_data[j.to_i64()])
        j = j + 1
    out
