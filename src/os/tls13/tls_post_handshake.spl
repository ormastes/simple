class KeyUpdateRequest:
    update_requested (bool)
    sender_epoch (i32)
    old_secret_hash (text)
    new_secret_hash (text)

    me is_request():
        return self.update_requested

    me is_notification():
        return self.update_requested == false

    me epoch_after():
        return self.sender_epoch + 1

    static fn request(epoch: i32, old_hash: text, new_hash: text) -> KeyUpdateRequest:
        return KeyUpdateRequest(update_requested: true, sender_epoch: epoch, old_secret_hash: old_hash, new_secret_hash: new_hash)

    static fn notification(epoch: i32, old_hash: text, new_hash: text) -> KeyUpdateRequest:
        return KeyUpdateRequest(update_requested: false, sender_epoch: epoch, old_secret_hash: old_hash, new_secret_hash: new_hash)


class KeyDerivation:
    cipher_suite (text)
    current_secret (text)
    derived_secret (text)
    key_length (i32)
    iv_length (i32)

    me is_aes128():
        return self.cipher_suite == "TLS_AES_128_GCM_SHA256"

    me is_aes256():
        return self.cipher_suite == "TLS_AES_256_GCM_SHA384"

    me total_material():
        return self.key_length + self.iv_length

    static fn aes128(current: text, derived: text) -> KeyDerivation:
        return KeyDerivation(cipher_suite: "TLS_AES_128_GCM_SHA256", current_secret: current, derived_secret: derived, key_length: 16, iv_length: 12)

    static fn aes256(current: text, derived: text) -> KeyDerivation:
        return KeyDerivation(cipher_suite: "TLS_AES_256_GCM_SHA384", current_secret: current, derived_secret: derived, key_length: 32, iv_length: 12)


class NewSessionTicket:
    ticket_lifetime (i32)
    ticket_age_add (i32)
    ticket_nonce (text)
    ticket_data (text)
    max_early_data (i32)
    issued_at (i32)

    me is_expired(current_time: i32):
        return (current_time - self.issued_at) > self.ticket_lifetime

    me obfuscated_age(current_time: i32):
        return (current_time - self.issued_at) + self.ticket_age_add

    me supports_early_data():
        return self.max_early_data > 0

    static fn create(lifetime: i32, age_add: i32, nonce: text, data: text, early: i32, now: i32) -> NewSessionTicket:
        return NewSessionTicket(ticket_lifetime: lifetime, ticket_age_add: age_add, ticket_nonce: nonce, ticket_data: data, max_early_data: early, issued_at: now)


class PskStorageEntry:
    identity (text)
    ticket_data (text)
    cipher_suite (text)
    resumption_secret (text)
    lifetime (i32)
    age_add (i32)
    stored_at (i32)

    me is_valid(current_time: i32):
        return (current_time - self.stored_at) < self.lifetime

    me psk_identity():
        return self.identity

    me matches_suite(suite: text):
        return self.cipher_suite == suite

    static fn from_ticket(id: text, ticket: text, suite: text, secret: text, life: i32, age: i32, now: i32) -> PskStorageEntry:
        return PskStorageEntry(identity: id, ticket_data: ticket, cipher_suite: suite, resumption_secret: secret, lifetime: life, age_add: age, stored_at: now)


fn main():
    print("tls_post_handshake loaded")
