# ============================================================================
# TLS 1.3 Server-side message builders — RFC 8446
# ============================================================================
#
# Extracted from server.spl. Contains pure byte-builder functions for the
# server-side handshake flight messages:
#   ServerHello, EncryptedExtensions, Certificate,
#   CertificateVerify, Finished.
#
# All functions are pure (no I/O) and exercised by
# test/01_unit/os/tls13/server_accept_spec.spl.
#
# Reference: RFC 8446 §4.1.3, §4.3.1, §4.4.2, §4.4.3, §4.4.4.

use os.tls13.handshake13.{build_finished_bytes, SIG_ED25519}
use os.tls13.server_types.{Tls13ServerConfig}
use os.crypto.sha256.{sha256_hmac}
use std.nogc_sync_mut.io.signature_sffi.{ecdsa_p256_sign}

extern fn rt_ed25519_sign(pkcs8: [u8], message: [u8]) -> [u8]

# HandshakeType bytes (local copies — handshake13 keeps the canonical defs).
val HS_SERVER_HELLO: u8         = 2
val HS_ENCRYPTED_EXTENSIONS: u8 = 8
val HS_CERTIFICATE: u8          = 11
val HS_CERTIFICATE_VERIFY: u8   = 15

# ServerHello extension type bytes (RFC 8446 §4.2)
val EXT_SUPPORTED_VERSIONS_SB: u16 = 43
val EXT_KEY_SHARE_SB: u16          = 51

# ============================================================================
# Local byte helpers (self-contained — no import from server.spl)
# ============================================================================

fn _b_put_u16_be(value: u16) -> [u8]:
    var out: [u8] = []
    out.push(((value.to_u32() >> 8) & 0xFF).to_u8())
    out.push((value.to_u32() & 0xFF).to_u8())
    out

fn _b_put_u24_be(value: u64) -> [u8]:
    var out: [u8] = []
    out.push(((value >> 16) & 0xFF).to_u8())
    out.push(((value >> 8) & 0xFF).to_u8())
    out.push((value & 0xFF).to_u8())
    out

fn _b_append(dst: [u8], src: [u8]) -> [u8]:
    var i: u64 = 0
    while i < src.len():
        dst.push(src[i])
        i = i + 1
    dst

fn _b_slice(data: [u8], offset: u64, length: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < length and offset + i < data.len():
        out.push(data[offset + i])
        i = i + 1
    out

fn _b_unwrap_sig(maybe: [u8]) -> [u8]:
    if val bytes = maybe:
        bytes
    else:
        []

# ============================================================================
# Public: build_server_hello — RFC 8446 §4.1.3
# ============================================================================

fn _build_sh_ext_supported_versions() -> [u8]:
    """ServerHello supported_versions: TLS 1.3 single u16 (no list_len)."""
    var out: [u8] = []
    out = _b_append(out, _b_put_u16_be(EXT_SUPPORTED_VERSIONS_SB))
    out = _b_append(out, _b_put_u16_be(2u16))
    out = _b_append(out, _b_put_u16_be(0x0304u16))
    out

fn _build_sh_ext_key_share(group: u16, key: [u8]) -> [u8]:
    """ServerHello key_share: single KeyShareEntry (group(2) + key_len(2) + key)."""
    var entry: [u8] = []
    entry = _b_append(entry, _b_put_u16_be(group))
    entry = _b_append(entry, _b_put_u16_be(key.len().to_u16()))
    entry = _b_append(entry, key)
    var out: [u8] = []
    out = _b_append(out, _b_put_u16_be(EXT_KEY_SHARE_SB))
    out = _b_append(out, _b_put_u16_be(entry.len().to_u16()))
    out = _b_append(out, entry)
    out

fn build_server_hello(
    server_random: [u8],
    cipher_suite: u16,
    named_group: u16,
    server_keyshare: [u8]
) -> [u8]:
    """Build a TLS 1.3 ServerHello handshake message (with handshake header).

    Wire format (RFC 8446 §4.1.3):
      HandshakeType(1)=2 + length(3) + legacy_version(2)=0x0303 +
      random(32) + legacy_session_id_len(1)=0 +
      cipher_suite(2) + legacy_compression_method(1)=0x00 +
      extensions_len(2) + extensions(supported_versions, key_share)
    """
    var body: [u8] = []
    body.push(0x03u8)
    body.push(0x03u8)
    body = _b_append(body, server_random)
    body.push(0x00u8)
    body = _b_append(body, _b_put_u16_be(cipher_suite))
    body.push(0x00u8)

    var exts: [u8] = []
    exts = _b_append(exts, _build_sh_ext_supported_versions())
    exts = _b_append(exts, _build_sh_ext_key_share(named_group, server_keyshare))
    body = _b_append(body, _b_put_u16_be(exts.len().to_u16()))
    body = _b_append(body, exts)

    var out: [u8] = []
    out.push(HS_SERVER_HELLO)
    out = _b_append(out, _b_put_u24_be(body.len().to_u64()))
    out = _b_append(out, body)
    out

# ============================================================================
# Public: build_encrypted_extensions_server_side — RFC 8446 §4.3.1
# ============================================================================

fn build_encrypted_extensions_server_side(server_config: Tls13ServerConfig) -> [u8]:
    """Build a minimal EncryptedExtensions handshake message.

    Wire format (RFC 8446 §4.3.1):
      HandshakeType(1)=8 + length(3) + extensions_len(2) + extensions

    An empty extension list (extensions_len = 0) is valid per §4.3.1; a
    server-side EE may omit any optional extensions. We currently always
    emit an empty list; ALPN/SNI ack/etc. land with the I/O wiring.
    """
    var body: [u8] = []
    body = _b_append(body, _b_put_u16_be(0u16))
    var out: [u8] = []
    out.push(HS_ENCRYPTED_EXTENSIONS)
    out = _b_append(out, _b_put_u24_be(body.len().to_u64()))
    out = _b_append(out, body)
    out

# ============================================================================
# Public: build_certificate — RFC 8446 §4.4.2
# ============================================================================

fn build_certificate(cert_chain: [[u8]]) -> [u8]:
    """Build the Certificate handshake message for a server-side flow.

    request_context MUST be empty for a non-mTLS server (RFC 8446 §4.4.2).
    """
    var body: [u8] = []
    body.push(0x00u8)

    var cert_list: [u8] = []
    var cert_idx: u64 = 0
    while cert_idx < cert_chain.len():
        val cert_der = cert_chain[cert_idx]
        cert_list = _b_append(cert_list, _b_put_u24_be(cert_der.len().to_u64()))
        cert_list = _b_append(cert_list, cert_der)
        cert_list.push(0x00u8)
        cert_list.push(0x00u8)
        cert_idx = cert_idx + 1

    body = _b_append(body, _b_put_u24_be(cert_list.len().to_u64()))
    body = _b_append(body, cert_list)

    var out: [u8] = []
    out.push(HS_CERTIFICATE)
    out = _b_append(out, _b_put_u24_be(body.len().to_u64()))
    out = _b_append(out, body)
    out

# ============================================================================
# Public: build_certificate_verify — RFC 8446 §4.4.3
# ============================================================================

fn _signing_context_server() -> [u8]:
    """Return the 64x0x20 || "TLS 1.3, server CertificateVerify" || 0x00 prefix."""
    var ctx: [u8] = []
    var i: u64 = 0
    while i < 64u64:
        ctx.push(0x20u8)
        i = i + 1u64
    # "TLS 1.3, server CertificateVerify" — 33 ASCII bytes.
    ctx.push(0x54u8)  # T
    ctx.push(0x4Cu8)  # L
    ctx.push(0x53u8)  # S
    ctx.push(0x20u8)  # space
    ctx.push(0x31u8)  # 1
    ctx.push(0x2Eu8)  # .
    ctx.push(0x33u8)  # 3
    ctx.push(0x2Cu8)  # ,
    ctx.push(0x20u8)  # space
    ctx.push(0x73u8)  # s
    ctx.push(0x65u8)  # e
    ctx.push(0x72u8)  # r
    ctx.push(0x76u8)  # v
    ctx.push(0x65u8)  # e
    ctx.push(0x72u8)  # r
    ctx.push(0x20u8)  # space
    ctx.push(0x43u8)  # C
    ctx.push(0x65u8)  # e
    ctx.push(0x72u8)  # r
    ctx.push(0x74u8)  # t
    ctx.push(0x69u8)  # i
    ctx.push(0x66u8)  # f
    ctx.push(0x69u8)  # i
    ctx.push(0x63u8)  # c
    ctx.push(0x61u8)  # a
    ctx.push(0x74u8)  # t
    ctx.push(0x65u8)  # e
    ctx.push(0x56u8)  # V
    ctx.push(0x65u8)  # e
    ctx.push(0x72u8)  # r
    ctx.push(0x69u8)  # i
    ctx.push(0x66u8)  # f
    ctx.push(0x79u8)  # y
    ctx.push(0x00u8)  # separator
    ctx

fn build_certificate_verify_signing_input(transcript_hash: [u8]) -> [u8]:
    """Build the message to feed the signature primitive (RFC 8446 §4.4.3)."""
    var msg: [u8] = _signing_context_server()
    msg = _b_append(msg, transcript_hash)
    msg

fn build_certificate_verify(transcript_hash: [u8], server_signing_key_pkcs8: [u8], sig_scheme: u16) -> [u8]:
    """Build a TLS 1.3 server-side CertificateVerify handshake message.

    Args:
        transcript_hash: Hash(CH || SH || EE || Certificate) in the negotiated
            hash (32 bytes for SHA-256, 48 for SHA-384).
        server_signing_key_pkcs8: PKCS#8 v1 DER of the server's signing key.
        sig_scheme: SignatureScheme code (e.g. 0x0807, 0x0403).

    Returns: complete handshake-layer CertificateVerify bytes.
    """
    val signing_input = build_certificate_verify_signing_input(transcript_hash)
    var sig: [u8] = []
    if sig_scheme == SIG_ED25519:
        sig = _b_unwrap_sig(rt_ed25519_sign(server_signing_key_pkcs8, signing_input))
        if sig.len() == 0:
            sig = _b_unwrap_sig(rt_ed25519_sign(server_signing_key_pkcs8, signing_input))
    elif sig_scheme == 0x0403u16:
        sig = ecdsa_p256_sign(server_signing_key_pkcs8, signing_input)
    else:
        return []

    if sig.len() == 0:
        return []

    var body: [u8] = []
    body = _b_append(body, _b_put_u16_be(sig_scheme))
    body = _b_append(body, _b_put_u16_be(sig.len() as u16))
    body = _b_append(body, sig)

    var out: [u8] = []
    out.push(HS_CERTIFICATE_VERIFY)
    out = _b_append(out, _b_put_u24_be(body.len().to_u64()))
    out = _b_append(out, body)
    out

# ============================================================================
# Public: build_server_finished — RFC 8446 §4.4.4
# ============================================================================

fn build_server_finished(server_finished_key: [u8], transcript_hash: [u8]) -> [u8]:
    """Build a TLS 1.3 server Finished handshake message.

    verify_data = HMAC-SHA-256(server_finished_key, transcript_hash) for
    SHA-256-based suites. SHA-384 path lives in key_schedule and is
    delegated by the caller — this server skeleton runs the SHA-256 path.

    Args:
        server_finished_key: Output of tls13_finished_key(server_hs_secret).
        transcript_hash: Hash(CH..server CV) or appropriate transcript prefix.

    Returns: complete handshake-layer Finished message bytes.
    """
    val verify_data = _server_verify_data_sha256(server_finished_key, transcript_hash)
    build_finished_bytes(verify_data)

fn _server_verify_data_sha256(finished_key: [u8], transcript_hash: [u8]) -> [u8]:
    """SHA-256 Finished verify_data without relying on a socket-runtime extern."""
    _b_slice(sha256_hmac(finished_key, transcript_hash), 0u64, 32u64)
