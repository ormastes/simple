# TLS 1.3 Key Schedule — RFC 8446 §7.1
#
# Implements the full key schedule:
#   early_secret → handshake_secret → master_secret
#   plus traffic key derivation and Finished MAC

use os.tls13.hkdf.{hkdf_extract, hkdf_expand_label, hkdf_extract_sha384, hkdf_expand_label_sha384}
use os.tls13.transcript.{Transcript, transcript_hash, transcript_empty_hash}
use os.crypto.sha256.{sha256_hmac}
use std.crypto.types.{rotr64}
use std.crypto.hmac.{hmac_sha384_bytes}

fn _copy_prefix(src: [u8], n: u64) -> [u8]:
    var out: [u8] = []
    var copied: u64 = 0
    for byte in src:
        if copied >= n:
            break
        out.push(byte.to_u8())
        copied = copied + 1
    out

# ============================================================================
# Data classes
# ============================================================================

class Tls13Secrets:
    early_secret: [u8]
    handshake_secret: [u8]
    master_secret: [u8]
    client_hs_traffic: [u8]
    server_hs_traffic: [u8]
    client_app_traffic: [u8]
    server_app_traffic: [u8]

class TrafficKeys:
    key: [u8]    # 16 bytes (AES-128)
    iv: [u8]     # 12 bytes

# ============================================================================
# _zeros — produce n zero bytes
# ============================================================================

fn _zeros(n: u64) -> [u8]:
    """Return a [u8] of n zero bytes."""
    var result: [u8] = []
    var i: u64 = 0
    while i < n:
        result.push(0x00)
        i = i + 1
    result

# ============================================================================
# derive_secret — HKDF-Expand-Label with transcript hash as context
# ============================================================================

fn derive_secret(secret: [u8], label: text, t: Transcript) -> [u8]:
    """Derive-Secret(secret, label, messages) per RFC 8446 §7.1.

    HKDF-Expand-Label(secret, label, transcript_hash(messages), 32)
    """
    val context = transcript_hash(t)
    _copy_prefix(hkdf_expand_label(secret, label, context, 32), 32)

# ============================================================================
# tls13_early_secret — first step of the key schedule
# ============================================================================

fn tls13_early_secret() -> [u8]:
    """Compute the early secret: HKDF-Extract(0^32, 0^32)."""
    val salt = _zeros(32)
    val ikm = _zeros(32)
    _copy_prefix(hkdf_extract(salt, ikm), 32)

# ============================================================================
# tls13_handshake_secret — second step of the key schedule
# ============================================================================

fn tls13_handshake_secret(early_secret: [u8], dhe_shared: [u8]) -> [u8]:
    """Compute the handshake secret per RFC 8446 §7.1.

    derived = HKDF-Expand-Label(early_secret, "derived", transcript_empty_hash(), 32)
    return HKDF-Extract(salt=derived, IKM=dhe_shared)
    """
    val derived = hkdf_expand_label(early_secret, "derived", transcript_empty_hash(), 32)
    _copy_prefix(hkdf_extract(derived, dhe_shared), 32)

# ============================================================================
# tls13_master_secret — third step of the key schedule
# ============================================================================

fn tls13_master_secret(handshake_secret: [u8]) -> [u8]:
    """Compute the master secret per RFC 8446 §7.1.

    derived = HKDF-Expand-Label(handshake_secret, "derived", transcript_empty_hash(), 32)
    return HKDF-Extract(salt=derived, IKM=0^32)
    """
    val derived = hkdf_expand_label(handshake_secret, "derived", transcript_empty_hash(), 32)
    val ikm = _zeros(32)
    _copy_prefix(hkdf_extract(derived, ikm), 32)

# ============================================================================
# tls13_traffic_keys — derive AES-128 key and IV from a traffic secret
# ============================================================================

fn tls13_traffic_keys(traffic_secret: [u8]) -> TrafficKeys:
    """Derive key (16 bytes) and IV (12 bytes) from a traffic secret.

    key = HKDF-Expand-Label(traffic_secret, "key", "", 16)
    iv  = HKDF-Expand-Label(traffic_secret, "iv",  "", 12)
    """
    val empty: [u8] = []
    val key = _copy_prefix(hkdf_expand_label(traffic_secret, "key", empty, 16), 16)
    val iv = _copy_prefix(hkdf_expand_label(traffic_secret, "iv", empty, 12), 12)
    TrafficKeys(key: key, iv: iv)

fn tls13_traffic_keys_chacha20(traffic_secret: [u8]) -> TrafficKeys:
    """Derive ChaCha20 key (32 bytes) and IV (12 bytes) from a traffic secret.

    SHA-256 path (TLS_CHACHA20_POLY1305_SHA256, 0x1303) per RFC 8446 §7.3:
      key = HKDF-Expand-Label(traffic_secret, "key", "", 32)
      iv  = HKDF-Expand-Label(traffic_secret, "iv",  "", 12)
    """
    val empty: [u8] = []
    val key = _copy_prefix(hkdf_expand_label(traffic_secret, "key", empty, 32), 32)
    val iv = _copy_prefix(hkdf_expand_label(traffic_secret, "iv", empty, 12), 12)
    TrafficKeys(key: key, iv: iv)

# ============================================================================
# tls13_finished_key — derive the Finished MAC key
# ============================================================================

fn tls13_finished_key(traffic_secret: [u8]) -> [u8]:
    """Derive the Finished key: HKDF-Expand-Label(traffic_secret, "finished", "", 32)."""
    val empty: [u8] = []
    _copy_prefix(hkdf_expand_label(traffic_secret, "finished", empty, 32), 32)

# ============================================================================
# tls13_verify_data — compute Finished verify_data
# ============================================================================

fn tls13_verify_data(finished_key: [u8], t: Transcript) -> [u8]:
    """Compute verify_data = HMAC-SHA-256(finished_key, transcript_hash(t))."""
    val h = transcript_hash(t)
    _copy_prefix(sha256_hmac(finished_key, h), 32)

# ============================================================================
# tls13_compute_handshake_secrets — derive handshake traffic secrets
# ============================================================================

fn tls13_compute_handshake_secrets(dhe_shared: [u8], transcript_sh: Transcript) -> Tls13Secrets:
    """Compute early + handshake secrets and HS traffic secrets.

    App traffic secrets and master secret are left empty ([]) —
    call tls13_compute_app_secrets to fill them after server Finished.
    """
    val early = tls13_early_secret()
    val hs = tls13_handshake_secret(early_secret: early, dhe_shared: dhe_shared)
    val client_hs = derive_secret(secret: hs, label: "c hs traffic", t: transcript_sh)
    val server_hs = derive_secret(secret: hs, label: "s hs traffic", t: transcript_sh)
    val empty: [u8] = []
    Tls13Secrets(
        early_secret: early,
        handshake_secret: hs,
        master_secret: empty,
        client_hs_traffic: client_hs,
        server_hs_traffic: server_hs,
        client_app_traffic: empty,
        server_app_traffic: empty,
    )

# ============================================================================
# tls13_compute_app_secrets — derive application traffic secrets
# ============================================================================

fn tls13_compute_app_secrets(hs_secrets: Tls13Secrets, transcript_sf: Transcript) -> Tls13Secrets:
    """Compute master secret and application traffic secrets.

    Copies early/handshake/client_hs/server_hs from hs_secrets and fills in
    master_secret, client_app_traffic, and server_app_traffic.
    """
    val master = tls13_master_secret(hs_secrets.handshake_secret)
    val client_app = derive_secret(secret: master, label: "c ap traffic", t: transcript_sf)
    val server_app = derive_secret(secret: master, label: "s ap traffic", t: transcript_sf)
    Tls13Secrets(
        early_secret: hs_secrets.early_secret,
        handshake_secret: hs_secrets.handshake_secret,
        master_secret: master,
        client_hs_traffic: hs_secrets.client_hs_traffic,
        server_hs_traffic: hs_secrets.server_hs_traffic,
        client_app_traffic: client_app,
        server_app_traffic: server_app,
    )

# ============================================================================
# SHA-384 sibling key schedule — for TLS_AES_256_GCM_SHA384
#
# Mirrors the SHA-256 path above with 48-byte secret length and SHA-384
# HMAC primitives. Per RFC 8446 §7.1, all secret/PRK lengths are HashLen,
# not constant 32. For TLS_AES_256_GCM_SHA384, HashLen = 48.
# ============================================================================

fn _zeros_48() -> [u8]:
    var z: [u8] = []
    var i: u64 = 0
    while i < 48:
        z.push(0x00)
        i = i + 1
    z

fn _sha384_empty_hash() -> [u8]:
    """SHA-384("") — hardcoded RFC 6234 constant.

    Avoids transitive dependency on std.crypto.sha512.sha384_bytes (which
    pulls in helpers via std.crypto.types) so this module stays cleanly
    isolated. The empty-string SHA-384 hash is a fixed constant — caching
    it as bytes avoids any std-side namespace conflicts.
    """
    [0x38u8, 0xb0u8, 0x60u8, 0xa7u8, 0x51u8, 0xacu8, 0x96u8, 0x38u8,
     0x4cu8, 0xd9u8, 0x32u8, 0x7eu8, 0xb1u8, 0xb1u8, 0xe3u8, 0x6au8,
     0x21u8, 0xfdu8, 0xb7u8, 0x11u8, 0x14u8, 0xbeu8, 0x07u8, 0x43u8,
     0x4cu8, 0x0cu8, 0xc7u8, 0xbfu8, 0x63u8, 0xf6u8, 0xe1u8, 0xdau8,
     0x27u8, 0x4eu8, 0xdeu8, 0xbfu8, 0xe7u8, 0x6fu8, 0x65u8, 0xfbu8,
     0xd5u8, 0x1au8, 0xd2u8, 0xf1u8, 0x48u8, 0x98u8, 0xb9u8, 0x5bu8]

fn tls13_early_secret_sha384() -> [u8]:
    """Early secret for SHA-384 path: HKDF-Extract-SHA-384(0^48, 0^48)."""
    val salt = _zeros_48()
    val ikm = _zeros_48()
    hkdf_extract_sha384(salt, ikm)

fn tls13_handshake_secret_sha384(early_secret: [u8], dhe_shared: [u8]) -> [u8]:
    """SHA-384 path handshake_secret per RFC 8446 §7.1.

    derived = HKDF-Expand-Label-SHA384(early_secret, "derived", SHA-384(""), 48)
    return HKDF-Extract-SHA-384(salt=derived, IKM=dhe_shared)
    """
    val empty_hash = _sha384_empty_hash()
    val derived = hkdf_expand_label_sha384(early_secret, "derived", empty_hash, 48)
    hkdf_extract_sha384(derived, dhe_shared)

fn tls13_master_secret_sha384(handshake_secret: [u8]) -> [u8]:
    """SHA-384 path master_secret."""
    val empty_hash = _sha384_empty_hash()
    val derived = hkdf_expand_label_sha384(handshake_secret, "derived", empty_hash, 48)
    val ikm = _zeros_48()
    hkdf_extract_sha384(derived, ikm)

fn tls13_traffic_keys_sha384(traffic_secret: [u8]) -> TrafficKeys:
    """Derive AES-256 key (32 bytes) and IV (12 bytes) from a SHA-384 traffic secret."""
    val empty: [u8] = []
    val key = hkdf_expand_label_sha384(traffic_secret, "key", empty, 32)
    val iv = hkdf_expand_label_sha384(traffic_secret, "iv", empty, 12)
    TrafficKeys(key: key, iv: iv)

fn tls13_finished_key_sha384(traffic_secret: [u8]) -> [u8]:
    """SHA-384 Finished key: HKDF-Expand-Label-SHA384(traffic_secret, "finished", "", 48)."""
    val empty: [u8] = []
    hkdf_expand_label_sha384(traffic_secret, "finished", empty, 48)

fn tls13_verify_data_sha384(finished_key: [u8], transcript_hash_sha384: [u8]) -> [u8]:
    """SHA-384 verify_data = HMAC-SHA-384(finished_key, transcript_hash_sha384)."""
    hmac_sha384_bytes(finished_key, transcript_hash_sha384)

# ============================================================================
# PSK + 0-RTT key schedule extensions — RFC 8446 §7.1 + §4.2.11
#
# When a PSK is offered (resumption or external), the early_secret is derived
# from the PSK rather than the all-zero IKM. The binder_key authenticates the
# OfferedPsks identity over a partial-ClientHello transcript per §4.1.4.
#
# Hash IDs:
#   0x01 — SHA-256 (32-byte secrets) — TLS_AES_128_GCM_SHA256, TLS_CHACHA20_POLY1305_SHA256
#   0x02 — SHA-384 (48-byte secrets) — TLS_AES_256_GCM_SHA384
# ============================================================================

# ============================================================================
# tls13_early_secret_from_psk — PSK-fed Extract step (RFC 8446 §7.1)
# ============================================================================

fn tls13_early_secret_from_psk(psk: [u8], hash_id: u8) -> [u8]:
    """Compute early_secret = HKDF-Extract(salt=0^HashLen, IKM=psk).

    For SHA-256 path (hash_id=1) returns 32 bytes; SHA-384 path (hash_id=2)
    returns 48 bytes. PSK length must equal HashLen per RFC 8446 §4.2.11
    binder size requirement.
    """
    if hash_id.to_u32() == 2u32:
        val salt = _zeros_48()
        return hkdf_extract_sha384(salt, psk)
    val salt = _zeros(32)
    _copy_prefix(hkdf_extract(salt, psk), 32)

# ============================================================================
# tls13_binder_key — derive PSK binder key (RFC 8446 §7.1)
#
# binder_key = HKDF-Expand-Label(early_secret, label, "", HashLen)
# where label is "ext binder" for external PSKs and "res binder" for
# resumption PSKs.
# ============================================================================

fn tls13_binder_key(early_secret: [u8], hash_id: u8, is_resumption: bool) -> [u8]:
    """Derive the PSK binder key per RFC 8446 §7.1.

    Args:
        early_secret: output of tls13_early_secret_from_psk.
        hash_id: 1=SHA-256, 2=SHA-384.
        is_resumption: true → "res binder", false → "ext binder".
    """
    val empty: [u8] = []
    val label = if is_resumption { "res binder" } else { "ext binder" }
    if hash_id.to_u32() == 2u32:
        return hkdf_expand_label_sha384(early_secret, label, empty, 48)
    _copy_prefix(hkdf_expand_label(early_secret, label, empty, 32), 32)

# ============================================================================
# tls13_compute_psk_binder — HMAC over partial-ClientHello transcript
#
# Per RFC 8446 §4.2.11.2:
#   1. Derive finished_key = HKDF-Expand-Label(binder_key, "finished", "", HashLen)
#   2. Compute HMAC(finished_key, Transcript-Hash(Truncate(ClientHello1)))
#      where Truncate strips off the binders block (everything from the
#      uint16 binders_len through end of OfferedPsks).
# ============================================================================

fn tls13_compute_psk_binder(binder_key: [u8], transcript_hash_partial: [u8], hash_id: u8) -> [u8]:
    """Compute the PSK binder MAC over a partial-ClientHello transcript hash.

    Args:
        binder_key: output of tls13_binder_key.
        transcript_hash_partial: pre-computed Hash(Truncate(ClientHello)).
            Caller is responsible for truncating before binders block.
        hash_id: 1=SHA-256, 2=SHA-384.

    Returns: HMAC = HashLen-byte binder.
    """
    val empty: [u8] = []
    if hash_id.to_u32() == 2u32:
        val finished_key = hkdf_expand_label_sha384(binder_key, "finished", empty, 48)
        return hmac_sha384_bytes(finished_key, transcript_hash_partial)
    val finished_key = _copy_prefix(hkdf_expand_label(binder_key, "finished", empty, 32), 32)
    _copy_prefix(sha256_hmac(finished_key, transcript_hash_partial), 32)

# ============================================================================
# tls13_client_early_traffic_secret — 0-RTT traffic secret (RFC 8446 §7.1)
#
# client_early_traffic_secret =
#     HKDF-Expand-Label(early_secret, "c e traffic", Hash(ClientHello), HashLen)
# ============================================================================

fn tls13_client_early_traffic_secret(early_secret: [u8], transcript_hash_ch: [u8], hash_id: u8) -> [u8]:
    """Derive client_early_traffic_secret per RFC 8446 §7.1.

    Args:
        early_secret: PSK-fed early secret.
        transcript_hash_ch: Hash(ClientHello) — full ClientHello including binders.
        hash_id: 1=SHA-256, 2=SHA-384.
    """
    if hash_id.to_u32() == 2u32:
        return hkdf_expand_label_sha384(early_secret, "c e traffic", transcript_hash_ch, 48)
    _copy_prefix(hkdf_expand_label(early_secret, "c e traffic", transcript_hash_ch, 32), 32)

# ============================================================================
# tls13_early_exporter_master_secret — early exporter (RFC 8446 §7.5)
# ============================================================================

fn tls13_early_exporter_master_secret(early_secret: [u8], transcript_hash_ch: [u8], hash_id: u8) -> [u8]:
    """early_exporter_master_secret = HKDF-Expand-Label(es, "e exp master", H(CH), HashLen)."""
    if hash_id.to_u32() == 2u32:
        return hkdf_expand_label_sha384(early_secret, "e exp master", transcript_hash_ch, 48)
    _copy_prefix(hkdf_expand_label(early_secret, "e exp master", transcript_hash_ch, 32), 32)

# ============================================================================
# tls13_resumption_master_secret — emitted after server Finished (RFC 8446 §7.1)
#
# resumption_master_secret =
#     HKDF-Expand-Label(master_secret, "res master", Hash(ClientHello..ClientFinished), HashLen)
#
# Then a per-ticket resumption_secret derived via:
#   PSK = HKDF-Expand-Label(resumption_master_secret, "resumption", ticket_nonce, HashLen)
# ============================================================================

fn tls13_resumption_master_secret(master_secret: [u8], transcript_hash_cf: [u8], hash_id: u8) -> [u8]:
    """Derive resumption_master_secret per RFC 8446 §7.1."""
    if hash_id.to_u32() == 2u32:
        return hkdf_expand_label_sha384(master_secret, "res master", transcript_hash_cf, 48)
    _copy_prefix(hkdf_expand_label(master_secret, "res master", transcript_hash_cf, 32), 32)

fn tls13_resumption_secret(resumption_master_secret: [u8], ticket_nonce: [u8], hash_id: u8) -> [u8]:
    """Per-ticket PSK = HKDF-Expand-Label(rms, "resumption", ticket_nonce, HashLen)."""
    if hash_id.to_u32() == 2u32:
        return hkdf_expand_label_sha384(resumption_master_secret, "resumption", ticket_nonce, 48)
    _copy_prefix(hkdf_expand_label(resumption_master_secret, "resumption", ticket_nonce, 32), 32)
