#![allow(unnamed_duplicate_typed_args)]
# TLS 1.3 Transcript Hash — running SHA-256 over handshake messages
#
# Implements an immutable accumulator: each transcript_add returns a new
# Transcript with the message appended, so the original is never mutated.

use os.crypto.sha256.{sha256_with_len}
fn rt_array_new_with_cap(cap: i64) -> [u8]:
    []

class Transcript:
    buf: [u8]
    buf_len: u64

fn _copy_prefix(src: [u8], n: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < n:
        out.push(src[i].to_u8())
        i = i + 1
    out

fn transcript_new() -> Transcript:
    return Transcript(buf: [], buf_len: 0)

fn transcript_add_with_len(t: Transcript, msg: [u8], msg_len: u64) -> Transcript:
    var merged: [u8] = rt_array_new_with_cap((t.buf_len + msg_len).to_i64())
    var i: u64 = 0
    val prev_len = t.buf_len
    while i < prev_len:
        merged.push(t.buf[i].to_u8())
        i = i + 1
    i = 0
    while i < msg_len:
        merged.push(msg[i].to_u8())
        i = i + 1
    return Transcript(buf: merged, buf_len: prev_len + msg_len)

fn transcript_add(t: Transcript, msg: [u8]) -> Transcript:
    transcript_add_with_len(t, msg, msg.len().to_u64())

fn transcript_hash(t: Transcript) -> [u8]:
    return _copy_prefix(sha256_with_len(t.buf, t.buf_len), 32)

fn transcript_empty_hash() -> [u8]:
    return _copy_prefix(sha256_with_len([], 0), 32)
