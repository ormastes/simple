# ============================================================================
# TLS 1.3 Server-side handshake skeleton — RFC 8446
# ============================================================================
#
# Provides the server-side counterpart to the client state machine in tls13.spl.
# This file seeds the happy-path server flow:
#
#   ClientHello -> [HRR-not-implemented] -> ServerHello -> EncryptedExtensions
#                  -> Certificate -> CertificateVerify -> Finished
#
# `tls13_accept` now drives the happy-path TLS 1.3 server handshake through the
# encrypted client Finished record and returns application traffic keys. The
# pure builders + selectors below are bytes-only and exercised by
# test/unit/os/tls13/server_accept_spec.spl.
#
# Out of scope (Wave 9+):
#   - Session tickets / 0-RTT / PSK
#   - HRR FROM the server side (we currently only accept ClientHellos that
#     already include a key_share for X25519 or P-256; a CH that needs HRR
#     fast-fails with reason "hrr_not_implemented_server_side").
#   - Multiple key_share entries in CH
#   - CertificateRequest (mTLS server side)
#
# Reference: RFC 8446 §4.1.2 (ClientHello), §4.1.3 (ServerHello),
#            §4.3.1 (EncryptedExtensions), §4.4.2 (Certificate),
#            §4.4.3 (CertificateVerify), §4.4.4 (Finished).

use os.tls13.handshake13.{
    parse_handshake_header, parse_certificate_body,
    parse_finished_body, build_finished_bytes,
    ParsedHandshake,
    HS_CLIENT_HELLO,
    GROUP_X25519, GROUP_SECP256R1, SIG_ED25519
}
use os.tls13.key_schedule.{
    tls13_compute_handshake_secrets, tls13_compute_app_secrets,
    tls13_finished_key, tls13_traffic_keys, tls13_verify_data,
    Tls13Secrets, TrafficKeys
}
use os.tls13.transcript.{Transcript, transcript_new, transcript_add, transcript_hash}
use os.tls13.record13.{RecordKey, RecordResult, record13_encrypt_for_suite, record13_decrypt_for_suite}
use os.crypto.curve25519.{x25519, x25519_base}
use os.crypto.ecdh_p256.{p256_ecdh_shared_x, p256_keypair_pub}
use os.crypto.random.{random_bytes}
use os.crypto.sha256.{sha256_hmac}
use std.nogc_sync_mut.io.signature_sffi.{ed25519_sign_pkcs8, ecdsa_p256_sign}

extern fn rt_tls13_recv_record(sock_fd: i64) -> [u8]
extern fn rt_net_send_bytes(sock_fd: i64, data: [u8]) -> i64

# ============================================================================
# Constants — TLS 1.3 cipher suites and named groups (RFC 8446 §B.4, §4.2.7)
# ============================================================================

val CIPHER_AES_128_GCM_SHA256: u16       = 0x1301
val CIPHER_AES_256_GCM_SHA384: u16       = 0x1302
val CIPHER_CHACHA20_POLY1305_SHA256: u16 = 0x1303

# HandshakeType bytes (local copies — handshake13 keeps the canonical defs).
val HS_SERVER_HELLO: u8         = 2
val HS_ENCRYPTED_EXTENSIONS: u8 = 8
val TLS_CONTENT_HANDSHAKE: u8   = 0x16
val TLS_MAX_RECORD_PAYLOAD: u64 = 18432

# ServerHello extension type bytes (RFC 8446 §4.2)
val EXT_SUPPORTED_VERSIONS: u16 = 43
val EXT_KEY_SHARE: u16          = 51

# RFC 8446 §4.4.3 signing context — repeated 0x20 byte (64 times) ||
# "TLS 1.3, server CertificateVerify" || 0x00 || transcript_hash. The
# string runs exactly 33 ASCII chars; we use the same construction the
# client uses in cert_verify.verify_certificate_verify_msg_scheme.

# ============================================================================
# Data classes
# ============================================================================

class ClientHello13:
    """Decoded ClientHello fields needed to drive the server flow.

    RFC 8446 §4.1.2 — fields populated only when present:
      - random: 32-byte ClientHello.random
      - cipher_suites: u16 list, in offered order
      - named_groups: u16 list (from supported_groups, ext 10), informational
      - key_share_groups: u16 list (groups for which CH carried a key_share)
      - x25519_key_share: 32-byte CH X25519 share, empty if absent
      - p256_key_share: 65-byte uncompressed CH P-256 share, empty if absent
      - sni_host: server_name from SNI ext, empty text if absent
      - has_supported_versions_tls13: true if 0x0304 was advertised
    """
    random: [u8]
    cipher_suites: [u16]
    named_groups: [u16]
    key_share_groups: [u16]
    x25519_key_share: [u8]
    p256_key_share: [u8]
    sni_host: text
    has_supported_versions_tls13: bool

class Tls13ClientHelloRecord:
    ch: ClientHello13
    handshake_msg: [u8]

class Tls13ServerConfig:
    """Minimum server-side configuration to drive the happy-path flow.

    Fields:
      - cert_chain: server certificate chain in DER, leaf first.
      - server_pkcs8: PKCS#8 v1 DER of the leaf signing key.
      - server_sig_scheme: SignatureScheme code (e.g. 0x0807 = ed25519,
        0x0403 = ecdsa_secp256r1_sha256). Must match cert leaf algorithm.
      - alpn_protocols: ALPN protocol list (informational; minimal EE
        builder leaves the extension list empty per §4.3.1 for now).
    """
    cert_chain: [[u8]]
    server_pkcs8: [u8]
    server_sig_scheme: u16
    alpn_protocols: [text]

class Tls13ServerContext:
    """Output of a successful tls13_accept.

    Mirrors the shape of Tls13Context on the client side; populated only
    once the full server-side record loop is wired (Wave 9+).
    """
    cipher_suite: u16
    named_group: u16
    server_random: [u8]
    server_keyshare_pub: [u8]
    client_app_key: [u8]
    client_app_iv: [u8]
    server_app_key: [u8]
    server_app_iv: [u8]
    client_seq: u64
    server_seq: u64

class Tls13ServerHandshakeMaterial:
    """Offline-prepared server-side handshake crypto material.

    Built only from an already-read ClientHello record plus an explicit server
    scalar. The live accept path sources fresh production entropy before using
    this shape on a socket, writes these records, and verifies client Finished.
    """
    cipher_suite: u16
    named_group: u16
    server_random: [u8]
    server_hello: [u8]
    server_keyshare_pub: [u8]
    shared_secret: [u8]
    handshake_secret: [u8]
    client_hs_traffic: [u8]
    server_hs_traffic: [u8]
    client_hs_key: [u8]
    client_hs_iv: [u8]
    server_hs_key: [u8]
    server_hs_iv: [u8]
    client_app_traffic: [u8]
    server_app_traffic: [u8]
    client_app_key: [u8]
    client_app_iv: [u8]
    server_app_key: [u8]
    server_app_iv: [u8]
    expected_client_finished: [u8]
    encrypted_extensions: [u8]
    certificate: [u8]
    certificate_verify: [u8]
    server_finished: [u8]
    server_hello_record: [u8]
    encrypted_extensions_record: [u8]
    certificate_record: [u8]
    certificate_verify_record: [u8]
    server_finished_record: [u8]

enum Tls13AcceptResult:
    Accepted(ctx: Tls13ServerContext)
    Failed(reason: text)

enum Tls13ServerHandshakeResult:
    Prepared(material: Tls13ServerHandshakeMaterial)
    Failed(reason: text)

# ============================================================================
# Private byte helpers (do not reach into handshake13 internals)
# ============================================================================

fn _u8_at(data: [u8], offset: u64) -> u8:
    if offset >= data.len():
        return 0u8
    data[offset]

fn _u16_be_at(data: [u8], offset: u64) -> u16:
    if offset + 2 > data.len():
        return 0u16
    ((_u8_at(data, offset).to_u16() << 8) | _u8_at(data, offset + 1).to_u16()).to_u16()

fn _put_u16_be(value: u16) -> [u8]:
    var out: [u8] = []
    out.push(((value.to_u32() >> 8) & 0xFF).to_u8())
    out.push((value.to_u32() & 0xFF).to_u8())
    out

fn _put_u24_be(value: u64) -> [u8]:
    var out: [u8] = []
    out.push(((value >> 16) & 0xFF).to_u8())
    out.push(((value >> 8) & 0xFF).to_u8())
    out.push((value & 0xFF).to_u8())
    out

fn _append(dst: [u8], src: [u8]) -> [u8]:
    var i: u64 = 0
    while i < src.len():
        dst.push(src[i])
        i = i + 1
    dst

fn _slice(data: [u8], offset: u64, length: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < length and offset + i < data.len():
        out.push(data[offset + i])
        i = i + 1
    out

fn _ct_bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var acc: u8 = 0u8
    var i: u64 = 0
    while i < a.len():
        acc = acc | (_u8_at(a, i) ^ _u8_at(b, i))
        i = i + 1
    acc == 0u8

fn _u24_be_at(data: [u8], offset: u64) -> u64:
    if offset + 3 > data.len():
        return 0u64
    (_u8_at(data, offset).to_u64() << 16) |
        (_u8_at(data, offset + 1u64).to_u64() << 8) |
        _u8_at(data, offset + 2u64).to_u64()

fn _validate_server_config(server_config: Tls13ServerConfig) -> text:
    if server_config.cert_chain.len() == 0:
        return "missing_certificate_chain"
    if server_config.server_pkcs8.len() == 0:
        return "missing_server_private_key"
    if server_config.server_sig_scheme == 0u16:
        return "missing_signature_scheme"
    ""

fn _record_payload(raw_record: [u8]) -> Result<[u8], text>:
    if raw_record.len() < 5u64:
        return Err("no_client_hello_record")
    if _u8_at(raw_record, 0u64) != TLS_CONTENT_HANDSHAKE:
        return Err("expected_handshake_record")
    if _u8_at(raw_record, 1u64) != 0x03u8:
        return Err("unsupported_record_version")

    val payload_len = (_u8_at(raw_record, 3u64).to_u64() << 8) |
        _u8_at(raw_record, 4u64).to_u64()
    if payload_len == 0u64 or payload_len > TLS_MAX_RECORD_PAYLOAD:
        return Err("invalid_record_length")
    if raw_record.len() != 5u64 + payload_len:
        return Err("incomplete_client_hello_record")
    Ok(_slice(raw_record, 5u64, payload_len))

fn _build_tls13_plaintext_record(content_type: u8, payload: [u8]) -> [u8]:
    var rec: [u8] = []
    rec.push(content_type)
    rec.push(0x03u8)
    rec.push(0x03u8)
    rec.push(((payload.len().to_u64() >> 8) & 0xFF).to_u8())
    rec.push((payload.len().to_u64() & 0xFF).to_u8())
    var i: u64 = 0
    while i < payload.len():
        rec.push(_u8_at(payload, i))
        i = i + 1u64
    rec

fn _send_all_record(socket_fd: i64, record: [u8]) -> bool:
    if record.len() == 0u64:
        return false
    var sent: u64 = 0
    var zero_writes: u64 = 0
    while sent < record.len():
        val remaining = _slice(record, sent, record.len() - sent)
        val wrote_i = rt_net_send_bytes(socket_fd, remaining)
        if wrote_i < 0:
            return false
        val wrote = wrote_i.to_u64()
        if wrote == 0u64:
            zero_writes = zero_writes + 1u64
            if zero_writes > 1024u64:
                return false
        else:
            zero_writes = 0u64
            if wrote > remaining.len():
                sent = record.len()
            else:
                sent = sent + wrote
    true

fn _send_server_flight(socket_fd: i64, material: Tls13ServerHandshakeMaterial) -> text:
    if not _send_all_record(socket_fd, material.server_hello_record):
        return "server_hello_send_failed"
    if not _send_all_record(socket_fd, material.encrypted_extensions_record):
        return "encrypted_extensions_send_failed"
    if not _send_all_record(socket_fd, material.certificate_record):
        return "certificate_send_failed"
    if not _send_all_record(socket_fd, material.certificate_verify_record):
        return "certificate_verify_send_failed"
    if not _send_all_record(socket_fd, material.server_finished_record):
        return "server_finished_send_failed"
    ""

fn _accepted_context(material: Tls13ServerHandshakeMaterial) -> Tls13ServerContext:
    Tls13ServerContext(
        cipher_suite: material.cipher_suite,
        named_group: material.named_group,
        server_random: material.server_random,
        server_keyshare_pub: material.server_keyshare_pub,
        client_app_key: material.client_app_key,
        client_app_iv: material.client_app_iv,
        server_app_key: material.server_app_key,
        server_app_iv: material.server_app_iv,
        client_seq: 0u64,
        server_seq: 0u64
    )

fn _verify_client_finished_record(material: Tls13ServerHandshakeMaterial, raw_record: [u8]) -> Tls13AcceptResult:
    if raw_record.len() == 0u64:
        return Tls13AcceptResult.Failed("missing_client_finished")
    val client_rk = RecordKey(key: material.client_hs_key, iv: material.client_hs_iv)
    match record13_decrypt_for_suite(material.cipher_suite, client_rk, 0u64, raw_record):
        case RecordResult.Err(msg):
            Tls13AcceptResult.Failed("client_finished_decrypt_failed")
        case RecordResult.Ok(content_type, data):
            if content_type != TLS_CONTENT_HANDSHAKE.to_i64():
                return Tls13AcceptResult.Failed("client_finished_not_handshake")
            val parsed = parse_handshake_header(data)
            if parsed.msg_type != 20u8:
                return Tls13AcceptResult.Failed("client_finished_unexpected_message")
            val verify_data = parse_finished_body(parsed.body)
            if not _ct_bytes_equal(verify_data, material.expected_client_finished):
                return Tls13AcceptResult.Failed("client_finished_verify_failed")
            Tls13AcceptResult.Accepted(_accepted_context(material))

fn _empty_ch() -> ClientHello13:
    ClientHello13(
        random: [],
        cipher_suites: [],
        named_groups: [],
        key_share_groups: [],
        x25519_key_share: [],
        p256_key_share: [],
        sni_host: "",
        has_supported_versions_tls13: false
    )

fn _u16_list_contains(xs: [u16], v: u16) -> bool:
    var i: u64 = 0
    while i < xs.len():
        if xs[i] == v:
            return true
        i = i + 1
    false

# ============================================================================
# Public: process_client_hello — RFC 8446 §4.1.2
# ============================================================================

fn process_client_hello(body: [u8]) -> ClientHello13:
    """Parse a ClientHello body (i.e. `parse_handshake_header(...).body`).

    Wire format (RFC 8446 §4.1.2):
      legacy_version(2) + random(32) +
      legacy_session_id_len(1) + legacy_session_id(<=32) +
      cipher_suites_len(2) + cipher_suites +
      legacy_compression_methods_len(1) + legacy_compression_methods +
      extensions_len(2) + extensions

    Returns an empty ClientHello13 if the body is malformed; the caller
    is expected to detect this via `random.len() == 0`.
    """
    if body.len() < 39:
        return _empty_ch()

    # legacy_version (2 bytes) is at offset 0; we accept 0x0303 only.
    if _u8_at(body, 0) != 0x03u8 or _u8_at(body, 1) != 0x03u8:
        return _empty_ch()

    # random (32 bytes) at offset 2..34
    var random: [u8] = _slice(body, 2u64, 32u64)

    # legacy_session_id at offset 34
    val sid_len = _u8_at(body, 34u64).to_u64()
    if sid_len > 32u64:
        return _empty_ch()
    var off: u64 = 35u64 + sid_len

    # cipher_suites
    if off + 2 > body.len():
        return _empty_ch()
    val cs_len = _u16_be_at(body, off).to_u64()
    off = off + 2u64
    if off + cs_len > body.len() or (cs_len & 1u64) != 0u64:
        return _empty_ch()
    var cipher_suites: [u16] = []
    var ci: u64 = 0
    while ci < cs_len:
        cipher_suites.push(_u16_be_at(body, off + ci))
        ci = ci + 2u64
    off = off + cs_len

    # legacy_compression_methods
    if off + 1 > body.len():
        return _empty_ch()
    val cm_len = _u8_at(body, off).to_u64()
    off = off + 1u64 + cm_len
    if off > body.len():
        return _empty_ch()

    # extensions
    if off + 2 > body.len():
        return _empty_ch()
    val ext_total = _u16_be_at(body, off).to_u64()
    off = off + 2u64
    val ext_end = off + ext_total
    if ext_end > body.len():
        return _empty_ch()

    var named_groups: [u16] = []
    var ks_groups: [u16] = []
    var x25519_share: [u8] = []
    var p256_share: [u8] = []
    var sni: text = ""
    var has_tls13 = false

    while off + 4 <= ext_end:
        val ext_type = _u16_be_at(body, off)
        off = off + 2u64
        val ext_len = _u16_be_at(body, off).to_u64()
        off = off + 2u64
        if off + ext_len > ext_end:
            return _empty_ch()
        val ext_end_inner = off + ext_len

        if ext_type == 10u16:
            # supported_groups: 2-byte list_len + u16 entries
            if ext_len >= 2u64:
                val gl = _u16_be_at(body, off).to_u64()
                var gp = off + 2u64
                while gp + 2 <= off + 2u64 + gl and gp + 2 <= ext_end_inner:
                    named_groups.push(_u16_be_at(body, gp))
                    gp = gp + 2u64

        if ext_type == 43u16:
            # supported_versions: 1-byte list_len + u16 entries
            if ext_len >= 1u64:
                val vl = _u8_at(body, off).to_u64()
                var vp = off + 1u64
                while vp + 2 <= off + 1u64 + vl and vp + 2 <= ext_end_inner:
                    if _u16_be_at(body, vp) == 0x0304u16:
                        has_tls13 = true
                    vp = vp + 2u64

        if ext_type == 51u16:
            # key_share (CH): 2-byte client_shares_len + entries of {group(2), key_len(2), key}
            if ext_len >= 2u64:
                val ksl = _u16_be_at(body, off).to_u64()
                var kp = off + 2u64
                val ks_end = kp + ksl
                while kp + 4 <= ks_end and kp + 4 <= ext_end_inner:
                    val grp = _u16_be_at(body, kp)
                    val klen = _u16_be_at(body, kp + 2u64).to_u64()
                    val key_start = kp + 4u64
                    if key_start + klen > ks_end:
                        return _empty_ch()
                    # Only register a group as "key_share-offered" when the
                    # advertised key length matches the named-group spec
                    # (RFC 8446 §4.2.8). Otherwise select_named_group could
                    # later return a group whose share is empty/invalid.
                    if grp == GROUP_X25519 and klen == 32u64:
                        x25519_share = _slice(body, key_start, klen)
                        ks_groups.push(grp)
                    elif grp == GROUP_SECP256R1 and klen == 65u64:
                        p256_share = _slice(body, key_start, klen)
                        ks_groups.push(grp)
                    kp = key_start + klen

        if ext_type == 0u16:
            # server_name: list_len(2) + (name_type(1) + name_len(2) + name)*
            if ext_len >= 5u64:
                var sp = off + 2u64
                if _u8_at(body, sp) == 0u8:
                    val nl = _u16_be_at(body, sp + 1u64).to_u64()
                    val name_start = sp + 3u64
                    if name_start + nl <= ext_end_inner:
                        var name_bytes: [u8] = _slice(body, name_start, nl)
                        # SNI is ASCII per RFC 6066; build a text accumulator.
                        var bi: u64 = 0
                        while bi < name_bytes.len():
                            sni = sni + name_bytes[bi].to_text()
                            bi = bi + 1u64

        off = ext_end_inner

    ClientHello13(
        random: random,
        cipher_suites: cipher_suites,
        named_groups: named_groups,
        key_share_groups: ks_groups,
        x25519_key_share: x25519_share,
        p256_key_share: p256_share,
        sni_host: sni,
        has_supported_versions_tls13: has_tls13
    )

# ============================================================================
# Public: select_cipher_suite — RFC 8446 §4.1.1 server preference
# ============================================================================

fn select_cipher_suite(client_suites: [u16], supported: [u16]) -> u16:
    """Pick the server's most-preferred suite that the client offered.

    Match-key on the three TLS 1.3 mandatory cipher suites:
      0x1301 TLS_AES_128_GCM_SHA256
      0x1302 TLS_AES_256_GCM_SHA384
      0x1303 TLS_CHACHA20_POLY1305_SHA256
    Returns 0u16 if no match.
    """
    var i: u64 = 0
    while i < supported.len():
        val s = supported[i]
        var j: u64 = 0
        while j < client_suites.len():
            if client_suites[j] == s:
                if s == CIPHER_AES_128_GCM_SHA256
                   or s == CIPHER_AES_256_GCM_SHA384
                   or s == CIPHER_CHACHA20_POLY1305_SHA256:
                    return s
            j = j + 1u64
        i = i + 1u64
    0u16

# ============================================================================
# Public: select_named_group — RFC 8446 §4.2.7 / §4.2.8 server preference
# ============================================================================

fn select_named_group(client_key_share_groups: [u16], supported: [u16]) -> u16:
    """Pick the server's most-preferred group present in CH key_shares.

    `client_key_share_groups` is the list of groups for which the CH
    actually carried a key_share entry — only those allow a single-flight
    ServerHello (no HRR). Returns 0u16 if no overlap exists; the caller
    should treat that as "HRR-needed", which we don't yet implement.
    """
    var i: u64 = 0
    while i < supported.len():
        val g = supported[i]
        if g == GROUP_X25519 or g == GROUP_SECP256R1:
            if _u16_list_contains(client_key_share_groups, g):
                return g
        i = i + 1u64
    0u16

# ============================================================================
# Public: build_server_hello — RFC 8446 §4.1.3
# ============================================================================

fn _build_sh_ext_supported_versions() -> [u8]:
    """ServerHello supported_versions: TLS 1.3 single u16 (no list_len)."""
    var out: [u8] = []
    out = _append(out, _put_u16_be(EXT_SUPPORTED_VERSIONS))
    out = _append(out, _put_u16_be(2u16))
    out = _append(out, _put_u16_be(0x0304u16))
    out

fn _build_sh_ext_key_share(group: u16, key: [u8]) -> [u8]:
    """ServerHello key_share: single KeyShareEntry (group(2) + key_len(2) + key)."""
    var entry: [u8] = []
    entry = _append(entry, _put_u16_be(group))
    entry = _append(entry, _put_u16_be(key.len().to_u16()))
    entry = _append(entry, key)
    var out: [u8] = []
    out = _append(out, _put_u16_be(EXT_KEY_SHARE))
    out = _append(out, _put_u16_be(entry.len().to_u16()))
    out = _append(out, entry)
    out

fn build_server_hello(
    server_random: [u8],
    cipher_suite: u16,
    named_group: u16,
    server_keyshare: [u8]
) -> [u8]:
    """Build a TLS 1.3 ServerHello handshake message (with handshake header).

    Wire format (RFC 8446 §4.1.3):
      HandshakeType(1)=2 + length(3) + legacy_version(2)=0x0303 +
      random(32) + legacy_session_id_len(1)=0 +
      cipher_suite(2) + legacy_compression_method(1)=0x00 +
      extensions_len(2) + extensions(supported_versions, key_share)
    """
    # Body
    var body: [u8] = []
    body.push(0x03u8)
    body.push(0x03u8)
    body = _append(body, server_random)
    body.push(0x00u8)
    body = _append(body, _put_u16_be(cipher_suite))
    body.push(0x00u8)

    var exts: [u8] = []
    exts = _append(exts, _build_sh_ext_supported_versions())
    exts = _append(exts, _build_sh_ext_key_share(named_group, server_keyshare))
    body = _append(body, _put_u16_be(exts.len().to_u16()))
    body = _append(body, exts)

    # Wrap with handshake header (type + 3-byte length).
    var out: [u8] = []
    out.push(HS_SERVER_HELLO)
    out = _append(out, _put_u24_be(body.len().to_u64()))
    out = _append(out, body)
    out

# ============================================================================
# Public: build_encrypted_extensions_server_side — RFC 8446 §4.3.1
# ============================================================================

fn build_encrypted_extensions_server_side(server_config: Tls13ServerConfig) -> [u8]:
    """Build a minimal EncryptedExtensions handshake message.

    Wire format (RFC 8446 §4.3.1):
      HandshakeType(1)=8 + length(3) + extensions_len(2) + extensions

    An empty extension list (extensions_len = 0) is valid per §4.3.1; a
    server-side EE may omit any optional extensions. We currently always
    emit an empty list; ALPN/SNI ack/etc. land with the I/O wiring.
    """
    var body: [u8] = []
    body = _append(body, _put_u16_be(0u16))
    var out: [u8] = []
    out.push(HS_ENCRYPTED_EXTENSIONS)
    out = _append(out, _put_u24_be(body.len().to_u64()))
    out = _append(out, body)
    out

# ============================================================================
# Public: build_certificate — RFC 8446 §4.4.2 (delegated to handshake13)
# ============================================================================

fn build_certificate(cert_chain: [[u8]]) -> [u8]:
    """Build the Certificate handshake message for a server-side flow.

    request_context MUST be empty for a non-mTLS server (RFC 8446 §4.4.2).
    """
    var body: [u8] = []
    body.push(0x00u8)

    var cert_list: [u8] = []
    var cert_idx: u64 = 0
    while cert_idx < cert_chain.len():
        val cert_der = cert_chain[cert_idx]
        cert_list = _append(cert_list, _put_u24_be(cert_der.len().to_u64()))
        cert_list = _append(cert_list, cert_der)
        cert_list.push(0x00u8)
        cert_list.push(0x00u8)
        cert_idx = cert_idx + 1

    body = _append(body, _put_u24_be(cert_list.len().to_u64()))
    body = _append(body, cert_list)

    var out: [u8] = []
    out.push(HS_CERTIFICATE)
    out = _append(out, _put_u24_be(body.len().to_u64()))
    out = _append(out, body)
    out

# ============================================================================
# Public: build_certificate_verify — RFC 8446 §4.4.3
# ============================================================================

fn _signing_context_server() -> [u8]:
    """Return the 64x0x20 || "TLS 1.3, server CertificateVerify" || 0x00 prefix."""
    var ctx: [u8] = []
    var i: u64 = 0
    while i < 64u64:
        ctx.push(0x20u8)
        i = i + 1u64
    # "TLS 1.3, server CertificateVerify" — 33 ASCII bytes.
    ctx.push(0x54u8)  # T
    ctx.push(0x4Cu8)  # L
    ctx.push(0x53u8)  # S
    ctx.push(0x20u8)  # space
    ctx.push(0x31u8)  # 1
    ctx.push(0x2Eu8)  # .
    ctx.push(0x33u8)  # 3
    ctx.push(0x2Cu8)  # ,
    ctx.push(0x20u8)  # space
    ctx.push(0x73u8)  # s
    ctx.push(0x65u8)  # e
    ctx.push(0x72u8)  # r
    ctx.push(0x76u8)  # v
    ctx.push(0x65u8)  # e
    ctx.push(0x72u8)  # r
    ctx.push(0x20u8)  # space
    ctx.push(0x43u8)  # C
    ctx.push(0x65u8)  # e
    ctx.push(0x72u8)  # r
    ctx.push(0x74u8)  # t
    ctx.push(0x69u8)  # i
    ctx.push(0x66u8)  # f
    ctx.push(0x69u8)  # i
    ctx.push(0x63u8)  # c
    ctx.push(0x61u8)  # a
    ctx.push(0x74u8)  # t
    ctx.push(0x65u8)  # e
    ctx.push(0x56u8)  # V
    ctx.push(0x65u8)  # e
    ctx.push(0x72u8)  # r
    ctx.push(0x69u8)  # i
    ctx.push(0x66u8)  # f
    ctx.push(0x79u8)  # y
    ctx.push(0x00u8)  # separator
    ctx

fn build_certificate_verify_signing_input(transcript_hash: [u8]) -> [u8]:
    """Build the message to feed the signature primitive (RFC 8446 §4.4.3)."""
    var msg: [u8] = _signing_context_server()
    msg = _append(msg, transcript_hash)
    msg

fn build_certificate_verify(transcript_hash: [u8], server_signing_key_pkcs8: [u8], sig_scheme: u16) -> [u8]:
    """Build a TLS 1.3 server-side CertificateVerify handshake message.

    Args:
        transcript_hash: Hash(CH || SH || EE || Certificate) in the negotiated
            hash (32 bytes for SHA-256, 48 for SHA-384).
        server_signing_key_pkcs8: PKCS#8 v1 DER of the server's signing key.
        sig_scheme: SignatureScheme code (e.g. 0x0807, 0x0403).

    Returns: complete handshake-layer CertificateVerify bytes.
    """
    val signing_input = build_certificate_verify_signing_input(transcript_hash)
    var sig: [u8] = []
    if sig_scheme == SIG_ED25519:
        sig = ed25519_sign_pkcs8(server_signing_key_pkcs8, signing_input)
        if sig.len() == 0:
            sig = ed25519_sign_pkcs8(server_signing_key_pkcs8, signing_input)
    elif sig_scheme == 0x0403u16:
        sig = ecdsa_p256_sign(server_signing_key_pkcs8, signing_input)
    else:
        # Unsupported scheme — return empty signature wrapped in CV. The
        # caller is expected to validate against the cert leaf algorithm
        # before invoking.
        sig = []
    var body: [u8] = []
    body = _append(body, _put_u16_be(sig_scheme))
    body = _append(body, _put_u16_be(sig.len() as u16))
    body = _append(body, sig)

    var out: [u8] = []
    out.push(HS_CERTIFICATE_VERIFY)
    out = _append(out, _put_u24_be(body.len().to_u64()))
    out = _append(out, body)
    out

# ============================================================================
# Public: build_server_finished — RFC 8446 §4.4.4
# ============================================================================

fn build_server_finished(server_finished_key: [u8], transcript_hash: [u8]) -> [u8]:
    """Build a TLS 1.3 server Finished handshake message.

    verify_data = HMAC-SHA-256(server_finished_key, transcript_hash) for
    SHA-256-based suites. SHA-384 path lives in key_schedule and is
    delegated by the caller — this server skeleton runs the SHA-256 path.

    Args:
        server_finished_key: Output of tls13_finished_key(server_hs_secret).
        transcript_hash: Hash(CH..server CV) or appropriate transcript prefix.

    Returns: complete handshake-layer Finished message bytes.
    """
    val verify_data = _server_verify_data_sha256(server_finished_key, transcript_hash)
    build_finished_bytes(verify_data)

fn _server_verify_data_sha256(finished_key: [u8], transcript_hash: [u8]) -> [u8]:
    """SHA-256 Finished verify_data without relying on a socket-runtime extern."""
    _slice(sha256_hmac(finished_key, transcript_hash), 0u64, 32u64)

# ============================================================================
# Public: server handshake crypto preparation
# ============================================================================

fn _validate_client_hello_record(raw_record: [u8]) -> Result<Tls13ClientHelloRecord, text>:
    val payload_result = _record_payload(raw_record)
    if payload_result.is_err():
        return Err(payload_result.err().unwrap())
    val payload = payload_result.unwrap()

    if payload.len() < 4u64:
        return Err("malformed_client_hello")
    val declared_len = _u24_be_at(payload, 1u64)
    if declared_len != payload.len() - 4u64:
        return Err("malformed_client_hello")

    val parsed = parse_handshake_header(payload)
    if parsed.msg_type != HS_CLIENT_HELLO:
        return Err("expected_client_hello")

    val ch = process_client_hello(parsed.body)
    if ch.random.len() == 0:
        return Err("malformed_client_hello")
    if not ch.has_supported_versions_tls13:
        return Err("not_tls13")
    Ok(Tls13ClientHelloRecord(ch: ch, handshake_msg: payload))

fn _server_random_from_client_random(ch: ClientHello13) -> [u8]:
    """Deterministic test-only random surrogate.

    Live TLS must replace this with fresh random_bytes before sending a
    production ServerHello. The helper is kept local to the explicit
    `*_for_test` preparation path.
    """
    var out: [u8] = []
    var i: u64 = 0
    while i < 32u64:
        out.push(_u8_at(ch.random, i) ^ 0xA5u8)
        i = i + 1u64
    out

fn _prepare_server_handshake_from_client_hello_record(
    ch_pair: Tls13ClientHelloRecord,
    server_config: Tls13ServerConfig,
    server_random: [u8],
    server_scalar: [u8]
) -> Tls13ServerHandshakeResult:
    val config_error = _validate_server_config(server_config)
    if config_error != "":
        return Tls13ServerHandshakeResult.Failed(config_error)
    if server_random.len() != 32u64:
        return Tls13ServerHandshakeResult.Failed("invalid_server_random")
    if server_scalar.len() != 32u64:
        return Tls13ServerHandshakeResult.Failed("invalid_server_scalar")

    val ch = ch_pair.ch
    val ch_msg = ch_pair.handshake_msg

    val cipher = select_cipher_suite(ch.cipher_suites, [
        CIPHER_AES_128_GCM_SHA256,
        CIPHER_AES_256_GCM_SHA384,
        CIPHER_CHACHA20_POLY1305_SHA256
    ])
    if cipher == 0u16:
        return Tls13ServerHandshakeResult.Failed("no_shared_cipher_suite")

    val group = select_named_group(ch.key_share_groups, [GROUP_X25519, GROUP_SECP256R1])
    if group == 0u16:
        return Tls13ServerHandshakeResult.Failed("hrr_not_implemented_server_side")

    var server_pub: [u8] = []
    var shared_secret: [u8] = []
    if group == GROUP_X25519:
        server_pub = x25519_base(server_scalar)
        shared_secret = x25519(server_scalar, ch.x25519_key_share)
    elif group == GROUP_SECP256R1:
        server_pub = p256_keypair_pub(server_scalar)
        shared_secret = p256_ecdh_shared_x(server_scalar, ch.p256_key_share)
    else:
        return Tls13ServerHandshakeResult.Failed("unsupported_named_group")

    if server_pub.len() == 0u64 or shared_secret.len() != 32u64:
        return Tls13ServerHandshakeResult.Failed("server_key_exchange_failed")

    val sh = build_server_hello(server_random, cipher, group, server_pub)
    var transcript = transcript_new()
    transcript = transcript_add(transcript, ch_msg)
    transcript = transcript_add(transcript, sh)

    val secrets = tls13_compute_handshake_secrets(shared_secret, transcript)
    val client_tk = tls13_traffic_keys(secrets.client_hs_traffic)
    val server_tk = tls13_traffic_keys(secrets.server_hs_traffic)
    val server_rk = RecordKey(key: server_tk.key, iv: server_tk.iv)

    val ee = build_encrypted_extensions_server_side(server_config)
    transcript = transcript_add(transcript, ee)

    val cert = build_certificate(server_config.cert_chain)
    transcript = transcript_add(transcript, cert)

    val cv_hash = transcript_hash(transcript)
    val cv = build_certificate_verify(
        cv_hash,
        server_config.server_pkcs8,
        server_config.server_sig_scheme
    )
    if cv.len() == 0u64:
        return Tls13ServerHandshakeResult.Failed("certificate_verify_failed")
    transcript = transcript_add(transcript, cv)

    val fin_hash = transcript_hash(transcript)
    val fin = build_server_finished(tls13_finished_key(secrets.server_hs_traffic), fin_hash)
    if fin.len() == 0u64:
        return Tls13ServerHandshakeResult.Failed("server_finished_failed")
    transcript = transcript_add(transcript, fin)

    val client_finished_key = tls13_finished_key(secrets.client_hs_traffic)
    val expected_client_finished = tls13_verify_data(client_finished_key, transcript)
    val app_secrets = tls13_compute_app_secrets(secrets, transcript)
    val client_app_tk = tls13_traffic_keys(app_secrets.client_app_traffic)
    val server_app_tk = tls13_traffic_keys(app_secrets.server_app_traffic)
    if expected_client_finished.len() != 32u64 or client_app_tk.key.len() == 0u64 or server_app_tk.key.len() == 0u64:
        return Tls13ServerHandshakeResult.Failed("application_secret_derivation_failed")

    val sh_record = _build_tls13_plaintext_record(TLS_CONTENT_HANDSHAKE, sh)
    val ee_record = record13_encrypt_for_suite(cipher, server_rk, 0u64, TLS_CONTENT_HANDSHAKE, ee)
    val cert_record = record13_encrypt_for_suite(cipher, server_rk, 1u64, TLS_CONTENT_HANDSHAKE, cert)
    val cv_record = record13_encrypt_for_suite(cipher, server_rk, 2u64, TLS_CONTENT_HANDSHAKE, cv)
    val fin_record = record13_encrypt_for_suite(cipher, server_rk, 3u64, TLS_CONTENT_HANDSHAKE, fin)
    if sh_record.len() == 0u64 or ee_record.len() == 0u64 or cert_record.len() == 0u64 or cv_record.len() == 0u64 or fin_record.len() == 0u64:
        return Tls13ServerHandshakeResult.Failed("server_flight_record_failed")

    Tls13ServerHandshakeResult.Prepared(Tls13ServerHandshakeMaterial(
        cipher_suite: cipher,
        named_group: group,
        server_random: server_random,
        server_hello: sh,
        server_keyshare_pub: server_pub,
        shared_secret: shared_secret,
        handshake_secret: secrets.handshake_secret,
        client_hs_traffic: secrets.client_hs_traffic,
        server_hs_traffic: secrets.server_hs_traffic,
        client_hs_key: client_tk.key,
        client_hs_iv: client_tk.iv,
        server_hs_key: server_tk.key,
        server_hs_iv: server_tk.iv,
        client_app_traffic: app_secrets.client_app_traffic,
        server_app_traffic: app_secrets.server_app_traffic,
        client_app_key: client_app_tk.key,
        client_app_iv: client_app_tk.iv,
        server_app_key: server_app_tk.key,
        server_app_iv: server_app_tk.iv,
        expected_client_finished: expected_client_finished,
        encrypted_extensions: ee,
        certificate: cert,
        certificate_verify: cv,
        server_finished: fin,
        server_hello_record: sh_record,
        encrypted_extensions_record: ee_record,
        certificate_record: cert_record,
        certificate_verify_record: cv_record,
        server_finished_record: fin_record
    ))

fn tls13_prepare_server_handshake_from_record_for_test(
    raw_record: [u8],
    server_config: Tls13ServerConfig,
    server_scalar: [u8]
) -> Tls13ServerHandshakeResult:
    """Prepare deterministic test-only server handshake material.

    This closes the offline server-crypto slice after ClientHello validation:
    select cipher/group, compute the server key share, derive the shared secret,
    build ServerHello, derive client/server handshake traffic keys, and build
    encrypted server EE/Certificate/CertificateVerify/Finished records. It does
    not read client Finished or return Accepted. Live accept uses fresh random
    bytes instead of the deterministic server-random surrogate.
    """
    val ch_result = _validate_client_hello_record(raw_record)
    if ch_result.is_err():
        return Tls13ServerHandshakeResult.Failed(ch_result.err().unwrap())
    val ch_pair = ch_result.unwrap()
    _prepare_server_handshake_from_client_hello_record(
        ch_pair,
        server_config,
        _server_random_from_client_random(ch_pair.ch),
        server_scalar
    )

fn tls13_accept_client_hello_record_with_server_material_for_test(
    raw_record: [u8],
    server_config: Tls13ServerConfig,
    server_random: [u8],
    server_scalar: [u8]
) -> Tls13AcceptResult:
    """Run the accept path through server crypto prep with explicit material."""
    val ch_result = _validate_client_hello_record(raw_record)
    if ch_result.is_err():
        return Tls13AcceptResult.Failed(ch_result.err().unwrap())
    val prep = _prepare_server_handshake_from_client_hello_record(
        ch_result.unwrap(),
        server_config,
        server_random,
        server_scalar
    )
    match prep:
        case Tls13ServerHandshakeResult.Failed(reason):
            Tls13AcceptResult.Failed(reason)
        case Tls13ServerHandshakeResult.Prepared(_material):
            Tls13AcceptResult.Failed("client_finished_pending")

fn tls13_accept_client_finished_record_for_test(
    material: Tls13ServerHandshakeMaterial,
    client_finished_record: [u8]
) -> Tls13AcceptResult:
    """Verify an encrypted client Finished record against prepared material."""
    _verify_client_finished_record(material, client_finished_record)

# ============================================================================
# Public: tls13_accept — top-level entry stub
# ============================================================================

fn tls13_accept(socket_fd: i64, server_config: Tls13ServerConfig) -> Tls13AcceptResult:
    """Top-level server-side handshake entry point.

    Validates server prerequisites before entering the socket record path.
    The byte-level builders + selectors below are exercised standalone. The
    server now writes SH+EE+Cert+CV+Finished, reads client Finished, verifies
    it, and returns application record keys.

    Documented behaviour for the full flow:
      1. Read ClientHello record from `socket_fd`.
      2. process_client_hello -> ClientHello13.
      3. If !ch.has_supported_versions_tls13 → Failed("not_tls13").
      4. cipher = select_cipher_suite(ch.cipher_suites, [0x1301,0x1302,0x1303])
         -> Failed("no_shared_cipher_suite") if 0.
      5. group  = select_named_group(ch.key_share_groups, [X25519, P256])
         -> Failed("hrr_not_implemented_server_side") if 0.
      6. Generate server keyshare for `group` and ECDH-derive shared secret.
      7. build_server_hello + send.
      8. Derive handshake secrets, switch record layer to encrypted.
      9. send build_encrypted_extensions_server_side, build_certificate,
         build_certificate_verify, build_server_finished.
     10. Read client Finished, verify, derive app secrets, return Accepted.
    """
    if socket_fd < 0:
        return Tls13AcceptResult.Failed("invalid_socket_fd")
    val config_error = _validate_server_config(server_config)
    if config_error != "":
        return Tls13AcceptResult.Failed(config_error)

    val ch_record = rt_tls13_recv_record(socket_fd)
    val ch_result = _validate_client_hello_record(ch_record)
    if ch_result.is_err():
        return Tls13AcceptResult.Failed(ch_result.err().unwrap())
    val prep = _prepare_server_handshake_from_client_hello_record(
        ch_result.unwrap(),
        server_config,
        random_bytes(32u64),
        random_bytes(32u64)
    )
    match prep:
        case Tls13ServerHandshakeResult.Failed(reason):
            Tls13AcceptResult.Failed(reason)
        case Tls13ServerHandshakeResult.Prepared(material):
            val send_error = _send_server_flight(socket_fd, material)
            if send_error != "":
                return Tls13AcceptResult.Failed(send_error)
            val client_finished_record = rt_tls13_recv_record(socket_fd)
            _verify_client_finished_record(material, client_finished_record)

fn tls13_accept_client_hello_record_for_test(raw_record: [u8], server_config: Tls13ServerConfig) -> Tls13AcceptResult:
    """Validate the first plaintext ClientHello record for the server path.

    This is the record-I/O core used by tls13_accept after reading from the
    socket. It intentionally stops before key generation and encrypted flight
    writing, which remain the next server-side TLS production step.
    """
    val config_error = _validate_server_config(server_config)
    if config_error != "":
        return Tls13AcceptResult.Failed(config_error)

    val ch_result = _validate_client_hello_record(raw_record)
    if ch_result.is_err():
        return Tls13AcceptResult.Failed(ch_result.err().unwrap())
    val ch = ch_result.unwrap().ch

    val cipher = select_cipher_suite(ch.cipher_suites, [
        CIPHER_AES_128_GCM_SHA256,
        CIPHER_AES_256_GCM_SHA384,
        CIPHER_CHACHA20_POLY1305_SHA256
    ])
    if cipher == 0u16:
        return Tls13AcceptResult.Failed("no_shared_cipher_suite")

    val group = select_named_group(ch.key_share_groups, [GROUP_X25519, GROUP_SECP256R1])
    if group == 0u16:
        return Tls13AcceptResult.Failed("hrr_not_implemented_server_side")

    Tls13AcceptResult.Failed("server_crypto_pending")

# ============================================================================
# Helper used by tls13_accept and re-exported for tests: derive
# server_finished_key from a server_hs_secret. Thin wrapper so the spec
# can name `tls13_finished_key` from key_schedule directly.
# ============================================================================

fn server_finished_key(server_hs_secret: [u8]) -> [u8]:
    tls13_finished_key(server_hs_secret)
