"""TLS 1.3 KeyUpdate handshake message — RFC 8446 §4.6.3.

Provides:
  tls13_emit_key_update      — encode full KeyUpdate handshake message (5 bytes)
  tls13_parse_key_update     — decode full KeyUpdate message → request_update flag
  tls13_advance_traffic_secret — §7.2 application_traffic_secret_N+1

Wire format (RFC 8446 §4.6.3):
  struct {
      KeyUpdateRequest request_update;
  } KeyUpdate;

  enum { update_not_requested(0), update_requested(1), (255) } KeyUpdateRequest;

Full handshake envelope: type(0x18) + length(0x000001) + flag(0|1)
  = 5 bytes total.

NOTE: tls13_parse_key_update takes the FULL handshake message bytes (including
the 4-byte envelope header) so that tls13_emit_key_update(f) → tls13_parse_key_update
is a direct round-trip.

Integration into the connection state machine is a follow-up task.
"""

use os.tls13.hkdf.{hkdf_expand_label, hkdf_expand_label_sha384}

# ============================================================================
# Constants
# ============================================================================

# RFC 8446 §4.6.3: KeyUpdate handshake message type = 24 (0x18)
val HS_KEY_UPDATE: u8 = 24

# KeyUpdateRequest enum values
val KEY_UPDATE_NOT_REQUESTED: u8 = 0
val KEY_UPDATE_REQUESTED: u8     = 1

# ============================================================================
# Helpers (local — mirror handshake13.spl pattern)
# ============================================================================

fn _ku_u8_at(data: [u8], offset: u64) -> u8:
    # Use direct array indexing — rt_bytes_u8_at returns 0 for u8-literal-pushed bytes
    # in interpreter mode (interpreter bug; direct indexing is correct).
    data[offset]

fn _ku_u24_be(data: [u8], offset: u64) -> u64:
    (_ku_u8_at(data, offset).to_u64() << 16) |
        (_ku_u8_at(data, offset + 1).to_u64() << 8) |
        _ku_u8_at(data, offset + 2).to_u64()

fn _ku_copy_prefix(src: [u8], n: u64) -> [u8]:
    var out: [u8] = []
    val limit = if n < src.len().to_u64() { n } else { src.len().to_u64() }
    var i: u64 = 0
    while i < limit:
        out.push(src[i])
        i = i + 1
    out

# ============================================================================
# tls13_emit_key_update
# ============================================================================

fn tls13_emit_key_update(request_update: bool) -> [u8]:
    """Encode a KeyUpdate handshake message per RFC 8446 §4.6.3.

    Args:
        request_update: true → update_requested(1), false → update_not_requested(0).

    Returns: 5-byte handshake message: type(0x18) + length(0x000001) + flag.
    """
    val flag_val: i64 = if request_update { 1 } else { 0 }
    var out: [u8] = []
    out.push(0x18.to_u8())     # HS_KEY_UPDATE type
    out.push(0.to_u8())        # length high byte
    out.push(0.to_u8())        # length mid byte
    out.push(1.to_u8())        # length low byte (body = 1 byte)
    out.push(flag_val.to_u8()) # KeyUpdateRequest flag
    out

# ============================================================================
# tls13_parse_key_update
# ============================================================================

fn tls13_parse_key_update(bytes: [u8]) -> Result<bool, text>:
    """Decode a full KeyUpdate handshake message per RFC 8446 §4.6.3.

    Args:
        bytes: Full handshake message bytes including 4-byte envelope header.
               Must be exactly 5 bytes: type(0x18) + length(0x000001) + flag.

    Returns: Ok(true)  if flag == update_requested(1)
             Ok(false) if flag == update_not_requested(0)
             Err(reason) on any malformed input.
             RFC 8446 §4.6.3: any unknown flag value MUST be treated as
             illegal_parameter.
    """
    if bytes.len() != 5:
        return Err("KeyUpdate: expected 5 bytes, got {bytes.len()}")
    val msg_type = _ku_u8_at(bytes, 0)
    if msg_type != HS_KEY_UPDATE:
        return Err("KeyUpdate: wrong type byte {msg_type}, expected 24")
    val body_len = _ku_u24_be(bytes, 1)
    if body_len != 1:
        return Err("KeyUpdate: body length {body_len} != 1 (illegal_parameter)")
    val flag = _ku_u8_at(bytes, 4)
    if flag == KEY_UPDATE_NOT_REQUESTED:
        return Ok(false)
    if flag == KEY_UPDATE_REQUESTED:
        return Ok(true)
    Err("KeyUpdate: illegal_parameter flag={flag}, expected 0 or 1")

# ============================================================================
# tls13_advance_traffic_secret
# ============================================================================

fn tls13_advance_traffic_secret(prev_secret: [u8], hash_id: u8) -> [u8]:
    """Derive the next-generation application traffic secret per RFC 8446 §7.2.

    application_traffic_secret_N+1 =
        HKDF-Expand-Label(application_traffic_secret_N, "traffic upd", "", Hash.length)

    Args:
        prev_secret: application_traffic_secret_N (32 bytes for SHA-256, 48 for SHA-384).
        hash_id: 1=SHA-256 (32-byte secrets), 2=SHA-384 (48-byte secrets).
                 Matches codebase convention in key_schedule.spl.

    Returns: application_traffic_secret_N+1, same length as prev_secret.
    """
    val empty: [u8] = []
    if hash_id.to_u32() == 2u32:
        return _ku_copy_prefix(hkdf_expand_label_sha384(prev_secret, "traffic upd", empty, 48), 48)
    _ku_copy_prefix(hkdf_expand_label(prev_secret, "traffic upd", empty, 32), 32)
