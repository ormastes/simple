"""
# TLS Test Server SDN Configuration

Pure-Simple parser for the shared external TLS test-server config.

Supported SDN subset:

```sdn
server:
  listen: "127.0.0.1:4433"
  accept_count: 1
  require_client_auth: false
  fixture_dir: "tmp/tls_test_server"
  greeting: "Hello from rustls TLS 1.3"
```
"""

extern fn rt_file_read_text(path: text) -> text

class TlsTestServerConfig:
    listen: text
    accept_count: i64
    require_client_auth: bool
    fixture_dir: text
    greeting: text

fn tls_test_server_default_config() -> TlsTestServerConfig:
    TlsTestServerConfig(
        listen: "127.0.0.1:4433",
        accept_count: 1,
        require_client_auth: false,
        fixture_dir: "tmp/tls_test_server",
        greeting: "Hello from rustls TLS 1.3"
    )

fn load_tls_test_server_config(path: text) -> Result<TlsTestServerConfig, text>:
    var source = rt_file_read_text(path)
    match source:
        case Some(s):
            source = s
    if source == nil or source.trim() == "":
        return Err("Failed to read config: {path}")
    parse_tls_test_server_config_text(source)

fn parse_tls_test_server_config_text(source: text) -> Result<TlsTestServerConfig, text>:
    val server_block = _extract_block(source, "server")
    if not server_block.?:
        return Err("Missing 'server' block")

    var config = tls_test_server_default_config()
    val block = server_block.unwrap()

    val listen = _extract_scalar(block, "listen")
    if listen.?:
        config.listen = _unquote(listen.unwrap())

    val accept_count = _extract_scalar(block, "accept_count")
    if accept_count.?:
        val count_text = accept_count.unwrap()
        val n = count_text.to_int()
        if n <= 0:
            return Err("server.accept_count must be > 0")
        config.accept_count = n

    val require_client_auth = _extract_scalar(block, "require_client_auth")
    if require_client_auth.?:
        val raw = require_client_auth.unwrap().trim()
        if raw == "true":
            config.require_client_auth = true
        elif raw == "false":
            config.require_client_auth = false
        else:
            return Err("server.require_client_auth must be bool")

    val fixture_dir = _extract_scalar(block, "fixture_dir")
    if fixture_dir.?:
        config.fixture_dir = _unquote(fixture_dir.unwrap())

    val greeting = _extract_scalar(block, "greeting")
    if greeting.?:
        config.greeting = _unquote(greeting.unwrap())

    Ok(config)

fn _extract_block(source: text, key: text) -> text?:
    val lines = source.split("\n")
    val marker = "{key}:"
    var idx: i64 = 0
    while idx < lines.len():
        if lines[idx].trim() == marker:
            var out = ""
            var j = idx + 1
            while j < lines.len():
                val line = lines[j]
                if line.trim() == "":
                    j = j + 1
                    continue
                if not line.starts_with("  "):
                    return Some(out)
                out = out + line + "\n"
                j = j + 1
            return Some(out)
        idx = idx + 1
    nil

fn _extract_scalar(block: text, key: text) -> text?:
    val prefix = "{key}:"
    val lines = block.split("\n")
    var idx: i64 = 0
    while idx < lines.len():
        val trimmed = lines[idx].trim()
        if trimmed.starts_with(prefix):
            return Some(trimmed.slice(prefix.len().to_u64(), trimmed.len()).trim())
        idx = idx + 1
    nil

fn _unquote(value: text) -> text:
    val trimmed = value.trim()
    if trimmed.len() >= 2 and trimmed[0] == "\"" and trimmed[trimmed.len() - 1] == "\"":
        trimmed.slice(1, trimmed.len() - 1)
    else:
        trimmed
