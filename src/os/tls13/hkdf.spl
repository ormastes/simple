#![allow(unnamed_duplicate_typed_args)]
# HKDF (RFC 5869) with SHA-256 for TLS 1.3
#
# Implements:
#   hkdf_extract    — PRK = HMAC(salt, ikm)
#   hkdf_expand     — OKM via iterative HMAC chain
#   hkdf_expand_label — RFC 8446 §7.1 HkdfLabel encoding

extern fn rt_text_to_bytes(s: text) -> [u8]
extern fn rt_tls13_hkdf_extract(salt: [u8], ikm: [u8]) -> [u8]
extern fn rt_tls13_hkdf_extract_into(salt: [u8], ikm: [u8], out: [u8]) -> i64
extern fn rt_tls13_hkdf_expand_into(prk: [u8], info: [u8], out: [u8], length: i64) -> i64
extern fn rt_tls13_hkdf_expand_label(secret: [u8], label: [u8], context: [u8], length: i64) -> [u8]
extern fn rt_tls13_hkdf_expand_label_into(secret: [u8], label: [u8], context: [u8], out: [u8], length: i64) -> i64
extern fn rt_tls13_hkdf_expand_label_derived(secret: [u8], context: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label_key(secret: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label_iv(secret: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label_finished(secret: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label_client_hs(secret: [u8], context: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label_server_hs(secret: [u8], context: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label_client_app(secret: [u8], context: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label_server_app(secret: [u8], context: [u8]) -> [u8]
extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

use os.crypto.sha256.{sha256_hmac, sha256_hmac_with_len, sha256_hmac_from_list}

fn _text_to_bytes(s: text) -> [u8]:
    rt_text_to_bytes(s)

fn _label_bytes(label: text) -> [u8]:
    if label == "key":
        return [0x6bu8, 0x65u8, 0x79u8]
    if label == "iv":
        return [0x69u8, 0x76u8]
    if label == "finished":
        return [0x66u8, 0x69u8, 0x6eu8, 0x69u8, 0x73u8, 0x68u8, 0x65u8, 0x64u8]
    if label == "c hs traffic":
        return [0x63u8, 0x20u8, 0x68u8, 0x73u8, 0x20u8, 0x74u8, 0x72u8, 0x61u8, 0x66u8, 0x66u8, 0x69u8, 0x63u8]
    if label == "s hs traffic":
        return [0x73u8, 0x20u8, 0x68u8, 0x73u8, 0x20u8, 0x74u8, 0x72u8, 0x61u8, 0x66u8, 0x66u8, 0x69u8, 0x63u8]
    if label == "derived":
        return [0x64u8, 0x65u8, 0x72u8, 0x69u8, 0x76u8, 0x65u8, 0x64u8]
    return _text_to_bytes(label)

fn _label_len(label: text) -> u64:
    if label == "key":
        return 3
    if label == "iv":
        return 2
    if label == "finished":
        return 8
    if label == "c hs traffic":
        return 12
    if label == "s hs traffic":
        return 12
    if label == "derived":
        return 7
    return label.len().to_u64()

fn _copy_prefix(src: [u8], n: u64) -> [u8]:
    var out: [u8] = []
    val limit = if n < src.len().to_u64() { n } else { src.len().to_u64() }
    var copied: u64 = 0
    while copied < limit:
        out.push(rt_bytes_u8_at(src, copied.to_i64()).to_u8())
        copied = copied + 1
    out

# ============================================================================
# hkdf_extract
# ============================================================================

fn hkdf_extract(salt: [u8], ikm: [u8]) -> [u8]:
    """HKDF-Extract (RFC 5869 §2.2).

    PRK = HMAC-Hash(salt, IKM)

    If salt is empty, a string of HashLen zero bytes is used as salt.
    """
    hkdf_extract_with_len(salt, salt.len().to_u64(), ikm, ikm.len().to_u64())

fn hkdf_extract_with_len(salt: [u8], salt_len: u64, ikm: [u8], ikm_len: u64) -> [u8]:
    if salt_len == 0:
        var effective_salt: [u8] = []
        var i: u64 = 0
        while i < 32:
            effective_salt.push(0x00)
            i = i + 1
        if ikm_len == ikm.len().to_u64():
            var out: [u8] = []
            i = 0
            while i < 32:
                out.push(0x00)
                i = i + 1
            if rt_tls13_hkdf_extract_into(effective_salt, ikm, out) != 0:
                return out
        val out = sha256_hmac_with_len(effective_salt, 32, ikm, ikm_len)
        return _copy_prefix(out, 32)
    else:
        if salt_len == salt.len().to_u64() and ikm_len == ikm.len().to_u64():
            var out: [u8] = []
            var i: u64 = 0
            while i < 32:
                out.push(0x00)
                i = i + 1
            if rt_tls13_hkdf_extract_into(salt, ikm, out) != 0:
                return out
        val out = sha256_hmac_with_len(salt, salt_len, ikm, ikm_len)
        return _copy_prefix(out, 32)

fn hkdf_extract_from_list(salt: list, ikm: list) -> [u8]:
    if salt.len() == 0:
        var effective_salt = []
        var i = 0
        while i < 32:
            effective_salt.push(0x00)
            i = i + 1
        return _copy_prefix(sha256_hmac_from_list(effective_salt, ikm), 32)
    _copy_prefix(sha256_hmac_from_list(salt, ikm), 32)

# ============================================================================
# hkdf_expand
# ============================================================================

fn hkdf_expand(prk: [u8], info: [u8], length: u64) -> [u8]:
    hkdf_expand_with_info_len(prk, info, info.len().to_u64(), length)

fn hkdf_expand_with_info_len(prk: [u8], info: [u8], info_len: u64, length: u64) -> [u8]:
    """HKDF-Expand (RFC 5869 §2.3).

    OKM = T(1) || T(2) || ... || T(N)  (truncated to length bytes)

    T(0) = empty string
    T(i) = HMAC-Hash(PRK, T(i-1) || info || i)

    Compile-mode fast-path: delegate to rt_tls13_hkdf_expand_into. Pure-Simple
    code below depends on `[u8].len()` and `[u32]` shifts that compile-mode
    Cranelift miscompiles. C extern reads runtime lengths directly.
    """
    val _unused_info_len = info_len
    var out_buf: [u8] = []
    var alloc_i: u64 = 0
    while alloc_i < length:
        out_buf.push(0x00)
        alloc_i = alloc_i + 1
    val rc = rt_tls13_hkdf_expand_into(prk, info, out_buf, length.to_i64())
    if rc != 0:
        return out_buf

    val digest_len: u64 = 32
    val block_count = if length == 0 { 0u64 } else { ((length + digest_len - 1) / digest_len) }
    var okm: [u8] = []
    var okm_len: u64 = 0
    var t_prev: [u8] = []
    var t_prev_len: u64 = 0
    val prk_len: u64 = 32
    var counter: u64 = 1

    while okm_len < length:
        # Build input: T(i-1) || info || counter_byte
        var input: [u8] = []
        var input_len: u64 = 0

        # Append T(i-1)
        var j: u64 = 0
        while j < t_prev_len:
            input.push(rt_bytes_u8_at(t_prev, j.to_i64()).to_u8())
            input_len = input_len + 1
            j = j + 1
        # Append info
        j = 0
        while j < info_len:
            input.push(rt_bytes_u8_at(info, j.to_i64()).to_u8())
            input_len = input_len + 1
            j = j + 1

        # Append counter as single byte
        input.push(counter.to_u8())
        input_len = input_len + 1

        val t_i = _copy_prefix(sha256_hmac_with_len(prk, prk_len, input, input_len), digest_len)

        # Append T(i) to OKM
        j = 0
        while j < digest_len:
            okm.push(rt_bytes_u8_at(t_i, j.to_i64()).to_u8())
            okm_len = okm_len + 1
            j = j + 1

        t_prev = t_i
        t_prev_len = digest_len
        counter = counter + 1

    # Truncate to requested length
    var result: [u8] = []
    var k: u64 = 0
    while k < length:
        result.push(rt_bytes_u8_at(okm, k.to_i64()).to_u8())
        k = k + 1
    _copy_prefix(result, length)

# ============================================================================
# hkdf_expand_label
# ============================================================================

fn hkdf_expand_label(secret: [u8], label: text, context: [u8], length: u64) -> [u8]:
    """HKDF-Expand-Label (RFC 8446 §7.1).

    Encodes HkdfLabel struct:
      uint16 length
      opaque label<7..255>   = "tls13 " + label
      opaque context<0..255>

    Then calls hkdf_expand(secret, encoded_label, length).
    """
    if label == "key" and length == 16:
        return rt_tls13_hkdf_expand_label_key(secret)
    if label == "key" and length == 32:
        var out: [u8] = []
        var i: u64 = 0
        while i < 32:
            out.push(0x00)
            i = i + 1
        if rt_tls13_hkdf_expand_label_into(secret, [0x6bu8, 0x65u8, 0x79u8], context, out, 32) != 0:
            return out
    if label == "iv" and length == 12:
        return rt_tls13_hkdf_expand_label_iv(secret)
    if label == "finished" and length == 32:
        return rt_tls13_hkdf_expand_label_finished(secret)
    if label == "derived" and length == 32:
        return rt_tls13_hkdf_expand_label_derived(secret, context)
    if label == "c hs traffic" and length == 32:
        return rt_tls13_hkdf_expand_label_client_hs(secret, context)
    if label == "s hs traffic" and length == 32:
        return rt_tls13_hkdf_expand_label_server_hs(secret, context)
    if label == "c ap traffic" and length == 32:
        return rt_tls13_hkdf_expand_label_client_app(secret, context)
    if label == "s ap traffic" and length == 32:
        return rt_tls13_hkdf_expand_label_server_app(secret, context)

    val label_tail = _label_bytes(label)
    if context.len().to_u64() == context.len() and length <= 255:
        val out = rt_tls13_hkdf_expand_label(secret, label_tail, context, length.to_i64())
        if out.len().to_u64() == length:
            return out
    val label_tail_len = _label_len(label)
    var label_bytes: [u8] = []
    label_bytes.push(0x74u8)
    label_bytes.push(0x6cu8)
    label_bytes.push(0x73u8)
    label_bytes.push(0x31u8)
    label_bytes.push(0x33u8)
    label_bytes.push(0x20u8)
    var label_bytes_len = 6u64
    var li: u64 = 0
    while li < label_tail_len:
        label_bytes.push(rt_bytes_u8_at(label_tail, li.to_i64()).to_u8())
        label_bytes_len = label_bytes_len + 1
        li = li + 1

    val context_len = context.len().to_u64()

    # Encode HkdfLabel:
    #   2 bytes: length (big-endian u16)
    #   1 byte:  label length
    #   N bytes: label
    #   1 byte:  context length
    #   M bytes: context
    val encoded_cap = (2u64 + 1u64 + label_bytes_len + 1u64 + context_len).to_i64()
    var encoded: [u8] = []
    var encoded_len: u64 = 0

    # length field (u16 big-endian)
    encoded.push(((length >> 8) & 0xFF).to_u8())
    encoded_len = encoded_len + 1
    encoded.push((length & 0xFF).to_u8())
    encoded_len = encoded_len + 1

    # label_length
    encoded.push(label_bytes_len.to_u8())
    encoded_len = encoded_len + 1

    # label bytes
    var i: u64 = 0
    while i < label_bytes_len:
        encoded.push(rt_bytes_u8_at(label_bytes, i.to_i64()).to_u8())
        encoded_len = encoded_len + 1
        i = i + 1

    # context_length
    encoded.push(context_len.to_u8())
    encoded_len = encoded_len + 1

    # context bytes
    i = 0
    while i < context_len:
        encoded.push(rt_bytes_u8_at(context, i.to_i64()).to_u8())
        encoded_len = encoded_len + 1
        i = i + 1

    hkdf_expand_with_info_len(secret, encoded, encoded.len().to_u64(), length)
