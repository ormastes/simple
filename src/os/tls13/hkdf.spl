#![allow(unnamed_duplicate_typed_args)]
# HKDF (RFC 5869) with SHA-256 for TLS 1.3
#
# Implements:
#   hkdf_extract    — PRK = HMAC(salt, ikm)
#   hkdf_expand     — OKM via iterative HMAC chain
#   hkdf_expand_label — RFC 8446 §7.1 HkdfLabel encoding

use os.crypto.sha256.{sha256_hmac}

# ============================================================================
# hkdf_extract
# ============================================================================

fn hkdf_extract(salt: [u8], ikm: [u8]) -> [u8]:
    """HKDF-Extract (RFC 5869 §2.2).

    PRK = HMAC-Hash(salt, IKM)

    If salt is empty, a string of HashLen zero bytes is used as salt.
    """
    var effective_salt: [u8] = []
    if salt.len() == 0:
        var i: u64 = 0
        while i < 32:
            effective_salt.push(0x00)
            i = i + 1
    else:
        var i: u64 = 0
        while i < salt.len():
            effective_salt.push(salt[i])
            i = i + 1
    sha256_hmac(effective_salt, ikm)

# ============================================================================
# hkdf_expand
# ============================================================================

fn hkdf_expand(prk: [u8], info: [u8], length: u64) -> [u8]:
    """HKDF-Expand (RFC 5869 §2.3).

    OKM = T(1) || T(2) || ... || T(N)  (truncated to length bytes)

    T(0) = empty string
    T(i) = HMAC-Hash(PRK, T(i-1) || info || i)
    """
    var okm: [u8] = []
    var t_prev: [u8] = []
    var counter: u64 = 1

    while okm.len() < length:
        # Build input: T(i-1) || info || counter_byte
        var input: [u8] = []

        # Append T(i-1)
        var j: u64 = 0
        while j < t_prev.len():
            input.push(t_prev[j])
            j = j + 1

        # Append info
        j = 0
        while j < info.len():
            input.push(info[j])
            j = j + 1

        # Append counter as single byte
        input.push(counter.to_u8())

        val t_i = sha256_hmac(prk, input)

        # Append T(i) to OKM
        j = 0
        while j < t_i.len():
            okm.push(t_i[j])
            j = j + 1

        t_prev = t_i
        counter = counter + 1

    # Truncate to requested length
    var result: [u8] = []
    var k: u64 = 0
    while k < length:
        result.push(okm[k])
        k = k + 1
    result

# ============================================================================
# hkdf_expand_label
# ============================================================================

fn hkdf_expand_label(secret: [u8], label: text, context: [u8], length: u64) -> [u8]:
    """HKDF-Expand-Label (RFC 8446 §7.1).

    Encodes HkdfLabel struct:
      uint16 length
      opaque label<7..255>   = "tls13 " + label
      opaque context<0..255>

    Then calls hkdf_expand(secret, encoded_label, length).
    """
    val tls13_prefix = "tls13 "

    # Compute label bytes: "tls13 " + label
    var label_bytes: [u8] = []

    # Push "tls13 " prefix (ASCII)
    label_bytes.push(0x74) # t
    label_bytes.push(0x6c) # l
    label_bytes.push(0x73) # s
    label_bytes.push(0x31) # 1
    label_bytes.push(0x33) # 3
    label_bytes.push(0x20) # space

    # Push label string as UTF-8 bytes
    val label_len = label.len()
    var li: u64 = 0
    while li < label_len:
        label_bytes.push(label[li].to_u8())
        li = li + 1

    val full_label_len = label_bytes.len()

    # Encode HkdfLabel:
    #   2 bytes: length (big-endian u16)
    #   1 byte:  label length
    #   N bytes: label
    #   1 byte:  context length
    #   M bytes: context
    var encoded: [u8] = []

    # length field (u16 big-endian)
    encoded.push(((length >> 8) & 0xFF).to_u8())
    encoded.push((length & 0xFF).to_u8())

    # label_length
    encoded.push(full_label_len.to_u8())

    # label bytes
    var i: u64 = 0
    while i < full_label_len:
        encoded.push(label_bytes[i])
        i = i + 1

    # context_length
    encoded.push(context.len().to_u8())

    # context bytes
    i = 0
    while i < context.len():
        encoded.push(context[i])
        i = i + 1

    hkdf_expand(secret, encoded, length)
