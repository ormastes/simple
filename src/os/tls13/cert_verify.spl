# TLS 1.3 Certificate Verification — DER parse + Ed25519 + RSA-PSS + ECDSA-P256/P-384/P-521 signature verify
#
# Implements:
#   - DER TLV helpers (tag, length, TLV, skip)
#   - extract_ed25519_pubkey_from_cert: navigate X.509 DER to extract Ed25519 public key
#   - extract_rsa_pubkey_spki_from_cert: navigate X.509 DER to extract RSA/ECDSA SPKI TLV bytes
#   - verify_certificate_verify_msg: RFC 8446 §4.4.3 CertificateVerify verify (Ed25519 shim)
#   - verify_certificate_verify_msg_scheme: dispatch on SignatureScheme (Ed25519 + RSA-PSS + ECDSA-P256/P-384/P-521)
#   - verify_cert_signature_ed25519: verify a certificate's self/issuer signature
#
# Signature schemes (RFC 8446 §4.2.3):
#   ed25519:                    0x0807
#   rsa_pss_rsae_sha256:        0x0804
#   rsa_pss_rsae_sha384:        0x0805
#   rsa_pss_rsae_sha512:        0x0806
#   ecdsa_secp256r1_sha256:     0x0403
#   ecdsa_secp384r1_sha384:     0x0503
#   ecdsa_secp521r1_sha512:     0x0603
#
# Reference: RFC 8446 §4.4.3 (CertificateVerify)
# Reference: RFC 5280 (X.509 DER encoding)
# Reference: RFC 8410 (Ed25519 in X.509, OID 1.3.101.112)
# Reference: RFC 8017 (RSA-PSS)
# Reference: RFC 5480 (ECDSA in X.509, OID 1.2.840.10045.4.3.2)

# Split from src/os/tls13/cert_verify.spl to keep module cohesion under the 800-line source limit.
export use os.tls13.cert_verify_part1.*
export use os.tls13.cert_verify_part2.*
