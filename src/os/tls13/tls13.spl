#![allow(unnamed_duplicate_typed_args)]
# TLS 1.3 Client State Machine — RFC 8446
#
# Orchestrates the full TLS 1.3 client handshake:
#   ClientHello → ServerHello → EncryptedExtensions → Certificate →
#   CertificateVerify → server Finished → client Finished → App data
#
# Uses AES-128-GCM cipher suite (TLS_AES_128_GCM_SHA256, 0x1301).
# Ed25519-only certificates (Phase 1).

use os.tls13.transcript.{Transcript, transcript_new, transcript_add, transcript_add_with_len, transcript_hash, transcript_empty_hash}
use os.tls13.key_schedule.{
    Tls13Secrets, TrafficKeys,
    derive_secret, tls13_early_secret,
    tls13_compute_handshake_secrets, tls13_compute_app_secrets,
    tls13_traffic_keys, tls13_finished_key, tls13_verify_data
}
use os.tls13.hkdf.{hkdf_extract, hkdf_expand_label}
use os.tls13.record13.{RecordKey, RecordResult, record13_encrypt, record13_decrypt, record13_decrypt_fd_inner}
use os.tls13.handshake13.{
    build_client_hello_bytes, parse_server_hello, parse_handshake_header,
    parse_certificate_body, parse_certificate_chain_body, parse_certificate_request, parse_certificate_verify, parse_finished_body,
    build_finished_bytes, build_certificate_bytes, build_certificate_verify_bytes,
    ServerHello13, ParsedHandshake, CertVerifyFields, CertificateRequest13
}
use os.tls13.cert_verify.{
    extract_ed25519_pubkey_from_cert, extract_rsa_pubkey_spki_from_cert,
    verify_certificate_verify_msg_scheme, verify_cert_chain,
    CertVerifyResult, CertChainResult
}
use os.crypto.curve25519.{x25519}
use os.crypto.random.{random_bytes}
use std.nogc_sync_mut.io.signature_ffi.{ed25519_sign}
use std.nogc_sync_mut.io.tcp.{TcpStream}

# ============================================================================
# TCP I/O externs
# ============================================================================

extern fn rt_net_close(sock_fd: i64) -> i64
extern fn rt_net_send_bytes(sock_fd: i64, data: [u8]) -> i64
extern fn rt_net_recv_bytes(sock_fd: i64, max_len: i64) -> [u8]
extern fn rt_thread_sleep(ms: i64)
extern fn serial_println(msg: text)
extern fn rt_ipc_send_bytes(port: u64, method: u64, data: [u8]) -> i64
extern fn rt_ipc_recv_bytes(port: u64, max_len: i64) -> [u8]
extern fn rt_array_new_with_cap(cap: i64) -> [u8]
extern fn rt_push_byte(arr: [u8], byte_val: i64) -> [u8]
extern fn rt_bytes_concat(a: [u8], b: [u8]) -> [u8]
extern fn rt_bytes_slice(arr: [u8], start: i64, length: i64) -> [u8]
extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64
extern fn rt_tls13_serverhello_cipher_suite(body: [u8]) -> i64
extern fn rt_tls13_serverhello_x25519_pub(body: [u8]) -> [u8]
extern fn rt_tls13_build_client_hello(host: text) -> [u8]
extern fn rt_tls13_build_client_hello_record(host: text) -> [u8]
extern fn rt_tls13_x25519_shared_secret(scalar: [u8], point: [u8]) -> [u8]
extern fn rt_tls13_hkdf_extract(salt: [u8], ikm: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label(secret: [u8], label: [u8], context: [u8], length: i64) -> [u8]
extern fn rt_tls13_hkdf_expand_label_derived(secret: [u8], context: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label_key(secret: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label_iv(secret: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label_finished(secret: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label_client_hs(secret: [u8], context: [u8]) -> [u8]
extern fn rt_tls13_hkdf_expand_label_server_hs(secret: [u8], context: [u8]) -> [u8]
extern fn rt_tls13_sha256(data: [u8]) -> [u8]
extern fn rt_tls13_transcript_hash_2(a: [u8], b: [u8]) -> [u8]
extern fn rt_tls13_transcript_hash_6(a: [u8], b: [u8], c: [u8], d: [u8], e: [u8], f: [u8]) -> [u8]
extern fn rt_tls13_find_handshake_message(buf: [u8], msg_type: i64) -> [u8]
extern fn rt_tls13_record_find_handshake_message(raw: [u8], key: [u8], iv: [u8], seq_num: i64, msg_type: i64) -> [u8]
extern fn rt_tls13_verify_data_hmac(finished_key: [u8], transcript_hash: [u8]) -> [u8]
extern fn rt_tls13_certificate_body_ed25519_pubkey(body: [u8]) -> [u8]
extern fn rt_tls13_certificate_verify_algorithm(body: [u8]) -> i64
extern fn rt_tls13_certificate_verify_signature(body: [u8]) -> [u8]
