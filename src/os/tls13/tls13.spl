extern fn rt_tls13_inner_plaintext_content(inner: [u8]) -> [u8]
extern fn rt_ed25519_verify(msg: [u8], pk: [u8], sig: [u8]) -> i64
extern fn rt_tls13_ed25519_verify(msg: [u8], pk: [u8], sig: [u8]) -> i64

# RFC 8446 record payloads are bounded; reject clearly invalid lengths
# before trying to allocate or read them from the transport.
val _TLS_MAX_RECORD_PAYLOAD: u64 = 18432
val _NETSTACK_PORT: u64 = 2
val _NET_SEND: u64 = 6
val _NET_RECV: u64 = 7

# ============================================================================
# Handshake message type constants (local copies from handshake13)
# ============================================================================

val _HS_ENCRYPTED_EXTENSIONS: u8 = 8
val _HS_CERTIFICATE: u8          = 11
val _HS_CERTIFICATE_REQUEST: u8  = 13
val _HS_CERTIFICATE_VERIFY: u8   = 15
val _HS_FINISHED: u8             = 20

# ============================================================================
# Data classes
# ============================================================================

class Tls13Context:
    io: Tls13Io
    server_key: RecordKey
    client_key: RecordKey
    server_seq: u64
    client_seq: u64

class Tls13RecvData:
    ctx: Tls13Context
    data: [u8]
    ok: bool
    reason: text

class Tls13SendResult:
    ctx: Tls13Context
    ok: bool
    reason: text

class Tls13CloseResult:
    ok: bool
    reason: text

enum Tls13ConnectResult:
    Connected(ctx: Tls13Context)
    Failed(reason: text)

class Tls13ClientConfig:
    client_cert_chain: [[u8]]
    client_pkcs8: [u8]
    client_sig_scheme: u16
    root_store: [[u8]]

class Tls13Io:
    kind: text
    tcp_fd: i64
    host_stream: TcpStream

fn _tls_debug(msg: text):
    serial_println("[tls13] {msg}")

fn _byte_buf(cap: u64) -> [u8]:
    rt_array_new_with_cap(cap.to_i64())

fn _push_byte(buf: [u8], byte_val: i64) -> [u8]:
    rt_push_byte(buf, byte_val)

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

fn _clone_bytes(buf: [u8]) -> [u8]:
    var out: [u8] = _byte_buf(buf.len())
    var i: u64 = 0
    while i < buf.len():
        out = _push_byte(out, _u8_at(buf, i).to_u64().to_i64())
        i = i + 1
    out

fn _copy_range(buf: [u8], start: u64, count: u64) -> [u8]:
    var out: [u8] = _byte_buf(count)
    var i: u64 = 0
    while i < count:
        out = _push_byte(out, _u8_at(buf, start + i).to_u64().to_i64())
        i = i + 1
    out

fn _bytes_equal(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    while i < a.len():
        if _u8_at(a, i) != _u8_at(b, i):
            return false
        i = i + 1
    true

fn _debug_bytes4(label: text, buf: [u8]):
    if buf.len() >= 4:
        _tls_debug("{label} b0={_u8_at(buf, 0)} b1={_u8_at(buf, 1)} b2={_u8_at(buf, 2)} b3={_u8_at(buf, 3)} len={buf.len()}")
    else:
        _tls_debug("{label} short len={buf.len()}")

fn _debug_bytes32(label: text, buf: [u8]):
    if buf.len() < 32:
        _tls_debug("{label} short len={buf.len()}")
        return
    _tls_debug("{label} 0={_u8_at(buf, 0)} 1={_u8_at(buf, 1)} 2={_u8_at(buf, 2)} 3={_u8_at(buf, 3)} 4={_u8_at(buf, 4)} 5={_u8_at(buf, 5)} 6={_u8_at(buf, 6)} 7={_u8_at(buf, 7)}")
    _tls_debug("{label} 8={_u8_at(buf, 8)} 9={_u8_at(buf, 9)} 10={_u8_at(buf, 10)} 11={_u8_at(buf, 11)} 12={_u8_at(buf, 12)} 13={_u8_at(buf, 13)} 14={_u8_at(buf, 14)} 15={_u8_at(buf, 15)}")
    _tls_debug("{label} 16={_u8_at(buf, 16)} 17={_u8_at(buf, 17)} 18={_u8_at(buf, 18)} 19={_u8_at(buf, 19)} 20={_u8_at(buf, 20)} 21={_u8_at(buf, 21)} 22={_u8_at(buf, 22)} 23={_u8_at(buf, 23)}")
    _tls_debug("{label} 24={_u8_at(buf, 24)} 25={_u8_at(buf, 25)} 26={_u8_at(buf, 26)} 27={_u8_at(buf, 27)} 28={_u8_at(buf, 28)} 29={_u8_at(buf, 29)} 30={_u8_at(buf, 30)} 31={_u8_at(buf, 31)}")

fn _transcript_hash_fd(t: Transcript) -> [u8]:
    _clone_bytes(rt_tls13_sha256(t.buf))

fn _tls_label_bytes(label: text) -> [u8]:
    if label == "derived":
        return [0x64u8, 0x65u8, 0x72u8, 0x69u8, 0x76u8, 0x65u8, 0x64u8]
    if label == "key":
        return [0x6bu8, 0x65u8, 0x79u8]
    if label == "iv":
        return [0x69u8, 0x76u8]
    if label == "c hs traffic":
        return [0x63u8, 0x20u8, 0x68u8, 0x73u8, 0x20u8, 0x74u8, 0x72u8, 0x61u8, 0x66u8, 0x66u8, 0x69u8, 0x63u8]
    if label == "s hs traffic":
        return [0x73u8, 0x20u8, 0x68u8, 0x73u8, 0x20u8, 0x74u8, 0x72u8, 0x61u8, 0x66u8, 0x66u8, 0x69u8, 0x63u8]
    []

fn _tls13_traffic_keys_fd(traffic_secret: [u8]) -> TrafficKeys:
    val key = _copy_range(_clone_bytes(rt_tls13_hkdf_expand_label_key(traffic_secret)), 0, 16)
    val iv = _copy_range(_clone_bytes(rt_tls13_hkdf_expand_label_iv(traffic_secret)), 0, 12)
    TrafficKeys(key: key, iv: iv)

# ============================================================================
# TCP I/O helpers
# ============================================================================

fn _fd_io(fd: i64) -> Tls13Io:
    Tls13Io(kind: "fd", tcp_fd: fd, host_stream: TcpStream(fd: -1, open: false))

fn _host_stream_io(stream: TcpStream) -> Tls13Io:
    Tls13Io(kind: "host_stream", tcp_fd: -1, host_stream: stream)

fn _net_push_i32(out: [u8], value: i32):
    val raw = value as u32
    out = _push_byte(out, (raw & 0xFF).to_i64())
    out = _push_byte(out, ((raw >> 8) & 0xFF).to_i64())
    out = _push_byte(out, ((raw >> 16) & 0xFF).to_i64())
    out = _push_byte(out, ((raw >> 24) & 0xFF).to_i64())

fn _net_push_u32(out: [u8], value: u32):
    val raw = value
    out = _push_byte(out, (raw & 0xFF).to_i64())
    out = _push_byte(out, ((raw >> 8) & 0xFF).to_i64())
    out = _push_byte(out, ((raw >> 16) & 0xFF).to_i64())
    out = _push_byte(out, ((raw >> 24) & 0xFF).to_i64())

fn _net_read_i32(buf: [u8], offset: u64) -> i32:
    val b0 = buf[offset] as u32
    val b1 = buf[offset + 1] as u32
    val b2 = buf[offset + 2] as u32
    val b3 = buf[offset + 3] as u32
    (b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)) as i32

fn _net_send_direct(fd: i32, data: [u8]) -> Result<u64, text>:
    var payload: [u8] = _byte_buf(data.len() + 4)
    _net_push_i32(payload, fd)
    var i: u64 = 0
    while i < data.len():
        payload = _push_byte(payload, data[i].to_u64().to_i64())
        i = i + 1
    val send_rc = rt_ipc_send_bytes(_NETSTACK_PORT, _NET_SEND, payload)
    if send_rc < 0:
        return Err("ipc send failed")
    val reply = rt_ipc_recv_bytes(_NETSTACK_PORT, 64)
    _tls_debug("_net_send_direct reply_len={reply.len()}")
    if reply.len() < 4:
        return Err("short send reply")
    val status = _net_read_i32(reply, 0)
    _tls_debug("_net_send_direct status={status}")
    if status < 0:
        return Err("send failed status {status}")
    val wrote = if reply.len() >= 8: _net_read_i32(reply, 4) else: status
    _tls_debug("_net_send_direct wrote={wrote}")
    if wrote < 0:
        return Err("send failed value {wrote}")
    Ok(wrote.to_u64())

fn _net_recv_direct(fd: i32, max_len: u64) -> Result<[u8], text>:
    var payload: [u8] = _byte_buf(8)
    _net_push_i32(payload, fd)
    _net_push_u32(payload, max_len.to_u32())
    val send_rc = rt_ipc_send_bytes(_NETSTACK_PORT, _NET_RECV, payload)
    if send_rc < 0:
        return Err("ipc recv request failed")
    val reply = rt_ipc_recv_bytes(_NETSTACK_PORT, (max_len + 16).to_i64())
    _tls_debug("_net_recv_direct reply_len={reply.len()}")
    if reply.len() < 4:
        return Err("short recv reply")
    val status = _net_read_i32(reply, 0)
    _tls_debug("_net_recv_direct status={status}")
    if status < 0:
        return Err("recv failed status {status}")
    var data: [u8] = _byte_buf(reply.len())
    var i: u64 = 4
    while i < reply.len():
        data = _push_byte(data, reply[i].to_u64().to_i64())
        i = i + 1
    Ok(data)

fn _io_send(io: Tls13Io, data: [u8]) -> bool:
    """Send all bytes over TCP. Returns false if the write fails."""
    _tls_debug("_io_send start kind={io.kind} len={data.len()}")
    if io.kind == "host_stream":
        match io.host_stream.write_all(data):
            Ok(()): true
            Err(_): false
    else:
        var sent: u64 = 0
        var zero_writes: u64 = 0
        while sent < data.len():
            _tls_debug("_io_send loop sent={sent} total={data.len()}")
            val wrote_i = rt_net_send_bytes(io.tcp_fd, data)
            if wrote_i < 0:
                _tls_debug("_io_send send err status={wrote_i}")
                return false
            val wrote = wrote_i.to_u64()
            _tls_debug("_io_send wrote={wrote}")
            if wrote == 0:
                zero_writes = zero_writes + 1
                if zero_writes > 100000:
                    return false
                rt_thread_sleep(1)
                pass_dn
            else:
                zero_writes = 0
            sent = sent + wrote
        true

fn _io_recv(io: Tls13Io, length: u64) -> [u8]:
    """Read exactly length bytes from TCP. Returns partial data on close."""
    _tls_debug("_io_recv request len={length} kind={io.kind}")
    if length == 0:
        return []
    if length > _TLS_MAX_RECORD_PAYLOAD and length != 5:
        return []
    var result: [u8] = _byte_buf(length)
    var empty_spins: u64 = 0
    while result.len() < length:
        if result.len() > length:
            var trimmed: [u8] = _byte_buf(length)
            var trim_idx: u64 = 0
            while trim_idx < length:
                trimmed = _push_byte(trimmed, result[trim_idx].to_u64().to_i64())
                trim_idx = trim_idx + 1
            return trimmed
        val remaining = length - result.len()
        if remaining == 0:
            return result
        if remaining > _TLS_MAX_RECORD_PAYLOAD and remaining != 5:
            return result
        _tls_debug("_io_recv remaining={remaining} have={result.len()}")
        val chunk = if io.kind == "host_stream":
            match io.host_stream.read(remaining.to_i64()):
                Ok(data): data
                Err(_): []
        else:
            rt_net_recv_bytes(io.tcp_fd, remaining.to_i64())
        _tls_debug("_io_recv chunk_len={chunk.len()}")
        if chunk.len() == 0:
            empty_spins = empty_spins + 1
            if empty_spins > 100000:
                return result
            rt_thread_sleep(1)
            pass_dn
        else:
            empty_spins = 0
        # Defensive cap: some guest-side net shims can return a chunk larger
        # than the requested max_len. If we blindly append it, result.len()
        # can overshoot length and the next remaining computation underflows
        # into a giant allocation request.
        val copy_len = if chunk.len() < remaining { chunk.len() } else { remaining }
        var i: u64 = 0
        while i < copy_len:
            result = _push_byte(result, _u8_at(chunk, i).to_u64().to_i64())
            i = i + 1
    result

fn _io_recv_record(io: Tls13Io) -> [u8]:
    """Read one complete TLS record: 5-byte header + payload."""
    _tls_debug("_io_recv_record start")
    val header = _io_recv(io, 5)
    if header.len() < 5:
        _tls_debug("_io_recv_record short_header={header.len()}")
        return header
    val h0 = _u8_at(header, 0)
    val h3 = _u8_at(header, 3)
    val h4 = _u8_at(header, 4)
    val pay_len = (h3.to_u64() << 8) | h4.to_u64()
    _tls_debug("_io_recv_record header type={h0} pay_len={pay_len}")
    if pay_len == 0 or pay_len > _TLS_MAX_RECORD_PAYLOAD:
        return []
    val payload = _io_recv(io, pay_len)
    if payload.len() < pay_len:
        return []
    var result: [u8] = _byte_buf(header.len() + payload.len())
    _tls_debug("_io_recv_record concat header={header.len()} payload={payload.len()}")
    var i: u64 = 0
    while i < header.len():
        result = _push_byte(result, _u8_at(header, i).to_u64().to_i64())
        i = i + 1
    i = 0
    while i < payload.len():
        result = _push_byte(result, _u8_at(payload, i).to_u64().to_i64())
        i = i + 1
    result

# ============================================================================
# Helper: build a plaintext TLS record with legacy ClientHello framing
# ============================================================================

fn _build_plaintext_record(content_type: u8, payload: [u8]) -> [u8]:
    """Build a plaintext TLS record. Uses 0x0301 legacy version for ClientHello."""
    val pay_len = payload.len()
    var rec: [u8] = _byte_buf(pay_len + 5)
    rec = _push_byte(rec, content_type.to_u64().to_i64())
    rec = _push_byte(rec, 0x03)
    rec = _push_byte(rec, 0x01)
    rec = _push_byte(rec, ((pay_len >> 8) & 0xFF).to_i64())
    rec = _push_byte(rec, (pay_len & 0xFF).to_i64())
    var i: u64 = 0
    while i < pay_len:
        rec = _push_byte(rec, payload[i].to_u64().to_i64())
        i = i + 1
    rec

fn _sig_algs_contains(sig_algs: [u16], scheme: u16) -> bool:
    if sig_algs.len() == 0:
        return true
    var i: u64 = 0
    while i < sig_algs.len():
        if sig_algs[i] == scheme:
            return true
        i = i + 1
    false

fn _build_client_cert_verify_content(thash: [u8]) -> [u8]:
    """Build the client-side RFC 8446 CertificateVerify signed content."""
    var content: [u8] = []
    var i: u64 = 0
    while i < 64:
        content = _push_byte(content, 0x20)
        i = i + 1

    val prefix = [
        0x54u8, 0x4C, 0x53, 0x20, 0x31, 0x2E, 0x33, 0x2C, 0x20,
        0x63, 0x6C, 0x69, 0x65, 0x6E, 0x74, 0x20,
        0x43, 0x65, 0x72, 0x74, 0x69, 0x66, 0x69, 0x63, 0x61,
        0x74, 0x65, 0x56, 0x65, 0x72, 0x69, 0x66, 0x79
    ]
    i = 0
    while i < prefix.len():
        content = _push_byte(content, prefix[i].to_u64().to_i64())
        i = i + 1
    content = _push_byte(content, 0x00)

    i = 0
    while i < thash.len():
        content = _push_byte(content, thash[i].to_u64().to_i64())
        i = i + 1
    content

fn tls13_default_client_config() -> Tls13ClientConfig:
    Tls13ClientConfig(client_cert_chain: [], client_pkcs8: [], client_sig_scheme: 0x0807, root_store: [])

# ============================================================================
# Main: tls13_connect
# ============================================================================

fn tls13_connect(tcp_fd: i64, hostname: text) -> Tls13ConnectResult:
    tls13_connect_with_config(tcp_fd, hostname, tls13_default_client_config())

fn tls13_connect_with_config(tcp_fd: i64, hostname: text, config: Tls13ClientConfig) -> Tls13ConnectResult:
    tls13_connect_io_with_config(_fd_io(tcp_fd), hostname, config)

fn tls13_connect_host_stream(stream: TcpStream, hostname: text) -> Tls13ConnectResult:
    tls13_connect_host_stream_with_config(stream, hostname, tls13_default_client_config())

fn tls13_connect_host_stream_with_config(stream: TcpStream, hostname: text, config: Tls13ClientConfig) -> Tls13ConnectResult:
    tls13_connect_io_with_config(_host_stream_io(stream), hostname, config)

fn tls13_connect_io_with_config(io: Tls13Io, hostname: text, config: Tls13ClientConfig) -> Tls13ConnectResult:
    """Perform a full TLS 1.3 client handshake over an existing TCP connection.

    Steps:
      1. Generate X25519 ephemeral keypair.
      2. Build and send ClientHello plaintext record. Add to transcript.
      3. Read and parse ServerHello. Add to transcript.
      4. Compute X25519 shared secret + handshake secrets.
      5. Read encrypted records, accumulate handshake bytes.
      6. Process: EncryptedExtensions, Certificate, CertificateVerify, Finished.
      7. Verify CertificateVerify + server Finished.
      8. Compute app secrets. Optionally send client auth. Send client Finished.
      9. Return Tls13Context with app traffic keys.
    """
    # The current C-backed guest networking profile completes connect()
    # asynchronously. Give the TCP state machine one short tick so the
    # SYN/SYN-ACK/ACK path settles before we send the first TLS record.
    _tls_debug("connect start host={hostname} kind={io.kind}")
    rt_thread_sleep(10)

    # ------------------------------------------------------------------
    # Step 1: Generate X25519 ephemeral keypair
    # ------------------------------------------------------------------
    val priv_key: [u8] = [
        0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17, 0x18,
        0x19, 0x1a, 0x1b, 0x1c, 0x1d, 0x1e, 0x1f, 0x20,
        0x21, 0x22, 0x23, 0x24, 0x25, 0x26, 0x27, 0x28,
        0x29, 0x2a, 0x2b, 0x2c, 0x2d, 0x2e, 0x2f, 0x30
    ]
    # priv_key is fixed in this bootstrap client, so its public share can be
    # precomputed once and reused to avoid an expensive baremetal basepoint multiply.
    val pub_key: [u8] = [
        0x4d, 0x27, 0xbc, 0xee, 0x31, 0x35, 0xc4, 0x94,
        0x4b, 0x28, 0xd2, 0x7d, 0xd8, 0x09, 0xb0, 0x7b,
        0xe1, 0x0c, 0x35, 0x16, 0x0d, 0x20, 0x13, 0x1c,
        0xaa, 0x7e, 0x85, 0x57, 0x54, 0x98, 0xd0, 0x7c
    ]

    # ------------------------------------------------------------------
    # Step 2: Build and send ClientHello
    # ------------------------------------------------------------------
    val ch_random: [u8] = [
        0xa0, 0xa1, 0xa2, 0xa3, 0xa4, 0xa5, 0xa6, 0xa7,
        0xa8, 0xa9, 0xaa, 0xab, 0xac, 0xad, 0xae, 0xaf,
        0xb0, 0xb1, 0xb2, 0xb3, 0xb4, 0xb5, 0xb6, 0xb7,
        0xb8, 0xb9, 0xba, 0xbb, 0xbc, 0xbd, 0xbe, 0xbf
    ]
    _tls_debug("before build_client_hello")
    val fd_mode = io.kind == "fd"
    val ch_bytes = if fd_mode { [] } else { build_client_hello_bytes(ch_random, pub_key, hostname) }
    _tls_debug("after build_client_hello len={ch_bytes.len()}")
    val ch_record = if fd_mode { rt_tls13_build_client_hello_record(hostname) } else { _build_plaintext_record(0x16, ch_bytes) }
    _tls_debug("after build_plaintext_record len={ch_record.len()}")
    if not _io_send(io, ch_record):
        return Tls13ConnectResult.Failed(reason: "ClientHello send failed")

    var transcript = transcript_new()
    val ch_transcript_bytes = if fd_mode {
        _copy_range(ch_record, 5, ch_record.len() - 5)
    } else {
        ch_bytes
    }
    transcript = transcript_add(transcript, ch_transcript_bytes)
    if fd_mode:
        fd_transcript = rt_bytes_concat(fd_transcript, ch_transcript_bytes)
    _tls_debug("after transcript_add clienthello")

    # ------------------------------------------------------------------
    # Step 3: Read and parse ServerHello
    # ------------------------------------------------------------------
    val sh_raw = _io_recv_record(io)
    if sh_raw.len() < 5:
        return Tls13ConnectResult.Failed(reason: "ServerHello: short read")

    # Extract the handshake-layer bytes (the record payload)
    val sh_pay_len = (_u8_at(sh_raw, 3).to_u64() << 8) | _u8_at(sh_raw, 4).to_u64()
    _tls_debug("before sh slice pay_len={sh_pay_len} raw_len={sh_raw.len()}")
    val sh_hs_bytes = _copy_range(sh_raw, 5, sh_pay_len)
    _tls_debug("after sh slice hs_len={sh_hs_bytes.len()}")

    # parse_handshake_header parses type(1) + length(3) → body
    _tls_debug("before parse_handshake_header")
    val sh_parsed = parse_handshake_header(sh_hs_bytes)
    _tls_debug("after parse_handshake_header type={sh_parsed.msg_type} body_len={sh_parsed.body.len()}")
    val sh = ServerHello13(
        random: [],
        cipher_suite: rt_tls13_serverhello_cipher_suite(sh_parsed.body).to_u16(),
        x25519_pub: rt_tls13_serverhello_x25519_pub(sh_parsed.body))
    _tls_debug("after parse_server_hello cipher={sh.cipher_suite} key_len={sh.x25519_pub.len()}")
    if fd_mode:
        _debug_bytes32("server_x25519_pub", sh.x25519_pub)

    # Add full ServerHello handshake bytes (including 4-byte header) to transcript
    transcript = transcript_add_with_len(transcript, sh_hs_bytes, sh_pay_len)
    if fd_mode:
        fd_transcript = rt_bytes_concat(fd_transcript, _copy_range(sh_hs_bytes, 0, sh_pay_len))
    _tls_debug("after transcript_add serverhello")

    # ------------------------------------------------------------------
    # Step 4: X25519 DH + handshake secrets
    # ------------------------------------------------------------------
    val dhe_shared = if fd_mode {
        rt_tls13_x25519_shared_secret(priv_key, sh.x25519_pub)
    } else {
        x25519(priv_key, sh.x25519_pub)
    }
    _tls_debug("after x25519 shared_len={dhe_shared.len()}")
    if fd_mode:
        _debug_bytes32("dhe_shared", dhe_shared)
    _tls_debug("before tls13_early_secret transcript_len={transcript.buf_len}")
    val early_secret = if fd_mode {
        [
            0x33, 0xad, 0x0a, 0x1c, 0x60, 0x7e, 0xc0, 0x3b,
            0x09, 0xe6, 0xcd, 0x98, 0x93, 0x68, 0x0c, 0xe2,
            0x10, 0xad, 0xf3, 0x00, 0xaa, 0x1f, 0x26, 0x60,
            0xe1, 0xb2, 0x2e, 0x10, 0xf1, 0x70, 0xf9, 0x2a
        ]
    } else {
        tls13_early_secret()
    }
    _tls_debug("after tls13_early_secret len={early_secret.len()}")
    if fd_mode:
        _debug_bytes32("early_secret", early_secret)
    val empty_thash = if fd_mode { _clone_bytes(rt_tls13_sha256(rt_array_new_with_cap(0))) } else { transcript_empty_hash() }
    _tls_debug("after transcript_empty_hash len={empty_thash.len()}")
    if fd_mode:
        _debug_bytes32("empty_thash", empty_thash)
    val hs_derived = if fd_mode {
        _clone_bytes(rt_tls13_hkdf_expand_label_derived(early_secret, empty_thash))
    } else {
        hkdf_expand_label(early_secret, "derived", empty_thash, 32)
    }
    _tls_debug("after hs_derived len={hs_derived.len()}")
    if fd_mode:
        _debug_bytes32("hs_derived", hs_derived)
    val handshake_secret = if fd_mode {
        _clone_bytes(rt_tls13_hkdf_extract(hs_derived, dhe_shared))
    } else {
        hkdf_extract(hs_derived, dhe_shared)
    }
    _tls_debug("after tls13_handshake_secret len={handshake_secret.len()}")
    if fd_mode:
        _debug_bytes32("handshake_secret", handshake_secret)
    val transcript_sh_hash = if fd_mode {
        _clone_bytes(rt_tls13_transcript_hash_2(ch_transcript_bytes, sh_hs_bytes))
    } else {
        transcript_hash(transcript)
    }
    _tls_debug("after transcript_hash len={transcript_sh_hash.len()}")
    if fd_mode:
        _debug_bytes32("transcript_sh_hash", transcript_sh_hash)
    val client_hs_secret = if fd_mode {
        _clone_bytes(rt_tls13_hkdf_expand_label(handshake_secret, [
            0x63, 0x20, 0x68, 0x73, 0x20, 0x74, 0x72, 0x61, 0x66, 0x66, 0x69, 0x63
        ], transcript_sh_hash, 32))
    } else {
        derive_secret(handshake_secret, "c hs traffic", transcript)
    }
    _tls_debug("after client_hs_derive len={client_hs_secret.len()}")
    if fd_mode:
        _debug_bytes32("client_hs_secret", client_hs_secret)
    val server_hs_secret = if fd_mode {
        _clone_bytes(rt_tls13_hkdf_expand_label(handshake_secret, [
            0x73, 0x20, 0x68, 0x73, 0x20, 0x74, 0x72, 0x61, 0x66, 0x66, 0x69, 0x63
        ], transcript_sh_hash, 32))
    } else {
        derive_secret(handshake_secret, "s hs traffic", transcript)
    }
    _tls_debug("after server_hs_derive len={server_hs_secret.len()}")
    if fd_mode:
        _debug_bytes32("server_hs_secret", server_hs_secret)
    val empty_secret: [u8] = []
    val secrets = Tls13Secrets(
        early_secret: early_secret,
        handshake_secret: handshake_secret,
        master_secret: empty_secret,
        client_hs_traffic: client_hs_secret,
        server_hs_traffic: server_hs_secret,
        client_app_traffic: empty_secret,
        server_app_traffic: empty_secret,
    )
    _tls_debug("after tls13_compute_handshake_secrets")

    # Derive traffic keys
    val server_hs_tk = if fd_mode {
        _tls13_traffic_keys_fd(secrets.server_hs_traffic)
    } else {
        tls13_traffic_keys(secrets.server_hs_traffic)
    }
    _tls_debug("after server_hs_tk key_len={server_hs_tk.key.len()} iv_len={server_hs_tk.iv.len()}")
    val client_hs_tk = if fd_mode {
        _tls13_traffic_keys_fd(secrets.client_hs_traffic)
    } else {
        tls13_traffic_keys(secrets.client_hs_traffic)
    }
    _tls_debug("after client_hs_tk key_len={client_hs_tk.key.len()} iv_len={client_hs_tk.iv.len()}")
    if fd_mode:
        _debug_bytes4("server_hs_key", server_hs_tk.key)
        _debug_bytes4("server_hs_iv", server_hs_tk.iv)
        _debug_bytes4("client_hs_key", client_hs_tk.key)
        _debug_bytes4("client_hs_iv", client_hs_tk.iv)
    val server_hs_rk = RecordKey(key: server_hs_tk.key, iv: server_hs_tk.iv)
    val client_hs_rk = RecordKey(key: client_hs_tk.key, iv: client_hs_tk.iv)

    # ------------------------------------------------------------------
    # Step 5-8: Read and process encrypted handshake records
    # ------------------------------------------------------------------
    # We accumulate all inner handshake bytes from decrypted records,
    # then walk them parsing message-by-message.

    var server_seq: u64 = 0

    # Accumulate all decrypted handshake bytes across records
    var hs_buf: [u8] = rt_array_new_with_cap(512)

    # We need to see 4 messages: EE, Cert, CertVerify, Finished
    # Read records until we have all 4 in hs_buf
    var have_ee: bool = false
    var have_cert: bool = false
    var have_cv: bool = false
    var have_fin: bool = false

    var cert_der: [u8] = []
    var cert_chain: [[u8]] = []
    var cert_verify_sig: [u8] = []
    var cert_verify_algo: u16 = 0
    var server_verify_data: [u8] = []
    var pubkey_for_verify: [u8] = []
    var cert_request = CertificateRequest13(request_context: [], sig_algs: [])
    var server_requested_client_auth: bool = false

    # Saved transcript snapshots for verification
    var transcript_before_cv: Transcript = transcript_new()
    var transcript_before_fin: Transcript = transcript_new()
    var fd_transcript: [u8] = rt_array_new_with_cap(0)
    var fd_transcript_before_cv: [u8] = rt_array_new_with_cap(0)
    var fd_transcript_before_fin: [u8] = rt_array_new_with_cap(0)
    var fd_msg_ee: [u8] = rt_array_new_with_cap(0)
    var fd_msg_cr: [u8] = rt_array_new_with_cap(0)
    var fd_msg_cert: [u8] = rt_array_new_with_cap(0)
    var fd_msg_cv: [u8] = rt_array_new_with_cap(0)

    while (not have_ee) or (not have_cert) or (not have_cv) or (not have_fin):
        # Read one TLS record (may be plaintext CCS or encrypted handshake)
        val raw = _io_recv_record(io)
        if raw.len() < 5:
            return Tls13ConnectResult.Failed(reason: "encrypted record: short read")

        # Skip plaintext ChangeCipherSpec (0x14) — middlebox compat per RFC 8446 §D.4
        if _u8_at(raw, 0) == 0x14:
            pass_dn

        if _u8_at(raw, 0) != 0x14:
            var ct: u8 = 0
            var dec_data: [u8] = rt_array_new_with_cap(0)

            if fd_mode:
                val inner = record13_decrypt_fd_inner(server_hs_rk, server_seq, raw)
                server_seq = server_seq + 1
                if inner.len() == 0:
                    return Tls13ConnectResult.Failed(reason: "authentication tag mismatch")
                val fd_ct = rt_tls13_inner_plaintext_type(inner)
                if fd_ct < 0:
                    return Tls13ConnectResult.Failed(reason: "decrypted inner plaintext missing content type")
                ct = fd_ct.to_u8()
                dec_data = _clone_bytes(rt_tls13_inner_plaintext_content(inner))
                if ct == 0x16 and dec_data.len() == 0:
                    return Tls13ConnectResult.Failed(reason: "decrypted handshake content empty")
            else:
                val dec_result = record13_decrypt(server_hs_rk, server_seq, raw)
                server_seq = server_seq + 1
                if val RecordResult.Err(err_msg) = dec_result:
                    return Tls13ConnectResult.Failed(reason: err_msg)
                if val RecordResult.Ok(res_ct, res_data) = dec_result:
                    ct = res_ct
                    dec_data = res_data

            _tls_debug("record ok ct={ct} dec_len={dec_data.len()}")
            # Only process handshake content (0x16); skip others (alerts, etc.)
            if ct == 0x16:
                # Append decrypted handshake bytes to buffer
                var di: u64 = 0
                while di < dec_data.len():
                    hs_buf = _push_byte(hs_buf, _u8_at(dec_data, di).to_u64().to_i64())
                    di = di + 1
                _tls_debug("hs_buf len after append={hs_buf.len()}")

                if fd_mode:
                    val scan_buf = dec_data
                    val raw_seq = (server_seq - 1).to_i64()
                    if not have_ee:
                        var ee_msg = _clone_bytes(rt_tls13_record_find_handshake_message(raw, server_hs_rk.key, server_hs_rk.iv, raw_seq, _HS_ENCRYPTED_EXTENSIONS.to_i64()))
                        _tls_debug("fd helper ee len={ee_msg.len()}")
                        if ee_msg.len() == 0:
                            ee_msg = _clone_bytes(rt_tls13_find_handshake_message(scan_buf, _HS_ENCRYPTED_EXTENSIONS.to_i64()))
                        if ee_msg.len() == 0:
                            ee_msg = _clone_bytes(rt_tls13_find_handshake_message(hs_buf, _HS_ENCRYPTED_EXTENSIONS.to_i64()))
                        if ee_msg.len() > 0:
                            fd_msg_ee = ee_msg
                            have_ee = true
                    if not have_cert:
                        var cert_msg = _clone_bytes(rt_tls13_record_find_handshake_message(raw, server_hs_rk.key, server_hs_rk.iv, raw_seq, _HS_CERTIFICATE.to_i64()))
                        _tls_debug("fd helper cert len={cert_msg.len()}")
                        if cert_msg.len() == 0:
                            cert_msg = _clone_bytes(rt_tls13_find_handshake_message(scan_buf, _HS_CERTIFICATE.to_i64()))
                        if cert_msg.len() == 0:
                            cert_msg = _clone_bytes(rt_tls13_find_handshake_message(hs_buf, _HS_CERTIFICATE.to_i64()))
                        if cert_msg.len() > 0:
                            fd_msg_cert = cert_msg
                            val cert_body = _copy_range(cert_msg, 4, cert_msg.len() - 4)
                            pubkey_for_verify = _clone_bytes(rt_tls13_certificate_body_ed25519_pubkey(cert_body))
                            have_cert = true
                    if not have_cv:
                        var cv_msg = _clone_bytes(rt_tls13_record_find_handshake_message(raw, server_hs_rk.key, server_hs_rk.iv, raw_seq, _HS_CERTIFICATE_VERIFY.to_i64()))
                        _tls_debug("fd helper cv len={cv_msg.len()}")
                        if cv_msg.len() == 0:
                            cv_msg = _clone_bytes(rt_tls13_find_handshake_message(scan_buf, _HS_CERTIFICATE_VERIFY.to_i64()))
                        if cv_msg.len() == 0:
                            cv_msg = _clone_bytes(rt_tls13_find_handshake_message(hs_buf, _HS_CERTIFICATE_VERIFY.to_i64()))
                        if cv_msg.len() > 0:
                            fd_msg_cv = cv_msg
                            val cv_body = _copy_range(cv_msg, 4, cv_msg.len() - 4)
                            cert_verify_sig = _clone_bytes(rt_tls13_certificate_verify_signature(cv_body))
                            cert_verify_algo = rt_tls13_certificate_verify_algorithm(cv_body).to_u16()
                            have_cv = true
                    if not have_fin:
                        var fin_msg = _clone_bytes(rt_tls13_record_find_handshake_message(raw, server_hs_rk.key, server_hs_rk.iv, raw_seq, _HS_FINISHED.to_i64()))
                        _tls_debug("fd helper fin len={fin_msg.len()}")
                        if fin_msg.len() == 0:
                            fin_msg = _clone_bytes(rt_tls13_find_handshake_message(scan_buf, _HS_FINISHED.to_i64()))
                        if fin_msg.len() == 0:
                            fin_msg = _clone_bytes(rt_tls13_find_handshake_message(hs_buf, _HS_FINISHED.to_i64()))
                        if fin_msg.len() > 0:
                            val fin_body = _copy_range(fin_msg, 4, fin_msg.len() - 4)
                            server_verify_data = parse_finished_body(fin_body)
                            have_fin = true
                else:

                    # Walk hs_buf parsing complete messages.
                    # Track consumed separately to avoid re-processing on incomplete read.
                    var consumed: u64 = 0
                    var buf_offset: u64 = 0
                    var keep_walking: bool = true

                    while (keep_walking) and (buf_offset + 4 <= hs_buf.len()):
                        _tls_debug("hs hdr b0={_u8_at(hs_buf, buf_offset)} b1={_u8_at(hs_buf, buf_offset + 1)} b2={_u8_at(hs_buf, buf_offset + 2)} b3={_u8_at(hs_buf, buf_offset + 3)}")
                        # Peek at the 3-byte length
                        val msg_body_len: u64 = ((_u8_at(hs_buf, buf_offset + 1).to_u64() << 16) |
                                                 (_u8_at(hs_buf, buf_offset + 2).to_u64() << 8) |
                                                 _u8_at(hs_buf, buf_offset + 3).to_u64())
                        var msg_total: u64 = msg_body_len
                        msg_total = msg_total + 1
                        msg_total = msg_total + 1
                        msg_total = msg_total + 1
                        msg_total = msg_total + 1
                        _tls_debug("hs msg_body_len={msg_body_len} msg_total={msg_total} hs_len={hs_buf.len()}")

                        if buf_offset + msg_total > hs_buf.len():
                            # Incomplete message — stop walking, preserve hs_buf tail
                            keep_walking = false
                        else:
                            # Extract full message bytes (including 4-byte header)
                            var msg_bytes: [u8] = rt_array_new_with_cap(msg_total.to_i64())
                            var mi: u64 = 0
                            while mi < msg_total:
                                msg_bytes = _push_byte(msg_bytes, _u8_at(hs_buf, buf_offset + mi).to_u64().to_i64())
                                mi = mi + 1

                            val ph = parse_handshake_header(msg_bytes)
                            _tls_debug("hs msg type={ph.msg_type} total={msg_total} body_len={ph.body.len()}")

                            if ph.msg_type == _HS_ENCRYPTED_EXTENSIONS:
                                transcript = transcript_add_with_len(transcript, msg_bytes, msg_total)
                                have_ee = true

                            elif ph.msg_type == _HS_CERTIFICATE_REQUEST:
                                transcript = transcript_add(transcript, msg_bytes)
                                cert_request = parse_certificate_request(ph.body)
                                server_requested_client_auth = true

                            elif ph.msg_type == _HS_CERTIFICATE:
                                transcript = transcript_add(transcript, msg_bytes)
                                cert_chain = parse_certificate_chain_body(ph.body)
                                cert_der = parse_certificate_body(ph.body)
                                have_cert = true

                            elif ph.msg_type == _HS_CERTIFICATE_VERIFY:
                                # Snapshot transcript BEFORE adding CertVerify
                                transcript_before_cv = transcript
                                transcript = transcript_add_with_len(transcript, msg_bytes, msg_total)
                                val cv_fields = parse_certificate_verify(ph.body)
                                cert_verify_sig = cv_fields.signature
                                cert_verify_algo = cv_fields.algorithm
                                have_cv = true

                            elif ph.msg_type == _HS_FINISHED:
                                # Snapshot transcript BEFORE adding server Finished
                                transcript_before_fin = transcript
                                transcript = transcript_add_with_len(transcript, msg_bytes, msg_total)
                                server_verify_data = parse_finished_body(ph.body)
                                have_fin = true

                            buf_offset = buf_offset + msg_total
                            consumed = buf_offset

                    # Trim only successfully consumed bytes from hs_buf
                    var new_buf: [u8] = rt_array_new_with_cap((hs_buf.len() - consumed).to_i64())
                    var ti: u64 = consumed
                    while ti < hs_buf.len():
                        new_buf = _push_byte(new_buf, _u8_at(hs_buf, ti).to_u64().to_i64())
                        ti = ti + 1
                    hs_buf = new_buf

    # ------------------------------------------------------------------
    # Step 9: Verify CertificateVerify
    # ------------------------------------------------------------------
    val cv_hash = if fd_mode {
        _clone_bytes(rt_tls13_transcript_hash_6(
            ch_transcript_bytes,
            _copy_range(sh_hs_bytes, 0, sh_pay_len),
            fd_msg_cr,
            fd_msg_ee,
            fd_msg_cert,
            rt_array_new_with_cap(0)
        ))
    } else { transcript_hash(transcript_before_cv) }
    val sig_scheme = cert_verify_algo
    if pubkey_for_verify.len() == 0 and sig_scheme == 0x0807:
        pubkey_for_verify = extract_ed25519_pubkey_from_cert(cert_der)
    elif pubkey_for_verify.len() == 0 and ((sig_scheme == 0x0804) or (sig_scheme == 0x0805) or (sig_scheme == 0x0806)):
        pubkey_for_verify = extract_rsa_pubkey_spki_from_cert(cert_der)
    if sig_scheme == 0x0807:
        val cv_content_dbg = _build_server_cert_verify_content(cv_hash)
        _debug_bytes32("cv_hash", cv_hash)
        _debug_bytes32("cv_pubkey", pubkey_for_verify)
        if cert_verify_sig.len() >= 64:
            _debug_bytes32("cv_sig_lo", _copy_range(cert_verify_sig, 0, 32))
            _debug_bytes32("cv_sig_hi", _copy_range(cert_verify_sig, 32, 32))
        val raw_cv_rc = rt_ed25519_verify(cv_content_dbg, pubkey_for_verify, cert_verify_sig)
        val tls_cv_rc = rt_tls13_ed25519_verify(cv_content_dbg, pubkey_for_verify, cert_verify_sig)
        _tls_debug("cv verify raw_rc={raw_cv_rc} tls_rc={tls_cv_rc} pk_len={pubkey_for_verify.len()} sig_len={cert_verify_sig.len()}")
    val cv_result =
        if fd_mode and sig_scheme == 0x0807:
            val cv_fd_rc = rt_tls13_cert_verify_ed25519(cv_hash, pubkey_for_verify, cert_verify_sig)
            _tls_debug("cv verify fd_rc={cv_fd_rc}")
            if cv_fd_rc == 0:
                CertVerifyResult.Ok
            else:
                CertVerifyResult.Err(msg: "CertificateVerify signature invalid (fd-cv-rc={cv_fd_rc})")
        else:
            verify_certificate_verify_msg_scheme(pubkey_for_verify, sig_scheme, cv_hash, cert_verify_sig)

    if val CertVerifyResult.Err(cv_err) = cv_result:
        return Tls13ConnectResult.Failed(reason: cv_err)

    if config.root_store.len() > 0:
        if cert_chain.len() == 0:
            return Tls13ConnectResult.Failed(reason: "server certificate chain is empty")
        val chain_result = verify_cert_chain(cert_chain, config.root_store)
        if val CertChainResult.Err(chain_err) = chain_result:
            return Tls13ConnectResult.Failed(reason: chain_err)
    _tls_debug("after cert-verify root_store_len={config.root_store.len()}")

    # ------------------------------------------------------------------
    # Step 10: Verify server Finished
    # ------------------------------------------------------------------
    val server_fin_key = if io.kind == "fd" {
        rt_tls13_hkdf_expand_label_finished(secrets.server_hs_traffic)
    } else {
        tls13_finished_key(secrets.server_hs_traffic)
    }
    _tls_debug("after server_fin_key len={server_fin_key.len()}")
    val expected_fin = if io.kind == "fd" {
        rt_tls13_verify_data_hmac(server_fin_key, _clone_bytes(rt_tls13_transcript_hash_6(
            ch_transcript_bytes,
            _copy_range(sh_hs_bytes, 0, sh_pay_len),
            fd_msg_cr,
            fd_msg_ee,
            fd_msg_cert,
            fd_msg_cv
        )))
    } else {
        tls13_verify_data(server_fin_key, transcript_before_fin)
    }
    _tls_debug("after expected_fin len={expected_fin.len()} server_verify_len={server_verify_data.len()}")

    # Compare verify_data bytes
    if expected_fin.len() != server_verify_data.len():
        return Tls13ConnectResult.Failed(reason: "server Finished: length mismatch")

    var fin_ok: bool = true
    var fi: u64 = 0
    while fi < expected_fin.len():
        if expected_fin[fi] != server_verify_data[fi]:
            fin_ok = false
        fi = fi + 1

    if not fin_ok:
        return Tls13ConnectResult.Failed(reason: "server Finished: verify_data mismatch")
    _tls_debug("after server finished verify")

    # ------------------------------------------------------------------
    # Step 11: Compute application secrets (transcript after server Finished)
    # ------------------------------------------------------------------
    val app_secrets = tls13_compute_app_secrets(secrets, transcript)
    _tls_debug("after app_secrets server_len={app_secrets.server_app_traffic.len()} client_len={app_secrets.client_app_traffic.len()}")

    # ------------------------------------------------------------------
    # Step 12: Derive application traffic RecordKeys
    # ------------------------------------------------------------------
    val server_app_tk = tls13_traffic_keys(app_secrets.server_app_traffic)
    val client_app_tk = tls13_traffic_keys(app_secrets.client_app_traffic)
    _tls_debug("after app traffic keys")
    val server_app_rk = RecordKey(key: server_app_tk.key, iv: server_app_tk.iv)
    val client_app_rk = RecordKey(key: client_app_tk.key, iv: client_app_tk.iv)

    # ------------------------------------------------------------------
    # Step 13: Optional client auth, then client Finished
    # ------------------------------------------------------------------
    var client_hs_seq: u64 = 0
    if server_requested_client_auth:
        var client_cert_msg = build_certificate_bytes(cert_request.request_context, [])
        var should_send_cert_verify: bool = false

        if (config.client_cert_chain.len() > 0) and
           (config.client_pkcs8.len() > 0) and
           _sig_algs_contains(cert_request.sig_algs, config.client_sig_scheme):
            client_cert_msg = build_certificate_bytes(cert_request.request_context, config.client_cert_chain)
            if config.client_sig_scheme == 0x0807:
                should_send_cert_verify = true

        transcript = transcript_add(transcript, client_cert_msg)
        val client_cert_record = record13_encrypt(client_hs_rk, client_hs_seq, 0x16, client_cert_msg)
        _io_send(io, client_cert_record)
        client_hs_seq = client_hs_seq + 1

        if should_send_cert_verify:
            val client_cv_hash = transcript_hash(transcript)
            val client_cv_content = _build_client_cert_verify_content(client_cv_hash)
            val client_cv_sig = ed25519_sign(config.client_pkcs8, client_cv_content)
            if client_cv_sig.len() == 0:
                return Tls13ConnectResult.Failed(reason: "client CertificateVerify signing failed")
            val client_cv_msg = build_certificate_verify_bytes(config.client_sig_scheme, client_cv_sig)
            transcript = transcript_add(transcript, client_cv_msg)
            val client_cv_record = record13_encrypt(client_hs_rk, client_hs_seq, 0x16, client_cv_msg)
            _io_send(io, client_cv_record)
            client_hs_seq = client_hs_seq + 1

    val client_fin_key = if io.kind == "fd" {
        rt_tls13_hkdf_expand_label_finished(secrets.client_hs_traffic)
    } else {
        tls13_finished_key(secrets.client_hs_traffic)
    }
    val client_fin_data = if io.kind == "fd" {
        rt_tls13_verify_data_hmac(client_fin_key, _transcript_hash_fd(transcript))
    } else {
        tls13_verify_data(client_fin_key, transcript)
    }
    val client_fin_bytes = build_finished_bytes(client_fin_data)

    # Encrypt with handshake key at the next client handshake sequence number.
    val client_fin_record = record13_encrypt(client_hs_rk, client_hs_seq, 0x16, client_fin_bytes)
    if not _io_send(io, client_fin_record):
        return Tls13ConnectResult.Failed(reason: "client Finished send failed")

    # ------------------------------------------------------------------
    # Step 14-15: Reset seq numbers, return context with app keys
    # ------------------------------------------------------------------
    val ctx = Tls13Context(
        io: io,
        server_key: server_app_rk,
        client_key: client_app_rk,
        server_seq: 0,
        client_seq: 0,
    )
    Tls13ConnectResult.Connected(ctx: ctx)

# ============================================================================
# tls13_send — encrypt and send application data
# ============================================================================

fn tls13_send(ctx: Tls13Context, data: [u8]) -> Tls13SendResult:
    """Encrypt application data and report whether the transport write succeeded."""
    val record = record13_encrypt(ctx.client_key, ctx.client_seq, 0x17, data)
    if not _io_send(ctx.io, record):
        return Tls13SendResult(
            ctx: ctx,
            ok: false,
            reason: "application data send failed",
        )
    val new_ctx = Tls13Context(
        io: ctx.io,
        server_key: ctx.server_key,
        client_key: ctx.client_key,
        server_seq: ctx.server_seq,
        client_seq: ctx.client_seq + 1,
    )
    Tls13SendResult(
        ctx: new_ctx,
        ok: true,
        reason: "",
    )

# ============================================================================
# tls13_recv — decrypt one application data record
# ============================================================================

fn tls13_recv(ctx: Tls13Context) -> Tls13RecvData:
    """Read and decrypt one TLS record. Returns updated context and plaintext."""
    val raw = _io_recv_record(ctx.io)
    if raw.len() < 5:
        return Tls13RecvData(
            ctx: ctx,
            data: [],
            ok: false,
            reason: "application data read failed",
        )
    val dec = if ctx.io.kind == "fd":
        record13_decrypt_fd(ctx.server_key, ctx.server_seq, raw)
    else:
        record13_decrypt(ctx.server_key, ctx.server_seq, raw)

    if val RecordResult.Err(err_msg) = dec:
        return Tls13RecvData(
            ctx: ctx,
            data: [],
            ok: false,
            reason: err_msg,
        )

    if val RecordResult.Ok(_ct, dec_data) = dec:
        val new_ctx = Tls13Context(
            io: ctx.io,
            server_key: ctx.server_key,
            client_key: ctx.client_key,
            server_seq: ctx.server_seq + 1,
            client_seq: ctx.client_seq,
        )
        return Tls13RecvData(
            ctx: new_ctx,
            data: dec_data,
            ok: true,
            reason: "",
        )

    Tls13RecvData(
        ctx: ctx,
        data: [],
        ok: false,
        reason: "application data decrypt failed",
    )

# ============================================================================
# tls13_close — send close_notify alert and close TCP
# ============================================================================

fn tls13_close(ctx: Tls13Context) -> Tls13CloseResult:
    """Send close_notify alert (encrypted), then close the TCP connection."""
    # Alert: level=1 (warning), description=0 (close_notify)
    var alert: [u8] = []
    alert = _push_byte(alert, 0x01)  # warning
    alert = _push_byte(alert, 0x00)  # close_notify
    # content_type 0x15 = alert
    val alert_record = record13_encrypt(ctx.client_key, ctx.client_seq, 0x15, alert)
    if not _io_send(ctx.io, alert_record):
        return Tls13CloseResult(
            ok: false,
            reason: "close_notify send failed",
        )
    if ctx.io.kind == "host_stream":
        match ctx.io.host_stream.close():
            Ok(()):
                Tls13CloseResult(ok: true, reason: "")
            Err(_):
                Tls13CloseResult(ok: false, reason: "transport close failed")
    else:
        if rt_net_close(ctx.io.tcp_fd) < 0:
            Tls13CloseResult(ok: false, reason: "transport close failed")
        else:
            Tls13CloseResult(ok: true, reason: "")
