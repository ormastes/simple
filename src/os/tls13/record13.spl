#![allow(unnamed_duplicate_typed_args)]
# TLS 1.3 AEAD Record Layer
#
# Implements TLS 1.3 record encrypt/decrypt per RFC 8446 §5.2.
# Uses AES-128-GCM for AEAD. No Rust FFI — pure Simple, baremetal-safe.
#
# Reference: RFC 8446 §5.2 (TLSInnerPlaintext, TLSCiphertext)

use os.crypto.aes128_gcm.{aes128_gcm_encrypt, aes128_gcm_decrypt, Aes128GcmResult}
extern fn rt_tls13_aes128_gcm_decrypt(key: [u8], nonce: [u8], ciphertext: [u8], aad: [u8], tag: [u8]) -> [u8]

# ============================================================================
# Constants
# ============================================================================

val TLS_CONTENT_APPLICATION: u8 = 0x17
val TLS_LEGACY_VERSION_HI: u8 = 0x03
val TLS_LEGACY_VERSION_LO: u8 = 0x03
val TLS_MAX_FRAGMENT: u64 = 16384
val AEAD_TAG_SIZE: u64 = 16

# ============================================================================
# Types
# ============================================================================

class RecordKey:
    key: [u8]    # 16 bytes — AES-128 key
    iv: [u8]     # 12 bytes — base IV (XOR'd with seq_num to form nonce)

enum RecordResult:
    Ok(content_type: u8, data: [u8])
    Err(msg: text)

fn _u8_at(buf: [u8], idx: u64) -> u8:
    buf[idx]

fn _rec_debug(msg: text):
    pass

fn _copy_range(src: [u8], start: u64, count: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < count:
        out.push(_u8_at(src, start + i))
        i = i + 1
    out

fn _append_bytes(a: [u8], b: [u8]) -> [u8]:
    """Append two byte arrays without relying on array concatenation."""
    var out: [u8] = []
    var i: u64 = 0
    while i < a.len():
        out.push(_u8_at(a, i))
        i = i + 1
    i = 0
    while i < b.len():
        out.push(_u8_at(b, i))
        i = i + 1
    out

# ============================================================================
# record13_make_nonce
# ============================================================================

fn record13_make_nonce(iv: [u8], seq_num: u64) -> [u8]:
    """Build per-record nonce per RFC 8446 §5.3.

    Pad seq_num to 12 bytes (4 zero bytes + 8 big-endian bytes),
    then XOR each byte with the base IV.
    """
    var nonce: [u8] = []
    nonce.push(_u8_at(iv, 0) ^ 0x00)
    nonce.push(_u8_at(iv, 1) ^ 0x00)
    nonce.push(_u8_at(iv, 2) ^ 0x00)
    nonce.push(_u8_at(iv, 3) ^ 0x00)
    nonce.push(_u8_at(iv, 4) ^ ((seq_num >> 56) & 0xFF).to_u8())
    nonce.push(_u8_at(iv, 5) ^ ((seq_num >> 48) & 0xFF).to_u8())
    nonce.push(_u8_at(iv, 6) ^ ((seq_num >> 40) & 0xFF).to_u8())
    nonce.push(_u8_at(iv, 7) ^ ((seq_num >> 32) & 0xFF).to_u8())
    nonce.push(_u8_at(iv, 8) ^ ((seq_num >> 24) & 0xFF).to_u8())
    nonce.push(_u8_at(iv, 9) ^ ((seq_num >> 16) & 0xFF).to_u8())
    nonce.push(_u8_at(iv, 10) ^ ((seq_num >> 8) & 0xFF).to_u8())
    nonce.push(_u8_at(iv, 11) ^ (seq_num & 0xFF).to_u8())
    nonce

# ============================================================================
# record13_build_header
# ============================================================================

fn record13_build_header(payload_length: u64) -> [u8]:
    """Build the 5-byte TLS record header.

    Format: content_type(1) || legacy_version(2) || length(2 big-endian)
    For TLS 1.3, content_type is always 0x17 (application_data),
    legacy_version is always 0x0303.
    """
    var header: [u8] = []
    header.push(0x17u8)
    header.push(0x03u8)
    header.push(0x03u8)
    header.push(((payload_length >> 8) & 0xFF).to_u8())
    header.push((payload_length & 0xFF).to_u8())
    header

# ============================================================================
# record13_encrypt
# ============================================================================

fn record13_encrypt(rk: RecordKey, seq_num: u64, content_type: u8, plaintext: [u8]) -> [u8]:
    """Encrypt a TLS 1.3 record.

    Builds TLSInnerPlaintext = plaintext || content_type, then AEAD-encrypts
    with the record header as AAD. Returns the full TLSCiphertext wire bytes.

    Args:
        rk: RecordKey with 16-byte key and 12-byte IV.
        seq_num: Sequence number for nonce derivation.
        content_type: Real content type (e.g. 0x17 for application data).
        plaintext: Data to encrypt.

    Returns: 5-byte header || ciphertext || 16-byte tag.
    """
    # TLSInnerPlaintext = plaintext || content_type byte
    var inner: [u8] = []
    var i: u64 = 0
    while i < plaintext.len():
        inner.push(plaintext[i])
        i = i + 1
    inner.push(content_type)

    # payload_length = len(inner) + AEAD tag size
    val payload_length = inner.len() + AEAD_TAG_SIZE
    val header_hi = ((payload_length >> 8) & 0xFF).to_u8()
    val header_lo = (payload_length & 0xFF).to_u8()

    # Derive per-record nonce
    val nonce = record13_make_nonce(rk.iv, seq_num)

    # AEAD encrypt: returns ciphertext || tag
    val aead_output = aes128_gcm_encrypt(
        rk.key,
        nonce,
        inner,
        [0x17u8, 0x03u8, 0x03u8, header_hi, header_lo]
    )

    # Assemble: header || ciphertext || tag
    _append_bytes(
        [0x17u8, 0x03u8, 0x03u8, header_hi, header_lo],
        aead_output
    )

# ============================================================================
# record13_decrypt
# ============================================================================

fn record13_decrypt(rk: RecordKey, seq_num: u64, raw_record: [u8]) -> RecordResult:
    """Decrypt and authenticate a TLS 1.3 record.

    Validates header, extracts ciphertext and tag, AEAD-decrypts,
    then strips the inner content_type byte from the plaintext.

    Args:
        rk: RecordKey with 16-byte key and 12-byte IV.
        seq_num: Sequence number for nonce derivation.
        raw_record: Full TLSCiphertext wire bytes (header + payload).

    Returns: RecordResult.Ok(content_type, data) on success,
             RecordResult.Err(msg) on validation or authentication failure.
    """
    # Validate minimum length for header
    _rec_debug("decrypt raw_len={raw_record.len()} seq={seq_num}")
    if raw_record.len() < 5:
        return RecordResult.Err("record too short: missing header")

    _rec_debug("header b0={_u8_at(raw_record, 0)} b1={_u8_at(raw_record, 1)} b2={_u8_at(raw_record, 2)} b3={_u8_at(raw_record, 3)} b4={_u8_at(raw_record, 4)}")

    # Validate TLS 1.3 header fields
    if _u8_at(raw_record, 0) != 0x17:
        return RecordResult.Err("record header: expected content_type 0x17")
    if _u8_at(raw_record, 1) != 0x03:
        return RecordResult.Err("record header: expected legacy_version_hi 0x03")
    if _u8_at(raw_record, 2) != 0x03:
        return RecordResult.Err("record header: expected legacy_version_lo 0x03")

    # Read payload_length from header[3..4] big-endian
    val payload_length = (_u8_at(raw_record, 3).to_u64() << 8) | _u8_at(raw_record, 4).to_u64()
    _rec_debug("payload_length={payload_length}")

    val header_len: u64 = 5
    val available_payload = raw_record.len() - header_len
    if available_payload < payload_length:
        _rec_debug("truncated raw_len={raw_record.len()} available_payload={available_payload} payload_length={payload_length}")
        return RecordResult.Err("record too short: payload truncated")

    # Payload must be at least the tag size (16 bytes)
    if payload_length < AEAD_TAG_SIZE:
        return RecordResult.Err("record payload too short: less than tag size")

    val ct_len = payload_length - AEAD_TAG_SIZE

    # Extract ciphertext: raw_record[5 .. 5+ct_len]
    val ciphertext = _copy_range(raw_record, header_len, ct_len)

    # Extract tag: raw_record[5+ct_len .. 5+payload_length]
    val tag_start = raw_record.len() - AEAD_TAG_SIZE
    val tag = _copy_range(raw_record, tag_start, AEAD_TAG_SIZE)

    # AAD = header (5 bytes)
    val aad = _copy_range(raw_record, 0, 5)

    # Derive per-record nonce
    val nonce = record13_make_nonce(rk.iv, seq_num)

    # AEAD decrypt
    val dec_result = aes128_gcm_decrypt(rk.key, nonce, ciphertext, aad, tag)

    if val Aes128GcmResult.Ok(inner) = dec_result:
        # TLSInnerPlaintext = content || zeros* || content_type.
        # Strip the final content_type and any zero padding that precedes it.
        if inner.len() == 0:
            return RecordResult.Err("decrypted inner plaintext is empty")
        var cursor = inner.len()
        while cursor > 0:
            val idx = cursor - 1
            if _u8_at(inner, idx) != 0x00:
                cursor = idx
                break
            cursor = idx
        if cursor >= inner.len():
            return RecordResult.Err("decrypted inner plaintext missing content type")
        val real_content_type = _u8_at(inner, cursor)
        var data: [u8] = []
        var j: u64 = 0
        while j < cursor:
            data.push(_u8_at(inner, j))
            j = j + 1
        return RecordResult.Ok(content_type: real_content_type, data: data)

    if val Aes128GcmResult.Err(err_msg) = dec_result:
        return RecordResult.Err(err_msg)

    RecordResult.Err("aes128_gcm_decrypt returned unexpected result")

fn record13_decrypt_fd(rk: RecordKey, seq_num: u64, raw_record: [u8]) -> RecordResult:
    _rec_debug("decrypt(fd) raw_len={raw_record.len()} seq={seq_num}")
    if raw_record.len() < 5:
        return RecordResult.Err("record too short: missing header")

    if _u8_at(raw_record, 0) != 0x17:
        return RecordResult.Err("record header: expected content_type 0x17")
    if _u8_at(raw_record, 1) != 0x03:
        return RecordResult.Err("record header: expected legacy_version_hi 0x03")
    if _u8_at(raw_record, 2) != 0x03:
        return RecordResult.Err("record header: expected legacy_version_lo 0x03")

    val payload_length = (_u8_at(raw_record, 3).to_u64() << 8) | _u8_at(raw_record, 4).to_u64()
    val header_len: u64 = 5
    val available_payload = raw_record.len() - header_len
    if available_payload < payload_length:
        return RecordResult.Err("record too short: payload truncated")
    if payload_length < AEAD_TAG_SIZE:
        return RecordResult.Err("record payload too short: less than tag size")

    val ct_len = payload_length - AEAD_TAG_SIZE
    val ciphertext = _copy_range(raw_record, header_len, ct_len)
    val tag_start = raw_record.len() - AEAD_TAG_SIZE
    val tag = _copy_range(raw_record, tag_start, AEAD_TAG_SIZE)
    val aad = _copy_range(raw_record, 0, 5)
    val nonce = record13_make_nonce(rk.iv, seq_num)
    val inner = rt_tls13_aes128_gcm_decrypt(rk.key, nonce, ciphertext, aad, tag)
    if inner.len() == 0:
        return RecordResult.Err("authentication tag mismatch")
    _rec_debug("decrypt(fd) inner_len={inner.len()} b0={_u8_at(inner, 0)}")

    var cursor = inner.len()
    while cursor > 0:
        val idx = cursor - 1
        if _u8_at(inner, idx) != 0x00:
            cursor = idx
            break
        cursor = idx
    if cursor >= inner.len():
        return RecordResult.Err("decrypted inner plaintext missing content type")
    val real_content_type = _u8_at(inner, cursor)
    _rec_debug("decrypt(fd) real_ct={real_content_type} data_len={cursor}")
    var data: [u8] = []
    var j: u64 = 0
    while j < cursor:
        data.push(_u8_at(inner, j))
        j = j + 1
    return RecordResult.Ok(content_type: real_content_type, data: data)

fn record13_decrypt_fd_inner(rk: RecordKey, seq_num: u64, raw_record: [u8]) -> [u8]:
    _rec_debug("decrypt(fd) raw_len={raw_record.len()} seq={seq_num}")
    if raw_record.len() < 5:
        return []

    if _u8_at(raw_record, 0) != 0x17:
        return []
    if _u8_at(raw_record, 1) != 0x03:
        return []
    if _u8_at(raw_record, 2) != 0x03:
        return []

    val payload_length = (_u8_at(raw_record, 3).to_u64() << 8) | _u8_at(raw_record, 4).to_u64()
    val header_len: u64 = 5
    val available_payload = raw_record.len() - header_len
    if available_payload < payload_length:
        return []
    if payload_length < AEAD_TAG_SIZE:
        return []

    val ct_len = payload_length - AEAD_TAG_SIZE
    val ciphertext = _copy_range(raw_record, header_len, ct_len)
    val tag_start = raw_record.len() - AEAD_TAG_SIZE
    val tag = _copy_range(raw_record, tag_start, AEAD_TAG_SIZE)
    val aad = _copy_range(raw_record, 0, 5)
    val nonce = record13_make_nonce(rk.iv, seq_num)
    val inner = rt_tls13_aes128_gcm_decrypt(rk.key, nonce, ciphertext, aad, tag)
    if inner.len() == 0:
        return []
    _rec_debug("decrypt(fd) inner_len={inner.len()} b0={_u8_at(inner, 0)}")
    inner
