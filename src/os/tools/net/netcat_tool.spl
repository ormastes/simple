# nc / netcat — Network utility
# MDSOC: feature dimension, apps layer

use os.userlib.net.{SockAddr, Socket, socket, connect, send, recv, bind, listen, accept}

fn run_netcat(args: [text]) -> i32:
    """Netcat — read/write data across network connections.

    Usage: nc HOST PORT            (connect mode)
           nc -l PORT              (listen mode)
    """
    var listen_mode = false
    var host = ""
    var port: i32 = 0
    var positional: [text] = []

    for arg in args:
        if arg == "-l":
            listen_mode = true
        else:
            positional = positional.push(arg)

    if listen_mode:
        if positional.len() < 1:
            print "nc: missing port"
            return 1
        port = _nc_parse_int(positional[0])
        return _nc_listen(port)
    else:
        if positional.len() < 2:
            print "nc: missing host or port"
            return 1
        host = positional[0]
        port = _nc_parse_int(positional[1])
        return _nc_connect(host, port)

fn _nc_connect(host: text, port: i32) -> i32:
    """Connect to host:port and relay data."""
    val sock = socket("tcp")
    val addr = SockAddr(host: host, port: port)
    connect(sock, addr)
    print "nc: connected to {host}:{port}"

    # Read response
    val data = recv(sock, 4096, 5000)
    if data.len() > 0:
        print data.as_text()
    return 0

fn _nc_listen(port: i32) -> i32:
    """Listen on port and accept one connection."""
    val sock = socket("tcp")
    val addr = SockAddr(host: "0.0.0.0", port: port)
    bind(sock, addr)
    listen(sock, 1)
    print "nc: listening on port {port}"

    val client = accept(sock)
    print "nc: connection accepted"

    val data = recv(client, 4096, 5000)
    if data.len() > 0:
        print data.as_text()
    return 0

fn _nc_parse_int(s: text) -> i32:
    var result: i32 = 0
    for ch in s:
        if ch >= "0" and ch <= "9":
            result = result * 10 + (ch.to_i32() - "0".to_i32())
    return result
