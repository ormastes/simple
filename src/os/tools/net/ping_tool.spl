use os.userlib.net.{IpAddr, SockAddr, Socket, socket, connect, send, recv}

## ICMP ping tool.
## Usage: ping HOST [-c COUNT] [-i INTERVAL_MS]

struct PingOptions:
    host: text
    count: i32
    interval_ms: i32

struct PingResult:
    seq: i32
    rtt_ms: i64
    success: bool

fn _parse_args(args: [text]) -> Result<PingOptions, text>:
    if args.len() == 0:
        return Err("missing HOST")

    var host = args[0]
    var count = 4
    var interval_ms = 1000
    var idx = 1

    while idx < args.len():
        val arg = args[idx]
        if arg == "-c":
            idx = idx + 1
            if idx >= args.len():
                return Err("-c requires a value")
            count = args[idx].to_i32() ?? 4
        else if arg == "-i":
            idx = idx + 1
            if idx >= args.len():
                return Err("-i requires a value")
            interval_ms = args[idx].to_i32() ?? 1000
        else if arg == "-h":
            return Err("help")
        idx = idx + 1

    Ok(PingOptions(host: host, count: count, interval_ms: interval_ms))

fn _build_icmp_echo(seq: i32) -> [u8]:
    ## Build minimal ICMP echo request packet
    ## Type=8, Code=0, Checksum=placeholder, ID=0x1234, Seq=seq
    var packet: [u8] = [8, 0, 0, 0, 0x12, 0x34, 0, 0]
    packet[6] = (seq >> 8) & 0xFF
    packet[7] = seq & 0xFF

    ## Compute checksum
    var sum: u32 = 0
    var i = 0
    while i < packet.len():
        val high = packet[i]
        val low = if i + 1 < packet.len(): packet[i + 1] else: 0
        sum = sum + (high << 8) + low
        i = i + 2

    sum = (sum >> 16) + (sum & 0xFFFF)
    sum = sum + (sum >> 16)
    val checksum = ~sum & 0xFFFF
    packet[2] = (checksum >> 8) & 0xFF
    packet[3] = checksum & 0xFF

    packet

fn _send_ping(sock: Socket, addr: SockAddr, seq: i32) -> PingResult:
    val packet = _build_icmp_echo(seq)
    val start = clock_ms()
    send(sock, addr, packet)
    val reply = recv(sock, 64, 2000)
    val end = clock_ms()

    if reply.len() > 0:
        PingResult(seq: seq, rtt_ms: end - start, success: true)
    else:
        PingResult(seq: seq, rtt_ms: 0, success: false)

fn _print_usage():
    print "Usage: ping HOST [-c COUNT] [-i INTERVAL_MS]"
    print ""
    print "Send ICMP echo requests to a host."
    print ""
    print "Options:"
    print "  -c COUNT        Number of pings (default: 4)"
    print "  -i INTERVAL_MS  Interval between pings in ms (default: 1000)"

extern fn clock_ms() -> i64
extern fn sleep_ms(ms: i32)

fn run_ping(args: [text]) -> i32:
    val opts_result = _parse_args(args)
    match opts_result:
        Err(msg):
            if msg == "help":
                _print_usage()
                return 0
            print "ping: {msg}"
            _print_usage()
            return 1
        Ok(opts):
            pass_dn

    val opts = opts_result.unwrap()
    val host = opts.host
    val count = opts.count

    print "PING {host}: {count} packets"

    val sock = socket("icmp")
    val addr = SockAddr(host: host, port: 0)

    var transmitted = 0
    var received = 0
    var seq = 0

    while seq < count:
        val result = _send_ping(sock, addr, seq)
        transmitted = transmitted + 1

        if result.success:
            val rtt = result.rtt_ms
            print "64 bytes from {host}: icmp_seq={seq} time={rtt}ms"
            received = received + 1
        else:
            print "Request timeout for icmp_seq {seq}"

        seq = seq + 1
        if seq < count:
            sleep_ms(opts.interval_ms)

    print ""
    val loss = if transmitted > 0: ((transmitted - received) * 100) / transmitted else: 0
    print "{transmitted} packets transmitted, {received} received, {loss}% loss"

    if received == 0: 1 else: 0
