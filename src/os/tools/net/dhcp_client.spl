#![allow(unnamed_duplicate_typed_args)]
use os.userlib.net.{SockAddr, Socket, socket, send, recv}

## DHCP client.
## Usage: dhcp [INTERFACE]

val DHCP_CLIENT_PORT = 68
val DHCP_SERVER_PORT = 67
val BROADCAST_ADDR = "255.255.255.255"

struct DhcpLease:
    ip: text
    netmask: text
    gateway: text
    dns: text
    lease_time: u32

fn _build_dhcp_discover() -> [u8]:
    ## Minimal DHCP DISCOVER packet
    ## op=1(BOOTREQUEST), htype=1(Ethernet), hlen=6, hops=0
    var packet: [u8] = [1, 1, 6, 0]

    ## XID (transaction ID) - fixed for simplicity
    packet = packet + [0xDE, 0xAD, 0xBE, 0xEF]

    ## secs=0, flags=0x8000 (broadcast)
    packet = packet + [0x00, 0x00, 0x80, 0x00]

    ## ciaddr, yiaddr, siaddr, giaddr (all zeros, 16 bytes)
    var i = 0
    while i < 16:
        packet.push(0)
        i = i + 1

    ## chaddr (MAC placeholder, 16 bytes padded)
    packet = packet + [0x52, 0x54, 0x00, 0x12, 0x34, 0x56]
    i = 0
    while i < 10:
        packet.push(0)
        i = i + 1

    ## sname (64 bytes) + file (128 bytes) = 192 zeros
    i = 0
    while i < 192:
        packet.push(0)
        i = i + 1

    ## DHCP magic cookie
    packet = packet + [99, 130, 83, 99]

    ## Option 53: DHCP Message Type = 1 (DISCOVER)
    packet = packet + [53, 1, 1]
    ## Option 255: End
    packet.push(255)

    packet

fn _build_dhcp_request(offered_ip: [u8], server_ip: [u8]) -> [u8]:
    var packet: [u8] = [1, 1, 6, 0]
    packet = packet + [0xDE, 0xAD, 0xBE, 0xEF]
    packet = packet + [0x00, 0x00, 0x80, 0x00]

    var i = 0
    while i < 16:
        packet.push(0)
        i = i + 1

    packet = packet + [0x52, 0x54, 0x00, 0x12, 0x34, 0x56]
    i = 0
    while i < 10:
        packet.push(0)
        i = i + 1

    i = 0
    while i < 192:
        packet.push(0)
        i = i + 1

    packet = packet + [99, 130, 83, 99]

    ## Option 53: DHCP Message Type = 3 (REQUEST)
    packet = packet + [53, 1, 3]
    ## Option 50: Requested IP
    packet = packet + [50, 4] + offered_ip
    ## Option 54: Server Identifier
    packet = packet + [54, 4] + server_ip
    ## Option 255: End
    packet.push(255)

    packet

fn _parse_dhcp_response(data: [u8]) -> Result<DhcpLease, text>:
    if data.len() < 240:
        return Err("response too short")

    ## yiaddr at offset 16
    val ip = "{data[16]}.{data[17]}.{data[18]}.{data[19]}"

    var netmask = "255.255.255.0"
    var gateway = ""
    var dns = ""
    var lease_time: u32 = 86400

    ## Parse options starting after magic cookie (offset 240)
    var offset = 240
    while offset < data.len():
        val opt = data[offset]
        if opt == 255:
            break
        if opt == 0:
            offset = offset + 1
            continue
        val opt_len = data[offset + 1]
        offset = offset + 2

        if opt == 1 and opt_len == 4:
            netmask = "{data[offset]}.{data[offset+1]}.{data[offset+2]}.{data[offset+3]}"
        else if opt == 3 and opt_len >= 4:
            gateway = "{data[offset]}.{data[offset+1]}.{data[offset+2]}.{data[offset+3]}"
        else if opt == 6 and opt_len >= 4:
            dns = "{data[offset]}.{data[offset+1]}.{data[offset+2]}.{data[offset+3]}"
        else if opt == 51 and opt_len == 4:
            lease_time = (data[offset] << 24) | (data[offset+1] << 16) | (data[offset+2] << 8) | data[offset+3]

        offset = offset + opt_len

    Ok(DhcpLease(ip: ip, netmask: netmask, gateway: gateway, dns: dns, lease_time: lease_time))

fn _print_usage():
    print "Usage: dhcp [INTERFACE] [-h]"
    print ""
    print "Request a DHCP lease on the specified interface."
    print "Default interface: eth0"

fn run_dhcp(args: [text]) -> i32:
    for arg in args:
        if arg == "-h":
            _print_usage()
            return 0

    val iface = if args.len() > 0: args[0] else: "eth0"
    print "DHCP: requesting lease on {iface}..."

    val sock = socket("udp")
    val server_addr = SockAddr(host: BROADCAST_ADDR, port: DHCP_SERVER_PORT)

    ## Send DHCPDISCOVER
    val discover = _build_dhcp_discover()
    send(sock, server_addr, discover)
    print "  DHCPDISCOVER sent"

    ## Wait for DHCPOFFER
    val offer_data = recv(sock, 1024, 5000)
    if offer_data.len() == 0:
        print "DHCP: no DHCPOFFER received (timeout)"
        return 1
    print "  DHCPOFFER received"

    val offer_result = _parse_dhcp_response(offer_data)
    match offer_result:
        Err(msg):
            print "DHCP: failed to parse offer: {msg}"
            return 1
        Ok(_):
            pass_dn

    val offer = offer_result.unwrap()

    ## Send DHCPREQUEST
    val offered_ip = [offer_data[16], offer_data[17], offer_data[18], offer_data[19]]
    val server_ip = [offer_data[20], offer_data[21], offer_data[22], offer_data[23]]
    val request = _build_dhcp_request(offered_ip, server_ip)
    send(sock, server_addr, request)
    print "  DHCPREQUEST sent"

    ## Wait for DHCPACK
    val ack_data = recv(sock, 1024, 5000)
    if ack_data.len() == 0:
        print "DHCP: no DHCPACK received (timeout)"
        return 1

    val ack_result = _parse_dhcp_response(ack_data)
    match ack_result:
        Err(msg):
            print "DHCP: failed to parse ACK: {msg}"
            return 1
        Ok(_):
            pass_dn

    val lease = ack_result.unwrap()
    print "  DHCPACK received"
    print ""
    print "Lease acquired:"
    print "  IP:         {lease.ip}"
    print "  Netmask:    {lease.netmask}"
    print "  Gateway:    {lease.gateway}"
    print "  DNS:        {lease.dns}"
    print "  Lease time: {lease.lease_time}s"

    0
