# ssh — SSH client
# MDSOC: feature dimension, apps layer

fn run_ssh(args: [text]) -> i32:
    """SSH client (stub — delegates to sshd infrastructure).

    Usage: ssh [user@]host [command]
    """
    if args.len() == 0:
        print "ssh: missing host"
        print "Usage: ssh [user@]host [command]"
        return 1

    val target = args[0]
    var user = "root"
    var host = target

    # Parse user@host
    val at_idx = target.find("@")
    if at_idx >= 0:
        user = target.slice(0, at_idx)
        host = target.slice(at_idx + 1, target.len())

    print "ssh: connecting to {user}@{host}..."
    print "ssh: client not yet implemented (sshd server exists at src/os/apps/sshd/)"
    return 1
