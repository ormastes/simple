use os.userlib.net.{SockAddr, Socket, socket, connect, send, recv}
use os.userlib.fs.{write_text}

## HTTP file downloader.
## Usage: wget URL [-o OUTPUT_FILE]

struct ParsedUrl:
    scheme: text
    host: text
    port: i32
    path: text

fn _parse_url(url: text) -> Result<ParsedUrl, text>:
    var remaining = url
    var scheme = "http"
    var port = 80

    if remaining.starts_with("http://"):
        remaining = remaining.slice(7, remaining.len())
        scheme = "http"
        port = 80
    else if remaining.starts_with("https://"):
        remaining = remaining.slice(8, remaining.len())
        scheme = "https"
        port = 443
    else if remaining.contains("://"):
        return Err("unsupported scheme")

    ## Split host and path
    val slash_idx = remaining.index_of("/")
    var host = ""
    var path = "/"
    if val Some(idx) = slash_idx:
        host = remaining.slice(0, idx)
        path = remaining.slice(idx, remaining.len())
    else:
        host = remaining

    ## Check for port in host
    val colon_idx = host.index_of(":")
    if val Some(cidx) = colon_idx:
        val port_str = host.slice(cidx + 1, host.len())
        host = host.slice(0, cidx)
        port = port_str.to_i32() ?? port

    if host.len() == 0:
        return Err("empty hostname")

    Ok(ParsedUrl(scheme: scheme, host: host, port: port, path: path))

fn _filename_from_url(parsed: ParsedUrl) -> text:
    val path = parsed.path
    val last_slash = path.last_index_of("/")
    if val Some(idx) = last_slash:
        val name = path.slice(idx + 1, path.len())
        if name.len() > 0:
            return name
    "index.html"

fn _build_http_request(parsed: ParsedUrl) -> text:
    val host = parsed.host
    val path = parsed.path
    "GET {path} HTTP/1.1\r\nHost: {host}\r\nConnection: close\r\nUser-Agent: wget-simple/1.0\r\n\r\n"

fn _extract_body(response: text) -> text:
    val separator = "\r\n\r\n"
    val idx = response.index_of(separator)
    if val Some(i) = idx:
        return response.slice(i + 4, response.len())
    response

fn _print_usage():
    print "Usage: wget URL [-o OUTPUT_FILE]"
    print ""
    print "Download a file via HTTP."
    print ""
    print "Options:"
    print "  -o FILE   Save to FILE (default: derived from URL)"
    print "  -h        Show this help"

fn run_wget(args: [text]) -> i32:
    if args.len() == 0:
        _print_usage()
        return 1

    if args[0] == "-h":
        _print_usage()
        return 0

    val url = args[0]

    ## Parse output file option
    var output_file = ""
    var idx = 1
    while idx < args.len():
        if args[idx] == "-o":
            idx = idx + 1
            if idx < args.len():
                output_file = args[idx]
        idx = idx + 1

    val parsed_result = _parse_url(url)
    match parsed_result:
        Err(msg):
            print "wget: invalid URL: {msg}"
            return 1
        Ok(_):
            pass_dn

    val parsed = parsed_result.unwrap()

    if output_file.len() == 0:
        output_file = _filename_from_url(parsed)

    val host = parsed.host
    val port = parsed.port
    print "Connecting to {host}:{port}..."

    val sock = socket("tcp")
    val addr = SockAddr(host: host, port: port)
    connect(sock, addr)

    val request = _build_http_request(parsed)
    send(sock, addr, request.bytes())

    ## Read response
    var response_bytes: [u8] = []
    var chunk = recv(sock, 4096, 10000)
    while chunk.len() > 0:
        response_bytes = response_bytes + chunk
        chunk = recv(sock, 4096, 1000)

    if response_bytes.len() == 0:
        print "wget: no response from server"
        return 1

    val response_text = text.from_bytes(response_bytes)
    val body = _extract_body(response_text)

    write_text(output_file, body)
    val size = body.len()
    print "Saved to '{output_file}' ({size} bytes)"

    0
