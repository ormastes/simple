# id / whoami — User identity
# MDSOC: feature dimension, apps layer

use os.apps.terminal.terminal.{Terminal}
use os.apps.shell.shell_tools.{_write_line}

fn run_id(args: [text]) -> i32:
    """Print user identity."""
    print "uid=0(root) gid=0(root)"
    return 0

fn tool_id(terminal: Terminal) -> i32:
    """Print user identity. SimpleOS is single-user (root)."""
    _write_line(terminal, "uid=0(root) gid=0(root)")
    return 0

fn run_whoami(args: [text]) -> i32:
    """Print current user name."""
    print "root"
    return 0

fn tool_whoami(terminal: Terminal) -> i32:
    """Print current user name."""
    _write_line(terminal, "root")
    return 0
