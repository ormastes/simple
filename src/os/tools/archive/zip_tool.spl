# Zip Tool — ZIP Archive
# MDSOC: feature dimension, apps layer

use os.userlib.fs.{read_text, write_text, readdir}

struct ZipEntry:
    name: text
    size: u64
    compressed_size: u64
    data: text

fn run_zip(args: [text]) -> i32:
    """ZIP archive tool.

    Usage: zip ARCHIVE FILES...
           unzip ARCHIVE [-d DEST]
    """
    if args.len() < 1:
        print "Usage: zip ARCHIVE FILES... | unzip ARCHIVE [-d DEST]"
        return 1

    # Determine mode from first arg or invocation context
    val archive_path = args[0]

    # Check if we have files to add (zip mode) or just an archive (unzip mode)
    if args.len() >= 2:
        val second = args[1]
        if second == "-d":
            # unzip mode: unzip ARCHIVE -d DEST
            var dest = "."
            if args.len() >= 3:
                dest = args[2]
            val result = zip_extract(archive_path, dest)
            if val Ok(count) = result:
                print "Extracted {count} files to {dest}"
                return 0
            else if val Err(e) = result:
                print "Error: {e}"
                return 1
        else:
            # zip mode: zip ARCHIVE FILES...
            var files: [text] = []
            var i = 1
            while i < args.len():
                files.push(args[i])
                i = i + 1
            val result = zip_create(archive_path, files)
            if val Ok(_) = result:
                print "Created archive: {archive_path}"
                return 0
            else if val Err(e) = result:
                print "Error: {e}"
                return 1
    else:
        # List mode if only archive given
        val result = zip_list(archive_path)
        if val Ok(entries) = result:
            for entry in entries:
                print "{entry.name}\t{entry.size}"
            return 0
        else if val Err(e) = result:
            print "Error: {e}"
            return 1

    return 0

fn zip_create(archive_path: text, files: [text]) -> Result<bool, text>:
    """Create a ZIP archive from files."""
    var entries: [ZipEntry] = []
    for path in files:
        val content = read_text(path)
        val entry = ZipEntry(
            name: path,
            size: content.len().to_u64(),
            compressed_size: content.len().to_u64(),
            data: content
        )
        entries.push(entry)

    # Serialize as simple text-based zip (header + entries)
    var archive = "ZIP_SIMPLE_V1\n"
    archive = archive + "{entries.len()}\n"
    for entry in entries:
        archive = archive + "{entry.name}\t{entry.size}\n"
        archive = archive + entry.data
        archive = archive + "\n---ENTRY_END---\n"

    write_text(archive_path, archive)
    return Result.Ok(true)

fn zip_extract(archive_path: text, dest: text) -> Result<i32, text>:
    """Extract a ZIP archive to destination directory. Returns file count."""
    val data = read_text(archive_path)
    val lines = data.split("\n")

    if lines.len() < 2:
        return Result.Err("Invalid archive format")
    if lines[0] != "ZIP_SIMPLE_V1":
        return Result.Err("Unsupported archive format: {lines[0]}")

    val entry_count = lines[1].to_i32()
    var count = 0
    var line_idx = 2

    while count < entry_count:
        if line_idx >= lines.len():
            return Result.Err("Unexpected end of archive")

        val header_line = lines[line_idx]
        val parts = header_line.split("\t")
        if parts.len() < 2:
            return Result.Err("Invalid entry header at line {line_idx}")

        val name = parts[0]
        line_idx = line_idx + 1

        # Read data until ---ENTRY_END--- marker
        var file_data = ""
        while line_idx < lines.len():
            if lines[line_idx] == "---ENTRY_END---":
                line_idx = line_idx + 1
                break
            if file_data != "":
                file_data = file_data + "\n"
            file_data = file_data + lines[line_idx]
            line_idx = line_idx + 1

        val out_path = "{dest}/{name}"
        write_text(out_path, file_data)
        count = count + 1

    return Result.Ok(count)

fn zip_list(archive_path: text) -> Result<[ZipEntry], text>:
    """List contents of a ZIP archive."""
    val data = read_text(archive_path)
    val lines = data.split("\n")

    if lines.len() < 2:
        return Result.Err("Invalid archive format")
    if lines[0] != "ZIP_SIMPLE_V1":
        return Result.Err("Unsupported archive format: {lines[0]}")

    val entry_count = lines[1].to_i32()
    var entries: [ZipEntry] = []
    var count = 0
    var line_idx = 2

    while count < entry_count:
        if line_idx >= lines.len():
            return Result.Err("Unexpected end of archive")

        val header_line = lines[line_idx]
        val parts = header_line.split("\t")
        if parts.len() < 2:
            return Result.Err("Invalid entry header at line {line_idx}")

        val entry = ZipEntry(
            name: parts[0],
            size: parts[1].to_u64(),
            compressed_size: parts[1].to_u64(),
            data: ""
        )
        entries.push(entry)

        # Skip data lines until marker
        line_idx = line_idx + 1
        while line_idx < lines.len():
            if lines[line_idx] == "---ENTRY_END---":
                line_idx = line_idx + 1
                break
            line_idx = line_idx + 1

        count = count + 1

    return Result.Ok(entries)
