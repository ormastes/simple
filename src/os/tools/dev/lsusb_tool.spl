## List USB devices.
## Stub until USB host controller driver exists.

fn run_lsusb(args: [text]) -> i32:
    for arg in args:
        if arg == "-h":
            print "Usage: lsusb [-h]"
            print ""
            print "List USB devices."
            print "  (USB host controller driver not yet implemented)"
            return 0

    print "lsusb: no USB host controller found"
    print "  (USB driver not yet implemented)"
    0
