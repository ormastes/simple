use os.userlib.device.{DeviceEntry, enumerate_devices}

## List USB host controllers found on the PCI bus.
## Flags: -h (help)
##
## Filters PCI class 0x0C, subclass 0x03 (USB controller).
## prog_if (UHCI/OHCI/EHCI/XHCI distinction) is not exposed by DeviceEntry,
## so all USB controllers are reported generically as "USB Controller".

val USB_CLASS: u8 = 0x0C
val USB_SUBCLASS: u8 = 0x03

fn is_usb_controller(class_code: u8, subclass: u8) -> bool:
    """Return true when class/subclass identify a USB host controller (0x0C/0x03)."""
    class_code == USB_CLASS and subclass == USB_SUBCLASS

fn _format_usb_line(entry: DeviceEntry) -> text:
    val bus = entry.bus
    val device = entry.device
    val func = entry.func
    val vendor = entry.vendor_id
    val dev_id = entry.device_id
    "Bus {bus:02x} Device {device:02x} Function {func}: USB Controller [{vendor:04x}:{dev_id:04x}]"

fn _print_usage():
    print "Usage: lsusb [-h]"
    print ""
    print "List USB host controllers (PCI class 0x0C, subclass 0x03)."
    print ""
    print "Options:"
    print "  -h    Show this help"

fn run_lsusb(args: [text]) -> i32:
    for arg in args:
        if arg == "-h":
            _print_usage()
            return 0

    val result = enumerate_devices()
    if val Err(msg) = result:
        print "lsusb: error enumerating devices: {msg}"
        return 1

    val devices = result.unwrap()
    var found: i32 = 0
    for entry in devices:
        if is_usb_controller(entry.class_code, entry.subclass):
            val line = _format_usb_line(entry)
            print line
            found = found + 1

    if found == 0:
        print "No USB host controllers found"

    0
