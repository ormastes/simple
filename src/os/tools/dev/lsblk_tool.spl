use os.userlib.device.{DeviceEntry, enumerate_devices, device_class_name}
use os.userlib.mounts.{mount_list}

## List block devices with mount points.

struct BlockDeviceInfo:
    name: text
    size_sectors: u64
    mounted_at: text?

fn _is_storage_class(entry: DeviceEntry) -> bool:
    entry.class_code == 0x01

fn _sectors_to_human(sectors: u64) -> text:
    val bytes = sectors * 512
    if bytes >= 1073741824:
        val gb = bytes / 1073741824
        "{gb}G"
    else if bytes >= 1048576:
        val mb = bytes / 1048576
        "{mb}M"
    else if bytes >= 1024:
        val kb = bytes / 1024
        "{kb}K"
    else:
        "{bytes}B"

fn _find_mount_point(device_name: text, mounts: [text]) -> text?:
    for mount_entry in mounts:
        if mount_entry.contains(device_name):
            return Some(mount_entry)
    nil

fn _collect_block_devices() -> [BlockDeviceInfo]:
    val devices = enumerate_devices()
    val mounts = mount_list()
    var result: [BlockDeviceInfo] = []

    for entry in devices:
        if _is_storage_class(entry):
            val name = entry.name
            val mounted_at = _find_mount_point(name, mounts)
            val info = BlockDeviceInfo(
                name: name,
                size_sectors: entry.size_sectors,
                mounted_at: mounted_at,
            )
            result.push(info)

    result

fn _print_usage():
    print "Usage: lsblk [-h]"
    print ""
    print "List block devices with mount points."
    print ""
    print "Options:"
    print "  -h    Show this help"

fn run_lsblk(args: [text]) -> i32:
    for arg in args:
        if arg == "-h":
            _print_usage()
            return 0

    val block_devices = _collect_block_devices()

    print "NAME        SIZE  MOUNT"
    for dev in block_devices:
        val name = dev.name
        val size = _sectors_to_human(dev.size_sectors)
        val mount = dev.mounted_at ?? "-"
        print "{name}  {size}  {mount}"

    0
