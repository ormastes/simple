# Shell Tool Helpers — Shared utilities for shell tools
# MDSOC: feature dimension, shell layer
#
# Path resolution and output helpers used by all shell tools.
# Avoids circular dependency with os.apps.shell.shell_tools.

use os.apps.terminal.terminal.{Terminal}

fn resolve_path(cwd: text, path: text) -> text:
    """Resolve a relative path against cwd for tool use."""
    if path.starts_with("/"):
        return _normalize(path)
    if path == "..":
        return _parent(cwd)
    if path == ".":
        return cwd
    val full = if cwd == "/": "/{path}" else: "{cwd}/{path}"
    return _normalize(full)

fn _normalize(path: text) -> text:
    """Normalize path by resolving . and .. components."""
    var parts: [text] = []
    var current = ""
    for ch in path:
        if ch == "/":
            if current == "..":
                if parts.len() > 0:
                    var new_parts: [text] = []
                    var j = 0
                    while j < parts.len() - 1:
                        new_parts = new_parts.push(parts[j])
                        j = j + 1
                    parts = new_parts
            elif current != "." and current != "":
                parts = parts.push(current)
            current = ""
        else:
            current = "{current}{ch}"
    if current == "..":
        if parts.len() > 0:
            var new_parts: [text] = []
            var j = 0
            while j < parts.len() - 1:
                new_parts = new_parts.push(parts[j])
                j = j + 1
            parts = new_parts
    elif current != "." and current != "":
        parts = parts.push(current)
    if parts.len() == 0:
        return "/"
    var result = ""
    for part in parts:
        result = "{result}/{part}"
    return result

fn _parent(path: text) -> text:
    """Get parent directory of a path."""
    if path == "/":
        return "/"
    var last_slash = 0
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash == 0:
        return "/"
    return path.slice(0, last_slash)

fn write_line(terminal: Terminal, line: text):
    """Write a line with newline to terminal."""
    terminal.write_string("{line}\n")

fn write_error(terminal: Terminal, msg: text):
    """Write an error message in red."""
    val esc = "\u{001b}"
    terminal.write_string("{esc}[31m{msg}{esc}[0m\n")

fn split_text_on(content: text, delimiter: text) -> [text]:
    """Split text on a single-character delimiter without relying on text.split."""
    var parts: [text] = []
    var start: i64 = 0
    var i: i64 = 0
    while i <= content.len():
        if i == content.len():
            parts = parts.push(content.slice(start, i))
            i = i + 1
        elif content.slice(i, i + 1) == delimiter:
            parts = parts.push(content.slice(start, i))
            i = i + 1
            start = i
        else:
            i = i + 1
    return parts

fn split_lines(content: text) -> [text]:
    return split_text_on(content, "\n")
