# expr — Evaluate arithmetic expression
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.tools.shell.shell_helpers.{write_line, write_error}

fn tool_expr(args: [text], terminal: Terminal) -> i32:
    """Evaluate integer arithmetic expression.

    Supports: + - * / % = != < > <= >=
    Usage: expr ARG1 OP ARG2
    """
    if args.len() < 3:
        write_error(terminal, "expr: syntax error")
        return 2

    val left_str = args[0]
    val op = args[1]
    val right_str = args[2]

    val left = _expr_parse(left_str)
    val right = _expr_parse(right_str)

    match op:
        "+":
            write_line(terminal, "{left + right}")
            return 0
        "-":
            write_line(terminal, "{left - right}")
            return 0
        "*":
            write_line(terminal, "{left * right}")
            return 0
        "/":
            if right == 0:
                write_error(terminal, "expr: division by zero")
                return 2
            write_line(terminal, "{left / right}")
            return 0
        "%":
            if right == 0:
                write_error(terminal, "expr: division by zero")
                return 2
            write_line(terminal, "{left % right}")
            return 0
        "=":
            val result = if left == right: 1 else: 0
            write_line(terminal, "{result}")
            return if result == 1: 0 else: 1
        "!=":
            val result = if left != right: 1 else: 0
            write_line(terminal, "{result}")
            return if result == 1: 0 else: 1
        "<":
            val result = if left < right: 1 else: 0
            write_line(terminal, "{result}")
            return if result == 1: 0 else: 1
        ">":
            val result = if left > right: 1 else: 0
            write_line(terminal, "{result}")
            return if result == 1: 0 else: 1
        "<=":
            val result = if left <= right: 1 else: 0
            write_line(terminal, "{result}")
            return if result == 1: 0 else: 1
        ">=":
            val result = if left >= right: 1 else: 0
            write_line(terminal, "{result}")
            return if result == 1: 0 else: 1
        _:
            write_error(terminal, "expr: unknown operator: {op}")
            return 2

fn _expr_parse(s: text) -> i64:
    """Parse text to i64."""
    var result: i64 = 0
    var neg = false
    var started = false
    for ch in s:
        if ch == "-" and not started:
            neg = true
            started = true
        elif ch >= "0" and ch <= "9":
            result = result * 10 + (ch.to_i32() - "0".to_i32())
            started = true
    if neg:
        return -result
    return result
