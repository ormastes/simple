# fold — Wrap long lines to fit a specified width
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error, split_lines}

fn tool_fold(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Wrap long lines to fit a specified width."""
    if args.len() < 1:
        write_error(terminal, "fold: usage: fold [-w WIDTH] FILE...")
        return 1
    # Parse flags
    var width = 80
    var file_args: [text] = []
    var i = 0
    while i < args.len():
        if args[i] == "-w" and i + 1 < args.len():
            val w_str = args[i + 1]
            var parsed = 0
            var ci = 0
            while ci < w_str.len():
                val ch = w_str.slice(ci, ci + 1)
                if ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9":
                    if ch == "0": parsed = parsed * 10
                    if ch == "1": parsed = parsed * 10 + 1
                    if ch == "2": parsed = parsed * 10 + 2
                    if ch == "3": parsed = parsed * 10 + 3
                    if ch == "4": parsed = parsed * 10 + 4
                    if ch == "5": parsed = parsed * 10 + 5
                    if ch == "6": parsed = parsed * 10 + 6
                    if ch == "7": parsed = parsed * 10 + 7
                    if ch == "8": parsed = parsed * 10 + 8
                    if ch == "9": parsed = parsed * 10 + 9
                ci = ci + 1
            if parsed > 0:
                width = parsed
            i = i + 2
        else:
            file_args = file_args.push(args[i])
            i = i + 1
    if file_args.len() < 1:
        write_error(terminal, "fold: usage: fold [-w WIDTH] FILE...")
        return 1
    var exit_code = 0
    var fi = 0
    while fi < file_args.len():
        val path = resolve_path(cwd, file_args[fi])
        if vfs != nil:
            val result = vfs.read_text(path)
            if result.is_ok():
                val content = result.unwrap()
                for line in split_lines(content):
                    if line.len() <= width:
                        write_line(terminal, line)
                    else:
                        var offset = 0
                        while offset < line.len():
                            var end = offset + width
                            if end > line.len():
                                end = line.len()
                            write_line(terminal, line.slice(offset, end))
                            offset = offset + width
            else:
                write_error(terminal, "fold: {path}: {result.unwrap_err()}")
                exit_code = 1
        fi = fi + 1
    return exit_code
