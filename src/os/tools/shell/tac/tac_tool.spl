# tac — Print lines in reverse order
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error, split_lines}

fn tool_tac(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Print lines of files in reverse order."""
    if args.len() < 1:
        write_error(terminal, "tac: usage: tac FILE...")
        return 1
    var exit_code = 0
    var i = 0
    while i < args.len():
        val path = resolve_path(cwd, args[i])
        if vfs != nil:
            val result = vfs.read_text(path)
            if result.is_ok():
                val content = result.unwrap()
                val lines = split_lines(content)
                var j = lines.len() - 1
                while j >= 0:
                    write_line(terminal, lines[j])
                    j = j - 1
            else:
                write_error(terminal, "tac: {path}: {result.unwrap_err()}")
                exit_code = 1
        i = i + 1
    return exit_code
