# ls — List directory contents
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.kernel.types.fs_types.{FsNodeKind}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error}

fn tool_ls(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """List directory contents."""
    var path = cwd
    var show_all = false
    var show_long = false

    for arg in args:
        if arg == "-a":
            show_all = true
        elif arg == "-l":
            show_long = true
        elif not arg.starts_with("-"):
            path = resolve_path(cwd, arg)

    if vfs == nil:
        write_error(terminal, "ls: no filesystem mounted")
        return 1

    val result = vfs.readdir(path)
    if result.is_err():
        write_error(terminal, "ls: cannot access '{path}': {result.unwrap_err()}")
        return 1

    val entries = result.unwrap()
    for entry in entries:
        if not show_all and entry.name.starts_with("."):
            pass_dn
        else:
            if show_long:
                val kind_str = match entry.node.kind:
                    FsNodeKind.Directory => "d"
                    FsNodeKind.Symlink => "l"
                    FsNodeKind.Device => "c"
                    FsNodeKind.Pipe => "p"
                    _ => "-"
                write_line(terminal, "{kind_str}  {entry.node.size}  {entry.name}")
            else:
                terminal.write_string("{entry.name}  ")
    if not show_long:
        terminal.write_string("\n")
    return 0
