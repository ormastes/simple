# dirname — Strip filename from path
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.tools.shell.shell_helpers.{write_line, write_error}

fn tool_dirname(args: [text], terminal: Terminal) -> i32:
    """Strip last component from path."""
    if args.len() == 0:
        write_error(terminal, "dirname: missing operand")
        return 1
    val path = args[0]
    var last_slash = -1
    var i = 0
    for ch in path:
        if ch == "/":
            last_slash = i
        i = i + 1
    if last_slash < 0:
        write_line(terminal, ".")
    elif last_slash == 0:
        write_line(terminal, "/")
    else:
        write_line(terminal, path.slice(0, last_slash))
    return 0
