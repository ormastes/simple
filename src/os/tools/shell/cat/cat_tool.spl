# cat — Concatenate and print files
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error}

fn tool_cat(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Display file contents."""
    if args.len() == 0:
        write_error(terminal, "cat: missing file operand")
        return 1
    var exit_code: i32 = 0
    for filename in args:
        val path = resolve_path(cwd, filename)
        if vfs != nil:
            val result = vfs.read_text(path)
            if result.is_err():
                write_error(terminal, "cat: {path}: {result.unwrap_err()}")
                exit_code = 1
            else:
                write_line(terminal, result.unwrap())
        else:
            write_error(terminal, "cat: no filesystem mounted")
            exit_code = 1
    return exit_code
