#![allow(unnamed_duplicate_typed_args)]
# sed — Stream editor (basic)
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error}

fn tool_sed(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Basic stream editor. Supports s/old/new/[g] and d commands.

    Usage: sed 's/old/new/' FILE
           sed 's/old/new/g' FILE
           sed '/pattern/d' FILE
    """
    if args.len() < 2:
        write_error(terminal, "sed: usage: sed COMMAND FILE")
        return 1
    if vfs == nil:
        write_error(terminal, "sed: no filesystem mounted")
        return 1

    val cmd = args[0]
    val file_path = args[1]
    val path = resolve_path(cwd, file_path)
    val result = vfs.read_text(path)
    if result.is_err():
        write_error(terminal, "sed: {path}: {result.unwrap_err()}")
        return 1

    val content = result.unwrap()
    val lines = content.split("\n")

    # Detect command type
    if cmd.starts_with("s"):
        return _sed_substitute(cmd, lines, terminal)
    elif cmd.ends_with("/d"):
        return _sed_delete(cmd, lines, terminal)
    else:
        write_error(terminal, "sed: unknown command: {cmd}")
        return 1

fn _sed_substitute(cmd: text, lines: [text], terminal: Terminal) -> i32:
    """Handle s/old/new/[g] substitution."""
    # Parse s/old/new/[g] — delimiter is character after 's'
    if cmd.len() < 4:
        write_error(terminal, "sed: invalid substitution")
        return 1
    val delim = cmd.char_at(1)
    # Split the rest by delimiter
    val rest = cmd.slice(2, cmd.len())
    val parts = rest.split(delim)
    if parts.len() < 2:
        write_error(terminal, "sed: invalid substitution")
        return 1
    val old_str = parts[0]
    val new_str = parts[1]
    val global = if parts.len() > 2: parts[2] == "g" else: false

    for line in lines:
        if global:
            write_line(terminal, line.replace(old_str, new_str))
        else:
            write_line(terminal, _replace_first(line, old_str, new_str))
    return 0

fn _sed_delete(cmd: text, lines: [text], terminal: Terminal) -> i32:
    """Handle /pattern/d deletion."""
    # Parse /pattern/d
    if cmd.len() < 3:
        write_error(terminal, "sed: invalid delete command")
        return 1
    val pattern = cmd.slice(1, cmd.len() - 2)
    for line in lines:
        if not line.contains(pattern):
            write_line(terminal, line)
    return 0

fn _replace_first(s: text, old: text, new: text) -> text:
    """Replace first occurrence of old with new in s."""
    val idx = s.find(old)
    if idx < 0:
        return s
    val before = s.slice(0, idx)
    val after = s.slice(idx + old.len(), s.len())
    return "{before}{new}{after}"
