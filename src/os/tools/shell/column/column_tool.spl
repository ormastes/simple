#![allow(unnamed_duplicate_typed_args)]
# column — Format input into columns
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error, split_lines, split_text_on}

fn tool_column(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Format input into columns.

    Flag: -t (table mode: split each line by whitespace and align columns)
    Without -t, lines are passed through unchanged.
    Usage: column -t FILE
    """
    var table_mode = false
    var file_path = ""
    var i = 0

    while i < args.len():
        val arg = args[i]
        if arg == "-t":
            table_mode = true
        elif not arg.starts_with("-"):
            file_path = arg
        i = i + 1

    if file_path == "":
        write_error(terminal, "column: missing file operand")
        write_error(terminal, "Usage: column [-t] FILE")
        return 1
    if vfs == nil:
        write_error(terminal, "column: no filesystem mounted")
        return 1

    val path = resolve_path(cwd, file_path)
    val result = vfs.read_text(path)
    if result.is_err():
        write_error(terminal, "column: {path}: {result.unwrap_err()}")
        return 1

    val content = result.unwrap()
    val lines = split_lines(content)

    if not table_mode:
        for line in lines:
            write_line(terminal, line)
        return 0

    # Table mode: split each line into fields and align columns
    var rows: [[text]] = []
    for line in lines:
        if line.trim() != "":
            rows = rows.push(_split_whitespace(line))

    if rows.len() == 0:
        return 0

    # Find max column count
    var max_cols = 0
    for row in rows:
        if row.len() > max_cols:
            max_cols = row.len()

    # Find max width per column
    var col_widths: [i32] = []
    var c = 0
    while c < max_cols:
        col_widths = col_widths.push(0)
        c = c + 1

    for row in rows:
        var ci = 0
        while ci < row.len():
            val w = row[ci].len() as i32
            if w > col_widths[ci]:
                col_widths[ci] = w
            ci = ci + 1

    # Print each row padded to column widths
    for row in rows:
        var out = ""
        var ci = 0
        while ci < row.len():
            val field = row[ci]
            if ci > 0:
                out = "{out}  "
            out = "{out}{field}"
            # Pad to column width (except last column)
            if ci < row.len() - 1:
                val pad_count = col_widths[ci] - field.len() as i32
                var p = 0
                while p < pad_count:
                    out = "{out} "
                    p = p + 1
            ci = ci + 1
        write_line(terminal, out)

    return 0

fn _split_whitespace(line: text) -> [text]:
    """Split a line on whitespace, collapsing multiple spaces."""
    var parts: [text] = []
    var current = ""
    var in_word = false
    for ch in line:
        if ch == " " or ch == "\t":
            if in_word:
                parts = parts.push(current)
                current = ""
                in_word = false
        else:
            current = "{current}{ch}"
            in_word = true
    if in_word and current != "":
        parts = parts.push(current)
    return parts
