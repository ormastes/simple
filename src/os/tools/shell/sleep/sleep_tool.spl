# sleep — Delay execution
# MDSOC: feature dimension, shell layer

use os.tools.shell.shell_helpers.{write_error}
use os.apps.terminal.terminal.{Terminal}

extern fn sleep_ms(ms: i32)

fn tool_sleep(args: [text], terminal: Terminal) -> i32:
    """Delay for a specified number of seconds."""
    if args.len() == 0:
        write_error(terminal, "sleep: missing operand")
        return 1
    val secs_str = args[0]
    var secs: i32 = 0
    var valid = true
    for ch in secs_str:
        if ch >= "0" and ch <= "9":
            secs = secs * 10 + (ch.to_i32() - "0".to_i32())
        else:
            valid = false
    if not valid or secs < 0:
        write_error(terminal, "sleep: invalid time interval '{secs_str}'")
        return 1
    sleep_ms(secs * 1000)
    return 0
