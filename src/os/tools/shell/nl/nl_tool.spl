# nl — Number lines of files
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error, split_lines}

fn tool_nl(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Number lines of files."""
    if args.len() < 1:
        write_error(terminal, "nl: usage: nl [-b a|t] FILE...")
        return 1
    # Parse flags
    var body_style = "a"
    var file_args: [text] = []
    var i = 0
    while i < args.len():
        if args[i] == "-b" and i + 1 < args.len():
            body_style = args[i + 1]
            i = i + 2
        else:
            file_args = file_args.push(args[i])
            i = i + 1
    if file_args.len() < 1:
        write_error(terminal, "nl: usage: nl [-b a|t] FILE...")
        return 1
    var exit_code = 0
    var fi = 0
    while fi < file_args.len():
        val path = resolve_path(cwd, file_args[fi])
        if vfs != nil:
            val result = vfs.read_text(path)
            if result.is_ok():
                val content = result.unwrap()
                var line_num = 1
                for line in split_lines(content):
                    val is_blank = line.trim() == ""
                    if body_style == "t" and is_blank:
                        write_line(terminal, "")
                    else:
                        val num_str = "{line_num}"
                        var padded = num_str
                        var pad = 6 - num_str.len()
                        while pad > 0:
                            padded = " {padded}"
                            pad = pad - 1
                        write_line(terminal, "{padded}\t{line}")
                        line_num = line_num + 1
            else:
                write_error(terminal, "nl: {path}: {result.unwrap_err()}")
                exit_code = 1
        fi = fi + 1
    return exit_code
