#![allow(unnamed_duplicate_typed_args)]
# find — Find files by name
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.kernel.types.fs_types.{FsNodeKind}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error}

fn tool_find(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Find files by name pattern."""
    val start_path = if args.len() > 0: resolve_path(cwd, args[0]) else: cwd
    val name_pattern = if args.len() > 2 and args[1] == "-name": args[2] else: "*"
    if vfs == nil:
        write_error(terminal, "find: no filesystem mounted")
        return 1
    _find_recursive(vfs, start_path, name_pattern, terminal)
    return 0

fn _find_recursive(vfs: VfsManager, path: text, pattern: text, terminal: Terminal):
    """Recursively find files matching a pattern."""
    val result = vfs.readdir(path)
    if result.is_err():
        return
    val entries = result.unwrap()
    for entry in entries:
        val full_path = if path == "/": "/{entry.name}" else: "{path}/{entry.name}"
        if pattern == "*" or entry.name.contains(pattern):
            write_line(terminal, full_path)
        if entry.node.kind == FsNodeKind.Directory:
            _find_recursive(vfs, full_path, pattern, terminal)
