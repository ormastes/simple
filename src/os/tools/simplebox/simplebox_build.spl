# simplebox build wiring — compile the simplebox userland binary for SimpleOS.
#
# Produces build/os/rootfs/bin/simplebox via `native-build --target simpleos`,
# which compiles simplebox_main.spl (and, transitively, the pure-Simple libc it
# imports) into the OS image's userland. Self-contained: the cmd builder has no
# heavy imports so it stays cheap to test; the caller ensures the sysroot.

use std.process

val SIMPLEBOX_ENTRY: text = "src/os/tools/simplebox/simplebox_main.spl"

fn simplebox_output_path() -> text:
    """Rootfs path of the compiled simplebox binary (packed at /bin/simplebox)."""
    "build/os/rootfs/bin/simplebox"

fn simplebox_native_build_cmd(target: text) -> [text]:
    """native-build argv that compiles simplebox for a SimpleOS target."""
    ["native-build", "--target", target, "--entry", SIMPLEBOX_ENTRY, "-o", simplebox_output_path()]

fn _is_simpleos_target(target: text) -> bool:
    target == "simpleos" or target.ends_with("-simpleos")

fn build_simplebox(target: text) -> i32:
    """Compile simplebox for a simpleos target into the rootfs. Returns the
    native-build exit code (2 if target is not a SimpleOS target). The caller
    is responsible for ensuring the sysroot (libc/crt0/linker script) exists."""
    if not _is_simpleos_target(target):
        return 2
    val args = simplebox_native_build_cmd(target)
    val (out, err, rc) = process.run("bin/simple", args)
    rc
