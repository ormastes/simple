# SimpleOS simplebox — busybox-style multi-call entry point (userland binary).
#
# This is the binary packed at /bin/simplebox in the SimpleOS image. It
# GENUINELY consumes the pure-Simple libc: numeric applet arguments are parsed
# with libc_strtoul (not open-coded), so building and running simplebox
# exercises the pure-Simple libc inside the OS image. MDSOC+ preserved — the
# dispatcher stays a stateless router; this entry only adds libc-backed applets.
#
# Build (simpleos target):
#   bin/simple native-build --target simpleos \
#     --entry src/os/tools/simplebox/simplebox_main.spl -o build/os/rootfs/bin/simplebox

use os.tools.simplebox.simplebox_dispatch.{simplebox_dispatch}
use os.libc.simpleos_stdlib_num.{libc_strtoul}

# seq N — count parsed via the pure-Simple libc (libc_strtoul, base 10: skips
# leading whitespace, stops at the first non-digit). Splitting this out makes the
# libc consumption directly testable (and proves it is the libc, not open code).
fn simplebox_seq_count(args: [text]) -> i64:
    if args.len() == 0:
        return 0
    libc_strtoul(args[0].bytes(), 10)

fn _applet_seq(args: [text]) -> i32:
    val count = simplebox_seq_count(args)
    var i: i64 = 1
    while i <= count:
        print(i)
        i = i + 1
    0

# simplebox_run routes libc-backed applets here; everything else falls through
# to the self-contained dispatcher (echo/true/false/pwd/--list).
fn simplebox_run(argv: [text]) -> i32:
    if argv.len() >= 2 and argv[1] == "seq":
        return _applet_seq(argv.slice(2, argv.len()))
    simplebox_dispatch(argv)

fn main(argv: [text]) -> i32:
    simplebox_run(argv)
