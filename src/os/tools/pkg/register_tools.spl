# Package Tool Registration — Register pkg commands with shell ToolRegistry
# MDSOC: feature dimension, apps layer
#
# Registers all package-related tools so the shell can dispatch them.

use os.tools.tool_registry.{ToolRegistry, ToolEntry}
use os.tools.pkg.pkg_cli.{run_pkg_cli}
use os.installer.image_builder.{run_image_builder}
use os.installer.usb_installer.{run_usb_installer}
use os.installer.release_pipeline.{run_release}
use os.apps.registry.registry_server.{run_registry}

fn register_pkg_tools(registry: ToolRegistry):
    """Register all package infrastructure tools with the shell."""

    registry.register(ToolEntry(
        name: "pkg",
        description: "Package manager (install, remove, update, build, image, registry)",
        category: "pkg",
        run_fn: run_pkg_cli,
        capabilities: ["install", "remove", "update", "list", "search", "info", "build", "build-os", "image", "installer", "registry"]
    ))

    registry.register(ToolEntry(
        name: "image-builder",
        description: "Create bootable disk/USB images for SimpleOS",
        category: "pkg",
        run_fn: run_image_builder,
        capabilities: ["create"]
    ))

    registry.register(ToolEntry(
        name: "installer",
        description: "Interactive OS installer (from USB boot media)",
        category: "pkg",
        run_fn: run_usb_installer,
        capabilities: ["install", "upgrade", "detect"]
    ))

    registry.register(ToolEntry(
        name: "release",
        description: "Build release images and package sets",
        category: "pkg",
        run_fn: run_release,
        capabilities: ["all", "packages", "usb", "disk"]
    ))

    registry.register(ToolEntry(
        name: "registry-server",
        description: "Package registry server (host packages over HTTP)",
        category: "pkg",
        run_fn: run_registry,
        capabilities: ["start", "init", "add-token", "reindex", "list"]
    ))
