# SimpleOS — MDSOC Capsule Configuration
#
# Defines the multi-dimensional architecture of the OS kernel and userspace.
# Compile-time enforced isolation between subsystems.
# Based on the same MDSOC system the Simple compiler uses.

[capsule]
name = "simple_os"
version = "0.1.0"

[roots]
simple_os = "src/os"

# ============================================================================
# ENTITY DIMENSION — Pure types, no behavior
# ============================================================================

[dimension entity]

[capsule simple_os.types.core]
dimension = "entity"
layer = "types"
path = "src/os/kernel/types"
exports = [
    "VmMap", "PageTable", "PageFrame", "PhysAddr", "VirtAddr",
    "TaskContext", "TaskId", "TaskState", "TaskPriority",
    "InterruptFrame", "ExceptionCode", "IrqNumber",
    "CapabilityToken", "CapabilitySet", "CapabilityKind",
    "SyscallId", "SyscallArgs", "SyscallResult",
    "FileDescriptor", "MountPoint", "FsNode",
    "IpcMessage", "IpcPort", "IpcEndpoint"
]

[capsule simple_os.types.arch]
dimension = "entity"
layer = "types"
path = "src/os/kernel/arch"
exports = [
    "X86Context", "X86Gdt", "X86Idt", "X86Tss", "X86PageTable",
    "RiscvContext", "RiscvPlic", "RiscvSbi",
    "ArmContext", "ArmGic", "ArmMmu"
]

[capsule simple_os.types.ui]
dimension = "entity"
layer = "types"
path = "src/os/compositor/types"
exports = [
    "WindowId", "WindowState", "CompositorSurface",
    "FramebufferInfo", "PixelFormat"
]

# ============================================================================
# FEATURE DIMENSION — Behavior, directional layers (upper depends on lower)
# ============================================================================

[dimension feature]

[capsule simple_os.boot]
dimension = "feature"
layer = "boot"
path = "src/os/kernel/boot"
dependencies = ["simple_os.types.core", "simple_os.types.arch"]
exports = ["kernel_main", "early_serial_write", "boot_info"]

[capsule simple_os.memory]
dimension = "feature"
layer = "memory"
path = "src/os/kernel/memory"
dependencies = ["simple_os.boot", "simple_os.types.core"]
exports = [
    "pmm_alloc_page", "pmm_free_page",
    "vmm_map_page", "vmm_unmap_page", "vmm_create_address_space",
    "heap_alloc", "heap_free"
]

[capsule simple_os.interrupts]
dimension = "feature"
layer = "interrupts"
path = "src/os/kernel/interrupts"
dependencies = ["simple_os.memory", "simple_os.types.core", "simple_os.types.arch"]
exports = [
    "idt_init", "register_irq_handler", "enable_interrupts",
    "disable_interrupts", "apic_init", "apic_eoi"
]

[capsule simple_os.scheduler]
dimension = "feature"
layer = "scheduler"
path = "src/os/kernel/scheduler"
dependencies = ["simple_os.interrupts", "simple_os.memory", "simple_os.types.core"]
exports = [
    "task_create", "task_exit", "task_yield", "schedule",
    "task_set_priority", "task_get_current"
]

[capsule simple_os.ipc]
dimension = "feature"
layer = "ipc"
path = "src/os/kernel/ipc"
dependencies = ["simple_os.scheduler", "simple_os.memory", "simple_os.types.core"]
exports = [
    "ipc_send", "ipc_recv", "ipc_create_port",
    "cap_grant", "cap_revoke", "cap_check",
    "pledge", "unveil"
]

[capsule simple_os.drivers.input]
dimension = "feature"
layer = "drivers"
path = "src/os/drivers/input"
dependencies = ["simple_os.interrupts", "simple_os.ipc"]
exports = ["ps2_init", "input_poll_event"]

[capsule simple_os.drivers.pci]
dimension = "feature"
layer = "drivers"
path = "src/os/drivers/pci"
dependencies = ["simple_os.memory", "simple_os.ipc"]
exports = ["pci_enumerate", "pci_read_config", "pci_write_config"]

[capsule simple_os.drivers.virtio]
dimension = "feature"
layer = "drivers"
path = "src/os/drivers/virtio"
dependencies = ["simple_os.drivers.pci", "simple_os.memory", "simple_os.ipc"]
exports = ["virtio_blk_read", "virtio_blk_write", "virtio_net_send", "virtio_net_recv"]

[capsule simple_os.drivers.framebuffer]
dimension = "feature"
layer = "drivers"
path = "src/os/drivers/framebuffer"
dependencies = ["simple_os.memory", "simple_os.boot"]
exports = ["fb_init", "fb_fill_rect", "fb_blit", "fb_swap_buffers"]

[capsule simple_os.vfs]
dimension = "feature"
layer = "vfs"
path = "src/os/services/vfs"
dependencies = ["simple_os.drivers.virtio", "simple_os.ipc", "simple_os.types.core"]
exports = [
    "vfs_open", "vfs_read", "vfs_write", "vfs_close",
    "vfs_stat", "vfs_mkdir", "vfs_readdir", "vfs_mount"
]

[capsule simple_os.vfs.fat32]
dimension = "feature"
layer = "vfs"
path = "src/os/services/fat32"
dependencies = ["simple_os.drivers.virtio", "simple_os.types.core"]
exports = ["fat32_mount", "fat32_read", "fat32_write"]

[capsule simple_os.net]
dimension = "feature"
layer = "net"
path = "src/os/services/net"
dependencies = ["simple_os.drivers.virtio", "simple_os.ipc"]
exports = ["tcp_connect", "tcp_listen", "udp_send", "udp_recv", "dns_resolve"]

[capsule simple_os.compositor]
dimension = "feature"
layer = "compositor"
path = "src/os/compositor"
dependencies = [
    "simple_os.drivers.framebuffer", "simple_os.drivers.input",
    "simple_os.ipc", "simple_os.types.ui"
]
exports = [
    "compositor_create_window", "compositor_destroy_window",
    "compositor_render", "compositor_focus_window"
]

[capsule simple_os.apps.terminal]
dimension = "feature"
layer = "apps"
path = "src/os/apps/terminal"
dependencies = ["simple_os.compositor", "simple_os.vfs", "simple_os.ipc"]
exports = ["terminal_create", "terminal_run"]

[capsule simple_os.apps.file_manager]
dimension = "feature"
layer = "apps"
path = "src/os/apps/file_manager"
dependencies = ["simple_os.compositor", "simple_os.vfs"]
exports = ["file_manager_create"]

[capsule simple_os.apps.editor]
dimension = "feature"
layer = "apps"
path = "src/os/apps/editor"
dependencies = ["simple_os.compositor", "simple_os.vfs"]
exports = ["editor_open"]

[capsule simple_os.apps.shell]
dimension = "feature"
layer = "apps"
path = "src/os/apps/shell"
dependencies = ["simple_os.vfs", "simple_os.ipc", "simple_os.scheduler"]
exports = ["shell_run", "shell_exec"]

[capsule simple_os.llm]
dimension = "feature"
layer = "llm"
path = "src/os/services/llm"
dependencies = [
    "simple_os.compositor", "simple_os.vfs", "simple_os.net",
    "simple_os.ipc", "simple_os.scheduler"
]
exports = ["mcp_os_server_start", "llm_widget_eval"]

# ============================================================================
# TRANSFORM DIMENSION — Explicit bridges between dimensions
# ============================================================================

[dimension transform]

[capsule simple_os.transform.arch_adapt]
dimension = "transform"
layer = "adapters"
path = "src/os/kernel/arch_adapt"
dependencies = ["simple_os.types.arch", "simple_os.types.core"]
exports = [
    "context_save", "context_restore",
    "enable_paging", "flush_tlb",
    "syscall_entry", "syscall_exit"
]

[capsule simple_os.transform.ui_adapt]
dimension = "transform"
layer = "adapters"
path = "src/os/compositor/ui_adapt"
dependencies = ["simple_os.types.ui", "simple_os.drivers.framebuffer"]
exports = ["ui_session_to_framebuffer", "input_event_to_ui_event"]

# ============================================================================
# RULES — Compile-time enforcement
# ============================================================================

[rules]
layer_order = [
    "boot", "memory", "interrupts", "scheduler", "ipc",
    "drivers", "vfs", "net", "compositor", "apps", "llm"
]
direction = "upper_to_lower"
enforce_layering = true
reject_cycles = true
forbid_implicit_merge = true
require_explicit_bind = true
allow_same_layer = true
allow_adjacent_only = false
