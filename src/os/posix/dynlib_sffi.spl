# SFFI Dynamic Call Bridge — rt_dyncall extern declarations + safe wrappers
#
# Declares rt_dyncall_N externs for calling into loaded library functions
# at the native ABI level. The runtime must provide these symbols (TODO).
# Safe wrappers resolve a named symbol from a DynLibKind, then dispatch.

use os.posix.dynlib.{DynLibKind, dynlib_symbol}

# --- Forward-declared runtime externs (not yet implemented in runtime) ---
# These are the contract for WS3/runtime to fulfill.

extern fn rt_dyncall_0(fn_ptr: i64) -> i64
extern fn rt_dyncall_1(fn_ptr: i64, arg0: i64) -> i64
extern fn rt_dyncall_2(fn_ptr: i64, arg0: i64, arg1: i64) -> i64
extern fn rt_dyncall_3(fn_ptr: i64, arg0: i64, arg1: i64, arg2: i64) -> i64
extern fn rt_dyncall_4(fn_ptr: i64, arg0: i64, arg1: i64, arg2: i64, arg3: i64) -> i64
extern fn rt_dyncall_5(fn_ptr: i64, arg0: i64, arg1: i64, arg2: i64, arg3: i64, arg4: i64) -> i64
extern fn rt_dyncall_6(fn_ptr: i64, arg0: i64, arg1: i64, arg2: i64, arg3: i64, arg4: i64, arg5: i64) -> i64

# --- Safe wrappers: resolve symbol by name, then call ---

fn dynlib_call_0(lib: DynLibKind, name: text) -> i64:
    """Resolve `name` from `lib` and call it with 0 arguments."""
    val ptr = dynlib_symbol(lib, name)
    if ptr < 0:
        return ptr
    rt_dyncall_0(ptr)

fn dynlib_call_1(lib: DynLibKind, name: text, arg0: i64) -> i64:
    """Resolve `name` from `lib` and call it with 1 argument."""
    val ptr = dynlib_symbol(lib, name)
    if ptr < 0:
        return ptr
    rt_dyncall_1(ptr, arg0)

fn dynlib_call_2(lib: DynLibKind, name: text, arg0: i64, arg1: i64) -> i64:
    """Resolve `name` from `lib` and call it with 2 arguments."""
    val ptr = dynlib_symbol(lib, name)
    if ptr < 0:
        return ptr
    rt_dyncall_2(ptr, arg0, arg1)

fn dynlib_call_3(lib: DynLibKind, name: text, arg0: i64, arg1: i64, arg2: i64) -> i64:
    """Resolve `name` from `lib` and call it with 3 arguments."""
    val ptr = dynlib_symbol(lib, name)
    if ptr < 0:
        return ptr
    rt_dyncall_3(ptr, arg0, arg1, arg2)

fn dynlib_call_4(lib: DynLibKind, name: text, arg0: i64, arg1: i64, arg2: i64, arg3: i64) -> i64:
    """Resolve `name` from `lib` and call it with 4 arguments."""
    val ptr = dynlib_symbol(lib, name)
    if ptr < 0:
        return ptr
    rt_dyncall_4(ptr, arg0, arg1, arg2, arg3)

fn dynlib_call_5(lib: DynLibKind, name: text, arg0: i64, arg1: i64, arg2: i64, arg3: i64, arg4: i64) -> i64:
    """Resolve `name` from `lib` and call it with 5 arguments."""
    val ptr = dynlib_symbol(lib, name)
    if ptr < 0:
        return ptr
    rt_dyncall_5(ptr, arg0, arg1, arg2, arg3, arg4)

fn dynlib_call_6(lib: DynLibKind, name: text, arg0: i64, arg1: i64, arg2: i64, arg3: i64, arg4: i64, arg5: i64) -> i64:
    """Resolve `name` from `lib` and call it with 6 arguments."""
    val ptr = dynlib_symbol(lib, name)
    if ptr < 0:
        return ptr
    rt_dyncall_6(ptr, arg0, arg1, arg2, arg3, arg4, arg5)
