# Signal Dispatch Externs — G6 POSIX Signal Delivery
#
# Two externs that wire the shim to the kernel/PM side.
# The real implementations live in C (PM agent's domain).
# This file is `use`d by signal_compat.spl; tests override the
# behaviour via module-level counters declared in their spec.

extern fn notify_task(pid: u64)
extern fn trampoline_invoke(pid: u64, signo: i32, handler: u64)
