# POSIX errno codes for SimpleOS
#
# Standard error numbers matching POSIX.1-2017.
# Used by the POSIX compatibility layer.

val ESUCCESS: i32 = 0
val EPERM: i32 = 1       # Operation not permitted
val ENOENT: i32 = 2      # No such file or directory
val ESRCH: i32 = 3       # No such process
val EINTR: i32 = 4       # Interrupted system call
val EIO: i32 = 5         # I/O error
val ENXIO: i32 = 6       # No such device or address
val E2BIG: i32 = 7       # Argument list too long
val ENOEXEC: i32 = 8     # Exec format error
val EBADF: i32 = 9       # Bad file descriptor
val ECHILD: i32 = 10     # No child processes
val EAGAIN: i32 = 11     # Try again (also EWOULDBLOCK)
val ENOMEM: i32 = 12     # Out of memory
val EACCES: i32 = 13     # Permission denied
val EFAULT: i32 = 14     # Bad address
val EBUSY: i32 = 16      # Device or resource busy
val EEXIST: i32 = 17     # File exists
val EXDEV: i32 = 18      # Cross-device link
val ENODEV: i32 = 19     # No such device
val ENOTDIR: i32 = 20    # Not a directory
val EISDIR: i32 = 21     # Is a directory
val EINVAL: i32 = 22     # Invalid argument
val ENFILE: i32 = 23     # File table overflow
val EMFILE: i32 = 24     # Too many open files
val ENOTTY: i32 = 25     # Not a typewriter
val EFBIG: i32 = 27      # File too large
val ENOSPC: i32 = 28     # No space left on device
val ESPIPE: i32 = 29     # Illegal seek
val EROFS: i32 = 30      # Read-only file system
val EPIPE: i32 = 32      # Broken pipe
val ERANGE: i32 = 34     # Math result not representable
val ENAMETOOLONG: i32 = 36 # File name too long
val ENOSYS: i32 = 38     # Function not implemented
val ENOTEMPTY: i32 = 39  # Directory not empty
val ELOOP: i32 = 40      # Too many symbolic links
val ENOMSG: i32 = 42     # No message of desired type
val ENOTSOCK: i32 = 88   # Socket operation on non-socket
val ECONNREFUSED: i32 = 111 # Connection refused
val ETIMEDOUT: i32 = 110    # Connection timed out
val ECONNRESET: i32 = 104   # Connection reset by peer
val ENOTCONN: i32 = 107     # Transport endpoint not connected
val EINPROGRESS: i32 = 115  # Operation now in progress
val ENETUNREACH: i32 = 101  # Network is unreachable
val EADDRINUSE: i32 = 98    # Address already in use
val EAFNOSUPPORT: i32 = 97  # Address family not supported
val EPROTONOSUPPORT: i32 = 93  # Protocol not supported

val EWOULDBLOCK: i32 = 11   # Alias for EAGAIN
