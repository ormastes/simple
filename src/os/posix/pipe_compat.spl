# POSIX Pipes — implemented over IPC port pairs
#
# pipe() creates a pair of FDs: read end and write end.
# Internally uses IPC endpoints for data transfer.

use os.posix.errno.{EMFILE, ENOMEM}
use os.posix.fd_table.{fd_alloc, fd_set, FD_TYPE_PIPE_READ, FD_TYPE_PIPE_WRITE}

fn posix_pipe(fds_out_read: u64, fds_out_write: u64) -> i32:
    """Create a pipe. Writes read FD and write FD to the output addresses.
    Returns 0 on success, -errno on error.

    Internally creates an IPC endpoint pair for the pipe.
    """
    val read_fd = fd_alloc()
    if read_fd < 0:
        return read_fd
    val write_fd = fd_alloc()
    if write_fd < 0:
        return write_fd
    # Create IPC endpoint for the pipe
    pass_todo("create IPC endpoint pair for pipe data transfer")
    val pipe_endpoint: u64 = 0  # TODO: from kernel notification_create or endpoint_create
    fd_set(read_fd, FD_TYPE_PIPE_READ, 0, pipe_endpoint)
    fd_set(write_fd, FD_TYPE_PIPE_WRITE, 0, pipe_endpoint)
    # Write FDs to caller's output addresses
    pass_todo("write read_fd to fds_out_read, write_fd to fds_out_write via userspace pointer")
    0
