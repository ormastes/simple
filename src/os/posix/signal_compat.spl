# POSIX Signal Compatibility — basic signal handling
#
# SimpleOS has signal/kill syscalls. This layer adds handler registration.
# No fork-based signal delivery — signals are delivered at next scheduling point.
#
# Kernel syscall 7 (Signal) sends signals to processes.
# The posix_kill() wrapper is in process_compat.spl since it depends on
# the kernel signal mapping. This module handles:
#   - Signal handler registration (posix_signal)
#   - Signal mask management (posix_sigprocmask)
#   - Pending signal delivery (signal_deliver_pending)

use os.posix.errno.{EINVAL, ESRCH}
use os.userlib.syscall_raw.{syscall}

# Standard signal numbers
val SIGHUP: i32 = 1
val SIGINT: i32 = 2
val SIGQUIT: i32 = 3
val SIGKILL: i32 = 9
val SIGTERM: i32 = 15
val SIGSTOP: i32 = 19
val SIGCONT: i32 = 18
val SIGCHLD: i32 = 17
val SIGUSR1: i32 = 10
val SIGUSR2: i32 = 12

# Signal dispositions
val SIG_DFL: u64 = 0  # default action
val SIG_IGN: u64 = 1  # ignore

val MAX_SIGNALS: u64 = 32

# Per-process signal handler table
# handler_addr = 0 -> default, handler_addr = 1 -> ignore, else -> user fn pointer
var signal_handlers: [u64; 32]
var signal_mask: u64 = 0       # blocked signal bitmask
var signal_pending: u64 = 0    # pending signal bitmask

fn signal_init():
    """Initialize signal handling for a process."""
    var i: u64 = 0
    while i < MAX_SIGNALS:
        signal_handlers[i] = SIG_DFL
        i = i + 1
    signal_mask = 0
    signal_pending = 0

fn posix_signal(signum: i32, handler: u64) -> u64:
    """Register a signal handler. Returns previous handler.

    handler = SIG_DFL (0) for default, SIG_IGN (1) to ignore,
    or a function pointer for a user handler.
    """
    if signum < 1 or signum >= MAX_SIGNALS as i32:
        return SIG_DFL
    # SIGKILL and SIGSTOP cannot be caught
    if signum == SIGKILL or signum == SIGSTOP:
        return SIG_DFL
    val idx: u64 = signum as u64
    val prev = signal_handlers[idx]
    signal_handlers[idx] = handler
    prev

fn posix_kill(pid: u64, signum: i32) -> i32:
    """Send a signal to a process via kernel syscall 7.

    Maps POSIX signal numbers to kernel signal codes:
      SIGTERM (15) -> 0 (Term)
      SIGKILL (9)  -> 1 (Kill, uncatchable)
      SIGSTOP (19) -> 2 (Stop)
      SIGCONT (18) -> 3 (Cont)
      SIGINT  (2)  -> 4 (Int)

    Returns 0 on success, -errno on failure.
    """
    if signum < 1 or signum >= MAX_SIGNALS as i32:
        return 0 - EINVAL

    val _SYS_SIGNAL: u64 = 7

    # Map POSIX signal to kernel signal code
    var kern_sig: u64 = 0
    if signum == SIGTERM:
        kern_sig = 0
    elif signum == SIGKILL:
        kern_sig = 1
    elif signum == SIGSTOP:
        kern_sig = 2
    elif signum == SIGCONT:
        kern_sig = 3
    elif signum == SIGINT:
        kern_sig = 4
    else:
        # Default: map to Term (0) for other signals
        kern_sig = 0

    val result = syscall(_SYS_SIGNAL, pid, kern_sig, 0, 0, 0)
    if result < 0:
        return result as i32
    0

fn posix_sigprocmask(how: i32, set: u64) -> u64:
    """Modify the signal mask. Returns the previous mask.

    how: 0 = SIG_BLOCK (add to mask), 1 = SIG_UNBLOCK (remove from mask),
         2 = SIG_SETMASK (replace mask)
    set: bitmask of signals to block/unblock
    """
    val prev = signal_mask
    if how == 0:        # SIG_BLOCK
        signal_mask = signal_mask | set
    elif how == 1:      # SIG_UNBLOCK
        signal_mask = signal_mask & ~set
    elif how == 2:      # SIG_SETMASK
        signal_mask = set
    # Ensure SIGKILL and SIGSTOP are never blocked
    val kill_bit: u64 = 1 << SIGKILL as u64
    val stop_bit: u64 = 1 << SIGSTOP as u64
    signal_mask = signal_mask & ~kill_bit & ~stop_bit
    prev

fn signal_raise(signum: i32):
    """Raise a signal in the current process (queue for delivery)."""
    if signum < 1 or signum >= MAX_SIGNALS as i32:
        return
    val bit: u64 = 1 << (signum as u64)
    signal_pending = signal_pending | bit

fn signal_deliver_pending():
    """Check and deliver pending signals. Called at scheduling points.

    Iterates through all pending signals that are not blocked.
    For each deliverable signal:
      - SIG_IGN: discard
      - SIG_DFL: default action (currently no-op; real OS would terminate/stop)
      - User handler: invoke the registered handler function
    """
    var sig: u64 = 1
    while sig < MAX_SIGNALS:
        val bit: u64 = 1 << sig
        if (signal_pending & bit) != 0 and (signal_mask & bit) == 0:
            # Signal is pending and not blocked
            signal_pending = signal_pending & ~bit  # clear pending
            val handler = signal_handlers[sig]
            if handler == SIG_IGN:
                pass_dn  # ignore
            elif handler == SIG_DFL:
                # Default action: for SIGKILL/SIGTERM, would terminate.
                # For SIGSTOP, would stop. For now, no-op (kernel handles
                # the actual signal via syscall 7).
                pass_dn
            else:
                # User handler: call the function pointer.
                # In a real implementation, this would invoke the handler
                # with appropriate signal context. For now, we mark it
                # as dispatched — the handler invocation requires arch-specific
                # trampoline to set up the user-mode signal frame.
                pass_dn
        sig = sig + 1

fn signal_is_pending(signum: i32) -> bool:
    """Check if a specific signal is pending."""
    if signum < 1 or signum >= MAX_SIGNALS as i32:
        return false
    val bit: u64 = 1 << (signum as u64)
    (signal_pending & bit) != 0

# ---- Cross-module aliases (resolve externs declared by PM / other callers) ----

fn signal_deliver(target_pid: u64, signo: i32) -> i32:
    """Alias for posix_kill — the extern name PM and other services declare."""
    posix_kill(target_pid, signo)

fn signal_queue_has_pending(pid: u64) -> bool:
    """True if any non-blocked signal is pending for pid.

    Current impl is per-process (single signal_pending bitmask), so `pid` is
    informational. When PM spins up multi-process bookkeeping this becomes
    per-pid.
    """
    (signal_pending & ~signal_mask) != 0
