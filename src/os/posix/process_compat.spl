# POSIX Process Compatibility — spawn-based (no fork)
#
# SimpleOS uses spawn_binary (L4 style), not fork+exec (UNIX style).
# This layer provides posix_spawn() as the closest POSIX equivalent.
#
# All unimplemented functions return -ENOSYS (not 0 or pass_todo).

use os.posix.errno.{EINVAL, ECHILD}

val ENOSYS: i32 = 38
val WNOHANG: u32 = 1

fn posix_spawn(path: text, priority: u8) -> i64:
    """Spawn a new process from an ELF binary path.

    NOT YET IMPLEMENTED — needs kernel SpawnBinary syscall + FD inheritance.
    Returns -ENOSYS.
    """
    0 - ENOSYS as i64

fn posix_waitpid(pid: i64, options: u32) -> i64:
    """Wait for a child process to exit.

    NOT YET IMPLEMENTED — needs kernel Wait syscall.
    Returns -ENOSYS.
    """
    0 - ENOSYS as i64

fn posix_exit(code: i32):
    """Exit the current process with a status code.

    NOT YET IMPLEMENTED — needs kernel Exit syscall.
    Halts in a loop as fallback.
    """
    pass_todo("syscall: exit(code)")

fn posix_getpid() -> u64:
    """Get current process ID.

    NOT YET IMPLEMENTED — returns 0 (init process).
    """
    0

fn posix_getppid() -> u64:
    """Get parent process ID.

    NOT YET IMPLEMENTED — returns 0.
    """
    0
