#![allow(unnamed_duplicate_typed_args)]
# POSIX async I/O compatibility wrapper.
#
# Native async I/O ownership lives in os.sosix.io. This file keeps the legacy
# POSIX exported names stable for fd_io and existing tests.

use os.sosix.io.{
    SOSIX_ASYNC_FREE,
    SOSIX_ASYNC_PENDING,
    SOSIX_ASYNC_COMPLETE,
    SOSIX_ASYNC_ERROR,
    SOSIX_IO_BACKEND_INVALID,
    SOSIX_IO_BACKEND_SERIAL,
    SOSIX_IO_BACKEND_VFS,
    SOSIX_MAX_ASYNC_REQUESTS,
    sosix_io_backend_for_fd_type,
    sosix_io_init,
    sosix_async_alloc_request,
    sosix_async_free_request,
    sosix_async_is_complete,
    sosix_async_get_result,
    sosix_async_read,
    sosix_async_write,
    sosix_sync_read,
    sosix_sync_write
}

val ASYNC_IO_BACKEND_INVALID: u8 = SOSIX_IO_BACKEND_INVALID
val ASYNC_IO_BACKEND_SERIAL: u8 = SOSIX_IO_BACKEND_SERIAL
val ASYNC_IO_BACKEND_VFS: u8 = SOSIX_IO_BACKEND_VFS

val MAX_ASYNC_REQUESTS: u64 = SOSIX_MAX_ASYNC_REQUESTS

val VFS_OPEN: u32 = 1
val VFS_READ: u32 = 2
val VFS_WRITE: u32 = 3
val VFS_CLOSE: u32 = 4
val VFS_STAT: u32 = 5
val VFS_SEEK: u32 = 6
val VFS_READDIR: u32 = 7
val VFS_MKDIR: u32 = 8

val ASYNC_FREE: u8 = SOSIX_ASYNC_FREE
val ASYNC_PENDING: u8 = SOSIX_ASYNC_PENDING
val ASYNC_COMPLETE: u8 = SOSIX_ASYNC_COMPLETE
val ASYNC_ERROR: u8 = SOSIX_ASYNC_ERROR

fn async_io_backend_for_fd_type(fd_type: u8) -> u8:
    """Return the native SOSIX async backend for FD types exposed through POSIX."""
    sosix_io_backend_for_fd_type(fd_type)

fn async_io_init():
    """Initialize the SOSIX async I/O owner."""
    sosix_io_init()

fn async_alloc_request() -> u64:
    """Allocate an async request slot."""
    sosix_async_alloc_request()

fn async_free_request(req_id: u64):
    """Free an async request slot."""
    sosix_async_free_request(req_id)

fn async_is_complete(req_id: u64) -> bool:
    """Check if an async request has completed."""
    sosix_async_is_complete(req_id)

fn async_get_result(req_id: u64) -> i64:
    """Get the result of a completed async request."""
    sosix_async_get_result(req_id)

fn async_read(fd: i32, buf_addr: u64, count: u64) -> u64:
    """Start an async read. Returns request ID.

    Compatibility wrapper over SOSIX async I/O.
    """
    sosix_async_read(fd, buf_addr, count)

fn async_write(fd: i32, buf_addr: u64, count: u64) -> u64:
    """Start an async write. Returns request ID."""
    sosix_async_write(fd, buf_addr, count)

fn sync_read(fd: i32, buf_addr: u64, count: u64) -> i64:
    """Synchronous read — blocks until complete. Returns bytes read or -errno."""
    sosix_sync_read(fd, buf_addr, count)

fn sync_write(fd: i32, buf_addr: u64, count: u64) -> i64:
    """Synchronous write — blocks until complete. Returns bytes written or -errno."""
    sosix_sync_write(fd, buf_addr, count)
