#![allow(unnamed_duplicate_typed_args)]
# POSIX async process compatibility wrappers over SOSIX.

use os.sosix.process.{
    SOSIX_PROCESS_MAX_REQUESTS,
    SOSIX_PROCESS_REQ_FREE,
    SOSIX_PROCESS_REQ_PENDING,
    SOSIX_PROCESS_REQ_COMPLETE,
    SOSIX_PROCESS_REQ_ERROR,
    SOSIX_PROCESS_OP_NONE,
    SOSIX_PROCESS_OP_FORK,
    SOSIX_PROCESS_OP_EXECVE,
    SOSIX_PROCESS_OP_SPAWN,
    SOSIX_PROCESS_OP_WAITPID,
    SOSIX_PROCESS_OP_EXIT,
    SOSIX_PROCESS_OP_GETPID,
    SOSIX_PROCESS_OP_SIGNAL,
    SOSIX_PROCESS_WNOHANG,
    sosix_process_init,
    sosix_process_alloc_request,
    sosix_process_free_request,
    sosix_process_is_complete,
    sosix_process_result,
    sosix_process_fork,
    sosix_process_execve,
    sosix_process_spawn,
    sosix_process_waitpid,
    sosix_process_getpid,
    sosix_process_signal,
    sosix_process_exit,
    sosix_process_wait_request
}

val PROCESS_MAX_REQUESTS: u64 = SOSIX_PROCESS_MAX_REQUESTS

val PROCESS_REQ_FREE: u8 = SOSIX_PROCESS_REQ_FREE
val PROCESS_REQ_PENDING: u8 = SOSIX_PROCESS_REQ_PENDING
val PROCESS_REQ_COMPLETE: u8 = SOSIX_PROCESS_REQ_COMPLETE
val PROCESS_REQ_ERROR: u8 = SOSIX_PROCESS_REQ_ERROR

val PROCESS_OP_NONE: u8 = SOSIX_PROCESS_OP_NONE
val PROCESS_OP_FORK: u8 = SOSIX_PROCESS_OP_FORK
val PROCESS_OP_EXECVE: u8 = SOSIX_PROCESS_OP_EXECVE
val PROCESS_OP_SPAWN: u8 = SOSIX_PROCESS_OP_SPAWN
val PROCESS_OP_WAITPID: u8 = SOSIX_PROCESS_OP_WAITPID
val PROCESS_OP_EXIT: u8 = SOSIX_PROCESS_OP_EXIT
val PROCESS_OP_GETPID: u8 = SOSIX_PROCESS_OP_GETPID
val PROCESS_OP_SIGNAL: u8 = SOSIX_PROCESS_OP_SIGNAL

val PROCESS_WNOHANG: u32 = SOSIX_PROCESS_WNOHANG

fn process_async_init():
    """Initialize async process request slots through SOSIX."""
    sosix_process_init()

fn process_async_alloc_request() -> u64:
    sosix_process_alloc_request()

fn process_async_free_request(req: u64):
    sosix_process_free_request(req)

fn process_async_is_complete(req: u64) -> bool:
    sosix_process_is_complete(req)

fn process_async_result(req: u64) -> i64:
    sosix_process_result(req)

fn process_async_fork() -> u64:
    sosix_process_fork()

fn process_async_execve(path: text, args: [text], envp: [text]) -> u64:
    sosix_process_execve(path, args, envp)

fn process_async_spawn(path: text, args: [text], priority: u8) -> u64:
    sosix_process_spawn(path, args, priority)

fn process_async_waitpid(pid: i64, options: u32) -> u64:
    sosix_process_waitpid(pid, options)

fn process_async_getpid() -> u64:
    sosix_process_getpid()

fn process_async_signal(pid: u64, kern_sig: i32) -> u64:
    sosix_process_signal(pid, kern_sig)

fn process_async_exit(code: i32) -> u64:
    sosix_process_exit(code)

fn process_wait_request(req: u64) -> i64:
    sosix_process_wait_request(req)
