# SimpleOS POSIX Compatibility Layer
#
# Provides POSIX-like APIs over SimpleOS's L4 microkernel + async IPC.
# Design: async by default, sync POSIX wrappers block on completion.
#
# Architecture:
#   POSIX sync API (this layer) → async I/O → IPC to services → kernel syscalls
#
# Modules:
#   errno.spl         — Standard POSIX error codes
#   fd_table.spl      — Per-process file descriptor table
#   fd_io.spl         — open/read/write/close/lseek/dup/dup2
#   async_io.spl      — Non-blocking I/O over IPC (the real implementation)
#   pipe_compat.spl   — pipe() via IPC endpoint pairs
#   signal_compat.spl — Signal handlers over SimpleOS signal syscalls
#   process_compat.spl — posix_spawn/waitpid/exit/getpid (no fork)
#
# What's NOT supported (by design, L4 microkernel):
#   - fork() — use posix_spawn() instead
#   - exec() — use posix_spawn() instead
#   - select/poll/epoll — use notification wait_any() instead
#   - shared memory mmap — use IPC shared pages instead
#   - POSIX threads — use kernel threads instead

use os.posix.errno.*
use os.posix.fd_table.{fd_table_init}
use os.posix.async_io.{async_io_init}
use os.posix.signal_compat.{signal_init}

fn posix_init():
    """Initialize the POSIX compatibility layer for the current process."""
    fd_table_init()
    async_io_init()
    signal_init()
