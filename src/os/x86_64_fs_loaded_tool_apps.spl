"""
x86_64 FS-Loaded Tool Apps — canonical identity registry for the six tool apps.

Subsystem: Disk/Media + Launcher identity layer (remainder only).
Canonical runtime app ids: /sys/apps/<name>. Packaging and launcher wiring
already exist; this module exposes the identity constants for contract use.

MDSOC: os layer — identity/descriptor only, no spawn or IPC.
"""

# Canonical VFS path prefix for all tool apps.
pub val TOOL_APP_PATH_PREFIX: text = "/sys/apps/"

# The six tool apps that must be proven in the x64-desktop-uefi lane.
pub val TOOL_APP_SIMPLE_BROWSER: text = "simple_browser"
pub val TOOL_APP_SIMPLE_COMPILER: text = "simple_compiler"
pub val TOOL_APP_SIMPLE_INTERPRETER: text = "simple_interpreter"
pub val TOOL_APP_SIMPLE_LOADER: text = "simple_loader"
pub val TOOL_APP_LLVM: text = "llvm"
pub val TOOL_APP_RUST: text = "rust"

# Ordered list of the six target apps for iteration in contract checks.
pub fn tool_app_names() -> [text]:
    [
        TOOL_APP_SIMPLE_BROWSER,
        TOOL_APP_SIMPLE_COMPILER,
        TOOL_APP_SIMPLE_INTERPRETER,
        TOOL_APP_SIMPLE_LOADER,
        TOOL_APP_LLVM,
        TOOL_APP_RUST
    ]

# Returns the canonical VFS path for a given tool app name.
pub fn tool_app_canonical_path(app_name: text) -> text:
    "{TOOL_APP_PATH_PREFIX}{app_name}"

# Returns true if the given app name is one of the six target tool apps.
pub fn is_target_tool_app(app_name: text) -> bool:
    app_name == TOOL_APP_SIMPLE_BROWSER or
    app_name == TOOL_APP_SIMPLE_COMPILER or
    app_name == TOOL_APP_SIMPLE_INTERPRETER or
    app_name == TOOL_APP_SIMPLE_LOADER or
    app_name == TOOL_APP_LLVM or
    app_name == TOOL_APP_RUST
