# Bare-metal Simple runtime — port of src/runtime/startup/baremetal/runtime_minimal.c.
#
# Provides the high-level startup glue (`__spl_start_bare`, `main`,
# `__spl_exit`, `spl_thread_init`, `spl_init_args`, `zero_bss`) that the
# per-arch crt0 stubs jump to. All inline-asm primitives (rt_mmio_*,
# rt_port_*, rt_read_cr3, rt_*msr, rt_cli/sti/hlt, rt_lgdt/lidt/ltr,
# rt_reload_segments) remain in `runtime_minimal.c` as `extern fn rt_*`
# entry points — Simple has no general inline-asm syntax for these
# variadic patterns and the existing FFI surface is the standard pattern.
#
# Wave 2b — added 2026-04-25 to satisfy Phase-3 §C-Inventory file #1
# (runtime_minimal.c → runtime_minimal.spl).
#
# Status:
#   - .spl side ports control-flow only (no inline asm).
#   - C side stays in tree as `runtime_minimal.c` (DEPRECATED header marks
#     it for removal in Wave 3 once x86_64 smoke is green via the .spl
#     entry path).
#   - Build manifest swap to use this file lives in
#     `src/compiler/80.driver/build/baremetal.spl` and is gated until
#     Wave 3 (avoids a forced bootstrap rebuild during Wave 2).
#
# Wiring (post-Wave-3):
#   per-arch crt0 → __spl_start_bare (this file) →
#       rt_zero_bss (new C extern) → main →
#       __simple_main (compiler-emitted) →
#       __spl_exit → rt_halt_exit (new C extern, arch-conditional).

# ---------------------------------------------------------------
# extern declarations — bridge to the residual C primitives.
# ---------------------------------------------------------------

# Generated by the Simple compiler — entry point of the user kernel.
extern fn __simple_main() -> i64

# Wave 3: rt_zero_bss replaces the inline `for (char *p = __bss_start; ...)`
# loop. The C version sees the linker-defined `__bss_start`/`__bss_end`
# symbols directly; in Simple we route through an extern so the linker
# script stays in C-symbol space.
extern fn rt_zero_bss()

# Wave 3: rt_halt_exit replaces the per-arch inline-asm halt loop in the
# original `__spl_exit`. Arch-dispatch lives in C (matches the existing
# `#if defined(__x86_64__)` style) so we don't need Simple-level @cfg
# in the runtime crate.
extern fn rt_halt_exit(code: i32)

# ---------------------------------------------------------------
# Public Simple entry points — called from per-arch crt0 stubs and
# from the runtime initializer.
# ---------------------------------------------------------------

@no_mangle
fn spl_thread_init():
    """Hosted-runtime hook — bare-metal has no thread setup work."""
    pass_do_nothing("baremetal images are uniprocessor at boot; no thread init needed")

@no_mangle
fn spl_init_args(argc: i32, argv: u64):
    """Bare-metal kernels ignore argc/argv; signature kept for ABI parity."""
    pass_do_nothing("argc/argv are loader-controlled; bare-metal images discard them")

@no_mangle
fn main(argc: i32, argv: u64) -> i32:
    """Standard C entry shim — invokes the Simple-emitted user main."""
    __simple_main() as i32

@no_mangle
fn __spl_exit(status: i32) -> i32:
    """Bare-metal exit — disable interrupts and halt forever.
    Returns i32 only to satisfy the trait-level signature; this never returns."""
    rt_halt_exit(status)
    # Unreachable — rt_halt_exit is a noreturn primitive. We return -1 to
    # keep Simple's type checker satisfied; the hardware halt before this
    # point means the value is never observed.
    -1

@no_mangle
fn __spl_start_bare():
    """First-instruction Simple entry from per-arch crt0.
    Invokes BSS zeroing, then main, then the halt path."""
    rt_zero_bss()
    val rc: i32 = main(0, 0)
    val _ignored: i32 = __spl_exit(rc)
    pass_do_nothing("halt path above is noreturn; control flow never reaches this point")
