# Host-side QEMU contract for the x64 production SSHD live scenario.

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

pub fn run_x64_ssh_probe(cmd_parts: [text], timeout_ms: u64) -> (text, text, i32):
    val serial_path = "build/os/x64-ssh-live.serial.log"
    val good_path = "build/os/x64-ssh-live.openssh-good.txt"
    val bad_path = "build/os/x64-ssh-live.openssh-bad-auth.txt"
    val askpass_ok = "build/os/x64-ssh-live.askpass-ok.sh"
    val askpass_bad = "build/os/x64-ssh-live.askpass-bad.sh"
    val known_hosts = "build/os/x64-ssh-live.known-hosts"
    val ssh_opts =
        "-F /dev/null " +
        "-p 2222 " +
        "-o StrictHostKeyChecking=no " +
        "-o UserKnownHostsFile=" + known_hosts + " " +
        "-o GlobalKnownHostsFile=/dev/null " +
        "-o ConnectTimeout=10 " +
        "-o PreferredAuthentications=password " +
        "-o PasswordAuthentication=yes " +
        "-o PubkeyAuthentication=no " +
        "-o HostKeyAlgorithms=rsa-sha2-256,rsa-sha2-512 " +
        "-o KbdInteractiveAuthentication=no " +
        "-o NumberOfPasswordPrompts=1 " +
        "-o BatchMode=no " +
        "-o LogLevel=ERROR "
    val shell_cmd =
        "rm -f \"" + serial_path + "\" \"" + good_path + "\" \"" + bad_path + "\" \"" + askpass_ok + "\" \"" + askpass_bad + "\" \"" + known_hosts + "\"; " +
        "printf '#!/bin/sh\\necho simpleos\\n' > \"" + askpass_ok + "\"; chmod +x \"" + askpass_ok + "\"; " +
        "printf '#!/bin/sh\\necho wrongpass\\n' > \"" + askpass_bad + "\"; chmod +x \"" + askpass_bad + "\"; " +
        cmd_parts.join(" ") + " > \"" + serial_path + "\" 2>&1 & qpid=$!; " +
        "ready=0; for i in $(seq 1 160); do " +
        "if grep -a -q '\\[sshd\\] SSH daemon listening on port 22' \"" + serial_path + "\" 2>/dev/null; then ready=1; break; fi; " +
        "if ! kill -0 \"$qpid\" 2>/dev/null; then break; fi; sleep 0.25; done; " +
        "good_exit=1; if [ \"$ready\" = 1 ]; then " +
        "timeout 30 bash -lc 'SSH_ASKPASS=\"" + askpass_ok + "\" SSH_ASKPASS_REQUIRE=force DISPLAY=none setsid ssh " + ssh_opts + " root@127.0.0.1 true' > \"" + good_path + "\" 2>&1; " +
        "good_exit=$?; fi; " +
        "bad_exit=0; if [ \"$ready\" = 1 ]; then " +
        "timeout 30 bash -lc 'SSH_ASKPASS=\"" + askpass_bad + "\" SSH_ASKPASS_REQUIRE=force DISPLAY=none setsid ssh " + ssh_opts + " root@127.0.0.1 true' > \"" + bad_path + "\" 2>&1; " +
        "bad_exit=$?; fi; " +
        "good_seen=0; bad_seen=0; if [ \"$ready\" = 1 ]; then " +
        "for i in $(seq 1 80); do " +
        "if grep -a -q '\\[sshd-session\\] auth ok user=root method=password' \"" + serial_path + "\" 2>/dev/null && " +
        "grep -a -q '\\[sshd-session\\] exec command=true' \"" + serial_path + "\" 2>/dev/null; then good_seen=1; fi; " +
        "if grep -a -q '\\[sshd-session\\] auth password fail branch' \"" + serial_path + "\" 2>/dev/null; then bad_seen=1; fi; " +
        "if [ \"$good_seen\" = 1 ] && [ \"$bad_seen\" = 1 ]; then break; fi; " +
        "if ! kill -0 \"$qpid\" 2>/dev/null; then break; fi; sleep 0.25; done; fi; " +
        "kill \"$qpid\" 2>/dev/null || true; wait \"$qpid\" 2>/dev/null || true; " +
        "cat \"" + serial_path + "\"; echo '[ssh-host] openssh-good:'; cat \"" + good_path + "\" 2>/dev/null || true; echo '[ssh-host] openssh-bad-auth:'; cat \"" + bad_path + "\" 2>/dev/null || true; " +
        "if [ \"$ready\" = 1 ] && [ \"$good_exit\" = 0 ] && [ \"$bad_exit\" != 0 ] && [ \"$good_seen\" = 1 ] && [ \"$bad_seen\" = 1 ]; then echo 'TEST PASSED'; else echo 'TEST FAILED'; exit 2; fi"
    rt_process_run_timeout("/bin/bash", ["-c", shell_cmd], timeout_ms as i64)
