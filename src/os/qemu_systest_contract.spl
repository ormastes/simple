    ["[x86_32 fs] initrd fat32 ok",
     "[x86_32 fs] hello_world smf ok",
     "[x86_32 fs] browser smf ok",
     "[x86_32 fs] x86_32 payload ok",
     "[x86_32 fs] app execution ok"]

pub fn x86_32_timeout_ms() -> i64:
    60000

# ---------------------------------------------------------------------------
# Run helper — spawn QEMU, write serial log, return classification
# ---------------------------------------------------------------------------

pub fn run_qemu_systest(
    arch: text,
    kernel_path: text,
    image_path: text,
    qemu_bin: text,
    qemu_args: [text],
    markers: [text],
    timeout_ms: i64
) -> text:
    """Spawn QEMU for one arch, write serial log, return classification string.

    Returns 'missing-media:<path>' immediately if kernel or image is absent.
    Otherwise runs QEMU and calls classify_serial on the combined output.
    Serial log is written to build/os/systest/<arch>.serial.log.
    """
    if not rt_file_exists(kernel_path):
        return SYSTEST_PREFIX_MISSING_MEDIA + kernel_path
    if not rt_file_exists(image_path):
        return SYSTEST_PREFIX_MISSING_MEDIA + image_path
    rt_dir_create_all("build/os/systest")
    val log_path = "build/os/systest/" + arch + ".serial.log"
    val result = rt_process_run_timeout(qemu_bin, qemu_args, timeout_ms)
    val serial = result[0] + result[1]
    rt_file_write_text(log_path, serial)
    classify_serial(serial, markers)
