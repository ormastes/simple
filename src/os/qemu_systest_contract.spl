# ---------------------------------------------------------------------------
# arm64 descriptor (-kernel ELF boot; force-raw loader executed the ELF header → fixed 2026-06-13)
# ---------------------------------------------------------------------------

pub fn arm64_kernel_path() -> text:
    "build/os/simpleos_arm64_fs_exec.elf"

pub fn arm64_image_path() -> text:
    "build/os/fat32-arm64.img"

pub fn arm64_qemu_bin() -> text:
    "qemu-system-aarch64"

pub fn arm64_qemu_args() -> [text]:
    ["-machine", "virt",
     "-cpu", "cortex-a72",
     "-m", "384M",
     "-nographic",
     "-global", "virtio-mmio.force-legacy=false",
     "-drive", "file=build/os/fat32-arm64.img,if=none,id=armdisk,format=raw",
     "-device", "virtio-blk-device,drive=armdisk",
     "-semihosting-config", "enable=on,target=native",
     "-kernel", "build/os/simpleos_arm64_fs_exec.elf"]

pub fn arm64_markers() -> [text]:
    # arm64 fs-exec lane scope = boot + virtio-blk + FAT32 + VFS + ELF load + launch proof.
    # Each marker asserts a GENUINE capability on the real success path (verified live):
    #   FAT32 bpb parsed  = real boot-sector read+parse off the virtio-blk disk
    #   vfs:ok            = VFS came up over real virtio-blk+FAT32
    #   ELF_LOAD_OK       = real arm64 ELF parse (validated header, parsed entry, counted
    #                       PT_LOAD) + segment-stage-to-phys + user-AS page-map at register
    #                       time — the same load-proof bar riscv64/x86_64 assert
    #   SMF_CLI_LAUNCH_OK = a launchable bootstrap task (pid) registered from that image
    #   process-backed:ok = a process was spawned from a disk-sourced executable (TCB+pid+image)
    # NOTE: this lane verifies fs-exec ELF load + launch proof, NOT EL0 usercode execution.
    # No arch `eret`s into the (marker-ELF) payload yet; true execution is tracked separately.
    ["[vfs-init] FAT32 bpb parsed",
     "[arm-fs-exec] vfs:ok",
     "ELF_LOAD_OK arch=aarch64",
     "SMF_CLI_LAUNCH_OK app=/sys/apps/hello_world.smf",
     "[desktop-e2e] process-backed:ok app=hello_world",
     "TEST PASSED"]

pub fn arm64_timeout_ms() -> i64:
    60000

