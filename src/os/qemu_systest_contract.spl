"""
QEMU System Test Contract — Per-Architecture Descriptors and Classification.

**Feature IDs:** #QEMU-SYSTEST-MULTIARCH-AC1
**Category:** OS system test infrastructure

Provides hardcoded per-arch QEMU boot descriptors and a pure classifier
function for use by system specs. Does NOT call simpleos_platform_* or any
catalog-lane accessor (those crash in interpreter mode). All argv is hardcoded
from the lane reference data in src/os/port/simpleos_multiplatform_build_part2.spl.

Serial logs are written to build/os/systest/<arch>.serial.log.
"""

use os.fs_exec_fallback_contract.{fs_exec_serial_has_fallback}

extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)
extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool

# ---------------------------------------------------------------------------
# Classification results (string constants)
# ---------------------------------------------------------------------------

pub val SYSTEST_PASS: text = "pass"
pub val SYSTEST_PREFIX_MISSING_MEDIA: text = "missing-media:"
pub val SYSTEST_PREFIX_BOOT_FAIL: text = "boot-fail:"
pub val SYSTEST_BOOT_FAIL_FALLBACK: text = "boot-fail:fallback"

export SYSTEST_PASS, SYSTEST_PREFIX_MISSING_MEDIA, SYSTEST_PREFIX_BOOT_FAIL, SYSTEST_BOOT_FAIL_FALLBACK

# ---------------------------------------------------------------------------
# Classifier — pure text-in, no I/O (testable without QEMU)
# ---------------------------------------------------------------------------

pub fn classify_serial(serial: text, markers: [text]) -> text:
    """Classify a completed QEMU serial log against required markers.

    Returns:
      'pass'                     — all markers present, no fallback pattern
      'boot-fail:fallback'       — fallback pattern detected in serial
      'boot-fail:<marker>'       — first missing marker
    """
    if fs_exec_serial_has_fallback(serial):
        return SYSTEST_BOOT_FAIL_FALLBACK
    val n = markers.len()
    val i = 0
    while i < n:
        val m = markers[i]
        if not serial.contains(m):
            return "boot-fail:" + m
        val i = i + 1
    SYSTEST_PASS

# ---------------------------------------------------------------------------
# riscv64 descriptor
# ---------------------------------------------------------------------------

pub fn riscv64_kernel_path() -> text:
    "build/os/simpleos_riscv64_smf_fs.elf"

pub fn riscv64_image_path() -> text:
    "build/os/fat32-riscv64.img"

pub fn riscv64_qemu_bin() -> text:
    "qemu-system-riscv64"

pub fn riscv64_qemu_args() -> [text]:
    ["-machine", "virt",
     "-cpu", "rv64",
     "-m", "512M",
     "-nographic",
     "-bios", "default",
     "-global", "virtio-mmio.force-legacy=false",
     "-drive", "file=build/os/fat32-riscv64.img,if=none,id=rvdisk,format=raw",
     "-device", "virtio-blk-device,drive=rvdisk",
     "-kernel", "build/os/simpleos_riscv64_smf_fs.elf"]

pub fn riscv64_markers() -> [text]:
    ["ELF_LOAD_OK",
     "SMF_CLI_LAUNCH_OK",
     "SMF_WM_GUI_LAUNCH_OK",
     "NATIVE_GUI_PROCESS_RENDER_OK",
     "SIMPLEOS_RISCV_SMF_FS_PASS",
     "TEST PASSED"]

pub fn riscv64_timeout_ms() -> i64:
    60000

