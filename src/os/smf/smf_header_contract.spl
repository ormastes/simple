# SMF Header Contract — Shared header detection, trailer location, and fallback rules
#
# Provides the core data types for SMF (Simple Module Format) runtime header
# detection: SmfHeader, TrailerDetection, HeaderFallback, and SmfTestVector.

# ============================================================================
# SmfHeader — parsed SMF file header
# ============================================================================

class SmfHeader:
    """Parsed SMF file header with magic, version, section count, and trailer offset."""
    magic: text
    version: int
    section_count: int
    trailer_offset: int
    is_valid: bool

    me has_trailer() -> bool:
        """Returns true if a trailer offset is recorded."""
        self.trailer_offset > 0

    me to_text() -> text:
        """Returns a short human-readable description."""
        "SMF v" + self.version.to_text() + " sections=" + self.section_count.to_text()

    me validate() -> SmfHeader:
        """Returns a copy with is_valid set according to magic and version checks."""
        val ok = self.magic == "SMF1" and self.version > 0
        SmfHeader(
            magic: self.magic,
            version: self.version,
            section_count: self.section_count,
            trailer_offset: self.trailer_offset,
            is_valid: ok
        )

    static fn create(ver: int, sections: int, trailer: int) -> SmfHeader:
        """Factory: build a header with magic SMF1 and is_valid=false."""
        SmfHeader(
            magic: "SMF1",
            version: ver,
            section_count: sections,
            trailer_offset: trailer,
            is_valid: false
        )

    static fn empty() -> SmfHeader:
        """Factory: zero-valued header with is_valid=false."""
        SmfHeader(
            magic: "SMF1",
            version: 0,
            section_count: 0,
            trailer_offset: 0,
            is_valid: false
        )

# ============================================================================
# TrailerDetection — result of locating the SMF trailer
# ============================================================================

class TrailerDetection:
    """Describes how (or whether) the SMF trailer was located."""
    detection_mode: text
    confidence: int
    fallback_used: bool
    raw_offset: int

    me is_trailer() -> bool:
        """Returns true when detection used the real trailer."""
        self.detection_mode == "trailer"

    me is_offset0() -> bool:
        """Returns true when detection fell back to offset-zero heuristic."""
        self.detection_mode == "offset0"

    me is_found() -> bool:
        """Returns true when any detection mode succeeded."""
        self.detection_mode != "none"

    me to_text() -> text:
        """Returns a short human-readable description."""
        "detect:" + self.detection_mode + " confidence=" + self.confidence.to_text() + "%"

    static fn trailer(offset: int) -> TrailerDetection:
        """Factory: confirmed trailer at the given offset, confidence=100."""
        TrailerDetection(
            detection_mode: "trailer",
            confidence: 100,
            fallback_used: false,
            raw_offset: offset
        )

    static fn offset0() -> TrailerDetection:
        """Factory: offset-zero fallback, confidence=80."""
        TrailerDetection(
            detection_mode: "offset0",
            confidence: 80,
            fallback_used: true,
            raw_offset: 0
        )

    static fn not_found() -> TrailerDetection:
        """Factory: no trailer located."""
        TrailerDetection(
            detection_mode: "none",
            confidence: 0,
            fallback_used: false,
            raw_offset: 0
        )

# ============================================================================
# HeaderFallback — fallback chain for header location strategy
# ============================================================================

class HeaderFallback:
    """Tracks the primary and fallback strategy for locating the SMF header."""
    primary_mode: text
    fallback_mode: text
    resolved: bool
    attempt_count: int

    me needs_fallback() -> bool:
        """Returns true when primary mode has not yet been resolved."""
        self.resolved == false

    me resolve() -> HeaderFallback:
        """Returns a copy with resolved=true."""
        HeaderFallback(
            primary_mode: self.primary_mode,
            fallback_mode: self.fallback_mode,
            resolved: true,
            attempt_count: self.attempt_count
        )

    me to_text() -> text:
        """Returns a short human-readable description."""
        "fallback: " + self.primary_mode + " -> " + self.fallback_mode + " resolved=" + self.resolved.to_text()

    static fn standard() -> HeaderFallback:
        """Factory: trailer primary with offset0 fallback, unresolved."""
        HeaderFallback(
            primary_mode: "trailer",
            fallback_mode: "offset0",
            resolved: false,
            attempt_count: 0
        )

    static fn trailer_only() -> HeaderFallback:
        """Factory: trailer primary with no fallback, unresolved."""
        HeaderFallback(
            primary_mode: "trailer",
            fallback_mode: "none",
            resolved: false,
            attempt_count: 0
        )

# ============================================================================
# SmfTestVector — parameterised test case for header detection logic
# ============================================================================

class SmfTestVector:
    """A named test vector describing expected header detection behaviour."""
    vector_name: text
    expected_mode: text
    expected_valid: bool
    file_size: int

    me is_positive() -> bool:
        """Returns true for vectors that expect a valid detection outcome."""
        self.expected_valid

    me to_text() -> text:
        """Returns a short human-readable description."""
        "vector:" + self.vector_name + " expect=" + self.expected_mode + " valid=" + self.expected_valid.to_text()

    static fn pure_smf(size: int) -> SmfTestVector:
        """Factory: well-formed SMF file, expects trailer detection."""
        SmfTestVector(
            vector_name: "pure_smf",
            expected_mode: "trailer",
            expected_valid: true,
            file_size: size
        )

    static fn malformed(size: int) -> SmfTestVector:
        """Factory: malformed file, expects no detection."""
        SmfTestVector(
            vector_name: "malformed",
            expected_mode: "none",
            expected_valid: false,
            file_size: size
        )
