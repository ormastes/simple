# Phase 1: Shared Header Contract — Spec
#
# Covers SmfHeader, TrailerDetection, HeaderFallback, and SmfTestVector
# using the pure-data factories; no file I/O required.

use std.spec.*

# ============================================================================
# SmfHeader specs
# ============================================================================

describe "SmfHeader - factory and validation":
    it "create produces valid magic and version":
        val h = SmfHeader.create(1, 3, 128)
        expect(h.magic).to_equal("SMF1")
        expect(h.version).to_equal(1)
        expect(h.section_count).to_equal(3)
        expect(h.trailer_offset).to_equal(128)

    it "create leaves is_valid false":
        val h = SmfHeader.create(1, 3, 128)
        expect(h.is_valid).to_equal(false)

    it "validate sets is_valid true for good magic and positive version":
        val h = SmfHeader.create(1, 3, 128).validate()
        expect(h.is_valid).to_equal(true)

    it "validate leaves is_valid false when version is zero":
        val h = SmfHeader.create(0, 3, 128).validate()
        expect(h.is_valid).to_equal(false)

    it "empty returns version zero":
        val h = SmfHeader.empty()
        expect(h.version).to_equal(0)

    it "empty has no trailer":
        val h = SmfHeader.empty()
        expect(h.has_trailer()).to_equal(false)

    it "has_trailer true when trailer_offset is positive":
        val h = SmfHeader.create(1, 2, 64)
        expect(h.has_trailer()).to_equal(true)

    it "to_text contains version number":
        val h = SmfHeader.create(2, 4, 0)
        expect(h.to_text()).to_contain("2")

# ============================================================================
# TrailerDetection specs
# ============================================================================

describe "TrailerDetection - factory predicates":
    it "trailer factory yields is_trailer true":
        val td = TrailerDetection.trailer(256)
        expect(td.is_trailer()).to_equal(true)

    it "trailer factory has confidence 100":
        val td = TrailerDetection.trailer(256)
        expect(td.confidence).to_equal(100)

    it "trailer factory records raw_offset":
        val td = TrailerDetection.trailer(256)
        expect(td.raw_offset).to_equal(256)

    it "trailer factory has fallback_used false":
        val td = TrailerDetection.trailer(256)
        expect(td.fallback_used).to_equal(false)

    it "offset0 factory yields is_offset0 true":
        val td = TrailerDetection.offset0()
        expect(td.is_offset0()).to_equal(true)

    it "offset0 factory has confidence 80":
        val td = TrailerDetection.offset0()
        expect(td.confidence).to_equal(80)

    it "offset0 factory has fallback_used true":
        val td = TrailerDetection.offset0()
        expect(td.fallback_used).to_equal(true)

    it "not_found factory yields is_found false":
        val td = TrailerDetection.not_found()
        expect(td.is_found()).to_equal(false)

    it "not_found factory has confidence 0":
        val td = TrailerDetection.not_found()
        expect(td.confidence).to_equal(0)

    it "trailer factory is_found true":
        val td = TrailerDetection.trailer(1)
        expect(td.is_found()).to_equal(true)

    it "to_text contains detection_mode":
        val td = TrailerDetection.trailer(8)
        expect(td.to_text()).to_contain("trailer")

# ============================================================================
# HeaderFallback specs
# ============================================================================

describe "HeaderFallback - strategy resolution":
    it "standard factory has primary trailer mode":
        val fb = HeaderFallback.standard()
        expect(fb.primary_mode).to_equal("trailer")

    it "standard factory has offset0 fallback mode":
        val fb = HeaderFallback.standard()
        expect(fb.fallback_mode).to_equal("offset0")

    it "standard factory starts unresolved":
        val fb = HeaderFallback.standard()
        expect(fb.resolved).to_equal(false)

    it "needs_fallback true when unresolved":
        val fb = HeaderFallback.standard()
        expect(fb.needs_fallback()).to_equal(true)

    it "resolve sets resolved true":
        val fb = HeaderFallback.standard().resolve()
        expect(fb.resolved).to_equal(true)

    it "needs_fallback false after resolve":
        val fb = HeaderFallback.standard().resolve()
        expect(fb.needs_fallback()).to_equal(false)

    it "trailer_only has no fallback mode":
        val fb = HeaderFallback.trailer_only()
        expect(fb.fallback_mode).to_equal("none")

    it "to_text contains primary mode":
        val fb = HeaderFallback.standard()
        expect(fb.to_text()).to_contain("trailer")

# ============================================================================
# SmfTestVector specs
# ============================================================================

describe "SmfTestVector - parameterised detection vectors":
    it "pure_smf vector expects trailer mode":
        val v = SmfTestVector.pure_smf(1024)
        expect(v.expected_mode).to_equal("trailer")

    it "pure_smf vector is positive":
        val v = SmfTestVector.pure_smf(1024)
        expect(v.is_positive()).to_equal(true)

    it "pure_smf vector records file_size":
        val v = SmfTestVector.pure_smf(1024)
        expect(v.file_size).to_equal(1024)

    it "malformed vector expects none mode":
        val v = SmfTestVector.malformed(512)
        expect(v.expected_mode).to_equal("none")

    it "malformed vector is not positive":
        val v = SmfTestVector.malformed(512)
        expect(v.is_positive()).to_equal(false)

    it "to_text contains vector name":
        val v = SmfTestVector.pure_smf(256)
        expect(v.to_text()).to_contain("pure_smf")

    it "to_text contains expected mode":
        val v = SmfTestVector.malformed(256)
        expect(v.to_text()).to_contain("none")
