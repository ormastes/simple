class LibraryRole:
    role_name: text
    is_pic: bool
    load_priority: int
    version: int

    me is_runtime() -> bool:
        return role_name == "runtime"

    me is_plugin() -> bool:
        return role_name == "plugin"

    me to_text() -> text:
        return "role:" + role_name + " pic=" + is_pic.to_text() + " v" + version.to_text()

    static fn runtime(ver: int) -> LibraryRole:
        return LibraryRole(role_name: "runtime", is_pic: true, load_priority: 0, version: ver)

    static fn plugin(ver: int) -> LibraryRole:
        return LibraryRole(role_name: "plugin", is_pic: true, load_priority: 10, version: ver)


class LinkNamespace:
    namespace_name: text
    process_id: int
    lib_count: int
    is_global: bool

    me is_process_local() -> bool:
        return is_global == false

    me to_text() -> text:
        return "ns:" + namespace_name + " pid=" + process_id.to_text() + " libs=" + lib_count.to_text()

    me add_lib() -> LinkNamespace:
        return LinkNamespace(namespace_name: namespace_name, process_id: process_id, lib_count: lib_count + 1, is_global: is_global)

    static fn global_ns() -> LinkNamespace:
        return LinkNamespace(namespace_name: "global", process_id: 0, lib_count: 0, is_global: true)

    static fn process_ns(name: text, pid: int) -> LinkNamespace:
        return LinkNamespace(namespace_name: name, process_id: pid, lib_count: 0, is_global: false)


class DynLoadRequest:
    library_name: text
    search_path: text
    load_mode: text
    namespace_ref: text

    me is_lazy() -> bool:
        return load_mode == "lazy"

    me is_eager() -> bool:
        return load_mode == "eager"

    me to_text() -> text:
        return "load:" + library_name + " mode=" + load_mode + " ns=" + namespace_ref

    static fn lazy(name: text, path: text, ns: text) -> DynLoadRequest:
        return DynLoadRequest(library_name: name, search_path: path, load_mode: "lazy", namespace_ref: ns)

    static fn eager(name: text, path: text, ns: text) -> DynLoadRequest:
        return DynLoadRequest(library_name: name, search_path: path, load_mode: "eager", namespace_ref: ns)


class DynLoadResult:
    library_name: text
    success: bool
    handle_id: int
    error_msg: text

    me is_loaded() -> bool:
        return success

    me is_error() -> bool:
        return success == false

    me to_text() -> text:
        if success:
            return "loaded:" + library_name + " handle=" + handle_id.to_text()
        return "error:" + library_name + " " + error_msg

    static fn ok(name: text, handle: int) -> DynLoadResult:
        return DynLoadResult(library_name: name, success: true, handle_id: handle, error_msg: "")

    static fn fail(name: text, err: text) -> DynLoadResult:
        return DynLoadResult(library_name: name, success: false, handle_id: 0, error_msg: err)
