use common.window_protocol.geometry.{Size}
use common.ui.html_window.{html_pre_block, html_titlebar_button, html_window_content, html_window_content_with_titlebar_widgets}
use os.compositor.host_compositor_entry.{
    HostCompositor,
    host_compositor_cycle_focus,
    host_compositor_focused_window_id,
    host_compositor_minimize_focused,
    host_compositor_restore_all
}
use os.compositor.hosted_backend_win32.{HostedWin32Backend}

extern fn rt_env_get(key: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_sleep_ms(ms: i64)
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_win32_message_pump(hwnd: i64) -> i64

val WINDOW_WIDTH: i32 = 1024
val WINDOW_HEIGHT: i32 = 720
val WINDOW_TITLE: text = "SimpleOS Win32 Hosted MDI Probe"

fn _env_or(key: text, fallback: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value == "":
        return fallback
    value

fn _env_i64_or(key: text, fallback: i64) -> i64:
    val value = _env_or(key, "")
    if value == "":
        return fallback
    value.to_i64()

fn _terminal_body() -> text:
    html_pre_block("$ simple --version\nSimple Language\n\n$ _") +
        "<button data-action=\"mdi_terminal_action\">Run</button>" +
        "<input data-target-id=\"mdi_terminal_input\" value=\"ready\">"

fn _terminal_html() -> text:
    val titlebar_css = ".simple-titlebar-widget{background:rgb(18,58,52);border-color:rgb(52,211,153);color:rgb(236,254,255);}"
    html_window_content_with_titlebar_widgets(
        "Terminal",
        _terminal_body(),
        html_titlebar_button("mdi_terminal_action", "Run"),
        titlebar_css
    )

fn _editor_html() -> text:
    html_window_content("Editor", html_pre_block("src/main.spl\nreal Simple Web text"), "")

fn _browser_html() -> text:
    html_window_content("Browser", html_pre_block("about:network"), "")

fn _files_html() -> text:
    html_window_content("File Manager", html_pre_block("home\nusr\nvar"), "")

fn _seed_probe_windows(comp: HostCompositor):
    comp.apply_bridge_request(101, 101, 1, 0, "Terminal", 50, 60, 600, 400, _terminal_html(), 101, "terminal")
    comp.apply_bridge_request(102, 102, 1, 0, "Editor", 90, 480, 520, 190, _editor_html(), 102, "editor")
    comp.apply_bridge_request(103, 103, 1, 0, "Browser", 680, 80, 280, 220, _browser_html(), 103, "browser")
    comp.apply_bridge_request(104, 104, 1, 0, "File Manager", 690, 340, 250, 190, _files_html(), 104, "file-manager")

fn _find_window_index_by_title(comp: HostCompositor, title: text) -> i32:
    var i = 0
    while i < comp.windows.len():
        if comp.windows[i].title == title:
            return i
        i = i + 1
    -1

fn _count_minimized(comp: HostCompositor) -> i32:
    var count = 0
    for win in comp.windows:
        if win.minimized:
            count = count + 1
    count

fn _count_focused(comp: HostCompositor) -> i32:
    var count = 0
    for win in comp.windows:
        if win.focused:
            count = count + 1
    count

fn _write_proof(path: text, content: text):
    if path != "":
        rt_file_write_text(path, content)

fn _proof_text(
    status: text,
    reason: text,
    window_count: i32,
    focused_count: i32,
    focused_before: i64,
    focused_after: i64,
    drag_moved: bool,
    minimized_after_action: i32,
    minimized_after_restore: i32,
    titlebar_widget_markup_present: bool,
    body_button_markup_present: bool,
    body_input_markup_present: bool,
    titlebar_css_present: bool,
    rendered_titlebar_css_pixels: i32,
    rendered_titlebar_css_applied: bool,
    terminal_before_x: i32,
    terminal_after_x: i32,
    terminal_before_y: i32,
    terminal_after_y: i32
) -> text:
    "status=" + status + "\n" +
        "reason=" + reason + "\n" +
        "backend=win32-native\n" +
        "window_title=" + WINDOW_TITLE + "\n" +
        "window_count=" + window_count.to_text() + "\n" +
        "focused_count=" + focused_count.to_text() + "\n" +
        "focused_before=" + focused_before.to_text() + "\n" +
        "focused_after=" + focused_after.to_text() + "\n" +
        "focus_cycle_changed=" + (focused_before != focused_after).to_text() + "\n" +
        "drag_moved=" + drag_moved.to_text() + "\n" +
        "minimized_after_action=" + minimized_after_action.to_text() + "\n" +
        "minimized_after_restore=" + minimized_after_restore.to_text() + "\n" +
        "titlebar_widget_markup_present=" + titlebar_widget_markup_present.to_text() + "\n" +
        "body_button_markup_present=" + body_button_markup_present.to_text() + "\n" +
        "body_input_markup_present=" + body_input_markup_present.to_text() + "\n" +
        "titlebar_css_present=" + titlebar_css_present.to_text() + "\n" +
        "rendered_titlebar_css_pixels=" + rendered_titlebar_css_pixels.to_text() + "\n" +
        "rendered_titlebar_css_applied=" + rendered_titlebar_css_applied.to_text() + "\n" +
        "terminal_before_x=" + terminal_before_x.to_text() + "\n" +
        "terminal_after_x=" + terminal_after_x.to_text() + "\n" +
        "terminal_before_y=" + terminal_before_y.to_text() + "\n" +
        "terminal_after_y=" + terminal_after_y.to_text() + "\n"

fn _count_titlebar_css_pixels(backend: HostedWin32Backend, x: i32, y: i32, w: i32, h: i32) -> i32:
    val end_x = x + w
    val end_y = y + h
    var count = 0
    var py = y
    while py < end_y:
        var px = x
        while px < end_x:
            val pixel = backend.read_pixel(px, py)
            if pixel == 0xFF123A34u32 or pixel == 0xFF34D399u32:
                count = count + 1
            px = px + 1
        py = py + 1
    count

fn main() -> i64:
    val proof_path = _env_or("SIMPLE_WIN32_MDI_PROOF_PATH", "")
    val hold_ms = _env_i64_or("SIMPLE_WIN32_MDI_HOLD_MS", 5000)

    val backend = HostedWin32Backend.try_create(0, WINDOW_WIDTH, WINDOW_HEIGHT, 0xFF0F172Au32)
    if backend == nil:
        _write_proof(proof_path, _proof_text("fail", "win32-backend-unavailable", 0, 0, 0, 0, false, 0, 0, false, false, false, false, 0, false, 0, 0, 0, 0))
        print "status=fail"
        print "reason=win32-backend-unavailable"
        return 1

    print "SimpleOS Win32 hosted MDI probe"
    val comp = HostCompositor.new(backend, Size(width: WINDOW_WIDTH.to_u64(), height: WINDOW_HEIGHT.to_u64()))
    _seed_probe_windows(comp)
    comp.render_frame()

    val terminal_idx = _find_window_index_by_title(comp, "Terminal")
    val terminal_before = if terminal_idx >= 0: comp.windows[terminal_idx] else: nil
    val terminal_html = _terminal_html()
    val titlebar_widget_markup_present = terminal_html.contains("data-simple-titlebar-widget")
    val body_button_markup_present = terminal_html.contains("mdi_terminal_action")
    val body_input_markup_present = terminal_html.contains("mdi_terminal_input")
    val titlebar_css_present = terminal_html.contains(".simple-titlebar-widgets{display:flex;align-items:center;gap:6px;margin-left:auto;}") and
        terminal_html.contains(".simple-titlebar-widget{background:rgb(18,58,52);border-color:rgb(52,211,153);color:rgb(236,254,255);}")
    val focused_before = host_compositor_focused_window_id(comp)

    if terminal_before != nil:
        comp.pointer_move(terminal_before.x + 40, terminal_before.y + 10)
        comp.handle_left_button(true)
        comp.pointer_move(terminal_before.x + 130, terminal_before.y + 50)
        comp.handle_left_button(false)
        comp.render_frame()

    val focused_cycled = host_compositor_cycle_focus(comp)
    comp.windows = focused_cycled.windows
    comp.next_window_id = focused_cycled.next_window_id
    comp.render_frame()
    val focused_after = host_compositor_focused_window_id(comp)

    val minimized = host_compositor_minimize_focused(comp)
    comp.windows = minimized.windows
    comp.next_window_id = minimized.next_window_id
    comp.render_frame()
    val minimized_after_action = _count_minimized(comp)

    val restored = host_compositor_restore_all(comp)
    comp.windows = restored.windows
    comp.next_window_id = restored.next_window_id
    comp.render_frame()
    val minimized_after_restore = _count_minimized(comp)

    val terminal_after_idx = _find_window_index_by_title(comp, "Terminal")
    val terminal_after = if terminal_after_idx >= 0: comp.windows[terminal_after_idx] else: nil
    val drag_moved = terminal_before != nil and terminal_after != nil and
        (terminal_before.x != terminal_after.x or terminal_before.y != terminal_after.y)
    val rendered_titlebar_css_pixels = if terminal_after != nil:
        _count_titlebar_css_pixels(backend, terminal_after.x + 4, terminal_after.y + 28, terminal_after.w - 8, 96)
    else:
        0
    val rendered_titlebar_css_applied = rendered_titlebar_css_pixels > 20

    val proof = _proof_text(
        "pass",
        "pass",
        comp.windows.len(),
        _count_focused(comp),
        focused_before,
        focused_after,
        drag_moved,
        minimized_after_action,
        minimized_after_restore,
        titlebar_widget_markup_present,
        body_button_markup_present,
        body_input_markup_present,
        titlebar_css_present,
        rendered_titlebar_css_pixels,
        rendered_titlebar_css_applied,
        if terminal_before != nil: terminal_before.x else: 0,
        if terminal_after != nil: terminal_after.x else: 0,
        if terminal_before != nil: terminal_before.y else: 0,
        if terminal_after != nil: terminal_after.y else: 0
    )
    _write_proof(proof_path, proof)

    val deadline = rt_time_now_unix_micros() + hold_ms * 1000
    while rt_time_now_unix_micros() < deadline:
        rt_win32_message_pump(backend.window_id)
        rt_sleep_ms(16)

    backend.free()
    print "status=pass"
    print "reason=pass"
    return 0
