# SimpleOS hosted shared WM entry.
#
# This is the manual-inspection entry for the real hosted GUI path. It uses the
# shared host compositor lifecycle state and Simple Web app renderer, then
# presents through the winit buffer backend.

use common.window_protocol.geometry.{Size}
use os.compositor.host_compositor_entry.{
    HostCompositor,
    host_compositor_cycle_focus,
    host_compositor_focused_window_id,
    host_compositor_minimize_focused,
    host_compositor_restore_all
}
use os.compositor.hosted_backend_winit.{HostedWinitBufferBackend}
use os.compositor.shared_mdi_host_seed.{seed_host_compositor_shared_mdi}
use os.compositor.compositor_engine2d.{Engine2dCompositorBackend}
use common.ui.window_scene.{shared_wm_motion_background_next_due_micros, shared_wm_motion_dirty_due, shared_wm_motion_background_consume_due}

extern fn rt_winit_event_loop_new() -> i64
extern fn rt_winit_window_new(el: i64, w: i64, h: i64, title: text) -> i64
extern fn rt_winit_event_loop_poll_events(el: i64, max: i64) -> i64
extern fn rt_winit_event_get_type(ev: i64) -> i64
extern fn rt_winit_event_keyboard_input(ev: i64) -> (i64, i64, bool)
extern fn rt_winit_event_mouse_moved(ev: i64) -> (i32, i32)
extern fn rt_winit_event_mouse_button(ev: i64) -> (i64, bool)
extern fn rt_winit_event_mouse_wheel(ev: i64) -> (f64, f64)
extern fn rt_winit_event_free(ev: i64)
extern fn rt_winit_window_free(win: i64)
extern fn rt_winit_event_loop_free(el: i64)
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_env_get(key: text) -> text?

# Engine2D raster-lane present sink: a raw winit buffer used only to blit the
# Engine2D-composed frame onto the window when SIMPLE_WM_RASTER=engine2d is
# set. It is NOT wrapped in CompositorBackend — the compositor draws into the
# Engine2D session (comp.backend), and this buffer only carries the final
# pixels to the OS window each frame.
extern fn rt_winit_buffer_create(w: i64, h: i64, fill_color: i64) -> i64
extern fn rt_winit_buffer_blit_pixels(buf: i64, x: i32, y: i32, w: i32, h: i32, pixels: [u32]) -> bool
extern fn rt_winit_buffer_present(win: i64, buf: i64) -> bool
extern fn rt_winit_buffer_free(buf: i64) -> bool

# SIMPLE_WM_RASTER=engine2d opts the live WM lane into the persistent Engine2D
# compositor backend (src/os/compositor/compositor_engine2d.spl) instead of
# the default HostedWinitBufferBackend. Unset/any-other-value keeps the
# historical default lane byte-identical. See
# doc/08_tracking/bug/ (task #28-A) for the adoption rationale.
fn _engine2d_raster_mode() -> bool:
    (rt_env_get("SIMPLE_WM_RASTER") ?? "") == "engine2d"

val WINDOW_WIDTH: i32 = 1024
val WINDOW_HEIGHT: i32 = 720
val WINDOW_TITLE: text = "SimpleOS Shared Hosted WM"

val EVT_CLOSE: i64 = 3
val EVT_FOCUS: i64 = 5
val EVT_UNFOCUS: i64 = 6
val EVT_KEY: i64 = 10
val EVT_MOUSE_BUTTON: i64 = 20
val EVT_MOUSE_MOVE: i64 = 21
val EVT_MOUSE_WHEEL: i64 = 22

val KEY_ESCAPE: i64 = 27
val KEY_TAB: i64 = 9
val KEY_M: i64 = 77
val KEY_R: i64 = 82
val KEY_W: i64 = 87
val HOSTED_CREATE_WEB_WINDOW: i64 = 14

fn _live_proof_mode() -> bool:
    (rt_env_get("SIMPLE_HOSTED_WM_LIVE_PROOF") ?? "") == "1"

fn _seed_live_proof_surface(comp: HostCompositor) -> HostCompositor:
    var out = comp
    out.apply_bridge_request(
        101,
        101,
        HOSTED_CREATE_WEB_WINDOW,
        0,
        "Terminal",
        58,
        76,
        180,
        96,
        "simple$ live proof",
        101,
        "terminal"
    )
    out

fn main() -> i64:
    print "SimpleOS shared hosted WM ({WINDOW_WIDTH}x{WINDOW_HEIGHT})"
    print "Renderer: HostCompositor lifecycle + Simple Web app content + winit buffer backend"
    print "Controls: drag titlebars, click focus, close X, Tab cycle, W close, M minimize, R restore, Esc quit"

    val el = rt_winit_event_loop_new()
    val win = rt_winit_window_new(el, WINDOW_WIDTH.to_i64(), WINDOW_HEIGHT.to_i64(), WINDOW_TITLE)
    if win == 0:
        print "ERROR: winit window creation failed"
        return 1
    print "[hosted-wm] window-created backend=winit mode=windowed fullscreen=false width={WINDOW_WIDTH} height={WINDOW_HEIGHT} title={WINDOW_TITLE}"

    val engine2d_raster = _engine2d_raster_mode()
    if engine2d_raster:
        val e2d_backend = Engine2dCompositorBackend.create_from_env(WINDOW_WIDTH, WINDOW_HEIGHT)
        val present_sink = rt_winit_buffer_create(WINDOW_WIDTH.to_i64(), WINDOW_HEIGHT.to_i64(), 0xFF0F172A)
        if present_sink <= 0:
            print "ERROR: hosted engine2d present-sink buffer creation failed"
            e2d_backend.shutdown()
            rt_winit_window_free(win)
            rt_winit_event_loop_free(el)
            return 1
        print "[hosted-wm] raster-backend=engine2d {e2d_backend.frame_provenance()}"
        val comp = HostCompositor.new(e2d_backend, Size(width: WINDOW_WIDTH.to_u64(), height: WINDOW_HEIGHT.to_u64()))
        return _run_hosted_wm(comp, el, win, true, present_sink, nil)
    else:
        val backend = HostedWinitBufferBackend.create(win, WINDOW_WIDTH, WINDOW_HEIGHT, 0xFF0F172Au32)
        if backend == nil:
            print "ERROR: hosted winit backend creation failed"
            rt_winit_window_free(win)
            rt_winit_event_loop_free(el)
            return 1
        val comp = HostCompositor.new(backend, Size(width: WINDOW_WIDTH.to_u64(), height: WINDOW_HEIGHT.to_u64()))
        return _run_hosted_wm(comp, el, win, false, 0, backend)

# Engine2D raster-lane present-sink flush: reads back the persistent
# Engine2D session's pixels and forwards them to the OS window via the winit
# buffer present sink. Shared by the full render_frame() path and the I8
# background-only region-dirty path (HostCompositor.render_background_only)
# below — both leave the final pixels sitting in the SAME Engine2D session, so
# both need the identical readback+blit+present sequence to actually reach
# the screen.
fn _hosted_wm_flush_engine2d_frame(comp: HostCompositor, present_sink: i64, win: i64):
    val pixels = comp.backend.get_pixel_buffer()
    rt_winit_buffer_blit_pixels(present_sink, 0, 0, WINDOW_WIDTH, WINDOW_HEIGHT, pixels)
    rt_winit_buffer_present(win, present_sink)

# Shared event loop + render/present + shutdown for both raster lanes. `comp`
# arrives already backed by either HostedWinitBufferBackend (default) or
# Engine2dCompositorBackend (SIMPLE_WM_RASTER=engine2d); `present_sink` and
# `winit_backend` carry whichever lane-specific handle needs freeing on exit.
fn _run_hosted_wm(comp_in: HostCompositor, el: i64, win: i64, engine2d_raster: bool, present_sink: i64, winit_backend: HostedWinitBufferBackend?) -> i64:
    var comp = comp_in
    val live_proof = _live_proof_mode()
    if live_proof:
        comp = _seed_live_proof_surface(comp)
        print "[hosted-wm] live-proof-mode enabled=true"
    else:
        comp = seed_host_compositor_shared_mdi(comp)
    print "[hosted-wm] windows-ready count={comp.windows.len()}"
    comp.render_frame()
    if engine2d_raster:
        val pixels0 = comp.backend.get_pixel_buffer()
        rt_winit_buffer_blit_pixels(present_sink, 0, 0, WINDOW_WIDTH, WINDOW_HEIGHT, pixels0)
        rt_winit_buffer_present(win, present_sink)
        print "[hosted-wm] frame-presented renderer=simple-web host=linux-windowed width={WINDOW_WIDTH} height={WINDOW_HEIGHT} raster=engine2d provenance={comp.backend.frame_provenance()}"
    else:
        print "[hosted-wm] frame-presented renderer=simple-web host=linux-windowed width={WINDOW_WIDTH} height={WINDOW_HEIGHT} raster=winit"
    print "Frame presented: shared lifecycle windows + Simple Web MDI content"

    var running = true
    var warmup_frames: i64 = 0
    var mouse_move_events: i64 = 0
    var mouse_button_events: i64 = 0
    var focus_events: i64 = 0
    var key_events: i64 = 0
    # Motion-background cadence seam (plan item B): the loop stays dirty-gated
    # (GUI-5a) — a due motion frame is just one more dirty *trigger*, evaluated
    # by the pure shared_wm_motion_dirty_due predicate on the loop's existing
    # iteration cadence (no new polling/sleeping is introduced). With no
    # motion source registered the seam reads -1 ("never due") and this loop
    # is byte-for-byte the old dirty decision.
    #
    # Self-re-arm: the trigger's once-per-due-value contract needs the
    # source's next-due to advance to a NEW value after it fires, which
    # normally happens as a side effect of render consuming the frame. Calling
    # shared_wm_motion_background_consume_due() right after the trigger fires
    # advances the source's bookkeeping directly at the seam, so the loop
    # re-arms itself every interval independent of what any render path does.
    #
    # I8 region-dirty (plan item B follow-up 1/2, LANDED): `other_dirty` and
    # `motion_dirty` are tracked separately so a due motion frame with NO
    # other reason to redraw takes HostCompositor.render_background_only()
    # instead of a full render_frame() — background-only advance no longer
    # re-rasters windows/chrome (host_compositor_entry.spl). Any OTHER dirty
    # reason (input, warmup) still forces the full path, which itself now
    # resolves self.background (color/image/motion) before drawing chrome
    # instead of hardcoding theme.compositor_bg — see
    # HostCompositor._resolve_background / render_frame's direct-draw branch.
    # render_background_only returns false when the background-visible region
    # can't be cheaply computed (pathological window layout); that case falls
    # back to a full render_frame() rather than risking an incorrect partial
    # paint.
    var last_motion_fired_due: i64 = -1
    val end_at = rt_time_now_unix_micros() + 300000000
    while running and rt_time_now_unix_micros() < end_at:
        var other_dirty = false
        var motion_dirty = false
        val now_micros = rt_time_now_unix_micros()
        val motion_due = shared_wm_motion_background_next_due_micros()
        if shared_wm_motion_dirty_due(now_micros, motion_due, last_motion_fired_due):
            motion_dirty = true
            last_motion_fired_due = motion_due
            shared_wm_motion_background_consume_due(motion_due)
        var ev = rt_winit_event_loop_poll_events(el, 1)
        while ev != 0:
            val kind = rt_winit_event_get_type(ev)
            if kind == EVT_CLOSE:
                running = false
            elif kind == EVT_FOCUS or kind == EVT_UNFOCUS:
                focus_events = focus_events + 1
                print "[hosted-wm] event focus count={focus_events} focused={kind == EVT_FOCUS}"
            elif kind == EVT_MOUSE_MOVE:
                val (mx, my) = rt_winit_event_mouse_moved(ev)
                comp.pointer_move(mx, my)
                mouse_move_events = mouse_move_events + 1
                if mouse_move_events <= 3:
                    print "[hosted-wm] event mouse_move count={mouse_move_events} x={mx} y={my}"
                other_dirty = true
            elif kind == EVT_MOUSE_BUTTON:
                val (button, pressed) = rt_winit_event_mouse_button(ev)
                # Route all buttons (0=left, 1=middle, 2=right) to the compositor,
                # not just left. Left keeps its full chrome semantics; middle/right
                # are recorded on the compositor (last_button/last_button_down) so
                # the event is observable even though no chrome action consumes
                # them yet (parity with ui.browser/app.spl's unconditional forward).
                comp.handle_mouse_button(button, pressed)
                mouse_button_events = mouse_button_events + 1
                print "[hosted-wm] event mouse_button count={mouse_button_events} button={button} pressed={pressed}"
                other_dirty = true
            elif kind == EVT_MOUSE_WHEEL:
                val (wheel_dx, wheel_dy) = rt_winit_event_mouse_wheel(ev)
                comp.handle_mouse_wheel(wheel_dx, wheel_dy)
                other_dirty = true
            elif kind == EVT_KEY:
                val (scan_code, keycode, pressed_key) = rt_winit_event_keyboard_input(ev)
                if pressed_key:
                    key_events = key_events + 1
                    print "[hosted-wm] event key count={key_events} keycode={keycode}"
                    if keycode == KEY_ESCAPE:
                        running = false
                    elif keycode == KEY_TAB:
                        comp = host_compositor_cycle_focus(comp)
                    elif keycode == KEY_W:
                        val focused = host_compositor_focused_window_id(comp)
                        if focused > 0:
                            comp.destroy_window(focused)
                    elif keycode == KEY_M:
                        comp = host_compositor_minimize_focused(comp)
                    elif keycode == KEY_R:
                        comp = host_compositor_restore_all(comp)
                    other_dirty = true
            rt_winit_event_free(ev)
            ev = rt_winit_event_loop_poll_events(el, 1)
        if other_dirty or warmup_frames < 12:
            comp.render_frame()
            if engine2d_raster:
                _hosted_wm_flush_engine2d_frame(comp, present_sink, win)
            if warmup_frames < 12:
                warmup_frames = warmup_frames + 1
                if warmup_frames == 12:
                    print "[hosted-wm] warmup-frames-presented count={warmup_frames}"
                    if engine2d_raster:
                        print "[hosted-wm] frame-provenance {comp.backend.frame_provenance()}"
        elif motion_dirty:
            if comp.render_background_only(motion_due):
                if engine2d_raster:
                    _hosted_wm_flush_engine2d_frame(comp, present_sink, win)
            else:
                comp.render_frame()
                if engine2d_raster:
                    _hosted_wm_flush_engine2d_frame(comp, present_sink, win)

    if engine2d_raster:
        print "[hosted-wm] frame-provenance-final {comp.backend.frame_provenance()}"
        comp.backend.shutdown()
        rt_winit_buffer_free(present_sink)
    elif val wb = winit_backend:
        wb.free()
    rt_winit_window_free(win)
    rt_winit_event_loop_free(el)
    print "SimpleOS shared hosted WM closed"
    return 0
