# SimpleOS hosted shared WM entry.
#
# This is the manual-inspection entry for the real hosted GUI path. It uses the
# shared host compositor lifecycle state and Simple Web app renderer, then
# presents through the winit buffer backend.

use common.window_protocol.geometry.{Size}
use os.compositor.host_compositor_entry.{
    HostCompositor,
    host_compositor_cycle_focus,
    host_compositor_focused_window_id,
    host_compositor_minimize_focused,
    host_compositor_restore_all
}
use os.compositor.hosted_backend_winit.{HostedWinitBufferBackend}
use os.compositor.shared_mdi_host_seed.{seed_host_compositor_shared_mdi}

extern fn rt_winit_event_loop_new() -> i64
extern fn rt_winit_window_new(el: i64, w: i64, h: i64, title: text) -> i64
extern fn rt_winit_event_loop_poll_events(el: i64, max: i64) -> i64
extern fn rt_winit_event_get_type(ev: i64) -> i64
extern fn rt_winit_event_keyboard_input(ev: i64) -> (i64, i64, bool)
extern fn rt_winit_event_mouse_moved(ev: i64) -> (i32, i32)
extern fn rt_winit_event_mouse_button(ev: i64) -> (i64, bool)
extern fn rt_winit_event_mouse_wheel(ev: i64) -> (f64, f64)
extern fn rt_winit_event_free(ev: i64)
extern fn rt_winit_window_free(win: i64)
extern fn rt_winit_event_loop_free(el: i64)
extern fn rt_time_now_unix_micros() -> i64
extern fn rt_env_get(key: text) -> text?

val WINDOW_WIDTH: i32 = 1024
val WINDOW_HEIGHT: i32 = 720
val WINDOW_TITLE: text = "SimpleOS Shared Hosted WM"

val EVT_CLOSE: i64 = 3
val EVT_FOCUS: i64 = 5
val EVT_UNFOCUS: i64 = 6
val EVT_KEY: i64 = 10
val EVT_MOUSE_BUTTON: i64 = 20
val EVT_MOUSE_MOVE: i64 = 21
val EVT_MOUSE_WHEEL: i64 = 22

val KEY_ESCAPE: i64 = 27
val KEY_TAB: i64 = 9
val KEY_M: i64 = 77
val KEY_R: i64 = 82
val KEY_W: i64 = 87
val HOSTED_CREATE_WEB_WINDOW: i64 = 14

fn _live_proof_mode() -> bool:
    (rt_env_get("SIMPLE_HOSTED_WM_LIVE_PROOF") ?? "") == "1"

fn _seed_live_proof_surface(comp: HostCompositor) -> HostCompositor:
    var out = comp
    out.apply_bridge_request(
        101,
        101,
        HOSTED_CREATE_WEB_WINDOW,
        0,
        "Terminal",
        58,
        76,
        180,
        96,
        "simple$ live proof",
        101,
        "terminal"
    )
    out

fn main() -> i64:
    print "SimpleOS shared hosted WM ({WINDOW_WIDTH}x{WINDOW_HEIGHT})"
    print "Renderer: HostCompositor lifecycle + Simple Web app content + winit buffer backend"
    print "Controls: drag titlebars, click focus, close X, Tab cycle, W close, M minimize, R restore, Esc quit"

    val el = rt_winit_event_loop_new()
    val win = rt_winit_window_new(el, WINDOW_WIDTH.to_i64(), WINDOW_HEIGHT.to_i64(), WINDOW_TITLE)
    if win == 0:
        print "ERROR: winit window creation failed"
        return 1
    print "[hosted-wm] window-created backend=winit mode=windowed fullscreen=false width={WINDOW_WIDTH} height={WINDOW_HEIGHT} title={WINDOW_TITLE}"

    val backend = HostedWinitBufferBackend.create(win, WINDOW_WIDTH, WINDOW_HEIGHT, 0xFF0F172Au32)
    if backend == nil:
        print "ERROR: hosted winit backend creation failed"
        rt_winit_window_free(win)
        rt_winit_event_loop_free(el)
        return 1

    val live_proof = _live_proof_mode()
    var comp = HostCompositor.new(backend, Size(width: WINDOW_WIDTH.to_u64(), height: WINDOW_HEIGHT.to_u64()))
    if live_proof:
        comp = _seed_live_proof_surface(comp)
        print "[hosted-wm] live-proof-mode enabled=true"
    else:
        comp = seed_host_compositor_shared_mdi(comp)
    print "[hosted-wm] windows-ready count={comp.windows.len()}"
    comp.render_frame()
    print "[hosted-wm] frame-presented renderer=simple-web host=linux-windowed width={WINDOW_WIDTH} height={WINDOW_HEIGHT}"
    print "Frame presented: shared lifecycle windows + Simple Web MDI content"

    var running = true
    var warmup_frames: i64 = 0
    var mouse_move_events: i64 = 0
    var mouse_button_events: i64 = 0
    var focus_events: i64 = 0
    var key_events: i64 = 0
    val end_at = rt_time_now_unix_micros() + 300000000
    while running and rt_time_now_unix_micros() < end_at:
        var dirty = false
        var ev = rt_winit_event_loop_poll_events(el, 1)
        while ev != 0:
            val kind = rt_winit_event_get_type(ev)
            if kind == EVT_CLOSE:
                running = false
            elif kind == EVT_FOCUS or kind == EVT_UNFOCUS:
                focus_events = focus_events + 1
                print "[hosted-wm] event focus count={focus_events} focused={kind == EVT_FOCUS}"
            elif kind == EVT_MOUSE_MOVE:
                val (mx, my) = rt_winit_event_mouse_moved(ev)
                comp.pointer_move(mx, my)
                mouse_move_events = mouse_move_events + 1
                if mouse_move_events <= 3:
                    print "[hosted-wm] event mouse_move count={mouse_move_events} x={mx} y={my}"
                dirty = true
            elif kind == EVT_MOUSE_BUTTON:
                val (button, pressed) = rt_winit_event_mouse_button(ev)
                # Route all buttons (0=left, 1=middle, 2=right) to the compositor,
                # not just left. Left keeps its full chrome semantics; middle/right
                # are recorded on the compositor (last_button/last_button_down) so
                # the event is observable even though no chrome action consumes
                # them yet (parity with ui.browser/app.spl's unconditional forward).
                comp.handle_mouse_button(button, pressed)
                mouse_button_events = mouse_button_events + 1
                print "[hosted-wm] event mouse_button count={mouse_button_events} button={button} pressed={pressed}"
                dirty = true
            elif kind == EVT_MOUSE_WHEEL:
                val (wheel_dx, wheel_dy) = rt_winit_event_mouse_wheel(ev)
                comp.handle_mouse_wheel(wheel_dx, wheel_dy)
                dirty = true
            elif kind == EVT_KEY:
                val (scan_code, keycode, pressed_key) = rt_winit_event_keyboard_input(ev)
                if pressed_key:
                    key_events = key_events + 1
                    print "[hosted-wm] event key count={key_events} keycode={keycode}"
                    if keycode == KEY_ESCAPE:
                        running = false
                    elif keycode == KEY_TAB:
                        comp = host_compositor_cycle_focus(comp)
                    elif keycode == KEY_W:
                        val focused = host_compositor_focused_window_id(comp)
                        if focused > 0:
                            comp.destroy_window(focused)
                    elif keycode == KEY_M:
                        comp = host_compositor_minimize_focused(comp)
                    elif keycode == KEY_R:
                        comp = host_compositor_restore_all(comp)
                    dirty = true
            rt_winit_event_free(ev)
            ev = rt_winit_event_loop_poll_events(el, 1)
        if dirty or warmup_frames < 12:
            comp.render_frame()
            if warmup_frames < 12:
                warmup_frames = warmup_frames + 1
                if warmup_frames == 12:
                    print "[hosted-wm] warmup-frames-presented count={warmup_frames}"

    backend.free()
    rt_winit_window_free(win)
    rt_winit_event_loop_free(el)
    print "SimpleOS shared hosted WM closed"
    return 0
