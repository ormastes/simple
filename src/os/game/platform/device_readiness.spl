# Game Device Readiness Contracts — SimpleOS
# MDSOC: feature dimension, os/game/platform layer
# Readiness structs for GPU, audio, input, network, filesystem, and CPU,
# plus GameDeviceReadinessReport aggregating all six subsystems.

class GpuGameReadiness:
    """GPU readiness descriptor for game compatibility checks."""
    vulkan_available: bool
    vulkan_version: text
    compute_available: bool
    compute_backend: text
    vram_mb: i64
    shader_model: text
    vendor: text
    driver_version: text

impl GpuGameReadiness:
    static fn create() -> GpuGameReadiness:
        GpuGameReadiness(
            vulkan_available: false, vulkan_version: "",
            compute_available: false, compute_backend: "none",
            vram_mb: 0, shader_model: "", vendor: "unknown", driver_version: ""
        )

    static fn from_vendor(vendor: text, vulkan: bool, vk_ver: text, compute: bool, comp_be: text, vram: i64) -> GpuGameReadiness:
        GpuGameReadiness(
            vulkan_available: vulkan, vulkan_version: vk_ver,
            compute_available: compute, compute_backend: comp_be,
            vram_mb: vram, shader_model: "", vendor: vendor, driver_version: ""
        )

    me meets_minimum() -> bool:
        self.vulkan_available == true && self.vram_mb >= 1024

    me meets_recommended() -> bool:
        self.vulkan_available == true && self.compute_available == true && self.vram_mb >= 4096

    me summary() -> text:
        "gpu vendor=" + self.vendor +
            " vulkan=" + self.vulkan_available.to_text() +
            " vk_ver=" + self.vulkan_version +
            " compute=" + self.compute_available.to_text() +
            " comp_be=" + self.compute_backend +
            " vram_mb=" + self.vram_mb.to_text() +
            " shader=" + self.shader_model +
            " driver=" + self.driver_version

class AudioGameReadiness:
    """Audio readiness descriptor for game compatibility checks."""
    hda_available: bool
    sample_rate: i64
    channels: i64
    latency_ms: i64
    positional_audio: bool
    voice_chat: bool

impl AudioGameReadiness:
    static fn create() -> AudioGameReadiness:
        AudioGameReadiness(
            hda_available: false, sample_rate: 0, channels: 0,
            latency_ms: 0, positional_audio: false, voice_chat: false
        )

    static fn from_hda(rate: i64, ch: i64, lat: i64) -> AudioGameReadiness:
        AudioGameReadiness(
            hda_available: true, sample_rate: rate, channels: ch,
            latency_ms: lat, positional_audio: false, voice_chat: false
        )

    me meets_minimum() -> bool:
        self.hda_available == true && self.sample_rate >= 44100

    me summary() -> text:
        "audio hda=" + self.hda_available.to_text() +
            " rate=" + self.sample_rate.to_text() +
            " ch=" + self.channels.to_text() +
            " lat_ms=" + self.latency_ms.to_text() +
            " positional=" + self.positional_audio.to_text() +
            " voice_chat=" + self.voice_chat.to_text()

class InputGameReadiness:
    """Input device readiness descriptor for game compatibility checks."""
    keyboard_ready: bool
    mouse_ready: bool
    gamepad_ready: bool
    touch_ready: bool
    hotplug_supported: bool
    force_feedback: bool

impl InputGameReadiness:
    static fn create() -> InputGameReadiness:
        InputGameReadiness(
            keyboard_ready: true, mouse_ready: true,
            gamepad_ready: false, touch_ready: false,
            hotplug_supported: false, force_feedback: false
        )

    me device_count() -> i64:
        var count: i64 = 0
        if self.keyboard_ready == true:
            count = count + 1
        if self.mouse_ready == true:
            count = count + 1
        if self.gamepad_ready == true:
            count = count + 1
        if self.touch_ready == true:
            count = count + 1
        count

    me meets_minimum() -> bool:
        self.keyboard_ready == true && self.mouse_ready == true

    me summary() -> text:
        "input kb=" + self.keyboard_ready.to_text() +
            " mouse=" + self.mouse_ready.to_text() +
            " gamepad=" + self.gamepad_ready.to_text() +
            " touch=" + self.touch_ready.to_text() +
            " hotplug=" + self.hotplug_supported.to_text() +
            " ff=" + self.force_feedback.to_text() +
            " devices=" + self.device_count().to_text()

class NetworkGameReadiness:
    """Network readiness descriptor for game compatibility checks."""
    tcp_available: bool
    udp_available: bool
    ipv4_ready: bool
    ipv6_ready: bool
    max_connections: i64
    latency_target_ms: i64

impl NetworkGameReadiness:
    static fn create() -> NetworkGameReadiness:
        NetworkGameReadiness(
            tcp_available: true, udp_available: true,
            ipv4_ready: true, ipv6_ready: false,
            max_connections: 64, latency_target_ms: 100
        )

    me meets_minimum() -> bool:
        self.tcp_available == true && self.udp_available == true && self.ipv4_ready == true

    me summary() -> text:
        "network tcp=" + self.tcp_available.to_text() +
            " udp=" + self.udp_available.to_text() +
            " ipv4=" + self.ipv4_ready.to_text() +
            " ipv6=" + self.ipv6_ready.to_text() +
            " max_conn=" + self.max_connections.to_text() +
            " lat_ms=" + self.latency_target_ms.to_text()

class FsGameReadiness:
    """Filesystem readiness descriptor for game compatibility checks."""
    read_write: bool
    large_file: bool
    case_insensitive_compat: bool
    max_path_bytes: i64
    symlink_support: bool

impl FsGameReadiness:
    static fn create() -> FsGameReadiness:
        FsGameReadiness(
            read_write: true, large_file: true,
            case_insensitive_compat: false,
            max_path_bytes: 4096, symlink_support: true
        )

    me meets_minimum() -> bool:
        self.read_write == true && self.large_file == true

    me summary() -> text:
        "fs rw=" + self.read_write.to_text() +
            " large_file=" + self.large_file.to_text() +
            " ci_compat=" + self.case_insensitive_compat.to_text() +
            " max_path=" + self.max_path_bytes.to_text() +
            " symlinks=" + self.symlink_support.to_text()

class CpuGameReadiness:
    """CPU and SIMD readiness descriptor for game compatibility checks."""
    arch: text
    bits: i64
    core_count: i64
    simd_tier: text
    has_atomic_64: bool
    has_cmpxchg16b: bool

impl CpuGameReadiness:
    static fn create() -> CpuGameReadiness:
        CpuGameReadiness(
            arch: "unknown", bits: 0, core_count: 0,
            simd_tier: "none", has_atomic_64: false, has_cmpxchg16b: false
        )

    static fn x86_64(cores: i64, simd: text) -> CpuGameReadiness:
        CpuGameReadiness(
            arch: "x86_64", bits: 64, core_count: cores,
            simd_tier: simd, has_atomic_64: true, has_cmpxchg16b: true
        )

    static fn aarch64(cores: i64) -> CpuGameReadiness:
        CpuGameReadiness(
            arch: "aarch64", bits: 64, core_count: cores,
            simd_tier: "neon", has_atomic_64: true, has_cmpxchg16b: false
        )

    static fn riscv64(cores: i64, has_rvv: bool) -> CpuGameReadiness:
        var tier = "none"
        if has_rvv == true:
            tier = "rvv"
        CpuGameReadiness(
            arch: "riscv64", bits: 64, core_count: cores,
            simd_tier: tier, has_atomic_64: true, has_cmpxchg16b: false
        )

    me meets_minimum() -> bool:
        self.bits >= 64 && self.core_count >= 2 && self.simd_tier != "none"

    me summary() -> text:
        "cpu arch=" + self.arch +
            " bits=" + self.bits.to_text() +
            " cores=" + self.core_count.to_text() +
            " simd=" + self.simd_tier +
            " atomic64=" + self.has_atomic_64.to_text() +
            " cmpxchg16b=" + self.has_cmpxchg16b.to_text()

class GameDeviceReadinessReport:
    """Aggregate device readiness report across all six subsystems."""
    gpu: GpuGameReadiness
    audio: AudioGameReadiness
    input: InputGameReadiness
    network: NetworkGameReadiness
    fs: FsGameReadiness
    cpu: CpuGameReadiness

impl GameDeviceReadinessReport:
    static fn create() -> GameDeviceReadinessReport:
        GameDeviceReadinessReport(
            gpu: GpuGameReadiness.create(),
            audio: AudioGameReadiness.create(),
            input: InputGameReadiness.create(),
            network: NetworkGameReadiness.create(),
            fs: FsGameReadiness.create(),
            cpu: CpuGameReadiness.create()
        )

    me all_minimum() -> bool:
        (self.gpu.meets_minimum() == true &&
            self.audio.meets_minimum() == true &&
            self.input.meets_minimum() == true &&
            self.network.meets_minimum() == true &&
            self.fs.meets_minimum() == true &&
            self.cpu.meets_minimum() == true)

    me all_recommended() -> bool:
        (self.gpu.meets_recommended() == true &&
            self.audio.meets_minimum() == true &&
            self.input.meets_minimum() == true &&
            self.network.meets_minimum() == true &&
            self.fs.meets_minimum() == true &&
            self.cpu.meets_minimum() == true)

    me ready_count() -> i64:
        var count: i64 = 0
        if self.gpu.meets_minimum() == true:
            count = count + 1
        if self.audio.meets_minimum() == true:
            count = count + 1
        if self.input.meets_minimum() == true:
            count = count + 1
        if self.network.meets_minimum() == true:
            count = count + 1
        if self.fs.meets_minimum() == true:
            count = count + 1
        if self.cpu.meets_minimum() == true:
            count = count + 1
        count

    me report() -> text:
        "=== Game Device Readiness Report ===\n" +
            self.gpu.summary() + "\n" +
            self.audio.summary() + "\n" +
            self.input.summary() + "\n" +
            self.network.summary() + "\n" +
            self.fs.summary() + "\n" +
            self.cpu.summary() + "\n" +
            "ready=" + self.ready_count().to_text() + "/6" +
            " all_min=" + self.all_minimum().to_text() +
            " all_rec=" + self.all_recommended().to_text()
