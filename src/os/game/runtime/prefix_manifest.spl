"""Runtime prefix manifest parser and sandbox policy report.

Handles /games/app_<id>/ SDN layout prefix manifests.
"""

class PrefixManifest:
    app_id: text
    prefix_path: text
    steam_runtime_version: text
    proton_version: text
    wine_prefix: text
    sandbox_policy: text
    is_valid: bool

    static fn create(app: text, path: text) -> PrefixManifest:
        PrefixManifest(
            app_id: app,
            prefix_path: path,
            steam_runtime_version: "",
            proton_version: "",
            wine_prefix: "",
            sandbox_policy: "default",
            is_valid: false
        )

    static fn from_fields(
        app: text, path: text,
        sr_ver: text, proton_ver: text,
        wine_pfx: text, policy: text
    ) -> PrefixManifest:
        PrefixManifest(
            app_id: app,
            prefix_path: path,
            steam_runtime_version: sr_ver,
            proton_version: proton_ver,
            wine_prefix: wine_pfx,
            sandbox_policy: policy,
            is_valid: true
        )

    me has_steam_runtime() -> bool:
        self.steam_runtime_version != ""

    me has_proton() -> bool:
        self.proton_version != ""

    me has_wine_prefix() -> bool:
        self.wine_prefix != ""

    me is_proton_capable() -> bool:
        self.is_valid and self.has_steam_runtime() and self.has_proton() and self.has_wine_prefix()

    me prefix_root() -> text:
        "/games/app_" + self.app_id

    me report() -> text:
        "prefix: app=" + self.app_id +
            " path=" + self.prefix_path +
            " sr=" + self.steam_runtime_version +
            " proton=" + self.proton_version +
            " wine=" + self.wine_prefix +
            " policy=" + self.sandbox_policy +
            " valid=" + self.is_valid.to_text()


class SandboxPolicyReport:
    app_id: text
    policy_name: text
    allow_network: bool
    allow_ipc: bool
    allow_gpu: bool
    allow_audio: bool
    restricted_paths: i64
    sandbox_violations: i64

    static fn create(app: text, policy: text) -> SandboxPolicyReport:
        SandboxPolicyReport(
            app_id: app,
            policy_name: policy,
            allow_network: false,
            allow_ipc: false,
            allow_gpu: false,
            allow_audio: false,
            restricted_paths: 0,
            sandbox_violations: 0
        )

    static fn default_game_policy(app: text) -> SandboxPolicyReport:
        SandboxPolicyReport(
            app_id: app,
            policy_name: "game-default",
            allow_network: true,
            allow_ipc: true,
            allow_gpu: true,
            allow_audio: true,
            restricted_paths: 3,
            sandbox_violations: 0
        )

    me record_violation() -> i64:
        self.sandbox_violations = self.sandbox_violations + 1
        self.sandbox_violations

    me is_clean() -> bool:
        self.sandbox_violations == 0

    me report() -> text:
        "sandbox: app=" + self.app_id +
            " policy=" + self.policy_name +
            " net=" + self.allow_network.to_text() +
            " ipc=" + self.allow_ipc.to_text() +
            " gpu=" + self.allow_gpu.to_text() +
            " audio=" + self.allow_audio.to_text() +
            " restricted_paths=" + self.restricted_paths.to_text() +
            " violations=" + self.sandbox_violations.to_text()


fn parse_prefix_manifest(app_id: text, sr_ver: text, proton_ver: text) -> PrefixManifest:
    val path = "/games/app_" + app_id + "/pfx"
    PrefixManifest.from_fields(app_id, path, sr_ver, proton_ver, path + "/drive_c", "game-default")
