# QEMU evidence normalization for software-breakpoint counters.

use os.baremetal.profile.breakpoint_counter.{breakpoint_architecture_patch_profile}

pub class BreakpointQemuEvidence:
    arch: text
    qemu_command: text
    patched_address: u64
    original_bytes: text
    trap_bytes: text
    hit_count: i64
    trap_latency_us: i64
    restored: bool
    rearmed: bool
    cleanup_complete: bool
    icache_flushed: bool
    sampled_only_reason: text
    valid: bool
    status: text

fn breakpoint_qemu_field(line: text, key: text) -> text:
    val prefix = key + "="
    val parts = line.split(";")
    var i = 0
    while i < parts.len():
        val part = parts[i].trim()
        if part.starts_with(prefix):
            return part[prefix.len():]
        i = i + 1
    ""

fn breakpoint_qemu_bool(value: text) -> bool:
    value == "true" or value == "1" or value == "yes"

fn breakpoint_qemu_i64(value: text) -> i64:
    value.to_i64() ?? 0

fn breakpoint_qemu_u64(value: text) -> u64:
    val parsed = value.to_i64() ?? 0
    if parsed < 0:
        return 0
    parsed as u64

pub fn breakpoint_qemu_evidence_from_line(line: text) -> BreakpointQemuEvidence:
    val arch = breakpoint_qemu_field(line, "arch")
    val profile = breakpoint_architecture_patch_profile(arch)
    val trap_bytes = breakpoint_qemu_field(line, "trap")
    val hit_count = breakpoint_qemu_i64(breakpoint_qemu_field(line, "hits"))
    val restored = breakpoint_qemu_bool(breakpoint_qemu_field(line, "restored"))
    val rearmed = breakpoint_qemu_bool(breakpoint_qemu_field(line, "rearmed"))
    val cleanup = breakpoint_qemu_bool(breakpoint_qemu_field(line, "cleanup"))
    val icache = breakpoint_qemu_bool(breakpoint_qemu_field(line, "icache"))
    var status = "valid"
    if not profile.valid:
        status = "unsupported_arch"
    elif trap_bytes != profile.patch_bytes:
        status = "trap_bytes_mismatch"
    elif hit_count <= 0:
        status = "missing_hits"
    elif not restored:
        status = "not_restored"
    elif not cleanup:
        status = "cleanup_incomplete"
    elif profile.requires_icache_flush and not icache:
        status = "missing_icache_flush"

    BreakpointQemuEvidence(
        arch: arch,
        qemu_command: breakpoint_qemu_field(line, "qemu"),
        patched_address: breakpoint_qemu_u64(breakpoint_qemu_field(line, "address")),
        original_bytes: breakpoint_qemu_field(line, "original"),
        trap_bytes: trap_bytes,
        hit_count: hit_count,
        trap_latency_us: breakpoint_qemu_i64(breakpoint_qemu_field(line, "latency_us")),
        restored: restored,
        rearmed: rearmed,
        cleanup_complete: cleanup,
        icache_flushed: icache,
        sampled_only_reason: breakpoint_qemu_field(line, "sampled"),
        valid: status == "valid",
        status: status
    )
