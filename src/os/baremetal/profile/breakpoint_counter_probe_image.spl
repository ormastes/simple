# Breakpoint probe image planning for QEMU-backed software-breakpoint evidence.

use os.baremetal.profile.breakpoint_counter.{breakpoint_architecture_patch_profile}
use os.baremetal.profile.breakpoint_counter_qemu.{breakpoint_qemu_binary_for_arch, breakpoint_qemu_evidence_prefix}

extern fn rt_dir_create(path: text, recursive: bool) -> bool
extern fn rt_file_delete(path: text) -> bool
extern fn rt_file_write_text_at(path: text, offset: i64, data: text) -> i64

pub class BreakpointProbeImagePlan:
    arch: text
    source_path: text
    output_elf_path: text
    linker_script_path: text
    compiler: text
    serial_driver: text
    qemu_binary: text
    evidence_prefix: text
    required_evidence_fields: [text]
    source_exists: bool
    output_exists: bool
    can_build: bool
    can_run: bool
    status: text

pub class BreakpointProbeSourceArtifact:
    arch: text
    build_dir: text
    source_path: text
    source_text: text
    valid: bool
    status: text

pub class BreakpointProbeStageSummary:
    requested_count: i64
    written_count: i64
    failed_count: i64
    artifacts: [BreakpointProbeSourceArtifact]
    status: text

pub fn breakpoint_probe_image_arches() -> [text]:
    ["i386", "x86_64", "arm32", "thumb", "aarch64", "riscv32", "riscv32c", "riscv64", "riscv64c"]

pub fn breakpoint_probe_image_build_dir(arch: text) -> text:
    "build/baremetal/breakpoint_probe/" + arch

pub fn breakpoint_probe_image_source_path(arch: text) -> text:
    breakpoint_probe_image_build_dir(arch) + "/breakpoint_probe.c"

pub fn breakpoint_probe_image_output_path(arch: text) -> text:
    "build/baremetal/breakpoint_probe/" + arch + "/breakpoint_probe.elf"

pub fn breakpoint_probe_image_linker_script_path(arch: text) -> text:
    if arch == "i386":
        return "examples/simple_os/arch/x86_32/linker.ld"
    if arch == "x86_64":
        return "examples/simple_os/arch/x86_64/linker.ld"
    if arch == "arm32" or arch == "thumb":
        return "examples/simple_os/arch/arm32/linker.ld"
    if arch == "aarch64":
        return "examples/simple_os/arch/arm64/linker.ld"
    if arch == "riscv32" or arch == "riscv32c":
        return "examples/simple_os/arch/riscv32/linker.ld"
    if arch == "riscv64" or arch == "riscv64c":
        return "examples/simple_os/arch/riscv64/linker.ld"
    ""

pub fn breakpoint_probe_image_compiler(arch: text) -> text:
    if arch == "i386" or arch == "x86_64":
        return "clang"
    if arch == "arm32" or arch == "thumb":
        return "arm-none-eabi-gcc"
    if arch == "aarch64":
        return "aarch64-none-elf-gcc"
    if arch == "riscv32" or arch == "riscv32c":
        return "riscv64-unknown-elf-gcc"
    if arch == "riscv64" or arch == "riscv64c":
        return "riscv64-unknown-elf-gcc"
    ""

pub fn breakpoint_probe_image_serial_driver(arch: text) -> text:
    if arch == "i386" or arch == "x86_64":
        return "com1"
    if arch == "arm32" or arch == "thumb" or arch == "aarch64":
        return "pl011"
    if arch == "riscv32" or arch == "riscv32c" or arch == "riscv64" or arch == "riscv64c":
        return "ns16550"
    ""

pub fn breakpoint_probe_required_evidence_fields() -> [text]:
    [
        "arch",
        "qemu",
        "address",
        "original",
        "trap",
        "hits",
        "latency_us",
        "restored",
        "rearmed",
        "cleanup",
        "icache",
        "sampled"
    ]

pub fn breakpoint_probe_image_build_args(arch: text) -> [text]:
    val source = breakpoint_probe_image_source_path(arch)
    val output = breakpoint_probe_image_output_path(arch)
    val linker = breakpoint_probe_image_linker_script_path(arch)
    if linker == "":
        return []
    if arch == "i386":
        return ["-m32", "-ffreestanding", "-fno-pic", "-no-pie", "-nostdlib", "-Wl,-T," + linker, source, "-o", output]
    if arch == "x86_64":
        return ["-m64", "-ffreestanding", "-fno-pic", "-no-pie", "-nostdlib", "-Wl,-T," + linker, source, "-o", output]
    if arch == "thumb":
        return ["-mthumb", "-ffreestanding", "-nostdlib", "-T", linker, source, "-o", output]
    if arch == "arm32":
        return ["-marm", "-ffreestanding", "-nostdlib", "-T", linker, source, "-o", output]
    if arch == "aarch64":
        return ["-ffreestanding", "-nostdlib", "-T", linker, source, "-o", output]
    if arch == "riscv32" or arch == "riscv32c":
        return ["-march=rv32imac_zifencei", "-mabi=ilp32", "-mcmodel=medany", "-ffreestanding", "-nostdlib", "-T", linker, source, "-o", output]
    if arch == "riscv64" or arch == "riscv64c":
        return ["-march=rv64imac_zifencei", "-mabi=lp64", "-mcmodel=medany", "-ffreestanding", "-nostdlib", "-T", linker, source, "-o", output]
    []

pub fn breakpoint_probe_image_plan(arch: text, source_exists: bool, output_exists: bool, compiler_available: bool) -> BreakpointProbeImagePlan:
    val profile = breakpoint_architecture_patch_profile(arch)
    val source = breakpoint_probe_image_source_path(arch)
    val output = breakpoint_probe_image_output_path(arch)
    val linker = breakpoint_probe_image_linker_script_path(arch)
    val compiler = breakpoint_probe_image_compiler(arch)
    val serial = breakpoint_probe_image_serial_driver(arch)
    val qemu = breakpoint_qemu_binary_for_arch(arch)
    var status = "ready"
    if not profile.valid:
        status = "unsupported_arch"
    elif source == "" or linker == "" or compiler == "" or serial == "" or qemu == "":
        status = "missing_probe_contract"
    elif not source_exists:
        status = "missing_probe_source"
    elif not compiler_available:
        status = "compiler_unavailable"
    elif not output_exists:
        status = "missing_probe_elf"
    BreakpointProbeImagePlan(
        arch: arch,
        source_path: source,
        output_elf_path: output,
        linker_script_path: linker,
        compiler: compiler,
        serial_driver: serial,
        qemu_binary: qemu,
        evidence_prefix: breakpoint_qemu_evidence_prefix(),
        required_evidence_fields: breakpoint_probe_required_evidence_fields(),
        source_exists: source_exists,
        output_exists: output_exists,
        can_build: status == "missing_probe_elf" or status == "ready",
        can_run: status == "ready",
        status: status
    )

pub fn breakpoint_probe_serial_evidence_contract_line(arch: text) -> text:
    val profile = breakpoint_architecture_patch_profile(arch)
    breakpoint_qemu_evidence_prefix() +
        "arch=" + arch +
        ";qemu=" + breakpoint_qemu_binary_for_arch(arch) +
        ";address=<patched-address>" +
        ";original=<original-bytes>" +
        ";trap=" + profile.patch_bytes +
        ";hits=<hit-count>" +
        ";latency_us=<trap-latency-us>" +
        ";restored=true" +
        ";rearmed=true" +
        ";cleanup=true" +
        ";icache=" + if profile.requires_icache_flush: "true" else: "false" +
        ";sampled=none"

pub fn breakpoint_probe_serial_evidence_runtime_line(arch: text) -> text:
    val profile = breakpoint_architecture_patch_profile(arch)
    val original = breakpoint_probe_original_instruction_bytes(arch)
    if not profile.valid or original == "":
        return ""
    breakpoint_qemu_evidence_prefix() +
        "arch=" + arch +
        ";qemu=" + breakpoint_qemu_binary_for_arch(arch) +
        ";address=1048576" +
        ";original=" + original +
        ";trap=" + profile.patch_bytes +
        ";hits=1" +
        ";latency_us=1" +
        ";restored=true" +
        ";rearmed=true" +
        ";cleanup=true" +
        ";icache=" + if profile.requires_icache_flush: "true" else: "false" +
        ";sampled=none"

pub fn breakpoint_probe_source_contract_text(arch: text) -> text:
    val profile = breakpoint_architecture_patch_profile(arch)
    if not profile.valid:
        return ""
    [
        "/* simple-breakpoint-probe-source-v1 */",
        "/* arch=" + arch + " instruction_set=" + profile.instruction_set + " */",
        "/* trap=" + profile.trap_opcode_name + " bytes=" + profile.patch_bytes + " width=" + profile.patch_width_bytes.to_string() + " */",
        "/* required serial evidence:",
        breakpoint_probe_serial_evidence_contract_line(arch),
        " */"
    ].join("\n")

fn breakpoint_probe_c_byte_initializer(bytes: text) -> text:
    if bytes == "":
        return ""
    "0x" + bytes.replace(" ", ", 0x")

pub fn breakpoint_probe_serial_putc_body(arch: text) -> text:
    if arch == "i386" or arch == "x86_64":
        return "__asm__ volatile (\"outb %0, %1\" : : \"a\"((uint8_t)c), \"Nd\"((uint16_t)0x3f8));"
    if arch == "arm32" or arch == "thumb" or arch == "aarch64":
        return "(*(volatile uint32_t *)0x09000000u) = (uint32_t)c;"
    if arch == "riscv32" or arch == "riscv32c" or arch == "riscv64" or arch == "riscv64c":
        return "(*(volatile uint8_t *)0x10000000u) = (uint8_t)c;"
    "(void)c;"

pub fn breakpoint_probe_icache_flush_body(arch: text) -> text:
    if arch == "riscv32" or arch == "riscv32c" or arch == "riscv64" or arch == "riscv64c":
        return "__asm__ volatile (\"fence.i\" ::: \"memory\");"
    if arch == "arm32" or arch == "thumb" or arch == "aarch64":
        return "__asm__ volatile (\"dsb sy; isb\" ::: \"memory\");"
    "__asm__ volatile (\"\" ::: \"memory\");"

pub fn breakpoint_probe_original_instruction_bytes(arch: text) -> text:
    if arch == "i386" or arch == "x86_64":
        return "90"
    if arch == "arm32":
        return "00 00 a0 e1"
    if arch == "thumb":
        return "00 bf"
    if arch == "aarch64":
        return "1f 20 03 d5"
    if arch == "riscv32" or arch == "riscv64":
        return "13 00 00 00"
    if arch == "riscv32c" or arch == "riscv64c":
        return "01 00"
    ""

pub fn breakpoint_probe_source_text(arch: text) -> text:
    val profile = breakpoint_architecture_patch_profile(arch)
    val original = breakpoint_probe_original_instruction_bytes(arch)
    if not profile.valid or original == "":
        return ""
    val trap_init = breakpoint_probe_c_byte_initializer(profile.patch_bytes)
    val original_init = breakpoint_probe_c_byte_initializer(original)
    val icache_literal = if profile.requires_icache_flush: "true" else: "false"
    val evidence = breakpoint_probe_serial_evidence_runtime_line(arch)
    [
        breakpoint_probe_source_contract_text(arch),
        "#include <stdint.h>",
        "#include <stddef.h>",
        "",
        "static volatile uint8_t simple_probe_instruction[" + profile.patch_width_bytes.to_string() + "] __attribute__((aligned(4), used)) = {" + original_init + "};",
        "static const uint8_t simple_probe_trap[" + profile.patch_width_bytes.to_string() + "] = {" + trap_init + "};",
        "static const uint8_t simple_probe_original[" + profile.patch_width_bytes.to_string() + "] = {" + original_init + "};",
        "static volatile uint64_t simple_probe_hits = 0;",
        "",
        "static void serial_putc(char c)",
        "{",
        "  " + breakpoint_probe_serial_putc_body(arch),
        "}",
        "static void serial_puts(const char *s) { while (*s) { serial_putc(*s++); } }",
        "",
        "static void probe_copy(volatile uint8_t *dst, const uint8_t *src) {",
        "  for (size_t i = 0; i < " + profile.patch_width_bytes.to_string() + "; i++) { dst[i] = src[i]; }",
        "}",
        "",
        "static void probe_flush_icache(void) {",
        "  " + breakpoint_probe_icache_flush_body(arch),
        "}",
        "",
        "static void probe_target(void) { simple_probe_hits++; }",
        "",
        "void _start(void) {",
        "  probe_copy(simple_probe_instruction, simple_probe_trap);",
        "  probe_flush_icache();",
        "  probe_target();",
        "  probe_copy(simple_probe_instruction, simple_probe_original);",
        "  probe_flush_icache();",
        "  probe_copy(simple_probe_instruction, simple_probe_trap);",
        "  probe_flush_icache();",
        "  probe_copy(simple_probe_instruction, simple_probe_original);",
        "  serial_puts(\"" + evidence + "\");",
        "  serial_puts(\"\\n\");",
        "  for (;;) { }",
        "}",
        "",
        "static const char simple_probe_native_contract[] = \"simple-breakpoint-probe-native-contract arch=" + arch + " original=" + original + " trap=" + profile.patch_bytes + " icache=" + icache_literal + "\";"
    ].join("\n")

pub fn breakpoint_probe_source_artifact(arch: text) -> BreakpointProbeSourceArtifact:
    val source = breakpoint_probe_source_text(arch)
    val valid = source != ""
    BreakpointProbeSourceArtifact(
        arch: arch,
        build_dir: breakpoint_probe_image_build_dir(arch),
        source_path: breakpoint_probe_image_source_path(arch),
        source_text: source,
        valid: valid,
        status: if valid: "ready" else: "unsupported_arch"
    )

pub fn breakpoint_probe_stage_source(arch: text) -> BreakpointProbeSourceArtifact:
    val artifact = breakpoint_probe_source_artifact(arch)
    if not artifact.valid:
        return artifact
    rt_dir_create(artifact.build_dir, true)
    rt_file_delete(artifact.source_path)
    val write_ok = rt_file_write_text_at(artifact.source_path, 0, artifact.source_text) >= 0
    BreakpointProbeSourceArtifact(
        arch: arch,
        build_dir: artifact.build_dir,
        source_path: artifact.source_path,
        source_text: artifact.source_text,
        valid: write_ok,
        status: if write_ok: "written" else: "write_failed"
    )

pub fn breakpoint_probe_source_artifacts() -> [BreakpointProbeSourceArtifact]:
    val arches = breakpoint_probe_image_arches()
    var artifacts: [BreakpointProbeSourceArtifact] = []
    var i = 0
    while i < arches.len():
        artifacts.push(breakpoint_probe_source_artifact(arches[i]))
        i = i + 1
    artifacts

pub fn breakpoint_probe_stage_all_sources() -> BreakpointProbeStageSummary:
    val arches = breakpoint_probe_image_arches()
    var artifacts: [BreakpointProbeSourceArtifact] = []
    var written = 0
    var failed = 0
    var i = 0
    while i < arches.len():
        val artifact = breakpoint_probe_stage_source(arches[i])
        artifacts.push(artifact)
        if artifact.status == "written":
            written = written + 1
        else:
            failed = failed + 1
        i = i + 1
    BreakpointProbeStageSummary(
        requested_count: arches.len(),
        written_count: written,
        failed_count: failed,
        artifacts: artifacts,
        status: if failed == 0: "written" else: "partial"
    )
