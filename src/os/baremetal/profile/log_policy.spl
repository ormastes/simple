# Bare-metal logging policy helpers.
#
# This intentionally avoids environment lookups, heap-heavy parsing, and hosted
# runtime services so boot/debug builds can carry explicit compile/runtime log
# levels through generated code or board configuration.

const BAREMETAL_LOG_TRACE = 0
const BAREMETAL_LOG_DEBUG = 1
const BAREMETAL_LOG_INFO = 2
const BAREMETAL_LOG_WARN = 3
const BAREMETAL_LOG_ERROR = 4
const BAREMETAL_LOG_OFF = 5

struct BaremetalLogPolicy:
    compile_level: i64
    runtime_level: i64
    function_call_aop: bool
    variable_assignment_aop: bool

impl BaremetalLogPolicy:
    static fn default_debug() -> BaremetalLogPolicy:
        BaremetalLogPolicy(
            compile_level: 1,
            runtime_level: 2,
            function_call_aop: false,
            variable_assignment_aop: false
        )

    static fn with_aop(function_calls: bool, variable_assignments: bool) -> BaremetalLogPolicy:
        BaremetalLogPolicy(
            compile_level: 1,
            runtime_level: 1,
            function_call_aop: function_calls,
            variable_assignment_aop: variable_assignments
        )

fn baremetal_compile_log_allows(policy: BaremetalLogPolicy, level: i64) -> bool:
    if policy.compile_level >= 5:
        return false
    level >= policy.compile_level

fn baremetal_runtime_log_allows(policy: BaremetalLogPolicy, level: i64) -> bool:
    if policy.runtime_level >= 5:
        return false
    level >= policy.runtime_level

fn baremetal_log_policy_with_compile_level(policy: BaremetalLogPolicy, level: i64) -> BaremetalLogPolicy:
    BaremetalLogPolicy(
        compile_level: level,
        runtime_level: policy.runtime_level,
        function_call_aop: policy.function_call_aop,
        variable_assignment_aop: policy.variable_assignment_aop
    )

fn baremetal_aop_function_calls_enabled(policy: BaremetalLogPolicy) -> bool:
    policy.function_call_aop and baremetal_compile_log_allows(policy, 1)

fn baremetal_aop_variable_assignments_enabled(policy: BaremetalLogPolicy) -> bool:
    policy.variable_assignment_aop and baremetal_compile_log_allows(policy, 1)
