# Stage generated bare-metal breakpoint probe sources.

use os.baremetal.profile.breakpoint_counter_probe_image.{breakpoint_probe_stage_all_sources}

fn main() -> i64:
    val summary = breakpoint_probe_stage_all_sources()
    print "simple-breakpoint-probe-stage;status=" + summary.status + ";requested=" + summary.requested_count.to_string() + ";written=" + summary.written_count.to_string() + ";failed=" + summary.failed_count.to_string()
    var i = 0
    while i < summary.artifacts.len():
        val artifact = summary.artifacts[i]
        print "simple-breakpoint-probe-source;arch=" + artifact.arch + ";status=" + artifact.status + ";path=" + artifact.source_path
        i = i + 1
    if summary.failed_count == 0:
        return 0
    1
