# ARM software-breakpoint target adapter contracts.

use os.baremetal.profile.breakpoint_counter.{breakpoint_architecture_patch_profile}

pub class BreakpointArmResumePlan:
    arch: text
    exception_pc: u64
    restore_pc: u64
    resume_pc_after_single_step: u64
    patch_width_bytes: i64
    requires_icache_flush: bool
    valid: bool
    reason: text

fn breakpoint_arm_arch_supported(arch: text) -> bool:
    arch == "arm" or arch == "arm32" or arch == "thumb" or arch == "thumb2" or arch == "aarch64"

pub fn breakpoint_arm_resume_plan(arch: text, exception_pc: u64) -> BreakpointArmResumePlan:
    val profile = breakpoint_architecture_patch_profile(arch)
    if not breakpoint_arm_arch_supported(arch) or not profile.valid:
        return BreakpointArmResumePlan(
            arch: arch,
            exception_pc: exception_pc,
            restore_pc: 0,
            resume_pc_after_single_step: 0,
            patch_width_bytes: 0,
            requires_icache_flush: false,
            valid: false,
            reason: "unsupported_arm_arch"
        )
    if exception_pc == 0:
        return BreakpointArmResumePlan(
            arch: arch,
            exception_pc: exception_pc,
            restore_pc: 0,
            resume_pc_after_single_step: 0,
            patch_width_bytes: profile.patch_width_bytes,
            requires_icache_flush: profile.requires_icache_flush,
            valid: false,
            reason: "missing_exception_pc"
        )
    BreakpointArmResumePlan(
        arch: arch,
        exception_pc: exception_pc,
        restore_pc: exception_pc,
        resume_pc_after_single_step: exception_pc + (profile.pc_advance_bytes as u64),
        patch_width_bytes: profile.patch_width_bytes,
        requires_icache_flush: profile.requires_icache_flush,
        valid: true,
        reason: "arm_breakpoint_pc_at_instruction"
    )

pub fn breakpoint_arm_qemu_target(arch: text) -> text:
    if arch == "arm" or arch == "arm32" or arch == "thumb" or arch == "thumb2":
        return "qemu-system-arm"
    if arch == "aarch64":
        return "qemu-system-aarch64"
    ""
