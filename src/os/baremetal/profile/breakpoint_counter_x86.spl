# x86 software-breakpoint target adapter contracts.

use os.baremetal.profile.breakpoint_counter.{breakpoint_architecture_patch_profile}

pub class BreakpointX86ResumePlan:
    arch: text
    reported_pc: u64
    patched_address: u64
    restore_pc: u64
    resume_pc_after_single_step: u64
    trap_width_bytes: i64
    valid: bool
    reason: text

fn breakpoint_x86_arch_supported(arch: text) -> bool:
    arch == "x86" or arch == "i386" or arch == "x86_64"

pub fn breakpoint_x86_resume_plan(arch: text, reported_pc: u64) -> BreakpointX86ResumePlan:
    val profile = breakpoint_architecture_patch_profile(arch)
    if not breakpoint_x86_arch_supported(arch) or not profile.valid:
        return BreakpointX86ResumePlan(
            arch: arch,
            reported_pc: reported_pc,
            patched_address: 0,
            restore_pc: 0,
            resume_pc_after_single_step: 0,
            trap_width_bytes: 0,
            valid: false,
            reason: "unsupported_x86_arch"
        )
    if reported_pc == 0:
        return BreakpointX86ResumePlan(
            arch: arch,
            reported_pc: reported_pc,
            patched_address: 0,
            restore_pc: 0,
            resume_pc_after_single_step: 0,
            trap_width_bytes: profile.patch_width_bytes,
            valid: false,
            reason: "missing_reported_pc"
        )
    val patched = reported_pc - 1
    BreakpointX86ResumePlan(
        arch: arch,
        reported_pc: reported_pc,
        patched_address: patched,
        restore_pc: patched,
        resume_pc_after_single_step: reported_pc,
        trap_width_bytes: profile.patch_width_bytes,
        valid: true,
        reason: "x86_int3_pc_after_trap"
    )

pub fn breakpoint_x86_qemu_target(arch: text) -> text:
    if arch == "x86" or arch == "i386":
        return "qemu-system-i386"
    if arch == "x86_64":
        return "qemu-system-x86_64"
    ""
