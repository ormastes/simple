# Bare-metal software-breakpoint counter helpers.

pub class BreakpointTrapOpcode:
    arch: text
    opcode_hex: text
    width_bytes: i64
    little_endian: bool
    valid: bool
    reason: text

pub class BreakpointPatchRecord:
    address: u64
    arch: text
    original_opcode: text
    trap_opcode: text
    patch_width_bytes: i64
    armed: bool
    valid: bool
    reason: text

pub class BreakpointHitAccounting:
    hit_count: i64
    trap_time_us: i64
    state: text
    fallback_reason: text
    should_disarm: bool

pub class BreakpointTransitionResult:
    restored_opcode: text
    rearmed_opcode: text
    state: text
    rearmed: bool
    sampled_only: bool
    reason: text

pub class BreakpointCleanupLedgerSummary:
    patched_entries: i64
    restored_entries: i64
    pending_entries: i64
    failed_restore_entries: i64
    cleanup_complete: bool
    summary: text

pub class BreakpointMemoryPatchApplication:
    address: u64
    image_base_address: u64
    patch_offset: i64
    old_bytes: [text]
    trap_bytes: [text]
    restored_bytes: [text]
    before_image: [text]
    patched_image: [text]
    restored_image: [text]
    rearmed_image: [text]
    actions: [text]
    icache_flush_required: bool
    icache_flushed: bool
    cleanup_complete: bool
    valid: bool
    reason: text
    cleanup_evidence: text

fn breakpoint_arch_is_four_byte_aligned(address: u64, width_bytes: i64) -> bool:
    if width_bytes == 1:
        return true
    return address % 4 == 0

pub fn breakpoint_trap_opcode_for_arch(arch: text) -> BreakpointTrapOpcode:
    if arch == "riscv32" or arch == "riscv64":
        return BreakpointTrapOpcode(
            arch: arch,
            opcode_hex: "0x00100073",
            width_bytes: 4,
            little_endian: true,
            valid: true,
            reason: "riscv-ebreak"
        )
    if arch == "x86_64":
        return BreakpointTrapOpcode(
            arch: arch,
            opcode_hex: "0xcc",
            width_bytes: 1,
            little_endian: true,
            valid: true,
            reason: "x86-int3"
        )
    if arch == "aarch64":
        return BreakpointTrapOpcode(
            arch: arch,
            opcode_hex: "0xd4200000",
            width_bytes: 4,
            little_endian: true,
            valid: true,
            reason: "aarch64-brk-0"
        )
    return BreakpointTrapOpcode(
        arch: arch,
        opcode_hex: "",
        width_bytes: 0,
        little_endian: true,
        valid: false,
        reason: "unsupported_arch"
    )

pub fn breakpoint_patch_record_construct(address: u64, arch: text, original_opcode: text) -> BreakpointPatchRecord:
    val trap = breakpoint_trap_opcode_for_arch(arch)
    if not trap.valid:
        return BreakpointPatchRecord(
            address: address,
            arch: arch,
            original_opcode: original_opcode,
            trap_opcode: "",
            patch_width_bytes: 0,
            armed: false,
            valid: false,
            reason: trap.reason
        )
    if address == 0:
        return BreakpointPatchRecord(
            address: address,
            arch: arch,
            original_opcode: original_opcode,
            trap_opcode: trap.opcode_hex,
            patch_width_bytes: trap.width_bytes,
            armed: false,
            valid: false,
            reason: "zero_address"
        )
    if not breakpoint_arch_is_four_byte_aligned(address, trap.width_bytes):
        return BreakpointPatchRecord(
            address: address,
            arch: arch,
            original_opcode: original_opcode,
            trap_opcode: trap.opcode_hex,
            patch_width_bytes: trap.width_bytes,
            armed: false,
            valid: false,
            reason: "unaligned_patch_address"
        )
    if original_opcode == "" or original_opcode == trap.opcode_hex:
        return BreakpointPatchRecord(
            address: address,
            arch: arch,
            original_opcode: original_opcode,
            trap_opcode: trap.opcode_hex,
            patch_width_bytes: trap.width_bytes,
            armed: false,
            valid: false,
            reason: "invalid_original_opcode"
        )
    return BreakpointPatchRecord(
        address: address,
        arch: arch,
        original_opcode: original_opcode,
        trap_opcode: trap.opcode_hex,
        patch_width_bytes: trap.width_bytes,
        armed: true,
        valid: true,
        reason: "armed"
    )

pub fn breakpoint_next_state(state: text, event: text) -> text:
    if event == "stop_profile":
        return "removed"
    if event == "over_budget":
        return "sampled_only"
    if state == "sampled_only":
        return "sampled_only"
    if state == "candidate" and event == "arm":
        return "armed"
    if state == "armed" and event == "hit":
        return "counted"
    if state == "counted" and event == "restore":
        return "single_step"
    if state == "single_step" and event == "rearm":
        return "armed"
    if event == "failed_single_step":
        return "sampled_only"
    state

pub fn breakpoint_should_disarm(hit_count: i64, trap_time_us: i64, hit_limit: i64, trap_budget_us: i64, hot_loop: bool) -> bool:
    hot_loop or hit_count > hit_limit or trap_time_us > trap_budget_us

pub fn breakpoint_auto_disarm_state(
    state: text,
    hit_count: i64,
    trap_time_us: i64,
    hit_limit: i64,
    trap_budget_us: i64,
    hot_loop: bool
) -> text:
    if breakpoint_should_disarm(hit_count, trap_time_us, hit_limit, trap_budget_us, hot_loop):
        return breakpoint_next_state(state, "over_budget")
    state

pub fn breakpoint_profile_session_record_valid(
    session_id: text,
    target_name: text,
    started_at_us: i64,
    stopped_at_us: i64,
    armed_breakpoints: i64,
    sampled_only_breakpoints: i64,
    cleanup_complete: bool
) -> bool:
    session_id != "" and
        target_name != "" and
        started_at_us >= 0 and
        stopped_at_us >= started_at_us and
        armed_breakpoints >= 0 and
        sampled_only_breakpoints >= 0 and
        armed_breakpoints + sampled_only_breakpoints > 0 and
        cleanup_complete

pub fn breakpoint_trap_budget_total_us(
    patch_time_us: i64,
    trap_time_us: i64,
    restore_time_us: i64,
    single_step_time_us: i64,
    rearm_time_us: i64
) -> i64:
    patch_time_us + trap_time_us + restore_time_us + single_step_time_us + rearm_time_us

pub fn breakpoint_trap_budget_total_over_budget(
    patch_time_us: i64,
    trap_time_us: i64,
    restore_time_us: i64,
    single_step_time_us: i64,
    rearm_time_us: i64,
    trap_budget_us: i64
) -> bool:
    breakpoint_trap_budget_total_us(
        patch_time_us,
        trap_time_us,
        restore_time_us,
        single_step_time_us,
        rearm_time_us
    ) > trap_budget_us

pub fn breakpoint_sampled_fallback_reason(
    hit_count: i64,
    trap_time_us: i64,
    hit_limit: i64,
    trap_budget_us: i64,
    hot_loop: bool,
    failed_single_step: bool
) -> text:
    if failed_single_step:
        return "failed_single_step"
    if hot_loop:
        return "hot_loop"
    if hit_count > hit_limit:
        return "hit_limit"
    if trap_time_us > trap_budget_us:
        return "trap_budget"
    "none"

pub fn breakpoint_sampled_only_fallback_state(state: text, event: text) -> text:
    if state == "sampled_only":
        return "sampled_only"
    breakpoint_next_state(state, event)

pub fn breakpoint_hit_accounting_update(
    current_hit_count: i64,
    current_trap_time_us: i64,
    hit_trap_time_us: i64,
    hit_limit: i64,
    trap_budget_us: i64,
    hot_loop: bool,
    failed_single_step: bool
) -> BreakpointHitAccounting:
    val next_hits = current_hit_count + 1
    val next_trap_time = current_trap_time_us + hit_trap_time_us
    val reason = breakpoint_sampled_fallback_reason(
        next_hits,
        next_trap_time,
        hit_limit,
        trap_budget_us,
        hot_loop,
        failed_single_step
    )
    val disarm = reason != "none"
    var next_state = "counted"
    if disarm:
        next_state = "sampled_only"
    return BreakpointHitAccounting(
        hit_count: next_hits,
        trap_time_us: next_trap_time,
        state: next_state,
        fallback_reason: reason,
        should_disarm: disarm
    )

pub fn breakpoint_restore_rearm_transition(
    record: BreakpointPatchRecord,
    accounting: BreakpointHitAccounting
) -> BreakpointTransitionResult:
    if not record.valid:
        return BreakpointTransitionResult(
            restored_opcode: record.original_opcode,
            rearmed_opcode: "",
            state: "sampled_only",
            rearmed: false,
            sampled_only: true,
            reason: record.reason
        )
    if accounting.should_disarm:
        return BreakpointTransitionResult(
            restored_opcode: record.original_opcode,
            rearmed_opcode: "",
            state: "sampled_only",
            rearmed: false,
            sampled_only: true,
            reason: accounting.fallback_reason
        )
    return BreakpointTransitionResult(
        restored_opcode: record.original_opcode,
        rearmed_opcode: record.trap_opcode,
        state: "armed",
        rearmed: true,
        sampled_only: false,
        reason: "rearmed"
    )

pub fn breakpoint_cleanup_events() -> [text]:
    ["normal_stop", "panic", "watchdog_timeout", "failed_single_step", "target_reset"]

pub fn breakpoint_cleanup_events_cover(events: [text]) -> bool:
    events.contains("normal_stop") and
        events.contains("panic") and
        events.contains("watchdog_timeout") and
        events.contains("failed_single_step") and
        events.contains("target_reset")

pub fn breakpoint_patch_ledger_valid(
    address: u64,
    original_opcode: text,
    patched_opcode: text,
    restored_opcode: text,
    trap_opcode: text
) -> bool:
    address > 0 and
        original_opcode != "" and
        trap_opcode != "" and
        original_opcode != trap_opcode and
        patched_opcode == trap_opcode and
        restored_opcode == original_opcode

pub fn breakpoint_patch_ledger_cleanup_complete(
    patched_entries: i64,
    restored_entries: i64,
    pending_entries: i64,
    failed_restore_entries: i64
) -> bool:
    patched_entries >= 0 and
        restored_entries >= 0 and
        pending_entries == 0 and
        failed_restore_entries == 0 and
        restored_entries == patched_entries

pub fn breakpoint_cleanup_ledger_summary(
    patched_entries: i64,
    restored_entries: i64,
    failed_restore_entries: i64
) -> BreakpointCleanupLedgerSummary:
    val pending_entries = patched_entries - restored_entries - failed_restore_entries
    val complete = breakpoint_patch_ledger_cleanup_complete(
        patched_entries,
        restored_entries,
        pending_entries,
        failed_restore_entries
    )
    var status = "incomplete"
    if complete:
        status = "complete"
    return BreakpointCleanupLedgerSummary(
        patched_entries: patched_entries,
        restored_entries: restored_entries,
        pending_entries: pending_entries,
        failed_restore_entries: failed_restore_entries,
        cleanup_complete: complete,
        summary: "patched={patched_entries} restored={restored_entries} pending={pending_entries} failed={failed_restore_entries} status={status}"
    )

pub fn breakpoint_supported_trap_opcodes() -> [text]:
    [
        "x86_64:int3",
        "aarch64:brk-imm0",
        "riscv32:ebreak",
        "riscv64:ebreak",
        "riscv32:c.ebreak",
        "riscv64:c.ebreak"
    ]

pub fn breakpoint_trap_patch_bytes(architecture: text, trap_opcode: text) -> text:
    if architecture == "x86_64" and trap_opcode == "int3":
        return "cc"
    if architecture == "aarch64" and trap_opcode == "brk-imm0":
        return "00 00 20 d4"
    if (architecture == "riscv32" or architecture == "riscv64") and trap_opcode == "ebreak":
        return "73 00 10 00"
    if (architecture == "riscv32" or architecture == "riscv64") and trap_opcode == "c.ebreak":
        return "02 90"
    ""

pub fn breakpoint_trap_patch_encoding(architecture: text, trap_opcode: text) -> text:
    val bytes = breakpoint_trap_patch_bytes(architecture, trap_opcode)
    if bytes == "":
        return ""
    "patch-bytes:arch={architecture};trap={trap_opcode};bytes={bytes}"

fn breakpoint_patch_bytes_arch_supported(architecture: text) -> bool:
    architecture == "x86_64" or
        architecture == "aarch64" or
        architecture == "riscv32" or
        architecture == "riscv64"

fn breakpoint_opcode_hex_payload(opcode_hex: text) -> text:
    val normalized = opcode_hex.lower()
    if normalized.starts_with("0x"):
        return normalized.substring(2, normalized.len())
    normalized

pub fn breakpoint_original_opcode_restore_bytes(original_opcode_hex: text) -> text:
    val payload = breakpoint_opcode_hex_payload(original_opcode_hex)
    if payload.len() == 2:
        return payload
    if payload.len() == 4:
        return payload.substring(2, 4) + " " + payload.substring(0, 2)
    if payload.len() == 8:
        return payload.substring(6, 8) + " " + payload.substring(4, 6) + " " + payload.substring(2, 4) + " " + payload.substring(0, 2)
    ""

pub fn breakpoint_restore_original_bytes(architecture: text, original_opcode_bytes: text) -> text:
    if not breakpoint_patch_bytes_arch_supported(architecture) or original_opcode_bytes == "":
        return ""
    "restore-bytes:arch={architecture};bytes={original_opcode_bytes}"

pub fn breakpoint_restore_original_opcode_encoding(architecture: text, original_opcode_hex: text) -> text:
    val bytes = breakpoint_original_opcode_restore_bytes(original_opcode_hex)
    if bytes == "":
        return ""
    breakpoint_restore_original_bytes(architecture, bytes)

pub fn breakpoint_patch_encoding_valid(architecture: text, trap_opcode: text, encoded_bytes: text) -> bool:
    val expected = breakpoint_trap_patch_bytes(architecture, trap_opcode)
    expected != "" and encoded_bytes == expected

pub fn breakpoint_restore_encoding_valid(
    architecture: text,
    original_opcode_bytes: text,
    restore_encoding: text
) -> bool:
    original_opcode_bytes != "" and
        restore_encoding == breakpoint_restore_original_bytes(architecture, original_opcode_bytes)

pub fn breakpoint_patch_action_sequence(rearm: bool, sampled_only: bool) -> [text]:
    if sampled_only:
        return [
            "read_original",
            "write_trap",
            "flush_icache",
            "restore_original",
            "single_step",
            "sampled_only"
        ]
    if rearm:
        return [
            "read_original",
            "write_trap",
            "flush_icache",
            "restore_original",
            "single_step",
            "rearm"
        ]
    [
        "read_original",
        "write_trap",
        "flush_icache",
        "restore_original",
        "single_step"
    ]

pub fn breakpoint_patch_action_sequence_valid(actions: [text], rearm: bool, sampled_only: bool) -> bool:
    actions == breakpoint_patch_action_sequence(rearm, sampled_only)

fn breakpoint_memory_copy(image: [text]) -> [text]:
    var copied: [text] = []
    for byte in image:
        copied.push(byte)
    copied

fn breakpoint_memory_read(image: [text], offset: i64, width_bytes: i64) -> [text]:
    var bytes: [text] = []
    var i = 0
    while i < width_bytes:
        bytes.push(image[offset + i])
        i = i + 1
    bytes

fn breakpoint_memory_write(image: [text], offset: i64, bytes: [text]) -> [text]:
    var patched = breakpoint_memory_copy(image)
    var i = 0
    while i < bytes.len() as i64:
        patched[offset + i] = bytes[i]
        i = i + 1
    patched

fn breakpoint_memory_patch_failure(
    record: BreakpointPatchRecord,
    image_base_address: u64,
    image: [text],
    reason: text
) -> BreakpointMemoryPatchApplication:
    BreakpointMemoryPatchApplication(
        address: record.address,
        image_base_address: image_base_address,
        patch_offset: -1,
        old_bytes: [],
        trap_bytes: [],
        restored_bytes: [],
        before_image: breakpoint_memory_copy(image),
        patched_image: breakpoint_memory_copy(image),
        restored_image: breakpoint_memory_copy(image),
        rearmed_image: breakpoint_memory_copy(image),
        actions: [],
        icache_flush_required: false,
        icache_flushed: false,
        cleanup_complete: false,
        valid: false,
        reason: reason,
        cleanup_evidence: "cleanup:address={record.address};patched=0;restored=0;rearmed=0;status=not_applied;reason={reason}"
    )

pub fn breakpoint_apply_patch_record_to_memory(
    record: BreakpointPatchRecord,
    image_base_address: u64,
    image: [text],
    rearm: bool,
    sampled_only: bool,
    icache_flushed: bool
) -> BreakpointMemoryPatchApplication:
    if not record.valid:
        return breakpoint_memory_patch_failure(record, image_base_address, image, record.reason)
    if record.address < image_base_address:
        return breakpoint_memory_patch_failure(record, image_base_address, image, "address_before_image")

    val patch_offset = (record.address - image_base_address) as i64
    if patch_offset < 0 or patch_offset + record.patch_width_bytes > image.len() as i64:
        return breakpoint_memory_patch_failure(record, image_base_address, image, "patch_out_of_bounds")

    val trap_bytes = breakpoint_original_opcode_restore_bytes(record.trap_opcode).split(" ")
    val expected_old_bytes = breakpoint_original_opcode_restore_bytes(record.original_opcode).split(" ")
    if trap_bytes.len() as i64 != record.patch_width_bytes or expected_old_bytes.len() as i64 != record.patch_width_bytes:
        return breakpoint_memory_patch_failure(record, image_base_address, image, "opcode_width_mismatch")

    val before_image = breakpoint_memory_copy(image)
    val old_bytes = breakpoint_memory_read(before_image, patch_offset, record.patch_width_bytes)
    if old_bytes != expected_old_bytes:
        return breakpoint_memory_patch_failure(record, image_base_address, image, "memory_original_mismatch")

    val patched_image = breakpoint_memory_write(before_image, patch_offset, trap_bytes)
    val restored_image = breakpoint_memory_write(patched_image, patch_offset, old_bytes)
    var final_image = breakpoint_memory_copy(restored_image)
    if rearm and not sampled_only and icache_flushed:
        final_image = breakpoint_memory_write(restored_image, patch_offset, trap_bytes)

    val actions = breakpoint_patch_action_sequence(rearm, sampled_only or not icache_flushed)
    val cleanup_complete = breakpoint_memory_read(restored_image, patch_offset, record.patch_width_bytes) == old_bytes
    var reason = "applied"
    if not icache_flushed:
        reason = "icache_flush_required"
    elif sampled_only:
        reason = "sampled_only_cleanup"
    elif rearm:
        reason = "rearmed"

    BreakpointMemoryPatchApplication(
        address: record.address,
        image_base_address: image_base_address,
        patch_offset: patch_offset,
        old_bytes: old_bytes,
        trap_bytes: trap_bytes,
        restored_bytes: breakpoint_memory_read(restored_image, patch_offset, record.patch_width_bytes),
        before_image: before_image,
        patched_image: patched_image,
        restored_image: restored_image,
        rearmed_image: final_image,
        actions: actions,
        icache_flush_required: true,
        icache_flushed: icache_flushed,
        cleanup_complete: cleanup_complete,
        valid: icache_flushed and cleanup_complete,
        reason: reason,
        cleanup_evidence: "cleanup:address={record.address};offset={patch_offset};old={old_bytes.join(\" \")};trap={trap_bytes.join(\" \")};restored={cleanup_complete};rearmed={rearm and not sampled_only and icache_flushed};icache={icache_flushed};status={reason}"
    )
