# Core NoGC Module - Variant-agnostic, explicit #[no_gc] utilities
# These types work without garbage collection

#[no_gc]
#[variant(any)]
mod core_nogc

export arena.*
export fixed_vec.*
export fixed_string.*
export bump.*

# Re-exported from small_map.spl
export SmallMapEntry, SmallMap, SmallMap4, SmallMap8, SmallMap16

# Re-exported from small_vec.spl
export SmallVec, SmallVec4, SmallVec8, SmallVec16, SmallVec32

# Re-exported from string_view.spl
export StringView
