# Size-unit type aliases and the process-run runtime extern for binary optimization.
use compiler_rust.lib.std.src.tooling.deployment.optimization.*
# Binary Stripping & Optimization
# Reduce binary size for deployment

# reason: stdlib primitive boundary — changing signature breaks all callers and native SFFI

use core.result.{Result, Ok, Err}

type Bytes = i64
type MegaBytes = f64
type KiloBytes = f64

# SFFI for process execution and file operations
@extern("runtime", "rt_process_run")
fn _rt_process_run(cmd_ptr: &u8, cmd_len: u64, args_ptr: &u8, args_len: u64) -> (i32, text, text)

@extern("runtime", "rt_file_size")
