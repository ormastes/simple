# File System Helper Functions
#
# Provides convenience functions for common file operations.

use infra.file_io.{read_file, write_file, create_dir_all, file_exists as infra_file_exists, remove_file, list_dir}
use core.result.{Ok, Err}

# =========================================================================
# Read Operations
# =========================================================================

fn read_text_file(path: text) -> Result<text, text>:
    """Read entire file contents as text."""
    read_file(path)

# =========================================================================
# Write Operations
# =========================================================================

fn write_text_file(path: text, content: text) -> Result<(), text>:
    """Write text content to file."""
    write_file(path, content)

# =========================================================================
# Directory Operations
# =========================================================================

fn ensure_dir(path: text) -> Result<(), text>:
    """Create directory if it doesn't exist."""
    create_dir_all(path)

fn file_exists(path: text) -> bool:
    """Check if file or directory exists."""
    infra_file_exists(path)

fn exist(path: text) -> bool:
    """Check if file or directory exists."""
    file_exists(path)

# =========================================================================
# File Deletion
# =========================================================================

fn delete_file(path: text) -> Result<(), text>:
    """Delete a file."""
    remove_file(path)

# =========================================================================
# Directory Listing
# =========================================================================

fn list_directory(path: text) -> Result<List<text>, text>:
    """List contents of directory."""
    list_dir(path)

fn walk_directory(path: text, patterns: List<text>, exclude_patterns: List<text>) -> List<text>:
    """Recursively walk directory."""
    @extern("runtime", "rt_walk_directory")
    fn _rt_walk_directory(
        root_ptr: &u8,
        root_len: u64,
        include_patterns: &List<text>,
        exclude_patterns: &List<text>
    ) -> List<text>

    return _rt_walk_directory(path.ptr(), path.len(), &patterns, &exclude_patterns)

# =========================================================================
# Exports
# =========================================================================
