# File System Helper Functions
#
# Provides convenience functions for common file operations.

use infra.file_io.{read_file, write_file, create_dir_all, remove_file, list_dir}
use core.result.{Ok, Err}

# =========================================================================
# Read Operations
# =========================================================================

pub fn read_text_file(path: text) -> Result<text, text>:
    """Read entire file contents as text."""
    read_file(path)

# =========================================================================
# Write Operations
# =========================================================================

pub fn write_text_file(path: text, content: text) -> Result<(), text>:
    """Write text content to file."""
    write_file(path, content)

# =========================================================================
# Directory Operations
# =========================================================================

pub fn ensure_dir(path: text) -> Result<(), text>:
    """Create directory if it doesn't exist."""
    create_dir_all(path)

# NOTE: `exists`/`file_exists`/`exist` intentionally do NOT import
# `infra.file_io.file_exists` under its own name. A prior version imported
# it unaliased, which collided with the local `pub fn file_exists` below
# (same name, same module) and made `exists()` call `file_exists()` call
# `exists()` forever -- infinite mutual recursion that stack-overflows the
# interpreter (see doc/08_tracking/bug/interp_app_io_mod_import_stack_overflow_2026-07-17.md).
# Calling the runtime extern directly avoids the name collision entirely.
extern fn rt_file_exists(path: text) -> bool

pub fn exists(path: text) -> bool:
    """Check if file or directory exists."""
    rt_file_exists(path)

pub fn file_exists(path: text) -> bool:
    """Compatibility alias for the exported helper name."""
    rt_file_exists(path)

pub fn exist(path: text) -> bool:
    """Check if file or directory exists."""
    exists(path)

# =========================================================================
# File Deletion
# =========================================================================

pub fn delete_file(path: text) -> Result<(), text>:
    """Delete a file."""
    remove_file(path)

# =========================================================================
# Directory Listing
# =========================================================================

pub fn list_directory(path: text) -> Result<List<text>, text>:
    """List contents of directory."""
    list_dir(path)

pub fn walk_directory(path: text, patterns: List<text>, exclude_patterns: List<text>) -> List<text>:
    """Recursively walk directory."""
    @extern("runtime", "rt_walk_directory")
    fn _rt_walk_directory(
        root_ptr: &u8,
        root_len: u64,
        include_patterns: &List<text>,
        exclude_patterns: &List<text>
    ) -> List<text>

    return _rt_walk_directory(path.ptr(), path.len(), &patterns, &exclude_patterns)

# =========================================================================
# Exports
# =========================================================================
