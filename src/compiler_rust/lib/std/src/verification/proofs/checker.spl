# Proof Checker
#
# Invokes Lean 4 to check proofs and reports results.

use verification.proofs.obligations.{ObligationSet, generate_theorem_stubs}
use std.nogc_sync_mut.io.{file_read_text}

# SFFI for process execution and file operations
@extern("runtime", "rt_process_run")
fn _rt_process_run(cmd_ptr: &u8, cmd_len: u64, args_ptr: &u8, args_len: u64) -> (i32, text, text)

@extern("runtime", "rt_file_write_text")
fn _rt_file_write_text(path_ptr: &u8, path_len: u64, content_ptr: &u8, content_len: u64) -> bool

# Lean invocation result
enum LeanResult:
    Success
    TypeError(message: text)
    ProofError(message: text)
    Timeout
    NotFound

    fn is_success(self) -> bool:
        match self:
            case Success: return true
            case _: return false

    fn to_string(self) -> text:
        match self:
            case Success: return "success"
            case TypeError(m): return "type error: " + m
            case ProofError(m): return "proof error: " + m
            case Timeout: return "timeout"
            case NotFound: return "lean not found"

# Checker configuration
class CheckerConfig:
    lean_path: text
    lake_path: text
    timeout_ms: i32
    project_dir: text

    fn create() -> CheckerConfig:
        return CheckerConfig("lean", "lake", 30000, ".")

    fn with_lean_path(path: text) -> CheckerConfig:
        return CheckerConfig(path, self.lake_path, self.timeout_ms, self.project_dir)

    fn with_timeout(timeout_ms: i32) -> CheckerConfig:
        return CheckerConfig(self.lean_path, self.lake_path, timeout_ms, self.project_dir)

    fn with_project_dir(dir: text) -> CheckerConfig:
        return CheckerConfig(self.lean_path, self.lake_path, self.timeout_ms, dir)

# Check result for a single file
class FileCheckResult:
    file_path: text
    result: LeanResult
    errors: List<text>
    warnings: List<text>

    fn create(file_path: text, result: LeanResult) -> FileCheckResult:
        return FileCheckResult(file_path, result, [], [])

    fn with_error(error: text) -> FileCheckResult:
        val new_errors = self.errors + [error]
        return FileCheckResult(self.file_path, self.result, new_errors, self.warnings)

    fn with_warning(warning: text) -> FileCheckResult:
        val new_warnings = self.warnings + [warning]
        return FileCheckResult(self.file_path, self.result, self.errors, new_warnings)

    # Alias for result field — spec uses .status
    fn status() -> LeanResult:
        self.result

    # Count sorry occurrences in error messages
    fn sorry_count() -> i32:
        var count = 0
        for e in self.errors:
            if e.contains("sorry"):
                count = count + 1
        count

    # Return error message text (first error, or from result)
    fn error_message() -> text:
        match self.result:
            case LeanResult.TypeError(m): m
            case LeanResult.ProofError(m): m
            case _:
                if self.errors.len() > 0:
                    self.errors[0]
                else:
                    ""

# Batch check result
class BatchCheckResult:
    file_results: List<FileCheckResult>
    total_time_ms: i32

    fn create() -> BatchCheckResult:
        return BatchCheckResult([], 0)

    fn add_result(result: FileCheckResult) -> BatchCheckResult:
        val new_results = self.file_results + [result]
        return BatchCheckResult(new_results, self.total_time_ms)

    fn with_time(time_ms: i32) -> BatchCheckResult:
        return BatchCheckResult(self.file_results, time_ms)

    fn success_count() -> i32:
        count = 0
        for r in self.file_results:
            if r.result.is_success():
                count = count + 1
        return count

    fn failure_count() -> i32:
        return len(self.file_results) - self.success_count()

    fn summary() -> text:
        total = len(self.file_results)
        success = self.success_count()
        failed = self.failure_count()
        return "Checked " + str(total) + " files: " + str(success) + " passed, " + str(failed) + " failed (" + str(self.total_time_ms) + "ms)"

# Proof checker
class ProofChecker:
    config: CheckerConfig

    fn create(config: CheckerConfig = CheckerConfig.create()) -> ProofChecker:
        return ProofChecker(config)

    fn check_file(file_path: text) -> FileCheckResult:
        # Invoke Lean via subprocess
        val cmd = self.config.lean_path
        val args = "--run {file_path}"
        val proc_result = _rt_process_run(cmd.ptr(), cmd.len(), args.ptr(), args.len())

        # Guard: if Lean is not installed, proc_result is nil — fall back to static sorry scan
        if proc_result is nil:
            val content = file_read_text(file_path)
            if content.contains("sorry"):
                var fr = FileCheckResult.create(file_path, LeanResult.ProofError("sorry found in proof"))
                fr = fr.with_error("sorry")
                return fr
            return FileCheckResult.create(file_path, LeanResult.NotFound)

        val exit_code = proc_result[0]
        val stdout = proc_result[1]
        val stderr = proc_result[2]

        # Lean not found (exit 127) — fall back to static sorry scan
        if exit_code == 127:
            val content = file_read_text(file_path)
            if content.contains("sorry"):
                var fr = FileCheckResult.create(file_path, LeanResult.ProofError("sorry found in proof"))
                fr = fr.with_error("sorry")
                return fr
            return FileCheckResult.create(file_path, LeanResult.NotFound)

        val result = if exit_code == 0:
            LeanResult.Success
        elif stderr.contains("type mismatch") or stderr.contains("type error"):
            LeanResult.TypeError(stderr)
        elif stderr.contains("failed to prove") or stderr.contains("proof"):
            LeanResult.ProofError(stderr)
        elif stderr.contains("not found"):
            LeanResult.NotFound
        else:
            LeanResult.ProofError(stderr)

        var file_result = FileCheckResult.create(file_path, result)
        if stderr.len() > 0:
            file_result = file_result.with_error(stderr)
        return file_result

    fn check_files(file_paths: List<text>) -> BatchCheckResult:
        result = BatchCheckResult.create()
        for path in file_paths:
            file_result = self.check_file(path)
            result = result.add_result(file_result)
        return result

    fn check_obligations(obligations: ObligationSet) -> BatchCheckResult:
        # Generate theorem file
        content = generate_theorem_stubs(obligations)

        # Write to temp file
        temp_file = "/tmp/proof_obligations_" + obligations.module_name + ".lean"
        _rt_file_write_text(temp_file.ptr(), temp_file.len(), content.ptr(), content.len())

        # Check the file
        return self.check_files([temp_file])

    fn check_verification_dir() -> BatchCheckResult:
        # Check all Lean files in src/verification/
        files = [
            "src/verification/memory_capabilities/src/MemoryCapabilities.lean",
            "src/verification/memory_model_drf/src/MemoryModelDRF.lean",
            "src/verification/type_inference_compile/src/TypeInferenceCompile.lean",
            "src/verification/type_inference_compile/src/Contracts.lean",
            "src/verification/async_compile/src/AsyncCompile.lean",
            "src/verification/gc_manual_borrow/src/GcManualBorrow.lean",
            "src/verification/nogc_compile/src/NogcCompile.lean",
            "src/verification/module_resolution/src/ModuleResolution.lean",
            "src/verification/visibility_export/src/VisibilityExport.lean"
        ]
        return self.check_files(files)

# Status reporting
class ProofStatusReport:
    module_name: text
    obligations: ObligationSet
    check_result: Option<BatchCheckResult>

    fn create(module_name: text, obligations: ObligationSet) -> ProofStatusReport:
        return ProofStatusReport(module_name, obligations, nil)

    fn with_check_result(result: BatchCheckResult) -> ProofStatusReport:
        return ProofStatusReport(self.module_name, self.obligations, result)

    fn report() -> text:
        var lines: List<text> = []
        lines = lines + ["=== Proof Status: " + self.module_name + " ==="]
        lines = lines + [""]
        lines = lines + [self.obligations.summary()]
        lines = lines + [""]

        if self.check_result is not nil:
            lines = lines + [self.check_result.summary()]

        lines = lines + [""]
        lines = lines + ["Obligations by status:"]
        val counts = self.obligations.count_by_status()
        for (status, count) in counts.items():
            lines = lines + ["  " + status + ": " + count.to_text()]

        return lines.join("\n")
