# Lean Code Generation Module
# Generates Lean 4 code from Simple verification models.
#
# This module provides a complete pipeline for:
# - Translating Simple types to Lean structures and inductives
# - Converting Simple functions to Lean definitions
# - Generating verification theorems from contracts
# - Emitting memory safety verification code
# - Running Lean to check proofs
# - Auto-generating scaffolding from @auto_lean annotated types
#
# ## Module Structure
#
# ### Core Modules
# - naming.spl: Identifier conversion (snake_case -> PascalCase/camelCase)
# - types.spl: Type translation (class -> structure, enum -> inductive)
# - expressions.spl: Expression translation to Lean terms
# - contracts.spl: Contract to theorem conversion
# - functions.spl: Function definition generation
# - traits.spl: Trait/impl to class/instance conversion
# - emitter.spl: Low-level Lean syntax emission
# - codegen.spl: Main code generator orchestration
# - memory_safety.spl: Memory safety verification code generation
# - verification_checker.spl: Pre-codegen constraint checking
# - verification_diagnostics.spl: Error codes and diagnostics
# - runner.spl: Lean invocation and proof checking
#
# ### Auto-Generation Modules (Phase 7)
# - structure_gen.spl: Generate Lean structures from Simple classes
# - lookup_gen.spl: Generate lookup functions for registries
# - instantiation_gen.spl: Generate instantiation for generic types
# - beq_gen.spl: Generate BEq instances and reflexivity proofs
# - theorem_gen.spl: Generate determinism and other theorems
# - auto_gen.spl: Integration module for auto-generation
#
# Import submodules directly:
#   import verification.lean.emitter as emitter
#   import verification.lean.types as types
#   import verification.lean.codegen as codegen
#   import verification.lean.naming as naming
#   import verification.lean.expressions as expressions
#   import verification.lean.contracts as contracts
#   import verification.lean.functions as functions
#   import verification.lean.traits as traits
#   import verification.lean.memory_safety as memory_safety
#   import verification.lean.verification_checker as checker
#   import verification.lean.verification_diagnostics as diagnostics
#   import verification.lean.runner as runner
#
# Auto-generation modules (Phase 7):
#   import verification.lean.structure_gen as structure_gen
#   import verification.lean.lookup_gen as lookup_gen
#   import verification.lean.instantiation_gen as instantiation_gen
#   import verification.lean.beq_gen as beq_gen
#   import verification.lean.theorem_gen as theorem_gen
#   import verification.lean.auto_gen as auto_gen

