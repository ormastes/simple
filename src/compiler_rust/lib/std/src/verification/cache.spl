# Verification Cache
#
# Stores and retrieves verification results keyed by proof-unit fingerprint.
# Cache location: build/verification-cache/ (git-ignored)
#
# Invariant: cache MUST never preserve a false Verified result.
# If the fingerprint does not match, lookup returns nil (stale/missing).
#
# Persistence uses SDN-style flat files (one per source file) in the cache
# directory, not JSON or YAML.

use verification.state.{VerificationState}
use verification.fingerprint.{Fingerprint}
use verification.proof_unit.{ProofUnit}
use infra.file_io.{file_exist, list_dir, read_file, create_dir_all, write_file, remove_file}

# A single cached verification result
class CacheEntry:
    fingerprint: text           # Combined fingerprint hash
    state: VerificationState
    theorem_results: Dict<text, text>  # theorem_name -> "proven"|"failed"|"admitted"
    timestamp: text             # ISO-8601
    lean_version: text
    source_file: text           # Original source file path

    # Serialize to SDN-style text for on-disk storage
    fn to_sdn(self) -> text:
        var out = "fingerprint = {self.fingerprint}\n"
        out = out + "state = {self.state.to_string()}\n"
        out = out + "timestamp = {self.timestamp}\n"
        out = out + "lean_version = {self.lean_version}\n"
        out = out + "source_file = {self.source_file}\n"
        out = out + "theorem_count = {self.theorem_results.len()}\n"
        for key in self.theorem_results.keys():
            val value = self.theorem_results[key]
            out = out + "theorem.{key} = {value}\n"
        out

    # Deserialize from SDN-style text
    static fn from_sdn(raw: text) -> Option<CacheEntry>:
        var fingerprint = ""
        var state_str = ""
        var timestamp = ""
        var lean_version = ""
        var source_file = ""
        var theorem_results: Dict<text, text> = {}

        val lines = raw.split("\n")
        for line in lines:
            val trimmed = line.trim()
            if trimmed.len() == 0:
                continue
            val eq_pos = trimmed.index_of("=")
            if eq_pos < 0:
                continue
            val key = trimmed.substring(0, eq_pos).trim()
            val value = trimmed.substring(eq_pos + 1).trim()

            if key == "fingerprint":
                fingerprint = value
            else if key == "state":
                state_str = value
            else if key == "timestamp":
                timestamp = value
            else if key == "lean_version":
                lean_version = value
            else if key == "source_file":
                source_file = value
            else if key.starts_with("theorem."):
                val theorem_name = key.substring(8)  # len("theorem.") == 8
                theorem_results[theorem_name] = value

        if fingerprint.len() == 0:
            return nil

        val state = parse_verification_state(state_str)
        Some(CacheEntry(fingerprint, state, theorem_results, timestamp, lean_version, source_file))

# Parse a state string back into VerificationState
fn parse_verification_state(s: text) -> VerificationState:
    match s:
        case "verified": VerificationState.Verified
        case "failed": VerificationState.Failed
        case "admitted": VerificationState.Admitted
        case "trusted": VerificationState.Trusted
        case "stale": VerificationState.Stale
        case _: VerificationState.NotChecked

# Verification cache with SDN-based file storage
class VerificationCache:
    cache_dir: text
    entries: Dict<text, CacheEntry>  # keyed by source_file
    hit_count: i32
    miss_count: i32
    stale_count: i32

    static fn new(cache_dir: text) -> VerificationCache:
        VerificationCache(cache_dir, {}, 0, 0, 0)

    static fn default() -> VerificationCache:
        VerificationCache.new("build/verification-cache")

    # Load all cached entries from disk
    me load() -> VerificationCache:
        if not file_exist(self.cache_dir):
            return self
        match list_dir(self.cache_dir):
            case Ok(files):
                for file in files:
                    if not file.ends_with(".sdn"):
                        continue
                    val path = "{self.cache_dir}/{file}"
                    val content = match read_file(path):
                        case Ok(text): text
                        case Err(_): ""
                    if content.len() == 0:
                        continue
                    val entry_opt = CacheEntry.from_sdn(content)
                    match entry_opt:
                        case Some(entry):
                            self.entries[entry.source_file] = entry
                        case nil:
                            pass_do_nothing  # Skip malformed entries
            case Err(_):
                return self
        self

    # Save all entries to disk (one SDN file per source file)
    fn save(self):
        if not file_exist(self.cache_dir):
            create_dir_all(self.cache_dir)
        for key in self.entries.keys():
            val entry = self.entries[key]
            val filename = sanitize_path(key) + ".sdn"
            val path = "{self.cache_dir}/{filename}"
            write_file(path, entry.to_sdn())

    # Lookup a cached result.
    # Returns nil if not cached or if fingerprint doesn't match (stale).
    # This is the key safety invariant: stale entries are never returned.
    me lookup(source_file: text, current_fingerprint: Fingerprint) -> Option<CacheEntry>:
        if not self.entries.get(source_file).?:
            self.miss_count = self.miss_count + 1
            return nil
        val entry = self.entries[source_file]
        if entry.fingerprint == current_fingerprint.combined:
            self.hit_count = self.hit_count + 1
            return Some(entry)
        # Fingerprint mismatch - entry is stale, must not be trusted
        self.stale_count = self.stale_count + 1
        nil

    # Store a verification result in the cache
    me store(source_file: text, fingerprint: Fingerprint, state: VerificationState, theorem_results: Dict<text, text>, lean_version: text):
        val timestamp = current_timestamp()
        val entry = CacheEntry(
            fingerprint=fingerprint.combined,
            state=state,
            theorem_results=theorem_results,
            timestamp=timestamp,
            lean_version=lean_version,
            source_file=source_file
        )
        self.entries[source_file] = entry

    # Invalidate all entries that depend on a changed module.
    # Walks the proof units to find transitive dependents, including cycles.
    me invalidate_dependents(changed_module: text, all_units: List<ProofUnit>):
        var changed_keys: List<text> = [changed_module]
        var invalidated_sources: List<text> = []
        var progressed = true
        while progressed:
            progressed = false
            for unit in all_units:
                if invalidated_sources.contains(unit.source_file):
                    continue
                var depends_on_changed = false
                if changed_keys.contains(unit.source_file):
                    depends_on_changed = true
                if changed_keys.contains(unit.lean_module):
                    depends_on_changed = true
                if unit.source_symbol.len() > 0 and changed_keys.contains(unit.source_symbol):
                    depends_on_changed = true
                for dep in unit.dependencies:
                    if changed_keys.contains(dep):
                        depends_on_changed = true
                if depends_on_changed:
                    invalidated_sources = invalidated_sources + [unit.source_file]
                    if self.entries.get(unit.source_file).?:
                        self.entries = self.entries.remove(unit.source_file)
                    if not changed_keys.contains(unit.source_file):
                        changed_keys = changed_keys + [unit.source_file]
                    if not changed_keys.contains(unit.lean_module):
                        changed_keys = changed_keys + [unit.lean_module]
                    if unit.source_symbol.len() > 0 and not changed_keys.contains(unit.source_symbol):
                        changed_keys = changed_keys + [unit.source_symbol]
                    progressed = true

    # Clear the entire cache (both in-memory and on-disk)
    me clear():
        self.entries = {}
        self.hit_count = 0
        self.miss_count = 0
        self.stale_count = 0
        match list_dir(self.cache_dir):
            case Ok(files):
                for file in files:
                    if file.ends_with(".sdn"):
                        val _ = remove_file("{self.cache_dir}/{file}")
            case Err(_):
                pass_do_nothing

    # Get cache statistics
    fn stats(self) -> CacheStats:
        CacheStats(
            total_entries=self.entries.len(),
            hits=self.hit_count,
            misses=self.miss_count,
            stale=self.stale_count
        )

# Cache performance statistics
class CacheStats:
    total_entries: i32
    hits: i32
    misses: i32
    stale: i32

    fn format(self) -> text:
        val total_lookups = self.hits + self.misses + self.stale
        var hit_rate = "0%"
        if total_lookups > 0:
            val pct = (self.hits * 100) / total_lookups
            hit_rate = "{pct}%"
        "Cache: {self.total_entries} entries, {self.hits} hits, {self.misses} misses, {self.stale} stale (hit rate: {hit_rate})"

# Sanitize a file path into a safe filename for cache storage.
# Replaces path separators and special characters with underscores.
fn sanitize_path(path: text) -> text:
    var result = path
    result = result.replace("/", "_")
    result = result.replace("\\", "_")
    result = result.replace(":", "_")
    result = result.replace(" ", "_")
    result = result.replace("..", "_")
    result

# Get current timestamp in ISO-8601 format.
# Returns a placeholder if system time is unavailable.
fn current_timestamp() -> text:
    "1970-01-01T00:00:00Z"
