# Verification Fingerprinting
#
# Computes content hashes for cache invalidation.
# Any change in fingerprint inputs marks a proof unit as Stale.
#
# A fingerprint is computed from:
# 1. Source file content hash
# 2. Generated Lean content hash
# 3. Dependency file hashes (imported proof modules)
# 4. Lean toolchain version string

use io.fs as fs

# Fingerprint for a proof unit
class Fingerprint:
    source_hash: text
    lean_hash: text
    dep_hashes: List<text>
    toolchain_version: text
    combined: text              # Final combined hash

    # Compute a fingerprint from source, lean, dependency files, and toolchain version.
    # Reads file contents and hashes them. Missing files hash as empty string.
    static fn compute(source_file: text, lean_file: text, dep_files: List<text>, toolchain_version: text) -> Fingerprint:
        val source_content = fs.read_text(source_file) ?? ""
        val lean_content = fs.read_text(lean_file) ?? ""
        val source_hash = simple_hash(source_content)
        val lean_hash = simple_hash(lean_content)
        var dep_hashes: List<text> = []
        for dep in dep_files:
            val dep_content = fs.read_text(dep) ?? ""
            dep_hashes = dep_hashes + [simple_hash(dep_content)]
        val combined = simple_hash(source_hash + "|" + lean_hash + "|" + dep_hashes.join("|") + "|" + toolchain_version)
        Fingerprint(source_hash, lean_hash, dep_hashes, toolchain_version, combined)

    # Build a fingerprint from pre-computed hash values (no file I/O).
    # Useful for tests and cache deserialization.
    static fn from_hashes(source_hash: text, lean_hash: text, dep_hashes: List<text>, toolchain_version: text) -> Fingerprint:
        val combined = simple_hash(source_hash + "|" + lean_hash + "|" + dep_hashes.join("|") + "|" + toolchain_version)
        Fingerprint(source_hash, lean_hash, dep_hashes, toolchain_version, combined)

    # Check whether two fingerprints are semantically identical.
    fn matches(self, other: Fingerprint) -> bool:
        self.combined == other.combined

    # Serialize to a flat text representation for SDN storage.
    # Format: source_hash|lean_hash|dep1,dep2,...|toolchain_version|combined
    fn to_text(self) -> text:
        val deps_str = self.dep_hashes.join(",")
        "{self.source_hash}|{self.lean_hash}|{deps_str}|{self.toolchain_version}|{self.combined}"

    # Deserialize from flat text representation.
    static fn from_text(raw: text) -> Option<Fingerprint>:
        val parts = raw.split("|")
        if parts.len() < 5:
            return nil
        val source_hash = parts[0]
        val lean_hash = parts[1]
        val deps_str = parts[2]
        val toolchain_version = parts[3]
        val combined = parts[4]
        var dep_hashes: List<text> = []
        if deps_str.len() > 0:
            dep_hashes = deps_str.split(",")
        Some(Fingerprint(source_hash, lean_hash, dep_hashes, toolchain_version, combined))

# Simple string hash function (FNV-1a inspired).
# Returns a deterministic text representation of the hash value.
export fn simple_hash(input: text) -> text:
    var h: i64 = 14695981039346656037  # FNV offset basis
    for ch in input:
        h = h ^ ch.to_i64()
        h = h * 1099511628211  # FNV prime
    "{h}"  # Convert to string representation
