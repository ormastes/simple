# Generics - Generics/polymorphism verification
# Generates Lean verification for generic type handling

use verification.lean.codegen as codegen

fn regenerate_generics() -> text:
    codegen_ = codegen.LeanCodegen.create("Generics")

    # Block comment
    codegen_ = codegen_.add_block_comment([
        "Generics.lean - Formal model for generic type inference",
        "",
        "This module extends the basic type inference model with:",
        "1. Type variables for polymorphism",
        "2. Generic types with type arguments (List<T>, Map<K,V>)",
        "3. Substitution mechanism",
        "4. Unification with occurs check",
        "5. Type schemes (∀T. τ) for val-polymorphism",
        "6. Instantiation and generalization",
        "",
        "The model follows Algorithm W (Damas-Milner) style inference."
    ])

    codegen_ = codegen_.add_namespace("Generics")
    codegen_ = codegen_.add_section_header("Type Definitions")

    # TyVar abbreviation
    codegen_ = codegen_.add_doc_comment("Type variable identifier")
    codegen_ = codegen_.add_abbrev(codegen.build_abbrev("TyVar", "Nat"))

    # GenericInfo structure
    codegen_ = codegen_.add_doc_comment("Generic type: name with arity (number of type parameters)")
    info = codegen.build_class_with_deriving("GenericInfo", [
        ("name", codegen.make_string_type()),
        ("arity", codegen.make_simple_type("Nat"))
    ], ["Repr", "BEq", "Inhabited"])
    codegen_ = codegen_.add_structure(info)

    codegen_ = codegen_.add_block_comment([
        "## Type Representation",
        "",
        "We use a two-level encoding to handle generic types with arguments:",
        "- Base types (Ty) include primitives, variables, arrows, and generic references",
        "- Generic applications are represented as (GenericInfo, List of argument indices)",
        "",
        "This avoids nested inductive termination issues while still modeling generics."
    ])

    # Ty inductive
    codegen_ = codegen_.add_doc_comment("Types with type variables and generics")
    ty = codegen.build_enum_with_deriving("Ty", [
        ("var", [("v", codegen.make_simple_type("TyVar"))]),
        ("nat", []),
        ("bool", []),
        ("str", []),
        ("arrow", [("a", codegen.make_simple_type("Ty")), ("b", codegen.make_simple_type("Ty"))]),
        ("generic0", [("name", codegen.make_string_type())]),
        ("generic1", [("name", codegen.make_string_type()), ("arg", codegen.make_simple_type("Ty"))]),
        ("generic2", [("name", codegen.make_string_type()), ("arg1", codegen.make_simple_type("Ty")), ("arg2", codegen.make_simple_type("Ty"))])
    ], ["Repr", "BEq", "Inhabited"])
    codegen_ = codegen_.add_inductive(ty)

    # Scheme structure
    codegen_ = codegen_.add_doc_comment("Type scheme: ∀α₁...αₙ. τ (polymorphic type)")
    scheme = codegen.build_class_with_deriving("Scheme", [
        ("vars", codegen.make_list_type(codegen.make_simple_type("TyVar"))),
        ("ty", codegen.make_simple_type("Ty"))
    ], ["Repr", "Inhabited"])
    codegen_ = codegen_.add_structure(scheme)

    codegen_ = codegen_.add_section_header("Substitution")

    # SubstEntry structure
    codegen_ = codegen_.add_doc_comment("Substitution entry")
    entry = codegen.build_class_with_deriving("SubstEntry", [
        ("var", codegen.make_simple_type("TyVar")),
        ("ty", codegen.make_simple_type("Ty"))
    ], ["Repr", "Inhabited"])
    codegen_ = codegen_.add_structure(entry)

    # Subst abbreviation
    codegen_ = codegen_.add_doc_comment("Substitution: mapping from type variables to types")
    codegen_ = codegen_.add_raw_line("def Subst := List SubstEntry")
    codegen_ = codegen_.add_raw_line("  deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    # Substitution functions
    codegen_ = codegen_.add_doc_comment("Empty substitution")
    codegen_ = codegen_.add_raw_line("def emptySubst : Subst := []")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_doc_comment("Lookup in substitution")
    codegen_ = codegen_.add_raw_line("def substLookup (s : Subst) (v : TyVar) : Option Ty :=")
    codegen_ = codegen_.add_raw_line("  match s with")
    codegen_ = codegen_.add_raw_line("  | [] => none")
    codegen_ = codegen_.add_raw_line("  | e . rest => if e.var == v then some e.ty else substLookup rest v")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_doc_comment("Singleton substitution: [α ↦ τ]")
    codegen_ = codegen_.add_raw_line("def singleSubst (v : TyVar) (t : Ty) : Subst := [{{ var := v, ty := t }}]")
    codegen_ = codegen_.add_blank()

    # applySubst function
    codegen_ = codegen_.add_doc_comment("Apply substitution to a type")
    codegen_ = codegen_.add_raw_line("def applySubst (s : Subst) : Ty → Ty")
    codegen_ = codegen_.add_raw_line("  | Ty.var v =>")
    codegen_ = codegen_.add_raw_line("    match substLookup s v with")
    codegen_ = codegen_.add_raw_line("    | some t => t")
    codegen_ = codegen_.add_raw_line("    | none => Ty.var v")
    codegen_ = codegen_.add_raw_line("  | Ty.nat => Ty.nat")
    codegen_ = codegen_.add_raw_line("  | Ty.bool => Ty.bool")
    codegen_ = codegen_.add_raw_line("  | Ty.str => Ty.str")
    codegen_ = codegen_.add_raw_line("  | Ty.arrow a b => Ty.arrow (applySubst s a) (applySubst s b)")
    codegen_ = codegen_.add_raw_line("  | Ty.generic0 name => Ty.generic0 name")
    codegen_ = codegen_.add_raw_line("  | Ty.generic1 name arg => Ty.generic1 name (applySubst s arg)")
    codegen_ = codegen_.add_raw_line("  | Ty.generic2 name arg1 arg2 => Ty.generic2 name (applySubst s arg1) (applySubst s arg2)")
    codegen_ = codegen_.add_blank()

    # Compose substitution functions
    codegen_ = codegen_.add_doc_comment("Append substitutions")
    codegen_ = codegen_.add_raw_line("def appendSubst (s1 s2 : Subst) : Subst :=")
    codegen_ = codegen_.add_raw_line("  match s1 with")
    codegen_ = codegen_.add_raw_line("  | [] => s2")
    codegen_ = codegen_.add_raw_line("  | e . rest => e . appendSubst rest s2")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_doc_comment("Compose two substitutions: (s1 ∘ s2)")
    codegen_ = codegen_.add_raw_line("def composeSubst (s1 s2 : Subst) : Subst :=")
    codegen_ = codegen_.add_raw_line("  val s2' := s2.map (fun e => {{ e with ty := applySubst s1 e.ty }})")
    codegen_ = codegen_.add_raw_line("  appendSubst s2' s1")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_section_header("Free Type Variables")

    # freeVars function
    codegen_ = codegen_.add_doc_comment("Collect free type variables in a type")
    codegen_ = codegen_.add_raw_line("def freeVars : Ty → List TyVar")
    codegen_ = codegen_.add_raw_line("  | Ty.var v => [v]")
    codegen_ = codegen_.add_raw_line("  | Ty.nat => []")
    codegen_ = codegen_.add_raw_line("  | Ty.bool => []")
    codegen_ = codegen_.add_raw_line("  | Ty.str => []")
    codegen_ = codegen_.add_raw_line("  | Ty.arrow a b => freeVars a ++ freeVars b")
    codegen_ = codegen_.add_raw_line("  | Ty.generic0 _ => []")
    codegen_ = codegen_.add_raw_line("  | Ty.generic1 _ arg => freeVars arg")
    codegen_ = codegen_.add_raw_line("  | Ty.generic2 _ arg1 arg2 => freeVars arg1 ++ freeVars arg2")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_doc_comment("Free variables in a scheme (excluding bound vars)")
    codegen_ = codegen_.add_raw_line("def freeVarsScheme (sch : Scheme) : List TyVar :=")
    codegen_ = codegen_.add_raw_line("  (freeVars sch.ty).filter (fun v => !sch.vars.contains v)")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_section_header("Occurs Check")

    codegen_ = codegen_.add_doc_comment("Check if type variable occurs in type (for occurs check)")
    codegen_ = codegen_.add_raw_line("def occurs (v : TyVar) : Ty → bool")
    codegen_ = codegen_.add_raw_line("  | Ty.var v' => v == v'")
    codegen_ = codegen_.add_raw_line("  | Ty.nat => false")
    codegen_ = codegen_.add_raw_line("  | Ty.bool => false")
    codegen_ = codegen_.add_raw_line("  | Ty.str => false")
    codegen_ = codegen_.add_raw_line("  | Ty.arrow a b => occurs v a || occurs v b")
    codegen_ = codegen_.add_raw_line("  | Ty.generic0 _ => false")
    codegen_ = codegen_.add_raw_line("  | Ty.generic1 _ arg => occurs v arg")
    codegen_ = codegen_.add_raw_line("  | Ty.generic2 _ arg1 arg2 => occurs v arg1 || occurs v arg2")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_section_header("Unification")

    # UnifyResult inductive
    codegen_ = codegen_.add_doc_comment("Unification result")
    unify_result = codegen.build_enum_with_deriving("UnifyResult", [
        ("ok", [("s", codegen.make_simple_type("Subst"))]),
        ("occursCheckFail", [("v", codegen.make_simple_type("TyVar")), ("t", codegen.make_simple_type("Ty"))]),
        ("mismatch", [("t1", codegen.make_simple_type("Ty")), ("t2", codegen.make_simple_type("Ty"))])
    ], ["Repr", "Inhabited"])
    codegen_ = codegen_.add_inductive(unify_result)

    # unify function (partial)
    codegen_ = codegen_.add_doc_comment("Unify two types")
    codegen_ = codegen_.add_raw_line("partial def unify (t1 t2 : Ty) : UnifyResult :=")
    codegen_ = codegen_.add_raw_line("  match t1, t2 with")
    codegen_ = codegen_.add_raw_line("  | Ty.var v1, Ty.var v2 =>")
    codegen_ = codegen_.add_raw_line("    if v1 == v2 then UnifyResult.ok emptySubst")
    codegen_ = codegen_.add_raw_line("    else UnifyResult.ok (singleSubst v1 (Ty.var v2))")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Ty.var v, t =>")
    codegen_ = codegen_.add_raw_line("    if occurs v t then UnifyResult.occursCheckFail v t")
    codegen_ = codegen_.add_raw_line("    else UnifyResult.ok (singleSubst v t)")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | t, Ty.var v =>")
    codegen_ = codegen_.add_raw_line("    if occurs v t then UnifyResult.occursCheckFail v t")
    codegen_ = codegen_.add_raw_line("    else UnifyResult.ok (singleSubst v t)")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Ty.nat, Ty.nat => UnifyResult.ok emptySubst")
    codegen_ = codegen_.add_raw_line("  | Ty.bool, Ty.bool => UnifyResult.ok emptySubst")
    codegen_ = codegen_.add_raw_line("  | Ty.str, Ty.str => UnifyResult.ok emptySubst")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Ty.arrow a1 b1, Ty.arrow a2 b2 =>")
    codegen_ = codegen_.add_raw_line("    match unify a1 a2 with")
    codegen_ = codegen_.add_raw_line("    | UnifyResult.ok s1 =>")
    codegen_ = codegen_.add_raw_line("      match unify (applySubst s1 b1) (applySubst s1 b2) with")
    codegen_ = codegen_.add_raw_line("      | UnifyResult.ok s2 => UnifyResult.ok (composeSubst s2 s1)")
    codegen_ = codegen_.add_raw_line("      | err => err")
    codegen_ = codegen_.add_raw_line("    | err => err")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Ty.generic0 n1, Ty.generic0 n2 =>")
    codegen_ = codegen_.add_raw_line("    if n1 == n2 then UnifyResult.ok emptySubst")
    codegen_ = codegen_.add_raw_line("    else UnifyResult.mismatch t1 t2")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Ty.generic1 n1 arg1, Ty.generic1 n2 arg2 =>")
    codegen_ = codegen_.add_raw_line("    if n1 != n2 then UnifyResult.mismatch t1 t2")
    codegen_ = codegen_.add_raw_line("    else unify arg1 arg2")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Ty.generic2 n1 a1 b1, Ty.generic2 n2 a2 b2 =>")
    codegen_ = codegen_.add_raw_line("    if n1 != n2 then UnifyResult.mismatch t1 t2")
    codegen_ = codegen_.add_raw_line("    else")
    codegen_ = codegen_.add_raw_line("      match unify a1 a2 with")
    codegen_ = codegen_.add_raw_line("      | UnifyResult.ok s1 =>")
    codegen_ = codegen_.add_raw_line("        match unify (applySubst s1 b1) (applySubst s1 b2) with")
    codegen_ = codegen_.add_raw_line("        | UnifyResult.ok s2 => UnifyResult.ok (composeSubst s2 s1)")
    codegen_ = codegen_.add_raw_line("        | err => err")
    codegen_ = codegen_.add_raw_line("      | err => err")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | _, _ => UnifyResult.mismatch t1 t2")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_section_header("Instantiation and Generalization")

    # FreshState structure
    codegen_ = codegen_.add_doc_comment("Fresh variable counter (for generating new type variables)")
    fresh_state = codegen.build_class_with_deriving("FreshState", [
        ("next", codegen.make_simple_type("TyVar"))
    ], ["Repr", "Inhabited"])
    codegen_ = codegen_.add_structure(fresh_state)

    codegen_ = codegen_.add_raw_line("def freshVar (st : FreshState) : (TyVar × FreshState) :=")
    codegen_ = codegen_.add_raw_line("  (st.next, {{ next := st.next + 1 }})")
    codegen_ = codegen_.add_blank()

    # instantiate function
    codegen_ = codegen_.add_doc_comment("Instantiate a scheme with fresh type variables")
    codegen_ = codegen_.add_raw_line("def instantiate (sch : Scheme) (st : FreshState) : (Ty × FreshState) :=")
    codegen_ = codegen_.add_raw_line("  val (freshVars, st') := sch.vars.foldl")
    codegen_ = codegen_.add_raw_line("    (fun (acc, s) _ =>")
    codegen_ = codegen_.add_raw_line("      val (v, s') := freshVar s")
    codegen_ = codegen_.add_raw_line("      (acc ++ [v], s'))")
    codegen_ = codegen_.add_raw_line("    ([], st)")
    codegen_ = codegen_.add_raw_line("  val subst : Subst := List.zipWith (fun old new => {{ var := old, ty := Ty.var new }}) sch.vars freshVars")
    codegen_ = codegen_.add_raw_line("  (applySubst subst sch.ty, st')")
    codegen_ = codegen_.add_blank()

    # generalize function
    codegen_ = codegen_.add_doc_comment("Generalize a type over free variables not in environment")
    codegen_ = codegen_.add_raw_line("def generalize (envFreeVars : List TyVar) (t : Ty) : Scheme :=")
    codegen_ = codegen_.add_raw_line("  val tyFree := freeVars t")
    codegen_ = codegen_.add_raw_line("  val toGeneralize := tyFree.filter (fun v => !envFreeVars.contains v)")
    codegen_ = codegen_.add_raw_line("  {{ vars := toGeneralize.eraseDups, ty := t }}")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_section_header("Type Environment")

    # EnvEntry structure
    codegen_ = codegen_.add_doc_comment("Type environment entry")
    env_entry = codegen.build_class_with_deriving("EnvEntry", [
        ("name", codegen.make_string_type()),
        ("scheme", codegen.make_simple_type("Scheme"))
    ], ["Repr", "Inhabited"])
    codegen_ = codegen_.add_structure(env_entry)

    codegen_ = codegen_.add_doc_comment("Type environment: maps variable names to type schemes")
    codegen_ = codegen_.add_raw_line("def TypeEnv := List EnvEntry")
    codegen_ = codegen_.add_raw_line("  deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def lookupEnv (env : TypeEnv) (name : text) : Option Scheme :=")
    codegen_ = codegen_.add_raw_line("  match env with")
    codegen_ = codegen_.add_raw_line("  | [] => none")
    codegen_ = codegen_.add_raw_line("  | e . rest => if e.name == name then some e.scheme else lookupEnv rest name")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def extendEnv (env : TypeEnv) (name : text) (sch : Scheme) : TypeEnv :=")
    codegen_ = codegen_.add_raw_line("  {{ name := name, scheme := sch }} . env")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_doc_comment("Free variables in environment")
    codegen_ = codegen_.add_raw_line("def freeVarsEnv (env : TypeEnv) : List TyVar :=")
    codegen_ = codegen_.add_raw_line("  env.foldl (fun acc e => acc ++ freeVarsScheme e.scheme) []")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_section_header("Expressions")

    # Expr inductive
    expr = codegen.build_enum_with_deriving("Expr", [
        ("var", [("name", codegen.make_string_type())]),
        ("litNat", [("n", codegen.make_simple_type("Nat"))]),
        ("litBool", [("b", codegen.make_bool_type())]),
        ("litStr", [("s", codegen.make_string_type())]),
        ("lam", [("param", codegen.make_string_type()), ("body", codegen.make_simple_type("Expr"))]),
        ("app", [("", codegen.make_simple_type("Expr")), ("x", codegen.make_simple_type("Expr"))]),
        ("letIn", [("name", codegen.make_string_type()), ("value", codegen.make_simple_type("Expr")), ("body", codegen.make_simple_type("Expr"))]),
        ("ifElse", [("cond", codegen.make_simple_type("Expr")), ("thenE", codegen.make_simple_type("Expr")), ("elseE", codegen.make_simple_type("Expr"))]),
        ("mkGeneric1", [("name", codegen.make_string_type()), ("arg", codegen.make_simple_type("Expr"))]),
        ("mkGeneric2", [("name", codegen.make_string_type()), ("arg1", codegen.make_simple_type("Expr")), ("arg2", codegen.make_simple_type("Expr"))])
    ], ["Repr", "Inhabited"])
    codegen_ = codegen_.add_inductive(expr)

    codegen_ = codegen_.add_section_header("Type Inference (Algorithm W style)")

    # InferResult inductive
    codegen_ = codegen_.add_doc_comment("Inference result")
    infer_result = codegen.build_enum_with_deriving("InferResult", [
        ("ok", [("ty", codegen.make_simple_type("Ty")), ("subst", codegen.make_simple_type("Subst")), ("state", codegen.make_simple_type("FreshState"))]),
        ("error", [("msg", codegen.make_string_type())])
    ], ["Repr", "Inhabited"])
    codegen_ = codegen_.add_inductive(infer_result)

    # applySubstEnv function
    codegen_ = codegen_.add_doc_comment("Apply substitution to environment")
    codegen_ = codegen_.add_raw_line("def applySubstEnv (s : Subst) (env : TypeEnv) : TypeEnv :=")
    codegen_ = codegen_.add_raw_line("  env.map (fun e => {{ e with scheme := {{ e.scheme with ty := applySubst s e.scheme.ty }} }})")
    codegen_ = codegen_.add_blank()

    # The infer function is very long - emit it as raw lines
    codegen_ = codegen_.add_doc_comment("Infer type of expression")
    codegen_ = codegen_.add_raw_line("def infer (env : TypeEnv) (expr : Expr) (st : FreshState) : InferResult :=")
    codegen_ = codegen_.add_raw_line("  match expr with")
    codegen_ = codegen_.add_raw_line("  | Expr.var name =>")
    codegen_ = codegen_.add_raw_line("    match lookupEnv env name with")
    codegen_ = codegen_.add_raw_line("    | some sch =>")
    codegen_ = codegen_.add_raw_line("      val (ty, st') := instantiate sch st")
    codegen_ = codegen_.add_raw_line("      InferResult.ok ty emptySubst st'")
    codegen_ = codegen_.add_raw_line("    | none => InferResult.error s!\"Undefined variable: {{name}}\"")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Expr.litNat _ => InferResult.ok Ty.nat emptySubst st")
    codegen_ = codegen_.add_raw_line("  | Expr.litBool _ => InferResult.ok Ty.bool emptySubst st")
    codegen_ = codegen_.add_raw_line("  | Expr.litStr _ => InferResult.ok Ty.str emptySubst st")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Expr.lam param body =>")
    codegen_ = codegen_.add_raw_line("    val (paramVar, st') := freshVar st")
    codegen_ = codegen_.add_raw_line("    val paramTy := Ty.var paramVar")
    codegen_ = codegen_.add_raw_line("    val paramSch : Scheme := {{ vars := [], ty := paramTy }}")
    codegen_ = codegen_.add_raw_line("    val env' := extendEnv env param paramSch")
    codegen_ = codegen_.add_raw_line("    match infer env' body st' with")
    codegen_ = codegen_.add_raw_line("    | InferResult.ok bodyTy s st'' =>")
    codegen_ = codegen_.add_raw_line("      val resultTy := Ty.arrow (applySubst s paramTy) bodyTy")
    codegen_ = codegen_.add_raw_line("      InferResult.ok resultTy s st''")
    codegen_ = codegen_.add_raw_line("    | err => err")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Expr.app f x =>")
    codegen_ = codegen_.add_raw_line("    match infer env f st with")
    codegen_ = codegen_.add_raw_line("    | InferResult.ok fTy s1 st1 =>")
    codegen_ = codegen_.add_raw_line("      val env' := applySubstEnv s1 env")
    codegen_ = codegen_.add_raw_line("      match infer env' x st1 with")
    codegen_ = codegen_.add_raw_line("      | InferResult.ok xTy s2 st2 =>")
    codegen_ = codegen_.add_raw_line("        val (retVar, st3) := freshVar st2")
    codegen_ = codegen_.add_raw_line("        val retTy := Ty.var retVar")
    codegen_ = codegen_.add_raw_line("        val fTy' := applySubst s2 fTy")
    codegen_ = codegen_.add_raw_line("        match unify fTy' (Ty.arrow xTy retTy) with")
    codegen_ = codegen_.add_raw_line("        | UnifyResult.ok s3 =>")
    codegen_ = codegen_.add_raw_line("          val finalSubst := composeSubst s3 (composeSubst s2 s1)")
    codegen_ = codegen_.add_raw_line("          InferResult.ok (applySubst s3 retTy) finalSubst st3")
    codegen_ = codegen_.add_raw_line("        | UnifyResult.occursCheckFail v t =>")
    codegen_ = codegen_.add_raw_line("          InferResult.error s!\"Occurs check failed: {{v}} in {{repr t}}\"")
    codegen_ = codegen_.add_raw_line("        | UnifyResult.mismatch t1 t2 =>")
    codegen_ = codegen_.add_raw_line("          InferResult.error s!\"Type mismatch: {{repr t1}} vs {{repr t2}}\"")
    codegen_ = codegen_.add_raw_line("      | err => err")
    codegen_ = codegen_.add_raw_line("    | err => err")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Expr.letIn name value body =>")
    codegen_ = codegen_.add_raw_line("    match infer env value st with")
    codegen_ = codegen_.add_raw_line("    | InferResult.ok valueTy s1 st1 =>")
    codegen_ = codegen_.add_raw_line("      val env' := applySubstEnv s1 env")
    codegen_ = codegen_.add_raw_line("      val valueTy' := applySubst s1 valueTy")
    codegen_ = codegen_.add_raw_line("      val sch := generalize (freeVarsEnv env') valueTy'")
    codegen_ = codegen_.add_raw_line("      val env'' := extendEnv env' name sch")
    codegen_ = codegen_.add_raw_line("      match infer env'' body st1 with")
    codegen_ = codegen_.add_raw_line("      | InferResult.ok bodyTy s2 st2 =>")
    codegen_ = codegen_.add_raw_line("        InferResult.ok bodyTy (composeSubst s2 s1) st2")
    codegen_ = codegen_.add_raw_line("      | err => err")
    codegen_ = codegen_.add_raw_line("    | err => err")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Expr.ifElse cond thenE elseE =>")
    codegen_ = codegen_.add_raw_line("    match infer env cond st with")
    codegen_ = codegen_.add_raw_line("    | InferResult.ok condTy s1 st1 =>")
    codegen_ = codegen_.add_raw_line("      match unify condTy Ty.bool with")
    codegen_ = codegen_.add_raw_line("      | UnifyResult.ok s1' =>")
    codegen_ = codegen_.add_raw_line("        val s1'' := composeSubst s1' s1")
    codegen_ = codegen_.add_raw_line("        val env' := applySubstEnv s1'' env")
    codegen_ = codegen_.add_raw_line("        match infer env' thenE st1 with")
    codegen_ = codegen_.add_raw_line("        | InferResult.ok thenTy s2 st2 =>")
    codegen_ = codegen_.add_raw_line("          val env'' := applySubstEnv s2 env'")
    codegen_ = codegen_.add_raw_line("          match infer env'' elseE st2 with")
    codegen_ = codegen_.add_raw_line("          | InferResult.ok elseTy s3 st3 =>")
    codegen_ = codegen_.add_raw_line("            val thenTy' := applySubst s3 thenTy")
    codegen_ = codegen_.add_raw_line("            match unify thenTy' elseTy with")
    codegen_ = codegen_.add_raw_line("            | UnifyResult.ok s4 =>")
    codegen_ = codegen_.add_raw_line("              val finalSubst := composeSubst s4 (composeSubst s3 (composeSubst s2 s1''))")
    codegen_ = codegen_.add_raw_line("              InferResult.ok (applySubst s4 elseTy) finalSubst st3")
    codegen_ = codegen_.add_raw_line("            | UnifyResult.mismatch t1 t2 =>")
    codegen_ = codegen_.add_raw_line("              InferResult.error s!\"Branch type mismatch: {{repr t1}} vs {{repr t2}}\"")
    codegen_ = codegen_.add_raw_line("            | UnifyResult.occursCheckFail v t =>")
    codegen_ = codegen_.add_raw_line("              InferResult.error s!\"Occurs check failed: {{v}} in {{repr t}}\"")
    codegen_ = codegen_.add_raw_line("          | err => err")
    codegen_ = codegen_.add_raw_line("        | err => err")
    codegen_ = codegen_.add_raw_line("      | UnifyResult.mismatch _ _ =>")
    codegen_ = codegen_.add_raw_line("        InferResult.error \"Condition must be bool\"")
    codegen_ = codegen_.add_raw_line("      | UnifyResult.occursCheckFail v t =>")
    codegen_ = codegen_.add_raw_line("        InferResult.error s!\"Occurs check failed: {{v}} in {{repr t}}\"")
    codegen_ = codegen_.add_raw_line("    | err => err")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Expr.mkGeneric1 name arg =>")
    codegen_ = codegen_.add_raw_line("    match infer env arg st with")
    codegen_ = codegen_.add_raw_line("    | InferResult.ok argTy s st' =>")
    codegen_ = codegen_.add_raw_line("      InferResult.ok (Ty.generic1 name argTy) s st'")
    codegen_ = codegen_.add_raw_line("    | err => err")
    codegen_ = codegen_.add_raw_line("")
    codegen_ = codegen_.add_raw_line("  | Expr.mkGeneric2 name arg1 arg2 =>")
    codegen_ = codegen_.add_raw_line("    match infer env arg1 st with")
    codegen_ = codegen_.add_raw_line("    | InferResult.ok arg1Ty s1 st1 =>")
    codegen_ = codegen_.add_raw_line("      val env' := applySubstEnv s1 env")
    codegen_ = codegen_.add_raw_line("      match infer env' arg2 st1 with")
    codegen_ = codegen_.add_raw_line("      | InferResult.ok arg2Ty s2 st2 =>")
    codegen_ = codegen_.add_raw_line("        val arg1Ty' := applySubst s2 arg1Ty")
    codegen_ = codegen_.add_raw_line("        val finalSubst := composeSubst s2 s1")
    codegen_ = codegen_.add_raw_line("        InferResult.ok (Ty.generic2 name arg1Ty' arg2Ty) finalSubst st2")
    codegen_ = codegen_.add_raw_line("      | err => err")
    codegen_ = codegen_.add_raw_line("    | err => err")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_section_header("Soundness Theorems")

    # Soundness theorems with full proofs
    codegen_ = codegen_.add_doc_comment("Substitution preserves type structure for primitives")
    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "applySubst_nat",
        [("s", "Subst")],
        "applySubst s Ty.nat = Ty.nat",
        "simp only [applySubst]"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "applySubst_bool",
        [("s", "Subst")],
        "applySubst s Ty.bool = Ty.bool",
        "simp only [applySubst]"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "applySubst_str",
        [("s", "Subst")],
        "applySubst s Ty.str = Ty.str",
        "simp only [applySubst]"
    ))

    codegen_ = codegen_.add_doc_comment("Empty substitution is identity")
    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "emptySubst_identity",
        [("t", "Ty")],
        "applySubst emptySubst t = t",
        "cases t with\n| var v => simp [applySubst, emptySubst, substLookup]\n| nat => simp [applySubst]\n| bool => simp [applySubst]\n| str => simp [applySubst]\n| arrow a b =>\n  simp only [applySubst]\n  rw [emptySubst_identity a, emptySubst_identity b]\n| generic0 name => simp [applySubst]\n| generic1 name arg =>\n  simp only [applySubst]\n  rw [emptySubst_identity arg]\n| generic2 name arg1 arg2 =>\n  simp only [applySubst]\n  rw [emptySubst_identity arg1, emptySubst_identity arg2]"
    ))

    codegen_ = codegen_.add_doc_comment("Occurs check prevents infinite types")
    codegen_ = codegen_.add_theorem(codegen.build_theorem("occurs_nat", [("v", "TyVar")], "occurs v Ty.nat = false", "simp [occurs]"))
    codegen_ = codegen_.add_theorem(codegen.build_theorem("occurs_bool", [("v", "TyVar")], "occurs v Ty.bool = false", "simp [occurs]"))
    codegen_ = codegen_.add_theorem(codegen.build_theorem("occurs_str", [("v", "TyVar")], "occurs v Ty.str = false", "simp [occurs]"))
    codegen_ = codegen_.add_theorem(codegen.build_theorem("occurs_var_same", [("v", "TyVar")], "occurs v (Ty.var v) = true", "simp [occurs]"))

    codegen_ = codegen_.add_doc_comment("Generic1 occurs check propagates to argument")
    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "occurs_generic1",
        [("v", "TyVar"), ("name", "text"), ("arg", "Ty")],
        "occurs v (Ty.generic1 name arg) = occurs v arg",
        "simp [occurs]"
    ))

    codegen_ = codegen_.add_doc_comment("Generic2 occurs check propagates to both arguments")
    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "occurs_generic2",
        [("v", "TyVar"), ("name", "text"), ("arg1", "Ty"), ("arg2", "Ty")],
        "occurs v (Ty.generic2 name arg1 arg2) = (occurs v arg1 || occurs v arg2)",
        "simp [occurs]"
    ))

    codegen_ = codegen_.add_doc_comment("Type inference is deterministic")
    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "infer_deterministic",
        [("env", "TypeEnv"), ("e", "Expr"), ("st", "FreshState"), ("t1", "Ty"), ("t2", "Ty"), ("s1", "Subst"), ("s2", "Subst"), ("st1", "FreshState"), ("st2", "FreshState")],
        "infer env e st = InferResult.ok t1 s1 st1 →\n    infer env e st = InferResult.ok t2 s2 st2 →\n    t1 = t2 ∧ s1 = s2 ∧ st1 = st2",
        "intro h1 h2\nhave : InferResult.ok t1 s1 st1 = InferResult.ok t2 s2 st2 := by\n  simpa [h1] using h2\ncases this\nexact ⟨rfl, rfl, rfl⟩"
    ))

    codegen_ = codegen_.add_doc_comment("Unification is sound: if unify succeeds, applying the substitution makes types equal")
    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "unify_sound",
        [("t1", "Ty"), ("t2", "Ty"), ("s", "Subst")],
        "unify t1 t2 = UnifyResult.ok s →\n    applySubst s t1 = applySubst s t2",
        "sorry  -- Main unification correctness theorem"
    ))

    codegen_ = codegen_.add_doc_comment("Principal type property (informal statement)")
    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "principal_type_informal",
        [("_env", "TypeEnv"), ("_e", "Expr"), ("_st", "FreshState")],
        "True",
        "trivial"
    ))

    codegen_ = codegen_.add_section_header("Example Generic Types")

    # Example type constructors
    codegen_ = codegen_.add_doc_comment("Option<T> type constructor")
    codegen_ = codegen_.add_raw_line("def optionTy (arg : Ty) : Ty := Ty.generic1 \"Option\" arg")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_doc_comment("List<T> type constructor")
    codegen_ = codegen_.add_raw_line("def listTy (arg : Ty) : Ty := Ty.generic1 \"List\" arg")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_doc_comment("Map<K,V> type constructor")
    codegen_ = codegen_.add_raw_line("def mapTy (key value : Ty) : Ty := Ty.generic2 \"Map\" key value")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_doc_comment("Either<A,B> type constructor")
    codegen_ = codegen_.add_raw_line("def eitherTy (left right : Ty) : Ty := Ty.generic2 \"Either\" left right")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_doc_comment("Result<T,E> type constructor")
    codegen_ = codegen_.add_raw_line("def resultTy (ok err : Ty) : Ty := Ty.generic2 \"Result\" ok err")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.end_namespace("Generics")

    return codegen_.emit()


