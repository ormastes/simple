# Generates Lean verification for generic type handling

use verification.lean.codegen as codegen

fn regenerate_generics() -> text:
    var codegen_ = codegen.LeanCodegen.create("Generics")

    codegen_ = codegen_.add_block_comment([
        "Generics.lean - Reduced formal model for generic type inference",
        "",
        "This generator emits a small valid Lean model for polymorphic types,",
        "substitution, simple schemes, and environment operations."
    ])
    codegen_ = codegen_.add_namespace("Generics")

    codegen_ = codegen_.add_raw_line("abbrev TyVar := Nat")
    codegen_ = codegen_.add_blank()

    ty = codegen.build_enum_with_deriving("Ty", [
        ("var", [("v", codegen.make_nat_type())]),
        ("nat", []),
        ("bool", []),
        ("str", []),
        ("arrow", [("a", codegen.make_simple_type("Ty")), ("b", codegen.make_simple_type("Ty"))]),
        ("generic0", [("name", codegen.make_string_type())]),
        ("generic1", [("name", codegen.make_string_type()), ("arg", codegen.make_simple_type("Ty"))]),
        ("generic2", [("name", codegen.make_string_type()), ("arg1", codegen.make_simple_type("Ty")), ("arg2", codegen.make_simple_type("Ty"))])
    ], ["Repr", "DecidableEq", "BEq", "Inhabited"])
    codegen_ = codegen_.add_inductive(ty)

    expr = codegen.build_enum_with_deriving("Expr", [
        ("var", [("name", codegen.make_string_type())]),
        ("litNat", [("n", codegen.make_nat_type())]),
        ("litBool", [("b", codegen.make_bool_type())]),
        ("litStr", [("s", codegen.make_string_type())]),
        ("lam", [("name", codegen.make_string_type()), ("body", codegen.make_simple_type("Expr"))]),
        ("app", [("f", codegen.make_simple_type("Expr")), ("x", codegen.make_simple_type("Expr"))]),
        ("letIn", [("name", codegen.make_string_type()), ("value", codegen.make_simple_type("Expr")), ("body", codegen.make_simple_type("Expr"))]),
        ("ifElse", [("c", codegen.make_simple_type("Expr")), ("t", codegen.make_simple_type("Expr")), ("e", codegen.make_simple_type("Expr"))]),
        ("mkGeneric1", [("name", codegen.make_string_type()), ("arg", codegen.make_simple_type("Expr"))]),
        ("mkGeneric2", [("name", codegen.make_string_type()), ("arg1", codegen.make_simple_type("Expr")), ("arg2", codegen.make_simple_type("Expr"))])
    ], ["Repr", "Inhabited"])
    codegen_ = codegen_.add_inductive(expr)

    codegen_ = codegen_.add_raw_line("structure Scheme where")
    codegen_ = codegen_.add_raw_line("  vars : List TyVar")
    codegen_ = codegen_.add_raw_line("  ty : Ty")
    codegen_ = codegen_.add_raw_line("  deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("structure SubstEntry where")
    codegen_ = codegen_.add_raw_line("  var : TyVar")
    codegen_ = codegen_.add_raw_line("  ty : Ty")
    codegen_ = codegen_.add_raw_line("  deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("abbrev Subst := List SubstEntry")
    codegen_ = codegen_.add_raw_line("def emptySubst : Subst := []")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("structure FreshState where")
    codegen_ = codegen_.add_raw_line("  next : Nat")
    codegen_ = codegen_.add_raw_line("  deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("structure EnvEntry where")
    codegen_ = codegen_.add_raw_line("  name : String")
    codegen_ = codegen_.add_raw_line("  scheme : Scheme")
    codegen_ = codegen_.add_raw_line("  deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("abbrev TypeEnv := List EnvEntry")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def substLookup (s : Subst) (v : TyVar) : Option Ty :=")
    codegen_ = codegen_.add_raw_line("  match s.find? (fun e => e.var == v) with")
    codegen_ = codegen_.add_raw_line("  | some e => some e.ty")
    codegen_ = codegen_.add_raw_line("  | none => none")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def singleSubst (v : TyVar) (t : Ty) : Subst := [{ var := v, ty := t }]")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def applySubst (s : Subst) : Ty → Ty")
    codegen_ = codegen_.add_raw_line("  | Ty.var v => match substLookup s v with | some t => t | none => Ty.var v")
    codegen_ = codegen_.add_raw_line("  | Ty.nat => Ty.nat")
    codegen_ = codegen_.add_raw_line("  | Ty.bool => Ty.bool")
    codegen_ = codegen_.add_raw_line("  | Ty.str => Ty.str")
    codegen_ = codegen_.add_raw_line("  | Ty.arrow a b => Ty.arrow (applySubst s a) (applySubst s b)")
    codegen_ = codegen_.add_raw_line("  | Ty.generic0 n => Ty.generic0 n")
    codegen_ = codegen_.add_raw_line("  | Ty.generic1 n a => Ty.generic1 n (applySubst s a)")
    codegen_ = codegen_.add_raw_line("  | Ty.generic2 n a b => Ty.generic2 n (applySubst s a) (applySubst s b)")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def composeSubst (s1 s2 : Subst) : Subst :=")
    codegen_ = codegen_.add_raw_line("  s1 ++ s2.map (fun e => { e with ty := applySubst s1 e.ty })")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def freeVars : Ty → List TyVar")
    codegen_ = codegen_.add_raw_line("  | Ty.var v => [v]")
    codegen_ = codegen_.add_raw_line("  | Ty.nat => []")
    codegen_ = codegen_.add_raw_line("  | Ty.bool => []")
    codegen_ = codegen_.add_raw_line("  | Ty.str => []")
    codegen_ = codegen_.add_raw_line("  | Ty.arrow a b => freeVars a ++ freeVars b")
    codegen_ = codegen_.add_raw_line("  | Ty.generic0 _ => []")
    codegen_ = codegen_.add_raw_line("  | Ty.generic1 _ a => freeVars a")
    codegen_ = codegen_.add_raw_line("  | Ty.generic2 _ a b => freeVars a ++ freeVars b")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def freeVarsScheme (sch : Scheme) : List TyVar :=")
    codegen_ = codegen_.add_raw_line("  (freeVars sch.ty).filter (fun v => !(sch.vars.contains v))")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def occurs (v : TyVar) : Ty → Bool")
    codegen_ = codegen_.add_raw_line("  | Ty.var v' => decide (v = v')")
    codegen_ = codegen_.add_raw_line("  | Ty.nat => false")
    codegen_ = codegen_.add_raw_line("  | Ty.bool => false")
    codegen_ = codegen_.add_raw_line("  | Ty.str => false")
    codegen_ = codegen_.add_raw_line("  | Ty.arrow a b => occurs v a || occurs v b")
    codegen_ = codegen_.add_raw_line("  | Ty.generic0 _ => false")
    codegen_ = codegen_.add_raw_line("  | Ty.generic1 _ a => occurs v a")
    codegen_ = codegen_.add_raw_line("  | Ty.generic2 _ a b => occurs v a || occurs v b")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("inductive UnifyResult")
    codegen_ = codegen_.add_raw_line("  | ok : Subst → UnifyResult")
    codegen_ = codegen_.add_raw_line("  | occursCheckFail : TyVar → Ty → UnifyResult")
    codegen_ = codegen_.add_raw_line("  | mismatch : Ty → Ty → UnifyResult")
    codegen_ = codegen_.add_raw_line("deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("inductive InferResult")
    codegen_ = codegen_.add_raw_line("  | ok : Ty → Subst → FreshState → InferResult")
    codegen_ = codegen_.add_raw_line("  | error : String → InferResult")
    codegen_ = codegen_.add_raw_line("deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def unify (t1 t2 : Ty) : UnifyResult :=")
    codegen_ = codegen_.add_raw_line("  if t1 == t2 then UnifyResult.ok emptySubst")
    codegen_ = codegen_.add_raw_line("  else match t1, t2 with")
    codegen_ = codegen_.add_raw_line("    | Ty.var v, t => if occurs v t then UnifyResult.occursCheckFail v t else UnifyResult.ok (singleSubst v t)")
    codegen_ = codegen_.add_raw_line("    | t, Ty.var v => if occurs v t then UnifyResult.occursCheckFail v t else UnifyResult.ok (singleSubst v t)")
    codegen_ = codegen_.add_raw_line("    | _, _ => UnifyResult.mismatch t1 t2")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def freshVar (st : FreshState) : (TyVar × FreshState) :=")
    codegen_ = codegen_.add_raw_line("  (st.next, { next := st.next + 1 })")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def instantiate (sch : Scheme) (st : FreshState) : (Ty × FreshState) :=")
    codegen_ = codegen_.add_raw_line("  (sch.ty, st)")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def generalize (envFreeVars : List TyVar) (t : Ty) : Scheme :=")
    codegen_ = codegen_.add_raw_line("  { vars := (freeVars t).filter (fun v => !(envFreeVars.contains v)), ty := t }")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def lookupEnv (env : TypeEnv) (name : String) : Option Scheme :=")
    codegen_ = codegen_.add_raw_line("  match env.find? (fun e => e.name == name) with")
    codegen_ = codegen_.add_raw_line("  | some e => some e.scheme")
    codegen_ = codegen_.add_raw_line("  | none => none")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def extendEnv (env : TypeEnv) (name : String) (sch : Scheme) : TypeEnv :=")
    codegen_ = codegen_.add_raw_line("  { name := name, scheme := sch } :: env")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def freeVarsEnv (env : TypeEnv) : List TyVar :=")
    codegen_ = codegen_.add_raw_line("  env.foldl (fun acc e => acc ++ freeVarsScheme e.scheme) []")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def applySubstEnv (s : Subst) (env : TypeEnv) : TypeEnv :=")
    codegen_ = codegen_.add_raw_line("  env.map (fun e => { e with scheme := { e.scheme with ty := applySubst s e.scheme.ty } })")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def infer (env : TypeEnv) (expr : Expr) (st : FreshState) : InferResult :=")
    codegen_ = codegen_.add_raw_line("  match expr with")
    codegen_ = codegen_.add_raw_line("  | Expr.var name =>")
    codegen_ = codegen_.add_raw_line("      match lookupEnv env name with")
    codegen_ = codegen_.add_raw_line("      | some sch => let (ty, st') := instantiate sch st; InferResult.ok ty emptySubst st'")
    codegen_ = codegen_.add_raw_line("      | none => InferResult.error \"Undefined variable\"")
    codegen_ = codegen_.add_raw_line("  | Expr.litNat _ => InferResult.ok Ty.nat emptySubst st")
    codegen_ = codegen_.add_raw_line("  | Expr.litBool _ => InferResult.ok Ty.bool emptySubst st")
    codegen_ = codegen_.add_raw_line("  | Expr.litStr _ => InferResult.ok Ty.str emptySubst st")
    codegen_ = codegen_.add_raw_line("  | Expr.lam _ _ => let (v, st') := freshVar st; InferResult.ok (Ty.arrow (Ty.var v) (Ty.var v)) emptySubst st'")
    codegen_ = codegen_.add_raw_line("  | Expr.app _ _ => let (v, st') := freshVar st; InferResult.ok (Ty.var v) emptySubst st'")
    codegen_ = codegen_.add_raw_line("  | Expr.letIn name _ body => infer (extendEnv env name (generalize (freeVarsEnv env) Ty.nat)) body st")
    codegen_ = codegen_.add_raw_line("  | Expr.ifElse _ t _ => infer env t st")
    codegen_ = codegen_.add_raw_line("  | Expr.mkGeneric1 name _ => InferResult.ok (Ty.generic1 name Ty.nat) emptySubst st")
    codegen_ = codegen_.add_raw_line("  | Expr.mkGeneric2 name _ _ => InferResult.ok (Ty.generic2 name Ty.nat Ty.nat) emptySubst st")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "applySubst_empty",
        [("t", "Ty")],
        "applySubst emptySubst t = t",
        "induction t with\n| var v => simp [applySubst, emptySubst, substLookup]\n| nat => rfl\n| bool => rfl\n| str => rfl\n| arrow a b iha ihb => simp [applySubst, iha, ihb]\n| generic0 n => rfl\n| generic1 n a iha => simp [applySubst, iha]\n| generic2 n a b iha ihb => simp [applySubst, iha, ihb]"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "occurs_nat_false",
        [("v", "TyVar")],
        "occurs v Ty.nat = false",
        "rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "occurs_bool_false",
        [("v", "TyVar")],
        "occurs v Ty.bool = false",
        "rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "occurs_str_false",
        [("v", "TyVar")],
        "occurs v Ty.str = false",
        "rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "occurs_var_true",
        [("v", "TyVar")],
        "occurs v (Ty.var v) = true",
        "simp [occurs]"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "instantiate_preserves_shape",
        [("sch", "Scheme"), ("st", "FreshState")],
        "(instantiate sch st).fst = sch.ty",
        "rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "generalize_preserves_type",
        [("envFreeVars", "List TyVar"), ("t", "Ty")],
        "(generalize envFreeVars t).ty = t",
        "rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "infer_lit_nat",
        [("env", "TypeEnv"), ("st", "FreshState"), ("n", "Nat")],
        "infer env (Expr.litNat n) st = InferResult.ok Ty.nat emptySubst st",
        "rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "infer_lit_bool",
        [("env", "TypeEnv"), ("st", "FreshState"), ("b", "Bool")],
        "infer env (Expr.litBool b) st = InferResult.ok Ty.bool emptySubst st",
        "rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "infer_lit_str",
        [("env", "TypeEnv"), ("st", "FreshState"), ("s", "String")],
        "infer env (Expr.litStr s) st = InferResult.ok Ty.str emptySubst st",
        "rfl"
    ))

    codegen_ = codegen_.end_namespace("Generics")
    return codegen_.emit()


fn main():
    print(regenerate_generics())
