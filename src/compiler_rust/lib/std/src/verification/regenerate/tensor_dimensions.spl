# Tensor Dimensions - Lean verification generation
# Generates Lean proofs for tensor dimension inference

use verification.lean.codegen.{build_enum_with_deriving, build_theorem, LeanCodegen, make_list_type, make_nat_type, make_option_type, make_simple_type, make_string_type}

fn regenerate_tensor_dimensions() -> text:
    lgen = LeanCodegen.create("TensorDimensions")

    lgen = lgen.add_namespace("TensorDimensions")

    # Doc comment
    lgen = lgen.add_doc_comment("Tensor dimension inference and verification.\n    Provides compile-time dimension tracking with range constraints.")

    # ========================================================================
    # Dimension type
    # ========================================================================

    dim = build_enum_with_deriving("Dim", [
        ("literal", [("value", make_nat_type())]),
        ("variable", [("id", make_nat_type()), ("name", make_option_type(make_string_type()))]),
        ("named", [("name", make_string_type()), ("lo", make_option_type(make_nat_type())), ("hi", make_option_type(make_nat_type()))]),
        ("dynamic", []),
        ("broadcast", [])
    ], ["Repr", "DecidableEq"])
    lgen = lgen.add_inductive(dim)

    # ========================================================================
    # TensorShape type
    # ========================================================================

    lgen = lgen.add_raw_line("abbrev TensorShape := List Dim")
    lgen = lgen.add_blank()

    # ========================================================================
    # Dimension constraint type
    # ========================================================================

    constraint = build_enum_with_deriving("DimConstraint", [
        ("equal", [("d1", make_simple_type("Dim")), ("d2", make_simple_type("Dim"))]),
        ("greaterThan", [("d", make_simple_type("Dim")), ("min", make_nat_type())]),
        ("lessThan", [("d", make_simple_type("Dim")), ("max", make_nat_type())]),
        ("inRange", [("d", make_simple_type("Dim")), ("lo", make_nat_type()), ("hi", make_nat_type())]),
        ("productEquals", [("dims", make_list_type(make_simple_type("Dim"))), ("value", make_nat_type())])
    ], ["Repr"])
    lgen = lgen.add_inductive(constraint)

    # ========================================================================
    # Dimension equality
    # ========================================================================

    lgen = lgen.add_doc_comment("Check if two dimensions are equal (for unification).")
    lgen = lgen.add_raw_line("def dimEq : Dim → Dim → bool")
    lgen = lgen.add_raw_line("  | Dim.literal v1, Dim.literal v2 => v1 = v2")
    lgen = lgen.add_raw_line("  | Dim.variable id1 _, Dim.variable id2 _ => id1 = id2")
    lgen = lgen.add_raw_line("  | Dim.named n1 _ _, Dim.named n2 _ _ => n1 = n2")
    lgen = lgen.add_raw_line("  | Dim.dynamic, Dim.dynamic => true")
    lgen = lgen.add_raw_line("  | Dim.broadcast, Dim.broadcast => true")
    lgen = lgen.add_raw_line("  | _, _ => false")
    lgen = lgen.add_blank()

    # ========================================================================
    # Shape compatibility
    # ========================================================================

    lgen = lgen.add_doc_comment("Check if two shapes are compatible (same rank, compatible dims).")
    lgen = lgen.add_raw_line("def shapesCompatible : TensorShape → TensorShape → bool")
    lgen = lgen.add_raw_line("  | [], [] => true")
    lgen = lgen.add_raw_line("  | d1 . s1, d2 . s2 => dimEq d1 d2 && shapesCompatible s1 s2")
    lgen = lgen.add_raw_line("  | _, _ => false")
    lgen = lgen.add_blank()

    # ========================================================================
    # Dimension value extraction
    # ========================================================================

    lgen = lgen.add_doc_comment("Get concrete value from dimension if literal.")
    lgen = lgen.add_raw_line("def getDimValue : Dim → Option ℕ")
    lgen = lgen.add_raw_line("  | Dim.literal v => some v")
    lgen = lgen.add_raw_line("  | _ => none")
    lgen = lgen.add_blank()

    # ========================================================================
    # Range checking
    # ========================================================================

    lgen = lgen.add_doc_comment("Check if dimension satisfies range constraint.")
    lgen = lgen.add_raw_line("def dimInRange (d : Dim) (lo hi : ℕ) : Prop :=")
    lgen = lgen.add_raw_line("  match getDimValue d with")
    lgen = lgen.add_raw_line("  | some v => lo ≤ v ∧ v ≤ hi")
    lgen = lgen.add_raw_line("  | none => True  -- Dynamic dims always satisfy")
    lgen = lgen.add_blank()

    # ========================================================================
    # Unification result
    # ========================================================================

    lgen = lgen.add_doc_comment("Result of dimension unification.")
    unify_result = build_enum_with_deriving("UnifyResult", [
        ("success", [("d", make_simple_type("Dim"))]),
        ("failure", [("expected", make_simple_type("Dim")), ("actual", make_simple_type("Dim"))])
    ], ["Repr"])
    lgen = lgen.add_inductive(unify_result)

    # ========================================================================
    # Dimension unification
    # ========================================================================

    lgen = lgen.add_doc_comment("Unify two dimensions, returning unified dim or error.")
    lgen = lgen.add_raw_line("def unifyDim : Dim → Dim → UnifyResult")
    lgen = lgen.add_raw_line("  -- Same literal")
    lgen = lgen.add_raw_line("  | Dim.literal v1, Dim.literal v2 =>")
    lgen = lgen.add_raw_line("    if v1 = v2 then UnifyResult.success (Dim.literal v1)")
    lgen = lgen.add_raw_line("    else UnifyResult.failure (Dim.literal v1) (Dim.literal v2)")
    lgen = lgen.add_raw_line("  -- Variable binds to anything")
    lgen = lgen.add_raw_line("  | Dim.variable _ _, d => UnifyResult.success d")
    lgen = lgen.add_raw_line("  | d, Dim.variable _ _ => UnifyResult.success d")
    lgen = lgen.add_raw_line("  -- Dynamic matches anything")
    lgen = lgen.add_raw_line("  | Dim.dynamic, d => UnifyResult.success d")
    lgen = lgen.add_raw_line("  | d, Dim.dynamic => UnifyResult.success d")
    lgen = lgen.add_raw_line("  -- Broadcast rules")
    lgen = lgen.add_raw_line("  | Dim.broadcast, Dim.literal 1 => UnifyResult.success (Dim.literal 1)")
    lgen = lgen.add_raw_line("  | Dim.literal 1, Dim.broadcast => UnifyResult.success (Dim.literal 1)")
    lgen = lgen.add_raw_line("  | Dim.broadcast, d => UnifyResult.success d")
    lgen = lgen.add_raw_line("  | d, Dim.broadcast => UnifyResult.success d")
    lgen = lgen.add_raw_line("  -- Named dims with same name")
    lgen = lgen.add_raw_line("  | Dim.named n1 lo1 hi1, Dim.named n2 lo2 hi2 =>")
    lgen = lgen.add_raw_line("    if n1 = n2 then UnifyResult.success (Dim.named n1 lo1 hi1)")
    lgen = lgen.add_raw_line("    else UnifyResult.failure (Dim.named n1 lo1 hi1) (Dim.named n2 lo2 hi2)")
    lgen = lgen.add_raw_line("  -- Default: failure")
    lgen = lgen.add_raw_line("  | d1, d2 => UnifyResult.failure d1 d2")
    lgen = lgen.add_blank()

    # ========================================================================
    # Shape unification
    # ========================================================================

    lgen = lgen.add_doc_comment("Unify two shapes dimension by dimension.")
    lgen = lgen.add_raw_line("def unifyShapes : TensorShape → TensorShape → Option TensorShape")
    lgen = lgen.add_raw_line("  | [], [] => some []")
    lgen = lgen.add_raw_line("  | d1 . s1, d2 . s2 =>")
    lgen = lgen.add_raw_line("    match unifyDim d1 d2, unifyShapes s1 s2 with")
    lgen = lgen.add_raw_line("    | UnifyResult.success d, some s => some (d . s)")
    lgen = lgen.add_raw_line("    | _, _ => none")
    lgen = lgen.add_raw_line("  | _, _ => none")
    lgen = lgen.add_blank()

    # ========================================================================
    # Matrix multiplication shape inference
    # ========================================================================

    lgen = lgen.add_doc_comment("Infer shape of matrix multiplication [M,K] @ [K,N] -> [M,N].")
    lgen = lgen.add_raw_line("def matmulShape (left right : TensorShape) : Option TensorShape :=")
    lgen = lgen.add_raw_line("  match left, right with")
    lgen = lgen.add_raw_line("  | [m, k1], [k2, n] =>")
    lgen = lgen.add_raw_line("    match unifyDim k1 k2 with")
    lgen = lgen.add_raw_line("    | UnifyResult.success _ => some [m, n]")
    lgen = lgen.add_raw_line("    | UnifyResult.failure _ _ => none")
    lgen = lgen.add_raw_line("  | _, _ => none")
    lgen = lgen.add_blank()

    # ========================================================================
    # Theorems
    # ========================================================================

    # Reflexivity of shape compatibility
    lgen = lgen.add_doc_comment("Shape compatibility is reflexive.")
    lgen = lgen.add_theorem(build_theorem(
        "shapesCompatible_refl",
        [("s", "TensorShape")],
        "shapesCompatible s s = true",
        "induction s with\n| nil => rfl\n| cons d s' ih => simp [shapesCompatible, dimEq]; exact ih"
    ))

    # Unification success means dims are compatible
    lgen = lgen.add_doc_comment("Successful unification implies dimension equality.")
    lgen = lgen.add_theorem(build_theorem(
        "unifyDim_success_eq",
        [("d1", "Dim"), ("d2", "Dim"), ("d", "Dim")],
        "unifyDim d1 d2 = UnifyResult.success d → dimEq d1 d ∨ dimEq d2 d",
        "intro h\ncases d1 <;> cases d2 <;> simp [unifyDim] at h <;> try (left; simp [dimEq]; rfl) <;> try (right; simp [dimEq]; rfl)"
    ))

    # Matmul shape determinism
    lgen = lgen.add_doc_comment("Matmul shape inference is deterministic.")
    lgen = lgen.add_theorem(build_theorem(
        "matmulShape_deterministic",
        [("l", "TensorShape"), ("r", "TensorShape"), ("s1", "TensorShape"), ("s2", "TensorShape")],
        "matmulShape l r = some s1 → matmulShape l r = some s2 → s1 = s2",
        "intro h1 h2\nhave : some s1 = some s2 := by simpa [h1] using h2\ncases this\nrfl"
    ))

    # Shape product preservation (for reshape)
    lgen = lgen.add_doc_comment("Product of dimensions helper.")
    lgen = lgen.add_raw_line("def dimProduct : TensorShape → Option ℕ")
    lgen = lgen.add_raw_line("  | [] => some 1")
    lgen = lgen.add_raw_line("  | d . ds =>")
    lgen = lgen.add_raw_line("    match getDimValue d, dimProduct ds with")
    lgen = lgen.add_raw_line("    | some v, some p => some (v * p)")
    lgen = lgen.add_raw_line("    | _, _ => none")
    lgen = lgen.add_blank()

    # Memory estimation
    lgen = lgen.add_doc_comment("Minimum memory for shape (in elements).")
    lgen = lgen.add_raw_line("def minElements : TensorShape → Option ℕ :=")
    lgen = lgen.add_raw_line("  dimProduct")
    lgen = lgen.add_blank()

    lgen = lgen.add_doc_comment("Maximum memory for shape (using range upper bounds).")
    lgen = lgen.add_raw_line("def maxElementsAux : List Dim → Option ℕ")
    lgen = lgen.add_raw_line("  | [] => some 1")
    lgen = lgen.add_raw_line("  | d . ds =>")
    lgen = lgen.add_raw_line("    match d, maxElementsAux ds with")
    lgen = lgen.add_raw_line("    | Dim.literal v, some p => some (v * p)")
    lgen = lgen.add_raw_line("    | Dim.named _ _ (some hi), some p => some (hi * p)")
    lgen = lgen.add_raw_line("    | _, _ => none")
    lgen = lgen.add_blank()

    lgen = lgen.add_raw_line("def maxElements : TensorShape → Option ℕ := maxElementsAux")
    lgen = lgen.add_blank()

    # Memory bound theorem
    lgen = lgen.add_doc_comment("Min elements ≤ max elements when both exist.")
    lgen = lgen.add_theorem(build_theorem(
        "min_le_max_elements",
        [("s", "TensorShape")],
        "∀ min max, minElements s = some min → maxElements s = some max → min ≤ max",
        "intro min max h_min h_max\nsorry  -- Requires induction on s with product monotonicity"
    ))

    lgen = lgen.end_namespace("TensorDimensions")

    return lgen.emit()


# ============================================================================
# Memory Verification
# ============================================================================

fn regenerate_tensor_memory() -> text:
    lgen = LeanCodegen.create("TensorMemory")

    lgen = lgen.add_namespace("TensorMemory")

    lgen = lgen.add_doc_comment("Memory estimation and verification for tensor training.")

    # Import TensorDimensions
    lgen = lgen.add_raw_line("open TensorDimensions")
    lgen = lgen.add_blank()

    # Memory bound structure
    lgen = lgen.add_raw_line("structure MemoryBound where")
    lgen = lgen.add_raw_line("  minBytes : ℕ")
    lgen = lgen.add_raw_line("  maxBytes : ℕ")
    lgen = lgen.add_raw_line("  valid : minBytes ≤ maxBytes")
    lgen = lgen.add_blank()

    # Device memory
    lgen = lgen.add_raw_line("structure DeviceMemory where")
    lgen = lgen.add_raw_line("  totalBytes : ℕ")
    lgen = lgen.add_raw_line("  availableBytes : ℕ")
    lgen = lgen.add_raw_line("  valid : availableBytes ≤ totalBytes")
    lgen = lgen.add_blank()

    # Training memory components
    lgen = lgen.add_raw_line("structure TrainingMemory where")
    lgen = lgen.add_raw_line("  parameters : MemoryBound")
    lgen = lgen.add_raw_line("  gradients : MemoryBound")
    lgen = lgen.add_raw_line("  optimizerState : MemoryBound")
    lgen = lgen.add_raw_line("  activations : MemoryBound")
    lgen = lgen.add_blank()

    # Total memory
    lgen = lgen.add_raw_line("def TrainingMemory.totalMax (tm : TrainingMemory) : ℕ :=")
    lgen = lgen.add_raw_line("  tm.parameters.maxBytes + tm.gradients.maxBytes +")
    lgen = lgen.add_raw_line("  tm.optimizerState.maxBytes + tm.activations.maxBytes")
    lgen = lgen.add_blank()

    lgen = lgen.add_raw_line("def TrainingMemory.totalMin (tm : TrainingMemory) : ℕ :=")
    lgen = lgen.add_raw_line("  tm.parameters.minBytes + tm.gradients.minBytes +")
    lgen = lgen.add_raw_line("  tm.optimizerState.minBytes + tm.activations.minBytes")
    lgen = lgen.add_blank()

    # Fits theorem
    lgen = lgen.add_doc_comment("If max estimate fits, any actual usage fits.")
    lgen = lgen.add_theorem(build_theorem(
        "training_fits_if_max_fits",
        [("tm", "TrainingMemory"), ("device", "DeviceMemory"), ("actual", "ℕ")],
        "tm.totalMax ≤ device.availableBytes → tm.totalMin ≤ actual → actual ≤ tm.totalMax → actual ≤ device.availableBytes",
        "intro h_max h_min h_actual\nomega"
    ))

    lgen = lgen.end_namespace("TensorMemory")

    return lgen.emit()
