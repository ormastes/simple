# Manual Pointer Borrow - Borrow checker model generation
# Generates Lean verification for manual pointer borrow checking

use verification.lean.codegen as codegen

fn regenerate_manual_pointer_borrow() -> text:
    var codegen_ = codegen.LeanCodegen.create("ManualPointerBorrow")

    # Namespace
    codegen_ = codegen_.add_namespace("ManualPointerBorrow")

    # BorrowState structure
    codegen_ = codegen_.add_doc_comment("A tiny borrow checker for manual pointers: `exclusive` tracks a unique borrow,\n    `shared` counts active shared borrows.")
    borrow_state = codegen.build_class("BorrowState", [
        ("exclusive", codegen.make_simple_type("bool")),
        ("shared", codegen.make_simple_type("Nat"))
    ])
    codegen_ = codegen_.add_structure(borrow_state)

    # ValidBorrowState inductive
    codegen_ = codegen_.add_doc_comment("Type-safe borrow state where invalid states are unrepresentable.\n    Shared borrows are encoded as `n + 1`, so the shared case is always positive.")
    valid_state = codegen.build_enum_with_deriving("ValidBorrowState", [
        ("unborrowed", []),
        ("exclusive", []),
        ("shared", [("count", codegen.make_simple_type("Nat"))])
    ], ["Repr"])
    codegen_ = codegen_.add_inductive(valid_state)

    # valid definition
    valid_def = codegen.build_function(
        "valid",
        [("s", codegen.make_simple_type("BorrowState"))],
        codegen.make_simple_type("Prop"),
        "if s.exclusive then s.shared = 0 else True"
    )
    codegen_ = codegen_.add_function(valid_def)

    # Conversion functions
    codegen_ = codegen_.add_doc_comment("Convert ValidBorrowState to BorrowState. Always produces a valid state.")
    codegen_ = codegen_.add_raw_line("def ValidBorrowState.toState : ValidBorrowState → BorrowState")
    codegen_ = codegen_.add_raw_line("  | .unborrowed => {{ exclusive := false, shared := 0 }}")
    codegen_ = codegen_.add_raw_line("  | .exclusive => {{ exclusive := true, shared := 0 }}")
    codegen_ = codegen_.add_raw_line("  | .shared count => {{ exclusive := false, shared := count + 1 }}")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_doc_comment("Convert BorrowState to ValidBorrowState if valid.")
    codegen_ = codegen_.add_raw_line("def BorrowState.toValid (s : BorrowState) : Option ValidBorrowState :=")
    codegen_ = codegen_.add_raw_line("  match s.exclusive, s.shared with")
    codegen_ = codegen_.add_raw_line("  | false, 0 => some .unborrowed")
    codegen_ = codegen_.add_raw_line("  | true, 0 => some .exclusive")
    codegen_ = codegen_.add_raw_line("  | false, n + 1 => some (.shared n)")
    codegen_ = codegen_.add_raw_line("  | true, _ + 1 => none")
    codegen_ = codegen_.add_blank()

    # Key theorems
    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "validState_always_valid",
        [("vs", "ValidBorrowState")],
        "valid vs.toState",
        "cases vs with\n| unborrowed => simp [ValidBorrowState.toState, valid]\n| exclusive => simp [ValidBorrowState.toState, valid]\n| shared count => simp [ValidBorrowState.toState, valid]"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "toValid_toState",
        [("vs", "ValidBorrowState")],
        "vs.toState.toValid = some vs",
        "cases vs with\n| unborrowed => simp [ValidBorrowState.toState, BorrowState.toValid]\n| exclusive => simp [ValidBorrowState.toState, BorrowState.toValid]\n| shared count => simp [ValidBorrowState.toState, BorrowState.toValid]"
    ))

    # Operation functions
    take_excl_def = codegen.build_function(
        "takeExclusive",
        [("s", codegen.make_simple_type("BorrowState"))],
        codegen.make_simple_type("BorrowState"),
        "if s.shared = 0 then {{ s with exclusive := true }} else s"
    )
    codegen_ = codegen_.add_function(take_excl_def)

    take_shared_def = codegen.build_function(
        "takeShared",
        [("s", codegen.make_simple_type("BorrowState"))],
        codegen.make_simple_type("BorrowState"),
        "if s.exclusive then s else {{ s with shared := s.shared + 1 }}"
    )
    codegen_ = codegen_.add_function(take_shared_def)

    release_shared_def = codegen.build_function(
        "releaseShared",
        [("s", codegen.make_simple_type("BorrowState"))],
        codegen.make_simple_type("BorrowState"),
        "{{ s with shared := s.shared.pred }}"
    )
    codegen_ = codegen_.add_function(release_shared_def)

    release_excl_def = codegen.build_function(
        "releaseExclusive",
        [("s", codegen.make_simple_type("BorrowState"))],
        codegen.make_simple_type("BorrowState"),
        "{{ s with exclusive := false }}"
    )
    codegen_ = codegen_.add_function(release_excl_def)

    # Preservation theorems
    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "exclusive_ok",
        [("s", "BorrowState"), ("hv", "valid s")],
        "valid (takeExclusive s)",
        "unfold takeExclusive valid at *\nsplit\n· assumption\n· exact hv"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "shared_ok",
        [("s", "BorrowState"), ("hv", "valid s")],
        "valid (takeShared s)",
        "unfold takeShared valid at *\nsplit\n· split at hv\n  · exact hv\n  · trivial\n· simp"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "release_ok",
        [("s", "BorrowState"), ("hv", "valid s")],
        "valid (releaseShared s) ∧ valid (releaseExclusive s)",
        "unfold releaseShared releaseExclusive valid at *\nconstructor\n· split\n  case isTrue hex =>\n    split at hv\n    case isTrue => simp_all\n    case isFalse h => exact absurd hex h\n  case isFalse => trivial\n· simp"
    ))

    # End namespace
    codegen_ = codegen_.end_namespace("ManualPointerBorrow")

    return codegen_.emit()


# ============================================================================
