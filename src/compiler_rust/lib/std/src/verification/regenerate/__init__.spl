        "src/verification/nogc_compile/src/NogcCompile.lean",
        "src/verification/async_compile/src/AsyncCompile.lean",
        "src/verification/gc_manual_borrow/src/GcManualBorrow.lean",
        "src/verification/manual_pointer_borrow/src/ManualPointerBorrow.lean",
        "src/verification/module_resolution/src/ModuleResolution.lean",
        "src/verification/visibility_export/src/VisibilityExport.lean",
        "src/verification/macro_auto_import/src/MacroAutoImport.lean",
        "src/verification/type_inference_compile/src/TypeInferenceCompile.lean",
        "src/verification/type_inference_compile/src/Generics.lean",
        "src/verification/type_inference_compile/src/Contracts.lean",
        "src/verification/memory_capabilities/src/MemoryCapabilities.lean",
        "src/verification/memory_model_drf/src/MemoryModelDRF.lean",
        "src/verification/type_inference_compile/src/AsyncEffectInference.lean",
        "src/verification/tensor_dimensions/src/TensorDimensions.lean",
        "src/verification/tensor_dimensions/src/TensorMemory.lean"
    ]

# Regenerate all Lean files
fn regenerate_all() -> Dict<text, text>:
    print("  [1/15] regenerate_nogc_compile...")
    r1 = regenerate_nogc_compile()
    print("  [2/15] regenerate_async_compile...")
    r2 = regenerate_async_compile()
    print("  [3/15] regenerate_gc_manual_borrow...")
    r3 = regenerate_gc_manual_borrow()
    print("  [4/15] regenerate_manual_pointer_borrow...")
    r4 = regenerate_manual_pointer_borrow()
    print("  [5/15] regenerate_module_resolution...")
    r5 = regenerate_module_resolution()
    print("  [6/15] regenerate_visibility_export...")
    r6 = regenerate_visibility_export()
    print("  [7/15] regenerate_macro_auto_import...")
    r7 = regenerate_macro_auto_import()
    print("  [8/15] regenerate_type_inference_compile...")
    r8 = regenerate_type_inference_compile()
    print("  [9/15] regenerate_generics...")
    r9 = regenerate_generics()
    print("  [10/15] regenerate_contracts...")
    r10 = regenerate_contracts()
    print("  [11/15] regenerate_memory_capabilities...")
    r11 = regenerate_memory_capabilities()
    print("  [12/15] regenerate_memory_model_drf...")
    r12 = regenerate_memory_model_drf()
    print("  [13/15] regenerate_async_effect_inference...")
    r13 = regenerate_async_effect_inference()
    print("  [14/15] regenerate_tensor_dimensions...")
    r14 = regenerate_tensor_dimensions()
    print("  [15/15] regenerate_tensor_memory...")
    r15 = regenerate_tensor_memory()
    print("  Building result dict...")
    {
        "src/verification/nogc_compile/src/NogcCompile.lean": r1,
        "src/verification/async_compile/src/AsyncCompile.lean": r2,
        "src/verification/gc_manual_borrow/src/GcManualBorrow.lean": r3,
        "src/verification/manual_pointer_borrow/src/ManualPointerBorrow.lean": r4,
        "src/verification/module_resolution/src/ModuleResolution.lean": r5,
        "src/verification/visibility_export/src/VisibilityExport.lean": r6,
        "src/verification/macro_auto_import/src/MacroAutoImport.lean": r7,
        "src/verification/type_inference_compile/src/TypeInferenceCompile.lean": r8,
        "src/verification/type_inference_compile/src/Generics.lean": r9,
        "src/verification/type_inference_compile/src/Contracts.lean": r10,
        "src/verification/memory_capabilities/src/MemoryCapabilities.lean": r11,
        "src/verification/memory_model_drf/src/MemoryModelDRF.lean": r12,
        "src/verification/type_inference_compile/src/AsyncEffectInference.lean": r13,
        "src/verification/tensor_dimensions/src/TensorDimensions.lean": r14,
        "src/verification/tensor_dimensions/src/TensorMemory.lean": r15
    }

# Marker every generator-owned Lean file must carry. Files without it are
# treated as hand-written and are never overwritten (GenLeanUnmarkedOverwrite).
fn generated_marker() -> text:
    "GENERATED by `simple gen-lean` -- DO NOT EDIT."

# Write regenerated files to disk.
# Refuses (per-file GenLeanUnmarkedOverwrite error) to replace any existing
# file that lacks the generated marker: that file is hand-written proof work.
fn write_regenerated_files(files: Dict<text, text>, base_path: text = ".") -> List<text>:
    var written = []
    for (path, content) in files.items():
        val full_path = base_path + "/" + path
        if file_exists(full_path):
            val existing = file_read_text(full_path)
            if not existing.contains(generated_marker()):
                print("error[GenLeanUnmarkedOverwrite]: refusing to overwrite {full_path}: existing file lacks the generated marker; move manual theorems to the sibling *Constraints.lean or restore the marker header")
                continue
        # Use shell mkdir for recursive dir creation (rt_dir_create_all is unimplemented in interpreter)
        shell("mkdir -p \"$(dirname '" + full_path + "')\"")
        file_write(full_path, content)
        written = written + [full_path]
    written

# Validate regenerated files match existing files on disk.
# Returns Dict<text, text> with "match" or "mismatch" per file path.
fn validate_regeneration(files: Dict<text, text>, base_path: text = ".") -> Dict<text, text>:
    var validation = {}
    for (path, content) in files.items():
        val full_path = base_path + "/" + path
        if file_exists(full_path):
            val disk = file_read_text(full_path)
            if disk == content:
                validation[path] = "match"
            else:
                validation[path] = "mismatch"
        else:
            validation[path] = "mismatch"
    validation

# Main entry point for CLI
fn main():
    print("Regenerating Lean verification files...")

    val files = regenerate_all()

    for (path, content) in files.items():
        print("Generated: {path} ({len(content)} bytes)")

    print("")
    print("Validating against existing files...")
    val validation = validate_regeneration(files)

    var all_valid = true
    for (path, status) in validation.items():
        print("  {path}: {status}")
        if status == "mismatch":
            all_valid = false

    if all_valid:
        print("")
        print("All files validated successfully!")
    else:
        print("")
        print("WARNING: Some files do not match. Review changes before committing.")
