# Lean File Regeneration
#
# Regenerates the Lean verification artifacts tracked by the repo and
# validates them against the checked-in/generated files on disk.

use std.nogc_sync_mut.io.{file_exists, dir_create_all, file_write, file_read_text, shell}



# Import individual regeneration modules
use verification.regenerate.nogc_compile.{regenerate_nogc_compile}
use verification.regenerate.async_compile.{regenerate_async_compile}
use verification.regenerate.gc_manual_borrow.{regenerate_gc_manual_borrow}
use verification.regenerate.manual_pointer_borrow.{regenerate_manual_pointer_borrow}
use verification.regenerate.module_resolution.{regenerate_module_resolution}
use verification.regenerate.visibility_export.{regenerate_visibility_export}
use verification.regenerate.macro_auto_import.{regenerate_macro_auto_import}
use verification.regenerate.type_inference.{regenerate_type_inference_compile}
use verification.regenerate.generics.{regenerate_generics}
use verification.regenerate.contracts.{regenerate_contracts}
use verification.regenerate.memory_capabilities.{regenerate_memory_capabilities}
use verification.regenerate.memory_model_drf.{regenerate_memory_model_drf}
use verification.regenerate.async_effect_inference.{regenerate_async_effect_inference}
use verification.regenerate.tensor_dimensions.{regenerate_tensor_dimensions, regenerate_tensor_memory}

