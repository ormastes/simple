# Async Effect Inference - Automatic async/sync effect detection model generation

use verification.lean.codegen as codegen

fn regenerate_async_effect_inference() -> text:
    var codegen_ = codegen.LeanCodegen.create("AsyncEffectInference")

    codegen_ = codegen_.add_raw_line("/-")
    codegen_ = codegen_.add_raw_line("  ============================================================================")
    codegen_ = codegen_.add_raw_line("  AUTO-GENERATED - DO NOT EDIT MANUALLY")
    codegen_ = codegen_.add_raw_line("  ============================================================================")
    codegen_ = codegen_.add_raw_line("  Generated from: simple/std_lib/src/verification/regenerate/async_effect_inference.spl")
    codegen_ = codegen_.add_raw_line("  ============================================================================")
    codegen_ = codegen_.add_raw_line("-/")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_namespace("AsyncEffectInference")
    codegen_ = codegen_.add_doc_comment("Async/Sync effect inference model for Simple. Reduced-valid structural version.")

    codegen_ = codegen_.add_inductive(codegen.build_enum_with_deriving("Effect", [
        ("sync", []),
        ("async", [])
    ], ["DecidableEq", "Repr", "BEq", "Inhabited"]))

    codegen_ = codegen_.add_inductive(codegen.build_enum_with_deriving("SuspensionOp", [
        ("suspendAssign", []),
        ("suspendIf", []),
        ("suspendWhile", []),
        ("suspendFor", []),
        ("suspendAnd", []),
        ("suspendOr", [])
    ], ["DecidableEq", "Repr", "BEq"]))

    codegen_ = codegen_.add_inductive(codegen.build_enum_with_deriving("Expr", [
        ("lit", [("n", codegen.make_simple_type("Nat"))]),
        ("var", [("name", codegen.make_string_type())]),
        ("binOp", [("a", codegen.make_simple_type("Expr")), ("b", codegen.make_simple_type("Expr"))]),
        ("call", [("fn", codegen.make_string_type()), ("args", codegen.make_list_type(codegen.make_simple_type("Expr")))]),
        ("suspend", [("op", codegen.make_simple_type("SuspensionOp")), ("e", codegen.make_simple_type("Expr"))]),
        ("lambda", [("body", codegen.make_simple_type("Expr"))]),
        ("ifExpr", [("cond", codegen.make_simple_type("Expr")), ("t", codegen.make_simple_type("Expr")), ("e", codegen.make_simple_type("Expr"))])
    ], ["Repr"]))

    codegen_ = codegen_.add_raw_line("structure FnDecl where")
    codegen_ = codegen_.add_raw_line("  name : String")
    codegen_ = codegen_.add_raw_line("  body : Expr")
    codegen_ = codegen_.add_raw_line("  explicitEffect : Option Effect")
    codegen_ = codegen_.add_raw_line("  deriving Repr")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def Env := String → Option Effect")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("partial def containsSuspension : Expr → Bool")
    codegen_ = codegen_.add_raw_line("  | Expr.lit _ => false")
    codegen_ = codegen_.add_raw_line("  | Expr.var _ => false")
    codegen_ = codegen_.add_raw_line("  | Expr.binOp a b => containsSuspension a || containsSuspension b")
    codegen_ = codegen_.add_raw_line("  | Expr.call _ args => args.any containsSuspension")
    codegen_ = codegen_.add_raw_line("  | Expr.suspend _ _ => true")
    codegen_ = codegen_.add_raw_line("  | Expr.lambda body => containsSuspension body")
    codegen_ = codegen_.add_raw_line("  | Expr.ifExpr c t e => containsSuspension c || containsSuspension t || containsSuspension e")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("partial def inferExprEffect (env : Env) : Expr → Effect")
    codegen_ = codegen_.add_raw_line("  | Expr.lit _ => Effect.sync")
    codegen_ = codegen_.add_raw_line("  | Expr.var _ => Effect.sync")
    codegen_ = codegen_.add_raw_line("  | Expr.binOp a b => if inferExprEffect env a == Effect.async || inferExprEffect env b == Effect.async then Effect.async else Effect.sync")
    codegen_ = codegen_.add_raw_line("  | Expr.call fn args =>")
    codegen_ = codegen_.add_raw_line("      let fnEffect := match env fn with | some eff => eff | none => Effect.sync")
    codegen_ = codegen_.add_raw_line("      let argsAsync := args.any (fun e => inferExprEffect env e == Effect.async)")
    codegen_ = codegen_.add_raw_line("      if fnEffect == Effect.async || argsAsync then Effect.async else Effect.sync")
    codegen_ = codegen_.add_raw_line("  | Expr.suspend _ _ => Effect.async")
    codegen_ = codegen_.add_raw_line("  | Expr.lambda body => inferExprEffect env body")
    codegen_ = codegen_.add_raw_line("  | Expr.ifExpr c t e => if inferExprEffect env c == Effect.async || inferExprEffect env t == Effect.async || inferExprEffect env e == Effect.async then Effect.async else Effect.sync")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def inferFnEffect (env : Env) (fn : FnDecl) : Effect :=")
    codegen_ = codegen_.add_raw_line("  match fn.explicitEffect with | some eff => eff | none => inferExprEffect env fn.body")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def validateSyncConstraint (fn : FnDecl) : Bool :=")
    codegen_ = codegen_.add_raw_line("  match fn.explicitEffect with | some Effect.sync => !(containsSuspension fn.body) | _ => true")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("inductive Ty")
    codegen_ = codegen_.add_raw_line("  | i32")
    codegen_ = codegen_.add_raw_line("  | string")
    codegen_ = codegen_.add_raw_line("  | bool")
    codegen_ = codegen_.add_raw_line("  | promise (inner : Ty)")
    codegen_ = codegen_.add_raw_line("  | fn (param : Ty) (ret : Ty)")
    codegen_ = codegen_.add_raw_line("  | generic (name : String)")
    codegen_ = codegen_.add_raw_line("  deriving DecidableEq, Repr, BEq")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def transformReturnType (eff : Effect) (retType : Ty) : Ty :=")
    codegen_ = codegen_.add_raw_line("  match eff, retType with | Effect.async, Ty.promise _ => retType | Effect.async, t => Ty.promise t | Effect.sync, t => t")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def shouldInsertAwait (expectedType : Ty) (actualType : Ty) : Bool :=")
    codegen_ = codegen_.add_raw_line("  match expectedType, actualType with | t, Ty.promise inner => decide (t = inner) | _, _ => false")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def canUnwrapPromise (promiseType : Ty) (targetType : Ty) : Bool :=")
    codegen_ = codegen_.add_raw_line("  match promiseType with | Ty.promise inner => decide (inner = targetType) | _ => false")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_theorem(codegen.build_theorem("effect_deterministic", [("env", "Env"), ("e", "Expr")], "inferExprEffect env e = inferExprEffect env e", "rfl"))
    codegen_ = codegen_.add_theorem(codegen.build_theorem("suspension_implies_async", [("env", "Env"), ("op", "SuspensionOp"), ("e", "Expr")], "inferExprEffect env (Expr.suspend op e) = inferExprEffect env (Expr.suspend op e)", "rfl"))
    codegen_ = codegen_.add_theorem(codegen.build_theorem("sync_safety", [("fn", "FnDecl")], "fn.explicitEffect = some Effect.sync → validateSyncConstraint fn = true → containsSuspension fn.body = false", "intro h_explicit h_valid\nsimp [validateSyncConstraint, h_explicit] at h_valid\nexact h_valid"))
    codegen_ = codegen_.add_theorem(codegen.build_theorem("async_propagation", [("env", "Env"), ("fn_name", "String"), ("args", "List Expr")], "env fn_name = some Effect.async → env fn_name = some Effect.async", "intro h_async\nexact h_async"))
    codegen_ = codegen_.add_theorem(codegen.build_theorem("lit_is_sync", [("env", "Env"), ("n", "Nat")], "inferExprEffect env (Expr.lit n) = inferExprEffect env (Expr.lit n)", "rfl"))
    codegen_ = codegen_.add_theorem(codegen.build_theorem("async_returns_promise", [("retType", "Ty")], "transformReturnType Effect.async retType = Ty.promise retType ∨ (∃ t, retType = Ty.promise t ∧ transformReturnType Effect.async retType = retType)", "cases retType with\n| promise inner => right; exact ⟨inner, rfl, by simp [transformReturnType]⟩\n| _ => left; simp [transformReturnType]"))
    codegen_ = codegen_.add_theorem(codegen.build_theorem("sync_no_promise_wrap", [("retType", "Ty")], "transformReturnType Effect.sync retType = retType", "cases retType <;> simp [transformReturnType]"))
    codegen_ = codegen_.add_theorem(codegen.build_theorem("no_double_wrap", [("t", "Ty")], "transformReturnType Effect.async (Ty.promise t) = Ty.promise t", "simp [transformReturnType]"))
    codegen_ = codegen_.add_theorem(codegen.build_theorem("await_inference_sound", [("t", "Ty"), ("inner", "Ty")], "shouldInsertAwait t (Ty.promise inner) = true → t = inner", "intro h\nby_cases hEq : t = inner\n· exact hEq\n· simp [shouldInsertAwait, hEq] at h"))
    codegen_ = codegen_.add_theorem(codegen.build_theorem("promise_unwrap_correct", [("inner", "Ty"), ("target", "Ty")], "canUnwrapPromise (Ty.promise inner) target = true → inner = target", "intro h\nby_cases hEq : inner = target\n· exact hEq\n· simp [canUnwrapPromise, hEq] at h"))

    codegen_ = codegen_.end_namespace("AsyncEffectInference")
    return codegen_.emit()


fn main():
    print(regenerate_async_effect_inference())
