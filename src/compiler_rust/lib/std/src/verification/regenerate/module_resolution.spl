# Module Resolution - Module system verification
# Generates Lean verification for module resolution

use verification.lean.codegen.{build_class_with_deriving, build_enum, build_function, build_theorem, LeanCodegen, make_list_type, make_simple_type, make_string_type}

fn regenerate_module_resolution() -> text:
    var lgen = LeanCodegen.create("ModuleResolution")

    # Namespace
    lgen = lgen.add_namespace("ModuleResolution")

    # Block comment with description
    lgen = lgen.add_block_comment([
        "# Module Resolution Model",
        "",
        "This model formalizes the module path resolution semantics."
    ])

    # Segment structure
    segment = build_class_with_deriving("Segment", [
        ("name", make_string_type()),
        ("nonEmpty", make_simple_type('name ≠ ""'))
    ], ["DecidableEq", "Repr"])
    lgen = lgen.add_structure(segment)

    # ModPath structure
    modpath = build_class_with_deriving("ModPath", [
        ("segments", make_list_type(make_simple_type("Segment"))),
        ("nonEmpty", make_simple_type("segments ≠ []"))
    ], ["Repr"])
    lgen = lgen.add_structure(modpath)

    # FileKind inductive
    filekind = build_enum("FileKind", [
        ("file", []),
        ("directory", [])
    ])
    lgen = lgen.add_inductive(filekind)

    # FileSystem structure
    filesystem = build_class_with_deriving("FileSystem", [
        ("files", make_list_type(make_string_type()))
    ], ["Repr"])
    lgen = lgen.add_structure(filesystem)

    # FileSystem.exists function
    fs_exists = build_function(
        "FileSystem.exists",
        [("fs", make_simple_type("FileSystem")), ("path", make_string_type())],
        make_simple_type("bool"),
        "fs.files.any (· == path)"
    )
    lgen = lgen.add_function(fs_exists)

    # Path conversion functions
    to_file_path = build_function(
        "toFilePath",
        [("root", make_string_type()), ("mp", make_simple_type("ModPath"))],
        make_string_type(),
        "root ++ \"/\" ++ text.intercalate \"/\" (mp.segments.map (·.name)) ++ \".spl\""
    )
    lgen = lgen.add_function(to_file_path)

    to_dir_path = build_function(
        "toDirPath",
        [("root", make_string_type()), ("mp", make_simple_type("ModPath"))],
        make_string_type(),
        "root ++ \"/\" ++ text.intercalate \"/\" (mp.segments.map (·.name)) ++ \"/__init__.spl\""
    )
    lgen = lgen.add_function(to_dir_path)

    # ResolutionResult inductive
    resolution = build_enum("ResolutionResult", [
        ("unique", [("kind", make_simple_type("FileKind")), ("path", make_string_type())]),
        ("ambiguous", [("filePath", make_string_type()), ("dirPath", make_string_type())]),
        ("notFound", [])
    ])
    lgen = lgen.add_inductive(resolution)

    # resolve function
    resolve_def = build_function(
        "resolve",
        [
            ("fs", make_simple_type("FileSystem")),
            ("root", make_string_type()),
            ("mp", make_simple_type("ModPath"))
        ],
        make_simple_type("ResolutionResult"),
        "val filePath := toFilePath root mp\nlet dirPath := toDirPath root mp\nlet fileExists := fs.exists filePath\nlet dirExists := fs.exists dirPath\nmatch fileExists, dirExists with\n| true, true => ResolutionResult.ambiguous filePath dirPath\n| true, false => ResolutionResult.unique FileKind.file filePath\n| false, true => ResolutionResult.unique FileKind.directory dirPath\n| false, false => ResolutionResult.notFound"
    )
    lgen = lgen.add_function(resolve_def)

    # wellFormed definition
    wellformed_def = build_function(
        "wellFormed",
        [("fs", make_simple_type("FileSystem")), ("root", make_string_type())],
        make_simple_type("Prop"),
        "∀ mp : ModPath, ¬(fs.exists (toFilePath root mp) = true ∧ fs.exists (toDirPath root mp) = true)"
    )
    lgen = lgen.add_function(wellformed_def)

    # Theorems
    lgen = lgen.add_theorem(build_theorem(
        "resolve_deterministic",
        [("fs", "FileSystem"), ("root", "text"), ("mp", "ModPath")],
        "resolve fs root mp = resolve fs root mp",
        "rfl"
    ))

    lgen = lgen.add_theorem(build_theorem(
        "wellformed_not_ambiguous",
        [("fs", "FileSystem"), ("root", "text"), ("mp", "ModPath"), ("hwf", "wellFormed fs root")],
        "∀ fp dp, resolve fs root mp ≠ ResolutionResult.ambiguous fp dp",
        "intro fp dp h\nunfold resolve at h\nsimp only at h\ncases hfile : fs.exists (toFilePath root mp) <;>\ncases hdir : fs.exists (toDirPath root mp)\n· simp_all\n· simp_all\n· simp_all\n· simp only [hfile, hdir] at h\n  obtain ⟨hfp, hdp⟩ := h\n  have hwf_mp := hwf mp\n  exact hwf_mp (And.intro hfile hdir)"
    ))

    lgen = lgen.add_theorem(build_theorem(
        "unique_implies_exists",
        [("fs", "FileSystem"), ("root", "text"), ("mp", "ModPath"), ("kind", "FileKind"), ("path", "text")],
        "resolve fs root mp = ResolutionResult.unique kind path → fs.exists path = true",
        "intro h\nunfold resolve at h\nsimp only at h\ncases hfile : fs.exists (toFilePath root mp) <;>\ncases hdir : fs.exists (toDirPath root mp) <;>\nsimp_all"
    ))

    lgen = lgen.add_theorem(build_theorem(
        "notfound_means_neither",
        [("fs", "FileSystem"), ("root", "text"), ("mp", "ModPath")],
        "resolve fs root mp = ResolutionResult.notFound → fs.exists (toFilePath root mp) = false ∧ fs.exists (toDirPath root mp) = false",
        "intro h\nunfold resolve at h\nsimp only at h\ncases hfile : fs.exists (toFilePath root mp) <;>\ncases hdir : fs.exists (toDirPath root mp) <;>\nsimp_all"
    ))

    # End namespace
    lgen = lgen.end_namespace("ModuleResolution")

    return lgen.emit()


# ============================================================================
# 6. VisibilityExport - Visibility rules (222 lines)
# ============================================================================
