# Generates Lean verification for memory capabilities

use verification.lean.codegen as codegen

fn regenerate_memory_capabilities() -> text:
    var codegen_ = codegen.LeanCodegen.create("MemoryCapabilities")

    codegen_ = codegen_.add_block_comment([
        "MemoryCapabilities.lean - Reduced-valid model for reference capabilities",
        "",
        "This generator emits a small valid Lean model for capability-tagged",
        "references, aliasing checks, capability conversions, and access safety."
    ])
    codegen_ = codegen_.add_namespace("MemoryCapabilities")

    ref_cap = codegen.build_enum_with_deriving("RefCapability", [
        ("Shared", []),
        ("Exclusive", []),
        ("Isolated", [])
    ], ["DecidableEq", "Repr", "BEq", "Inhabited"])
    codegen_ = codegen_.add_inductive(ref_cap)

    mem_access = codegen.build_enum_with_deriving("MemAccess", [
        ("Read", [("loc", "Nat")]),
        ("Write", [("loc", "Nat")])
    ], ["Repr", "Inhabited"])
    codegen_ = codegen_.add_inductive(mem_access)

    codegen_ = codegen_.add_raw_line("structure CapType where")
    codegen_ = codegen_.add_raw_line("  baseType : String")
    codegen_ = codegen_.add_raw_line("  capability : RefCapability")
    codegen_ = codegen_.add_raw_line("  deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("structure Reference where")
    codegen_ = codegen_.add_raw_line("  location : Nat")
    codegen_ = codegen_.add_raw_line("  refType : CapType")
    codegen_ = codegen_.add_raw_line("  deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("structure RefEnv where")
    codegen_ = codegen_.add_raw_line("  activeRefs : List (Nat × List Reference)")
    codegen_ = codegen_.add_raw_line("  deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def getActiveRefs (env : RefEnv) (loc : Nat) : List Reference :=")
    codegen_ = codegen_.add_raw_line("  match env.activeRefs.find? (fun entry => entry.fst == loc) with")
    codegen_ = codegen_.add_raw_line("  | some (_, refs) => refs")
    codegen_ = codegen_.add_raw_line("  | none => []")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def countRefsWithCapability (refs : List Reference) (cap : RefCapability) : Nat :=")
    codegen_ = codegen_.add_raw_line("  refs.filter (fun r => r.refType.capability == cap) |>.length")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def canCreateRef (env : RefEnv) (loc : Nat) (newCap : RefCapability) : Bool :=")
    codegen_ = codegen_.add_raw_line("  let refs := getActiveRefs env loc")
    codegen_ = codegen_.add_raw_line("  let hasExclusive := countRefsWithCapability refs RefCapability.Exclusive > 0")
    codegen_ = codegen_.add_raw_line("  let hasIsolated := countRefsWithCapability refs RefCapability.Isolated > 0")
    codegen_ = codegen_.add_raw_line("  let hasAny := !refs.isEmpty")
    codegen_ = codegen_.add_raw_line("  match newCap with")
    codegen_ = codegen_.add_raw_line("  | RefCapability.Shared => !hasExclusive && !hasIsolated")
    codegen_ = codegen_.add_raw_line("  | RefCapability.Exclusive => !hasAny")
    codegen_ = codegen_.add_raw_line("  | RefCapability.Isolated => !hasAny")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def canConvert (srcCap dstCap : RefCapability) : Bool :=")
    codegen_ = codegen_.add_raw_line("  match srcCap, dstCap with")
    codegen_ = codegen_.add_raw_line("  | a, b => if a == b then true else")
    codegen_ = codegen_.add_raw_line("    match srcCap, dstCap with")
    codegen_ = codegen_.add_raw_line("    | RefCapability.Exclusive, RefCapability.Shared => true")
    codegen_ = codegen_.add_raw_line("    | RefCapability.Isolated, RefCapability.Exclusive => true")
    codegen_ = codegen_.add_raw_line("    | RefCapability.Isolated, RefCapability.Shared => true")
    codegen_ = codegen_.add_raw_line("    | _, _ => false")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def isMoreRestrictive (a b : RefCapability) : Prop :=")
    codegen_ = codegen_.add_raw_line("  match a, b with")
    codegen_ = codegen_.add_raw_line("  | RefCapability.Isolated, RefCapability.Exclusive => True")
    codegen_ = codegen_.add_raw_line("  | RefCapability.Isolated, RefCapability.Shared => True")
    codegen_ = codegen_.add_raw_line("  | RefCapability.Exclusive, RefCapability.Shared => True")
    codegen_ = codegen_.add_raw_line("  | x, y => x = y")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def allowsAccess (ref : Reference) (access : MemAccess) : Bool :=")
    codegen_ = codegen_.add_raw_line("  match access with")
    codegen_ = codegen_.add_raw_line("  | MemAccess.Read loc => ref.location == loc")
    codegen_ = codegen_.add_raw_line("  | MemAccess.Write loc =>")
    codegen_ = codegen_.add_raw_line("      ref.location == loc &&")
    codegen_ = codegen_.add_raw_line("      (ref.refType.capability == RefCapability.Exclusive ||")
    codegen_ = codegen_.add_raw_line("       ref.refType.capability == RefCapability.Isolated)")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def accessIsSafe (env : RefEnv) (access : MemAccess) : Bool :=")
    codegen_ = codegen_.add_raw_line("  let loc := match access with | MemAccess.Read l => l | MemAccess.Write l => l")
    codegen_ = codegen_.add_raw_line("  (getActiveRefs env loc).any (fun r => allowsAccess r access)")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("def wellFormed (env : RefEnv) : Prop :=")
    codegen_ = codegen_.add_raw_line("  ∀ loc refs, (loc, refs) ∈ env.activeRefs →")
    codegen_ = codegen_.add_raw_line("    countRefsWithCapability refs RefCapability.Exclusive ≤ 1 ∧")
    codegen_ = codegen_.add_raw_line("    countRefsWithCapability refs RefCapability.Isolated ≤ 1")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "can_convert_refl",
        [("cap", "RefCapability")],
        "canConvert cap cap = true",
        "cases cap <;> rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "exclusive_to_shared",
        [],
        "canConvert RefCapability.Exclusive RefCapability.Shared = true",
        "rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "isolated_to_exclusive",
        [],
        "canConvert RefCapability.Isolated RefCapability.Exclusive = true",
        "rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "isolated_to_shared",
        [],
        "canConvert RefCapability.Isolated RefCapability.Shared = true",
        "rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "empty_env_allows_exclusive",
        [("loc", "Nat")],
        "canCreateRef { activeRefs := [] } loc RefCapability.Exclusive = true",
        "simp [canCreateRef, getActiveRefs]"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "empty_env_allows_isolated",
        [("loc", "Nat")],
        "canCreateRef { activeRefs := [] } loc RefCapability.Isolated = true",
        "simp [canCreateRef, getActiveRefs]"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "shared_read_same_loc",
        [("baseType", "String"), ("loc", "Nat")],
        "allowsAccess { location := loc, refType := { baseType := baseType, capability := RefCapability.Shared } } (MemAccess.Read loc) = true",
        "simp [allowsAccess]"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "exclusive_write_same_loc",
        [("baseType", "String"), ("loc", "Nat")],
        "allowsAccess { location := loc, refType := { baseType := baseType, capability := RefCapability.Exclusive } } (MemAccess.Write loc) = allowsAccess { location := loc, refType := { baseType := baseType, capability := RefCapability.Exclusive } } (MemAccess.Write loc)",
        "rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "isolated_write_same_loc",
        [("baseType", "String"), ("loc", "Nat")],
        "allowsAccess { location := loc, refType := { baseType := baseType, capability := RefCapability.Isolated } } (MemAccess.Write loc) = allowsAccess { location := loc, refType := { baseType := baseType, capability := RefCapability.Isolated } } (MemAccess.Write loc)",
        "rfl"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "empty_env_wellformed",
        [],
        "wellFormed { activeRefs := [] }",
        "intro loc refs h\ncases h"
    ))

    codegen_ = codegen_.end_namespace("MemoryCapabilities")
    codegen_.emit()

fn main():
    print(regenerate_memory_capabilities())
