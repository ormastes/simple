# Browser Fetch API
#
# Provides HTTP request functionality for making network requests from the browser.
# Supports GET, POST, PUT, DELETE and other HTTP methods with full async/await support.
#
# Example:
#   ```
#   import browser.fetch as fetch
#
#   # GET request
#   val response = await fetch.get("https://api.example.com/users")
#   val data = await response.json()
#
#   # POST request with JSON
#   val user = {"name": "Alice", "email": "alice@example.com"}
#   val response = await fetch.post_json("/api/users", user)
#   ```

# Make a GET request
#
# Example:
#   ```
#   val response = await fetch.get("/api/data")
#   if response.is_ok():
#       val text = await response.text()
#   ```
@async
@extern("browser", "fetch_get")
fn get(url: text) -> Response:
    pass

# Make a POST request with text body
#
# Example:
#   ```
#   val response = await fetch.post("/api/data", "request body")
#   ```
@async
@extern("browser", "fetch_post")
fn post(url: text, body: text) -> Response:
    pass

# Make a PUT request
@async
@extern("browser", "fetch_put")
fn put(url: text, body: text) -> Response:
    pass

# Make a DELETE request
@async
@extern("browser", "fetch_delete")
fn delete(url: text) -> Response:
    pass

# Make a PATCH request
@async
@extern("browser", "fetch_patch")
fn patch(url: text, body: text) -> Response:
    pass

# Make a HEAD request
@async
@extern("browser", "fetch_head")
fn head(url: text) -> Response:
    pass

# Make a GET request and parse JSON response
#
# Convenience method that combines get() + response.json()
#
# Example:
#   ```
#   val users = await fetch.get_json("/api/users")
#   for user in users:
#       console.log(user.name)
#   ```
@async
@extern("browser", "fetch_get_json")
fn get_json(url: text) -> Value:
    pass

# Make a POST request with JSON body
#
# Automatically serializes the body to JSON and sets Content-Type header.
#
# Example:
#   ```
#   val new_user = {"name": "Bob", "age": 30}
#   val response = await fetch.post_json("/api/users", new_user)
#   val created = await response.json()
#   ```
@async
@extern("browser", "fetch_post_json")
fn post_json(url: text, body: Value) -> Response:
    pass

# Make a PUT request with JSON body
@async
@extern("browser", "fetch_put_json")
fn put_json(url: text, body: Value) -> Response:
    pass

# Make a PATCH request with JSON body
@async
@extern("browser", "fetch_patch_json")
fn patch_json(url: text, body: Value) -> Response:
    pass

# Make a custom request with full options
#
# Example:
#   ```
#   val options = RequestOptions()
#       .method("POST")
#       .header("Authorization", "Bearer token")
#       .body("data")
#
#   val response = await fetch.request("/api/endpoint", options)
#   ```
@async
@extern("browser", "fetch_request")
fn request(url: text, options: RequestOptions) -> Response:
    pass

# Request options builder
class RequestOptions:
    # Create new request options
    static fn new() -> RequestOptions:
        pass

    # Set HTTP method
    fn method(method: text) -> RequestOptions:
        pass

    # Set request body
    fn body(body: text) -> RequestOptions:
        pass

    # Add a header
    fn header(name: text, value: text) -> RequestOptions:
        pass

    # Set multiple headers
    fn headers(headers: Map<text, text>) -> RequestOptions:
        pass

    # Set request mode (cors, no-cors, same-origin)
    fn mode(mode: text) -> RequestOptions:
        pass

    # Set credentials mode (omit, same-origin, include)
    fn credentials(credentials: text) -> RequestOptions:
        pass

    # Set cache mode (default, no-cache, reload, force-cache)
    fn cache(cache: text) -> RequestOptions:
        pass

    # Set redirect mode (follow, error, manual)
    fn redirect(redirect: text) -> RequestOptions:
        pass

    # Set referrer
    fn referrer(referrer: text) -> RequestOptions:
        pass

    # Set timeout in milliseconds
    fn timeout(ms: i64) -> RequestOptions:
        pass

# HTTP Response
class Response:
    # Get response status code
    #
    # Example:
    #   ```
    #   val response = await fetch.get("/api/data")
    #   if response.status() == 200:
    #       # Success
    #   ```
    @extern("browser", "response_get_status")
    fn status() -> i64:
        pass

    # Get response status text
    @extern("browser", "response_get_status_text")
    fn status_text() -> text:
        pass

    # Check if response is ok (status 200-299)
    #
    # Example:
    #   ```
    #   if response.is_ok():
    #       val data = await response.json()
    #   else:
    #       console.error("Request failed:", response.status())
    #   ```
    @extern("browser", "response_is_ok")
    fn is_ok() -> bool:
        pass

    # Get response headers
    @extern("browser", "response_get_headers")
    fn headers() -> Headers:
        pass

    # Get specific header value
    @extern("browser", "response_get_header")
    fn header(name: text) -> text:
        pass

    # Get response URL
    @extern("browser", "response_get_url")
    fn url() -> text:
        pass

    # Check if response was redirected
    @extern("browser", "response_is_redirected")
    fn redirected() -> bool:
        pass

    # Read response body as text
    #
    # Example:
    #   ```
    #   val html = await response.text()
    #   ```
    @async
    @extern("browser", "response_text")
    fn text() -> text:
        pass

    # Parse response body as JSON
    #
    # Example:
    #   ```
    #   val data = await response.json()
    #   console.log(data.message)
    #   ```
    @async
    @extern("browser", "response_json")
    fn json() -> Value:
        pass

    # Read response body as blob
    @async
    @extern("browser", "response_blob")
    fn blob() -> Blob:
        pass

    # Read response body as array buffer
    @async
    @extern("browser", "response_array_buffer")
    fn array_buffer() -> ArrayBuffer:
        pass

    # Clone the response
    @extern("browser", "response_clone")
    fn clone() -> Response:
        pass

# HTTP Headers
class Headers:
    # Create new headers
    static fn new() -> Headers:
        pass

    # Get header value
    @extern("browser", "headers_get")
    fn get(name: text) -> text:
        pass

    # Set header value
    @extern("browser", "headers_set")
    fn set(name: text, value: text):
        pass

    # Append header value
    @extern("browser", "headers_append")
    fn append(name: text, value: text):
        pass

    # Delete header
    @extern("browser", "headers_delete")
    fn delete(name: text):
        pass

    # Check if header exists
    @extern("browser", "headers_has")
    fn has(name: text) -> bool:
        pass

    # Get all header names
    @extern("browser", "headers_keys")
    fn keys() -> List<text>:
        pass

    # Get all header values
    @extern("browser", "headers_values")
    fn values() -> List<text>:
        pass

    # Get all headers as map
    @extern("browser", "headers_entries")
    fn entries() -> Map<text, text>:
        pass

# Blob (binary large object)
class Blob:
    # Get blob size in bytes
    @extern("browser", "blob_get_size")
    fn size() -> i64:
        pass

    # Get blob MIME type
    @extern("browser", "blob_get_type")
    fn type() -> text:
        pass

    # Read blob as text
    @async
    @extern("browser", "blob_text")
    fn text() -> text:
        pass

    # Read blob as array buffer
    @async
    @extern("browser", "blob_array_buffer")
    fn array_buffer() -> ArrayBuffer:
        pass

    # Slice blob
    @extern("browser", "blob_slice")
    fn slice(start: i64, end: i64) -> Blob:
        pass

# ArrayBuffer for binary data
class ArrayBuffer:
    # Get buffer size
    @extern("browser", "array_buffer_get_byte_length")
    fn byte_length() -> i64:
        pass

    # Slice buffer
    @extern("browser", "array_buffer_slice")
    fn slice(start: i64, end: i64) -> ArrayBuffer:
        pass

# Abort controller for canceling requests
class AbortController:
    # Create new abort controller
    @extern("browser", "abort_controller_new")
    static fn new() -> AbortController:
        pass

    # Get the abort signal
    @extern("browser", "abort_controller_signal")
    fn signal() -> AbortSignal:
        pass

    # Abort the request
    #
    # Example:
    #   ```
    #   val controller = AbortController.new()
    #   val signal = controller.signal()
    #
    #   # Start request with signal
    #   val promise = fetch.get_with_signal("/api/slow", signal)
    #
    #   # Cancel request after 5 seconds
    #   await sleep(5000)
    #   controller.abort()
    #   ```
    @extern("browser", "abort_controller_abort")
    fn abort():
        pass

# Abort signal
class AbortSignal:
    # Check if aborted
    @extern("browser", "abort_signal_is_aborted")
    fn aborted() -> bool:
        pass

    # Add abort event listener
    @extern("browser", "abort_signal_add_listener")
    fn on_abort(handler: fn):
        pass

# Timeout helper - abort request after delay
#
# Example:
#   ```
#   val controller = AbortController.new()
#
#   # Auto-abort after 5 seconds
#   fetch.abort_after(controller, 5000)
#
#   val response = await fetch.get_with_signal("/api/data", controller.signal())
#   ```
@async
fn abort_after(controller: AbortController, ms: i64):
    await sleep(ms)
    controller.abort()

# Helper: sleep for milliseconds
@async
@extern("browser", "sleep")
fn sleep(ms: i64):
    pass
