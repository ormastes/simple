    print("LENGTH:" + str(len(f1)))
    print(f1)
    print("END_FILE")

    print("FILE:verification/async_compile/src/AsyncCompile.lean")
    val f2 = regen_async.regenerate_async_compile()
    print("LENGTH:" + str(len(f2)))
    print(f2)
    print("END_FILE")

    print("FILE:verification/gc_manual_borrow/src/GcManualBorrow.lean")
