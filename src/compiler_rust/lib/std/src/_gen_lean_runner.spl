    print("LENGTH:" + str(len(f3)))
    print(f3)
    print("END_FILE")

    print("FILE:verification/manual_pointer_borrow/src/ManualPointerBorrow.lean")
    val f4 = regen_manual.regenerate_manual_pointer_borrow()
    print("LENGTH:" + str(len(f4)))
    print(f4)
    print("END_FILE")

    print("FILE:verification/module_resolution/src/ModuleResolution.lean")
    val f5 = regen_module.regenerate_module_resolution()
    print("LENGTH:" + str(len(f5)))
    print(f5)
    print("END_FILE")

    print("FILE:verification/visibility_export/src/VisibilityExport.lean")
    val f6 = regen_visibility.regenerate_visibility_export()
    print("LENGTH:" + str(len(f6)))
    print(f6)
    print("END_FILE")

    print("FILE:verification/macro_auto_import/src/MacroAutoImport.lean")
    val f7 = regen_macro.regenerate_macro_auto_import()
    print("LENGTH:" + str(len(f7)))
    print(f7)
    print("END_FILE")

    print("FILE:verification/type_inference_compile/src/TypeInferenceCompile.lean")
    val f8 = regen_type.regenerate_type_inference_compile()
    print("LENGTH:" + str(len(f8)))
    print(f8)
    print("END_FILE")

    print("FILE:verification/type_inference_compile/src/Contracts.lean")
    val f9 = regen_contracts.regenerate_contracts()
    print("LENGTH:" + str(len(f9)))
    print(f9)
    print("END_FILE")

    print("FILE:verification/type_inference_compile/src/AsyncEffectInference.lean")
    val f10 = regen_effect.regenerate_async_effect_inference()
    print("LENGTH:" + str(len(f10)))
    print(f10)
    print("END_FILE")
    0
