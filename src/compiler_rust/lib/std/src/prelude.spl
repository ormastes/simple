# Print functions (Python-style, parentheses optional)
# Usage:
#   print "hello"          # no newline
#   println "hello"        # with newline
#   print "x =", x, "y =", y
#   eprint "error!"        # to stderr
#   eprintln "error!"      # to stderr with newline
#   dbg!(expr)             # debug print with file:line
#   input "prompt: "       # read line from stdin

