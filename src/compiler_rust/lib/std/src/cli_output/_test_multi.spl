fn test_buffer_len() -> i64:
    val buffer = ["alpha", "beta", "gamma"]
    buffer.len()

fn test_starts_len() -> i64:
    val starts = [0, 5, 10]
    starts.len()

fn test_names_len() -> i64:
    val names = ["first", "second"]
    names.len()

fn test_ids_len() -> i64:
    val ids = [101, 102, 103, 104]
    ids.len()
