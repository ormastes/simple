# Core Module - Variant-agnostic pure utilities
# No allocation, no side effects

#[variant(any)]
mod core

# Fundamental types and traits
export option.*
export result.*
export traits.*

# Collection traits and types
export collections.*
export list.*
export array.*
export set.*
export string.*

# JSON support
export json.*

# Math and numeric utilities
export math.*

# Random number generation
export random.*

# Regular expressions
export regex.*

# Synchronization primitives
export synchronization.*

# Domain-specific languages
export dsl.*

# Decorator support
export decorators.*

# Context management
export context.*

# Resource cleanup
export resource.*
export resource_registry.*
export leak_tracked.*

