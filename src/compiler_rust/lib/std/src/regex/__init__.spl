# Regular Expression Module
#
# Provides pattern matching, searching, and text transformation using regex.
# Built on Rust's regex crate for high performance and safety.

# Re-export all functions from mod.spl
export mod.*

# Re-exported from mod.spl
export Match
export is_match, find, find_all, captures
export replace, replace_all
export split, split_n
export extract_all, count_matches, matches, replace_with
export EMAIL_PATTERN, URL_PATTERN, INTEGER_PATTERN, FLOAT_PATTERN
export WHITESPACE_PATTERN, WORD_PATTERN, HEX_COLOR_PATTERN
export is_email, is_url, is_integer, is_float
