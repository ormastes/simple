# PTY (Pseudo-Terminal) System Library
#
# Provides low-level PTY operations for terminal I/O testing and multiplexing.

# Runtime externs — implemented in src/runtime/runtime_pty.c (compiled mode)
# and src/compiler_rust/compiler/src/interpreter_extern/pty.rs (interpreter mode).
#
# rt_pty_open(rows, cols) -> i32
#   Opens a POSIX PTY pair.  Returns the master fd on success, or -1 on error.
#   The slave fd is tracked internally and released by rt_pty_spawn.
#
# rt_pty_spawn(master_fd, shell) -> i64
#   Forks a shell process on the slave side of the PTY.
#   Returns the child PID on success, or -1 on error.
extern fn rt_pty_open(rows: i32, cols: i32) -> i32
extern fn rt_pty_spawn(master_fd: i32, shell: text) -> i64

# Legacy SFFI declarations (interpreter testing helpers)
extern fn native_pty_openpty()
extern fn native_pty_write(fd: i32, data: text) -> bool
extern fn native_pty_read(fd: i32, timeout_ms: i32) -> text
extern fn native_pty_close(fd: i32) -> bool

def openpty():
    """
    Open a new pseudo-terminal pair.

    Returns:
        (master_fd, slave_fd) - File descriptors for master and slave ends
    """
    return native_pty_openpty()

def write(fd: i32, data: text) -> bool:
    """
    Write data to a PTY file descriptor.

    Args:
        fd: File descriptor
        data: Data to write

    Returns:
        True on success, False on failure
    """
    return native_pty_write(fd, data)

def read(fd: i32, timeout_ms: i32 = 1000) -> text:
    """
    Read data from a PTY file descriptor with timeout.

    Args:
        fd: File descriptor
        timeout_ms: Timeout in milliseconds (default: 1000)

    Returns:
        text of data read, or empty string on timeout
    """
    return native_pty_read(fd, timeout_ms)

def close(fd: i32) -> bool:
    """
    Close a PTY file descriptor.

    Args:
        fd: File descriptor to close

    Returns:
        True on success, False on failure
    """
    return native_pty_close(fd)
