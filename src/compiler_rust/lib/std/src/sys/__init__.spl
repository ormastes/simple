# Sys Module - Tier 2: OS/Platform (file I/O, env, process)
#
# Provides OS-level operations including filesystem, environment,
# process control, and time. Not available on baremetal targets.
# Import via: use std.sys.*

@variant(platform_host)
mod sys

# Re-export existing sys modules
export args.*
export env.*
export process.*

# FFI declarations for OS operations
export ffi.*

# Re-exported from args.spl
export count, get, all, program_name, args, has, get_flag_value, positional

# Re-exported from env.spl
export get, get_or, get_opt, set, remove, exists, all
export cwd, home, temp
export path, user, shell, lang, term
