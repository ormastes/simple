class Foo:
    pos: i64

impl Foo:
    me advance() -> i64:
        self.pos = self.pos + 1
        self.pos

    me step() -> i64:
        val result = if true:
            self.advance()
        else:
            0
        print("  [step] result={result}, self.pos = {self.pos}")
        result

var f = Foo(pos: 0)
val r = f.step()
print("f.pos = {f.pos}, r = {r}")

