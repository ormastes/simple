# Coverage doctests — mix of nil-producing and non-nil expressions
# Exercises the false branch of `if __repl_val != nil: print __repl_val`

# Non-nil: exercises true branch of repl wrapper
>>> 1 + 1
2
>>> 42
42
>>> "hello"
hello
>>> true
true

# Nil-producing: print returns nil
>>> print "output only"
output only

# Nil-producing: variable declarations
>>> a = 10
>>> b = 20

# Non-nil: reading variables back
>>> a
10
>>> b
20
>>> a + b
30

# More nil-producing: print calls
>>> print "another side effect"
another side effect
>>> print "done"
done
