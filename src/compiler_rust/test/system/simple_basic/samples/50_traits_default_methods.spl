# 50_traits_default_methods.spl - Traits with default methods

trait Printable:
    fn stringify() -> text
    fn print_self():
        print self.stringify()

struct User:
    name: text

impl Printable for User:
    fn stringify() -> text:
        return "User(name={self.name})"

val u = User(name: "Kim")
u.print_self()

main = 0
