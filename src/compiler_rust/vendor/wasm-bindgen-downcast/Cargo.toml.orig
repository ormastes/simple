[package]
name = "wasm-bindgen-downcast"
description = "Downcast a JavaScript wrapper generated by `wasm-bindgen` back to its original struct."
authors = ["Wasmer Engineering Team <engineering@wasmer.io>"]
edition = "2021"
homepage = "https://wasmer.io/"
license = "MIT OR Apache-2.0"
readme = "../../README.md"
repository = "https://github.com/wasmerio/wasm-bindgen-downcast.git"
rust-version = "1.63"
version = "0.1.1"

# See more keys and their definitions at https://doc.rust-lang.org/cargo/reference/manifest.html

[dependencies]
js-sys = "0.3.60"
once_cell = "1.16.0"
wasm-bindgen = "0.2.83"
wasm-bindgen-downcast-macros = { path = "../macros", version = "0.1.1" }
