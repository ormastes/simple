# Unit: Magnitude
# Kind: AstronomyBrightness
# Symbol: magnitude
# Canonical scale: 1.0 mag

class Magnitude:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Magnitude) -> Magnitude: Magnitude(value: self.value + other.value)
    fn sub(other: Magnitude) -> Magnitude: Magnitude(value: self.value - other.value)

    static fn kind() -> text: "AstronomyBrightness"
    static fn symbol() -> text: "magnitude"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "mag"
    static fn zero() -> Magnitude: Magnitude(value: 0.0)

export Magnitude
