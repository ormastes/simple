# Unit: En
# Kind: Typography
# Symbol: en
# Canonical scale: 0.5 em

class En:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: En) -> En: En(value: self.value + other.value)
    fn sub(other: En) -> En: En(value: self.value - other.value)

    static fn kind() -> text: "Typography"
    static fn symbol() -> text: "en"
    static fn scale_to_base() -> f64: 0.5
    static fn base_unit() -> text: "em"
    static fn zero() -> En: En(value: 0.0)

export En
