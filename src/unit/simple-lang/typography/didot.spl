# Unit: Didot
# Kind: Typography
# Symbol: didot
# Canonical scale: 0.375 mm

class Didot:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Didot) -> Didot: Didot(value: self.value + other.value)
    fn sub(other: Didot) -> Didot: Didot(value: self.value - other.value)

    static fn kind() -> text: "Typography"
    static fn symbol() -> text: "didot"
    static fn scale_to_base() -> f64: 0.375
    static fn base_unit() -> text: "mm"
    static fn zero() -> Didot: Didot(value: 0.0)

export Didot
