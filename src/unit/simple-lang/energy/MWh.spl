# Unit: MegaWattHour
# Kind: Energy
# Symbol: MWh
# Canonical scale: 3600000000.0 J

class MegaWattHour:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MegaWattHour) -> MegaWattHour: MegaWattHour(value: self.value + other.value)
    fn sub(other: MegaWattHour) -> MegaWattHour: MegaWattHour(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "MWh"
    static fn scale_to_base() -> f64: 3600000000.0
    static fn base_unit() -> text: "J"
    static fn zero() -> MegaWattHour: MegaWattHour(value: 0.0)

export MegaWattHour
