# Unit: Btu
# Kind: Energy
# Symbol: BTU
# Canonical scale: 1055.05585262 J

class Btu:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Btu) -> Btu: Btu(value: self.value + other.value)
    fn sub(other: Btu) -> Btu: Btu(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "BTU"
    static fn scale_to_base() -> f64: 1055.05585262
    static fn base_unit() -> text: "J"
    static fn zero() -> Btu: Btu(value: 0.0)

export Btu
