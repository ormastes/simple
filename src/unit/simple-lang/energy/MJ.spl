# Unit: MegaJoule
# Kind: Energy
# Symbol: MJ
# Canonical scale: 1000000.0 J

class MegaJoule:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MegaJoule) -> MegaJoule: MegaJoule(value: self.value + other.value)
    fn sub(other: MegaJoule) -> MegaJoule: MegaJoule(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "MJ"
    static fn scale_to_base() -> f64: 1000000.0
    static fn base_unit() -> text: "J"
    static fn zero() -> MegaJoule: MegaJoule(value: 0.0)

export MegaJoule
