# Unit: KiloJoule
# Kind: Energy
# Symbol: kJ
# Canonical scale: 1000.0 J

class KiloJoule:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KiloJoule) -> KiloJoule: KiloJoule(value: self.value + other.value)
    fn sub(other: KiloJoule) -> KiloJoule: KiloJoule(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "kJ"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "J"
    static fn zero() -> KiloJoule: KiloJoule(value: 0.0)

export KiloJoule
