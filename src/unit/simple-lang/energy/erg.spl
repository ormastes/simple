# Unit: Erg
# Kind: Energy
# Symbol: erg
# Canonical scale: 1e-07 J

class Erg:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Erg) -> Erg: Erg(value: self.value + other.value)
    fn sub(other: Erg) -> Erg: Erg(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "erg"
    static fn scale_to_base() -> f64: 1e-07
    static fn base_unit() -> text: "J"
    static fn zero() -> Erg: Erg(value: 0.0)

export Erg
