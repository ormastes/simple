# Unit: Smidgen
# Kind: Culinary
# Symbol: smidgen
# Canonical scale: 0.15 mL

class Smidgen:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Smidgen) -> Smidgen: Smidgen(value: self.value + other.value)
    fn sub(other: Smidgen) -> Smidgen: Smidgen(value: self.value - other.value)

    static fn kind() -> text: "Culinary"
    static fn symbol() -> text: "smidgen"
    static fn scale_to_base() -> f64: 0.15
    static fn base_unit() -> text: "mL"
    static fn zero() -> Smidgen: Smidgen(value: 0.0)

export Smidgen
