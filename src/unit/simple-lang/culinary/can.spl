# Unit: Can
# Kind: Culinary
# Symbol: can
# Canonical scale: 1.0 can

class Can:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Can) -> Can: Can(value: self.value + other.value)
    fn sub(other: Can) -> Can: Can(value: self.value - other.value)

    static fn kind() -> text: "Culinary"
    static fn symbol() -> text: "can"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "can"
    static fn zero() -> Can: Can(value: 0.0)

export Can
