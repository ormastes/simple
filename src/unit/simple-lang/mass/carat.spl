# Unit: Carat
# Kind: Mass
# Symbol: carat
# Canonical scale: 0.0002 kg

class Carat:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Carat) -> Carat: Carat(value: self.value + other.value)
    fn sub(other: Carat) -> Carat: Carat(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "carat"
    static fn scale_to_base() -> f64: 0.0002
    static fn base_unit() -> text: "kg"
    static fn zero() -> Carat: Carat(value: 0.0)

export Carat
