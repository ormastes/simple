# Unit: Oz
# Kind: Mass
# Symbol: oz
# Canonical scale: 0.0283495231 kg

class Oz:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Oz) -> Oz: Oz(value: self.value + other.value)
    fn sub(other: Oz) -> Oz: Oz(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "oz"
    static fn scale_to_base() -> f64: 0.0283495231
    static fn base_unit() -> text: "kg"
    static fn zero() -> Oz: Oz(value: 0.0)

export Oz
