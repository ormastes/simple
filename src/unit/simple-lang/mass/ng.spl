# Unit: Ng
# Kind: Mass
# Symbol: ng
# Canonical scale: 1e-12 kg

class Ng:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ng) -> Ng: Ng(value: self.value + other.value)
    fn sub(other: Ng) -> Ng: Ng(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "ng"
    static fn scale_to_base() -> f64: 1e-12
    static fn base_unit() -> text: "kg"
    static fn zero() -> Ng: Ng(value: 0.0)

export Ng
