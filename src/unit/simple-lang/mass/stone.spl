# Unit: Stone
# Kind: Mass
# Symbol: stone
# Canonical scale: 6.35029318 kg

class Stone:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Stone) -> Stone: Stone(value: self.value + other.value)
    fn sub(other: Stone) -> Stone: Stone(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "stone"
    static fn scale_to_base() -> f64: 6.35029318
    static fn base_unit() -> text: "kg"
    static fn zero() -> Stone: Stone(value: 0.0)

export Stone
