# Unit: Amu
# Kind: Mass
# Symbol: amu
# Canonical scale: 1.6605390666e-27 kg

class Amu:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Amu) -> Amu: Amu(value: self.value + other.value)
    fn sub(other: Amu) -> Amu: Amu(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "amu"
    static fn scale_to_base() -> f64: 1.6605390666e-27
    static fn base_unit() -> text: "kg"
    static fn zero() -> Amu: Amu(value: 0.0)

export Amu
