# Unit: SolarMass
# Kind: Mass
# Symbol: solar_mass
# Canonical scale: 1.98892e+30 kg

class SolarMass:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: SolarMass) -> SolarMass: SolarMass(value: self.value + other.value)
    fn sub(other: SolarMass) -> SolarMass: SolarMass(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "solar_mass"
    static fn scale_to_base() -> f64: 1.98892e+30
    static fn base_unit() -> text: "kg"
    static fn zero() -> SolarMass: SolarMass(value: 0.0)

export SolarMass
