# Unit: G
# Kind: Mass
# Symbol: g
# Canonical scale: 0.001 kg

class G:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: G) -> G: G(value: self.value + other.value)
    fn sub(other: G) -> G: G(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "g"
    static fn scale_to_base() -> f64: 0.001
    static fn base_unit() -> text: "kg"
    static fn zero() -> G: G(value: 0.0)

export G
