# Unit: TonUs
# Kind: Mass
# Symbol: ton_us
# Canonical scale: 907.18474 kg

class TonUs:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: TonUs) -> TonUs: TonUs(value: self.value + other.value)
    fn sub(other: TonUs) -> TonUs: TonUs(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "ton_us"
    static fn scale_to_base() -> f64: 907.18474
    static fn base_unit() -> text: "kg"
    static fn zero() -> TonUs: TonUs(value: 0.0)

export TonUs
