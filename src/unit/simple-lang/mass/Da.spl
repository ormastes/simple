# Unit: Dalton
# Kind: Mass
# Symbol: Da
# Canonical scale: 1.6605390666e-27 kg

class Dalton:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Dalton) -> Dalton: Dalton(value: self.value + other.value)
    fn sub(other: Dalton) -> Dalton: Dalton(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "Da"
    static fn scale_to_base() -> f64: 1.6605390666e-27
    static fn base_unit() -> text: "kg"
    static fn zero() -> Dalton: Dalton(value: 0.0)

export Dalton
