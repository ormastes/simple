# Unit: Slug
# Kind: Mass
# Symbol: slug
# Canonical scale: 14.5939029372 kg

class Slug:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Slug) -> Slug: Slug(value: self.value + other.value)
    fn sub(other: Slug) -> Slug: Slug(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "slug"
    static fn scale_to_base() -> f64: 14.5939029372
    static fn base_unit() -> text: "kg"
    static fn zero() -> Slug: Slug(value: 0.0)

export Slug
