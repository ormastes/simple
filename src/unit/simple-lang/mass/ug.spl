# Unit: Ug
# Kind: Mass
# Symbol: ug
# Canonical scale: 1e-09 kg

class Ug:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ug) -> Ug: Ug(value: self.value + other.value)
    fn sub(other: Ug) -> Ug: Ug(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "ug"
    static fn scale_to_base() -> f64: 1e-09
    static fn base_unit() -> text: "kg"
    static fn zero() -> Ug: Ug(value: 0.0)

export Ug
