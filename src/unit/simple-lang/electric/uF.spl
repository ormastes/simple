# Unit: MicroFarad
# Kind: Capacitance
# Symbol: uF
# Canonical scale: 1e-06 F

class MicroFarad:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MicroFarad) -> MicroFarad: MicroFarad(value: self.value + other.value)
    fn sub(other: MicroFarad) -> MicroFarad: MicroFarad(value: self.value - other.value)

    static fn kind() -> text: "Capacitance"
    static fn symbol() -> text: "uF"
    static fn scale_to_base() -> f64: 1e-06
    static fn base_unit() -> text: "F"
    static fn zero() -> MicroFarad: MicroFarad(value: 0.0)

export MicroFarad
