# Unit: Farad
# Kind: Capacitance
# Symbol: F
# Canonical scale: 1.0 F

class Farad:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Farad) -> Farad: Farad(value: self.value + other.value)
    fn sub(other: Farad) -> Farad: Farad(value: self.value - other.value)

    static fn kind() -> text: "Capacitance"
    static fn symbol() -> text: "F"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "F"
    static fn zero() -> Farad: Farad(value: 0.0)

export Farad
