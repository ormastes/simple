# Unit: MegaOhm
# Kind: ElectricResistance
# Symbol: Mohm
# Canonical scale: 1000000.0 ohm

class MegaOhm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MegaOhm) -> MegaOhm: MegaOhm(value: self.value + other.value)
    fn sub(other: MegaOhm) -> MegaOhm: MegaOhm(value: self.value - other.value)

    static fn kind() -> text: "ElectricResistance"
    static fn symbol() -> text: "Mohm"
    static fn scale_to_base() -> f64: 1000000.0
    static fn base_unit() -> text: "ohm"
    static fn zero() -> MegaOhm: MegaOhm(value: 0.0)

export MegaOhm
