# Unit: KiloVolt
# Kind: ElectricPotential
# Symbol: kV
# Canonical scale: 1000.0 V

class KiloVolt:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KiloVolt) -> KiloVolt: KiloVolt(value: self.value + other.value)
    fn sub(other: KiloVolt) -> KiloVolt: KiloVolt(value: self.value - other.value)

    static fn kind() -> text: "ElectricPotential"
    static fn symbol() -> text: "kV"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "V"
    static fn zero() -> KiloVolt: KiloVolt(value: 0.0)

export KiloVolt
