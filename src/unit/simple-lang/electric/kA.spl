# Unit: KiloAmp
# Kind: ElectricCurrent
# Symbol: kA
# Canonical scale: 1000.0 A

class KiloAmp:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KiloAmp) -> KiloAmp: KiloAmp(value: self.value + other.value)
    fn sub(other: KiloAmp) -> KiloAmp: KiloAmp(value: self.value - other.value)

    static fn kind() -> text: "ElectricCurrent"
    static fn symbol() -> text: "kA"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "A"
    static fn zero() -> KiloAmp: KiloAmp(value: 0.0)

export KiloAmp
