# Unit: Volt
# Kind: ElectricPotential
# Symbol: V
# Canonical scale: 1.0 V

class Volt:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Volt) -> Volt: Volt(value: self.value + other.value)
    fn sub(other: Volt) -> Volt: Volt(value: self.value - other.value)

    static fn kind() -> text: "ElectricPotential"
    static fn symbol() -> text: "V"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "V"
    static fn zero() -> Volt: Volt(value: 0.0)

export Volt
