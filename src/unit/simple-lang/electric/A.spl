# Unit: Amp
# Kind: ElectricCurrent
# Symbol: A
# Canonical scale: 1.0 A

class Amp:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Amp) -> Amp: Amp(value: self.value + other.value)
    fn sub(other: Amp) -> Amp: Amp(value: self.value - other.value)

    static fn kind() -> text: "ElectricCurrent"
    static fn symbol() -> text: "A"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "A"
    static fn zero() -> Amp: Amp(value: 0.0)

export Amp
