# Unit: KiloOhm
# Kind: ElectricResistance
# Symbol: kohm
# Canonical scale: 1000.0 ohm

class KiloOhm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KiloOhm) -> KiloOhm: KiloOhm(value: self.value + other.value)
    fn sub(other: KiloOhm) -> KiloOhm: KiloOhm(value: self.value - other.value)

    static fn kind() -> text: "ElectricResistance"
    static fn symbol() -> text: "kohm"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "ohm"
    static fn zero() -> KiloOhm: KiloOhm(value: 0.0)

export KiloOhm
