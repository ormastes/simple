# Unit: Henry
# Kind: Inductance
# Symbol: H
# Canonical scale: 1.0 H

class Henry:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Henry) -> Henry: Henry(value: self.value + other.value)
    fn sub(other: Henry) -> Henry: Henry(value: self.value - other.value)

    static fn kind() -> text: "Inductance"
    static fn symbol() -> text: "H"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "H"
    static fn zero() -> Henry: Henry(value: 0.0)

export Henry
