# Composite Unit: KgPerM3
# Kind: Density
# Symbol: kg_per_m3
# Scale to SI base: 1.0 kg/m^3

class KgPerM3:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KgPerM3) -> KgPerM3: KgPerM3(value: self.value + other.value)
    fn sub(other: KgPerM3) -> KgPerM3: KgPerM3(value: self.value - other.value)

    static fn kind() -> text: "Density"
    static fn symbol() -> text: "kg_per_m3"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "kg/m^3"
    static fn numerator() -> [text]: ["kg"]
    static fn denominator() -> [text]: ["m", "m", "m"]
    static fn zero() -> KgPerM3: KgPerM3(value: 0.0)

export KgPerM3
