# Composite Unit: WperM2
# Kind: HeatFlux
# Symbol: W_per_m2
# Scale to SI base: 1.0 W/m^2

class WperM2:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: WperM2) -> WperM2: WperM2(value: self.value + other.value)
    fn sub(other: WperM2) -> WperM2: WperM2(value: self.value - other.value)

    static fn kind() -> text: "HeatFlux"
    static fn symbol() -> text: "W_per_m2"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "W/m^2"
    static fn numerator() -> [text]: ["W"]
    static fn denominator() -> [text]: ["m", "m"]
    static fn zero() -> WperM2: WperM2(value: 0.0)

export WperM2
