# Composite Unit: NperM2
# Kind: Pressure
# Symbol: N_per_m2
# Scale to SI base: 1.0 Pa

class NperM2:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: NperM2) -> NperM2: NperM2(value: self.value + other.value)
    fn sub(other: NperM2) -> NperM2: NperM2(value: self.value - other.value)

    static fn kind() -> text: "Pressure"
    static fn symbol() -> text: "N_per_m2"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "Pa"
    static fn numerator() -> [text]: ["N"]
    static fn denominator() -> [text]: ["m", "m"]
    static fn zero() -> NperM2: NperM2(value: 0.0)

export NperM2
