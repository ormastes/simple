# Composite Unit: HzComp
# Kind: Frequency
# Symbol: Hz_c
# Scale to SI base: 1.0 Hz

class HzComp:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: HzComp) -> HzComp: HzComp(value: self.value + other.value)
    fn sub(other: HzComp) -> HzComp: HzComp(value: self.value - other.value)

    static fn kind() -> text: "Frequency"
    static fn symbol() -> text: "Hz_c"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "Hz"
    static fn numerator() -> [text]: ["cycle"]
    static fn denominator() -> [text]: ["s"]
    static fn zero() -> HzComp: HzComp(value: 0.0)

export HzComp
