# Composite Unit: WattHourC
# Kind: Energy
# Symbol: Wh_c
# Scale to SI base: 3600.0 J

class WattHourC:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: WattHourC) -> WattHourC: WattHourC(value: self.value + other.value)
    fn sub(other: WattHourC) -> WattHourC: WattHourC(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "Wh_c"
    static fn scale_to_base() -> f64: 3600.0
    static fn base_unit() -> text: "J"
    static fn numerator() -> [text]: ["W", "h"]
    static fn denominator() -> [text]: []
    static fn zero() -> WattHourC: WattHourC(value: 0.0)

export WattHourC
