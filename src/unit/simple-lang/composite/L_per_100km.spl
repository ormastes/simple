# Composite Unit: LPer100Km
# Kind: FuelEconomy
# Symbol: L_per_100km
# Scale to SI base: 1.0 L/100km

class LPer100Km:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: LPer100Km) -> LPer100Km: LPer100Km(value: self.value + other.value)
    fn sub(other: LPer100Km) -> LPer100Km: LPer100Km(value: self.value - other.value)

