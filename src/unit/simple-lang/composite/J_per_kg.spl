# Composite Unit: JperKg
# Kind: SpecificEnergy
# Symbol: J_per_kg
# Scale to SI base: 1.0 J/kg

class JperKg:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: JperKg) -> JperKg: JperKg(value: self.value + other.value)
    fn sub(other: JperKg) -> JperKg: JperKg(value: self.value - other.value)

    static fn kind() -> text: "SpecificEnergy"
    static fn symbol() -> text: "J_per_kg"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "J/kg"
    static fn numerator() -> [text]: ["J"]
    static fn denominator() -> [text]: ["kg"]
    static fn zero() -> JperKg: JperKg(value: 0.0)

export JperKg
