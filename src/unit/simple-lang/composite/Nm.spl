# Composite Unit: NewtonMetre
# Kind: Torque
# Symbol: Nm
# Scale to SI base: 1.0 N*m

class NewtonMetre:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: NewtonMetre) -> NewtonMetre: NewtonMetre(value: self.value + other.value)
    fn sub(other: NewtonMetre) -> NewtonMetre: NewtonMetre(value: self.value - other.value)

    static fn kind() -> text: "Torque"
    static fn symbol() -> text: "Nm"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "N*m"
    static fn numerator() -> [text]: ["N", "m"]
    static fn denominator() -> [text]: []
    static fn zero() -> NewtonMetre: NewtonMetre(value: 0.0)

export NewtonMetre
