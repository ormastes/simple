# Composite Unit: KiloWattHourC
# Kind: Energy
# Symbol: kWh_c
# Scale to SI base: 3600000.0 J

class KiloWattHourC:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KiloWattHourC) -> KiloWattHourC: KiloWattHourC(value: self.value + other.value)
    fn sub(other: KiloWattHourC) -> KiloWattHourC: KiloWattHourC(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "kWh_c"
    static fn scale_to_base() -> f64: 3600000.0
    static fn base_unit() -> text: "J"
    static fn numerator() -> [text]: ["kW", "h"]
    static fn denominator() -> [text]: []
    static fn zero() -> KiloWattHourC: KiloWattHourC(value: 0.0)

export KiloWattHourC
