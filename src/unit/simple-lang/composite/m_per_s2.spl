# Composite Unit: MperS2
# Kind: Acceleration
# Symbol: m_per_s2
# Scale to SI base: 1.0 m/s^2

class MperS2:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MperS2) -> MperS2: MperS2(value: self.value + other.value)
    fn sub(other: MperS2) -> MperS2: MperS2(value: self.value - other.value)

    static fn kind() -> text: "Acceleration"
    static fn symbol() -> text: "m_per_s2"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "m/s^2"
    static fn numerator() -> [text]: ["m"]
    static fn denominator() -> [text]: ["s", "s"]
    static fn zero() -> MperS2: MperS2(value: 0.0)

export MperS2
