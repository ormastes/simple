# Composite Unit: BpmC
# Kind: Frequency
# Symbol: bpm_c
# Scale to SI base: 0.016666666666666666 Hz

class BpmC:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: BpmC) -> BpmC: BpmC(value: self.value + other.value)
    fn sub(other: BpmC) -> BpmC: BpmC(value: self.value - other.value)

    static fn kind() -> text: "Frequency"
    static fn symbol() -> text: "bpm_c"
    static fn scale_to_base() -> f64: 0.016666666666666666
    static fn base_unit() -> text: "Hz"
    static fn numerator() -> [text]: ["beat"]
    static fn denominator() -> [text]: ["min"]
    static fn zero() -> BpmC: BpmC(value: 0.0)

export BpmC
