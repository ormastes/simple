# Composite Unit: RPMc
# Kind: Frequency
# Symbol: RPM
# Scale to SI base: 0.016666666666666666 Hz

class RPMc:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: RPMc) -> RPMc: RPMc(value: self.value + other.value)
    fn sub(other: RPMc) -> RPMc: RPMc(value: self.value - other.value)

    static fn kind() -> text: "Frequency"
    static fn symbol() -> text: "RPM"
    static fn scale_to_base() -> f64: 0.016666666666666666
    static fn base_unit() -> text: "Hz"
    static fn numerator() -> [text]: ["rev"]
    static fn denominator() -> [text]: ["min"]
    static fn zero() -> RPMc: RPMc(value: 0.0)

export RPMc
