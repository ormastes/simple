# Composite Unit: WattHour
# Kind: Energy
# Symbol: Wh
# Scale to SI base: 3600.0 J

class WattHour:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: WattHour) -> WattHour: WattHour(value: self.value + other.value)
    fn sub(other: WattHour) -> WattHour: WattHour(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "Wh"
    static fn scale_to_base() -> f64: 3600.0
    static fn base_unit() -> text: "J"
    static fn numerator() -> [text]: ["W", "h"]
    static fn denominator() -> [text]: []
    static fn zero() -> WattHour: WattHour(value: 0.0)

export WattHour
