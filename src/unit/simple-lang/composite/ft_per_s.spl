# Composite Unit: FtPerS
# Kind: Velocity
# Symbol: ft_per_s
# Scale to SI base: 0.3048 m/s

class FtPerS:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: FtPerS) -> FtPerS: FtPerS(value: self.value + other.value)
    fn sub(other: FtPerS) -> FtPerS: FtPerS(value: self.value - other.value)

    static fn kind() -> text: "Velocity"
    static fn symbol() -> text: "ft_per_s"
    static fn scale_to_base() -> f64: 0.3048
    static fn base_unit() -> text: "m/s"
    static fn numerator() -> [text]: ["ft"]
    static fn denominator() -> [text]: ["s"]
    static fn zero() -> FtPerS: FtPerS(value: 0.0)

export FtPerS
