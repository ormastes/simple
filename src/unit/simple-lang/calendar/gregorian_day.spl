# Unit: GregorianDay
# Kind: CalendarDay
# Symbol: gregorian_day
# Canonical scale: 1.0 day

class GregorianDay:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: GregorianDay) -> GregorianDay: GregorianDay(value: self.value + other.value)
    fn sub(other: GregorianDay) -> GregorianDay: GregorianDay(value: self.value - other.value)

    static fn kind() -> text: "CalendarDay"
    static fn symbol() -> text: "gregorian_day"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "day"
    static fn zero() -> GregorianDay: GregorianDay(value: 0.0)

export GregorianDay
