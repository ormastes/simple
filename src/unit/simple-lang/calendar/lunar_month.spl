# Unit: LunarMonth
# Kind: CalendarMonth
# Symbol: lunar_month
# Canonical scale: 29.53059 day

class LunarMonth:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: LunarMonth) -> LunarMonth: LunarMonth(value: self.value + other.value)
    fn sub(other: LunarMonth) -> LunarMonth: LunarMonth(value: self.value - other.value)

    static fn kind() -> text: "CalendarMonth"
    static fn symbol() -> text: "lunar_month"
    static fn scale_to_base() -> f64: 29.53059
    static fn base_unit() -> text: "day"
    static fn zero() -> LunarMonth: LunarMonth(value: 0.0)

export LunarMonth
