# Unit: GregorianYear
# Kind: CalendarYear
# Symbol: gregorian_year
# Canonical scale: 365.2425 day

class GregorianYear:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: GregorianYear) -> GregorianYear: GregorianYear(value: self.value + other.value)
    fn sub(other: GregorianYear) -> GregorianYear: GregorianYear(value: self.value - other.value)

    static fn kind() -> text: "CalendarYear"
    static fn symbol() -> text: "gregorian_year"
    static fn scale_to_base() -> f64: 365.2425
    static fn base_unit() -> text: "day"
    static fn zero() -> GregorianYear: GregorianYear(value: 0.0)

export GregorianYear
