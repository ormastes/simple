# Unit: TropicalYear
# Kind: CalendarYear
# Symbol: tropical_year
# Canonical scale: 365.24219 day

class TropicalYear:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: TropicalYear) -> TropicalYear: TropicalYear(value: self.value + other.value)
    fn sub(other: TropicalYear) -> TropicalYear: TropicalYear(value: self.value - other.value)

    static fn kind() -> text: "CalendarYear"
    static fn symbol() -> text: "tropical_year"
    static fn scale_to_base() -> f64: 365.24219
    static fn base_unit() -> text: "day"
    static fn zero() -> TropicalYear: TropicalYear(value: 0.0)

export TropicalYear
