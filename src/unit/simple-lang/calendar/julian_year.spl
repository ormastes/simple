# Unit: JulianYearCal
# Kind: CalendarYear
# Symbol: julian_year
# Canonical scale: 365.25 day

class JulianYearCal:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: JulianYearCal) -> JulianYearCal: JulianYearCal(value: self.value + other.value)
    fn sub(other: JulianYearCal) -> JulianYearCal: JulianYearCal(value: self.value - other.value)

    static fn kind() -> text: "CalendarYear"
    static fn symbol() -> text: "julian_year"
    static fn scale_to_base() -> f64: 365.25
    static fn base_unit() -> text: "day"
    static fn zero() -> JulianYearCal: JulianYearCal(value: 0.0)

export JulianYearCal
