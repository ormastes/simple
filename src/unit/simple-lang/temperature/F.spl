# Unit: F
# Kind: Temperature
# Symbol: F
# Canonical scale: 0.5555555555555556 K

class F:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: F) -> F: F(value: self.value + other.value)
    fn sub(other: F) -> F: F(value: self.value - other.value)

    static fn kind() -> text: "Temperature"
    static fn symbol() -> text: "F"
    static fn scale_to_base() -> f64: 0.5555555555555556
    static fn base_unit() -> text: "K"
    static fn zero() -> F: F(value: 0.0)

export F
