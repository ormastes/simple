# Unit: K
# Kind: Temperature
# Symbol: K
# Canonical scale: 1.0 K

class K:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: K) -> K: K(value: self.value + other.value)
    fn sub(other: K) -> K: K(value: self.value - other.value)

    static fn kind() -> text: "Temperature"
    static fn symbol() -> text: "K"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "K"
    static fn zero() -> K: K(value: 0.0)

export K
