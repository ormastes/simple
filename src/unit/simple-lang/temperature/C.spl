# Unit: C
# Kind: Temperature
# Symbol: C
# Canonical scale: 1.0 K

class C:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: C) -> C: C(value: self.value + other.value)
    fn sub(other: C) -> C: C(value: self.value - other.value)

    static fn kind() -> text: "Temperature"
    static fn symbol() -> text: "C"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "K"
    static fn zero() -> C: C(value: 0.0)

export C
