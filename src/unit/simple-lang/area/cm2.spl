# Unit: Cm2
# Kind: Area
# Symbol: cm2
# Canonical scale: 0.0001 m2

class Cm2:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Cm2) -> Cm2: Cm2(value: self.value + other.value)
    fn sub(other: Cm2) -> Cm2: Cm2(value: self.value - other.value)

    static fn kind() -> text: "Area"
    static fn symbol() -> text: "cm2"
    static fn scale_to_base() -> f64: 0.0001
    static fn base_unit() -> text: "m2"
    static fn zero() -> Cm2: Cm2(value: 0.0)

export Cm2
