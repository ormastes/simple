# Unit: M2
# Kind: Area
# Symbol: m2
# Canonical scale: 1.0 m2

class M2:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: M2) -> M2: M2(value: self.value + other.value)
    fn sub(other: M2) -> M2: M2(value: self.value - other.value)

    static fn kind() -> text: "Area"
    static fn symbol() -> text: "m2"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "m2"
    static fn zero() -> M2: M2(value: 0.0)

export M2
