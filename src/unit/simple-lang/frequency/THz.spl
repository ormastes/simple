# Unit: TeraHertz
# Kind: Frequency
# Symbol: THz
# Canonical scale: 1000000000000.0 Hz

class TeraHertz:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: TeraHertz) -> TeraHertz: TeraHertz(value: self.value + other.value)
    fn sub(other: TeraHertz) -> TeraHertz: TeraHertz(value: self.value - other.value)

    static fn kind() -> text: "Frequency"
    static fn symbol() -> text: "THz"
    static fn scale_to_base() -> f64: 1000000000000.0
    static fn base_unit() -> text: "Hz"
    static fn zero() -> TeraHertz: TeraHertz(value: 0.0)

export TeraHertz
