# Unit: GigaHertz
# Kind: Frequency
# Symbol: GHz
# Canonical scale: 1000000000.0 Hz

class GigaHertz:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: GigaHertz) -> GigaHertz: GigaHertz(value: self.value + other.value)
    fn sub(other: GigaHertz) -> GigaHertz: GigaHertz(value: self.value - other.value)

    static fn kind() -> text: "Frequency"
    static fn symbol() -> text: "GHz"
    static fn scale_to_base() -> f64: 1000000000.0
    static fn base_unit() -> text: "Hz"
    static fn zero() -> GigaHertz: GigaHertz(value: 0.0)

export GigaHertz
