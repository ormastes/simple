# Unit: Rpm
# Kind: Frequency
# Symbol: rpm
# Canonical scale: 0.016666666666666666 Hz

class Rpm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Rpm) -> Rpm: Rpm(value: self.value + other.value)
    fn sub(other: Rpm) -> Rpm: Rpm(value: self.value - other.value)

    static fn kind() -> text: "Frequency"
    static fn symbol() -> text: "rpm"
    static fn scale_to_base() -> f64: 0.016666666666666666
    static fn base_unit() -> text: "Hz"
    static fn zero() -> Rpm: Rpm(value: 0.0)

export Rpm
