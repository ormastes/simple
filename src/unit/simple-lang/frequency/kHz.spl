# Unit: KiloHertz
# Kind: Frequency
# Symbol: kHz
# Canonical scale: 1000.0 Hz

class KiloHertz:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KiloHertz) -> KiloHertz: KiloHertz(value: self.value + other.value)
    fn sub(other: KiloHertz) -> KiloHertz: KiloHertz(value: self.value - other.value)

    static fn kind() -> text: "Frequency"
    static fn symbol() -> text: "kHz"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "Hz"
    static fn zero() -> KiloHertz: KiloHertz(value: 0.0)

export KiloHertz
