# Unit: NmolAmt
# Kind: Amount
# Symbol: nmol
# Canonical scale: 1e-09 mol

class NmolAmt:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: NmolAmt) -> NmolAmt: NmolAmt(value: self.value + other.value)
    fn sub(other: NmolAmt) -> NmolAmt: NmolAmt(value: self.value - other.value)

    static fn kind() -> text: "Amount"
    static fn symbol() -> text: "nmol"
    static fn scale_to_base() -> f64: 1e-09
    static fn base_unit() -> text: "mol"
    static fn zero() -> NmolAmt: NmolAmt(value: 0.0)

export NmolAmt
