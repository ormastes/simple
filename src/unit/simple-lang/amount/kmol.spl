# Unit: Kmol
# Kind: Amount
# Symbol: kmol
# Canonical scale: 1000.0 mol

class Kmol:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Kmol) -> Kmol: Kmol(value: self.value + other.value)
    fn sub(other: Kmol) -> Kmol: Kmol(value: self.value - other.value)

    static fn kind() -> text: "Amount"
    static fn symbol() -> text: "kmol"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "mol"
    static fn zero() -> Kmol: Kmol(value: 0.0)

export Kmol
