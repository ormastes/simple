# Unit: Mol
# Kind: Amount
# Symbol: mol
# Canonical scale: 1.0 mol

class Mol:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mol) -> Mol: Mol(value: self.value + other.value)
    fn sub(other: Mol) -> Mol: Mol(value: self.value - other.value)

    static fn kind() -> text: "Amount"
    static fn symbol() -> text: "mol"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "mol"
    static fn zero() -> Mol: Mol(value: 0.0)

export Mol
