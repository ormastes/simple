# Unit: LatRad
# Kind: GeoAngle
# Symbol: lat_rad
# Canonical scale: 57.29577951308232 deg

class LatRad:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: LatRad) -> LatRad: LatRad(value: self.value + other.value)
    fn sub(other: LatRad) -> LatRad: LatRad(value: self.value - other.value)

    static fn kind() -> text: "GeoAngle"
    static fn symbol() -> text: "lat_rad"
    static fn scale_to_base() -> f64: 57.29577951308232
    static fn base_unit() -> text: "deg"
    static fn zero() -> LatRad: LatRad(value: 0.0)

export LatRad
