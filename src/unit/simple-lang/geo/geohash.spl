# Unit: Geohash
# Kind: GeoCode
# Symbol: geohash
# Canonical scale: 1.0 geohash

class Geohash:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Geohash) -> Geohash: Geohash(value: self.value + other.value)
    fn sub(other: Geohash) -> Geohash: Geohash(value: self.value - other.value)

    static fn kind() -> text: "GeoCode"
    static fn symbol() -> text: "geohash"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "geohash"
    static fn zero() -> Geohash: Geohash(value: 0.0)

export Geohash
