# Unit: AltitudeM
# Kind: GeoHeight
# Symbol: altitude_m
# Canonical scale: 1.0 m

class AltitudeM:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: AltitudeM) -> AltitudeM: AltitudeM(value: self.value + other.value)
    fn sub(other: AltitudeM) -> AltitudeM: AltitudeM(value: self.value - other.value)

    static fn kind() -> text: "GeoHeight"
    static fn symbol() -> text: "altitude_m"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "m"
    static fn zero() -> AltitudeM: AltitudeM(value: 0.0)

export AltitudeM
