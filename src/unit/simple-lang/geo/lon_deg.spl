# Unit: LonDeg
# Kind: GeoAngle
# Symbol: lon_deg
# Canonical scale: 1.0 deg

class LonDeg:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: LonDeg) -> LonDeg: LonDeg(value: self.value + other.value)
    fn sub(other: LonDeg) -> LonDeg: LonDeg(value: self.value - other.value)

    static fn kind() -> text: "GeoAngle"
    static fn symbol() -> text: "lon_deg"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "deg"
    static fn zero() -> LonDeg: LonDeg(value: 0.0)

export LonDeg
