# Unit: LonRad
# Kind: GeoAngle
# Symbol: lon_rad
# Canonical scale: 57.29577951308232 deg

class LonRad:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: LonRad) -> LonRad: LonRad(value: self.value + other.value)
    fn sub(other: LonRad) -> LonRad: LonRad(value: self.value - other.value)

    static fn kind() -> text: "GeoAngle"
    static fn symbol() -> text: "lon_rad"
    static fn scale_to_base() -> f64: 57.29577951308232
    static fn base_unit() -> text: "deg"
    static fn zero() -> LonRad: LonRad(value: 0.0)

export LonRad
