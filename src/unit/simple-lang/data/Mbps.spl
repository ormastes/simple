# Unit: Mbps
# Kind: DataRate
# Symbol: Mbps
# Canonical scale: 125000.0 B/s

class Mbps:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mbps) -> Mbps: Mbps(value: self.value + other.value)
    fn sub(other: Mbps) -> Mbps: Mbps(value: self.value - other.value)

    static fn kind() -> text: "DataRate"
    static fn symbol() -> text: "Mbps"
    static fn scale_to_base() -> f64: 125000.0
    static fn base_unit() -> text: "B/s"
    static fn zero() -> Mbps: Mbps(value: 0.0)

export Mbps
