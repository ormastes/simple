# Unit: GigaByte
# Kind: Data
# Symbol: GB
# Canonical scale: 1000000000.0 B

class GigaByte:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: GigaByte) -> GigaByte: GigaByte(value: self.value + other.value)
    fn sub(other: GigaByte) -> GigaByte: GigaByte(value: self.value - other.value)

    static fn kind() -> text: "Data"
    static fn symbol() -> text: "GB"
    static fn scale_to_base() -> f64: 1000000000.0
    static fn base_unit() -> text: "B"
    static fn zero() -> GigaByte: GigaByte(value: 0.0)

export GigaByte
