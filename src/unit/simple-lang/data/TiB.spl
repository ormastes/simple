# Unit: TebiByte
# Kind: Data
# Symbol: TiB
# Canonical scale: 1099511627776.0 B

class TebiByte:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: TebiByte) -> TebiByte: TebiByte(value: self.value + other.value)
    fn sub(other: TebiByte) -> TebiByte: TebiByte(value: self.value - other.value)

    static fn kind() -> text: "Data"
    static fn symbol() -> text: "TiB"
    static fn scale_to_base() -> f64: 1099511627776.0
    static fn base_unit() -> text: "B"
    static fn zero() -> TebiByte: TebiByte(value: 0.0)

export TebiByte
