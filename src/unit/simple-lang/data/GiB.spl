# Unit: GibiByte
# Kind: Data
# Symbol: GiB
# Canonical scale: 1073741824.0 B

class GibiByte:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: GibiByte) -> GibiByte: GibiByte(value: self.value + other.value)
    fn sub(other: GibiByte) -> GibiByte: GibiByte(value: self.value - other.value)

    static fn kind() -> text: "Data"
    static fn symbol() -> text: "GiB"
    static fn scale_to_base() -> f64: 1073741824.0
    static fn base_unit() -> text: "B"
    static fn zero() -> GibiByte: GibiByte(value: 0.0)

export GibiByte
