# Unit: Bit
# Kind: Data
# Symbol: bit
# Canonical scale: 0.125 B

class Bit:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Bit) -> Bit: Bit(value: self.value + other.value)
    fn sub(other: Bit) -> Bit: Bit(value: self.value - other.value)

    static fn kind() -> text: "Data"
    static fn symbol() -> text: "bit"
    static fn scale_to_base() -> f64: 0.125
    static fn base_unit() -> text: "B"
    static fn zero() -> Bit: Bit(value: 0.0)

export Bit
