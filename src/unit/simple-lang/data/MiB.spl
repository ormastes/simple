# Unit: MebiByte
# Kind: Data
# Symbol: MiB
# Canonical scale: 1048576.0 B

class MebiByte:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MebiByte) -> MebiByte: MebiByte(value: self.value + other.value)
    fn sub(other: MebiByte) -> MebiByte: MebiByte(value: self.value - other.value)

    static fn kind() -> text: "Data"
    static fn symbol() -> text: "MiB"
    static fn scale_to_base() -> f64: 1048576.0
    static fn base_unit() -> text: "B"
    static fn zero() -> MebiByte: MebiByte(value: 0.0)

export MebiByte
