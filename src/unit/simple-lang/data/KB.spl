# Unit: KiloByte
# Kind: Data
# Symbol: KB
# Canonical scale: 1000.0 B

class KiloByte:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KiloByte) -> KiloByte: KiloByte(value: self.value + other.value)
    fn sub(other: KiloByte) -> KiloByte: KiloByte(value: self.value - other.value)

    static fn kind() -> text: "Data"
    static fn symbol() -> text: "KB"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "B"
    static fn zero() -> KiloByte: KiloByte(value: 0.0)

export KiloByte
