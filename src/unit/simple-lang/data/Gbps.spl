# Unit: Gbps
# Kind: DataRate
# Symbol: Gbps
# Canonical scale: 125000000.0 B/s

class Gbps:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Gbps) -> Gbps: Gbps(value: self.value + other.value)
    fn sub(other: Gbps) -> Gbps: Gbps(value: self.value - other.value)

    static fn kind() -> text: "DataRate"
    static fn symbol() -> text: "Gbps"
    static fn scale_to_base() -> f64: 125000000.0
    static fn base_unit() -> text: "B/s"
    static fn zero() -> Gbps: Gbps(value: 0.0)

export Gbps
