# Unit: MegaByte
# Kind: Data
# Symbol: MB
# Canonical scale: 1000000.0 B

class MegaByte:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MegaByte) -> MegaByte: MegaByte(value: self.value + other.value)
    fn sub(other: MegaByte) -> MegaByte: MegaByte(value: self.value - other.value)

    static fn kind() -> text: "Data"
    static fn symbol() -> text: "MB"
    static fn scale_to_base() -> f64: 1000000.0
    static fn base_unit() -> text: "B"
    static fn zero() -> MegaByte: MegaByte(value: 0.0)

export MegaByte
