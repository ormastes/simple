# Unit: Bbl
# Kind: Volume
# Symbol: bbl
# Canonical scale: 0.158987294928 m3

class Bbl:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Bbl) -> Bbl: Bbl(value: self.value + other.value)
    fn sub(other: Bbl) -> Bbl: Bbl(value: self.value - other.value)

    static fn kind() -> text: "Volume"
    static fn symbol() -> text: "bbl"
    static fn scale_to_base() -> f64: 0.158987294928
    static fn base_unit() -> text: "m3"
