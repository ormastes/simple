# Unit: MolPerL
# Kind: Concentration
# Symbol: mol_per_l
# Canonical scale: 1.0 mol/L

class MolPerL:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MolPerL) -> MolPerL: MolPerL(value: self.value + other.value)
    fn sub(other: MolPerL) -> MolPerL: MolPerL(value: self.value - other.value)

    static fn kind() -> text: "Concentration"
    static fn symbol() -> text: "mol_per_l"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "mol/L"
    static fn zero() -> MolPerL: MolPerL(value: 0.0)

export MolPerL
