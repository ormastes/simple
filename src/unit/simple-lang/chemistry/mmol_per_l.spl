# Unit: MmolPerL
# Kind: Concentration
# Symbol: mmol_per_l
# Canonical scale: 0.001 mol/L

class MmolPerL:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MmolPerL) -> MmolPerL: MmolPerL(value: self.value + other.value)
    fn sub(other: MmolPerL) -> MmolPerL: MmolPerL(value: self.value - other.value)

    static fn kind() -> text: "Concentration"
    static fn symbol() -> text: "mmol_per_l"
    static fn scale_to_base() -> f64: 0.001
    static fn base_unit() -> text: "mol/L"
    static fn zero() -> MmolPerL: MmolPerL(value: 0.0)

export MmolPerL
