# Unit: Ppb
# Kind: MassFraction
# Symbol: ppb
# Canonical scale: 1e-09 ratio

class Ppb:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ppb) -> Ppb: Ppb(value: self.value + other.value)
    fn sub(other: Ppb) -> Ppb: Ppb(value: self.value - other.value)

    static fn kind() -> text: "MassFraction"
    static fn symbol() -> text: "ppb"
    static fn scale_to_base() -> f64: 1e-09
    static fn base_unit() -> text: "ratio"
    static fn zero() -> Ppb: Ppb(value: 0.0)

export Ppb
