# Unit: Ph
# Kind: AcidityIndex
# Symbol: pH
# Canonical scale: 1.0 pH

class Ph:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ph) -> Ph: Ph(value: self.value + other.value)
    fn sub(other: Ph) -> Ph: Ph(value: self.value - other.value)

    static fn kind() -> text: "AcidityIndex"
    static fn symbol() -> text: "pH"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "pH"
    static fn zero() -> Ph: Ph(value: 0.0)

export Ph
