# Unit: UmolPerL
# Kind: Concentration
# Symbol: umol_per_l
# Canonical scale: 1e-06 mol/L

class UmolPerL:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: UmolPerL) -> UmolPerL: UmolPerL(value: self.value + other.value)
    fn sub(other: UmolPerL) -> UmolPerL: UmolPerL(value: self.value - other.value)

    static fn kind() -> text: "Concentration"
    static fn symbol() -> text: "umol_per_l"
    static fn scale_to_base() -> f64: 1e-06
    static fn base_unit() -> text: "mol/L"
    static fn zero() -> UmolPerL: UmolPerL(value: 0.0)

export UmolPerL
