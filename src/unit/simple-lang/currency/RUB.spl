# Unit: Rub
# Kind: Currency
# Symbol: RUB
# Canonical scale: 1.0 USD

class Rub:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Rub) -> Rub: Rub(value: self.value + other.value)
    fn sub(other: Rub) -> Rub: Rub(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "RUB"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Rub: Rub(value: 0.0)

export Rub
