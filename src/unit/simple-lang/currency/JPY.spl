# Unit: Jpy
# Kind: Currency
# Symbol: JPY
# Canonical scale: 1.0 USD

class Jpy:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Jpy) -> Jpy: Jpy(value: self.value + other.value)
    fn sub(other: Jpy) -> Jpy: Jpy(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "JPY"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Jpy: Jpy(value: 0.0)

export Jpy
