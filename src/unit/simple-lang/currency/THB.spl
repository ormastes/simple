# Unit: Thb
# Kind: Currency
# Symbol: THB
# Canonical scale: 1.0 USD

class Thb:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Thb) -> Thb: Thb(value: self.value + other.value)
    fn sub(other: Thb) -> Thb: Thb(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "THB"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Thb: Thb(value: 0.0)

export Thb
