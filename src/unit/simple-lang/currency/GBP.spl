# Unit: Gbp
# Kind: Currency
# Symbol: GBP
# Canonical scale: 1.0 USD

class Gbp:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Gbp) -> Gbp: Gbp(value: self.value + other.value)
    fn sub(other: Gbp) -> Gbp: Gbp(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "GBP"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Gbp: Gbp(value: 0.0)

export Gbp
