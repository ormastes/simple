# Unit: Chf
# Kind: Currency
# Symbol: CHF
# Canonical scale: 1.0 USD

class Chf:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Chf) -> Chf: Chf(value: self.value + other.value)
    fn sub(other: Chf) -> Chf: Chf(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "CHF"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Chf: Chf(value: 0.0)

export Chf
