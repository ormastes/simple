# Unit: Sgd
# Kind: Currency
# Symbol: SGD
# Canonical scale: 1.0 USD

class Sgd:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Sgd) -> Sgd: Sgd(value: self.value + other.value)
    fn sub(other: Sgd) -> Sgd: Sgd(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "SGD"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Sgd: Sgd(value: 0.0)

export Sgd
