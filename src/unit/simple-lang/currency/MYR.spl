# Unit: Myr
# Kind: Currency
# Symbol: MYR
# Canonical scale: 1.0 USD

class Myr:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Myr) -> Myr: Myr(value: self.value + other.value)
    fn sub(other: Myr) -> Myr: Myr(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "MYR"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Myr: Myr(value: 0.0)

export Myr
