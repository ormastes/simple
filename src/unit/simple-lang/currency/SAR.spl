# Unit: Sar
# Kind: Currency
# Symbol: SAR
# Canonical scale: 1.0 USD

class Sar:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Sar) -> Sar: Sar(value: self.value + other.value)
    fn sub(other: Sar) -> Sar: Sar(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "SAR"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Sar: Sar(value: 0.0)

export Sar
