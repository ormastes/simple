# Unit: Pln
# Kind: Currency
# Symbol: PLN
# Canonical scale: 1.0 USD

class Pln:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Pln) -> Pln: Pln(value: self.value + other.value)
    fn sub(other: Pln) -> Pln: Pln(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "PLN"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Pln: Pln(value: 0.0)

export Pln
