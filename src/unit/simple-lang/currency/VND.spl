# Unit: Vnd
# Kind: Currency
# Symbol: VND
# Canonical scale: 1.0 USD

class Vnd:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Vnd) -> Vnd: Vnd(value: self.value + other.value)
    fn sub(other: Vnd) -> Vnd: Vnd(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "VND"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Vnd: Vnd(value: 0.0)

export Vnd
