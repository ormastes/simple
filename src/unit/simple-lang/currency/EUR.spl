# Unit: Eur
# Kind: Currency
# Symbol: EUR
# Canonical scale: 1.0 USD

class Eur:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Eur) -> Eur: Eur(value: self.value + other.value)
    fn sub(other: Eur) -> Eur: Eur(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "EUR"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Eur: Eur(value: 0.0)

export Eur
