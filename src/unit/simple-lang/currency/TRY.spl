# Unit: Try_
# Kind: Currency
# Symbol: TRY
# Canonical scale: 1.0 USD

class Try_:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Try_) -> Try_: Try_(value: self.value + other.value)
    fn sub(other: Try_) -> Try_: Try_(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "TRY"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Try_: Try_(value: 0.0)

export Try_
