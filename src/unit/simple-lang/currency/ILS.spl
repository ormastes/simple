# Unit: Ils
# Kind: Currency
# Symbol: ILS
# Canonical scale: 1.0 USD

class Ils:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ils) -> Ils: Ils(value: self.value + other.value)
    fn sub(other: Ils) -> Ils: Ils(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "ILS"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Ils: Ils(value: 0.0)

export Ils
