# Unit: Cad
# Kind: Currency
# Symbol: CAD
# Canonical scale: 1.0 USD

class Cad:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Cad) -> Cad: Cad(value: self.value + other.value)
    fn sub(other: Cad) -> Cad: Cad(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "CAD"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Cad: Cad(value: 0.0)

export Cad
