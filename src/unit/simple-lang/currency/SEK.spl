# Unit: Sek
# Kind: Currency
# Symbol: SEK
# Canonical scale: 1.0 USD

class Sek:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Sek) -> Sek: Sek(value: self.value + other.value)
    fn sub(other: Sek) -> Sek: Sek(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "SEK"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Sek: Sek(value: 0.0)

export Sek
