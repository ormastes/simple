# Unit: Cny
# Kind: Currency
# Symbol: CNY
# Canonical scale: 1.0 USD

class Cny:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Cny) -> Cny: Cny(value: self.value + other.value)
    fn sub(other: Cny) -> Cny: Cny(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "CNY"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Cny: Cny(value: 0.0)

export Cny
