# Unit: Idr
# Kind: Currency
# Symbol: IDR
# Canonical scale: 1.0 USD

class Idr:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Idr) -> Idr: Idr(value: self.value + other.value)
    fn sub(other: Idr) -> Idr: Idr(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "IDR"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Idr: Idr(value: 0.0)

export Idr
