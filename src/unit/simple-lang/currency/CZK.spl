# Unit: Czk
# Kind: Currency
# Symbol: CZK
# Canonical scale: 1.0 USD

class Czk:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Czk) -> Czk: Czk(value: self.value + other.value)
    fn sub(other: Czk) -> Czk: Czk(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "CZK"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Czk: Czk(value: 0.0)

export Czk
