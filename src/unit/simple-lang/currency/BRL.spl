# Unit: Brl
# Kind: Currency
# Symbol: BRL
# Canonical scale: 1.0 USD

class Brl:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Brl) -> Brl: Brl(value: self.value + other.value)
    fn sub(other: Brl) -> Brl: Brl(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "BRL"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Brl: Brl(value: 0.0)

export Brl
