# Unit: Inr
# Kind: Currency
# Symbol: INR
# Canonical scale: 1.0 USD

class Inr:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Inr) -> Inr: Inr(value: self.value + other.value)
    fn sub(other: Inr) -> Inr: Inr(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "INR"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Inr: Inr(value: 0.0)

export Inr
