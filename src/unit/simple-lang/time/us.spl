# Unit: UsT
# Kind: Time
# Symbol: us
# Canonical scale: 1e-06 s

class UsT:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: UsT) -> UsT: UsT(value: self.value + other.value)
    fn sub(other: UsT) -> UsT: UsT(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "us"
    static fn scale_to_base() -> f64: 1e-06
    static fn base_unit() -> text: "s"
    static fn zero() -> UsT: UsT(value: 0.0)

export UsT
