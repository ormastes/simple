# Unit: Ms
# Kind: Time
# Symbol: ms
# Canonical scale: 0.001 s

class Ms:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ms) -> Ms: Ms(value: self.value + other.value)
    fn sub(other: Ms) -> Ms: Ms(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "ms"
    static fn scale_to_base() -> f64: 0.001
    static fn base_unit() -> text: "s"
    static fn zero() -> Ms: Ms(value: 0.0)

export Ms
