# Unit: Min
# Kind: Time
# Symbol: min
# Canonical scale: 60.0 s

class Min:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Min) -> Min: Min(value: self.value + other.value)
    fn sub(other: Min) -> Min: Min(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "min"
    static fn scale_to_base() -> f64: 60.0
    static fn base_unit() -> text: "s"
    static fn zero() -> Min: Min(value: 0.0)

export Min
