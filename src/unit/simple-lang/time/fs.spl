# Unit: Fs
# Kind: Time
# Symbol: fs
# Canonical scale: 1e-15 s

class Fs:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Fs) -> Fs: Fs(value: self.value + other.value)
    fn sub(other: Fs) -> Fs: Fs(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "fs"
    static fn scale_to_base() -> f64: 1e-15
    static fn base_unit() -> text: "s"
    static fn zero() -> Fs: Fs(value: 0.0)

export Fs
