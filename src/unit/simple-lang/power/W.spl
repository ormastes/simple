# Unit: WattP
# Kind: Power
# Symbol: W
# Canonical scale: 1.0 W

class WattP:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: WattP) -> WattP: WattP(value: self.value + other.value)
    fn sub(other: WattP) -> WattP: WattP(value: self.value - other.value)

    static fn kind() -> text: "Power"
    static fn symbol() -> text: "W"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "W"
    static fn zero() -> WattP: WattP(value: 0.0)

export WattP
