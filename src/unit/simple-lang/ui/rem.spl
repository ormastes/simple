# Unit: Rem
# Kind: UiLength
# Symbol: rem
# Canonical scale: 16.0 px

class Rem:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Rem) -> Rem: Rem(value: self.value + other.value)
    fn sub(other: Rem) -> Rem: Rem(value: self.value - other.value)

    static fn kind() -> text: "UiLength"
    static fn symbol() -> text: "rem"
    static fn scale_to_base() -> f64: 16.0
    static fn base_unit() -> text: "px"
    static fn zero() -> Rem: Rem(value: 0.0)

export Rem
