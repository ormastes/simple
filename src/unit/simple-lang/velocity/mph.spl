# Unit: Mph
# Kind: Velocity
# Symbol: mph
# Canonical scale: 0.44704 m/s

class Mph:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mph) -> Mph: Mph(value: self.value + other.value)
    fn sub(other: Mph) -> Mph: Mph(value: self.value - other.value)

    static fn kind() -> text: "Velocity"
    static fn symbol() -> text: "mph"
    static fn scale_to_base() -> f64: 0.44704
    static fn base_unit() -> text: "m/s"
    static fn zero() -> Mph: Mph(value: 0.0)

export Mph
