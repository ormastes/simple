# Unit: Knot
# Kind: Velocity
# Symbol: knot
# Canonical scale: 0.514444 m/s

class Knot:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Knot) -> Knot: Knot(value: self.value + other.value)
    fn sub(other: Knot) -> Knot: Knot(value: self.value - other.value)

    static fn kind() -> text: "Velocity"
    static fn symbol() -> text: "knot"
    static fn scale_to_base() -> f64: 0.514444
    static fn base_unit() -> text: "m/s"
    static fn zero() -> Knot: Knot(value: 0.0)

export Knot
