# Unit: Mach
# Kind: Velocity
# Symbol: mach
# Canonical scale: 340.29 m/s

class Mach:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mach) -> Mach: Mach(value: self.value + other.value)
    fn sub(other: Mach) -> Mach: Mach(value: self.value - other.value)

    static fn kind() -> text: "Velocity"
    static fn symbol() -> text: "mach"
    static fn scale_to_base() -> f64: 340.29
    static fn base_unit() -> text: "m/s"
