# Unit: Mps
# Kind: Velocity
# Symbol: mps
# Canonical scale: 1.0 m/s

class Mps:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mps) -> Mps: Mps(value: self.value + other.value)
    fn sub(other: Mps) -> Mps: Mps(value: self.value - other.value)

    static fn kind() -> text: "Velocity"
    static fn symbol() -> text: "mps"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "m/s"
    static fn zero() -> Mps: Mps(value: 0.0)

export Mps
