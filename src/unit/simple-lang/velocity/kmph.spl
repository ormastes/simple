# Unit: KmphV
# Kind: Velocity
# Symbol: kmph
# Canonical scale: 0.277777777777778 m/s

class KmphV:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KmphV) -> KmphV: KmphV(value: self.value + other.value)
    fn sub(other: KmphV) -> KmphV: KmphV(value: self.value - other.value)

    static fn kind() -> text: "Velocity"
    static fn symbol() -> text: "kmph"
    static fn scale_to_base() -> f64: 0.277777777777778
    static fn base_unit() -> text: "m/s"
    static fn zero() -> KmphV: KmphV(value: 0.0)

export KmphV
