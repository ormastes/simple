# Unit: CLight
# Kind: Velocity
# Symbol: c_light
# Canonical scale: 299792458.0 m/s

class CLight:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: CLight) -> CLight: CLight(value: self.value + other.value)
    fn sub(other: CLight) -> CLight: CLight(value: self.value - other.value)

    static fn kind() -> text: "Velocity"
    static fn symbol() -> text: "c_light"
    static fn scale_to_base() -> f64: 299792458.0
    static fn base_unit() -> text: "m/s"
    static fn zero() -> CLight: CLight(value: 0.0)

export CLight
