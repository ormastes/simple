# Unit: Ppcm
# Kind: GraphicsDensity
# Symbol: ppcm
# Canonical scale: 2.54 dpi

class Ppcm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ppcm) -> Ppcm: Ppcm(value: self.value + other.value)
    fn sub(other: Ppcm) -> Ppcm: Ppcm(value: self.value - other.value)

    static fn kind() -> text: "GraphicsDensity"
    static fn symbol() -> text: "ppcm"
    static fn scale_to_base() -> f64: 2.54
    static fn base_unit() -> text: "dpi"
    static fn zero() -> Ppcm: Ppcm(value: 0.0)

export Ppcm
