# Unit: Dpi
# Kind: GraphicsDensity
# Symbol: dpi
# Canonical scale: 1.0 dpi

class Dpi:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Dpi) -> Dpi: Dpi(value: self.value + other.value)
    fn sub(other: Dpi) -> Dpi: Dpi(value: self.value - other.value)

    static fn kind() -> text: "GraphicsDensity"
    static fn symbol() -> text: "dpi"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "dpi"
    static fn zero() -> Dpi: Dpi(value: 0.0)

export Dpi
