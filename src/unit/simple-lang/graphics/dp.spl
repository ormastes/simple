# Unit: Dp
# Kind: Graphics
# Symbol: dp
# Canonical scale: 1.0 px

class Dp:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Dp) -> Dp: Dp(value: self.value + other.value)
    fn sub(other: Dp) -> Dp: Dp(value: self.value - other.value)

    static fn kind() -> text: "Graphics"
    static fn symbol() -> text: "dp"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "px"
    static fn zero() -> Dp: Dp(value: 0.0)

export Dp
