# Unit: Sp
# Kind: Graphics
# Symbol: sp
# Canonical scale: 1.0 px

class Sp:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Sp) -> Sp: Sp(value: self.value + other.value)
    fn sub(other: Sp) -> Sp: Sp(value: self.value - other.value)

    static fn kind() -> text: "Graphics"
    static fn symbol() -> text: "sp"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "px"
    static fn zero() -> Sp: Sp(value: 0.0)

export Sp
