# Unit: Bps
# Kind: NetBandwidth
# Symbol: bps
# Canonical scale: 0.125 B/s

class Bps:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Bps) -> Bps: Bps(value: self.value + other.value)
    fn sub(other: Bps) -> Bps: Bps(value: self.value - other.value)

    static fn kind() -> text: "NetBandwidth"
    static fn symbol() -> text: "bps"
    static fn scale_to_base() -> f64: 0.125
    static fn base_unit() -> text: "B/s"
    static fn zero() -> Bps: Bps(value: 0.0)

export Bps
