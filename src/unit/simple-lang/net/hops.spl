# Unit: Hops
# Kind: NetHopCount
# Symbol: hops
# Canonical scale: 1.0 hop

class Hops:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Hops) -> Hops: Hops(value: self.value + other.value)
    fn sub(other: Hops) -> Hops: Hops(value: self.value - other.value)

    static fn kind() -> text: "NetHopCount"
    static fn symbol() -> text: "hops"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "hop"
    static fn zero() -> Hops: Hops(value: 0.0)

export Hops
