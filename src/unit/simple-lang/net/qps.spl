# Unit: Qps
# Kind: NetQueryRate
# Symbol: qps
# Canonical scale: 1.0 Hz

class Qps:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Qps) -> Qps: Qps(value: self.value + other.value)
    fn sub(other: Qps) -> Qps: Qps(value: self.value - other.value)

    static fn kind() -> text: "NetQueryRate"
    static fn symbol() -> text: "qps"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "Hz"
    static fn zero() -> Qps: Qps(value: 0.0)

export Qps
