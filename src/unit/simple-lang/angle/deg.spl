# Unit: Deg
# Kind: Angle
# Symbol: deg
# Canonical scale: 0.017453292519943295 rad

class Deg:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Deg) -> Deg: Deg(value: self.value + other.value)
    fn sub(other: Deg) -> Deg: Deg(value: self.value - other.value)

    static fn kind() -> text: "Angle"
    static fn symbol() -> text: "deg"
    static fn scale_to_base() -> f64: 0.017453292519943295
    static fn base_unit() -> text: "rad"
    static fn zero() -> Deg: Deg(value: 0.0)

export Deg
