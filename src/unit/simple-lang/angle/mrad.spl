# Unit: Mrad
# Kind: Angle
# Symbol: mrad
# Canonical scale: 0.001 rad

class Mrad:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mrad) -> Mrad: Mrad(value: self.value + other.value)
    fn sub(other: Mrad) -> Mrad: Mrad(value: self.value - other.value)

    static fn kind() -> text: "Angle"
    static fn symbol() -> text: "mrad"
    static fn scale_to_base() -> f64: 0.001
    static fn base_unit() -> text: "rad"
    static fn zero() -> Mrad: Mrad(value: 0.0)

export Mrad
