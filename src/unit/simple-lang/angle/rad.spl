# Unit: Rad
# Kind: Angle
# Symbol: rad
# Canonical scale: 1.0 rad

class Rad:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Rad) -> Rad: Rad(value: self.value + other.value)
    fn sub(other: Rad) -> Rad: Rad(value: self.value - other.value)

    static fn kind() -> text: "Angle"
    static fn symbol() -> text: "rad"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "rad"
    static fn zero() -> Rad: Rad(value: 0.0)

export Rad
