# Unit: Mps2
# Kind: Acceleration
# Symbol: mps2
# Canonical scale: 1.0 m/s2

class Mps2:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mps2) -> Mps2: Mps2(value: self.value + other.value)
    fn sub(other: Mps2) -> Mps2: Mps2(value: self.value - other.value)

    static fn kind() -> text: "Acceleration"
    static fn symbol() -> text: "mps2"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "m/s2"
    static fn zero() -> Mps2: Mps2(value: 0.0)

export Mps2
