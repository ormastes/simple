# Unit: Inch
# Kind: Length
# Symbol: inch
# Canonical scale: 0.0254 m

class Inch:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Inch) -> Inch: Inch(value: self.value + other.value)
    fn sub(other: Inch) -> Inch: Inch(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "inch"
    static fn scale_to_base() -> f64: 0.0254
    static fn base_unit() -> text: "m"
    static fn zero() -> Inch: Inch(value: 0.0)

export Inch
