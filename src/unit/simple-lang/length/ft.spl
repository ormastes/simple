# Unit: Ft
# Kind: Length
# Symbol: ft
# Canonical scale: 0.3048 m

class Ft:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ft) -> Ft: Ft(value: self.value + other.value)
    fn sub(other: Ft) -> Ft: Ft(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "ft"
    static fn scale_to_base() -> f64: 0.3048
    static fn base_unit() -> text: "m"
    static fn zero() -> Ft: Ft(value: 0.0)

export Ft
