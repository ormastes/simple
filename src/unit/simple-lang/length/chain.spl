# Unit: Chain
# Kind: Length
# Symbol: chain
# Canonical scale: 20.1168 m

class Chain:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Chain) -> Chain: Chain(value: self.value + other.value)
    fn sub(other: Chain) -> Chain: Chain(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "chain"
    static fn scale_to_base() -> f64: 20.1168
    static fn base_unit() -> text: "m"
    static fn zero() -> Chain: Chain(value: 0.0)

export Chain
