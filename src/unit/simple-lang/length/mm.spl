    fn to_f64() -> f64: self.value
    fn add(other: Mm_) -> Mm_: Mm_(value: self.value + other.value)
    fn sub(other: Mm_) -> Mm_: Mm_(value: self.value - other.value)

    static fn kind() -> text: "Length"
