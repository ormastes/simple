# Unit: Millimetre
# Kind: Length
# Symbol: mm
# Canonical scale: 0.001 m

class Millimetre:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Millimetre) -> Millimetre: Millimetre(value: self.value + other.value)
    fn sub(other: Millimetre) -> Millimetre: Millimetre(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "mm"
    static fn scale_to_base() -> f64: 0.001
    static fn base_unit() -> text: "m"
    static fn zero() -> Millimetre: Millimetre(value: 0.0)

export Millimetre
