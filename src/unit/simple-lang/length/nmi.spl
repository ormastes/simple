# Unit: Nmi
# Kind: Length
# Symbol: nmi
# Canonical scale: 1852.0 m

class Nmi:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Nmi) -> Nmi: Nmi(value: self.value + other.value)
    fn sub(other: Nmi) -> Nmi: Nmi(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "nmi"
    static fn scale_to_base() -> f64: 1852.0
    static fn base_unit() -> text: "m"
    static fn zero() -> Nmi: Nmi(value: 0.0)

export Nmi
