# Unit: Cm
# Kind: Length
# Symbol: cm
# Canonical scale: 0.01 m

class Cm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Cm) -> Cm: Cm(value: self.value + other.value)
    fn sub(other: Cm) -> Cm: Cm(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "cm"
    static fn scale_to_base() -> f64: 0.01
    static fn base_unit() -> text: "m"
    static fn zero() -> Cm: Cm(value: 0.0)

export Cm
