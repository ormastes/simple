# Unit: M
# Kind: Length
# Symbol: m
# Canonical scale: 1.0 m

class M:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: M) -> M: M(value: self.value + other.value)
    fn sub(other: M) -> M: M(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "m"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "m"
    static fn zero() -> M: M(value: 0.0)

export M
