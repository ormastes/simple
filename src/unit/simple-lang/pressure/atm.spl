# Unit: Atm
# Kind: Pressure
# Symbol: atm
# Canonical scale: 101325.0 Pa

class Atm:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Atm) -> Atm: Atm(value: self.value + other.value)
    fn sub(other: Atm) -> Atm: Atm(value: self.value - other.value)

    static fn kind() -> text: "Pressure"
    static fn symbol() -> text: "atm"
    static fn scale_to_base() -> f64: 101325.0
    static fn base_unit() -> text: "Pa"
    static fn zero() -> Atm: Atm(value: 0.0)

export Atm
