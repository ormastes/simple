# Unit: MegaPascal
# Kind: Pressure
# Symbol: MPa
# Canonical scale: 1000000.0 Pa

class MegaPascal:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MegaPascal) -> MegaPascal: MegaPascal(value: self.value + other.value)
    fn sub(other: MegaPascal) -> MegaPascal: MegaPascal(value: self.value - other.value)

    static fn kind() -> text: "Pressure"
    static fn symbol() -> text: "MPa"
    static fn scale_to_base() -> f64: 1000000.0
    static fn base_unit() -> text: "Pa"
    static fn zero() -> MegaPascal: MegaPascal(value: 0.0)

export MegaPascal
