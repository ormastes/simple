# Unit: KiloPascal
# Kind: Pressure
# Symbol: kPa
# Canonical scale: 1000.0 Pa

class KiloPascal:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: KiloPascal) -> KiloPascal: KiloPascal(value: self.value + other.value)
    fn sub(other: KiloPascal) -> KiloPascal: KiloPascal(value: self.value - other.value)

    static fn kind() -> text: "Pressure"
    static fn symbol() -> text: "kPa"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "Pa"
    static fn zero() -> KiloPascal: KiloPascal(value: 0.0)

export KiloPascal
