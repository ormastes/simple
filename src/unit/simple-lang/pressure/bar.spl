# Unit: Bar
# Kind: Pressure
# Symbol: bar
# Canonical scale: 100000.0 Pa

class Bar:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Bar) -> Bar: Bar(value: self.value + other.value)
    fn sub(other: Bar) -> Bar: Bar(value: self.value - other.value)

    static fn kind() -> text: "Pressure"
    static fn symbol() -> text: "bar"
    static fn scale_to_base() -> f64: 100000.0
    static fn base_unit() -> text: "Pa"
    static fn zero() -> Bar: Bar(value: 0.0)

export Bar
