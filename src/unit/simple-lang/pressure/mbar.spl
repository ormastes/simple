# Unit: MilliBar
# Kind: Pressure
# Symbol: mbar
# Canonical scale: 100.0 Pa

class MilliBar:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MilliBar) -> MilliBar: MilliBar(value: self.value + other.value)
    fn sub(other: MilliBar) -> MilliBar: MilliBar(value: self.value - other.value)

    static fn kind() -> text: "Pressure"
    static fn symbol() -> text: "mbar"
    static fn scale_to_base() -> f64: 100.0
    static fn base_unit() -> text: "Pa"
    static fn zero() -> MilliBar: MilliBar(value: 0.0)

export MilliBar
