# Unit: MmHg
# Kind: Pressure
# Symbol: mmHg
# Canonical scale: 133.322387415 Pa

class MmHg:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MmHg) -> MmHg: MmHg(value: self.value + other.value)
    fn sub(other: MmHg) -> MmHg: MmHg(value: self.value - other.value)

    static fn kind() -> text: "Pressure"
    static fn symbol() -> text: "mmHg"
    static fn scale_to_base() -> f64: 133.322387415
    static fn base_unit() -> text: "Pa"
    static fn zero() -> MmHg: MmHg(value: 0.0)

export MmHg
