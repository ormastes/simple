# Unit: PascalP
# Kind: Pressure
# Symbol: Pa
# Canonical scale: 1.0 Pa

class PascalP:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: PascalP) -> PascalP: PascalP(value: self.value + other.value)
    fn sub(other: PascalP) -> PascalP: PascalP(value: self.value - other.value)

    static fn kind() -> text: "Pressure"
    static fn symbol() -> text: "Pa"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "Pa"
    static fn zero() -> PascalP: PascalP(value: 0.0)

export PascalP
