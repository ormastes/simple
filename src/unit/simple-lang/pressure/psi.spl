# Unit: Psi
# Kind: Pressure
# Symbol: psi
# Canonical scale: 6894.757293168 Pa

class Psi:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Psi) -> Psi: Psi(value: self.value + other.value)
    fn sub(other: Psi) -> Psi: Psi(value: self.value - other.value)

    static fn kind() -> text: "Pressure"
    static fn symbol() -> text: "psi"
    static fn scale_to_base() -> f64: 6894.757293168
    static fn base_unit() -> text: "Pa"
