# Unit: Tbsp
# Kind: Volume
# Symbol: tbsp
# Canonical scale: 1.47868e-05 m3

class Tbsp:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Tbsp) -> Tbsp: Tbsp(value: self.value + other.value)
    fn sub(other: Tbsp) -> Tbsp: Tbsp(value: self.value - other.value)

    static fn kind() -> text: "Volume"
    static fn symbol() -> text: "tbsp"
    static fn scale_to_base() -> f64: 1.47868e-05
    static fn base_unit() -> text: "m3"
    static fn zero() -> Tbsp: Tbsp(value: 0.0)

export Tbsp
