# Unit: Cm3
# Kind: Volume
# Symbol: cm3
# Canonical scale: 1e-06 m3

class Cm3:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Cm3) -> Cm3: Cm3(value: self.value + other.value)
    fn sub(other: Cm3) -> Cm3: Cm3(value: self.value - other.value)

    static fn kind() -> text: "Volume"
    static fn symbol() -> text: "cm3"
    static fn scale_to_base() -> f64: 1e-06
    static fn base_unit() -> text: "m3"
    static fn zero() -> Cm3: Cm3(value: 0.0)

export Cm3
