# coreutils/run — launch a command by path
#
# Lightweight wrapper that mirrors the shell's explicit-run path.
#
# MDSOC: feature dimension, coreutils layer

use os.services.launcher.launcher.{launcher_launch_path_with_args}
extern fn println(msg: text)

fn main_run(args: [text]) -> i32:
    """Launch a command path with optional arguments.

    Usage: run CMD [ARGS...]
    """
    if args.len() == 0u64:
        println("Usage: run CMD [ARGS...]")
        return 1i32
    if args[0u64] == "--help":
        println("usage: run CMD [ARGS...]")
        return 0i32

    val command = args[0u64]
    var rest: [text] = []
    var i: u64 = 1
    while i < args.len():
        rest = rest.push(args[i])
        i = i + 1

    val pid = launcher_launch_path_with_args(command, rest)
    if pid < 0:
        println("run: failed to launch {command}")
        return 1i32
    println("run: launched {command} (pid={pid})")
    0i32
