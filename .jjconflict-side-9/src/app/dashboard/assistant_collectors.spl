use app.mcp.assistant.{
    AssistantSessionRecord, AssistantTimelineRecord,
    assistant_store_collect_timeline, assistant_store_collect_notifications,
    assistant_store_load_session
}
use app.mcp.assistant.session_store_helpers.{
    ASSISTANT_STORE_ROOT, assistant_store_sessions_dir,
    assistant_store_session_path
}
use std.io_runtime.{file_exists, list_dir}

pub class AssistantDashboardSnapshot:
    selected_session_id: text
    total_sessions: i64
    sessions: [AssistantSessionRecord]
    timeline: [AssistantTimelineRecord]
    notifications: [AssistantTimelineRecord]
    source_root: text
    mode: text

    static fn empty(root: text) -> AssistantDashboardSnapshot:
        AssistantDashboardSnapshot(
            selected_session_id: "",
            total_sessions: 0,
            sessions: [],
            timeline: [],
            notifications: [],
            source_root: root,
            mode: "replay"
        )

fn _dashboard_assistant_root(root: text) -> text:
    if root.trim() == "":
        ASSISTANT_STORE_ROOT
    else:
        root

pub fn collect_assistant_snapshot() -> AssistantDashboardSnapshot:
    collect_assistant_snapshot_from_root(ASSISTANT_STORE_ROOT)

pub fn collect_assistant_snapshot_from_root(root: text) -> AssistantDashboardSnapshot:
    val resolved = _dashboard_assistant_root(root)
    val sessions = _collect_sessions_unsorted(resolved)
    if sessions.len() == 0:
        return AssistantDashboardSnapshot.empty(resolved)

    val selected_session_id = _select_latest_session_id(sessions)
    val timeline = assistant_store_collect_timeline(resolved, selected_session_id, 200, 0)
    val notifications = assistant_store_collect_notifications(resolved, selected_session_id, 50, 0)
    AssistantDashboardSnapshot(
        selected_session_id: selected_session_id,
        total_sessions: sessions.len(),
        sessions: sessions,
        timeline: timeline,
        notifications: notifications,
        source_root: resolved,
        mode: "replay"
    )

pub fn collect_assistant_timeline(session_id: text) -> [AssistantTimelineRecord]:
    assistant_store_collect_timeline(ASSISTANT_STORE_ROOT, session_id, 200, 0)

fn _collect_sessions_unsorted(root: text) -> [AssistantSessionRecord]:
    val dir = assistant_store_sessions_dir(root)
    var sessions: [AssistantSessionRecord] = []
    if not file_exists(dir):
        return sessions
    val entries = list_dir(dir)
    for entry in entries:
        if entry.ends_with(".json"):
            val session_id = entry.slice(0, entry.len() - 5)
            val path = assistant_store_session_path(root, session_id)
            if file_exists(path):
                match assistant_store_load_session(root, session_id):
                    case Some(session):
                        sessions.push(session)
                    case nil:
                        pass
    sessions

fn _select_latest_session_id(sessions: [AssistantSessionRecord]) -> text:
    var selected_id = ""
    var selected_updated: i64 = -1
    for session in sessions:
        if selected_id == "" or session.updated_at_ms > selected_updated or (session.updated_at_ms == selected_updated and session.session_id > selected_id):
            selected_id = session.session_id
            selected_updated = session.updated_at_ms
    selected_id

export AssistantDashboardSnapshot
export collect_assistant_snapshot, collect_assistant_snapshot_from_root, collect_assistant_timeline
