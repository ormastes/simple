# VexRiscv-SMP Top-Level Port Map
#
# Describes the VexRiscv-SMP cluster top-level port map and provides
# filename resolution for the pre-generated Verilog configurations.
#
# Source: SpinalHDL VexRiscv-SMP (MIT License)
# Vendored from: build/litex-env/pythondata-cpu-vexriscv-smp/
# Configuration: 1-core, 64-bit I/D buses, 8 KiB caches, 128-bit LiteDRAM AXI

# ============================================================================
# VexRiscv-SMP Port Map Configuration
# ============================================================================

pub struct VexRiscvSmpPortMap:
    """
    Describes the port map of a VexRiscv-SMP cluster configuration.
    Maps to a specific pre-generated Verilog file.
    """
    hart_count: i64      # Number of hardware threads (cores)
    ibus_width: i64      # Instruction bus AXI data width in bits (32 or 64)
    dbus_width: i64      # Data bus AXI data width in bits (32 or 64)
    icache_size_kb: i64  # Instruction cache size in KB
    dcache_size_kb: i64  # Data cache size in KB
    axi_data_width: i64  # LiteDRAM AXI data width in bits (16/32/64/128)
    axi_addr_width: i64  # AXI address width in bits

# ============================================================================
# Default Configurations
# ============================================================================

pub fn vexriscv_smp_single_core() -> VexRiscvSmpPortMap:
    """
    Single-core 64-bit VexRiscv-SMP with 128-bit LiteDRAM AXI.
    Corresponds to: VexRiscvLitexSmpCluster_Cc1_Iw64Is8192Iy2_Dw64Ds8192Dy2_ITs4DTs4_Ldw128_Cdma_Ood.v
    """
    VexRiscvSmpPortMap(
        hart_count: 1,
        ibus_width: 64,
        dbus_width: 64,
        icache_size_kb: 8,
        dcache_size_kb: 8,
        axi_data_width: 128,
        axi_addr_width: 32
    )

pub fn vexriscv_smp_dual_core() -> VexRiscvSmpPortMap:
    """
    Dual-core 64-bit VexRiscv-SMP with 128-bit LiteDRAM AXI.
    Corresponds to: VexRiscvLitexSmpCluster_Cc2_Iw64Is8192Iy2_Dw64Ds8192Dy2_ITs4DTs4_Ldw128_Cdma_Ood.v
    """
    VexRiscvSmpPortMap(
        hart_count: 2,
        ibus_width: 64,
        dbus_width: 64,
        icache_size_kb: 8,
        dcache_size_kb: 8,
        axi_data_width: 128,
        axi_addr_width: 32
    )

# ============================================================================
# Filename Resolution
# ============================================================================

pub fn vexriscv_smp_v_filename(cfg: VexRiscvSmpPortMap) -> text:
    """
    Resolves the pre-generated Verilog filename for the given configuration.
    Naming convention: VexRiscvLitexSmpCluster_Cc{cores}_Iw{iw}Is{ic}Iy2_Dw{dw}Ds{dc}Dy2_ITs4DTs4_Ldw{ldw}_Cdma_Ood.v
    """
    val cc = cfg.hart_count
    val iw = cfg.ibus_width
    val ic = cfg.icache_size_kb * 1024
    val dw = cfg.dbus_width
    val dc = cfg.dcache_size_kb * 1024
    val ldw = cfg.axi_data_width
    "VexRiscvLitexSmpCluster_Cc{cc}_Iw{iw}Is{ic}Iy2_Dw{dw}Ds{dc}Dy2_ITs4DTs4_Ldw{ldw}_Cdma_Ood.v"

pub fn vexriscv_smp_import_path() -> text:
    """Returns the import path for the VexRiscv-SMP Verilog sources."""
    "src/lib/hardware/opensource_rtl/vexriscv_smp"
