# std.nogc_async_mut.engine.render.vulkan_commands — VulkanCommand3D
#
# Tagged command enum for 3D Vulkan command recording.
# No external dependencies — pure data.
#
# Commands are recorded into a buffer during the frame and drained in
# end_frame() by VulkanRenderBackend3D, which submits them via rt_vulkan_* externs.

# ============================================================================
# VulkanCommand3DKind — tag discriminator
# ============================================================================

enum VulkanCommand3DKind:
    BeginRenderPass
    SetPipeline
    BindVertexBuffer
    BindIndexBuffer
    BindTexture
    BindUniformBuffer
    DrawIndexed
    EndRenderPass

# ============================================================================
# VulkanCommand3D — a single recorded 3D Vulkan-like command
#
# Fields are overloaded by kind:
#   BeginRenderPass  -> color_image, depth_image
#   SetPipeline      -> pipeline_id
#   BindVertexBuffer -> buffer_id, slot
#   BindIndexBuffer  -> buffer_id
#   BindTexture      -> image_id (stored in buffer_id), slot
#   BindUniformBuffer-> buffer_id, slot
#   DrawIndexed      -> index_count, base_vertex (stored in slot and buffer_id)
#   EndRenderPass    -> (no fields used)
# ============================================================================

class VulkanCommand3D:
    kind: VulkanCommand3DKind
    # Resource IDs (GPU native handles)
    color_image: i64
    depth_image: i64
    pipeline_id: i64
    buffer_id: i64
    image_id: i64
    # Slot / index parameters
    slot: i64
    index_count: i64
    base_vertex: i64

fn vk_cmd3d_begin_render_pass(color_image: i64, depth_image: i64) -> VulkanCommand3D:
    VulkanCommand3D(
        kind: VulkanCommand3DKind.BeginRenderPass,
        color_image: color_image,
        depth_image: depth_image,
        pipeline_id: 0,
        buffer_id: 0,
        image_id: 0,
        slot: 0,
        index_count: 0,
        base_vertex: 0
    )

fn vk_cmd3d_set_pipeline(pipeline_id: i64) -> VulkanCommand3D:
    VulkanCommand3D(
        kind: VulkanCommand3DKind.SetPipeline,
        color_image: 0,
        depth_image: 0,
        pipeline_id: pipeline_id,
        buffer_id: 0,
        image_id: 0,
        slot: 0,
        index_count: 0,
        base_vertex: 0
    )

fn vk_cmd3d_bind_vertex_buffer(buffer_id: i64, slot: i64) -> VulkanCommand3D:
    VulkanCommand3D(
        kind: VulkanCommand3DKind.BindVertexBuffer,
        color_image: 0,
        depth_image: 0,
        pipeline_id: 0,
        buffer_id: buffer_id,
        image_id: 0,
        slot: slot,
        index_count: 0,
        base_vertex: 0
    )

fn vk_cmd3d_bind_index_buffer(buffer_id: i64) -> VulkanCommand3D:
    VulkanCommand3D(
        kind: VulkanCommand3DKind.BindIndexBuffer,
        color_image: 0,
        depth_image: 0,
        pipeline_id: 0,
        buffer_id: buffer_id,
        image_id: 0,
        slot: 0,
        index_count: 0,
        base_vertex: 0
    )

fn vk_cmd3d_bind_texture(image_id: i64, slot: i64) -> VulkanCommand3D:
    VulkanCommand3D(
        kind: VulkanCommand3DKind.BindTexture,
        color_image: 0,
        depth_image: 0,
        pipeline_id: 0,
        buffer_id: 0,
        image_id: image_id,
        slot: slot,
        index_count: 0,
        base_vertex: 0
    )

fn vk_cmd3d_bind_uniform_buffer(buffer_id: i64, slot: i64) -> VulkanCommand3D:
    VulkanCommand3D(
        kind: VulkanCommand3DKind.BindUniformBuffer,
        color_image: 0,
        depth_image: 0,
        pipeline_id: 0,
        buffer_id: buffer_id,
        image_id: 0,
        slot: slot,
        index_count: 0,
        base_vertex: 0
    )

fn vk_cmd3d_draw_indexed(index_count: i64, base_vertex: i64) -> VulkanCommand3D:
    VulkanCommand3D(
        kind: VulkanCommand3DKind.DrawIndexed,
        color_image: 0,
        depth_image: 0,
        pipeline_id: 0,
        buffer_id: 0,
        image_id: 0,
        slot: 0,
        index_count: index_count,
        base_vertex: base_vertex
    )

fn vk_cmd3d_end_render_pass() -> VulkanCommand3D:
    VulkanCommand3D(
        kind: VulkanCommand3DKind.EndRenderPass,
        color_image: 0,
        depth_image: 0,
        pipeline_id: 0,
        buffer_id: 0,
        image_id: 0,
        slot: 0,
        index_count: 0,
        base_vertex: 0
    )
