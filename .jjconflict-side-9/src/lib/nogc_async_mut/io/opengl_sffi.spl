"""
# No-GC Async OpenGL I/O SFFI

Compatibility facade over the no-GC sync backend owner. The runtime boundary is
synchronous SFFI; async-family users import this facade so GC async surfaces can
route through no-GC async before reaching the no-GC sync hook owner.
"""

export use std.nogc_sync_mut.io.opengl_sffi.{
    opengl_available, opengl_last_error, OpenGLContext, opengl_init, opengl_destroy,
    OpenGLFBO, opengl_create_fbo, opengl_destroy_fbo, opengl_bind_fbo, opengl_read_pixels,
    opengl_clear, opengl_draw_rect, opengl_draw_line, opengl_draw_circle,
    opengl_draw_triangle, opengl_draw_rounded_rect, opengl_draw_gradient_rect,
    opengl_draw_image, opengl_set_scissor, opengl_clear_scissor, opengl_flush
}
