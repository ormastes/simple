"""
# No-GC async SFFI runtime

Compatibility facade over the no-GC sync backend boundary.
"""

export use std.nogc_sync_mut.sffi.runtime.{
    gc_init, gc_collect, gc_malloc,
    value_nil, value_bool, value_int, value_float, value_string,
    value_string_from_text, value_array_new, value_dict_new,
    value_type, value_is_nil, value_is_bool, value_is_int, value_is_float,
    value_is_string, value_is_array, value_is_dict,
    value_as_bool, value_as_int, value_as_float, value_as_string,
    value_clone, value_free,
    value_add, value_sub, value_mul, value_div, value_eq, value_lt,
    value_print, value_println
}
