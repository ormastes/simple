# =============================================================================
# common/crypto/typed/aead.spl — typed AEAD wrappers
# =============================================================================
# Thin additive wrappers over pure-Simple KAT-passing cores:
#   - AES-256-GCM  (src/os/crypto/aes256_gcm.spl)
#   - ChaCha20-Poly1305  (src/os/crypto/chacha20_poly1305.spl)
#
# These wrappers convert between the barrier types in ctypes.spl and the
# [u8]-based raw core APIs. They do NOT re-implement any crypto; they only
# add type safety at the call boundary.
#
# Alpha-oracle status: rt_aes_gcm_*_hex externs exist in quic_crypto.spl but
# are hex-level adapters in a different module and not confirmed non-stub for
# standalone AEAD; dual_backend path absent here — pure-typed path exposed.
# =============================================================================

use os.crypto.aes256_gcm.{aes256_gcm_encrypt, aes256_gcm_decrypt, Aes256GcmResult}
use os.crypto.chacha20_poly1305.{chacha20_poly1305_encrypt, chacha20_poly1305_decrypt, Chacha20Poly1305Result}
use std.common.bytes.span.{ByteSpan}
use std.common.crypto.typed.ctypes.{SecretKey, Nonce, Plaintext, Ciphertext, AuthTag}

# =============================================================================
# AeadSealed — typed pair returned by seal operations
# =============================================================================
# NOTE: Simple does not support tuple-return syntax `-> (A, B)`.
# AeadSealed is a plain struct carrying the two typed outputs.

struct AeadSealed:
    """Typed pair of (Ciphertext, AuthTag) returned by any AEAD seal call."""
    ct: Ciphertext
    tag: AuthTag

# =============================================================================
# AeadOpenResult — typed Result for open operations
# =============================================================================
# NOTE: Result<Plaintext, text> uses Simple generics which are broken for
# struct type params (bug: crypto_digest_generic_struct_2026-06-15).
# Use a concrete enum instead, matching the pattern of Aes256GcmResult /
# Chacha20Poly1305Result in the underlying cores.

enum AeadOpenResult:
    """Result of an AEAD open (decrypt + verify) operation."""
    Ok(pt: Plaintext)
    Err(msg: text)

# =============================================================================
# Helpers
# =============================================================================

fn _extract_ct(raw: [u8]) -> [u8]:
    """Extract ciphertext bytes (all but last 16 bytes) from core output."""
    val total = raw.len()
    val ct_len = total - 16
    var ct: [u8] = []
    var i: i64 = 0
    while i < ct_len:
        ct.push(raw[i])
        i = i + 1
    ct

fn _extract_tag(raw: [u8]) -> [u8]:
    """Extract the last 16 bytes (tag) from core output."""
    val total = raw.len()
    var tg: [u8] = []
    var i: i64 = total - 16
    while i < total:
        tg.push(raw[i])
        i = i + 1
    tg

# =============================================================================
# AES-256-GCM typed wrappers
# =============================================================================

fn aes256_gcm_seal(key: SecretKey, nonce: Nonce, pt: Plaintext, aad: ByteSpan) -> AeadSealed:
    """AES-256-GCM authenticated encryption over typed barrier types.

    Args:
        key:   32-byte AES-256 key (SecretKey).
        nonce: 12-byte nonce (Nonce).
        pt:    Plaintext to encrypt.
        aad:   Additional authenticated data (ByteSpan, not encrypted).

    Returns: AeadSealed{ct, tag} where tag is the 16-byte GCM auth tag.
    """
    val raw_key = key.bytes().to_bytes()
    val raw_nonce = nonce.bytes().to_bytes()
    val raw_pt = pt.bytes().to_bytes()
    val raw_aad = aad.to_bytes()

    val raw_out = aes256_gcm_encrypt(raw_key, raw_nonce, raw_pt, raw_aad)

    val ct_bytes = _extract_ct(raw_out)
    val tag_bytes = _extract_tag(raw_out)

    AeadSealed(ct: Ciphertext.new(ct_bytes), tag: AuthTag.new(tag_bytes))

fn aes256_gcm_open(key: SecretKey, nonce: Nonce, ct: Ciphertext, aad: ByteSpan, tag: AuthTag) -> AeadOpenResult:
    """AES-256-GCM authenticated decryption over typed barrier types.

    Verifies the auth tag via the core's constant-time compare.
    Returns Err on tag mismatch (fail-closed).

    Args:
        key:   32-byte AES-256 key (SecretKey).
        nonce: 12-byte nonce (Nonce).
        ct:    Ciphertext to decrypt.
        aad:   Additional authenticated data.
        tag:   16-byte AuthTag to verify.

    Returns: AeadOpenResult.Ok(pt) on success, AeadOpenResult.Err(msg) on failure.
    """
    val raw_key = key.bytes().to_bytes()
    val raw_nonce = nonce.bytes().to_bytes()
    val raw_ct = ct.bytes().to_bytes()
    val raw_aad = aad.to_bytes()
    val raw_tag = tag.bytes().to_bytes()

    val result = aes256_gcm_decrypt(raw_key, raw_nonce, raw_ct, raw_aad, raw_tag)

    if val Aes256GcmResult.Ok(inner_data) = result:
        return AeadOpenResult.Ok(pt: Plaintext.new(inner_data))
    if val Aes256GcmResult.Err(inner_msg) = result:
        return AeadOpenResult.Err(msg: inner_msg)
    AeadOpenResult.Err(msg: "aes256_gcm_decrypt returned unexpected result")

# =============================================================================
# ChaCha20-Poly1305 typed wrappers
# =============================================================================

fn chacha20_poly1305_seal(key: SecretKey, nonce: Nonce, pt: Plaintext, aad: ByteSpan) -> AeadSealed:
    """ChaCha20-Poly1305 authenticated encryption over typed barrier types.

    Args:
        key:   32-byte key (SecretKey).
        nonce: 12-byte nonce (Nonce).
        pt:    Plaintext to encrypt.
        aad:   Additional authenticated data (ByteSpan).

    Returns: AeadSealed{ct, tag} where tag is the 16-byte Poly1305 tag.
    """
    val raw_key = key.bytes().to_bytes()
    val raw_nonce = nonce.bytes().to_bytes()
    val raw_pt = pt.bytes().to_bytes()
    val raw_aad = aad.to_bytes()

    val raw_out = chacha20_poly1305_encrypt(raw_key, raw_nonce, raw_pt, raw_aad)

    val ct_bytes = _extract_ct(raw_out)
    val tag_bytes = _extract_tag(raw_out)

    AeadSealed(ct: Ciphertext.new(ct_bytes), tag: AuthTag.new(tag_bytes))

fn chacha20_poly1305_open(key: SecretKey, nonce: Nonce, ct: Ciphertext, aad: ByteSpan, tag: AuthTag) -> AeadOpenResult:
    """ChaCha20-Poly1305 authenticated decryption over typed barrier types.

    Verifies the Poly1305 tag via the core's constant-time compare.
    Returns Err on tag mismatch (fail-closed).

    Args:
        key:   32-byte key (SecretKey).
        nonce: 12-byte nonce (Nonce).
        ct:    Ciphertext to decrypt.
        aad:   Additional authenticated data.
        tag:   16-byte AuthTag to verify.

    Returns: AeadOpenResult.Ok(pt) on success, AeadOpenResult.Err(msg) on failure.
    """
    val raw_key = key.bytes().to_bytes()
    val raw_nonce = nonce.bytes().to_bytes()
    val raw_ct = ct.bytes().to_bytes()
    val raw_aad = aad.to_bytes()
    val raw_tag = tag.bytes().to_bytes()

    val result = chacha20_poly1305_decrypt(raw_key, raw_nonce, raw_ct, raw_aad, raw_tag)

    if val Chacha20Poly1305Result.Ok(inner_data) = result:
        return AeadOpenResult.Ok(pt: Plaintext.new(inner_data))
    if val Chacha20Poly1305Result.Err(inner_msg) = result:
        return AeadOpenResult.Err(msg: inner_msg)
    AeadOpenResult.Err(msg: "chacha20_poly1305_decrypt returned unexpected result")
