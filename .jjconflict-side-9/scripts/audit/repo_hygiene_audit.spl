# Repository hygiene gate for generated clutter and stale structure.

extern fn rt_cli_get_args() -> [text]
extern fn rt_file_read_text(path: text) -> text
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_exit(code: i32) -> void

struct HygieneConfig:
    root: text
    policy_path: text
    allow_empty_source_dirs: bool

struct HygienePolicy:
    dirty_dir_names: [text]
    dirty_suffixes: [text]
    skip_dir_names: [text]
    skip_prefixes: [text]
    source_roots: [text]

fn shell_quote(value: text) -> text:
    "'" + value.replace("'", "'\"'\"'") + "'"

fn normalize_args(all_args: [text]) -> [text]:
    var start = 0
    var found = false
    var i = 0
    while i < all_args.len():
        if all_args[i].ends_with("repo_hygiene_audit.spl"):
            start = i + 1
            found = true
            break
        i = i + 1
    if not found and all_args.len() > 0:
        start = 1

    var args: [text] = []
    i = start
    while i < all_args.len():
        if all_args[i] != "--":
            args = args.push(all_args[i])
        i = i + 1
    args

fn default_config() -> HygieneConfig:
    HygieneConfig(
        root: ".",
        policy_path: "scripts/audit/repo_hygiene_policy.json",
        allow_empty_source_dirs: false
    )

fn parse_args(args: [text]) -> HygieneConfig:
    var config = default_config()
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--allow-empty-source-dirs":
            config.allow_empty_source_dirs = true
            i = i + 1
        elif arg == "--root" and i + 1 < args.len():
            config.root = args[i + 1]
            i = i + 2
        elif arg.starts_with("--root="):
            config.root = arg.substring("--root=".len())
            i = i + 1
        elif arg == "--policy" and i + 1 < args.len():
            config.policy_path = args[i + 1]
            i = i + 2
        elif arg.starts_with("--policy="):
            config.policy_path = arg.substring("--policy=".len())
            i = i + 1
        else:
            i = i + 1
    config

fn json_string_array(source: text, key: text) -> [text]:
    val marker = "\"" + key + "\":"
    val marker_idx = source.index_of(marker) ?? -1
    if marker_idx < 0:
        return []
    val rest = source.substring(marker_idx + marker.len())
    val open_idx = rest.index_of("[") ?? -1
    if open_idx < 0:
        return []
    val after_open = rest.substring(open_idx + 1)
    val close_idx = after_open.index_of("]") ?? -1
    if close_idx < 0:
        return []
    var values: [text] = []
    var scan = after_open.substring(0, close_idx)
    while true:
        val first = scan.index_of("\"") ?? -1
        if first < 0:
            break
        val after_first = scan.substring(first + 1)
        val second = after_first.index_of("\"") ?? -1
        if second < 0:
            break
        values = values.push(after_first.substring(0, second))
        scan = after_first.substring(second + 1)
    values

fn load_policy(path: text) -> HygienePolicy:
    val source = rt_file_read_text(path) ?? ""
    HygienePolicy(
        dirty_dir_names: json_string_array(source, "dirty_dir_names"),
        dirty_suffixes: json_string_array(source, "dirty_suffixes"),
        skip_dir_names: json_string_array(source, "skip_dir_names"),
        skip_prefixes: json_string_array(source, "skip_prefixes"),
        source_roots: json_string_array(source, "source_roots")
    )

fn contains_text(values: [text], target: text) -> bool:
    for value in values:
        if value == target:
            return true
    false

fn basename(path: text) -> text:
    var idx = path.len() - 1
    while idx >= 0:
        if path.substring(idx, idx + 1) == "/":
            return path.substring(idx + 1, path.len())
        idx = idx - 1
    path

fn normalize_find_path(path: text) -> text:
    if path.starts_with("./"):
        return path.substring(2)
    path

fn is_external(path: text, policy: HygienePolicy) -> bool:
    val rel = normalize_find_path(path)
    for prefix in policy.skip_prefixes:
        if rel.starts_with(prefix):
            return true
    false

fn prune_expression(skip_dir_names: [text]) -> text:
    if skip_dir_names.len() == 0:
        return ""
    var expr = "\\( "
    var i = 0
    while i < skip_dir_names.len():
        if i > 0:
            expr = expr + " -o "
        expr = expr + "-name " + shell_quote(skip_dir_names[i])
        i = i + 1
    expr + " \\) -prune -o "

fn list_paths(root: text, policy: HygienePolicy, kind: text) -> [text]:
    val command = "cd " + shell_quote(root) + " && find . -mindepth 1 " + prune_expression(policy.skip_dir_names) + "-type " + kind + " -print | sort"
    val result = rt_process_run("/bin/sh", ["-c", command])
    if result.2 != 0:
        print("Repository Hygiene Audit")
        print("========================")
        print("find failed:")
        print(result.1)
        rt_exit(1)
    var paths: [text] = []
    for raw in result.0.split("\n"):
        val path = normalize_find_path(raw.trim())
        if path != "" and not is_external(path, policy):
            paths = paths.push(path)
    paths

fn git_ignored(path: text) -> bool:
    val result = rt_process_run("git", ["check-ignore", "-q", path])
    result.2 == 0

fn dirty_suffix(path: text, policy: HygienePolicy) -> bool:
    val name = basename(path)
    if name == ".DS_Store":
        return true
    for suffix in policy.dirty_suffixes:
        if name.ends_with(suffix):
            return true
    false

fn find_dirty_dirs(dirs: [text], policy: HygienePolicy) -> [text]:
    var hits: [text] = []
    for path in dirs:
        if contains_text(policy.dirty_dir_names, basename(path)) and not git_ignored(path):
            hits = hits.push(path)
    hits

fn find_dirty_files(files: [text], policy: HygienePolicy) -> [text]:
    var hits: [text] = []
    for path in files:
        if dirty_suffix(path, policy) and not git_ignored(path):
            hits = hits.push(path)
    hits

fn find_empty_source_dirs(root: text, policy: HygienePolicy) -> [text]:
    var hits: [text] = []
    for source_root in policy.source_roots:
        val command = "cd " + shell_quote(root) + " && if [ -e " + shell_quote(source_root) + " ]; then find " + shell_quote(source_root) + " -mindepth 1 " + prune_expression(policy.skip_dir_names) + "-type d -empty -print | sort; fi"
        val result = rt_process_run("/bin/sh", ["-c", command])
        if result.2 != 0:
            continue
        for raw in result.0.split("\n"):
            val path = normalize_find_path(raw.trim())
            if path != "" and not is_external(path, policy):
                hits = hits.push(path)
    hits

fn print_group(title: text, items: [text]):
    print(title)
    if items.len() == 0:
        print("  OK")
        return
    for item in items:
        print("  - " + item)

val config = parse_args(normalize_args(rt_cli_get_args()))
val policy = load_policy(config.policy_path)
val dirs = list_paths(config.root, policy, "d")
val files = list_paths(config.root, policy, "f")
val dirty_dirs = find_dirty_dirs(dirs, policy)
val dirty_files = find_dirty_files(files, policy)
val empty_source_dirs = find_empty_source_dirs(config.root, policy)

print("Repository Hygiene Audit")
print("========================")
print_group("Unignored generated/cache directories", dirty_dirs)
print_group("Unignored temporary files", dirty_files)
print_group("Empty source directories", empty_source_dirs)

if dirty_dirs.len() > 0 or dirty_files.len() > 0:
    rt_exit(1)
if empty_source_dirs.len() > 0 and not config.allow_empty_source_dirs:
    rt_exit(1)
rt_exit(0)
