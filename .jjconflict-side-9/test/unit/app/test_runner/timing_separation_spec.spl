# Test: Timing separation — setup_ms field in TestFileResult
#
# Verifies that TestFileResult and TestRunResult have setup_ms / total_setup_ms
# fields, and that they default to 0 for non-QEMU tests.

# Local struct definitions matching the production types

struct TestFileResult:
    path: text
    passed: i64
    failed: i64
    skipped: i64
    pending: i64
    duration_ms: i64
    setup_ms: i64
    error: text
    timed_out: bool

struct TestRunResult:
    total_passed: i64
    total_failed: i64
    total_skipped: i64
    total_pending: i64
    total_timed_out: i64
    total_duration_ms: i64
    total_setup_ms: i64

# Wrap tests in module-level functions to avoid closure issues

fn test_setup_ms_default() -> bool:
    val result = TestFileResult(
        path: "test.spl", passed: 1, failed: 0, skipped: 0,
        pending: 0, duration_ms: 100, setup_ms: 0,
        error: "", timed_out: false
    )
    result.setup_ms == 0 and result.duration_ms == 100

fn test_setup_ms_nonzero() -> bool:
    val result = TestFileResult(
        path: "qemu_test.spl", passed: 1, failed: 0, skipped: 0,
        pending: 0, duration_ms: 500, setup_ms: 200,
        error: "", timed_out: false
    )
    result.setup_ms == 200 and result.duration_ms == 500

fn test_setup_ms_independent() -> bool:
    val result = TestFileResult(
        path: "test.spl", passed: 3, failed: 1, skipped: 0,
        pending: 0, duration_ms: 1000, setup_ms: 350,
        error: "some error", timed_out: false
    )
    result.setup_ms == 350 and result.duration_ms == 1000

fn test_run_result_setup_ms() -> bool:
    val run_result = TestRunResult(
        total_passed: 5, total_failed: 0,
        total_skipped: 0, total_pending: 0, total_timed_out: 0,
        total_duration_ms: 1000, total_setup_ms: 150
    )
    run_result.total_setup_ms == 150

fn test_run_result_setup_ms_zero() -> bool:
    val run_result = TestRunResult(
        total_passed: 0, total_failed: 0,
        total_skipped: 0, total_pending: 0, total_timed_out: 0,
        total_duration_ms: 0, total_setup_ms: 0
    )
    run_result.total_setup_ms == 0

describe "TestFileResult setup_ms":
    it "has setup_ms field defaulting to 0":
        expect(test_setup_ms_default()).to_equal(true)

    it "can hold non-zero setup_ms":
        expect(test_setup_ms_nonzero()).to_equal(true)

    it "setup_ms is independent of duration_ms":
        expect(test_setup_ms_independent()).to_equal(true)

describe "TestRunResult total_setup_ms":
    it "has total_setup_ms field":
        expect(test_run_result_setup_ms()).to_equal(true)

    it "defaults to 0":
        expect(test_run_result_setup_ms_zero()).to_equal(true)
