extern fn rt_file_read_text(path: text) -> text

fn _contains_software_backend_negative_guards(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn _read_byte_as_f64(data: [u8], off: i64) -> f64:") and
        source.to_contain("if off >= 0 and off < data.len():") and
        source.to_contain("fn _swb_decode_index(data: [u8], offset: i64) -> i64:") and
        source.to_contain("if offset >= 0 and offset + 3 < data.len():") and
        source.to_contain("val bv: i64 = data[off]") and
        source.to_contain("val b0: i64 = data[offset]")

describe "Software 3D backend negative offset guards":
    it "guards mirrored byte and index readers before indexed reads":
        expect(_contains_software_backend_negative_guards("src/lib/nogc_sync_mut/engine/render/software_backend3d.spl")).to_equal(true)
        expect(_contains_software_backend_negative_guards("src/lib/nogc_async_mut/engine/render/software_backend3d.spl")).to_equal(true)
