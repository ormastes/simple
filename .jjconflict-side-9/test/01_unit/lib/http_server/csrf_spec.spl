# CSRF Protection Specification
#
# **Feature IDs:** #SEC-011
# **Category:** HTTP Server Security
# **Difficulty:** 2/5
# **Status:** Implemented
#
# ## Overview
# Tests for CSRF token generation, constant-time token comparison, config
# defaults, method exemptions, and the fail-closed empty-secret guard in
# csrf_handler.  Rewrites the phantom spec that called non-existent symbols
# (validate_csrf_token / is_csrf_exempt_method / default_csrf_config / zero-arg
# generate_csrf_token) against the real API in
# src/lib/nogc_async_mut/http_server/csrf.spl.

use std.http_server.csrf.{
    CsrfConfig,
    generate_csrf_token,
    generate_csrf_token_with_timestamp,
    csrf_handler,
    constant_time_eq,
    get_header_value,
    get_cookie_value
}
use std.http_server.types.{
    HttpRequestData,
    ServerConfig,
    PhaseResult
}

# ============================================================================
# Helpers
# ============================================================================

fn _test_config() -> CsrfConfig:
    CsrfConfig(
        secret_key: "test-secret-key-32bytes-min!!!!",
        token_header: "X-CSRF-Token",
        cookie_name: "csrf_token",
        exempt_paths: [],
        exempt_methods: ["GET", "HEAD", "OPTIONS"]
    )

fn _test_server_config() -> ServerConfig:
    ServerConfig(
        listen_addr: "0.0.0.0:8080",
        worker_count: 1,
        max_connections: 100,
        keepalive_timeout_ms: 65000,
        read_timeout_ms: 60000,
        write_timeout_ms: 60000,
        idle_timeout_ms: 120000,
        client_max_body_size: 1048576,
        server_name: "TestServer",
        locations: [],
        upstreams: [],
        access_log: "",
        error_log: "",
        tls_enabled: false,
        tls_cert_path: "",
        tls_key_path: "",
        tls_min_version: "1.2",
        drain_timeout_ms: 30000
    )

fn _test_request(method: text, path: text, headers: [(text, text)]) -> HttpRequestData:
    HttpRequestData(
        method: method,
        path: path,
        query: "",
        version: "HTTP/1.1",
        headers: headers,
        body: "",
        params: {},
        peer_addr: "127.0.0.1:1234"
    )

# ============================================================================
# Test Group 1: Token generation
# ============================================================================

describe "CSRF token generation":
    # generate_csrf_token / generate_csrf_token_with_timestamp call the
    # rt_hmac_sha256 extern which is only available in compiled/native mode.
    # The two tests below exercise the fail-closed guard that fires BEFORE
    # the extern call and are therefore safe to run in interpreter mode.

    it "returns empty string when secret_key is empty (fail-closed)":
        val config = CsrfConfig.default()
        val token = generate_csrf_token(config, "session-abc")
        expect(token).to_equal("")

    it "generate_csrf_token_with_timestamp returns empty when secret_key is empty":
        val config = CsrfConfig.default()
        val token = generate_csrf_token_with_timestamp(config, "session-abc", 1000000)
        expect(token).to_equal("")

# ============================================================================
# Test Group 2: Constant-time comparison (replaces phantom validate_csrf_token)
# ============================================================================

describe "CSRF token constant-time comparison":
    it "identical strings compare equal":
        val token = "abc123def456ghi789jkl012mno345pq"
        val result = constant_time_eq(token, token)
        expect(result).to_equal(true)

    it "mismatched tokens compare unequal":
        val token_a = "abc123def456ghi789jkl012mno345pq"
        val token_b = "zzz999yyy888xxx777www666vvv555uu"
        val result = constant_time_eq(token_a, token_b)
        expect(result).to_equal(false)

    it "empty string does not equal a non-empty token":
        val token = "abc123def456ghi789jkl012mno345pq"
        val result = constant_time_eq("", token)
        expect(result).to_equal(false)

    it "both empty strings compare equal":
        val result = constant_time_eq("", "")
        expect(result).to_equal(true)

# ============================================================================
# Test Group 3: CsrfConfig defaults and method exemptions
# (replaces phantom is_csrf_exempt_method / default_csrf_config)
# ============================================================================

describe "CsrfConfig defaults":
    it "default config has empty secret_key":
        val config = CsrfConfig.default()
        expect(config.secret_key).to_equal("")

    it "default config uses X-CSRF-Token header":
        val config = CsrfConfig.default()
        expect(config.token_header).to_equal("X-CSRF-Token")

    it "default config uses csrf_token cookie":
        val config = CsrfConfig.default()
        expect(config.cookie_name).to_equal("csrf_token")

    it "default exempt_methods includes GET":
        val config = CsrfConfig.default()
        val has_get = config.exempt_methods.contains("GET")
        expect(has_get).to_equal(true)

    it "default exempt_methods includes HEAD":
        val config = CsrfConfig.default()
        val has_head = config.exempt_methods.contains("HEAD")
        expect(has_head).to_equal(true)

    it "default exempt_methods includes OPTIONS":
        val config = CsrfConfig.default()
        val has_options = config.exempt_methods.contains("OPTIONS")
        expect(has_options).to_equal(true)

    it "default exempt_methods does not include POST":
        val config = CsrfConfig.default()
        val has_post = config.exempt_methods.contains("POST")
        expect(has_post).to_equal(false)

    it "default exempt_methods does not include DELETE":
        val config = CsrfConfig.default()
        val has_delete = config.exempt_methods.contains("DELETE")
        expect(has_delete).to_equal(false)

# ============================================================================
# Test Group 4: csrf_handler — exempt methods pass through
# ============================================================================

describe "csrf_handler exempt methods pass through":
    it "GET request continues without CSRF check":
        val config = _test_config()
        val server_config = _test_server_config()
        val request = _test_request("GET", "/", [])
        val result = csrf_handler(request, server_config, config)
        match result:
            PhaseResult.Continue:
                expect(true).to_equal(true)
            _:
                expect(false).to_equal(true)

    it "HEAD request continues without CSRF check":
        val config = _test_config()
        val server_config = _test_server_config()
        val request = _test_request("HEAD", "/", [])
        val result = csrf_handler(request, server_config, config)
        match result:
            PhaseResult.Continue:
                expect(true).to_equal(true)
            _:
                expect(false).to_equal(true)

    it "OPTIONS request continues without CSRF check":
        val config = _test_config()
        val server_config = _test_server_config()
        val request = _test_request("OPTIONS", "/", [])
        val result = csrf_handler(request, server_config, config)
        match result:
            PhaseResult.Continue:
                expect(true).to_equal(true)
            _:
                expect(false).to_equal(true)

# ============================================================================
# Test Group 5: csrf_handler — fail-closed on empty secret (security: 4b)
# ============================================================================

describe "csrf_handler fail-closed on empty secret":
    it "POST with empty secret_key returns Error(403)":
        val config = CsrfConfig.default()
        val server_config = _test_server_config()
        val request = _test_request("POST", "/api/data",
            [("X-CSRF-Token", "sometoken"), ("Cookie", "csrf_token=sometoken")])
        val result = csrf_handler(request, server_config, config)
        match result:
            PhaseResult.Error(status, _):
                expect(status).to_equal(403)
            _:
                expect(false).to_equal(true)

    it "PUT with empty secret_key returns Error(403)":
        val config = CsrfConfig.default()
        val server_config = _test_server_config()
        val request = _test_request("PUT", "/api/data",
            [("X-CSRF-Token", "sometoken"), ("Cookie", "csrf_token=sometoken")])
        val result = csrf_handler(request, server_config, config)
        match result:
            PhaseResult.Error(status, _):
                expect(status).to_equal(403)
            _:
                expect(false).to_equal(true)

# ============================================================================
# Test Group 6: Header and cookie helpers
# ============================================================================

describe "CSRF header and cookie helpers":
    it "get_header_value finds a header case-insensitively":
        val headers = [("X-CSRF-Token", "mytoken123")]
        val result = get_header_value(headers, "x-csrf-token")
        expect(result).to_equal("mytoken123")

    it "get_header_value returns empty when header not found":
        val headers = [("Content-Type", "text/html")]
        val result = get_header_value(headers, "X-CSRF-Token")
        expect(result).to_equal("")

    it "get_cookie_value extracts named cookie":
        val headers = [("Cookie", "session=abc; csrf_token=tok456")]
        val result = get_cookie_value(headers, "csrf_token")
        expect(result).to_equal("tok456")

    it "get_cookie_value returns empty when cookie not found":
        val headers = [("Cookie", "session=abc")]
        val result = get_cookie_value(headers, "csrf_token")
        expect(result).to_equal("")

    it "get_cookie_value returns empty when no Cookie header present":
        val headers = [("Content-Type", "application/json")]
        val result = get_cookie_value(headers, "csrf_token")
        expect(result).to_equal("")
