use app.llm_dashboard.gui.dashboard_glass_css.{generate_dashboard_glass_css}

describe "dashboard_glass_css":
    describe "generate_dashboard_glass_css":
        it "AC-1: returns a non-empty CSS string":
            val css = generate_dashboard_glass_css()
            expect(css.len()).to_be_greater_than(0)

        it "AC-1: contains Stitch obsidian accent color #0A84FF":
            val css = generate_dashboard_glass_css()
            expect(css).to_contain("#0A84FF")

        it "AC-1: contains backdrop-filter for glass effect":
            val css = generate_dashboard_glass_css()
            expect(css).to_contain("backdrop-filter")

        it "AC-2: contains .tab-btn class binding":
            val css = generate_dashboard_glass_css()
            expect(css).to_contain(".tab-btn")

        it "AC-2: contains body background using Stitch surface token":
            val css = generate_dashboard_glass_css()
            expect(css).to_contain("--surface")
