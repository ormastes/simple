use std.nogc_async_mut.gc.{GcStats}

describe "nogc_async_mut GC stats":
    it "returns zero survival rate for empty stats":
        expect(GcStats.new().survival_rate()).to_equal(0.0)

    it "guards freed count above allocated count":
        val stats = GcStats(
            collections: 0,
            objects_allocated: 1,
            objects_freed: 2,
            bytes_allocated: 0,
            bytes_freed: 0,
            young_collections: 0,
            full_collections: 0,
            total_pause_time: 0,
            last_pause_time: 0
        )
        expect(stats.survival_rate()).to_equal(0.0)
