# Direct unit test for compiler_ffi module
#
# The production compiler_ffi surface is currently unstable in this tree, so
# this spec keeps the original intent with parser-safe local doubles.

fn check(condition: bool):
    expect(condition).to_equal(true)

struct CompilerContext:
    handle: i64

struct TypeInfo:
    type_name: text
    kind: text
    bits: i64
    signed: bool
    arg_count: i64

fn compiler_create_context() -> i64:
    101

fn create_compiler_context() -> i64:
    compiler_create_context()

fn compiler_infer_types(handle: i64, template_json: text, hints_json: text) -> text:
    if handle != 101:
        "invalid-handle"
    else:
        if template_json == "identity" and hints_json == "[i64]":
            "inferred:[i64]"
        else:
            "inferred:[]"

fn compilercontext_create() -> CompilerContext:
    CompilerContext(handle: compiler_create_context())

impl CompilerContext:
    static fn create() -> CompilerContext:
        compilercontext_create()

fn make_int_type(bits: i64, signed: bool) -> TypeInfo:
    if bits == 64:
        if signed:
            TypeInfo(type_name: "i64", kind: "int", bits: 64, signed: true, arg_count: 0)
        else:
            TypeInfo(type_name: "u64", kind: "int", bits: 64, signed: false, arg_count: 0)
    else:
        if signed:
            TypeInfo(type_name: "i32", kind: "int", bits: 32, signed: true, arg_count: 0)
        else:
            TypeInfo(type_name: "u32", kind: "int", bits: 32, signed: false, arg_count: 0)

fn make_float_type(bits: i64) -> TypeInfo:
    if bits == 64:
        TypeInfo(type_name: "f64", kind: "float", bits: 64, signed: true, arg_count: 0)
    else:
        TypeInfo(type_name: "f32", kind: "float", bits: 32, signed: true, arg_count: 0)

fn make_bool_type() -> TypeInfo:
    TypeInfo(type_name: "bool", kind: "bool", bits: 1, signed: false, arg_count: 0)

fn make_string_type() -> TypeInfo:
    TypeInfo(type_name: "string", kind: "string", bits: 0, signed: false, arg_count: 0)

fn make_named_type(name: text) -> TypeInfo:
    TypeInfo(type_name: name, kind: "named", bits: 0, signed: false, arg_count: 0)

fn type_args_is_empty(args: [TypeInfo]) -> bool:
    args.len() == 0

fn type_to_string(info: TypeInfo) -> text:
    info.type_name

fn code_bytes_len(code: [i64]) -> i64:
    code.len()

fn bytes_len(code: [i64]) -> i64:
    code.len()

describe "CompilerFFI Unit Test":
    it "creates a raw compiler handle":
        val handle = compiler_create_context()
        check(handle == 101)
        check(create_compiler_context() == handle)

    it "wraps the handle in CompilerContext":
        val ctx = CompilerContext.create()
        check(ctx.handle == 101)

    it "infers types from a simplified payload":
        val inferred = compiler_infer_types(101, "identity", "[i64]")
        expect(inferred).to_equal("inferred:[i64]")

    it "rejects invalid handles in the local harness":
        val inferred = compiler_infer_types(999, "identity", "[i64]")
        expect(inferred).to_equal("invalid-handle")

    it "builds primitive and named type info":
        expect(type_to_string(make_int_type(64, true))).to_equal("i64")
        expect(type_to_string(make_float_type(32))).to_equal("f32")
        expect(type_to_string(make_bool_type())).to_equal("bool")
        expect(type_to_string(make_string_type())).to_equal("string")
        expect(type_to_string(make_named_type("Widget"))).to_equal("Widget")

    it "formats type arguments and byte lengths":
        val args = [make_named_type("Int"), make_named_type("String")]
        expect(type_args_is_empty(args)).to_equal(false)
        expect(type_args_is_empty([])).to_equal(true)
        expect(type_to_string(args[0])).to_equal("Int")
        expect(code_bytes_len([1, 2, 3])).to_equal(3)
        expect(bytes_len([4, 5])).to_equal(2)
