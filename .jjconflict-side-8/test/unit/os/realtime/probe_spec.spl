use std.spipe.*

# Inline probe config types (i64 for interpreter mode)

val PROBE_TYPE_OPENOCD: i64 = 0
val PROBE_TYPE_TRACE32: i64 = 1

class ProbeConfig:
    probe_type: i64
    host: text
    port: i64
    target_arch: text

    static fn openocd(host: text, port: i64, arch: text) -> ProbeConfig:
        ProbeConfig(probe_type: PROBE_TYPE_OPENOCD, host: host, port: port, target_arch: arch)

    static fn trace32(host: text, port: i64, arch: text) -> ProbeConfig:
        ProbeConfig(probe_type: PROBE_TYPE_TRACE32, host: host, port: port, target_arch: arch)

# Inline register name helpers (no string interpolation in loops for interpreter safety)

fn get_t32_register_names(arch: text) -> [text]:
    var names: [text] = []
    if arch == "arm":
        names = ["R0", "R1", "R2", "R3", "R4", "R5", "R6", "R7",
                 "R8", "R9", "R10", "R11", "R12", "R13", "R14", "R15", "CPSR"]
    if arch == "riscv32":
        names = ["X0", "X1", "X2", "X3", "X4", "X5", "X6", "X7",
                 "X8", "X9", "X10", "X11", "X12", "X13", "X14", "X15",
                 "X16", "X17", "X18", "X19", "X20", "X21", "X22", "X23",
                 "X24", "X25", "X26", "X27", "X28", "X29", "X30", "X31", "PC"]
    if arch == "x86_64":
        names = ["RAX", "RBX", "RCX", "RDX", "RSI", "RDI", "RBP", "RSP",
                 "R8", "R9", "R10", "R11", "R12", "R13", "R14", "R15",
                 "RIP", "RFLAGS"]
    names

# ============================================================================
# Tests
# ============================================================================

describe "ProbeConfig construction":
    it "openocd factory sets fields":
        val cfg = ProbeConfig.openocd("localhost", 3333, "arm")
        expect(cfg.probe_type).to_equal(PROBE_TYPE_OPENOCD)
        expect(cfg.host).to_equal("localhost")
        expect(cfg.port).to_equal(3333)
        expect(cfg.target_arch).to_equal("arm")

    it "trace32 factory sets fields":
        val cfg = ProbeConfig.trace32("192.168.1.10", 20000, "riscv32")
        expect(cfg.probe_type).to_equal(PROBE_TYPE_TRACE32)
        expect(cfg.host).to_equal("192.168.1.10")
        expect(cfg.port).to_equal(20000)
        expect(cfg.target_arch).to_equal("riscv32")

    it "probe type constants are distinct":
        expect(PROBE_TYPE_OPENOCD).to_equal(0)
        expect(PROBE_TYPE_TRACE32).to_equal(1)

describe "ARM register names":
    it "returns 17 registers":
        val names = get_t32_register_names("arm")
        expect(names.len()).to_equal(17)

    it "starts with R0":
        val names = get_t32_register_names("arm")
        expect(names[0]).to_equal("R0")

    it "ends with CPSR":
        val names = get_t32_register_names("arm")
        expect(names[16]).to_equal("CPSR")

    it "contains R15":
        val names = get_t32_register_names("arm")
        expect(names).to_contain("R15")

describe "RISC-V register names":
    it "returns 33 registers":
        val names = get_t32_register_names("riscv32")
        expect(names.len()).to_equal(33)

    it "starts with X0":
        val names = get_t32_register_names("riscv32")
        expect(names[0]).to_equal("X0")

    it "ends with PC":
        val names = get_t32_register_names("riscv32")
        expect(names[32]).to_equal("PC")

    it "contains X31":
        val names = get_t32_register_names("riscv32")
        expect(names).to_contain("X31")

describe "x86_64 register names":
    it "returns 18 registers":
        val names = get_t32_register_names("x86_64")
        expect(names.len()).to_equal(18)

    it "starts with RAX":
        val names = get_t32_register_names("x86_64")
        expect(names[0]).to_equal("RAX")

    it "contains RIP":
        val names = get_t32_register_names("x86_64")
        expect(names).to_contain("RIP")

    it "contains RFLAGS":
        val names = get_t32_register_names("x86_64")
        expect(names).to_contain("RFLAGS")

describe "Unknown arch":
    it "returns empty list":
        val names = get_t32_register_names("mips")
        expect(names.len()).to_equal(0)
