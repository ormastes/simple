# glTF Asset Types — Data Structures for glTF/GLB Import
#
# Structs and classes for meshes, materials, bones, skins,
# animations, nodes, and transforms from the glTF 2.0 format.

# ============================================================================
# Math Primitives
# ============================================================================

struct GltfVec3:
    x: f64
    y: f64
    z: f64

struct GltfQuat:
    x: f64
    y: f64
    z: f64
    w: f64

impl GltfQuat:
    static fn identity() -> GltfQuat:
        GltfQuat(x: 0.0, y: 0.0, z: 0.0, w: 1.0)

struct GltfTransform:
    translation: GltfVec3
    rotation: GltfQuat
    scale: GltfVec3

impl GltfTransform:
    static fn identity() -> GltfTransform:
        GltfTransform(
            translation: GltfVec3(x: 0.0, y: 0.0, z: 0.0),
            rotation: GltfQuat.identity(),
            scale: GltfVec3(x: 1.0, y: 1.0, z: 1.0)
        )

# ============================================================================
# Vertex and Mesh
# ============================================================================

struct GltfVertex:
    px: f64
    py: f64
    pz: f64
    nx: f64
    ny: f64
    nz: f64
    u: f64
    v: f64

class GltfMesh:
    name: text
    vertices: [GltfVertex]
    indices: [i32]

impl GltfMesh:
    static fn new(name: text) -> GltfMesh:
        GltfMesh(name: name, vertices: [], indices: [])

    me add_vertex(px: f64, py: f64, pz: f64, nx: f64, ny: f64, nz: f64, u: f64, v: f64):
        self.vertices.push(GltfVertex(
            px: px, py: py, pz: pz,
            nx: nx, ny: ny, nz: nz,
            u: u, v: v
        ))

    me add_index(idx: i32):
        self.indices.push(idx)

    fn vertex_count() -> i32:
        self.vertices.len()

    fn index_count() -> i32:
        self.indices.len()

    fn triangle_count() -> i32:
        self.indices.len() / 3

# ============================================================================
# Material (PBR Metallic-Roughness)
# ============================================================================

struct GltfMaterial:
    name: text
    base_color_r: f64
    base_color_g: f64
    base_color_b: f64
    base_color_a: f64
    metallic: f64
    roughness: f64
    emissive_r: f64
    emissive_g: f64
    emissive_b: f64
    texture_path: text

impl GltfMaterial:
    static fn new(name: text) -> GltfMaterial:
        GltfMaterial(
            name: name,
            base_color_r: 1.0,
            base_color_g: 1.0,
            base_color_b: 1.0,
            base_color_a: 1.0,
            metallic: 0.0,
            roughness: 0.5,
            emissive_r: 0.0,
            emissive_g: 0.0,
            emissive_b: 0.0,
            texture_path: ""
        )

    fn is_metallic() -> bool:
        self.metallic > 0.5

# ============================================================================
# Skeleton / Skin
# ============================================================================

struct GltfBone:
    name: text
    index: i32
    parent_index: i32
    bind_transform: GltfTransform

class GltfSkin:
    name: text
    bones: [GltfBone]
    root_bone_index: i32

impl GltfSkin:
    static fn new(name: text) -> GltfSkin:
        GltfSkin(name: name, bones: [], root_bone_index: -1)

    me add_bone(name: text, parent_index: i32, bind_transform: GltfTransform) -> i32:
        val idx = self.bones.len()
        self.bones.push(GltfBone(
            name: name,
            index: idx,
            parent_index: parent_index,
            bind_transform: bind_transform
        ))
        idx

    fn bone_count() -> i32:
        self.bones.len()

    fn find_bone(bone_name: text) -> i32:
        var i = 0
        while i < self.bones.len():
            if self.bones[i].name == bone_name:
                return i
            i = i + 1
        -1

# ============================================================================
# Animation
# ============================================================================

struct GltfAnimChannel:
    bone_index: i32
    property: text
    times: [f64]
    values: [f64]

class GltfAnimation:
    name: text
    channels: [GltfAnimChannel]
    duration: f64

impl GltfAnimation:
    static fn new(name: text) -> GltfAnimation:
        GltfAnimation(name: name, channels: [], duration: 0.0)

    me add_channel(channel: GltfAnimChannel):
        self.channels.push(channel)

    fn channel_count() -> i32:
        self.channels.len()

# ============================================================================
# Scene Node
# ============================================================================

class GltfNode:
    name: text
    mesh_index: i32
    skin_index: i32
    transform: GltfTransform
    children: [i32]

impl GltfNode:
    static fn new(name: text) -> GltfNode:
        GltfNode(
            name: name,
            mesh_index: -1,
            skin_index: -1,
            transform: GltfTransform.identity(),
            children: []
        )
