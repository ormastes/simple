# Editor Theme Manager Extension
#
# Manages color themes: loading, switching, and querying colors
# for syntax highlighting and UI elements.

struct ThemeColor:
    key: text
    fg: text
    bg: text
    bold: bool
    italic: bool

struct Theme:
    name: text
    colors: [ThemeColor]
    is_dark: bool

struct ThemeManager:
    themes: [Theme]
    active_theme: text

fn theme_manager_new() -> ThemeManager:
    ThemeManager(themes: [], active_theme: "default")

fn theme_manager_with_themes(themes: [Theme]) -> ThemeManager:
    val active = if themes.len() > 0 then themes[0].name else: "default"
    ThemeManager(themes: themes, active_theme: active)

fn theme_manager_set_theme(manager: ThemeManager, name: text) -> ThemeManager:
    ThemeManager(themes: manager.themes, active_theme: name)

fn theme_manager_active(manager: ThemeManager) -> Theme:
    for t in manager.themes:
        if t.name == manager.active_theme:
            return t
    Theme(name: "default", colors: [], is_dark: true)

fn theme_manager_color(manager: ThemeManager, key: text) -> ThemeColor:
    val theme = theme_manager_active(manager)
    for c in theme.colors:
        if c.key == key:
            return c
    ThemeColor(key: key, fg: "", bg: "", bold: false, italic: false)
