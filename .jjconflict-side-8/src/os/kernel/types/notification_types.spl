# Notification Types — L4-style lightweight async event signaling
#
# All fields use primitive types for baremetal ABI safety.

# Notification bit assignments for device drivers
val NOTIFY_IRQ: u64 = 1
val NOTIFY_TIMER: u64 = 2
val NOTIFY_IPC_READY: u64 = 4
val NOTIFY_DMA_COMPLETE: u64 = 8
val NOTIFY_SHUTDOWN: u64 = 16

struct Notification:
    id: u64
    bits: u64        # 64-bit bitmask, each bit = distinct event
    waiter_ids: [u64]           # threads waiting on this notification
    signaled_waiter_ids: [u64]  # threads staged for wake after signal
