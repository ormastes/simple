# native-build codegen bugs: `text.to_int()` and text `>=` both miscompile.
#
#   bin/simple native-build --runtime-bundle core-c-bootstrap \
#       --entry doc/08_tracking/bug/repro/native_text_ordering_to_int_repro.spl \
#       --output /tmp/r && /tmp/r
#   bin/simple run doc/08_tracking/bug/repro/native_text_ordering_to_int_repro.spl   # baseline
#
# native-build (buggy):
#   "1".to_int() -> <value:0x1>     (tagged garbage, not raw i64)
#   "136".to_int() -> 17            (wrong)
#   "5" >= "0" -> false             (wrong; "5" <= "9" -> true is correct)
#   parse_bad("136") -> 0 ; parse_good("136") -> 136
# interpreter: all correct.

fn parse_bad(s: text) -> i64:
    var result: i64 = 0
    var i = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch >= "0" and ch <= "9":          # text `>=` miscompiles -> false
            result = result * 10 + (ch.to_int())   # .to_int() returns garbage
        else:
            return result
        i = i + 1
    result

fn parse_good(s: text) -> i64:
    var result: i64 = 0
    var i = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch == "0":
            result = result * 10
        elif ch == "1":
            result = result * 10 + 1
        elif ch == "2":
            result = result * 10 + 2
        elif ch == "3":
            result = result * 10 + 3
        elif ch == "4":
            result = result * 10 + 4
        elif ch == "5":
            result = result * 10 + 5
        elif ch == "6":
            result = result * 10 + 6
        elif ch == "7":
            result = result * 10 + 7
        elif ch == "8":
            result = result * 10 + 8
        elif ch == "9":
            result = result * 10 + 9
        else:
            return result
        i = i + 1
    result

fn main():
    println("toint_1=" + str(("1").to_int()))
    println("toint_136=" + str(("136").to_int()))
    println("ge_5_0=" + str("5" >= "0"))
    println("le_5_9=" + str("5" <= "9"))
    println("parse_bad_136=" + str(parse_bad("136")))
    println("parse_good_136=" + str(parse_good("136")))
