use std.io_runtime

class SyscallCap:
    name: text
    status: text

    static fn ready(n: text) -> SyscallCap:
        SyscallCap(name: n, status: "ready")

    static fn stub(n: text) -> SyscallCap:
        SyscallCap(name: n, status: "stub")

    me is_usable() -> bool:
        if self.status == "ready":
            return true
        if self.status == "partial":
            return true
        return false

class DeviceReady:
    name: text
    available: bool
    meets_min: bool

    static fn create(n: text, avail: bool, min: bool) -> DeviceReady:
        DeviceReady(name: n, available: avail, meets_min: min)

class SandboxCap:
    name: text
    granted: bool

    static fn permit(n: text) -> SandboxCap:
        SandboxCap(name: n, granted: true)

    static fn deny(n: text) -> SandboxCap:
        SandboxCap(name: n, granted: false)

class ProtonComp:
    name: text
    status: text
    blocker: text

    static fn ready(n: text) -> ProtonComp:
        ProtonComp(name: n, status: "ready", blocker: "")

    static fn blocked(n: text, reason: text) -> ProtonComp:
        ProtonComp(name: n, status: "blocked", blocker: reason)

    me is_usable() -> bool:
        return self.status == "ready"

class CompatEntry:
    api: text
    status: text

    static fn native(a: text) -> CompatEntry:
        CompatEntry(api: a, status: "native")

    static fn missing(a: text) -> CompatEntry:
        CompatEntry(api: a, status: "missing")

    me is_functional() -> bool:
        if self.status == "native":
            return true
        if self.status == "translated":
            return true
        return false

fn test_syscall_ready_is_usable():
    val s = SyscallCap.ready("mmap")
    if s.is_usable():
        print("PASS: test_syscall_ready_is_usable")
    else:
        print("FAIL: test_syscall_ready_is_usable")

fn test_syscall_stub_not_usable():
    val s = SyscallCap.stub("futex")
    if s.is_usable() == false:
        print("PASS: test_syscall_stub_not_usable")
    else:
        print("FAIL: test_syscall_stub_not_usable")

fn test_game_viable_needs_core_syscalls():
    val elf = SyscallCap.ready("elf")
    val dynlink = SyscallCap.ready("dynlink")
    val mmap = SyscallCap.ready("mmap")
    val clone = SyscallCap.stub("clone")
    var viable = true
    if elf.is_usable() == false:
        viable = false
    if dynlink.is_usable() == false:
        viable = false
    if mmap.is_usable() == false:
        viable = false
    if clone.is_usable() == false:
        viable = false
    if viable == false:
        print("PASS: test_game_viable_needs_core_syscalls")
    else:
        print("FAIL: test_game_viable_needs_core_syscalls")

fn test_vfs_minimal_viable():
    var proc_exe = true
    var dev_null = true
    var dev_zero = true
    var dev_urandom = true
    if proc_exe:
        if dev_null:
            if dev_zero:
                if dev_urandom:
                    print("PASS: test_vfs_minimal_viable")
                    return
    print("FAIL: test_vfs_minimal_viable")

fn test_gpu_meets_minimum():
    var vulkan = true
    var vram = 2048
    if vulkan:
        if vram >= 1024:
            print("PASS: test_gpu_meets_minimum")
            return
    print("FAIL: test_gpu_meets_minimum")

fn test_gpu_below_minimum():
    var vulkan = true
    var vram = 512
    var meets = true
    if vram < 1024:
        meets = false
    if meets == false:
        print("PASS: test_gpu_below_minimum")
    else:
        print("FAIL: test_gpu_below_minimum")

fn test_cpu_meets_minimum():
    var bits = 64
    var cores = 4
    var simd = "avx2"
    var meets = true
    if bits < 64:
        meets = false
    if cores < 2:
        meets = false
    if simd == "none":
        meets = false
    if meets:
        print("PASS: test_cpu_meets_minimum")
    else:
        print("FAIL: test_cpu_meets_minimum")

fn test_all_device_minimum():
    val d_gpu = DeviceReady.create("gpu", true, true)
    val d_audio = DeviceReady.create("audio", true, true)
    val d_input = DeviceReady.create("input", true, true)
    val d_net = DeviceReady.create("network", true, true)
    val d_fs = DeviceReady.create("fs", true, true)
    val d_cpu = DeviceReady.create("cpu", true, true)
    var count = 0
    if d_gpu.meets_min:
        count = count + 1
    if d_audio.meets_min:
        count = count + 1
    if d_input.meets_min:
        count = count + 1
    if d_net.meets_min:
        count = count + 1
    if d_fs.meets_min:
        count = count + 1
    if d_cpu.meets_min:
        count = count + 1
    if count == 6:
        print("PASS: test_all_device_minimum")
    else:
        print("FAIL: test_all_device_minimum")

fn test_sandbox_deny_by_default():
    val net = SandboxCap.deny("network")
    val ipc = SandboxCap.deny("ipc")
    if net.granted == false:
        if ipc.granted == false:
            print("PASS: test_sandbox_deny_by_default")
            return
    print("FAIL: test_sandbox_deny_by_default")

fn test_sandbox_game_grants():
    val sg = SandboxCap.permit("gpu")
    val sa = SandboxCap.permit("audio")
    val si = SandboxCap.permit("input")
    if sg.granted:
        if sa.granted:
            if si.granted:
                print("PASS: test_sandbox_game_grants")
                return
    print("FAIL: test_sandbox_game_grants")

fn test_sandbox_check_denied():
    val cap = SandboxCap.deny("camera")
    var result = ""
    if cap.granted == false:
        result = "denied:camera:capture"
    if result == "denied:camera:capture":
        print("PASS: test_sandbox_check_denied")
    else:
        print("FAIL: test_sandbox_check_denied")

fn test_proton_wine_ready():
    val wine = ProtonComp.ready("wine")
    if wine.is_usable():
        print("PASS: test_proton_wine_ready")
    else:
        print("FAIL: test_proton_wine_ready")

fn test_proton_blocked():
    val mf = ProtonComp.blocked("media_foundation", "no codec pack")
    if mf.is_usable() == false:
        if mf.blocker == "no codec pack":
            print("PASS: test_proton_blocked")
            return
    print("FAIL: test_proton_blocked")

fn test_proton_viable_needs_wine_dxvk():
    val wine = ProtonComp.ready("wine")
    val dxvk = ProtonComp.ready("dxvk")
    var viable = true
    if wine.is_usable() == false:
        viable = false
    if dxvk.is_usable() == false:
        viable = false
    if viable:
        print("PASS: test_proton_viable_needs_wine_dxvk")
    else:
        print("FAIL: test_proton_viable_needs_wine_dxvk")

fn test_compat_native_functional():
    val e = CompatEntry.native("CreateFile")
    if e.is_functional():
        print("PASS: test_compat_native_functional")
    else:
        print("FAIL: test_compat_native_functional")

fn test_compat_missing_not_functional():
    val e = CompatEntry.missing("NtQueryObject")
    if e.is_functional() == false:
        print("PASS: test_compat_missing_not_functional")
    else:
        print("FAIL: test_compat_missing_not_functional")

fn test_porting_viability():
    var coverage = 75
    var failures = 0
    var viable = true
    if coverage < 70:
        viable = false
    if failures > 0:
        viable = false
    if viable:
        print("PASS: test_porting_viability")
    else:
        print("FAIL: test_porting_viability")

fn test_porting_not_viable_low_coverage():
    var coverage = 50
    var failures = 0
    var viable = true
    if coverage < 70:
        viable = false
    if viable == false:
        print("PASS: test_porting_not_viable_low_coverage")
    else:
        print("FAIL: test_porting_not_viable_low_coverage")

fn main():
    test_syscall_ready_is_usable()
    test_syscall_stub_not_usable()
    test_game_viable_needs_core_syscalls()
    test_vfs_minimal_viable()
    test_gpu_meets_minimum()
    test_gpu_below_minimum()
    test_cpu_meets_minimum()
    test_all_device_minimum()
    test_sandbox_deny_by_default()
    test_sandbox_game_grants()
    test_sandbox_check_denied()
    test_proton_wine_ready()
    test_proton_blocked()
    test_proton_viable_needs_wine_dxvk()
    test_compat_native_functional()
    test_compat_missing_not_functional()
    test_porting_viability()
    test_porting_not_viable_low_coverage()
    print("DONE")
