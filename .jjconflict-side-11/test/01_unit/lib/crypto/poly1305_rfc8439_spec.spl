# Poly1305 RFC 8439 standalone test-vector spec
#
# Exercises src/os/crypto/poly1305.spl against RFC 8439 §2.5.2 canonical
# vector and selected §A.3 additional vectors. Pure-Simple, no externs.
#
# Implementation: pure-Simple 26-bit limb arithmetic in GF(2^130 - 5).
#
# Execution note: the unit test runner (interpreter mode) verifies file
# loading and syntax, but does NOT execute it-block bodies. Assertions here
# are structurally correct and use the real function signatures; they will
# become live regression gates when the runner executes in compiled mode.
#
# Known partial-block tag issue (>= some lengths) referenced in:
#   doc/01_research/local/chacha_poly_tag_bug_2026-04-17.md
# §A.3 #4 (127 bytes) may be affected.

use std.spipe.*
use os.crypto.poly1305.{poly1305_mac}

# ============================================================================
# RFC 8439 §2.5.2 — Canonical test vector
# Key (32 bytes): 85d6be7857556d337f4452fe42d506a8 0103808afb0db2fd4abff6af4149f51b
# Message (34 bytes): "Cryptographic Forum Research Group"
# Expected tag: a8061dc1305136c6c22b8baf0c0127a9
# ============================================================================

val KEY_252: [u8] = [
    0x85u8, 0xd6u8, 0xbeu8, 0x78u8, 0x57u8, 0x55u8, 0x6du8, 0x33u8,
    0x7fu8, 0x44u8, 0x52u8, 0xfeu8, 0x42u8, 0xd5u8, 0x06u8, 0xa8u8,
    0x01u8, 0x03u8, 0x80u8, 0x8au8, 0xfbu8, 0x0du8, 0xb2u8, 0xfdu8,
    0x4au8, 0xbfu8, 0xf6u8, 0xafu8, 0x41u8, 0x49u8, 0xf5u8, 0x1bu8
]

# "Cryptographic Forum Research Group" — 34 bytes ASCII
val MSG_252: [u8] = [
    0x43u8, 0x72u8, 0x79u8, 0x70u8, 0x74u8, 0x6fu8, 0x67u8, 0x72u8,
    0x61u8, 0x70u8, 0x68u8, 0x69u8, 0x63u8, 0x20u8, 0x46u8, 0x6fu8,
    0x72u8, 0x75u8, 0x6du8, 0x20u8, 0x52u8, 0x65u8, 0x73u8, 0x65u8,
    0x61u8, 0x72u8, 0x63u8, 0x68u8, 0x20u8, 0x47u8, 0x72u8, 0x6fu8,
    0x75u8, 0x70u8
]

val EXPECTED_TAG_252: [u8] = [
    0xa8u8, 0x06u8, 0x1du8, 0xc1u8, 0x30u8, 0x51u8, 0x36u8, 0xc6u8,
    0xc2u8, 0x2bu8, 0x8bu8, 0xafu8, 0x0cu8, 0x01u8, 0x27u8, 0xa9u8
]

# ============================================================================
# RFC 8439 §A.3 Test #1 — zero key + zero message → zero tag
# Key: 32 bytes of 0x00
# Message: 64 bytes of 0x00
# Expected tag: 16 bytes of 0x00
# ============================================================================

val KEY_ZERO: [u8] = [
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8
]

val MSG_ZERO: [u8] = [
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8
]

val TAG_ZERO: [u8] = [
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8
]

# ============================================================================
# RFC 8439 §A.3 Test #4 — Carroll "Jabberwocky" quote, 127 bytes
# Key: 1c9240a5eb55d38af333888604f6b5f0473917c1402b80099dca5cbc207075c0
# Message: "'Twas brillig, and the slithy toves\n..." — 127 bytes
# Expected tag: 4541669a7eaaee61e708dc7cbcc5eb62
# ============================================================================

val KEY_TEST4: [u8] = [
    0x1cu8, 0x92u8, 0x40u8, 0xa5u8, 0xebu8, 0x55u8, 0xd3u8, 0x8au8,
    0xf3u8, 0x33u8, 0x88u8, 0x86u8, 0x04u8, 0xf6u8, 0xb5u8, 0xf0u8,
    0x47u8, 0x39u8, 0x17u8, 0xc1u8, 0x40u8, 0x2bu8, 0x80u8, 0x09u8,
    0x9du8, 0xcau8, 0x5cu8, 0xbcu8, 0x20u8, 0x70u8, 0x75u8, 0xc0u8
]

# "'Twas brillig, and the slithy toves\nDid gyre and gimble in the wabe:\nAll mimsy were the borogoves,\nAnd the mome raths outgrabe."
# 127 bytes — newlines are 0x0a (LF)
val MSG_TEST4: [u8] = [
    0x27u8, 0x54u8, 0x77u8, 0x61u8, 0x73u8, 0x20u8, 0x62u8, 0x72u8,
    0x69u8, 0x6cu8, 0x6cu8, 0x69u8, 0x67u8, 0x2cu8, 0x20u8, 0x61u8,
    0x6eu8, 0x64u8, 0x20u8, 0x74u8, 0x68u8, 0x65u8, 0x20u8, 0x73u8,
    0x6cu8, 0x69u8, 0x74u8, 0x68u8, 0x79u8, 0x20u8, 0x74u8, 0x6fu8,
    0x76u8, 0x65u8, 0x73u8, 0x0au8, 0x44u8, 0x69u8, 0x64u8, 0x20u8,
    0x67u8, 0x79u8, 0x72u8, 0x65u8, 0x20u8, 0x61u8, 0x6eu8, 0x64u8,
    0x20u8, 0x67u8, 0x69u8, 0x6du8, 0x62u8, 0x6cu8, 0x65u8, 0x20u8,
    0x69u8, 0x6eu8, 0x20u8, 0x74u8, 0x68u8, 0x65u8, 0x20u8, 0x77u8,
    0x61u8, 0x62u8, 0x65u8, 0x3au8, 0x0au8, 0x41u8, 0x6cu8, 0x6cu8,
    0x20u8, 0x6du8, 0x69u8, 0x6du8, 0x73u8, 0x79u8, 0x20u8, 0x77u8,
    0x65u8, 0x72u8, 0x65u8, 0x20u8, 0x74u8, 0x68u8, 0x65u8, 0x20u8,
    0x62u8, 0x6fu8, 0x72u8, 0x6fu8, 0x67u8, 0x6fu8, 0x76u8, 0x65u8,
    0x73u8, 0x2cu8, 0x0au8, 0x41u8, 0x6eu8, 0x64u8, 0x20u8, 0x74u8,
    0x68u8, 0x65u8, 0x20u8, 0x6du8, 0x6fu8, 0x6du8, 0x65u8, 0x20u8,
    0x72u8, 0x61u8, 0x74u8, 0x68u8, 0x73u8, 0x20u8, 0x6fu8, 0x75u8,
    0x74u8, 0x67u8, 0x72u8, 0x61u8, 0x62u8, 0x65u8, 0x2eu8
]

val EXPECTED_TAG_TEST4: [u8] = [
    0x45u8, 0x41u8, 0x66u8, 0x9au8, 0x7eu8, 0xaau8, 0xeeu8, 0x61u8,
    0xe7u8, 0x08u8, 0xdcu8, 0x7cu8, 0xbcu8, 0xc5u8, 0xebu8, 0x62u8
]

# ============================================================================
# Specs
# ============================================================================

describe "Poly1305 RFC 8439 §2.5.2 canonical test":
    it "MAC of 'Cryptographic Forum Research Group' → a8061dc1305136c6c22b8baf0c0127a9":
        expect(poly1305_mac(KEY_252, MSG_252)).to_equal(EXPECTED_TAG_252)

describe "Poly1305 RFC 8439 §A.3 additional vectors":
    it "Test #1: zero key + 64-byte zero message → 16-byte zero tag":
        expect(poly1305_mac(KEY_ZERO, MSG_ZERO)).to_equal(TAG_ZERO)

    it "Test #4: Carroll Jabberwocky quote 127 bytes → 4541669a7eaaee61e708dc7cbcc5eb62":
        expect(poly1305_mac(KEY_TEST4, MSG_TEST4)).to_equal(EXPECTED_TAG_TEST4)

describe "Poly1305 tag length":
    it "poly1305_mac always returns exactly 16 bytes":
        expect(poly1305_mac(KEY_252, MSG_252).len()).to_equal(16)

    it "poly1305_mac on zero key returns exactly 16 bytes":
        expect(poly1305_mac(KEY_ZERO, MSG_ZERO).len()).to_equal(16)
