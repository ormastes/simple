extern fn rt_file_read_text(path: text) -> text

fn _contains_negative_offset_guard(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn mqtt_decode_string(bytes, offset):") and
        source.to_contain("fn mqtt_decode_binary(bytes, offset):") and
        source.to_contain("fn mqtt_decode_two_byte_int(bytes, offset):") and
        source.to_contain("fn mqtt_decode_four_byte_int(bytes, offset):") and
        source.to_contain("fn mqtt_decode_variable_byte_int(bytes, offset):") and
        source.to_contain("if offset < 0:\n        return nil")

describe "mqtt packet negative offset guard":
    it "guards mirrored packet decode helpers before field indexing":
        expect(_contains_negative_offset_guard("src/lib/nogc_sync_mut/mqtt/packet.spl")).to_equal(true)
        expect(_contains_negative_offset_guard("src/lib/nogc_async_mut/mqtt/packet.spl")).to_equal(true)
        expect(_contains_negative_offset_guard("src/lib/gc_async_mut/mqtt/packet.spl")).to_equal(true)

        val facade_source = rt_file_read_text("src/lib/gc_sync_mut/mqtt/packet.spl") ?? ""
        expect(facade_source).to_contain("export use std.gc_async_mut.mqtt.packet.*")
