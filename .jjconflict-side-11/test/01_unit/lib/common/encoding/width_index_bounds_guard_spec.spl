use std.spec.{describe, it, assert_equal}
use std.encoding.width_index.{WidthIndex}

describe "WidthIndex bounds guards":
    it "rejects negative character indexes":
        val idx = WidthIndex.for_text("abc")
        assert_equal(idx.char_to_byte(-1), -1)
        assert_equal(idx.char_at(-1), "")

    it "rejects negative byte indexes":
        val idx = WidthIndex.for_text("abc")
        assert_equal(idx.byte_to_char(-1), -1)

    it "keeps valid zero indexes":
        val idx = WidthIndex.for_text("abc")
        assert_equal(idx.char_to_byte(0), 0)
        assert_equal(idx.byte_to_char(0), 0)
