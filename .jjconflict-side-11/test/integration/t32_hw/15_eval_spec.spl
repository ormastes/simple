# T32 Hardware -- Eval Expressions
#
# Tests eval_expr with VERSION.BUILD(), STATE.RUN(), DEBUGMODE(),
# Register(PC), and an invalid expression.
# All expressions used here are available in all T32 versions (old + new).
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, old_tools
# @reuse: exclusive_reused

use std.spipe.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port
}

describe "T32 eval expressions":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "valid expressions":
        it "eval VERSION.BUILD()":
            val result = t32_hw_eval(client, "VERSION.BUILD()")
            match result:
                Ok(v):
                    # VERSION.BUILD returns a numeric string like "134567"
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("VERSION.BUILD failed: {e}").to_equal("")

        it "eval STATE.RUN()":
            val result = t32_hw_eval(client, "STATE.RUN()")
            match result:
                Ok(v):
                    # Returns "TRUE" or "FALSE" -- non-empty means valid response
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("STATE.RUN failed: {e}").to_equal("")

        it "eval DEBUGMODE()":
            val result = t32_hw_eval(client, "DEBUGMODE()")
            match result:
                Ok(v):
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("DEBUGMODE failed: {e}").to_equal("")

        it "eval Register(PC)":
            val result = t32_hw_eval(client, "Register(PC)")
            match result:
                Ok(v):
                    # PC register returns a hex value like "0x00008000"
                    expect(v.len()).to_be_greater_than(0)
                Err(e):
                    expect("Register(PC) failed: {e}").to_equal("")

    context "invalid expressions":
        it "eval invalid expression":
            val result = t32_hw_eval(client, "NONEXISTENT.FUNC.12345()")
            match result:
                Err(_): expect("error accepted").to_contain("accepted")
                Ok(_):
                    # Some T32 versions may return empty on bad expr
                    expect("accepted ok").to_contain("ok")
