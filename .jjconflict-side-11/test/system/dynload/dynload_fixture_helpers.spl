"""Shared synthetic binary fixture builders for dynload system tests.

Provides functions to construct valid ELF64, SMF-wrapped-ELF64, and PE64
byte arrays in memory. These are used by all dynload system specs to avoid
duplicating fixture construction logic.

# TODO(dynload-system-tests): switch to gcc -shared + file_read_bytes
# once interpreter FFI [u8] wrapping bug is fixed (see D-1 in state.md).
"""

# ============================================================================
# ELF64 byte-level helpers
# ============================================================================

fn push_u16_le(buf: [u8], value: i64) -> [u8]:
    """Append a little-endian u16 to buf."""
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf

fn push_u32_le(buf: [u8], value: i64) -> [u8]:
    """Append a little-endian u32 to buf."""
    buf.push((value & 0xFF).to_u8())
    buf.push(((value >> 8) & 0xFF).to_u8())
    buf.push(((value >> 16) & 0xFF).to_u8())
    buf.push(((value >> 24) & 0xFF).to_u8())
    buf

fn push_u64_le(buf: [u8], value: i64) -> [u8]:
    """Append a little-endian u64 to buf."""
    var out = buf
    out = push_u32_le(out, value & 0xFFFFFFFF)
    out = push_u32_le(out, (value >> 32) & 0xFFFFFFFF)
    out

fn pad_to(buf: [u8], target: i64) -> [u8]:
    """Zero-pad buf to target length."""
    while buf.len() < target:
        buf.push(0.to_u8())
    buf

# ============================================================================
# ELF64 fixture builders
# ============================================================================

fn make_elf64_exec() -> [u8]:
    """Build a minimal valid ELF64 ET_EXEC with entry point 0x400000."""
    var bytes: [u8] = []
    # ELF magic
    bytes.push(0x7F.to_u8())
    bytes.push(0x45.to_u8())
    bytes.push(0x4C.to_u8())
    bytes.push(0x46.to_u8())
    # Class=64-bit, Data=LE, Version=1, OS/ABI=0, padding
    bytes.push(2.to_u8())
    bytes.push(1.to_u8())
    bytes.push(1.to_u8())
    bytes.push(0.to_u8())
    bytes.push(0.to_u8())
    while bytes.len() < 16:
        bytes.push(0.to_u8())
    # e_type=ET_EXEC(2), e_machine=x86_64(62), e_version=1
    bytes = push_u16_le(bytes, 2)
    bytes = push_u16_le(bytes, 62)
    bytes = push_u32_le(bytes, 1)
    # e_entry=0x400000
    bytes = push_u64_le(bytes, 0x400000)
    # e_phoff=64
    bytes = push_u64_le(bytes, 64)
    # e_shoff=0 (no section headers)
    bytes = push_u64_le(bytes, 0)
    # e_flags=0
    bytes = push_u32_le(bytes, 0)
    # e_ehsize=64, e_phentsize=56, e_phnum=1
    bytes = push_u16_le(bytes, 64)
    bytes = push_u16_le(bytes, 56)
    bytes = push_u16_le(bytes, 1)
    # e_shentsize=0, e_shnum=0, e_shstrndx=0
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    bytes = push_u16_le(bytes, 0)
    # PT_LOAD program header
    bytes = push_u32_le(bytes, 1)
    bytes = push_u32_le(bytes, 5)
    bytes = push_u64_le(bytes, 0x1000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 0x400000)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 4)
    bytes = push_u64_le(bytes, 0x1000)
    # Code section (RET instruction)
    while bytes.len() < 0x1000:
        bytes.push(0.to_u8())
    bytes.push(0xC3.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes.push(0x00.to_u8())
    bytes

fn make_elf64_with_dynsym() -> [u8]:
    """Build minimal ELF64 with .dynsym containing symbol 'hello' at 0xBEEF."""
    var b: [u8] = []
    # ELF ident
    b.push(0x7F.to_u8())
    b.push(0x45.to_u8())
    b.push(0x4C.to_u8())
    b.push(0x46.to_u8())
    b.push(2.to_u8())
    b.push(1.to_u8())
    b.push(1.to_u8())
    b = pad_to(b, 16)
    # e_type=ET_EXEC, e_machine=x86_64, e_version=1
    b = push_u16_le(b, 2)
    b = push_u16_le(b, 62)
    b = push_u32_le(b, 1)
    # e_entry=0x400000
    b = push_u64_le(b, 0x400000)
    # e_phoff=64
    b = push_u64_le(b, 64)
    # e_shoff=192
    b = push_u64_le(b, 192)
    # e_flags=0
    b = push_u32_le(b, 0)
    # e_ehsize=64
    b = push_u16_le(b, 64)
    # e_phentsize=56, e_phnum=1
    b = push_u16_le(b, 56)
    b = push_u16_le(b, 1)
    # e_shentsize=64, e_shnum=3, e_shstrndx=0
    b = push_u16_le(b, 64)
    b = push_u16_le(b, 3)
    b = push_u16_le(b, 0)
    # PT_LOAD program header at offset 64
    b = push_u32_le(b, 1)
    b = push_u32_le(b, 5)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0x400000)
    b = push_u64_le(b, 0x400000)
    b = push_u64_le(b, 120)
    b = push_u64_le(b, 120)
    b = push_u64_le(b, 0x1000)
    # .strtab at 128: \0 h e l l o \0 = 7 bytes
    b = pad_to(b, 128)
    b.push(0.to_u8())
    b.push(0x68.to_u8())
    b.push(0x65.to_u8())
    b.push(0x6C.to_u8())
    b.push(0x6C.to_u8())
    b.push(0x6F.to_u8())
    b.push(0.to_u8())
    # .dynsym at 144: null sym (24 bytes) + hello sym (24 bytes)
    b = pad_to(b, 144)
    # null sym
    b = pad_to(b, 168)
    # hello sym: st_name=1, st_info=0x12, st_other=0, st_shndx=1
    b = push_u32_le(b, 1)
    b.push(0x12.to_u8())
    b.push(0.to_u8())
    b = push_u16_le(b, 1)
    # st_value=0xBEEF, st_size=8
    b = push_u64_le(b, 0xBEEF)
    b = push_u64_le(b, 8)
    # Section headers at 192: null(64) + .dynsym(64) + .strtab(64)
    b = pad_to(b, 192)
    # SHT_NULL
    b = pad_to(b, 256)
    # .dynsym: sh_name=0, sh_type=11(SHT_DYNSYM), sh_flags=0, sh_addr=0
    b = push_u32_le(b, 0)
    b = push_u32_le(b, 11)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0)
    # sh_offset=144, sh_size=48
    b = push_u64_le(b, 144)
    b = push_u64_le(b, 48)
    # sh_link=2 (strtab), sh_info=0
    b = push_u32_le(b, 2)
    b = push_u32_le(b, 0)
    # sh_addralign=0, sh_entsize=24
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 24)
    # .strtab: sh_name=0, sh_type=3(SHT_STRTAB), sh_flags=0, sh_addr=0
    b = push_u32_le(b, 0)
    b = push_u32_le(b, 3)
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0)
    # sh_offset=128, sh_size=7
    b = push_u64_le(b, 128)
    b = push_u64_le(b, 7)
    # sh_link=0, sh_info=0
    b = push_u32_le(b, 0)
    b = push_u32_le(b, 0)
    # sh_addralign=0, sh_entsize=0
    b = push_u64_le(b, 0)
    b = push_u64_le(b, 0)
    b

# ============================================================================
# SMF fixture builder
# ============================================================================

fn make_smf_wrapped_elf64_exec() -> [u8]:
    """Build SMF container wrapping make_elf64_exec() as native stub."""
    var bytes = make_elf64_exec()
    val stub_size = bytes.len()
    # SMF magic "SMF\0"
    bytes.push(83.to_u8())
    bytes.push(77.to_u8())
    bytes.push(70.to_u8())
    bytes.push(0.to_u8())
    # Padding to offset 44 within trailer
    var i = 4
    while i < 44:
        bytes.push(0.to_u8())
        i = i + 1
    # Entry point at offset 44
    bytes = push_u64_le(bytes, 0x400000)
    # stub_offset and stub_size at offsets 52 and 56
    bytes = push_u32_le(bytes, stub_size)
    bytes = push_u32_le(bytes, stub_size)
    # Pad to 128-byte trailer
    while bytes.len() < stub_size + 128:
        bytes.push(0.to_u8())
    bytes

# ============================================================================
# PE64 byte-level helpers
# ============================================================================

fn zero_bytes(count: i64) -> [u8]:
    """Allocate count zero-filled bytes."""
    var out: [u8] = []
    var i = 0
    while i < count:
        out.push(0)
        i = i + 1
    out

fn put_u16_le(data: [u8], offset: i64, value: i64) -> [u8]:
    """Write little-endian u16 at offset."""
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data

fn put_u32_le(data: [u8], offset: i64, value: i64) -> [u8]:
    """Write little-endian u32 at offset."""
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data[offset + 2] = ((value >> 16) & 0xff) as u8
    data[offset + 3] = ((value >> 24) & 0xff) as u8
    data

fn put_u64_le(data: [u8], offset: i64, value: i64) -> [u8]:
    """Write little-endian u64 at offset."""
    data[offset] = (value & 0xff) as u8
    data[offset + 1] = ((value >> 8) & 0xff) as u8
    data[offset + 2] = ((value >> 16) & 0xff) as u8
    data[offset + 3] = ((value >> 24) & 0xff) as u8
    data[offset + 4] = ((value >> 32) & 0xff) as u8
    data[offset + 5] = ((value >> 40) & 0xff) as u8
    data[offset + 6] = ((value >> 48) & 0xff) as u8
    data[offset + 7] = ((value >> 56) & 0xff) as u8
    data

fn put_ascii(data: [u8], offset: i64, text_val: text) -> [u8]:
    """Write ASCII text at offset."""
    var i = 0
    while i < text_val.len():
        val ch = text_val[i:i + 1]
        val chars = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
        var j = 0
        while j < chars.len():
            if chars[j:j + 1] == ch:
                data[offset + i] = (j + 32) as u8
                break
            j = j + 1
        i = i + 1
    data

# ============================================================================
# PE64 fixture builders
# ============================================================================

fn make_pe64_reloc_image() -> [u8]:
    """Build minimal PE64 image with relocation directory containing one block with two DIR64 entries."""
    var data = zero_bytes(1024)
    # DOS header
    data[0] = 0x4d
    data[1] = 0x5a
    data = put_u32_le(data, 0x3c, 0x80)
    # PE signature
    data[0x80] = 0x50
    data[0x81] = 0x45
    # COFF header
    data = put_u16_le(data, 0x84, 0x8664)
    data = put_u16_le(data, 0x86, 1)
    data = put_u16_le(data, 0x94, 0xf0)
    # Optional header magic PE32+
    data = put_u16_le(data, 0x98, 0x20b)
    # AddressOfEntryPoint
    data = put_u32_le(data, 0x98 + 0x10, 0x2010)
    # ImageBase
    data = put_u32_le(data, 0x98 + 0x18, 0x400000)
    data = put_u32_le(data, 0x98 + 0x1c, 0)
    # SizeOfImage
    data = put_u32_le(data, 0x98 + 0x38, 0x5000)
    # SizeOfHeaders
    data = put_u32_le(data, 0x98 + 0x3c, 0x200)
    # NumberOfRvaAndSizes
    data = put_u16_le(data, 0x98 + 0x5c, 3)
    # Data directories
    data = put_u32_le(data, 0x98 + 0x6c, 16)
    # Import directory
    data = put_u32_le(data, 0x98 + 0x70 + 8, 0x2020)
    data = put_u32_le(data, 0x98 + 0x70 + 12, 0x40)
    # Resource directory
    data = put_u32_le(data, 0x98 + 0x70 + 40, 0x2160)
    data = put_u32_le(data, 0x98 + 0x70 + 44, 0x10)
    # Debug directory
    data = put_u32_le(data, 0x98 + 0x70 + 72, 0x2170)
    data = put_u32_le(data, 0x98 + 0x70 + 76, 0x28)
    # Section header
    val section_offset = 0x188
    data = put_u32_le(data, section_offset + 8, 0x300)
    data = put_u32_le(data, section_offset + 12, 0x2000)
    data = put_u32_le(data, section_offset + 16, 0x200)
    data = put_u32_le(data, section_offset + 20, 0x200)
    data = put_u32_le(data, section_offset + 36, 0x60000020)
    # Import table
    data = put_u32_le(data, 0x220, 0x2060)
    data = put_u32_le(data, 0x220 + 12, 0x2050)
    data = put_u32_le(data, 0x220 + 16, 0x2060)
    data = put_u32_le(data, 0x234, 0)
    data = put_u32_le(data, 0x238, 0)
    data = put_u32_le(data, 0x23c, 0)
    data = put_u32_le(data, 0x240, 0)
    data = put_u32_le(data, 0x244, 0)
    data = put_ascii(data, 0x250, "kernel32.dll")
    data = put_u32_le(data, 0x260, 0x2080)
    data = put_u32_le(data, 0x264, 0)
    data = put_u32_le(data, 0x268, 0)
    data = put_u32_le(data, 0x26c, 0)
    data = put_u16_le(data, 0x280, 0)
    data = put_ascii(data, 0x282, "ExitProcess")
    # Relocation block
    data = put_u32_le(data, 0x360, 0x2000)
    data = put_u32_le(data, 0x364, 0x0c)
    data = put_u16_le(data, 0x368, 0xa018)
    data = put_u16_le(data, 0x36a, 0xa028)
    # Fixup values
    data = put_u64_le(data, 0x218, 0x400100)
    data = put_u64_le(data, 0x228, 0x400200)
    # TLS callback
    data = put_u32_le(data, 0x370 + 24, 0x2190)
    # Entry point code
    data = put_u32_le(data, 0x390, 0x2010)
    data

fn make_pe64_export_image() -> [u8]:
    """Build PE64 image with export directory containing Alpha and Beta exports."""
    var data = zero_bytes(1024)
    # DOS header
    data[0] = 0x4d
    data[1] = 0x5a
    data = put_u32_le(data, 0x3c, 0x80)
    # PE signature
    data[0x80] = 0x50
    data[0x81] = 0x45
    # COFF header
    data = put_u16_le(data, 0x84, 0x8664)
    data = put_u16_le(data, 0x86, 1)
    data = put_u16_le(data, 0x94, 0xf0)
    # Optional header magic PE32+
    data = put_u16_le(data, 0x98, 0x20b)
    # AddressOfEntryPoint
    data = put_u32_le(data, 0x98 + 0x10, 0x2010)
    # ImageBase
    data = put_u32_le(data, 0x98 + 0x18, 0x400000)
    data = put_u32_le(data, 0x98 + 0x1c, 0)
    # SizeOfImage
    data = put_u32_le(data, 0x98 + 0x38, 0x5000)
    # SizeOfHeaders
    data = put_u32_le(data, 0x98 + 0x3c, 0x200)
    # NumberOfRvaAndSizes
    data = put_u16_le(data, 0x98 + 0x5c, 3)
    # Data directories - size
    data = put_u32_le(data, 0x98 + 0x6c, 16)
    # Export directory at RVA 0x20a0, size 0x60
    data = put_u32_le(data, 0x98 + 0x70, 0x20a0)
    data = put_u32_le(data, 0x98 + 0x70 + 4, 0x60)
    # Import directory
    data = put_u32_le(data, 0x98 + 0x70 + 8, 0x2020)
    data = put_u32_le(data, 0x98 + 0x70 + 12, 0x40)
    # Resource directory
    data = put_u32_le(data, 0x98 + 0x70 + 40, 0x2160)
    data = put_u32_le(data, 0x98 + 0x70 + 44, 0x08)
    # Debug directory
    data = put_u32_le(data, 0x98 + 0x70 + 72, 0x2170)
    data = put_u32_le(data, 0x98 + 0x70 + 76, 0x28)
    # Section header
    val section_offset = 0x188
    data = put_u32_le(data, section_offset + 8, 0x300)
    data = put_u32_le(data, section_offset + 12, 0x2000)
    data = put_u32_le(data, section_offset + 16, 0x200)
    data = put_u32_le(data, section_offset + 20, 0x200)
    data = put_u32_le(data, section_offset + 36, 0x60000020)
    # Import table
    data = put_u32_le(data, 0x220, 0x2060)
    data = put_u32_le(data, 0x220 + 12, 0x2050)
    data = put_u32_le(data, 0x220 + 16, 0x2060)
    data = put_u32_le(data, 0x234, 0)
    data = put_u32_le(data, 0x238, 0)
    data = put_u32_le(data, 0x23c, 0)
    data = put_u32_le(data, 0x240, 0)
    data = put_u32_le(data, 0x244, 0)
    data = put_ascii(data, 0x250, "kernel32.dll")
    data = put_u32_le(data, 0x260, 0x2080)
    data = put_u32_le(data, 0x264, 0)
    data = put_u32_le(data, 0x268, 0)
    data = put_u32_le(data, 0x26c, 0)
    data = put_u16_le(data, 0x280, 0)
    data = put_ascii(data, 0x282, "ExitProcess")
    # Relocation block (empty)
    data = put_u32_le(data, 0x360, 0x2000)
    data = put_u32_le(data, 0x364, 0x08)
    data = put_u32_le(data, 0x370 + 24, 0)
    # Export directory at RVA 0x20a0 => file offset 0x2a0
    # NumberOfFunctions=2, NumberOfNames=2
    data = put_u32_le(data, 0x2a0 + 20, 2)
    data = put_u32_le(data, 0x2a0 + 24, 2)
    # AddressOfFunctions
    data = put_u32_le(data, 0x2a0 + 28, 0x20d0)
    # AddressOfNames
    data = put_u32_le(data, 0x2a0 + 32, 0x20d8)
    # AddressOfNameOrdinals
    data = put_u32_le(data, 0x2a0 + 36, 0x20e0)
    # Function RVAs
    data = put_u32_le(data, 0x2d0, 0x2010)
    data = put_u32_le(data, 0x2d4, 0x2030)
    # Name RVAs
    data = put_u32_le(data, 0x2d8, 0x20e8)
    data = put_u32_le(data, 0x2dc, 0x20f0)
    # Ordinals
    data = put_u16_le(data, 0x2e0, 0)
    data = put_u16_le(data, 0x2e2, 1)
    # Export names
    data = put_ascii(data, 0x2e8, "Alpha")
    data[0x2ed] = 0
    data = put_ascii(data, 0x2f0, "Beta")
    data[0x2f4] = 0
    data
