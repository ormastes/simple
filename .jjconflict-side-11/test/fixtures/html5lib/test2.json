{"tests": [
  {"description": "Empty body", "input": "<body></body>", "output": [["StartTag", "body", {}], ["EndTag", "body"], ["EOF"]]},
  {"description": "Paragraph with em", "input": "<p>Hello <em>world</em></p>", "output": [["StartTag", "p", {}], ["Character", "Hello "], ["StartTag", "em", {}], ["Character", "world"], ["EndTag", "em"], ["EndTag", "p"], ["EOF"]]},
  {"description": "Anchor with href and title", "input": "<a href=\"/\" title=\"home\">Home</a>", "output": [["StartTag", "a", {"href": "/", "title": "home"}], ["Character", "Home"], ["EndTag", "a"], ["EOF"]]},
  {"description": "Section tag", "input": "<section><h2>Section</h2><p>content</p></section>", "output": [["StartTag", "section", {}], ["StartTag", "h2", {}], ["Character", "Section"], ["EndTag", "h2"], ["StartTag", "p", {}], ["Character", "content"], ["EndTag", "p"], ["EndTag", "section"], ["EOF"]]},
  {"description": "Header nav footer", "input": "<header>H</header><nav>N</nav><footer>F</footer>", "output": [["StartTag", "header", {}], ["Character", "H"], ["EndTag", "header"], ["StartTag", "nav", {}], ["Character", "N"], ["EndTag", "nav"], ["StartTag", "footer", {}], ["Character", "F"], ["EndTag", "footer"], ["EOF"]]},
  {"description": "Input type submit", "input": "<input type=\"submit\" value=\"Go\">", "output": [["StartTag", "input", {"type": "submit", "value": "Go"}, true], ["EOF"]]},
  {"description": "Ordered list", "input": "<ol><li>First</li><li>Second</li></ol>", "output": [["StartTag", "ol", {}], ["StartTag", "li", {}], ["Character", "First"], ["EndTag", "li"], ["StartTag", "li", {}], ["Character", "Second"], ["EndTag", "li"], ["EndTag", "ol"], ["EOF"]]},
  {"description": "Div with id", "input": "<div id=\"main\">content</div>", "output": [["StartTag", "div", {"id": "main"}], ["Character", "content"], ["EndTag", "div"], ["EOF"]]},
  {"description": "HR void", "input": "<hr>", "output": [["StartTag", "hr", {}, true], ["EOF"]]},
  {"description": "Meta charset", "input": "<meta charset=\"utf-8\">", "output": [["StartTag", "meta", {"charset": "utf-8"}, true], ["EOF"]]},
  {"description": "Pre code", "input": "<pre><code>x = 1</code></pre>", "output": [["StartTag", "pre", {}], ["StartTag", "code", {}], ["Character", "x = 1"], ["EndTag", "code"], ["EndTag", "pre"], ["EOF"]]},
  {"description": "Form with action", "input": "<form action=\"/submit\"><input type=\"text\"></form>", "output": [["StartTag", "form", {"action": "/submit"}], ["StartTag", "input", {"type": "text"}, true], ["EndTag", "form"], ["EOF"]]},
  {"description": "Button", "input": "<button type=\"button\">Click</button>", "output": [["StartTag", "button", {"type": "button"}], ["Character", "Click"], ["EndTag", "button"], ["EOF"]]},
  {"description": "Strong em", "input": "<strong>bold</strong> and <em>italic</em>", "output": [["StartTag", "strong", {}], ["Character", "bold"], ["EndTag", "strong"], ["Character", " and "], ["StartTag", "em", {}], ["Character", "italic"], ["EndTag", "em"], ["EOF"]]},
  {"description": "Table with thead tbody", "input": "<table><thead><tr><th>H</th></tr></thead><tbody><tr><td>D</td></tr></tbody></table>", "output": [["StartTag", "table", {}], ["StartTag", "thead", {}], ["StartTag", "tr", {}], ["StartTag", "th", {}], ["Character", "H"], ["EndTag", "th"], ["EndTag", "tr"], ["EndTag", "thead"], ["StartTag", "tbody", {}], ["StartTag", "tr", {}], ["StartTag", "td", {}], ["Character", "D"], ["EndTag", "td"], ["EndTag", "tr"], ["EndTag", "tbody"], ["EndTag", "table"], ["EOF"]]},
  {"description": "Image with alt", "input": "<img src=\"photo.jpg\" alt=\"photo\">", "output": [["StartTag", "img", {"src": "photo.jpg", "alt": "photo"}, true], ["EOF"]]},
  {"description": "Blockquote cite", "input": "<blockquote cite=\"url\"><p>quote</p></blockquote>", "output": [["StartTag", "blockquote", {"cite": "url"}], ["StartTag", "p", {}], ["Character", "quote"], ["EndTag", "p"], ["EndTag", "blockquote"], ["EOF"]]},
  {"description": "Named entity nbsp", "input": "a&nbsp;b", "output": [["Character", "a b"], ["EOF"]]},
  {"description": "H2 heading", "input": "<h2>Subtitle</h2>", "output": [["StartTag", "h2", {}], ["Character", "Subtitle"], ["EndTag", "h2"], ["EOF"]]},
  {"description": "Span with style", "input": "<span style=\"color:red\">red text</span>", "output": [["StartTag", "span", {"style": "color:red"}], ["Character", "red text"], ["EndTag", "span"], ["EOF"]]}
]}
