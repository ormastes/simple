        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", "[]")
    )
    val annot = _jo3(
        _jp("readOnlyHint", "true"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("ui_access_query"))
    result = result + "," + _jp("description", _js("Query canonical UI nodes with structured JSON results"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_ui_access_ensure() -> text:
    """Schema for ui_access_ensure tool."""
    val p_surface = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional surface ID to query"))
    )
    val p_canonical = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional canonical node ID like surface#widget"))
    )
    val p_kind = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional widget kind filter"))
    )
    val p_text = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional text or prop substring filter"))
    )
    val p_focused = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional focused-only flag: true or false"))
    )
    val p_expectation = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Expectation to satisfy: exists, absent, active, focused, enabled, disabled, selected, unselected, or match_count"))
    )
    val p_expected_value = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional expected value for the expectation, used for match_count"))
    )
    val p_limit = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional maximum number of nodes to include in the result"))
    )
    val p_timeout = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional bounded wait timeout in milliseconds"))
    )
    val p_poll = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional poll interval in milliseconds while waiting"))
    )
    val props = "{" +
        _jp("surface_id", p_surface) + "," +
        _jp("canonical_id", p_canonical) + "," +
        _jp("kind", p_kind) + "," +
        _jp("text", p_text) + "," +
        _jp("focused_only", p_focused) + "," +
        _jp("expectation", p_expectation) + "," +
        _jp("expected_value", p_expected_value) + "," +
        _jp("limit", p_limit) + "," +
        _jp("timeout_ms", p_timeout) + "," +
        _jp("poll_ms", p_poll) +
        "}"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", "[]")
    )
    val annot = _jo3(
        _jp("readOnlyHint", "true"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("ui_access_ensure"))
    result = result + "," + _jp("description", _js("Ensure canonical UI state satisfies a bounded declarative expectation"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_ui_access_value() -> text:
    """Schema for ui_access_value tool."""
    val p_surface = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional surface ID target"))
    )
    val p_canonical = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Canonical node ID like surface#widget"))
    )
    val p_value = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional value to write. Omit to read the current value."))
    )
    val props = "{" +
        _jp("surface_id", p_surface) + "," +
        _jp("canonical_id", p_canonical) + "," +
        _jp("value", p_value) +
        "}"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", "[\"canonical_id\"]")
    )
    val annot = _jo3(
        _jp("readOnlyHint", "false"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "false")
    )
    var result = "{"
    result = result + _jp("name", _js("ui_access_value"))
    result = result + "," + _jp("description", _js("Read or set typed values for canonical input, textfield, or textarea nodes"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_ui_access_adapter_snapshot() -> text:
    """Schema for ui_access_adapter_snapshot tool."""
    val p_surface = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional surface ID target; defaults to the active surface"))
    )
    val props = "{" + _jp("surface_id", p_surface) + "}"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", "[]")
    )
    val annot = _jo3(
        _jp("readOnlyHint", "true"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("ui_access_adapter_snapshot"))
    result = result + "," + _jp("description", _js("Read an additive adapter-backed snapshot envelope"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

