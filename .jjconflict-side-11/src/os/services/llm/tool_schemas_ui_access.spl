# Tool Schemas — UI Access tools
#
# Schema builder functions for the MCP OS server tool registry.
# UI access tools: ui_access_snapshot, ui_access_surface, ui_access_find,
#   ui_access_act, ui_access_history, ui_access_observe, ui_access_state,
#   ui_access_query, ui_access_ensure, ui_access_value,
#   ui_access_adapter_snapshot, ui_access_visual_probe

fn schema_ui_access_snapshot() -> text:
    """Schema for ui_access_snapshot tool."""
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", "{}"),
        _jp("required", "[]")
    )
    val annot = _jo3(
        _jp("readOnlyHint", "true"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("ui_access_snapshot"))
    result = result + "," + _jp("description", _js("Read the canonical UI access snapshot across all surfaces"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_ui_access_surface() -> text:
    """Schema for ui_access_surface tool."""
    val p_surface = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Surface ID to inspect"))
    )
    val props = _jo1(_jp("surface_id", p_surface))
    val required = "[" + _js("surface_id") + "]"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "true"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("ui_access_surface"))
    result = result + "," + _jp("description", _js("Read one surface and its nodes from the canonical UI access model"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_ui_access_find() -> text:
    """Schema for ui_access_find tool."""
    val p_surface = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional surface ID filter"))
    )
    val p_kind = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional widget kind filter"))
    )
    val p_text = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional text or prop substring filter"))
    )
    val p_focused = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional focused-only flag: true or false"))
    )
    val props = "{" +
        _jp("surface_id", p_surface) + "," +
        _jp("kind", p_kind) + "," +
        _jp("text", p_text) + "," +
        _jp("focused_only", p_focused) +
        "}"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", "[]")
    )
    val annot = _jo3(
        _jp("readOnlyHint", "true"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("ui_access_find"))
    result = result + "," + _jp("description", _js("Find canonical UI nodes by surface, kind, text, or focus"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_ui_access_act() -> text:
    """Schema for ui_access_act tool."""
    val p_surface = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Surface ID to target when canonical_id is omitted"))
    )
    val p_canonical = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Canonical node ID like surface#widget"))
    )
    val p_action = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Action name to dispatch"))
    )
    val props = "{" +
        _jp("surface_id", p_surface) + "," +
        _jp("canonical_id", p_canonical) + "," +
        _jp("action", p_action) +
        "}"
    val required = "[" + _js("action") + "]"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "false"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "false")
    )
    var result = "{"
    result = result + _jp("name", _js("ui_access_act"))
    result = result + "," + _jp("description", _js("Dispatch an action against a canonical UI node or surface"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

