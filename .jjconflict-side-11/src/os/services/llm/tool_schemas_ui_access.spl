fn schema_ui_access_state() -> text:
    """Schema for ui_access_state tool."""
    val p_surface = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional surface ID target"))
    )
    val p_canonical = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional canonical node ID like surface#widget"))
    )
    val p_key = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("State key to read or set, such as active, focused, selected, toggled, invoke, submit, or action"))
    )
    val p_value = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Desired state value or action name"))
    )
    val props = "{" +
        _jp("surface_id", p_surface) + "," +
        _jp("canonical_id", p_canonical) + "," +
        _jp("state_key", p_key) + "," +
        _jp("state_value", p_value) +
        "}"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", "[]")
    )
    val annot = _jo3(
        _jp("readOnlyHint", "false"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "false")
    )
    var result = "{"
    result = result + _jp("name", _js("ui_access_state"))
    result = result + "," + _jp("description", _js("Read or set declarative UI state for a surface or canonical node"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_ui_access_query() -> text:
    """Schema for ui_access_query tool."""
    val p_surface = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional surface ID to query"))
    )
    val p_canonical = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional canonical node ID like surface#widget"))
    )
    val p_kind = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional widget kind filter"))
    )
    val p_text = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional text or prop substring filter"))
    )
    val p_focused = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional focused-only flag: true or false"))
    )
    val p_limit = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Optional maximum number of nodes to return"))
    )
    val props = "{" +
        _jp("surface_id", p_surface) + "," +
        _jp("canonical_id", p_canonical) + "," +
        _jp("kind", p_kind) + "," +
