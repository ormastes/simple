# QEMU ramfb Driver — Virtual Framebuffer via fw_cfg
#
# MDSOC: feature dimension, drivers layer
#
# QEMU's ramfb device provides a simple framebuffer by writing a configuration
# struct to fw_cfg. The guest allocates a memory region for the framebuffer,
# then writes the address + dimensions to fw_cfg's DMA interface.
#
# fw_cfg access varies by architecture:
#   - x86_64: I/O ports 0x510 (selector), 0x511 (data), 0x514 (DMA)
#   - arm64:  MMIO at 0x09020000 (selector), 0x09020008 (DMA)
#   - riscv:  MMIO at 0x10100000 (selector), 0x10100008 (DMA)
#
# Protocol:
#   1. Select fw_cfg file "etc/ramfb" via selector port
#   2. Write RAMFBConfig struct (28 bytes) via DMA write
#   3. QEMU creates the framebuffer at the specified address
#
# Pixel format: XRGB8888 (DRM_FORMAT_XRGB8888 = 0x34325258)

use os.kernel.arch.arch_context.{Architecture}
use os.kernel.boot.mmio.{mmio_read8, mmio_write8, mmio_read16, mmio_write16,
                          mmio_read32, mmio_write32, mmio_read64, mmio_write64}
use os.kernel.boot.ports.{FramebufferInfo}
use os.kernel.types.memory_types.{PhysAddr}

# ============================================================================
# fw_cfg Constants
# ============================================================================

# fw_cfg I/O ports (x86_64 only)
val FWCFG_IO_SELECTOR: u16 = 0x510
val FWCFG_IO_DATA: u16 = 0x511
val FWCFG_IO_DMA: u16 = 0x514

# fw_cfg MMIO bases per architecture
val FWCFG_MMIO_ARM64: u64 = 0x09020000
val FWCFG_MMIO_RISCV: u64 = 0x10100000

# fw_cfg file directory selector
val FWCFG_FILE_DIR: u16 = 0x0019

# DRM pixel format for XRGB8888
val DRM_FORMAT_XRGB8888: u32 = 0x34325258

# DMA control flags
val FWCFG_DMA_SELECT: u32 = 0x08
val FWCFG_DMA_WRITE: u32 = 0x10
val FWCFG_DMA_READ: u32 = 0x02
val FWCFG_DMA_ERROR: u32 = 0x01

# ============================================================================
# fw_cfg Access (Architecture-Abstracted)
# ============================================================================

struct FwCfgAccess:
    """Architecture-specific fw_cfg access handle."""
    arch: Architecture
    mmio_base: u64          # 0 for x86_64 (uses I/O ports)

impl FwCfgAccess:
    static fn for_arch(arch: Architecture) -> FwCfgAccess:
        """Create fw_cfg access for the given architecture."""
        val base = match arch:
            Architecture.X86_64: 0u64
            Architecture.X86: 0u64
            Architecture.Arm64: FWCFG_MMIO_ARM64
            Architecture.Riscv64: FWCFG_MMIO_RISCV
            Architecture.Riscv32: FWCFG_MMIO_RISCV
            Architecture.Arm32: 0u64    # ARM32 virt does not have fw_cfg
        FwCfgAccess(arch: arch, mmio_base: base)

    fn select(selector: u16):
        """Select a fw_cfg entry by its selector index."""
        match self.arch:
            Architecture.X86_64:
                x86_port_outw(FWCFG_IO_SELECTOR, selector)
            Architecture.X86:
                x86_port_outw(FWCFG_IO_SELECTOR, selector)
            _:
                # MMIO: write selector as big-endian u16 to base + 0x08
                val sel_addr = self.mmio_base + 0x08
                mmio_write16(sel_addr, swap16(selector))

    fn read_byte() -> u8:
        """Read one byte from the currently selected fw_cfg entry."""
        match self.arch:
            Architecture.X86_64:
                x86_port_inb(FWCFG_IO_DATA)
            Architecture.X86:
                x86_port_inb(FWCFG_IO_DATA)
            _:
                mmio_read8(self.mmio_base)

    fn read_u16_be() -> u16:
        """Read a big-endian u16 (two bytes) from fw_cfg data."""
        val hi = self.read_byte().to_u16()
        val lo = self.read_byte().to_u16()
        (hi << 8) | lo

    fn read_u32_be() -> u32:
        """Read a big-endian u32 (four bytes) from fw_cfg data."""
        val b0 = self.read_byte().to_u32()
        val b1 = self.read_byte().to_u32()
        val b2 = self.read_byte().to_u32()
        val b3 = self.read_byte().to_u32()
        (b0 << 24) | (b1 << 16) | (b2 << 8) | b3

    fn write_bytes(data: [u8]):
        """Write bytes to the currently selected fw_cfg entry via DMA."""
        # For simplicity, write byte-by-byte via data port
        # (DMA write is more complex and requires physical address alignment)
        match self.arch:
            Architecture.X86_64:
                for byte in data:
                    x86_port_outb(FWCFG_IO_DATA, byte)
            Architecture.X86:
                for byte in data:
                    x86_port_outb(FWCFG_IO_DATA, byte)
            _:
                for byte in data:
                    mmio_write8(self.mmio_base, byte)

# ============================================================================
# x86 Port I/O Wrappers (extern, only used on x86/x86_64)
# ============================================================================

extern fn rt_port_outb(port: u16, value: u8)
extern fn rt_port_inb(port: u16) -> u8
extern fn rt_port_outw(port: u16, value: u16)
extern fn rt_port_inw(port: u16) -> u16

fn x86_port_outb(port: u16, value: u8):
    rt_port_outb(port, value)

fn x86_port_inb(port: u16) -> u8:
    rt_port_inb(port)

fn x86_port_outw(port: u16, value: u16):
    rt_port_outw(port, value)

fn x86_port_inw(port: u16) -> u16:
    rt_port_inw(port)

# ============================================================================
# Byte Swap Helpers
# ============================================================================

fn swap16(v: u16) -> u16:
    """Swap bytes in a u16 (host to big-endian or vice versa)."""
    ((v & 0xFF) << 8) | ((v >> 8) & 0xFF)

fn swap32(v: u32) -> u32:
    """Swap bytes in a u32 (host to big-endian or vice versa)."""
    val b0 = (v >> 24) & 0xFF
    val b1 = (v >> 16) & 0xFF
    val b2 = (v >> 8) & 0xFF
    val b3 = v & 0xFF
    (b3 << 24) | (b2 << 16) | (b1 << 8) | b0

fn swap64(v: u64) -> u64:
    """Swap bytes in a u64 (host to big-endian)."""
    val lo = swap32((v & 0xFFFFFFFF).to_u32()).to_u64()
    val hi = swap32(((v >> 32) & 0xFFFFFFFF).to_u32()).to_u64()
    (lo << 32) | hi

# ============================================================================
# RAMFBConfig — Struct Written to fw_cfg
# ============================================================================
#
# Wire format (all fields big-endian):
#   u64  addr       — physical address of framebuffer memory
#   u32  fourcc     — pixel format (DRM_FORMAT_XRGB8888)
#   u32  flags      — 0
#   u32  width      — display width in pixels
#   u32  height     — display height in pixels
#   u32  stride     — bytes per scanline (width * 4 for XRGB8888)

fn encode_ramfb_config(addr: u64, width: u32, height: u32) -> [u8]:
    """Encode RAMFBConfig struct as big-endian bytes (28 bytes)."""
    val stride = width * 4
    var buf: [u8] = []

    # addr (8 bytes, big-endian)
    val addr_be = swap64(addr)
    buf.push(((addr_be >> 56) & 0xFF).to_u8())
    buf.push(((addr_be >> 48) & 0xFF).to_u8())
    buf.push(((addr_be >> 40) & 0xFF).to_u8())
    buf.push(((addr_be >> 32) & 0xFF).to_u8())
    buf.push(((addr_be >> 24) & 0xFF).to_u8())
    buf.push(((addr_be >> 16) & 0xFF).to_u8())
    buf.push(((addr_be >> 8) & 0xFF).to_u8())
    buf.push((addr_be & 0xFF).to_u8())

    # fourcc (4 bytes, big-endian)
    val fourcc_be = swap32(DRM_FORMAT_XRGB8888)
    buf.push(((fourcc_be >> 24) & 0xFF).to_u8())
    buf.push(((fourcc_be >> 16) & 0xFF).to_u8())
    buf.push(((fourcc_be >> 8) & 0xFF).to_u8())
    buf.push((fourcc_be & 0xFF).to_u8())

    # flags (4 bytes, 0)
    buf.push(0u8)
    buf.push(0u8)
    buf.push(0u8)
    buf.push(0u8)

    # width (4 bytes, big-endian)
    val w_be = swap32(width)
    buf.push(((w_be >> 24) & 0xFF).to_u8())
    buf.push(((w_be >> 16) & 0xFF).to_u8())
    buf.push(((w_be >> 8) & 0xFF).to_u8())
    buf.push((w_be & 0xFF).to_u8())

    # height (4 bytes, big-endian)
    val h_be = swap32(height)
    buf.push(((h_be >> 24) & 0xFF).to_u8())
    buf.push(((h_be >> 16) & 0xFF).to_u8())
    buf.push(((h_be >> 8) & 0xFF).to_u8())
    buf.push((h_be & 0xFF).to_u8())

    # stride (4 bytes, big-endian)
    val s_be = swap32(stride)
    buf.push(((s_be >> 24) & 0xFF).to_u8())
    buf.push(((s_be >> 16) & 0xFF).to_u8())
    buf.push(((s_be >> 8) & 0xFF).to_u8())
    buf.push((s_be & 0xFF).to_u8())

    buf

# ============================================================================
# ramfb File Selector Lookup
# ============================================================================

fn find_ramfb_selector(fwcfg: FwCfgAccess) -> u16?:
    """Find the fw_cfg selector for 'etc/ramfb' by scanning the file directory.

    Returns the selector index, or nil if not found (ramfb device not present).
    """
    # Select the file directory
    fwcfg.select(FWCFG_FILE_DIR)

    # Read file count (big-endian u32)
    val count = fwcfg.read_u32_be()

    # Each file entry: 4 bytes size + 2 bytes select + 2 bytes reserved + 56 bytes name = 64 bytes
    var i: u32 = 0
    while i < count:
        val _size = fwcfg.read_u32_be()
        val select = fwcfg.read_u16_be()
        val _reserved = fwcfg.read_u16_be()

        # Read 56-byte name
        var name_bytes: [u8] = []
        var j: u32 = 0
        while j < 56:
            name_bytes.push(fwcfg.read_byte())
            j = j + 1

        # Check if name matches "etc/ramfb"
        if name_starts_with(name_bytes, "etc/ramfb"):
            return select

        i = i + 1

    nil

fn name_starts_with(name_bytes: [u8], prefix: text) -> bool:
    """Check if a null-terminated byte array starts with the given prefix."""
    var k: u32 = 0
    for ch in prefix:
        if k >= name_bytes.len().to_u32():
            return false
        if name_bytes[k] != ch.to_u8():
            return false
        k = k + 1
    # Must be followed by null terminator or end
    if k < name_bytes.len().to_u32():
        return name_bytes[k] == 0
    true

# ============================================================================
# Public API
# ============================================================================

fn init_ramfb(arch: Architecture, fb_phys_addr: u64, width: u32, height: u32) -> FramebufferInfo?:
    """Initialize QEMU ramfb device for the given architecture.

    Allocates a framebuffer at fb_phys_addr, writes the RAMFBConfig struct
    to fw_cfg, and returns the FramebufferInfo on success.

    The caller must ensure fb_phys_addr points to a valid, writable memory
    region of at least (width * height * 4) bytes.

    Returns nil if the ramfb device is not present in QEMU.
    """
    val fwcfg = FwCfgAccess.for_arch(arch)

    # Find the ramfb selector
    val selector = find_ramfb_selector(fwcfg)
    if selector.?:
        pass_do_nothing
    else:
        return nil

    val sel = selector!

    # Select the ramfb file and write the config
    fwcfg.select(sel)

    val config_bytes = encode_ramfb_config(fb_phys_addr, width, height)
    fwcfg.write_bytes(config_bytes)

    # Return framebuffer info
    val pitch = width * 4
    FramebufferInfo(
        addr: PhysAddr(addr: fb_phys_addr),
        width: width,
        height: height,
        pitch: pitch,
        bpp: 32
    )
