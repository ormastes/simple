# Scene Graph Node3D — Node3D + NodeStore3D
#
# 3D scene graph using generational-index arena (mirrors 2D NodeStore pattern).
# Each Node3D has position, rotation, scale, parent/child relationships.
#
# Usage:
#   var store = NodeStore3D.create()
#   val root_id = store.create_node("root")
#   val child_id = store.create_node("child")
#   store.set_parent(child_id, root_id)
#   store.set_position(child_id, Vec3(x: 10.0, y: 20.0, z: 30.0))

use std.common.engine.ids.{NodeId, RawHandle, Generation}
use std.common.engine.math3d.{Vec3, Quaternion, Transform3D, Mat4}

# ============================================================================
# Node3D — a single 3D scene graph node
# ============================================================================

class Node3D:
    id: NodeId
    name: text
    parent: NodeId
    children: [NodeId]
    position: Vec3
    rotation: Quaternion
    scale: Vec3
    visible: bool
    active: bool
    tags: [text]

impl Node3D:
    static fn create(id: NodeId, name: text) -> Node3D:
        """Create a new node with default transform (identity)."""
        Node3D(
            id: id,
            name: name,
            parent: NodeId.invalid(),
            children: [],
            position: Vec3.zero(),
            rotation: Quaternion.identity(),
            scale: Vec3.one(),
            visible: true,
            active: true,
            tags: []
        )

    fn has_tag(tag: text) -> bool:
        """Check if this node has the given tag."""
        var i = 0
        while i < self.tags.len():
            if self.tags[i] == tag:
                return true
            i = i + 1
        false

    fn get_transform() -> Transform3D:
        """Get the local transform for this node."""
        Transform3D(
            position: self.position,
            rotation: self.rotation,
            scale: self.scale
        )

# ============================================================================
# NodeStore3D — flat generational-index arena for all 3D nodes
# ============================================================================

class NodeStore3D:
    nodes: [Node3D?]
    generations: [i64]
    free_indices: [i64]
    count: i64
    root_nodes: [NodeId]

impl NodeStore3D:
    static fn create() -> NodeStore3D:
        """Create an empty 3D node store."""
        NodeStore3D(
            nodes: [],
            generations: [],
            free_indices: [],
            count: 0,
            root_nodes: []
        )

    me create_node(name: text) -> NodeId:
        """Allocate a new 3D node, reusing a free slot if available."""
        var index = -1
        var gen_val = 1

        if self.free_indices.len() > 0:
            # Reuse free slot
            val last_idx = self.free_indices.len() - 1
            index = self.free_indices[last_idx]
            self.free_indices.pop()
            self.generations[index] = self.generations[index] + 1
            gen_val = self.generations[index]
        else:
            # Append new slot
            index = self.nodes.len()
            self.nodes.push(nil)
            self.generations.push(1)
            gen_val = 1

        val raw = RawHandle.new(index, gen_val)
        val node_id = NodeId(raw: raw)
        val node = Node3D.create(node_id, name)
        self.nodes[index] = node
        self.count = self.count + 1
        self._add_root_node(node_id)
        node_id

    fn get_node(id: NodeId) -> Node3D?:
        """Look up a node by its NodeId."""
        if not id.is_valid():
            return nil
        val index = id.to_index()
        if index < 0 or index >= self.nodes.len():
            return nil
        if self.generations[index] != id.raw.generation.value:
            return nil
        self.nodes[index]

    me destroy_node(id: NodeId) -> bool:
        """Remove a 3D node from the store."""
        val maybe_node = self.get_node(id)
        if maybe_node == nil:
            return false

        if val Some(node) = maybe_node:
            val parent_id = node.parent
            val children = node.children

            # Reparent children
            var i = 0
            while i < children.len():
                val child_id = children[i]
                val maybe_child = self.get_node(child_id)
                if val Some(child) = maybe_child:
                    val updated = Node3D(
                        id: child.id, name: child.name,
                        parent: parent_id, children: child.children,
                        position: child.position, rotation: child.rotation,
                        scale: child.scale, visible: child.visible,
                        active: child.active, tags: child.tags
                    )
                    self.nodes[child_id.to_index()] = updated
                    if not parent_id.is_valid():
                        self._add_root_node(child_id)
                    else:
                        self._add_child_to_parent(parent_id, child_id)
                i = i + 1

            # Remove from parent's children list
            if parent_id.is_valid():
                self._remove_child_from_parent(parent_id, id)

            # Remove from root_nodes if applicable
            self._remove_from_root_nodes(id)

            # Clear slot and add to free list
            val index = id.to_index()
            self.nodes[index] = nil
            self.free_indices.push(index)
            self.count = self.count - 1
            return true
        false

    me set_parent(child_id: NodeId, parent_id: NodeId) -> bool:
        """Set parent-child relationship between two nodes."""
        val maybe_child = self.get_node(child_id)
        if maybe_child == nil:
            return false
        val maybe_parent = self.get_node(parent_id)
        if maybe_parent == nil:
            return false

        if val Some(child) = maybe_child:
            # Remove from old parent
            val old_parent = child.parent
            if old_parent.is_valid():
                self._remove_child_from_parent(old_parent, child_id)
            else:
                self._remove_from_root_nodes(child_id)

            # Update child's parent reference
            val updated_child = Node3D(
                id: child.id, name: child.name,
                parent: parent_id, children: child.children,
                position: child.position, rotation: child.rotation,
                scale: child.scale, visible: child.visible,
                active: child.active, tags: child.tags
            )
            self.nodes[child_id.to_index()] = updated_child

            # Add to new parent's children
            self._add_child_to_parent(parent_id, child_id)
            return true
        false

    me set_position(id: NodeId, pos: Vec3) -> bool:
        """Set the local position of a node."""
        val maybe_node = self.get_node(id)
        if maybe_node == nil:
            return false
        if val Some(node) = maybe_node:
            val updated = Node3D(
                id: node.id, name: node.name,
                parent: node.parent, children: node.children,
                position: pos, rotation: node.rotation,
                scale: node.scale, visible: node.visible,
                active: node.active, tags: node.tags
            )
            self.nodes[id.to_index()] = updated
            return true
        false

    me set_rotation(id: NodeId, rot: Quaternion) -> bool:
        """Set the local rotation of a node."""
        val maybe_node = self.get_node(id)
        if maybe_node == nil:
            return false
        if val Some(node) = maybe_node:
            val updated = Node3D(
                id: node.id, name: node.name,
                parent: node.parent, children: node.children,
                position: node.position, rotation: rot,
                scale: node.scale, visible: node.visible,
                active: node.active, tags: node.tags
            )
            self.nodes[id.to_index()] = updated
            return true
        false

    me set_scale(id: NodeId, s: Vec3) -> bool:
        """Set the local scale of a node."""
        val maybe_node = self.get_node(id)
        if maybe_node == nil:
            return false
        if val Some(node) = maybe_node:
            val updated = Node3D(
                id: node.id, name: node.name,
                parent: node.parent, children: node.children,
                position: node.position, rotation: node.rotation,
                scale: s, visible: node.visible,
                active: node.active, tags: node.tags
            )
            self.nodes[id.to_index()] = updated
            return true
        false

    fn node_count() -> i64:
        self.count

    # --- Internal helpers ---

    me _add_root_node(id: NodeId):
        if not self._node_list_contains(self.root_nodes, id):
            self.root_nodes.push(id)

    me _remove_from_root_nodes(id: NodeId):
        var new_roots: [NodeId] = []
        var i = 0
        while i < self.root_nodes.len():
            if not self.root_nodes[i].eq(id):
                new_roots.push(self.root_nodes[i])
            i = i + 1
        self.root_nodes = new_roots

    me _add_child_to_parent(parent_id: NodeId, child_id: NodeId):
        val maybe_parent = self.get_node(parent_id)
        if val Some(parent) = maybe_parent:
            var new_children = parent.children
            if not self._node_list_contains(new_children, child_id):
                new_children.push(child_id)
            val updated = Node3D(
                id: parent.id, name: parent.name,
                parent: parent.parent, children: new_children,
                position: parent.position, rotation: parent.rotation,
                scale: parent.scale, visible: parent.visible,
                active: parent.active, tags: parent.tags
            )
            self.nodes[parent_id.to_index()] = updated

    me _remove_child_from_parent(parent_id: NodeId, child_id: NodeId):
        val maybe_parent = self.get_node(parent_id)
        if val Some(parent) = maybe_parent:
            var new_children: [NodeId] = []
            var i = 0
            while i < parent.children.len():
                if not parent.children[i].eq(child_id):
                    new_children.push(parent.children[i])
                i = i + 1
            val updated = Node3D(
                id: parent.id, name: parent.name,
                parent: parent.parent, children: new_children,
                position: parent.position, rotation: parent.rotation,
                scale: parent.scale, visible: parent.visible,
                active: parent.active, tags: parent.tags
            )
            self.nodes[parent_id.to_index()] = updated

    fn _node_list_contains(list: [NodeId], id: NodeId) -> bool:
        var i = 0
        while i < list.len():
            if list[i].eq(id):
                return true
            i = i + 1
        false

# ============================================================================
# Free functions
# ============================================================================

fn get_world_transform_3d(store: NodeStore3D, id: NodeId) -> Transform3D:
    """Compute the world transform by walking up the parent chain."""
    val maybe_node = store.get_node(id)
    if maybe_node == nil:
        return Transform3D.identity()

    if val Some(node) = maybe_node:
        val local = node.get_transform()
        if not node.parent.is_valid():
            return local
        val parent_world = get_world_transform_3d(store, node.parent)
        return parent_world.compose(local)
    Transform3D.identity()

fn find_by_name_3d(store: NodeStore3D, name: text) -> NodeId?:
    """Find the first node with the given name."""
    var i = 0
    while i < store.nodes.len():
        val maybe_node = store.nodes[i]
        if val Some(node) = maybe_node:
            if node.name == name:
                return node.id
        i = i + 1
    nil
