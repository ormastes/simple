# PBKDF2 — Pure Simple Implementation (RFC 2898 §5.2 / RFC 8018)
#
# Provides PBKDF2 key derivation with HMAC-SHA-256, HMAC-SHA-384, and
# HMAC-SHA-512 as the pseudo-random function.
#
# Public API:
#   pbkdf2_sha256_bytes(password, salt, iterations, dk_len) -> [i64]
#   pbkdf2_sha384_bytes(password, salt, iterations, dk_len) -> [i64]
#   pbkdf2_sha512_bytes(password, salt, iterations, dk_len) -> [i64]
#
# All inputs and outputs use [i64] byte lists (values 0-255).
#
# RFC 2898 §5.2 algorithm:
#   For each block i = 1 .. ceil(dkLen / hLen):
#     U_1 = PRF(password, salt || INT(i))   INT(i) = 4-byte big-endian
#     U_j = PRF(password, U_{j-1})           j = 2..c
#     T_i = U_1 XOR U_2 XOR ... XOR U_c
#   DK = T_1 || T_2 || ... (truncated to dkLen bytes)
#
# INTERPRETER PERFORMANCE
#   HMAC-SHA-256 takes ~9.5 ms per call in interpreter mode. At c=4096
#   iterations, each block requires 4096 HMAC calls (~39 s per block).
#   A single 32-byte block (dkLen=32) at c=4096 exceeds the 60 s test-runner
#   watchdog. This is a known limitation:
#   Filed: doc/08_tracking/bug/pbkdf2_interpreter_slow_c4096_2026-06-15.md
#
# References:
#   RFC 2898 §5.2 — PBKDF2 algorithm
#   RFC 8018 §5.2 — Same algorithm, updated obsoletes RFC 2898
#   draft-josefsson-pbkdf2-test-vectors-00 — reference test vectors

use std.common.crypto.hmac.{hmac_sha256_bytes, hmac_sha384_bytes, hmac_sha512_bytes}

# ============================================================================
# Internal helpers
# ============================================================================

fn _pbkdf2_int4(n: i64) -> [i64]:
    """Encode n as 4-byte big-endian (RFC 2898 §5.2 INT(i))."""
    var out: [i64] = []
    out.push((n >> 24) & 255)
    out.push((n >> 16) & 255)
    out.push((n >> 8) & 255)
    out.push(n & 255)
    out

fn _pbkdf2_xor_bytes(a: [i64], b: [i64]) -> [i64]:
    """XOR two equal-length byte lists."""
    var r: [i64] = []
    var i: i64 = 0
    val n = a.len()
    while i < n:
        r.push(a[i] ^ b[i])
        i = i + 1
    r

fn _pbkdf2_append(a: [i64], b: [i64]) -> [i64]:
    """Concatenate two byte lists."""
    var r: [i64] = []
    var i: i64 = 0
    val n_a = a.len()
    while i < n_a:
        r.push(a[i])
        i = i + 1
    var j: i64 = 0
    val n_b = b.len()
    while j < n_b:
        r.push(b[j])
        j = j + 1
    r

fn _pbkdf2_slice(src: [i64], start: i64, end_excl: i64) -> [i64]:
    """Extract bytes src[start..end_excl]."""
    var out: [i64] = []
    var i: i64 = start
    while i < end_excl:
        out.push(src[i])
        i = i + 1
    out

# ============================================================================
# Core PBKDF2 implementation parameterized by hash function and hash length.
#
# To avoid first-class function issues in interpreter mode, the hash variant
# (256/384/512) is selected via the h_variant parameter:
#   h_variant = 256 → HMAC-SHA-256 (hLen = 32)
#   h_variant = 384 → HMAC-SHA-384 (hLen = 48)
#   h_variant = 512 → HMAC-SHA-512 (hLen = 64)
# ============================================================================

fn _pbkdf2_block_sha256(password: [i64], salt: [i64], iterations: i64,
                        block_i: i64) -> [i64]:
    """Compute T_i = U_1 XOR ... XOR U_c for one block using HMAC-SHA-256."""
    # U_1 = HMAC(password, salt || INT(i))
    val u1_input = _pbkdf2_append(salt, _pbkdf2_int4(block_i))
    var u = hmac_sha256_bytes(password, u1_input)
    var t = u
    var j: i64 = 2
    while j <= iterations:
        u = hmac_sha256_bytes(password, u)
        t = _pbkdf2_xor_bytes(t, u)
        j = j + 1
    t

fn _pbkdf2_block_sha384(password: [i64], salt: [i64], iterations: i64,
                        block_i: i64) -> [i64]:
    """Compute T_i = U_1 XOR ... XOR U_c for one block using HMAC-SHA-384."""
    val u1_input = _pbkdf2_append(salt, _pbkdf2_int4(block_i))
    var u = hmac_sha384_bytes(password, u1_input)
    var t = u
    var j: i64 = 2
    while j <= iterations:
        u = hmac_sha384_bytes(password, u)
        t = _pbkdf2_xor_bytes(t, u)
        j = j + 1
    t

fn _pbkdf2_block_sha512(password: [i64], salt: [i64], iterations: i64,
                        block_i: i64) -> [i64]:
    """Compute T_i = U_1 XOR ... XOR U_c for one block using HMAC-SHA-512."""
    val u1_input = _pbkdf2_append(salt, _pbkdf2_int4(block_i))
    var u = hmac_sha512_bytes(password, u1_input)
    var t = u
    var j: i64 = 2
    while j <= iterations:
        u = hmac_sha512_bytes(password, u)
        t = _pbkdf2_xor_bytes(t, u)
        j = j + 1
    t

# ============================================================================
# Public API
# ============================================================================

fn pbkdf2_sha256_bytes(password: [i64], salt: [i64], iterations: i64,
                       dk_len: i64) -> [i64]:
    """PBKDF2-HMAC-SHA-256 key derivation (RFC 2898 §5.2).

    Args:
      password   — secret octet string
      salt       — random salt (at least 8 bytes recommended by RFC §4)
      iterations — iteration count c (>= 1; higher is slower but safer)
      dk_len     — desired derived-key length in bytes (<= 32 * (2^32 - 1))

    Returns: dk_len-byte derived key as [i64] list (values 0-255).
    """
    val h_len: i64 = 32   # HMAC-SHA-256 output bytes
    val num_blocks: i64 = (dk_len + h_len - 1) / h_len
    var dk: [i64] = []
    var bi: i64 = 1
    while bi <= num_blocks:
        val t = _pbkdf2_block_sha256(password, salt, iterations, bi)
        var ki: i64 = 0
        while ki < t.len():
            dk.push(t[ki])
            ki = ki + 1
        bi = bi + 1
    _pbkdf2_slice(dk, 0, dk_len)

fn pbkdf2_sha384_bytes(password: [i64], salt: [i64], iterations: i64,
                       dk_len: i64) -> [i64]:
    """PBKDF2-HMAC-SHA-384 key derivation (RFC 2898 §5.2).

    Args:
      password   — secret octet string
      salt       — random salt
      iterations — iteration count c (>= 1)
      dk_len     — desired derived-key length in bytes (<= 48 * (2^32 - 1))

    Returns: dk_len-byte derived key as [i64] list (values 0-255).
    """
    val h_len: i64 = 48   # HMAC-SHA-384 output bytes
    val num_blocks: i64 = (dk_len + h_len - 1) / h_len
    var dk: [i64] = []
    var bi: i64 = 1
    while bi <= num_blocks:
        val t = _pbkdf2_block_sha384(password, salt, iterations, bi)
        var ki: i64 = 0
        while ki < t.len():
            dk.push(t[ki])
            ki = ki + 1
        bi = bi + 1
    _pbkdf2_slice(dk, 0, dk_len)

fn pbkdf2_sha512_bytes(password: [i64], salt: [i64], iterations: i64,
                       dk_len: i64) -> [i64]:
    """PBKDF2-HMAC-SHA-512 key derivation (RFC 2898 §5.2).

    Args:
      password   — secret octet string
      salt       — random salt
      iterations — iteration count c (>= 1)
      dk_len     — desired derived-key length in bytes (<= 64 * (2^32 - 1))

    Returns: dk_len-byte derived key as [i64] list (values 0-255).
    """
    val h_len: i64 = 64   # HMAC-SHA-512 output bytes
    val num_blocks: i64 = (dk_len + h_len - 1) / h_len
    var dk: [i64] = []
    var bi: i64 = 1
    while bi <= num_blocks:
        val t = _pbkdf2_block_sha512(password, salt, iterations, bi)
        var ki: i64 = 0
        while ki < t.len():
            dk.push(t[ki])
            ki = ki + 1
        bi = bi + 1
    _pbkdf2_slice(dk, 0, dk_len)
