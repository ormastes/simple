"""
# Response Cache

Per-worker cache for pre-serialized HTTP response bytes. Avoids
re-running the handler, content-type detection, header construction,
and file I/O on repeated requests for the same static file path.

Each worker owns its own cache — no cross-thread synchronization.
"""

class CacheEntry:
    response_bytes: text
    content_length: i64
    timestamp: i64
    hit_count: i64

class ResponseCache:
    entries: Dict<text, CacheEntry>
    max_entries: i64
    total_hits: i64
    total_misses: i64

    static fn create(max_entries: i64) -> ResponseCache:
        return ResponseCache(
            entries: {},
            max_entries: max_entries,
            total_hits: 0,
            total_misses: 0
        )

    me get(path: text) -> text?:
        val entry = self.entries.get(path)
        if entry.?:
            var e = entry as CacheEntry
            e.hit_count = e.hit_count + 1
            self.entries[path] = e
            self.total_hits = self.total_hits + 1
            return e.response_bytes
        self.total_misses = self.total_misses + 1
        return nil

    me put(path: text, response_bytes: text, content_length: i64, now: i64):
        if self.entries.len() >= self.max_entries:
            self.evict_oldest()
        self.entries[path] = CacheEntry(
            response_bytes: response_bytes,
            content_length: content_length,
            timestamp: now,
            hit_count: 0
        )

    me invalidate(path: text):
        self.entries.remove(path)

    me clear():
        self.entries = {}

    me evict_oldest():
        var oldest_path = ""
        var oldest_ts = 9999999999
        var oldest_hits = 9999999999
        for entry in self.entries:
            val e = entry.value
            if e.hit_count < oldest_hits or (e.hit_count == oldest_hits and e.timestamp < oldest_ts):
                oldest_path = entry.key
                oldest_ts = e.timestamp
                oldest_hits = e.hit_count
        if oldest_path != "":
            self.entries.remove(oldest_path)

    me hit_rate() -> f64:
        val total = self.total_hits + self.total_misses
        if total == 0:
            return 0.0
        return (self.total_hits as f64) / (total as f64)
