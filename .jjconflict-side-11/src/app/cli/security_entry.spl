# Pure Simple entrypoint for `simple security`.

use std.cli.cli_util.{get_cli_args}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_text(path: text) -> text

fn args_after_command() -> [text]:
    val raw = get_cli_args()
    var args: [text] = []
    var start = 1
    var i = 0
    while i < raw.len():
        if raw[i].ends_with("security_entry.spl") or raw[i] == "security":
            start = i + 1
            break
        i = i + 1
    i = start
    while i < raw.len():
        args.push(raw[i])
        i = i + 1
    args

fn print_usage():
    print "Usage: simple security <check|audit|violations|explain> <file.spl> [file2.spl ...]"
    print ""
    print "Runs lightweight source security checks in pure Simple."

fn is_option_with_value(arg: text) -> bool:
    arg == "--config" or arg == "--out"

fn collect_files(args: [text]) -> [text]:
    var files: [text] = []
    var i = 1
    while i < args.len():
        val arg = args[i]
        if is_option_with_value(arg):
            i = i + 1
        elif arg.starts_with("--config=") or arg.starts_with("--out="):
            val _skip = 0
        elif not arg.starts_with("-"):
            files.push(arg)
        i = i + 1
    files

fn scan_file(path: text) -> [text]:
    var findings: [text] = []
    if not rt_file_exists(path):
        findings.push("{path}:1:1:error[SEC-FILE]: file not found")
        return findings
    val source = rt_file_read_text(path) ?? ""
    val lines = source.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i]
        val line_no = i + 1
        if line.contains("password") and line.contains("="):
            findings.push("{path}:{line_no}:1:warning[SEC-SECRET]: possible hardcoded password")
        if line.contains("api_key") or line.contains("secret_key"):
            findings.push("{path}:{line_no}:1:warning[SEC-SECRET]: possible hardcoded key")
        if line.contains("raw_html") or line.contains("innerHTML"):
            findings.push("{path}:{line_no}:1:warning[SEC-HTML]: raw HTML sink")
        if line.contains("SELECT ") and line.contains("+"):
            findings.push("{path}:{line_no}:1:warning[SEC-SQL]: possible SQL string concatenation")
        if line.contains("http://"):
            findings.push("{path}:{line_no}:1:warning[SEC-HTTP]: plaintext HTTP URL")
        i = i + 1
    findings

fn main() -> i64:
    val args = args_after_command()
    if args.len() == 0 or args.contains("-h") or args.contains("--help"):
        print_usage()
        if args.contains("-h") or args.contains("--help"):
            return 0
        return 1

    val command = args[0]
    val files = collect_files(args)
    if files.len() == 0:
        eprint "error: security command requires at least one source file"
        return 1

    var all_findings: [text] = []
    for file in files:
        val findings = scan_file(file)
        for finding in findings:
            all_findings.push(finding)

    if command == "check" or command == "audit" or command == "violations" or command == "explain":
        for finding in all_findings:
            print finding
        if command == "explain":
            print "security files checked: {files.len()}"
            print "security findings: {all_findings.len()}"
        if all_findings.len() == 0:
            print "security: no findings"
            return 0
        return 1

    eprint "error: unknown security command: {command}"
    1
