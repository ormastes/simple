use compiler.tools.duplicate_check.tokenizer.{SimpleToken, SimpleTokenKind}

struct RelaxedToken:
    kind_ordinal: i64
    line: i64
    column: i64

fn token_kind_ordinal(kind: SimpleTokenKind) -> i64:
    match kind:
        case Identifier: 0
        case Keyword: 1
        case Operator: 2
        case Literal: 3
        case Punctuation: 4
        case Comment: 5
        case Whitespace: 6

fn to_relaxed_tokens(tokens: [SimpleToken]) -> [RelaxedToken]:
    var result: [RelaxedToken] = []
    for token in tokens:
        if token.kind != SimpleTokenKind.Whitespace and token.kind != SimpleTokenKind.Comment:
            result.push(RelaxedToken(kind_ordinal: token_kind_ordinal(token.kind), line: token.line, column: token.column))
    result

fn relaxed_power_mod(base: i64, exp: i64, prime: i64) -> i64:
    var result = 1
    var i = 0
    while i < exp:
        result = (result * base) % prime
        i = i + 1
    result

fn relaxed_rolling_hash(tokens: [RelaxedToken], start: i64, count: i64, base: i64, prime: i64) -> i64:
    var hash = 0
    var i = 0
    while i < count and start + i < tokens.len():
        hash = (hash * base + tokens[start + i].kind_ordinal) % prime
        i = i + 1
    hash

export RelaxedToken
export to_relaxed_tokens
export relaxed_power_mod
export relaxed_rolling_hash
