# Golden fixture: path_winding — self-intersecting pentagram with Winding fill

use std.skia.backend.cpu.backend.{CpuBackend, cpu_backend_new}
use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.entity.picture.{SkPicture, SkPictureOp, sk_picture_op_draw_path}
use std.skia.entity.path.{SkPath, sk_path_new}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{sk_color_red}
use std.skia.entity.enums.{SkPathFillType}

fn _pentagram_path(fill: SkPathFillType) -> SkPath:
    # Five-pointed star (pentagram) via every-other vertex of a regular pentagon
    # Center (128, 128), outer radius 100, inner radius ~38
    val cx = 128.0
    val cy = 128.0
    val r  = 100.0
    # Vertices at angles: -90, -90+144, -90+288, -90+432, -90+576 degrees
    # Precomputed (sin/cos not available — use rational approximations)
    # Angle offsets in radians: 0=top, stepping by 144deg (2*pi*2/5)
    # cos/sin approximations for multiples of 72deg:
    #   0 deg:   cos=1.0,      sin=0.0
    #  72 deg:   cos=0.309,    sin=0.951
    # 144 deg:   cos=-0.809,   sin=0.588
    # 216 deg:   cos=-0.809,   sin=-0.588
    # 288 deg:   cos=0.309,    sin=-0.951
    # Star vertex order (skip 1): 0->144->288->72->216->close
    val x0 = cx + r * 0.0
    val y0 = cy - r * 1.0
    val x1 = cx + r * (-0.809)
    val y1 = cy - r * (-0.588)
    val x2 = cx + r * 0.951
    val y2 = cy - r * (-0.309)
    val x3 = cx + r * (-0.951)
    val y3 = cy - r * (-0.309)
    val x4 = cx + r * 0.809
    val y4 = cy - r * (-0.588)
    val base = sk_path_new()
    val p0 = base.with_fill_type(fill)
    val p1 = p0.move_to(x0, y0)
    val p2 = p1.line_to(x1, y1)
    val p3 = p2.line_to(x2, y2)
    val p4 = p3.line_to(x3, y3)
    val p5 = p4.line_to(x4, y4)
    p5.close()

fn golden() -> Bitmap:
    val cull = SkRect(left: 0.0, top: 0.0, right: 256.0, bottom: 256.0)
    val path = _pentagram_path(SkPathFillType.Winding)
    val paint = sk_paint_fill(sk_color_red())
    val op = sk_picture_op_draw_path(path, paint)
    val ops = [op]
    val picture = SkPicture(cull_rect: cull, op_count: 1, ops: ops)
    val backend = cpu_backend_new()
    backend.render_picture(picture, cull)
