# opacity_layer scene — SaveLayer alpha=128 + DrawRect + Restore, cull 400x401

use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_rect}
use std.skia.entity.paint.{SkPaint, sk_paint_new, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{sk_color_argb}

fn scene() -> SkPicture:
    val cull = SkRect(left: 0.0, top: 0.0, right: 400.0, bottom: 401.0)
    val zero_rect = SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0)
    # SaveLayer with alpha=128 (0.5 opacity) encoded in paint color alpha channel
    val layer_paint = sk_paint_fill(sk_color_argb(128, 0, 0, 0))
    val save_layer_op = SkPictureOp(
        kind: SkPictureOpKind.SaveLayer,
        rect: zero_rect,
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: None,
        paint: layer_paint,
        x: 0.0,
        y: 0.0
    )
    # DrawRect inside the layer: red rect
    val inner_rect = SkRect(left: 40.0, top: 40.0, right: 360.0, bottom: 361.0)
    val paint_inner = sk_paint_fill(sk_color_argb(255, 220, 50, 50))
    # Restore op
    val restore_paint = sk_paint_new()
    val restore_op = SkPictureOp(
        kind: SkPictureOpKind.Restore,
        rect: zero_rect,
        rx: 0.0,
        ry: 0.0,
        path: None,
        image: None,
        paint: restore_paint,
        x: 0.0,
        y: 0.0
    )
    val ops = [SkPictureOp]()
    ops.push(save_layer_op)
    ops.push(sk_picture_op_draw_rect(inner_rect, paint_inner))
    ops.push(restore_op)
    SkPicture(cull_rect: cull, op_count: ops.len() as i64, ops: ops)
