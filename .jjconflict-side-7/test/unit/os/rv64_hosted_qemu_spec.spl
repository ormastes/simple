class HostedScenario:
  scenario_name: text
  arch: text
  machine_type: text
  cpu_model: text
  memory_mb: int

  me is_rv64() -> bool:
    return self.arch == "rv64"

  me with_memory(mb: int) -> HostedScenario:
    return HostedScenario(scenario_name: self.scenario_name, arch: self.arch, machine_type: self.machine_type, cpu_model: self.cpu_model, memory_mb: mb)

  static fn default_rv64() -> HostedScenario:
    return HostedScenario(scenario_name: "rv64-hosted", arch: "rv64", machine_type: "virt", cpu_model: "rv64", memory_mb: 256)

class TargetRegistration:
  target_triple: text
  is_hosted: bool
  boot_mode: text
  kernel_path: text

  me is_hosted_mode() -> bool:
    return self.boot_mode == "hosted"

  me is_baremetal() -> bool:
    return self.boot_mode == "baremetal"

  static fn hosted(triple: text, kpath: text) -> TargetRegistration:
    return TargetRegistration(target_triple: triple, is_hosted: true, boot_mode: "hosted", kernel_path: kpath)

  static fn baremetal(triple: text, kpath: text) -> TargetRegistration:
    return TargetRegistration(target_triple: triple, is_hosted: false, boot_mode: "baremetal", kernel_path: kpath)

class PreflightEntry:
  entry_name: text
  keep_alive: bool
  timeout_ms: int
  probe_count: int

  me is_persistent() -> bool:
    return self.keep_alive

  me with_timeout(ms: int) -> PreflightEntry:
    return PreflightEntry(entry_name: self.entry_name, keep_alive: self.keep_alive, timeout_ms: ms, probe_count: self.probe_count)

  static fn create(name: text, probes: int) -> PreflightEntry:
    return PreflightEntry(entry_name: name, keep_alive: true, timeout_ms: 5000, probe_count: probes)

class GuestProbe:
  probe_type: text
  host: text
  port: int
  expected_response: text
  passed: bool

  me is_ssh() -> bool:
    return self.probe_type == "ssh"

  me is_http() -> bool:
    return self.probe_type == "http"

  me mark_passed() -> GuestProbe:
    return GuestProbe(probe_type: self.probe_type, host: self.host, port: self.port, expected_response: self.expected_response, passed: true)

  static fn ssh(h: text, p: int) -> GuestProbe:
    return GuestProbe(probe_type: "ssh", host: h, port: p, expected_response: "SSH-2.0", passed: false)

  static fn http(h: text, p: int) -> GuestProbe:
    return GuestProbe(probe_type: "http", host: h, port: p, expected_response: "200 OK", passed: false)

class ProbeResult:
  probe_type: text
  latency_ms: int
  success: bool
  error_msg: text
  retry_count: int

  me is_success() -> bool:
    return self.success

  me is_timeout() -> bool:
    return self.error_msg == "timeout"

  static fn ok(ptype: text, lat: int) -> ProbeResult:
    return ProbeResult(probe_type: ptype, latency_ms: lat, success: true, error_msg: "", retry_count: 0)

  static fn fail(ptype: text, err: text) -> ProbeResult:
    return ProbeResult(probe_type: ptype, latency_ms: 0, success: false, error_msg: err, retry_count: 0)

class SmokeMedia:
  media_type: text
  image_path: text
  is_attached: bool
  mount_point: text

  me is_disk() -> bool:
    return self.media_type == "disk"

  me attach() -> SmokeMedia:
    return SmokeMedia(media_type: self.media_type, image_path: self.image_path, is_attached: true, mount_point: self.mount_point)

  static fn disk(path: text, mount: text) -> SmokeMedia:
    return SmokeMedia(media_type: "disk", image_path: path, is_attached: false, mount_point: mount)

class BootPhase:
  phase_name: text
  completed: bool
  duration_ms: int
  error_msg: text

  me is_done() -> bool:
    return self.completed

  me complete(ms: int) -> BootPhase:
    return BootPhase(phase_name: self.phase_name, completed: true, duration_ms: ms, error_msg: "")

  static fn create(name: text) -> BootPhase:
    return BootPhase(phase_name: name, completed: false, duration_ms: 0, error_msg: "")

class LaneEntry:
  entry_name: text
  test_kind: text
  passed: bool
  duration_ms: int

  me is_smoke() -> bool:
    return self.test_kind == "smoke"

  me mark_passed(ms: int) -> LaneEntry:
    return LaneEntry(entry_name: self.entry_name, test_kind: self.test_kind, passed: true, duration_ms: ms)

  static fn create(name: text, kind: text) -> LaneEntry:
    return LaneEntry(entry_name: name, test_kind: kind, passed: false, duration_ms: 0)

class SmokeLane:
  lane_name: text
  lane_type: text
  f0_entry: LaneEntry
  f1_entry: LaneEntry
  f2_entry: LaneEntry
  entry_count: int

  me is_smf() -> bool:
    return self.lane_type == "smf"

  me all_passed() -> bool:
    if self.entry_count == 0:
      return true
    if self.entry_count >= 1:
      if self.f0_entry.passed == false:
        return false
    if self.entry_count >= 2:
      if self.f1_entry.passed == false:
        return false
    if self.entry_count >= 3:
      if self.f2_entry.passed == false:
        return false
    return true

  static fn smf_lane(name: text) -> SmokeLane:
    val e = LaneEntry(entry_name: "", test_kind: "smoke", passed: false, duration_ms: 0)
    return SmokeLane(lane_name: name, lane_type: "smf", f0_entry: e, f1_entry: e, f2_entry: e, entry_count: 0)

class SmfLaneConfig:
  config_name: text
  is_smoke_only: bool
  arch_filter: text
  max_entries: int

  me accepts_arch(arch: text) -> bool:
    return self.arch_filter == arch

  static fn rv64_smoke() -> SmfLaneConfig:
    return SmfLaneConfig(config_name: "rv64-smoke", is_smoke_only: true, arch_filter: "rv64", max_entries: 32)

class LaneGate:
  gate_name: text
  required_pass: int
  actual_pass: int
  is_open: bool

  me check() -> LaneGate:
    if self.actual_pass >= self.required_pass:
      return LaneGate(gate_name: self.gate_name, required_pass: self.required_pass, actual_pass: self.actual_pass, is_open: true)
    return LaneGate(gate_name: self.gate_name, required_pass: self.required_pass, actual_pass: self.actual_pass, is_open: false)

  me record_pass() -> LaneGate:
    return LaneGate(gate_name: self.gate_name, required_pass: self.required_pass, actual_pass: self.actual_pass + 1, is_open: self.is_open)

  static fn create(name: text, required: int) -> LaneGate:
    return LaneGate(gate_name: name, required_pass: required, actual_pass: 0, is_open: false)

fn test_scenario_default():
  val s = HostedScenario.default_rv64()
  if s.arch == "rv64":
    if s.memory_mb == 256:
      print("PASS: test_scenario_default")
      return
  print("FAIL: test_scenario_default")

fn test_scenario_is_rv64():
  val s = HostedScenario.default_rv64()
  if s.is_rv64():
    print("PASS: test_scenario_is_rv64")
    return
  print("FAIL: test_scenario_is_rv64")

fn test_scenario_memory():
  val s = HostedScenario.default_rv64()
  val s2 = s.with_memory(512)
  if s2.memory_mb == 512:
    print("PASS: test_scenario_memory")
    return
  print("FAIL: test_scenario_memory")

fn test_target_hosted():
  val t = TargetRegistration.hosted("riscv64-unknown-linux-gnu", "/boot/vmlinux")
  if t.boot_mode == "hosted":
    print("PASS: test_target_hosted")
    return
  print("FAIL: test_target_hosted")

fn test_target_baremetal():
  val t = TargetRegistration.baremetal("riscv64-unknown-none", "/boot/kernel.elf")
  if t.boot_mode == "baremetal":
    print("PASS: test_target_baremetal")
    return
  print("FAIL: test_target_baremetal")

fn test_target_is_hosted():
  val t = TargetRegistration.hosted("riscv64-unknown-linux-gnu", "/boot/vmlinux")
  if t.is_hosted_mode():
    print("PASS: test_target_is_hosted")
    return
  print("FAIL: test_target_is_hosted")

fn test_preflight_create():
  val p = PreflightEntry.create("boot-probe", 3)
  if p.keep_alive:
    if p.probe_count == 3:
      print("PASS: test_preflight_create")
      return
  print("FAIL: test_preflight_create")

fn test_preflight_timeout():
  val p = PreflightEntry.create("boot-probe", 3)
  val p2 = p.with_timeout(10000)
  if p2.timeout_ms == 10000:
    print("PASS: test_preflight_timeout")
    return
  print("FAIL: test_preflight_timeout")

fn test_probe_ssh():
  val g = GuestProbe.ssh("localhost", 2222)
  if g.is_ssh():
    if g.port == 2222:
      print("PASS: test_probe_ssh")
      return
  print("FAIL: test_probe_ssh")

fn test_probe_http():
  val g = GuestProbe.http("localhost", 8080)
  if g.is_http():
    if g.port == 8080:
      print("PASS: test_probe_http")
      return
  print("FAIL: test_probe_http")

fn test_probe_pass():
  val g = GuestProbe.ssh("localhost", 2222)
  val g2 = g.mark_passed()
  if g2.passed:
    print("PASS: test_probe_pass")
    return
  print("FAIL: test_probe_pass")

fn test_probe_result_ok():
  val r = ProbeResult.ok("ssh", 42)
  if r.is_success():
    print("PASS: test_probe_result_ok")
    return
  print("FAIL: test_probe_result_ok")

fn test_probe_result_fail():
  val r = ProbeResult.fail("ssh", "connection refused")
  if r.success == false:
    print("PASS: test_probe_result_fail")
    return
  print("FAIL: test_probe_result_fail")

fn test_probe_timeout():
  val r = ProbeResult.fail("ssh", "timeout")
  if r.is_timeout():
    print("PASS: test_probe_timeout")
    return
  print("FAIL: test_probe_timeout")

fn test_media_disk():
  val m = SmokeMedia.disk("/images/rv64.qcow2", "/mnt")
  if m.is_disk():
    print("PASS: test_media_disk")
    return
  print("FAIL: test_media_disk")

fn test_media_attach():
  val m = SmokeMedia.disk("/images/rv64.qcow2", "/mnt")
  val m2 = m.attach()
  if m2.is_attached:
    print("PASS: test_media_attach")
    return
  print("FAIL: test_media_attach")

fn test_boot_phase():
  val b = BootPhase.create("kernel-load")
  val b2 = b.complete(100)
  if b2.completed:
    if b2.duration_ms == 100:
      print("PASS: test_boot_phase")
      return
  print("FAIL: test_boot_phase")

fn test_lane_entry():
  val e = LaneEntry.create("smoke-basic", "smoke")
  val e2 = e.mark_passed(50)
  if e2.passed:
    if e2.duration_ms == 50:
      print("PASS: test_lane_entry")
      return
  print("FAIL: test_lane_entry")

fn test_lane_config():
  val c = SmfLaneConfig.rv64_smoke()
  if c.accepts_arch("rv64"):
    print("PASS: test_lane_config")
    return
  print("FAIL: test_lane_config")

fn test_gate_check():
  val g = LaneGate.create("rv64-gate", 1)
  val g2 = g.record_pass()
  val g3 = g2.check()
  if g3.is_open:
    print("PASS: test_gate_check")
    return
  print("FAIL: test_gate_check")

fn main():
  test_scenario_default()
  test_scenario_is_rv64()
  test_scenario_memory()
  test_target_hosted()
  test_target_baremetal()
  test_target_is_hosted()
  test_preflight_create()
  test_preflight_timeout()
  test_probe_ssh()
  test_probe_http()
  test_probe_pass()
  test_probe_result_ok()
  test_probe_result_fail()
  test_probe_timeout()
  test_media_disk()
  test_media_attach()
  test_boot_phase()
  test_lane_entry()
  test_lane_config()
  test_gate_check()
  print("DONE")
