# Test: env/printenv tool
# Feature: TOOL-ENV - Print environment variables
# @cover tools/shell/env/env_tool.spl

describe "env tool":
    context "environment listing":
        it "formats key=value pairs":
            val key = "HOME"
            val value = "/root"
            val formatted = "{key}={value}"
            expect(formatted).to_equal("HOME=/root")

    context "variable lookup":
        it "finds existing variable":
            val env: [(text, text)] = [("PATH", "/bin"), ("HOME", "/root")]
            var found = ""
            for pair in env:
                if pair.0 == "HOME":
                    found = pair.1
            expect(found).to_equal("/root")

        it "returns empty for missing variable":
            val env: [(text, text)] = [("PATH", "/bin")]
            var found = ""
            for pair in env:
                if pair.0 == "MISSING":
                    found = pair.1
            expect(found).to_equal("")
