#!/bin/sh
# SimpleOS / RISC-V system test, observed over the telnet-over-serial bridge.
#
# This is a REAL OS system test (unlike the KV260 transport test, whose marker
# is a synthetic JTAG injection). Here the marker is genuine SimpleOS kernel
# output: the OS boots on a RISC-V CPU (QEMU `virt`, rv64, via OpenSBI), its
# UART console streams to a file, the telnet_serial_bridge relays that file to
# a TCP telnet port, and a telnet client must observe a real SimpleOS boot
# marker arriving through the bridge.
#
#   qemu-system-riscv64 -serial file:$rx   (SimpleOS RV64 kernel boots)
#        |  console bytes
#        v
#   telnet_serial_bridge  rx=$rx  ->  TCP :PORT
#        |
#        v
#   telnet_serial_probe  waits for MARKER ("SimpleOS RV64" by default)
#
# Physical-FPGA note: the KV260 NaxRiscv bitstream exposes only serial_tx/_rx
# on PMOD H12/E10 (no PS-AXI bridge, no RISC-V JTAG debug module — verified
# from the netlist 2026-06-13), so the same OS marker on real silicon needs a
# 3.3V PMOD adapter wired to those pins; point QEMU_RX at that adapter's tty
# and this same harness validates the physical path.
#
# All long-lived helpers run in their own detached process groups (setsid +
# timeout) so a wedge or crash never takes down the invoking session.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

ELF="${ELF:-build/os/simpleos_riscv64.elf}"
OUT_DIR="${OUT_DIR:-build/simpleos_riscv_telnet_serial_$(date +%Y%m%d_%H%M%S)}"
BRIDGE_PORT="${BRIDGE_PORT:-2341}"
MARKER="${MARKER:-TEST PASSED}"
CAPTURE_MS="${CAPTURE_MS:-30000}"
# Seed binary streams stdout immediately; stage4 bin/simple buffers until exit
# so live BRIDGE_LISTENING / PROBE markers would never appear.
SIMPLE="${SIMPLE:-bin/release/x86_64-unknown-linux-gnu/simple_seed}"

mkdir -p "$OUT_DIR"

fail() { printf 'FAIL %s\n' "$1"; exit 1; }
pass() { printf 'PASS %s\n' "$1"; }
info() { printf 'INFO %s\n' "$1"; }

# Guarded kill: never signal pid <= 1 or empty (session-crash hardening).
safe_kill() {
    for pid in "$@"; do
        case "$pid" in
            ''|0|1|-*) continue ;;
        esac
        kill "$pid" 2>/dev/null || true
    done
}

command -v qemu-system-riscv64 >/dev/null 2>&1 || fail "qemu_riscv64_missing"
[ -f "$ELF" ] || fail "simpleos_rv64_elf_missing path=$ELF"
[ -x "$SIMPLE" ] || fail "simple_seed_missing path=$SIMPLE"
pass "prerequisites"

rx_file="$OUT_DIR/qemu_serial.log"
tx_file="$OUT_DIR/client_to_guest.bin"
: > "$rx_file"
: > "$tx_file"

qemu_pid=""
bridge_pid=""
probe_pid=""
cleanup() { safe_kill "$probe_pid" "$bridge_pid" "$qemu_pid"; }
trap cleanup EXIT INT TERM

# 1. Bridge first (so it captures the boot from byte 0 — the OS banner prints
#    within the first boot iteration; starting late risks racing a fast log).
bridge_log="$OUT_DIR/bridge.log"
setsid timeout 90 env SIMPLE_EXECUTION_MODE=interpreter \
    "$SIMPLE" run scripts/fpga/telnet_serial_bridge.spl \
    "$rx_file" "$tx_file" "127.0.0.1:$BRIDGE_PORT" 1 0 \
    >"$bridge_log" 2>&1 &
bridge_pid=$!
i=0
while [ "$i" -lt 60 ]; do
    grep -q 'BRIDGE_LISTENING' "$bridge_log" 2>/dev/null && break
    grep -q 'BRIDGE_ERROR' "$bridge_log" 2>/dev/null && break
    sleep 1; i=$((i + 1))
done
grep -q 'BRIDGE_LISTENING' "$bridge_log" || { sed -n '1,40p' "$bridge_log"; fail "bridge_listening"; }
pass "bridge_listening"

# 2. Telnet probe: connect through the bridge, watch for the real OS marker.
probe_log="$OUT_DIR/probe.log"
setsid timeout 80 env SIMPLE_EXECUTION_MODE=interpreter \
    "$SIMPLE" run scripts/fpga/telnet_serial_probe.spl \
    127.0.0.1 "$BRIDGE_PORT" "$CAPTURE_MS" "$MARKER" \
    >"$probe_log" 2>&1 &
probe_pid=$!
i=0
while [ "$i" -lt 30 ]; do
    grep -q 'TELNET_PROBE_CONNECTED' "$probe_log" 2>/dev/null && break
    grep -q 'connect_failed' "$probe_log" 2>/dev/null && break
    sleep 1; i=$((i + 1))
done
grep -q 'TELNET_PROBE_CONNECTED' "$probe_log" || { sed -n '1,40p' "$probe_log"; fail "telnet_client_connected"; }
pass "telnet_client_connected"

# 3. Boot SimpleOS RV64 on QEMU RISC-V; console streams to the bridge's rx file.
info "booting SimpleOS RV64 on qemu-system-riscv64 (virt, rv64, OpenSBI)"
setsid timeout 60 qemu-system-riscv64 \
    -machine virt -cpu rv64 -m 256M \
    -nographic -monitor none \
    -kernel "$ELF" \
    -serial file:"$rx_file" \
    </dev/null >"$OUT_DIR/qemu.log" 2>&1 &
qemu_pid=$!
pass "simpleos_rv64_qemu_launched"

# 4. The probe must observe the real SimpleOS marker through the bridge.
wait "$probe_pid" 2>/dev/null || true
probe_pid=""
sed -n '1,60p' "$probe_log"
if grep -q 'TELNET_PROBE_STATUS=marker_seen' "$probe_log"; then
    pass "simpleos_riscv_marker_over_telnet_serial"
else
    info "rx_file_bytes=$(wc -c <"$rx_file" | tr -d ' ')"
    info "qemu_boot_head:"
    tr -cd '\11\12\15\40-\176' <"$rx_file" 2>/dev/null | sed -n '1,30p'
    fail "simpleos_riscv_marker_over_telnet_serial"
fi

for required_marker in \
    "FS_MOUNT_OK" \
    "SMF_DISCOVERY_OK" \
    "ELF_LOAD_OK arch=riscv64 app=/sys/apps/hello_world.smf" \
    "SMF_CLI_LAUNCH_OK app=/sys/apps/hello_world.smf" \
    "SMF_WM_GUI_LAUNCH_OK app=/sys/apps/browser_demo.smf" \
    "NATIVE_GUI_PROCESS_RENDER_OK app=/sys/apps/browser_demo.smf" \
    "SIMPLEOS_RISCV_SMF_FS_PASS" \
    "TEST PASSED"
do
    grep -q "$required_marker" "$probe_log" || fail "simpleos_riscv_required_marker marker=$required_marker"
done
pass "simpleos_riscv_required_markers"

safe_kill "$bridge_pid" "$qemu_pid"
bridge_pid=""; qemu_pid=""

info "marker=\"$MARKER\" (real SimpleOS RV64 kernel output, not synthetic)"
info "out_dir=$OUT_DIR"
pass "simpleos_riscv_telnet_serial_systest"
