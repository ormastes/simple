# Graphics Optimization Registry
#
# Registry of graphics optimization providers. Uses flat scalar fields
# (p0_, p1_, p2_, p3_) to work around interpreter array mutation bugs.
# Supports up to 4 providers.
#
# Usage:
#   use std.gpu.session.optimization_registry.{GraphicsOptRegistry}

use std.io

class GraphicsOptRegistry:
    provider_count: i64
    p0_id: text
    p0_kind: text
    p0_backend: text
    p0_arch: text
    p0_bits: i64
    p0_mode: text
    p0_active: bool
    p1_id: text
    p1_kind: text
    p1_backend: text
    p1_arch: text
    p1_bits: i64
    p1_mode: text
    p1_active: bool
    p2_id: text
    p2_kind: text
    p2_backend: text
    p2_arch: text
    p2_bits: i64
    p2_mode: text
    p2_active: bool
    p3_id: text
    p3_kind: text
    p3_backend: text
    p3_arch: text
    p3_bits: i64
    p3_mode: text
    p3_active: bool

    static fn create() -> GraphicsOptRegistry:
        GraphicsOptRegistry(
            provider_count: 0,
            p0_id: "", p0_kind: "", p0_backend: "", p0_arch: "", p0_bits: 0, p0_mode: "", p0_active: false,
            p1_id: "", p1_kind: "", p1_backend: "", p1_arch: "", p1_bits: 0, p1_mode: "", p1_active: false,
            p2_id: "", p2_kind: "", p2_backend: "", p2_arch: "", p2_bits: 0, p2_mode: "", p2_active: false,
            p3_id: "", p3_kind: "", p3_backend: "", p3_arch: "", p3_bits: 0, p3_mode: "", p3_active: false
        )

    me register_provider(id: text, kind: text, backend: text, arch: text, bits: i64, mode: text) -> text:
        if self.provider_count >= 4:
            return "registry full: max 4 providers"
        if self.provider_count == 0:
            self.p0_id = id
            self.p0_kind = kind
            self.p0_backend = backend
            self.p0_arch = arch
            self.p0_bits = bits
            self.p0_mode = mode
            self.p0_active = true
        if self.provider_count == 1:
            self.p1_id = id
            self.p1_kind = kind
            self.p1_backend = backend
            self.p1_arch = arch
            self.p1_bits = bits
            self.p1_mode = mode
            self.p1_active = true
        if self.provider_count == 2:
            self.p2_id = id
            self.p2_kind = kind
            self.p2_backend = backend
            self.p2_arch = arch
            self.p2_bits = bits
            self.p2_mode = mode
            self.p2_active = true
        if self.provider_count == 3:
            self.p3_id = id
            self.p3_kind = kind
            self.p3_backend = backend
            self.p3_arch = arch
            self.p3_bits = bits
            self.p3_mode = mode
            self.p3_active = true
        self.provider_count = self.provider_count + 1
        return ""

    me find_provider(kind: text, backend: text, arch: text) -> text:
        if self.p0_active:
            if self.p0_kind == kind:
                if self.p0_backend == backend:
                    if self.p0_arch == arch:
                        return self.p0_id
        if self.p1_active:
            if self.p1_kind == kind:
                if self.p1_backend == backend:
                    if self.p1_arch == arch:
                        return self.p1_id
        if self.p2_active:
            if self.p2_kind == kind:
                if self.p2_backend == backend:
                    if self.p2_arch == arch:
                        return self.p2_id
        if self.p3_active:
            if self.p3_kind == kind:
                if self.p3_backend == backend:
                    if self.p3_arch == arch:
                        return self.p3_id
        return ""

    me invalidate_for_backend(backend: text) -> i64:
        var count = 0
        if self.p0_active:
            if self.p0_backend == backend:
                self.p0_active = false
                count = count + 1
        if self.p1_active:
            if self.p1_backend == backend:
                self.p1_active = false
                count = count + 1
        if self.p2_active:
            if self.p2_backend == backend:
                self.p2_active = false
                count = count + 1
        if self.p3_active:
            if self.p3_backend == backend:
                self.p3_active = false
                count = count + 1
        return count

    me invalidate_for_mode(mode: text) -> i64:
        var count = 0
        if self.p0_active:
            if self.p0_mode == mode:
                self.p0_active = false
                count = count + 1
        if self.p1_active:
            if self.p1_mode == mode:
                self.p1_active = false
                count = count + 1
        if self.p2_active:
            if self.p2_mode == mode:
                self.p2_active = false
                count = count + 1
        if self.p3_active:
            if self.p3_mode == mode:
                self.p3_active = false
                count = count + 1
        return count

    me active_count() -> i64:
        var count = 0
        if self.p0_active:
            count = count + 1
        if self.p1_active:
            count = count + 1
        if self.p2_active:
            count = count + 1
        if self.p3_active:
            count = count + 1
        return count

    me snapshot_for_perf() -> GraphicsOptRegistry:
        val snap = GraphicsOptRegistry.create()
        snap.provider_count = self.provider_count
        snap.p0_id = self.p0_id
        snap.p0_kind = self.p0_kind
        snap.p0_backend = self.p0_backend
        snap.p0_arch = self.p0_arch
        snap.p0_bits = self.p0_bits
        snap.p0_mode = "perf_exclusive"
        snap.p0_active = self.p0_active
        snap.p1_id = self.p1_id
        snap.p1_kind = self.p1_kind
        snap.p1_backend = self.p1_backend
        snap.p1_arch = self.p1_arch
        snap.p1_bits = self.p1_bits
        snap.p1_mode = "perf_exclusive"
        snap.p1_active = self.p1_active
        snap.p2_id = self.p2_id
        snap.p2_kind = self.p2_kind
        snap.p2_backend = self.p2_backend
        snap.p2_arch = self.p2_arch
        snap.p2_bits = self.p2_bits
        snap.p2_mode = "perf_exclusive"
        snap.p2_active = self.p2_active
        snap.p3_id = self.p3_id
        snap.p3_kind = self.p3_kind
        snap.p3_backend = self.p3_backend
        snap.p3_arch = self.p3_arch
        snap.p3_bits = self.p3_bits
        snap.p3_mode = "perf_exclusive"
        snap.p3_active = self.p3_active
        return snap

    me stats() -> text:
        var msg = "GraphicsOptRegistry: providers=" + self.provider_count.to_text()
        msg = msg + " active=" + self.active_count().to_text()
        return msg
