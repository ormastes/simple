# Shared WM runtime dispatch adapter.
#
# Converts backend-neutral SharedWmDispatchResult values into stable command
# names and payload text that host WM and SimpleOS WM runtimes can consume.

use common.ui.window_scene.{SharedWmDispatchResult}

struct WmRuntimeDispatchCommand:
    kind: text
    target_id: text
    app_id: text
    window_id: text
    payload: text
    handled: bool

struct WmRuntimeShellState:
    launched_apps: [text]
    focused_window_id: text
    dragging_surface_id: text
    command_lane_target: text
    background_click_count: i32
    last_command_kind: text

fn wm_runtime_shell_state_empty() -> WmRuntimeShellState:
    WmRuntimeShellState(
        launched_apps: [],
        focused_window_id: "",
        dragging_surface_id: "",
        command_lane_target: "",
        background_click_count: 0,
        last_command_kind: ""
    )

fn wm_runtime_dispatch_command(kind: text, target_id: text, app_id: text, window_id: text, payload: text, handled: bool) -> WmRuntimeDispatchCommand:
    WmRuntimeDispatchCommand(
        kind: kind,
        target_id: target_id,
        app_id: app_id,
        window_id: window_id,
        payload: payload,
        handled: handled
    )

fn wm_runtime_command_from_shared_dispatch(result: SharedWmDispatchResult) -> WmRuntimeDispatchCommand:
    if result.action == "launch_app":
        return wm_runtime_dispatch_command(
            "launcher_launch",
            result.target_id,
            result.app_id,
            "",
            "app_id={result.app_id}",
            true
        )
    if result.action == "focus_window":
        return wm_runtime_dispatch_command(
            "window_focus",
            result.target_id,
            result.app_id,
            result.window_id,
            "window_id={result.window_id};app_id={result.app_id}",
            true
        )
    if result.action == "begin_drag_window":
        return wm_runtime_dispatch_command(
            "window_drag_begin",
            result.target_id,
            result.app_id,
            result.window_id,
            "surface_id={result.target_id};window_id={result.window_id}",
            true
        )
    if result.action == "command_lane_clock":
        return wm_runtime_dispatch_command(
            "command_lane_clock",
            result.target_id,
            "",
            "",
            "target=clock",
            true
        )
    if result.action == "command_lane_icon":
        return wm_runtime_dispatch_command(
            "command_lane_icon",
            result.target_id,
            "",
            "",
            "target={result.target_id}",
            true
        )
    if result.action == "desktop_background":
        return wm_runtime_dispatch_command(
            "desktop_background",
            result.target_id,
            "",
            "",
            "target=background",
            true
        )
    if result.action == "command_lane":
        return wm_runtime_dispatch_command(
            "command_lane",
            result.target_id,
            "",
            "",
            "target=command_lane",
            true
        )
    wm_runtime_dispatch_command(
        "ignored",
        result.target_id,
        result.app_id,
        result.window_id,
        "",
        false
    )

fn wm_runtime_dispatch_wire(command: WmRuntimeDispatchCommand) -> text:
    var parts: [text] = [
        "kind=", command.kind,
        ";target=", command.target_id,
        ";app=", command.app_id,
        ";window=", command.window_id,
        ";handled=", "{command.handled}",
        ";payload=", command.payload
    ]
    parts.join("")

fn wm_runtime_apply_command(state: WmRuntimeShellState, command: WmRuntimeDispatchCommand) -> WmRuntimeShellState:
    if not command.handled:
        return WmRuntimeShellState(
            launched_apps: state.launched_apps,
            focused_window_id: state.focused_window_id,
            dragging_surface_id: state.dragging_surface_id,
            command_lane_target: state.command_lane_target,
            background_click_count: state.background_click_count,
            last_command_kind: "ignored"
        )
    if command.kind == "launcher_launch":
        var launched = state.launched_apps
        launched = launched.push(command.app_id)
        return WmRuntimeShellState(
            launched_apps: launched,
            focused_window_id: state.focused_window_id,
            dragging_surface_id: state.dragging_surface_id,
            command_lane_target: state.command_lane_target,
            background_click_count: state.background_click_count,
            last_command_kind: command.kind
        )
    if command.kind == "window_focus":
        return WmRuntimeShellState(
            launched_apps: state.launched_apps,
            focused_window_id: command.window_id,
            dragging_surface_id: "",
            command_lane_target: state.command_lane_target,
            background_click_count: state.background_click_count,
            last_command_kind: command.kind
        )
    if command.kind == "window_drag_begin":
        return WmRuntimeShellState(
            launched_apps: state.launched_apps,
            focused_window_id: command.window_id,
            dragging_surface_id: command.target_id,
            command_lane_target: state.command_lane_target,
            background_click_count: state.background_click_count,
            last_command_kind: command.kind
        )
    if command.kind == "command_lane_clock" or command.kind == "command_lane_icon" or command.kind == "command_lane":
        return WmRuntimeShellState(
            launched_apps: state.launched_apps,
            focused_window_id: state.focused_window_id,
            dragging_surface_id: state.dragging_surface_id,
            command_lane_target: command.target_id,
            background_click_count: state.background_click_count,
            last_command_kind: command.kind
        )
    if command.kind == "desktop_background":
        return WmRuntimeShellState(
            launched_apps: state.launched_apps,
            focused_window_id: "",
            dragging_surface_id: "",
            command_lane_target: state.command_lane_target,
            background_click_count: state.background_click_count + 1,
            last_command_kind: command.kind
        )
    WmRuntimeShellState(
        launched_apps: state.launched_apps,
        focused_window_id: state.focused_window_id,
        dragging_surface_id: state.dragging_surface_id,
        command_lane_target: state.command_lane_target,
        background_click_count: state.background_click_count,
        last_command_kind: "ignored"
    )

fn wm_runtime_apply_shared_dispatch(state: WmRuntimeShellState, result: SharedWmDispatchResult) -> WmRuntimeShellState:
    wm_runtime_apply_command(state, wm_runtime_command_from_shared_dispatch(result))
