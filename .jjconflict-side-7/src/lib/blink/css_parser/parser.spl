# CSS parser — consumes CssToken stream → rule list.
#
# Mirrors Blink's CSSParser (subset). Produces a list of style rules, each
# with a selector string and a list of (property, value) declarations.
#
# Scope: flat rule list only. No at-rules, no nested rules, no media queries,
# no custom property dereferencing, no shorthand expansion.

use std.lib.blink.css_parser.{CssTokenKind, CssToken}

# ============================================================================
# CssDeclaration — a single property: value pair inside a rule block.
# ============================================================================

class CssDeclaration:
    property: String
    value: String
    important: bool

# ============================================================================
# CssStyleRule — one selector + its declaration block.
# ============================================================================

class CssStyleRule:
    selector: String
    declarations: [CssDeclaration]

# ============================================================================
# CssStyleSheet — top-level parse result.
# ============================================================================

class CssStyleSheet:
    rules: [CssStyleRule]
    errors: [String]

# ============================================================================
# Private helpers
# ============================================================================

# _peek_token — returns token at pos, or a synthetic Eof token if out of range.
fn _peek_token(tokens: [CssToken], pos: i64) -> CssToken:
    if pos < 0 or pos >= tokens.len():
        return CssToken(kind: CssTokenKind.Eof, text: "", line: 0, column: 0)
    val opt = tokens.at(pos)
    match opt:
        Some(t):
            t
        None:
            CssToken(kind: CssTokenKind.Eof, text: "", line: 0, column: 0)

# _is_delim — true when the token is a Delim whose text equals ch.
fn _is_delim(t: CssToken, ch: String) -> bool:
    val is_d = t.kind == CssTokenKind.Delim
    is_d and t.text == ch

# _collect_selector_text — joins text of tokens[start..end) with spaces.
fn _collect_selector_text(tokens: [CssToken], start: i64, end: i64) -> String:
    var result: String = ""
    var i = start
    while i < end:
        val t = _peek_token(tokens, i)
        if result == "":
            result = t.text
        else:
            result = result + " " + t.text
        i = i + 1
    result

# _is_important — checks whether tokens[start..end) ends with "!" followed by "important".
fn _is_important(tokens: [CssToken], start: i64, end: i64) -> bool:
    # Need at least 2 tokens: "!" and "important"
    if end - start < 2:
        return false
    val bang = _peek_token(tokens, end - 2)
    val word = _peek_token(tokens, end - 1)
    val bang_ok = _is_delim(bang, "!")
    val word_ok = word.kind == CssTokenKind.Identifier and word.text == "important"
    bang_ok and word_ok

# _collect_value_text — joins text of tokens[start..end), stripping trailing !important.
fn _collect_value_text(tokens: [CssToken], start: i64, end: i64) -> String:
    var real_end = end
    if _is_important(tokens, start, end):
        real_end = end - 2
    var result: String = ""
    var i = start
    while i < real_end:
        val t = _peek_token(tokens, i)
        if result == "":
            result = t.text
        else:
            result = result + " " + t.text
        i = i + 1
    result

# ============================================================================
# parse_css — main entry point.
#
# State machine:
#   SELECTOR  — accumulating selector tokens until `{`
#   DECL_PROP — expecting a property identifier (or `}` to end the block)
#   DECL_VAL  — accumulating value tokens until `;` or `}`
# ============================================================================

fn parse_css(tokens: [CssToken]) -> CssStyleSheet:
    var rules: [CssStyleRule] = []
    var errors: [String] = []

    val n = tokens.len()
    var pos = 0

    while pos < n:
        val cur = _peek_token(tokens, pos)

        # Skip Eof
        if cur.kind == CssTokenKind.Eof:
            break

        # Skip Comment tokens at top level
        if cur.kind == CssTokenKind.Comment:
            pos = pos + 1
            continue

        # ----- Collect selector tokens until `{` -----
        val sel_start = pos
        var found_open = false
        while pos < n:
            val t = _peek_token(tokens, pos)
            if t.kind == CssTokenKind.Eof:
                break
            if _is_delim(t, "{"):
                found_open = true
                break
            # A bare `}` without a `{` is a stray token — record error and skip
            if _is_delim(t, "}"):
                errors.push("Unexpected '}' at line " + t.line.to_string() + ", col " + t.column.to_string())
                pos = pos + 1
                break
            pos = pos + 1

        if not found_open:
            # Reached Eof while scanning selector — error if we consumed tokens
            if pos > sel_start:
                val first = _peek_token(tokens, sel_start)
                errors.push("Missing '{' for rule starting at line " + first.line.to_string())
            continue

        val sel_text = _collect_selector_text(tokens, sel_start, pos)
        # advance past `{`
        pos = pos + 1

        # ----- Parse declarations inside `{ ... }` -----
        var declarations: [CssDeclaration] = []

        while pos < n:
            val t = _peek_token(tokens, pos)

            # End of block
            if _is_delim(t, "}"):
                pos = pos + 1
                break

            if t.kind == CssTokenKind.Eof:
                errors.push("Unexpected end of tokens inside rule block for selector '" + sel_text + "'")
                break

            # Skip comments and stray semicolons inside a block
            if t.kind == CssTokenKind.Comment:
                pos = pos + 1
                continue
            if _is_delim(t, ";"):
                pos = pos + 1
                continue

            # Expect property identifier
            if t.kind != CssTokenKind.Identifier:
                errors.push("Expected property identifier, got '" + t.text + "' at line " + t.line.to_string())
                # skip to next `;` or `}`
                while pos < n:
                    val sk = _peek_token(tokens, pos)
                    if _is_delim(sk, ";") or _is_delim(sk, "}") or sk.kind == CssTokenKind.Eof:
                        break
                    pos = pos + 1
                continue

            val prop_text = t.text
            pos = pos + 1

            # Expect `:`
            val colon = _peek_token(tokens, pos)
            if not _is_delim(colon, ":"):
                errors.push("Expected ':' after property '" + prop_text + "' at line " + colon.line.to_string())
                # skip to next `;` or `}`
                while pos < n:
                    val sk = _peek_token(tokens, pos)
                    if _is_delim(sk, ";") or _is_delim(sk, "}") or sk.kind == CssTokenKind.Eof:
                        break
                    pos = pos + 1
                continue
            pos = pos + 1

            # Collect value tokens until `;` or `}`
            val val_start = pos
            while pos < n:
                val vt = _peek_token(tokens, pos)
                if _is_delim(vt, ";") or _is_delim(vt, "}") or vt.kind == CssTokenKind.Eof:
                    break
                pos = pos + 1
            val val_end = pos

            val imp = _is_important(tokens, val_start, val_end)
            val val_text = _collect_value_text(tokens, val_start, val_end)

            declarations.push(CssDeclaration(property: prop_text, value: val_text, important: imp))

            # consume `;` if present (leave `}` for outer loop)
            val after_val = _peek_token(tokens, pos)
            if _is_delim(after_val, ";"):
                pos = pos + 1

        rules.push(CssStyleRule(selector: sel_text, declarations: declarations))

    CssStyleSheet(rules: rules, errors: errors)
