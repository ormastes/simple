# TLS 1.3 Constants and Types — No-Alloc Baremetal
#
# Defines protocol constants, error type, and enums for the
# no-alloc TLS 1.3 client implementation.
#
# Reference: RFC 8446

# ============================================================================
# Protocol Version Constants
# ============================================================================

pub val TLS_VERSION_1_2: u16 = 0x0303   # Legacy version field in TLS 1.3 records
pub val TLS_VERSION_1_3: u16 = 0x0304   # Actual TLS 1.3 version (in supported_versions)

# ============================================================================
# Cipher Suite
# ============================================================================

pub val CIPHER_AES_128_GCM_SHA256: u16 = 0x1301   # Only supported suite

# ============================================================================
# Named Group (Key Exchange)
# ============================================================================

pub val GROUP_X25519: u16 = 0x001D   # Only supported group

# ============================================================================
# Signature Algorithm
# ============================================================================

pub val SIG_ED25519: u16    = 0x0807
pub val SIG_ECDSA_P256: u16 = 0x0403
pub val SIG_RSA_PSS: u16    = 0x0804

# ============================================================================
# Record Sizes
# ============================================================================

pub val TLS_MAX_FRAGMENT: u64     = 16384    # RFC 8446 §5.1
pub val TLS_RECORD_HEADER: u64    = 5        # 1 content-type + 2 version + 2 length
pub val AEAD_TAG_SIZE: u64        = 16       # AES-128-GCM tag size
pub val TLS_MAX_RECORD_PAYLOAD: u64 = 18432  # TLS_MAX_FRAGMENT + 256 overhead
pub val TLS_RECORD_BUFFER_SIZE: u64 = 18448  # TLS_MAX_RECORD_PAYLOAD + TLS_RECORD_HEADER + AEAD_TAG_SIZE

# ============================================================================
# Key Material Sizes
# ============================================================================

pub val KEY_SIZE_AES128: u64   = 16
pub val KEY_SIZE_IV: u64       = 12
pub val HASH_SIZE_SHA256: u64  = 32
pub val X25519_KEY_SIZE: u64   = 32

# ============================================================================
# ContentType enum (RFC 8446 §5.1)
# ============================================================================

enum ContentType:
    Invalid          # 0
    ChangeCipherSpec # 20 (0x14) — ignored in TLS 1.3
    Alert            # 21 (0x15)
    Handshake        # 22 (0x16)
    ApplicationData  # 23 (0x17)
    Unknown

fn content_type_from_byte(b: u8) -> ContentType:
    if b == 0x14:
        return ContentType.ChangeCipherSpec
    if b == 0x15:
        return ContentType.Alert
    if b == 0x16:
        return ContentType.Handshake
    if b == 0x17:
        return ContentType.ApplicationData
    if b == 0x00:
        return ContentType.Invalid
    ContentType.Unknown

fn content_type_to_byte(ct: ContentType) -> u8:
    match ct:
        ContentType.Invalid:          0x00u8
        ContentType.ChangeCipherSpec: 0x14u8
        ContentType.Alert:            0x15u8
        ContentType.Handshake:        0x16u8
        ContentType.ApplicationData:  0x17u8
        ContentType.Unknown:          0xFFu8

# ============================================================================
# HandshakeType enum (RFC 8446 §4)
# ============================================================================

enum HandshakeType:
    ClientHello          # 1
    ServerHello          # 2
    NewSessionTicket     # 4
    EncryptedExtensions  # 8
    Certificate          # 11
    CertificateVerify    # 15
    Finished             # 20
    MessageHash          # 254 (0xfe) — used in HRR transcript
    Unknown

fn handshake_type_from_byte(b: u8) -> HandshakeType:
    if b == 1:
        return HandshakeType.ClientHello
    if b == 2:
        return HandshakeType.ServerHello
    if b == 4:
        return HandshakeType.NewSessionTicket
    if b == 8:
        return HandshakeType.EncryptedExtensions
    if b == 11:
        return HandshakeType.Certificate
    if b == 15:
        return HandshakeType.CertificateVerify
    if b == 20:
        return HandshakeType.Finished
    if b == 254:
        return HandshakeType.MessageHash
    HandshakeType.Unknown

fn handshake_type_to_byte(ht: HandshakeType) -> u8:
    match ht:
        HandshakeType.ClientHello:         1u8
        HandshakeType.ServerHello:         2u8
        HandshakeType.NewSessionTicket:    4u8
        HandshakeType.EncryptedExtensions: 8u8
        HandshakeType.Certificate:         11u8
        HandshakeType.CertificateVerify:   15u8
        HandshakeType.Finished:            20u8
        HandshakeType.MessageHash:         254u8
        HandshakeType.Unknown:             0xFFu8

# ============================================================================
# AlertDescription enum (RFC 8446 §6)
# ============================================================================

enum AlertDescription:
    CloseNotify
    UnexpectedMessage
    BadRecordMac
    HandshakeFailure
    BadCertificate
    UnsupportedCertificate
    IllegalParameter
    UnknownCA
    DecodeError
    DecryptError
    ProtocolVersion
    InternalError
    Unknown

fn alert_description_from_byte(b: u8) -> AlertDescription:
    if b == 0:
        return AlertDescription.CloseNotify
    if b == 10:
        return AlertDescription.UnexpectedMessage
    if b == 20:
        return AlertDescription.BadRecordMac
    if b == 40:
        return AlertDescription.HandshakeFailure
    if b == 42:
        return AlertDescription.BadCertificate
    if b == 43:
        return AlertDescription.UnsupportedCertificate
    if b == 47:
        return AlertDescription.IllegalParameter
    if b == 48:
        return AlertDescription.UnknownCA
    if b == 50:
        return AlertDescription.DecodeError
    if b == 51:
        return AlertDescription.DecryptError
    if b == 70:
        return AlertDescription.ProtocolVersion
    if b == 80:
        return AlertDescription.InternalError
    AlertDescription.Unknown

# ============================================================================
# TLS 1.3 Client Error Type
# ============================================================================

enum TlsError:
    TransportError(msg: text)
    RecordTooLarge
    BadVersion
    UnexpectedMessage
    BadMac
    HandshakeFailure(reason: text)
    CertificateRejected
    AlertReceived(desc: AlertDescription)
    BufferFull
    Internal(msg: text)

# ============================================================================
# Extension Types
# ============================================================================

pub val EXT_SERVER_NAME: u16          = 0x0000
pub val EXT_MAX_FRAGMENT_LENGTH: u16  = 0x0001
pub val EXT_SUPPORTED_GROUPS: u16     = 0x000A
pub val EXT_SIG_ALGS: u16             = 0x000D
pub val EXT_KEY_SHARE: u16            = 0x0033
pub val EXT_SUPPORTED_VERSIONS: u16   = 0x002B
pub val EXT_PSK_KEY_EXCHANGE: u16     = 0x002D

# ============================================================================
# Handshake State Machine
# ============================================================================

enum TlsState:
    Idle
    WaitServerHello
    WaitEncryptedExtensions
    WaitCertificate
    WaitCertificateVerify
    WaitFinished
    Connected
    Closed
    Error

export AEAD_TAG_SIZE, CIPHER_AES_128_GCM_SHA256, EXT_KEY_SHARE, EXT_MAX_FRAGMENT_LENGTH, EXT_PSK_KEY_EXCHANGE, EXT_SERVER_NAME, EXT_SIG_ALGS, EXT_SUPPORTED_GROUPS, EXT_SUPPORTED_VERSIONS, GROUP_X25519, HASH_SIZE_SHA256, KEY_SIZE_AES128, KEY_SIZE_IV, SIG_ECDSA_P256, SIG_ED25519, SIG_RSA_PSS, TLS_MAX_FRAGMENT, TLS_MAX_RECORD_PAYLOAD, TLS_RECORD_BUFFER_SIZE, TLS_RECORD_HEADER, TLS_VERSION_1_2, TLS_VERSION_1_3, X25519_KEY_SIZE
