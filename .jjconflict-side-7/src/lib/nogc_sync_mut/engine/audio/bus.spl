# Audio Bus Graph — Named dB-domain bus graph (FMOD/Godot-style)
#
# Layered OVER AudioGroupTree: AudioGroupTree tracks linear Volume for playback
# routing; BusGraph tracks dB-domain bus nodes with explicit send_target
# routing that must form a DAG terminating at the master bus ("").
#
# AudioBusNode here is distinct from types.spl AudioBus (which is a
# playback-tier struct with a mixer_handle). AudioBusNode is the named-graph
# node with dB volume, send_target, and effect_ids.
#
# Usage:
#   var graph = BusGraph.new()
#   graph.add_bus("master", "", 0.0)
#   graph.add_bus("sfx", "master", -6.0)
#   graph.add_bus("reverb", "sfx", 0.0)
#   val gain = graph.effective_gain("reverb")  # ~0.5

# ============================================================================
# AudioBusNode — A dB-domain named bus in the graph
# ============================================================================

struct AudioBusNode:
    """A named audio bus node in the signal-flow graph.

    volume_db is the local gain in decibels (0.0 = unity, negative = attenuation).
    send_target is the name of the parent bus; "" means this is the master root.
    effect_ids lists opaque effect processor identifiers applied at this bus.
    muted = true zeroes this bus contribution without changing volume_db.
    """
    name: text
    volume_db: f64
    muted: bool
    send_target: text
    effect_ids: [i64]

# ============================================================================
# BusGraph — DAG of named audio buses
# ============================================================================

class BusGraph:
    """Named audio bus graph with dB-domain gain computation.

    Buses form a DAG: each bus sends to its send_target, eventually reaching
    the master bus (send_target == ""). Cycle insertion is rejected.
    effective_gain(name) walks the send_target chain and multiplies linear
    gains; a muted bus on the path returns 0.0.
    """
    buses: Dict<text, AudioBusNode>

impl BusGraph:
    static fn new() -> BusGraph:
        """Create an empty bus graph."""
        BusGraph(buses: {})

    me add_bus(name: text, send_target: text, volume_db: f64) -> bool:
        """Add a bus to the graph.

        Returns false if the name already exists or the send_target does not
        exist (unless send_target is "", the master root).
        A bus with send_target "" is a root bus (master).
        """
        if self.buses.contains_key(name):
            return false

        if send_target != "":
            if not self.buses.contains_key(send_target):
                return false

        self.buses[name] = AudioBusNode(
            name: name,
            volume_db: volume_db,
            muted: false,
            send_target: send_target,
            effect_ids: []
        )
        true

    fn get_bus(name: text) -> AudioBusNode?:
        """Return the bus node for the given name, or nil if not found."""
        if self.buses.contains_key(name):
            return self.buses[name]
        nil

    me set_volume_db(name: text, volume_db: f64) -> bool:
        """Set the dB volume of the named bus. Returns false if bus not found."""
        if self.buses.contains_key(name):
            val bus = self.buses[name]
            self.buses[name] = AudioBusNode(
                name: bus.name,
                volume_db: volume_db,
                muted: bus.muted,
                send_target: bus.send_target,
                effect_ids: bus.effect_ids
            )
            return true
        false

    me set_muted(name: text, muted: bool) -> bool:
        """Set the muted state of the named bus. Returns false if bus not found."""
        if self.buses.contains_key(name):
            val bus = self.buses[name]
            self.buses[name] = AudioBusNode(
                name: bus.name,
                volume_db: bus.volume_db,
                muted: muted,
                send_target: bus.send_target,
                effect_ids: bus.effect_ids
            )
            return true
        false

    me route(name: text, new_target: text) -> bool:
        """Set the send_target of a bus, rejecting cycles (DAG enforcement).

        Returns false if:
        - the bus or new_target do not exist (unless new_target is "")
        - the routing would create a cycle
        """
        if not self.buses.contains_key(name):
            return false

        if new_target != "":
            if not self.buses.contains_key(new_target):
                return false

        # Cycle check: walk from new_target toward root; if we reach `name`, reject.
        var cursor = new_target
        var steps = 0
        val max_steps = 128
        while cursor != "" and steps < max_steps:
            if cursor == name:
                return false
            if self.buses.contains_key(cursor):
                val parent = self.buses[cursor]
                cursor = parent.send_target
            else:
                cursor = ""
            steps = steps + 1

        val bus = self.buses[name]
        self.buses[name] = AudioBusNode(
            name: bus.name,
            volume_db: bus.volume_db,
            muted: bus.muted,
            send_target: new_target,
            effect_ids: bus.effect_ids
        )
        true

    fn effective_gain(name: text) -> f64:
        """Compute the linear gain from the named bus to the master root.

        Returns the product of db_to_linear(volume_db) for each bus on the
        send_target chain (inclusive of `name`). Any muted bus on the chain
        returns 0.0 immediately. Returns 0.0 if the bus is not found.
        """
        if not self.buses.contains_key(name):
            return 0.0

        var gain = 1.0
        var cursor = name
        var steps = 0
        val max_steps = 128

        while cursor != "" and steps < max_steps:
            if self.buses.contains_key(cursor):
                val bus = self.buses[cursor]
                if bus.muted:
                    return 0.0
                gain = gain * _db_to_linear(bus.volume_db)
                cursor = bus.send_target
            else:
                cursor = ""
            steps = steps + 1

        gain

    fn bus_count() -> i64:
        """Return the number of buses in the graph."""
        self.buses.len()

fn _db_to_linear(db: f64) -> f64:
    """Convert decibels to linear amplitude: 10^(db/20).

    Uses the identity 10^(db/20) = e^(db * ln10 / 20) = e^(db * 0.115129)
    with a range-reduced Taylor approximation for e^x.
    Accurate to better than ±0.01% for |db| ≤ 30 dB.
    """
    val exponent = db * 0.115129
    _exp_approx(exponent)

fn _exp_unit(x: f64) -> f64:
    """Degree-7 Taylor series for e^x; accurate only for |x| ≤ 1."""
    val x2 = x * x
    val x3 = x2 * x
    val x4 = x3 * x
    val x5 = x4 * x
    val x6 = x5 * x
    val x7 = x6 * x
    1.0 + x + x2 / 2.0 + x3 / 6.0 + x4 / 24.0 + x5 / 120.0 + x6 / 720.0 + x7 / 5040.0

fn _exp_approx(x: f64) -> f64:
    """Approximate e^x via range reduction: e^x = (e^(x/4))^4.

    The argument is quartered so the inner Taylor series stays in its
    accurate |x/4| ≤ 1 band even for larger dB magnitudes, then the result
    is raised back to the 4th power. Accurate to <0.001% for |x| ≤ 5.
    """
    val q = _exp_unit(x / 4.0)
    val q2 = q * q
    q2 * q2

export AudioBusNode
export BusGraph
export _db_to_linear
