# Host/GPU lane MIR queue evidence adapter.

use compiler.mir.mir_instructions.{MirConstValue, MirFunction, MirInstKind, MirOperand, MirOperandKind}
use std.gpu.engine2d.backend_lane.{
    ENGINE2D_HOST_GPU_LANE_HOST,
    ENGINE2D_HOST_GPU_LANE_GPU,
    engine2d_host_gpu_lane_schedule
}

val HOST_GPU_MIR_PACKET_BYTES_PER_INST: i64 = 64
val HOST_GPU_MIR_DEFAULT_MAX_PACKET_BYTES: i64 = 4096
val HOST_GPU_MIR_DEFAULT_OPERATION: text = "draw_ir_delta"

struct Engine2dHostGpuQueuePacket:
    sequence: i64
    source_lane: text
    target_lane: text
    operation: text
    payload_bytes: i64
    max_packet_bytes: i64
    accepted: bool

struct Engine2dHostGpuQueueTransportEvidence:
    packet_count: i64
    total_payload_bytes: i64
    max_packet_bytes: i64

struct Engine2dHostGpuQueueSubmissionEvidence:
    transport: Engine2dHostGpuQueueTransportEvidence
    submitted_to_device: bool
    readback_verified: bool
    rejected_before_submission: bool

fn engine2d_host_gpu_queue_transport_evidence(packets: [Engine2dHostGpuQueuePacket]) -> Engine2dHostGpuQueueTransportEvidence:
    var total_payload_bytes: i64 = 0
    var max_packet_bytes: i64 = 0
    for packet in packets:
        total_payload_bytes = total_payload_bytes + packet.payload_bytes
        if packet.max_packet_bytes > max_packet_bytes:
            max_packet_bytes = packet.max_packet_bytes
    Engine2dHostGpuQueueTransportEvidence(
        packet_count: packets.len(),
        total_payload_bytes: total_payload_bytes,
        max_packet_bytes: max_packet_bytes
    )

fn host_gpu_mir_max_packet_value(max_packet: MirOperand?) -> i64:
    if max_packet.?:
        val operand = max_packet.value()
        match operand.kind:
            case MirOperandKind.Const(value, _):
                match value:
                    case MirConstValue.Int(v):
                        return v
                    case _:
                        pass
            case _:
                pass
    HOST_GPU_MIR_DEFAULT_MAX_PACKET_BYTES

fn host_gpu_mir_payload_bytes(body_instruction_count: i64) -> i64:
    if body_instruction_count <= 0:
        return HOST_GPU_MIR_PACKET_BYTES_PER_INST
    body_instruction_count * HOST_GPU_MIR_PACKET_BYTES_PER_INST

fn host_gpu_mir_function_queue_packets(fn_: MirFunction, strict_backend_available: bool, baseline_ms: i64) -> [Engine2dHostGpuQueuePacket]:
    """Convert HostGpuLaneBegin/End MIR marker regions into queue packets."""
    var packets: [Engine2dHostGpuQueuePacket] = []
    var active = false
    var lane = ""
    var max_packet_bytes = HOST_GPU_MIR_DEFAULT_MAX_PACKET_BYTES
    var body_instruction_count: i64 = 0
    var sequence: i64 = 1

    for block in fn_.blocks:
        for inst in block.instructions:
            match inst.kind:
                case MirInstKind.HostGpuLaneBegin(begin_lane, max_packet):
                    active = true
                    lane = begin_lane
                    max_packet_bytes = host_gpu_mir_max_packet_value(max_packet)
                    body_instruction_count = 0
                case MirInstKind.HostGpuLaneEnd(end_lane):
                    if active:
                        val payload_bytes = host_gpu_mir_payload_bytes(body_instruction_count)
                        val lane_result = engine2d_host_gpu_lane_schedule(
                            ENGINE2D_HOST_GPU_LANE_HOST,
                            end_lane,
                            HOST_GPU_MIR_DEFAULT_OPERATION,
                            payload_bytes,
                            max_packet_bytes,
                            false,
                            false,
                            strict_backend_available,
                            baseline_ms
                        )
                        packets.push(Engine2dHostGpuQueuePacket(
                            sequence: sequence,
                            source_lane: ENGINE2D_HOST_GPU_LANE_HOST,
                            target_lane: end_lane,
                            operation: HOST_GPU_MIR_DEFAULT_OPERATION,
                            payload_bytes: payload_bytes,
                            max_packet_bytes: max_packet_bytes,
                            accepted: lane_result.ok and end_lane == ENGINE2D_HOST_GPU_LANE_GPU
                        ))
                        sequence = sequence + 1
                    active = false
                    lane = ""
                    body_instruction_count = 0
                case _:
                    if active:
                        body_instruction_count = body_instruction_count + 1

    packets

fn host_gpu_mir_function_submission_evidence(fn_: MirFunction, strict_backend_available: bool, baseline_ms: i64, device_submit_ms: i64, readback_ms: i64, readback_pixel_hash: i64, expected_pixel_hash: i64) -> Engine2dHostGpuQueueSubmissionEvidence:
    """Build queue submission/readback evidence from lowered HostGpuLane MIR markers."""
    val packets = host_gpu_mir_function_queue_packets(fn_, strict_backend_available, baseline_ms)
    val transport = engine2d_host_gpu_queue_transport_evidence(packets)
    var submitted = false
    for packet in packets:
        if packet.accepted:
            submitted = true
    Engine2dHostGpuQueueSubmissionEvidence(
        transport: transport,
        submitted_to_device: submitted,
        readback_verified: submitted and readback_pixel_hash == expected_pixel_hash,
        rejected_before_submission: packets.len() > 0 and not submitted
    )

export HOST_GPU_MIR_PACKET_BYTES_PER_INST, HOST_GPU_MIR_DEFAULT_MAX_PACKET_BYTES, HOST_GPU_MIR_DEFAULT_OPERATION
export Engine2dHostGpuQueuePacket, Engine2dHostGpuQueueTransportEvidence, Engine2dHostGpuQueueSubmissionEvidence
export host_gpu_mir_function_queue_packets, host_gpu_mir_function_submission_evidence
