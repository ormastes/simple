# FR-DRIVER-0001 synthetic registration codegen.
#
# MIR rewrite pass that injects `register_static_driver(manifest, ops)` calls
# into functions annotated with @driver(...) when the planner returns
# ReadyToSynthesize. Follows the mir_debug_trace_injection.spl pattern.

use compiler.mir.mir_instructions.{MirFunction, MirBlock, MirInst, MirInstKind, MirOperand, MirOperandKind, mir_operand_const_int}
use compiler.mir.mir_types.{MirConstValue, MirType, MirTypeKind, MirSignature}
use compiler.mir.synthetic_driver_registration.{plan_synthetic_driver_registration, SyntheticDriverRegistrationPlan, SyntheticDriverRegistrationStatus}
use compiler.hir.hir_definitions.{HirFunction}
use compiler.hir.hir_types.{SymbolTable}
use compiler.common.attributes.{DriverManifestAttr}

fn apply_synthetic_driver_codegen(fn_: HirFunction, mir_fn: MirFunction, symbols: SymbolTable) -> MirFunction:
    if not fn_.has_driver_manifest_attr:
        return mir_fn
    val plan = plan_synthetic_driver_registration(fn_, symbols)
    match plan.status:
        case ReadyToSynthesize:
            inject_register_static_driver(mir_fn, fn_.driver_manifest_attr, plan.ops_value_name)
        case _:
            mir_fn

fn inject_register_static_driver(mir_fn: MirFunction, manifest: DriverManifestAttr, ops_name: text) -> MirFunction:
    if mir_fn.blocks.len() == 0:
        return mir_fn
    val call_inst = make_register_static_driver_call(manifest, ops_name)
    val entry = mir_fn.blocks[0]
    var new_insts: [MirInst] = [call_inst]
    for inst in entry.instructions:
        new_insts.push(inst)
    val new_entry = MirBlock(
        id: entry.id,
        label: entry.label,
        instructions: new_insts,
        terminator: entry.terminator
    )
    var new_blocks: [MirBlock] = [new_entry]
    var i = 1
    while i < mir_fn.blocks.len():
        new_blocks.push(mir_fn.blocks[i])
        i = i + 1
    MirFunction(
        symbol: mir_fn.symbol,
        name: mir_fn.name,
        signature: mir_fn.signature,
        locals: mir_fn.locals,
        blocks: new_blocks,
        entry_block: mir_fn.entry_block,
        span: mir_fn.span,
        generic_params: mir_fn.generic_params,
        is_generic_template: mir_fn.is_generic_template,
        specialization_of: mir_fn.specialization_of,
        type_bindings: mir_fn.type_bindings,
        layout_phase: mir_fn.layout_phase,
        is_kernel: mir_fn.is_kernel,
        gpu_target: mir_fn.gpu_target,
        gpu_backend_order: mir_fn.gpu_backend_order,
        is_export_c: mir_fn.is_export_c,
        export_name: mir_fn.export_name,
        has_driver_manifest_attr: mir_fn.has_driver_manifest_attr,
        driver_manifest_attr: mir_fn.driver_manifest_attr,
        has_vhdl_metadata: mir_fn.has_vhdl_metadata,
        vhdl_metadata: mir_fn.vhdl_metadata,
        has_fast_math: mir_fn.has_fast_math,
        unroll_factor: mir_fn.unroll_factor,
        pipeline_ii: mir_fn.pipeline_ii,
        memory_banks: mir_fn.memory_banks
    )

fn make_register_static_driver_call(manifest: DriverManifestAttr, ops_name: text) -> MirInst:
    var manifest_fields: Dict<text, MirConstValue> = {}
    manifest_fields["driver_class"] = MirConstValue.Str(manifest.driver_class)
    manifest_fields["vendor"] = MirConstValue.Str(manifest.vendor)
    manifest_fields["version"] = MirConstValue.Str(manifest.version)
    manifest_fields["abi"] = MirConstValue.Str(manifest.abi)
    val manifest_operand = MirOperand(kind: MirOperandKind.Const(
        MirConstValue.Struct(manifest_fields),
        MirType(kind: MirTypeKind.Opaque("DriverManifest"))
    ))
    val ops_operand = MirOperand(kind: MirOperandKind.Const(
        MirConstValue.Str(ops_name),
        MirType(kind: MirTypeKind.Opaque("DriverOps"))
    ))
    val func_operand = MirOperand(kind: MirOperandKind.Const(
        MirConstValue.Str("register_static_driver"),
        MirType(kind: MirTypeKind.FuncPtr(MirSignature(
            params: [
                MirType(kind: MirTypeKind.Opaque("DriverManifest")),
                MirType(kind: MirTypeKind.Opaque("DriverOps"))
            ],
            return_type: MirType.unit(),
            is_variadic: false
        )))
    ))
    MirInst(
        kind: MirInstKind.Call(nil, func_operand, [manifest_operand, ops_operand]),
        span: nil
    )
