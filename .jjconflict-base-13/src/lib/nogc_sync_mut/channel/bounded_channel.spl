"""BoundedChannel — hardened close semantics with backpressure.

A bounded FIFO channel with explicit close signalling.
Senders receive `false` from `send` after close.
Receivers drain remaining items before observing close.
"""

# Channel states
fn chan_state_open() -> i64:
    0

fn chan_state_closed() -> i64:
    1

class BoundedChannel:
    capacity: i64
    items: [i64]
    state: i64

    fn is_closed() -> bool:
        self.state == chan_state_closed()

    fn is_full() -> bool:
        self.items.len() >= self.capacity

    fn is_empty() -> bool:
        self.items.len() == 0

    fn len() -> i64:
        self.items.len()

    # Returns true if item was accepted, false if channel closed or full
    me fn send(item: i64) -> bool:
        if self.is_closed():
            return false
        if self.is_full():
            return false
        self.items.push(item)
        true

    # Returns item or -1 if empty; -2 if closed-and-empty
    me fn recv() -> i64:
        if self.items.len() > 0:
            val item = self.items[0]
            self.items.remove(0)
            return item
        if self.is_closed():
            return -2
        -1

    # Close the channel — no more sends accepted; existing items still drainable
    me fn close():
        self.state = chan_state_closed()

fn bounded_channel_new(capacity: i64) -> BoundedChannel:
    BoundedChannel(capacity: capacity, items: [], state: chan_state_open())
