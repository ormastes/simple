# CLI Summary Formatters
#
# Shared formatting for pass/fail summaries, error/warning printing,
# and log file hints.

use std.nogc_sync_mut.io.pipe.{Stderr, Stdout}

# ANSI color codes (inline to avoid cross-module import issues)
val _RED: text = "\u{001b}[31m"
val _GREEN: text = "\u{001b}[32m"
val _YELLOW: text = "\u{001b}[33m"
val _DIM: text = "\u{001b}[2m"
val _BOLD: text = "\u{001b}[1m"
val _RESET: text = "\u{001b}[0m"

fn format_summary(passed: i64, failed: i64, warnings: i64, errors: i64, duration_ms: i64) -> text:
    var parts: [text] = []
    if passed > 0:
        parts.push("{_GREEN}{passed} passed{_RESET}")
    if failed > 0:
        parts.push("{_RED}{failed} failed{_RESET}")
    if warnings > 0:
        parts.push("{_YELLOW}{warnings} warnings{_RESET}")
    if errors > 0:
        parts.push("{_RED}{errors} errors{_RESET}")
    if parts.len() == 0:
        parts.push("0 passed")
    val counts = parts.join(", ")
    val dur = format_duration(duration_ms)
    "{counts} in {dur}"

fn format_duration(ms: i64) -> text:
    if ms < 1000:
        return "{ms}ms"
    if ms < 60000:
        val secs = ms / 1000
        val centis = (ms % 1000) / 10
        val centis_s = _pad2(centis)
        return "{secs}.{centis_s}s"
    # Minutes and seconds
    val total_secs = ms / 1000
    val mins = total_secs / 60
    val remaining_secs = total_secs % 60
    if remaining_secs == 0:
        return "{mins}m"
    "{mins}m {remaining_secs}s"

fn print_error_now(msg: text):
    var stderr = Stderr()
    stderr.write_text("{_RED}{_BOLD}error:{_RESET} {_RED}{msg}{_RESET}\n")

fn print_warning_now(msg: text, strict: bool):
    if not strict:
        return
    var stderr = Stderr()
    stderr.write_text("{_YELLOW}{_BOLD}warning:{_RESET} {_YELLOW}{msg}{_RESET}\n")

fn print_log_hint(command: text):
    var stdout = Stdout()
    stdout.write_text("{_DIM}Full log: build/log/{command}/latest.log{_RESET}\n")

# ============================================================================
# Internal Helpers
# ============================================================================

fn _pad2(n: i64) -> text:
    if n < 10:
        "0{n}"
    else:
        "{n}"
