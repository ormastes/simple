#![allow(primitive_api)]
use std.io_runtime
use std.nogc_sync_mut.spec.{describe, it, expect}
use std.nogc_sync_mut.debug.remote.target.avr.AvrTarget

fn main():
    describe("AvrTarget"):
        var target = AvrTarget.create()

        it("has 36 registers"):
            expect(target.register_count()).to_equal(36)

        it("returns r0 at index 0"):
            expect(target.register_name(0)).to_equal("r0")

        it("returns r31 at index 31"):
            expect(target.register_name(31)).to_equal("r31")

        it("returns SREG at index 32"):
            expect(target.register_name(32)).to_equal("SREG")

        it("returns SPL at index 33"):
            expect(target.register_name(33)).to_equal("SPL")

        it("returns SPH at index 34"):
            expect(target.register_name(34)).to_equal("SPH")

        it("returns PC at index 35"):
            expect(target.register_name(35)).to_equal("PC")

        it("returns 1-byte size for GP registers"):
            expect(target.register_size(0)).to_equal(1)

        it("returns 2-byte size for PC"):
            expect(target.register_size(35)).to_equal(2)

        it("has Avr architecture"):
            expect(target.arch().to_string()).to_equal("avr")

        it("has 1 hardware breakpoint"):
            expect(target.hw_breakpoint_count()).to_equal(1)

        it("has 0 hardware watchpoints"):
            expect(target.hw_watchpoint_count()).to_equal(0)

        it("has correct breakpoint instruction"):
            val t = AvrTarget.create()
            val bp = t.breakpoint_instruction()
            expect(bp.len()).to_equal(2)
            expect(bp[0]).to_equal(0x98)
            expect(bp[1]).to_equal(0x95)

        it("has PC register at index 35"):
            expect(target.pc_register_index()).to_equal(35)

        it("has SP register at index 33"):
            expect(target.sp_register_index()).to_equal(33)

        it("has FP register at index 28"):
            expect(target.fp_register_index()).to_equal(28)

        it("has return register at index 24"):
            expect(target.return_register_index()).to_equal(24)

        it("maps register name to index"):
            expect(target.register_index("r0")).to_equal(0)
            expect(target.register_index("SREG")).to_equal(32)
            expect(target.register_index("PC")).to_equal(35)

        it("returns -1 for unknown register"):
            expect(target.register_index("xmm0")).to_equal(-1)

        it("supports single step"):
            expect(target.supports_single_step()).to_equal(true)

        it("has correct arg registers"):
            val t = AvrTarget.create()
            val args = t.arg_registers()
            expect(args.len()).to_equal(4)
            expect(args[0]).to_equal(24)
            expect(args[1]).to_equal(22)
            expect(args[2]).to_equal(20)
            expect(args[3]).to_equal(18)

        it("has correct callee saved registers"):
            val t = AvrTarget.create()
            val saved = t.callee_saved_registers()
            expect(saved.len()).to_equal(18)
            expect(saved[0]).to_equal(2)
            expect(saved[17]).to_equal(29)
