# Algorithm utilities: sorting, searching, and list operations

fn is_sorted(arr: [i64]) -> bool:
    if arr.len() <= 1:
        return true
    var i = 0
    while i < arr.len() - 1:
        if arr[i] > arr[i + 1]:
            return false
        i = i + 1
    true

fn lists_equal(a: [i64], b: [i64]) -> bool:
    if a.len() != b.len():
        return false
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1
    true

fn swap(arr: [i64], i: i64, j: i64) -> [i64]:
    var result: [i64] = []
    var k = 0
    while k < arr.len():
        if k == i:
            result = result.push(arr[j])
        elif k == j:
            result = result.push(arr[i])
        else:
            result = result.push(arr[k])
        k = k + 1
    result

fn bubble_sort(arr: [i64]) -> [i64]:
    val n = arr.len()
    if n <= 1:
        return arr
    var result = arr
    var i = 0
    while i < n:
        var j = 0
        while j < n - i - 1:
            if result[j] > result[j + 1]:
                result = swap(result, j, j + 1)
            j = j + 1
        i = i + 1
    result

fn selection_sort(arr: [i64]) -> [i64]:
    val n = arr.len()
    if n <= 1:
        return arr
    var result = arr
    var i = 0
    while i < n - 1:
        var min_idx = i
        var j = i + 1
        while j < n:
            if result[j] < result[min_idx]:
                min_idx = j
            j = j + 1
        if min_idx != i:
            result = swap(result, i, min_idx)
        i = i + 1
    result

fn insertion_sort(arr: [i64]) -> [i64]:
    val n = arr.len()
    if n <= 1:
        return arr
    var result = arr
    var i = 1
    while i < n:
        var j = i
        while j > 0:
            if result[j - 1] > result[j]:
                result = swap(result, j - 1, j)
                j = j - 1
            else:
                j = 0
        i = i + 1
    result

fn quick_sort(arr: [i64]) -> [i64]:
    val n = arr.len()
    if n <= 1:
        return arr
    val pivot = arr[0]
    var less: [i64] = []
    var equal: [i64] = []
    var greater: [i64] = []
    var i = 0
    while i < n:
        val v = arr[i]
        if v < pivot:
            less = less.push(v)
        elif v == pivot:
            equal = equal.push(v)
        else:
            greater = greater.push(v)
        i = i + 1
    val sorted_less = quick_sort(less)
    val sorted_greater = quick_sort(greater)
    var result: [i64] = []
    var j = 0
    while j < sorted_less.len():
        result = result.push(sorted_less[j])
        j = j + 1
    j = 0
    while j < equal.len():
        result = result.push(equal[j])
        j = j + 1
    j = 0
    while j < sorted_greater.len():
        result = result.push(sorted_greater[j])
        j = j + 1
    result

fn _merge(left: [i64], right: [i64]) -> [i64]:
    var result: [i64] = []
    var i = 0
    var j = 0
    while i < left.len() and j < right.len():
        if left[i] <= right[j]:
            result = result.push(left[i])
            i = i + 1
        else:
            result = result.push(right[j])
            j = j + 1
    while i < left.len():
        result = result.push(left[i])
        i = i + 1
    while j < right.len():
        result = result.push(right[j])
        j = j + 1
    result

fn merge_sort(arr: [i64]) -> [i64]:
    val n = arr.len()
    if n <= 1:
        return arr
    val mid = n / 2
    var left: [i64] = []
    var right: [i64] = []
    var i = 0
    while i < mid:
        left = left.push(arr[i])
        i = i + 1
    while i < n:
        right = right.push(arr[i])
        i = i + 1
    _merge(merge_sort(left), merge_sort(right))

fn linear_search(arr: [i64], target: i64) -> i64?:
    var i = 0
    while i < arr.len():
        if arr[i] == target:
            return i
        i = i + 1
    nil

fn binary_search(arr: [i64], target: i64) -> i64?:
    var lo = 0
    var hi = arr.len() - 1
    while lo <= hi:
        val mid = (lo + hi) / 2
        if arr[mid] == target:
            return mid
        elif arr[mid] < target:
            lo = mid + 1
        else:
            hi = mid - 1
    nil

fn find_min(arr: [i64]) -> i64?:
    if arr.len() == 0:
        return nil
    var m = arr[0]
    var i = 1
    while i < arr.len():
        if arr[i] < m:
            m = arr[i]
        i = i + 1
    m

fn find_max(arr: [i64]) -> i64?:
    if arr.len() == 0:
        return nil
    var m = arr[0]
    var i = 1
    while i < arr.len():
        if arr[i] > m:
            m = arr[i]
        i = i + 1
    m

fn find_min_index(arr: [i64]) -> i64?:
    if arr.len() == 0:
        return nil
    var min_val = arr[0]
    var min_idx = 0
    var i = 1
    while i < arr.len():
        if arr[i] < min_val:
            min_val = arr[i]
            min_idx = i
        i = i + 1
    min_idx

fn find_max_index(arr: [i64]) -> i64?:
    if arr.len() == 0:
        return nil
    var max_val = arr[0]
    var max_idx = 0
    var i = 1
    while i < arr.len():
        if arr[i] > max_val:
            max_val = arr[i]
            max_idx = i
        i = i + 1
    max_idx

fn reverse_list(arr: [i64]) -> [i64]:
    var result: [i64] = []
    var i = arr.len() - 1
    while i >= 0:
        result = result.push(arr[i])
        i = i - 1
    result

fn take(arr: [i64], n: i64) -> [i64]:
    var result: [i64] = []
    var limit = n
    if n > arr.len():
        limit = arr.len()
    var i = 0
    while i < limit:
        result = result.push(arr[i])
        i = i + 1
    result

fn drop(arr: [i64], n: i64) -> [i64]:
    var result: [i64] = []
    var i = n
    if i < 0:
        i = 0
    while i < arr.len():
        result = result.push(arr[i])
        i = i + 1
    result

fn sum(arr: [i64]) -> i64:
    var total = 0
    var i = 0
    while i < arr.len():
        total = total + arr[i]
        i = i + 1
    total

fn count_occurrences(arr: [i64], target: i64) -> i64:
    var count = 0
    var i = 0
    while i < arr.len():
        if arr[i] == target:
            count = count + 1
        i = i + 1
    count

fn find_all_indices(arr: [i64], target: i64) -> [i64]:
    var result: [i64] = []
    var i = 0
    while i < arr.len():
        if arr[i] == target:
            result = result.push(i)
        i = i + 1
    result

fn _contains(arr: [i64], v: i64) -> bool:
    var i = 0
    while i < arr.len():
        if arr[i] == v:
            return true
        i = i + 1
    false

fn remove_duplicates(arr: [i64]) -> [i64]:
    var result: [i64] = []
    var i = 0
    while i < arr.len():
        val v = arr[i]
        if _contains(result, v) == false:
            result = result.push(v)
        i = i + 1
    result

fn is_prefix(prefix: [i64], arr: [i64]) -> bool:
    if prefix.len() > arr.len():
        return false
    var i = 0
    while i < prefix.len():
        if prefix[i] != arr[i]:
            return false
        i = i + 1
    true

fn is_suffix(suffix: [i64], arr: [i64]) -> bool:
    val sl = suffix.len()
    val al = arr.len()
    if sl > al:
        return false
    val offset = al - sl
    var i = 0
    while i < sl:
        if suffix[i] != arr[offset + i]:
            return false
        i = i + 1
    true

fn find_sublist(haystack: [i64], needle: [i64]) -> i64?:
    val hl = haystack.len()
    val nl = needle.len()
    if nl == 0:
        return 0
    if nl > hl:
        return nil
    var i = 0
    while i <= hl - nl:
        var j = 0
        var match = true
        while j < nl:
            if haystack[i + j] != needle[j]:
                match = false
            j = j + 1
        if match:
            return i
        i = i + 1
    nil

export is_sorted, lists_equal, swap
export bubble_sort, selection_sort, insertion_sort, quick_sort, merge_sort
export linear_search, binary_search, find_min, find_max
export find_min_index, find_max_index
export reverse_list, take, drop, sum, count_occurrences, find_all_indices
export remove_duplicates, is_prefix, is_suffix, find_sublist
