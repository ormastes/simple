# Shared bitmap evidence for WebRender and pure Simple Engine2D fixtures.

use common.ui.web_render_api.{
    WEB_RENDER_TARGET_CHROME,
    WEB_RENDER_TARGET_CHROMIUM,
    WEB_RENDER_TARGET_ELECTRON,
    WEB_RENDER_TARGET_PURE_SIMPLE,
    WEB_RENDER_TARGET_TAURI,
    WebRenderArtifact,
    WebRenderRequest,
    web_render_engine2d_compatibility_artifact,
    web_render_engine2d_rendered_artifact,
    web_render_gtk_benchmark_has_enough_samples,
    web_render_gtk_benchmark_has_enough_trials,
    web_render_gtk_benchmark_min_iterations,
    web_render_pixel_artifact
}

class WebRenderExactBitmapComparisonEvidence:
    scene_id: text
    simple_renderer: text
    baseline_renderer: text
    width: i64
    height: i64
    simple_checksum: i64
    baseline_checksum: i64
    mismatch_count: i64
    blur_or_tolerance_used: bool
    simple_frame_us: i64
    baseline_frame_us: i64
    simple_iterations: i64
    baseline_iterations: i64
    simple_trial_count: i64
    baseline_trial_count: i64
    status: text
    reason: text

    static fn create(scene_id: text, simple_renderer: text, baseline_renderer: text, width: i64, height: i64, simple_checksum: i64, baseline_checksum: i64, mismatch_count: i64, blur_or_tolerance_used: bool, simple_frame_us: i64, baseline_frame_us: i64, simple_iterations: i64, baseline_iterations: i64, simple_trial_count: i64, baseline_trial_count: i64) -> WebRenderExactBitmapComparisonEvidence:
        val reason = web_render_exact_bitmap_comparison_reason(scene_id, simple_renderer, baseline_renderer, width, height, simple_checksum, baseline_checksum, mismatch_count, blur_or_tolerance_used, simple_frame_us, baseline_frame_us, simple_iterations, baseline_iterations, simple_trial_count, baseline_trial_count)
        WebRenderExactBitmapComparisonEvidence(
            scene_id: scene_id,
            simple_renderer: simple_renderer,
            baseline_renderer: baseline_renderer,
            width: width,
            height: height,
            simple_checksum: simple_checksum,
            baseline_checksum: baseline_checksum,
            mismatch_count: mismatch_count,
            blur_or_tolerance_used: blur_or_tolerance_used,
            simple_frame_us: simple_frame_us,
            baseline_frame_us: baseline_frame_us,
            simple_iterations: simple_iterations,
            baseline_iterations: baseline_iterations,
            simple_trial_count: simple_trial_count,
            baseline_trial_count: baseline_trial_count,
            status: if reason == "pass": "pass" else: "fail",
            reason: reason
        )

    fn summary() -> text:
        "WebRenderExactBitmapComparisonEvidence[scene={self.scene_id} simple_renderer={self.simple_renderer} baseline_renderer={self.baseline_renderer} width={self.width} height={self.height} simple_checksum={self.simple_checksum} baseline_checksum={self.baseline_checksum} mismatches={self.mismatch_count} blur_or_tolerance_used={self.blur_or_tolerance_used} simple_frame_us={self.simple_frame_us} baseline_frame_us={self.baseline_frame_us} simple_iters={self.simple_iterations} baseline_iters={self.baseline_iterations} simple_trials={self.simple_trial_count} baseline_trials={self.baseline_trial_count} status={self.status} reason={self.reason}]"

fn web_render_exact_bitmap_comparison_reason(scene_id: text, simple_renderer: text, baseline_renderer: text, width: i64, height: i64, simple_checksum: i64, baseline_checksum: i64, mismatch_count: i64, blur_or_tolerance_used: bool, simple_frame_us: i64, baseline_frame_us: i64, simple_iterations: i64, baseline_iterations: i64, simple_trial_count: i64, baseline_trial_count: i64) -> text:
    if scene_id == "":
        return "missing-scene"
    if simple_renderer == "":
        return "missing-simple-renderer"
    if baseline_renderer == "":
        return "missing-baseline-renderer"
    if width <= 0 or height <= 0:
        return "missing-dimensions"
    if blur_or_tolerance_used:
        return "blur-or-tolerance-not-allowed"
    if simple_checksum <= 0 or baseline_checksum <= 0:
        return "missing-checksum"
    if simple_checksum != baseline_checksum:
        return "checksum-mismatch"
    if mismatch_count != 0:
        return "pixel-mismatch"
    if simple_iterations <= 0 or baseline_iterations <= 0:
        return "missing-iterations"
    if simple_trial_count <= 0 or baseline_trial_count <= 0:
        return "missing-trials"
    if not web_render_gtk_benchmark_has_enough_samples(simple_iterations, baseline_iterations):
        return "sample-count-too-low"
    if not web_render_gtk_benchmark_has_enough_trials(simple_trial_count, baseline_trial_count):
        return "trial-count-too-low"
    if simple_frame_us <= 0 or baseline_frame_us <= 0:
        return "missing-timings"
    if simple_frame_us > baseline_frame_us:
        return "simple-slower-than-baseline"
    "pass"

fn web_render_exact_bitmap_comparison_evidence(scene_id: text, simple_renderer: text, baseline_renderer: text, width: i64, height: i64, simple_checksum: i64, baseline_checksum: i64, mismatch_count: i64, blur_or_tolerance_used: bool, simple_frame_us: i64, baseline_frame_us: i64, simple_iterations: i64, baseline_iterations: i64, simple_trial_count: i64, baseline_trial_count: i64) -> WebRenderExactBitmapComparisonEvidence:
    WebRenderExactBitmapComparisonEvidence.create(scene_id, simple_renderer, baseline_renderer, width, height, simple_checksum, baseline_checksum, mismatch_count, blur_or_tolerance_used, simple_frame_us, baseline_frame_us, simple_iterations, baseline_iterations, simple_trial_count, baseline_trial_count)

class WebRenderNodeBitmapFixtureEvidence:
    tool_path: text
    scene_id: text
    target: text
    renderer: text
    producer: text
    engine2d_backend: text
    width: i64
    height: i64
    checksum: i64
    weighted_checksum: i64
    iterations: i64
    frame_us: i64
    pixel_format: text
    blur_or_tolerance_used: bool
    status: text
    reason: text

    static fn create(tool_path: text, scene_id: text, target: text, renderer: text, producer: text, engine2d_backend: text, width: i64, height: i64, checksum: i64, weighted_checksum: i64, iterations: i64, frame_us: i64, pixel_format: text, blur_or_tolerance_used: bool) -> WebRenderNodeBitmapFixtureEvidence:
        val reason = web_render_node_bitmap_fixture_reason(tool_path, scene_id, target, renderer, producer, engine2d_backend, width, height, checksum, weighted_checksum, iterations, frame_us, pixel_format, blur_or_tolerance_used)
        WebRenderNodeBitmapFixtureEvidence(
            tool_path: tool_path,
            scene_id: scene_id,
            target: target,
            renderer: renderer,
            producer: producer,
            engine2d_backend: engine2d_backend,
            width: width,
            height: height,
            checksum: checksum,
            weighted_checksum: weighted_checksum,
            iterations: iterations,
            frame_us: frame_us,
            pixel_format: pixel_format,
            blur_or_tolerance_used: blur_or_tolerance_used,
            status: if reason == "pass": "pass" else: "fail",
            reason: reason
        )

    fn summary() -> text:
        "WebRenderNodeBitmapFixtureEvidence[tool={self.tool_path} scene={self.scene_id} target={self.target} renderer={self.renderer} producer={self.producer} engine2d_backend={self.engine2d_backend} width={self.width} height={self.height} checksum={self.checksum} weighted_checksum={self.weighted_checksum} iterations={self.iterations} frame_us={self.frame_us} pixel_format={self.pixel_format} blur_or_tolerance_used={self.blur_or_tolerance_used} status={self.status} reason={self.reason}]"

fn web_render_node_bitmap_fixture_reason(tool_path: text, scene_id: text, target: text, renderer: text, producer: text, engine2d_backend: text, width: i64, height: i64, checksum: i64, weighted_checksum: i64, iterations: i64, frame_us: i64, pixel_format: text, blur_or_tolerance_used: bool) -> text:
    if tool_path == "":
        return "missing-tool-path"
    if scene_id == "":
        return "missing-scene"
    if target != WEB_RENDER_TARGET_PURE_SIMPLE:
        return "wrong-render-target"
    if renderer == "":
        return "missing-renderer"
    if producer == "":
        return "missing-producer"
    if engine2d_backend == "":
        return "missing-engine2d-backend"
    if width <= 0 or height <= 0:
        return "missing-dimensions"
    if checksum <= 0:
        return "missing-checksum"
    if weighted_checksum <= 0:
        return "missing-weighted-checksum"
    if iterations < web_render_gtk_benchmark_min_iterations():
        return "sample-count-too-low"
    if frame_us <= 0:
        return "missing-timing"
    if pixel_format != "argb-u32":
        return "unsupported-pixel-format"
    if blur_or_tolerance_used:
        return "blur-or-tolerance-not-allowed"
    "pass"

fn web_render_node_bitmap_fixture_evidence(tool_path: text, scene_id: text, target: text, renderer: text, producer: text, engine2d_backend: text, width: i64, height: i64, checksum: i64, weighted_checksum: i64, iterations: i64, frame_us: i64, pixel_format: text, blur_or_tolerance_used: bool) -> WebRenderNodeBitmapFixtureEvidence:
    WebRenderNodeBitmapFixtureEvidence.create(tool_path, scene_id, target, renderer, producer, engine2d_backend, width, height, checksum, weighted_checksum, iterations, frame_us, pixel_format, blur_or_tolerance_used)

fn web_render_node_bitmap_fixture_artifact_reason(req: WebRenderRequest, pixels: [u32], evidence: WebRenderNodeBitmapFixtureEvidence) -> text:
    if evidence.status != "pass":
        return evidence.reason
    if req.target != evidence.target:
        return "artifact-target-mismatch"
    if (req.viewport_w as i64) != evidence.width or (req.viewport_h as i64) != evidence.height:
        return "artifact-dimension-mismatch"
    if (pixels.len() as i64) != evidence.width * evidence.height:
        return "artifact-pixel-count-mismatch"
    "pass"

fn web_render_node_bitmap_fixture_artifact(req: WebRenderRequest, pixels: [u32], evidence: WebRenderNodeBitmapFixtureEvidence) -> WebRenderArtifact:
    val artifact = web_render_pixel_artifact(req.with_pixel_output(), pixels)
    val reason = web_render_node_bitmap_fixture_artifact_reason(req, pixels, evidence)
    if reason == "pass":
        return web_render_engine2d_rendered_artifact(artifact, evidence.engine2d_backend)
    val backend = if evidence.engine2d_backend != "": evidence.engine2d_backend else: "unknown"
    web_render_engine2d_compatibility_artifact(artifact, backend, reason)

class WebRenderTauriBitmapParityEvidence:
    scene_id: text
    target: text
    renderer: text
    producer: text
    reference_renderer: text
    width: i64
    height: i64
    checksum: i64
    reference_checksum: i64
    mismatch_count: i64
    pixel_format: text
    blur_or_tolerance_used: bool
    status: text
    reason: text

    static fn create(scene_id: text, target: text, renderer: text, producer: text, reference_renderer: text, width: i64, height: i64, checksum: i64, reference_checksum: i64, mismatch_count: i64, pixel_format: text, blur_or_tolerance_used: bool) -> WebRenderTauriBitmapParityEvidence:
        val reason = web_render_tauri_bitmap_parity_reason(scene_id, target, renderer, producer, reference_renderer, width, height, checksum, reference_checksum, mismatch_count, pixel_format, blur_or_tolerance_used)
        WebRenderTauriBitmapParityEvidence(
            scene_id: scene_id,
            target: target,
            renderer: renderer,
            producer: producer,
            reference_renderer: reference_renderer,
            width: width,
            height: height,
            checksum: checksum,
            reference_checksum: reference_checksum,
            mismatch_count: mismatch_count,
            pixel_format: pixel_format,
            blur_or_tolerance_used: blur_or_tolerance_used,
            status: if reason == "pass": "pass" else: "fail",
            reason: reason
        )

    fn summary() -> text:
        "WebRenderTauriBitmapParityEvidence[scene={self.scene_id} target={self.target} renderer={self.renderer} producer={self.producer} reference_renderer={self.reference_renderer} width={self.width} height={self.height} checksum={self.checksum} reference_checksum={self.reference_checksum} mismatches={self.mismatch_count} pixel_format={self.pixel_format} blur_or_tolerance_used={self.blur_or_tolerance_used} status={self.status} reason={self.reason}]"

fn web_render_tauri_bitmap_parity_reason(scene_id: text, target: text, renderer: text, producer: text, reference_renderer: text, width: i64, height: i64, checksum: i64, reference_checksum: i64, mismatch_count: i64, pixel_format: text, blur_or_tolerance_used: bool) -> text:
    if scene_id == "":
        return "missing-scene"
    if target != WEB_RENDER_TARGET_TAURI:
        return "wrong-render-target"
    if renderer == "":
        return "missing-renderer"
    if producer == "":
        return "missing-producer"
    if reference_renderer == "":
        return "missing-reference-renderer"
    if width <= 0 or height <= 0:
        return "missing-dimensions"
    if checksum <= 0 or reference_checksum <= 0:
        return "missing-checksum"
    if checksum != reference_checksum:
        return "checksum-mismatch"
    if mismatch_count != 0:
        return "pixel-mismatch"
    if pixel_format != "argb-u32":
        return "unsupported-pixel-format"
    if blur_or_tolerance_used:
        return "blur-or-tolerance-not-allowed"
    "pass"

fn web_render_tauri_bitmap_parity_evidence(scene_id: text, target: text, renderer: text, producer: text, reference_renderer: text, width: i64, height: i64, checksum: i64, reference_checksum: i64, mismatch_count: i64, pixel_format: text, blur_or_tolerance_used: bool) -> WebRenderTauriBitmapParityEvidence:
    WebRenderTauriBitmapParityEvidence.create(scene_id, target, renderer, producer, reference_renderer, width, height, checksum, reference_checksum, mismatch_count, pixel_format, blur_or_tolerance_used)

fn web_render_tauri_bitmap_parity_artifact_reason(req: WebRenderRequest, pixels: [u32], evidence: WebRenderTauriBitmapParityEvidence) -> text:
    if evidence.status != "pass":
        return evidence.reason
    if req.target != WEB_RENDER_TARGET_TAURI:
        return "artifact-target-mismatch"
    if req.target != evidence.target:
        return "evidence-target-mismatch"
    if (req.viewport_w as i64) != evidence.width or (req.viewport_h as i64) != evidence.height:
        return "artifact-dimension-mismatch"
    if (pixels.len() as i64) != evidence.width * evidence.height:
        return "artifact-pixel-count-mismatch"
    "pass"

fn web_render_tauri_bitmap_parity_artifact(req: WebRenderRequest, pixels: [u32], evidence: WebRenderTauriBitmapParityEvidence) -> WebRenderArtifact:
    val artifact = web_render_pixel_artifact(req.with_pixel_output(), pixels)
    val reason = web_render_tauri_bitmap_parity_artifact_reason(req, pixels, evidence)
    if reason == "pass":
        return web_render_engine2d_compatibility_artifact(artifact, evidence.reference_renderer, "tauri-shared-web-renderer-pixel-contract")
    val backend = if evidence.reference_renderer != "": evidence.reference_renderer else: "unknown"
    web_render_engine2d_compatibility_artifact(artifact, backend, reason)

class WebRenderSurfaceManifestCaptureEvidence:
    surface: text
    target: text
    renderer: text
    reference_renderer: text
    capture_status: text
    capture_reason: text
    live_capture: bool
    case_count: i64
    pass_count: i64
    fail_count: i64
    mismatch_count: i64
    blur_or_tolerance_used: bool
    status: text
    reason: text

    static fn create(surface: text, target: text, renderer: text, reference_renderer: text, capture_status: text, capture_reason: text, live_capture: bool, case_count: i64, pass_count: i64, fail_count: i64, mismatch_count: i64, blur_or_tolerance_used: bool) -> WebRenderSurfaceManifestCaptureEvidence:
        val reason = web_render_surface_manifest_capture_reason(surface, target, renderer, reference_renderer, capture_status, capture_reason, live_capture, case_count, pass_count, fail_count, mismatch_count, blur_or_tolerance_used)
        WebRenderSurfaceManifestCaptureEvidence(
            surface: surface,
            target: target,
            renderer: renderer,
            reference_renderer: reference_renderer,
            capture_status: capture_status,
            capture_reason: capture_reason,
            live_capture: live_capture,
            case_count: case_count,
            pass_count: pass_count,
            fail_count: fail_count,
            mismatch_count: mismatch_count,
            blur_or_tolerance_used: blur_or_tolerance_used,
            status: web_render_surface_manifest_capture_status_from_reason(reason),
            reason: reason
        )

    fn summary() -> text:
        "WebRenderSurfaceManifestCaptureEvidence[surface={self.surface} target={self.target} renderer={self.renderer} reference_renderer={self.reference_renderer} capture_status={self.capture_status} capture_reason={self.capture_reason} live_capture={self.live_capture.to_text()} case_count={self.case_count} pass_count={self.pass_count} fail_count={self.fail_count} mismatch_count={self.mismatch_count} blur_or_tolerance_used={self.blur_or_tolerance_used} status={self.status} reason={self.reason}]"

fn web_render_surface_manifest_capture_status_from_reason(reason: text) -> text:
    if reason == "pass":
        return "pass"
    if reason == "typed-unavailable":
        return "unavailable"
    "fail"

fn web_render_surface_manifest_capture_target_supported(target: text) -> bool:
    target == WEB_RENDER_TARGET_ELECTRON or
    target == WEB_RENDER_TARGET_TAURI or
    target == WEB_RENDER_TARGET_CHROME or
    target == WEB_RENDER_TARGET_CHROMIUM

fn web_render_surface_manifest_capture_reason(surface: text, target: text, renderer: text, reference_renderer: text, capture_status: text, capture_reason: text, live_capture: bool, case_count: i64, pass_count: i64, fail_count: i64, mismatch_count: i64, blur_or_tolerance_used: bool) -> text:
    if surface == "":
        return "missing-surface"
    if not web_render_surface_manifest_capture_target_supported(target):
        return "unsupported-target"
    if renderer == "":
        return "missing-renderer"
    if reference_renderer == "":
        return "missing-reference-renderer"
    if blur_or_tolerance_used:
        return "blur-or-tolerance-not-allowed"
    if capture_status == "pass":
        if not live_capture:
            return "pass-requires-live-capture"
        if case_count <= 0:
            return "missing-cases"
        if pass_count != case_count:
            return "case-count-mismatch"
        if fail_count != 0:
            return "case-failures"
        if mismatch_count != 0:
            return "pixel-mismatch"
        return "pass"
    if capture_status == "unavailable":
        if live_capture:
            return "unavailable-cannot-claim-live-capture"
        if capture_reason == "":
            return "missing-unavailable-reason"
        if mismatch_count != 0:
            return "unavailable-cannot-report-pixel-mismatch"
        return "typed-unavailable"
    "unsupported-capture-status"

fn web_render_surface_manifest_capture_evidence(surface: text, target: text, renderer: text, reference_renderer: text, capture_status: text, capture_reason: text, live_capture: bool, case_count: i64, pass_count: i64, fail_count: i64, mismatch_count: i64, blur_or_tolerance_used: bool) -> WebRenderSurfaceManifestCaptureEvidence:
    WebRenderSurfaceManifestCaptureEvidence.create(surface, target, renderer, reference_renderer, capture_status, capture_reason, live_capture, case_count, pass_count, fail_count, mismatch_count, blur_or_tolerance_used)
