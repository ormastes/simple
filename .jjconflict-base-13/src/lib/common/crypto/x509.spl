# X.509 DER certificate parser — Pure Simple.
#
# MDSOC: feature dimension, crypto layer.
# RFC 5280 §4 (X.509 v3 certificate structure).
#
# Parses TBSCertificate fields needed for TLS certificate validation:
#   - version, serial number
#   - signature algorithm OID
#   - issuer and subject DN (as raw DER bytes)
#   - validity (notBefore / notAfter as raw bytes)
#   - subjectPublicKeyInfo: algorithm OID + RSA modulus + exponent bytes
#   - signature bytes
#
# Uses an offset-based TLV walker (_x_read_tlv) that returns raw value
# byte-slices — NOT BerValue — because ber.spl's Integer variant truncates
# to i64 and cannot hold a 2048-bit RSA modulus.
#
# BUG(ber_integer_i64_truncates_bigint): ber.spl BerValue.Integer is i64;
# cannot represent RSA-2048 modulus. Filed 2026-06-15.
#
# tag: crypto, x509, der, certificate

# ============================================================================
# TLV walker result types
# ============================================================================

struct X509TlvOk:
    """Successful TLV parse: tag, value byte-slice, offset of next TLV."""
    tag: u8
    value: [u8]
    next_off: u64

enum X509TlvResult:
    Ok(r: X509TlvOk)
    Err(msg: text)

# ============================================================================
# Certificate structures
# ============================================================================

struct X509PublicKey:
    """RSA public key extracted from SubjectPublicKeyInfo."""
    algorithm_oid: text       # e.g. "1.2.840.113549.1.1.1" (rsaEncryption)
    modulus: [u8]             # raw big-endian modulus bytes (stripped)
    public_exponent: [u8]     # raw big-endian exponent bytes (stripped)
    spki_raw: [u8]            # full SubjectPublicKeyInfo DER bytes (for TLS)

struct X509Certificate:
    """Parsed X.509v3 certificate fields needed for TLS."""
    version: i64              # 0=v1, 1=v2, 2=v3
    serial: [u8]              # serial number bytes (stripped)
    sig_alg_oid: text         # signature algorithm OID text
    issuer_raw: [u8]          # issuer DN raw DER bytes
    not_before: [u8]          # validity notBefore raw bytes
    not_after: [u8]           # validity notAfter raw bytes
    subject_raw: [u8]         # subject DN raw DER bytes
    public_key: X509PublicKey
    signature: [u8]           # signature value bytes

enum X509ParseResult:
    Ok(cert: X509Certificate)
    Err(msg: text)

# ============================================================================
# Byte utilities
# ============================================================================

fn _x_slice(data: [u8], start: u64, length: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < length:
        out.push(data[start + i])
        i = i + 1
    out

# Strip leading 0x00 padding from DER INTEGER value bytes.
fn _x_strip_padding(bytes: [u8]) -> [u8]:
    var start: u64 = 0
    while start + 1 < bytes.len() and bytes[start] == 0x00:
        start = start + 1
    _x_slice(bytes, start, bytes.len() - start)

# Decode OID subidentifiers from raw BER content bytes -> dot-notation text.
fn _x_oid_to_text(raw: [u8]) -> text:
    if raw.len() == 0:
        return ""
    val first = raw[0].to_i64()
    val arc0 = first / 40
    val arc1 = first % 40
    var s = "{arc0}.{arc1}"
    var i: u64 = 1
    while i < raw.len():
        var acc: i64 = 0
        while i < raw.len():
            val bv = raw[i].to_i64()
            acc = (acc << 7) | (bv & 0x7F)
            i = i + 1
            if (bv & 0x80) == 0:
                break
        s = s + ".{acc}"
    s

# ============================================================================
# TLV walker: read one TLV at offset `off` inside `data`.
# Handles short form (1-byte), 0x81 (1-byte extended), 0x82 (2-byte extended),
# 0x83 (3-byte extended) length forms.
# ============================================================================

fn _x_read_tlv(data: [u8], off: u64) -> X509TlvResult:
    if off + 2 > data.len():
        return X509TlvResult.Err(msg: "tlv: truncated at {off}")
    val tag = data[off]
    val first = data[off + 1]
    var value_off: u64 = off + 2
    var length: u64 = 0
    if (first & 0x80) == 0:
        length = first.to_u64()
    elif first == 0x81:
        if off + 3 > data.len():
            return X509TlvResult.Err(msg: "tlv: truncated len(0x81)")
        length = data[off + 2].to_u64()
        value_off = off + 3
    elif first == 0x82:
        if off + 4 > data.len():
            return X509TlvResult.Err(msg: "tlv: truncated len(0x82)")
        val hi = data[off + 2].to_u64()
        val lo = data[off + 3].to_u64()
        length = (hi << 8) | lo
        value_off = off + 4
    elif first == 0x83:
        if off + 5 > data.len():
            return X509TlvResult.Err(msg: "tlv: truncated len(0x83)")
        val b2 = data[off + 2].to_u64()
        val b3 = data[off + 3].to_u64()
        val b4 = data[off + 4].to_u64()
        length = (b2 << 16) | (b3 << 8) | b4
        value_off = off + 5
    else:
        return X509TlvResult.Err(msg: "tlv: unsupported length form {first}")
    if value_off + length > data.len():
        return X509TlvResult.Err(msg: "tlv: value extends past buffer")
    val value_bytes = _x_slice(data, value_off, length)
    X509TlvResult.Ok(r: X509TlvOk(
        tag: tag,
        value: value_bytes,
        next_off: value_off + length
    ))

fn _x_expect_tag(data: [u8], off: u64, want: u8, label: text) -> X509TlvResult:
    val r = _x_read_tlv(data, off)
    if val X509TlvResult.Ok(tlv) = r:
        if tlv.tag == want:
            return X509TlvResult.Ok(r: tlv)
        return X509TlvResult.Err(msg: "{label}: tag {tlv.tag} != {want}")
    r

# ============================================================================
# SPKI parser: SubjectPublicKeyInfo -> RSA modulus + exponent
#
# Layout inside spki_bytes (the outer SEQUENCE value):
#   off=0: AlgorithmIdentifier SEQUENCE
#          off=0: OID
#          off=next: NULL (or params)
#   off=alg_next: BITSTRING
#          byte 0: unused-bits count (always 0)
#          bytes 1..: RSAPublicKey SEQUENCE
#                     off=0: INTEGER modulus
#                     off=next: INTEGER exponent
# ============================================================================

fn _x_parse_spki(spki_bytes: [u8]) -> X509ParseResult:
    # Step 1: outer SEQUENCE
    val outer_r = _x_expect_tag(spki_bytes, 0, 0x30, "spki outer SEQUENCE")
    if val X509TlvResult.Err(msg) = outer_r:
        return X509ParseResult.Err(msg: msg)
    # outer_tlv.value = the contents of the outer SEQUENCE
    if val X509TlvResult.Ok(outer_tlv) = outer_r:
        val oseq = outer_tlv.value

        # Step 2: AlgorithmIdentifier SEQUENCE (first item in oseq)
        val alg_r = _x_expect_tag(oseq, 0, 0x30, "spki alg SEQUENCE")
        if val X509TlvResult.Err(msg) = alg_r:
            return X509ParseResult.Err(msg: msg)
        if val X509TlvResult.Ok(alg_tlv) = alg_r:
            # Step 3: OID inside AlgorithmIdentifier
            val oid_r = _x_expect_tag(alg_tlv.value, 0, 0x06, "spki oid")
            var oid_text = ""
            if val X509TlvResult.Ok(oid_tlv) = oid_r:
                oid_text = _x_oid_to_text(oid_tlv.value)

            # Step 4: BITSTRING (at alg_tlv.next_off within oseq)
            val bs_r = _x_expect_tag(oseq, alg_tlv.next_off, 0x03, "spki bitstring")
            if val X509TlvResult.Err(msg) = bs_r:
                return X509ParseResult.Err(msg: msg)
            if val X509TlvResult.Ok(bs_tlv) = bs_r:
                if bs_tlv.value.len() < 2:
                    return X509ParseResult.Err(msg: "spki: BITSTRING too short")
                # Skip unused-bits byte
                val inner_key = _x_slice(bs_tlv.value, 1, bs_tlv.value.len() - 1)

                # Step 5: RSAPublicKey SEQUENCE
                val rsa_r = _x_expect_tag(inner_key, 0, 0x30, "RSAPublicKey SEQUENCE")
                if val X509TlvResult.Err(msg) = rsa_r:
                    return X509ParseResult.Err(msg: msg)
                if val X509TlvResult.Ok(rsa_tlv) = rsa_r:
                    val rk = rsa_tlv.value

                    # Step 6: modulus INTEGER
                    val mod_r = _x_expect_tag(rk, 0, 0x02, "RSA modulus")
                    if val X509TlvResult.Err(msg) = mod_r:
                        return X509ParseResult.Err(msg: msg)
                    if val X509TlvResult.Ok(mod_tlv) = mod_r:
                        val modulus = _x_strip_padding(mod_tlv.value)

                        # Step 7: exponent INTEGER
                        val exp_r = _x_expect_tag(rk, mod_tlv.next_off, 0x02, "RSA exponent")
                        if val X509TlvResult.Err(msg) = exp_r:
                            return X509ParseResult.Err(msg: msg)
                        if val X509TlvResult.Ok(exp_tlv) = exp_r:
                            val exponent = _x_strip_padding(exp_tlv.value)
                            return X509ParseResult.Ok(cert: X509Certificate(
                                version: 0,
                                serial: [],
                                sig_alg_oid: "",
                                issuer_raw: [],
                                not_before: [],
                                not_after: [],
                                subject_raw: [],
                                public_key: X509PublicKey(
                                    algorithm_oid: oid_text,
                                    modulus: modulus,
                                    public_exponent: exponent,
                                    spki_raw: spki_bytes
                                ),
                                signature: []
                            ))
    X509ParseResult.Err(msg: "spki: parse failed")

# ============================================================================
# Full certificate parser
#
# Certificate  ::=  SEQUENCE {
#   tbsCertificate      TBSCertificate,
#   signatureAlgorithm  AlgorithmIdentifier,
#   signatureValue      BIT STRING
# }
# TBSCertificate  ::=  SEQUENCE {
#   version         [0] EXPLICIT INTEGER OPTIONAL
#   serialNumber    INTEGER,
#   signature       AlgorithmIdentifier,
#   issuer          Name,
#   validity        Validity,
#   subject         Name,
#   subjectPublicKeyInfo SubjectPublicKeyInfo,
#   ...optional extensions...
# }
# ============================================================================

fn x509_parse_der(der: [u8]) -> X509ParseResult:
    # Outer Certificate SEQUENCE
    val cert_r = _x_expect_tag(der, 0, 0x30, "Certificate SEQUENCE")
    if val X509TlvResult.Err(msg) = cert_r:
        return X509ParseResult.Err(msg: msg)
    if val X509TlvResult.Ok(cert_tlv) = cert_r:
        val cert_val = cert_tlv.value

        # TBSCertificate SEQUENCE (first item in cert_val)
        val tbs_r = _x_expect_tag(cert_val, 0, 0x30, "TBSCertificate SEQUENCE")
        if val X509TlvResult.Err(msg) = tbs_r:
            return X509ParseResult.Err(msg: msg)
        if val X509TlvResult.Ok(tbs_tlv) = tbs_r:
            val tbs = tbs_tlv.value
            var pos: u64 = 0

            # version [0] EXPLICIT INTEGER OPTIONAL (tag 0xA0)
            var version: i64 = 0
            val ft_r = _x_read_tlv(tbs, pos)
            if val X509TlvResult.Ok(ft) = ft_r:
                if ft.tag == 0xA0:
                    val vi_r = _x_expect_tag(ft.value, 0, 0x02, "version INTEGER")
                    if val X509TlvResult.Ok(vi) = vi_r:
                        if vi.value.len() > 0:
                            version = vi.value[0].to_i64()
                    pos = ft.next_off

            # serialNumber INTEGER
            val ser_r = _x_expect_tag(tbs, pos, 0x02, "serialNumber")
            if val X509TlvResult.Err(msg) = ser_r:
                return X509ParseResult.Err(msg: msg)
            var serial_bytes: [u8] = []
            if val X509TlvResult.Ok(ser_tlv) = ser_r:
                serial_bytes = _x_strip_padding(ser_tlv.value)
                pos = ser_tlv.next_off

            # signature AlgorithmIdentifier SEQUENCE
            val sa_r = _x_expect_tag(tbs, pos, 0x30, "signature AlgId")
            if val X509TlvResult.Err(msg) = sa_r:
                return X509ParseResult.Err(msg: msg)
            var sig_alg_oid = ""
            if val X509TlvResult.Ok(sa_tlv) = sa_r:
                val oid_r = _x_expect_tag(sa_tlv.value, 0, 0x06, "sig alg OID")
                if val X509TlvResult.Ok(oid_tlv) = oid_r:
                    sig_alg_oid = _x_oid_to_text(oid_tlv.value)
                pos = sa_tlv.next_off

            # issuer Name SEQUENCE
            val iss_r = _x_expect_tag(tbs, pos, 0x30, "issuer")
            if val X509TlvResult.Err(msg) = iss_r:
                return X509ParseResult.Err(msg: msg)
            var issuer_raw: [u8] = []
            if val X509TlvResult.Ok(iss_tlv) = iss_r:
                issuer_raw = _x_slice(tbs, pos, iss_tlv.next_off - pos)
                pos = iss_tlv.next_off

            # validity SEQUENCE
            val val_r = _x_expect_tag(tbs, pos, 0x30, "validity")
            if val X509TlvResult.Err(msg) = val_r:
                return X509ParseResult.Err(msg: msg)
            var not_before: [u8] = []
            var not_after: [u8] = []
            if val X509TlvResult.Ok(val_tlv) = val_r:
                val nb_r = _x_read_tlv(val_tlv.value, 0)
                if val X509TlvResult.Ok(nb_tlv) = nb_r:
                    not_before = nb_tlv.value
                    val na_r = _x_read_tlv(val_tlv.value, nb_tlv.next_off)
                    if val X509TlvResult.Ok(na_tlv) = na_r:
                        not_after = na_tlv.value
                pos = val_tlv.next_off

            # subject Name SEQUENCE
            val subj_r = _x_expect_tag(tbs, pos, 0x30, "subject")
            if val X509TlvResult.Err(msg) = subj_r:
                return X509ParseResult.Err(msg: msg)
            var subject_raw: [u8] = []
            if val X509TlvResult.Ok(subj_tlv) = subj_r:
                subject_raw = _x_slice(tbs, pos, subj_tlv.next_off - pos)
                pos = subj_tlv.next_off

            # subjectPublicKeyInfo SEQUENCE
            val spki_r = _x_expect_tag(tbs, pos, 0x30, "subjectPublicKeyInfo")
            if val X509TlvResult.Err(msg) = spki_r:
                return X509ParseResult.Err(msg: msg)
            var pub_key = X509PublicKey(
                algorithm_oid: "",
                modulus: [],
                public_exponent: [],
                spki_raw: []
            )
            var spki_ok = false
            if val X509TlvResult.Ok(spki_seq) = spki_r:
                val spki_bytes = _x_slice(tbs, pos, spki_seq.next_off - pos)
                val pk_r = _x_parse_spki(spki_bytes)
                if val X509ParseResult.Ok(pk_cert) = pk_r:
                    pub_key = pk_cert.public_key
                    spki_ok = true
                pos = spki_seq.next_off

            if not spki_ok:
                return X509ParseResult.Err(msg: "x509: SPKI parse failed")

            # signatureAlgorithm + signatureValue are in cert_val AFTER TBSCertificate
            val outer_after_tbs = tbs_tlv.next_off

            # outer signatureAlgorithm SEQUENCE
            var sig_bytes: [u8] = []
            val osa_r = _x_expect_tag(cert_val, outer_after_tbs, 0x30, "outer sigAlg")
            if val X509TlvResult.Ok(osa_tlv) = osa_r:
                # signatureValue BITSTRING
                val sv_r = _x_expect_tag(cert_val, osa_tlv.next_off, 0x03, "signatureValue")
                if val X509TlvResult.Ok(sv_tlv) = sv_r:
                    if sv_tlv.value.len() > 1:
                        sig_bytes = _x_slice(sv_tlv.value, 1, sv_tlv.value.len() - 1)

            return X509ParseResult.Ok(cert: X509Certificate(
                version: version,
                serial: serial_bytes,
                sig_alg_oid: sig_alg_oid,
                issuer_raw: issuer_raw,
                not_before: not_before,
                not_after: not_after,
                subject_raw: subject_raw,
                public_key: pub_key,
                signature: sig_bytes
            ))
    X509ParseResult.Err(msg: "x509_parse_der: outer parse failed")

# Parse a SubjectPublicKeyInfo DER blob directly (no full certificate wrapper).
fn x509_parse_spki(spki_der: [u8]) -> X509ParseResult:
    _x_parse_spki(spki_der)

export x509_parse_der, x509_parse_spki
export X509Certificate, X509PublicKey, X509ParseResult, X509TlvResult, X509TlvOk
