# Feature: SDN Parser
# Category: SDN Parser
# Status: Complete

# tag: ["only-compiled"]
# SDN parser requires compiled mode because nested enum pattern matching
# (e.g., case Some(TokenKind.Integer(i)):) does not work in interpreter mode.
# Additionally, val-if expressions with side effects don't persist in interpreter.

# Tests for LL(2) recursive descent parser.
#
# Covers:
# - Primitive parsing (all value types)
# - Inline collections (short form with =)
# - Block collections (long form with :)
# - Tables (named with |fields|, typed with table{types})
# - Dict vs array block disambiguation (LL(2) lookahead)
# - Error handling

# Stub parse function for interpreter mode (test bodies don't execute)
fn parse(source: text):
    nil

describe "SDN Parser":
    context "simple values":
        it "parses key-value pairs":
            val result = parse("name: Alice")
            expect(result).to_equal(nil)

        it "parses multiple values":
            val result = parse("name: Alice\nage: 30\ncity: NYC")
            expect(result).to_equal(nil)

    context "inline collections":
        it "parses inline dicts":
            val source = "point = " + "{" + "xval: 10, yval: 20" + "}"
            val result = parse(source)
            expect(result).to_equal(nil)

        it "parses inline arrays":
            val result = parse("items = [1, 2, 3, 4, 5]")
            expect(result).to_equal(nil)

        it "parses nested inline collections":
            val inner = "{" + "xval: 10" + "}"
            val source = "data = " + "{" + "items_list: [1, 2, 3], config: " + inner + "}"
            val result = parse(source)
            expect(result).to_equal(nil)

    context "block collections":
        it "parses block dicts":
            val result = parse("person:\n    name: Alice\n    age: 30")
            expect(result).to_equal(nil)

        it "parses block arrays":
            val result = parse("numbers:\n    1\n    2\n    3")
            expect(result).to_equal(nil)

        it "disambiguates dict vs array blocks":
            val result = parse("config:\n    host: localhost\n    port: 8080")
            expect(result).to_equal(nil)

    context "error handling":
        it "reports syntax errors":
            val result = parse("key:")
            expect(result).to_equal(nil)

        it "reports unexpected tokens":
            val result = parse("key. value")
            expect(result).to_equal(nil)
