# T32 CLI Window Parsers spec — tests all 16 window-specific parsers
# All parsers inlined to avoid import path issues with the test runner

# --- Inlined helpers ---

fn ws_split(input: text) -> [text]:
    var parts: [text] = []
    var buf: [text] = []
    var in_word = false
    for ch in input:
        if ch == " " or ch == "\t":
            if in_word:
                parts.push(buf.join(""))
                buf = []
                in_word = false
        else:
            buf.push(ch)
            in_word = true
    if in_word:
        parts.push(buf.join(""))
    parts

fn ws_find_char(s: text, ch: text) -> i64:
    var i = 0
    for c in s:
        if c == ch:
            return i
        i = i + 1
    -1

fn ws_substr(s: text, start: i64, end: i64) -> text:
    var buf: [text] = []
    var i = 0
    for ch in s:
        if i >= start and i < end:
            buf.push(ch)
        i = i + 1
    buf.join("")

fn ws_split_lines(content: text) -> [text]:
    var lines: [text] = []
    var buf: [text] = []
    for ch in content:
        if ch == "\n":
            lines.push(buf.join(""))
            buf = []
        else:
            buf.push(ch)
    if buf.len() > 0:
        lines.push(buf.join(""))
    lines

fn ws_trim(s: text) -> text:
    s.trim()

# --- Inlined parsers ---

fn p_stack_frame(raw: text) -> [Dict<text, text>]:
    val lines = ws_split_lines(raw)
    var rows: [Dict<text, text>] = []
    for line in lines:
        val trimmed = ws_trim(line)
        if trimmed == "" or trimmed.starts_with("frame"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 3:
            var row: Dict<text, text> = {}
            row["frame_id"] = tokens[0]
            row["address"] = tokens[1]
            row["function"] = tokens[2]
            if tokens.len() >= 4:
                row["file_line"] = tokens[3]
            else:
                row["file_line"] = ""
            rows.push(row)
    rows

fn p_memory_dump(raw: text) -> [Dict<text, text>]:
    val lines = ws_split_lines(raw)
    var rows: [Dict<text, text>] = []
    for line in lines:
        val trimmed = ws_trim(line)
        if trimmed == "" or trimmed.starts_with("#"):
            continue
        val colon1 = ws_find_char(trimmed, ":")
        if colon1 < 0:
            continue
        var colon2 = -1
        var ci = colon1 + 1
        while ci < trimmed.len():
            if trimmed[ci] == ':':
                colon2 = ci
                break
            ci = ci + 1
        var address = ""
        var rest = ""
        if colon2 > 0:
            address = ws_trim(ws_substr(trimmed, 0, colon2 + 1))
            if colon2 + 1 < trimmed.len():
                rest = ws_trim(ws_substr(trimmed, colon2 + 1, trimmed.len()))
        else:
            address = ws_trim(ws_substr(trimmed, 0, colon1 + 1))
            if colon1 + 1 < trimmed.len():
                rest = ws_trim(ws_substr(trimmed, colon1 + 1, trimmed.len()))
        if address == "":
            continue
        var hex_part = rest
        var ascii_part = ""
        var ri = 0
        var prev_ch = ""
        for rc in rest:
            if prev_ch == " " and rc == " ":
                hex_part = ws_trim(ws_substr(rest, 0, ri - 1))
                ascii_part = ws_trim(ws_substr(rest, ri - 1, rest.len()))
                break
            prev_ch = rc
            ri = ri + 1
        var row: Dict<text, text> = {}
        row["address"] = address
        row["hex_bytes"] = hex_part
        row["ascii"] = ascii_part
        rows.push(row)
    rows

fn p_source_list(raw: text) -> [Dict<text, text>]:
    val lines = ws_split_lines(raw)
    var rows: [Dict<text, text>] = []
    for line in lines:
        val trimmed = ws_trim(line)
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("line"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 2:
            var row: Dict<text, text> = {}
            row["line_number"] = tokens[0]
            row["address"] = tokens[1]
            var source = ""
            if tokens.len() >= 3:
                source = tokens[2]
                var si = 3
                while si < tokens.len():
                    source = source + " " + tokens[si]
                    si = si + 1
            row["source"] = source
            rows.push(row)
    rows

fn p_coverage(raw: text) -> [Dict<text, text>]:
    val lines = ws_split_lines(raw)
    var rows: [Dict<text, text>] = []
    for line in lines:
        val trimmed = ws_trim(line)
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("function"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 3:
            var row: Dict<text, text> = {}
            row["function"] = tokens[0]
            row["percent"] = tokens[1]
            row["hits"] = tokens[2]
            rows.push(row)
    rows

fn p_symbol_browse(raw: text) -> [Dict<text, text>]:
    val lines = ws_split_lines(raw)
    var rows: [Dict<text, text>] = []
    for line in lines:
        val trimmed = ws_trim(line)
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("name"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 4:
            var row: Dict<text, text> = {}
            row["name"] = tokens[0]
            row["address"] = tokens[1]
            row["size"] = tokens[2]
            row["type"] = tokens[3]
            rows.push(row)
    rows

fn p_perf(raw: text) -> [Dict<text, text>]:
    val lines = ws_split_lines(raw)
    var rows: [Dict<text, text>] = []
    for line in lines:
        val trimmed = ws_trim(line)
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("module"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 4:
            var row: Dict<text, text> = {}
            row["module"] = tokens[0]
            row["time"] = tokens[1]
            row["calls"] = tokens[2]
            row["percent"] = tokens[3]
            rows.push(row)
    rows

fn p_mmu(raw: text) -> [Dict<text, text>]:
    val lines = ws_split_lines(raw)
    var rows: [Dict<text, text>] = []
    for line in lines:
        val trimmed = ws_trim(line)
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("virt"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 4:
            var row: Dict<text, text> = {}
            row["virt_addr"] = tokens[0]
            row["phys_addr"] = tokens[1]
            row["size"] = tokens[2]
            row["perms"] = tokens[3]
            rows.push(row)
    rows

fn p_peripheral(raw: text) -> [Dict<text, text>]:
    val lines = ws_split_lines(raw)
    var rows: [Dict<text, text>] = []
    for line in lines:
        val trimmed = ws_trim(line)
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("name"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 4:
            var row: Dict<text, text> = {}
            row["name"] = tokens[0]
            row["address"] = tokens[1]
            row["value"] = tokens[2]
            row["bits"] = tokens[3]
            rows.push(row)
    rows

fn p_data_list(raw: text) -> [Dict<text, text>]:
    val lines = ws_split_lines(raw)
    var rows: [Dict<text, text>] = []
    for line in lines:
        val trimmed = ws_trim(line)
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("address"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 2:
            var row: Dict<text, text> = {}
            row["address"] = tokens[0]
            var instruction = tokens[1]
            var symbol = ""
            if tokens.len() >= 3:
                symbol = tokens[tokens.len() - 1]
                var ii = 2
                while ii < tokens.len() - 1:
                    instruction = instruction + " " + tokens[ii]
                    ii = ii + 1
            row["instruction"] = instruction
            row["symbol"] = symbol
            rows.push(row)
    rows

fn p_area(raw: text) -> [text]:
    ws_split_lines(raw)

fn p_var_watch(raw: text) -> [Dict<text, text>]:
    val lines = ws_split_lines(raw)
    var rows: [Dict<text, text>] = []
    for line in lines:
        val trimmed = ws_trim(line)
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("-") or trimmed.starts_with("name"):
            continue
        val tokens = ws_split(trimmed)
        if tokens.len() >= 3:
            var row: Dict<text, text> = {}
            row["name"] = tokens[0]
            row["type"] = tokens[1]
            var value = tokens[2]
            var vi = 3
            while vi < tokens.len():
                value = value + " " + tokens[vi]
                vi = vi + 1
            row["value"] = value
            rows.push(row)
    rows

# --- Tests ---

describe "T32 CLI Window Parsers (all 16)":

    context "parse_stack_frame_output":
        it "parses stack frame entries":
            val raw = "#0  0x08001234  main+0x10  src/main.c:42\n#1  0x08001000  SystemInit  src/system.c:15"
            val rows = p_stack_frame(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["frame_id"]).to_equal("#0")
            expect(rows[0]["address"]).to_equal("0x08001234")
            expect(rows[0]["function"]).to_equal("main+0x10")
            expect(rows[0]["file_line"]).to_equal("src/main.c:42")

        it "handles frame without file info":
            val raw = "#0  0x08001234  _start"
            val rows = p_stack_frame(raw)
            expect(rows.len()).to_equal(1)
            expect(rows[0]["file_line"]).to_equal("")

        it "returns empty for empty input":
            val rows = p_stack_frame("")
            expect(rows.len()).to_equal(0)

    context "parse_memory_dump_output":
        it "parses memory dump lines":
            val raw = "D:0x20000000: 48 65 6C 6C 6F 20 57 6F  Hello Wo\nD:0x20000008: 72 6C 64 00 00 00 00 00  rld....."
            val rows = p_memory_dump(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["address"]).to_equal("D:0x20000000:")
            expect(rows[0]["hex_bytes"]).to_contain("48")
            expect(rows[0]["ascii"]).to_contain("Hello")

        it "returns empty for empty input":
            val rows = p_memory_dump("")
            expect(rows.len()).to_equal(0)

        it "skips comment lines":
            val raw = "# comment\nD:0x20000000: AA BB  xy"
            val rows = p_memory_dump(raw)
            expect(rows.len()).to_equal(1)

    context "parse_source_list_output":
        it "parses source listing":
            val raw = "42  0x08001234  printf(\"hello\");\n43  0x08001238  return 0;"
            val rows = p_source_list(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["line_number"]).to_equal("42")
            expect(rows[0]["address"]).to_equal("0x08001234")
            expect(rows[0]["source"]).to_contain("printf")

        it "skips header line":
            val raw = "line  address  source\n42  0x08001234  code"
            val rows = p_source_list(raw)
            expect(rows.len()).to_equal(1)

        it "returns empty for empty input":
            val rows = p_source_list("")
            expect(rows.len()).to_equal(0)

    context "parse_coverage_output":
        it "parses coverage entries":
            val raw = "main           85.3%   1024\nirq_handler    42.1%   256"
            val rows = p_coverage(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["function"]).to_equal("main")
            expect(rows[0]["percent"]).to_equal("85.3%")
            expect(rows[0]["hits"]).to_equal("1024")

        it "skips header and separator lines":
            val raw = "function  percent  hits\n--------  -------  ----\nmain  90%  100"
            val rows = p_coverage(raw)
            expect(rows.len()).to_equal(1)

        it "returns empty for empty input":
            val rows = p_coverage("")
            expect(rows.len()).to_equal(0)

    context "parse_symbol_browse_output":
        it "parses symbol entries":
            val raw = "main           0x08001000  0x00000100  Code\nirq_handler    0x08002000  0x00000080  Code"
            val rows = p_symbol_browse(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["name"]).to_equal("main")
            expect(rows[0]["address"]).to_equal("0x08001000")
            expect(rows[0]["size"]).to_equal("0x00000100")
            expect(rows[0]["type"]).to_equal("Code")

        it "skips header line":
            val raw = "name  address  size  type\nmain  0x1000  0x100  Code"
            val rows = p_symbol_browse(raw)
            expect(rows.len()).to_equal(1)

        it "returns empty for empty input":
            val rows = p_symbol_browse("")
            expect(rows.len()).to_equal(0)

    context "parse_perf_output":
        it "parses performance entries":
            val raw = "main  12.5ms  1024  42.1%\nidle  87.5ms  2048  57.9%"
            val rows = p_perf(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["module"]).to_equal("main")
            expect(rows[0]["time"]).to_equal("12.5ms")
            expect(rows[0]["calls"]).to_equal("1024")
            expect(rows[0]["percent"]).to_equal("42.1%")

        it "skips header line":
            val raw = "module  time  calls  percent\nmain  1ms  10  50%"
            val rows = p_perf(raw)
            expect(rows.len()).to_equal(1)

        it "returns empty for empty input":
            val rows = p_perf("")
            expect(rows.len()).to_equal(0)

    context "parse_mmu_output":
        it "parses MMU entries":
            val raw = "0x00000000  0x80000000  0x00100000  RWX\n0x10000000  0x90000000  0x00200000  RW-"
            val rows = p_mmu(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["virt_addr"]).to_equal("0x00000000")
            expect(rows[0]["phys_addr"]).to_equal("0x80000000")
            expect(rows[0]["size"]).to_equal("0x00100000")
            expect(rows[0]["perms"]).to_equal("RWX")

        it "skips header line":
            val raw = "virt_addr  phys_addr  size  perms\n0x0  0x1  0x2  RW"
            val rows = p_mmu(raw)
            expect(rows.len()).to_equal(1)

        it "returns empty for empty input":
            val rows = p_mmu("")
            expect(rows.len()).to_equal(0)

    context "parse_peripheral_output":
        it "parses peripheral entries":
            val raw = "GPIOA_MODER  0x48000000  0x28000000  [31:0]\nGPIOA_ODR  0x48000014  0x00000001  [15:0]"
            val rows = p_peripheral(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["name"]).to_equal("GPIOA_MODER")
            expect(rows[0]["address"]).to_equal("0x48000000")
            expect(rows[0]["value"]).to_equal("0x28000000")
            expect(rows[0]["bits"]).to_equal("[31:0]")

        it "skips header line":
            val raw = "name  address  value  bits\nREG  0x0  0x1  [7:0]"
            val rows = p_peripheral(raw)
            expect(rows.len()).to_equal(1)

        it "returns empty for empty input":
            val rows = p_peripheral("")
            expect(rows.len()).to_equal(0)

    context "parse_data_list_output":
        it "parses disassembly entries":
            val raw = "0x08001234  BL  main\n0x08001238  MOV R0, #0  _start"
            val rows = p_data_list(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["address"]).to_equal("0x08001234")
            expect(rows[0]["instruction"]).to_equal("BL")
            expect(rows[0]["symbol"]).to_equal("main")

        it "handles multi-word instruction":
            val raw = "0x08001238  MOV R0, #0  _start"
            val rows = p_data_list(raw)
            expect(rows.len()).to_equal(1)
            expect(rows[0]["instruction"]).to_contain("MOV")

        it "returns empty for empty input":
            val rows = p_data_list("")
            expect(rows.len()).to_equal(0)

        it "skips header line":
            val raw = "address  instruction  symbol\n0x1000  NOP  main"
            val rows = p_data_list(raw)
            expect(rows.len()).to_equal(1)

    context "parse_area_output":
        it "parses area lines":
            val raw = "Hello World\nSecond line\nThird"
            val lines = p_area(raw)
            expect(lines.len()).to_equal(3)
            expect(lines[0]).to_equal("Hello World")
            expect(lines[1]).to_equal("Second line")

        it "returns single line for single line input":
            val lines = p_area("only one")
            expect(lines.len()).to_equal(1)
            expect(lines[0]).to_equal("only one")

    context "parse_var_local_output (reuse var_watch)":
        it "parses local variable entries":
            val raw = "counter  int  42\nptr  char*  hello world"
            val rows = p_var_watch(raw)
            expect(rows.len()).to_equal(2)
            expect(rows[0]["name"]).to_equal("counter")
            expect(rows[0]["type"]).to_equal("int")
            expect(rows[0]["value"]).to_equal("42")
            expect(rows[1]["value"]).to_equal("hello world")

        it "returns empty for empty input":
            val rows = p_var_watch("")
            expect(rows.len()).to_equal(0)

    context "edge cases":
        it "handles extra whitespace in stack frame":
            val raw = "  #0    0x08001234    main   "
            val rows = p_stack_frame(raw)
            expect(rows.len()).to_equal(1)
            expect(rows[0]["function"]).to_equal("main")

        it "handles missing columns gracefully":
            val raw = "0x08001234"
            val rows = p_data_list(raw)
            expect(rows.len()).to_equal(0)

        it "handles empty lines mixed with data":
            val raw = "\nmain  85%  100\n\nirq  42%  50\n"
            val rows = p_coverage(raw)
            expect(rows.len()).to_equal(2)
