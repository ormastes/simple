use std.spec
use std.scv.pack.{scv_pack_bytes_line}

describe "scv pack byte text conversion":
    it "decodes pack header lines without text.from_bytes":
        val payload = [101u8, 110u8, 116u8, 114u8, 121u8, 32u8, 102u8, 105u8, 108u8, 101u8, 115u8, 32u8, 105u8, 100u8, 32u8, 51u8, 13u8, 9u8, 255u8, 10u8]
        val (line, end) = scv_pack_bytes_line(payload, 0)
        expect(line).to_equal("entry files id 3\r\t?")
        expect(end).to_equal(19)
