use std.spec.*

use std.gc_async_mut.gpu.browser_engine.paint.{paint_scrollbar, PaintCommand}

fn approx_i32(a: i32, b: i32) -> bool:
    val diff = a - b
    val abs_diff = if diff < 0: diff * (-1) else: diff
    abs_diff < 4

describe "WPT-derived CSS scrollbar subset":

    context "CSS scrollbar pure function coverage":

        it "scrollbar renders track when content overflows":
            val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 800.0, 0.0)
            expect(cmds.len() >= 1).to_equal(true)

        it "scrollbar thumb proportional to viewport content ratio":
            # height=400, content_height=800, ratio=0.5, thumb_h = 400 * 0.5 = 200 (above 16 floor)
            val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 800.0, 0.0)
            expect(cmds.len() >= 2).to_equal(true)
            val thumb = cmds[1]
            expect(approx_i32(thumb.height, 200)).to_equal(true)

        it "no thumb when content fits within viewport":
            # content_height <= height, so only the track command is generated
            val cmds = paint_scrollbar(0.0, 0.0, 200.0, 400.0, 300.0, 0.0)
            expect(cmds.len()).to_equal(1)
