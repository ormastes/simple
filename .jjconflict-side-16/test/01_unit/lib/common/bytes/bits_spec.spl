# bits_spec.spl — BitWriter/BitReader bit-exact round-trips (AC-4)
use std.spec
use lib.common.bytes.bits.{BitWriter, BitReader}

describe "BitWriter and BitReader":
    context "LSB-first bit ordering":
        it "packs 0b101 (n=3) into the low bits of a byte = 0x05":
            var w = BitWriter.lsb()
            w.put_bits(5, 3)
            val out = w.finish().to_bytes()
            expect(out.len()).to_equal(1)
            expect(out[0].to_i64()).to_equal(0x05)

        it "packs two fields LSB-first: 0b11 then 0b10 -> byte 0b1011 = 0x0B":
            var w = BitWriter.lsb()
            w.put_bits(3, 2)
            w.put_bits(2, 2)
            val out = w.finish().to_bytes()
            expect(out[0].to_i64()).to_equal(0x0B)

        it "reads back the same fields in order":
            var w = BitWriter.lsb()
            w.put_bits(3, 2)
            w.put_bits(2, 2)
            val bytes = w.finish().to_bytes()
            var r = BitReader.lsb(bytes)
            expect(r.read_bits(2)).to_equal(3)
            expect(r.read_bits(2)).to_equal(2)

        it "writer ignores invalid bit widths":
            var w = BitWriter.lsb()
            w.put_bits(1, 0)
            w.put_bits(1, 65)
            val out = w.finish().to_bytes()
            assert_equal(out.len(), 0)

        it "reader fails closed on invalid bit widths without advancing":
            var r = BitReader.lsb([0x05u8])
            assert_equal(r.read_bits(0), 0)
            assert_equal(r.read_bits(65), 0)
            assert_equal(r.read_bits(3), 5)

    context "MSB-first bit ordering":
        it "packs 0b101 (n=3) into the high bits of a byte = 0xA0":
            var w = BitWriter.msb()
            w.put_bits(5, 3)
            val out = w.finish().to_bytes()
            expect(out[0].to_i64()).to_equal(0xA0)

        it "reads back MSB-first fields in order":
            var w = BitWriter.msb()
            w.put_bits(5, 3)
            w.put_bits(1, 1)
            val bytes = w.finish().to_bytes()
            var r = BitReader.msb(bytes)
            expect(r.read_bits(3)).to_equal(5)
            expect(r.read_bits(1)).to_equal(1)

    context "Round-trip across non-byte-aligned widths":
        it "LSB round-trips a sequence of varied widths exactly":
            var w = BitWriter.lsb()
            w.put_bits(1, 1)
            w.put_bits(13, 5)
            w.put_bits(700, 11)
            w.put_bits(255, 8)
            val bytes = w.finish().to_bytes()
            var r = BitReader.lsb(bytes)
            expect(r.read_bits(1)).to_equal(1)
            expect(r.read_bits(5)).to_equal(13)
            expect(r.read_bits(11)).to_equal(700)
            expect(r.read_bits(8)).to_equal(255)

        it "MSB round-trips a sequence of varied widths exactly":
            var w = BitWriter.msb()
            w.put_bits(1, 1)
            w.put_bits(13, 5)
            w.put_bits(700, 11)
            w.put_bits(255, 8)
            val bytes = w.finish().to_bytes()
            var r = BitReader.msb(bytes)
            expect(r.read_bits(1)).to_equal(1)
            expect(r.read_bits(5)).to_equal(13)
            expect(r.read_bits(11)).to_equal(700)
            expect(r.read_bits(8)).to_equal(255)

        it "LSB round-trips a wide 33-bit value":
            var w = BitWriter.lsb()
            val big = 0x1FEEDBEEF
            w.put_bits(big, 33)
            val bytes = w.finish().to_bytes()
            var r = BitReader.lsb(bytes)
            expect(r.read_bits(33)).to_equal(big)

        it "LSB round-trips a 48-bit value":
            var w = BitWriter.lsb()
            val v = 0xABCDEF012345
            w.put_bits(v, 48)
            var r = BitReader.lsb(w.finish().to_bytes())
            expect(r.read_bits(48)).to_equal(v)

        it "MSB round-trips a full 64-bit value (AC-4 upper bound)":
            var w = BitWriter.msb()
            val v = 0x0123456789ABCDEF
            w.put_bits(v, 64)
            var r = BitReader.msb(w.finish().to_bytes())
            expect(r.read_bits(64)).to_equal(v)

        it "LSB round-trips a full 64-bit value (AC-4 upper bound)":
            var w = BitWriter.lsb()
            val v = 0x0123456789ABCDEF
            w.put_bits(v, 64)
            var r = BitReader.lsb(w.finish().to_bytes())
            expect(r.read_bits(64)).to_equal(v)
