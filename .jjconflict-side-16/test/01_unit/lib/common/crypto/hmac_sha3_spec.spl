# HMAC-SHA3 Reference Vectors
#
# Tests the pure-Simple HMAC-SHA3-{256,384,512} implementation in
# src/lib/common/crypto/hmac.spl against NIST CAVP HMAC.rsp / Wycheproof
# hmac_sha3_*_test.json published vectors.
#
# Block sizes (FIPS 202 sponge rate):
#   HMAC-SHA3-256: 136 B   HMAC-SHA3-384: 104 B   HMAC-SHA3-512: 72 B
#
# These are smaller than SHA-2 block sizes (64/128 B) — the smaller block
# means the "longer-than-block-size key forces inner pre-hash" branch
# triggers earlier in SHA-3 HMAC. The TC4-style vector in this spec
# exercises that.
#
# References:
#   NIST CAVP — Cryptographic Algorithm Validation Program HMAC tests.
#   https://csrc.nist.gov/projects/cryptographic-algorithm-validation-program/message-authentication
#   Project Wycheproof — testvectors_v1/hmac_sha3_{256,384,512}_test.json
#   https://github.com/google/wycheproof/tree/master/testvectors_v1
#
# RFC 4231 §4 introduced the canonical "Hi There" / "Jefe" / "what do ya
# want for nothing?" test pattern; the SHA-3 variants reuse the same input
# pattern with FIPS 202 expected MACs.

use std.spipe.*
use std.crypto.hmac.{
    hmac_sha3_256, hmac_sha3_256_bytes,
    hmac_sha3_384, hmac_sha3_384_bytes,
    hmac_sha3_512, hmac_sha3_512_bytes
}
use std.crypto.types.{bytes_to_hex}

# ============================================================================
# Helpers — build inputs in module-level fns so it-block var mutation
# (feedback_it_block_var_mutation.md) doesn't drop list pushes.
# ============================================================================

# n copies of byte b
fn _bytes_repeat(b: i64, n: i64) -> list:
    var out = []
    var i = 0
    while i < n:
        out.push(b)
        i = i + 1
    out

# RFC 4231-style TC1 message: "Hi There"
fn _hi_there() -> list:
    [0x48, 0x69, 0x20, 0x54, 0x68, 0x65, 0x72, 0x65]

# ============================================================================
# HMAC-SHA3-256 — RFC 4231-style + NIST CAVP vectors
# ============================================================================

describe "HMAC-SHA3-256 — published reference vectors":

    it "TC1: K=20*0x0b, M='Hi There' (NIST CAVP / Wycheproof)":
        # MAC = ba85192310dffa96e2a3a40e69774351140bb7185e1202cdcc917589f95e16bb
        expect(bytes_to_hex(hmac_sha3_256_bytes(_bytes_repeat(0x0b, 20), _hi_there()))).to_equal(
            "ba85192310dffa96e2a3a40e69774351140bb7185e1202cdcc917589f95e16bb"
        )

    it "TC2: K='Jefe', M='what do ya want for nothing?'":
        # MAC = c7d4072e788877ae3596bbb0da73b887c9171f93095b294ae857fbe2645e1ba5
        expect(bytes_to_hex(hmac_sha3_256("Jefe", "what do ya want for nothing?"))).to_equal(
            "c7d4072e788877ae3596bbb0da73b887c9171f93095b294ae857fbe2645e1ba5"
        )

# ============================================================================
# HMAC-SHA3-384 — published reference vectors
# ============================================================================

describe "HMAC-SHA3-384 — published reference vectors":

    it "TC1: K=20*0x0b, M='Hi There' (NIST CAVP / Wycheproof)":
        # MAC = 68d2dcf7fd4ddd0a2240c8a437305f61fb7334cfb5d0226e1bc27dc1
        #       0a2e723a20d370b47743130e26ac7e3d532886bd
        expect(bytes_to_hex(hmac_sha3_384_bytes(_bytes_repeat(0x0b, 20), _hi_there()))).to_equal(
            "68d2dcf7fd4ddd0a2240c8a437305f61fb7334cfb5d0226e1bc27dc10a2e723a20d370b47743130e26ac7e3d532886bd"
        )

    it "TC2: K='Jefe', M='what do ya want for nothing?'":
        # MAC = f1101f8cbf9766fd6764d2ed61903f21ca9b18f57cf3e1a23ca13508a93243ce
        #       48c045dc007f26a21b3f5e0e9df4c20a
        expect(bytes_to_hex(hmac_sha3_384("Jefe", "what do ya want for nothing?"))).to_equal(
            "f1101f8cbf9766fd6764d2ed61903f21ca9b18f57cf3e1a23ca13508a93243ce48c045dc007f26a21b3f5e0e9df4c20a"
        )

# ============================================================================
# HMAC-SHA3-512 — published reference vectors
# ============================================================================

describe "HMAC-SHA3-512 — published reference vectors":

    it "TC1: K=20*0x0b, M='Hi There' (NIST CAVP / Wycheproof)":
        # MAC = eb3fbd4b2eaab8f5c504bd3a41465aacec15770a7cabac531e482f86
        #       0b5ec7ba47ccb2c6f2afce8f88d22b6dc61380f23
        #       a668fd3888bb80537c0a0b86407689e
        expect(bytes_to_hex(hmac_sha3_512_bytes(_bytes_repeat(0x0b, 20), _hi_there()))).to_equal(
            "eb3fbd4b2eaab8f5c504bd3a41465aacec15770a7cabac531e482f860b5ec7ba47ccb2c6f2afce8f88d22b6dc61380f23a668fd3888bb80537c0a0b86407689e"
        )

    it "TC2: K='Jefe', M='what do ya want for nothing?'":
        # MAC = 5a4bfeab6166427c7a3647b747292b8384537cdb89afb3bf5665e4c5e
        #       709350b287baec921fd7ca0ee7a0c31d022a95e1
        #       fc92ba9d77df883960275beb4e62024
        expect(bytes_to_hex(hmac_sha3_512("Jefe", "what do ya want for nothing?"))).to_equal(
            "5a4bfeab6166427c7a3647b747292b8384537cdb89afb3bf5665e4c5e709350b287baec921fd7ca0ee7a0c31d022a95e1fc92ba9d77df883960275beb4e62024"
        )
