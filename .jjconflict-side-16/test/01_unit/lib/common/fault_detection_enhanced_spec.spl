use std.spipe.*

# Fault detection state modelled as a class so mutations persist inside
# interpreter-mode it-block closures (module-level `var` writes via free
# functions are not visible across the closure boundary).
class FaultDetector:
    var signal_detected: bool
    var signal_number: i64
    var signal_name: text
    var memory_exceeded: bool
    var memory_used: i64
    var memory_limit: i64
    var interrupt: bool
    var timeout: bool
    var stack_overflow: bool
    var recursion_depth: i64
    var max_depth: i64

    static fn new() -> FaultDetector:
        FaultDetector(
            signal_detected: false,
            signal_number: 0,
            signal_name: "",
            memory_exceeded: false,
            memory_used: 0,
            memory_limit: 0,
            interrupt: false,
            timeout: false,
            stack_overflow: false,
            recursion_depth: 0,
            max_depth: 1000)

    me set_signal(num: i64, name: text):
        self.signal_detected = true
        self.signal_number = num
        self.signal_name = name

    me clear_signal():
        self.signal_detected = false
        self.signal_number = 0
        self.signal_name = ""

    me set_memory(used: i64, limit: i64):
        self.memory_exceeded = true
        self.memory_used = used
        self.memory_limit = limit

    me clear_memory():
        self.memory_exceeded = false
        self.memory_used = 0
        self.memory_limit = 0

    me set_interrupt():
        self.interrupt = true

    me clear_all():
        self.signal_detected = false
        self.signal_number = 0
        self.signal_name = ""
        self.memory_exceeded = false
        self.memory_used = 0
        self.memory_limit = 0
        self.interrupt = false
        self.timeout = false
        self.stack_overflow = false
        self.recursion_depth = 0
        self.max_depth = 1000

    fn check() -> text:
        if self.signal_detected:
            return "signal:" + str(self.signal_number) + ":" + self.signal_name
        if self.memory_exceeded:
            return "memory:" + str(self.memory_used) + ":" + str(self.memory_limit)
        if self.timeout:
            return "timeout"
        if self.stack_overflow or self.recursion_depth > self.max_depth:
            return "stack_overflow:" + str(self.recursion_depth) + ":" + str(self.max_depth)
        if self.interrupt:
            return "interrupt"
        ""

describe "Enhanced Fault Detection":
    context "signal fault":
        it "not detected initially":
            val fd = FaultDetector.new()
            expect(fd.signal_detected).to_equal(false)

        it "set marks active":
            val fd = FaultDetector.new()
            fd.set_signal(11, "SIGSEGV")
            expect(fd.signal_detected).to_equal(true)

        it "stores signal number":
            val fd = FaultDetector.new()
            fd.set_signal(6, "SIGABRT")
            expect(fd.signal_number).to_equal(6)

        it "stores signal name":
            val fd = FaultDetector.new()
            fd.set_signal(6, "SIGABRT")
            expect(fd.signal_name).to_equal("SIGABRT")

        it "clear resets":
            val fd = FaultDetector.new()
            fd.set_signal(11, "SIGSEGV")
            fd.clear_signal()
            expect(fd.signal_detected).to_equal(false)

    context "memory exceeded":
        it "not exceeded initially":
            val fd = FaultDetector.new()
            expect(fd.memory_exceeded).to_equal(false)

        it "set marks active":
            val fd = FaultDetector.new()
            fd.set_memory(512, 256)
            expect(fd.memory_exceeded).to_equal(true)

        it "stores used and limit":
            val fd = FaultDetector.new()
            fd.set_memory(512, 256)
            expect(fd.memory_used).to_equal(512)
            expect(fd.memory_limit).to_equal(256)

        it "clear resets":
            val fd = FaultDetector.new()
            fd.set_memory(512, 256)
            fd.clear_memory()
            expect(fd.memory_exceeded).to_equal(false)

    context "interrupt":
        it "not requested initially":
            val fd = FaultDetector.new()
            expect(fd.interrupt).to_equal(false)

        it "set marks active":
            val fd = FaultDetector.new()
            fd.set_interrupt()
            expect(fd.interrupt).to_equal(true)

    context "fault priority":
        it "signal highest":
            val fd = FaultDetector.new()
            fd.set_signal(11, "SIGSEGV")
            fd.timeout = true
            fd.interrupt = true
            expect(fd.check()).to_start_with("signal:")

        it "memory over timeout":
            val fd = FaultDetector.new()
            fd.set_memory(512, 256)
            fd.timeout = true
            expect(fd.check()).to_start_with("memory:")

        it "timeout over stack overflow":
            val fd = FaultDetector.new()
            fd.timeout = true
            fd.recursion_depth = 2000
            expect(fd.check()).to_equal("timeout")

        it "stack overflow over interrupt":
            val fd = FaultDetector.new()
            fd.recursion_depth = 2000
            fd.interrupt = true
            expect(fd.check()).to_start_with("stack_overflow:")

        it "interrupt lowest":
            val fd = FaultDetector.new()
            fd.interrupt = true
            expect(fd.check()).to_equal("interrupt")

        it "no fault returns empty":
            val fd = FaultDetector.new()
            expect(fd.check()).to_equal("")

    context "reset":
        it "clears all state":
            val fd = FaultDetector.new()
            fd.set_signal(11, "SIGSEGV")
            fd.set_memory(512, 256)
            fd.set_interrupt()
            fd.timeout = true
            fd.clear_all()
            expect(fd.check()).to_equal("")

        it "restores defaults":
            val fd = FaultDetector.new()
            fd.clear_all()
            expect(fd.max_depth).to_equal(1000)
