use std.spec.{describe, it, assert_equal}
use std.common.encoding.reed_solomon.{gf_mul, gf_inv, gf_pow}

describe "Reed-Solomon GF bounds guards":
    it "rejects out-of-range multiplication operands":
        assert_equal(gf_mul(-1, 1), 0)
        assert_equal(gf_mul(1, 256), 0)

    it "rejects out-of-range inverse operands":
        assert_equal(gf_inv(-1), 0)
        assert_equal(gf_inv(256), 0)

    it "rejects out-of-range powers":
        assert_equal(gf_pow(-1, 2), 0)
        assert_equal(gf_pow(2, -1), 0)

    it "keeps valid GF arithmetic":
        assert_equal(gf_mul(2, 2), 4)
        assert_equal(gf_inv(1), 1)
        assert_equal(gf_pow(2, 0), 1)
