# Tests for `simple query symbols` subcommand

use app.cli.query_engine.{engine_document_symbols}

describe "query symbols":
    it "returns 0 for valid file":
        val result = engine_document_symbols("src/app/lsp/lsp_json.spl")
        expect(result).to_equal(0)

    it "returns 0 for file with no symbols":
        val result = engine_document_symbols("/dev/null")
        expect(result).to_equal(0)

    it "returns 0 for lsp_handlers file":
        val result = engine_document_symbols("src/app/lsp/lsp_handlers.spl")
        expect(result).to_equal(0)
