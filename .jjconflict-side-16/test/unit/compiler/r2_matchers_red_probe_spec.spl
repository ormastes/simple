# R2-broader Phase 2 deliberate-fail probes: prove the matcher folds in
# `rewrite_method_expect_line` actually emit a real `rt_bdd_expect_eq_rv`
# call and not a no-op stub. Both `it` blocks below MUST report RED in
# compile mode:
#   bin/simple test --mode=smf --force-rebuild test/unit/compiler/r2_matchers_red_probe_spec.spl
#
# Substituted from the originally-requested `to_be_greater_than` /
# `to_contain` probes because their folds (`expect a > b`,
# `expect (s).contains(t)`) trip pre-existing upstream BDD-runtime/parser
# bugs that obscure whether the fold itself fired (see the Phase 2 status
# update in feedback_compile_mode_false_greens.md). The two folds
# exercised here ride the only HIR fast-path that is verified working
# today — `rt_bdd_expect_eq_rv` over int/nil — so a green here would be
# unambiguous proof the fold short-circuited.

describe "R2 matcher deliberate-fail probes":
    it "to_equal must report RED for 1 == 2":
        expect(1).to_equal(2)

    it "to_be_nil must report RED for non-nil":
        expect(42).to_be_nil()
