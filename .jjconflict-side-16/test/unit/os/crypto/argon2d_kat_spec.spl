# Argon2d RFC 9106 Known-Answer Tests
#
# Tests the pure-Simple Argon2d implementation in
#   src/os/crypto/argon2d.spl
# against RFC 9106 §5.1 and small-parameter sanity vectors.
#
# RFC 9106 §5.1 fixes p=4, T=32, m=32 KiB, t=3, v=0x13. In interpreter mode
# this exceeds the 60s test-runner watchdog (memory-hard by design — see
# scrypt_rfc7914_kat_spec.spl for the same pattern). Coverage here:
#
#   1. Smoke / output-length: Argon2d(empty pwd, 8-byte salt, t=1, m=8, p=1, T=32)
#      returns exactly 32 bytes and is deterministic.
#   2. Tag-length variation: T=16 and T=64 each return correct length.
#   3. Determinism: same inputs produce same tag across two calls.
#   4. Salt sensitivity: differing salts produce differing tags.
#   5. Key/ad sensitivity: argon2d_hash with non-empty key/ad differs from empty.
#   6. RFC 5.1 (full m=32 KiB / t=3 / p=4) -- pending behind the
#      argon2_native_runtime_helpers FR (perf cliff in interpreter).
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution under the current interpreter (see feedback_compile_mode_false_greens.md).
# Assertions only fire under compiled/native mode.

use std.spipe.*
use os.crypto.argon2d.{argon2d, argon2d_hash}

fn _bytes_to_hex(bytes: [u8]) -> text:
    """Convert a byte list to lowercase hex without separators."""
    val hex_chars = "0123456789abcdef"
    var out = ""
    var i: i64 = 0
    val n = bytes.len()
    while i < n:
        val b = bytes[i].to_i64()
        out = out + hex_chars.char_at((b >> 4) & 0xF).to_text()
        out = out + hex_chars.char_at(b & 0xF).to_text()
        i = i + 1
    out

fn _ascii(s: text) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    val n = s.len()
    while i < n:
        val ch = s[i:i + 1]
        out.push(ch.ord().to_u8())
        i = i + 1
    out

fn _repeat_bytes(byte: i64, n: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < n:
        out.push(byte.to_u8())
        i = i + 1
    out

describe("Argon2d pure Simple smoke (small interpreter-tractable parameters)"):

    it("returns 32 bytes for the default 32-byte tag length"):
        val pwd = _ascii("password")
        val salt = _ascii("somesalt")
        val tag = argon2d(pwd, salt, 1, 8, 1, 32)
        expect(tag.len()).to_equal(32)

    it("returns 16 bytes when tag_len=16"):
        val pwd = _ascii("password")
        val salt = _ascii("somesalt")
        val tag = argon2d(pwd, salt, 1, 8, 1, 16)
        expect(tag.len()).to_equal(16)

    it("returns 64 bytes when tag_len=64 (single-BLAKE2b-call H' branch)"):
        val pwd = _ascii("password")
        val salt = _ascii("somesalt")
        val tag = argon2d(pwd, salt, 1, 8, 1, 64)
        expect(tag.len()).to_equal(64)

    it("returns 96 bytes when tag_len=96 (multi-block H' branch)"):
        val pwd = _ascii("password")
        val salt = _ascii("somesalt")
        val tag = argon2d(pwd, salt, 1, 8, 1, 96)
        expect(tag.len()).to_equal(96)

describe("Argon2d determinism and input sensitivity"):

    it("is deterministic -- same inputs produce same tag"):
        val pwd = _ascii("password")
        val salt = _ascii("somesalt")
        val tag_a = argon2d(pwd, salt, 1, 8, 1, 32)
        val tag_b = argon2d(pwd, salt, 1, 8, 1, 32)
        expect(_bytes_to_hex(tag_a)).to_equal(_bytes_to_hex(tag_b))

    it("differing salt produces different tag"):
        val pwd = _ascii("password")
        val salt1 = _ascii("somesalt")
        val salt2 = _ascii("othersalt")
        val tag1 = argon2d(pwd, salt1, 1, 8, 1, 32)
        val tag2 = argon2d(pwd, salt2, 1, 8, 1, 32)
        expect(_bytes_to_hex(tag1)).to_not_equal(_bytes_to_hex(tag2))

    it("differing password produces different tag"):
        val salt = _ascii("somesalt")
        val pwd1 = _ascii("password")
        val pwd2 = _ascii("Password")
        val tag1 = argon2d(pwd1, salt, 1, 8, 1, 32)
        val tag2 = argon2d(pwd2, salt, 1, 8, 1, 32)
        expect(_bytes_to_hex(tag1)).to_not_equal(_bytes_to_hex(tag2))

    it("non-empty key changes output vs empty key (argon2d_hash)"):
        val pwd = _ascii("password")
        val salt = _ascii("somesalt")
        val empty: [u8] = []
        val key = _repeat_bytes(1, 4)
        val tag_no_key = argon2d_hash(pwd, salt, 1, 8, 1, empty, empty, 32)
        val tag_with_key = argon2d_hash(pwd, salt, 1, 8, 1, key, empty, 32)
        expect(_bytes_to_hex(tag_no_key)).to_not_equal(_bytes_to_hex(tag_with_key))

    it("non-empty ad changes output vs empty ad (argon2d_hash)"):
        val pwd = _ascii("password")
        val salt = _ascii("somesalt")
        val empty: [u8] = []
        val ad = _repeat_bytes(4, 4)
        val tag_no_ad = argon2d_hash(pwd, salt, 1, 8, 1, empty, empty, 32)
        val tag_with_ad = argon2d_hash(pwd, salt, 1, 8, 1, empty, ad, 32)
        expect(_bytes_to_hex(tag_no_ad)).to_not_equal(_bytes_to_hex(tag_with_ad))

describe("Argon2d RFC 9106 5.1 -- pending native fast path"):

    it("RFC 5.1 (p=4, m=32 KiB, t=3, T=32) -- pending FR argon2_native_runtime_helpers"):
        # RFC 9106 5.1 inputs:
        #   password = 32 bytes 0x01, salt = 16 bytes 0x02
        #   secret = 8 bytes 0x03, ad = 12 bytes 0x04
        #   t=3, m=32, p=4, T=32, v=0x13
        #   tag = 51 2b 39 1b 6f 11 62 97 53 71 d3 09 19 73 42 94
        #         f8 68 e3 be 39 84 f3 c1 a1 3a 4d b9 fa be 4a cb
        # Memory-hard pure-Simple loop exceeds 60s watchdog under interpreter.
        # Filed: doc/02_requirements/feature/argon2_native_runtime_helpers_2026-05-02.md
        pending("argon2_native_runtime_helpers")
