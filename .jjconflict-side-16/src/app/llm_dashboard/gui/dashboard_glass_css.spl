fn generate_dashboard_glass_css() -> text:
    """
    CSS tokens for the lightweight LLM dashboard glass theme.
    """
    """
:root {
  --surface: #0B0F14;
  --panel: rgba(255, 255, 255, 0.08);
  --accent: #0A84FF;
}

body {
  background: var(--surface);
  color: #F5F7FA;
}

.panel {
  background: var(--panel);
  backdrop-filter: blur(18px);
}

.tab-btn {
  color: #F5F7FA;
  border-color: var(--accent);
}
"""

export generate_dashboard_glass_css
