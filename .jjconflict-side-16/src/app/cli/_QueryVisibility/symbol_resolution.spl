# Query visibility — symbol + module path resolution helpers
use app.cli.query_visibility.*
# Query CLI - LSP visibility JSON adapters
#
# Wraps the existing text-oriented query commands and enriches them with
# lightweight visibility metadata derived from file/module boundaries.

use app.cli.query_rich_common.{query_file_read_rich, query_file_exists, query_process_run, query_cli_get_args}
use app.cli.query_sanitize.{sanitize_path, sanitize_symbol}
use common.text_advanced.{escape_json}

fn capsule_name(file_path: text) -> text:
    val idx = file_path.index_of("/85.mdsoc/") ?? -1
    if idx < 0:
        return ""
    val rest = file_path.substring(idx + 10)
    val parts = rest.split("/")
    if parts.len() >= 2:
        return parts[0] + "." + parts[1]
    if parts.len() >= 1:
        return parts[0]
    ""

fn resolve_symbol_file(current_file: text, symbol: text) -> text:
    if declaration_line(symbol: symbol, owner_file: current_file) != "":
        return current_file
    val imports = parse_imported_modules(file_path: current_file)
    for module_path in imports:
        val resolved = resolve_module_path(mod_path: module_path)
        if resolved != "" and declaration_line(symbol: symbol, owner_file: resolved) != "":
            return resolved
    current_file

fn parse_imported_modules(file_path: text) -> [text]:
    if not query_file_exists(file_path):
        return []
    val content = query_file_read_rich(file_path) ?? ""
    val lines = content.split("\n")
    var modules: [text] = []
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("use "):
            val rest = trimmed.substring(4)
            val end_idx = rest.index_of("{") ?? -1
            if end_idx >= 0:
                modules = modules.push(rest.substring(0, end_idx).trim().trim_end("."))
            else:
                val star_idx = rest.index_of("*") ?? -1
                if star_idx >= 0:
                    modules = modules.push(rest.substring(0, star_idx).trim().trim_end("."))
                else:
                    modules = modules.push(rest.trim())
    modules

fn resolve_module_path(mod_path: text) -> text:
    if mod_path.contains("/"):
        val slash_parts = mod_path.split("/")
        if slash_parts.len() >= 2 and slash_parts[0].contains("-"):
            val owner_segment = slash_parts[0]
            val owner_domain = owner_segment.replace("-", "_")
            val type_base = "src/type/" + owner_domain + "/" + slash_parts[1..].join("/")
            val type_mod = type_base + "/mod.spl"
            if query_file_exists(type_mod):
                return type_mod
            val type_direct = type_base + ".spl"
            if query_file_exists(type_direct):
                return type_direct

    if not mod_path.contains("."):
        val type_base = "src/type/simple_lang/" + mod_path
        val type_mod = type_base + "/mod.spl"
        if query_file_exists(type_mod):
            return type_mod
        val type_direct = type_base + ".spl"
        if query_file_exists(type_direct):
            return type_direct

    var path = mod_path
    if path.starts_with("std."):
        path = "lib." + path.substring(4)
    elif path.starts_with("lib.") or path.starts_with("app.") or path.starts_with("compiler."):
        path = path
    else:
        path = "lib." + path
    val file_base = "src/" + path.split(".").join("/")
    val mod_file = file_base + "/mod.spl"
    if query_file_exists(mod_file):
        return mod_file
    val direct_file = file_base + ".spl"
    if query_file_exists(direct_file):
        return direct_file
    ""

fn extract_symbol_at(file: text, line_num: i64, col: i64) -> text:
    val content = query_file_read_rich(file) ?? ""
    if content == "":
        return ""
    val lines = content.split("\n")
    if line_num < 1 or line_num > lines.len():
        return ""
    val target = lines[line_num - 1]
    val declared = declaration_name(target)
    if declared != "":
        return declared
    val chars = text_chars(target)
    if col > 0 and col <= chars.len():
        var idx = col - 1
        if idx >= chars.len():
            idx = chars.len() - 1
        if idx >= 0 and idx < chars.len() and not is_ident_char(chars[idx]) and idx > 0 and is_ident_char(chars[idx - 1]):
            idx = idx - 1
        if idx >= 0 and idx < chars.len() and is_ident_char(chars[idx]):
            var start = idx
            var end_pos = idx
            while start > 0 and is_ident_char(chars[start - 1]):
                start = start - 1
            while end_pos + 1 < chars.len() and is_ident_char(chars[end_pos + 1]):
                end_pos = end_pos + 1
            var parts: [text] = []
            var i = start
            while i <= end_pos:
                parts = parts.push(chars[i])
                i = i + 1
            return parts.join("")
    return ""

fn token_name_at(file: text, line_num: i64, col: i64, length: i64) -> text:
    val content = query_file_read_rich(file) ?? ""
    if content == "":
        return ""
    val lines = content.split("\n")
    if line_num < 0 or line_num >= lines.len():
        return ""
    val chars = text_chars(lines[line_num])
    if col < 0 or col + length > chars.len():
        return ""
    var parts: [text] = []
    var i = col
    while i < col + length:
        parts = parts.push(chars[i])
        i = i + 1
    return parts.join("")

fn semantic_token_type_number(name: text) -> i64:
    if name == "namespace":
        return 0
    elif name == "type":
        return 1
    elif name == "class":
        return 2
    elif name == "enum":
        return 3
    elif name == "struct":
        return 4
    elif name == "function":
        return 5
    elif name == "method":
        return 6
    elif name == "property":
        return 7
    elif name == "variable":
        return 8
    elif name == "parameter":
        return 9
    elif name == "enumMember":
        return 10
    elif name == "keyword":
        return 11
    elif name == "comment":
        return 12
    elif name == "string":
        return 13
    elif name == "number":
        return 14
    elif name == "operator":
        return 15
    8

fn symbol_kind_number(kind: text) -> i64:
    if kind == "fn" or kind == "function" or kind == "extern_fn":
        return 12
    elif kind == "method" or kind == "static_method":
        return 6
    elif kind == "class":
        return 5
    elif kind == "struct":
        return 23
    elif kind == "enum":
        return 10
    elif kind == "trait":
        return 11
    elif kind == "module":
        return 2
    elif kind == "domain":
        return 2
    13

fn parent_dir(path: text) -> text:
    val idx = path.last_index_of("/") ?? -1
    if idx <= 0:
        return ""
    path.substring(0, idx)

fn relative_to_src(path: text) -> text:
    val idx = path.index_of("/src/") ?? -1
    if idx >= 0:
        return path.substring(idx + 5)
    if path.starts_with("src/"):
        return path.substring(4)
    path

fn contains_symbol_token(line: text, symbol: text) -> bool:
    val chars = text_chars(line)
    val symbol_chars = text_chars(symbol)
    if symbol_chars.len() == 0 or chars.len() < symbol_chars.len():
        return false
    var pos = 0
    while pos <= chars.len() - symbol_chars.len():
        var matches = true
        var j = 0
        while j < symbol_chars.len():
            if chars[pos + j] != symbol_chars[j]:
                matches = false
                break
            j = j + 1
        if matches:
            val left_ok = if pos == 0: true else: not is_ident_char(chars[pos - 1])
            val right_ok = if pos + symbol_chars.len() >= chars.len(): true else: not is_ident_char(chars[pos + symbol_chars.len()])
            if left_ok and right_ok:
                return true
        pos = pos + 1
    false

fn is_ident_char(ch: text) -> bool:
    (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_"

fn list_has_text(items: [text], value: text) -> bool:
    for item in items:
        if item == value:
            return true
    false

fn bool_json(value: bool) -> text:
    if value:
        return "true"
    "false"

fn json_text_array(items: [text]) -> text:
    var encoded: [text] = []
    for item in items:
        encoded = encoded.push(json_text(item))
    encoded.join(",")

fn json_text(value: text) -> text:
    "\"" + escape_json(value) + "\""

fn find_spl_files(root: text) -> [text]:
    val (stdout, stderr, code) = query_process_run("/bin/sh", ["-c", "find " + root + " -type f -name '*.spl' | sort"])
    if code != 0 or stdout.trim() == "":
        return []
    var result: [text] = []
    val lines = stdout.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            continue
        result = result.push(trimmed)
    result

fn matching_keywords(prefix: text) -> [text]:
    val all = ["fn", "val", "var", "class", "struct", "enum", "trait", "impl", "if", "elif", "else", "for", "while", "match", "case", "return", "break", "continue", "use", "import", "export", "extern", "static", "me", "in", "not", "and", "or", "true", "false", "nil", "self"]
    var items: [text] = []
    for kw in all:
        if prefix == "" or kw.starts_with(prefix):
            items = items.push(kw)
    items

fn scan_semantic_tokens(file_path: text, start_line: i64, end_line: i64) -> [text]:
    if not query_file_exists(file_path):
        return []
    val content = query_file_read_rich(file_path) ?? ""
    val lines = content.split("\n")
    var fn_names: [text] = []
    var type_names: [text] = []
    var param_names: [text] = []
    val parsed = parse_symbols_in_file(file_path)
    for sym in parsed:
        if sym.kind == "fn" or sym.kind == "method":
            fn_names = fn_names.push(sym.name)
        elif sym.kind == "class" or sym.kind == "struct" or sym.kind == "enum" or sym.kind == "trait":
            type_names = type_names.push(sym.name)
    var results: [text] = []
    var line_idx = 1
    var last_line = end_line
    if last_line <= 0 or last_line > lines.len():
        last_line = lines.len()
    for line in lines:
        if line_idx < start_line and start_line > 0:
            line_idx = line_idx + 1
            continue
        if line_idx > last_line:
            break
        val chars = text_chars(line)
        var ci = 0
        while ci < chars.len():
            val ch = chars[ci]
            if ch == " " or ch == "\t":
                ci = ci + 1
                continue
            if ch == "#":
                results = results.push(str(line_idx) + ":" + str(ci) + ":" + str(chars.len() - ci) + ":comment")
                break
            if ch == "\"":
                var si = ci + 1
                while si < chars.len():
                    val current = chars[si]
                    if current == "\"":
                        si = si + 1
                        break
                    si = si + 1
                results = results.push(str(line_idx) + ":" + str(ci) + ":" + str(si - ci) + ":string")
                ci = si
                continue
            if ch >= "0" and ch <= "9":
                var ni = ci + 1
                while ni < chars.len():
                    val current = chars[ni]
                    if not ((current >= "0" and current <= "9") or current == "."):
                        break
                    ni = ni + 1
                results = results.push(str(line_idx) + ":" + str(ci) + ":" + str(ni - ci) + ":number")
                ci = ni
                continue
            if is_ident_char(ch):
                var wi = ci + 1
                while wi < chars.len():
                    val current = chars[wi]
                    if not is_ident_char(current):
                        break
                    wi = wi + 1
                var word_parts: [text] = []
                var wj = ci
                while wj < wi:
                    word_parts = word_parts.push(chars[wj])
                    wj = wj + 1
                val word = word_parts.join("")
                var token_type = "variable"
                if list_has_text(matching_keywords(word), word):
                    token_type = "keyword"
                elif list_has_text(fn_names, word):
                    token_type = "function"
                elif list_has_text(type_names, word):
                    token_type = "type"
                elif list_has_text(param_names, word):
                    token_type = "parameter"
                results = results.push(str(line_idx) + ":" + str(ci) + ":" + str(wi - ci) + ":" + token_type)
                ci = wi
                continue
            if ci + 1 < chars.len():
                val op = chars[ci] + chars[ci + 1]
                if op == "->" or op == ":=" or op == "==" or op == "!=" or op == ">=" or op == "<=":
                    results = results.push(str(line_idx) + ":" + str(ci) + ":2:operator")
                    ci = ci + 2
                    continue
            ci = ci + 1
        line_idx = line_idx + 1
    results

fn text_chars(value: text) -> [text]:
    var chars: [text] = []
    val parts = value.split("")
    for part in parts:
        if part != "":
            chars = chars.push(part)
    chars

fn join_char_slice(chars: [text], start_idx: i64, end_idx: i64) -> text:
    var out: [text] = []
    var i = start_idx
    while i < end_idx and i < chars.len():
        out = out.push(chars[i])
        i = i + 1
    out.join("")
