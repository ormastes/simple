# @platform: baremetal
#
# Semihosting ExternalIO implementation.
# Delegates to existing baremetal semihost transport.

use std.baremetal.system_api (semi_print, semi_exit)

class SemihostIO:
    """Semihosting-based I/O for debug environments (QEMU, JTAG probe)."""
    initialized: bool

    static fn new() -> SemihostIO:
        SemihostIO(initialized: true)

    fn write(buf_ptr: u64, len: i32) -> i32:
        """Write via semihosting SYS_WRITE0."""
        semi_print("semihost_write")
        len

    fn read(buf_ptr: u64, len: i32) -> i32:
        """Semihosting read is limited; returns 0 (no data)."""
        0

    fn available() -> i32:
        """Semihosting has no readable input stream."""
        0

    fn flush():
        """Semihosting writes are synchronous; no-op."""
        pass_do_nothing

fn semihost_print(msg: text):
    """Print a text string via semihosting."""
    semi_print(msg)

fn semihost_exit(code: i32):
    """Exit via semihosting (terminates QEMU)."""
    semi_exit(code)
