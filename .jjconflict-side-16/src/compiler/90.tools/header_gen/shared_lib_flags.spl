# Shared Library Build Flags
#
# Returns the correct compiler and linker flags for building shared libraries
# on each supported platform (Linux, macOS, Windows MSVC, Windows MinGW).
#
# Used by the linker wrapper and driver to support `--shared` build mode.
# When --shared is specified:
#   - Code is compiled with position-independent code flags (-fPIC)
#   - The linker produces a .so / .dylib / .dll instead of an executable
#   - No main() entry point is generated
#   - SPL_SHARED_LIBRARY macro is defined during compilation

use std.io_runtime.{host_os, env_get}

# ============================================================================
# Platform Detection
# ============================================================================

fn is_windows() -> bool:
    """Check if the current platform is Windows."""
    host_os() == "windows"

fn is_macos() -> bool:
    """Check if the current platform is macOS."""
    host_os() == "macos" or host_os() == "darwin"

fn is_linux() -> bool:
    """Check if the current platform is Linux."""
    host_os() == "linux"

fn is_mingw() -> bool:
    """Check if running under MinGW/MSYS2 on Windows."""
    val msystem = env_get("MSYSTEM")
    if msystem != "" and msystem != nil:
        return true
    val linker_flavor = env_get("SIMPLE_LINKER_FLAVOR")
    linker_flavor == "gnu"

fn is_msvc() -> bool:
    """Check if targeting MSVC toolchain on Windows."""
    is_windows() and not is_mingw()

# ============================================================================
# Shared Library Flags
# ============================================================================

struct SharedLibFlags:
    """Platform-specific flags for building a shared library."""
    compile_flags: [text]    # Flags for the C compiler (e.g., -fPIC)
    link_flags: [text]       # Flags for the linker (e.g., -shared)
    defines: [text]          # Preprocessor defines (e.g., SPL_SHARED_LIBRARY)
    output_extension: text   # File extension (.so, .dylib, .dll)
    import_lib_ext: text     # Import library extension (.lib for MSVC, empty otherwise)

fn get_shared_lib_flags() -> SharedLibFlags:
    """Get platform-specific shared library build flags.

    Returns the correct compiler flags, linker flags, preprocessor defines,
    and file extensions for the current platform.
    """
    if is_msvc():
        return _msvc_flags()
    elif is_mingw():
        return _mingw_flags()
    elif is_macos():
        return _macos_flags()
    else:
        # Linux, FreeBSD, and other Unix-like
        return _linux_flags()

fn _linux_flags() -> SharedLibFlags:
    SharedLibFlags(
        compile_flags: ["-fPIC"],
        link_flags: ["-shared"],
        defines: ["SPL_SHARED_LIBRARY"],
        output_extension: ".so",
        import_lib_ext: ""
    )

fn _macos_flags() -> SharedLibFlags:
    SharedLibFlags(
        compile_flags: ["-fPIC"],
        link_flags: ["-dynamiclib"],
        defines: ["SPL_SHARED_LIBRARY"],
        output_extension: ".dylib",
        import_lib_ext: ""
    )

fn _msvc_flags() -> SharedLibFlags:
    SharedLibFlags(
        compile_flags: [],
        link_flags: ["/DLL"],
        defines: ["SPL_SHARED_LIBRARY", "_USRDLL"],
        output_extension: ".dll",
        import_lib_ext: ".lib"
    )

fn _mingw_flags() -> SharedLibFlags:
    SharedLibFlags(
        compile_flags: [],
        link_flags: ["-shared"],
        defines: ["SPL_SHARED_LIBRARY"],
        output_extension: ".dll",
        import_lib_ext: ""
    )

# ============================================================================
# Helper Functions
# ============================================================================

fn shared_lib_output_path(base_name: text) -> text:
    """Compute the shared library output filename for the current platform.

    Args:
        base_name: Library base name (e.g., "mylib")

    Returns:
        Platform-appropriate filename (e.g., "libmylib.so", "mylib.dll")
    """
    val flags = get_shared_lib_flags()
    if is_windows():
        base_name + flags.output_extension
    else:
        "lib" + base_name + flags.output_extension

fn import_lib_output_path(base_name: text) -> text:
    """Compute the import library path for MSVC builds.

    Returns empty string on non-MSVC platforms.
    """
    if is_msvc():
        base_name + ".lib"
    else:
        ""

fn apply_shared_compile_flags(existing_flags: [text]) -> [text]:
    """Append shared library compile flags to an existing flag list."""
    val flags = get_shared_lib_flags()
    var result = existing_flags
    var fi = 0
    while fi < flags.compile_flags.len():
        result.push(flags.compile_flags[fi])
        fi = fi + 1
    # Add defines as -D flags
    var di = 0
    while di < flags.defines.len():
        result.push("-D" + flags.defines[di])
        di = di + 1
    result

fn apply_shared_link_flags(existing_flags: [text]) -> [text]:
    """Append shared library link flags to an existing flag list."""
    val flags = get_shared_lib_flags()
    var result = existing_flags
    var fi = 0
    while fi < flags.link_flags.len():
        result.push(flags.link_flags[fi])
        fi = fi + 1
    result

# ============================================================================
# Export
# ============================================================================
