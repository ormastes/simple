# Data Structure utilities
# Queue, Stack, Deque (double-ended queue) implementations

# =====================================
# Stack (LIFO - Last In First Out)
# =====================================

struct Stack<T>:
    items: [T]

impl Stack<T>:
    # Create new empty stack
    static fn new() -> Stack<T>:
        Stack(items: [])

    # Push item onto stack
    fn push(item: T):
        me.items.push(item)

    # Pop item from stack
    me pop() -> T?:
        if me.items.len() == 0:
            return nil
        val last_idx = me.items.len() - 1
        val item = me.items[last_idx]
        me.items = me.items.slice(0, last_idx)
        item

    # Peek at top item without removing
    fn peek() -> T?:
        if me.items.len() == 0:
            return nil
        me.items[me.items.len() - 1]

    # Check if stack is empty
    fn is_empty() -> bool:
        me.items.len() == 0

    # Get size of stack
    fn size() -> i64:
        me.items.len()

    # Clear all items
    me clear():
        me.items = []

    # Convert to list
    fn to_list() -> [T]:
        me.items

# =====================================
# Queue (FIFO - First In First Out)
# =====================================

struct Queue<T>:
    items: [T]

impl Queue<T>:
    # Create new empty queue
    static fn new() -> Queue<T>:
        Queue(items: [])

    # Enqueue (add to back)
    fn enqueue(item: T):
        me.items.push(item)

    # Dequeue (remove from front)
    me dequeue() -> T?:
        if me.items.len() == 0:
            return nil
        val item = me.items[0]
        me.items = me.items.slice(1, me.items.len())
        item

    # Peek at front item without removing
    fn peek() -> T?:
        if me.items.len() == 0:
            return nil
        me.items[0]

    # Check if queue is empty
    fn is_empty() -> bool:
        me.items.len() == 0

    # Get size of queue
    fn size() -> i64:
        me.items.len()

    # Clear all items
    me clear():
        me.items = []

    # Convert to list
    fn to_list() -> [T]:
        me.items

# =====================================
# Deque (Double-Ended Queue)
# =====================================

struct Deque<T>:
    items: [T]

impl Deque<T>:
    # Create new empty deque
    static fn new() -> Deque<T>:
        Deque(items: [])

    # Add to front
    me push_front(item: T):
        var new_items: [T] = []
        new_items.push(item)
        for existing in me.items:
            new_items.push(existing)
        me.items = new_items

    # Add to back
    fn push_back(item: T):
        me.items.push(item)

    # Remove from front
    me pop_front() -> T?:
        if me.items.len() == 0:
            return nil
        val item = me.items[0]
        me.items = me.items.slice(1, me.items.len())
        item

    # Remove from back
    me pop_back() -> T?:
        if me.items.len() == 0:
            return nil
        val last_idx = me.items.len() - 1
        val item = me.items[last_idx]
        me.items = me.items.slice(0, last_idx)
        item

    # Peek at front without removing
    fn peek_front() -> T?:
        if me.items.len() == 0:
            return nil
        me.items[0]

    # Peek at back without removing
    fn peek_back() -> T?:
        if me.items.len() == 0:
            return nil
        me.items[me.items.len() - 1]

    # Check if deque is empty
    fn is_empty() -> bool:
        me.items.len() == 0

    # Get size of deque
    fn size() -> i64:
        me.items.len()

    # Clear all items
    me clear():
        me.items = []

    # Convert to list
    fn to_list() -> [T]:
        me.items

# =====================================
# Helper Functions
# =====================================

# Create stack from list
fn stack_from_list<T>(items: [T]) -> Stack<T>:
    Stack(items: items)

# Create queue from list
fn queue_from_list<T>(items: [T]) -> Queue<T>:
    Queue(items: items)

# Create deque from list
fn deque_from_list<T>(items: [T]) -> Deque<T>:
    Deque(items: items)

# Get nth element from stack (0 = top), returns nil if out of bounds
# ponytail: `any` instead of T? — free-function generic T? return wraps values in Option::Some
#           (interpreter bug; impl-method T? is unaffected). See bug free_fn_optional_wrap_2026-06-26.
fn stack_get<T>(stack: Stack<T>, n: i64) -> any:
    val idx = stack.items.len() - 1 - n
    if idx < 0 or idx >= stack.items.len():
        return nil
    stack.items[idx]

# Get nth element from queue (0 = front), returns nil if out of bounds
# ponytail: same free-function T? workaround as stack_get above.
fn queue_get<T>(queue: Queue<T>, n: i64) -> any:
    if n < 0 or n >= queue.items.len():
        return nil
    queue.items[n]

# Reverse stack (returns new stack)
fn reverse_stack<T>(stack: Stack<T>) -> Stack<T>:
    var reversed: [T] = []
    var i = stack.items.len() - 1
    while i >= 0:
        reversed.push(stack.items[i])
        i = i - 1
    Stack(items: reversed)

# Merge two queues into one
fn merge_queues<T>(q1: Queue<T>, q2: Queue<T>) -> Queue<T>:
    var merged: [T] = []
    for item in q1.items:
        merged.push(item)
    for item in q2.items:
        merged.push(item)
    Queue(items: merged)
