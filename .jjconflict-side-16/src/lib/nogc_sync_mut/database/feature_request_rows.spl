# Canonical requested feature-row writer.
#
# This owner-module path avoids manual edits to feature_db.sdn while keeping the
# write narrow enough for request rows that do not need the full SDN query stack.

use std.io_runtime.{file_exists, file_read, file_write}

struct FeatureRequestRow:
    id: text
    group: text
    component: text
    title: text
    description: text
    priority: text
    source_file: text
    plan: text
    architecture: text
    design: text
    system_spec: text
    spec_doc: text
    guide: text
    created_at: text
    updated_at: text

fn _feature_csv(value: text) -> text:
    "\"" + value.replace("\"", "\"\"") + "\""

fn feature_request_row_line(feature: FeatureRequestRow) -> text:
    var fields: [text] = []
    fields.push(_feature_csv(feature.id))
    fields.push(_feature_csv(feature.group))
    fields.push(_feature_csv(feature.group))
    fields.push(_feature_csv(feature.component))
    fields.push(_feature_csv(feature.title))
    fields.push(_feature_csv(feature.description))
    fields.push(_feature_csv("request"))
    fields.push(_feature_csv(feature.priority))
    fields.push(_feature_csv(feature.source_file))
    fields.push(_feature_csv(""))
    fields.push(_feature_csv(""))
    fields.push(_feature_csv(feature.plan))
    fields.push(_feature_csv(feature.architecture))
    fields.push(_feature_csv(feature.design))
    fields.push(_feature_csv(feature.system_spec))
    fields.push(_feature_csv(feature.spec_doc))
    fields.push(_feature_csv(""))
    fields.push(_feature_csv(""))
    fields.push(_feature_csv(""))
    fields.push(_feature_csv(feature.guide))
    fields.push(_feature_csv(""))
    fields.push(_feature_csv(""))
    fields.push(_feature_csv(""))
    fields.push(_feature_csv(feature.updated_at))
    fields.push(_feature_csv(feature.created_at))
    fields.push(_feature_csv(feature.updated_at))
    fields.push("true")
    "    " + fields.join(", ")

fn feature_request_exists(content: text, id: text) -> bool:
    content.contains("\"" + id + "\"")

fn add_feature_request_row(path: text, feature: FeatureRequestRow) -> bool:
    if not file_exists(path):
        return false
    val content = file_read(path)
    if feature_request_exists(content, feature.id):
        return true
    val sep = if content.ends_with("\n"): "" else: "\n"
    file_write(path, content + sep + feature_request_row_line(feature) + "\n")

export FeatureRequestRow, feature_request_row_line, feature_request_exists, add_feature_request_row
