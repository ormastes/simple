# Editor Terminal Panel
#
# Integrated terminal panel for running shell commands inside the editor.

struct TerminalPanelLine:
    text: text
    kind: text

struct TerminalPanel:
    title: text
    lines: [TerminalPanelLine]
    input: text
    active: bool
    scroll_offset: i64

fn terminal_panel_new(title: text) -> TerminalPanel:
    TerminalPanel(
        title: title,
        lines: [],
        input: "",
        active: false,
        scroll_offset: 0
    )

fn terminal_panel_append(panel: TerminalPanel, text: text, kind: text) -> TerminalPanel:
    var new_lines = panel.lines
    new_lines.push(TerminalPanelLine(text: text, kind: kind))
    TerminalPanel(
        title: panel.title,
        lines: new_lines,
        input: panel.input,
        active: panel.active,
        scroll_offset: panel.scroll_offset
    )

fn terminal_panel_render(panel: TerminalPanel, height: i64) -> [text]:
    var lines: [text] = []
    var start = panel.scroll_offset
    if start < 0:
        start = 0
    var i = start
    while i < panel.lines.len() and lines.len() < height - 1:
        lines.push(panel.lines[i].text)
        i = i + 1
    lines.push("> " + panel.input)
    lines
