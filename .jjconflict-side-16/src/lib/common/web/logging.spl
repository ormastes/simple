"""
Web UI Logging

Provides Logger and LogLevel for web_ui component diagnostic output.
Consumed by nogc_sync_mut/web_ui/{app, bridge, dom_backend, window}.
"""

# ============================================================================
# LogLevel
# ============================================================================

enum LogLevel:
    """Severity levels for log messages."""
    Trace
    Debug
    Info
    Warn
    Error

fn log_level_text(level: LogLevel) -> text:
    match level:
        LogLevel.Trace: "TRACE"
        LogLevel.Debug: "DEBUG"
        LogLevel.Info: "INFO"
        LogLevel.Warn: "WARN"
        LogLevel.Error: "ERROR"

fn log_level_value(level: LogLevel) -> i64:
    """Numeric severity (higher = more severe)."""
    match level:
        LogLevel.Trace: 0
        LogLevel.Debug: 1
        LogLevel.Info: 2
        LogLevel.Warn: 3
        LogLevel.Error: 4

# ============================================================================
# Logger
# ============================================================================

class Logger:
    """Lightweight logger with a component name and minimum level filter."""
    component: text
    min_level: LogLevel

impl Logger:
    static fn new(component: text) -> Logger:
        """Create a Logger that emits Info and above."""
        Logger(component: component, min_level: LogLevel.Info)

    static fn with_level(component: text, min_level: LogLevel) -> Logger:
        """Create a Logger with a custom minimum level."""
        Logger(component: component, min_level: min_level)

    fn log(level: LogLevel, message: text):
        """Emit a log line if level >= min_level."""
        if log_level_value(level) >= log_level_value(self.min_level):
            val label = log_level_text(level)
            print("[{label}] {self.component}: {message}")

    fn trace(message: text):
        self.log(LogLevel.Trace, message)

    fn debug(message: text):
        self.log(LogLevel.Debug, message)

    fn info(message: text):
        self.log(LogLevel.Info, message)

    fn warn(message: text):
        self.log(LogLevel.Warn, message)

    fn error(message: text):
        self.log(LogLevel.Error, message)

    fn is_enabled(level: LogLevel) -> bool:
        log_level_value(level) >= log_level_value(self.min_level)
