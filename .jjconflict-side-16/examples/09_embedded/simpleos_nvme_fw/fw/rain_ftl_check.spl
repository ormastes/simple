"""
rain_ftl_check — FTL-integrated RAIN channel reconstruction (gap-closure P8, wired).

Proves the RAIN parity is load-bearing in the live FTL, not a standalone model: write known
data through the real FTL write path, seal RAIN parity over the physical contents, then make a
whole channel (die) go uncorrectable and rebuild it from parity + the surviving channels. Every
logical block must read back its original value through the normal FTL read path.

Run: bin/simple run examples/09_embedded/simpleos_nvme_fw/fw/rain_ftl_check.spl
"""

use nvme_types.*
use fil_scheduler.*     # NUM_CHANNELS
use rain.*
use ftl.*

fn main():
    var fail: i64 = 0
    var ftl: Ftl = ftl_new()

    # Write known, nonzero data to a span of LBAs (fills several blocks across channels).
    val N: i64 = 256
    var i: i64 = 0
    while i < N:
        val v: i64 = (i % 251) + 1
        val st: i64 = ftl.write(i, v)
        fail = fail + expect_eq(st, SC_SUCCESS, "write LBA succeeds")
        i = i + 1

    # Seal RAIN parity over the device's current physical contents.
    ftl.rain_seal()

    # Choose the channel that backs LBA 0 — guaranteed to hold live data to lose.
    val ppn0: i64 = ftl.physical_ppn(0)
    val blk0: i64 = ppn_block(ppn0)
    val failed: i64 = blk0 % NUM_CHANNELS

    # Simulate the die failure: every live page on that channel goes uncorrectable.
    var corrupted: i64 = 0
    var first: i64 = -1
    i = 0
    while i < N:
        val ppn: i64 = ftl.physical_ppn(i)
        if ppn != UNMAP:
            val blk: i64 = ppn_block(ppn)
            if blk % NUM_CHANNELS == failed:
                ftl.inject_read_bitflip(ppn, 2)     # 2 flips → NAND_ECC_FAIL (uncorrectable)
                corrupted = corrupted + 1
                if first == -1:
                    first = i
        i = i + 1
    var some: i64 = 0
    if corrupted > 0:
        some = 1
    fail = fail + expect_eq(some, 1, "the failed channel held live data to lose")

    # Before the rebuild, a lost block reads as an uncorrectable media error.
    val st_pre: i64 = ftl.read_status(first)
    fail = fail + expect_eq(st_pre, SC_MEDIA_ERR, "lost block is uncorrectable before the rebuild")

    # Rebuild the channel from RAIN parity + the survivors.
    val rebuilt: i64 = ftl.rain_recover_channel(failed)
    fail = fail + expect_eq(rebuilt, corrupted, "every lost page was rebuilt")

    # After the rebuild the block is clean and reads its original value.
    val st_post: i64 = ftl.read_status(first)
    fail = fail + expect_eq(st_post, SC_SUCCESS, "rebuilt block reads clean")

    # Every LBA survives the channel failure (read through the normal FTL path).
    i = 0
    while i < N:
        val want: i64 = (i % 251) + 1
        val got: i64 = ftl.read(i)
        fail = fail + expect_eq(got, want, "LBA survives the channel failure")
        i = i + 1

    if fail == 0:
        print "RAIN-FTL OK"
    else:
        print "RAIN-FTL FAIL ({fail})"
