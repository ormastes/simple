{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "model": "zhipuai/glm-5.2",
  "small_model": "zhipuai/glm-5.2",
  "skills": {
    "paths": [".codex/skills"]
  },
  "mcp": {
    "simple-mcp": {
      "type": "local",
      "enabled": true,
      "timeout": 120000,
      "command": [
        "/bin/sh",
        "-lc",
        "cd '/home/ormastes/dev/pub/simple' && exec node '/home/ormastes/dev/pub/simple/bin/mcp_stdio_bridge.js' -- '/home/ormastes/dev/pub/simple/bin/simple' run '/home/ormastes/dev/pub/simple/src/app/mcp/main.spl'"
      ],
      "env": {
        "SIMPLE_LOG": "error",
        "RUST_LOG": "error",
        "SIMPLE_LIB": "/home/ormastes/dev/pub/simple/src"
      }
    },
    "simple-lsp-mcp": {
      "type": "local",
      "enabled": true,
      "timeout": 120000,
      "command": [
        "/bin/sh",
        "-lc",
        "cd '/home/ormastes/dev/pub/simple' && exec node '/home/ormastes/dev/pub/simple/bin/mcp_stdio_bridge.js' -- '/home/ormastes/dev/pub/simple/bin/simple' run '/home/ormastes/dev/pub/simple/src/app/simple_lsp_mcp/main.spl'"
      ],
      "env": {
        "SIMPLE_LOG": "error",
        "RUST_LOG": "error",
        "SIMPLE_LIB": "/home/ormastes/dev/pub/simple/src"
      }
    },
    "stitch": {
      "type": "local",
      "enabled": true,
      "command": [
        "/bin/sh",
        "-lc",
        "cd '/home/ormastes/dev/pub/simple' && exec node '/home/ormastes/dev/pub/simple/bin/mcp_stdio_bridge.js' -- node '/home/ormastes/dev/pub/simple/bin/codex_stitch_mcp.js'"
      ]
    }
  },
  "experimental": {
    "mcp_timeout": 120000
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "external_directory": { "*": "allow" },
    "edit": "ask",
    "bash": {
      "*": "ask",
      "bin/simple": "allow",
      "bin/simple *": "allow",
      "./bin/simple *": "allow",
      "sh scripts/*": "allow",
      "sh *": "allow",
      "git *": "allow",
      "jj *": "allow",
      "node *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "rg *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "find *": "allow"
    }
  }
}
