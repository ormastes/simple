# MDSOC layer visibility audit for SimpleOS driver platform.

class LayerBoundary:
    layer_name: text
    layer_level: i64
    allowed_imports: text
    violation_count: i64

    me check_import(from_layer: text) -> bool:
        if self.allowed_imports == "":
            return false
        self.allowed_imports.contains(from_layer)

    me record_violation() -> i64:
        self.violation_count = self.violation_count + 1
        self.violation_count

    me summary() -> text:
        "[layer-boundary] name=" + self.layer_name +
            " level=" + self.layer_level.to_text() +
            " allowed=" + self.allowed_imports +
            " violations=" + self.violation_count.to_text()

impl LayerBoundary:
    static fn kernel() -> LayerBoundary:
        LayerBoundary(layer_name: "kernel", layer_level: 0, allowed_imports: "", violation_count: 0)

    static fn service() -> LayerBoundary:
        LayerBoundary(layer_name: "service", layer_level: 1, allowed_imports: "kernel", violation_count: 0)

    static fn driver() -> LayerBoundary:
        LayerBoundary(layer_name: "driver", layer_level: 2, allowed_imports: "kernel,service", violation_count: 0)

    static fn app() -> LayerBoundary:
        LayerBoundary(layer_name: "app", layer_level: 3, allowed_imports: "kernel,service,driver", violation_count: 0)

class ImportViolation:
    count: i64
    v0_source: text
    v0_target: text
    v0_source_layer: text
    v0_target_layer: text
    v1_source: text
    v1_target: text
    v1_source_layer: text
    v1_target_layer: text
    v2_source: text
    v2_target: text
    v2_source_layer: text
    v2_target_layer: text
    v3_source: text
    v3_target: text
    v3_source_layer: text
    v3_target_layer: text
    v4_source: text
    v4_target: text
    v4_source_layer: text
    v4_target_layer: text
    v5_source: text
    v5_target: text
    v5_source_layer: text
    v5_target_layer: text
    v6_source: text
    v6_target: text
    v6_source_layer: text
    v6_target_layer: text
    v7_source: text
    v7_target: text
    v7_source_layer: text
    v7_target_layer: text

    me add(source: text, target: text, src_layer: text, tgt_layer: text) -> text:
        if self.count >= 8:
            return "full"
        if self.count == 0:
            self.v0_source = source
            self.v0_target = target
            self.v0_source_layer = src_layer
            self.v0_target_layer = tgt_layer
        elif self.count == 1:
            self.v1_source = source
            self.v1_target = target
            self.v1_source_layer = src_layer
            self.v1_target_layer = tgt_layer
        elif self.count == 2:
            self.v2_source = source
            self.v2_target = target
            self.v2_source_layer = src_layer
            self.v2_target_layer = tgt_layer
        elif self.count == 3:
            self.v3_source = source
            self.v3_target = target
            self.v3_source_layer = src_layer
            self.v3_target_layer = tgt_layer
        elif self.count == 4:
            self.v4_source = source
            self.v4_target = target
            self.v4_source_layer = src_layer
            self.v4_target_layer = tgt_layer
        elif self.count == 5:
            self.v5_source = source
            self.v5_target = target
            self.v5_source_layer = src_layer
            self.v5_target_layer = tgt_layer
        elif self.count == 6:
            self.v6_source = source
            self.v6_target = target
            self.v6_source_layer = src_layer
            self.v6_target_layer = tgt_layer
        elif self.count == 7:
            self.v7_source = source
            self.v7_target = target
            self.v7_source_layer = src_layer
            self.v7_target_layer = tgt_layer
        self.count = self.count + 1
        ""

    me has_violations() -> bool:
        self.count > 0

    me report() -> text:
        if self.count == 0:
            return "[violations] none"
        var out = "[violations] count=" + self.count.to_text() + "\n"
        if self.count > 0:
            out = out + "  v0: " + self.v0_source_layer + "/" + self.v0_source + " -> " + self.v0_target_layer + "/" + self.v0_target + "\n"
        if self.count > 1:
            out = out + "  v1: " + self.v1_source_layer + "/" + self.v1_source + " -> " + self.v1_target_layer + "/" + self.v1_target + "\n"
        if self.count > 2:
            out = out + "  v2: " + self.v2_source_layer + "/" + self.v2_source + " -> " + self.v2_target_layer + "/" + self.v2_target + "\n"
        if self.count > 3:
            out = out + "  v3: " + self.v3_source_layer + "/" + self.v3_source + " -> " + self.v3_target_layer + "/" + self.v3_target + "\n"
        if self.count > 4:
            out = out + "  v4: " + self.v4_source_layer + "/" + self.v4_source + " -> " + self.v4_target_layer + "/" + self.v4_target + "\n"
        if self.count > 5:
            out = out + "  v5: " + self.v5_source_layer + "/" + self.v5_source + " -> " + self.v5_target_layer + "/" + self.v5_target + "\n"
        if self.count > 6:
            out = out + "  v6: " + self.v6_source_layer + "/" + self.v6_source + " -> " + self.v6_target_layer + "/" + self.v6_target + "\n"
        if self.count > 7:
            out = out + "  v7: " + self.v7_source_layer + "/" + self.v7_source + " -> " + self.v7_target_layer + "/" + self.v7_target + "\n"
        out

impl ImportViolation:
    static fn create() -> ImportViolation:
        ImportViolation(
            count: 0,
            v0_source: "", v0_target: "", v0_source_layer: "", v0_target_layer: "",
            v1_source: "", v1_target: "", v1_source_layer: "", v1_target_layer: "",
            v2_source: "", v2_target: "", v2_source_layer: "", v2_target_layer: "",
            v3_source: "", v3_target: "", v3_source_layer: "", v3_target_layer: "",
            v4_source: "", v4_target: "", v4_source_layer: "", v4_target_layer: "",
            v5_source: "", v5_target: "", v5_source_layer: "", v5_target_layer: "",
            v6_source: "", v6_target: "", v6_source_layer: "", v6_target_layer: "",
            v7_source: "", v7_target: "", v7_source_layer: "", v7_target_layer: ""
        )

class LayerAuditResult:
    kernel_modules: i64
    service_modules: i64
    driver_modules: i64
    app_modules: i64
    total_imports: i64
    valid_imports: i64
    violation_count: i64
    violations: ImportViolation
    audit_timestamp: i64

    me record_valid(from_layer: text, to_layer: text) -> i64:
        self.total_imports = self.total_imports + 1
        self.valid_imports = self.valid_imports + 1
        self.valid_imports

    me record_violation(source: text, target: text, src_layer: text, tgt_layer: text) -> text:
        self.total_imports = self.total_imports + 1
        self.violation_count = self.violation_count + 1
        self.violations.add(source, target, src_layer, tgt_layer)

    me is_clean() -> bool:
        self.violation_count == 0

    me summary() -> text:
        "[layer-audit] kernel=" + self.kernel_modules.to_text() +
            " service=" + self.service_modules.to_text() +
            " driver=" + self.driver_modules.to_text() +
            " app=" + self.app_modules.to_text() +
            " imports=" + self.total_imports.to_text() +
            " valid=" + self.valid_imports.to_text() +
            " violations=" + self.violation_count.to_text()

    me full_report() -> text:
        self.summary() + "\n" + self.violations.report()

impl LayerAuditResult:
    static fn create() -> LayerAuditResult:
        LayerAuditResult(
            kernel_modules: 0,
            service_modules: 0,
            driver_modules: 0,
            app_modules: 0,
            total_imports: 0,
            valid_imports: 0,
            violation_count: 0,
            violations: ImportViolation.create(),
            audit_timestamp: 0
        )
