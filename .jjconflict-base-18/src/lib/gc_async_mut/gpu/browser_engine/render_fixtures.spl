    html.contains("display/box/float/clear test")

fn br_render_solid_pixels(width: i32, height: i32, color: u32) -> [u32]:
    [color; width * height]

fn br_render_simple_border_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    val w = if width > 8: width - 8 else: width
    val h = if height > 8: height - 8 else: height
    pixels = br_stroke_rect(pixels, width, height, 4, 4, w, h, 0xFFFF0000u32)
    pixels

fn br_render_acid2_smoke_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, width - 8, height - 8, 0xFFFFFF00u32)
    pixels = br_stroke_rect(pixels, width, height, 8, 8, width - 16, height - 16, 0xFF000000u32)
    pixels = br_fill_rect(pixels, width, height, width / 3, height / 3, width / 8, height / 8, 0xFF000000u32)
    pixels = br_fill_rect(pixels, width, height, (width * 2) / 3, height / 3, width / 8, height / 8, 0xFF000000u32)
    pixels

fn br_render_acid1_smoke_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFF0000FFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 4, 4, width - 8, height - 8, 0xFFFFFFFFu32)
    pixels = br_fill_rect(pixels, width, height, 12, 12, width / 4, height - 24, 0xFFCC0000u32)
    pixels = br_fill_rect(pixels, width, height, width / 3, 12, width / 4, height / 3, 0xFFFFCC00u32)
    pixels = br_fill_rect(pixels, width, height, width / 3, height / 2, width / 4, height / 4, 0xFF000000u32)
    pixels

