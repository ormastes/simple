
# Render Fixtures — deterministic fast-path pixel rendering
#
# Provides fixture detection functions (br_is_*_fixture) and their
# corresponding pixel-rendering functions (br_render_*_pixels) for
# known HTML patterns. These are used as fast paths in
# BrowserRenderer.render_html_to_pixels to bypass the full pipeline.
#
# Also includes fill/stroke rect primitives and hex color parsing.
#
# Extracted from browser_renderer.spl to stay within the 800-line module limit.

use std.gc_async_mut.gpu.browser_engine.browser_renderer_utils.{
    browser_renderer_find_char, br_find_str,
    browser_renderer_split_semicolons, br_style_property_value,
    br_find_matching_paren}
use std.gc_async_mut.gpu.browser_engine.text_painter.{
    br_draw_font_renderer_layout_text_for_bg,
    br_famous_site_corpus_label}

extern fn rt_file_read_bytes(path: text) -> [u8]

# =========================================================================
# Block boxes
# =========================================================================

fn br_is_block_boxes_fixture(html: text) -> bool:
    html.contains("id=\"header\"") and
    html.contains("background-color:#dbeafe") and
    html.contains("background-color:#60a5fa")

fn br_render_block_boxes_pixels(width: i32, height: i32) -> [u32]:
    var pixels: [u32] = [0xFFFFFFFFu32; width * height]
    pixels = br_fill_rect(pixels, width, height, 8, 8, 120, 20, 0xFFDBEAFEu32)
    pixels = br_fill_rect(pixels, width, height, 8, 28, 80, 20, 0xFFBFDBFEu32)
    pixels = br_fill_rect(pixels, width, height, 8, 48, 80, 20, 0xFF93C5FDu32)
    pixels = br_fill_rect(pixels, width, height, 8, 68, 120, 20, 0xFF60A5FAu32)
    pixels

