# Security core types for audit logging, events, and security context.

use std.nogc_sync_mut.io.time_ops.{current_time_ms}
use std.crypto.hmac.{hmac_sha256_bytes}
use std.common.crypto.constant_time.{constant_time_compare}
use std.common.crypto.types.{bytes_to_hex, text_to_bytes}

extern fn rt_random_hex(length: i64) -> text

## Security event types for audit logging.
enum SecurityEvent:
    AuthSuccess(user: text, peer: text)
    AuthFailure(user: text, peer: text, reason: text)
    AccessDenied(resource: text, capability: text, peer: text)
    CsrfViolation(peer: text, path: text)
    RateLimitHit(peer: text, path: text)
    InputSanitized(field: text, original_len: i64)
    SessionCreated(session_id: text, peer: text)
    SessionExpired(session_id: text)
    CapabilityDenied(capability: text, window_id: text)
    RequestProcessed(path: text, duration_ms: i64, status: i64)

## Severity levels for security events.
enum SecuritySeverity:
    Info
    Warning
    Critical

## A single structured audit log entry.
##
## Hash-chain fields (`seq`, `prev_hash`, `entry_hash`) are populated by
## `audit_chain_append` (see `src/lib/common/security/audit_chain.spl`).
## `AuditEntry.new(...)` leaves them at zero defaults — direct callers of
## `log_security_event` (non-chained path) will see seq=0 / zero hashes.
class AuditEntry:
    timestamp_ms: i64
    event: SecurityEvent
    correlation_id: text
    module_path: text
    severity: SecuritySeverity
    seq: i64                  # NEW — monotonic 1-based; 0 means "not chained"
    prev_hash: [u8]           # NEW — sha256 of previous entry's entry_hash; 32 bytes
    entry_hash: [u8]          # NEW — sha256(seq_be || ts_be || sev || event_json || prev_hash)

    static fn new(event: SecurityEvent, correlation_id: text, module_path: text) -> AuditEntry:
        AuditEntry(
            timestamp_ms: time_now_ms(),
            event: event,
            correlation_id: correlation_id,
            module_path: module_path,
            severity: severity_for_event(event),
            seq: 0,
            prev_hash: _zero_hash_32(),
            entry_hash: _zero_hash_32()
        )

## Returns a 32-byte zero list — used as the genesis prev_hash and as the
## default for non-chained AuditEntry construction.
fn _zero_hash_32() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 32:
        out.push(0)
        i = i + 1
    out

## Security context carried through a request/session lifecycle.
class SecurityContext:
    peer_addr: text
    session_id: text
    user_id: text
    correlation_id: text
    capabilities: List<text>

    static fn anonymous(peer_addr: text) -> SecurityContext:
        SecurityContext(
            peer_addr: peer_addr,
            session_id: "",
            user_id: "",
            correlation_id: generate_correlation_id(),
            capabilities: []
        )

    fn is_authenticated() -> bool:
        self.user_id != ""

    fn has_capability(cap: text) -> bool:
        self.capabilities.contains(cap)

## Display-only permission snapshot sent to remote UI clients.
##
## This is never an authorization token. Clients may use it to hide or disable
## UI, but every privileged action must still call a server-side gate that
## reconstructs and checks a SecurityContext.
class PermissionSnapshot:
    subject: text
    scopes: List<text>
    ui_hints: Dict<text, bool>
    policy_version: i64
    expires_at_ms: i64
    authority: text
    server_gate_required: bool

    static fn display_only(subject: text, scopes: List<text>, ui_hints: Dict<text, bool>, policy_version: i64, expires_at_ms: i64) -> PermissionSnapshot:
        PermissionSnapshot(
            subject: subject,
            scopes: scopes,
            ui_hints: ui_hints,
            policy_version: policy_version,
            expires_at_ms: expires_at_ms,
            authority: "display_only",
            server_gate_required: true
        )

    fn is_display_only() -> bool:
        self.authority == "display_only" and self.server_gate_required

    fn is_expired(now_ms: i64) -> bool:
        self.expires_at_ms <= now_ms

    fn has_scope(scope: text) -> bool:
        self.scopes.contains(scope)

    fn can_show(key: text) -> bool:
        val maybe_allowed = self.ui_hints.get(key)
        if val allowed = maybe_allowed:
            allowed
        else:
            false

## Remote request headers that are safe to propagate into context assembly.
##
## Raw authorization remains an input to server-side reconstruction; baggage is
## limited to non-authoritative metadata and must not contain roles or secrets.
class RemoteSecurityContextHeaders:
    authorization: text
    traceparent: text
    tenant_id: text
    policy_version: text
    request_class: text

    static fn empty() -> RemoteSecurityContextHeaders:
        RemoteSecurityContextHeaders(
            authorization: "",
            traceparent: "",
            tenant_id: "",
            policy_version: "",
            request_class: ""
        )

    fn has_authorization() -> bool:
        self.authorization != ""

    fn safe_baggage() -> Dict<text, text>:
        {
            "tenant_id": self.tenant_id,
            "policy_version": self.policy_version,
            "request_class": self.request_class
        }

fn remote_security_headers_from_pairs(headers: [(text, text)]) -> RemoteSecurityContextHeaders:
    var authorization = ""
    var traceparent = ""
    var tenant_id = ""
    var policy_version = ""
    var request_class = ""

    for pair in headers:
        val name = pair.0.lower()
        val value = pair.1
        if name == "authorization":
            authorization = value
        elif name == "traceparent":
            traceparent = value
        elif name == "x-simple-tenant-id":
            tenant_id = value
        elif name == "x-simple-policy-version":
            policy_version = value
        elif name == "x-simple-request-class":
            request_class = value

    RemoteSecurityContextHeaders(
        authorization: authorization,
        traceparent: traceparent,
        tenant_id: tenant_id,
        policy_version: policy_version,
        request_class: request_class
    )

fn remote_security_session_id_from_pairs(headers: [(text, text)]) -> text:
    for pair in headers:
        if pair.0.lower() == "x-simple-session-id":
            return pair.1
    return ""

fn anonymous_remote_security_context(headers: RemoteSecurityContextHeaders, peer_addr: text) -> SecurityContext:
    reconstruct_remote_security_context(headers, peer_addr, "", "", [])

## Validated identity extracted from a server-signed remote token.
class RemoteSecurityValidatedIdentity:
    session_id: text
    user_id: text
    capabilities: List<text>
    expires_at_ms: i64

    static fn invalid() -> RemoteSecurityValidatedIdentity:
        RemoteSecurityValidatedIdentity(
            session_id: "",
            user_id: "",
            capabilities: [],
            expires_at_ms: 0
        )

    fn is_valid() -> bool:
        self.session_id != "" and self.user_id != ""

    fn is_expired(now_ms: i64) -> bool:
        self.expires_at_ms <= now_ms

class RemoteSecuritySigningKeyRing:
    active_key_id: text
    keys: Dict<text, text>

    static fn empty() -> RemoteSecuritySigningKeyRing:
        val empty_keys: Dict<text, text> = {}
        var ring = RemoteSecuritySigningKeyRing.new("__empty__", "")
        ring.active_key_id = ""
        ring.keys = empty_keys
        ring

    static fn new(active_key_id: text, signing_key: text) -> RemoteSecuritySigningKeyRing:
        RemoteSecuritySigningKeyRing(
            active_key_id: active_key_id,
            keys: {active_key_id: signing_key}
        )

    me add_key(key_id: text, signing_key: text):
        self.keys = self.keys.set(key_id, signing_key)

    me rotate_key(key_id: text, signing_key: text):
        self.keys = self.keys.set(key_id, signing_key)
        self.active_key_id = key_id

    me retire_key(key_id: text):
        if self.keys.has(key_id):
            self.keys = self.keys.set(key_id, "")
        if self.active_key_id == key_id:
            self.active_key_id = ""

    me merge_from(peer: RemoteSecuritySigningKeyRing):
        for key_id in peer.keys.keys():
            self.keys = self.keys.set(key_id, peer.keys[key_id])
        if peer.active_key_id != "":
            self.active_key_id = peer.active_key_id

    fn export_sdn() -> text:
        var lines: [text] = ["remote_security_key_ring:", "  active: {self.active_key_id}"]
        for key_id in self.keys.keys():
            lines.push("  key|{key_id}|{self.keys[key_id]}")
        lines.join("\n")

    static fn from_sdn(sdn: text) -> RemoteSecuritySigningKeyRing:
        var ring = RemoteSecuritySigningKeyRing.empty()
        ring.load_sdn(sdn)
        ring

    me load_sdn(sdn: text):
        for raw_line in sdn.split("\n"):
            val line = raw_line.trim()
            if line.starts_with("active:"):
                self.active_key_id = line[7:].trim()
            elif line.starts_with("key|"):
                val parts = line.split("|")
                if parts.len() >= 3:
                    self.keys = self.keys.set(parts[1], parts[2])

    fn active_key() -> text:
        if self.keys.has(self.active_key_id):
            return self.keys[self.active_key_id]
        ""

    fn key_for(key_id: text) -> text:
        if self.keys.has(key_id):
            return self.keys[key_id]
        ""

class RemoteSecuritySession:
    session_id: text
    user_id: text
    capabilities: List<text>
    expires_at_ms: i64
    revoked: bool

    fn is_active(now_ms: i64) -> bool:
        not self.revoked and self.expires_at_ms > now_ms

    fn refreshed(expires_at_ms: i64) -> RemoteSecuritySession:
        RemoteSecuritySession(
            session_id: self.session_id,
            user_id: self.user_id,
            capabilities: self.capabilities,
            expires_at_ms: expires_at_ms,
            revoked: self.revoked
        )

class RemoteSecuritySessionStore:
    sessions: Dict<text, RemoteSecuritySession>

    static fn new() -> RemoteSecuritySessionStore:
        val empty_sessions: Dict<text, RemoteSecuritySession> = {}
        RemoteSecuritySessionStore(sessions: empty_sessions)

    me create_session(session_id: text, user_id: text, capabilities: List<text>, expires_at_ms: i64):
        self.sessions = self.sessions.set(session_id, RemoteSecuritySession(
            session_id: session_id,
            user_id: user_id,
            capabilities: capabilities,
            expires_at_ms: expires_at_ms,
            revoked: false
        ))

    me save_session(session: RemoteSecuritySession):
        self.sessions = self.sessions.set(session.session_id, session)

    fn export_sdn() -> text:
        var lines: [text] = ["remote_security_sessions:"]
        for session_id in self.sessions.keys():
            val session = self.sessions[session_id]
            val revoked = if session.revoked: "true" else: "false"
            lines.push("  session|{session.session_id}|{session.user_id}|{session.expires_at_ms}|{revoked}|{session.capabilities.join(\",\")}")
        lines.join("\n")

    static fn from_sdn(sdn: text) -> RemoteSecuritySessionStore:
        var store = RemoteSecuritySessionStore.new()
        store.load_sdn(sdn)
        store

    me load_sdn(sdn: text):
        for raw_line in sdn.split("\n"):
            val line = raw_line.trim()
            if line.starts_with("session|"):
                val parts = line.split("|")
                if parts.len() >= 6:
                    val capabilities = if parts[5] == "": [] else: parts[5].split(",")
                    self.save_session(RemoteSecuritySession(
                        session_id: parts[1],
                        user_id: parts[2],
                        capabilities: capabilities,
                        expires_at_ms: parts[3].to_i64() ?? 0,
                        revoked: parts[4] == "true"
                    ))

    me merge_from(peer: RemoteSecuritySessionStore):
        for session_id in peer.sessions.keys():
            val incoming = peer.sessions[session_id]
            if not self.sessions.has(session_id):
                self.save_session(incoming)
            else:
                val local = self.sessions[session_id]
                if incoming.revoked:
                    self.save_session(incoming)
                elif not local.revoked and incoming.expires_at_ms > local.expires_at_ms:
                    self.save_session(incoming)

    fn lookup_session(session_id: text) -> RemoteSecuritySession?:
        self.sessions.get(session_id)

    fn lookup_active_session(session_id: text, now_ms: i64) -> RemoteSecuritySession?:
        if self.sessions.has(session_id):
            val session = self.sessions[session_id]
            if session.is_active(now_ms):
                return session
        nil

    me refresh_session(session_id: text, expires_at_ms: i64) -> bool:
        if self.sessions.has(session_id):
            val session = self.sessions[session_id]
            if not session.revoked:
                self.sessions = self.sessions.set(session_id, session.refreshed(expires_at_ms))
                return true
        false

    me revoke_session(session_id: text) -> bool:
        if self.sessions.has(session_id):
            val session = self.sessions[session_id]
            self.sessions = self.sessions.set(session_id, RemoteSecuritySession(
                session_id: session.session_id,
                user_id: session.user_id,
                capabilities: session.capabilities,
                expires_at_ms: session.expires_at_ms,
                revoked: true
            ))
            return true
        false

class RemoteSecuritySessionStoreAdapter:
    """Adapter boundary for replicated remote SecurityContext session storage.

    The local store remains useful for tests and single-process tools. Hosted
    production adapters should keep the same operation surface while backing it
    with Redis, quorum storage, or another replicated service.
    """
    backend: text
    store_namespace: text
    store: RemoteSecuritySessionStore

    static fn memory() -> RemoteSecuritySessionStoreAdapter:
        RemoteSecuritySessionStoreAdapter(
            backend: "memory",
            store_namespace: "remote_security",
            store: RemoteSecuritySessionStore.new()
        )

    static fn replicated(backend: text, store_namespace: text) -> RemoteSecuritySessionStoreAdapter:
        RemoteSecuritySessionStoreAdapter(
            backend: backend,
            store_namespace: store_namespace,
            store: RemoteSecuritySessionStore.new()
        )

    me save_session(session: RemoteSecuritySession):
        self.store.save_session(session)

    me create_session(session_id: text, user_id: text, capabilities: List<text>, expires_at_ms: i64):
        self.store.create_session(session_id, user_id, capabilities, expires_at_ms)

    fn lookup_session(session_id: text) -> RemoteSecuritySession?:
        self.store.lookup_session(session_id)

    fn lookup_active_session(session_id: text, now_ms: i64) -> RemoteSecuritySession?:
        self.store.lookup_active_session(session_id, now_ms)

    me refresh_session(session_id: text, expires_at_ms: i64) -> bool:
        self.store.refresh_session(session_id, expires_at_ms)

    me revoke_session(session_id: text) -> bool:
        self.store.revoke_session(session_id)

    me merge_from(peer: RemoteSecuritySessionStoreAdapter):
        self.store.merge_from(peer.store)

    fn export_sdn() -> text:
        var lines: [text] = [
            "remote_security_session_adapter:",
            "  backend: {self.backend}",
            "  namespace: {self.store_namespace}",
            self.store.export_sdn()
        ]
        lines.join("\n")

    static fn from_sdn(sdn: text) -> RemoteSecuritySessionStoreAdapter:
        var adapter = RemoteSecuritySessionStoreAdapter.memory()
        adapter.load_sdn(sdn)
        adapter

    me load_sdn(sdn: text):
        for raw_line in sdn.split("\n"):
            val line = raw_line.trim()
            if line.starts_with("backend:"):
                self.backend = line[8:].trim()
            elif line.starts_with("namespace:"):
                self.store_namespace = line[10:].trim()
        self.store.load_sdn(sdn)

class RemoteSecurityKeyRolloutProvider:
    """Opaque key rollout adapter for KMS/HSM-backed signing.

    The provider stores key ids and opaque handles, not raw signing keys. Tests
    and external adapters register accepted signatures for a payload; hosted
    production wiring should delegate the verification check to KMS/HSM.
    """
    active_key_id: text
    key_handles: Dict<text, text>
    accepted_signatures: Dict<text, bool>

    static fn empty() -> RemoteSecurityKeyRolloutProvider:
        val handles: Dict<text, text> = {}
        val signatures: Dict<text, bool> = {}
        RemoteSecurityKeyRolloutProvider(
            active_key_id: "",
            key_handles: handles,
            accepted_signatures: signatures
        )

    static fn with_active_key(key_id: text, key_handle: text) -> RemoteSecurityKeyRolloutProvider:
        var provider = RemoteSecurityKeyRolloutProvider.empty()
        provider.add_key(key_id, key_handle)
        provider.active_key_id = key_id
        provider

    me add_key(key_id: text, key_handle: text):
        self.key_handles = self.key_handles.set(key_id, key_handle)

    me rotate_key(key_id: text, key_handle: text):
        self.add_key(key_id, key_handle)
        self.active_key_id = key_id

    me retire_key(key_id: text):
        if self.key_handles.has(key_id):
            self.key_handles = self.key_handles.set(key_id, "")
        if self.active_key_id == key_id:
            self.active_key_id = ""

    fn key_handle_for(key_id: text) -> text:
        if self.key_handles.has(key_id):
            return self.key_handles[key_id]
        ""

    fn signature_key(key_id: text, payload: text, signature: text) -> text:
        "{key_id}|{payload}|{signature}"

    me allow_external_signature(key_id: text, payload: text, signature: text):
        self.accepted_signatures = self.accepted_signatures.set(self.signature_key(key_id, payload, signature), true)

    fn verify_external_signature(key_id: text, payload: text, signature: text) -> bool:
        if self.key_handle_for(key_id) == "":
            return false
        self.accepted_signatures.get(self.signature_key(key_id, payload, signature)) ?? false

    fn export_sdn() -> text:
        var lines: [text] = ["remote_security_key_rollout_provider:", "  active: {self.active_key_id}"]
        for key_id in self.key_handles.keys():
            lines.push("  key_handle|{key_id}|{self.key_handles[key_id]}")
        lines.join("\n")

fn remote_security_bearer_token(headers: RemoteSecurityContextHeaders) -> text:
    val authorization = headers.authorization.trim()
    if authorization.starts_with("Bearer "):
        return authorization[7:].trim()
    return ""

fn remote_security_token_payload(session_id: text, user_id: text, expires_at_ms: i64, capabilities: List<text>) -> text:
    val scopes = capabilities.join(",")
    "{session_id}|{user_id}|{expires_at_ms}|{scopes}"

fn remote_security_hmac_sha256_hex(signing_key: text, payload: text) -> text:
    bytes_to_hex(hmac_sha256_bytes(text_to_bytes(signing_key), text_to_bytes(payload)))

fn sign_remote_security_token(signing_key: text,
                              session_id: text,
                              user_id: text,
                              expires_at_ms: i64,
                              capabilities: List<text>) -> text:
    val payload = remote_security_token_payload(session_id, user_id, expires_at_ms, capabilities)
    val signature = remote_security_hmac_sha256_hex(signing_key, payload)
    "simple-v1|{payload}|{signature}"

fn remote_security_token_payload_v2(key_id: text, session_id: text, user_id: text, expires_at_ms: i64, capabilities: List<text>) -> text:
    val scopes = capabilities.join(",")
    "{key_id}|{session_id}|{user_id}|{expires_at_ms}|{scopes}"

fn sign_remote_security_token_with_key_id(key_id: text,
                                          signing_key: text,
                                          session_id: text,
                                          user_id: text,
                                          expires_at_ms: i64,
                                          capabilities: List<text>) -> text:
    val payload = remote_security_token_payload_v2(key_id, session_id, user_id, expires_at_ms, capabilities)
    val signature = remote_security_hmac_sha256_hex(signing_key, payload)
    "simple-v2|{payload}|{signature}"

fn sign_remote_security_token_with_key_ring(key_ring: RemoteSecuritySigningKeyRing,
                                            session_id: text,
                                            user_id: text,
                                            expires_at_ms: i64,
                                            capabilities: List<text>) -> text:
    sign_remote_security_token_with_key_id(key_ring.active_key_id, key_ring.active_key(), session_id, user_id, expires_at_ms, capabilities)

fn remote_security_token_with_external_signature(key_id: text,
                                                 session_id: text,
                                                 user_id: text,
                                                 expires_at_ms: i64,
                                                 capabilities: List<text>,
                                                 signature: text) -> text:
    val payload = remote_security_token_payload_v2(key_id, session_id, user_id, expires_at_ms, capabilities)
    "simple-v2|{payload}|{signature}"

fn validate_remote_security_token(headers: RemoteSecurityContextHeaders,
                                  session_id: text,
                                  signing_key: text,
                                  now_ms: i64) -> RemoteSecurityValidatedIdentity:
    if signing_key == "":
        return RemoteSecurityValidatedIdentity.invalid()
    val bearer = remote_security_bearer_token(headers)
    if bearer == "":
        return RemoteSecurityValidatedIdentity.invalid()
    val parts = bearer.split("|")
    if parts.len() != 6:
        return RemoteSecurityValidatedIdentity.invalid()
    if parts[0] != "simple-v1":
        return RemoteSecurityValidatedIdentity.invalid()
    val token_session_id = parts[1]
    val user_id = parts[2]
    val expires_at_ms = parts[3].to_i64() ?? 0
    val scopes = parts[4]
    val signature = parts[5]
    if token_session_id == "" or user_id == "":
        return RemoteSecurityValidatedIdentity.invalid()
    if session_id != "" and session_id != token_session_id:
        return RemoteSecurityValidatedIdentity.invalid()
    val capabilities = if scopes == "": [] else: scopes.split(",")
    val payload = remote_security_token_payload(token_session_id, user_id, expires_at_ms, capabilities)
    val expected = remote_security_hmac_sha256_hex(signing_key, payload)
    if not constant_time_compare(expected, signature):
        return RemoteSecurityValidatedIdentity.invalid()
    val identity = RemoteSecurityValidatedIdentity(
        session_id: token_session_id,
        user_id: user_id,
        capabilities: capabilities,
        expires_at_ms: expires_at_ms
    )
    if identity.is_expired(now_ms):
        return RemoteSecurityValidatedIdentity.invalid()
    identity

fn validate_remote_security_token_with_key_ring(headers: RemoteSecurityContextHeaders,
                                                session_id: text,
                                                key_ring: RemoteSecuritySigningKeyRing,
                                                session_store: RemoteSecuritySessionStore,
                                                now_ms: i64) -> RemoteSecurityValidatedIdentity:
    val bearer = remote_security_bearer_token(headers)
    if bearer == "":
        return RemoteSecurityValidatedIdentity.invalid()
    val parts = bearer.split("|")
    if parts.len() != 7:
        return RemoteSecurityValidatedIdentity.invalid()
    if parts[0] != "simple-v2":
        return RemoteSecurityValidatedIdentity.invalid()

    val key_id = parts[1]
    val token_session_id = parts[2]
    val user_id = parts[3]
    val expires_at_ms = parts[4].to_i64() ?? 0
    val scopes = parts[5]
    val signature = parts[6]
    if key_id == "" or token_session_id == "" or user_id == "":
        return RemoteSecurityValidatedIdentity.invalid()
    if session_id != "" and session_id != token_session_id:
        return RemoteSecurityValidatedIdentity.invalid()

    val signing_key = key_ring.key_for(key_id)
    if signing_key == "":
        return RemoteSecurityValidatedIdentity.invalid()

    val capabilities = if scopes == "": [] else: scopes.split(",")
    val payload = remote_security_token_payload_v2(key_id, token_session_id, user_id, expires_at_ms, capabilities)
    val expected = remote_security_hmac_sha256_hex(signing_key, payload)
    if not constant_time_compare(expected, signature):
        return RemoteSecurityValidatedIdentity.invalid()

    if expires_at_ms <= now_ms:
        return RemoteSecurityValidatedIdentity.invalid()

    if session_store.sessions.has(token_session_id):
        val session = session_store.sessions[token_session_id]
        if not session.is_active(now_ms):
            return RemoteSecurityValidatedIdentity.invalid()
        if session.user_id != user_id:
            return RemoteSecurityValidatedIdentity.invalid()
        return RemoteSecurityValidatedIdentity(
            session_id: token_session_id,
            user_id: user_id,
            capabilities: session.capabilities,
            expires_at_ms: expires_at_ms
        )

    RemoteSecurityValidatedIdentity.invalid()

fn validate_remote_security_token_with_adapters(headers: RemoteSecurityContextHeaders,
                                                session_id: text,
                                                key_provider: RemoteSecurityKeyRolloutProvider,
                                                session_adapter: RemoteSecuritySessionStoreAdapter,
                                                now_ms: i64) -> RemoteSecurityValidatedIdentity:
    val bearer = remote_security_bearer_token(headers)
    if bearer == "":
        return RemoteSecurityValidatedIdentity.invalid()
    val parts = bearer.split("|")
    if parts.len() != 7:
        return RemoteSecurityValidatedIdentity.invalid()
    if parts[0] != "simple-v2":
        return RemoteSecurityValidatedIdentity.invalid()

    val key_id = parts[1]
    val token_session_id = parts[2]
    val user_id = parts[3]
    val expires_at_ms = parts[4].to_i64() ?? 0
    val scopes = parts[5]
    val signature = parts[6]
    if key_id == "" or token_session_id == "" or user_id == "":
        return RemoteSecurityValidatedIdentity.invalid()
    if session_id != "" and session_id != token_session_id:
        return RemoteSecurityValidatedIdentity.invalid()

    val capabilities = if scopes == "": [] else: scopes.split(",")
    val payload = remote_security_token_payload_v2(key_id, token_session_id, user_id, expires_at_ms, capabilities)
    if not key_provider.verify_external_signature(key_id, payload, signature):
        return RemoteSecurityValidatedIdentity.invalid()
    if expires_at_ms <= now_ms:
        return RemoteSecurityValidatedIdentity.invalid()

    val session = session_adapter.lookup_active_session(token_session_id, now_ms)
    if session == nil:
        return RemoteSecurityValidatedIdentity.invalid()
    val active = session
    if active.user_id != user_id:
        return RemoteSecurityValidatedIdentity.invalid()
    RemoteSecurityValidatedIdentity(
        session_id: token_session_id,
        user_id: user_id,
        capabilities: active.capabilities,
        expires_at_ms: expires_at_ms
    )

## Validate a remote bearer token against the server signing key. Invalid,
## missing, expired, tampered, or session-mismatched tokens reconstruct an
## anonymous context while preserving peer/session transport metadata.
fn validate_remote_security_context(headers: RemoteSecurityContextHeaders,
                                    peer_addr: text,
                                    session_id: text,
                                    signing_key: text,
                                    now_ms: i64) -> SecurityContext:
    val identity = validate_remote_security_token(headers, session_id, signing_key, now_ms)
    if identity.is_valid():
        return reconstruct_remote_security_context(headers, peer_addr, identity.session_id, identity.user_id, identity.capabilities)

    reconstruct_remote_security_context(headers, peer_addr, session_id, "", [])

fn validate_remote_security_context_with_key_ring(headers: RemoteSecurityContextHeaders,
                                                 peer_addr: text,
                                                 session_id: text,
                                                 key_ring: RemoteSecuritySigningKeyRing,
                                                 session_store: RemoteSecuritySessionStore,
                                                 now_ms: i64) -> SecurityContext:
    val identity = validate_remote_security_token_with_key_ring(headers, session_id, key_ring, session_store, now_ms)
    if identity.is_valid():
        return reconstruct_remote_security_context(headers, peer_addr, identity.session_id, identity.user_id, identity.capabilities)

    reconstruct_remote_security_context(headers, peer_addr, session_id, "", [])

fn validate_remote_security_context_with_adapters(headers: RemoteSecurityContextHeaders,
                                                 peer_addr: text,
                                                 session_id: text,
                                                 key_provider: RemoteSecurityKeyRolloutProvider,
                                                 session_adapter: RemoteSecuritySessionStoreAdapter,
                                                 now_ms: i64) -> SecurityContext:
    val identity = validate_remote_security_token_with_adapters(headers, session_id, key_provider, session_adapter, now_ms)
    if identity.is_valid():
        return reconstruct_remote_security_context(headers, peer_addr, identity.session_id, identity.user_id, identity.capabilities)

    reconstruct_remote_security_context(headers, peer_addr, session_id, "", [])

## Reconstructed remote context plus its display-only client snapshot.
class RemoteSecurityContext:
    ctx: SecurityContext
    headers: RemoteSecurityContextHeaders
    snapshot: PermissionSnapshot

    fn server_authoritative() -> bool:
        self.snapshot.is_display_only()

## Reconstruct a server SecurityContext from already-validated identity data.
##
## The client snapshot is deliberately not used as an authority source.
fn reconstruct_remote_security_context(headers: RemoteSecurityContextHeaders, peer_addr: text, session_id: text, user_id: text, capabilities: List<text>) -> SecurityContext:
    if user_id == "":
        return SecurityContext(
            peer_addr: peer_addr,
            session_id: session_id,
            user_id: "",
            correlation_id: generate_correlation_id(),
            capabilities: []
        )

    SecurityContext(
        peer_addr: peer_addr,
        session_id: session_id,
        user_id: user_id,
        correlation_id: generate_correlation_id(),
        capabilities: capabilities
    )

## Configuration for audit logging behavior.
class AuditConfig:
    enabled: bool
    log_file: text
    log_to_stdout: bool
    min_severity: SecuritySeverity
    mask_secrets: bool

    static fn default() -> AuditConfig:
        AuditConfig(
            enabled: true,
            log_file: "tmp/security_audit.log",
            log_to_stdout: false,
            min_severity: SecuritySeverity.Info,
            mask_secrets: true
        )

## Determine severity from event type.
fn severity_for_event(event: SecurityEvent) -> SecuritySeverity:
    """
    Maps security events to their severity level.

    sdoctest:
        val e1 = SecurityEvent.AuthSuccess(user: "u", peer: "p")
        expect(severity_for_event(e1)).to_equal(SecuritySeverity.Info)
        val e2 = SecurityEvent.CsrfViolation(peer: "p", path: "/")
        expect(severity_for_event(e2)).to_equal(SecuritySeverity.Critical)
    """
    match event:
        AuthFailure(_, _, _): SecuritySeverity.Warning
        AccessDenied(_, _, _): SecuritySeverity.Warning
        CsrfViolation(_, _): SecuritySeverity.Critical
        CapabilityDenied(_, _): SecuritySeverity.Warning
        _: SecuritySeverity.Info

## Generate a unique correlation ID for request tracing.
fn generate_correlation_id() -> text:
    val ts = time_now_ms()
    val rand = random_hex(8)
    "{ts}-{rand}"

## Time helper (delegates to runtime).
fn time_now_ms() -> i64:
    current_time_ms()

## Random hex helper (delegates to crypto SFFI).
fn random_hex(bytes: i64) -> text:
    rt_random_hex(bytes)
