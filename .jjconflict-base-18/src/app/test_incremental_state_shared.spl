# Shared Incremental Test State
#
# Canonical internal composition of test cache + dependency graph.

use app.test_cache_shared.{TestCacheEntry}
use app.test_cache_shared.{shared_cache_check_freshness, shared_cache_build_entry, shared_cache_save, shared_cache_load_entries}
use app.test_dep_graph_shared.{SharedDepGraph, shared_dep_graph_new, shared_dep_graph_load}

class IncrementalTestState:
    entries: {text: TestCacheEntry}
    cache_path: text
    dep_graph: SharedDepGraph

fn incremental_test_state_new(cache_path: text, graph_path: text, track_reverse_deps: bool) -> IncrementalTestState:
    IncrementalTestState(
        entries: {},
        cache_path: cache_path,
        dep_graph: shared_dep_graph_new(graph_path, track_reverse_deps)
    )

fn incremental_test_state_load(cache_path: text, graph_path: text, track_reverse_deps: bool) -> IncrementalTestState:
    var entries: {text: TestCacheEntry} = {}
    if cache_path != "":
        entries = shared_cache_load_entries(cache_path)
    IncrementalTestState(
        entries: entries,
        cache_path: cache_path,
        dep_graph: shared_dep_graph_load(graph_path, track_reverse_deps)
    )

impl IncrementalTestState:
    me prepare_test(test_path: text) -> [text]:
        self.dep_graph.analyze_test(test_path)
        self.dep_graph.get_deps(test_path)

    fn get_deps(test_path: text) -> [text]:
        self.dep_graph.get_deps(test_path)

    fn get_affected_tests(source_path: text) -> [text]:
        self.dep_graph.get_affected_tests(source_path)

    fn check_freshness(test_path: text) -> TestCacheEntry:
        val dep_paths = self.prepare_test(test_path)
        shared_cache_check_freshness(self.entries, test_path, dep_paths)

    me record_runner_result(test_path: text, passed: i64, failed: i64, skipped: i64, duration_ms: i64):
        val dep_paths = self.prepare_test(test_path)
        var status = 0
        if failed > 0:
            status = 1
        self.entries[test_path] = shared_cache_build_entry(test_path, dep_paths, status, passed, failed, skipped, duration_ms, "")

    me record_daemon_result(test_path: text, status: i64, passed: i64, failed: i64, skipped: i64, duration_ms: i64, output: text):
        val dep_paths = self.prepare_test(test_path)
        self.entries[test_path] = shared_cache_build_entry(test_path, dep_paths, status, passed, failed, skipped, duration_ms, output)

    me invalidate_all():
        self.entries = {}

    me save():
        if self.cache_path != "":
            shared_cache_save(self.entries, self.cache_path)
        self.dep_graph.save()
