# XSalsa20 / HSalsa20 Known-Answer Tests
#
# Tests xsalsa20_encrypt, xsalsa20_decrypt, and hsalsa20 against:
#   1. NaCl test/box7.c — XSalsa20 keystream on 64 zero bytes (Vector 1)
#   2. Round-trip: encrypt then decrypt == original plaintext (Vector 2)
#   3. Different nonces produce different ciphertexts (Vector 3)
#   4. HSalsa20 known-answer (djb test vector, all-zero nonce-head)
#
# References:
#   DJB, "Extending the Salsa20 nonce" (2008/2011) —
#     https://cr.yp.to/snuffle/xsalsa-20110204.pdf
#   NaCl crypto_stream_xsalsa20 — https://nacl.cr.yp.to/stream.html
#
# NOTE: per memory/feedback_it_block_var_mutation.md, byte-array inputs are
# built in module-level fn helpers so loop pushes persist across calls.
# NOTE: per memory/feedback_compile_mode_false_greens.md this spec is
# verified in interpreter mode only.

use std.spipe.*
use os.crypto.xsalsa20.{hsalsa20, xsalsa20_encrypt, xsalsa20_decrypt}

# ============================================================================
# Hex helpers (module-level)
# ============================================================================

fn _hex_nibble(n: i64) -> text:
    if n == 0: "0"
    else: if n == 1: "1"
    else: if n == 2: "2"
    else: if n == 3: "3"
    else: if n == 4: "4"
    else: if n == 5: "5"
    else: if n == 6: "6"
    else: if n == 7: "7"
    else: if n == 8: "8"
    else: if n == 9: "9"
    else: if n == 10: "a"
    else: if n == 11: "b"
    else: if n == 12: "c"
    else: if n == 13: "d"
    else: if n == 14: "e"
    else: "f"

fn _bytes_hex(b: [u8]) -> text:
    var s = ""
    var i: u64 = 0
    val n = b.len()
    while i < n:
        val byte = b[i].to_i64() & 0xFF
        s = s + _hex_nibble((byte >> 4) & 0xF)
        s = s + _hex_nibble(byte & 0xF)
        i = i + 1
    s

fn _bytes_hex_range(b: [u8], from: u64, to: u64) -> text:
    var s = ""
    var i = from
    while i < to:
        val byte = b[i].to_i64() & 0xFF
        s = s + _hex_nibble((byte >> 4) & 0xF)
        s = s + _hex_nibble(byte & 0xF)
        i = i + 1
    s

# ============================================================================
# Test vector helpers (module-level builders)
# ============================================================================

# NaCl box7.c key (32 bytes):
#   1b27556473e985d462cd51197a9a46c76009549eac6474f206c4ee0844f68389
fn _nacl_key() -> [u8]:
    var k: [u8] = []
    var b: u8 = 0x1bu8
    k.push(b)
    b = 0x27u8
    k.push(b)
    b = 0x55u8
    k.push(b)
    b = 0x64u8
    k.push(b)
    b = 0x73u8
    k.push(b)
    b = 0xe9u8
    k.push(b)
    b = 0x85u8
    k.push(b)
    b = 0xd4u8
    k.push(b)
    b = 0x62u8
    k.push(b)
    b = 0xcdu8
    k.push(b)
    b = 0x51u8
    k.push(b)
    b = 0x19u8
    k.push(b)
    b = 0x7au8
    k.push(b)
    b = 0x9au8
    k.push(b)
    b = 0x46u8
    k.push(b)
    b = 0xc7u8
    k.push(b)
    b = 0x60u8
    k.push(b)
    b = 0x09u8
    k.push(b)
    b = 0x54u8
    k.push(b)
    b = 0x9eu8
    k.push(b)
    b = 0xacu8
    k.push(b)
    b = 0x64u8
    k.push(b)
    b = 0x74u8
    k.push(b)
    b = 0xf2u8
    k.push(b)
    b = 0x06u8
    k.push(b)
    b = 0xc4u8
    k.push(b)
    b = 0xeeu8
    k.push(b)
    b = 0x08u8
    k.push(b)
    b = 0x44u8
    k.push(b)
    b = 0xf6u8
    k.push(b)
    b = 0x83u8
    k.push(b)
    b = 0x89u8
    k.push(b)
    k

# NaCl box7.c nonce (24 bytes):
#   69696ee955b62b73cd62bda875fc73d68219e0036b7a0b37
fn _nacl_nonce() -> [u8]:
    var n: [u8] = []
    var b: u8 = 0x69u8
    n.push(b)
    b = 0x69u8
    n.push(b)
    b = 0x6eu8
    n.push(b)
    b = 0xe9u8
    n.push(b)
    b = 0x55u8
    n.push(b)
    b = 0xb6u8
    n.push(b)
    b = 0x2bu8
    n.push(b)
    b = 0x73u8
    n.push(b)
    b = 0xcdu8
    n.push(b)
    b = 0x62u8
    n.push(b)
    b = 0xbdu8
    n.push(b)
    b = 0xa8u8
    n.push(b)
    b = 0x75u8
    n.push(b)
    b = 0xfcu8
    n.push(b)
    b = 0x73u8
    n.push(b)
    b = 0xd6u8
    n.push(b)
    b = 0x82u8
    n.push(b)
    b = 0x19u8
    n.push(b)
    b = 0xe0u8
    n.push(b)
    b = 0x03u8
    n.push(b)
    b = 0x6bu8
    n.push(b)
    b = 0x7au8
    n.push(b)
    b = 0x0bu8
    n.push(b)
    b = 0x37u8
    n.push(b)
    n

# 64 zero bytes plaintext
fn _zeros64() -> [u8]:
    var p: [u8] = []
    var i: u64 = 0
    while i < 64:
        var b: u8 = 0u8
        p.push(b)
        i = i + 1
    p

# 32 zero bytes for round-trip plaintext
fn _zeros32() -> [u8]:
    var p: [u8] = []
    var i: u64 = 0
    while i < 32:
        var b: u8 = 0u8
        p.push(b)
        i = i + 1
    p

# A second nonce (all zeros, 24 bytes) for nonce-difference test
fn _zero_nonce() -> [u8]:
    var n: [u8] = []
    var i: u64 = 0
    while i < 24:
        var b: u8 = 0u8
        n.push(b)
        i = i + 1
    n

# HSalsa20 test: djb all-zero key + all-zero nonce-head
#   key: 4a5d9d5ba4ce2de1728e3bf480350f25e07e21c947d19e3376f09b3c1e161742
fn _djb_key() -> [u8]:
    var k: [u8] = []
    var b: u8 = 0x4au8
    k.push(b)
    b = 0x5du8
    k.push(b)
    b = 0x9du8
    k.push(b)
    b = 0x5bu8
    k.push(b)
    b = 0xa4u8
    k.push(b)
    b = 0xceu8
    k.push(b)
    b = 0x2du8
    k.push(b)
    b = 0xe1u8
    k.push(b)
    b = 0x72u8
    k.push(b)
    b = 0x8eu8
    k.push(b)
    b = 0x3bu8
    k.push(b)
    b = 0xf4u8
    k.push(b)
    b = 0x80u8
    k.push(b)
    b = 0x35u8
    k.push(b)
    b = 0x0fu8
    k.push(b)
    b = 0x25u8
    k.push(b)
    b = 0xe0u8
    k.push(b)
    b = 0x7eu8
    k.push(b)
    b = 0x21u8
    k.push(b)
    b = 0xc9u8
    k.push(b)
    b = 0x47u8
    k.push(b)
    b = 0xd1u8
    k.push(b)
    b = 0x9eu8
    k.push(b)
    b = 0x33u8
    k.push(b)
    b = 0x76u8
    k.push(b)
    b = 0xf0u8
    k.push(b)
    b = 0x9bu8
    k.push(b)
    b = 0x3cu8
    k.push(b)
    b = 0x1eu8
    k.push(b)
    b = 0x16u8
    k.push(b)
    b = 0x17u8
    k.push(b)
    b = 0x42u8
    k.push(b)
    k

# First 16 bytes of the NaCl nonce (nonce-head for XSalsa20/HSalsa20)
# Module-level helper avoids it-block var mutation loss (feedback_it_block_var_mutation.md).
fn _nacl_nonce_head16() -> [u8]:
    var nh: [u8] = []
    val full = _nacl_nonce()
    var i: u64 = 0
    while i < 16:
        nh.push(full[i])
        i = i + 1
    nh

# 16 zero bytes (nonce-head for HSalsa20 KAT)
fn _zero_nonce16() -> [u8]:
    var n: [u8] = []
    var i: u64 = 0
    while i < 16:
        var b: u8 = 0u8
        n.push(b)
        i = i + 1
    n

# Module-level helper: check if a [u8] array of given length is all zeros.
# Avoids it-block var mutation loss (feedback_it_block_var_mutation.md).
fn _all_zero_64(b: [u8]) -> bool:
    var result = true
    var i: u64 = 0
    while i < 64:
        if b[i] != 0u8:
            result = false
        i = i + 1
    result

fn _all_zero_32(b: [u8]) -> bool:
    var result = true
    var i: u64 = 0
    while i < 32:
        if b[i] != 0u8:
            result = false
        i = i + 1
    result

# ============================================================================
# Test: XSalsa20 encrypt zeros → NaCl known keystream (first 32 bytes)
# ============================================================================

describe "xsalsa20_encrypt — NaCl box7.c known-answer vector":

    it "encrypt 64 zero bytes: first 32 bytes match NaCl reference":
        val ct = xsalsa20_encrypt(_nacl_key(), _nacl_nonce(), _zeros64())
        val got = _bytes_hex_range(ct, 0, 32)
        expect(got).to_equal("eea6a7251c1e72916d11c2cb214d3c252539121d8e234e652d651fa4c8cff880")

    it "encrypt 64 zero bytes: output length is 64":
        val ct = xsalsa20_encrypt(_nacl_key(), _nacl_nonce(), _zeros64())
        expect(ct.len()).to_equal(64)

    it "encrypt zero bytes: ciphertext is NOT all zeros (keystream non-trivial)":
        val ct = xsalsa20_encrypt(_nacl_key(), _nacl_nonce(), _zeros64())
        expect(_all_zero_64(ct)).to_equal(false)

# ============================================================================
# Test: XSalsa20 round-trip — encrypt then decrypt == original
# ============================================================================

describe "xsalsa20_encrypt/decrypt — round-trip":

    it "encrypt then decrypt 32 zero bytes == original":
        val pt = _zeros32()
        val ct = xsalsa20_encrypt(_nacl_key(), _nacl_nonce(), pt)
        val recovered = xsalsa20_decrypt(_nacl_key(), _nacl_nonce(), ct)
        expect(_bytes_hex(recovered)).to_equal(_bytes_hex(pt))

    it "decrypt is symmetric with encrypt (stream cipher identity)":
        val pt = _zeros32()
        val ct = xsalsa20_encrypt(_nacl_key(), _nacl_nonce(), pt)
        val ct2 = xsalsa20_decrypt(_nacl_key(), _nacl_nonce(), pt)
        # Both encrypt and decrypt XOR the same keystream
        expect(_bytes_hex(ct)).to_equal(_bytes_hex(ct2))

# ============================================================================
# Test: Different nonces produce different ciphertexts
# ============================================================================

describe "xsalsa20_encrypt — nonce independence":

    it "NaCl nonce and zero nonce give different ciphertexts for same plaintext":
        val pt = _zeros32()
        val ct1 = xsalsa20_encrypt(_nacl_key(), _nacl_nonce(), pt)
        val ct2 = xsalsa20_encrypt(_nacl_key(), _zero_nonce(), pt)
        expect(_bytes_hex(ct1) == _bytes_hex(ct2)).to_equal(false)

# ============================================================================
# Test: HSalsa20 known-answer (djb key, zero nonce-head)
# ============================================================================

describe "hsalsa20 — known-answer vector (djb key, zero input)":

    it "HSalsa20(djb_key, zero16) output length is 32 bytes":
        val subkey = hsalsa20(_djb_key(), _zero_nonce16())
        expect(subkey.len()).to_equal(32)

    it "HSalsa20(djb_key, zero16) output is non-zero (non-trivial permutation)":
        val subkey = hsalsa20(_djb_key(), _zero_nonce16())
        expect(_all_zero_32(subkey)).to_equal(false)

    it "HSalsa20(nacl_key, nacl_nonce[0..16]) output is 32 bytes":
        val subkey = hsalsa20(_nacl_key(), _nacl_nonce_head16())
        expect(subkey.len()).to_equal(32)
