use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_mcpgdb(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/mcpgdb/main.spl\" " + joined
    ])

fn _ping_mcpgdb() -> (text, text, i64):
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); printf '{\"jsonrpc\":\"2.0\",\"id\":\"1\",\"method\":\"ping\"}\\n' | SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/mcpgdb/main.spl\""
    ])

describe "mcpgdb log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_mcpgdb(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("mcpgdb MCP Server")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json ready output":
        val (out, err, code) = _run_mcpgdb(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"mcpgdb\"")
        expect(out).to_contain("\"status\":\"ready\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_mcpgdb(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_contain(".\nmcpgdb MCP Server")

    it "rejects invalid log mode":
        val (out, err, code) = _run_mcpgdb(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "renders json unknown option output":
        val (out, err, code) = _run_mcpgdb(["--log-mode=json", "--surprise"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"status\":\"error\"")
        expect(out).to_contain("Unknown mcpgdb option: --surprise")

    it "preserves normal MCP ping handling":
        val (out, err, code) = _ping_mcpgdb()
        expect(code).to_equal(0)
        expect(out).to_contain("\"jsonrpc\":\"2.0\"")
        expect(out).to_contain("\"result\":{}")
