# test/perf/tauri_equiv/gui_vs_tauri_spec.spl
#
# **Feature IDs:** AC-9 — Tauri-equivalent benchmark:
#   startup, windows, scroll, IPC, memory; reports vs baseline.
# **Category:** Performance | GUI | Tauri
# **Status:** Pending implementation (Phase 5)
#
# Verifies that the Tauri-equivalent benchmark:
#   - Runs startup, new_window, close, resize, scroll, route_change, ipc, event_broadcast, idle_memory
#   - Reports Tauri renderer identity and Simple backend identity
#   - Fails the Tauri-equivalent performance claim when NFR ratios are missed
#   - Reference kind is "rust-tauri"
#
# @cover test/perf/tauri_equiv/workflow_driver.spl
# @cover test/perf/tauri_equiv/report_spec.spl
# @cover test/perf/tauri_equiv/simple_app.spl

val REF_KIND_TAURI: text = "rust-tauri"

val WORKFLOW_STARTUP:         text = "startup"
val WORKFLOW_NEW_WINDOW:      text = "new_window"
val WORKFLOW_CLOSE:           text = "close"
val WORKFLOW_RESIZE:          text = "resize"
val WORKFLOW_SCROLL:          text = "scroll"
val WORKFLOW_ROUTE_CHANGE:    text = "route_change"
val WORKFLOW_IPC:             text = "ipc"
val WORKFLOW_EVENT_BROADCAST: text = "event_broadcast"
val WORKFLOW_IDLE_MEMORY:     text = "idle_memory"

val NFR_TAURI_RATIO_THRESHOLD: i64 = 1500  # Simple must be <= 1.5x Tauri for pass

struct TauriWorkflowResult:
    workflow:         text
    simple_us:        i64
    tauri_us:         i64
    rss_kb:           i64
    pass:             bool

struct TauriBenchReport:
    reference_kind:        text
    tauri_renderer:        text
    simple_backend:        text
    sample_count:          i64
    warmup_count:          i64
    workflows:             [TauriWorkflowResult]

fn make_workflow(wf: text, s_us: i64, t_us: i64, rss: i64) -> TauriWorkflowResult:
    val ratio: i64 = if t_us > 0: (s_us * 1000) / t_us else: 9999
    TauriWorkflowResult(
        workflow:  wf,
        simple_us: s_us,
        tauri_us:  t_us,
        rss_kb:    rss,
        pass:      ratio <= NFR_TAURI_RATIO_THRESHOLD
    )

fn make_tauri_bench_ok() -> TauriBenchReport:
    val wf: [TauriWorkflowResult] = [
        make_workflow(WORKFLOW_STARTUP,         1200000, 1000000, 45000),
        make_workflow(WORKFLOW_NEW_WINDOW,       80000,    60000,  2000),
        make_workflow(WORKFLOW_CLOSE,            15000,    12000,   500),
        make_workflow(WORKFLOW_RESIZE,           25000,    20000,   800),
        make_workflow(WORKFLOW_SCROLL,            5000,     4000,   200),
        make_workflow(WORKFLOW_ROUTE_CHANGE,     90000,    75000,  3000),
        make_workflow(WORKFLOW_IPC,               3000,     2500,   100),
        make_workflow(WORKFLOW_EVENT_BROADCAST,  12000,    10000,   400),
        make_workflow(WORKFLOW_IDLE_MEMORY,          0,        0, 38000)
    ]
    TauriBenchReport(
        reference_kind:  REF_KIND_TAURI,
        tauri_renderer:  "wry/webkit",
        simple_backend:  "simple_cpu_scalar",
        sample_count:    20,
        warmup_count:    3,
        workflows:       wf
    )

describe "gui_vs_tauri — AC-9: Tauri-equivalent benchmark":

    describe "report schema":

        it "AC-9: reference_kind is rust-tauri":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.reference_kind).to_equal(REF_KIND_TAURI)

        it "AC-9: tauri_renderer field is non-empty":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.tauri_renderer).to_equal("wry/webkit")

        it "AC-9: simple_backend field is non-empty":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.simple_backend).to_equal("simple_cpu_scalar")

        it "AC-9: sample_count is greater than zero":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.sample_count > 0).to_equal(true)

        it "AC-9: warmup_count is greater than zero":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.warmup_count > 0).to_equal(true)

    describe "workflow coverage (9 workflows)":

        it "AC-9: nine workflows are recorded":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.workflows.len()).to_equal(9)

        it "AC-9: first workflow is startup":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.workflows[0].workflow).to_equal(WORKFLOW_STARTUP)

        it "AC-9: new_window workflow is present":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.workflows[1].workflow).to_equal(WORKFLOW_NEW_WINDOW)

        it "AC-9: ipc workflow is present":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.workflows[6].workflow).to_equal(WORKFLOW_IPC)

        it "AC-9: idle_memory workflow is last":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.workflows[8].workflow).to_equal(WORKFLOW_IDLE_MEMORY)

    describe "pass/fail per workflow":

        it "AC-9: startup workflow passes when ratio <= NFR_TAURI_RATIO_THRESHOLD":
            val wf: TauriWorkflowResult = make_workflow(WORKFLOW_STARTUP, 1200000, 1000000, 45000)
            expect(wf.pass).to_equal(true)

        it "AC-9: scroll workflow passes when simple_us is close to tauri_us":
            val wf: TauriWorkflowResult = make_workflow(WORKFLOW_SCROLL, 5000, 4000, 200)
            expect(wf.pass).to_equal(true)

        it "AC-9: workflow fails when simple is more than 1.5x Tauri":
            val wf: TauriWorkflowResult = make_workflow(WORKFLOW_STARTUP, 2000000, 1000000, 45000)
            expect(wf.pass).to_equal(false)

        it "AC-9: simple_us is greater than zero for non-idle workflows":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.workflows[0].simple_us > 0).to_equal(true)

        it "AC-9: tauri_us is greater than zero for non-idle workflows":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.workflows[0].tauri_us > 0).to_equal(true)

    describe "memory reporting":

        it "AC-9: idle_memory rss_kb is greater than zero":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.workflows[8].rss_kb > 0).to_equal(true)

        it "AC-9: startup rss_kb is greater than zero":
            val b: TauriBenchReport = make_tauri_bench_ok()
            expect(b.workflows[0].rss_kb > 0).to_equal(true)
