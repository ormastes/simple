# Minimal UI Launch Demo
#
# Keeps the dependency surface intentionally small so the shared UI core
# can be launched even when the full repo build is noisy.

use common.ui.builder.{column, panel, text_widget, progress, statusbar, build_tree_with_title}
use common.ui.widget.{WidgetNode, WidgetRect, UIState}
use common.ui.layout.{compute_layout, find_rect}

fn build_state() -> UIState:
    val greeting = text_widget("greeting", "Hello from Simple UI")
    val help = text_widget("help", "Scratch launch path is running")
    val bar = progress("build_progress", 75)
    val header = panel("header", "Simple GUI Demo", [greeting, help, bar])
    val status = statusbar("status", "NORMAL", "hello_gui_min")
    val root = column("root", [header, status])
    val tree = build_tree_with_title(root, "Hello Simple GUI", "dark")
    return UIState.new(tree)

fn render_widget_text(node: WidgetNode, rects: [WidgetRect], depth: i32) -> text:
    val rect = find_rect(rects, node.id)
    val kind = node.kind_name()
    val indent = repeat_text("  ", depth)
    val title = node.get_prop("title")
    val content = node.get_prop("content")
    val label = node.get_prop("label")
    val summary = if title != "":
        title
    elif content != "":
        content
    else:
        label
    val dims = if rect != nil:
        "@({rect.x},{rect.y}) {rect.w}x{rect.h}"
    else:
        "@(?,?) ?x?"
    var out = "{indent}- {node.id} [{kind}] {dims}"
    if summary != "":
        out = "{out} :: {summary}"
    out = "{out}\n"
    for child in node.children():
        out = "{out}{render_widget_text(child, rects, depth + 1)}"
    return out

fn repeat_text(value: text, count: i32) -> text:
    var out = ""
    var idx = 0
    while idx < count:
        out = "{out}{value}"
        idx = idx + 1
    return out

fn main() -> i64:
    val state = build_state()
    val rects = compute_layout(state.tree.root_node(), 0, 0, 80, 24)

    print "launch:title:{state.tree.title_text()}"
    print "launch:theme:{state.tree.theme_name()}"
    print "launch:widgets:{state.tree.all_widget_ids().len()}"
    print "launch:rects:{rects.len()}"
    print "launch:frame:start"
    print render_widget_text(state.tree.root_node(), rects, 0)
    print "launch:frame:end"
    return 0
