# WebGPU runtime hook owner for 2D engine backends.

extern fn rt_webgpu_is_available() -> bool
extern fn rt_webgpu_init() -> bool
extern fn rt_webgpu_shutdown() -> bool
extern fn rt_webgpu_create_surface(width: i32, height: i32) -> i64
extern fn rt_webgpu_destroy_surface(handle: i64) -> bool
extern fn rt_webgpu_upload_pixels(handle: i64, pixels: [u32], w: i32, h: i32) -> bool
extern fn rt_webgpu_present(handle: i64) -> bool
extern fn rt_webgpu_compute_draw(handle: i64, op_kind: i32, x: i32, y: i32, w: i32, h: i32, color: u32) -> bool
extern fn rt_webgpu_adapter_count() -> i64
extern fn rt_webgpu_adapter_name(index: i64) -> text
extern fn rt_webgpu_adapter_is_cpu(index: i64) -> bool

fn webgpu_sffi_is_available() -> bool:
    rt_webgpu_is_available()

fn webgpu_sffi_init() -> bool:
    rt_webgpu_init()

fn webgpu_sffi_shutdown() -> bool:
    rt_webgpu_shutdown()

fn webgpu_sffi_create_surface(width: i32, height: i32) -> i64:
    rt_webgpu_create_surface(width, height)

fn webgpu_sffi_destroy_surface(handle: i64) -> bool:
    rt_webgpu_destroy_surface(handle)

fn webgpu_sffi_upload_pixels(handle: i64, pixels: [u32], w: i32, h: i32) -> bool:
    rt_webgpu_upload_pixels(handle, pixels, w, h)

fn webgpu_sffi_present(handle: i64) -> bool:
    rt_webgpu_present(handle)

fn webgpu_sffi_compute_draw(handle: i64, op_kind: i32, x: i32, y: i32, w: i32, h: i32, color: u32) -> bool:
    rt_webgpu_compute_draw(handle, op_kind, x, y, w, h, color)

fn webgpu_sffi_adapter_count() -> i64:
    rt_webgpu_adapter_count()

fn webgpu_sffi_adapter_name(index: i64) -> text:
    rt_webgpu_adapter_name(index)

fn webgpu_sffi_adapter_is_cpu(index: i64) -> bool:
    rt_webgpu_adapter_is_cpu(index)
