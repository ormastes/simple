# Tool Schemas — Screen and System tools
#
# Schema builder functions for the MCP OS server tool registry.
# Screen tools: screenshot, screen_read_text
# System tools: system_info, system_exec

use os.services.llm.tool_schema_helpers.{llm_tool_property, llm_tool_input_schema, llm_tool_annotations, llm_tool_schema}

fn schema_screenshot() -> text:
    """Schema for screenshot tool."""
    val props = "{}"
    val required = "[]"
    val schema = llm_tool_input_schema(props, required)
    val annot = llm_tool_annotations("true", "false", "true")
    return llm_tool_schema("screenshot", "Get text description of entire screen state: all windows, positions, and widget tree summaries", schema, annot)

fn schema_screen_read_text() -> text:
    """Schema for screen_read_text tool."""
    val props = "{}"
    val required = "[]"
    val schema = llm_tool_input_schema(props, required)
    val annot = llm_tool_annotations("true", "false", "true")
    return llm_tool_schema("screen_read_text", "Extract all visible text from screen for accessibility or LLM reading", schema, annot)

fn schema_system_info() -> text:
    """Schema for system_info tool."""
    val props = "{}"
    val required = "[]"
    val schema = llm_tool_input_schema(props, required)
    val annot = llm_tool_annotations("true", "false", "true")
    return llm_tool_schema("system_info", "Get system information: hostname, uptime, process count, window count", schema, annot)

fn schema_system_exec() -> text:
    """Schema for system_exec tool."""
    val p_cmd = llm_tool_property("string", "Shell command to execute")
    val props = _jo1(_jp("command", p_cmd))
    val required = "[" + _js("command") + "]"
    val schema = llm_tool_input_schema(props, required)
    val annot = llm_tool_annotations("false", "true", "false")
    return llm_tool_schema("system_exec", "Execute a shell command and return output", schema, annot)
