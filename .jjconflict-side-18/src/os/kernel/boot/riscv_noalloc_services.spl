# RISC-V noalloc service handoff.
#
# Scalar boot-service snapshot for the freestanding path. Hosted services
# still need the runtime ABI; this records which boot facilities are safe to
# expose before that boundary is crossed.

var g_riscv_noalloc_services_ready: bool = false
var g_riscv_noalloc_spm_ready: bool = false
var g_riscv_noalloc_memory_ready: bool = false
var g_riscv_noalloc_network_ready: bool = false
var g_riscv_noalloc_display_ready: bool = false
var g_riscv_noalloc_storage_ready: bool = false

extern fn rt_riscv_uart_put(byte: u64)

fn _uart_put(byte: u64):
    rt_riscv_uart_put(byte)

fn _crlf():
    _uart_put(13)
    _uart_put(10)

fn _line_svc_ok():
    _uart_put(83)  # S
    _uart_put(86)  # V
    _uart_put(67)  # C
    _uart_put(32)  # space
    _uart_put(79)  # O
    _uart_put(75)  # K
    _crlf()

fn riscv_noalloc_services_init(memory_ready: bool):
    g_riscv_noalloc_spm_ready = true
    g_riscv_noalloc_memory_ready = memory_ready
    g_riscv_noalloc_network_ready = false
    g_riscv_noalloc_display_ready = false
    g_riscv_noalloc_storage_ready = false
    g_riscv_noalloc_services_ready = true
    _line_svc_ok()

fn riscv_noalloc_services_are_ready() -> bool:
    g_riscv_noalloc_services_ready

fn riscv_noalloc_memory_ready() -> bool:
    g_riscv_noalloc_memory_ready

fn riscv_noalloc_network_ready() -> bool:
    g_riscv_noalloc_network_ready

fn riscv_noalloc_display_ready() -> bool:
    g_riscv_noalloc_display_ready

fn riscv_noalloc_storage_ready() -> bool:
    g_riscv_noalloc_storage_ready
