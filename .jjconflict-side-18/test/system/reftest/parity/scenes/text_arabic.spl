# text_arabic scene — Arabic glyph outline as manually-built path, cull 200x202

use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_path}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.path.{SkPath, sk_path_new}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.enums.{SkPathFillType}
use std.skia.entity.color.{sk_color_argb}

fn scene() -> SkPicture:
    val cull = SkRect(left: 0.0, top: 0.0, right: 200.0, bottom: 202.0)
    # Manually-built path approximating first glyph outline of "السلام"
    # Using cubic bezier segments to distinguish from straight-line paths
    val p0 = sk_path_new()
    val p1 = p0.move_to(160.0, 40.0)
    val p2 = p1.cubic_to(170.0, 30.0, 180.0, 50.0, 185.0, 70.0)
    val p3 = p2.cubic_to(188.0, 85.0, 175.0, 90.0, 165.0, 85.0)
    val p4 = p3.line_to(150.0, 60.0)
    val p5 = p4.close()
    val glyph_path = p5.with_fill_type(SkPathFillType.Winding)
    val paint = sk_paint_fill(sk_color_argb(255, 10, 10, 10))
    val ops = [SkPictureOp]()
    ops.push(sk_picture_op_draw_path(glyph_path, paint))
    SkPicture(cull_rect: cull, op_count: ops.len() as i64, ops: ops)
