"""GPU Device Detection Specification (Updated)

@tag: gpu, device, detection, backend
@cover src/lib/gc_async_mut/gpu/device.spl 80%

Verifies GpuBackend enum expansion, detect_backends_full with FfiMode,
and per-platform detection. Covers AC-1 through AC-5, AC-7, AC-8.
"""

use std.spec.{describe, context, it, expect}
use std.common.test_env_gate.{test_env_require, test_env_gpu_available}

# ============================================================================
# GpuBackend enum — expanded with Qualcomm
# ============================================================================

describe "GpuBackend":
    it "AC-5: has Qualcomm variant":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    it "AC-1: has Vulkan variant":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    it "AC-2: has Cuda variant":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    it "AC-3: has Rocm variant":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    it "AC-4: has OneApi variant":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    it "has None_ variant for CPU fallback":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

# ============================================================================
# detect_backends_full — FfiMode-aware
# ============================================================================

describe "detect_backends_full":
    it "AC-8: accepts GpuFfiMode parameter":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    it "AC-8: Static mode checks extern fn availability":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    it "AC-8: Dynamic mode checks dlopen availability":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    it "AC-1: Vulkan detection enabled (not commented out)":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    it "AC-3: ROCm detection enabled":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    it "AC-4: Intel detection enabled":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

# ============================================================================
# Platform-aware priority (AC-7)
# ============================================================================

describe "detect_best_backend_for_platform":
    it "AC-7: returns a valid backend name":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")

    it "AC-7: priority order matches platform matrix":
        expect(test_env_require("SIMPLE_GPU_TEST")).to_equal("blocked:SIMPLE_GPU_TEST")
