# Bug: Double execution in interpreter mode
# Severity: P2
# Workaround: Guard flag (MAIN_EXECUTED) to prevent re-entry

var EXEC_COUNT = 0
var MAIN_GUARD_EXECUTED = false

fn guarded_main():
    if MAIN_GUARD_EXECUTED:
        return
    MAIN_GUARD_EXECUTED = true
    EXEC_COUNT = EXEC_COUNT + 1

# Module-level unguarded counter for third test
var UNGUARDED_COUNT = 0

fn unguarded_increment():
    UNGUARDED_COUNT = UNGUARDED_COUNT + 1

# Wrap test logic in module-level functions to avoid closure capture limitation
# (it blocks can READ module vars but CANNOT MODIFY them)
fn _test_guard_single_call() -> Int:
    EXEC_COUNT = 0
    MAIN_GUARD_EXECUTED = false
    guarded_main()
    EXEC_COUNT

fn _test_guard_is_set() -> bool:
    MAIN_GUARD_EXECUTED

fn _test_guard_multiple_calls() -> Int:
    EXEC_COUNT = 0
    MAIN_GUARD_EXECUTED = false
    guarded_main()
    guarded_main()
    guarded_main()
    EXEC_COUNT

fn _test_unguarded_calls() -> Int:
    UNGUARDED_COUNT = 0
    unguarded_increment()
    unguarded_increment()
    UNGUARDED_COUNT

describe "Double execution bug":
    it "guard prevents multiple executions":
        expect(_test_guard_single_call()).to_equal(1)
        expect(_test_guard_is_set()).to_equal(true)

    it "calling guarded_main again is a no-op":
        expect(_test_guard_multiple_calls()).to_equal(1)

    it "without guard, count increments each call":
        expect(_test_unguarded_calls()).to_equal(2)
