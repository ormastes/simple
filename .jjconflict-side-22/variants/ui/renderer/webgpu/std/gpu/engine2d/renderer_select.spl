# variants/ui/renderer/webgpu — renderer_select override
#
# WebGPU-first build target (browser/WASM targets): WebGPU leads, then
# Vulkan as portable native fallback, then CPU lanes.
# Always ends with "cpu".

fn renderer_priority_order() -> [text]:
    """WebGPU-first build: WebGPU, Vulkan, then CPU fallbacks."""
    ["webgpu", "vulkan", "opencl", "opengl", "cpu_simd", "software", "cpu"]
