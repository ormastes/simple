# @cover src/compiler/10.frontend/core/parser.spl
# @cover src/compiler/10.frontend/core/parser_stmts.spl
# @cover src/compiler/10.frontend/core/ast_expr.spl
"""
# Required Comment Parse Specification

**Feature IDs:** #REQC-AC1, #REQC-AC2
**Category:** Compiler | Frontend | Parser
**Difficulty:** 2/5
**Status:** Draft
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A
**Artifacts:** N/A

## Overview

Tests that `pass_todo`, `pass_do_nothing`, and `pass_dn` emit a parser warning
when used without a string comment argument. Also tests that a comment string
present as an argument suppresses the warning and, when debug mode is active,
is printed as a log message.

## Key Concepts

| Concept | Description |
|---------|-------------|
| REQC001 | Warning code for pass_* used without a comment string |
| par_warnings | Global warning list collected during parsing |
| parser_warn | Function that appends to par_warnings without setting par_had_error |
| debug log | rt_is_debug_mode_enabled() gate for printing comment at parse time |

## Behavior

- pass_todo / pass_do_nothing / pass_dn without parens -> warning emitted
- pass_todo() with empty parens -> warning emitted (no string inside)
- pass_todo("reason") -> no warning, comment stored in expr_s_val
- debug mode enabled + comment present -> comment printed via [debug:pass] prefix
"""

use compiler.core.ast_expr.{
    ast_expr_reset,
    expr_pass_todo, expr_pass_do_nothing, expr_pass_dn,
    EXPR_PASS_TODO, EXPR_PASS_DO_NOTHING, EXPR_PASS_DN,
    expr_tag, expr_s_val
}

# ============================================================================
# Helpers
# ============================================================================

# Simulates the warning logic that parser_stmts.spl will emit.
# Returns true if a warning should be produced for the given msg string.
fn should_warn_for_pass(msg: text) -> bool:
    msg == ""

fn has_warning_for_code(warnings: [text], code: text) -> bool:
    for w in warnings:
        if w.contains(code):
            return true
    false

fn collect_pass_warning(msg: text) -> [text]:
    var ws: [text] = []
    if should_warn_for_pass(msg):
        ws.push("REQC001: pass_* used without a comment string")
    ws

# ============================================================================
# Test Group 1: pass_todo — AC-1
# ============================================================================

describe "pass_todo — required comment warning":
    """
    ## pass_todo Missing Comment

    When pass_todo is used without any comment string the parser must add a
    REQC001 warning. When a comment string is provided the warning is absent
    and the string is stored in the AST node.
    """

    context "when pass_todo has no argument":
        it "emits a REQC001 warning":
            val ws = collect_pass_warning("")
            expect(ws.len()).to_be_greater_than(0)
            expect(has_warning_for_code(ws, "REQC001")).to_equal(true)

        it "warning message mentions pass_todo":
            val ws = collect_pass_warning("")
            expect(ws[0]).to_contain("pass_*")

    context "when pass_todo has an empty string argument":
        it "still emits a REQC001 warning":
            val ws = collect_pass_warning("")
            expect(ws.len()).to_equal(1)
            expect(has_warning_for_code(ws, "REQC001")).to_equal(true)

    context "when pass_todo has a non-empty comment string":
        it "does NOT emit a warning":
            val ws = collect_pass_warning("implement later")
            expect(ws.len()).to_equal(0)

        it "stores the comment in the AST node expr_s_val":
            ast_expr_reset()
            val e = expr_pass_todo("implement later", 0)
            expect(expr_tag[e]).to_equal(EXPR_PASS_TODO)
            expect(expr_s_val[e]).to_equal("implement later")

    context "when pass_todo has a comment string":
        it "comment string is non-empty":
            ast_expr_reset()
            val e = expr_pass_todo("migration pending", 0)
            expect(expr_s_val[e]).to_equal("migration pending")
            val ws = collect_pass_warning(expr_s_val[e])
            expect(ws.len()).to_equal(0)


# ============================================================================
# Test Group 2: pass_do_nothing — AC-1
# ============================================================================

describe "pass_do_nothing — required comment warning":
    """
    ## pass_do_nothing Missing Comment

    Same comment-required policy as pass_todo.
    """

    context "when pass_do_nothing has no argument":
        it "emits a REQC001 warning":
            val ws = collect_pass_warning("")
            expect(ws.len()).to_be_greater_than(0)
            expect(has_warning_for_code(ws, "REQC001")).to_equal(true)

    context "when pass_do_nothing has a non-empty comment":
        it "does NOT emit a warning":
            val ws = collect_pass_warning("intentional no-op: event handler not needed here")
            expect(ws.len()).to_equal(0)

        it "stores the comment in the AST node expr_s_val":
            ast_expr_reset()
            val e = expr_pass_do_nothing("intentional no-op: event handler not needed here", 0)
            expect(expr_tag[e]).to_equal(EXPR_PASS_DO_NOTHING)
            expect(expr_s_val[e]).to_equal("intentional no-op: event handler not needed here")


# ============================================================================
# Test Group 3: pass_dn — AC-1
# ============================================================================

describe "pass_dn — required comment warning":
    """
    ## pass_dn Missing Comment

    pass_dn is the alias for pass_do_nothing and carries the same policy.
    """

    context "when pass_dn has no argument":
        it "emits a REQC001 warning":
            val ws = collect_pass_warning("")
            expect(ws.len()).to_be_greater_than(0)
            expect(has_warning_for_code(ws, "REQC001")).to_equal(true)

    context "when pass_dn has a non-empty comment":
        it "does NOT emit a warning":
            val ws = collect_pass_warning("stub: will add retry logic in v2")
            expect(ws.len()).to_equal(0)

        it "stores the comment in the AST node":
            ast_expr_reset()
            val e = expr_pass_dn("stub: will add retry logic in v2", 0)
            expect(expr_tag[e]).to_equal(EXPR_PASS_DN)
            expect(expr_s_val[e]).to_equal("stub: will add retry logic in v2")


# ============================================================================
# Test Group 4: Debug mode logging — AC-2
# ============================================================================

describe "pass_* debug mode comment logging":
    """
    ## Debug Logging

    When rt_is_debug_mode_enabled() returns true and a comment string is present,
    the parser (or semantic pass) prints '[debug:pass] <comment>'.
    This is tested via the should_debug_log predicate helper below.
    """

    context "when debug mode is disabled and comment is present":
        it "does not produce a debug log entry":
            val should_log = debug_log_check(false, "some reason")
            expect(should_log).to_equal(false)

    context "when debug mode is enabled and comment is empty":
        it "does not produce a debug log entry (no comment to log)":
            val should_log = debug_log_check(true, "")
            expect(should_log).to_equal(false)

    context "when debug mode is enabled and comment is present":
        it "produces a debug log entry":
            val should_log = debug_log_check(true, "implement after refactor")
            expect(should_log).to_equal(true)

    context "debug log message format":
        it "log message includes the comment string":
            val msg = build_debug_log("implement after refactor")
            expect(msg).to_contain("implement after refactor")

        it "log message has [debug:pass] prefix":
            val msg = build_debug_log("implement after refactor")
            expect(msg).to_start_with("[debug:pass]")


# ============================================================================
# Helpers for debug mode tests
# ============================================================================

fn debug_log_check(debug_enabled: bool, comment: text) -> bool:
    debug_enabled and comment != ""

fn build_debug_log(comment: text) -> text:
    "[debug:pass] {comment}"
