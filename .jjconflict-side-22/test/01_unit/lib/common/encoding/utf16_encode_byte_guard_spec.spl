use std.spec.{describe, it, assert_equal}
use std.common.encoding.utf16.{utf16_to_bytes_le, utf16_to_bytes_be, utf16_from_bytes_le, utf16_from_bytes_be}

describe "utf16 byte encoding guards":
    it "keeps valid little-endian serialization":
        assert_equal(utf16_to_bytes_le([0x41]), [0x41, 0x00])

    it "keeps valid big-endian serialization":
        assert_equal(utf16_to_bytes_be([0x41]), [0x00, 0x41])

    it "serializes negative units as replacement":
        assert_equal(utf16_from_bytes_le(utf16_to_bytes_le([-1])), [0xFFFD])

    it "serializes above-range units as replacement":
        assert_equal(utf16_from_bytes_be(utf16_to_bytes_be([0x10041])), [0xFFFD])
