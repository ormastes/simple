# SimpleOS — Production Failure Capture (Track 5.10)
#
# Captures a container checkpoint + event log tail on kernel panic
# or fatal signal, for post-mortem analysis.

use os.kernel.replay.checkpoint.checkpoint_types.{ContainerCheckpoint}
use os.kernel.replay.log_buffer.{replay_event_count}

# ============================================================================
# Configuration
# ============================================================================

struct FailureCaptureConfig:
    max_events_before: i32   # how many event-log entries to include before failure
    include_memory: bool     # whether to snapshot memory pages
    output_path: text        # directory where capture is written

impl FailureCaptureConfig:
    static fn default() -> FailureCaptureConfig:
        FailureCaptureConfig(
            max_events_before: 256,
            include_memory: true,
            output_path: "/var/log/sreplay/failures"
        )

# ============================================================================
# FailureCapture
# ============================================================================

class FailureCapture:
    config: FailureCaptureConfig
    captured: bool
    capture_cycle: i64

impl FailureCapture:
    static fn with_config(cfg: FailureCaptureConfig) -> FailureCapture:
        FailureCapture(
            config: cfg,
            captured: false,
            capture_cycle: 0
        )

    me fn capture_on_panic(cycle: i64, pc: i64, sp: i64):
        if self.captured:
            return
        self.captured = true
        self.capture_cycle = cycle
        # In a real kernel this would flush the event ring, serialize the
        # checkpoint, and write it to config.output_path.  Here we record
        # the trigger metadata so callers can retrieve it via summary().

    me fn capture_on_signal(cycle: i64, signal: i32, pid: i64):
        if self.captured:
            return
        self.captured = true
        self.capture_cycle = cycle

    fn is_captured() -> bool:
        self.captured

    fn summary() -> text:
        if not self.captured:
            return "FailureCapture: no capture recorded"
        var lines: [text] = []
        lines.push("FailureCapture:")
        lines.push("  captured: true")
        lines.push("  capture_cycle: {self.capture_cycle}")
        lines.push("  max_events_before: {self.config.max_events_before}")
        lines.push("  include_memory: {self.config.include_memory}")
        lines.push("  output_path: {self.config.output_path}")
        lines.join("\n")
