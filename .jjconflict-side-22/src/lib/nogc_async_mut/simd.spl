"""
# No-GC Async SIMD

Compatibility facade over the no-GC sync SIMD backend. SIMD feature detection
and vector intrinsics are synchronous runtime/compiler boundaries, so the async
family reuses the shared no-GC declaration owner.
"""

export use std.nogc_sync_mut.simd.{
    SimdTier, detect_profile, profile_name, has_sse, has_avx, has_avx2,
    has_neon, has_rvv, simd_width,
    Vec4f, Vec8f, Vec4d, Vec4i, Vec8i, Vec4u32, Vec4i64, Vec16u8, Vec2u64,
    simd_add_f32x4, simd_sub_f32x4, simd_mul_f32x4, simd_div_f32x4,
    simd_fma_f32x4, simd_add_f32x8, simd_sub_f32x8, simd_mul_f32x8,
    simd_div_f32x8, simd_fma_f32x8, simd_add_f64x4, simd_sub_f64x4,
    simd_mul_f64x4, simd_div_f64x4, simd_fma_f64x4,
    simd_add_i32x4, simd_sub_i32x4, simd_mul_i32x4, simd_xor_i32x4,
    simd_and_i32x4, simd_or_i32x4, simd_shl_i32x4, simd_shr_i32x4,
    simd_rotl_i32x4, simd_rotr_i32x4,
    simd_add_i32x8, simd_sub_i32x8, simd_mul_i32x8, simd_xor_i32x8,
    simd_and_i32x8, simd_or_i32x8, simd_shl_i32x8, simd_shr_i32x8,
    simd_add_u32x4, simd_sub_u32x4, simd_and_u32x4, simd_or_u32x4,
    simd_xor_u32x4, simd_add_i64x4, simd_sub_i64x4,
    simd_add_u8x16, simd_xor_u8x16, simd_aes_round, simd_aes_round_last,
    simd_clmul_lo_u64, simd_clmul_hi_u64, simd_xor_u64x2,
    simd_hadd_f32x4, simd_hmax_f32x4, simd_hmin_f32x4
}
