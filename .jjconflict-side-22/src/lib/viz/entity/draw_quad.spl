# DrawQuad and SharedQuadState: flat-field discriminated quad types for a render pass

use std.skia.entity.geometry.{SkRect}
use std.skia.entity.matrix.{Matrix3x3}
use std.skia.entity.color.{SkColor4f}
use std.skia.entity.enums.{SkBlendMode}
use std.viz.entity.shared_image.{SharedImageMailbox}

class SharedQuadState:
    quad_to_target_transform: Matrix3x3
    visible_layer_rect: SkRect
    clip_rect: SkRect
    is_clipped: bool
    opacity: f64
    blend_mode: SkBlendMode
    sorting_context_id: i32

enum DrawQuadKind:
    SolidColor
    Texture
    Tile
    RenderPass
    Video
    Debug

class DrawQuad:
    kind: DrawQuadKind
    shared_quad_state_index: i32
    rect: SkRect
    visible_rect: SkRect
    needs_blending: bool

    solid_color: SkColor4f
    texture_mailbox: SharedImageMailbox
    texture_premultiplied: bool
    uv_top_left: SkRect
    uv_bottom_right: SkRect
    render_pass_id: i32
    mask_resource_id: i32
    mask_uv_rect: SkRect
    filters_scale: f64
    video_plane_count: i32
    debug_width: i32

    static fn solid_color(sqs_index: i32, rect: SkRect, color: SkColor4f) -> DrawQuad:
        val zero_rect = SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0)
        val empty_mailbox = SharedImageMailbox(bytes: [])
        DrawQuad(
            kind: DrawQuadKind.SolidColor,
            shared_quad_state_index: sqs_index,
            rect: rect,
            visible_rect: rect,
            needs_blending: true,
            solid_color: color,
            texture_mailbox: empty_mailbox,
            texture_premultiplied: false,
            uv_top_left: zero_rect,
            uv_bottom_right: zero_rect,
            render_pass_id: -1,
            mask_resource_id: -1,
            mask_uv_rect: zero_rect,
            filters_scale: 1.0,
            video_plane_count: 0,
            debug_width: 0
        )

    static fn texture(sqs_index: i32, rect: SkRect, mailbox: SharedImageMailbox) -> DrawQuad:
        val zero_rect = SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0)
        val zero_color = SkColor4f(r: 0.0, g: 0.0, b: 0.0, a: 0.0)
        DrawQuad(
            kind: DrawQuadKind.Texture,
            shared_quad_state_index: sqs_index,
            rect: rect,
            visible_rect: rect,
            needs_blending: true,
            solid_color: zero_color,
            texture_mailbox: mailbox,
            texture_premultiplied: true,
            uv_top_left: SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0),
            uv_bottom_right: SkRect(left: 1.0, top: 1.0, right: 1.0, bottom: 1.0),
            render_pass_id: -1,
            mask_resource_id: -1,
            mask_uv_rect: zero_rect,
            filters_scale: 1.0,
            video_plane_count: 0,
            debug_width: 0
        )

    static fn render_pass(sqs_index: i32, rect: SkRect, pass_id: i32) -> DrawQuad:
        val zero_rect = SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0)
        val zero_color = SkColor4f(r: 0.0, g: 0.0, b: 0.0, a: 0.0)
        val empty_mailbox = SharedImageMailbox(bytes: [])
        DrawQuad(
            kind: DrawQuadKind.RenderPass,
            shared_quad_state_index: sqs_index,
            rect: rect,
            visible_rect: rect,
            needs_blending: false,
            solid_color: zero_color,
            texture_mailbox: empty_mailbox,
            texture_premultiplied: false,
            uv_top_left: zero_rect,
            uv_bottom_right: zero_rect,
            render_pass_id: pass_id,
            mask_resource_id: -1,
            mask_uv_rect: zero_rect,
            filters_scale: 1.0,
            video_plane_count: 0,
            debug_width: 0
        )
