# damage.spl — Wave 3 (6c): damage aggregation across surfaces
#
# Provides rect union/intersect helpers and surface damage aggregation for the
# viz compositor.  Mirrors Chrome's DamageTracker role.

use std.skia.entity.geometry.{SkRect}
use std.skia.entity.matrix.{Matrix3x3}
use std.viz.entity.compositor_frame.{CompositorFrame}

# ============================================================================
# fn sk_rect_empty — canonical empty sentinel
# ============================================================================

fn sk_rect_empty() -> SkRect:
    SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0)

# ============================================================================
# fn union_rects
# Axis-aligned bounding union.  If one operand is empty (right <= left or
# bottom <= top) the other is returned unchanged.
# ============================================================================

fn union_rects(a: SkRect, b: SkRect) -> SkRect:
    """Return the axis-aligned bounding rect of a and b.
    If either rect is empty the other is returned unchanged."""
    val a_empty = (a.left >= a.right) or (a.top >= a.bottom)
    val b_empty = (b.left >= b.right) or (b.top >= b.bottom)
    if a_empty:
        return b
    if b_empty:
        return a
    val l = if a.left < b.left: a.left else: b.left
    val t = if a.top < b.top: a.top else: b.top
    val r = if a.right > b.right: a.right else: b.right
    val bot = if a.bottom > b.bottom: a.bottom else: b.bottom
    SkRect(left: l, top: t, right: r, bottom: bot)

# ============================================================================
# fn intersect_rect
# Axis-aligned intersection.  Returns empty (0,0,0,0) when disjoint.
# ============================================================================

fn intersect_rect(rect: SkRect, clip: SkRect) -> SkRect:
    """Intersect rect with clip.  Returns empty (0,0,0,0) when disjoint."""
    val l = if rect.left > clip.left: rect.left else: clip.left
    val t = if rect.top > clip.top: rect.top else: clip.top
    val r = if rect.right < clip.right: rect.right else: clip.right
    val b = if rect.bottom < clip.bottom: rect.bottom else: clip.bottom
    if (l >= r) or (t >= b):
        sk_rect_empty()
    else:
        SkRect(left: l, top: t, right: r, bottom: b)

# ============================================================================
# fn damage_from_frame
# Extract the aggregate damage rect from a CompositorFrame.
# The root render pass (last in render_pass_list) holds the frame-level
# damage_rect.  If there are multiple passes, union all damage_rects.
# Falls back to device_viewport_rect when the pass list is empty.
# ============================================================================

fn damage_from_frame(frame: CompositorFrame) -> SkRect:
    """Return the aggregate damage rect for frame.
    Unions all RenderPass.damage_rect fields; falls back to viewport."""
    val n = frame.render_pass_list.len().to_i32()
    if n == 0:
        return frame.device_viewport_rect
    var result = sk_rect_empty()
    var i = 0
    while i < n:
        val pass_damage = frame.render_pass_list[i.to_i64()].damage_rect
        result = union_rects(result, pass_damage)
        i = i + 1
    result

# ============================================================================
# fn aggregate_damage
# Aggregate damage across a root frame and a list of child surfaces.
#
# Algorithm:
#   1. Start with damage_rect from root_frame (via damage_from_frame).
#   2. For each child surface i:
#        child_dmg  = damage_from_frame(child_surfaces[i])
#        clipped    = intersect_rect(child_dmg, clips_for_surfaces[i])
#        running    = union_rects(running, clipped)
#   3. Clamp result to root_frame's device_viewport_rect.
# ============================================================================

fn aggregate_damage(root_frame: CompositorFrame, child_surfaces: [CompositorFrame], clips_for_surfaces: [SkRect]) -> SkRect:
    """Union damage from root and all clipped child surfaces, clamped to root viewport."""
    var running = damage_from_frame(root_frame)
    val n = child_surfaces.len().to_i32()
    var i = 0
    while i < n:
        val child_dmg = damage_from_frame(child_surfaces[i.to_i64()])
        val child_clip = clips_for_surfaces[i.to_i64()]
        val clipped = intersect_rect(child_dmg, child_clip)
        running = union_rects(running, clipped)
        i = i + 1
    intersect_rect(running, root_frame.device_viewport_rect)

# ============================================================================
# fn propagate_damage_up
# Transform a damage rect through a Matrix3x3 and return the axis-aligned
# bounding box of the four transformed corners.
#
# Matrix convention (row-major, Skia style):
#   x' = m00*x + m01*y + m02
#   y' = m10*x + m11*y + m12
# ============================================================================

fn _transform_point_x(m: Matrix3x3, px: f64, py: f64) -> f64:
    m.m00 * px + m.m01 * py + m.m02

fn _transform_point_y(m: Matrix3x3, px: f64, py: f64) -> f64:
    m.m10 * px + m.m11 * py + m.m12

fn propagate_damage_up(child_damage: SkRect, parent_transform: Matrix3x3) -> SkRect:
    """Transform child_damage through parent_transform and return AABB of the result."""
    val x0 = child_damage.left
    val y0 = child_damage.top
    val x1 = child_damage.right
    val y1 = child_damage.bottom
    val m = parent_transform

    val tx0y0_x = _transform_point_x(m, x0, y0)
    val tx0y0_y = _transform_point_y(m, x0, y0)
    val tx1y0_x = _transform_point_x(m, x1, y0)
    val tx1y0_y = _transform_point_y(m, x1, y0)
    val tx0y1_x = _transform_point_x(m, x0, y1)
    val tx0y1_y = _transform_point_y(m, x0, y1)
    val tx1y1_x = _transform_point_x(m, x1, y1)
    val tx1y1_y = _transform_point_y(m, x1, y1)

    # min x
    val min_x_a = if tx0y0_x < tx1y0_x: tx0y0_x else: tx1y0_x
    val min_x_b = if tx0y1_x < tx1y1_x: tx0y1_x else: tx1y1_x
    val min_x   = if min_x_a < min_x_b: min_x_a else: min_x_b
    # max x
    val max_x_a = if tx0y0_x > tx1y0_x: tx0y0_x else: tx1y0_x
    val max_x_b = if tx0y1_x > tx1y1_x: tx0y1_x else: tx1y1_x
    val max_x   = if max_x_a > max_x_b: max_x_a else: max_x_b
    # min y
    val min_y_a = if tx0y0_y < tx1y0_y: tx0y0_y else: tx1y0_y
    val min_y_b = if tx0y1_y < tx1y1_y: tx0y1_y else: tx1y1_y
    val min_y   = if min_y_a < min_y_b: min_y_a else: min_y_b
    # max y
    val max_y_a = if tx0y0_y > tx1y0_y: tx0y0_y else: tx1y0_y
    val max_y_b = if tx0y1_y > tx1y1_y: tx0y1_y else: tx1y1_y
    val max_y   = if max_y_a > max_y_b: max_y_a else: max_y_b

    SkRect(left: min_x, top: min_y, right: max_x, bottom: max_y)
