#!/bin/sh
# Guarded codex launcher.
#
# Routes every `codex` invocation through scripts/check/codex-run-guard.shs, the
# operational backstop for the AGENTS.md "Termination & Runaway Guard" rules
# (pre-flight poison-rollout refusal + wall-clock/RSS caps on unattended runs).
#
# Use this instead of the bare `codex`: e.g. `bin/codex resume <id> --yolo`,
# or put repo `bin/` ahead of ~/.npm-global/bin on PATH so `codex ...` is guarded.
REPO=$(CDPATH= cd "$(dirname "$0")/.." && pwd)
exec "$REPO/scripts/check/codex-run-guard.shs" "$@"
