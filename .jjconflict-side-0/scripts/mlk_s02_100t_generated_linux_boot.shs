#!/bin/sh
# Capture UART for an MLK-S02-100T generated Linux boot and verify markers.

set -eu

UART_PORT="${MLK_UART_PORT:-/dev/ttyUSB0}"
UART_BAUD="${MLK_UART_BAUD:-115200}"
UART_LOG=""
TIMEOUT_SEC="${MLK_UART_TIMEOUT_SEC:-120}"
COLD_BOOTS=1
MARKERS=""
BOOT_PRODUCTS_MANIFEST=""
PRODUCT_ID=""
BOOT_LOADER_CMD=""

while [ $# -gt 0 ]; do
    case "$1" in
        --uart-port=*) UART_PORT="${1#--uart-port=}" ;;
        --uart-baud=*) UART_BAUD="${1#--uart-baud=}" ;;
        --uart-log=*) UART_LOG="${1#--uart-log=}" ;;
        --timeout=*) TIMEOUT_SEC="${1#--timeout=}" ;;
        --cold-boots=*) COLD_BOOTS="${1#--cold-boots=}" ;;
        --markers=*) MARKERS="${1#--markers=}" ;;
        --boot-products-manifest=*) BOOT_PRODUCTS_MANIFEST="${1#--boot-products-manifest=}" ;;
        --product-id=*) PRODUCT_ID="${1#--product-id=}" ;;
        --boot-loader-cmd=*) BOOT_LOADER_CMD="${1#--boot-loader-cmd=}" ;;
        *) echo "unknown option: $1" >&2; exit 2 ;;
    esac
    shift
done

[ -n "$UART_LOG" ] || { echo "missing --uart-log" >&2; exit 2; }
mkdir -p "$(dirname "$UART_LOG")"

markers_from_manifest() {
    manifest_path="$1"
    product_id="$2"
    [ -f "$manifest_path" ] || { echo "missing --boot-products-manifest file: $manifest_path" >&2; exit 2; }
    awk -v product_id="$product_id" '
        $0 == "[[product]]" {
            in_product = 1
            matched = 0
            next
        }
        in_product && $0 ~ /^product_id = "/ {
            id = $0
            sub(/^product_id = "/, "", id)
            sub(/"$/, "", id)
            matched = (id == product_id)
            next
        }
        in_product && matched && $0 ~ /^expected_markers = "/ {
            markers = $0
            sub(/^expected_markers = "/, "", markers)
            sub(/"$/, "", markers)
            print markers
            exit
        }
    ' "$manifest_path"
}

resolve_markers() {
    if [ -n "$MARKERS" ]; then
        return 0
    fi
    if [ -n "$BOOT_PRODUCTS_MANIFEST" ] && [ -n "$PRODUCT_ID" ]; then
        MARKERS="$(markers_from_manifest "$BOOT_PRODUCTS_MANIFEST" "$PRODUCT_ID")"
    fi
    [ -n "$MARKERS" ] || { echo "missing UART markers; pass --markers or both --boot-products-manifest and --product-id" >&2; exit 2; }
}

configure_uart() {
    stty -F "$UART_PORT" "$UART_BAUD" cs8 -cstopb -parenb -ixon -ixoff -icanon -echo min 1 time 0
}

check_markers() {
    old_ifs="$IFS"
    IFS='|'
    for marker in $MARKERS; do
        if ! grep -a -q "$marker" "$UART_LOG"; then
            IFS="$old_ifs"
            return 1
        fi
    done
    IFS="$old_ifs"
    return 0
}

resolve_markers

attempt=1
while [ "$attempt" -le "$COLD_BOOTS" ]; do
    : > "$UART_LOG"
    configure_uart
    cat < "$UART_PORT" > "$UART_LOG" &
    cat_pid=$!
    if [ -n "$BOOT_LOADER_CMD" ]; then
        sh -c "$BOOT_LOADER_CMD"
    fi
    deadline=$(( $(date +%s) + TIMEOUT_SEC ))
    ok=0
    while [ "$(date +%s)" -lt "$deadline" ]; do
        if check_markers; then
            ok=1
            break
        fi
        sleep 1
    done
    kill "$cat_pid" 2>/dev/null || true
    wait "$cat_pid" 2>/dev/null || true
    if [ "$ok" -ne 1 ]; then
        echo "FAIL: UART markers missing in $UART_LOG for cold boot $attempt/$COLD_BOOTS" >&2
        exit 1
    fi
    attempt=$((attempt + 1))
done

echo "PASS: UART markers found for $COLD_BOOTS cold boot(s)"
