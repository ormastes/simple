#!/bin/sh
# run_os_tests.shs — Compile and run all OS unit tests, report results.
#
# Usage: scripts/run_os_tests.shs
#
# Finds test/unit/os/test_*.spl, compiles each with the Rust bootstrap
# compiler, runs with a 10s timeout, and checks output for FAIL:/OK:.

set -eu

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
COMPILER="$REPO_ROOT/src/compiler_rust/target/bootstrap/simple"
BUILD_DIR="$REPO_ROOT/build"
TEST_DIR="$REPO_ROOT/test/unit/os"

# Ensure build directory exists
mkdir -p "$BUILD_DIR"

test_list="$BUILD_DIR/os_test_files.list"
find "$TEST_DIR" -maxdepth 1 -name 'test_*.spl' | sort > "$test_list"

total=$(wc -l < "$test_list" | tr -d ' ')
if [ "$total" -eq 0 ]; then
    echo "No test files found matching test/unit/os/test_*.spl"
    exit 1
fi

passed=0
failed=0
no_output=0

while IFS= read -r test_file; do
    # Derive test name from filename (strip directory and .spl extension)
    basename_spl="$(basename "$test_file")"
    testname="${basename_spl%.spl}"
    binary="$BUILD_DIR/$testname"

    echo "========================================"
    echo "TEST: $testname"
    echo "  Source: $test_file"

    # --- Compile ---
    echo "  Compiling..."
    compile_log="$BUILD_DIR/$testname.compile.log"
    if "$COMPILER" native-build --entry-closure --entry "$test_file" -o "$binary" > "$compile_log" 2>&1; then
        compile_status=0
    else
        compile_status=$?
    fi
    compile_output=$(grep -E "failed|complete|error" "$compile_log" || true)
    echo "  Compile: $compile_output"

    if [ "$compile_status" -ne 0 ]; then
        echo "  RESULT: COMPILE FAILED"
        echo "  Full compile log: $compile_log"
        failed=$((failed + 1))
        continue
    fi

    if [ ! -x "$binary" ]; then
        echo "  RESULT: COMPILE FAILED (no binary produced)"
        failed=$((failed + 1))
        continue
    fi

    # --- Run ---
    echo "  Running (timeout 10s)..."
    run_output=$(timeout 10 "$binary" 2>&1 || true)

    if [ -z "$run_output" ]; then
        echo "  RESULT: NO OUTPUT (possible entry point bug)"
        no_output=$((no_output + 1))
        continue
    fi

    echo "  Output:"
    echo "$run_output" | sed 's/^/    /'

    # --- Check results ---
    has_fail=false
    has_ok=false

    if echo "$run_output" | grep -q "FAIL:"; then
        has_fail=true
    fi
    if echo "$run_output" | grep -q "OK:"; then
        has_ok=true
    fi

    if $has_fail; then
        echo "  RESULT: FAILED"
        failed=$((failed + 1))
    elif $has_ok; then
        echo "  RESULT: PASSED"
        passed=$((passed + 1))
    else
        echo "  RESULT: NO OUTPUT (no OK:/FAIL: markers found)"
        no_output=$((no_output + 1))
    fi
done < "$test_list"

echo ""
echo "========================================"
echo "SUMMARY: $passed passed, $failed failed, $no_output no-output out of $total total"
echo "========================================"

if [ "$failed" -gt 0 ] || [ "$no_output" -gt 0 ]; then
    exit 1
fi

exit 0
