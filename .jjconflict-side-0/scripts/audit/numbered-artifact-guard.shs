#!/bin/sh
# Guard against LLM-style numbered duplicate artifacts.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

MODE="--staged"
BASE_REF=""

usage() {
    cat <<'EOF'
Usage: sh scripts/audit/numbered-artifact-guard.shs [--working|--staged|--all|--changed-from <ref>|--self-test]

Blocks newly added or renamed files that look like LLM-created numbered copies:
foo_1.spl, foo-2.spl, foo_part1.md, foo.v2.md, foo_ver1.md, foo_version1.md.
EOF
}

if [ "$#" -gt 0 ]; then
    MODE="$1"
    shift
fi

case "$MODE" in
        --working|--staged|--all|--self-test) ;;
    --changed-from)
        [ "$#" -ge 1 ] || { usage >&2; exit 2; }
        BASE_REF="$1"
        ;;
    -h|--help)
        usage
        exit 0
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac

is_in_scope() {
    case "$1" in
        src/*|test/*|doc/*|.claude/*|.codex/*|.agents/*|scripts/*) ;;
        *) return 1 ;;
    esac
    case "$1" in
        src/compiler_rust/vendor/*|src/runtime/vendor/*|src/compiler_rust/target*|build/*|target/*|tools/tauri-shell/src-tauri/gen/*|src/app/vscode_extension/node_modules/*|src/app/vscode_extension/.vscode-test/*|doc/09_report/misc/*)
            return 1
            ;;
    esac
    return 0
}

strip_extension() {
    base="$1"
    case "$base" in
        *.*) printf '%s\n' "${base%.*}" ;;
        *) printf '%s\n' "$base" ;;
    esac
}

classify_path() {
    path="$1"
    is_in_scope "$path" || return 1
    base="${path##*/}"
    stem="$(strip_extension "$base")"

    # Legitimate architecture/protocol/date/semantic-version names.
    echo "$base" | grep -Eiq '^(x86_64|armv[0-9]+|rv(32|64)|i[0-9]+)([._-]|$)' && return 1
    echo "$base" | grep -Eq '(^|[_-])(19|20)[0-9]{2}($|[_-])' && return 1
    echo "$base" | grep -Eiq '(^|[_-])v?[0-9]+\.[0-9]+(\.[0-9]+)?([._-]|$)' && return 1

    if echo "$stem" | grep -Eq '^[A-Za-z][A-Za-z0-9]*[_-][0-9]{1,3}$'; then
        printf 'copy_number_suffix:%s\n' "$stem"
        return 0
    fi
    case "$path" in
        src/*) ;;
        *)
            if echo "$stem" | grep -Eiq '(^|[_\.-])part[_\.-]?[0-9]{1,3}$'; then
                printf 'part_number:%s\n' "$stem"
                return 0
            fi
            if echo "$stem" | grep -Eiq '(^|[_\.-])(v|ver|version)[_\.-]?[0-9]{1,3}$'; then
                printf 'version_number:%s\n' "$stem"
                return 0
            fi
            ;;
    esac
    return 1
}

self_test() {
    for path in \
        src/app/foo_1.spl \
        src/app/foo-2.spl \
        doc/05_design/foo_v2.md \
        doc/05_design/foo-ver3.md \
        doc/05_design/foo_version4.md \
        doc/05_design/foo_part1.md \
        doc/05_design/foo.part2.md \
        doc/05_design/foo.version2.md \
        doc/05_design/part2.md
    do
        classify_path "$path" >/dev/null || {
            echo "self-test positive failed: $path" >&2
            exit 1
        }
    done

    for path in \
        src/app/foo_parser.spl \
        src/app/x86_64/tls_unit_entry.spl \
        doc/09_report/thing_2026-05-30.md \
        doc/09_report/RELEASE_0.6.0_SUMMARY.md \
        doc/04_architecture/format/smf_v1.1_summary.md \
        doc/09_report/misc/cmm_validate_arm_kernel_v14.txt \
        src/app/foo_part1.spl \
        src/app/foo_v2.spl \
        src/compiler/10.frontend/parser.spl
    do
        if classify_path "$path" >/dev/null; then
            echo "self-test negative failed: $path" >&2
            exit 1
        fi
    done
    echo "STATUS: PASS numbered-artifact-guard self-test"
}

list_paths() {
    case "$MODE" in
        --all)
            if [ -d .jj ] && command -v jj >/dev/null 2>&1; then
                jj file list
            else
                git ls-files
            fi
            ;;
        --working)
            git status --porcelain=v1 --untracked-files=all |
                awk '
                    {
                        status = substr($0, 1, 2)
                        path = substr($0, 4)
                        if (status ~ /R/) {
                            sub(/^.* -> /, "", path)
                            print path
                        } else if (status ~ /A/ || status == "??") {
                            print path
                        }
                    }
                '
            ;;
        --staged)
            git diff --cached --name-status --diff-filter=AR |
                awk -F '\t' '/^R/ {print $3; next} {print $2}'
            ;;
        --changed-from)
            git diff --name-status --diff-filter=AR "$BASE_REF" HEAD |
                awk -F '\t' '/^R/ {print $3; next} {print $2}'
            ;;
    esac
}

classify_paths_stream() {
    awk '
        function in_scope(path) {
            if (path !~ /^(src|test|doc|\.claude|\.codex|\.agents|scripts)\//) {
                return 0
            }
            if (path ~ /^(src\/compiler_rust\/vendor|src\/runtime\/vendor|src\/compiler_rust\/target|build|target|tools\/tauri-shell\/src-tauri\/gen|src\/app\/vscode_extension\/node_modules|src\/app\/vscode_extension\/\.vscode-test|doc\/09_report\/misc)(\/|$)/) {
                return 0
            }
            return 1
        }

        function basename(path, parts, n) {
            n = split(path, parts, "/")
            return parts[n]
        }

        function stemname(base) {
            sub(/\.[^.]*$/, "", base)
            return base
        }

        function classify(path, base, stem, lower) {
            if (!in_scope(path)) {
                return
            }
            base = basename(path)
            stem = stemname(base)
            lower = tolower(base)

            if (lower ~ /^(x86_64|armv[0-9]+|rv(32|64)|i[0-9]+)([._-]|$)/) {
                return
            }
            if (base ~ /(^|[_-])(19|20)[0-9][0-9]($|[_-])/) {
                return
            }
            if (lower ~ /(^|[_-])v?[0-9]+\.[0-9]+(\.[0-9]+)?([._-]|$)/) {
                return
            }

            if (stem ~ /^[A-Za-z][A-Za-z0-9]*[_-][0-9]{1,3}$/) {
                print path "\tcopy_number_suffix\t" stem
                return
            }
            if (path !~ /^src\//) {
                lower = tolower(stem)
                if (lower ~ /(^|[_\.-])part[_\.-]?[0-9]{1,3}$/) {
                    print path "\tpart_number\t" stem
                    return
                }
                if (lower ~ /(^|[_\.-])(v|ver|version)[_\.-]?[0-9]{1,3}$/) {
                    print path "\tversion_number\t" stem
                    return
                }
            }
        }

        NF > 0 { classify($0) }
    '
}

if [ "$MODE" = "--self-test" ]; then
    self_test
    exit 0
fi

tmp="${TMPDIR:-/tmp}/numbered-artifact-guard.$$"
trap 'rm -f "$tmp"' EXIT
: > "$tmp"

list_paths | classify_paths_stream > "$tmp"

if [ ! -s "$tmp" ]; then
    echo "Numbered artifact guard: OK"
    exit 0
fi

echo "Numbered artifact guard: suspicious numbered artifacts"
while IFS="$(printf '\t')" read -r path kind token; do
    echo "  - $path ($kind: $token)"
done < "$tmp"
echo
echo "Rename the artifact to a meaningful domain/module name, or update the"
echo "existing file instead of creating a numbered copy."
exit 1
