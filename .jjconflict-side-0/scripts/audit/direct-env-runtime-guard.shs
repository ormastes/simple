#!/bin/sh
# Guard against local env/process runtime calls outside owner modules.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

MODE="${1:---all}"

usage() {
    cat <<'EOF'
Usage: sh scripts/audit/direct-env-runtime-guard.shs [--all|--working|--staged|--self-test]

Blocks direct rt_env_get/cwd and direct process run/spawn/lifecycle calls or
imports in production app leaf code and gc_async_mut lib code outside runtime
owner modules. Use app/std/gc env and process facades instead.

Scope is intentionally src/app plus src/lib/gc_async_mut. Examples, tests,
compiler/bootstrap modules, and lower runtime owner layers are audited/fixed in
their own lanes; the 8K showcase has a documented local runtime-env boundary in
doc/08_tracking/bug/interp_io_runtime_env_get_option_text_corruption_2026-06-19.md.
EOF
}

case "$MODE" in
    --all|--working|--staged|--self-test) ;;
    -h|--help) usage; exit 0 ;;
    *) usage >&2; exit 2 ;;
esac

FORBIDDEN_DIRECT_ENV_PROCESS_RE='extern fn rt_env_(get|cwd)[[:space:]]*\(|rt_env_(get|cwd)[[:space:]]*\(|extern fn rt_process_(run(_timeout)?|spawn_async|wait|is_running|is_alive|kill)[[:space:]]*\(|rt_process_(run(_timeout)?|spawn_async|wait|is_running|is_alive|kill)[[:space:]]*\(|^(use|import|from|export[[:space:]]+use)[[:space:]].*rt_env_(get|cwd)([^[:alnum:]_]|$)|^(use|import|from|export[[:space:]]+use)[[:space:]].*rt_process_(run(_timeout)?|spawn_async|wait|is_running|is_alive|kill)([^[:alnum:]_]|$)'

self_test() {
    tmp_dir="${TMPDIR:-/tmp}/direct-env-runtime-guard.$$"
    mkdir -p "$tmp_dir"
    trap 'rm -rf "$tmp_dir"' EXIT
    printf '%s\n' 'use std.env.types.{rt_process_run}' >"$tmp_dir/raw_import.spl"
    printf '%s\n' 'use app.io.mod.{process_run_timeout}' >"$tmp_dir/facade_import.spl"
    printf '%s\n' 'val result = rt_process_spawn_async("sh", ["-c", "true"])' >"$tmp_dir/raw_call.spl"
    printf '%s\n' 'extern fn rt_env_get_var(env_handle: i64, name: text) -> auto' >"$tmp_dir/env_handle_owner.spl"

    grep -nE "$FORBIDDEN_DIRECT_ENV_PROCESS_RE" "$tmp_dir/raw_import.spl" >/dev/null || {
        echo "STATUS: FAIL direct-env-runtime-guard self-test raw import not detected" >&2
        exit 1
    }
    grep -nE "$FORBIDDEN_DIRECT_ENV_PROCESS_RE" "$tmp_dir/raw_call.spl" >/dev/null || {
        echo "STATUS: FAIL direct-env-runtime-guard self-test raw call not detected" >&2
        exit 1
    }
    if grep -nE "$FORBIDDEN_DIRECT_ENV_PROCESS_RE" "$tmp_dir/facade_import.spl" >/dev/null; then
        echo "STATUS: FAIL direct-env-runtime-guard self-test facade import rejected" >&2
        exit 1
    fi
    if grep -nE "$FORBIDDEN_DIRECT_ENV_PROCESS_RE" "$tmp_dir/env_handle_owner.spl" >/dev/null; then
        echo "STATUS: FAIL direct-env-runtime-guard self-test env handle owner rejected" >&2
        exit 1
    fi

    echo "STATUS: PASS direct-env-runtime-guard self-test"
}

if [ "$MODE" = "--self-test" ]; then
    self_test
    exit 0
fi

is_allowed_owner() {
    case "$1" in
        src/app/io/*) return 0 ;;
        src/app/ffi_gen.specs/*) return 0 ;;
        src/lib/nogc_sync_mut/io/env_ops.spl) return 0 ;;
    esac
    return 1
}

paths_for_mode() {
    case "$MODE" in
        --all)
            if [ -d .git ]; then
                git ls-files src/app src/lib/gc_async_mut | grep '\.spl$' || true
            elif [ -d .jj ] && command -v jj >/dev/null 2>&1; then
                jj file list src/app src/lib/gc_async_mut | grep '\.spl$' || true
            fi
            ;;
        --working)
            if [ -d .git ]; then
                {
                    git diff --name-only -- src/app src/lib/gc_async_mut
                    git ls-files --others --exclude-standard -- src/app src/lib/gc_async_mut
                } | grep '\.spl$' || true
            elif [ -d .jj ] && command -v jj >/dev/null 2>&1; then
                jj diff --name-only -- src/app src/lib/gc_async_mut | grep '\.spl$' || true
            fi
            ;;
        --staged)
            if [ -d .git ]; then
                git diff --cached --name-only -- src/app src/lib/gc_async_mut | grep '\.spl$' || true
            fi
            ;;
    esac
}

failures=""
for path in $(paths_for_mode | sort -u); do
    [ -f "$path" ] || continue
    is_allowed_owner "$path" && continue
    if grep -nE "$FORBIDDEN_DIRECT_ENV_PROCESS_RE" "$path" >/tmp/direct-env-runtime-guard.$$ 2>/dev/null; then
        while IFS= read -r line; do
            failures="${failures}${path}:${line}
"
        done < /tmp/direct-env-runtime-guard.$$
    fi
done
rm -f /tmp/direct-env-runtime-guard.$$

if [ -n "$failures" ]; then
    printf '%s' "$failures" >&2
    echo "STATUS: FAIL direct env/process runtime call outside owners" >&2
    exit 1
fi

echo "STATUS: PASS direct-env-runtime-guard"
