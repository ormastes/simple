#!/usr/bin/env bash
set -u

ROOT_DIR=$(cd "$(dirname "$0")/../.." && pwd)
cd "$ROOT_DIR" || exit 1

BUILD_DIR=${BUILD_DIR:-build/test-artifacts/02_integration/app/ui/web_wm_modern_shell_evidence}
EVIDENCE_ENV=${EVIDENCE_ENV:-"$BUILD_DIR/evidence.env"}
REPORT_PATH=${REPORT_PATH:-"$BUILD_DIR/report.md"}
HTML_PATH=${HTML_PATH:-"$BUILD_DIR/simple_wm_modern_preview.html"}
ARGB_PATH=${ARGB_PATH:-"$BUILD_DIR/simple_wm_modern_preview_argb.json"}
PNG_PATH=${PNG_PATH:-"$BUILD_DIR/simple_wm_modern_preview.png"}
AUDIT_PATH=${AUDIT_PATH:-"$BUILD_DIR/simple_wm_modern_preview_audit.json"}
LOG_PATH=${LOG_PATH:-"$BUILD_DIR/electron_capture.log"}
INTERACTION_PATH=${INTERACTION_PATH:-"$BUILD_DIR/simple_wm_modern_preview_interaction.json"}
INTERACTION_PNG_PATH=${INTERACTION_PNG_PATH:-"$BUILD_DIR/simple_wm_modern_preview_after_interaction.png"}
INTERACTION_LOG_PATH=${INTERACTION_LOG_PATH:-"$BUILD_DIR/electron_interaction.log"}
WIDTH=${WIDTH:-1360}
HEIGHT=${HEIGHT:-840}
ELECTRON_BIN=${ELECTRON_BIN:-tools/electron-shell/node_modules/electron/dist/electron}
TIMEOUT_SECS=${WEB_WM_MODERN_SHELL_TIMEOUT_SECS:-${TIMEOUT_SECS:-45}}
ELECTRON_STABLE_FLAGS="--no-sandbox --disable-gpu --disable-gpu-compositing --disable-software-rasterizer=false --disable-features=VizDisplayCompositor --force-device-scale-factor=1 --high-dpi-support=1 --force-color-profile=srgb"
SIMPLE_CMD=${SIMPLE_CMD:-}
SIMPLE_CMD_SOURCE=${SIMPLE_CMD_SOURCE:-explicit-env}
SIMPLE_CMD_STATUS=pass
SIMPLE_RUNTIME_FAILURES=${SIMPLE_RUNTIME_FAILURES:-}

mkdir -p "$BUILD_DIR" "$(dirname "$EVIDENCE_ENV")" "$(dirname "$REPORT_PATH")"

run_bound() {
  if command -v timeout >/dev/null 2>&1; then
    timeout "$TIMEOUT_SECS" "$@"
  elif command -v gtimeout >/dev/null 2>&1; then
    gtimeout "$TIMEOUT_SECS" "$@"
  else
    "$@"
  fi
}

write_evidence() {
  status=$1
  reason=$2
  {
    printf 'web_wm_modern_shell_evidence_status=%s\n' "$status"
    printf 'web_wm_modern_shell_evidence_reason=%s\n' "$reason"
    printf 'web_wm_modern_shell_evidence_html=%s\n' "$HTML_PATH"
    printf 'web_wm_modern_shell_evidence_html_path=%s\n' "$HTML_PATH"
    printf 'web_wm_modern_shell_evidence_argb=%s\n' "$ARGB_PATH"
    printf 'web_wm_modern_shell_evidence_argb_path=%s\n' "$ARGB_PATH"
    printf 'web_wm_modern_shell_evidence_png=%s\n' "$PNG_PATH"
    printf 'web_wm_modern_shell_evidence_png_path=%s\n' "$PNG_PATH"
    printf 'web_wm_modern_shell_evidence_audit=%s\n' "$AUDIT_PATH"
    printf 'web_wm_modern_shell_evidence_audit_path=%s\n' "$AUDIT_PATH"
    printf 'web_wm_modern_shell_evidence_log=%s\n' "$LOG_PATH"
    printf 'web_wm_modern_shell_evidence_log_path=%s\n' "$LOG_PATH"
    printf 'web_wm_modern_shell_evidence_interaction=%s\n' "$INTERACTION_PATH"
    printf 'web_wm_modern_shell_evidence_interaction_path=%s\n' "$INTERACTION_PATH"
    printf 'web_wm_modern_shell_evidence_interaction_png=%s\n' "$INTERACTION_PNG_PATH"
    printf 'web_wm_modern_shell_evidence_interaction_png_path=%s\n' "$INTERACTION_PNG_PATH"
    printf 'web_wm_modern_shell_evidence_interaction_log=%s\n' "$INTERACTION_LOG_PATH"
    printf 'web_wm_modern_shell_evidence_interaction_log_path=%s\n' "$INTERACTION_LOG_PATH"
    printf 'web_wm_modern_shell_evidence_width=%s\n' "$WIDTH"
    printf 'web_wm_modern_shell_evidence_height=%s\n' "$HEIGHT"
    printf 'web_wm_modern_shell_evidence_selectors=%s\n' '#wm-desktop,.wm-window,.wm-titlebar,.wm-command-palette,.wm-effect-controls,.wm-quality-inspector,.wm-traffic-lights button,.wm-command-palette-input,.wm-command-item,.wm-taskbar-item,.wm-effect-control'
    printf 'web_wm_modern_shell_evidence_contrast_min_x100=450\n'
    printf 'web_wm_modern_shell_evidence_touch_min_px=44\n'
    printf 'web_wm_modern_shell_evidence_media_features=%s\n' 'prefers-contrast=more,prefers-reduced-motion=reduce'
    printf 'web_wm_modern_shell_evidence_simple_runtime=%s\n' "${SIMPLE_CMD:-unavailable}"
    printf 'web_wm_modern_shell_evidence_simple_runtime_source=%s\n' "${SIMPLE_CMD_SOURCE:-unavailable}"
    printf 'web_wm_modern_shell_evidence_simple_runtime_status=%s\n' "${SIMPLE_CMD_STATUS:-unavailable}"
    printf 'web_wm_modern_shell_evidence_simple_runtime_failures=%s\n' "${SIMPLE_RUNTIME_FAILURES:-none}"
    printf 'web_wm_modern_shell_evidence_bitmap_nonblank_status=%s\n' "${BITMAP_NONBLANK_STATUS:-not-run}"
    printf 'web_wm_modern_shell_evidence_audit_pass=%s\n' "${AUDIT_PASS:-not-run}"
    printf 'web_wm_modern_shell_evidence_unexpected_overlap_count=%s\n' "${UNEXPECTED_OVERLAP_COUNT:-not-run}"
    printf 'web_wm_modern_shell_evidence_clipped_count=%s\n' "${CLIPPED_COUNT:-not-run}"
    printf 'web_wm_modern_shell_evidence_contrast_failures=%s\n' "${CONTRAST_FAILURES:-not-run}"
    printf 'web_wm_modern_shell_evidence_touch_failures=%s\n' "${TOUCH_FAILURES:-not-run}"
    printf 'web_wm_modern_shell_evidence_interaction_pass=%s\n' "${INTERACTION_PASS:-not-run}"
    printf 'web_wm_modern_shell_evidence_interaction_focus=%s\n' "${INTERACTION_FOCUS:-not-run}"
    printf 'web_wm_modern_shell_evidence_interaction_keyboard=%s\n' "${INTERACTION_KEYBOARD:-not-run}"
    printf 'web_wm_modern_shell_evidence_interaction_input=%s\n' "${INTERACTION_INPUT:-not-run}"
    printf 'web_wm_modern_shell_evidence_interaction_pointer=%s\n' "${INTERACTION_POINTER:-not-run}"
    printf 'web_wm_modern_shell_evidence_interaction_clicks=%s\n' "${INTERACTION_CLICKS:-not-run}"
    printf 'web_wm_modern_shell_evidence_interaction_event_count=%s\n' "${INTERACTION_EVENT_COUNT:-not-run}"
  } > "$EVIDENCE_ENV"
}

write_report() {
  {
    printf '# Web WM Modern Shell Evidence\n\n'
    printf '%s\n' "- status: \`$1\`"
    printf '%s\n' "- reason: \`$2\`"
    printf '%s\n' "- preview: \`$HTML_PATH\`"
    printf '%s\n' "- ARGB: \`$ARGB_PATH\`"
    printf '%s\n' "- PNG: \`$PNG_PATH\`"
    printf '%s\n' "- audit: \`$AUDIT_PATH\`"
    printf '%s\n' "- interaction: \`$INTERACTION_PATH\`"
    printf '%s\n' "- interaction PNG: \`$INTERACTION_PNG_PATH\`"
    printf '%s\n' "- log: \`$LOG_PATH\`"
    printf '%s\n' "- interaction log: \`$INTERACTION_LOG_PATH\`"
    printf '%s\n' "- simple runtime: \`${SIMPLE_CMD:-unavailable}\`"
    printf '%s\n' "- simple runtime source: \`${SIMPLE_CMD_SOURCE:-unavailable}\`"
    printf '%s\n' "- simple runtime status: \`${SIMPLE_CMD_STATUS:-unavailable}\`"
  } > "$REPORT_PATH"
}

is_rust_seed_simple() {
  case "$1" in
    src/compiler_rust/*|*/src/compiler_rust/*|./src/compiler_rust/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

if [ -n "$SIMPLE_CMD" ] && is_rust_seed_simple "$SIMPLE_CMD"; then
  SIMPLE_CMD_SOURCE=explicit-env-rust-seed-forbidden
  SIMPLE_CMD_STATUS=forbidden
  write_evidence fail simple-runtime-forbidden
  write_report fail simple-runtime-forbidden
  exit 1
fi

TMP_SPL="$BUILD_DIR/write_preview.spl"
cat > "$TMP_SPL" <<SIMPLE_PREVIEW_EOF
use app.ui.web.html.{write_wm_modern_preview_html}

fn main():
    val ok = write_wm_modern_preview_html("$HTML_PATH", "glass_dark")
    if ok:
        print "preview_written"
    else:
        print "preview_failed"
SIMPLE_PREVIEW_EOF

if [ -z "$SIMPLE_CMD" ]; then
  SIMPLE_CMD_SOURCE=missing
  for candidate in \
    bin/release/*/simple \
    release/*/simple \
    build/bootstrap/stage3/simple \
    bin/simple \
    bin/simple_native
  do
    if [ -x "$candidate" ]; then
      if is_rust_seed_simple "$candidate"; then
        SIMPLE_RUNTIME_FAILURES="${SIMPLE_RUNTIME_FAILURES}${candidate}:rust-seed-forbidden,"
        continue
      fi
      "$candidate" --version >/dev/null 2>&1
      candidate_code=$?
      if [ $candidate_code -eq 0 ]; then
        SIMPLE_CMD=$candidate
        SIMPLE_CMD_SOURCE="self-hosted:$candidate"
        SIMPLE_CMD_STATUS=pass
        break
      fi
      SIMPLE_RUNTIME_FAILURES="${SIMPLE_RUNTIME_FAILURES}${candidate}:${candidate_code},"
    else
      SIMPLE_RUNTIME_FAILURES="${SIMPLE_RUNTIME_FAILURES}${candidate}:missing,"
    fi
  done
  if [ -z "$SIMPLE_CMD" ] && [ "${ALLOW_PATH_SIMPLE_CMD:-0}" = "1" ]; then
    path_simple_candidate="$(command -v simple 2>/dev/null || true)"
    if [ -n "$path_simple_candidate" ] && [ -x "$path_simple_candidate" ]; then
      if is_rust_seed_simple "$path_simple_candidate"; then
        SIMPLE_RUNTIME_FAILURES="${SIMPLE_RUNTIME_FAILURES}${path_simple_candidate}:rust-seed-forbidden,"
      else
        "$path_simple_candidate" --version >/dev/null 2>&1
        candidate_code=$?
        if [ $candidate_code -eq 0 ]; then
          SIMPLE_CMD="$path_simple_candidate"
          SIMPLE_CMD_SOURCE="path:$path_simple_candidate"
          SIMPLE_CMD_STATUS=pass
        else
          SIMPLE_RUNTIME_FAILURES="${SIMPLE_RUNTIME_FAILURES}${path_simple_candidate}:${candidate_code},"
        fi
      fi
    else
      SIMPLE_RUNTIME_FAILURES="${SIMPLE_RUNTIME_FAILURES}simple:path-missing,"
    fi
  fi
  if [ -z "$SIMPLE_CMD" ]; then
    SIMPLE_CMD_STATUS=missing
    write_evidence environment-unavailable simple-runtime-unavailable
    write_report environment-unavailable simple-runtime-unavailable
    exit 0
  fi
fi

SIMPLE_LIB=src "$SIMPLE_CMD" run "$TMP_SPL" > "$BUILD_DIR/preview.log" 2>&1
if [ $? -ne 0 ] || [ ! -s "$HTML_PATH" ]; then
  write_evidence environment-unavailable simple-runtime-preview-failed
  write_report environment-unavailable simple-runtime-preview-failed
  exit 0
fi

if [ ! -x "$ELECTRON_BIN" ]; then
  write_evidence environment-unavailable electron-missing
  write_report environment-unavailable electron-missing
  exit 0
fi

USE_XVFB=0
if [ -z "${DISPLAY:-}" ]; then
  if command -v xvfb-run >/dev/null 2>&1; then
    USE_XVFB=1
  else
    write_evidence environment-unavailable display-missing
    write_report environment-unavailable display-missing
    exit 0
  fi
fi

if [ "$USE_XVFB" = 1 ]; then
  rm -f "$ARGB_PATH" "$PNG_PATH" "$AUDIT_PATH" "$LOG_PATH" \
    "$INTERACTION_PATH" "$INTERACTION_PNG_PATH" "$INTERACTION_LOG_PATH"
  ELECTRON_CAPTURE_HTML="$HTML_PATH" \
  ELECTRON_CAPTURE_WIDTH="$WIDTH" \
  ELECTRON_CAPTURE_HEIGHT="$HEIGHT" \
  ELECTRON_CAPTURE_OUTPUT="$ARGB_PATH" \
  ELECTRON_CAPTURE_PNG_OUTPUT="$PNG_PATH" \
  ELECTRON_CAPTURE_AUDIT_SELECTORS="#wm-desktop,.wm-window,.wm-titlebar,.wm-command-palette,.wm-effect-controls,.wm-quality-inspector,.wm-traffic-lights button,.wm-command-palette-input,.wm-command-item,.wm-taskbar-item,.wm-effect-control" \
  ELECTRON_CAPTURE_AUDIT_OUTPUT="$AUDIT_PATH" \
  ELECTRON_CAPTURE_CONTRAST_MIN_X100=450 \
  ELECTRON_CAPTURE_TOUCH_MIN_PX=44 \
  ELECTRON_CAPTURE_MEDIA_FEATURES="prefers-contrast=more,prefers-reduced-motion=reduce" \
  ELECTRON_CAPTURE_FAIL_ON_AUDIT=1 \
  ELECTRON_CAPTURE_OFFSCREEN_PAINT=1 \
  ELECTRON_CAPTURE_SETTLE_MS=1500 \
  ELECTRON_DISABLE_SANDBOX=1 \
  run_bound xvfb-run --auto-servernum "$ELECTRON_BIN" $ELECTRON_STABLE_FLAGS tools/electron-live-bitmap/capture_html_argb.js >"$LOG_PATH" 2>&1
else
  rm -f "$ARGB_PATH" "$PNG_PATH" "$AUDIT_PATH" "$LOG_PATH" \
    "$INTERACTION_PATH" "$INTERACTION_PNG_PATH" "$INTERACTION_LOG_PATH"
  ELECTRON_CAPTURE_HTML="$HTML_PATH" \
  ELECTRON_CAPTURE_WIDTH="$WIDTH" \
  ELECTRON_CAPTURE_HEIGHT="$HEIGHT" \
  ELECTRON_CAPTURE_OUTPUT="$ARGB_PATH" \
  ELECTRON_CAPTURE_PNG_OUTPUT="$PNG_PATH" \
  ELECTRON_CAPTURE_AUDIT_SELECTORS="#wm-desktop,.wm-window,.wm-titlebar,.wm-command-palette,.wm-effect-controls,.wm-quality-inspector,.wm-traffic-lights button,.wm-command-palette-input,.wm-command-item,.wm-taskbar-item,.wm-effect-control" \
  ELECTRON_CAPTURE_AUDIT_OUTPUT="$AUDIT_PATH" \
  ELECTRON_CAPTURE_CONTRAST_MIN_X100=450 \
  ELECTRON_CAPTURE_TOUCH_MIN_PX=44 \
  ELECTRON_CAPTURE_MEDIA_FEATURES="prefers-contrast=more,prefers-reduced-motion=reduce" \
  ELECTRON_CAPTURE_FAIL_ON_AUDIT=1 \
  ELECTRON_CAPTURE_OFFSCREEN_PAINT=1 \
  ELECTRON_CAPTURE_SETTLE_MS=1500 \
  ELECTRON_DISABLE_SANDBOX=1 \
  run_bound "$ELECTRON_BIN" $ELECTRON_STABLE_FLAGS tools/electron-live-bitmap/capture_html_argb.js >"$LOG_PATH" 2>&1
fi
CAPTURE_CODE=$?

if [ $CAPTURE_CODE -ne 0 ]; then
  write_evidence fail capture-failed
  write_report fail capture-failed
  exit 1
fi

eval "$(
  node - "$ARGB_PATH" "$AUDIT_PATH" <<'NODE'
const fs = require("fs");
const argb = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const audit = JSON.parse(fs.readFileSync(process.argv[3], "utf8"));
const pixels = Array.isArray(argb.pixels) ? argb.pixels : [];
const nonblank = pixels.some(v => (v >>> 0) !== 0 && (v >>> 0) !== 0xffffffff);
function out(k, v) {
  console.log(`${k}=${String(v).replace(/[^A-Za-z0-9_.:-]/g, "_")}`);
}
out("BITMAP_NONBLANK_STATUS", nonblank ? "pass" : "fail");
out("AUDIT_PASS", audit.pass ? "pass" : "fail");
out("UNEXPECTED_OVERLAP_COUNT", audit.unexpectedOverlapCount ?? "missing");
out("CLIPPED_COUNT", audit.clippedCount ?? "missing");
out("CONTRAST_FAILURES", audit.contrastFailures ?? "missing");
out("TOUCH_FAILURES", audit.touchFailures ?? "missing");
NODE
)"

if [ "${BITMAP_NONBLANK_STATUS:-fail}" != pass ] || [ "${AUDIT_PASS:-fail}" != pass ]; then
  write_evidence fail audit-or-bitmap-failed
  write_report fail audit-or-bitmap-failed
  exit 1
fi

if [ "$USE_XVFB" = 1 ]; then
  rm -f "$INTERACTION_PATH" "$INTERACTION_PNG_PATH" "$INTERACTION_LOG_PATH"
  ELECTRON_INTERACT_HTML="$HTML_PATH" \
  ELECTRON_INTERACT_WIDTH="$WIDTH" \
  ELECTRON_INTERACT_HEIGHT="$HEIGHT" \
  ELECTRON_INTERACT_OUTPUT="$INTERACTION_PATH" \
  ELECTRON_INTERACT_PNG_OUTPUT="$INTERACTION_PNG_PATH" \
  ELECTRON_INTERACT_SETTLE_MS=800 \
  ELECTRON_DISABLE_SANDBOX=1 \
  run_bound xvfb-run --auto-servernum "$ELECTRON_BIN" $ELECTRON_STABLE_FLAGS tools/electron-live-bitmap/interact_html_controls.js >"$INTERACTION_LOG_PATH" 2>&1
else
  rm -f "$INTERACTION_PATH" "$INTERACTION_PNG_PATH" "$INTERACTION_LOG_PATH"
  ELECTRON_INTERACT_HTML="$HTML_PATH" \
  ELECTRON_INTERACT_WIDTH="$WIDTH" \
  ELECTRON_INTERACT_HEIGHT="$HEIGHT" \
  ELECTRON_INTERACT_OUTPUT="$INTERACTION_PATH" \
  ELECTRON_INTERACT_PNG_OUTPUT="$INTERACTION_PNG_PATH" \
  ELECTRON_INTERACT_SETTLE_MS=800 \
  ELECTRON_DISABLE_SANDBOX=1 \
  run_bound "$ELECTRON_BIN" $ELECTRON_STABLE_FLAGS tools/electron-live-bitmap/interact_html_controls.js >"$INTERACTION_LOG_PATH" 2>&1
fi
INTERACTION_CODE=$?

if [ $INTERACTION_CODE -ne 0 ]; then
  write_evidence fail interaction-failed
  write_report fail interaction-failed
  exit 1
fi

eval "$(
  node - "$INTERACTION_PATH" <<'NODE'
const fs = require("fs");
const interaction = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
function out(k, v) {
  console.log(`${k}=${String(v).replace(/[^A-Za-z0-9_.:-]/g, "_")}`);
}
out("INTERACTION_PASS", interaction.pass ? "pass" : "fail");
out("INTERACTION_FOCUS", interaction.focusDelivered ? "pass" : "fail");
out("INTERACTION_KEYBOARD", interaction.keyboardInput ? "pass" : "fail");
out("INTERACTION_INPUT", interaction.inputDelivered ? "pass" : "fail");
out("INTERACTION_POINTER", interaction.pointerDelivered ? "pass" : "fail");
out("INTERACTION_CLICKS", interaction.controlClickDelivered && interaction.taskbarClickDelivered && interaction.trafficClickDelivered ? "pass" : "fail");
out("INTERACTION_EVENT_COUNT", interaction.eventCount ?? "missing");
NODE
)"

if [ "${INTERACTION_PASS:-fail}" != pass ]; then
  write_evidence fail interaction-audit-failed
  write_report fail interaction-audit-failed
  exit 1
fi

write_evidence pass pass
write_report pass pass
