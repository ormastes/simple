#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

SIMPLE_BIN="${SIMPLE_BIN:-release/x86_64-unknown-linux-gnu/simple}"
BUILD_DIR="${BUILD_DIR:-build/llm_tooling_context_ponytail_mimic}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/2026/06/llm_tooling_context_ponytail_mimic_$(date -u +%F).md}"
OUT_ENV="$BUILD_DIR/evidence.env"
FULL_REPLACEMENT_EVIDENCE_ENV="${CONTEXT_PONYTAIL_FULL_REPLACEMENT_EVIDENCE_ENV:-build/llm_tooling_context_ponytail_full_replacement/evidence.env}"
SYSTEM_LOG="$BUILD_DIR/context_ponytail_mimic_system.log"
CONTEXT_UNIT_LOG="$BUILD_DIR/context_generate_unit.log"
PONYTAIL_UNIT_LOG="$BUILD_DIR/ponytail_audit_unit.log"
SURFACE_MANIFEST="$BUILD_DIR/context_ponytail_mimic_surface_manifest.tsv"
STRICT_FULL_REPLACEMENT=0

while [ "$#" -gt 0 ]; do
    case "$1" in
        --strict-full-replacement)
            STRICT_FULL_REPLACEMENT=1
            ;;
        --help|-h)
            echo "usage: sh scripts/check/check-llm-tooling-context-ponytail-mimic.shs [--strict-full-replacement]"
            echo "  --strict-full-replacement  require CONTEXT_PONYTAIL_FULL_REPLACEMENT_EVIDENCE_ENV with llm_tooling_context_ponytail_full_replacement_status=pass"
            exit 0
            ;;
        *)
            echo "unknown argument: $1" >&2
            exit 2
            ;;
    esac
    shift
done

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$OUT_ENV" "$SYSTEM_LOG" "$CONTEXT_UNIT_LOG" "$PONYTAIL_UNIT_LOG" "$REPORT_PATH" "$SURFACE_MANIFEST"

artifact_size() {
    path="$1"
    if [ -n "$path" ] && [ -s "$path" ]; then
        wc -c <"$path" | tr -d ' '
    else
        printf '%s\n' "0"
    fi
}

artifact_sha256() {
    path="$1"
    if [ -n "$path" ] && [ -s "$path" ]; then
        if command -v sha256sum >/dev/null 2>&1; then
            sha256sum "$path" | awk '{print $1}'
        elif command -v shasum >/dev/null 2>&1; then
            shasum -a 256 "$path" | awk '{print $1}'
        else
            printf '%s\n' "unavailable"
        fi
    else
        printf '%s\n' "missing"
    fi
}

run_check() {
    name="$1"
    log="$2"
    shift 2
    if "$@" >"$log" 2>&1; then
        eval "${name}_status=pass"
        eval "${name}_exit=0"
    else
        code=$?
        eval "${name}_status=fail"
        eval "${name}_exit=$code"
    fi
}

run_check system "$SYSTEM_LOG" "$SIMPLE_BIN" test test/03_system/app/tooling/feature/context_ponytail_mimic_spec.spl --mode=interpreter --clean
run_check context_unit "$CONTEXT_UNIT_LOG" "$SIMPLE_BIN" test test/01_unit/app/tooling/context_generate_spec.spl --mode=interpreter --clean
run_check ponytail_unit "$PONYTAIL_UNIT_LOG" "$SIMPLE_BIN" test test/01_unit/app/tooling/ponytail_audit_spec.spl --mode=interpreter --clean

status="pass"
if [ "$system_status" != "pass" ] || [ "$context_unit_status" != "pass" ] || [ "$ponytail_unit_status" != "pass" ]; then
    status="fail"
fi

{
    for path in \
        scripts/check/check-llm-tooling-context-ponytail-mimic.shs \
        test/03_system/app/tooling/feature/context_ponytail_mimic_spec.spl \
        test/01_unit/app/tooling/context_generate_spec.spl \
        test/01_unit/app/tooling/ponytail_audit_spec.spl \
        doc/07_guide/app/llm/llm_tooling_context_ponytail_mimic.md \
        doc/04_architecture/app/tools/llm_tooling_context_ponytail_mimic.md \
        doc/02_requirements/feature/llm_tooling_context_ponytail_mimic.md \
        "$SYSTEM_LOG" \
        "$CONTEXT_UNIT_LOG" \
        "$PONYTAIL_UNIT_LOG"
    do
        printf '%s\t%s\t%s\n' "$path" "$(artifact_size "$path")" "$(artifact_sha256 "$path")"
    done
} >"$SURFACE_MANIFEST"
surface_manifest_count="$(wc -l <"$SURFACE_MANIFEST" | tr -d ' ')"
surface_manifest_size="$(artifact_size "$SURFACE_MANIFEST")"
surface_manifest_sha256="$(artifact_sha256 "$SURFACE_MANIFEST")"

full_replacement_status="not_required"
full_replacement_reason="default_local_mimic_evidence_only"
if [ "$STRICT_FULL_REPLACEMENT" -eq 1 ]; then
    full_replacement_status="missing"
    full_replacement_reason="missing_full_replacement_evidence"
    if [ -f "$FULL_REPLACEMENT_EVIDENCE_ENV" ]; then
        evidence_status="$(sed -n 's/^llm_tooling_context_ponytail_full_replacement_status=//p' "$FULL_REPLACEMENT_EVIDENCE_ENV" | tail -n 1)"
        evidence_reason="$(sed -n 's/^llm_tooling_context_ponytail_full_replacement_reason=//p' "$FULL_REPLACEMENT_EVIDENCE_ENV" | tail -n 1)"
        if [ "$evidence_status" = "pass" ]; then
            full_replacement_status="pass"
            full_replacement_reason="${evidence_reason:-full_replacement_passed}"
        else
            full_replacement_status="${evidence_status:-fail}"
            full_replacement_reason="${evidence_reason:-full_replacement_not_passed}"
        fi
    fi
    if [ "$full_replacement_status" != "pass" ]; then
        status="fail"
    fi
fi

{
    printf '%s\n' "llm_tooling_context_ponytail_mimic_status=$status"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_strict_full_replacement=$STRICT_FULL_REPLACEMENT"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_full_replacement_status=$full_replacement_status"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_full_replacement_reason=$full_replacement_reason"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_full_replacement_env=$FULL_REPLACEMENT_EVIDENCE_ENV"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_system_status=$system_status"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_context_unit_status=$context_unit_status"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_ponytail_unit_status=$ponytail_unit_status"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_system_log_size=$(artifact_size "$SYSTEM_LOG")"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_system_log_sha256=$(artifact_sha256 "$SYSTEM_LOG")"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_context_unit_log_size=$(artifact_size "$CONTEXT_UNIT_LOG")"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_context_unit_log_sha256=$(artifact_sha256 "$CONTEXT_UNIT_LOG")"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_ponytail_unit_log_size=$(artifact_size "$PONYTAIL_UNIT_LOG")"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_ponytail_unit_log_sha256=$(artifact_sha256 "$PONYTAIL_UNIT_LOG")"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_surface_manifest=$SURFACE_MANIFEST"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_surface_manifest_count=$surface_manifest_count"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_surface_manifest_size=$surface_manifest_size"
    printf '%s\n' "llm_tooling_context_ponytail_mimic_surface_manifest_sha256=$surface_manifest_sha256"
} >"$OUT_ENV"

{
    printf '# LLM Tooling Context/Ponytail Mimic Evidence\n\n'
    printf '%s\n' "- status: \`$status\`"
    if [ "$STRICT_FULL_REPLACEMENT" -eq 1 ]; then
        printf '%s\n' "- strict_full_replacement: \`true\`"
    else
        printf '%s\n' "- strict_full_replacement: \`false\`"
    fi
    printf '%s\n' "- full_replacement: \`$full_replacement_status\`"
    printf '%s\n' "- full_replacement_reason: \`$full_replacement_reason\`"
    printf '%s\n' "- full_replacement_env: \`$FULL_REPLACEMENT_EVIDENCE_ENV\`"
    printf '%s\n' "- system_spec: \`$system_status\` exit=\`$system_exit\` log=\`$SYSTEM_LOG\`"
    printf '%s\n' "- system_spec_log_size: \`$(artifact_size "$SYSTEM_LOG")\`"
    printf '%s\n' "- system_spec_log_sha256: \`$(artifact_sha256 "$SYSTEM_LOG")\`"
    printf '%s\n' "- context_unit: \`$context_unit_status\` exit=\`$context_unit_exit\` log=\`$CONTEXT_UNIT_LOG\`"
    printf '%s\n' "- context_unit_log_size: \`$(artifact_size "$CONTEXT_UNIT_LOG")\`"
    printf '%s\n' "- context_unit_log_sha256: \`$(artifact_sha256 "$CONTEXT_UNIT_LOG")\`"
    printf '%s\n' "- ponytail_unit: \`$ponytail_unit_status\` exit=\`$ponytail_unit_exit\` log=\`$PONYTAIL_UNIT_LOG\`"
    printf '%s\n' "- ponytail_unit_log_size: \`$(artifact_size "$PONYTAIL_UNIT_LOG")\`"
    printf '%s\n' "- ponytail_unit_log_sha256: \`$(artifact_sha256 "$PONYTAIL_UNIT_LOG")\`"
    printf '%s\n' "- surface_manifest: \`$SURFACE_MANIFEST\`"
    printf '%s\n' "- surface_manifest_count: \`$surface_manifest_count\`"
    printf '%s\n' "- surface_manifest_size: \`$surface_manifest_size\`"
    printf '%s\n' "- surface_manifest_sha256: \`$surface_manifest_sha256\`"
    printf '%s\n' "- env: \`$OUT_ENV\`"
    printf '\n'
    if [ "$STRICT_FULL_REPLACEMENT" -eq 1 ]; then
        printf 'This strict full-replacement check requires a separate evidence env with `llm_tooling_context_ponytail_full_replacement_status=pass`. Local file-pack, embedded-SQL mimic, MCP exposure, and Ponytail audit evidence alone is not full external context-mode/Ponytail replacement proof.\n'
    else
        printf 'This evidence covers the checked-in Simple context-mode mimic, embedded-SQL context query path, Ponytail audit surface, and MCP/guide contract assertions in the executable specs. It does not prove full context-mode fetch/index replacement beyond local file packs or full external Ponytail workflow replacement; run with `--strict-full-replacement` when that completion evidence must pass.\n'
    fi
} >"$REPORT_PATH"

if [ "$status" = "pass" ]; then
    echo "STATUS: PASS llm-tooling-context-ponytail-mimic"
else
    echo "STATUS: FAIL llm-tooling-context-ponytail-mimic"
    exit 1
fi
