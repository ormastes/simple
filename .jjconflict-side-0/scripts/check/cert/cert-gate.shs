#!/bin/sh
set -u

# cert-gate.shs — consolidated flight-level certification READINESS gate.
#
# Runs every in-tree certification-evidence check in one command and prints a
# per-phase PASS / WARN / FAIL table for the aero-d / auto-a target grade
# (DO-178C DAL D / ISO 26262 ASIL A: statement coverage + robustness). Repeatable
# single-command verification is itself a certification requirement (SVP), so this
# is the entry point a reviewer / CI runs.
#
#   Phase 1  Requirements traceability     scripts/check/cert/check-req-traceability.shs
#   Phase 3  Structural coverage (MC/DC)   std.mcdc report self-test
#   Phase 4  Optimization soundness        scripts/check/cert/soundness-diff.shs
#   Phase 6  Formal (DO-333) codegen TV    scripts/check/check-lean-proofs.shs (mir_opt_tv)
#   Phase 7  Tool-qualification corpus     scripts/check/cert/run-tool-qual-corpus.shs
#
# The stage4 seed-cranelift wall is OUT OF SCOPE here: every check runs on the
# clean self-hosted bin/simple (see doc/03_plan/cert/cert_roadmap.md).
#
# Exit status:
#   0  no FAIL (WARN allowed — e.g. traceability orphan burndown still open)
#   1  at least one phase FAILed  (or a required tool/binary is missing)
#
# Env:  SIMPLE_BIN  compiler binary (default: bin/release/x86_64-unknown-linux-gnu/simple)
# Usage: sh scripts/check/cert/cert-gate.shs [--help]

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/../../.." && pwd)
CERT_DIR="$REPO_ROOT/scripts/check/cert"
SIMPLE_BIN="${SIMPLE_BIN:-$REPO_ROOT/bin/release/x86_64-unknown-linux-gnu/simple}"
export SIMPLE_BIN
LEAN_BIN_DIR="$HOME/.elan/bin"
[ -d "$LEAN_BIN_DIR" ] && PATH="$LEAN_BIN_DIR:$PATH"

case "${1:-}" in --help|-h) sed -n '3,30p' "$0"; exit 0 ;; esac

FAILS=0
WARNS=0
RESULTS=""

# record PHASE VERDICT DETAIL
record() { RESULTS="${RESULTS}${1}|${2}|${3}
"; case "$2" in FAIL) FAILS=$((FAILS+1)) ;; WARN) WARNS=$((WARNS+1)) ;; esac; }

hr() { printf -- '---------------------------------------------------------------\n'; }

if [ ! -x "$SIMPLE_BIN" ]; then
    printf 'cert-gate: FATAL — compiler binary not found/executable: %s\n' "$SIMPLE_BIN" >&2
    exit 1
fi

printf '== FLIGHT-LEVEL CERTIFICATION READINESS GATE ==\n'
printf 'target : aero-d / auto-a (DO-178C DAL D / ISO 26262 ASIL A)\n'
printf 'binary : %s\n' "$SIMPLE_BIN"
hr

# --- Phase 1: requirements traceability (WARN-tier: orphan burndown is open) ---
printf '[phase 1] requirements traceability ...\n'
P1=$(sh "$CERT_DIR/check-req-traceability.shs" 2>&1 || true)
P1SUM=$(printf '%s\n' "$P1" | grep -iE 'orphan|traced|defined' | tail -3 | tr '\n' ';')
if printf '%s' "$P1" | grep -qiE 'orphan.*[1-9]'; then
    record "1 traceability" WARN "orphans present (burndown open): ${P1SUM:-see report}"
else
    record "1 traceability" PASS "no orphans"
fi

# --- Phase 3: MC/DC structural-coverage report self-test ---
printf '[phase 3] MC/DC coverage report ...\n'
MCDC_SPEC="src/lib/nogc_sync_mut/test/mcdc_report_spec.spl"
if [ -f "$REPO_ROOT/$MCDC_SPEC" ]; then
    P3=$("$SIMPLE_BIN" test "$REPO_ROOT/$MCDC_SPEC" 2>&1); P3E=$?
    if [ "$P3E" -eq 0 ] && printf '%s' "$P3" | grep -qiE '0 fail'; then
        record "3 mc/dc report" PASS "$(printf '%s' "$P3" | grep -iE 'examples|Passed' | tail -1)"
    else
        record "3 mc/dc report" FAIL "spec did not pass (exit $P3E)"
    fi
else
    record "3 mc/dc report" WARN "spec not found ($MCDC_SPEC)"
fi

# --- Phase 4: optimization-soundness differential ---
printf '[phase 4] optimization-soundness differential ...\n'
P4=$(sh "$CERT_DIR/soundness-diff.shs" 2>&1); P4E=$?
if [ "$P4E" -eq 0 ]; then
    record "4 soundness" PASS "$(printf '%s' "$P4" | grep -iE 'summary|RESULT' | tail -1)"
else
    record "4 soundness" FAIL "$(printf '%s' "$P4" | grep -iE 'DIVERGE|BOTH-WRONG|NO-OUTPUT|RESULT' | tail -1)"
fi

# --- Phase 6: formal (DO-333) codegen translation-validation proof ---
printf '[phase 6] formal codegen TV proof (mir_opt_tv) ...\n'
if command -v lake >/dev/null 2>&1; then
    P6=$(sh "$REPO_ROOT/scripts/check/check-lean-proofs.shs" --project "$REPO_ROOT/src/verification/mir_opt_tv" 2>&1); P6E=$?
    if [ "$P6E" -eq 0 ]; then
        record "6 formal (do-333)" PASS "mir_opt_tv validate_sound proven (0 sorry/admit)"
    else
        record "6 formal (do-333)" FAIL "$(printf '%s' "$P6" | grep -iE 'FAIL|error' | tail -1)"
    fi
else
    record "6 formal (do-333)" WARN "lake/lean toolchain not on PATH"
fi

# --- Phase 7: tool-qualification validation corpus ---
printf '[phase 7] tool-qualification corpus ...\n'
P7=$(sh "$CERT_DIR/run-tool-qual-corpus.shs" 2>&1); P7E=$?
if [ "$P7E" -eq 0 ]; then
    record "7 tool-qual" PASS "$(printf '%s' "$P7" | grep -iE 'summary|RESULT' | tail -1)"
else
    record "7 tool-qual" FAIL "$(printf '%s' "$P7" | grep -iE 'summary|RESULT|defect' | tail -1)"
fi

# --- report -------------------------------------------------------------------
hr
printf '%-20s %-6s %s\n' "PHASE" "VERDICT" "DETAIL"
printf '%s' "$RESULTS" | while IFS='|' read -r ph vd dt; do
    [ -z "$ph" ] && continue
    printf '%-20s %-6s %s\n' "$ph" "$vd" "$dt"
done
hr
printf 'totals: %d FAIL, %d WARN\n' "$FAILS" "$WARNS"
if [ "$FAILS" -ne 0 ]; then
    printf 'CERT-GATE: FAIL (%d phase(s) failed)\n' "$FAILS"
    exit 1
fi
if [ "$WARNS" -ne 0 ]; then
    printf 'CERT-GATE: PASS with %d WARN (aero-d/auto-a readiness gaps are known/deferred)\n' "$WARNS"
    exit 0
fi
printf 'CERT-GATE: PASS (all phases clean)\n'
exit 0
