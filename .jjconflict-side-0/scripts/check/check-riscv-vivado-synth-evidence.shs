#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
VIVADO_SETTINGS="${VIVADO_SETTINGS:-$HOME/Xilinx/2025.2/Vivado/settings64.sh}"
REPORT_DIR="${RISCV_SYNTH_REPORT_DIR:-$ROOT_DIR/build/riscv_synth_reports}"

if [ ! -f "$VIVADO_SETTINGS" ]; then
    echo "SKIP: Vivado settings not found at $VIVADO_SETTINGS"
    exit 0
fi

rm -rf "$REPORT_DIR"
mkdir -p "$REPORT_DIR"

RISCV_SYNTH_REPORT_DIR="$REPORT_DIR" sh "$ROOT_DIR/scripts/fpga/build_k26_rv32.shs" --synth-only
RISCV_SYNTH_REPORT_DIR="$REPORT_DIR" sh "$ROOT_DIR/scripts/fpga/build_k26_vexriscv.shs" --synth-only

SYNTH_REPORT_DIR="$REPORT_DIR" sh "$ROOT_DIR/scripts/check/check-riscv-product-level-evidence.shs" --require-vivado

echo "STATUS: PASS riscv-vivado-synth-evidence"
