#!/bin/sh
if [ "$1" = "--version" ]; then
    echo 'Simple v1.0.0-beta'
    exit 0
fi
[ "$1" = "native-build" ] || exit 1
[ "${SIMPLE_BINARY:-}" = "$0" ] || exit 90
[ "${SIMPLE_BIN:-}" = "$0" ] || exit 90
[ "${SIMPLE_BOOTSTRAP_DRIVER:-}" = "$0" ] || exit 90
[ "${SIMPLE_FRONTEND_DELEGATE:-}" = "$0" ] || exit 90
[ "${SIMPLE_FRONTEND_DELEGATED:-}" = 1 ] || exit 90
[ "${SIMPLE_NO_STUB_FALLBACK:-}" = 1 ] || exit 90
[ -z "${SIMPLE_EXECUTION_MODE:-}" ] || exit 90
[ "${SIMPLE_NATIVE_BUILD_FORCE_WORKER:-}" = 0 ] || exit 90
[ "${SIMPLE_BOOTSTRAP:-}" = 0 ] || exit 90
case "${SIMPLE_LIB:-}" in */src) ;; *) exit 90 ;; esac
case " $* " in
    *" --mode definitely-invalid-mode "*)
        echo "Error: invalid --mode 'definitely-invalid-mode' (expected dynload or one-binary)" >&2
        exit 1
        ;;
esac
case "${0##*/}" in
    simple-argument-only) exit 1 ;;
    simple-frontend-hanging)
        trap '' TERM
        while :; do sleep 1; done
        ;;
esac
backend=0
runtime_bundle=0
entry_closure=0
entry=0
cache_dir=0
mode=0
output=
while [ "$#" -gt 0 ]; do
    arg=$1
    shift
    case "$arg" in
        --backend)
            [ "$#" -gt 0 ] || exit 91
            [ "$1" = cranelift ] && backend=1
            shift
            ;;
        --runtime-bundle)
            [ "$#" -gt 0 ] || exit 91
            [ "$1" = core-c-bootstrap ] && runtime_bundle=1
            shift
            ;;
        --entry-closure) entry_closure=1 ;;
        --entry)
            [ "$#" -gt 0 ] || exit 91
            [ "$1" = scripts/check/cert/redeploy_gate/fixtures/p2_add.spl ] && entry=1
            shift
            ;;
        --cache-dir)
            [ "$#" -gt 0 ] || exit 91
            [ -n "$1" ] && cache_dir=1
            shift
            ;;
        --mode)
            [ "$#" -gt 0 ] || exit 91
            [ "$1" = one-binary ] && mode=1
            shift
            ;;
        --output)
            [ "$#" -gt 0 ] || exit 91
            output=$1
            shift
            ;;
    esac
done
[ "$backend:$runtime_bundle:$entry_closure:$entry:$cache_dir:$mode" = 1:1:1:1:1:1 ] || exit 91
[ -n "$output" ] || exit 91
result=5
if [ "${0##*/}" = simple-wrong-output ]; then
    result=4
fi
{
    printf '%s\n' '#!/bin/sh'
    printf "printf '%%s\\n' '%s'\n" "$result"
} >"$output"
chmod +x "$output"
exit 0
EOF
