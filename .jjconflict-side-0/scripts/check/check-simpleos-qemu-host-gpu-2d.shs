#!/bin/sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)
cd "$ROOT_DIR"

BUILD_DIR=${SIMPLEOS_HOST_GPU_BUILD_DIR:-build/simpleos_host_gpu_2d}
QEMU_TIMEOUT=${SIMPLEOS_HOST_GPU_QEMU_TIMEOUT:-20}
PRODUCTION_QEMU_TIMEOUT=${SIMPLEOS_HOST_GPU_PRODUCTION_QEMU_TIMEOUT:-120}
QEMU_KILL_GRACE_SECONDS=${SIMPLEOS_HOST_GPU_QEMU_KILL_GRACE_SECONDS:-2}
NATIVE_BUILD_TIMEOUT=${SIMPLEOS_HOST_GPU_NATIVE_BUILD_TIMEOUT:-900}
REQUIRE_CUDA=${SIMPLEOS_HOST_GPU_REQUIRE_CUDA:-0}
PROCESSING_SELECTOR=${SIMPLEOS_HOST_GPU_PROCESSING_BACKEND:-auto}
RSS_SAMPLE_INTERVAL=${SIMPLEOS_HOST_GPU_RSS_SAMPLE_INTERVAL:-0.1}
COMPILER_PROBE_TIMEOUT_SECONDS=5
COMPILER_BUILD_TIMEOUT_SECONDS=60
COMPILER_EXEC_TIMEOUT_SECONDS=5
COMPILER_CHECK_KILL_GRACE_SECONDS=1
CANDIDATE_FRONTEND_ROOT=$ROOT_DIR
. "$ROOT_DIR/scripts/check/cert/redeploy_gate/candidate_frontend_admission.shs"
EXPECTED_PROTOCOL_VERSION=$(sed -n 's/^val SIMPLEOS_HOST_GPU_PROTOCOL_VERSION: i64 = \([0-9][0-9]*\)$/\1/p' src/lib/common/gpu/simpleos_host_gpu_protocol.spl)
[ -n "$EXPECTED_PROTOCOL_VERSION" ] || exit 2
NEGOTIATION_MAX_US=$(sed -n 's/^val SIMPLEOS_HOST_GPU_NEGOTIATION_BUDGET_US: i64 = \([0-9][0-9]*\)$/\1/p' src/lib/common/gpu/simpleos_host_gpu_protocol.spl)
case "$NEGOTIATION_MAX_US" in ''|0|*[!0-9]*) exit 2 ;; esac
HOST_GPU_FIXTURE_WIDTH=1280
HOST_GPU_FIXTURE_HEIGHT=720
HOST_GPU_FIXTURE_CHECKSUM=1417723768
HOST_GPU_FIXTURE_BACKGROUND_PIXELS=633600
HOST_GPU_FIXTURE_RECT_PIXELS=288000
HOST_GPU_WARM_SAMPLE_COUNT=$(sed -n 's/^val HOST_GPU_WARM_SAMPLE_COUNT: i64 = \([0-9][0-9]*\)$/\1/p' examples/09_embedded/simple_os/arch/common/host_gpu_ivshmem_probe_entry.spl)
[ "$HOST_GPU_WARM_SAMPLE_COUNT" = 20 ] || exit 2
RENDER_READBACK_P95_MAX_US=16700
case "$NATIVE_BUILD_TIMEOUT" in ''|0|*[!0-9]*) exit 2 ;; esac

case "$(uname -s)" in
    Linux) ACTIVE_HOST=linux ;;
    Darwin) ACTIVE_HOST=macos ;;
    MINGW*|MSYS*|CYGWIN*) ACTIVE_HOST=windows ;;
    *) ACTIVE_HOST=unknown ;;
esac
case "$(uname -m)" in
    x86_64|amd64) HOST_ARCH=x86_64 ;;
    aarch64|arm64) HOST_ARCH=aarch64 ;;
    riscv64) HOST_ARCH=riscv64 ;;
    *) HOST_ARCH=unknown ;;
esac

set_host_contract() {
    ACTIVE_HOST=$1
    case "$ACTIVE_HOST" in
        linux)
            BACKEND=vulkan
            PROCESSING_BACKEND=cuda-preferred-vulkan-fallback
            EXPECTED_RENDER_MASK=1
            EXPECTED_PROCESSING_MASK='(1|9)'
            EXPECTED_PROCESSING_RECEIPT='(cuda|vulkan)'
            ;;
        macos)
            BACKEND=metal
            PROCESSING_BACKEND=metal
            EXPECTED_RENDER_MASK=2
            EXPECTED_PROCESSING_MASK=2
            EXPECTED_PROCESSING_RECEIPT=metal
            ;;
        windows)
            BACKEND=directx
            PROCESSING_BACKEND=cuda-preferred-vulkan-fallback
            EXPECTED_RENDER_MASK=4
            EXPECTED_PROCESSING_MASK='(1|8|9)'
            EXPECTED_PROCESSING_RECEIPT='(cuda|vulkan)'
            ;;
        *)
            BACKEND=unsupported
            PROCESSING_BACKEND=unsupported
            EXPECTED_RENDER_MASK=0
            EXPECTED_PROCESSING_MASK=0
            EXPECTED_PROCESSING_RECEIPT=unsupported
            ;;
    esac
}

apply_processing_selector() {
    case "$1:$ACTIVE_HOST" in
        auto:*) ;;
        vulkan:linux)
            PROCESSING_BACKEND=vulkan
            EXPECTED_PROCESSING_MASK=1
            EXPECTED_PROCESSING_RECEIPT=vulkan
            ;;
        *) return 1 ;;
    esac
}

set_host_contract "$ACTIVE_HOST"
if ! apply_processing_selector "$PROCESSING_SELECTOR"; then
    echo "simpleos_qemu_host_gpu_2d: SIMPLEOS_HOST_GPU_PROCESSING_BACKEND must be auto, or vulkan on Linux" >&2
    exit 2
fi
LINUX_RUNTIME_TARGET=build/simpleos_gpu_host/$HOST_ARCH-vulkan-cuda-runtime-target
case "$ACTIVE_HOST" in
    macos) DEFAULT_RUNTIME_PATH=src/compiler_rust/target/bootstrap ;;
    windows) DEFAULT_RUNTIME_PATH= ;;
    *) DEFAULT_RUNTIME_PATH=$LINUX_RUNTIME_TARGET/bootstrap ;;
esac
if [ "${SIMPLEOS_HOST_GPU_RUNTIME_PATH+x}" = x ]; then
    RUNTIME_PATH=$SIMPLEOS_HOST_GPU_RUNTIME_PATH
    RUNTIME_PATH_IS_DEFAULT=0
else
    RUNTIME_PATH=$DEFAULT_RUNTIME_PATH
    RUNTIME_PATH_IS_DEFAULT=1
fi
LINUX_DEFAULT_RUNTIME_PATH=$LINUX_RUNTIME_TARGET/bootstrap
 
 linux_runtime_artifact_is_valid() {
     runtime_dir=$1
     [ -s "$runtime_dir/libsimple_runtime.a" ] || return 1
     set -- "$runtime_dir"/.fingerprint/simple-runtime-*/lib-simple_runtime.json
     [ "$#" -eq 1 ] && [ -f "$1" ] || return 1
     features=$(sed -n 's/^.*"features":"\(.*\)","declared_features":.*$/\1/p' "$1")
     case "$features" in *'\"cuda\"'*) ;; *) return 1 ;; esac
     case "$features" in *'\"vulkan\"'*) ;; *) return 1 ;; esac
 }
 
 prepare_linux_runtime() {
     linux_runtime_artifact_is_valid "$RUNTIME_PATH" && return 0
     [ "$ACTIVE_HOST" = linux ] || return 1
     [ "$RUNTIME_PATH_IS_DEFAULT" = 1 ] || return 1
     [ "$RUNTIME_PATH" = "$LINUX_DEFAULT_RUNTIME_PATH" ] || return 1
     command -v cargo >/dev/null 2>&1 || return 1
     rm -rf "$LINUX_RUNTIME_TARGET"
     mkdir -p "$(dirname "$LINUX_RUNTIME_TARGET")"
     CARGO_TARGET_DIR="$ROOT_DIR/$LINUX_RUNTIME_TARGET" cargo build --locked \
         --manifest-path "$ROOT_DIR/src/compiler_rust/Cargo.toml" \
         --package simple-runtime --lib --profile bootstrap --features vulkan,cuda \
         >"$BUILD_DIR/runtime-build.log" 2>&1 || return 1
     linux_runtime_artifact_is_valid "$RUNTIME_PATH"
 }
find_simple() {
    if [ -n "${SIMPLE_BIN:-}" ]; then
        simple_binary_is_valid "$SIMPLE_BIN" || return 1
        printf '%s\n' "$SIMPLE_BIN"
        return 0
    fi
    case "$ACTIVE_HOST" in
        macos)
            candidates="bin/release/$(uname -m)-apple-darwin/simple
bin/release/aarch64-apple-darwin/simple
bin/release/x86_64-apple-darwin/simple
build/bootstrap/stage3/$(uname -m)-apple-darwin/simple
build/bootstrap/stage2/$(uname -m)-apple-darwin/simple"
            ;;
        windows)
            candidates="bin/release/x86_64-pc-windows-msvc/simple.exe
bin/release/x86_64-pc-windows-gnu/simple.exe
bin/release/windows-x86_64/simple.exe"
            ;;
        *)
            candidates="bin/release/$HOST_ARCH-unknown-linux-gnu/simple
build/bootstrap/stage3/$HOST_ARCH-unknown-linux-gnu/simple
build/bootstrap/stage2/$HOST_ARCH-unknown-linux-gnu/simple"
            ;;
    esac
    for candidate in $candidates
    do
        if simple_binary_is_valid "$candidate"; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

run_pinned_native_build() {
    timeout_bin=$(find_timeout || true)
    [ -n "$timeout_bin" ] || return 127
    SIMPLE_BINARY="$simple_bin" \
    SIMPLE_BIN="$simple_bin" \
    SIMPLE_BOOTSTRAP_DRIVER="$simple_bin" \
    SIMPLE_FRONTEND_DELEGATE="$simple_bin" \
    SIMPLE_FRONTEND_DELEGATED=1 \
    SIMPLE_NO_STUB_FALLBACK=1 \
    SIMPLE_LIB="$ROOT_DIR/src" \
        "$timeout_bin" -k "${QEMU_KILL_GRACE_SECONDS}s" \
        "${NATIVE_BUILD_TIMEOUT}s" "$simple_bin" native-build "$@"
}

serial_has_pass() {
    log=$1
    isa=$2
    [ "$(grep -aEc "^HOST_GPU_MAP_OK isa=$isa .*[[:space:]]*$" "$log")" -eq 1 ] &&
    [ "$(grep -aEc "^HOST_GPU_HELLO_OK isa=$isa .*[[:space:]]*$" "$log")" -eq 1 ] &&
    [ "$(grep -aEc "^HOST_GPU_PROCESS_OK isa=$isa .*[[:space:]]*$" "$log")" -eq 1 ] &&
    [ "$(grep -aEc "^SIMPLEOS_HOST_GPU_2D_PASS isa=$isa[[:space:]]*$" "$log")" -eq 1 ] &&
    [ "$(grep -aEc "^TEST PASSED[[:space:]]*$" "$log")" -eq 1 ] &&
    serial_qemu_execution_valid "$log" "$qemu_args" &&
    serial_receipts_valid "$log" "$isa" &&
    render_latency_evidence_valid "$log" "$isa" "$qemu_args" "$BACKEND" &&
    negotiation_timing_evidence_valid "$log" "$isa" probe "$(negotiation_applicability "$isa" "$qemu_args")" "$BACKEND" &&
    serial_processing_pair_valid "$log" "$isa" &&
    { [ "$ACTIVE_HOST" != linux ] || [ "$REQUIRE_CUDA" != 1 ] || grep -aFq "HOST_GPU_PROCESS_OK isa=$isa backend=cuda " "$log"; } &&
    ! grep -aEq "^HOST_GPU_PROBE_FAIL isa=$isa " "$log" &&
    ! grep -aEq "^TEST FAILED[[:space:]]*$" "$log"
}

serial_qemu_execution_valid() {
    log=$1
    encoded=$2
    encoded_argv_valid "$encoded" &&
    [ "$(grep -aFxc "HOST_GPU_QEMU_EXECUTION argv=$encoded" "$log")" -eq 1 ] &&
    [ "$(grep -aEc '^HOST_GPU_QEMU_EXECUTION argv=.*$' "$log")" -eq 1 ]
}

arm64_production_serial_has_correlated_frame() {
    log=$1
    [ -f "$log" ] || return 1
    serial_qemu_execution_valid "$log" "$qemu_args" || return 1
    ramfb_pattern='^\[WM\] ramfb configured successfully via fw_cfg DMA[[:space:]]*$'
    ready_pattern="^\\[wm-frame\\] host-gpu-ready backend=$BACKEND generation=[1-9][0-9]*[[:space:]]*$"
    presented_pattern="^\\[wm-frame\\] host-gpu-presented backend=$BACKEND generation=[1-9][0-9]* run=[1-9][0-9]* frame=[1-9][0-9]* checksum=[1-9][0-9]*[[:space:]]*$"
    first_frame_pattern='^\[desktop-gui\] first-frame-rendered scene_revision=[1-9][0-9]*[[:space:]]*$'
    desktop_ready_pattern='^\[desktop-gui-arm64\] desktop-ready revision=[1-9][0-9]*[[:space:]]*$'
    [ "$(grep -aEc "$ramfb_pattern" "$log")" -eq 1 ] || return 1
    [ "$(grep -aEc '^\[wm-frame\] host-gpu-ready ' "$log")" -eq 1 ] || return 1
    [ "$(grep -aEc '^\[wm-frame\] host-gpu-presented ' "$log")" -eq 1 ] || return 1
    [ "$(grep -aEc "$ready_pattern" "$log")" -eq 1 ] || return 1
    [ "$(grep -aEc "$presented_pattern" "$log")" -eq 1 ] || return 1
    [ "$(grep -aEc "$first_frame_pattern" "$log")" -eq 1 ] || return 1
    [ "$(grep -aEc "$desktop_ready_pattern" "$log")" -eq 1 ] || return 1
    negotiation_timing_evidence_valid "$log" aarch64 production "$(negotiation_applicability aarch64)" "$BACKEND" || return 1
    ! grep -aEq '^\[desktop-gui-arm64\] fatal ' "$log" || return 1

    ready_generation=$(sed -n "s/^\\[wm-frame\\] host-gpu-ready backend=$BACKEND generation=\\([1-9][0-9]*\\)[[:space:]]*$/\\1/p" "$log")
    presented_generation=$(sed -n "s/^\\[wm-frame\\] host-gpu-presented backend=$BACKEND generation=\\([1-9][0-9]*\\) run=.*/\\1/p" "$log")
    presented_run=$(sed -n "s/^\\[wm-frame\\] host-gpu-presented backend=$BACKEND generation=[1-9][0-9]* run=\\([1-9][0-9]*\\) .*/\\1/p" "$log")
    presented_frame=$(sed -n "s/^\\[wm-frame\\] host-gpu-presented backend=$BACKEND generation=[1-9][0-9]* run=[1-9][0-9]* frame=\\([1-9][0-9]*\\) .*/\\1/p" "$log")
    first_revision=$(sed -n 's/^\[desktop-gui\] first-frame-rendered scene_revision=\([1-9][0-9]*\)[[:space:]]*$/\1/p' "$log")
    desktop_revision=$(sed -n 's/^\[desktop-gui-arm64\] desktop-ready revision=\([1-9][0-9]*\)[[:space:]]*$/\1/p' "$log")
    ramfb_line=$(grep -anE "$ramfb_pattern" "$log" | cut -d: -f1)
    ready_line=$(grep -anE "$ready_pattern" "$log" | cut -d: -f1)
    presented_line=$(grep -anE "$presented_pattern" "$log" | cut -d: -f1)
    first_frame_line=$(grep -anE "$first_frame_pattern" "$log" | cut -d: -f1)
    desktop_ready_line=$(grep -anE "$desktop_ready_pattern" "$log" | cut -d: -f1)

    [ "$presented_generation" -eq "$((ready_generation + 1))" ] &&
    [ "$presented_run" -eq "$ready_generation" ] &&
    [ "$presented_frame" -eq "$presented_generation" ] &&
    [ "$first_revision" -eq "$desktop_revision" ] &&
    [ "$ramfb_line" -lt "$ready_line" ] &&
    [ "$ready_line" -lt "$presented_line" ] &&
    [ "$presented_line" -lt "$first_frame_line" ] &&
    [ "$first_frame_line" -lt "$desktop_ready_line" ] &&
    awk -v ready="$ready_line" 'NR > ready && /^\[wm-frame\] host-gpu-fallback / { failed=1 } END { exit failed ? 1 : 0 }' "$log"
}

serial_render_fixture_valid() {
    log=$1
    isa=$2
    [ "$(grep -aEc "^HOST_GPU_RENDER_OK isa=$isa backend=$BACKEND .*[[:space:]]*$" "$log")" -eq 1 ] &&
    [ "$(grep -aEc "^HOST_GPU_DRAW_IR_OK isa=$isa backend=$BACKEND .*[[:space:]]*$" "$log")" -eq 1 ] &&
    [ "$(grep -aEc "^HOST_GPU_FIXTURE_OK isa=$isa backend=$BACKEND generation=[1-9][0-9]* run=[1-9][0-9]* frame=[1-9][0-9]* protocol=$EXPECTED_PROTOCOL_VERSION width=$HOST_GPU_FIXTURE_WIDTH height=$HOST_GPU_FIXTURE_HEIGHT elapsed_us=[1-9][0-9]* handle=[1-9][0-9]* identity=[1-9][0-9]* checksum=$HOST_GPU_FIXTURE_CHECKSUM bg=$HOST_GPU_FIXTURE_BACKGROUND_PIXELS rect=$HOST_GPU_FIXTURE_RECT_PIXELS mismatches=0[[:space:]]*$" "$log")" -eq 1 ]
}

serial_receipts_valid() {
    log=$1
    isa=$2
    grep -aEq "^HOST_GPU_MAP_OK isa=$isa device=[1-9][0-9]*[[:space:]]*$" "$log" || return 1
    grep -aEq "^HOST_GPU_HELLO_OK isa=$isa generation=[1-9][0-9]* render_mask=$EXPECTED_RENDER_MASK processing_mask=$EXPECTED_PROCESSING_MASK protocol=$EXPECTED_PROTOCOL_VERSION elapsed_us=[1-9][0-9]*[[:space:]]*$" "$log" || return 1
    grep -aEq "^HOST_GPU_RENDER_OK isa=$isa backend=$BACKEND generation=[1-9][0-9]* run=[1-9][0-9]* frame=[1-9][0-9]* protocol=$EXPECTED_PROTOCOL_VERSION elapsed_us=[1-9][0-9]* handle=[1-9][0-9]* identity=[1-9][0-9]* checksum=405589360 bg=2112 rect=960 other=0[[:space:]]*$" "$log" || return 1
    grep -aEq "^HOST_GPU_DRAW_IR_OK isa=$isa backend=$BACKEND generation=[1-9][0-9]* run=[1-9][0-9]* frame=[1-9][0-9]* protocol=$EXPECTED_PROTOCOL_VERSION elapsed_us=[1-9][0-9]* handle=[1-9][0-9]* identity=[1-9][0-9]* checksum=405589360 bg=2112 image=960 other=0[[:space:]]*$" "$log" || return 1
    serial_render_fixture_valid "$log" "$isa" || return 1
    grep -aEq "^HOST_GPU_PROCESS_OK isa=$isa backend=$EXPECTED_PROCESSING_RECEIPT generation=[1-9][0-9]* run=[1-9][0-9]* frame=[1-9][0-9]* protocol=$EXPECTED_PROTOCOL_VERSION elapsed_us=[1-9][0-9]* handle=[1-9][0-9]* identity=[1-9][0-9]* checksum=1792 mismatches=0[[:space:]]*$" "$log" || return 1
    hello_generation=$(sed -n "s/^HOST_GPU_HELLO_OK isa=$isa generation=\([1-9][0-9]*\) .*/\1/p" "$log")
    render_generation=$(sed -n "s/^HOST_GPU_RENDER_OK isa=$isa backend=$BACKEND generation=\([1-9][0-9]*\) .*/\1/p" "$log")
    draw_ir_generation=$(sed -n "s/^HOST_GPU_DRAW_IR_OK isa=$isa backend=$BACKEND generation=\([1-9][0-9]*\) .*/\1/p" "$log")
    fixture_generation=$(sed -n "s/^HOST_GPU_FIXTURE_OK isa=$isa backend=$BACKEND generation=\([1-9][0-9]*\) .*/\1/p" "$log")
    process_generation=$(sed -n "s/^HOST_GPU_PROCESS_OK isa=$isa backend=.* generation=\([1-9][0-9]*\) .*/\1/p" "$log")
    render_run=$(sed -n "s/^HOST_GPU_RENDER_OK isa=$isa .* run=\([1-9][0-9]*\) .*/\1/p" "$log")
    draw_ir_run=$(sed -n "s/^HOST_GPU_DRAW_IR_OK isa=$isa .* run=\([1-9][0-9]*\) .*/\1/p" "$log")
    fixture_run=$(sed -n "s/^HOST_GPU_FIXTURE_OK isa=$isa .* run=\([1-9][0-9]*\) .*/\1/p" "$log")
    process_run=$(sed -n "s/^HOST_GPU_PROCESS_OK isa=$isa .* run=\([1-9][0-9]*\) .*/\1/p" "$log")
    render_frame=$(sed -n "s/^HOST_GPU_RENDER_OK isa=$isa .* frame=\([1-9][0-9]*\) .*/\1/p" "$log")
    draw_ir_frame=$(sed -n "s/^HOST_GPU_DRAW_IR_OK isa=$isa .* frame=\([1-9][0-9]*\) .*/\1/p" "$log")
    fixture_frame=$(sed -n "s/^HOST_GPU_FIXTURE_OK isa=$isa .* frame=\([1-9][0-9]*\) .*/\1/p" "$log")
    process_frame=$(sed -n "s/^HOST_GPU_PROCESS_OK isa=$isa .* frame=\([1-9][0-9]*\) .*/\1/p" "$log")
    render_identity=$(sed -n "s/^HOST_GPU_RENDER_OK isa=$isa .* identity=\([1-9][0-9]*\) checksum=.*/\1/p" "$log")
    draw_ir_identity=$(sed -n "s/^HOST_GPU_DRAW_IR_OK isa=$isa .* identity=\([1-9][0-9]*\) checksum=.*/\1/p" "$log")
    fixture_identity=$(sed -n "s/^HOST_GPU_FIXTURE_OK isa=$isa .* identity=\([1-9][0-9]*\) checksum=.*/\1/p" "$log")
    case "$isa" in
        x86_64) expected_hello_generation=9 ;;
        aarch64) expected_hello_generation=19 ;;
        riscv64) expected_hello_generation=29 ;;
        *) return 1 ;;
    esac
    case "$ACTIVE_HOST" in
        windows) expected_hello_generation=$((expected_hello_generation + 1)) ;;
        linux) expected_hello_generation=$((expected_hello_generation + 2)) ;;
    esac
    [ "$hello_generation" -eq "$expected_hello_generation" ] &&
    [ "$render_generation" -eq "$((hello_generation + 1))" ] &&
    [ "$draw_ir_generation" -eq "$((render_generation + 1))" ] &&
    [ "$fixture_generation" -eq "$((draw_ir_generation + 1))" ] &&
    [ "$process_generation" -eq "$((fixture_generation + HOST_GPU_WARM_SAMPLE_COUNT + 1))" ] &&
    [ "$render_run" = "$draw_ir_run" ] && [ "$render_run" = "$fixture_run" ] && [ "$render_run" = "$process_run" ] &&
    [ "$render_frame" = "$render_generation" ] &&
    [ "$draw_ir_frame" = "$draw_ir_generation" ] &&
    [ "$fixture_frame" = "$fixture_generation" ] &&
    [ "$process_frame" = "$process_generation" ] &&
    [ "$render_identity" = "$draw_ir_identity" ] && [ "$render_identity" = "$fixture_identity" ]
}

negotiation_applicability() {
    if [ "$1" = "$HOST_ARCH" ]; then
        echo native-isa
    else
        echo cross-isa-tcg-correctness-only
    fi
}

render_latency_p95_us() {
    log=$1
    isa=$2
    backend=$3
    values=$(awk -v expected_isa="$isa" -v expected_backend="$backend" '
        $1 == "HOST_GPU_FIXTURE_SAMPLE" && $2 == "isa=" expected_isa && $3 == "backend=" expected_backend {
            if ($11 ~ /^elapsed_us=[1-9][0-9]*$/) print substr($11, 12)
        }
    ' "$log")
    count=$(printf '%s\n' "$values" | awk 'NF { count++ } END { print count + 0 }')
    [ "$count" -eq "$HOST_GPU_WARM_SAMPLE_COUNT" ] || return 1
    rank=$((($HOST_GPU_WARM_SAMPLE_COUNT * 95 + 99) / 100))
    printf '%s\n' "$values" | LC_ALL=C sort -n | sed -n "${rank}p"
}

render_latency_evidence_valid() (
    log=$1
    isa=$2
    qemu_args=$3
    expected_backend=$4
    [ -f "$log" ] || return 1
    applicability=$(negotiation_applicability "$isa" "$qemu_args") || return 1
    serial_render_fixture_valid "$log" "$isa" || return 1
    awk -v expected_isa="$isa" -v expected_backend="$expected_backend" \
        -v expected_protocol="$EXPECTED_PROTOCOL_VERSION" \
        -v expected_width="$HOST_GPU_FIXTURE_WIDTH" -v expected_height="$HOST_GPU_FIXTURE_HEIGHT" \
        -v expected_checksum="$HOST_GPU_FIXTURE_CHECKSUM" -v expected_count="$HOST_GPU_WARM_SAMPLE_COUNT" '
        function field(n, prefix) {
            if (index($n, prefix) != 1) { bad = 1; return "" }
            return substr($n, length(prefix) + 1)
        }
        $1 == "HOST_GPU_FIXTURE_OK" && $2 == "isa=" expected_isa && $3 == "backend=" expected_backend {
            fixture_count++
            fixture_line = NR
            fixture_generation = field(4, "generation=")
            fixture_run = field(5, "run=")
            fixture_identity = field(12, "identity=")
            if (fixture_generation !~ /^[1-9][0-9]*$/ || fixture_run !~ /^[1-9][0-9]*$/ || fixture_identity !~ /^[1-9][0-9]*$/) bad = 1
        }
        $1 == "HOST_GPU_FIXTURE_SAMPLE" {
            sample_count++
            sample = field(4, "sample=")
            generation = field(5, "generation=")
            run = field(6, "run=")
            frame = field(7, "frame=")
            protocol = field(8, "protocol=")
            width = field(9, "width=")
            height = field(10, "height=")
            elapsed = field(11, "elapsed_us=")
            handle = field(12, "handle=")
            identity = field(13, "identity=")
            checksum = field(14, "checksum=")
            mismatches = field(15, "mismatches=")
            if (NF != 15 || $2 != "isa=" expected_isa || $3 != "backend=" expected_backend ||
                sample !~ /^[1-9][0-9]*$/ || generation !~ /^[1-9][0-9]*$/ || run !~ /^[1-9][0-9]*$/ || frame !~ /^[1-9][0-9]*$/ ||
                elapsed !~ /^[1-9][0-9]*$/ || handle !~ /^[1-9][0-9]*$/ || identity !~ /^[1-9][0-9]*$/ || checksum !~ /^[1-9][0-9]*$/ ||
                sample + 0 != sample_count || protocol + 0 != expected_protocol || width + 0 != expected_width || height + 0 != expected_height ||
                frame + 0 != generation + 0 || checksum + 0 != expected_checksum || mismatches != "0") bad = 1
            if (sample_count == 1) {
                if (fixture_count != 1 || NR != fixture_line + 1 || generation + 0 != fixture_generation + 1 || run != fixture_run || identity != fixture_identity) bad = 1
            } else if (NR != previous_line + 1 || generation + 0 != previous_generation + 1 || run != fixture_run || identity != fixture_identity) bad = 1
            previous_line = NR
            previous_generation = generation + 0
        }
        END { exit bad || fixture_count != 1 || sample_count != expected_count ? 1 : 0 }
    ' "$log" || return 1
    p95=$(render_latency_p95_us "$log" "$isa" "$expected_backend") || return 1
    case "$p95" in ''|0|*[!0-9]*) return 1 ;; esac
    [ "$applicability" != native-isa ] || [ "$p95" -le "$RENDER_READBACK_P95_MAX_US" ]
)

negotiation_timing_evidence_valid() (
    log=$1
    isa=$2
    scope=$3
    applicability=$4
    expected_backend=$5
    [ -f "$log" ] || return 1
    case "$applicability" in native-isa|cross-isa-tcg-correctness-only) ;; *) return 1 ;; esac
    awk -v expected_isa="$isa" -v expected_scope="$scope" \
        -v applicability="$applicability" -v expected_backend="$expected_backend" \
        -v max_us="$NEGOTIATION_MAX_US" '
        function field(n, prefix) {
            if (index($n, prefix) != 1) { bad = 1; return "" }
            return substr($n, length(prefix) + 1)
        }
        $1 == "HOST_GPU_MAP_OK" {
            if (expected_scope != "probe" || NF != 3 || $2 != "isa=" expected_isa || field(3, "device=") !~ /^[1-9][0-9]*$/) {
                bad = 1
            } else {
                map_count++
                map_line = NR
            }
        }
        $1 == "HOST_GPU_HELLO_OK" {
            if (expected_scope != "probe" || NF < 3 || $2 != "isa=" expected_isa) {
                bad = 1
            } else {
                hello_count++
                hello_line = NR
                hello_generation = field(3, "generation=")
                if (hello_generation !~ /^[1-9][0-9]*$/) bad = 1
            }
        }
        $1 == "[wm-frame]" && $2 == "host-gpu-ready" {
            if (expected_scope != "production" || NF != 4) {
                bad = 1
            } else {
                ready_count++
                ready_line = NR
                ready_backend = field(3, "backend=")
                ready_generation = field(4, "generation=")
                if (ready_generation !~ /^[1-9][0-9]*$/) bad = 1
            }
        }
        $1 == "HOST_GPU_NEGOTIATION_ATTEMPT" {
            if (done_count != 0 || terminal_seen || NF != 10) { bad = 1; next }
            row_scope = field(2, "scope=")
            row_isa = field(3, "isa=")
            backend = field(4, "backend=")
            generation = field(5, "generation=")
            outcome = field(6, "outcome=")
            status = field(7, "status=")
            reason = field(8, "reason=")
            daemon_us = field(9, "daemon_elapsed_us=")
            guest_us = field(10, "guest_elapsed_us=")
            if (row_scope != expected_scope || row_isa != expected_isa ||
                generation !~ /^[1-9][0-9]*$/ || status !~ /^[0-9]+$/ ||
                reason !~ /^[0-9]+$/ || daemon_us !~ /^[0-9]+$/ ||
                guest_us !~ /^[1-9][0-9]*$/ || length(daemon_us) > 15 || length(guest_us) > 15) bad = 1
            attempts++
            if (attempts == 1) first_attempt_line = NR
            if (attempts == 1) {
                first_generation = generation + 0
            } else if ((generation + 0) != last_generation + 1) bad = 1
            expected = attempts
            expected_name = expected == 1 ? "metal" : (expected == 2 ? "directx" : (expected == 3 ? "vulkan" : ""))
            if (backend != expected_name) bad = 1
            if (outcome == "selected") {
                selected_count++
                selected_backend = backend
                terminal_seen = 1
                if (status != 1 || reason != 0 || (daemon_us + 0) <= 0) bad = 1
            } else if (outcome == "rejected") {
                if (status != 2 || reason != 9 || (daemon_us + 0) <= 0) bad = 1
            } else if (outcome == "timeout") {
                if (status != 3 || reason != 3 || daemon_us != 0) bad = 1
                terminal_seen = 1
            } else if (outcome == "stale") {
                if (status != 3 || reason != 7 || daemon_us != 0) bad = 1
                terminal_seen = 1
            } else if (outcome == "budget") {
                if (status != 1 || reason != 3 || (daemon_us + 0) <= 0) bad = 1
                budget_seen = 1
                terminal_seen = 1
            } else if (outcome == "invalid") {
                if (reason + 0 <= 0 || status < 1 || status > 3 ||
                    (status == 2 && reason == 9) || (status == 3 && (reason == 3 || reason == 7)) ||
                    (status == 1 && reason == 3)) bad = 1
                terminal_seen = 1
            } else bad = 1
            guest_sum += guest_us + 0
            last_outcome = outcome
            last_reason = reason + 0
            last_generation = generation + 0
        }
        $1 == "HOST_GPU_NEGOTIATION_DONE" {
            done_count++
            done_line = NR
            if (done_count != 1 || NF != 11) { bad = 1; next }
            row_scope = field(2, "scope=")
            row_isa = field(3, "isa=")
            result = field(4, "result=")
            final_backend = field(5, "backend=")
            declared_attempts = field(6, "attempts=")
            declared_first = field(7, "first_generation=")
            declared_final = field(8, "final_generation=")
            elapsed_us = field(9, "elapsed_us=")
            budget_us = field(10, "budget_us=")
            final_reason = field(11, "reason=")
            if (row_scope != expected_scope || row_isa != expected_isa ||
                declared_attempts !~ /^[0-3]$/ || declared_first !~ /^(0|[1-9][0-9]*)$/ ||
                declared_final !~ /^(0|[1-9][0-9]*)$/ || elapsed_us !~ /^[1-9][0-9]*$/ ||
                length(elapsed_us) > 15 || budget_us != max_us || final_reason !~ /^[0-9]+$/) bad = 1
        }
        END {
            if (bad || done_count != 1 || attempts > 3 || declared_attempts + 0 != attempts ||
                elapsed_us + 0 < guest_sum) exit 1
            if (attempts == 0) {
                if (result != "fallback" || final_backend != "software" ||
                    declared_first != 0 || declared_final != 0 || final_reason + 0 <= 0) exit 1
            } else if (declared_first + 0 != first_generation || declared_final + 0 != last_generation) exit 1
            if (result == "selected") {
                if (attempts == 0 || selected_count != 1 || last_outcome != "selected" ||
                    final_backend != selected_backend || final_backend != expected_backend || final_reason != 0) exit 1
            } else if (result == "fallback") {
                if (selected_count != 0 || final_backend != "software") exit 1
                if (attempts > 0 && last_outcome == "selected") exit 1
                if (attempts > 0 && last_outcome == "rejected") {
                    if (attempts == 3 && final_reason + 0 != last_reason) exit 1
                    if (attempts < 3 && final_reason != 3 && final_reason != 7) exit 1
                } else if (attempts > 0 && final_reason + 0 != last_reason) exit 1
            } else exit 1
            first_event_line = attempts > 0 ? first_attempt_line : done_line
            if (expected_scope == "probe") {
                if (map_count != 1 || map_line >= first_event_line) exit 1
                if (result == "selected") {
                    if (hello_count != 1 || done_line >= hello_line || hello_generation + 0 != declared_final + 0) exit 1
                } else if (hello_count != 0) exit 1
            } else if (expected_scope == "production") {
                if (result == "selected") {
                    if (ready_count != 1 || done_line >= ready_line || ready_backend != final_backend ||
                        ready_generation + 0 != declared_final + 0) exit 1
                } else if (ready_count != 0) exit 1
            } else exit 1
            if (budget_seen && elapsed_us + 0 <= max_us) exit 1
            if (elapsed_us + 0 > max_us) exit 1
        }
    ' "$log"
)

serial_processing_pair_valid() {
    log=$1
    isa=$2
    if [ "$ACTIVE_HOST" = macos ]; then
        grep -aEq "^HOST_GPU_HELLO_OK isa=$isa .* processing_mask=2 " "$log" &&
        grep -aEq "^HOST_GPU_PROCESS_OK isa=$isa backend=metal " "$log"
    elif grep -aEq "^HOST_GPU_HELLO_OK isa=$isa .* processing_mask=(8|9) " "$log"; then
        grep -aEq "^HOST_GPU_PROCESS_OK isa=$isa backend=cuda " "$log"
    elif grep -aEq "^HOST_GPU_HELLO_OK isa=$isa .* processing_mask=1 " "$log"; then
        grep -aEq "^HOST_GPU_PROCESS_OK isa=$isa backend=vulkan " "$log"
    else
        return 1
    fi
}

processing_perf_field() {
    log=$1
    isa=$2
    field=$3
    awk -v expected_isa="$isa" -v expected_field="$field" '
        $1 == "HOST_GPU_PROCESS_PERF" && $2 == "isa=" expected_isa {
            for (i = 3; i <= NF; i++) {
                if (index($i, expected_field "=") == 1) {
                    print substr($i, length(expected_field) + 2)
                }
            }
        }
    ' "$log"
}

processing_perf_us_valid() {
    value=$1
    case "$value" in ''|0|*[!0-9]*) return 1 ;; esac
    [ "${#value}" -lt 16 ] && return 0
    [ "${#value}" -eq 16 ] || return 1
    awk -v value="$value" 'BEGIN {
        if (("x" value) <= "x9223372036854776") exit 0
        exit 1
    }'
}

processing_perf_evidence_valid() (
    serial_log=$1
    daemon_log=$2
    isa=$3
    [ -f "$serial_log" ] && [ -f "$daemon_log" ] || return 1
    [ "$(grep -aEc "^HOST_GPU_PROCESS_PERF isa=$isa backend=(cuda|vulkan|metal) generation=[1-9][0-9]* run=[1-9][0-9]* frame=[1-9][0-9]* cpu_us=[1-9][0-9]* device_us=[1-9][0-9]* preference=(preferred|available-not-preferred)[[:space:]]*$" "$daemon_log")" -eq 1 ] || return 1

    serial_backend=$(sed -n "s/^HOST_GPU_PROCESS_OK isa=$isa backend=\([^[:space:]]*\) .*/\1/p" "$serial_log")
    serial_generation=$(sed -n "s/^HOST_GPU_PROCESS_OK isa=$isa .* generation=\([1-9][0-9]*\) .*/\1/p" "$serial_log")
    serial_run=$(sed -n "s/^HOST_GPU_PROCESS_OK isa=$isa .* run=\([1-9][0-9]*\) .*/\1/p" "$serial_log")
    serial_frame=$(sed -n "s/^HOST_GPU_PROCESS_OK isa=$isa .* frame=\([1-9][0-9]*\) .*/\1/p" "$serial_log")
    serial_device_us=$(sed -n "s/^HOST_GPU_PROCESS_OK isa=$isa .* elapsed_us=\([1-9][0-9]*\) .*/\1/p" "$serial_log")
    perf_backend=$(processing_perf_field "$daemon_log" "$isa" backend)
    perf_generation=$(processing_perf_field "$daemon_log" "$isa" generation)
    perf_run=$(processing_perf_field "$daemon_log" "$isa" run)
    perf_frame=$(processing_perf_field "$daemon_log" "$isa" frame)
    cpu_us=$(processing_perf_field "$daemon_log" "$isa" cpu_us)
    device_us=$(processing_perf_field "$daemon_log" "$isa" device_us)
    preference=$(processing_perf_field "$daemon_log" "$isa" preference)
    case "$cpu_us:$device_us" in *[!0-9:]*|:*|*:) return 1 ;; esac
    processing_perf_us_valid "$cpu_us" && processing_perf_us_valid "$device_us" || return 1

    expected_preference=available-not-preferred
    if [ "$cpu_us" -ge "$device_us" ] &&
       [ "$((cpu_us - device_us))" -ge "$((device_us / 2 + device_us % 2))" ]; then
        expected_preference=preferred
    fi
    [ "$perf_backend" = "$serial_backend" ] &&
    [ "$perf_generation" = "$serial_generation" ] &&
    [ "$perf_run" = "$serial_run" ] &&
    [ "$perf_frame" = "$serial_frame" ] &&
    [ "$device_us" = "$serial_device_us" ] &&
    [ "$preference" = "$expected_preference" ]
)

processing_selector_evidence_valid() {
    log=$1
    selector=$2
    [ "$selector" = auto ] && return 0
    [ -f "$log" ] &&
    [ "$(grep -ac "^HOST_GPU_DAEMON_SELECTOR processing_backend=$selector[[:space:]]*$" "$log")" -eq 1 ]
}

serial_processing_backend() {
    sed -n "s/.*HOST_GPU_PROCESS_OK isa=$2 backend=\(cuda\|vulkan\|metal\) .*/\1/p" "$1"
}

serial_reason() {
    log=$1
    isa=$2
    reason=$(sed -n "s/.*HOST_GPU_PROBE_FAIL isa=$isa reason=\([^[:space:]]*\).*/\1/p" "$log" | tail -n 1)
    if [ -n "$reason" ]; then
        printf '%s\n' "$reason"
    elif grep -aFq "TEST FAILED" "$log"; then
        printf '%s\n' guest-test-failed
    else
        printf '%s\n' missing-correlated-device-receipt
    fi
}

find_timeout() {
    candidate_frontend_timeout_bin
}

size_shared_file() {
    path=$1
    if command -v truncate >/dev/null 2>&1; then
        truncate -s 8388608 "$path"
    else
        dd if=/dev/zero of="$path" bs=1048576 count=8 >/dev/null 2>&1
    fi
}

process_rss_sample_kib() {
    pid=$1
    if [ -r "/proc/$pid/status" ]; then
        sed -n 's/^VmRSS:[[:space:]]*\([0-9][0-9]*\).*/\1/p' "/proc/$pid/status"
    elif command -v ps >/dev/null 2>&1; then
        ps -o rss= -p "$pid" 2>/dev/null | sed -n 's/[[:space:]]*\([0-9][0-9]*\).*/\1/p'
    fi
}

rss_metric_value() {
    metric_file=$1
    metric_name=$2
    sed -n "s/^${metric_name}=//p" "$metric_file" 2>/dev/null | sed -n '1p'
}

monitor_guest_max_rss() {
    monitored_daemon_pid=$1
    monitored_timeout_pid=$2
    monitored_qemu_pid_file=$3
    rss_output=$4
    daemon_max_rss_kib=$(rss_metric_value "$rss_output" daemon_max_rss_kib || true)
    qemu_max_rss_kib=$(rss_metric_value "$rss_output" qemu_max_rss_kib || true)
    combined_max_rss_kib=$(rss_metric_value "$rss_output" combined_max_rss_kib || true)
    case "$daemon_max_rss_kib" in ''|*[!0-9]*) daemon_max_rss_kib=0 ;; esac
    case "$qemu_max_rss_kib" in ''|*[!0-9]*) qemu_max_rss_kib=0 ;; esac
    case "$combined_max_rss_kib" in ''|*[!0-9]*) combined_max_rss_kib=0 ;; esac
    while kill -0 "$monitored_timeout_pid" 2>/dev/null; do
        monitored_qemu_pid=$(sed -n '1p' "$monitored_qemu_pid_file" 2>/dev/null || true)
        case "$monitored_qemu_pid" in ''|*[!0-9]*|0) sampled_qemu_rss_kib=0 ;; *) sampled_qemu_rss_kib=$(process_rss_sample_kib "$monitored_qemu_pid" || true) ;; esac
        sampled_daemon_rss_kib=$(process_rss_sample_kib "$monitored_daemon_pid" || true)
        case "$sampled_daemon_rss_kib" in ''|*[!0-9]*) sampled_daemon_rss_kib=0 ;; esac
        case "$sampled_qemu_rss_kib" in ''|*[!0-9]*) sampled_qemu_rss_kib=0 ;; esac
        sampled_combined_rss_kib=$((sampled_daemon_rss_kib + sampled_qemu_rss_kib))
        [ "$sampled_daemon_rss_kib" -le "$daemon_max_rss_kib" ] || daemon_max_rss_kib=$sampled_daemon_rss_kib
        [ "$sampled_qemu_rss_kib" -le "$qemu_max_rss_kib" ] || qemu_max_rss_kib=$sampled_qemu_rss_kib
        [ "$sampled_combined_rss_kib" -le "$combined_max_rss_kib" ] || combined_max_rss_kib=$sampled_combined_rss_kib
        printf '%s\n' \
            "daemon_max_rss_kib=$daemon_max_rss_kib" \
            "qemu_max_rss_kib=$qemu_max_rss_kib" \
            "combined_max_rss_kib=$combined_max_rss_kib" >"$rss_output"
        sleep "$RSS_SAMPLE_INTERVAL"
    done
}

row_rss_evidence_valid() {
    daemon_rss=$1
    qemu_rss=$2
    combined_rss=$3
    case "$daemon_rss:$qemu_rss:$combined_rss" in *[!0-9:]*|:*|*:) return 1 ;; esac
    [ "$daemon_rss" -gt 0 ] && [ "$qemu_rss" -gt 0 ] &&
        [ "$combined_rss" -ge "$daemon_rss" ] && [ "$combined_rss" -ge "$qemu_rss" ] &&
        [ "$combined_rss" -le "$((daemon_rss + qemu_rss))" ]
}

run_qemu_with_rss() {
    qemu_deadline=$1
    qemu_output=$2
    monitored_daemon_pid=$3
    rss_output=$4
    qemu_command=$5
    shift 5
    qemu_pid_file="$rss_output.qemu-pid"
    rm -f "$qemu_pid_file"
    "$TIMEOUT_BIN" -k "${QEMU_KILL_GRACE_SECONDS}s" "$qemu_deadline" \
        sh -c 'qemu_pid_file=$1; shift; printf "%s\n" "$$" >"$qemu_pid_file"; exec "$@"' \
        sh "$qemu_pid_file" "$qemu_command" "$@" >"$qemu_output" 2>&1 &
    qemu_timeout_pid=$!
    monitor_guest_max_rss "$monitored_daemon_pid" "$qemu_timeout_pid" "$qemu_pid_file" "$rss_output" &
    rss_monitor_pid=$!
    wait "$qemu_timeout_pid" 2>/dev/null || true
    qemu_timeout_pid=
    wait "$rss_monitor_pid" 2>/dev/null || true
    rss_monitor_pid=
    qemu_pid_file=
}

qemu_bin_for_isa() {
    case "$1" in
        x86_64) printf '%s\n' "${QEMU_SYSTEM_X86_64:-qemu-system-x86_64}" ;;
        aarch64) printf '%s\n' "${QEMU_SYSTEM_AARCH64:-qemu-system-aarch64}" ;;
        riscv64) printf '%s\n' "${QEMU_SYSTEM_RISCV64:-qemu-system-riscv64}" ;;
    esac
}

qemu_capabilities_available() {
    isa=$1
    qemu_bin=$2
    machine=$3
    capability_dir="$BUILD_DIR/qemu-capabilities"
    mkdir -p "$capability_dir"
    "$qemu_bin" -machine help >"$capability_dir/$isa-machines.log" 2>&1 || return 1
    "$qemu_bin" -device help >"$capability_dir/$isa-devices.log" 2>&1 || return 1
    "$qemu_bin" -object help >"$capability_dir/$isa-objects.log" 2>&1 || return 1
    grep -Eq "(^|[[:space:],])$machine([[:space:],]|$)" "$capability_dir/$isa-machines.log" || return 1
    grep -Fq ivshmem-plain "$capability_dir/$isa-devices.log" || return 1
    [ "$isa" != aarch64 ] || grep -Fq ramfb "$capability_dir/$isa-devices.log" || return 1
    grep -Fq memory-backend-file "$capability_dir/$isa-objects.log" || return 1
}

metal_guest_contract_available() {
    probe=examples/09_embedded/simple_os/arch/common/host_gpu_ivshmem_probe_entry.spl
    [ -f "$probe" ] &&
    grep -Fq 'render_backend = "metal"' "$probe" &&
    grep -Eq 'host_gpu_ivshmem_negotiate\(.*render_backend' "$probe" &&
    grep -Fq 'HOST_GPU_RENDER_OK' "$probe" &&
    grep -Fq 'HOST_GPU_DRAW_IR_OK' "$probe" &&
    grep -Fq 'HOST_GPU_FIXTURE_OK' "$probe" &&
    grep -Fq 'HOST_GPU_PROCESS_OK' "$probe"
}

core_c_bootstrap_runtime_available() {
    [ -f "$RUNTIME_PATH/core-c-bootstrap/libsimple_runtime.a" ] ||
    [ -f "$RUNTIME_PATH/core_c_bootstrap/libsimple_runtime.a" ] ||
    [ -f "$RUNTIME_PATH/libsimple_runtime.a" ]
}

emit_row() {
    row_host=$1
    row_isa=$2
    row_status=$3
    row_reason=$4
    row_log=$5
    row_processing_backend=${6:-}
    row_prefix="simpleos_qemu_host_gpu_2d_${row_host}_${row_isa}"
    case "$row_host" in
        macos) row_render_backend=metal; row_processing_backend=${row_processing_backend:-metal} ;;
        windows) row_render_backend=directx; row_processing_backend=${row_processing_backend:-cuda} ;;
        linux)
            row_render_backend=vulkan
            if [ "$row_host" = "$ACTIVE_HOST" ]; then
                row_processing_backend=${row_processing_backend:-$PROCESSING_BACKEND}
            else
                row_processing_backend=${row_processing_backend:-cuda-preferred-vulkan-fallback}
            fi
            ;;
    esac
    echo "${row_prefix}_status=$row_status"
    echo "${row_prefix}_reason=$row_reason"
    echo "${row_prefix}_render_backend=$row_render_backend"
    echo "${row_prefix}_processing_backend=$row_processing_backend"
    echo "${row_prefix}_serial_log=$row_log"
}

encode_argv_hex() {
    encoded_argv=hex:
    separator=
    for argument
    do
        encoded_argument=$(printf '%s' "$argument" | od -An -v -tx1 | tr -d ' \n')
        encoded_argv="${encoded_argv}${separator}${encoded_argument}"
        separator=,
    done
    printf '%s' "$encoded_argv"
}

kernel_for_isa() {
    case "$1" in
        x86_64) echo build/os/simpleos_x86_64_host_gpu_probe.elf ;;
        aarch64) echo build/os/simpleos_arm64_host_gpu_probe.elf ;;
        riscv64) echo build/os/simpleos_riscv64_host_gpu_probe.elf ;;
    esac
}

arm64_production_kernel() {
    echo build/os/simpleos_arm64_desktop_engine2d.elf
}

encoded_argv_valid() {
    printf '%s\n' "$1" | grep -Eq '^hex:([0-9a-f][0-9a-f])+(,([0-9a-f][0-9a-f])+)*$'
}

encoded_argv_field() (
    encoded=$1
    index=$2
    encoded_argv_valid "$encoded" || return 1
    IFS=,
    set -- ${encoded#hex:}
    while [ "$index" -gt 1 ]; do
        [ "$#" -gt 1 ] || return 1
        shift
        index=$((index - 1))
    done
    printf '%s\n' "$1"
)

encoded_arg() {
    encode_argv_hex "$1" | sed 's/^hex://'
}

encoded_arg_has_affixes() {
    encoded_prefix=$(encoded_arg "$2")
    encoded_suffix=$(encoded_arg "$3")
    case "$1" in
        "$encoded_prefix"?*"$encoded_suffix")
            encoded_middle=${1#"$encoded_prefix"}
            encoded_middle=${encoded_middle%"$encoded_suffix"}
            case "$encoded_middle" in *2c*) return 1 ;; esac
            return 0
            ;;
        *) return 1 ;;
    esac
}

encoded_kernel_path_valid() {
    case "$1" in
        "$2"|*2f"$2"|*5c"$2") return 0 ;;
        *) return 1 ;;
    esac
}

qemu_argv_evidence_valid() (
    isa=$1
    encoded=$2
    lane=${3:-probe}
    encoded_argv_valid "$encoded" || return 1
    old_ifs=$IFS
    IFS=,
    set -- ${encoded#hex:}
    IFS=$old_ifs
    if [ "$lane" = production ] && [ "$isa" = aarch64 ]; then
        kernel_suffix=$(encoded_arg "$(basename "$(arm64_production_kernel)")")
    else
        [ "$lane" = probe ] || return 1
        kernel_suffix=$(encoded_arg "$(basename "$(kernel_for_isa "$isa")")")
    fi
    object_prefix='memory-backend-file,id=hostgpu,share=on,mem-path='
    object_suffix=',size=8M'
    ivshmem=$(encoded_arg 'ivshmem-plain,memdev=hostgpu')
    case "$isa:$lane" in
        x86_64:probe)
            [ "$#" -eq 14 ] &&
            [ "$1" = "$(encoded_arg -machine)" ] && [ "$2" = "$(encoded_arg q35)" ] &&
            [ "$3" = "$(encoded_arg -m)" ] && [ "$4" = "$(encoded_arg 512M)" ] &&
            [ "$5" = "$(encoded_arg -kernel)" ] && encoded_kernel_path_valid "$6" "$kernel_suffix" &&
            [ "$7" = "$(encoded_arg -nographic)" ] && [ "$8" = "$(encoded_arg -no-reboot)" ] &&
            [ "$9" = "$(encoded_arg -device)" ] && [ "${10}" = "$(encoded_arg virtio-net-pci)" ] &&
            [ "${11}" = "$(encoded_arg -object)" ] && encoded_arg_has_affixes "${12}" "$object_prefix" "$object_suffix" &&
            [ "${13}" = "$(encoded_arg -device)" ] && [ "${14}" = "$ivshmem" ]
            ;;
        aarch64:probe)
            [ "$#" -eq 15 ] &&
            [ "$1" = "$(encoded_arg -machine)" ] && [ "$2" = "$(encoded_arg virt)" ] &&
            [ "$3" = "$(encoded_arg -cpu)" ] && [ "$4" = "$(encoded_arg cortex-a72)" ] &&
            [ "$5" = "$(encoded_arg -m)" ] && [ "$6" = "$(encoded_arg 512M)" ] &&
            [ "$7" = "$(encoded_arg -kernel)" ] && encoded_kernel_path_valid "$8" "$kernel_suffix" &&
            [ "$9" = "$(encoded_arg -nographic)" ] && [ "${10}" = "$(encoded_arg -device)" ] &&
            [ "${11}" = "$(encoded_arg virtio-net-pci)" ] && [ "${12}" = "$(encoded_arg -object)" ] &&
            encoded_arg_has_affixes "${13}" "$object_prefix" "$object_suffix" &&
            [ "${14}" = "$(encoded_arg -device)" ] && [ "${15}" = "$ivshmem" ]
            ;;
        aarch64:production)
            [ "$#" -eq 17 ] &&
            [ "$1" = "$(encoded_arg -machine)" ] && [ "$2" = "$(encoded_arg virt)" ] &&
            [ "$3" = "$(encoded_arg -cpu)" ] && [ "$4" = "$(encoded_arg cortex-a72)" ] &&
            [ "$5" = "$(encoded_arg -m)" ] && [ "$6" = "$(encoded_arg 512M)" ] &&
            [ "$7" = "$(encoded_arg -kernel)" ] && encoded_kernel_path_valid "$8" "$kernel_suffix" &&
            [ "$9" = "$(encoded_arg -nographic)" ] && [ "${10}" = "$(encoded_arg -device)" ] &&
            [ "${11}" = "$(encoded_arg ramfb)" ] && [ "${12}" = "$(encoded_arg -device)" ] &&
            [ "${13}" = "$(encoded_arg virtio-net-pci)" ] && [ "${14}" = "$(encoded_arg -object)" ] &&
            encoded_arg_has_affixes "${15}" "$object_prefix" "$object_suffix" &&
            [ "${16}" = "$(encoded_arg -device)" ] && [ "${17}" = "$ivshmem" ]
            ;;
        riscv64:probe)
            [ "$#" -eq 11 ] &&
            [ "$1" = "$(encoded_arg -machine)" ] && [ "$2" = "$(encoded_arg virt)" ] &&
            [ "$3" = "$(encoded_arg -m)" ] && [ "$4" = "$(encoded_arg 512M)" ] &&
            [ "$5" = "$(encoded_arg -kernel)" ] && encoded_kernel_path_valid "$6" "$kernel_suffix" &&
            [ "$7" = "$(encoded_arg -nographic)" ] && [ "$8" = "$(encoded_arg -object)" ] &&
            encoded_arg_has_affixes "$9" "$object_prefix" "$object_suffix" &&
            [ "${10}" = "$(encoded_arg -device)" ] && [ "${11}" = "$ivshmem" ]
            ;;
        *) return 1 ;;
    esac
)

arm64_production_evidence_valid() (
    probe_log=$1
    probe_args=$2
    production_log=$3
    production_args=$4
    serial_qemu_execution_valid "$probe_log" "$probe_args" || return 1
    arm64_production_serial_has_correlated_frame "$production_log" "$production_args" || return 1
    qemu_argv_evidence_valid aarch64 "$probe_args" || return 1
    qemu_argv_evidence_valid aarch64 "$production_args" production || return 1
    [ "$(encoded_argv_field "$probe_args" 13)" = "$(encoded_argv_field "$production_args" 15)" ] || return 1
    probe_generation=$(sed -n 's/^HOST_GPU_PROCESS_OK isa=aarch64 .* generation=\([1-9][0-9]*\) .*/\1/p' "$probe_log")
    production_first_generation=$(sed -n "s/^HOST_GPU_NEGOTIATION_DONE scope=production isa=aarch64 result=selected backend=$BACKEND attempts=[1-3] first_generation=\\([1-9][0-9]*\\) .*/\\1/p" "$production_log")
    production_ready_generation=$(sed -n "s/^\\[wm-frame\\] host-gpu-ready backend=$BACKEND generation=\\([1-9][0-9]*\\)[[:space:]]*$/\\1/p" "$production_log")
    case "$probe_generation:$production_first_generation:$production_ready_generation" in *[!0-9:]*|:*|*:) return 1 ;; esac
    case "$BACKEND" in
        metal) expected_ready_generation=$((probe_generation + 1)) ;;
        directx) expected_ready_generation=$((probe_generation + 2)) ;;
        vulkan) expected_ready_generation=$((probe_generation + 3)) ;;
        *) return 1 ;;
    esac
    [ "$production_first_generation" -eq "$((probe_generation + 1))" ] &&
    [ "$production_ready_generation" -eq "$expected_ready_generation" ]
)

emit_row_execution_evidence() {
    evidence_prefix="simpleos_qemu_host_gpu_2d_$1_$2"
    printf '%s\n' "${evidence_prefix}_qemu_version=$3"
    printf '%s\n' "${evidence_prefix}_qemu_device_args=$4"
    printf '%s\n' "${evidence_prefix}_daemon_max_rss_kib=$5"
    printf '%s\n' "${evidence_prefix}_qemu_max_rss_kib=$6"
    printf '%s\n' "${evidence_prefix}_combined_max_rss_kib=$7"
}

emit_processing_perf_evidence() {
    evidence_host=$1
    evidence_isa=$2
    evidence_serial=$3
    evidence_daemon=$4
    processing_perf_evidence_valid "$evidence_serial" "$evidence_daemon" "$evidence_isa" || return 1
    evidence_prefix="simpleos_qemu_host_gpu_2d_${evidence_host}_${evidence_isa}"
    printf '%s\n' "${evidence_prefix}_daemon_log=$evidence_daemon"
    printf '%s\n' "${evidence_prefix}_processing_cpu_us=$(processing_perf_field "$evidence_daemon" "$evidence_isa" cpu_us)"
    printf '%s\n' "${evidence_prefix}_processing_device_us=$(processing_perf_field "$evidence_daemon" "$evidence_isa" device_us)"
    printf '%s\n' "${evidence_prefix}_processing_preference=$(processing_perf_field "$evidence_daemon" "$evidence_isa" preference)"
}

emit_render_latency_evidence() {
    evidence_host=$1
    evidence_isa=$2
    evidence_serial=$3
    evidence_qemu_args=$4
    render_latency_evidence_valid "$evidence_serial" "$evidence_isa" "$evidence_qemu_args" "$BACKEND" || return 1
    evidence_prefix="simpleos_qemu_host_gpu_2d_${evidence_host}_${evidence_isa}"
    printf '%s\n' "${evidence_prefix}_render_sample_count=$HOST_GPU_WARM_SAMPLE_COUNT"
    printf '%s\n' "${evidence_prefix}_render_readback_p95_us=$(render_latency_p95_us "$evidence_serial" "$evidence_isa" "$BACKEND")"
    printf '%s\n' "${evidence_prefix}_render_latency_applicability=$(negotiation_applicability "$evidence_isa" "$evidence_qemu_args")"
}

emit_arm64_production_evidence() {
    evidence_prefix="simpleos_qemu_host_gpu_2d_$1_aarch64"
    printf '%s\n' "${evidence_prefix}_production_serial_log=$2"
    printf '%s\n' "${evidence_prefix}_production_qemu_device_args=$3"
}

report_one() {
    report=$1
    key=$2
    [ "$(grep -ac "^${key}=" "$report" 2>/dev/null || true)" -eq 1 ] || return 1
    sed -n "s/^${key}=//p" "$report"
}

report_arm64_production_evidence_valid() {
    report=$1
    prefix=$2
    report_isa=$3
    row_log=$4
    row_qemu_device_args=$5
    row_production_serial_log=$(report_one "$report" "${prefix}_production_serial_log") || return 1
    row_production_qemu_device_args=$(report_one "$report" "${prefix}_production_qemu_device_args") || return 1
    [ "$report_isa" = aarch64 ] && [ -f "$row_production_serial_log" ] &&
    arm64_production_evidence_valid "$row_log" "$row_qemu_device_args" "$row_production_serial_log" "$row_production_qemu_device_args"
}

validate_report() (
    report=$1
    [ -f "$report" ] || return 1
    status=$(report_one "$report" simpleos_qemu_host_gpu_2d_status) || return 1
    reason=$(report_one "$report" simpleos_qemu_host_gpu_2d_reason) || return 1
    report_active_host=$(report_one "$report" simpleos_qemu_host_gpu_2d_host 2>/dev/null || true)
    [ -n "$report_active_host" ] || report_active_host=linux
    report_host_arch=$(report_one "$report" simpleos_qemu_host_gpu_2d_host_arch) || return 1
    selector_count=$(grep -ac '^simpleos_qemu_host_gpu_2d_processing_selector=' "$report" 2>/dev/null || true)
    case "$selector_count" in
        0) report_processing_selector=auto ;;
        1) report_processing_selector=$(report_one "$report" simpleos_qemu_host_gpu_2d_processing_selector) || return 1 ;;
        *) return 1 ;;
    esac
    case "$report_active_host" in linux|macos|windows) ;; *) return 1 ;; esac
    case "$report_host_arch" in x86_64|aarch64|riscv64) ;; *) return 1 ;; esac
    HOST_ARCH=$report_host_arch
    case "$report_processing_selector:$report_active_host" in auto:*|vulkan:linux) ;; *) return 1 ;; esac
    [ -n "$reason" ] || return 1
    case "$status" in pass|blocked|fail|unsupported) ;; *) return 1 ;; esac

    for report_host in linux macos windows; do
        for report_isa in x86_64 aarch64 riscv64; do
            prefix="simpleos_qemu_host_gpu_2d_${report_host}_${report_isa}"
            row_status=$(report_one "$report" "${prefix}_status") || return 1
            row_reason=$(report_one "$report" "${prefix}_reason") || return 1
            row_render_backend=$(report_one "$report" "${prefix}_render_backend") || return 1
            row_processing_backend=$(report_one "$report" "${prefix}_processing_backend") || return 1
            row_log=$(report_one "$report" "${prefix}_serial_log") || return 1
            [ -n "$row_reason" ] && [ -n "$row_log" ] || return 1
            case "$row_status" in pass|blocked|fail|unsupported) ;; *) return 1 ;; esac
            case "$report_host:$row_render_backend:$row_processing_backend" in
                linux:vulkan:cuda-preferred-vulkan-fallback|linux:vulkan:cuda|linux:vulkan:vulkan) ;;
                macos:metal:metal|windows:directx:cuda-preferred-vulkan-fallback|windows:directx:cuda|windows:directx:vulkan) ;;
                *) return 1 ;;
            esac
            if [ "$row_status" = pass ]; then
                saved_row_host=$ACTIVE_HOST
                set_host_contract "$report_host"
                if [ "$report_host" = "$report_active_host" ]; then
                    apply_processing_selector "$report_processing_selector" || return 1
                fi
                if ! {
                    [ "$row_reason" = ok ] &&
                    [ -f "$row_log" ] && serial_has_pass "$row_log" "$report_isa" &&
                    [ "$row_processing_backend" = "$(serial_processing_backend "$row_log" "$report_isa")" ] &&
                    row_qemu_version=$(report_one "$report" "${prefix}_qemu_version") &&
                    row_render_sample_count=$(report_one "$report" "${prefix}_render_sample_count") &&
                    row_render_readback_p95_us=$(report_one "$report" "${prefix}_render_readback_p95_us") &&
                    row_render_latency_applicability=$(report_one "$report" "${prefix}_render_latency_applicability") &&
                    row_qemu_device_args=$(report_one "$report" "${prefix}_qemu_device_args") &&
                    row_daemon_rss=$(report_one "$report" "${prefix}_daemon_max_rss_kib") &&
                    row_qemu_rss=$(report_one "$report" "${prefix}_qemu_max_rss_kib") &&
                    row_combined_rss=$(report_one "$report" "${prefix}_combined_max_rss_kib") &&
                    row_daemon_log=$(report_one "$report" "${prefix}_daemon_log") &&
                    row_processing_cpu_us=$(report_one "$report" "${prefix}_processing_cpu_us") &&
                    row_processing_device_us=$(report_one "$report" "${prefix}_processing_device_us") &&
                    row_processing_preference=$(report_one "$report" "${prefix}_processing_preference") &&
                    [ -n "$row_qemu_version" ] &&
                    qemu_argv_evidence_valid "$report_isa" "$row_qemu_device_args" &&
                    [ "$row_render_sample_count" = "$HOST_GPU_WARM_SAMPLE_COUNT" ] &&
                    [ "$row_render_readback_p95_us" = "$(render_latency_p95_us "$row_log" "$report_isa" "$BACKEND")" ] &&
                    [ "$row_render_latency_applicability" = "$(negotiation_applicability "$report_isa" "$row_qemu_device_args")" ] &&
                    row_rss_evidence_valid "$row_daemon_rss" "$row_qemu_rss" "$row_combined_rss" &&
                    processing_selector_evidence_valid "$row_daemon_log" "$report_processing_selector" &&
                    processing_perf_evidence_valid "$row_log" "$row_daemon_log" "$report_isa" &&
                    [ "$row_processing_cpu_us" = "$(processing_perf_field "$row_daemon_log" "$report_isa" cpu_us)" ] &&
                    [ "$row_processing_device_us" = "$(processing_perf_field "$row_daemon_log" "$report_isa" device_us)" ] &&
                    [ "$row_processing_preference" = "$(processing_perf_field "$row_daemon_log" "$report_isa" preference)" ] &&
                    { [ "$report_isa" != aarch64 ] || report_arm64_production_evidence_valid "$report" "$prefix" "$report_isa" "$row_log" "$row_qemu_device_args"; }
                }; then
                    set_host_contract "$saved_row_host"
                    return 1
                fi
                set_host_contract "$saved_row_host"
            elif grep -aEq "^${prefix}_(render_sample_count|render_readback_p95_us|render_latency_applicability|daemon_log|processing_cpu_us|processing_device_us|processing_preference)=" "$report"; then
                return 1
            fi
        done
    done

    if [ "$status" = pass ]; then
        saved_host=$ACTIVE_HOST
        set_host_contract "$report_active_host"
        apply_processing_selector "$report_processing_selector" || { set_host_contract "$saved_host"; return 1; }
        [ "$reason" = "all-$report_active_host-host-gpu-rows-pass" ] || { set_host_contract "$saved_host"; return 1; }
        [ "$(report_one "$report" simpleos_qemu_host_gpu_2d_backend)" = "$BACKEND" ] || { set_host_contract "$saved_host"; return 1; }
        [ "$(report_one "$report" simpleos_qemu_host_gpu_2d_processing_backend)" = "$PROCESSING_BACKEND" ] || { set_host_contract "$saved_host"; return 1; }
        [ "$(report_one "$report" simpleos_qemu_host_gpu_2d_rows)" -eq 3 ] || return 1
        [ "$(report_one "$report" simpleos_qemu_host_gpu_2d_passed)" -eq 3 ] || return 1
        [ "$(report_one "$report" simpleos_qemu_host_gpu_2d_blocked)" -eq 0 ] || return 1
        [ "$(report_one "$report" simpleos_qemu_host_gpu_2d_failed)" -eq 0 ] || return 1
        for inactive_host in linux macos windows; do
            if [ "$inactive_host" != "$report_active_host" ]; then
                for report_isa in x86_64 aarch64 riscv64; do
                    [ "$(report_one "$report" "simpleos_qemu_host_gpu_2d_${inactive_host}_${report_isa}_status")" = unsupported ] || return 1
                done
            fi
        done
        for report_isa in x86_64 aarch64 riscv64; do
            prefix="simpleos_qemu_host_gpu_2d_${report_active_host}_${report_isa}"
            [ "$(report_one "$report" "${prefix}_status")" = pass ] || return 1
        done
        set_host_contract "$saved_host"
    fi

    echo "simpleos_qemu_host_gpu_2d_report_validation=pass"
    echo "simpleos_qemu_host_gpu_2d_report_status=$status"
    echo "simpleos_qemu_host_gpu_2d_report_reason=$reason"
)

append_render_latency_fixture() {
    fixture_log=$1
    fixture_isa=$2
    fixture_backend=$3
    fixture_first_generation=$4
    fixture_run=$5
    fixture_identity=$6
    fixture_elapsed_us=$7
    fixture_sample=1
    while [ "$fixture_sample" -le "$HOST_GPU_WARM_SAMPLE_COUNT" ]; do
        fixture_generation=$((fixture_first_generation + fixture_sample - 1))
        printf '%s\n' "HOST_GPU_FIXTURE_SAMPLE isa=$fixture_isa backend=$fixture_backend sample=$fixture_sample generation=$fixture_generation run=$fixture_run frame=$fixture_generation protocol=$EXPECTED_PROTOCOL_VERSION width=$HOST_GPU_FIXTURE_WIDTH height=$HOST_GPU_FIXTURE_HEIGHT elapsed_us=$fixture_elapsed_us handle=$fixture_generation identity=$fixture_identity checksum=$HOST_GPU_FIXTURE_CHECKSUM mismatches=0" >>"$fixture_log"
        fixture_sample=$((fixture_sample + 1))
    done
}

append_qemu_execution_fixture() {
    printf '%s\n' "HOST_GPU_QEMU_EXECUTION argv=$2" >>"$1"
}

shift_probe_fixture() {
    fixture_source=$1
    fixture_target=$2
    fixture_isa=$3
    fixture_delta=$4
    fixture_qemu_args=$5
    awk -v target_isa="$fixture_isa" -v delta="$fixture_delta" '
        $1 != "HOST_GPU_QEMU_EXECUTION" {
            for (i = 1; i <= NF; i++) {
                if ($i == "isa=aarch64") $i = "isa=" target_isa
                if ($i ~ /^(generation|first_generation|final_generation|frame)=[1-9][0-9]*$/) {
                    split($i, parts, "=")
                    $i = parts[1] "=" (parts[2] + delta)
                }
            }
            print
        }
    ' "$fixture_source" >"$fixture_target"
    append_qemu_execution_fixture "$fixture_target" "$fixture_qemu_args"
}

self_test() {
    set_host_contract linux
    HOST_ARCH=x86_64
    REQUIRE_CUDA=0
    temp_dir=$(mktemp -d)
    trap 'rm -rf "$temp_dir"' EXIT HUP INT TERM
    pass_log="$temp_dir/pass.log"
    fail_log="$temp_dir/fail.log"
    corrupt_log="$temp_dir/corrupt.log"
    corrupt_draw_ir_log="$temp_dir/corrupt-draw-ir.log"
    vulkan_log="$temp_dir/vulkan.log"
    wrong_backend_log="$temp_dir/wrong-backend.log"
    wrong_generation_log="$temp_dir/wrong-generation.log"
    wrong_fixture_log="$temp_dir/wrong-fixture.log"
    wrong_fixture_correlation_log="$temp_dir/wrong-fixture-correlation.log"
    missing_latency_log="$temp_dir/render-latency-missing.log"
    duplicate_latency_log="$temp_dir/render-latency-duplicate.log"
    stale_latency_log="$temp_dir/render-latency-stale.log"
    zero_latency_log="$temp_dir/render-latency-zero.log"
    slow_latency_log="$temp_dir/render-latency-slow.log"
    native_limit_latency_log="$temp_dir/render-latency-native-limit.log"
    native_over_limit_latency_log="$temp_dir/render-latency-native-over-limit.log"
    tcg_over_limit_latency_log="$temp_dir/render-latency-tcg-over-limit.log"
    stale_generation_log="$temp_dir/stale-generation.log"
    trailing_log="$temp_dir/trailing.log"
    contradictory_terminal_log="$temp_dir/contradictory-terminal.log"
    over_budget_log="$temp_dir/negotiation-over-budget.log"
    missing_attempt_log="$temp_dir/negotiation-missing-attempt.log"
    duplicate_attempt_log="$temp_dir/negotiation-duplicate-attempt.log"
    stale_attempt_log="$temp_dir/negotiation-stale-attempt.log"
    wrong_attempt_status_log="$temp_dir/negotiation-wrong-attempt-status.log"
    wrong_attempt_reason_log="$temp_dir/negotiation-wrong-attempt-reason.log"
    wrong_timeout_reason_log="$temp_dir/negotiation-wrong-timeout-reason.log"
    wrong_budget_log="$temp_dir/negotiation-wrong-budget.log"
    undercounted_elapsed_log="$temp_dir/negotiation-undercounted-elapsed.log"
    wrong_attempt_order_log="$temp_dir/negotiation-wrong-attempt-order.log"
    late_map_log="$temp_dir/negotiation-late-map.log"
    fallback_negotiation_log="$temp_dir/negotiation-fallback.log"
    stale_negotiation_log="$temp_dir/negotiation-stale.log"
    budget_negotiation_log="$temp_dir/negotiation-budget.log"
    invalid_alias_log="$temp_dir/negotiation-invalid-alias.log"
    zero_attempt_fallback_log="$temp_dir/negotiation-zero-attempt-fallback.log"
    dishonest_zero_attempt_log="$temp_dir/negotiation-dishonest-zero-attempt.log"
    x86_log="$temp_dir/x86_64.log"
    riscv_log="$temp_dir/riscv64.log"
    metal_log="$temp_dir/metal-aarch64.log"
    metal_x86_log="$temp_dir/metal-x86_64.log"
    metal_riscv_log="$temp_dir/metal-riscv64.log"
    metal_wrong_mask_log="$temp_dir/metal-wrong-mask.log"
    metal_wrong_backend_log="$temp_dir/metal-wrong-backend.log"
    metal_wrong_generation_log="$temp_dir/metal-wrong-generation.log"
    directx_log="$temp_dir/directx-aarch64.log"
    directx_x86_log="$temp_dir/directx-x86_64.log"
    directx_riscv_log="$temp_dir/directx-riscv64.log"
    directx_vulkan_log="$temp_dir/directx-vulkan.log"
    directx_wrong_mask_log="$temp_dir/directx-wrong-mask.log"
    directx_wrong_backend_log="$temp_dir/directx-wrong-backend.log"
    directx_wrong_identity_log="$temp_dir/directx-wrong-identity.log"
    pass_daemon_log="$temp_dir/pass-daemon.log"
    x86_daemon_log="$temp_dir/x86_64-daemon.log"
    riscv_daemon_log="$temp_dir/riscv64-daemon.log"
    metal_daemon_log="$temp_dir/metal-aarch64-daemon.log"
    metal_x86_daemon_log="$temp_dir/metal-x86_64-daemon.log"
    metal_riscv_daemon_log="$temp_dir/metal-riscv64-daemon.log"
    directx_daemon_log="$temp_dir/directx-aarch64-daemon.log"
    directx_x86_daemon_log="$temp_dir/directx-x86_64-daemon.log"
    directx_riscv_daemon_log="$temp_dir/directx-riscv64-daemon.log"
    selector_log="$temp_dir/selector.log"
    slow_daemon_log="$temp_dir/slow-daemon.log"
    dishonest_daemon_log="$temp_dir/dishonest-daemon.log"
    stale_perf_daemon_log="$temp_dir/stale-perf-daemon.log"
    duplicate_perf_daemon_log="$temp_dir/duplicate-perf-daemon.log"
    zero_perf_daemon_log="$temp_dir/zero-perf-daemon.log"
    oversized_perf_daemon_log="$temp_dir/oversized-perf-daemon.log"
    production_log="$temp_dir/arm64-production.log"
    production_wrong_backend_log="$temp_dir/arm64-production-wrong-backend.log"
    production_wrong_run_log="$temp_dir/arm64-production-wrong-run.log"
    production_wrong_frame_log="$temp_dir/arm64-production-wrong-frame.log"
    production_discontinuous_log="$temp_dir/arm64-production-discontinuous.log"
    production_stale_negotiation_log="$temp_dir/arm64-production-stale-negotiation.log"
    production_duplicate_log="$temp_dir/arm64-production-duplicate.log"
    production_missing_log="$temp_dir/arm64-production-missing.log"
    metal_production_log="$temp_dir/metal-arm64-production.log"
    directx_production_log="$temp_dir/directx-arm64-production.log"
    pass_report="$temp_dir/pass.env"
    metal_pass_report="$temp_dir/metal-pass.env"
    directx_pass_report="$temp_dir/directx-pass.env"
    fake_report="$temp_dir/fake.env"
    bad_backend_report="$temp_dir/bad-backend.env"
    native_report="$temp_dir/native.env"
    relabeled_report="$temp_dir/native-relabeled-as-tcg.env"
    valid_simple="$temp_dir/simple-valid"
    argument_only_simple="$temp_dir/simple-argument-only"
    frontend_hanging_simple="$temp_dir/simple-frontend-hanging"
    wrong_output_simple="$temp_dir/simple-wrong-output"
    seed_simple="$temp_dir/simple-seed"
    hanging_simple="$temp_dir/simple-hanging"
    failing_simple="$temp_dir/simple-probe-failing"
    printf '%s\n' 'HOST_GPU_DAEMON_SELECTOR processing_backend=vulkan' >"$selector_log"
    processing_selector_evidence_valid "$selector_log" vulkan
    processing_selector_evidence_valid "$selector_log" auto
    if processing_selector_evidence_valid "$selector_log" metal; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    set_host_contract linux
    apply_processing_selector vulkan
    if [ "$PROCESSING_BACKEND:$EXPECTED_PROCESSING_MASK:$EXPECTED_PROCESSING_RECEIPT" != vulkan:1:vulkan ]; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    set_host_contract macos
    if apply_processing_selector vulkan; then
        echo "simpleos_qemu_host_gpu_2d_self_test=fail"
        exit 1
    fi
    set_host_contract linux
    x86_qemu_args=$(encode_argv_hex -machine q35 -accel tcg -m 512M -kernel "$(kernel_for_isa x86_64)" -nographic -no-reboot \
        -device virtio-net-pci -object "memory-backend-file,id=hostgpu,share=on,mem-path=$temp_dir/x86 host gpu.shm,size=8M" \
        -device ivshmem-plain,memdev=hostgpu)
    x86_native_qemu_args=$(encode_argv_hex -machine q35 -accel kvm -m 512M -kernel "$(kernel_for_isa x86_64)" -nographic -no-reboot \
        -device virtio-net-pci -object "memory-backend-file,id=hostgpu,share=on,mem-path=$temp_dir/x86 host gpu.shm,size=8M" \
        -device ivshmem-plain,memdev=hostgpu)
    arm_qemu_args=$(encode_argv_hex -machine virt -cpu cortex-a72 -m 512M -kernel "$(kernel_for_isa aarch64)" -nographic \
        -device virtio-net-pci -object "memory-backend-file,id=hostgpu,share=on,mem-path=$temp_dir/arm host gpu.shm,size=8M" \
        -device ivshmem-plain,memdev=hostgpu)
