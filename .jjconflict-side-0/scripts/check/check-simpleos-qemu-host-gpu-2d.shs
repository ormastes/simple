    sed '/^HOST_GPU_NEGOTIATION_ATTEMPT scope=probe isa=aarch64 backend=directx /s/generation=20/generation=99/' "$pass_log" >"$stale_attempt_log"
    sed '/^HOST_GPU_NEGOTIATION_ATTEMPT scope=probe isa=aarch64 backend=vulkan /s/status=1/status=3/' "$pass_log" >"$wrong_attempt_status_log"
    sed '/^HOST_GPU_NEGOTIATION_ATTEMPT scope=probe isa=aarch64 backend=metal /s/reason=9/reason=2/' "$pass_log" >"$wrong_attempt_reason_log"
    sed "/^HOST_GPU_NEGOTIATION_DONE /s/budget_us=$NEGOTIATION_MAX_US/budget_us=$((NEGOTIATION_MAX_US + 1))/" "$pass_log" >"$wrong_budget_log"
    sed '/^HOST_GPU_NEGOTIATION_DONE /s/elapsed_us=[1-9][0-9]*/elapsed_us=99/' "$pass_log" >"$undercounted_elapsed_log"
    sed '/^HOST_GPU_NEGOTIATION_ATTEMPT scope=probe isa=aarch64 backend=metal /s/backend=metal/backend=directx/' "$pass_log" >"$wrong_attempt_order_log"
    grep -v '^HOST_GPU_MAP_OK ' "$pass_log" | awk '/^HOST_GPU_HELLO_OK / { print "HOST_GPU_MAP_OK isa=aarch64 device=3" } { print }' >"$late_map_log"
    cat >"$fallback_negotiation_log" <<EOF
HOST_GPU_MAP_OK isa=aarch64 device=3
HOST_GPU_NEGOTIATION_ATTEMPT scope=probe isa=aarch64 backend=metal generation=19 outcome=rejected status=2 reason=9 daemon_elapsed_us=10 guest_elapsed_us=20
HOST_GPU_NEGOTIATION_ATTEMPT scope=probe isa=aarch64 backend=directx generation=20 outcome=rejected status=2 reason=9 daemon_elapsed_us=10 guest_elapsed_us=20
HOST_GPU_NEGOTIATION_ATTEMPT scope=probe isa=aarch64 backend=vulkan generation=21 outcome=timeout status=3 reason=3 daemon_elapsed_us=0 guest_elapsed_us=499960
HOST_GPU_NEGOTIATION_DONE scope=probe isa=aarch64 result=fallback backend=software attempts=3 first_generation=19 final_generation=21 elapsed_us=$NEGOTIATION_MAX_US budget_us=$NEGOTIATION_MAX_US reason=3
EOF
    sed '/backend=vulkan generation=21 outcome=timeout /s/reason=3/reason=9/' "$fallback_negotiation_log" >"$wrong_timeout_reason_log"
    sed -e '/backend=vulkan generation=21 outcome=timeout /s/outcome=timeout/outcome=stale/' \
        -e '/backend=vulkan generation=21 outcome=stale /s/reason=3/reason=7/' \
        -e '/^HOST_GPU_NEGOTIATION_DONE /s/reason=3/reason=7/' \
        "$fallback_negotiation_log" >"$stale_negotiation_log"
    sed -e '/backend=vulkan generation=21 outcome=timeout /s/outcome=timeout/outcome=budget/' \
        -e '/backend=vulkan generation=21 outcome=budget /s/status=3 reason=3 daemon_elapsed_us=0/status=1 reason=3 daemon_elapsed_us=10/' \
        "$fallback_negotiation_log" >"$budget_negotiation_log"
    sed '/backend=vulkan generation=21 outcome=selected /s/outcome=selected/outcome=invalid/' "$pass_log" >"$invalid_alias_log"
    cat >"$zero_attempt_fallback_log" <<EOF
HOST_GPU_MAP_OK isa=aarch64 device=3
HOST_GPU_NEGOTIATION_DONE scope=probe isa=aarch64 result=fallback backend=software attempts=0 first_generation=0 final_generation=0 elapsed_us=1 budget_us=$NEGOTIATION_MAX_US reason=7
EOF
    sed 's/first_generation=0/first_generation=19/' "$zero_attempt_fallback_log" >"$dishonest_zero_attempt_log"
    cat >"$pass_daemon_log" <<'EOF'
HOST_GPU_PROCESS_PERF isa=aarch64 backend=cuda generation=45 run=1022 frame=45 cpu_us=120 device_us=80 preference=preferred
EOF
    sed 's/aarch64/x86_64/; s/generation=45/generation=35/; s/frame=45/frame=35/' "$pass_daemon_log" >"$x86_daemon_log"
    sed 's/aarch64/riscv64/; s/generation=45/generation=55/; s/frame=45/frame=55/' "$pass_daemon_log" >"$riscv_daemon_log"
    sed 's/backend=cuda/backend=metal/; s/generation=45/generation=43/; s/run=1022/run=1020/; s/frame=45/frame=43/' "$pass_daemon_log" >"$metal_daemon_log"
    sed 's/aarch64/x86_64/; s/backend=cuda/backend=metal/; s/generation=45/generation=33/; s/run=1022/run=1020/; s/frame=45/frame=33/' "$pass_daemon_log" >"$metal_x86_daemon_log"
    sed 's/aarch64/riscv64/; s/backend=cuda/backend=metal/; s/generation=45/generation=53/; s/run=1022/run=1020/; s/frame=45/frame=53/' "$pass_daemon_log" >"$metal_riscv_daemon_log"
    sed 's/generation=45/generation=44/; s/run=1022/run=1021/; s/frame=45/frame=44/' "$pass_daemon_log" >"$directx_daemon_log"
    sed 's/aarch64/x86_64/; s/generation=45/generation=34/; s/run=1022/run=1021/; s/frame=45/frame=34/' "$pass_daemon_log" >"$directx_x86_daemon_log"
    sed 's/aarch64/riscv64/; s/generation=45/generation=54/; s/run=1022/run=1021/; s/frame=45/frame=54/' "$pass_daemon_log" >"$directx_riscv_daemon_log"
    sed 's/cpu_us=120/cpu_us=119/; s/preference=preferred/preference=available-not-preferred/' "$pass_daemon_log" >"$slow_daemon_log"
    sed 's/cpu_us=120/cpu_us=119/' "$pass_daemon_log" >"$dishonest_daemon_log"
    sed 's/generation=45/generation=46/' "$pass_daemon_log" >"$stale_perf_daemon_log"
    { cat "$pass_daemon_log"; cat "$pass_daemon_log"; } >"$duplicate_perf_daemon_log"
    sed 's/cpu_us=120/cpu_us=0/' "$pass_daemon_log" >"$zero_perf_daemon_log"
    sed 's/cpu_us=120/cpu_us=9223372036854775808/; s/preference=preferred/preference=available-not-preferred/' "$pass_daemon_log" >"$oversized_perf_daemon_log"
