        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc;color:transparent;font-size:0}.stage{display:flex;gap:4px;background-color:#e5e7eb;padding:4px;width:88px;height:56px}.left{display:block}.right{display:block}.article{display:block;background-color:#1d4ed8;width:36px;height:6px}.aside{display:block;background-color:#22c55e;width:28px;height:6px;margin-top:2px}.figure{display:block;background-color:#dbeafe;margin:2px 0 0 0;padding:2px;width:38px;height:14px}.caption{display:block;background-color:#f59e0b;width:20px;height:4px}.address{display:block;background-color:#ef4444;width:26px;height:6px;margin-top:2px}.time{display:block;background-color:#0f172a;width:34px;height:6px}.mark{display:block;background-color:#a855f7;width:24px;height:6px;margin-top:2px}.small{display:block;background-color:#14b8a6;width:20px;height:6px;margin-top:2px}.code{display:block;background-color:#84cc16;width:30px;height:6px;margin-top:2px}.kbd{display:block;background-color:#64748b;width:18px;height:6px;margin-top:2px}</style></head><body><section class='stage'><div class='left'><article class='article'></article><aside class='aside'></aside><figure class='figure'><figcaption class='caption'></figcaption></figure><address class='address'></address></div><div class='right'><time class='time'></time><mark class='mark'></mark><small class='small'></small><code class='code'></code><kbd class='kbd'></kbd></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-phrasing-tags-matrix":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc;color:transparent;font-size:0}.stage{display:flex;gap:4px;background-color:#e5e7eb;padding:4px;width:88px;height:56px}.left{display:block;width:30px}.right{display:block;width:34px}.a{display:block;background-color:#1d4ed8;width:30px;height:5px}.span{display:block;background-color:#22c55e;width:26px;height:5px;margin-top:2px}.b{display:block;background-color:#f59e0b;width:22px;height:5px;margin-top:2px}.strong{display:block;background-color:#ef4444;width:18px;height:5px;margin-top:2px}.em{display:block;background-color:#334155;width:28px;height:5px;margin-top:2px}.i{display:block;background-color:#a855f7;width:20px;height:5px}.u{display:block;background-color:#14b8a6;width:24px;height:5px;margin-top:2px}.s{display:block;background-color:#84cc16;width:16px;height:5px;margin-top:2px}.abbr{display:block;background-color:#0f172a;width:32px;height:5px;margin-top:2px}.cite{display:block;background-color:#64748b;width:22px;height:5px;margin-top:2px}</style></head><body><section class='stage'><div class='left'><a class='a'></a><span class='span'></span><b class='b'></b><strong class='strong'></strong><em class='em'></em></div><div class='right'><i class='i'></i><u class='u'></u><s class='s'></s><abbr class='abbr'></abbr><cite class='cite'></cite></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-ruby-edit-data-tags-matrix":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc;color:transparent;font-size:0}.stage{display:flex;gap:4px;background-color:#e5e7eb;padding:4px;width:88px;height:56px}.left,.right{display:block;width:34px}ruby,rb,rt,rp,ins,del,data,var,samp,q,dfn{display:block;margin:0;padding:0;border:0;color:transparent;font-size:0;line-height:0}ruby{background-color:#dbeafe;width:32px;height:16px;padding:2px}rb{background-color:#1d4ed8;width:24px;height:4px}rt{background-color:#22c55e;width:20px;height:4px;margin-top:2px}rp{background-color:#f59e0b;width:16px;height:3px;margin-top:1px}ins{background-color:#ef4444;width:30px;height:5px;margin-top:3px}del{background-color:#334155;width:26px;height:5px;margin-top:2px}data{background-color:#a855f7;width:22px;height:5px}var{background-color:#14b8a6;width:24px;height:5px;margin-top:2px}samp{background-color:#84cc16;width:28px;height:5px;margin-top:2px}q{background-color:#0f172a;width:18px;height:5px;margin-top:2px}dfn{background-color:#64748b;width:20px;height:5px;margin-top:2px}</style></head><body><section class='stage'><div class='left'><ruby><rb></rb><rt></rt><rp></rp></ruby><ins></ins><del></del></div><div class='right'><data value='42'></data><var></var><samp></samp><q></q><dfn></dfn></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-commandbar-taskbar-card":
        html = "<html><style>header{background-color:#1d4ed8;color:#ffffff;font-size:8px;padding:1px}nav{background-color:#0f172a;color:#ffffff;font-size:8px;padding:1px}main{background-color:#e5e7eb;background-image:linear-gradient(#e5e7eb,#cbd5e1);color:#111827;font-size:8px;padding:1px}button{background-color:#22c55e;color:#052e16;font-size:8px;padding:1px}footer{background-color:#334155;color:#ffffff;font-size:8px;padding:1px}</style><body><header>CMD</header><nav>TASK</nav><main><button>RUN</button>CARD</main><footer>OK</footer></body></html>"
    if "$SCENE" == "simple-web-layout-image-text-command-taskbar":
        html = "<html><style>header{background-color:#1d4ed8;color:#ffffff;font-size:8px;padding:1px}nav{background-color:#0f172a;color:#ffffff;font-size:8px;padding:1px}main{background-color:#f8fafc;color:#111827;font-size:8px;padding:1px}img.preview{display:block;width:48px;height:16px;object-fit:contain;object-position:left top;background-color:#94a3b8;padding:4px}p{color:#111827;font-size:8px;padding:1px}footer{background-color:#334155;color:#ffffff;font-size:8px;padding:1px}</style><body><header>CMD</header><nav>TASK</nav><main><img class='preview widget-image' alt='image'/><p>IMAGE LAB</p></main><footer>OK</footer></body></html>"
    if "$SCENE" == "simple-web-layout-selector-inline-override":
        html = "<html><style>body{background-color:#f8fafc;color:#111827;font-size:8px}.status{background-color:#22c55e;color:#052e16;font-size:8px;padding:1px}#override{background-color:#f59e0b;color:#111827;font-size:8px;padding:1px}footer.status{background-color:#334155;color:#ffffff;font-size:8px;padding:1px}</style><body><div class='status'>CLASS</div><button id='override' style='background-color:#ef4444;color:#ffffff;font-size:8px;padding:1px'>INLINE</button><footer class='status'>READY</footer></body></html>"
    if "$SCENE" == "simple-web-layout-descendant-scope":
        html = "<html><style>.status{background-color:#334155;color:#ffffff;font-size:8px;padding:1px}.panel .status{background-color:#22c55e;color:#052e16;font-size:8px;padding:1px}</style><body><section class='panel'><div class='status'>IN</div></section><div class='status'>OUT</div></body></html>"
    if "$SCENE" == "simple-web-layout-child-scope":
        html = "<html><style>.status{background-color:#334155;color:#ffffff;font-size:8px;padding:1px}.panel>.status{background-color:#22c55e;color:#052e16;font-size:8px;padding:1px}</style><body><section class='panel'><div class='status'>DIRECT</div><div><span class='status'>NESTED</span></div></section><div class='status'>OUT</div></body></html>"
    val wrote_html = file_write_text(HTML_PATH, html)
    val pixels = simple_web_render_html_to_pixels(html, WIDTH, HEIGHT)
    if pixels.len() != WIDTH * HEIGHT:
        print "simple_status=fail"
        print "simple_reason=wrong-pixel-count"
        return
    val wrote = write_expected_bitmap(pixels)
    print "simple_status={if wrote and wrote_html: \"pass\" else: \"fail\"}"
    print "simple_reason={if wrote and wrote_html: \"pass\" else: \"write-expected-artifacts-failed\"}"
    print "renderer=pure-simple-web-layout-renderer"
    print "scene=$SCENE"
    print "width={WIDTH}"
    print "height={HEIGHT}"
    print "checksum={checksum(pixels)}"
    print "weighted_checksum={weighted_checksum(pixels)}"
    print "expected_argb_path={EXPECTED_ARGB_PATH}"
    print "blur_or_tolerance_used=false"

main()
SIMPLE_EOF

set +e
if have timeout; then
    SIMPLE_LIB="${SIMPLE_LIB:-src}" timeout "$SIMPLE_EXPECTED_TIMEOUT_SECS" "$SIMPLE_BIN" run "$SIMPLE_SRC" --mode=interpreter --clean >"$SIMPLE_OUT" 2>&1
    simple_code=$?
else
    simple_code=127
fi
set -e
SIMPLE_EXPECTED_EXIT_CODE=$simple_code
if [ "$simple_code" -eq 124 ]; then
    SIMPLE_EXPECTED_TIMED_OUT=true
    SIMPLE_EXPECTED_STATUS=unavailable
    SIMPLE_EXPECTED_REASON=simple-expected-timeout
elif [ "$simple_code" -eq 127 ] && ! have timeout; then
    SIMPLE_EXPECTED_STATUS=unavailable
    SIMPLE_EXPECTED_REASON=simple-expected-timeout-command-missing
elif [ "$simple_code" -ne 0 ]; then
    SIMPLE_EXPECTED_STATUS=fail
    SIMPLE_EXPECTED_REASON=simple-layout-render-failed
else
    SIMPLE_EXPECTED_STATUS=pass
    SIMPLE_EXPECTED_REASON=pass
fi

if [ "$simple_code" -ne 0 ]; then
    emit_unavailable "$SIMPLE_EXPECTED_REASON"
    exit 1
fi

simple_status="$(field_of simple_status "$SIMPLE_OUT")"
simple_checksum="$(field_of checksum "$SIMPLE_OUT")"
simple_weighted="$(field_of weighted_checksum "$SIMPLE_OUT")"
simple_blur="$(field_of blur_or_tolerance_used "$SIMPLE_OUT")"

if [ "$simple_status" != "pass" ]; then
    emit_unavailable "simple-layout-status-failed"
    exit 1
fi
if [ ! -s "$HTML_PATH" ]; then
    emit_unavailable "missing-scene-html-file"
    exit 1
fi
if [ ! -s "$EXPECTED_ARGB" ]; then
    emit_unavailable "missing-expected-argb-file"
    exit 1
fi
if [ "$simple_blur" != "false" ]; then
    emit_unavailable "simple-blur-or-tolerance-not-allowed"
    exit 1
fi

ELECTRON_CAPTURE_HTML_PATH="$HTML_PATH"
if [ "$CAPTURE_MODE" = "canvas" ]; then
    ELECTRON_CAPTURE_HTML_PATH=""
elif [ "$CAPTURE_MODE" = "auto" ] && [ "$SCENE" = "simple-web-layout-text-flow" ]; then
    ELECTRON_CAPTURE_HTML_PATH=""
elif [ "$CAPTURE_MODE" != "auto" ] && [ "$CAPTURE_MODE" != "dom" ]; then
    emit_unavailable "invalid-capture-mode:$CAPTURE_MODE"
    exit 1
fi

set +e
if have xvfb-run; then
    ELECTRON_BITMAP_SCENE="$SCENE" ELECTRON_BITMAP_WIDTH="$WIDTH" ELECTRON_BITMAP_HEIGHT="$HEIGHT" ELECTRON_BITMAP_ITERATIONS="$ITERATIONS" ELECTRON_BITMAP_EXPECTED_CHECKSUM="$simple_checksum" ELECTRON_BITMAP_EXPECTED_WEIGHTED_CHECKSUM="$simple_weighted" ELECTRON_BITMAP_EXPECTED_ARGB_PATH="$EXPECTED_ARGB" ELECTRON_BITMAP_HTML_PATH="$ELECTRON_CAPTURE_HTML_PATH" ELECTRON_BITMAP_PROOF_PATH="$ELECTRON_PROOF" ELECTRON_BITMAP_CAPTURED_ARGB_PATH="$CAPTURED_ARGB" ELECTRON_BITMAP_GEOMETRY_PATH="$ELECTRON_GEOMETRY" SIMPLE_ELECTRON_LIVE_BITMAP=1 \
        xvfb-run -a --server-args="-screen 0 1280x720x24" \
        "$ELECTRON_BIN" --disable-gpu --disable-gpu-compositing --disable-software-rasterizer=false --force-device-scale-factor=1 --high-dpi-support=1 --force-color-profile=srgb --no-sandbox tools/electron-shell >"$ELECTRON_OUT" 2>&1 &
else
    ELECTRON_BITMAP_SCENE="$SCENE" ELECTRON_BITMAP_WIDTH="$WIDTH" ELECTRON_BITMAP_HEIGHT="$HEIGHT" ELECTRON_BITMAP_ITERATIONS="$ITERATIONS" ELECTRON_BITMAP_EXPECTED_CHECKSUM="$simple_checksum" ELECTRON_BITMAP_EXPECTED_WEIGHTED_CHECKSUM="$simple_weighted" ELECTRON_BITMAP_EXPECTED_ARGB_PATH="$EXPECTED_ARGB" ELECTRON_BITMAP_HTML_PATH="$ELECTRON_CAPTURE_HTML_PATH" ELECTRON_BITMAP_PROOF_PATH="$ELECTRON_PROOF" ELECTRON_BITMAP_CAPTURED_ARGB_PATH="$CAPTURED_ARGB" ELECTRON_BITMAP_GEOMETRY_PATH="$ELECTRON_GEOMETRY" SIMPLE_ELECTRON_LIVE_BITMAP=1 \
        "$ELECTRON_BIN" --disable-gpu --disable-gpu-compositing --disable-software-rasterizer=false --force-device-scale-factor=1 --high-dpi-support=1 --force-color-profile=srgb --no-sandbox tools/electron-shell >"$ELECTRON_OUT" 2>&1 &
fi
electron_pid=$!
elapsed=0
electron_code=0
while kill -0 "$electron_pid" >/dev/null 2>&1; do
    if [ "$elapsed" -ge "$TIMEOUT_SECS" ]; then
        kill "$electron_pid" >/dev/null 2>&1 || true
        sleep 1
        kill -9 "$electron_pid" >/dev/null 2>&1 || true
        wait "$electron_pid" >/dev/null 2>&1 || true
        electron_code=124
        break
    fi
    sleep 1
    elapsed=$((elapsed + 1))
done
if [ "$electron_code" -eq 0 ]; then
    wait "$electron_pid"
    electron_code=$?
fi
set -e

if [ -f "$ELECTRON_PROOF" ]; then
    set +e
    node "$VALIDATOR" "$ELECTRON_PROOF" >"$VALIDATED_ENV"
    validation_code=$?
    set -e
else
    validation_code=1
    {
        echo "electron_simple_web_layout_validation_status=fail"
        echo "electron_simple_web_layout_validation_reason=missing-electron-proof"
        echo "electron_simple_web_layout_renderer="
        echo "electron_simple_web_layout_proof_source="
        echo "electron_simple_web_layout_proof_source_file_status="
        echo "electron_simple_web_layout_proof_source_size_bytes="
        echo "electron_simple_web_layout_proof_source_actual_size_bytes="
        echo "electron_simple_web_layout_proof_source_file_reason="
        echo "electron_simple_web_layout_proof_source_artifact_status=fail"
        echo "electron_simple_web_layout_proof_symlink_status=missing"
        echo "electron_simple_web_layout_proof_hardlink_status=missing"
        echo "electron_simple_web_layout_scene="
        echo "electron_simple_web_layout_capture_backend="
        echo "electron_simple_web_layout_compositor_mode="
        echo "electron_simple_web_layout_browser_engine="
        echo "electron_simple_web_layout_electron_user_agent="
        echo "electron_simple_web_layout_electron_process_version="
        echo "electron_simple_web_layout_chrome_process_version="
        echo "electron_simple_web_layout_gpu_compositing="
        echo "electron_simple_web_layout_gpu_rasterization="
        echo "electron_simple_web_layout_simple_checksum=$simple_checksum"
        echo "electron_simple_web_layout_electron_checksum="
        echo "electron_simple_web_layout_simple_weighted_checksum=$simple_weighted"
        echo "electron_simple_web_layout_electron_weighted_checksum="
        echo "electron_simple_web_layout_mismatch_count="
        echo "electron_simple_web_layout_blur_or_tolerance_used="
        echo "electron_simple_web_layout_proof_iterations="
        echo "electron_simple_web_layout_electron_frame_us="
        echo "electron_simple_web_layout_estimated_fps_floor="
        echo "electron_simple_web_layout_requested_width="
        echo "electron_simple_web_layout_requested_height="
        echo "electron_simple_web_layout_capture_native_width="
        echo "electron_simple_web_layout_capture_native_height="
        echo "electron_simple_web_layout_capture_downsampled="
        echo "electron_simple_web_layout_geometry_path=$ELECTRON_GEOMETRY"
        echo "electron_simple_web_layout_geometry_written=false"
        echo "electron_simple_web_layout_geometry_file_status=fail"
        echo "electron_simple_web_layout_geometry_file_reason=not-run"
        echo "electron_simple_web_layout_geometry_artifact_status=fail"
        echo "electron_simple_web_layout_geometry_symlink_status=missing"
        echo "electron_simple_web_layout_geometry_hardlink_status=missing"
        echo "electron_simple_web_layout_geometry_size_bytes="
        echo "electron_simple_web_layout_geometry_producer="
        echo "electron_simple_web_layout_geometry_viewport_width="
        echo "electron_simple_web_layout_geometry_viewport_height="
        echo "electron_simple_web_layout_geometry_item_count=0"
        echo "electron_simple_web_layout_geometry_measured_item_count=0"
        echo "electron_simple_web_layout_captured_argb_path=$CAPTURED_ARGB"
        echo "electron_simple_web_layout_captured_argb_written=false"
        echo "electron_simple_web_layout_captured_argb_file_status=fail"
        echo "electron_simple_web_layout_captured_argb_file_reason=not-run"
        echo "electron_simple_web_layout_captured_argb_artifact_status=fail"
        echo "electron_simple_web_layout_captured_argb_symlink_status=missing"
        echo "electron_simple_web_layout_captured_argb_hardlink_status=missing"
        echo "electron_simple_web_layout_captured_argb_size_bytes="
        echo "electron_simple_web_layout_captured_argb_format="
        echo "electron_simple_web_layout_captured_argb_producer="
        echo "electron_simple_web_layout_captured_argb_width="
        echo "electron_simple_web_layout_captured_argb_height="
        echo "electron_simple_web_layout_captured_argb_pixel_count=0"
        echo "electron_simple_web_layout_captured_argb_nonzero_pixel_count=0"
        echo "electron_simple_web_layout_captured_argb_checksum="
        echo "electron_simple_web_layout_captured_argb_weighted_checksum="
    } >"$VALIDATED_ENV"
fi
cat "$VALIDATED_ENV"

validation_status="$(field_of_env electron_simple_web_layout_validation_status "$VALIDATED_ENV")"
validation_reason="$(field_of_env electron_simple_web_layout_validation_reason "$VALIDATED_ENV")"
proof_symlink_status="$(field_of_env electron_simple_web_layout_proof_symlink_status "$VALIDATED_ENV")"
proof_hardlink_status="$(field_of_env electron_simple_web_layout_proof_hardlink_status "$VALIDATED_ENV")"
proof_renderer="$(field_of_env electron_simple_web_layout_renderer "$VALIDATED_ENV")"
proof_source="$(field_of_env electron_simple_web_layout_proof_source "$VALIDATED_ENV")"
proof_source_file_status="$(field_of_env electron_simple_web_layout_proof_source_file_status "$VALIDATED_ENV")"
proof_source_size_bytes="$(field_of_env electron_simple_web_layout_proof_source_size_bytes "$VALIDATED_ENV")"
proof_source_actual_size_bytes="$(field_of_env electron_simple_web_layout_proof_source_actual_size_bytes "$VALIDATED_ENV")"
proof_source_file_reason="$(field_of_env electron_simple_web_layout_proof_source_file_reason "$VALIDATED_ENV")"
proof_source_artifact_status="$(field_of_env electron_simple_web_layout_proof_source_artifact_status "$VALIDATED_ENV")"
proof_scene="$(field_of_env electron_simple_web_layout_scene "$VALIDATED_ENV")"
capture_backend="$(field_of_env electron_simple_web_layout_capture_backend "$VALIDATED_ENV")"
compositor_mode="$(field_of_env electron_simple_web_layout_compositor_mode "$VALIDATED_ENV")"
browser_engine="$(field_of_env electron_simple_web_layout_browser_engine "$VALIDATED_ENV")"
electron_user_agent="$(field_of_env electron_simple_web_layout_electron_user_agent "$VALIDATED_ENV")"
electron_process_version="$(field_of_env electron_simple_web_layout_electron_process_version "$VALIDATED_ENV")"
chrome_process_version="$(field_of_env electron_simple_web_layout_chrome_process_version "$VALIDATED_ENV")"
gpu_compositing="$(field_of_env electron_simple_web_layout_gpu_compositing "$VALIDATED_ENV")"
gpu_rasterization="$(field_of_env electron_simple_web_layout_gpu_rasterization "$VALIDATED_ENV")"
electron_checksum="$(field_of_env electron_simple_web_layout_electron_checksum "$VALIDATED_ENV")"
electron_weighted="$(field_of_env electron_simple_web_layout_electron_weighted_checksum "$VALIDATED_ENV")"
mismatch_count="$(field_of_env electron_simple_web_layout_mismatch_count "$VALIDATED_ENV")"
proof_iterations="$(field_of_env electron_simple_web_layout_proof_iterations "$VALIDATED_ENV")"
electron_frame_us="$(field_of_env electron_simple_web_layout_electron_frame_us "$VALIDATED_ENV")"
estimated_fps_floor="$(field_of_env electron_simple_web_layout_estimated_fps_floor "$VALIDATED_ENV")"
requested_width="$(field_of_env electron_simple_web_layout_requested_width "$VALIDATED_ENV")"
requested_height="$(field_of_env electron_simple_web_layout_requested_height "$VALIDATED_ENV")"
capture_native_width="$(field_of_env electron_simple_web_layout_capture_native_width "$VALIDATED_ENV")"
capture_native_height="$(field_of_env electron_simple_web_layout_capture_native_height "$VALIDATED_ENV")"
capture_downsampled="$(field_of_env electron_simple_web_layout_capture_downsampled "$VALIDATED_ENV")"
geometry_path="$(field_of_env electron_simple_web_layout_geometry_path "$VALIDATED_ENV")"
geometry_written="$(field_of_env electron_simple_web_layout_geometry_written "$VALIDATED_ENV")"
geometry_file_status="$(field_of_env electron_simple_web_layout_geometry_file_status "$VALIDATED_ENV")"
geometry_file_reason="$(field_of_env electron_simple_web_layout_geometry_file_reason "$VALIDATED_ENV")"
geometry_artifact_status="$(field_of_env electron_simple_web_layout_geometry_artifact_status "$VALIDATED_ENV")"
geometry_symlink_status="$(field_of_env electron_simple_web_layout_geometry_symlink_status "$VALIDATED_ENV")"
geometry_hardlink_status="$(field_of_env electron_simple_web_layout_geometry_hardlink_status "$VALIDATED_ENV")"
geometry_size_bytes="$(field_of_env electron_simple_web_layout_geometry_size_bytes "$VALIDATED_ENV")"
geometry_producer="$(field_of_env electron_simple_web_layout_geometry_producer "$VALIDATED_ENV")"
geometry_viewport_width="$(field_of_env electron_simple_web_layout_geometry_viewport_width "$VALIDATED_ENV")"
geometry_viewport_height="$(field_of_env electron_simple_web_layout_geometry_viewport_height "$VALIDATED_ENV")"
geometry_item_count="$(field_of_env electron_simple_web_layout_geometry_item_count "$VALIDATED_ENV")"
geometry_measured_item_count="$(field_of_env electron_simple_web_layout_geometry_measured_item_count "$VALIDATED_ENV")"
captured_argb_path="$(field_of_env electron_simple_web_layout_captured_argb_path "$VALIDATED_ENV")"
captured_argb_written="$(field_of_env electron_simple_web_layout_captured_argb_written "$VALIDATED_ENV")"
captured_argb_file_status="$(field_of_env electron_simple_web_layout_captured_argb_file_status "$VALIDATED_ENV")"
captured_argb_file_reason="$(field_of_env electron_simple_web_layout_captured_argb_file_reason "$VALIDATED_ENV")"
captured_argb_artifact_status="$(field_of_env electron_simple_web_layout_captured_argb_artifact_status "$VALIDATED_ENV")"
captured_argb_symlink_status="$(field_of_env electron_simple_web_layout_captured_argb_symlink_status "$VALIDATED_ENV")"
captured_argb_hardlink_status="$(field_of_env electron_simple_web_layout_captured_argb_hardlink_status "$VALIDATED_ENV")"
captured_argb_size_bytes="$(field_of_env electron_simple_web_layout_captured_argb_size_bytes "$VALIDATED_ENV")"
captured_argb_format="$(field_of_env electron_simple_web_layout_captured_argb_format "$VALIDATED_ENV")"
captured_argb_producer="$(field_of_env electron_simple_web_layout_captured_argb_producer "$VALIDATED_ENV")"
captured_argb_width="$(field_of_env electron_simple_web_layout_captured_argb_width "$VALIDATED_ENV")"
captured_argb_height="$(field_of_env electron_simple_web_layout_captured_argb_height "$VALIDATED_ENV")"
captured_argb_pixel_count="$(field_of_env electron_simple_web_layout_captured_argb_pixel_count "$VALIDATED_ENV")"
captured_argb_nonzero_pixel_count="$(field_of_env electron_simple_web_layout_captured_argb_nonzero_pixel_count "$VALIDATED_ENV")"
captured_argb_checksum="$(field_of_env electron_simple_web_layout_captured_argb_checksum "$VALIDATED_ENV")"
captured_argb_weighted_checksum="$(field_of_env electron_simple_web_layout_captured_argb_weighted_checksum "$VALIDATED_ENV")"
blur_used="$(field_of_env electron_simple_web_layout_blur_or_tolerance_used "$VALIDATED_ENV")"

RESIDUAL_ENV="$BUILD_DIR/residual.env"
if [ -s "$EXPECTED_ARGB" ] && [ -s "$CAPTURED_ARGB" ]; then
    node - "$EXPECTED_ARGB" "$CAPTURED_ARGB" "$SCENE" >"$RESIDUAL_ENV" <<'NODE'
const fs = require("fs");
const simple = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const electron = JSON.parse(fs.readFileSync(process.argv[3], "utf8"));
const scene = String(process.argv[4] || "");
const sp = Array.isArray(simple.pixels) ? simple.pixels : [];
const ep = Array.isArray(electron.pixels) ? electron.pixels : [];
const surface = scene === "simple-web-layout-text-raster-track"
  ? new Set([0xffffffff, 0xfff8fafc, 0xff334155])
  : scene === "simple-web-layout-line-height-text-track"
  ? new Set([0xffffffff, 0xfff8fafc, 0xffe5e7eb, 0xffdbeafe, 0xfff59e0b])
  : scene === "simple-web-layout-text-style-flow-track"
  ? new Set([0xffffffff, 0xfff8fafc, 0xffe5e7eb, 0xffdbeafe, 0xfff59e0b])
  : scene === "simple-web-layout-overflow-axis-matrix"
  ? new Set([0xffffffff, 0xfff8fafc, 0xffe5e7eb, 0xffdbeafe, 0xfffef3c7, 0xff334155, 0xff1d4ed8, 0xff22c55e, 0xfff59e0b, 0xffef4444])
  : new Set([
      0xffffffff, 0xfff8fafc, 0xff334155, 0xffdbeafe, 0xffe5e7eb,
      0xff0f172a, 0xff1d4ed8, 0xff22c55e, 0xfff59e0b, 0xffef4444,
      0xff7c2d12, 0xff14532d
    ]);
let chromeExtraTextPixels = 0;
let simpleExtraTextPixels = 0;
let textColorDeltaPixels = 0;
let surfaceGeometryPixels = 0;
let samePixels = 0;
const n = Math.min(sp.length, ep.length);
for (let i = 0; i < n; i += 1) {
  const sv = Number(sp[i]) >>> 0;
  const ev = Number(ep[i]) >>> 0;
  if (sv === ev) {
    samePixels += 1;
    continue;
  }
  const simpleSurface = surface.has(sv);
  const electronSurface = surface.has(ev);
  if (simpleSurface && !electronSurface) chromeExtraTextPixels += 1;
  else if (!simpleSurface && electronSurface) simpleExtraTextPixels += 1;
  else if (!simpleSurface && !electronSurface) textColorDeltaPixels += 1;
  else surfaceGeometryPixels += 1;
}
surfaceGeometryPixels += Math.abs(sp.length - ep.length);
console.log(`electron_simple_web_layout_same_pixels=${samePixels}`);
console.log(`electron_simple_web_layout_chrome_extra_text_pixels=${chromeExtraTextPixels}`);
console.log(`electron_simple_web_layout_simple_extra_text_pixels=${simpleExtraTextPixels}`);
console.log(`electron_simple_web_layout_text_color_delta_pixels=${textColorDeltaPixels}`);
console.log(`electron_simple_web_layout_surface_geometry_pixels=${surfaceGeometryPixels}`);
NODE
else
    {
        echo "electron_simple_web_layout_same_pixels="
        echo "electron_simple_web_layout_chrome_extra_text_pixels="
        echo "electron_simple_web_layout_simple_extra_text_pixels="
        echo "electron_simple_web_layout_text_color_delta_pixels="
        echo "electron_simple_web_layout_surface_geometry_pixels="
    } >"$RESIDUAL_ENV"
fi
same_pixels="$(field_of electron_simple_web_layout_same_pixels "$RESIDUAL_ENV")"
chrome_extra_text_pixels="$(field_of electron_simple_web_layout_chrome_extra_text_pixels "$RESIDUAL_ENV")"
simple_extra_text_pixels="$(field_of electron_simple_web_layout_simple_extra_text_pixels "$RESIDUAL_ENV")"
text_color_delta_pixels="$(field_of electron_simple_web_layout_text_color_delta_pixels "$RESIDUAL_ENV")"
surface_geometry_pixels="$(field_of electron_simple_web_layout_surface_geometry_pixels "$RESIDUAL_ENV")"

mismatch_class=
if [ "${mismatch_count:-}" != "" ] && [ "${mismatch_count:-0}" != "0" ]; then
    text_delta_total=$(( ${chrome_extra_text_pixels:-0} + ${simple_extra_text_pixels:-0} + ${text_color_delta_pixels:-0} ))
    if [ "${surface_geometry_pixels:-0}" = "0" ] && [ "$text_delta_total" -gt 0 ]; then
        case "$SCENE" in
            simple-web-layout-text-raster-track|simple-web-layout-line-height-text-track|simple-web-layout-text-style-flow-track)
                mismatch_class=text-raster-mismatch
                ;;
            *)
                mismatch_class=paint-color-mismatch
                ;;
        esac
    elif [ "${surface_geometry_pixels:-0}" != "0" ]; then
        mismatch_class=surface-geometry-mismatch
    else
        mismatch_class=unknown-pixel-mismatch
    fi
fi

status=pass
reason=pass
if [ "$electron_code" -ne 0 ] && [ ! -f "$ELECTRON_PROOF" ]; then
    status=fail
    reason=electron-live-capture-failed
elif [ "$validation_code" -ne 0 ] || [ "$validation_status" != "pass" ]; then
    case "$validation_reason" in
        checksum-mismatch|weighted-checksum-mismatch|pixel-mismatch|captured-argb-checksum-mismatch|captured-argb-weighted-checksum-mismatch)
            status=divergent
            ;;
        *)
            status=fail
            ;;
    esac
    reason="${validation_reason:-electron-proof-validation-failed}"
    if [ "$status" = "divergent" ] && [ "$mismatch_class" != "" ]; then
        reason="$mismatch_class"
    fi
elif [ "$proof_symlink_status" != "pass" ]; then
    status=fail
    reason=proof-json-symlink-status-not-pass
elif [ "$proof_hardlink_status" != "pass" ]; then
    status=fail
    reason=proof-json-hardlink-status-not-pass
elif [ "$proof_source_file_status" != "pass" ] || [ "$proof_source_artifact_status" != "pass" ] || ! num_at_least "$proof_source_size_bytes" 1; then
    status=fail
    reason=proof-source-file-status-not-pass
elif ! num_at_least "$proof_source_actual_size_bytes" 1 || [ "$proof_source_actual_size_bytes" != "$proof_source_size_bytes" ]; then
    status=fail
    reason=proof-source-size-mismatch
elif [ "$geometry_symlink_status" != "pass" ]; then
    status=fail
    reason=electron-geometry-symlink-status-not-pass
elif [ "$geometry_hardlink_status" != "pass" ]; then
    status=fail
    reason=electron-geometry-hardlink-status-not-pass
elif [ "$geometry_artifact_status" != "pass" ]; then
    status=fail
    reason=electron-geometry-artifact-status-not-pass
elif [ "$captured_argb_symlink_status" != "pass" ]; then
    status=fail
    reason=captured-argb-symlink-status-not-pass
elif [ "$captured_argb_hardlink_status" != "pass" ]; then
    status=fail
    reason=captured-argb-hardlink-status-not-pass
elif [ "$captured_argb_artifact_status" != "pass" ]; then
    status=fail
    reason=captured-argb-artifact-status-not-pass
elif [ ! -s "$CAPTURED_ARGB" ]; then
    status=fail
    reason=missing-captured-argb-file
elif [ "$electron_code" -ne 0 ]; then
    reason=pass-with-electron-teardown-warning
fi

{
    echo "electron_simple_web_layout_status=$status"
    echo "electron_simple_web_layout_reason=$reason"
    echo "electron_simple_web_layout_scene=$SCENE"
    echo "electron_simple_web_layout_proof_renderer=${proof_renderer:-}"
    echo "electron_simple_web_layout_proof_source=${proof_source:-}"
    echo "electron_simple_web_layout_proof_source_file_status=${proof_source_file_status:-}"
    echo "electron_simple_web_layout_proof_source_size_bytes=${proof_source_size_bytes:-}"
    echo "electron_simple_web_layout_proof_source_actual_size_bytes=${proof_source_actual_size_bytes:-}"
    echo "electron_simple_web_layout_proof_source_file_reason=${proof_source_file_reason:-}"
    echo "electron_simple_web_layout_proof_source_artifact_status=${proof_source_artifact_status:-}"
    echo "electron_simple_web_layout_proof_scene=${proof_scene:-}"
    echo "electron_simple_web_layout_capture_backend=${capture_backend:-}"
    echo "electron_simple_web_layout_compositor_mode=${compositor_mode:-}"
    echo "electron_simple_web_layout_browser_engine=${browser_engine:-}"
    echo "electron_simple_web_layout_electron_user_agent=${electron_user_agent:-}"
    echo "electron_simple_web_layout_electron_process_version=${electron_process_version:-}"
    echo "electron_simple_web_layout_chrome_process_version=${chrome_process_version:-}"
    echo "electron_simple_web_layout_gpu_compositing=${gpu_compositing:-}"
    echo "electron_simple_web_layout_gpu_rasterization=${gpu_rasterization:-}"
    echo "electron_simple_web_layout_simple_bin=$SIMPLE_BIN"
    echo "electron_simple_web_layout_simple_bin_source=$SIMPLE_BIN_SOURCE"
    echo "electron_simple_web_layout_simple_bin_status=$SIMPLE_BIN_STATUS"
    echo "electron_simple_web_layout_capture_mode=$CAPTURE_MODE"
    echo "electron_simple_web_layout_dom_html_path=${ELECTRON_CAPTURE_HTML_PATH:-}"
    echo "electron_simple_web_layout_width=$WIDTH"
    echo "electron_simple_web_layout_height=$HEIGHT"
    echo "electron_simple_web_layout_iterations=$ITERATIONS"
    echo "electron_simple_web_layout_simple_expected_status=$SIMPLE_EXPECTED_STATUS"
    echo "electron_simple_web_layout_simple_expected_reason=$SIMPLE_EXPECTED_REASON"
    echo "electron_simple_web_layout_simple_expected_timeout_secs=$SIMPLE_EXPECTED_TIMEOUT_SECS"
    echo "electron_simple_web_layout_simple_expected_timed_out=$SIMPLE_EXPECTED_TIMED_OUT"
    echo "electron_simple_web_layout_simple_expected_exit_code=$SIMPLE_EXPECTED_EXIT_CODE"
    echo "electron_simple_web_layout_validation_status=${validation_status:-}"
    echo "electron_simple_web_layout_validation_reason=${validation_reason:-}"
    echo "electron_simple_web_layout_proof_symlink_status=${proof_symlink_status:-}"
    echo "electron_simple_web_layout_proof_hardlink_status=${proof_hardlink_status:-}"
    echo "electron_simple_web_layout_simple_checksum=$simple_checksum"
    echo "electron_simple_web_layout_electron_checksum=${electron_checksum:-0}"
    echo "electron_simple_web_layout_simple_weighted_checksum=$simple_weighted"
    echo "electron_simple_web_layout_electron_weighted_checksum=${electron_weighted:-0}"
    echo "electron_simple_web_layout_mismatch_count=${mismatch_count:-}"
    echo "electron_simple_web_layout_same_pixels=${same_pixels:-}"
    echo "electron_simple_web_layout_chrome_extra_text_pixels=${chrome_extra_text_pixels:-}"
    echo "electron_simple_web_layout_simple_extra_text_pixels=${simple_extra_text_pixels:-}"
    echo "electron_simple_web_layout_text_color_delta_pixels=${text_color_delta_pixels:-}"
    echo "electron_simple_web_layout_surface_geometry_pixels=${surface_geometry_pixels:-}"
    echo "electron_simple_web_layout_mismatch_class=${mismatch_class:-}"
    echo "electron_simple_web_layout_blur_or_tolerance_used=${blur_used:-}"
    echo "electron_simple_web_layout_proof_iterations=${proof_iterations:-}"
    echo "electron_simple_web_layout_electron_frame_us=${electron_frame_us:-0}"
    echo "electron_simple_web_layout_estimated_fps_floor=${estimated_fps_floor:-}"
    echo "electron_simple_web_layout_requested_width=${requested_width:-}"
    echo "electron_simple_web_layout_requested_height=${requested_height:-}"
    echo "electron_simple_web_layout_capture_native_width=${capture_native_width:-}"
    echo "electron_simple_web_layout_capture_native_height=${capture_native_height:-}"
    echo "electron_simple_web_layout_capture_downsampled=${capture_downsampled:-}"
    echo "electron_simple_web_layout_geometry_path=${geometry_path:-$ELECTRON_GEOMETRY}"
    echo "electron_simple_web_layout_geometry_written=${geometry_written:-}"
    echo "electron_simple_web_layout_geometry_file_status=${geometry_file_status:-}"
    echo "electron_simple_web_layout_geometry_file_reason=${geometry_file_reason:-}"
    echo "electron_simple_web_layout_geometry_artifact_status=${geometry_artifact_status:-}"
    echo "electron_simple_web_layout_geometry_symlink_status=${geometry_symlink_status:-}"
    echo "electron_simple_web_layout_geometry_hardlink_status=${geometry_hardlink_status:-}"
    echo "electron_simple_web_layout_geometry_size_bytes=${geometry_size_bytes:-}"
    echo "electron_simple_web_layout_geometry_producer=${geometry_producer:-}"
    echo "electron_simple_web_layout_geometry_viewport_width=${geometry_viewport_width:-}"
    echo "electron_simple_web_layout_geometry_viewport_height=${geometry_viewport_height:-}"
    echo "electron_simple_web_layout_geometry_item_count=${geometry_item_count:-}"
    echo "electron_simple_web_layout_geometry_measured_item_count=${geometry_measured_item_count:-}"
    echo "electron_simple_web_layout_html_path=$HTML_PATH"
    echo "electron_simple_web_layout_expected_argb_path=$EXPECTED_ARGB"
    echo "electron_simple_web_layout_captured_argb_path=${captured_argb_path:-$CAPTURED_ARGB}"
    echo "electron_simple_web_layout_captured_argb_written=${captured_argb_written:-}"
    echo "electron_simple_web_layout_captured_argb_file_status=${captured_argb_file_status:-}"
    echo "electron_simple_web_layout_captured_argb_file_reason=${captured_argb_file_reason:-}"
    echo "electron_simple_web_layout_captured_argb_artifact_status=${captured_argb_artifact_status:-}"
    echo "electron_simple_web_layout_captured_argb_symlink_status=${captured_argb_symlink_status:-}"
    echo "electron_simple_web_layout_captured_argb_hardlink_status=${captured_argb_hardlink_status:-}"
    echo "electron_simple_web_layout_captured_argb_size_bytes=${captured_argb_size_bytes:-}"
    echo "electron_simple_web_layout_captured_argb_format=${captured_argb_format:-}"
    echo "electron_simple_web_layout_captured_argb_producer=${captured_argb_producer:-}"
    echo "electron_simple_web_layout_captured_argb_width=${captured_argb_width:-}"
    echo "electron_simple_web_layout_captured_argb_height=${captured_argb_height:-}"
    echo "electron_simple_web_layout_captured_argb_pixel_count=${captured_argb_pixel_count:-}"
    echo "electron_simple_web_layout_captured_argb_nonzero_pixel_count=${captured_argb_nonzero_pixel_count:-}"
    echo "electron_simple_web_layout_captured_argb_checksum=${captured_argb_checksum:-}"
    echo "electron_simple_web_layout_captured_argb_weighted_checksum=${captured_argb_weighted_checksum:-}"
    echo "electron_simple_web_layout_exit_code=$electron_code"
} >"$BUILD_DIR/evidence.env"

{
    echo "# Electron Simple Web Layout Bitmap Evidence"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- scene: $SCENE"
    echo "- proof renderer: ${proof_renderer:-}"
    echo "- proof source: ${proof_source:-}"
    echo "- proof source artifact: ${proof_source_file_status:-} / ${proof_source_file_reason:-} / ${proof_source_artifact_status:-}"
    echo "- proof source size bytes: ${proof_source_size_bytes:-}"
    echo "- proof source actual size bytes: ${proof_source_actual_size_bytes:-}"
    echo "- proof symlink status: ${proof_symlink_status:-}"
    echo "- proof hardlink status: ${proof_hardlink_status:-}"
    echo "- proof scene: ${proof_scene:-}"
    echo "- capture backend: ${capture_backend:-}"
    echo "- compositor mode: ${compositor_mode:-}"
    echo "- browser engine: ${browser_engine:-}"
    echo "- Electron user agent: ${electron_user_agent:-}"
    echo "- Electron process version: ${electron_process_version:-}"
    echo "- Chrome process version: ${chrome_process_version:-}"
    echo "- GPU compositing: ${gpu_compositing:-}"
    echo "- GPU rasterization: ${gpu_rasterization:-}"
    echo "- capture mode: $CAPTURE_MODE"
    echo "- DOM HTML path: ${ELECTRON_CAPTURE_HTML_PATH:-}"
    echo "- dimensions: ${WIDTH}x${HEIGHT}"
    echo "- Simple expected status: $SIMPLE_EXPECTED_STATUS ($SIMPLE_EXPECTED_REASON; timeout ${SIMPLE_EXPECTED_TIMEOUT_SECS}s; timed out: $SIMPLE_EXPECTED_TIMED_OUT; exit: $SIMPLE_EXPECTED_EXIT_CODE)"
    echo "- Simple checksum: $simple_checksum"
    echo "- Electron checksum: ${electron_checksum:-0}"
    echo "- Simple weighted checksum: $simple_weighted"
    echo "- Electron weighted checksum: ${electron_weighted:-0}"
    echo "- mismatch count: ${mismatch_count:-}"
    echo "- same pixels: ${same_pixels:-}"
    echo "- Chrome extra text pixels: ${chrome_extra_text_pixels:-}"
    echo "- Simple extra text pixels: ${simple_extra_text_pixels:-}"
    echo "- text color delta pixels: ${text_color_delta_pixels:-}"
    echo "- surface geometry pixels: ${surface_geometry_pixels:-}"
    echo "- mismatch class: ${mismatch_class:-}"
    echo "- blur/tolerance used: ${blur_used:-}"
    echo "- proof iterations: ${proof_iterations:-}"
    echo "- Electron frame us: ${electron_frame_us:-0}"
    echo "- estimated FPS floor: ${estimated_fps_floor:-}"
    echo "- Electron geometry path: ${geometry_path:-$ELECTRON_GEOMETRY}"
    echo "- Electron geometry artifact: ${geometry_file_status:-} / ${geometry_file_reason:-} / ${geometry_artifact_status:-}"
    echo "- Electron geometry symlink status: ${geometry_symlink_status:-}"
    echo "- Electron geometry hardlink status: ${geometry_hardlink_status:-}"
    echo "- Electron geometry size bytes: ${geometry_size_bytes:-}"
    echo "- Electron geometry producer: ${geometry_producer:-}"
    echo "- Electron geometry viewport: ${geometry_viewport_width:-}x${geometry_viewport_height:-}"
    echo "- Electron geometry item count: ${geometry_item_count:-}"
    echo "- Electron geometry measured item count: ${geometry_measured_item_count:-}"
    echo "- HTML path: $HTML_PATH"
    echo "- expected ARGB path: $EXPECTED_ARGB"
    echo "- captured ARGB path: ${captured_argb_path:-$CAPTURED_ARGB}"
    echo "- captured ARGB written: ${captured_argb_written:-}"
    echo "- captured ARGB artifact: ${captured_argb_file_status:-} / ${captured_argb_file_reason:-} / ${captured_argb_artifact_status:-}"
    echo "- captured ARGB symlink status: ${captured_argb_symlink_status:-}"
    echo "- captured ARGB hardlink status: ${captured_argb_hardlink_status:-}"
    echo "- captured ARGB size bytes: ${captured_argb_size_bytes:-}"
    echo "- captured ARGB format: ${captured_argb_format:-}"
    echo "- captured ARGB producer: ${captured_argb_producer:-}"
    echo "- captured ARGB dimensions: ${captured_argb_width:-}x${captured_argb_height:-}"
    echo "- captured ARGB pixels: ${captured_argb_pixel_count:-} nonzero=${captured_argb_nonzero_pixel_count:-}"
    echo
    echo "## Raw Evidence"
    sed 's/^/- /' "$BUILD_DIR/evidence.env"
    echo
    echo "## Simple Output"
    sed 's/^/- /' "$SIMPLE_OUT"
    echo
    echo "## Electron Output"
    sed 's/^/- /' "$ELECTRON_OUT"
} >"$REPORT_PATH"

cat "$BUILD_DIR/evidence.env"
[ "$status" = "pass" ]
