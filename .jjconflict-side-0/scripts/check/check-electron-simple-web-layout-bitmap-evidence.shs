#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/electron_simple_web_layout_bitmap_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/electron_simple_web_layout_bitmap_evidence_$(date -u +%F).md}"
SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
SIMPLE_BIN_STATUS=pass

is_rust_seed_simple() {
    case "$1" in
        src/compiler_rust/*|*/src/compiler_rust/*) return 0 ;;
        *) return 1 ;;
    esac
}

if [ "${SIMPLE_BIN:-}" = "" ]; then
    SIMPLE_BIN_SOURCE="missing-self-hosted"
    for candidate in \
        "release"/*/simple \
        "bin/release"/*/simple \
        "build/bootstrap/stage3/simple" \
        "bin/simple" \
        "./bin/simple"
    do
        if [ -x "$candidate" ]; then
            SIMPLE_BIN="$candidate"
            SIMPLE_BIN_SOURCE="repo-self-hosted-fallback"
            break
        fi
    done
    if [ "${SIMPLE_BIN:-}" = "" ] && [ "${ALLOW_PATH_SIMPLE_BIN:-0}" = "1" ] && command -v simple >/dev/null 2>&1; then
        SIMPLE_BIN="$(command -v simple)"
        SIMPLE_BIN_SOURCE="path-opt-in"
    fi
else
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
fi
SIMPLE_BIN="${SIMPLE_BIN:-}"
if [ "$SIMPLE_BIN" = "" ]; then
    SIMPLE_BIN_STATUS=missing
elif is_rust_seed_simple "$SIMPLE_BIN"; then
    SIMPLE_BIN_STATUS=forbidden
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-rust-seed-forbidden"
elif [ ! -x "$SIMPLE_BIN" ]; then
    SIMPLE_BIN_STATUS=missing
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-missing"
fi
export SIMPLE_BIN SIMPLE_BIN_SOURCE SIMPLE_BIN_STATUS
WIDTH="${ELECTRON_BITMAP_WIDTH:-96}"
HEIGHT="${ELECTRON_BITMAP_HEIGHT:-64}"
ITERATIONS="${ELECTRON_BITMAP_ITERATIONS:-3}"
TIMEOUT_SECS="${ELECTRON_BITMAP_TIMEOUT_SECS:-60}"
SCENE="${ELECTRON_BITMAP_SCENE:-simple-web-layout-text-flow}"
CAPTURE_MODE="${ELECTRON_LAYOUT_CAPTURE_MODE:-auto}"
SIMPLE_SRC="$BUILD_DIR/simple_web_layout_expected.spl"
SIMPLE_OUT="$BUILD_DIR/simple.out"
HTML_PATH="$BUILD_DIR/scene.html"
EXPECTED_ARGB="$BUILD_DIR/expected-argb.json"
CAPTURED_ARGB="$BUILD_DIR/electron-argb.json"
ELECTRON_GEOMETRY="$BUILD_DIR/electron-geometry.json"
ELECTRON_OUT="$BUILD_DIR/electron.out"
ELECTRON_PROOF="$BUILD_DIR/electron-proof.json"
VALIDATED_ENV="$BUILD_DIR/electron-proof.validation.env"
VALIDATOR="scripts/check/validate-electron-simple-web-layout-proof.js"
SIMPLE_EXPECTED_TIMEOUT_SECS="$TIMEOUT_SECS"
SIMPLE_EXPECTED_EXIT_CODE=
SIMPLE_EXPECTED_TIMED_OUT=false
SIMPLE_EXPECTED_STATUS=not-run
SIMPLE_EXPECTED_REASON=not-run

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$SIMPLE_SRC" "$SIMPLE_OUT" "$HTML_PATH" "$EXPECTED_ARGB" "$CAPTURED_ARGB" "$ELECTRON_GEOMETRY" "$ELECTRON_OUT" "$ELECTRON_PROOF" "$VALIDATED_ENV" "$BUILD_DIR/evidence.env" "$REPORT_PATH"

have() {
    command -v "$1" >/dev/null 2>&1
}

field_of() {
    key="$1"
    file="$2"
    sed -n "s/^${key}=//p" "$file" | tail -n 1
}

field_of_env() {
    key="$1"
    file="$2"
    if [ -s "$file" ]; then
        sed -n "s/^${key}=//p" "$file" | tail -n 1
    fi
}

num_at_least() {
    value="$1"
    min="$2"
    case "$value" in
        ''|*[!0-9]*) return 1 ;;
    esac
    [ "$value" -ge "$min" ]
}

emit_unavailable() {
    reason="$1"
    {
        echo "electron_simple_web_layout_status=unavailable"
        echo "electron_simple_web_layout_reason=$reason"
        echo "electron_simple_web_layout_scene=$SCENE"
        echo "electron_simple_web_layout_simple_bin=$SIMPLE_BIN"
        echo "electron_simple_web_layout_simple_bin_source=$SIMPLE_BIN_SOURCE"
        echo "electron_simple_web_layout_simple_bin_status=$SIMPLE_BIN_STATUS"
        echo "electron_simple_web_layout_capture_mode=$CAPTURE_MODE"
        echo "electron_simple_web_layout_proof_source="
        echo "electron_simple_web_layout_proof_source_file_status="
        echo "electron_simple_web_layout_proof_source_size_bytes="
        echo "electron_simple_web_layout_proof_source_actual_size_bytes="
        echo "electron_simple_web_layout_proof_source_file_reason="
        echo "electron_simple_web_layout_proof_source_artifact_status=unavailable"
        echo "electron_simple_web_layout_proof_symlink_status="
        echo "electron_simple_web_layout_proof_hardlink_status="
        echo "electron_simple_web_layout_width=$WIDTH"
        echo "electron_simple_web_layout_height=$HEIGHT"
        echo "electron_simple_web_layout_iterations=$ITERATIONS"
        echo "electron_simple_web_layout_simple_expected_status=$SIMPLE_EXPECTED_STATUS"
        echo "electron_simple_web_layout_simple_expected_reason=$SIMPLE_EXPECTED_REASON"
        echo "electron_simple_web_layout_simple_expected_timeout_secs=$SIMPLE_EXPECTED_TIMEOUT_SECS"
        echo "electron_simple_web_layout_simple_expected_timed_out=$SIMPLE_EXPECTED_TIMED_OUT"
        echo "electron_simple_web_layout_simple_expected_exit_code=$SIMPLE_EXPECTED_EXIT_CODE"
        echo "electron_simple_web_layout_geometry_file_status=fail"
        echo "electron_simple_web_layout_geometry_file_reason=not-run"
        echo "electron_simple_web_layout_geometry_artifact_status=unavailable"
        echo "electron_simple_web_layout_geometry_symlink_status="
        echo "electron_simple_web_layout_geometry_hardlink_status="
        echo "electron_simple_web_layout_captured_argb_file_status=fail"
        echo "electron_simple_web_layout_captured_argb_file_reason=not-run"
        echo "electron_simple_web_layout_captured_argb_artifact_status=unavailable"
        echo "electron_simple_web_layout_captured_argb_symlink_status="
        echo "electron_simple_web_layout_captured_argb_hardlink_status="
    } >"$BUILD_DIR/evidence.env"
    {
        echo "# Electron Simple Web Layout Bitmap Evidence"
        echo
        echo "- status: unavailable"
        echo "- reason: $reason"
        echo "- proof source artifact:  /  / unavailable"
        echo "- Electron geometry artifact: fail / not-run / unavailable"
        echo "- captured ARGB artifact: fail / not-run / unavailable"
    } >"$REPORT_PATH"
    cat "$BUILD_DIR/evidence.env"
}

if [ "$SIMPLE_BIN_STATUS" != "pass" ]; then
    emit_unavailable "simple-bin-$SIMPLE_BIN_STATUS"
    exit 1
fi

for required in node npm; do
    if ! have "$required"; then
        emit_unavailable "missing-command:$required"
        exit 1
    fi
done

ELECTRON_BIN="${ELECTRON_BIN:-${SIMPLE_ELECTRON_BIN:-}}"
if [ -n "$ELECTRON_BIN" ] && [ ! -x "$ELECTRON_BIN" ]; then
    emit_unavailable "electron-bin-missing"
    exit 1
elif [ -x "tools/electron-shell/node_modules/electron/dist/Electron.app/Contents/MacOS/Electron" ]; then
    ELECTRON_BIN="tools/electron-shell/node_modules/electron/dist/Electron.app/Contents/MacOS/Electron"
elif [ -x "tools/electron-shell/node_modules/.bin/electron" ]; then
    ELECTRON_BIN="tools/electron-shell/node_modules/.bin/electron"
elif [ -x "tools/electron-shell/node_modules/electron/dist/electron" ]; then
    ELECTRON_BIN="tools/electron-shell/node_modules/electron/dist/electron"
fi

if [ ! -f "$VALIDATOR" ]; then
    emit_unavailable "missing-electron-proof-validator"
    exit 1
fi

if [ "$ELECTRON_BIN" = "" ]; then
    emit_unavailable "missing-electron-dependency"
    exit 1
fi

cat >"$SIMPLE_SRC" <<SIMPLE_EOF
use std.gc_async_mut.gpu.browser_engine.simple_web_renderer.{simple_web_render_html_to_pixels}
use std.nogc_sync_mut.sffi.io.{file_write_text}

val WIDTH: i32 = $WIDTH
val HEIGHT: i32 = $HEIGHT
val HTML_PATH: text = "$HTML_PATH"
val EXPECTED_ARGB_PATH: text = "$EXPECTED_ARGB"

fn checksum(pixels: [u32]) -> i64:
    var sum: i64 = 0
    var i = 0
    while i < pixels.len():
        sum = sum + pixels[i].to_i64()
        i = i + 1
    sum

fn weighted_checksum(pixels: [u32]) -> i64:
    var sum: i64 = 0
    var i = 0
    while i < pixels.len():
        sum = sum + (pixels[i].to_i64() * (i.to_i64() + 1))
        i = i + 1
    sum

fn write_expected_bitmap(pixels: [u32]) -> bool:
    var json = "{\"width\":" + WIDTH.to_text() + ",\"height\":" + HEIGHT.to_text() + ",\"format\":\"argb-u32\",\"producer\":\"simple_web_render_html_to_pixels\",\"pixels\":["
    var i = 0
    while i < pixels.len():
        if i > 0:
            json = json + ","
        json = json + pixels[i].to_i64().to_text()
        i = i + 1
    json = json + "]}"
    file_write_text(EXPECTED_ARGB_PATH, json)

fn main():
    var html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#ffffff;color:#141418}h1{font-size:34px;margin:10px 0;font-weight:bold}p{font-size:16px;margin:6px 0}</style></head><body><main><h1>GUI</h1><p>taskbar command</p></main></body></html>"
    if "$SCENE" == "simple-web-layout-css-box-matrix":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc}.shell{display:flex;gap:4px;background-color:#0f172a;padding:4px;width:88px;height:56px}.rail{background-color:#1d4ed8;width:12px;height:48px}.stack{display:flex;flex-direction:column;gap:3px;background-color:#e5e7eb;background-image:linear-gradient(#e5e7eb,#cbd5e1);background-blend-mode:multiply;background-size:20px 20px;background-repeat:no-repeat;background-position:4px 5px;background-attachment:fixed;padding:3px;padding-inline:3px 3px;padding-inline-start:3px;padding-inline-end:3px;padding-block:3px 3px;padding-block-start:3px;padding-block-end:3px;width:60px;height:42px;inline-size:60px;block-size:42px;min-inline-size:60px;max-inline-size:60px;min-block-size:42px;max-block-size:42px}.row{background-color:#22c55e;width:54px;height:10px}.row.alt{background-color:#f59e0b;width:36px;height:10px}.leaf{position:relative;inset:0 0 0 0;inset-block:0 0;inset-block-start:0;inset-block-end:0;inset-inline:0 0;inset-inline-start:0;inset-inline-end:0;background-color:#ef4444;width:18px;height:8px;margin-inline:6px 0;margin-inline-start:6px;margin-inline-end:0;margin-block:0 0;margin-block-start:0;margin-block-end:0}</style></head><body><section class='shell'><div class='rail'></div><div class='stack'><div class='row'></div><div class='row alt'></div><div class='leaf'></div></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-border-nested-matrix":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc}.shell{background-color:#dbeafe;border:2px solid #0f172a;border-style:solid;padding:4px;width:84px;height:52px}.shell>.direct{background-color:#22c55e;border:1px solid #14532d;width:24px;height:12px}.shell .nested .target{background-color:#f59e0b;border:2px solid #7c2d12;width:36px;height:10px;margin-left:6px}.shell>.nested{background-color:#e5e7eb;border:1px solid #334155;padding:3px;width:60px;height:24px;margin-top:4px}.outside .target{background-color:#ef4444;width:10px;height:10px}</style></head><body><section class='shell'><div class='direct'></div><div class='nested'><div class='target'></div></div></section><section class='outside'><div class='target'></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-text-raster-track":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#ffffff}.panel{background-color:#f8fafc;border:1px solid #334155;padding:4px;width:86px;height:54px}.title{color:#0f172a;font-size:16px;background-color:#f8fafc}.sub{color:#475569;font-size:8px;background-color:#f8fafc;margin-top:4px}</style></head><body><section class='panel'><div class='title'>TEXT RASTER</div><div class='sub'>Chrome AA baseline</div></section></body></html>"
    if "$SCENE" == "simple-web-layout-line-height-text-track":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc}.shell{background-color:#e5e7eb;background-clip:content-box;background-origin:content-box;background-image:linear-gradient(#e5e7eb,#cbd5e1);box-shadow:2px 2px #94a3b8;border-radius:4px;border-top-left-radius:6px;border-top-right-radius:3px;border-bottom-right-radius:5px;border-bottom-left-radius:2px;border-start-start-radius:6px;border-start-end-radius:3px;border-end-end-radius:5px;border-end-start-radius:2px;padding:4px;width:60px;height:56px}.copy{background-color:#dbeafe;color:#0f172a;font-family:system;font-size:8px;line-height:12px;width:22px}.copy::before{content:'>'}.after{background-color:#f59e0b;width:10px;height:6px;margin-top:2px}</style></head><body><section class='shell'><div class='copy'>ALPHA BETA GAMMA</div><div class='after'></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-text-style-flow-track":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc}.shell{background-color:#e5e7eb;padding:4px;width:88px;height:56px}.center{caption-side:top;list-style-position:outside;list-style-image:none;justify-items:stretch;justify-self:auto;color-scheme:dark;column-count:1;column-width:auto;columns:auto;column-rule:0 none transparent;column-rule-color:#000000;column-rule-style:none;column-rule-width:0;background-color:#ffffff;color:#0f172a;font:italic bold 8px/8px sans-serif;font-size:8px;font-size-adjust:0.5;font-palette:dark;font-feature-settings:'kern' 0;font-language-override:'TRK';font-variation-settings:'wght' 700;font-variant:small-caps tabular-nums;font-variant-alternates:historical-forms;font-variant-caps:small-caps;font-variant-east-asian:ruby;font-variant-emoji:emoji;font-variant-ligatures:no-common-ligatures;font-variant-numeric:tabular-nums;font-variant-position:super;font-style:italic;font-weight:bold;font-kerning:none;font-optical-sizing:none;font-stretch:expanded;font-width:expanded;font-synthesis:none;font-synthesis-small-caps:none;font-synthesis-position:none;font-synthesis-style:none;font-synthesis-weight:none;letter-spacing:1px;line-height:8px;hyphens:auto;line-break:strict;white-space:pre;text-overflow:ellipsis;overflow-wrap:anywhere;word-break:break-all;word-wrap:break-word;word-spacing:2px;caret-color:#06b6d4;cursor:pointer;resize:both;tab-size:4;unicode-bidi:plaintext;writing-mode:vertical-rl;text-orientation:upright;will-change:transform, opacity;color-adjust:exact;forced-color-adjust:none;print-color-adjust:exact;orphans:4;widows:5;text-combine-upright:all;text-align:center;text-align-all:center;text-align-last:right;text-emphasis:dot #dc2626;text-emphasis-color:#dc2626;text-emphasis-position:under;text-emphasis-style:dot;quotes:'[' ']';text-indent:4px;text-justify:inter-word;text-shadow:2px 1px #dc2626;text-transform:uppercase;text-decoration:underline;text-decoration-line:underline;text-decoration-color:#dc2626;text-decoration-style:double;text-decoration-thickness:2px;text-underline-offset:2px;text-underline-position:under;width:42px;height:18px;image-rendering:pixelated;overflow:hidden}.right{background-color:#dbeafe;color:#334155;font-size:8px;font-weight:400;line-height:8px;white-space:nowrap;text-align:right;direction:rtl;width:46px;height:10px;margin-top:4px;overflow:hidden}.marker{background-color:#f59e0b;width:16px;aspect-ratio:8/3;margin-top:4px}.grid{display:table;table-layout:fixed}.va{vertical-align:middle}</style></head><body><section class='shell'><div class='center'>a  b&#10;cd</div><div class='right'>TAIL SHIFT</div><div class='marker'></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-selector-inline-box-matrix":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc}.shell{background-color:#e5e7eb;padding:4px;width:88px;height:56px}.shell>.direct.hot{background-color:#22c55e;width:16px;height:12px}.shell .nested #target{background-color:#1d4ed8;width:24px;height:10px;margin-left:6px}.shell .nested .inline{background-color:#f59e0b;width:12px;height:8px;margin-left:8px;margin-top:3px}.outside #target{background-color:#ef4444;width:40px;height:40px}</style></head><body><section class='shell'><div class='direct hot'></div><div class='nested'><div id='target'></div><div class='inline' style='background-color:#334155;width:18px;height:8px'></div></div></section><section class='outside'><div id='target'></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-attribute-selector-box-matrix":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc}.shell{background-color:#e5e7eb;padding:4px;width:88px;height:56px}[data-card]{background-color:#22c55e;width:16px;height:8px}div[data-state='active']{background-color:#1d4ed8;width:20px;height:8px;margin-top:3px}div[data-route^='/app']{background-color:#f59e0b;width:12px;height:8px;margin-left:5px;margin-top:3px}div[data-route$='/settings']{background-color:#334155;width:10px;height:8px;margin-left:5px}.shell div[data-state='inactive']{background-color:#ef4444;width:40px;height:12px}</style></head><body><section class='shell'><div data-card='true'></div><div data-state='active'></div><div data-route='/app/home'></div><div data-route='/account/settings'></div><div data-state='inactive'></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-pseudo-selector-matrix":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc}.stage{display:flex;gap:3px;background-color:#e5e7eb;padding:4px;width:88px;height:56px}.col{display:block;width:18px}.card:is(.card,.alias){background-color:#1d4ed8;width:16px;height:6px}.not-target:not(.disabled,#archived){background-color:#22c55e;width:18px;height:6px;margin-top:2px}.has:has(> .badge){background-color:#f59e0b;width:18px;height:6px;margin-top:2px}.nohas:has(> .badge){background-color:#ef4444;width:18px;height:6px;margin-top:2px}.childbox .target:first-child{background-color:#334155;width:18px;height:6px}.childbox .target:last-child{background-color:#a855f7;width:18px;height:6px;margin-top:2px}.nthbox .target:nth-child(2n+1){background-color:#14b8a6;width:18px;height:6px;margin-top:2px}.spacer{width:18px;height:6px;margin-top:2px}</style></head><body><section class='stage'><div class='col'><div class='card'></div><div class='not-target'></div><div class='not-target disabled'></div></div><div class='col'><div class='has'><span class='badge'></span></div><div class='nohas'><section><span class='badge'></span></section></div></div><div class='col childbox'><div class='target'></div><div class='spacer'></div><div class='target'></div></div><div class='col nthbox'><div class='target'></div><div class='spacer'></div><div class='target'></div></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-layer-nesting-structural-matrix":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc}.stage{display:flex;gap:3px;background-color:#e5e7eb;padding:4px;width:88px;height:56px}@layer components{.layer-card{background-color:#1d4ed8;width:16px;height:6px}.layer-card:not(.disabled){margin-top:2px}.nest{&.primary{background-color:#22c55e;width:18px;height:6px;margin-top:2px}& .child{background-color:#f59e0b;width:14px;height:6px;margin-top:2px}}}.only>.target:only-child{background-color:#9333ea;width:18px;height:6px}.only>.target{background-color:#ef4444;width:18px;height:6px;margin-top:2px}.empty>.target:empty{background-color:#0f766e;width:18px;height:6px}.empty>.target{background-color:#334155;width:18px;height:6px;margin-top:2px}.nth>.target:nth-child(2n+1){background-color:#14b8a6;width:18px;height:6px;margin-top:2px}.col{display:block;width:18px}.spacer{width:18px;height:6px;margin-top:2px}</style></head><body><section class='stage'><div class='col'><div class='layer-card'></div><div class='layer-card disabled'></div></div><div class='col'><div class='nest primary'></div><div class='nest'><div class='child'></div></div></div><div class='col only'><div class='target'></div></div><div class='col empty'><div class='target'></div><div class='target'><span></span></div></div><div class='col nth'><div class='target'></div><div class='spacer'></div><div class='target'></div></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-border-box-matrix":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc}.shell{box-sizing:border-box;background-color:#dbeafe;border:3px solid #0f172a;padding:5px;width:88px;height:58px}.content{box-sizing:border-box;background-color:#22c55e;border:2px solid #14532d;padding:3px;width:42px;height:22px}.inner{background-color:#f59e0b;width:18px;height:6px}.normal{background-color:#1d4ed8;border:2px solid #1e3a8a;padding:3px;width:18px;height:6px;margin-top:4px}</style></head><body><section class='shell'><div class='content'><div class='inner'></div></div><div class='normal'></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-padding-longhand-matrix":
        html = "<html><head><style>html,body{margin:0;padding:0;width:${WIDTH}px;height:${HEIGHT}px;overflow:hidden;background-color:#f8fafc}.shell{background-color:#e5e7eb;padding-top:3px;padding-right:5px;padding-bottom:7px;padding-left:9px;width:78px;height:46px}.box{background-color:#22c55e;width:24px;height:10px}.override{background-color:#1d4ed8;padding:2px;padding-left:6px;padding-bottom:4px;width:20px;height:8px;margin-top:4px}.leaf{background-color:#f59e0b;width:8px;height:4px}</style></head><body><section class='shell'><div class='box'></div><div class='override'><div class='leaf'></div></div></section></body></html>"
    if "$SCENE" == "simple-web-layout-border-side-matrix":
