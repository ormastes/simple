#!/bin/sh
set -eu

JS_RENDER_RUNTIME="${JS_RENDER_RUNTIME:-bun}"
JS_RENDER_RUNTIME_BIN="${JS_RENDER_RUNTIME_BIN:-bun}"
BUILD_DIR="${BUILD_DIR:-build/bun_web_render_bitmap_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/bun_web_render_bitmap_evidence_$(date -u +%F).md}"
export JS_RENDER_RUNTIME JS_RENDER_RUNTIME_BIN BUILD_DIR REPORT_PATH

exec sh scripts/check-node-web-render-bitmap-evidence.shs
