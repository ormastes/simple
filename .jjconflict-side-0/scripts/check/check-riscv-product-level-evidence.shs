#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
SIMPLE_BIN="${SIMPLE_BIN:-$ROOT_DIR/bin/simple}"
SIDECAR_BUILD_ROOT="${RISCV_SIDECAR_BUILD_ROOT:-$ROOT_DIR/build/riscv_product_level_sidecar_$$}"
BUDGET_BUILD_ROOT="${RISCV_BUDGET_BUILD_ROOT:-$ROOT_DIR/build/riscv_product_level_budget_$$}"
DEFAULT_SYNTH_REPORT_DIR="$ROOT_DIR/build/riscv_synth_reports"

"$SIMPLE_BIN" test "$ROOT_DIR/test/03_system/app/hardware/feature/riscv_fpga_linux_spec.spl"
BUILD_ROOT="$SIDECAR_BUILD_ROOT" sh "$ROOT_DIR/scripts/check/check-riscv-formal-dual-track.shs"
RISCV_BUDGET_SELFCHECK_ROOT="$ROOT_DIR/build/riscv_product_level_budget_selfcheck_$$" sh "$ROOT_DIR/scripts/check/check-riscv-budget-evidence-selfcheck.shs"
if [ -z "${SYNTH_REPORT_DIR:-}" ] &&
    [ -f "$DEFAULT_SYNTH_REPORT_DIR/rv32_synth.sdn" ] &&
    [ -f "$DEFAULT_SYNTH_REPORT_DIR/rv64_synth.sdn" ]; then
    SYNTH_REPORT_DIR="$DEFAULT_SYNTH_REPORT_DIR" BUILD_ROOT="$BUDGET_BUILD_ROOT" sh "$ROOT_DIR/scripts/check/check-riscv-budget-evidence.shs" "$@"
else
    BUILD_ROOT="$BUDGET_BUILD_ROOT" sh "$ROOT_DIR/scripts/check/check-riscv-budget-evidence.shs" "$@"
fi

echo "STATUS: PASS riscv-product-level-evidence"
