use std.nogc_sync_mut.io.env_ops.{cwd}
use std.nogc_sync_mut.io.file_ops.{file_delete, file_write}
use std.nogc_sync_mut.io.process_ops.{shell}
use std.nogc_sync_mut.io.time_ops.{current_time_ms}

fn frame(body: text) -> text:
    "Content-Length: " + body.len().to_string() + "\r\n\r\n" + body

fn esc(value: text) -> text:
    "'" + value.replace("'", "'\\''") + "'"

fn probe(label: text, command: text, ready_marker: text, tool_marker: text):
    val input_path = "/tmp/simple_probe_" + label + "_" + current_time_ms().to_string() + ".in"
    val b1 = "{\"jsonrpc\":\"2.0\",\"id\":\"1\",\"method\":\"initialize\",\"params\":{\"protocolVersion\":\"2025-06-18\",\"capabilities\":{},\"clientInfo\":{\"name\":\"probe\",\"version\":\"1\"}}}"
    val b2 = "{\"jsonrpc\":\"2.0\",\"method\":\"notifications/initialized\",\"params\":{}}"
    val b3 = "{\"jsonrpc\":\"2.0\",\"id\":\"2\",\"method\":\"tools/list\",\"params\":{}}"
    file_write(input_path, frame(b1) + frame(b2) + frame(b3))
    val ready = shell(command + " --json")
    val start = current_time_ms()
    val result = shell("cd " + esc(cwd()) + " && SIMPLE_MCP_ALLOW_SOURCE_FALLBACK=0 SIMPLE_ALLOW_HOSTED_FALLBACK=0 timeout 15s " + command + " < " + esc(input_path))
    val elapsed = current_time_ms() - start
    file_delete(input_path)
    val out = result.stdout ?? ""
    val err = result.stderr ?? ""
    var reason = "ok"
    if ready.exit_code != 0:
        reason = "ready_json_failed"
    elif not (ready.stdout ?? "").contains(ready_marker):
        reason = "ready_marker"
    elif result.exit_code != 0:
        reason = "exit_" + result.exit_code.to_string()
    elif not out.contains("\"id\":\"2\"") and not out.contains("\"id\":2"):
        reason = "missing_id2"
    elif not out.contains("\"tools\""):
        reason = "missing_tools"
    elif not out.contains(tool_marker):
        reason = "missing_tool"
    print label + " reason=" + reason + " exit=" + result.exit_code.to_string() + " elapsed=" + elapsed.to_string() + " out_len=" + out.len().to_string() + " err=" + err.substring(0, if err.len() < 80: err.len() else: 80)

probe("simple_mcp", "bin/simple_mcp_server", "Simple MCP Server", "play_wm_text_status")
probe("simple_lsp_mcp", "bin/simple_lsp_mcp_server", "simple-lsp-mcp", "definition")
probe("t32_mcp", "bin/t32_mcp_server", "TRACE32 MCP Server", "t32_")
probe("t32_lsp_mcp", "bin/t32_lsp_mcp_server", "TRACE32 LSP MCP Server", "definition")
probe("obsidian_lsp_mcp", "bin/obsidian_lsp_mcp_server", "Obsidian LSP MCP Server", "obsidian")
