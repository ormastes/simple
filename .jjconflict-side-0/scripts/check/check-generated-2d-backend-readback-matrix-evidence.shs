set -eu
mkdir -p "$BUILD_DIR"
cat >"$BUILD_DIR/evidence.env" <<'EOF'
cuda_generated_2d_readback_status=pass
cuda_generated_2d_readback_reason=fake-pass-without-proof
cuda_generated_2d_readback_expected_checksum=1
cuda_generated_2d_readback_actual_checksum=1
cuda_generated_2d_readback_mismatch_count=0
EOF
SH
