#!/bin/sh
set -eu
mkdir -p "$BUILD_DIR"
printf '# fixture\n' >"$REPORT_PATH"
cat >"$BUILD_DIR/evidence.env" <<'EOF'
cuda_generated_2d_readback_status=pass
cuda_generated_2d_readback_reason=fake-pass-with-bad-per-op
cuda_generated_2d_readback_backend_name=cuda
cuda_generated_2d_readback_submit_attempted=true
cuda_generated_2d_readback_readback_available=true
cuda_generated_2d_readback_device_identity=123
cuda_generated_2d_readback_expected_checksum=4
cuda_generated_2d_readback_actual_checksum=4
cuda_generated_2d_readback_mismatch_count=0
cuda_generated_2d_readback_fill_expected_checksum=1
cuda_generated_2d_readback_fill_actual_checksum=1
cuda_generated_2d_readback_fill_mismatch_count=0
cuda_generated_2d_readback_copy_expected_checksum=1
cuda_generated_2d_readback_copy_actual_checksum=2
cuda_generated_2d_readback_copy_mismatch_count=0
