#!/bin/sh
set -eu

SIMPLE_BIN=${SIMPLE_BIN:-bin/simple}
ROOT="build/test-runner-outcome-exits.$$"
BATCH_ROOT=".simple/test-batches/outcome-exits-$$"
EMPTY_DIR="$ROOT/empty"
SLEEP_SPEC="$ROOT/timeout_spec.spl"
GREEN_SPEC="$ROOT/green_spec.spl"
SIGNAL_SPEC="$ROOT/signal_spec.spl"
SIGNAL_CHILD_PID_FILE="$ROOT/signal-child.pid"
MANIFEST="$BATCH_ROOT/contract.manifest"
RESULT="$BATCH_ROOT/contract.result"
RUNNER_PID=
CHILD_PID=

cleanup() {
    if [ -n "$RUNNER_PID" ]; then kill -KILL "$RUNNER_PID" 2>/dev/null || true; fi
    if [ -n "$CHILD_PID" ]; then kill -KILL "$CHILD_PID" 2>/dev/null || true; fi
    rm -rf "$ROOT" "$BATCH_ROOT"
}
trap cleanup EXIT HUP INT TERM

mkdir -p "$EMPTY_DIR" "$BATCH_ROOT"

cat >"$SLEEP_SPEC" <<'EOF'
use std.spec.*
extern fn rt_thread_sleep(ms: i64)

describe "timeout outcome":
    it "exceeds the one-second runner deadline":
        rt_thread_sleep(2000)
        expect(1).to_equal(1)
EOF

cat >"$GREEN_SPEC" <<'EOF'
use std.spec.*

describe "internal outcome setup":
    it "passes before result persistence fails":
        expect(1).to_equal(1)
EOF

cat >"$SIGNAL_SPEC" <<'EOF'
use std.spec.*
use std.io_runtime.{env_get, file_write, getpid, thread_sleep}

describe "signal cleanup outcome":
    it "records its pid and waits":
        expect(file_write(env_get("SIMPLE_SIGNAL_CHILD_PID_PATH"), "{getpid()}")).to_equal(true)
        thread_sleep(30000)
EOF

expect_exit() {
    expected=$1
    label=$2
    shift 2
    if "$@" >"$ROOT/$label.log" 2>&1; then
        actual=0
    else
        actual=$?
    fi
    if [ "$actual" -ne "$expected" ]; then
        echo "check-test-runner-outcome-exits: $label expected $expected, got $actual" >&2
        tail -n 40 "$ROOT/$label.log" >&2
        exit 1
    fi
}

expect_exit 4 empty timeout -k 2s 30s env SIMPLE_TEST_DEPTH=0 \
    "$SIMPLE_BIN" test "$EMPTY_DIR" --no-cache --no-db --no-session-daemon
grep -q "Outcome: empty_selection" "$ROOT/empty.log"

expect_exit 124 timeout timeout -k 2s 30s env SIMPLE_TEST_DEPTH=0 \
    "$SIMPLE_BIN" test "$SLEEP_SPEC" --timeout 1 --no-cache --no-db --no-session-daemon --assert-ran
grep -q "Outcome: timeout_resource_failure" "$ROOT/timeout.log"

printf '%s\n' "$GREEN_SPEC" >"$MANIFEST"
mkdir -p "$RESULT"
expect_exit 3 internal timeout -k 2s 30s env SIMPLE_TEST_DEPTH=0 \
    "$SIMPLE_BIN" test \
    "--batch-manifest=$MANIFEST" "--batch-result=$RESULT" \
    --no-cache --no-db --no-session-daemon

env SIMPLE_TEST_DEPTH=0 SIMPLE_SIGNAL_CHILD_PID_PATH="$SIGNAL_CHILD_PID_FILE" \
    "$SIMPLE_BIN" test "$SIGNAL_SPEC" --parallel --max-workers=1 \
    --no-cache --no-db --no-session-daemon --assert-ran \
    >"$ROOT/signal.log" 2>&1 &
RUNNER_PID=$!

attempt=0
while [ ! -s "$SIGNAL_CHILD_PID_FILE" ] && [ "$attempt" -lt 200 ]; do
    sleep 0.05
    attempt=$((attempt + 1))
done
if [ ! -s "$SIGNAL_CHILD_PID_FILE" ]; then
    echo "check-test-runner-outcome-exits: signal child did not start" >&2
    tail -n 40 "$ROOT/signal.log" >&2
    exit 1
fi
CHILD_PID=$(cat "$SIGNAL_CHILD_PID_FILE")
kill -INT "$RUNNER_PID"
set +e
wait "$RUNNER_PID"
signal_exit=$?
set -e
RUNNER_PID=
if [ "$signal_exit" -ne 130 ]; then
    echo "check-test-runner-outcome-exits: signal expected 130, got $signal_exit" >&2
    tail -n 40 "$ROOT/signal.log" >&2
    exit 1
fi

attempt=0
while kill -0 "$CHILD_PID" 2>/dev/null && [ "$attempt" -lt 100 ]; do
    sleep 0.05
    attempt=$((attempt + 1))
done
if kill -0 "$CHILD_PID" 2>/dev/null; then
    echo "check-test-runner-outcome-exits: signal child survived cleanup" >&2
    exit 1
fi
CHILD_PID=

echo "check-test-runner-outcome-exits: PASS"
