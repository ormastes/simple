    status=fail
    if [ "$android_mdi_proof_marker_source_file_reason" = "symlink" ]; then
        reason=android-mdi-proof-marker-source-symlink
    elif [ "$android_mdi_proof_marker_source_file_reason" = "hardlink" ]; then
        reason=android-mdi-proof-marker-source-hardlink
    elif [ "$android_mdi_proof_marker_source_file_reason" = "size-mismatch" ]; then
        reason=android-mdi-proof-marker-source-size-mismatch
    else
        reason=android-mdi-proof-marker-source-artifact-missing
    fi
elif [ "$android_mdi_proof_marker_source_alias_reason" != "pass" ]; then
    status=fail
    reason=android-mdi-proof-marker-source-overlap
elif [ "$android_mdi_proof_missing_source_count" != "0" ] || ! num_at_least "$android_mdi_proof_source_count" 1; then
    status=fail
    reason=android-mdi-proof-source-missing
elif [ "$android_mdi_failure_marker_status" = "fail" ]; then
    status=fail
    reason=android-mdi-failure-marker
elif [ "$android_mdi_failure_marker_status" != "pass" ]; then
    status=fail
    reason=android-mdi-failure-marker-status-missing
elif [ "$android_mdi_proof_status" != "pass" ] || [ "$android_mdi_render_status" != "pass" ] || [ "$android_mdi_event_status" != "pass" ] || [ "$android_mdi_capture_status" != "pass" ] || [ "$android_mdi_performance_status" != "pass" ] || [ "$android_mdi_interaction_latency_status" != "pass" ] || [ "$android_mdi_animation_status" != "pass" ]; then
    status=fail
    reason=android-mdi-render-event-capture-performance-animation-proof-missing
elif ! mobile_mdi_event_detail_pass "$android_mdi_event_has_desktop" "$android_mdi_event_drag_runtime_available" "$android_mdi_event_drag_events_available" "$android_mdi_event_drag_moved" "$android_mdi_event_window_event_runtime_available" "$android_mdi_event_app_action_control_found" "$android_mdi_event_app_input_control_found" "$android_mdi_event_body_click_routed" "$android_mdi_event_body_input_routed" "$android_mdi_event_body_key_routed" "$android_mdi_event_sequence" "$android_mdi_event_taskbar_icons_visible" "$android_mdi_event_taskbar_labels_visible"; then
    status=fail
    reason=android-mdi-render-event-capture-performance-animation-proof-incomplete
elif ! mobile_mdi_detail_pass "$android_mdi_proof_window_count" "$android_mdi_render_image_count" "$android_mdi_render_html_renderable" "$android_mdi_event_taskbar_item_count" "$android_mdi_event_taskbar_icon_count" "$android_mdi_capture_viewport_width" "$android_mdi_capture_viewport_height" "$android_mdi_capture_device_pixel_ratio" "$android_mdi_capture_screen_orientation" "$android_mdi_performance_now_available" "$android_mdi_performance_now_delta_ms" "$android_mdi_input_to_paint_ms" "$android_mdi_animation_frame_available" "$android_mdi_animation_frame_count" "$android_mdi_css_animation_probe"; then
    status=fail
    reason=android-mdi-render-event-capture-performance-animation-proof-incomplete
fi

