    ios_mdi_capture_viewport_width="$(value_of ios_mdi_capture_viewport_width "$BUILD_DIR/ios.out")"
    ios_mdi_capture_viewport_height="$(value_of ios_mdi_capture_viewport_height "$BUILD_DIR/ios.out")"
    ios_mdi_capture_device_pixel_ratio="$(value_of ios_mdi_capture_device_pixel_ratio "$BUILD_DIR/ios.out")"
    ios_mdi_capture_screen_orientation="$(value_of ios_mdi_capture_screen_orientation "$BUILD_DIR/ios.out")"
    ios_mdi_performance_now_available="$(value_of ios_mdi_performance_now_available "$BUILD_DIR/ios.out")"
    ios_mdi_performance_now_delta_ms="$(value_of ios_mdi_performance_now_delta_ms "$BUILD_DIR/ios.out")"
    ios_mdi_input_to_paint_ms="$(value_of ios_mdi_input_to_paint_ms "$BUILD_DIR/ios.out")"
    ios_mdi_animation_frame_available="$(value_of ios_mdi_animation_frame_available "$BUILD_DIR/ios.out")"
    ios_mdi_animation_frame_count="$(value_of ios_mdi_animation_frame_count "$BUILD_DIR/ios.out")"
    ios_mdi_css_animation_probe="$(value_of ios_mdi_css_animation_probe "$BUILD_DIR/ios.out")"
    ios_screenshot_file_reason="$(png_file_reason "$ios_screenshot" "$ios_mdi_capture_viewport_width" "$ios_mdi_capture_viewport_height")"
    ios_screenshot_file_status="$(png_file_status_from_reason "$ios_screenshot_file_reason")"
    ios_screenshot_artifact_status="$ios_screenshot_file_status"
    ios_screenshot_actual_size_bytes="$(file_size_bytes "$ios_screenshot")"
    ios_screenshot_width="$(png_width_value "$ios_screenshot")"
    ios_screenshot_height="$(png_height_value "$ios_screenshot")"
    ios_screenshot_distinct_color_count="$(png_distinct_color_count_from_reason "$ios_screenshot_file_reason")"
    ios_screenshot_pixel_diversity_status="$(png_pixel_diversity_status "$ios_screenshot_distinct_color_count")"
    ios_mdi_proof_file_reason="$(mdi_proof_file_reason "$ios_mdi_proof_json" \
        "$ios_mdi_proof_window_count" "$ios_mdi_render_image_count" "$ios_mdi_render_html_renderable" \
        "$ios_mdi_event_taskbar_item_count" "$ios_mdi_event_taskbar_icon_count" \
        "$ios_mdi_event_has_desktop" "$ios_mdi_event_drag_runtime_available" "$ios_mdi_event_drag_events_available" \
        "$ios_mdi_event_drag_moved" "$ios_mdi_event_window_event_runtime_available" \
        "$ios_mdi_event_app_action_control_found" "$ios_mdi_event_app_input_control_found" \
        "$ios_mdi_event_body_click_routed" "$ios_mdi_event_body_input_routed" "$ios_mdi_event_body_key_routed" \
        "$ios_mdi_event_sequence" \
        "$ios_mdi_event_taskbar_icons_visible" "$ios_mdi_event_taskbar_labels_visible" \
        "$ios_mdi_capture_viewport_width" "$ios_mdi_capture_viewport_height" "$ios_mdi_capture_device_pixel_ratio" \
        "$ios_mdi_capture_screen_orientation" "$ios_mdi_performance_now_available" "$ios_mdi_performance_now_delta_ms" \
        "$ios_mdi_input_to_paint_ms" "$ios_mdi_animation_frame_available" "$ios_mdi_animation_frame_count" \
        "$ios_mdi_css_animation_probe")"
    ios_mdi_proof_file_status="$(mdi_proof_file_status "$ios_mdi_proof_file_reason")"
    ios_mdi_proof_marker_source_alias_reason=pass
    if [ "$ios_mdi_proof_file_status" = "pass" ] && [ "$ios_mdi_proof_marker_source_file_status" = "pass" ] && same_file_identity "$ios_mdi_proof_json" "$ios_mdi_proof_marker_source_path"; then
        ios_mdi_proof_marker_source_alias_reason=proof-json-overlaps-marker-source
    fi
    ios_render_log_validation_env="$BUILD_DIR/ios_render_log.validation.env"
    if [ -f "$IOS_RENDER_LOG_VALIDATOR" ]; then
        ios_render_validation_code=0
        node "$IOS_RENDER_LOG_VALIDATOR" "$ios_log_stream" "$ios_dev_log" "$IOS_LOG_EXTRA" >"$ios_render_log_validation_env" \
            || ios_render_validation_code=$?
        cat "$ios_render_log_validation_env"
        ios_render_log_validation_status="$(value_of ios_render_log_validation_status "$ios_render_log_validation_env")"
        ios_render_log_validation_reason="$(value_of ios_render_log_validation_reason "$ios_render_log_validation_env")"
        ios_render_log_requested_source_count="$(value_of ios_render_log_requested_source_count "$ios_render_log_validation_env")"
        ios_render_log_source_count="$(value_of ios_render_log_source_count "$ios_render_log_validation_env")"
        ios_render_log_missing_source_count="$(value_of ios_render_log_missing_source_count "$ios_render_log_validation_env")"
        ios_render_log_empty_source_count="$(value_of ios_render_log_empty_source_count "$ios_render_log_validation_env")"
        ios_render_log_symlink_source_count="$(value_of ios_render_log_symlink_source_count "$ios_render_log_validation_env")"
        ios_render_log_hardlink_source_count="$(value_of ios_render_log_hardlink_source_count "$ios_render_log_validation_env")"
        if [ -z "$ios_render_log_hardlink_source_count" ]; then ios_render_log_hardlink_source_count=0; fi
        ios_render_log_duplicate_source_count="$(value_of ios_render_log_duplicate_source_count "$ios_render_log_validation_env")"
        if [ -z "$ios_render_log_duplicate_source_count" ]; then ios_render_log_duplicate_source_count=0; fi
        ios_render_log_nonregular_source_count="$(value_of ios_render_log_nonregular_source_count "$ios_render_log_validation_env")"
        ios_render_log_html_len="$(value_of ios_render_log_html_len "$ios_render_log_validation_env")"
        ios_render_log_source_coherence_status="$(value_of ios_render_log_source_coherence_status "$ios_render_log_validation_env")"
        ios_render_log_coherent_source_path="$(value_of ios_render_log_coherent_source_path "$ios_render_log_validation_env")"
        ios_render_log_coherent_source_size_bytes="$(value_of ios_render_log_coherent_source_size_bytes "$ios_render_log_validation_env")"
        ios_render_log_coherent_source_actual_size_bytes="$(file_size_bytes "$ios_render_log_coherent_source_path")"
        ios_render_log_coherent_source_file_reason="$(artifact_file_reason "$ios_render_log_coherent_source_path" "$ios_render_log_coherent_source_size_bytes")"
        ios_render_log_coherent_source_file_status="$(artifact_file_status "$ios_render_log_coherent_source_file_reason")"
        ios_render_log_coherent_source_artifact_status="$ios_render_log_coherent_source_file_status"
        ios_render_log_marker_status="$(value_of ios_render_log_marker_status "$ios_render_log_validation_env")"
        ios_render_log_marker_source="$(value_of ios_render_log_marker_source "$ios_render_log_validation_env")"
        ios_render_log_metal_marker_status="$(value_of ios_render_log_metal_marker_status "$ios_render_log_validation_env")"
        ios_render_log_fallback_marker_status="$(value_of ios_render_log_fallback_marker_status "$ios_render_log_validation_env")"
        ios_render_log_tauri_context_status="$(value_of ios_render_log_tauri_context_status "$ios_render_log_validation_env")"
        ios_render_log_metal_context_status="$(value_of ios_render_log_metal_context_status "$ios_render_log_validation_env")"
        ios_render_log_failure_marker_status="$(value_of ios_render_log_failure_marker_status "$ios_render_log_validation_env")"
        if [ "$ios_render_validation_code" -eq 0 ] && [ "$ios_render_log_validation_status" = "pass" ]; then
            ios_render_log_status=pass
            ios_metal_log_status=pass
        elif [ "$ios_status" = "pass" ]; then
            ios_render_log_status="$ios_render_log_marker_status"
            ios_metal_log_status="$ios_render_log_metal_marker_status"
            if [ "$ios_render_log_failure_marker_status" = "fail" ]; then
                ios_reason=ios-render-log-failure-marker
            elif [ "$ios_render_log_fallback_marker_status" = "fail" ]; then
                ios_reason=ios-render-log-fallback-gpu
            elif [ "$ios_render_log_marker_status" != "pass" ]; then
                ios_reason=ios-render-log-marker-missing
            elif [ "$ios_render_log_metal_marker_status" != "pass" ]; then
                ios_reason=ios-metal-log-marker-missing
            elif [ "$ios_render_log_tauri_context_status" != "pass" ]; then
                ios_reason=ios-tauri-wkwebview-context-missing
            elif [ "$ios_render_log_metal_context_status" != "pass" ]; then
                ios_reason=ios-metal-context-missing
            elif [ "$ios_render_log_source_coherence_status" != "pass" ]; then
                ios_reason=ios-render-log-source-mismatch
            elif [ "$ios_render_log_missing_source_count" != "0" ]; then
                ios_reason=ios-render-log-source-missing
            elif [ "$ios_render_log_symlink_source_count" != "0" ]; then
                ios_reason=ios-render-log-source-symlink
            elif [ "$ios_render_log_hardlink_source_count" != "0" ]; then
                ios_reason=ios-render-log-source-hardlink
            elif [ "$ios_render_log_duplicate_source_count" != "0" ]; then
                ios_reason=ios-render-log-source-duplicate
            elif [ "$ios_render_log_nonregular_source_count" != "0" ]; then
                ios_reason=ios-render-log-source-not-regular
            elif [ "$ios_render_log_empty_source_count" != "0" ]; then
                ios_reason=ios-render-log-source-empty
            else
                ios_reason="${ios_render_log_validation_reason:-ios-render-log-validation-failed}"
            fi
        fi
    elif [ "$ios_status" = "pass" ]; then
        ios_render_log_status=fail
        ios_metal_log_status=fail
        ios_render_log_validation_status=fail
        ios_render_log_validation_reason=ios-render-log-validator-missing
        ios_reason=ios-render-log-validator-missing
    fi
    if [ "$ios_status" = "pass" ] && [ "$ios_screenshot_file_status" = "pass" ]; then
        ios_layout_status=pass
    elif [ "$ios_status" = "pass" ]; then
        ios_layout_status=fail
        ios_reason=ios-screenshot-png-missing
    fi
else
    ios_reason=missing-ios-evidence-script
fi

