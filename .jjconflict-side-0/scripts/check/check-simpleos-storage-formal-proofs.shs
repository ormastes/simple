#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
CHECK_LEAN="$ROOT_DIR/scripts/check/check-lean-proofs.shs"

require_theorem() {
    file="$1"
    name="$2"
    if ! grep -Eq "^[[:space:]]*theorem[[:space:]]+$name([[:space:]]|:|\\(|$)" "$ROOT_DIR/$file"; then
        echo "FAIL: missing theorem $name in $file" >&2
        exit 1
    fi
}

if [ "${1:-}" = "--self-test" ]; then
    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' EXIT
    grep -v '^theorem T1_btree_ordered' \
        "$ROOT_DIR/src/verification/db_storage/DbStorage/Theorems.lean" \
        >"$tmp_dir/mutated.lean"
    if (ROOT_DIR="$tmp_dir" require_theorem "mutated.lean" "T1_btree_ordered" 2>/dev/null); then
        echo "STATUS: FAIL simpleos-storage-formal-proofs self-test: require_theorem did not fail on mutated copy" >&2
        exit 1
    fi
    echo "STATUS: PASS simpleos-storage-formal-proofs self-test (require_theorem correctly rejects a stripped theorem)"
    exit 0
fi

sh "$CHECK_LEAN" --self-test >/dev/null
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/db_storage" "verification/db_storage"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/fat32" "verification/fat32"
sh "$CHECK_LEAN" --project "$ROOT_DIR/src/verification/formal/nvfs" "verification/formal/nvfs"

require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T1_btree_ordered"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T1_btree_insert_contains_key"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T2_btree_balanced_leaf"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T3_btree_bounds"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T4_wal_before_data"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T4_commit_sets_committed"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T4_wal_appended_before_commit"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T4_publish_root_requires_wal_flush"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T4_publish_root_sets_published"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T4_pager_wal_gate"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T4_pager_wal_gate_blocked"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T4_pager_wal_gate_allows_flushed"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T5_snapshot_committed"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T5_snapshot_excludes_active_insert"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T5_snapshot_excludes_future"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T5_snapshot_excludes_deleted"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T5_snapshot_keeps_active_delete"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T6_recovery_equation"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T6_recovery_complete"
require_theorem "src/verification/db_storage/DbStorage/Theorems.lean" "T6_replay_requires_committed_txn"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T1_chain_length_bound"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T1_zero_fuel_empty"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T2_lba_monotone"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T3_lba_injective"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T4_encode_decode_README_MD"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T4_encode_decode_KERNEL_ELF"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T4_encode_decode_no_ext"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T5_cluster_count_covers"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T6_eoc_not_free"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T6_free_not_valid_chain"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T6_bad_not_valid_chain"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T6_bad_marker_not_valid_chain"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T6_eoc_not_valid_chain"
require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T7a_valid_link_ge2"
