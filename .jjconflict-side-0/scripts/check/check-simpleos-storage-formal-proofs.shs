require_theorem "src/verification/fat32/Fat32/Theorems.lean" "T7c_alloc_step2_new_chain_disjoint"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "arena_create_preserves_all"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "arena_seal_preserves_all"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "arena_append_preserves_all"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "arena_discard_preserves_all"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "arena_clone_range_preserves_all"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "pmap_publish_preserves_all"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "walStrictlyIncreasing_append"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "wal_append_preserves_I4"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "wal_append_preserves_all"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "checkpoint_commit_crash_refines"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "checkpoint_commit_preserves_all"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "mount_preserves_all"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "mount_success_increments_epoch"
require_theorem "src/verification/formal/nvfs/Nvfs/Theorems.lean" "unmount_preserves_all"

echo "STATUS: PASS simpleos-storage-formal-proofs"
