#!/bin/sh
set -eu

JS_RENDER_RUNTIME="${JS_RENDER_RUNTIME:-node}"
JS_RENDER_RUNTIME_BIN="${JS_RENDER_RUNTIME_BIN:-node}"
BUILD_DIR="${BUILD_DIR:-build/node_simple_web_engine2d_bitmap_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/node_simple_web_engine2d_bitmap_evidence_$(date -u +%F).md}"
export JS_RENDER_RUNTIME JS_RENDER_RUNTIME_BIN BUILD_DIR REPORT_PATH

exec sh scripts/check-simple-web-engine2d-js-bitmap-evidence.shs
