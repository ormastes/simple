#!/bin/sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT_DIR"

BUILD_DIR="${BUILD_DIR:-build/shared_wm_renderer_unification_evidence}"
REPORT_PATH="${REPORT_PATH:-doc/09_report/shared_wm_renderer_unification_evidence_$(date -u +%F).md}"
SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
SIMPLE_BIN_STATUS=pass

is_rust_seed_simple() {
    case "$1" in
        src/compiler_rust/*|*/src/compiler_rust/*) return 0 ;;
        *) return 1 ;;
    esac
}

if [ "${SIMPLE_BIN:-}" = "" ]; then
    SIMPLE_BIN_SOURCE="missing-self-hosted"
    for candidate in \
        "release"/*/simple \
        "bin/release"/*/simple \
        "build/bootstrap/stage3/simple" \
        "bin/simple" \
        "./bin/simple"
    do
        if [ -x "$candidate" ]; then
            SIMPLE_BIN="$candidate"
            SIMPLE_BIN_SOURCE="repo-self-hosted-fallback"
            break
        fi
    done
    if [ "${SIMPLE_BIN:-}" = "" ] && [ "${ALLOW_PATH_SIMPLE_BIN:-0}" = "1" ] && command -v simple >/dev/null 2>&1; then
        SIMPLE_BIN="$(command -v simple)"
        SIMPLE_BIN_SOURCE="path-opt-in"
    fi
else
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE:-explicit-env}"
fi
SIMPLE_BIN="${SIMPLE_BIN:-}"
if [ "$SIMPLE_BIN" = "" ]; then
    SIMPLE_BIN_STATUS=missing
elif is_rust_seed_simple "$SIMPLE_BIN"; then
    SIMPLE_BIN_STATUS=forbidden
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-rust-seed-forbidden"
elif [ ! -x "$SIMPLE_BIN" ]; then
    SIMPLE_BIN_STATUS=missing
    SIMPLE_BIN_SOURCE="${SIMPLE_BIN_SOURCE}-missing"
fi
export SIMPLE_BIN SIMPLE_BIN_SOURCE SIMPLE_BIN_STATUS
SPEC_PATH="test/03_system/app/ui/feature/shared_wm_renderer_unification_spec.spl"
HOST_SOURCE="src/os/compositor/host_compositor_entry.spl"

mkdir -p "$BUILD_DIR" "$(dirname -- "$REPORT_PATH")"
rm -f "$REPORT_PATH" "$BUILD_DIR/check.out" "$BUILD_DIR/test.out"

if [ "$SIMPLE_BIN_STATUS" != "pass" ]; then
    reason="simple-bin-$SIMPLE_BIN_STATUS"
    {
        echo "# Shared WM Renderer Unification Evidence"
        echo
        echo "- status: unavailable"
        echo "- reason: $reason"
        echo "- simple_bin: $SIMPLE_BIN"
        echo "- simple_bin_source: $SIMPLE_BIN_SOURCE"
        echo "- simple_bin_status: $SIMPLE_BIN_STATUS"
    } >"$REPORT_PATH"
    echo "shared_wm_renderer_unification_status=unavailable"
    echo "shared_wm_renderer_unification_reason=$reason"
    echo "shared_wm_renderer_unification_simple_bin=$SIMPLE_BIN"
    echo "shared_wm_renderer_unification_simple_bin_source=$SIMPLE_BIN_SOURCE"
    echo "shared_wm_renderer_unification_simple_bin_status=$SIMPLE_BIN_STATUS"
    echo "shared_wm_renderer_unification_report_path=$REPORT_PATH"
    exit 1
fi

tmp_dir="$(mktemp -d /tmp/simple-shared-wm-evidence.XXXXXX)"
cleanup() {
    rm -rf "$tmp_dir"
}
trap cleanup EXIT INT TERM

tmp_spec="$tmp_dir/shared_wm_renderer_unification_spec.spl"
cp "$SPEC_PATH" "$tmp_spec"

logic_check_status=fail
logic_test_status=fail
logic_passed=0
logic_failed=0
host_source_contract_status=fail
shared_simple_gui_scene_contract_status=fail
boolean_wrapper_scan_count=0
status=fail
reason=not-run

set +e
SIMPLE_LIB="${SIMPLE_LIB:-src}" "$SIMPLE_BIN" check "$tmp_spec" >"$BUILD_DIR/check.out" 2>&1
check_code=$?
SIMPLE_LIB="${SIMPLE_LIB:-src}" "$SIMPLE_BIN" test "$tmp_spec" --mode=interpreter --clean --format json >"$BUILD_DIR/test.out" 2>&1
test_code=$?
set -e

if [ "$check_code" -eq 0 ]; then
    logic_check_status=pass
fi
# `simple test --format json` is requested above, but the runner emits its
# human-readable summary regardless of the flag (a BDD "N examples, M
# failures" line plus a "Test Summary" block with "Passed: N" / "Failed: N"),
# so a JSON-only parser always reads zero counts here and the gate falsely
# reports RED on a passing run. Try the JSON markers first (so a runner build
# that does honor the flag still works), then fall back to the human-format
# summary line -- mirrors the same defensive pattern used in
# check-async-library-hardening-evidence.shs. Do not trust exit code alone
# (interpreter-mode `simple test` has been observed to exit 0 despite a
# failure in the printed summary), and a zero-example parse must not read as
# a pass.
logic_passed="$(sed -n 's/.*"total_passed": *\([0-9][0-9]*\).*/\1/p' "$BUILD_DIR/test.out" | tail -n 1)"
logic_failed="$(sed -n 's/.*"total_failed": *\([0-9][0-9]*\).*/\1/p' "$BUILD_DIR/test.out" | tail -n 1)"
if [ -z "$logic_passed" ] || [ -z "$logic_failed" ]; then
    # Human-format fallback. Match either the plain single-file form
    # ("Passed: N") or the ANSI-colored multi-file discovery form.
    logic_passed="$(grep -h -E 'Passed: [0-9]+' "$BUILD_DIR/test.out" | tail -n 1 | sed -E 's/^.*Passed: ([0-9]+).*$/\1/')"
    logic_failed="$(grep -h -E 'Failed: [0-9]+' "$BUILD_DIR/test.out" | tail -n 1 | sed -E 's/^.*Failed: ([0-9]+).*$/\1/')"
fi
if [ -z "$logic_passed" ]; then
    logic_passed=0
fi
if [ -z "$logic_failed" ]; then
    logic_failed=0
fi
if [ "$test_code" -eq 0 ] && [ "$logic_failed" -eq 0 ] && [ "$logic_passed" -gt 0 ]; then
    logic_test_status=pass
fi
if [ "$logic_check_status" != pass ] \
    && [ "$logic_test_status" = pass ] \
    && grep -Fq 'describe "shared WM renderer unification behavior contract":' "$SPEC_PATH" \
    && grep -Fq '[parser_error]' "$BUILD_DIR/check.out"; then
    logic_check_status=not-applicable-sspec-dsl
fi

if grep -Fq 'fn host_compositor_apply_lifecycle_action(comp: HostCompositor, action: WmAction) -> HostCompositor:' "$HOST_SOURCE" \
    && grep -Fq 'apply_wm_action_to_lifecycle_windows(host_windows_to_lifecycle_state(out.windows), out.next_window_id, out.width, out.height, action)' "$HOST_SOURCE" \
    && grep -Fq 'me apply_wm_action(action: WmAction):' "$HOST_SOURCE" \
    && grep -Fq 'val out = host_compositor_apply_lifecycle_action(self, action)' "$HOST_SOURCE" \
    && grep -Fq 'self.windows = out.windows' "$HOST_SOURCE" \
    && grep -Fq 'self.next_window_id = out.next_window_id' "$HOST_SOURCE"; then
    host_source_contract_status=pass
fi

if grep -Fq 'shared_mdi_scene_from_render_windows' "$HOST_SOURCE" \
    && grep -Fq 'shared_mdi_render_windows_from_simple_gui_scene' "$HOST_SOURCE" \
    && grep -Fq 'simple_gui_scene = shared_mdi_scene_from_render_windows' "$HOST_SOURCE" \
    && grep -Fq 'draw_shared_mdi_taskbar(self.backend, simple_gui_windows' "$HOST_SOURCE" \
    && grep -Fq 'simple_gui_internal_window_scene' src/os/compositor/shared_mdi_framebuffer_scene.spl \
    && grep -Fq 'render_shared_mdi_framebuffer_scene_for_windows(width, height, backend_kind, shared_mdi_render_windows_from_lifecycle(windows))' src/os/compositor/shared_mdi_framebuffer_scene.spl \
    && grep -Fq 'render_shared_mdi_framebuffer_scene_for_simple_gui_scene(_shared_mdi_scene_from_render_windows(width, height, backend_kind, windows)' src/os/compositor/shared_mdi_framebuffer_scene.spl \
    && grep -Fq 'render_shared_mdi_framebuffer_scene_for_simple_gui_scene' src/os/compositor/shared_mdi_framebuffer_scene.spl \
    && grep -Fq 'render_shared_mdi_framebuffer_scene_for_lifecycle_windows' examples/09_embedded/simple_os/arch/x86_64/gui_entry_engine2d.spl \
    && grep -Fq 'wm_lifecycle_pointer_move' examples/09_embedded/simple_os/arch/x86_64/gui_entry_engine2d.spl \
    && grep -Fq 'wm_lifecycle_left_button' examples/09_embedded/simple_os/arch/x86_64/gui_entry_engine2d.spl; then
    shared_simple_gui_scene_contract_status=pass
fi

boolean_wrapper_scan_count="$(grep -E '\.to_equal\((true|false)\)' "$SPEC_PATH" | wc -l | tr -d ' ')"

if { [ "$logic_check_status" = pass ] || [ "$logic_check_status" = not-applicable-sspec-dsl ]; } \
    && [ "$logic_test_status" = pass ] \
    && [ "$logic_passed" -ge 4 ] \
    && [ "$logic_failed" -eq 0 ] \
    && [ "$host_source_contract_status" = pass ] \
    && [ "$shared_simple_gui_scene_contract_status" = pass ] \
    && [ "$boolean_wrapper_scan_count" -eq 0 ]; then
    status=pass
    reason=pass
elif [ "$logic_check_status" != pass ] && [ "$logic_check_status" != not-applicable-sspec-dsl ]; then
    reason=logic-check-failed
elif [ "$logic_test_status" != pass ]; then
    reason=logic-test-failed
elif [ "$host_source_contract_status" != pass ]; then
    reason=host-source-contract-failed
elif [ "$shared_simple_gui_scene_contract_status" != pass ]; then
    reason=shared-simple-gui-scene-contract-failed
else
    reason=boolean-wrapper-scan-failed
fi

{
    echo "# Shared WM Renderer Unification Evidence"
    echo
    echo "- status: $status"
    echo "- reason: $reason"
    echo "- simple_bin: $SIMPLE_BIN"
    echo "- simple_bin_source: $SIMPLE_BIN_SOURCE"
    echo "- simple_bin_status: $SIMPLE_BIN_STATUS"
    echo "- spec: $SPEC_PATH"
    echo "- temp_spec: $tmp_spec"
    echo "- logic_check_status: $logic_check_status"
    echo "- logic_test_status: $logic_test_status"
    echo "- logic_passed: $logic_passed"
    echo "- logic_failed: $logic_failed"
    echo "- host_source_contract_status: $host_source_contract_status"
    echo "- shared_simple_gui_scene_contract_status: $shared_simple_gui_scene_contract_status"
    echo "- boolean_wrapper_scan_count: $boolean_wrapper_scan_count"
    echo
    echo "The executable lifecycle and SimpleOS adapter spec is copied outside the"
    echo "repository before execution because this dependency-heavy spec currently"
    echo "hits a repo-path runner/import failure while the same source passes from"
    echo "an out-of-tree spec path."
} >"$REPORT_PATH"

echo "shared_wm_renderer_unification_status=$status"
echo "shared_wm_renderer_unification_reason=$reason"
echo "shared_wm_renderer_unification_simple_bin=$SIMPLE_BIN"
echo "shared_wm_renderer_unification_simple_bin_source=$SIMPLE_BIN_SOURCE"
echo "shared_wm_renderer_unification_simple_bin_status=$SIMPLE_BIN_STATUS"
echo "shared_wm_renderer_unification_logic_check_status=$logic_check_status"
echo "shared_wm_renderer_unification_logic_test_status=$logic_test_status"
echo "shared_wm_renderer_unification_logic_passed=$logic_passed"
echo "shared_wm_renderer_unification_logic_failed=$logic_failed"
echo "shared_wm_renderer_unification_host_source_contract_status=$host_source_contract_status"
echo "shared_wm_renderer_unification_shared_simple_gui_scene_contract_status=$shared_simple_gui_scene_contract_status"
echo "shared_wm_renderer_unification_boolean_wrapper_scan_count=$boolean_wrapper_scan_count"
echo "shared_wm_renderer_unification_report_path=$REPORT_PATH"

if [ "$status" != pass ]; then
    echo "shared_wm_renderer_unification_check_log=$BUILD_DIR/check.out"
    echo "shared_wm_renderer_unification_test_log=$BUILD_DIR/test.out"
    exit 1
fi
