use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.backend_probe.{backend_status_text}

fn count_rect_mismatches(pixels: [u32], bg: u32, fg: u32) -> i64:
    var mismatches = 0
    var y = 0
    while y < 16:
        var x = 0
        while x < 16:
            val expected = if x >= 2 and x < 8 and y >= 2 and y < 8: fg else: bg
            if pixels[y * 16 + x] != expected:
                mismatches = mismatches + 1
            x = x + 1
        y = y + 1
    mismatches

fn checksum_expected_clear(count: i32, color: u32) -> i64:
    var sum: i64 = 0
    var i = 0
    while i < count:
        sum = sum + color.to_i64() * ((i + 1) as i64)
        i = i + 1
    sum

fn checksum_pixels(pixels: [u32]) -> i64:
    var sum: i64 = 0
    var i = 0
    while i < pixels.len():
        sum = sum + pixels[i].to_i64() * ((i + 1) as i64)
        i = i + 1
    sum

fn checksum_expected_rect(bg: u32, fg: u32) -> i64:
    var sum: i64 = 0
    var y = 0
    while y < 16:
        var x = 0
        while x < 16:
            val expected = if x >= 2 and x < 8 and y >= 2 and y < 8: fg else: bg
            val i = y * 16 + x
            sum = sum + expected.to_i64() * ((i + 1) as i64)
            x = x + 1
        y = y + 1
    sum

fn main() -> i64:
    print("evidence_program=engine2d_vulkan_readback")
    val probe = Engine2D.probe_backend(16, 16, "vulkan")
    print("vulkan_probe_status=" + backend_status_text(probe.status))
    print("vulkan_available=" + probe.is_ok().to_text())
    print("vulkan_probe_diagnostic=" + probe.diagnostic_text())

    if not probe.is_ok():
        print("backend_name=")
        print("present_exercised=false")
        print("readback_exercised=false")
        print("clear_status=not_run")
        print("rect_status=not_run")
        print("evidence_status=fail")
        print("overall=fail")
        return 1

    val result = Engine2D.create_with_backend_strict(16, 16, "vulkan")
    if not result.is_ok():
        val diag = result.unwrap_err()
        print("backend_name=")
        print("strict_create_status=fail")
        print("strict_create_diagnostic=" + diag.diagnostic_text())
        print("present_exercised=false")
        print("readback_exercised=false")
        print("clear_status=not_run")
        print("rect_status=not_run")
        print("evidence_status=fail")
        print("overall=fail")
        return 1

    var engine = result.unwrap()
    print("strict_create_status=pass")
    print("backend_name=" + engine.backend_name())

    val bg = 0xFF0000FFu32
    val fg = 0xFFFF0000u32
    print("step=before_clear")
    engine.clear(bg)
    print("step=after_clear")
    engine.present()
    print("step=after_present_clear")
    val clear_pixels = engine.read_pixels()
    print("step=after_read_clear")
    print("clear_readback_pixels=" + clear_pixels.len().to_text())
    print("clear_expected_checksum=" + checksum_expected_clear(clear_pixels.len(), bg).to_text())
    print("clear_actual_checksum=" + checksum_pixels(clear_pixels).to_text())
    var clear_mismatches = 0
    var i = 0
    while i < clear_pixels.len():
        if clear_pixels[i] != bg:
            clear_mismatches = clear_mismatches + 1
        i = i + 1
    print("clear_mismatches=" + clear_mismatches.to_text())
    if clear_mismatches != 0:
        engine.shutdown()
        print("present_exercised=true")
        print("readback_exercised=true")
        print("clear_status=fail")
        print("rect_status=not_run")
        print("evidence_status=fail")
        print("overall=fail")
        return 1

    engine.clear(bg)
    print("step=after_rect_clear")
    engine.draw_rect_filled(2, 2, 6, 6, fg)
    print("step=after_draw_rect")
    engine.present()
    print("step=after_present_rect")
    val rect_pixels = engine.read_pixels()
    print("step=after_read_rect")
    val rect_mismatches = count_rect_mismatches(rect_pixels, bg, fg)
    print("rect_readback_pixels=" + rect_pixels.len().to_text())
    print("rect_expected_checksum=" + checksum_expected_rect(bg, fg).to_text())
    print("rect_actual_checksum=" + checksum_pixels(rect_pixels).to_text())
    print("rect_mismatches=" + rect_mismatches.to_text())
    engine.shutdown()

    print("present_exercised=true")
    print("readback_exercised=true")
    print("clear_status=pass")
    if rect_mismatches != 0:
        print("rect_status=fail")
        print("evidence_status=fail")
        print("overall=fail")
        return 1

    print("rect_status=pass")
    print("evidence_status=pass")
    print("overall=pass")
    return 0
