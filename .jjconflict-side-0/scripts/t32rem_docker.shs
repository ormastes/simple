#!/bin/sh
# Run t32rem inside a privileged TRACE32 container.

set -eu

CONTAINER_NAME="${T32_CONTAINER_NAME:-simple-trace32-pv}"
T32REM_IN_CONTAINER="${T32REM_IN_CONTAINER:-/opt/t32/bin/pc_linux64/t32rem}"

if ! command -v docker >/dev/null 2>&1; then
    echo "ERROR: docker is required for $0" >&2
    exit 1
fi

exec docker exec "$CONTAINER_NAME" "$T32REM_IN_CONTAINER" "$@"
