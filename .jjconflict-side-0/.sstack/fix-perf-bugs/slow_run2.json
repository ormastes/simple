  <div id="app"><div class="widget-panel layout-vbox focused" id="layout" style="flex: 1;"><div class="panel-content"></div></div></div>
  <script>const wsProto = location.protocol === 'https:' ? 'wss' : 'ws';
const wsHost = location.host ? location.host : ('localhost:' + 8080 + '');
const wsUrl = wsProto + '://' + wsHost + '/ws';
let ws = null;
let currentFocusId = '';
function connect() {
  ws = new WebSocket(wsUrl);
  ws.onmessage = function(e) {
    const data = JSON.parse(e.data);
    if (data.type === 'render') {
      document.getElementById('app').innerHTML = data.html;
      restoreFocus();
    }
  };
  ws.onclose = function() {
    setTimeout(connect, 2000);
  };
}
connect();
function sendEvent(evt) {
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify(evt));
  }
}
function restoreFocus() {
  if (currentFocusId) {
    var el = document.getElementById(currentFocusId);
    if (el) el.setAttribute('data-focused', 'true');
  }
}
document.addEventListener('keydown', function(e) {
  var tag = e.target.tagName.toLowerCase();
  if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
  sendEvent({type: 'key', key: e.key});
  if (['j','k','Tab','Escape',':','i'].indexOf(e.key) >= 0) e.preventDefault();
});
document.addEventListener('click', function(e) {
  var el = e.target;
  var btn = el.closest('.widget-button');
  if (btn) {
    var action = btn.getAttribute('data-action');
    if (action) sendEvent({type: 'action', name: action});
    currentFocusId = btn.id;
    sendEvent({type: 'focus', id: btn.id});
    return;
  }
  var cb = el.closest('.widget-checkbox');
  if (cb) {
    var action = cb.getAttribute('data-action');
    var isChecked = cb.classList.contains('checked');
    if (action) sendEvent({type: 'action', name: action, value: isChecked ? 'false' : 'true'});
    currentFocusId = cb.id;
    return;
  }
  var li = el.closest('.list-item');
  if (li) {
    var list = li.closest('.widget-list');
    if (list) {
      var items = list.querySelectorAll('.list-item');
      for (var i = 0; i < items.length; i++) {
        if (items[i] === li) {
          sendEvent({type: 'action', name: 'select_' + list.id + '_' + i});
          break;
        }
      }
      currentFocusId = list.id;
    }
    return;
  }
  var tab = el.closest('.tab-item');
  if (tab) {
    var tabs = tab.parentElement;
    if (tabs) {
      var items = tabs.querySelectorAll('.tab-item');
      for (var i = 0; i < items.length; i++) {
        items[i].classList.remove('active');
        if (items[i] === tab) {
          tab.classList.add('active');
          sendEvent({type: 'action', name: 'tab_' + tabs.id + '_' + i});
        }
      }
      currentFocusId = tabs.id;
    }
    return;
  }
  var toggle = el.closest('.tree-toggle');
  if (toggle) {
    var action = toggle.getAttribute('data-action');
    if (action) sendEvent({type: 'action', name: action});
    return;
  }
  var th = el.closest('th[data-action]');
  if (th) {
    var action = th.getAttribute('data-action');
    if (action) sendEvent({type: 'action', name: action});
    return;
  }
  var sub = el.closest('.submenu-item');
  if (sub) {
    var action = sub.getAttribute('data-action');
    if (action) sendEvent({type: 'action', name: action});
    return;
  }
  var widget = el.closest('[id]');
  if (widget && widget.id) {
    currentFocusId = widget.id;
    sendEvent({type: 'focus', id: widget.id});
  }
});
document.addEventListener('input', function(e) {
  if (e.target.classList.contains('table-filter')) {
    var action = e.target.getAttribute('data-action');
    if (action) sendEvent({type: 'action', name: action, value: e.target.value});
  }
});
document.addEventListener('change', function(e) {
  var dd = e.target.closest('.widget-dropdown');
  if (dd) {
    sendEvent({type: 'action', name: 'select_' + dd.id + '_' + e.target.selectedIndex});
  }
});
document.addEventListener('change', function(e) {
  var inp = e.target.closest('.widget-input, .widget-textfield');
  if (inp && inp.id) sendEvent({type: 'action', name: 'change_' + inp.id, value: e.target.value});
  var ta = e.target.closest('.widget-textarea');
  if (ta && ta.id) sendEvent({type: 'action', name: 'change_' + ta.id, value: e.target.value});
});
</script>
</body>
