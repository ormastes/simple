"""
# RISC-V Types Package — Shared Type Definitions

Shared enums for ALU operations, branch operations, memory operations,
and forwarding sources. Used by both RV32 and RV64.
"""

enum AluOp:
    Add
    Sub
    And
    Or
    Xor
    Sll
    Srl
    Sra
    Slt
    Sltu
    PassB
    # W-variants (RV64 only, but enum is shared)
    Addw
    Subw
    Sllw
    Srlw
    Sraw

enum BranchOp:
    Beq
    Bne
    Blt
    Bge
    Bltu
    Bgeu

enum MemOp:
    Load
    Store
    None_

enum MemWidth:
    Byte
    Half
    Word
    Double

enum ForwardSrc:
    RegFile
    FromEx
    FromMem

enum MulDivOp:
    Mul
    Mulh
    Mulhsu
    Mulhu
    Div
    Divu
    Rem
    Remu
    # W-variants
    Mulw
    Divw
    Divuw
    Remw
    Remuw

enum AmoOp:
    Swap
    Add
    And
    Or
    Xor
    Max
    Maxu
    Min
    Minu

enum AmoOrdering:
    Relaxed
    Acquire
    Release
    SeqCst

class PipelineControl:
    stall: bool
    flush: bool

class AmoResult:
    old_value: i64
    new_value: i64
