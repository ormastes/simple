"""
# RV32 CSR File
"""

class Rv32CsrFile:
    satp: i64
    mtvec: i64
    mepc: i64
    mcause: i64
    mscratch: i64

    static fn create() -> Rv32CsrFile:
        Rv32CsrFile(satp: 0, mtvec: 0, mepc: 0, mcause: 0, mscratch: 0)

    fn read_satp() -> i64:
        self.satp

    me write_satp(value: i64):
        self.satp = value and 0xFFFFFFFF

    me trap_to(vector: i64, cause: i64, pc: i64):
        self.mtvec = vector and 0xFFFFFFFF
        self.mcause = cause and 0xFFFFFFFF
        self.mepc = pc and 0xFFFFFFFF
