# Generate the repo-native RISC-V FPGA RTL bundle.
#
# Usage:
#   bin/simple run src/hardware/fpga_linux/generate_riscv_fpga_bundle.spl -- <out-dir>
#   bin/simple run src/hardware/fpga_linux/generate_riscv_fpga_bundle.spl -- --board=mlk_s02_100t <out-dir>
#   bin/simple run src/hardware/fpga_linux/generate_riscv_fpga_bundle.spl -- --list-boards

use hardware.fpga_linux.riscv_fpga_linux.{generate_default_riscv_fpga_rtl_bundle, generate_riscv_fpga_rtl_bundle_for_board, known_riscv_fpga_board_ids}

extern fn sys_get_args() -> [text]

fn main() -> i32:
    val args = sys_get_args()
    var out_dir = ""
    var board_id = "xilinx_generic"
    var idx: i64 = 1
    while idx < args.len():
        val arg = args[idx]
        if arg == "--list-boards":
            print known_riscv_fpga_board_ids().join("\n")
            return 0
        elif arg.starts_with("--board="):
            board_id = arg[8:]
        elif arg.starts_with("--"):
            print "error: unknown option {arg}"
            print "usage: bin/simple run src/hardware/fpga_linux/generate_riscv_fpga_bundle.spl -- [--board=<board-id>] <out-dir>"
            print "known boards:"
            print known_riscv_fpga_board_ids().join("\n")
            return 1
        elif arg != "--":
            out_dir = arg
            break
        idx = idx + 1

    if out_dir == "":
        print "usage: bin/simple run src/hardware/fpga_linux/generate_riscv_fpga_bundle.spl -- [--board=<board-id>] <out-dir>"
        print "known boards:"
        print known_riscv_fpga_board_ids().join("\n")
        return 1

    val result = if board_id == "xilinx_generic":
        generate_default_riscv_fpga_rtl_bundle(out_dir)
    else:
        generate_riscv_fpga_rtl_bundle_for_board(out_dir, board_id)
    if result.is_ok():
        print "generated: {out_dir} board={board_id} rv32_default=linux rv64_default=linux"
        return 0
    print "error: {result.unwrap_err()}"
    1
