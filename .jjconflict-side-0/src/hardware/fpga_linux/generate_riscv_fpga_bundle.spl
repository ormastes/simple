use std.cli.cli_util (get_cli_args)
use lib.hardware.fpga_linux.riscv_fpga_linux.{generate_riscv_fpga_rtl_bundle_configured}

fn main() -> i64:
    val args = get_cli_args()
    var output_dir = "/tmp/simple_riscv_fpga_rtl_bundle"
    var board_id = ""
    var product_level = ""
    var profile = ""
    var rv32_luts = 25000
    var rv64_luts = 45000
    var rv32_mhz = 50
    var rv64_mhz = 50
    for arg in args:
        if arg.starts_with("--board="):
            board_id = arg.substring("--board=".len(), arg.len())
        elif arg.starts_with("--product-level="):
            product_level = arg.substring("--product-level=".len(), arg.len())
        elif arg.starts_with("--profile="):
            profile = arg.substring("--profile=".len(), arg.len())
        elif arg.starts_with("--rv32-luts="):
            rv32_luts = arg.substring("--rv32-luts=".len(), arg.len()).to_i64() ?? -1
        elif arg.starts_with("--rv64-luts="):
            rv64_luts = arg.substring("--rv64-luts=".len(), arg.len()).to_i64() ?? -1
        elif arg.starts_with("--rv32-mhz="):
            rv32_mhz = arg.substring("--rv32-mhz=".len(), arg.len()).to_i64() ?? -1
        elif arg.starts_with("--rv64-mhz="):
            rv64_mhz = arg.substring("--rv64-mhz=".len(), arg.len()).to_i64() ?? -1
        else:
            output_dir = arg
    if rv32_luts <= 0 or rv64_luts <= 0 or rv32_mhz <= 0 or rv64_mhz <= 0:
        print "failed to generate RISC-V FPGA RTL bundle: budget values must be positive integers"
        return 1
    val result = generate_riscv_fpga_rtl_bundle_configured(output_dir, board_id, product_level, profile, rv32_luts, rv64_luts, rv32_mhz, rv64_mhz)
    match result:
        Ok(_bundle):
            print "generated RISC-V FPGA RTL bundle: {output_dir}"
            return 0
        Err(message):
            print "failed to generate RISC-V FPGA RTL bundle: {message}"
            return 1
