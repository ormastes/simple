"""
# RV64 Floating-Point Types Package

IEEE 754 constants, rounding modes, and FP result types.
"""

enum RoundMode:
    RNE  # Round to Nearest, ties to Even
    RTZ  # Round Toward Zero
    RDN  # Round Down (toward -inf)
    RUP  # Round Up (toward +inf)
    RMM  # Round to Nearest, ties to Max Magnitude

class FpResult:
    value: i64
    flags: i64

# FP exception flags
val FP_FLAG_NX: i64 = 0x01  # Inexact
val FP_FLAG_UF: i64 = 0x02  # Underflow
val FP_FLAG_OF: i64 = 0x04  # Overflow
val FP_FLAG_DZ: i64 = 0x08  # Divide by zero
val FP_FLAG_NV: i64 = 0x10  # Invalid operation

# Single-precision IEEE 754 constants
val SP_POS_ZERO: i64 = 0x00000000
val SP_NEG_ZERO: i64 = 0x80000000
val SP_POS_INF: i64 = 0x7F800000
val SP_NEG_INF: i64 = 0xFF800000
val SP_QNAN: i64 = 0x7FC00000
val SP_SIGN_MASK: i64 = 0x80000000
val SP_EXP_MASK: i64 = 0x7F800000
val SP_FRAC_MASK: i64 = 0x007FFFFF

# Double-precision IEEE 754 constants
val DP_POS_ZERO: i64 = 0x0000000000000000
val DP_NEG_ZERO: i64 = 0x8000000000000000
val DP_POS_INF: i64 = 0x7FF0000000000000
val DP_NEG_INF: i64 = 0xFFF0000000000000
val DP_QNAN: i64 = 0x7FF8000000000000
val DP_SIGN_MASK: i64 = 0x8000000000000000
val DP_EXP_MASK: i64 = 0x7FF0000000000000
val DP_FRAC_MASK: i64 = 0x000FFFFFFFFFFFFF

# NaN-boxing mask: upper 32 bits all 1s for NaN-boxed single in double reg
val NAN_BOX_MASK: i64 = 0xFFFFFFFF00000000
