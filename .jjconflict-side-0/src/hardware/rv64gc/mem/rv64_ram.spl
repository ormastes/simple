"""
# RV64 RAM — Byte-Addressable Memory Model

Simple byte-addressable RAM with little-endian access.
"""

use hardware.rv64gc.core.rv64_memory.{MemResult, mem_ok, mem_fault}
use hardware.rv64gc.pkg.rv64_types_pkg.{TRAP_LOAD_ACCESS_FAULT, TRAP_STORE_ACCESS_FAULT}

class Rv64Ram:
    data: [i64]      # Stored as bytes (lower 8 bits of each element)
    size: i64        # Size in bytes

    static fn create(size_bytes: i64) -> Rv64Ram:
        var d: [i64] = []
        var i = 0
        while i < size_bytes:
            d = d + [0]
            i = i + 1
        Rv64Ram(data: d, size: size_bytes)

    fn _in_bounds(addr: i64, width: i64) -> bool:
        addr >= 0 and (addr + width) <= self.size

    fn read8(addr: i64) -> MemResult:
        if self._in_bounds(addr, 1):
            mem_ok(self.data[addr] and 0xFF)
        else:
            mem_fault(TRAP_LOAD_ACCESS_FAULT)

    fn read16(addr: i64) -> MemResult:
        """Read 16-bit little-endian."""
        if self._in_bounds(addr, 2):
            val b0 = self.data[addr] and 0xFF
            val b1 = self.data[addr + 1] and 0xFF
            mem_ok(b0 or (b1 << 8))
        else:
            mem_fault(TRAP_LOAD_ACCESS_FAULT)

    fn read32(addr: i64) -> MemResult:
        """Read 32-bit little-endian."""
        if self._in_bounds(addr, 4):
            val b0 = self.data[addr] and 0xFF
            val b1 = self.data[addr + 1] and 0xFF
            val b2 = self.data[addr + 2] and 0xFF
            val b3 = self.data[addr + 3] and 0xFF
            mem_ok(b0 or (b1 << 8) or (b2 << 16) or (b3 << 24))
        else:
            mem_fault(TRAP_LOAD_ACCESS_FAULT)

    fn read64(addr: i64) -> MemResult:
        """Read 64-bit little-endian."""
        if self._in_bounds(addr, 8):
            val b0 = self.data[addr] and 0xFF
            val b1 = self.data[addr + 1] and 0xFF
            val b2 = self.data[addr + 2] and 0xFF
            val b3 = self.data[addr + 3] and 0xFF
            val b4 = self.data[addr + 4] and 0xFF
            val b5 = self.data[addr + 5] and 0xFF
            val b6 = self.data[addr + 6] and 0xFF
            val b7 = self.data[addr + 7] and 0xFF
            mem_ok(b0 or (b1 << 8) or (b2 << 16) or (b3 << 24) or
                   (b4 << 32) or (b5 << 40) or (b6 << 48) or (b7 << 56))
        else:
            mem_fault(TRAP_LOAD_ACCESS_FAULT)

    me write8(addr: i64, value: i64) -> MemResult:
        if self._in_bounds(addr, 1):
            self.data[addr] = value and 0xFF
            mem_ok(0)
        else:
            mem_fault(TRAP_STORE_ACCESS_FAULT)

    me write16(addr: i64, value: i64) -> MemResult:
        """Write 16-bit little-endian."""
        if self._in_bounds(addr, 2):
            self.data[addr] = value and 0xFF
            self.data[addr + 1] = (value >> 8) and 0xFF
            mem_ok(0)
        else:
            mem_fault(TRAP_STORE_ACCESS_FAULT)

    me write32(addr: i64, value: i64) -> MemResult:
        """Write 32-bit little-endian."""
        if self._in_bounds(addr, 4):
            self.data[addr] = value and 0xFF
            self.data[addr + 1] = (value >> 8) and 0xFF
            self.data[addr + 2] = (value >> 16) and 0xFF
            self.data[addr + 3] = (value >> 24) and 0xFF
            mem_ok(0)
        else:
            mem_fault(TRAP_STORE_ACCESS_FAULT)

    me write64(addr: i64, value: i64) -> MemResult:
        """Write 64-bit little-endian."""
        if self._in_bounds(addr, 8):
            self.data[addr] = value and 0xFF
            self.data[addr + 1] = (value >> 8) and 0xFF
            self.data[addr + 2] = (value >> 16) and 0xFF
            self.data[addr + 3] = (value >> 24) and 0xFF
            self.data[addr + 4] = (value >> 32) and 0xFF
            self.data[addr + 5] = (value >> 40) and 0xFF
            self.data[addr + 6] = (value >> 48) and 0xFF
            self.data[addr + 7] = (value >> 56) and 0xFF
            mem_ok(0)
        else:
            mem_fault(TRAP_STORE_ACCESS_FAULT)

    me load_bytes(base_addr: i64, bytes: [i64]):
        """Load an array of bytes into RAM starting at base_addr."""
        var i = 0
        while i < bytes.len():
            val addr = base_addr + i
            if addr < self.size:
                self.data[addr] = bytes[i] and 0xFF
            i = i + 1
