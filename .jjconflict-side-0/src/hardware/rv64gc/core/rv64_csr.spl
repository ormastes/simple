"""
# RV64 CSR File

Full M/S/U Control and Status Register file for RV64GC.
Supports M-mode, S-mode, and FP CSRs with proper masking and delegation.
"""

use hardware.rv64gc.pkg.rv64_csr_addrs.*
use hardware.rv64gc.pkg.rv64_types_pkg.{PrivilegeMode, priv_to_i64, i64_to_priv}

class Rv64CsrFile:
    # M-mode CSRs
    mstatus: i64
    misa: i64
    medeleg: i64
    mideleg: i64
    mie: i64
    mtvec: i64
    mcounteren: i64
    mscratch: i64
    mepc: i64
    mcause: i64
    mtval: i64
    mip: i64
    mcycle: i64
    minstret: i64
    mhartid: i64

    # PMP CSRs (simplified: 2 cfg regs + 16 addr regs)
    pmpcfg0: i64
    pmpcfg2: i64
    pmpaddr: [i64]

    # S-mode CSRs
    stvec: i64
    scounteren: i64
    sscratch: i64
    sepc: i64
    scause: i64
    stval: i64
    satp: i64

    # FP CSRs
    fflags: i64
    frm: i64

    static fn create(hartid: i64) -> Rv64CsrFile:
        var pmp: [i64] = []
        var i = 0
        while i < 16:
            pmp = pmp + [0]
            i = i + 1

        Rv64CsrFile(
            mstatus: 0,
            misa: MISA_RV64GC,
            medeleg: 0,
            mideleg: 0,
            mie: 0,
            mtvec: 0,
            mcounteren: 0,
            mscratch: 0,
            mepc: 0,
            mcause: 0,
            mtval: 0,
            mip: 0,
            mcycle: 0,
            minstret: 0,
            mhartid: hartid,
            pmpcfg0: 0,
            pmpcfg2: 0,
            pmpaddr: pmp,
            stvec: 0,
            scounteren: 0,
            sscratch: 0,
            sepc: 0,
            scause: 0,
            stval: 0,
            satp: 0,
            fflags: 0,
            frm: 0
        )

    # ---------------------------------------------------------------------------
    # Read
    # ---------------------------------------------------------------------------

    fn read(addr: i64) -> i64:
        """Read a CSR by address. Returns 0 for unimplemented CSRs."""
        if addr == CSR_MSTATUS: self.mstatus
        elif addr == CSR_MISA: self.misa
        elif addr == CSR_MEDELEG: self.medeleg
        elif addr == CSR_MIDELEG: self.mideleg
        elif addr == CSR_MIE: self.mie
        elif addr == CSR_MTVEC: self.mtvec
        elif addr == CSR_MCOUNTEREN: self.mcounteren
        elif addr == CSR_MSCRATCH: self.mscratch
        elif addr == CSR_MEPC: self.mepc
        elif addr == CSR_MCAUSE: self.mcause
        elif addr == CSR_MTVAL: self.mtval
        elif addr == CSR_MIP: self.mip
        elif addr == CSR_MCYCLE: self.mcycle
        elif addr == CSR_MINSTRET: self.minstret
        elif addr == CSR_MHARTID: self.mhartid
        elif addr == CSR_PMPCFG0: self.pmpcfg0
        elif addr == CSR_PMPADDR0: self.pmpaddr[0]
        # S-mode
        elif addr == CSR_SSTATUS: self.mstatus and SSTATUS_MASK
        elif addr == CSR_SIE: self.mie and self.mideleg
        elif addr == CSR_STVEC: self.stvec
        elif addr == CSR_SCOUNTEREN: self.scounteren
        elif addr == CSR_SSCRATCH: self.sscratch
        elif addr == CSR_SEPC: self.sepc
        elif addr == CSR_SCAUSE: self.scause
        elif addr == CSR_STVAL: self.stval
        elif addr == CSR_SIP: self.mip and self.mideleg
        elif addr == CSR_SATP: self.satp
        # FP
        elif addr == CSR_FFLAGS: self.fflags
        elif addr == CSR_FRM: self.frm
        elif addr == CSR_FCSR: (self.frm << 5) or self.fflags
        else: 0

    # ---------------------------------------------------------------------------
    # Write
    # ---------------------------------------------------------------------------

    me write(addr: i64, value: i64):
        """Write a CSR by address. Read-only CSRs are silently ignored."""
        if addr == CSR_MSTATUS:
            self.mstatus = value
        elif addr == CSR_MEDELEG:
            self.medeleg = value
        elif addr == CSR_MIDELEG:
            self.mideleg = value
        elif addr == CSR_MIE:
            self.mie = value
        elif addr == CSR_MTVEC:
            self.mtvec = value
        elif addr == CSR_MCOUNTEREN:
            self.mcounteren = value
        elif addr == CSR_MSCRATCH:
            self.mscratch = value
        elif addr == CSR_MEPC:
            self.mepc = value
        elif addr == CSR_MCAUSE:
            self.mcause = value
        elif addr == CSR_MTVAL:
            self.mtval = value
        elif addr == CSR_MIP:
            self.mip = value
        elif addr == CSR_PMPCFG0:
            self.pmpcfg0 = value
        elif addr == CSR_PMPADDR0:
            self.pmpaddr[0] = value
        # S-mode
        elif addr == CSR_SSTATUS:
            val mask = SSTATUS_MASK
            self.mstatus = (self.mstatus and (mask xor 0xFFFFFFFFFFFFFFFF)) or (value and mask)
        elif addr == CSR_SIE:
            val mask = self.mideleg
            self.mie = (self.mie and (mask xor 0xFFFFFFFFFFFFFFFF)) or (value and mask)
        elif addr == CSR_STVEC:
            self.stvec = value
        elif addr == CSR_SCOUNTEREN:
            self.scounteren = value
        elif addr == CSR_SSCRATCH:
            self.sscratch = value
        elif addr == CSR_SEPC:
            self.sepc = value
        elif addr == CSR_SCAUSE:
            self.scause = value
        elif addr == CSR_STVAL:
            self.stval = value
        elif addr == CSR_SIP:
            val mask = self.mideleg
            self.mip = (self.mip and (mask xor 0xFFFFFFFFFFFFFFFF)) or (value and mask)
        elif addr == CSR_SATP:
            self.satp = value
        # FP
        elif addr == CSR_FFLAGS:
            self.fflags = value and 0x1F
        elif addr == CSR_FRM:
            self.frm = value and 0x7
        elif addr == CSR_FCSR:
            self.fflags = value and 0x1F
            self.frm = (value >> 5) and 0x7
        # misa, mhartid, mcycle, minstret are read-only or handled by tick/retire

    # ---------------------------------------------------------------------------
    # Atomic CSR operations
    # ---------------------------------------------------------------------------

    me csrrw(addr: i64, value: i64) -> i64:
        """CSR Read-Write: returns old value, writes new value."""
        val old = self.read(addr)
        self.write(addr, value)
        old

    me csrrs(addr: i64, mask: i64) -> i64:
        """CSR Read-Set: returns old value, sets bits in mask."""
        val old = self.read(addr)
        if mask != 0:
            self.write(addr, old or mask)
        old

    me csrrc(addr: i64, mask: i64) -> i64:
        """CSR Read-Clear: returns old value, clears bits in mask."""
        val old = self.read(addr)
        if mask != 0:
            self.write(addr, old and (mask xor 0xFFFFFFFFFFFFFFFF))
        old

    # ---------------------------------------------------------------------------
    # Trap handling
    # ---------------------------------------------------------------------------

    me trap_enter(cause: i64, tval: i64, pc: i64, target_mode: PrivilegeMode, prev_mode: PrivilegeMode):
        """Enter trap: save context and configure trap state."""
        val prev_priv = priv_to_i64(prev_mode)

        match target_mode:
            PrivilegeMode.Machine:
                self.mepc = pc
                self.mcause = cause
                self.mtval = tval
                # Save MIE to MPIE, clear MIE, set MPP
                val mie_bit = (self.mstatus and MSTATUS_MIE) >> 3
                self.mstatus = self.mstatus and (MSTATUS_MIE xor 0xFFFFFFFFFFFFFFFF)
                self.mstatus = self.mstatus and (MSTATUS_MPIE xor 0xFFFFFFFFFFFFFFFF)
                self.mstatus = self.mstatus or (mie_bit << 7)
                self.mstatus = self.mstatus and (MSTATUS_MPP_MASK xor 0xFFFFFFFFFFFFFFFF)
                self.mstatus = self.mstatus or (prev_priv << MSTATUS_MPP_SHIFT)

            PrivilegeMode.Supervisor:
                self.sepc = pc
                self.scause = cause
                self.stval = tval
                # Save SIE to SPIE, clear SIE, set SPP
                val sie_bit = (self.mstatus and MSTATUS_SIE) >> 1
                self.mstatus = self.mstatus and (MSTATUS_SIE xor 0xFFFFFFFFFFFFFFFF)
                self.mstatus = self.mstatus and (MSTATUS_SPIE xor 0xFFFFFFFFFFFFFFFF)
                self.mstatus = self.mstatus or (sie_bit << 5)
                self.mstatus = self.mstatus and (MSTATUS_SPP xor 0xFFFFFFFFFFFFFFFF)
                if prev_priv >= 1:
                    self.mstatus = self.mstatus or MSTATUS_SPP

            _: pass_dn  # User mode cannot be a trap target

    me trap_return(mode: PrivilegeMode) -> i64:
        """Return from trap. Returns the PC to resume at."""
        match mode:
            PrivilegeMode.Machine:
                # Restore MIE from MPIE, set MPIE=1, set MPP=U
                val mpie = (self.mstatus and MSTATUS_MPIE) >> 7
                self.mstatus = self.mstatus and (MSTATUS_MIE xor 0xFFFFFFFFFFFFFFFF)
                self.mstatus = self.mstatus or (mpie << 3)
                self.mstatus = self.mstatus or MSTATUS_MPIE
                self.mstatus = self.mstatus and (MSTATUS_MPP_MASK xor 0xFFFFFFFFFFFFFFFF)
                self.mepc

            PrivilegeMode.Supervisor:
                val spie = (self.mstatus and MSTATUS_SPIE) >> 5
                self.mstatus = self.mstatus and (MSTATUS_SIE xor 0xFFFFFFFFFFFFFFFF)
                self.mstatus = self.mstatus or (spie << 1)
                self.mstatus = self.mstatus or MSTATUS_SPIE
                self.mstatus = self.mstatus and (MSTATUS_SPP xor 0xFFFFFFFFFFFFFFFF)
                self.sepc

            _: 0  # Cannot xRET from User mode

    fn trap_return_priv(mode: PrivilegeMode) -> PrivilegeMode:
        """Get the privilege mode to return to after xRET."""
        match mode:
            PrivilegeMode.Machine:
                i64_to_priv((self.mstatus and MSTATUS_MPP_MASK) >> MSTATUS_MPP_SHIFT)
            PrivilegeMode.Supervisor:
                if (self.mstatus and MSTATUS_SPP) != 0:
                    PrivilegeMode.Supervisor
                else:
                    PrivilegeMode.User
            _: PrivilegeMode.User

    # ---------------------------------------------------------------------------
    # Cycle / retire counters
    # ---------------------------------------------------------------------------

    me tick():
        """Increment cycle counter (call once per clock cycle)."""
        self.mcycle = self.mcycle + 1

    me retire():
        """Increment instruction-retired counter."""
        self.minstret = self.minstret + 1
