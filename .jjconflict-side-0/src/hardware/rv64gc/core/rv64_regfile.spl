"""
# RV64 Integer Register File

32 × 64-bit general-purpose registers. x0 is hardwired to zero.
"""

class Rv64RegFile:
    regs: [i64]

    static fn create() -> Rv64RegFile:
        var r: [i64] = []
        var i = 0
        while i < 32:
            r = r + [0]
            i = i + 1
        Rv64RegFile(regs: r)

    fn read(idx: i64) -> i64:
        """Read register. x0 always returns 0."""
        if idx == 0: 0
        else: self.regs[idx]

    me write(idx: i64, value: i64):
        """Write register. Writes to x0 are silently discarded."""
        if idx != 0:
            self.regs[idx] = value
