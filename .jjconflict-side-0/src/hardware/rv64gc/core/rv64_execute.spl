#![allow(unnamed_duplicate_typed_args)]
"""
# RV64 ALU Execution

64-bit ALU operations and W-variant (32-bit with sign-extension) operations.
"""

use hardware.riscv_common.pkg.riscv_types_pkg.AluOp

fn _sign_extend_32(val_: i64) -> i64:
    """Sign-extend a 32-bit value to 64 bits."""
    val low32 = val_ and 0xFFFFFFFF
    if (low32 and 0x80000000) != 0:
        low32 or 0xFFFFFFFF00000000
    else:
        low32

fn _unsigned_lt(a: i64, b: i64) -> bool:
    """Unsigned less-than comparison for i64 values."""
    # XOR sign bits to handle unsigned comparison with signed i64
    val a_sign = (a >> 63) and 1
    val b_sign = (b >> 63) and 1
    if a_sign != b_sign:
        a_sign == 0  # If a is "positive" (sign=0) and b is "negative" (sign=1), a < b unsigned
    else:
        a < b

fn alu_execute(op: AluOp, a: i64, b: i64) -> i64:
    """Execute a 64-bit ALU operation."""
    match op:
        AluOp.Add: a + b
        AluOp.Sub: a - b
        AluOp.And: a and b
        AluOp.Or: a or b
        AluOp.Xor: a xor b
        AluOp.Sll:
            val shamt = b and 0x3F
            a << shamt
        AluOp.Srl:
            val shamt = b and 0x3F
            # Logical right shift: mask off sign extension
            if shamt == 0: a
            else:
                val mask = (1 << (64 - shamt)) - 1
                (a >> shamt) and mask
        AluOp.Sra:
            val shamt = b and 0x3F
            a >> shamt  # Arithmetic right shift (preserves sign in Simple)
        AluOp.Slt:
            if a < b: 1 else: 0
        AluOp.Sltu:
            if _unsigned_lt(a, b): 1 else: 0
        AluOp.PassB: b
        _: 0

fn alu_execute_word(op: AluOp, a: i64, b: i64) -> i64:
    """Execute a W-variant (32-bit) ALU operation with sign-extension to 64 bits."""
    val a32 = a and 0xFFFFFFFF
    val b32 = b and 0xFFFFFFFF
    match op:
        AluOp.Addw:
            _sign_extend_32(a32 + b32)
        AluOp.Subw:
            _sign_extend_32(a32 - b32)
        AluOp.Sllw:
            val shamt = b32 and 0x1F
            _sign_extend_32(a32 << shamt)
        AluOp.Srlw:
            val shamt = b32 and 0x1F
            if shamt == 0:
                _sign_extend_32(a32)
            else:
                val mask = (1 << (32 - shamt)) - 1
                _sign_extend_32((a32 >> shamt) and mask)
        AluOp.Sraw:
            val shamt = b32 and 0x1F
            val sa32 = _sign_extend_32(a32)
            _sign_extend_32(sa32 >> shamt)
        _: _sign_extend_32(a32 + b32)  # Default: treat as ADDW
