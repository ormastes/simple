# Unit: Horsepower
# Kind: Power
# Symbol: hp
# Canonical scale: 745.699872 W

class Horsepower:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Horsepower) -> Horsepower: Horsepower(value: self.value + other.value)
    fn sub(other: Horsepower) -> Horsepower: Horsepower(value: self.value - other.value)

    static fn kind() -> text: "Power"
    static fn symbol() -> text: "hp"
    static fn scale_to_base() -> f64: 745.699872
    static fn base_unit() -> text: "W"
    static fn zero() -> Horsepower: Horsepower(value: 0.0)

export Horsepower
