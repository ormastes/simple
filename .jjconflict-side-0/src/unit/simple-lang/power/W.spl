# Unit: Watt
# Kind: Power
# Symbol: W
# Canonical scale: 1.0 W

class Watt:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Watt) -> Watt: Watt(value: self.value + other.value)
    fn sub(other: Watt) -> Watt: Watt(value: self.value - other.value)

    static fn kind() -> text: "Power"
    static fn symbol() -> text: "W"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "W"
    static fn zero() -> Watt: Watt(value: 0.0)

export Watt
