# Unit: Year
# Kind: Time
# Symbol: year
# Canonical scale: 31556952.0 s

class Year:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Year) -> Year: Year(value: self.value + other.value)
    fn sub(other: Year) -> Year: Year(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "year"
    static fn scale_to_base() -> f64: 31556952.0
    static fn base_unit() -> text: "s"
    static fn zero() -> Year: Year(value: 0.0)

export Year
