# Unit: S
# Kind: Time
# Symbol: s
# Canonical scale: 1.0 s

class S:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: S) -> S: S(value: self.value + other.value)
    fn sub(other: S) -> S: S(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "s"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "s"
    static fn zero() -> S: S(value: 0.0)

export S
