# Unit: Decade
# Kind: Time
# Symbol: decade
# Canonical scale: 315569520.0 s

class Decade:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Decade) -> Decade: Decade(value: self.value + other.value)
    fn sub(other: Decade) -> Decade: Decade(value: self.value - other.value)

    static fn kind() -> text: "Time"
    static fn symbol() -> text: "decade"
    static fn scale_to_base() -> f64: 315569520.0
    static fn base_unit() -> text: "s"
    static fn zero() -> Decade: Decade(value: 0.0)

export Decade
