# Unit: Kgf
# Kind: Force
# Symbol: kgf
# Canonical scale: 9.80665 N

class Kgf:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Kgf) -> Kgf: Kgf(value: self.value + other.value)
    fn sub(other: Kgf) -> Kgf: Kgf(value: self.value - other.value)

    static fn kind() -> text: "Force"
    static fn symbol() -> text: "kgf"
    static fn scale_to_base() -> f64: 9.80665
    static fn base_unit() -> text: "N"
    static fn zero() -> Kgf: Kgf(value: 0.0)

export Kgf
