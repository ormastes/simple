# Composite Unit: DegPerS
# Kind: AngularVelocity
# Symbol: deg_per_s
# Scale to SI base: 0.017453292519943295 rad/s

class DegPerS:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: DegPerS) -> DegPerS: DegPerS(value: self.value + other.value)
    fn sub(other: DegPerS) -> DegPerS: DegPerS(value: self.value - other.value)

    static fn kind() -> text: "AngularVelocity"
    static fn symbol() -> text: "deg_per_s"
    static fn scale_to_base() -> f64: 0.017453292519943295
    static fn base_unit() -> text: "rad/s"
    static fn numerator() -> [text]: ["deg"]
    static fn denominator() -> [text]: ["s"]
    static fn zero() -> DegPerS: DegPerS(value: 0.0)

export DegPerS
