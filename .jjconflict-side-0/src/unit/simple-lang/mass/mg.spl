# Unit: Milligram
# Kind: Mass
# Symbol: mg
# Canonical scale: 1e-06 kg

class Milligram:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Milligram) -> Milligram: Milligram(value: self.value + other.value)
    fn sub(other: Milligram) -> Milligram: Milligram(value: self.value - other.value)

    static fn kind() -> text: "Mass"
    static fn symbol() -> text: "mg"
    static fn scale_to_base() -> f64: 1e-06
    static fn base_unit() -> text: "kg"
    static fn zero() -> Milligram: Milligram(value: 0.0)

export Milligram
