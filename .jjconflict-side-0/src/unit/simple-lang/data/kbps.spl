# Unit: Kbps
# Kind: DataRate
# Symbol: kbps
# Canonical scale: 125.0 B/s

class Kbps:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Kbps) -> Kbps: Kbps(value: self.value + other.value)
    fn sub(other: Kbps) -> Kbps: Kbps(value: self.value - other.value)

    static fn kind() -> text: "DataRate"
    static fn symbol() -> text: "kbps"
    static fn scale_to_base() -> f64: 125.0
    static fn base_unit() -> text: "B/s"
    static fn zero() -> Kbps: Kbps(value: 0.0)

export Kbps
