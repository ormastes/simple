# Unit: Km2
# Kind: Area
# Symbol: km2
# Canonical scale: 1000000.0 m2

class Km2:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Km2) -> Km2: Km2(value: self.value + other.value)
    fn sub(other: Km2) -> Km2: Km2(value: self.value - other.value)

    static fn kind() -> text: "Area"
    static fn symbol() -> text: "km2"
    static fn scale_to_base() -> f64: 1000000.0
    static fn base_unit() -> text: "m2"
    static fn zero() -> Km2: Km2(value: 0.0)

export Km2
