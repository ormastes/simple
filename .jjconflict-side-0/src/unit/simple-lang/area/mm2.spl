# Unit: Mm2
# Kind: Area
# Symbol: mm2
# Canonical scale: 1e-06 m2

class Mm2:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Mm2) -> Mm2: Mm2(value: self.value + other.value)
    fn sub(other: Mm2) -> Mm2: Mm2(value: self.value - other.value)

    static fn kind() -> text: "Area"
    static fn symbol() -> text: "mm2"
    static fn scale_to_base() -> f64: 1e-06
    static fn base_unit() -> text: "m2"
    static fn zero() -> Mm2: Mm2(value: 0.0)

export Mm2
