# Unit: Grad
# Kind: Angle
# Symbol: grad
# Canonical scale: 0.015707963267948967 rad

class Grad:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Grad) -> Grad: Grad(value: self.value + other.value)
    fn sub(other: Grad) -> Grad: Grad(value: self.value - other.value)

    static fn kind() -> text: "Angle"
    static fn symbol() -> text: "grad"
    static fn scale_to_base() -> f64: 0.015707963267948967
    static fn base_unit() -> text: "rad"
    static fn zero() -> Grad: Grad(value: 0.0)

export Grad
