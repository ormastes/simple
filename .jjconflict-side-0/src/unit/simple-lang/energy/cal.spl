# Unit: Calorie
# Kind: Energy
# Symbol: cal
# Canonical scale: 4.184 J

class Calorie:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Calorie) -> Calorie: Calorie(value: self.value + other.value)
    fn sub(other: Calorie) -> Calorie: Calorie(value: self.value - other.value)

    static fn kind() -> text: "Energy"
    static fn symbol() -> text: "cal"
    static fn scale_to_base() -> f64: 4.184
    static fn base_unit() -> text: "J"
    static fn zero() -> Calorie: Calorie(value: 0.0)

export Calorie
