# Unit: Hubble
# Kind: Frequency
# Symbol: hubble
# Canonical scale: 2.2e-18 Hz

class Hubble:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Hubble) -> Hubble: Hubble(value: self.value + other.value)
    fn sub(other: Hubble) -> Hubble: Hubble(value: self.value - other.value)

    static fn kind() -> text: "Frequency"
    static fn symbol() -> text: "hubble"
    static fn scale_to_base() -> f64: 2.2e-18
    static fn base_unit() -> text: "Hz"
    static fn zero() -> Hubble: Hubble(value: 0.0)

export Hubble
