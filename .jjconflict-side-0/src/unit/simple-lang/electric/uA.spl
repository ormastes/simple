# Unit: MicroAmp
# Kind: ElectricCurrent
# Symbol: uA
# Canonical scale: 1e-06 A

class MicroAmp:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: MicroAmp) -> MicroAmp: MicroAmp(value: self.value + other.value)
    fn sub(other: MicroAmp) -> MicroAmp: MicroAmp(value: self.value - other.value)

    static fn kind() -> text: "ElectricCurrent"
    static fn symbol() -> text: "uA"
    static fn scale_to_base() -> f64: 1e-06
    static fn base_unit() -> text: "A"
    static fn zero() -> MicroAmp: MicroAmp(value: 0.0)

export MicroAmp
