# Unit: Coulomb
# Kind: ElectricCharge
# Symbol: C
# Canonical scale: 1.0 C

class Coulomb:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Coulomb) -> Coulomb: Coulomb(value: self.value + other.value)
    fn sub(other: Coulomb) -> Coulomb: Coulomb(value: self.value - other.value)

    static fn kind() -> text: "ElectricCharge"
    static fn symbol() -> text: "C"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "C"
    static fn zero() -> Coulomb: Coulomb(value: 0.0)

export Coulomb
