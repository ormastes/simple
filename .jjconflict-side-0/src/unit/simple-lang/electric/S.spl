# Unit: Siemens
# Kind: ElectricConductance
# Symbol: S
# Canonical scale: 1.0 S

class Siemens:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Siemens) -> Siemens: Siemens(value: self.value + other.value)
    fn sub(other: Siemens) -> Siemens: Siemens(value: self.value - other.value)

    static fn kind() -> text: "ElectricConductance"
    static fn symbol() -> text: "S"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "S"
    static fn zero() -> Siemens: Siemens(value: 0.0)

export Siemens
