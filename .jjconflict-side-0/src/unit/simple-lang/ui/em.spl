# Unit: Em
# Kind: UiLength
# Symbol: em
# Canonical scale: 16.0 px

class Em:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Em) -> Em: Em(value: self.value + other.value)
    fn sub(other: Em) -> Em: Em(value: self.value - other.value)

    static fn kind() -> text: "UiLength"
    static fn symbol() -> text: "em"
    static fn scale_to_base() -> f64: 16.0
    static fn base_unit() -> text: "px"
    static fn zero() -> Em: Em(value: 0.0)

export Em
