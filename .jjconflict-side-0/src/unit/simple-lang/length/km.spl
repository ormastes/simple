# Unit: Km
# Kind: Length
# Symbol: km
# Canonical scale: 1000.0 m

class Km:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Km) -> Km: Km(value: self.value + other.value)
    fn sub(other: Km) -> Km: Km(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "km"
    static fn scale_to_base() -> f64: 1000.0
    static fn base_unit() -> text: "m"
    static fn zero() -> Km: Km(value: 0.0)

export Km
