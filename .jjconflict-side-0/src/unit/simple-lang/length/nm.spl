# Unit: Nanometre
# Kind: Length
# Symbol: nm
# Canonical scale: 1e-09 m

class Nanometre:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Nanometre) -> Nanometre: Nanometre(value: self.value + other.value)
    fn sub(other: Nanometre) -> Nanometre: Nanometre(value: self.value - other.value)

    static fn kind() -> text: "Length"
    static fn symbol() -> text: "nm"
    static fn scale_to_base() -> f64: 1e-09
    static fn base_unit() -> text: "m"
    static fn zero() -> Nanometre: Nanometre(value: 0.0)

export Nanometre
