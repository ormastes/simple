# Unit: Tsp
# Kind: Volume
# Symbol: tsp
# Canonical scale: 4.92892e-06 m3

class Tsp:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Tsp) -> Tsp: Tsp(value: self.value + other.value)
    fn sub(other: Tsp) -> Tsp: Tsp(value: self.value - other.value)

    static fn kind() -> text: "Volume"
    static fn symbol() -> text: "tsp"
    static fn scale_to_base() -> f64: 4.92892e-06
    static fn base_unit() -> text: "m3"
    static fn zero() -> Tsp: Tsp(value: 0.0)

export Tsp
