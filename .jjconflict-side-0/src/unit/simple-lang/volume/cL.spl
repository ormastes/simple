# Unit: ClVol
# Kind: Volume
# Symbol: cL
# Canonical scale: 1e-05 m3

class ClVol:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: ClVol) -> ClVol: ClVol(value: self.value + other.value)
    fn sub(other: ClVol) -> ClVol: ClVol(value: self.value - other.value)

    static fn kind() -> text: "Volume"
    static fn symbol() -> text: "cL"
    static fn scale_to_base() -> f64: 1e-05
    static fn base_unit() -> text: "m3"
    static fn zero() -> ClVol: ClVol(value: 0.0)

export ClVol
