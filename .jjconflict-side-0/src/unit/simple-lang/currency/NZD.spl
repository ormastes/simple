# Unit: Nzd
# Kind: Currency
# Symbol: NZD
# Canonical scale: 1.0 USD

class Nzd:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Nzd) -> Nzd: Nzd(value: self.value + other.value)
    fn sub(other: Nzd) -> Nzd: Nzd(value: self.value - other.value)

    static fn kind() -> text: "Currency"
    static fn symbol() -> text: "NZD"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "USD"
    static fn zero() -> Nzd: Nzd(value: 0.0)

export Nzd
