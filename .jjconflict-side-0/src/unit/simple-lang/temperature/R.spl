# Unit: Rankine
# Kind: Temperature
# Symbol: R
# Canonical scale: 0.5555555555555556 K

class Rankine:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Rankine) -> Rankine: Rankine(value: self.value + other.value)
    fn sub(other: Rankine) -> Rankine: Rankine(value: self.value - other.value)

    static fn kind() -> text: "Temperature"
    static fn symbol() -> text: "R"
    static fn scale_to_base() -> f64: 0.5555555555555556
    static fn base_unit() -> text: "K"
    static fn zero() -> Rankine: Rankine(value: 0.0)

export Rankine
