# Unit: Ppi
# Kind: GraphicsDensity
# Symbol: ppi
# Canonical scale: 1.0 dpi

class Ppi:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Ppi) -> Ppi: Ppi(value: self.value + other.value)
    fn sub(other: Ppi) -> Ppi: Ppi(value: self.value - other.value)

    static fn kind() -> text: "GraphicsDensity"
    static fn symbol() -> text: "ppi"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "dpi"
    static fn zero() -> Ppi: Ppi(value: 0.0)

export Ppi
