# Unit: Px
# Kind: Graphics
# Symbol: px
# Canonical scale: 1.0 px

class Px:
    value: f64

    fn to_f64() -> f64: self.value
    fn add(other: Px) -> Px: Px(value: self.value + other.value)
    fn sub(other: Px) -> Px: Px(value: self.value - other.value)

    static fn kind() -> text: "Graphics"
    static fn symbol() -> text: "px"
    static fn scale_to_base() -> f64: 1.0
    static fn base_unit() -> text: "px"
    static fn zero() -> Px: Px(value: 0.0)

export Px
