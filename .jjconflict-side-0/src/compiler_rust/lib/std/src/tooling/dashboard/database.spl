# Dashboard Database Compatibility Layer
#
# Minimal runtime-safe dashboard database used by app-local dashboard
# entrypoints when the interpreter is launched with `SIMPLE_LIB=src`.

use tooling.dashboard.types.{DashboardData, VcsState}

class DashboardDatabase:
    static fn new() -> DashboardDatabase:
        return DashboardDatabase {}

    fn write_all(data: DashboardData) -> Result<(), text>:
        val _ = data
        return Ok(())

    fn read_all() -> Result<DashboardData, text>:
        val timestamp = "1970-01-01T00:00:00Z"
        val vcs_state = VcsState.new("", "", "", 0, 0, timestamp)
        return Ok(DashboardData.new(
            [],
            [],
            [],
            [],
            [],
            [],
            [],
            vcs_state,
            [],
            [],
            [],
            timestamp
        ))
