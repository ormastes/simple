# Matchers package — re-exports from submodules
# Uses `export X from Y` so the symbols resolve at merge time.

# Core matchers (core.spl)
export eq from core
export be from core
export be_nil from core
export EqMatcher from core
export BeMatcher from core
export BeNilMatcher from core

# Boolean matchers (boolean.spl)
export be_true from boolean
export be_false from boolean
export be_truthy from boolean
export be_falsy from boolean
export BeTrueMatcher from boolean
export BeFalseMatcher from boolean
export BeTruthyMatcher from boolean
export BeFalsyMatcher from boolean

# Comparison matchers (comparison.spl)
export gt from comparison
export lt from comparison
export gte from comparison
export lte from comparison
export GtMatcher from comparison
export LtMatcher from comparison
export GteMatcher from comparison
export LteMatcher from comparison

# Collection matchers (collection.spl)
export include from collection
export be_empty from collection
export have_length from collection
export have_size from collection
export IncludeMatcher from collection
export BeEmptyMatcher from collection
export HaveLengthMatcher from collection

# String matchers (string.spl)
export include_string from string
export start_with from string
export end_with from string
export be_blank from string
export IncludeStringMatcher from string
export StartWithMatcher from string
export EndWithMatcher from string
export BeBlankMatcher from string

# Error matchers (error.spl)
export raise_error from error
export RaiseErrorMatcher from error

# Type matchers (type.spl)
export be_instance_of from type
export be_a from type
export be_an from type
export be_option from type
export be_result from type
export BeInstanceOfMatcher from type
export BeOptionMatcher from type
export BeResultMatcher from type
