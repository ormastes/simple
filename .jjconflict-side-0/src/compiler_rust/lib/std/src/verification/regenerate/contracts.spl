# Contracts - Contract system verification
# Generates Lean verification for design by contract

use verification.lean.codegen as codegen

fn regenerate_contracts() -> text:
    var codegen_ = codegen.LeanCodegen.create("Contracts")

    codegen_ = codegen_.add_namespace("Contracts")
    codegen_ = codegen_.add_doc_comment("Contracts.lean - Reduced formal model for contract verification")

    codegen_ = codegen_.add_raw_line("inductive Val")
    codegen_ = codegen_.add_raw_line("  | i32 : Int → Val")
    codegen_ = codegen_.add_raw_line("  | bool : Bool → Val")
    codegen_ = codegen_.add_raw_line("  | str : String → Val")
    codegen_ = codegen_.add_raw_line("  | nil")
    codegen_ = codegen_.add_raw_line("  | error : String → Val → Val")
    codegen_ = codegen_.add_raw_line("deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("inductive ContractExpr")
    codegen_ = codegen_.add_raw_line("  | val : Val → ContractExpr")
    codegen_ = codegen_.add_raw_line("  | var : String → ContractExpr")
    codegen_ = codegen_.add_raw_line("  | old : ContractExpr → ContractExpr")
    codegen_ = codegen_.add_raw_line("  | ret")
    codegen_ = codegen_.add_raw_line("  | err")
    codegen_ = codegen_.add_raw_line("  | binOp : String → ContractExpr → ContractExpr → ContractExpr")
    codegen_ = codegen_.add_raw_line("  | unOp : String → ContractExpr → ContractExpr")
    codegen_ = codegen_.add_raw_line("deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("structure ContractClause where")
    codegen_ = codegen_.add_raw_line("  condition : ContractExpr")
    codegen_ = codegen_.add_raw_line("  message : Option String")
    codegen_ = codegen_.add_raw_line("  deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_raw_line("structure FunctionContract where")
    codegen_ = codegen_.add_raw_line("  preconditions : List ContractClause")
    codegen_ = codegen_.add_raw_line("  invariants : List ContractClause")
    codegen_ = codegen_.add_raw_line("  postconditions : List ContractClause")
    codegen_ = codegen_.add_raw_line("  errorPostconditions : List ContractClause")
    codegen_ = codegen_.add_raw_line("  deriving Repr, Inhabited")
    codegen_ = codegen_.add_blank()

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "empty_contract_has_no_preconditions",
        [("fc", "FunctionContract")],
        "fc.preconditions = [] → fc.preconditions = []",
        "intro h\nexact h"
    ))

    codegen_ = codegen_.add_theorem(codegen.build_theorem(
        "empty_contract_has_no_postconditions",
        [("fc", "FunctionContract")],
        "fc.postconditions = [] → fc.postconditions = []",
        "intro h\nexact h"
    ))

    codegen_ = codegen_.end_namespace("Contracts")
    return codegen_.emit()
