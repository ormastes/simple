# Lean Block Model
# Represents an embedded lean{} block from Simple source.
#
# A lean{} block allows users to write raw Lean 4 code inline within Simple
# source files. The block content is extracted, validated for namespace
# collisions, and merged into the generated Lean output.

# Placement context for a lean{} block
enum LeanBlockPlacement:
    ModuleLevel    # Top-level namespace
    FunctionLevel  # After contract, within function scope
    TypeLevel      # Within type/struct definition

class LeanBlock:
    source_file: text           # Originating .spl file
    source_line: i32            # Line number in source
    placement: LeanBlockPlacement
    imports: List<text>         # Lean import statements within the block
    body: text                  # Raw Lean content
    theorem_names: List<text>   # Theorems declared in this block
    namespace: Option<text>     # Optional explicit namespace

    static fn create(source_file: text, source_line: i32, placement: LeanBlockPlacement, body: text) -> LeanBlock:
        val theorems = LeanBlock.extract_theorem_names(body)
        val imps = LeanBlock.extract_imports(body)
        LeanBlock(
            source_file: source_file,
            source_line: source_line,
            placement: placement,
            imports: imps,
            body: body,
            theorem_names: theorems,
            namespace: nil
        )

    # Extract theorem names from body text.
    # Scans for lines starting with "theorem " followed by an identifier.
    static fn extract_theorem_names(body: text) -> List<text>:
        var names: List<text> = []
        for line in body.split("\n"):
            val trimmed = line.trim()
            if trimmed.starts_with("theorem "):
                val rest = trimmed.slice(8, trimmed.len())
                # Extract the name (first word after "theorem ")
                var name = ""
                for ch in rest.chars():
                    if ch == ' ' or ch == '(' or ch == ':' or ch == '{':
                        break
                    name = name + ch.to_text()
                if name.len() > 0:
                    names = names + [name]
        names

    # Extract import lines from body text.
    # Scans for lines starting with "import ".
    static fn extract_imports(body: text) -> List<text>:
        var imps: List<text> = []
        for line in body.split("\n"):
            val trimmed = line.trim()
            if trimmed.starts_with("import "):
                val import_path = trimmed.slice(7, trimmed.len()).trim()
                if import_path.len() > 0:
                    imps = imps + [import_path]
        imps

    # Set an explicit namespace for this block
    me with_namespace(ns: text) -> LeanBlock:
        self.namespace = Some(ns)
        self
