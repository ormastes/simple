# Proof Reference Resolution
# Maps source @verify functions to external Lean proof modules.
#
# When a Simple function is annotated with `proof uses: theorem_name`,
# this module resolves that reference to a concrete .lean file containing
# the handwritten proof. It also detects collisions between generated
# (auto) theorems and user-supplied handwritten theorems.

use io.fs as fs

# Result status for a proof reference resolution attempt
enum ProofRefStatus:
    Found       # Proof file located successfully
    NotFound    # No matching proof file in search paths
    Ambiguous   # Multiple candidate files found

# A collision between a generated and handwritten theorem
class CollisionError:
    theorem_name: text          # The colliding theorem name
    generated_source: text      # File:line of the generated theorem origin
    handwritten_source: text    # File:line of the handwritten theorem origin
    message: text               # Human-readable error message

    static fn create(theorem_name: text, generated_source: text, handwritten_source: text) -> CollisionError:
        val msg = "Collision: theorem '{theorem_name}' defined in both generated output ({generated_source}) and handwritten proof ({handwritten_source})"
        CollisionError(
            theorem_name: theorem_name,
            generated_source: generated_source,
            handwritten_source: handwritten_source,
            message: msg
        )

# Result of resolving a single proof reference
class ProofRefResult:
    reference: ProofReference
    status: ProofRefStatus
    resolved_path: Option<text>   # Set when status == Found
    candidates: List<text>        # Set when status == Ambiguous (all matches)
    error_message: Option<text>   # Set when status != Found

    static fn found(ref: ProofReference, path: text) -> ProofRefResult:
        ProofRefResult(
            reference: ref,
            status: ProofRefStatus.Found,
            resolved_path: Some(path),
            candidates: [],
            error_message: nil
        )

    static fn not_found(ref: ProofReference, search_paths: List<text>) -> ProofRefResult:
        val paths_str = search_paths.join(", ")
        val msg = "Proof for theorem '{ref.theorem_name}' not found in search paths: [{paths_str}]"
        ProofRefResult(
            reference: ref,
            status: ProofRefStatus.NotFound,
            resolved_path: nil,
            candidates: [],
            error_message: Some(msg)
        )

    static fn ambiguous(ref: ProofReference, candidates: List<text>) -> ProofRefResult:
        val cands_str = candidates.join(", ")
        val msg = "Ambiguous proof for theorem '{ref.theorem_name}': found in multiple files: [{cands_str}]"
        ProofRefResult(
            reference: ref,
            status: ProofRefStatus.Ambiguous,
            resolved_path: nil,
            candidates: candidates,
            error_message: Some(msg)
        )

# A single proof reference from source annotations
class ProofReference:
    source_symbol: text      # Simple function/type name
    theorem_name: text       # Referenced theorem
    proof_module: text       # Lean module containing the proof
    proof_file: text         # Filesystem path to proof .lean file

    static fn create(source_symbol: text, theorem_name: text) -> ProofReference:
        ProofReference(
            source_symbol: source_symbol,
            theorem_name: theorem_name,
            proof_module: "",
            proof_file: ""
        )

# Resolver that finds proof files for registered references
class ProofRefResolver:
    references: List<ProofReference>
    search_paths: List<text>   # Directories to search for proof files

    static fn new(search_paths: List<text>) -> ProofRefResolver:
        ProofRefResolver(references: [], search_paths: search_paths)

    # Register a proof reference from "proof uses: theorem_name"
    me register(source_symbol: text, theorem_name: text) -> ProofRefResolver:
        val ref = ProofReference.create(source_symbol, theorem_name)
        self.references = self.references + [ref]
        self

    # Resolve all references -- find proof files in search paths
    fn resolve_all(self) -> List<ProofRefResult>:
        var results: List<ProofRefResult> = []
        for ref in self.references:
            val result = self.resolve_one(ref)
            results = results + [result]
        results

    # Resolve a single reference by searching for .lean files containing the theorem
    fn resolve_one(self, ref: ProofReference) -> ProofRefResult:
        var candidates: List<text> = []
        for dir in self.search_paths:
            val lean_files = fs.list_dir(dir)
            for file_name in lean_files:
                if file_name.ends_with(".lean"):
                    val full_path = "{dir}/{file_name}"
                    val content = fs.read_text(full_path)
                    if content.contains("theorem {ref.theorem_name}"):
                        candidates = candidates + [full_path]
        match candidates.len():
            case 0: ProofRefResult.not_found(ref, self.search_paths)
            case 1: ProofRefResult.found(ref, candidates[0])
            case _: ProofRefResult.ambiguous(ref, candidates)

    # Check for collisions between generated and handwritten theorems.
    # Returns a list of CollisionError for any theorem name present in both lists.
    static fn check_collisions(generated_theorems: List<text>, handwritten_theorems: List<text>) -> List<CollisionError>:
        var errors: List<CollisionError> = []
        for gen_name in generated_theorems:
            for hw_name in handwritten_theorems:
                if gen_name == hw_name:
                    val err = CollisionError.create(
                        theorem_name: gen_name,
                        generated_source: "<generated>",
                        handwritten_source: "<handwritten>"
                    )
                    errors = errors + [err]
        errors

    # Check collisions with source location information
    static fn check_collisions_with_sources(
        generated_theorems: List<(text, text)>,
        handwritten_theorems: List<(text, text)>
    ) -> List<CollisionError>:
        var errors: List<CollisionError> = []
        for (gen_name, gen_source) in generated_theorems:
            for (hw_name, hw_source) in handwritten_theorems:
                if gen_name == hw_name:
                    val err = CollisionError.create(
                        theorem_name: gen_name,
                        generated_source: gen_source,
                        handwritten_source: hw_source
                    )
                    errors = errors + [err]
        errors
