{
    "llvm-target": "armv7-unknown-none-eabihf",
    "data-layout": "e-m:e-p:32:32-Fi8-i64:64-v128:64:128-a:0:32-n32-S64",
    "arch": "arm",
    "target-endian": "little",
    "target-pointer-width": "32",
    "target-c-int-width": "32",
    "os": "none",
    "env": "eabihf",
    "vendor": "unknown",
    "linker-flavor": "gnu-lld-cc",
    "linker": "clang",
    "pre-link-args": {
        "gnu-lld-cc": [
            "-target", "armv7-unknown-none-eabihf",
            "-nostdlib",
            "-ffreestanding",
            "-fuse-ld=lld"
        ]
    },
    "post-link-args": {
        "gnu-lld-cc": [
            "-lsimpleos_c"
        ]
    },
    "features": "+v7,+vfp3,+d16,+thumb2,-neon",
    "executables": true,
    "has-thread-local": false,
    "panic-strategy": "abort",
    "relocation-model": "static",
    "code-model": "small",
    "emit-debug-gdb-scripts": false,
    "eh-frame-header": false,
    "exe-suffix": "",
    "max-atomic-width": 32,
    "stack-probes": { "kind": "none" },
    "supported-sanitizers": [],
    "singlethread": true
}
