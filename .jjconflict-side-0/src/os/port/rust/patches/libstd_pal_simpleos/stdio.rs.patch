//! Target: `library/std/src/sys/pal/simpleos/stdio.rs`
//!
//! Re-exports the `Stdin`/`Stdout`/`Stderr` types from `io.rs` under the
//! names `sys::stdio` expects. Matches the shape of `sys/pal/unix/stdio.rs`.

pub use crate::sys::io::{panic_output, Stderr, Stdin, Stdout, STDIN_BUF_SIZE};

/// True when the corresponding fd is connected to a terminal. SimpleOS has
/// no isatty syscall yet — return `false` unconditionally.
pub fn is_ebadf(err: &crate::io::Error) -> bool { crate::sys::io::is_ebadf(err) }
