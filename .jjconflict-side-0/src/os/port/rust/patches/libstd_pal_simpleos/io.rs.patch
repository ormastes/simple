//! Target: `library/std/src/sys/pal/simpleos/io.rs`
//!
//! Stdin / Stdout / Stderr wired to libsimpleos_c `read`/`write` against
//! fd 0, 1, 2. Single-threaded — no locking beyond what libstd wraps on top.

use crate::io::{self, BorrowedCursor, IoSlice, IoSliceMut};

const STDIN_FILENO: i32 = 0;
const STDOUT_FILENO: i32 = 1;
const STDERR_FILENO: i32 = 2;

unsafe extern "C" {
    fn read(fd: i32, buf: *mut u8, count: usize) -> isize;
    fn write(fd: i32, buf: *const u8, count: usize) -> isize;
}

fn errno_result<T>() -> io::Result<T> {
    Err(io::Error::from(io::ErrorKind::Other))
}

pub struct Stdin;
pub struct Stdout;
pub struct Stderr;

impl Stdin {
    pub const fn new() -> Stdin {
        Stdin
    }
}

impl io::Read for Stdin {
    fn read(&mut self, buf: &mut [u8]) -> io::Result<usize> {
        let n = unsafe { read(STDIN_FILENO, buf.as_mut_ptr(), buf.len()) };
        if n < 0 { errno_result() } else { Ok(n as usize) }
    }

    fn read_buf(&mut self, mut cursor: BorrowedCursor<'_>) -> io::Result<()> {
        let n = unsafe { read(STDIN_FILENO, cursor.as_mut().as_mut_ptr() as *mut u8, cursor.capacity()) };
        if n < 0 {
            return errno_result();
        }
        // SAFETY: kernel promised it wrote `n` bytes into our buffer.
        unsafe { cursor.advance_unchecked(n as usize) };
        Ok(())
    }

    fn read_vectored(&mut self, bufs: &mut [IoSliceMut<'_>]) -> io::Result<usize> {
        let mut total = 0;
        for b in bufs {
            let got = self.read(b)?;
            total += got;
            if got < b.len() { break; }
        }
        Ok(total)
    }

    fn is_read_vectored(&self) -> bool { false }
}

impl Stdout {
    pub const fn new() -> Stdout { Stdout }
}

impl io::Write for Stdout {
    fn write(&mut self, buf: &[u8]) -> io::Result<usize> {
        let n = unsafe { write(STDOUT_FILENO, buf.as_ptr(), buf.len()) };
        if n < 0 { errno_result() } else { Ok(n as usize) }
    }

    fn write_vectored(&mut self, bufs: &[IoSlice<'_>]) -> io::Result<usize> {
        let mut total = 0;
        for b in bufs {
            let put = self.write(b)?;
            total += put;
            if put < b.len() { break; }
        }
        Ok(total)
    }

    fn is_write_vectored(&self) -> bool { false }

    fn flush(&mut self) -> io::Result<()> { Ok(()) }
}

impl Stderr {
    pub const fn new() -> Stderr { Stderr }
}

impl io::Write for Stderr {
    fn write(&mut self, buf: &[u8]) -> io::Result<usize> {
        let n = unsafe { write(STDERR_FILENO, buf.as_ptr(), buf.len()) };
        if n < 0 { errno_result() } else { Ok(n as usize) }
    }

    fn write_vectored(&mut self, bufs: &[IoSlice<'_>]) -> io::Result<usize> {
        let mut total = 0;
        for b in bufs {
            let put = self.write(b)?;
            total += put;
            if put < b.len() { break; }
        }
        Ok(total)
    }

    fn is_write_vectored(&self) -> bool { false }

    fn flush(&mut self) -> io::Result<()> { Ok(()) }
}

pub const STDIN_BUF_SIZE: usize = 128;

pub fn is_ebadf(err: &io::Error) -> bool {
    matches!(err.kind(), io::ErrorKind::BrokenPipe | io::ErrorKind::Other)
}

pub fn panic_output() -> Option<impl io::Write> {
    Some(Stderr::new())
}
