fn simpleos_platform_target_matches(target: SimpleOsPlatformBuildTarget, name: text) -> bool:
    if target.name == name:
        return true
    if target.native_target == name:
        return true
    if target.clang_target == name:
        return true
    for alias in target.aliases:
        if alias == name:
            return true
    false

fn simpleos_platform_target_by_name(name: text) -> SimpleOsPlatformBuildTarget?:
    """Resolve a SimpleOS platform target by canonical name, triple, or alias."""
    for target in simpleos_platform_targets():
        if simpleos_platform_target_matches(target, name):
            return target
    nil

fn simpleos_platform_target_names() -> [text]:
    """Return canonical SimpleOS platform target names."""
    var names: [text] = []
    for target in simpleos_platform_targets():
        names.push(target.name)
    names

fn simpleos_platform_artifact_slug(name: text) -> text:
    if val target = simpleos_platform_target_by_name(name):
        return target.platform_slug
    "unknown"

