    if val target = simpleos_platform_target_by_name(name):
        return target.qemu_acceptance_lane
    simpleos_platform_qemu_smoke_lane(name)

fn simpleos_platform_qemu_additional_lanes(name: text) -> [SimpleOsLaneContract]:
    if val target = simpleos_platform_target_by_name(name):
        return target.qemu_additional_lanes
    []

fn simpleos_platform_qemu_lane(name: text, lane_name: text) -> SimpleOsLaneContract?:
    if val target = simpleos_platform_target_by_name(name):
        if target.qemu_smoke_lane.name == lane_name:
            return target.qemu_smoke_lane
        if target.qemu_acceptance_lane.name == lane_name:
            return target.qemu_acceptance_lane
        for lane in target.qemu_additional_lanes:
            if lane.name == lane_name:
                return lane
    nil

fn simpleos_platform_qemu_lanes(name: text) -> [SimpleOsLaneContract]:
    if val target = simpleos_platform_target_by_name(name):
        var lanes = [target.qemu_smoke_lane]
        if target.qemu_acceptance_lane.name != target.qemu_smoke_lane.name:
            lanes.push(target.qemu_acceptance_lane)
        for lane in target.qemu_additional_lanes:
            lanes.push(lane)
        return lanes
    []

fn simpleos_platform_qemu_acceptance_required_markers(name: text) -> [text]:
    simpleos_platform_qemu_acceptance_lane(name).required_serial_markers

fn simpleos_platform_qemu_acceptance_timeout_ms(name: text) -> i64:
    simpleos_platform_qemu_acceptance_lane(name).timeout_ms

fn simpleos_platform_board_lane(name: text) -> SimpleOsLaneContract?:
    if val target = simpleos_platform_target_by_name(name):
        return target.board_lane
    nil
