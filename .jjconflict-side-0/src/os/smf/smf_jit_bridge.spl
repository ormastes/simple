class SmfSource:
    source_kind: text
    module_path: text
    export_count: int
    import_count: int

    me is_file() -> bool:
        return self.source_kind == "file"

    me is_jit() -> bool:
        return self.source_kind == "jit"

    me is_remote() -> bool:
        return self.source_kind == "remote"

    me total_symbols() -> int:
        return self.export_count + self.import_count

    me to_text() -> text:
        return "source:" + self.source_kind + " path=" + self.module_path + " exports=" + self.export_count.to_text()

    static fn from_file(path: text, exports: int, imports: int) -> SmfSource:
        return SmfSource { source_kind: "file", module_path: path, export_count: exports, import_count: imports }

    static fn from_jit(path: text, exports: int, imports: int) -> SmfSource:
        return SmfSource { source_kind: "jit", module_path: path, export_count: exports, import_count: imports }

    static fn from_remote(path: text, exports: int, imports: int) -> SmfSource:
        return SmfSource { source_kind: "remote", module_path: path, export_count: exports, import_count: imports }


class ExportMetadata:
    symbol_name: text
    symbol_type: text
    offset: int
    is_public: bool

    me is_fn_export() -> bool:
        return self.symbol_type == "fn"

    me is_data() -> bool:
        return self.symbol_type == "data"

    me to_text() -> text:
        return "export:" + self.symbol_name + " type=" + self.symbol_type + " public=" + self.is_public.to_text()

    static fn public_fn(name: text, off: int) -> ExportMetadata:
        return ExportMetadata { symbol_name: name, symbol_type: "fn", offset: off, is_public: true }

    static fn private_data(name: text, off: int) -> ExportMetadata:
        return ExportMetadata { symbol_name: name, symbol_type: "data", offset: off, is_public: false }


class ImportMetadata:
    symbol_name: text
    required_module: text
    is_resolved: bool
    resolved_offset: int

    me is_pending() -> bool:
        return self.is_resolved == false

    me resolve(offset: int) -> ImportMetadata:
        return ImportMetadata { symbol_name: self.symbol_name, required_module: self.required_module, is_resolved: true, resolved_offset: offset }

    me to_text() -> text:
        return "import:" + self.symbol_name + " from=" + self.required_module + " resolved=" + self.is_resolved.to_text()

    static fn create(sym: text, mod_name: text) -> ImportMetadata:
        return ImportMetadata { symbol_name: sym, required_module: mod_name, is_resolved: false, resolved_offset: 0 }


class JitManifest:
    manifest_id: int
    candidate_count: int
    upload_size: int
    is_local: bool

    me is_remote_upload() -> bool:
        return self.is_local == false

    me to_text() -> text:
        return "manifest[" + self.manifest_id.to_text() + "] candidates=" + self.candidate_count.to_text() + " size=" + self.upload_size.to_text()

    static fn local(mid: int, candidates: int, size: int) -> JitManifest:
        return JitManifest { manifest_id: mid, candidate_count: candidates, upload_size: size, is_local: true }

    static fn remote(mid: int, candidates: int, size: int) -> JitManifest:
        return JitManifest { manifest_id: mid, candidate_count: candidates, upload_size: size, is_local: false }
