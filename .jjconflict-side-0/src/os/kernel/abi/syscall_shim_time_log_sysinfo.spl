# Time, log, and sysinfo syscall shims — split from syscall_shim.spl (Wave 10F).
# Contains spl_handle_* for clock_gettime (50), sleep (51),
# log_write (90), log_read (91), sysinfo (95), get_hostname (96), set_hostname (97).

use os.kernel.types.syscall_types.{SyscallArgs, SyscallResult}
use os.kernel.ipc.syscall.{_handle_clock_get_time}
use os.kernel.ipc.syscall.{_handle_sleep}
use os.kernel.ipc.syscall.{_handle_log_write}
use os.kernel.ipc.syscall.{_handle_log_read}
use os.kernel.ipc.syscall.{_handle_sysinfo}
use os.kernel.ipc.syscall.{_handle_get_hostname}
use os.kernel.ipc.syscall.{_handle_set_hostname}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.log.klog.{KernelLog}
use os.kernel.abi.syscall_shim.{g_shim_scheduler, g_shim_klog, _make_args}

# ===========================================================================
# syscall 50 — clock_gettime   [IMPLEMENTED]
#
# a0 = clock ID (CLOCK_MONOTONIC=0, CLOCK_REALTIME=1, etc.)
# a1 = pointer to output timespec struct (user VA)
# a2..a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_clock_gettime")
fn spl_handle_clock_gettime(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_clock_gettime stub.

    Forwards to _handle_clock_get_time() in syscall.spl.
    Syscall number 50: read a kernel clock (monotonic or wall-clock).
    """
    val args = _make_args(50, a0, a1, a2, a3, a4, a5)
    val result = _handle_clock_get_time(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 51 — sleep   [IMPLEMENTED]
#
# a0 = sleep duration in nanoseconds
# a1..a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_sleep")
fn spl_handle_sleep(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_sleep stub.

    Forwards to _handle_sleep() in syscall.spl.
    Syscall number 51: suspend the calling task for the given duration.
    """
    val args = _make_args(51, a0, a1, a2, a3, a4, a5)
    val result = _handle_sleep(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 90 — log_write   [IMPLEMENTED]
#
# a0 = log level (0=TRACE, 1=DEBUG, 2=INFO, 3=WARN, 4=ERROR)
# a1 = pointer to message string (user VA)
# a2 = message length in bytes
# a3..a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_log_write")
fn spl_handle_log_write(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_log_write stub.

    Forwards to _handle_log_write() in syscall.spl.
    Syscall number 90: write a structured log entry to the kernel log ring.
    """
    val args = _make_args(90, a0, a1, a2, a3, a4, a5)
    val result = _handle_log_write(args, g_shim_scheduler, g_shim_klog)
    result.value

# ===========================================================================
# syscall 91 — log_read   [IMPLEMENTED]
#
# a0 = pointer to output buffer (user VA)
# a1 = buffer capacity in bytes
# a2 = start sequence number (0 = oldest available)
# a3..a5 unused
# returns bytes written to buffer, or negative errno
# ===========================================================================
@export("C", name: "spl_handle_log_read")
fn spl_handle_log_read(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_log_read stub.

    Forwards to _handle_log_read() in syscall.spl.
    Syscall number 91: read entries from the kernel log ring buffer.
    """
    val args = _make_args(91, a0, a1, a2, a3, a4, a5)
    val result = _handle_log_read(args, g_shim_klog)
    result.value

# ===========================================================================
# syscall 95 — sysinfo   [IMPLEMENTED]
#
# a0 = pointer to output SysInfo struct (user VA)
# a1..a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_sysinfo")
fn spl_handle_sysinfo(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_sysinfo stub.

    Forwards to _handle_sysinfo() in syscall.spl.
    Syscall number 95: return system-wide resource statistics.
    """
    val args = _make_args(95, a0, a1, a2, a3, a4, a5)
    val result = _handle_sysinfo(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 96 — get_hostname   [IMPLEMENTED]
#
# a0..a5 unused
# returns pointer to null-terminated hostname string (kernel VA), or 0
# ===========================================================================
@export("C", name: "spl_handle_get_hostname")
fn spl_handle_get_hostname(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_get_hostname stub.

    Forwards to _handle_get_hostname() in syscall.spl.
    Syscall number 96: retrieve the system hostname.
    Note: _handle_get_hostname takes no arguments.
    """
    val result = _handle_get_hostname()
    result.value

# ===========================================================================
# syscall 97 — set_hostname   [IMPLEMENTED]
#
# a0 = pointer to hostname string (user VA)
# a1 = hostname length in bytes
# a2..a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_set_hostname")
fn spl_handle_set_hostname(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_set_hostname stub.

    Forwards to _handle_set_hostname() in syscall.spl.
    Syscall number 97: set the system hostname.
    """
    val args = _make_args(97, a0, a1, a2, a3, a4, a5)
    val result = _handle_set_hostname(args)
    result.value
