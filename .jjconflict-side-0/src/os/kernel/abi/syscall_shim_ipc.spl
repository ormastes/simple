# IPC and notification syscall shims — split from syscall_shim.spl (Wave 10F).
# Contains spl_handle_* for IPC syscalls 20–23 and notification syscalls 24–29.

use os.kernel.types.syscall_types.{SyscallArgs, SyscallResult}
use os.kernel.ipc.syscall.{_handle_ipc_send}
use os.kernel.ipc.syscall.{_handle_ipc_recv}
use os.kernel.ipc.syscall.{_handle_ipc_create_port}
use os.kernel.ipc.syscall.{_handle_ipc_connect}
use os.kernel.ipc.syscall.{_handle_notification_create}
use os.kernel.ipc.syscall.{_handle_notification_signal}
use os.kernel.ipc.syscall.{_handle_notification_wait}
use os.kernel.ipc.syscall.{_handle_notification_poll}
use os.kernel.ipc.syscall.{_handle_notification_destroy}
use os.kernel.ipc.syscall.{_handle_notification_wait_any}
use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.ipc.ipc.{IpcManager}
use os.kernel.abi.syscall_shim.{g_shim_scheduler, g_shim_ipc, _make_args}

# ===========================================================================
# syscall 20 — ipc_send   [IMPLEMENTED]
#
# a0 = destination port ID
# a1 = pointer to message data (user VA)
# a2 = message length in bytes
# a3..a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_ipc_send")
fn spl_handle_ipc_send(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_ipc_send stub.

    Forwards to _handle_ipc_send() in syscall.spl.
    Syscall number 20: send a message to a kernel IPC port.
    """
    val args = _make_args(20, a0, a1, a2, a3, a4, a5)
    val result = _handle_ipc_send(args, g_shim_scheduler, g_shim_ipc)
    result.value

# ===========================================================================
# syscall 21 — ipc_recv   [IMPLEMENTED]
#
# a0 = port ID to receive from
# a1 = pointer to message buffer (user VA)
# a2 = buffer capacity in bytes
# a3..a5 unused
# returns bytes received, or negative errno
# ===========================================================================
@export("C", name: "spl_handle_ipc_recv")
fn spl_handle_ipc_recv(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_ipc_recv stub.

    Forwards to _handle_ipc_recv() in syscall.spl.
    Syscall number 21: receive a message from a kernel IPC port.
    """
    val args = _make_args(21, a0, a1, a2, a3, a4, a5)
    val result = _handle_ipc_recv(args, g_shim_scheduler, g_shim_ipc)
    result.value

# ===========================================================================
# syscall 22 — ipc_create_port   [IMPLEMENTED]
#
# a0 = port name hash (or 0 for anonymous)
# a1..a5 unused
# returns new port ID on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_ipc_create_port")
fn spl_handle_ipc_create_port(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_ipc_create_port stub.

    Forwards to _handle_ipc_create_port() in syscall.spl.
    Syscall number 22: allocate a new IPC message port.
    """
    val args = _make_args(22, a0, a1, a2, a3, a4, a5)
    val result = _handle_ipc_create_port(args, g_shim_scheduler, g_shim_ipc)
    result.value

# ===========================================================================
# syscall 23 — ipc_connect   [IMPLEMENTED]
#
# a0 = target port ID
# a1..a5 unused
# returns connection handle on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_ipc_connect")
fn spl_handle_ipc_connect(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_ipc_connect stub.

    Forwards to _handle_ipc_connect() in syscall.spl.
    Syscall number 23: connect to an existing IPC port.
    Note: _handle_ipc_connect takes (args, ipc) only — no scheduler.
    """
    val args = _make_args(23, a0, a1, a2, a3, a4, a5)
    val result = _handle_ipc_connect(args, g_shim_ipc)
    result.value

# ===========================================================================
# syscall 24 — notification_create   [IMPLEMENTED]
#
# a0 = notification ID / name
# a1..a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_notification_create")
fn spl_handle_notification_create(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_notification_create stub.

    Forwards to _handle_notification_create() in syscall.spl.
    Syscall number 24: create a new notification object.
    """
    val args = _make_args(24, a0, a1, a2, a3, a4, a5)
    val result = _handle_notification_create(args)
    result.value

# ===========================================================================
# syscall 25 — notification_signal   [IMPLEMENTED]
#
# a0 = notification handle
# a1..a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_notification_signal")
fn spl_handle_notification_signal(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_notification_signal stub.

    Forwards to _handle_notification_signal() in syscall.spl.
    Syscall number 25: raise a notification, waking any waiting tasks.
    """
    val args = _make_args(25, a0, a1, a2, a3, a4, a5)
    val result = _handle_notification_signal(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 26 — notification_wait   [IMPLEMENTED]
#
# a0 = notification handle
# a1..a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_notification_wait")
fn spl_handle_notification_wait(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_notification_wait stub.

    Forwards to _handle_notification_wait() in syscall.spl.
    Syscall number 26: block until a notification is signalled.
    """
    val args = _make_args(26, a0, a1, a2, a3, a4, a5)
    val result = _handle_notification_wait(args, g_shim_scheduler)
    result.value

# ===========================================================================
# syscall 27 — notification_poll   [IMPLEMENTED]
#
# a0 = notification handle
# a1..a5 unused
# returns 1 if signalled (non-blocking), 0 if not, negative errno on error
# ===========================================================================
@export("C", name: "spl_handle_notification_poll")
fn spl_handle_notification_poll(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_notification_poll stub.

    Forwards to _handle_notification_poll() in syscall.spl.
    Syscall number 27: non-blocking check whether a notification is pending.
    """
    val args = _make_args(27, a0, a1, a2, a3, a4, a5)
    val result = _handle_notification_poll(args)
    result.value

# ===========================================================================
# syscall 28 — notification_destroy   [IMPLEMENTED]
#
# a0 = notification handle
# a1..a5 unused
# returns 0 on success, negative errno on failure
# ===========================================================================
@export("C", name: "spl_handle_notification_destroy")
fn spl_handle_notification_destroy(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_notification_destroy stub.

    Forwards to _handle_notification_destroy() in syscall.spl.
    Syscall number 28: release a notification object.
    """
    val args = _make_args(28, a0, a1, a2, a3, a4, a5)
    val result = _handle_notification_destroy(args)
    result.value

# ===========================================================================
# syscall 29 — notification_wait_any   [IMPLEMENTED]
#
# a0 = pointer to array of notification handles (user VA)
# a1 = number of handles in array
# a2..a5 unused
# returns index of first signalled handle, or negative errno
# ===========================================================================
@export("C", name: "spl_handle_notification_wait_any")
fn spl_handle_notification_wait_any(a0: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64) -> i64:
    """Strong override for the weak spl_handle_notification_wait_any stub.

    Forwards to _handle_notification_wait_any() in syscall.spl.
    Syscall number 29: block until any one of a set of notifications fires.
    """
    val args = _make_args(29, a0, a1, a2, a3, a4, a5)
    val result = _handle_notification_wait_any(args, g_shim_scheduler)
    result.value
