# Weak C-ABI shim layer for SYSCALL dispatch (Wave 10D).
#
# Exports extern symbols matching the weak default stubs in
# examples/09_embedded/simple_os/arch/x86_64/boot/baremetal_stubs.c.
# When this module is linked, the strong Simple-emitted definitions
# override the weak defaults, and syscalls forward into the real Simple
# kernel handlers in src/os/kernel/ipc/syscall.spl.
#
# @export("C") IS implemented in the Simple compiler.
# See: src/compiler/00.common/attributes.spl
#      src/compiler/70.backend/backend/c_backend_translate.spl
#      src/compiler/20.hir/hir_lowering/items.spl
#
# STATUS: Wave 10F — 53 shims implemented; device_grant wired via scheduler.
#
# This file is the hub. spl_handle_* functions are in:
#   syscall_shim_process.spl       — syscalls 0–14, 60
#   syscall_shim_ipc.spl           — syscalls 20–29
#   syscall_shim_file.spl          — syscalls 30–48, 57–69
#   syscall_shim_time_log_sysinfo.spl — syscalls 50–51, 90–91, 95–97
#   syscall_shim_net.spl           — syscalls 70–77
#   syscall_shim_device.spl        — syscalls 80–85
#   syscall_shim_g11g12g13.spl     — syscalls 15–16, 98–107

