# AArch64 Per-CPU Base Register (TPIDR_EL1) Helpers
#
# TPIDR_EL1 is the AArch64 equivalent of the RISC-V tp (x4) register:
#   TPIDR_EL1 = &per_cpu_data[core_id]
#
# At early boot each CPU core writes its per-CPU base into TPIDR_EL1 before
# calling the kernel entry point.  The helpers here provide:
#   - Simulated TPIDR_EL1 write for interpreter-mode tests (no real sysreg access)
#   - TPIDR_EL0 simulation for hosted userspace-thread-pointer tests
#
# AArch64 system registers are NOT part of the x0-x30 GPR file.
# They survive exception entry by design and do NOT need trap-frame save/restore.
# (Contrast with RISC-V where tp is x4, a GPR that traps must save.)
#
# The real read_tpidr_el1() / write_tpidr_el1() live in cpu.spl and are
# re-exported here for convenience.  Per-CPU code should use this module
# as the single import.
#
# Public API:
#   simulate_tpidr_el1_write_baremetal(core_id, per_cpu_base, per_cpu_shift)
#   read_tpidr_el1_test() -> u64
#   simulate_tpidr_write_hosted()
#   simulate_tpidr_el0_write(value)
#   read_tpidr_el0_test() -> u64

# ============================================================================
# Simulated TPIDR_EL1 state (no real sysreg access in interpreter/hosted mode)
# ============================================================================

var SIM_TPIDR_EL1_VALUE: u64 = 0u64
var SIM_TPIDR_EL0_VALUE: u64 = 0u64

fn simulate_tpidr_el1_write_baremetal(core_id: u32, per_cpu_base: u64, per_cpu_shift: u32):
    """Simulate the boot TPIDR_EL1 write:
    TPIDR_EL1 = per_cpu_base + (core_id << per_cpu_shift)."""
    SIM_TPIDR_EL1_VALUE = per_cpu_base + (core_id as u64 << per_cpu_shift as u64)

fn read_tpidr_el1_test() -> u64:
    """Return the simulated TPIDR_EL1 value set by simulate_tpidr_el1_write_baremetal."""
    SIM_TPIDR_EL1_VALUE

fn simulate_tpidr_write_hosted():
    """On hosted (non-baremetal) builds, TPIDR_EL1 MUST NOT be written — this is a no-op."""
    pass_do_nothing

fn simulate_tpidr_el0_write(value: u64):
    """Simulate a TPIDR_EL0 write for userspace thread-pointer tests."""
    SIM_TPIDR_EL0_VALUE = value

fn read_tpidr_el0_test() -> u64:
    """Return the simulated TPIDR_EL0 value."""
    SIM_TPIDR_EL0_VALUE
