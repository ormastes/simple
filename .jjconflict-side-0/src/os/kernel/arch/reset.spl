# Architecture-light reset facade.
#
# This module intentionally avoids importing os.kernel.arch.hal or
# arch_adapt.hal_current. Syscall dispatchers for non-x86_64 targets can import
# it without pulling foreign-arch inline assembly into their entry-closure build.

extern fn rt_port_outb(port: u16, value: u8)

var _hal_reset_test_mode: u64 = 0
var _hal_reset_requested_for_test: u64 = 0

fn hal_reset_set_test_mode(enabled: bool):
    """Enable a test-only reset latch so syscall tests cannot reset QEMU."""
    if enabled:
        _hal_reset_test_mode = 1
        _hal_reset_requested_for_test = 0
    else:
        _hal_reset_test_mode = 0
        _hal_reset_requested_for_test = 0

fn hal_reset_requested_for_test() -> bool:
    """Return whether hal_system_reset() was requested while test mode was active."""
    _hal_reset_requested_for_test != 0

fn hal_system_reset() -> i64:
    """Request a machine reset through the x86 reset-control register.

    Returns 0 only in test mode. On real QEMU/hardware the backend should not
    return; if it does, callers receive -38 to match ENOSYS-style syscall
    fallback behavior.
    """
    if _hal_reset_test_mode != 0:
        _hal_reset_requested_for_test = 1
        return 0
    rt_port_outb(0xCF9 as u16, 0x02 as u8)
    rt_port_outb(0xCF9 as u16, 0x06 as u8)
    -38
