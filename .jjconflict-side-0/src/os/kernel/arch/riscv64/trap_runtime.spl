# RISC-V 64 Trap Runtime Bundle
#
# Aggregates the kernel-owned services needed by the RV64 trap dispatcher so
# boot code can install one object instead of threading separate globals.

use os.kernel.scheduler.scheduler.{Scheduler}
use os.kernel.ipc.ipc.{IpcManager}
use os.kernel.log.klog.{KernelLog}

struct Rv64TrapRuntime:
    scheduler: Scheduler
    ipc: IpcManager
    klog: KernelLog

impl Rv64TrapRuntime:
    static fn new(scheduler: Scheduler, ipc: IpcManager, klog: KernelLog) -> Rv64TrapRuntime:
        Rv64TrapRuntime(
            scheduler: scheduler,
            ipc: ipc,
            klog: klog
        )

    static fn bootstrap(log_capacity: u64) -> Rv64TrapRuntime:
        """Create the minimal early-boot trap runtime.

        This is not the final kernel composition path. It exists so RV64
        bring-up can install a deterministic runtime bundle before the full
        scheduler/IPC bootstrap sequence is wired.
        """
        Rv64TrapRuntime(
            scheduler: Scheduler.new(),
            ipc: IpcManager.new(),
            klog: KernelLog.new(log_capacity)
        )
