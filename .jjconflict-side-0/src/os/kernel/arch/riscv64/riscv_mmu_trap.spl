class PageTableEntry:
    ppn: i32
    flags: i32
    valid: bool
    readable: bool
    writable: bool
    executable: bool
    user_accessible: bool
    dirty: bool
    accessed: bool

    me is_leaf() -> bool:
        return readable or writable or executable

    me is_pointer() -> bool:
        return valid and readable == false and writable == false and executable == false

    static fn leaf_rwx(ppn: i32) -> PageTableEntry:
        return PageTableEntry {
            ppn: ppn,
            flags: 15,
            valid: true,
            readable: true,
            writable: true,
            executable: true,
            user_accessible: false,
            dirty: false,
            accessed: false
        }

    static fn pointer(ppn: i32) -> PageTableEntry:
        return PageTableEntry {
            ppn: ppn,
            flags: 1,
            valid: true,
            readable: false,
            writable: false,
            executable: false,
            user_accessible: false,
            dirty: false,
            accessed: false
        }

    static fn invalid() -> PageTableEntry:
        return PageTableEntry {
            ppn: 0,
            flags: 0,
            valid: false,
            readable: false,
            writable: false,
            executable: false,
            user_accessible: false,
            dirty: false,
            accessed: false
        }


class PageTableWalk:
    mode: text
    levels_walked: i32
    final_ppn: i32
    page_fault: bool
    fault_reason: text
    tlb_hit: bool

    me is_sv39() -> bool:
        return mode == "Sv39"

    me succeeded() -> bool:
        return page_fault == false

    me is_miss() -> bool:
        return tlb_hit == false and page_fault == false

    static fn sv39_success(ppn: i32, levels: i32) -> PageTableWalk:
        return PageTableWalk {
            mode: "Sv39",
            levels_walked: levels,
            final_ppn: ppn,
            page_fault: false,
            fault_reason: "",
            tlb_hit: false
        }

    static fn sv39_fault(reason: text, levels: i32) -> PageTableWalk:
        return PageTableWalk {
            mode: "Sv39",
            levels_walked: levels,
            final_ppn: 0,
            page_fault: true,
            fault_reason: reason,
            tlb_hit: false
        }

    static fn tlb_hit(ppn: i32) -> PageTableWalk:
        return PageTableWalk {
            mode: "Sv39",
            levels_walked: 0,
            final_ppn: ppn,
            page_fault: false,
            fault_reason: "",
            tlb_hit: true
        }


class TrapCause:
    code: i32
    is_interrupt: bool
    name: text
    delegated: bool
    delegate_to: i32

    me is_sync() -> bool:
        return is_interrupt == false

    me is_async() -> bool:
        return is_interrupt

    me is_delegated() -> bool:
        return delegated

    static fn illegal_instruction() -> TrapCause:
        return TrapCause {
            code: 2,
            is_interrupt: false,
            name: "illegal_instruction",
            delegated: false,
            delegate_to: 3
        }

    static fn load_page_fault() -> TrapCause:
        return TrapCause {
            code: 13,
            is_interrupt: false,
            name: "load_page_fault",
            delegated: true,
            delegate_to: 1
        }

    static fn timer_interrupt() -> TrapCause:
        return TrapCause {
            code: 7,
            is_interrupt: true,
            name: "m_timer",
            delegated: false,
            delegate_to: 3
        }

    static fn external_interrupt() -> TrapCause:
        return TrapCause {
            code: 11,
            is_interrupt: true,
            name: "m_external",
            delegated: false,
            delegate_to: 3
        }


class TrapDispatch:
    cause_code: i32
    handler_addr: i32
    return_addr: i32
    target_mode: i32
    vector_mode: bool

    me is_vectored() -> bool:
        return vector_mode

    me is_direct() -> bool:
        return vector_mode == false

    me target_mode_name() -> text:
        if target_mode == 3:
            return "M"
        if target_mode == 1:
            return "S"
        return "U"

    static fn direct(cause: i32, handler: i32, ret: i32, mode: i32) -> TrapDispatch:
        return TrapDispatch {
            cause_code: cause,
            handler_addr: handler,
            return_addr: ret,
            target_mode: mode,
            vector_mode: false
        }

    static fn vectored(cause: i32, base: i32, ret: i32, mode: i32) -> TrapDispatch:
        return TrapDispatch {
            cause_code: cause,
            handler_addr: base + cause * 4,
            return_addr: ret,
            target_mode: mode,
            vector_mode: true
        }


fn main():
    print("riscv_mmu_trap loaded")
