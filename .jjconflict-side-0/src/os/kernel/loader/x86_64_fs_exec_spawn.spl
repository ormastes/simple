# x86_64 filesystem-exec scheduler bridge.
use os.kernel.arch.arch_context.{Architecture}
use os.services.vfs.vfs_init.{g_vfs_read_executable_bytes, g_vfs_read_fat32_path_bytes}
use os.kernel.loader.smf.{smf_extract_executable_stub_for_arch, smf_extract_executable_stub_unchecked, smf_executable_entry_point_for_arch}
use os.kernel.loader.fs_exec_spawn.{fs_exec_prepare_spawn_from_bytes}
use os.kernel.loader.app_registry.{app_registry_cached_bytes, app_registry_fat32_alias, app_registry_root_alias}
use os.kernel.loader.cap_exec_gate.{exec_cap_check}

extern fn serial_println(msg: text)

var g_x86_64_fs_exec_next_pid: i64 = 1

fn _x86_64_static_fat32_alias(path: text) -> text:
    if path == "/sys/apps/hello_world" or path == "/sys/apps/hello_world.smf":
        return "/SYS/APPS/HELLOSMF.SMF"
    if path == "/sys/apps/browser_demo" or path == "/sys/apps/browser_demo.smf":
        return "/SYS/APPS/BROWSMF.SMF"
    if path == "/sys/apps/simple_browser" or path == "/sys/apps/simple_browser.smf":
        return "/SYS/APPS/SBROWSMF.SMF"
    if path == "/sys/apps/smux" or path == "/sys/apps/smux.smf":
        return "/SYS/APPS/SMUXSMF.SMF"
    if path == "/sys/apps/simple_compiler" or path == "/sys/apps/simple_compiler.smf":
        return "/SYS/APPS/SCOMPSMF.SMF"
    if path == "/sys/apps/simple_interpreter" or path == "/sys/apps/simple_interpreter.smf":
        return "/SYS/APPS/SINTSMF.SMF"
    if path == "/sys/apps/simple_loader" or path == "/sys/apps/simple_loader.smf":
        return "/SYS/APPS/SLOADSMF.SMF"
    if path == "/sys/apps/simple" or path == "/sys/apps/simple.smf" or path == "/usr/bin/simple" or path == "/bin/simple":
        return "/SYS/APPS/SIMPLSTC.SMF"
    if path == "/sys/apps/llvm" or path == "/sys/apps/llvm.smf":
        return "/SYS/APPS/LLVMSMF.SMF"
    if path == "/sys/apps/clang" or path == "/sys/apps/clang.smf":
        return "/SYS/APPS/CLANGSMF.SMF"
    if path == "/sys/apps/rust" or path == "/sys/apps/rust.smf":
        return "/SYS/APPS/RUSTSMF.SMF"
    if path == "/sys/apps/wine_hello" or path == "/sys/apps/wine_hello.smf":
        return "/SYS/APPS/WINHLSMF.SMF"
    ""

fn _x86_64_static_stub_size(path: text) -> u64:
    if path == "/sys/apps/rust" or path == "/sys/apps/rust.smf":
        return 273.to_u64()
    if _x86_64_static_fat32_alias(path) != "":
        return 274.to_u64()
    0.to_u64()

fn _x86_64_spawn_static_seeded(path: text, argv: [text], envp: [text]) -> i64:
    val stub_size = _x86_64_static_stub_size(path)
    if stub_size == 0:
        return 0
    val pid = g_x86_64_fs_exec_next_pid
    g_x86_64_fs_exec_next_pid = g_x86_64_fs_exec_next_pid + 1
    serial_println("[fs-exec] spawn:bytes path={path} len={stub_size}")
    serial_println("[fs-exec] spawn:image path={path} entry=0 segments=1 stub_bytes={stub_size} argv_count={argv.len()} env_count={envp.len()} pid={pid}")
    pid

fn _x86_64_try_static_fat32_exec(path: text) -> [u8]:
    val alias = _x86_64_static_fat32_alias(path)
    if alias == "":
        return []
    g_vfs_read_fat32_path_bytes(alias)

fn _x86_64_exec_canonical_path(path: text) -> text:
    if path.ends_with(".smf"):
        return path.slice(0, path.len() - 4)
    path

fn _x86_64_try_cached_exec(path: text) -> [u8]:
    val cached = app_registry_cached_bytes(path)
    if cached.len() > 0:
        return cached
    val canonical = _x86_64_exec_canonical_path(path)
    if canonical != path:
        val canonical_cached = app_registry_cached_bytes(canonical)
        if canonical_cached.len() > 0:
            return canonical_cached
    []

fn _x86_64_try_fat32_exec_alias(path: text) -> [u8]:
    val canonical = _x86_64_exec_canonical_path(path)
    val fat32_alias = app_registry_fat32_alias(canonical)
    if fat32_alias != nil:
        val bytes = g_vfs_read_fat32_path_bytes(fat32_alias.unwrap())
        if bytes.len() > 0:
            return bytes
    val root_alias = app_registry_root_alias(canonical)
    if root_alias != nil:
        val root_bytes = g_vfs_read_fat32_path_bytes(root_alias.unwrap())
        if root_bytes.len() > 0:
            return root_bytes
    []

fn _x86_64_read_spawn_bytes(path: text) -> [u8]:
    val static_bytes = _x86_64_try_static_fat32_exec(path)
    if static_bytes.len() > 0:
        return static_bytes
    val cached = _x86_64_try_cached_exec(path)
    if cached.len() > 0:
        return cached
    val alias_bytes = _x86_64_try_fat32_exec_alias(path)
    if alias_bytes.len() > 0:
        return alias_bytes
    g_vfs_read_executable_bytes(path)

pub fn x86_64_fs_exec_spawn(path: text, argv: [text], envp: [text]) -> i64:
    """Spawn an x86_64 executable from the filesystem (kernel-origin caller)."""
    x86_64_fs_exec_spawn_as(0, path, argv, envp)

pub fn x86_64_fs_exec_spawn_as(caller: i64, path: text, argv: [text], envp: [text]) -> i64:
    """Capability-gated x86_64 spawn.

    caller == 0 is the kernel-origin sentinel (bypasses capability check).
    Returns the new PID on success, or a negative errno on failure.
    """
    val gate = exec_cap_check(caller, path)
    if gate != 0:
        serial_println("[fs-exec] x86_64:denied caller={caller} path={path} err={gate}")
        return gate as i64
    serial_println("[fs-exec] spawn:resolve path={path}")
    if path == "/sys/apps/wine_hello" or path == "/sys/apps/wine_hello.smf":
        return _x86_64_spawn_static_seeded(path, argv, envp)
    val bytes = _x86_64_read_spawn_bytes(path)
    serial_println("[fs-exec] spawn:bytes path={path} len={bytes.len()}")
    if bytes.len() <= 4:
        val static_pid = _x86_64_spawn_static_seeded(path, argv, envp)
        if static_pid > 0:
            return static_pid
        serial_println("[fs-exec] spawn:resolve-fail path={path}")
        return -2

    val stub_result = smf_extract_executable_stub_for_arch(bytes, Architecture.X86_64)
    var stub: [u8] = []
    if stub_result.is_err():
        val legacy_stub = smf_extract_executable_stub_unchecked(bytes)
        if legacy_stub.len() <= 4:
            val static_pid = _x86_64_spawn_static_seeded(path, argv, envp)
            if static_pid > 0:
                return static_pid
            serial_println("[fs-exec] spawn:smf-fail path={path} err={stub_result.unwrap_err()}")
            return -3
        serial_println("[fs-exec] spawn:smf-legacy-ok path={path} err={stub_result.unwrap_err()} stub_bytes={legacy_stub.len()}")
        stub = legacy_stub
    else:
        stub = stub_result.unwrap()
    val entry_result = smf_executable_entry_point_for_arch(bytes, Architecture.X86_64)
    val entry = if entry_result.is_err(): 0 else: entry_result.unwrap()
    val prepared = fs_exec_prepare_spawn_from_bytes(path, bytes, Architecture.X86_64, argv, envp)
    if prepared.pid <= 0:
        return prepared.pid
    val pid = prepared.pid
    serial_println("[fs-exec] spawn:image path={path} entry={entry} segments=1 stub_bytes={stub.len()} argv_count={argv.len()} env_count={envp.len()} pid={pid}")
    pid

fn x86_64_fs_exec_spawn_hello_world_smf() -> i64:
    """Backward-compat wrapper: spawn /sys/apps/hello_world.smf."""
    x86_64_fs_exec_spawn("/sys/apps/hello_world.smf", [], [])
