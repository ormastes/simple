# Byte Utilities — shared little-endian byte helpers for kernel loaders
#
# Centralises the duplicated _byte_at / _read_u{16,32,64}_le / patch helpers
# that were copy-pasted across elf64.spl, elf_loader.spl, and smf.spl.

fn byte_at(data: [u8], off: i64) -> u8:
    """Read a single byte from `data` at `off`."""
    data[off]

fn read_u16_le(data: [u8], off: i64) -> i64:
    """Read a little-endian u16 from `data` at `off`, returned as i64."""
    val b0 = byte_at(data, off) as i64
    val b1 = byte_at(data, off + 1) as i64
    b0 | (b1 << 8)

fn read_u32_le(data: [u8], off: i64) -> i64:
    """Read a little-endian u32 from `data` at `off`, returned as i64."""
    val b0 = byte_at(data, off) as i64
    val b1 = byte_at(data, off + 1) as i64
    val b2 = byte_at(data, off + 2) as i64
    val b3 = byte_at(data, off + 3) as i64
    b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

fn read_u64_le(data: [u8], off: i64) -> i64:
    """Read a little-endian u64 from `data` at `off`, returned as i64."""
    val b0 = byte_at(data, off) as i64
    val b1 = byte_at(data, off + 1) as i64
    val b2 = byte_at(data, off + 2) as i64
    val b3 = byte_at(data, off + 3) as i64
    val b4 = byte_at(data, off + 4) as i64
    val b5 = byte_at(data, off + 5) as i64
    val b6 = byte_at(data, off + 6) as i64
    val b7 = byte_at(data, off + 7) as i64
    b0 | (b1 << 8) | (b2 << 16) | (b3 << 24) | (b4 << 32) | (b5 << 40) | (b6 << 48) | (b7 << 56)

fn patch_u32_le(data: [u8], off: i64, value: i64) -> [u8]:
    """Write a little-endian u32 into `data` at `off`, returning the mutated array."""
    data[off]     = (value & 0xFF).to_u8()
    data[off + 1] = ((value >> 8) & 0xFF).to_u8()
    data[off + 2] = ((value >> 16) & 0xFF).to_u8()
    data[off + 3] = ((value >> 24) & 0xFF).to_u8()
    data

fn patch_u64_le(data: [u8], off: i64, value: i64) -> [u8]:
    """Write a little-endian u64 into `data` at `off`, returning the mutated array."""
    data[off]     = (value & 0xFF).to_u8()
    data[off + 1] = ((value >> 8) & 0xFF).to_u8()
    data[off + 2] = ((value >> 16) & 0xFF).to_u8()
    data[off + 3] = ((value >> 24) & 0xFF).to_u8()
    data[off + 4] = ((value >> 32) & 0xFF).to_u8()
    data[off + 5] = ((value >> 40) & 0xFF).to_u8()
    data[off + 6] = ((value >> 48) & 0xFF).to_u8()
    data[off + 7] = ((value >> 56) & 0xFF).to_u8()
    data

fn has_magic(data: [u8], off: i64, m0: u8, m1: u8, m2: u8, m3: u8) -> bool:
    """Return true if 4 bytes at `off` match (m0, m1, m2, m3)."""
    if off < 0:
        return false
    if off + 4 > data.len():
        return false
    (byte_at(data, off) == m0 and
     byte_at(data, off + 1) == m1 and
     byte_at(data, off + 2) == m2 and
     byte_at(data, off + 3) == m3)

fn in_range(data: [u8], off: i64, size: i64) -> bool:
    """Return true if [off, off+size) fits within `data`."""
    if off < 0 or size < 0:
        return false
    val end_ = off + size
    if end_ < off:
        return false
    end_ <= data.len()
