# Global Notification Table — shared between syscall dispatcher and IRQ routing
#
# Moved from syscall.spl so that both the syscall dispatcher and
# irq_routing can import the same table instance.

use os.kernel.ipc.notification.{NotificationTable, notification_clear_waiter}

var g_notification_table: NotificationTable = NotificationTable.new()

fn notification_clear_waiter_global(thread_id: u64) -> u32:
    notification_clear_waiter(g_notification_table, thread_id)
