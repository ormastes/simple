# TCP Shim State -- Module-Level FD Tracking and Address Parsing
#
# MDSOC: feature dimension, network layer
# Maintains a table mapping shim file descriptors (i64, starting at 100)
# to netstack socket fds (i32) and connection metadata.
# Also provides "host:port" address parsing since Ipv4Address lacks from_text.

use os.services.netstack.ipv4.{Ipv4Address}
use os.services.netstack.socket.{SockAddr}

# ============================================================================
# Shim FD Entry
# ============================================================================

struct ShimFdEntry:
    """Maps a shim fd to netstack state."""
    fd: i64                 # Our shim fd (>= 100)
    os_fd: i32              # Netstack SocketTable fd
    bound_addr: text        # "host:port" string for local_addr
    peer_addr_text: text    # "host:port" string for peer_addr
    is_listening: bool      # Whether this is a listener socket
    nonblocking: bool       # Non-blocking mode flag
    nodelay: bool           # TCP_NODELAY flag
    read_timeout_ms: i64    # Read timeout (-1 = none)
    write_timeout_ms: i64   # Write timeout (-1 = none)

# ============================================================================
# Global FD Table
# ============================================================================

var g_shim_fds: [ShimFdEntry] = []
var g_next_fd: i64 = 100   # Start above OS fds

fn shim_alloc_fd() -> i64:
    """Allocate and return the next shim fd."""
    val fd = g_next_fd
    g_next_fd = g_next_fd + 1
    fd

fn shim_get(fd: i64) -> ShimFdEntry?:
    """Look up a shim fd entry. Returns nil if not found."""
    var i: u64 = 0
    while i < g_shim_fds.len():
        if g_shim_fds[i].fd == fd:
            return g_shim_fds[i]
        i = i + 1
    nil

fn shim_set(fd: i64, entry: ShimFdEntry):
    """Insert or update a shim fd entry."""
    var i: u64 = 0
    while i < g_shim_fds.len():
        if g_shim_fds[i].fd == fd:
            g_shim_fds[i] = entry
            return
        i = i + 1
    g_shim_fds.push(entry)

fn shim_remove(fd: i64):
    """Remove a shim fd entry."""
    var new_fds: [ShimFdEntry] = []
    var i: u64 = 0
    while i < g_shim_fds.len():
        if g_shim_fds[i].fd != fd:
            new_fds.push(g_shim_fds[i])
        i = i + 1
    g_shim_fds = new_fds

# ============================================================================
# Address Parsing
# ============================================================================

struct HostPort:
    """Parsed host:port pair."""
    ip: Ipv4Address
    port: u16
    addr_text: text     # Original "host:port" string

fn parse_host_port(addr: text) -> HostPort?:
    """Parse "A.B.C.D:port" into HostPort. Returns nil on failure.

    Supports:
      "0.0.0.0:8080"   -> bind all interfaces
      "127.0.0.1:3000"  -> loopback
      "10.0.2.15:80"    -> specific IP
    """
    # Find the last colon separating host from port
    var colon_pos: i64 = -1
    var ci: i64 = addr.len().to_i64() - 1
    while ci >= 0:
        if addr[ci.to_u64()] == ':':
            colon_pos = ci
            break
        ci = ci - 1

    if colon_pos < 0:
        return nil

    # Extract host and port strings
    var host_str = ""
    var hi: u64 = 0
    while hi < colon_pos.to_u64():
        host_str = host_str + addr[hi].to_text()
        hi = hi + 1

    var port_str = ""
    var pi: u64 = colon_pos.to_u64() + 1
    while pi < addr.len():
        port_str = port_str + addr[pi].to_text()
        pi = pi + 1

    # Parse port
    val port_val = _parse_u16(port_str)
    if port_val < 0:
        return nil

    # Parse IP octets (A.B.C.D)
    val ip_opt = _parse_ipv4(host_str)
    if ip_opt == nil:
        return nil

    val ip = ip_opt.unwrap()
    HostPort(ip: ip, port: port_val.to_u16(), addr_text: addr)

fn _parse_u16(s: text) -> i64:
    """Parse a decimal string to i64. Returns -1 on failure."""
    if s.len() == 0:
        return -1
    var result: i64 = 0
    var i: u64 = 0
    while i < s.len():
        val ch = s[i]
        if ch < '0' or ch > '9':
            return -1
        val digit = ch.to_i64() - '0'.to_i64()
        result = result * 10 + digit
        i = i + 1
    if result > 65535:
        return -1
    result

fn _parse_ipv4(s: text) -> Ipv4Address?:
    """Parse dotted-decimal "A.B.C.D" into Ipv4Address. Returns nil on failure."""
    var octets: [i64] = []
    var current: i64 = 0
    var has_digit = false
    var i: u64 = 0

    while i < s.len():
        val ch = s[i]
        if ch == '.':
            if not has_digit:
                return nil
            octets.push(current)
            current = 0
            has_digit = false
        else if ch >= '0' and ch <= '9':
            val digit = ch.to_i64() - '0'.to_i64()
            current = current * 10 + digit
            has_digit = true
            if current > 255:
                return nil
        else:
            return nil
        i = i + 1

    # Push last octet
    if not has_digit:
        return nil
    octets.push(current)

    if octets.len() != 4:
        return nil

    Ipv4Address.from_bytes(
        octets[0].to_u8(), octets[1].to_u8(),
        octets[2].to_u8(), octets[3].to_u8()
    )

fn make_sock_addr(hp: HostPort) -> SockAddr:
    """Convert a parsed HostPort to a netstack SockAddr."""
    SockAddr(ip: hp.ip, port: hp.port)

fn sock_addr_to_text(addr: SockAddr) -> text:
    """Format a SockAddr as "A.B.C.D:port"."""
    "{addr.ip.to_text()}:{addr.port}"
