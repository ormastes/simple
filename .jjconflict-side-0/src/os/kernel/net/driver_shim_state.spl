# IoDriver Shim State -- Per-Handle Completion Queues
#
# MDSOC: feature dimension, network layer
# Status: B3 stub -- provides internal state for the baremetal IoDriver shim.
# Each driver handle owns its own pending/completed queues and tick counter.
#
# Architecture:
#   - PendingOp tracks submitted but not-yet-completed operations.
#   - CompletedOp tracks finished operations awaiting poll retrieval.
#   - BaremetalDriver is the per-handle state (pending list, completed list,
#     last-poll batch, id counter, tick counter).
#   - g_drivers is a handle-indexed table of BaremetalDriver instances.

# ============================================================================
# Operation Type Constants
# ============================================================================

val OP_TYPE_ACCEPT: i64 = 0
val OP_TYPE_RECV: i64 = 1
val OP_TYPE_SEND: i64 = 2
val OP_TYPE_TIMEOUT: i64 = 3
val OP_TYPE_CONNECT: i64 = 4
val OP_TYPE_SENDFILE: i64 = 5
val OP_TYPE_READ: i64 = 6
val OP_TYPE_WRITE: i64 = 7
val OP_TYPE_OPEN: i64 = 8
val OP_TYPE_CLOSE: i64 = 9
val OP_TYPE_FSYNC: i64 = 10

# ============================================================================
# Pending Operation
# ============================================================================

struct PendingOp:
    """An operation submitted but not yet completed."""
    op_id: i64
    op_type: i64       # One of OP_TYPE_* constants
    fd: i64
    timeout_target: i64  # Tick at which a timeout op fires (-1 if N/A)
    buf_size: i64        # For recv/read operations
    data_text: text      # For send/write operations
    data_len: i64        # Byte length for send/write
    offset: i64          # File offset for read/write
    addr: text           # For connect (host:port)
    port: i64            # For connect
    flags: i64           # For open
    mode: i64            # For open

# ============================================================================
# Completed Operation
# ============================================================================

struct CompletedOp:
    """A completed operation ready for poll retrieval."""
    op_id: i64
    result_val: i64    # Bytes transferred or negative errno
    flags: i64         # Platform-specific flags (0 for baremetal stub)
    data_text: text    # Received/read data (empty for non-recv ops)
    data_len: i64      # Byte length of data_text

# ============================================================================
# Per-Handle Driver State
# ============================================================================

class BaremetalDriver:
    """State for one IoDriver handle.

    Uses class (reference semantics) so that mutations through g_drivers[i]
    persist without explicit write-back. Structs in Simple arrays are copies.
    """
    handle: i64
    pending: [PendingOp]
    completed: [CompletedOp]
    last_poll_batch: [CompletedOp]   # Batch from most recent poll(), indexed by poll_id/result/flags
    next_op_id: i64
    tick: i64
    alive: bool

# ============================================================================
# Global Driver Table
# ============================================================================

var g_drivers: [BaremetalDriver] = []
var g_next_handle: i64 = 1

fn driver_create() -> i64:
    """Allocate a new BaremetalDriver and return its handle."""
    val h = g_next_handle
    g_next_handle = g_next_handle + 1
    val drv = BaremetalDriver(
        handle: h,
        pending: [],
        completed: [],
        last_poll_batch: [],
        next_op_id: 1,
        tick: 0,
        alive: true
    )
    g_drivers.push(drv)
    h

fn driver_get(handle: i64) -> BaremetalDriver?:
    """Look up a driver by handle. Returns nil if not found or dead."""
    var i: u64 = 0
    while i < g_drivers.len():
        if g_drivers[i].handle == handle and g_drivers[i].alive:
            return g_drivers[i]
        i = i + 1
    nil

fn driver_get_index(handle: i64) -> i64:
    """Return the index of a driver in g_drivers, or -1."""
    var i: u64 = 0
    while i < g_drivers.len():
        if g_drivers[i].handle == handle and g_drivers[i].alive:
            return i.to_i64()
        i = i + 1
    -1

fn driver_alloc_op_id(handle: i64) -> i64:
    """Allocate and return the next op_id for a driver."""
    val idx = driver_get_index(handle)
    if idx < 0:
        return -1
    val op_id = g_drivers[idx.to_u64()].next_op_id
    g_drivers[idx.to_u64()].next_op_id = op_id + 1
    op_id

fn driver_add_pending(handle: i64, op: PendingOp):
    """Add a pending operation to a driver's queue."""
    val idx = driver_get_index(handle)
    if idx < 0:
        return
    g_drivers[idx.to_u64()].pending.push(op)

fn driver_add_completed(handle: i64, op: CompletedOp):
    """Add a completed operation to a driver's ready queue."""
    val idx = driver_get_index(handle)
    if idx < 0:
        return
    g_drivers[idx.to_u64()].completed.push(op)

fn driver_destroy(handle: i64):
    """Mark a driver as dead. Clears queues."""
    val idx = driver_get_index(handle)
    if idx < 0:
        return
    g_drivers[idx.to_u64()].alive = false
    g_drivers[idx.to_u64()].pending = []
    g_drivers[idx.to_u64()].completed = []
    g_drivers[idx.to_u64()].last_poll_batch = []
