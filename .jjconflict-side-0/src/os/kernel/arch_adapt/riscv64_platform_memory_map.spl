# RISC-V64 board memory-map adapter.
#
# Arch-neutral boot handoff code imports this adapter instead of concrete
# os.kernel.arch.riscv64 platform modules.

use os.kernel.arch.riscv64.platform.kria_memory_map.{
    kria_uart_base,
    kria_ram_base,
    kria_ram_size,
    kria_heap_start,
    kria_heap_size,
    kria_clint_base,
    kria_plic_base
}
use os.kernel.arch.riscv64.platform.litex_memory_map.{
    litex_uart_base,
    litex_ram_base,
    litex_ram_size,
    litex_heap_start,
    litex_heap_size,
    litex_clint_base,
    litex_plic_base
}

fn riscv64_kria_uart_base() -> u64:
    kria_uart_base()

fn riscv64_kria_ram_base() -> u64:
    kria_ram_base()

fn riscv64_kria_ram_size() -> u64:
    kria_ram_size()

fn riscv64_kria_heap_start() -> u64:
    kria_heap_start()

fn riscv64_kria_heap_size() -> u64:
    kria_heap_size()

fn riscv64_kria_clint_base() -> u64:
    kria_clint_base()

fn riscv64_kria_plic_base() -> u64:
    kria_plic_base()

fn riscv64_litex_uart_base() -> u64:
    litex_uart_base()

fn riscv64_litex_ram_base() -> u64:
    litex_ram_base()

fn riscv64_litex_ram_size() -> u64:
    litex_ram_size()

fn riscv64_litex_heap_start() -> u64:
    litex_heap_start()

fn riscv64_litex_heap_size() -> u64:
    litex_heap_size()

fn riscv64_litex_clint_base() -> u64:
    litex_clint_base()

fn riscv64_litex_plic_base() -> u64:
    litex_plic_base()
