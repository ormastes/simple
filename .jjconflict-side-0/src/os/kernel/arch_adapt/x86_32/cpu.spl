# x86_32 CPU Adapter Scaffold
#
# Thin wrapper layer over the concrete x86_32 CPU primitives module.

use os.kernel.arch.x86_32.cpu.{X86_32Cpu, reboot}

fn cpu_id() -> u64:
    """Return the current x86_32 CPU id."""
    var cpu = X86_32Cpu()
    cpu.cpu_id()

fn cpu_address_width() -> u64:
    """Return the x86_32 virtual address width in bits."""
    var cpu = X86_32Cpu()
    cpu.cpu_address_width()

fn cpu_enable_interrupts():
    """Enable maskable interrupts on x86_32."""
    var cpu = X86_32Cpu()
    cpu.cpu_enable_interrupts()

fn cpu_disable_interrupts():
    """Disable maskable interrupts on x86_32."""
    var cpu = X86_32Cpu()
    cpu.cpu_disable_interrupts()

fn cpu_halt():
    """Halt the current x86_32 CPU until the next interrupt."""
    var cpu = X86_32Cpu()
    cpu.cpu_halt()

fn cpu_halt_loop():
    """Disable interrupts and halt forever on x86_32."""
    var cpu = X86_32Cpu()
    cpu.cpu_halt_loop()

fn cpu_flush_tlb(vaddr: u32):
    """Invalidate the TLB entry for one x86_32 virtual address."""
    var cpu = X86_32Cpu()
    cpu.cpu_flush_tlb(vaddr)

fn cpu_flush_tlb_all():
    """Flush the full x86_32 TLB."""
    var cpu = X86_32Cpu()
    cpu.cpu_flush_tlb_all()

fn cpu_read_page_table_base() -> u32:
    """Read the active x86_32 page-directory base from CR3."""
    var cpu = X86_32Cpu()
    cpu.cpu_read_page_table_base()

fn cpu_write_page_table_base(addr: u32):
    """Write the active x86_32 page-directory base to CR3."""
    var cpu = X86_32Cpu()
    cpu.cpu_write_page_table_base(addr)

fn cpu_reboot():
    """Request an x86_32 platform reboot."""
    reboot()
