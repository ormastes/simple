# x86_64 CPU Adapter
#
# Thin wrapper layer over the concrete x86_64 CPU primitives module.

use os.kernel.arch.x86_64.cpu.{X86Cpu, reboot}

fn cpu_id() -> u64:
    """Return the current x86_64 CPU id."""
    var cpu = X86Cpu()
    cpu.cpu_id()

fn cpu_address_width() -> u32:
    """Return the active x86_64 virtual address width in bits."""
    val cpu = X86Cpu()
    cpu.cpu_address_width() as u32

fn cpu_enable_interrupts():
    """Enable maskable interrupts on x86_64."""
    var cpu = X86Cpu()
    cpu.cpu_enable_interrupts()

fn cpu_disable_interrupts():
    """Disable maskable interrupts on x86_64."""
    var cpu = X86Cpu()
    cpu.cpu_disable_interrupts()

fn cpu_halt():
    """Halt the current x86_64 CPU until the next interrupt."""
    var cpu = X86Cpu()
    cpu.cpu_halt()

fn cpu_halt_loop():
    """Disable interrupts and halt forever on x86_64."""
    var cpu = X86Cpu()
    cpu.cpu_halt_loop()

fn cpu_flush_tlb(vaddr: u64):
    """Invalidate the TLB entry for one x86_64 virtual address."""
    var cpu = X86Cpu()
    cpu.cpu_flush_tlb(vaddr)

fn cpu_flush_tlb_all():
    """Flush the full x86_64 TLB."""
    var cpu = X86Cpu()
    cpu.cpu_flush_tlb_all()

fn cpu_read_page_table_base() -> u64:
    """Read the active x86_64 page-table base from CR3."""
    var cpu = X86Cpu()
    cpu.cpu_read_page_table_base()

fn cpu_write_page_table_base(addr: u64):
    """Write the active x86_64 page-table base to CR3."""
    var cpu = X86Cpu()
    cpu.cpu_write_page_table_base(addr)

fn cpu_system_reset() -> i64:
    """Request an x86_64 platform reset."""
    reboot()
    -38

