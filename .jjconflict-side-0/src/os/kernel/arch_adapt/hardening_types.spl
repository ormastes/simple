# Arch-neutral hardening probe result type.
#
# Populated by per-arch *_hardening_probe_full() functions and consumed by
# the boot log and security audit path.  Pure data — no methods.

class HardeningReport:
    """Boot-time hardware hardening feature report.

    Fields:
      nx         — No-Execute / XD / XN page protection is active
      smep       — Supervisor Mode Execution Prevention (or equivalent)
      smap       — Supervisor Mode Access Prevention (or equivalent)
      wp         — Write-Protect bit in CR0 / equivalent (kernel cannot write RO pages)
      aslr_seed  — Entropy seed collected from RDRAND / RDTSC / hardware RNG
      canary     — Stack canary value collected at probe time
      arch       — Architecture tag text (e.g. "x86_64", "riscv64", "arm64")
    """
    nx: bool
    smep: bool
    smap: bool
    wp: bool
    aslr_seed: u64
    canary: u64
    arch: text

pub fn hardening_report_empty(arch: text) -> HardeningReport:
    """Return a zero-initialised report for architectures without a probe."""
    HardeningReport(
        nx: false,
        smep: false,
        smap: false,
        wp: false,
        aslr_seed: 0,
        canary: 0,
        arch: arch
    )
