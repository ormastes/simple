# xargs — Build and execute command arguments from input
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error, split_lines}

fn tool_xargs(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Build argument lists from file input and print them.

    Usage: xargs COMMAND < FILE
    In SimpleOS shell, this reads from the last arg as file and prepends remaining args.
    Simplified: xargs [-n MAX] COMMAND FILE
    """
    var max_args: i32 = 0
    var command_parts: [text] = []
    var file_path = ""
    var i = 0

    while i < args.len():
        if args[i] == "-n" and i + 1 < args.len():
            i = i + 1
            max_args = _xargs_parse_int(args[i])
        else:
            command_parts = command_parts.push(args[i])
        i = i + 1

    # Last positional arg is the input file
    if command_parts.len() < 2:
        write_error(terminal, "xargs: usage: xargs [-n MAX] COMMAND FILE")
        return 1

    file_path = command_parts[command_parts.len() - 1]
    # Remove file from command parts
    var cmd_parts: [text] = []
    i = 0
    while i < command_parts.len() - 1:
        cmd_parts = cmd_parts.push(command_parts[i])
        i = i + 1

    if vfs == nil:
        write_error(terminal, "xargs: no filesystem mounted")
        return 1

    val path = resolve_path(cwd, file_path)
    val result = vfs.read_text(path)
    if result.is_err():
        write_error(terminal, "xargs: {path}: {result.unwrap_err()}")
        return 1

    val content = result.unwrap()
    var items: [text] = []
    for line in split_lines(content):
        val trimmed = line.trim()
        if trimmed != "":
            items = items.push(trimmed)

    # Output the constructed command lines
    if max_args > 0:
        var batch: [text] = []
        for item in items:
            batch = batch.push(item)
            if batch.len() as i32 >= max_args:
                var line = ""
                for part in cmd_parts:
                    line = "{line}{part} "
                for b in batch:
                    line = "{line}{b} "
                write_line(terminal, line.trim())
                batch = []
        if batch.len() > 0:
            var line = ""
            for part in cmd_parts:
                line = "{line}{part} "
            for b in batch:
                line = "{line}{b} "
            write_line(terminal, line.trim())
    else:
        var line = ""
        for part in cmd_parts:
            line = "{line}{part} "
        for item in items:
            line = "{line}{item} "
        write_line(terminal, line.trim())
    return 0

fn _xargs_parse_int(s: text) -> i32:
    var result: i32 = 0
    for ch in s:
        if ch >= "0" and ch <= "9":
            result = result * 10 + (ch.to_i32() - "0".to_i32())
    return result
