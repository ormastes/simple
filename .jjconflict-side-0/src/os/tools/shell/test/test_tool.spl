#![allow(unnamed_duplicate_typed_args)]
# test — Conditional expressions
# MDSOC: feature dimension, shell layer

use os.services.vfs.vfs.{VfsManager}
use os.kernel.types.fs_types.{FsNodeKind}
use os.tools.shell.shell_helpers.{resolve_path, write_error}
use os.apps.terminal.terminal.{Terminal}

fn tool_test(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Evaluate conditional expressions.

    File tests: -f FILE (is file), -d FILE (is directory), -e FILE (exists), -s FILE (non-empty)
    String tests: -z STRING (empty), -n STRING (non-empty), S1 = S2, S1 != S2
    Integer tests: N1 -eq N2, N1 -ne N2, N1 -lt N2, N1 -gt N2, N1 -le N2, N1 -ge N2
    Logic: ! EXPR (negate)
    """
    if args.len() == 0:
        return 1

    # Handle negation
    if args[0] == "!" and args.len() > 1:
        var rest: [text] = []
        var i = 1
        while i < args.len():
            rest = rest.push(args[i])
            i = i + 1
        val result = tool_test(vfs, cwd, rest, terminal)
        return if result == 0: 1 else: 0

    # Unary tests
    if args.len() == 2:
        val flag = args[0]
        val operand = args[1]
        match flag:
            "-f":
                return _test_file_type(vfs, cwd, operand, FsNodeKind.File)
            "-d":
                return _test_file_type(vfs, cwd, operand, FsNodeKind.Directory)
            "-e":
                return _test_exists(vfs, cwd, operand)
            "-s":
                return _test_non_empty(vfs, cwd, operand)
            "-r":
                return _test_exists(vfs, cwd, operand)
            "-w":
                return _test_exists(vfs, cwd, operand)
            "-x":
                return _test_exists(vfs, cwd, operand)
            "-z":
                return if operand.len() == 0: 0 else: 1
            "-n":
                return if operand.len() > 0: 0 else: 1
            _:
                return 2

    # Binary tests
    if args.len() == 3:
        val left = args[0]
        val op = args[1]
        val right = args[2]
        match op:
            "=":
                return if left == right: 0 else: 1
            "!=":
                return if left != right: 0 else: 1
            "-eq":
                return _cmp_int(left, right, "eq")
            "-ne":
                return _cmp_int(left, right, "ne")
            "-lt":
                return _cmp_int(left, right, "lt")
            "-gt":
                return _cmp_int(left, right, "gt")
            "-le":
                return _cmp_int(left, right, "le")
            "-ge":
                return _cmp_int(left, right, "ge")
            _:
                return 2

    # Single arg: true if non-empty string
    if args.len() == 1:
        return if args[0] != "": 0 else: 1

    return 2

fn _test_file_type(vfs: VfsManager?, cwd: text, path_str: text, expected: FsNodeKind) -> i32:
    if vfs == nil:
        return 1
    val path = resolve_path(cwd, path_str)
    val result = vfs.stat(path)
    if result.is_err():
        return 1
    val node = result.unwrap()
    return if node.kind == expected: 0 else: 1

fn _test_exists(vfs: VfsManager?, cwd: text, path_str: text) -> i32:
    if vfs == nil:
        return 1
    val path = resolve_path(cwd, path_str)
    val result = vfs.stat(path)
    return if result.is_ok(): 0 else: 1

fn _test_non_empty(vfs: VfsManager?, cwd: text, path_str: text) -> i32:
    if vfs == nil:
        return 1
    val path = resolve_path(cwd, path_str)
    val result = vfs.stat(path)
    if result.is_err():
        return 1
    val node = result.unwrap()
    return if node.size > 0: 0 else: 1

fn _cmp_int(left_str: text, right_str: text, op: text) -> i32:
    val left = _test_parse_i64(left_str)
    val right = _test_parse_i64(right_str)
    val result = match op:
        "eq": left == right
        "ne": left != right
        "lt": left < right
        "gt": left > right
        "le": left <= right
        "ge": left >= right
        _: false
    return if result: 0 else: 1

fn _test_parse_i64(s: text) -> i64:
    var result: i64 = 0
    var neg = false
    var started = false
    for ch in s:
        if ch == "-" and not started:
            neg = true
            started = true
        elif ch >= "0" and ch <= "9":
            result = result * 10 + (ch.to_i32() - "0".to_i32())
            started = true
    if neg:
        return -result
    return result
