# patch — Apply a diff to a file
# MDSOC: feature dimension, shell layer

use os.apps.terminal.terminal.{Terminal}
use os.services.vfs.vfs.{VfsManager}
use os.tools.shell.shell_helpers.{resolve_path, write_line, write_error, split_lines}

fn tool_patch(vfs: VfsManager?, cwd: text, args: [text], terminal: Terminal) -> i32:
    """Apply a simple unified diff to a file.

    Usage: patch FILE PATCHFILE
    Supports basic add (+) and remove (-) lines from unified diff format.
    """
    if args.len() < 2:
        write_error(terminal, "patch: usage: patch FILE PATCHFILE")
        return 1
    if vfs == nil:
        write_error(terminal, "patch: no filesystem mounted")
        return 1

    val target_path = resolve_path(cwd, args[0])
    val patch_path = resolve_path(cwd, args[1])

    val target_result = vfs.read_text(target_path)
    var target_content = ""
    match target_result:
        Ok(text):
            target_content = text
        Err(err):
            write_error(terminal, "patch: {target_path}: {err}")
            return 1
    val patch_result = vfs.read_text(patch_path)
    var patch_content = ""
    match patch_result:
        Ok(text):
            patch_content = text
        Err(err):
            write_error(terminal, "patch: {patch_path}: {err}")
            return 1

    val target_lines = split_lines(target_content)
    val patch_lines = split_lines(patch_content)

    # Simple line-based patch: apply + (add) and - (remove) lines
    var result_lines: [text] = []
    var target_idx: u64 = 0
    var hunks_applied = 0

    for pline in patch_lines:
        if pline.starts_with("---") or pline.starts_with("+++") or pline.starts_with("@@"):
            pass_dn
        elif pline.starts_with("-"):
            # Skip the corresponding line in target
            target_idx = target_idx + 1
        elif pline.starts_with("+"):
            # Add new line
            result_lines = result_lines.push(pline.slice(1, pline.len()))
            hunks_applied = hunks_applied + 1
        elif pline.starts_with(" "):
            # Context line — copy from target
            if target_idx < target_lines.len():
                result_lines = result_lines.push(target_lines[target_idx])
            target_idx = target_idx + 1
        else:
            # Non-diff line or header — skip
            pass_dn

    # Copy remaining target lines
    while target_idx < target_lines.len():
        result_lines = result_lines.push(target_lines[target_idx])
        target_idx = target_idx + 1

    # Write patched file
    var output = ""
    var first = true
    for line in result_lines:
        if not first:
            output = "{output}\n"
        output = "{output}{line}"
        first = false

    val write_result = vfs.write_text(target_path, output)
    match write_result:
        Ok(_):
            pass_dn
        Err(err):
            write_error(terminal, "patch: write failed: {err}")
            return 1

    write_line(terminal, "patching file {args[0]} ({hunks_applied} hunks)")
    return 0
