# Package CLI — Unified Package Management Commands
# MDSOC: feature dimension, apps layer
#
# Extends the existing `pkg` CLI with build, image, install-from-usb, and registry commands.
# Dispatches to pkg_manager (install/remove/update/list/search/info),
#              pkg_builder (build),
#              image_builder (image),
#              usb_installer (installer),
#              registry_server (registry).
#
# Usage:
#   pkg install NAME                  — Install a package
#   pkg remove NAME                   — Remove a package
#   pkg update [NAME]                 — Update packages
#   pkg list                          — List installed packages
#   pkg search QUERY                  — Search available packages
#   pkg info NAME                     — Show package details
#   pkg build <dir> [-o <out>]        — Build .spk from source directory
#   pkg image create [OPTIONS]        — Create bootable disk/USB image
#   pkg installer install|upgrade     — Run USB installer
#   pkg registry start|init|...       — Package registry server

use os.tools.pkg.pkg_manager.{run_pkg}
use os.tools.pkg.pkg_builder.{run_pkg_build}
use os.installer.image_builder.{run_image_builder}
use os.installer.usb_installer.{run_usb_installer}
use os.apps.registry.registry_server.{run_registry}

fn _print_pkg_cli_usage():
    print "pkg — SimpleOS Package Manager"
    print ""
    print "Usage: pkg <command> [ARGS...]"
    print ""
    print "Package Management:"
    print "  install NAME           Install a package and its dependencies"
    print "  remove NAME            Remove an installed package"
    print "  update [NAME]          Update a package (or all)"
    print "  list                   List installed packages"
    print "  search QUERY           Search available packages"
    print "  info NAME              Show package details"
    print ""
    print "Packaging:"
    print "  build <dir> [-o DIR]   Build a .spk package from source directory"
    print "  build-os [--arch=X]    Build all OS packages for an architecture"
    print ""
    print "Images:"
    print "  image create [OPTS]    Create bootable disk or USB installer image"
    print ""
    print "Installation:"
    print "  installer install      Run fresh OS installation from USB"
    print "  installer upgrade      Upgrade existing installation from USB"
    print "  installer detect       Detect available target disks"
    print ""
    print "Registry:"
    print "  registry start         Start package registry server"
    print "  registry init          Initialize registry data directory"
    print "  registry add-token T   Add API token"
    print "  registry reindex       Rebuild package index"
    print "  registry list          List packages in registry"
    print ""
    print "Options:"
    print "  -h                     Show this help"

fn run_pkg_cli(args: [text]) -> i32:
    """Main entry point for the unified pkg CLI."""
    for arg in args:
        if arg == "-h":
            _print_pkg_cli_usage()
            return 0

    if args.len() < 1:
        _print_pkg_cli_usage()
        return 1

    val command = args[0]
    val rest = args.slice(1, args.len())

    # Package management commands — delegate to existing pkg_manager
    if command == "install" or command == "remove" or command == "update" or command == "list" or command == "search" or command == "info":
        return run_pkg(args)

    # Build commands
    else if command == "build":
        return run_pkg_build(rest)

    else if command == "build-os":
        return _run_build_os(rest)

    # Image commands
    else if command == "image":
        return run_image_builder(rest)

    # Installer commands
    else if command == "installer":
        return run_usb_installer(rest)

    # Registry commands
    else if command == "registry":
        return run_registry(rest)

    else:
        print "Unknown command: {command}"
        print ""
        _print_pkg_cli_usage()
        return 1

# === Build OS Packages ===

fn _print_build_os_usage():
    print "Usage: pkg build-os [OPTIONS]"
    print ""
    print "Build all SimpleOS packages (.spk) for an architecture."
    print ""
    print "Options:"
    print "  --arch=ARCH    Target architecture (default: x86_64)"
    print "  -o DIR         Output directory (default: ./packages/)"
    print "  -h             Show this help"

fn _run_build_os(args: [text]) -> i32:
    """Build all OS packages for a given architecture."""
    for arg in args:
        if arg == "-h":
            _print_build_os_usage()
            return 0

    var arch_str = "x86_64"
    var output_dir = "./packages"

    for arg in args:
        if arg.starts_with("--arch="):
            arch_str = arg.slice(7, arg.len())
        else if arg.starts_with("-o"):
            pass_todo("parse -o flag for build-os")

    use os.tools.pkg.pkg_format.{PkgArch, pkg_arch_from_text, pkg_arch_to_text}
    use os.packages.os_packages.{list_all_packages}
    use os.tools.pkg.pkg_builder.{build_meta_package}
    use os.userlib.fs.{mkdir}

    val arch_result = pkg_arch_from_text(arch_str)
    if val Err(e) = arch_result:
        print "Error: {e}"
        return 1
    val arch = arch_result.unwrap()

    print "Building SimpleOS packages for {arch_str}..."
    print "Output: {output_dir}/"
    print ""

    mkdir(output_dir)
    val packages = list_all_packages(arch)
    var built = 0
    var failed = 0

    for pkg in packages:
        val name = pkg.base.name
        print "  Building {name}..."

        # Meta-packages have no payload files
        if pkg.pkg_type == os.tools.pkg.pkg_format.PackageType.Meta:
            val result = build_meta_package(pkg, output_dir)
            if val Ok(path) = result:
                print "    -> {path}"
                built = built + 1
            else if val Err(e) = result:
                print "    FAILED: {e}"
                failed = failed + 1
        else:
            # Non-meta packages need a source directory with actual files
            # For OS packages, we'd normally compile the kernel/apps first
            # Here we create manifest-only .spk files (the actual binaries
            # are added during the full OS build pipeline)
            val result = build_meta_package(pkg, output_dir)
            if val Ok(path) = result:
                print "    -> {path} (manifest-only, add binaries in build pipeline)"
                built = built + 1
            else if val Err(e) = result:
                print "    FAILED: {e}"
                failed = failed + 1

    print ""
    print "Results: {built} built, {failed} failed"
    return if failed > 0: 1 else: 0
