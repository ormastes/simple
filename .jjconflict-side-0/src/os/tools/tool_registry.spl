# Tool Registration System
# MDSOC: feature dimension, apps layer
#
# Tools register themselves and the shell dispatches to them.

struct ToolEntry:
    name: text
    description: text
    category: text
    run_fn: fn([text]) -> i32
    capabilities: [text]

class ToolRegistry:
    tools: [ToolEntry]

impl ToolRegistry:
    static fn new() -> ToolRegistry:
        ToolRegistry(tools: [])

    me register(entry: ToolEntry):
        # Avoid duplicate registration
        var i: u64 = 0
        while i < self.tools.len():
            val existing = self.tools[i]
            if existing.name == entry.name:
                # Replace existing entry
                self.tools[i] = entry
                return
            i = i + 1
        self.tools.push(entry)

    fn lookup(name: text) -> ToolEntry?:
        var i: u64 = 0
        while i < self.tools.len():
            val entry = self.tools[i]
            if entry.name == name:
                return entry
            i = i + 1
        nil

    fn list_by_category(category: text) -> [ToolEntry]:
        val result: [ToolEntry] = []
        var i: u64 = 0
        while i < self.tools.len():
            val entry = self.tools[i]
            if entry.category == category:
                result.push(entry)
            i = i + 1
        result

    fn list_all() -> [ToolEntry]:
        self.tools

    fn names() -> [text]:
        val result: [text] = []
        var i: u64 = 0
        while i < self.tools.len():
            val entry = self.tools[i]
            result.push(entry.name)
            i = i + 1
        result
