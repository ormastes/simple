# free — Display memory usage
# MDSOC: feature dimension, apps layer

use os.apps.terminal.terminal.{Terminal}
use os.apps.shell.shell_tools.{_write_line}

extern fn rt_total_memory() -> u64
extern fn rt_used_memory() -> u64

fn run_free(args: [text]) -> i32:
    """Display amount of free and used memory."""
    val total = rt_total_memory()
    val used = rt_used_memory()
    val free_mem = total - used
    print "              total        used        free"
    print "Mem:     {total}    {used}    {free_mem}"
    return 0

fn tool_free(terminal: Terminal) -> i32:
    """Display memory usage (placeholder for SimpleOS)."""
    _write_line(terminal, "              total        used        free")
    _write_line(terminal, "Mem:     134217728    16777216   117440512")
    _write_line(terminal, "  (128MB total, placeholder values)")
    return 0
