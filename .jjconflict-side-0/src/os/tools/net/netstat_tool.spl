#![allow(unnamed_duplicate_typed_args)]
## List network connections.
## Usage: netstat [-a] [-t] [-u]

struct ConnectionEntry:
    proto: text
    local_addr: text
    foreign_addr: text
    state: text

class NetstatFlags:
    show_all: bool
    tcp_only: bool
    udp_only: bool

fn _parse_flags(args: [text]) -> NetstatFlags:
    var show_all = false
    var tcp_only = false
    var udp_only = false
    for arg in args:
        if arg == "-a":
            show_all = true
        else if arg == "-t":
            tcp_only = true
        else if arg == "-u":
            udp_only = true
    NetstatFlags(show_all: show_all, tcp_only: tcp_only, udp_only: udp_only)

fn _should_show(entry: ConnectionEntry, show_all: bool, tcp_only: bool, udp_only: bool) -> bool:
    if tcp_only and entry.proto != "tcp":
        return false
    if udp_only and entry.proto != "udp":
        return false
    if not show_all and entry.state == "LISTEN":
        return false
    true

fn _query_connections() -> [ConnectionEntry]:
    ## Query the kernel network subsystem for active connections
    ## This will be populated when the net service exposes connection table via IPC
    pass_todo("query connection table from kernel net service via IPC")
    []

fn _print_usage():
    print "Usage: netstat [-a] [-t] [-u] [-h]"
    print ""
    print "List network connections."
    print ""
    print "Options:"
    print "  -a    Show all connections (including LISTEN)"
    print "  -t    TCP connections only"
    print "  -u    UDP connections only"
    print "  -h    Show this help"

fn run_netstat(args: [text]) -> i32:
    for arg in args:
        if arg == "-h":
            _print_usage()
            return 0

    val flags = _parse_flags(args)
    val connections = _query_connections()

    print "Proto  Local Address          Foreign Address        State"
    print "-----  -------------------    -------------------    -----"

    var count = 0
    for entry in connections:
        if _should_show(entry, flags.show_all, flags.tcp_only, flags.udp_only):
            val proto = entry.proto
            val local = entry.local_addr
            val foreign = entry.foreign_addr
            val state = entry.state
            print "{proto}    {local}    {foreign}    {state}"
            count = count + 1

    if count == 0:
        print "(no connections)"

    0
