#![allow(unnamed_duplicate_typed_args)]
use os.userlib.net.{ifconfig}

## Display/configure network interfaces.
## Usage: ifconfig [INTERFACE] [IP NETMASK]

fn _format_flags(iface_status: text) -> text:
    var flags: [text] = []
    if iface_status == "up":
        flags.push("UP")
        flags.push("RUNNING")
    if iface_status == "down":
        flags.push("DOWN")
    val joined = flags.join(",")
    "<{joined}>"

fn _print_interface(iface_name: text):
    val ifaces = ifconfig()
    for iface in ifaces:
        if iface.name == iface_name:
            val flags = _format_flags(iface.status)
            val name = iface.name
            val addr = iface.address
            val mask = iface.netmask
            val mac = iface.mac
            print "{name}: flags={flags}"
            print "    inet {addr}  netmask {mask}"
            if mac.len() > 0:
                print "    ether {mac}"
            print ""
            return
    print "ifconfig: interface {iface_name} not found"

fn _print_all_interfaces():
    val ifaces = ifconfig()
    if ifaces.len() == 0:
        print "No network interfaces found."
        return

    for iface in ifaces:
        val flags = _format_flags(iface.status)
        val name = iface.name
        val addr = iface.address
        val mask = iface.netmask
        val mac = iface.mac
        print "{name}: flags={flags}"
        print "    inet {addr}  netmask {mask}"
        if mac.len() > 0:
            print "    ether {mac}"
        print ""

fn _configure_interface(name: text, ip: text, netmask: text):
    ## Interface configuration requires kernel syscall support
    # Silent no-op: network interface configuration requires kernel netdev support
    pass_todo("configure interface via syscall - set IP/netmask on {name}")

fn _print_usage():
    print "Usage: ifconfig [INTERFACE] [IP NETMASK]"
    print ""
    print "Display or configure network interfaces."
    print "  No args: show all interfaces"
    print "  INTERFACE: show specific interface"
    print "  INTERFACE IP NETMASK: configure interface"

fn run_ifconfig(args: [text]) -> i32:
    if args.len() == 0:
        _print_all_interfaces()
        return 0

    if args[0] == "-h":
        _print_usage()
        return 0

    if args.len() == 1:
        _print_interface(args[0])
        return 0

    if args.len() >= 3:
        _configure_interface(args[0], args[1], args[2])
        return 0

    print "ifconfig: invalid arguments"
    _print_usage()
    1
