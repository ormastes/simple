use os.crypto.curve25519_bigint.{
    x25519_safe,
    x25519_base_safe,
    bigint_roundtrip_probe,
    bigint_mask_probe,
    bigint_cswap_probe,
    bigint_ladder_probe
}

fn x25519_bigint_probe(scalar: [u8], u_coord: [u8]) -> [u8]:
    x25519_safe(scalar, u_coord)

fn x25519_base_bigint_probe(scalar: [u8]) -> [u8]:
    x25519_base_safe(scalar)

fn x25519_bigint_roundtrip_probe(u_coord: [u8]) -> [u8]:
    bigint_roundtrip_probe(u_coord)

fn x25519_bigint_mask_probe(u_coord: [u8]) -> [u8]:
    bigint_mask_probe(u_coord)

fn x25519_bigint_cswap_probe() -> i64:
    bigint_cswap_probe()

fn x25519_bigint_ladder_probe() -> i64:
    bigint_ladder_probe()
