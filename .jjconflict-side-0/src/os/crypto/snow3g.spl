# SNOW 3G stream cipher — hub (TS 35.216)
#
# Sub-files:
#   snow3g_sr.spl       — S_R (Rijndael/AES SubBytes) + shared helpers
#   snow3g_sq.spl       — S_Q (SNOW-specific S-box)
#   snow3g_mul_alpha.spl — MUL_alpha table (GF(2^32))
#   snow3g_div_alpha.spl — DIV_alpha table (GF(2^32))

use os.crypto.snow3g_sr.{_u8_at, _logical_shr32, _add32, _make32, _b0, _b1, _b2, _b3, _sr}
use os.crypto.snow3g_sq.{_sq}
use os.crypto.snow3g_mul_alpha.{_mul_alpha}
use os.crypto.snow3g_div_alpha.{_div_alpha}

# ============================================================================
# S-box application to 32-bit words
# S_R applied to all 4 bytes (Rijndael S-box)
# S_Q applied to all 4 bytes (SNOW S_Q box)
# ============================================================================

fn _sr_word(x: u32) -> u32:
    """Apply S_R to each byte of a 32-bit word."""
    _make32(_sr(_b0(x)), _sr(_b1(x)), _sr(_b2(x)), _sr(_b3(x)))

fn _sq_word(x: u32) -> u32:
    """Apply S_Q to each byte of a 32-bit word."""
    _make32(_sq(_b0(x)), _sq(_b1(x)), _sq(_b2(x)), _sq(_b3(x)))

# ============================================================================
# GF(2^8) multiply — MULx per TS 35.216 §3.1.1
# MULx(V, c) = (V & 0x80) ? ((V << 1) ^ c) : (V << 1)
# ============================================================================

fn _mul_gf8(v: u8, c: u8) -> u8:
    """GF(2^8) multiply: if high bit set, shift and XOR with reduction poly c."""
    val vw = v.to_u32()
    val shifted = (vw << 1) & 0xFFu32
    if (vw & 0x80u32) != 0u32:
        (shifted ^ c.to_u32()).to_u8()
    else:
        shifted.to_u8()

# ============================================================================
# S1: AES SubBytes (S_R) + MDS MixColumns with reduction 0x1b (TS 35.216 §3.3.1)
# S2: SNOW S_Q SubBytes + MDS with reduction 0x69        (TS 35.216 §3.3.2)
#
# Both use the same MDS structure (same as AES MixColumns shape):
#   r0 = MULx(s0,p) ^ s1 ^ s2 ^ (MULx(s3,p) ^ s3)
#   r1 = (MULx(s0,p) ^ s0) ^ MULx(s1,p) ^ s2 ^ s3
#   r2 = s0 ^ (MULx(s1,p) ^ s1) ^ MULx(s2,p) ^ s3
#   r3 = s0 ^ s1 ^ (MULx(s2,p) ^ s2) ^ MULx(s3,p)
# where p=0x1b for S1, p=0x69 for S2.
# Input bytes: b0=bits[31:24], b1=bits[23:16], b2=bits[15:8], b3=bits[7:0]
# ============================================================================

fn _s1_word(w: u32) -> u32:
    """S1 box: AES SubBytes then MDS with poly 0x1b (TS 35.216 §3.3.1)."""
    val s0 = _sr(_b0(w))
    val s1 = _sr(_b1(w))
    val s2 = _sr(_b2(w))
    val s3 = _sr(_b3(w))
    val p: u8 = 0x1bu8
    val r0 = _mul_gf8(s0, p) ^ s1 ^ s2 ^ (_mul_gf8(s3, p) ^ s3)
    val r1 = (_mul_gf8(s0, p) ^ s0) ^ _mul_gf8(s1, p) ^ s2 ^ s3
    val r2 = s0 ^ (_mul_gf8(s1, p) ^ s1) ^ _mul_gf8(s2, p) ^ s3
    val r3 = s0 ^ s1 ^ (_mul_gf8(s2, p) ^ s2) ^ _mul_gf8(s3, p)
    _make32(r0, r1, r2, r3)

fn _s2_word(w: u32) -> u32:
    """S2 box: SNOW S_Q SubBytes then MDS with poly 0x69 (TS 35.216 §3.3.2)."""
    val s0 = _sq(_b0(w))
    val s1 = _sq(_b1(w))
    val s2 = _sq(_b2(w))
    val s3 = _sq(_b3(w))
    val p: u8 = 0x69u8
    val r0 = _mul_gf8(s0, p) ^ s1 ^ s2 ^ (_mul_gf8(s3, p) ^ s3)
    val r1 = (_mul_gf8(s0, p) ^ s0) ^ _mul_gf8(s1, p) ^ s2 ^ s3
    val r2 = s0 ^ (_mul_gf8(s1, p) ^ s1) ^ _mul_gf8(s2, p) ^ s3
    val r3 = s0 ^ s1 ^ (_mul_gf8(s2, p) ^ s2) ^ _mul_gf8(s3, p)
    _make32(r0, r1, r2, r3)

# ============================================================================
# SNOW 3G LFSR state initialization (TS 35.216 §3.3.1)
#
# State array layout: lfsr[0..15] = LFSR cells (s0..s15)
#                     lfsr[16] = R1, lfsr[17] = R2, lfsr[18] = R3
# ============================================================================

fn _snow3g_load_state(key: [u8], iv: [u8]) -> [u32]:
    """Load SNOW 3G initial state from 16-byte key and 16-byte IV.

    LFSR initialization per TS 35.216 §3.3.1:
    k = key as 4 x 32-bit big-endian words k[0..3]
    iv = IV as 4 x 32-bit big-endian words iv[0..3]

    s[15] = k[3] XOR iv[0]
    s[14] = k[2]
    s[13] = k[1]
    s[12] = k[0] XOR iv[1]
    s[11] = k[3] XOR 0xFFFFFFFF
    s[10] = k[2] XOR 0xFFFFFFFF XOR iv[2]
    s[9]  = k[1] XOR 0xFFFFFFFF XOR iv[3]
    s[8]  = k[0] XOR 0xFFFFFFFF
    s[7]  = k[3]
    s[6]  = k[2]
    s[5]  = k[1]
    s[4]  = k[0]
    s[3]  = k[3] XOR 0xFFFFFFFF
    s[2]  = k[2] XOR 0xFFFFFFFF
    s[1]  = k[1] XOR 0xFFFFFFFF
    s[0]  = k[0] XOR 0xFFFFFFFF
    R1 = R2 = R3 = 0
    """
    # Load key as 4 big-endian 32-bit words
    val k0 = (_u8_at(key, 0u64).to_u32() << 24) | (_u8_at(key, 1u64).to_u32() << 16) | (_u8_at(key, 2u64).to_u32() << 8) | _u8_at(key, 3u64).to_u32()
    val k1 = (_u8_at(key, 4u64).to_u32() << 24) | (_u8_at(key, 5u64).to_u32() << 16) | (_u8_at(key, 6u64).to_u32() << 8) | _u8_at(key, 7u64).to_u32()
    val k2 = (_u8_at(key, 8u64).to_u32() << 24) | (_u8_at(key, 9u64).to_u32() << 16) | (_u8_at(key, 10u64).to_u32() << 8) | _u8_at(key, 11u64).to_u32()
    val k3 = (_u8_at(key, 12u64).to_u32() << 24) | (_u8_at(key, 13u64).to_u32() << 16) | (_u8_at(key, 14u64).to_u32() << 8) | _u8_at(key, 15u64).to_u32()

    # Load IV as 4 big-endian 32-bit words
    val iv0 = (_u8_at(iv, 0u64).to_u32() << 24) | (_u8_at(iv, 1u64).to_u32() << 16) | (_u8_at(iv, 2u64).to_u32() << 8) | _u8_at(iv, 3u64).to_u32()
    val iv1 = (_u8_at(iv, 4u64).to_u32() << 24) | (_u8_at(iv, 5u64).to_u32() << 16) | (_u8_at(iv, 6u64).to_u32() << 8) | _u8_at(iv, 7u64).to_u32()
    val iv2 = (_u8_at(iv, 8u64).to_u32() << 24) | (_u8_at(iv, 9u64).to_u32() << 16) | (_u8_at(iv, 10u64).to_u32() << 8) | _u8_at(iv, 11u64).to_u32()
    val iv3 = (_u8_at(iv, 12u64).to_u32() << 24) | (_u8_at(iv, 13u64).to_u32() << 16) | (_u8_at(iv, 14u64).to_u32() << 8) | _u8_at(iv, 15u64).to_u32()

    var st: [u32] = []
    # s[0..15] — LFSR cells
    st.push(k0 ^ 0xFFFFFFFFu32)
    st.push(k1 ^ 0xFFFFFFFFu32)
    st.push(k2 ^ 0xFFFFFFFFu32)
    st.push(k3 ^ 0xFFFFFFFFu32)
    st.push(k0)
    st.push(k1)
    st.push(k2)
    st.push(k3)
    st.push(k0 ^ 0xFFFFFFFFu32)
    st.push(k1 ^ 0xFFFFFFFFu32 ^ iv3)
    st.push(k2 ^ 0xFFFFFFFFu32 ^ iv2)
    st.push(k3 ^ 0xFFFFFFFFu32)
    st.push(k0 ^ iv1)
    st.push(k1)
    st.push(k2)
    st.push(k3 ^ iv0)
    # R1, R2, R3 = 0
    st.push(0u32)
    st.push(0u32)
    st.push(0u32)
    st

# ============================================================================
# SNOW 3G FSM update (TS 35.216 §3.3.2)
# ============================================================================

fn _snow3g_fsm_output(st: [u32]) -> u32:
    """Compute FSM output word F.

    F = (s[15] + R1) XOR R2
    """
    _add32(st[15], st[16]) ^ st[17]

fn _snow3g_fsm_step(st: [u32]) -> [u32]:
    """Update FSM registers R1, R2, R3 and return updated state.

    Per TS 35.216 §3.4.6 (ClockFSM):
      r     = (R2 + (R3 XOR s[5])) mod 2^32   # saved first using OLD values
      R3_new = S2(R2)                           # S2 applied to OLD R2
      R2_new = S1(R1)                           # S1 applied to OLD R1
      R1_new = r
    """
    val r1 = st[16]
    val r2 = st[17]
    val r3 = st[18]

    val r = _add32(r2, r3 ^ st[5])
    val r3_new = _s2_word(r2)
    val r2_new = _s1_word(r1)
    val r1_new = r

    st[16] = r1_new
    st[17] = r2_new
    st[18] = r3_new
    st

# ============================================================================
# SNOW 3G LFSR update (TS 35.216 §3.3.1)
# LFSR feedback polynomial:
#   s[16] = MUL_alpha(s[0][31:24]) XOR s[0]<<8 XOR s[2] XOR DIV_alpha(s[11][7:0]) XOR s[11]>>8
# All operations are on 32-bit words.
# ============================================================================

fn _snow3g_lfsr_init_step(st: [u32], f: u32) -> [u32]:
    """LFSR update in initialization mode — with feedback word F. Returns updated state."""
    val s0_hi = _b0(st[0])
    val s11_lo = _b3(st[11])

    val v = _mul_alpha(s0_hi) ^ (st[0] << 8) ^ st[2] ^ _div_alpha(s11_lo) ^ _logical_shr32(st[11], 8u32) ^ f

    # Shift: s[0]=s[1], ..., s[14]=s[15], s[15]=v
    # Unrolled to avoid interpreter array-mutation-at-variable-index limitation
    st[0] = st[1]
    st[1] = st[2]
    st[2] = st[3]
    st[3] = st[4]
    st[4] = st[5]
    st[5] = st[6]
    st[6] = st[7]
    st[7] = st[8]
    st[8] = st[9]
    st[9] = st[10]
    st[10] = st[11]
    st[11] = st[12]
    st[12] = st[13]
    st[13] = st[14]
    st[14] = st[15]
    st[15] = v
    st

fn _snow3g_lfsr_work_step(st: [u32]) -> [u32]:
    """LFSR update in working mode. Returns updated state."""
    val s0_hi = _b0(st[0])
    val s11_lo = _b3(st[11])

    val v = _mul_alpha(s0_hi) ^ (st[0] << 8) ^ st[2] ^ _div_alpha(s11_lo) ^ _logical_shr32(st[11], 8u32)

    # Shift: s[0]=s[1], ..., s[14]=s[15], s[15]=v
    # Unrolled to avoid interpreter array-mutation-at-variable-index limitation
    st[0] = st[1]
    st[1] = st[2]
    st[2] = st[3]
    st[3] = st[4]
    st[4] = st[5]
    st[5] = st[6]
    st[6] = st[7]
    st[7] = st[8]
    st[8] = st[9]
    st[9] = st[10]
    st[10] = st[11]
    st[11] = st[12]
    st[12] = st[13]
    st[13] = st[14]
    st[14] = st[15]
    st[15] = v
    st

# ============================================================================
# SNOW 3G initialization — 32 rounds with FSM feedback into LFSR
# ============================================================================

fn _snow3g_initialize(st: [u32]) -> [u32]:
    """Run 32 initialization rounds. Returns updated state."""
    var round: u64 = 0
    var s = st
    while round < 32u64:
        val f = _snow3g_fsm_output(s)
        s = _snow3g_fsm_step(s)
        s = _snow3g_lfsr_init_step(s, f)
        round = round + 1u64
    s

# ============================================================================
# Public API: snow3g_keystream
# ============================================================================

fn snow3g_keystream(key: [u8], iv: [u8], num_words: u64) -> [u32]:
    """Generate SNOW 3G keystream words.

    Args:
        key:       16-byte key.
        iv:        16-byte IV.
        num_words: number of 32-bit keystream words to generate.

    Returns: list of num_words u32 keystream words.
    """
    val st0 = _snow3g_load_state(key, iv)
    var st = _snow3g_initialize(st0)
    var ks: [u32] = []
    var i: u64 = 0
    while i < num_words:
        val f = _snow3g_fsm_output(st)
        st = _snow3g_fsm_step(st)
        val z = f ^ st[0]
        st = _snow3g_lfsr_work_step(st)
        ks.push(z)
        i = i + 1u64
    ks

# ============================================================================
# UEA2 — Confidentiality (TS 35.215 §3.2)
# ============================================================================

fn _uea2_iv(count: u32, bearer: u8, direction: u8) -> [u8]:
    """Build 16-byte UEA2 IV.

    Per TS 35.215 §3.2:
    IV[0..3]  = COUNT
    IV[4]     = (BEARER<<3) | (DIRECTION<<2)
    IV[5..7]  = 0x00
    IV[8..11] = COUNT
    IV[12]    = (BEARER<<3) | (DIRECTION<<2)
    IV[13..15]= 0x00
    """
    var iv: [u8] = []
    iv.push(((count >> 24) & 0xFFu32).to_u8())
    iv.push(((count >> 16) & 0xFFu32).to_u8())
    iv.push(((count >> 8)  & 0xFFu32).to_u8())
    iv.push((count         & 0xFFu32).to_u8())
    iv.push(((bearer.to_u32() << 3) | (direction.to_u32() << 2)).to_u8())
    iv.push(0u8)
    iv.push(0u8)
    iv.push(0u8)
    iv.push(((count >> 24) & 0xFFu32).to_u8())
    iv.push(((count >> 16) & 0xFFu32).to_u8())
    iv.push(((count >> 8)  & 0xFFu32).to_u8())
    iv.push((count         & 0xFFu32).to_u8())
    iv.push(((bearer.to_u32() << 3) | (direction.to_u32() << 2)).to_u8())
    iv.push(0u8)
    iv.push(0u8)
    iv.push(0u8)
    iv

fn uea2_encrypt(count: u32, bearer: u8, direction: u8, key: [u8], message: [u8], length_bits: u64) -> [u8]:
    """UEA2 confidentiality encrypt/decrypt (XOR with keystream).

    Args:
        count:       32-bit COUNT.
        bearer:      5-bit BEARER.
        direction:   1-bit DIRECTION.
        key:         16-byte CK.
        message:     input bytes.
        length_bits: bit-length of message to process.

    Returns: ciphertext (same length as input).
    """
    val iv = _uea2_iv(count, bearer, direction)
    val num_words = (length_bits + 31u64) / 32u64
    val ks = snow3g_keystream(key, iv, num_words)

    var ciphertext: [u8] = []
    val num_bytes = (length_bits + 7u64) / 8u64
    var i: u64 = 0
    while i < num_bytes:
        val word_idx = i / 4u64
        val byte_pos = 3u64 - (i & 3u64)
        val shift = (byte_pos * 8u64).to_u32()
        val ks_byte = ((ks[word_idx] >> shift) & 0xFFu32).to_u8()
        ciphertext.push(_u8_at(message, i) ^ ks_byte)
        i = i + 1u64

    # Zero trailing bits in last byte if not byte-aligned
    val trailing = length_bits & 7u64
    if trailing != 0u64:
        val last = num_bytes - 1u64
        val mask = (0xFFu32 << (8u32 - trailing.to_u32())).to_u8()
        ciphertext[last] = ciphertext[last] & mask

    ciphertext

# ============================================================================
# UIA2 — Integrity MAC (TS 35.215 §3.3)
# ============================================================================

fn _uia2_iv(count: u32, fresh: u32, direction: u8) -> [u8]:
    """Build 16-byte UIA2 IV.

    Per TS 35.215 §3.3:
    IV[0..3]  = COUNT
    IV[4..7]  = FRESH
    IV[8..11] = COUNT
    IV[12..15]= FRESH XOR (DIRECTION<<31)
    """
    var iv: [u8] = []
    iv.push(((count >> 24) & 0xFFu32).to_u8())
    iv.push(((count >> 16) & 0xFFu32).to_u8())
    iv.push(((count >> 8)  & 0xFFu32).to_u8())
    iv.push((count         & 0xFFu32).to_u8())
    iv.push(((fresh >> 24) & 0xFFu32).to_u8())
    iv.push(((fresh >> 16) & 0xFFu32).to_u8())
    iv.push(((fresh >> 8)  & 0xFFu32).to_u8())
    iv.push((fresh         & 0xFFu32).to_u8())
    iv.push(((count >> 24) & 0xFFu32).to_u8())
    iv.push(((count >> 16) & 0xFFu32).to_u8())
    iv.push(((count >> 8)  & 0xFFu32).to_u8())
    iv.push((count         & 0xFFu32).to_u8())
    val dir_bit = direction.to_u32() << 31
    val fresh_xor = fresh ^ dir_bit
    iv.push(((fresh_xor >> 24) & 0xFFu32).to_u8())
    iv.push(((fresh_xor >> 16) & 0xFFu32).to_u8())
    iv.push(((fresh_xor >> 8)  & 0xFFu32).to_u8())
    iv.push((fresh_xor         & 0xFFu32).to_u8())
    iv

fn uia2_mac(count: u32, fresh: u32, direction: u8, key: [u8], message: [u8], length_bits: u64) -> u32:
    """UIA2 integrity MAC-I computation.

    Args:
        count:       32-bit COUNT.
        fresh:       32-bit FRESH.
        direction:   1-bit DIRECTION.
        key:         16-byte IK.
        message:     input bytes.
        length_bits: number of bits in message.

    Returns: 32-bit MAC-I.
    """
    val iv = _uia2_iv(count, fresh, direction)
    val num_ks_words = (length_bits / 32u64) + 2u64
    val ks = snow3g_keystream(key, iv, num_ks_words)

    var t: u32 = 0u32
    var bit_i: u64 = 0u64
    while bit_i < length_bits:
        val byte_idx = bit_i / 8u64
        val bit_in_byte = 7u64 - (bit_i & 7u64)
        val msg_byte = _u8_at(message, byte_idx).to_u64()
        val msg_bit = (msg_byte >> bit_in_byte) & 1u64

        if msg_bit == 1u64:
            val word_idx = bit_i / 32u64
            val bit_off  = bit_i & 31u64
            var z_i: u32 = 0u32
            if bit_off == 0u64:
                z_i = ks[word_idx]
            else:
                val shift_up = bit_off.to_u32()
                val shift_dn = (32u64 - bit_off).to_u32()
                z_i = (ks[word_idx] << shift_up) | _logical_shr32(ks[word_idx + 1u64], shift_dn)
            t = t ^ z_i

        bit_i = bit_i + 1u64

    # Final: T ^= z[L..L+31]
    val l_word = length_bits / 32u64
    val l_off  = length_bits & 31u64
    var z_l: u32 = 0u32
    if l_off == 0u64:
        z_l = ks[l_word]
    else:
        val shift_up = l_off.to_u32()
        val shift_dn = (32u64 - l_off).to_u32()
        z_l = (ks[l_word] << shift_up) | _logical_shr32(ks[l_word + 1u64], shift_dn)
    t = t ^ z_l

    t
