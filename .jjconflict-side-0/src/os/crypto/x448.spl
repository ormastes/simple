# X448 ECDH — RFC 7748 §5 (Curve448 Montgomery ladder)
#
# Thin wrapper over os.crypto.curve448 that exposes the canonical
# RFC 7748 API surface with the expected function names:
#
#   x448_scalarmult(scalar, u) -> [u8]   (56 + 56 → 56 bytes)
#   x448_keypair(seed)         -> [list]  ([priv: [u8], pub: [u8]])
#   x448_dh(priv, peer_pub)    -> [u8]
#   x448_clamp(scalar)         -> [u8]
#
# All real work is in os.crypto.curve448.  See that module for field
# arithmetic, Goldilocks reduction, Montgomery ladder details.
#
# Note: X448 keys are 56 bytes, NOT 32 bytes.  The scalar and u-coordinate
# are both 56-byte arrays.  (The "32 + 32" sizing in some task descriptions
# is a copy-paste from X25519; the correct sizes per RFC 7748 §5 are 56 + 56.)
#
# Reference: RFC 7748 §5, §6.2

use os.crypto.curve448.{x448_scalar_mult, x448_keygen, x448_clamp}
use os.crypto.curve448 as _c448

fn x448_scalarmult(scalar: [u8], u: [u8]) -> [u8]:
    """X448(k, u): RFC 7748 §5 scalar multiplication.

    scalar  — 56-byte private scalar (will be clamped internally)
    u       — 56-byte u-coordinate of the peer's public key (or base point)
    Returns   56-byte result.
    """
    x448_scalar_mult(scalar, u)

fn x448_keypair(seed: [u8]) -> [list]:
    """Derive an X448 key pair from a 56-byte seed.

    Returns [private_key: [u8], public_key: [u8]] — both 56 bytes.
    private_key is the clamped scalar; public_key is scalar × base_point.
    """
    x448_keygen(seed)

fn x448_dh(priv_key: [u8], peer_pub: [u8]) -> [u8]:
    """X448 Diffie-Hellman shared secret."""
    _c448.x448_dh(priv_key, peer_pub)
