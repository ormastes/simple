#![allow(unnamed_duplicate_typed_args)]
# SHA-256 — Pure Simple Implementation (FIPS 180-4)
#
# Implements SHA-256 hash and HMAC-SHA-256 for SimpleOS.
# No SFFI/Rust FFI — pure Simple language, suitable for baremetal.
#
# Reference: FIPS 180-4 (Secure Hash Standard)
# Reference: RFC 2104 (HMAC)

# ============================================================================
# Constants
# ============================================================================

# WORKAROUND: global val arrays not supported in baremetal Cranelift.
# Constants stored in C static const arrays (baremetal_stubs.c section 8d).
extern fn rt_sha256_K(index: i64) -> u32
extern fn rt_sha256_H(index: i64) -> u32

# ============================================================================
# Bit Manipulation Helpers (u32)
# ============================================================================

fn _u32_mask(x: u32) -> u32:
    """Mask to 32 bits."""
    x & 0xFFFFFFFF

fn rotr32(x: u32, n: u32) -> u32:
    """32-bit right rotation."""
    _u32_mask((x >> n) | (x << (32 - n)))

fn ch(e: u32, f: u32, g: u32) -> u32:
    """SHA-256 Ch function: (e AND f) XOR (NOT e AND g)."""
    _u32_mask((e & f) ^ ((~e) & g))

fn maj(a: u32, b: u32, c: u32) -> u32:
    """SHA-256 Maj function: (a AND b) XOR (a AND c) XOR (b AND c)."""
    _u32_mask((a & b) ^ (a & c) ^ (b & c))

fn big_sigma0(a: u32) -> u32:
    """SHA-256 big Sigma_0: ROTR^2(a) XOR ROTR^13(a) XOR ROTR^22(a)."""
    _u32_mask(rotr32(a, 2) ^ rotr32(a, 13) ^ rotr32(a, 22))

fn big_sigma1(e: u32) -> u32:
    """SHA-256 big Sigma_1: ROTR^6(e) XOR ROTR^11(e) XOR ROTR^25(e)."""
    _u32_mask(rotr32(e, 6) ^ rotr32(e, 11) ^ rotr32(e, 25))

fn small_sigma0(w: u32) -> u32:
    """SHA-256 small sigma_0: ROTR^7(w) XOR ROTR^18(w) XOR SHR^3(w)."""
    _u32_mask(rotr32(w, 7) ^ rotr32(w, 18) ^ (w >> 3))

fn small_sigma1(w: u32) -> u32:
    """SHA-256 small sigma_1: ROTR^17(w) XOR ROTR^19(w) XOR SHR^10(w)."""
    _u32_mask(rotr32(w, 17) ^ rotr32(w, 19) ^ (w >> 10))

# ============================================================================
# Message Padding
# ============================================================================

fn _sha256_compute_padded_len(data_len: u64) -> u64:
    """Compute the exact padded message length (always a multiple of 64).

    Standalone function to avoid depending on .len() which is unreliable
    in baremetal Cranelift.
    """
    val min_padded = data_len + 1 + 8   # data + 0x80 + 8 bytes length
    val rem = min_padded % 64
    if rem == 0:
        min_padded
    else:
        min_padded + (64 - rem)

fn sha256_pad(data: [u8]) -> [u8]:
    """Pad message to a multiple of 64 bytes per FIPS 180-4 section 5.1.1.

    Appends bit '1' (0x80 byte), then zeros, then 64-bit big-endian
    bit length, such that the total length is a multiple of 512 bits (64 bytes).

    WORKAROUND: Uses manual length counter because .len() is unreliable
    in baremetal Cranelift (returns wrong values after many pushes).
    """
    val data_len = data.len()
    val bit_len: u64 = data_len.to_u64() * 8

    # Start with copy of original data
    var padded: [u8] = []
    var i: u64 = 0
    var padded_count: u64 = 0
    while i < data_len:
        padded.push(data[i])
        padded_count = padded_count + 1
        i = i + 1

    # Append 0x80 byte (the '1' bit followed by zeros)
    padded.push(0x80)
    padded_count = padded_count + 1

    # Pad with zeros until length is 56 mod 64
    # (leaving 8 bytes for the 64-bit length)
    while (padded_count % 64) != 56:
        padded.push(0x00)
        padded_count = padded_count + 1

    # Append 64-bit big-endian bit length
    padded.push(((bit_len >> 56) & 0xFF).to_u8())
    padded.push(((bit_len >> 48) & 0xFF).to_u8())
    padded.push(((bit_len >> 40) & 0xFF).to_u8())
    padded.push(((bit_len >> 32) & 0xFF).to_u8())
    padded.push(((bit_len >> 24) & 0xFF).to_u8())
    padded.push(((bit_len >> 16) & 0xFF).to_u8())
    padded.push(((bit_len >> 8) & 0xFF).to_u8())
    padded.push((bit_len & 0xFF).to_u8())

    padded

# ============================================================================
# Block Processing
# ============================================================================

fn sha256_process_block(block: [u8], offset: u64, h: [u32]) -> [u32]:
    """Process one 512-bit (64-byte) block of padded message.

    Args:
        block: The padded message bytes.
        offset: Byte offset into block where this 64-byte chunk starts.
        h: Current hash state [8 x u32].

    Returns: Updated hash state [8 x u32].
    """
    # 1. Prepare the message schedule W[0..63]
    var w: [u32] = []

    # W[0..15]: big-endian decode from block
    var t: u64 = 0
    while t < 16:
        val base = offset + t * 4
        val w_t = _u32_mask(
            (block[base].to_u32() << 24) |
            (block[base + 1].to_u32() << 16) |
            (block[base + 2].to_u32() << 8) |
            block[base + 3].to_u32()
        )
        w.push(w_t)
        t = t + 1

    # W[16..63]: extended via small sigma functions
    while t < 64:
        val s0 = small_sigma0(w[t - 15])
        val s1 = small_sigma1(w[t - 2])
        val w_t = _u32_mask(w[t - 16] + s0 + w[t - 7] + s1)
        w.push(w_t)
        t = t + 1

    # 2. Initialize working variables
    var a = h[0]
    var b = h[1]
    var c = h[2]
    var d = h[3]
    var e = h[4]
    var f = h[5]
    var g = h[6]
    var hh = h[7]

    # 3. Compression loop (64 rounds)
    var round: u64 = 0
    while round < 64:
        val s1 = big_sigma1(e)
        val ch_val = ch(e, f, g)
        val temp1 = _u32_mask(hh + s1 + ch_val + rt_sha256_K(round) + w[round])
        val s0 = big_sigma0(a)
        val maj_val = maj(a, b, c)
        val temp2 = _u32_mask(s0 + maj_val)

        hh = g
        g = f
        f = e
        e = _u32_mask(d + temp1)
        d = c
        c = b
        b = a
        a = _u32_mask(temp1 + temp2)

        round = round + 1

    # 4. Compute new hash values
    var result: [u32] = []
    result.push(_u32_mask(h[0] + a))
    result.push(_u32_mask(h[1] + b))
    result.push(_u32_mask(h[2] + c))
    result.push(_u32_mask(h[3] + d))
    result.push(_u32_mask(h[4] + e))
    result.push(_u32_mask(h[5] + f))
    result.push(_u32_mask(h[6] + g))
    result.push(_u32_mask(h[7] + hh))
    result

# ============================================================================
# SHA-256 Hash
# ============================================================================

fn sha256(data: [u8]) -> [u8]:
    """Compute SHA-256 hash of data.

    Args:
        data: Input bytes.

    Returns: 32-byte (256-bit) digest.
    """
    # Compute padded length BEFORE padding (data.len() is reliable here,
    # before any push operations that could confuse the baremetal runtime)
    val original_len = data.len().to_u64()
    val padded_len = _sha256_compute_padded_len(original_len)
    val num_blocks = padded_len / 64

    # Pad the message
    val padded = sha256_pad(data)

    # Initialize hash state
    var h: [u32] = []
    var i: u64 = 0
    while i < 8:
        h.push(rt_sha256_H(i))
        i = i + 1

    # Process each 64-byte block
    var block_idx: u64 = 0
    while block_idx < num_blocks:
        h = sha256_process_block(padded, block_idx * 64, h)
        block_idx = block_idx + 1

    # Convert hash state to big-endian bytes
    var digest: [u8] = []
    i = 0
    while i < 8:
        val word = h[i]
        digest.push(((word >> 24) & 0xFF).to_u8())
        digest.push(((word >> 16) & 0xFF).to_u8())
        digest.push(((word >> 8) & 0xFF).to_u8())
        digest.push((word & 0xFF).to_u8())
        i = i + 1

    digest

# ============================================================================
# HMAC-SHA-256 (RFC 2104)
# ============================================================================

fn sha256_hmac(key: [u8], data: [u8]) -> [u8]:
    """Compute HMAC-SHA-256.

    HMAC(K, m) = H((K' XOR opad) || H((K' XOR ipad) || m))

    Where:
        K' = key padded/hashed to block size (64 bytes)
        ipad = 0x36 repeated 64 times
        opad = 0x5c repeated 64 times

    Args:
        key: HMAC key (any length).
        data: Message bytes.

    Returns: 32-byte HMAC digest.
    """
    val block_size: u64 = 64

    # Step 1: Derive K' (block-size key)
    # If key > block_size, hash it first
    var k_prime: [u8] = []
    if key.len() > block_size:
        val hashed_key = sha256(key)
        var j: u64 = 0
        while j < hashed_key.len():
            k_prime.push(hashed_key[j])
            j = j + 1
    else:
        var j: u64 = 0
        while j < key.len():
            k_prime.push(key[j])
            j = j + 1

    # Pad K' with zeros to block_size
    while k_prime.len() < block_size:
        k_prime.push(0x00)

    # Step 2: Compute inner hash: H((K' XOR ipad) || message)
    var inner_input: [u8] = []
    var i: u64 = 0
    while i < block_size:
        inner_input.push((k_prime[i] ^ 0x36).to_u8())
        i = i + 1

    # Append message
    i = 0
    while i < data.len():
        inner_input.push(data[i])
        i = i + 1

    val inner_hash = sha256(inner_input)

    # Step 3: Compute outer hash: H((K' XOR opad) || inner_hash)
    var outer_input: [u8] = []
    i = 0
    while i < block_size:
        outer_input.push((k_prime[i] ^ 0x5c).to_u8())
        i = i + 1

    # Append inner hash
    i = 0
    while i < inner_hash.len():
        outer_input.push(inner_hash[i])
        i = i + 1

    sha256(outer_input)
