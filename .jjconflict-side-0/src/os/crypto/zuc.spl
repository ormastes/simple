# ZUC-128 Stream Cipher — hub (TS 35.221)
#
# Implements ZUC-128 keystream generator per 3GPP TS 35.221,
# plus EEA3 (confidentiality) per 3GPP TS 35.222 §5
# and EIA3 (integrity MAC) per 3GPP TS 35.222 §6.
#
# References:
#   3GPP TS 35.221 v15 — ZUC specification
#   3GPP TS 35.222 v15 — EEA3 & EIA3; Document 2: ZUC Specification
#   3GPP TS 35.223     — EEA3 and EIA3 test data
#
# NOTE: verified in interpreter mode per
# .claude/memory/feedback_compile_mode_false_greens.md
#
# Sub-files:
#   zuc_s0.spl — S0 S-box (TS 35.221 Annex A, Table 1)
#   zuc_s1.spl — S1 S-box (TS 35.221 Annex A, Table 2)

use os.crypto.zuc_s0.{_s0}
use os.crypto.zuc_s1.{_s1}

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

# ============================================================================
# Internal helpers
# ============================================================================

fn _u8_at(buf: [u8], idx: u64) -> u8:
    rt_bytes_u8_at(buf, idx.to_i64()).to_u8()

fn _logical_shr64(x: u64, n: u64) -> u64:
    """Logical (zero-extending) right shift for u64 — works around interpreter
    arithmetic-shift bug on u64 fn parameters (see bug u64_right_shift_fn_param_arithmetic_2026-05-02)."""
    if n == 0u64:
        x
    else if n >= 64u64:
        0u64
    else:
        val mask: u64 = (1u64 << (64u64 - n)) - 1u64
        (x >> n) & mask

fn _mod31(x: u64) -> u32:
    """Reduction mod (2^31 - 1) — the ZUC prime field.

    Uses the identity: v mod (2^31-1) where v can be up to ~2^62.
    Applies iterative halving trick until < 2^31-1.
    """
    var v = x
    # First pass: fold bits above 31 — use logical shr to avoid interpreter sign-extend bug
    v = (v & 0x7FFFFFFFu64) + _logical_shr64(v, 31u64)
    # Second pass: might still be >= 2^31-1 after first fold
    if v >= 0x7FFFFFFFu64:
        v = v - 0x7FFFFFFFu64
    v.to_u32()

fn _logical_shr32(x: u32, n: u32) -> u32:
    """Logical (zero-extending) right shift for u32 — works around interpreter
    arithmetic-shift bug on fn parameters and potential sign-extension in to_u64()."""
    val xu = x.to_u64() & 0xFFFFFFFFu64
    val nu = n.to_u64()
    (_logical_shr64(xu, nu) & 0xFFFFFFFFu64).to_u32()

fn _rotl32(x: u32, n: u32) -> u32:
    """32-bit left rotation — uses logical shr to avoid interpreter arithmetic-shift bug."""
    (x << n) | _logical_shr32(x, 32u32 - n)

fn _add32(a: u32, b: u32) -> u32:
    """32-bit addition mod 2^32."""
    ((a.to_u64() + b.to_u64()) & 0xFFFFFFFFu64).to_u32()

# ============================================================================
# L1 and L2 linear transforms (TS 35.221 §3.1)
# ============================================================================

fn _l1(x: u32) -> u32:
    """L1 linear transform for F (TS 35.221 §3.1 Table 1)."""
    x ^ _rotl32(x, 2u32) ^ _rotl32(x, 10u32) ^ _rotl32(x, 18u32) ^ _rotl32(x, 24u32)

fn _l2(x: u32) -> u32:
    """L2 linear transform for F (TS 35.221 §3.1 Table 1)."""
    x ^ _rotl32(x, 8u32) ^ _rotl32(x, 14u32) ^ _rotl32(x, 22u32) ^ _rotl32(x, 30u32)

# ============================================================================
# Byte/word helpers
# ============================================================================

fn _make32(b0: u8, b1: u8, b2: u8, b3: u8) -> u32:
    """Pack 4 bytes big-endian into u32."""
    (b0.to_u32() << 24) | (b1.to_u32() << 16) | (b2.to_u32() << 8) | b3.to_u32()

fn _b0(x: u32) -> u8:
    (_logical_shr32(x, 24u32) & 0xFFu32).to_u8()

fn _b1(x: u32) -> u8:
    (_logical_shr32(x, 16u32) & 0xFFu32).to_u8()

fn _b2(x: u32) -> u8:
    (_logical_shr32(x, 8u32) & 0xFFu32).to_u8()

fn _b3(x: u32) -> u8:
    (x & 0xFFu32).to_u8()

# ============================================================================
# F function (TS 35.221 §3.1)
# ============================================================================

fn _f_out_w(x0: u32, r1: u32, r2: u32) -> u32:
    """W = (X0 XOR R1) + R2 (XOR first, then 32-bit addition)."""
    _add32(x0 ^ r1, r2)

fn _f_update(x1: u32, x2: u32, r1: u32, r2: u32) -> [u32]:
    """Compute new R1 and R2.

    Per TS 35.221 §3.1:
    W1 = R1 + X1  (32-bit mod 2^32 addition)
    W2 = R2 XOR X2
    u  = L1((W1 << 16) | (W2 >> 16))   (L applied first to bit-concat)
    v  = L2((W2 << 16) | (W1 >> 16))
    R1'= S(u)   (S applied after L: byte 0,2 → S0; byte 1,3 → S1)
    R2'= S(v)
    """
    val w1 = _add32(r1, x1)
    val w2 = r2 ^ x2

    # Bit-concatenation: (W1 << 16) | (W2 >> 16) — low 16 of W1 || high 16 of W2
    val w1u = w1.to_u64()
    val w2u = w2.to_u64()
    val u_raw = (((w1u << 16) | _logical_shr64(w2u, 16u64)) & 0xFFFFFFFFu64).to_u32()
    val v_raw = (((w2u << 16) | _logical_shr64(w1u, 16u64)) & 0xFFFFFFFFu64).to_u32()

    # L transform first, then S-box
    val lu = _l1(u_raw)
    val lv = _l2(v_raw)

    # S-box application: byte 0,2 → S0; byte 1,3 → S1
    val r1_new = _make32(_s0(_b0(lu)), _s1(_b1(lu)), _s0(_b2(lu)), _s1(_b3(lu)))
    val r2_new = _make32(_s0(_b0(lv)), _s1(_b1(lv)), _s0(_b2(lv)), _s1(_b3(lv)))

    var res: [u32] = []
    res.push(r1_new)
    res.push(r2_new)
    res

# ============================================================================
# ZUC LFSR update (TS 35.221 §3.1)
# LFSR feedback polynomial:
#   s_{16} = 2^15*s_{15} + 2^17*s_{13} + 2^21*s_{10} + 2^20*s_4 + (2^8+1)*s_0  mod (2^31-1)
# ============================================================================

fn _lfsr_feedback(s: [u32]) -> u64:
    """Compute the raw LFSR feedback sum (before mod)."""
    val s15 = s[15].to_u64()
    val s13 = s[13].to_u64()
    val s10 = s[10].to_u64()
    val s4  = s[4].to_u64()
    val s0  = s[0].to_u64()
    (s15 << 15) + (s13 << 17) + (s10 << 21) + (s4 << 20) + (s0 << 8) + s0

# ============================================================================
# Bit reorganization BR (TS 35.221 §3.1)
# ============================================================================

fn _bit_reorg(s: [u32]) -> [u32]:
    """Extract X0..X3 from LFSR state.

    X0 = s15[30:15] || s14[15:0]   (high 16 of 31-bit s15, low 16 of 31-bit s14)
    X1 = s11[15:0]  || s9[30:15]
    X2 = s7[15:0]   || s5[30:15]
    X3 = s2[15:0]   || s0[30:15]

    High 16 = bits 30..15, Low 16 = bits 15..0 of 31-bit cell.
    """
    val x0 = ((s[15] & 0x7FFF8000u32) << 1) | (s[14] & 0x0000FFFFu32)
    val x1 = ((s[11] & 0x0000FFFFu32) << 16) | _logical_shr32(s[9], 15u32)
    val x2 = ((s[7]  & 0x0000FFFFu32) << 16) | _logical_shr32(s[5], 15u32)
    val x3 = ((s[2]  & 0x0000FFFFu32) << 16) | _logical_shr32(s[0], 15u32)

    var res: [u32] = []
    res.push(x0)
    res.push(x1)
    res.push(x2)
    res.push(x3)
    res

# ============================================================================
# ZUC d_i constants (TS 35.221 Annex A, Table 3)
# Each d_i is a 15-bit value embedded in the LFSR initial state.
# ============================================================================

fn _d_const(i: u64) -> u32:
    """15-bit d constant for LFSR cell i (from TS 35.221 Annex A Table 3)."""
    if i == 0u64:  0x44D7u32
    else if i == 1u64:  0x26BCu32
    else if i == 2u64:  0x626Bu32
    else if i == 3u64:  0x135Eu32
    else if i == 4u64:  0x5789u32
    else if i == 5u64:  0x35E2u32
    else if i == 6u64:  0x7135u32
    else if i == 7u64:  0x09AFu32
    else if i == 8u64:  0x4D78u32
    else if i == 9u64:  0x2F13u32
    else if i == 10u64: 0x6BC4u32
    else if i == 11u64: 0x1AF1u32
    else if i == 12u64: 0x5E26u32
    else if i == 13u64: 0x3C4Du32
    else if i == 14u64: 0x789Au32
    else: 0x47ACu32

# ============================================================================
# ZUC state initialization (TS 35.221 §3.3)
# s_i = k_i || d_i || iv_i  (bit concatenation: 8 || 15 || 8 = 31 bits)
# s[16]=R1, s[17]=R2 (32-bit memory registers)
# ============================================================================

fn _zuc_load_state(key: [u8], iv: [u8]) -> [u32]:
    """Load ZUC initial state from 16-byte key and 16-byte IV."""
    var state: [u32] = []
    var i: u64 = 0
    while i < 16:
        val ki  = _u8_at(key, i).to_u32()
        val di  = _d_const(i) & 0x7FFFu32
        val ivi = _u8_at(iv, i).to_u32()
        # 31-bit cell: [bits 30..23] = k_i, [bits 22..8] = d_i, [bits 7..0] = iv_i
        val si = (ki << 23) | (di << 8) | ivi
        state.push(si)
        i = i + 1
    # R1 and R2 start at 0
    state.push(0u32)
    state.push(0u32)
    state

# ============================================================================
# Public API: zuc_keystream
# ============================================================================

fn zuc_keystream(key: [u8], iv: [u8], num_words: u64) -> [u32]:
    """Generate ZUC keystream words.

    Args:
        key:       16-byte key (ZUC-128).
        iv:        16-byte IV.
        num_words: number of 32-bit keystream words to generate.

    Returns: list of num_words u32 keystream words (big-endian word order,
             MSB of each word is the first bit of the keystream).

    All state mutations are inlined here to work around interpreter array-mutation
    boundary limitation (mutations to arrays passed as fn args don't propagate back).
    """
    var state = _zuc_load_state(key, iv)

    # === inline _zuc_initialize: 32 init rounds (TS 35.221 §3.4) ===
    var round: u64 = 0
    while round < 32:
        val r1 = state[16]
        val r2 = state[17]
        val x = _bit_reorg(state)
        val w = _f_out_w(x[0u64], r1, r2)
        val nr = _f_update(x[1u64], x[2u64], r1, r2)
        # inlined _lfsr_with_init_mode
        val _fb_i = _lfsr_feedback(state) + ((w >> 1) & 0x7FFFFFFFu32).to_u64()
        var _new_s_i = _mod31(_fb_i)
        if _new_s_i == 0u32:
            _new_s_i = 0x7FFFFFFFu32
        var _li: u64 = 0
        while _li < 15:
            val _li1 = _li + 1u64
            state[_li] = state[_li1]
            _li = _li + 1
        state[15] = _new_s_i
        state[16] = nr[0u64]
        state[17] = nr[1u64]
        round = round + 1

    # post-init discarded round (TS 35.221 §3.4)
    val ri1 = state[16]
    val ri2 = state[17]
    val xi = _bit_reorg(state)
    val nri = _f_update(xi[1u64], xi[2u64], ri1, ri2)
    # inlined _lfsr_with_work_mode
    val _fb_w1 = _lfsr_feedback(state)
    var _new_s_w1 = _mod31(_fb_w1)
    if _new_s_w1 == 0u32:
        _new_s_w1 = 0x7FFFFFFFu32
    var _lw1: u64 = 0
    while _lw1 < 15:
        val _lw1n = _lw1 + 1u64
        state[_lw1] = state[_lw1n]
        _lw1 = _lw1 + 1
    state[15] = _new_s_w1
    state[16] = nri[0u64]
    state[17] = nri[1u64]

    # === inline _zuc_run_32: keystream generation loop ===
    var ks: [u32] = []
    var i: u64 = 0
    while i < num_words:
        val rr1 = state[16]
        val rr2 = state[17]
        val xx = _bit_reorg(state)
        val ww = _f_out_w(xx[0u64], rr1, rr2)
        val nrr = _f_update(xx[1u64], xx[2u64], rr1, rr2)
        val z = ww ^ xx[3u64]
        # inlined _lfsr_with_work_mode
        val _fb_w2 = _lfsr_feedback(state)
        var _new_s_w2 = _mod31(_fb_w2)
        if _new_s_w2 == 0u32:
            _new_s_w2 = 0x7FFFFFFFu32
        var _lw2: u64 = 0
        while _lw2 < 15:
            val _lw2n = _lw2 + 1u64
            state[_lw2] = state[_lw2n]
            _lw2 = _lw2 + 1
        state[15] = _new_s_w2
        state[16] = nrr[0u64]
        state[17] = nrr[1u64]
        ks.push(z)
        i = i + 1
    ks

# ============================================================================
# EEA3 — Confidentiality (TS 35.222 §5)
# ============================================================================

fn _eea3_iv(count: u32, bearer: u8, direction: u8) -> [u8]:
    """Build 16-byte EEA3 IV.

    Per TS 35.222 §5.1:
    IV[0..3] = COUNT
    IV[4]    = (BEARER<<3) | (DIRECTION<<2)
    IV[5..7] = 0x00
    IV[8..15]= IV[0..7]   (duplicate)
    """
    var iv: [u8] = []
    iv.push((_logical_shr32(count, 24u32) & 0xFFu32).to_u8())
    iv.push((_logical_shr32(count, 16u32) & 0xFFu32).to_u8())
    iv.push((_logical_shr32(count, 8u32)  & 0xFFu32).to_u8())
    iv.push((count         & 0xFFu32).to_u8())
    iv.push(((bearer.to_u32() << 3) | (direction.to_u32() << 2)).to_u8())
    iv.push(0u8)
    iv.push(0u8)
    iv.push(0u8)
    # Duplicate bytes 0..7
    var j: u64 = 0
    while j < 8:
        iv.push(iv[j])
        j = j + 1
    iv

fn eea3_encrypt(count: u32, bearer: u8, direction: u8, key: [u8], message: [u8], length_bits: u64) -> [u8]:
    """EEA3 confidentiality encrypt/decrypt (same operation — XOR with keystream).

    Args:
        count:       32-bit COUNT.
        bearer:      5-bit BEARER.
        direction:   1-bit DIRECTION.
        key:         16-byte CK.
        message:     input bytes (ceil(length_bits/8) bytes).
        length_bits: bit-length of message to process.

    Returns: ciphertext (same length as input).
    """
    val iv = _eea3_iv(count, bearer, direction)
    val num_words = (length_bits + 31u64) / 32u64
    val ks = zuc_keystream(key, iv, num_words)

    var ciphertext: [u8] = []
    val num_bytes = (length_bits + 7u64) / 8u64
    val remainder = length_bits & 7u64
    var i: u64 = 0
    while i < num_bytes:
        val word_idx = i / 4u64
        val byte_pos = 3u64 - (i & 3u64)
        val shift = (byte_pos * 8u64).to_u32()
        val ks_byte = (_logical_shr32(ks[word_idx], shift) & 0xFFu32).to_u8()
        var ct_byte = _u8_at(message, i) ^ ks_byte
        # Mask the last byte to length_bits boundary (zero out unused trailing bits)
        if (remainder != 0u64) and (i == num_bytes - 1u64):
            val mask = ((0xFFu64 << (8u64 - remainder)) & 0xFFu64).to_u8()
            ct_byte = ct_byte & mask
        ciphertext.push(ct_byte)
        i = i + 1

    ciphertext

# ============================================================================
# EIA3 — Integrity MAC (TS 35.222 §6)
# ============================================================================

fn _eia3_iv(count: u32, bearer: u8, direction: u8) -> [u8]:
    """Build 16-byte EIA3 IV.

    Per TS 35.222 §6.1:
    IV[0..3]   = COUNT
    IV[4]      = BEARER << 3
    IV[5..7]   = 0x00
    IV[8..11]  = COUNT
    IV[12]     = (BEARER<<3) | (DIRECTION<<2)
    IV[13..15] = 0x00
    """
    var iv: [u8] = []
    iv.push((_logical_shr32(count, 24u32) & 0xFFu32).to_u8())
    iv.push((_logical_shr32(count, 16u32) & 0xFFu32).to_u8())
    iv.push((_logical_shr32(count, 8u32)  & 0xFFu32).to_u8())
    iv.push((count         & 0xFFu32).to_u8())
    iv.push((bearer.to_u32() << 3).to_u8())
    iv.push(0u8)
    iv.push(0u8)
    iv.push(0u8)
    iv.push((_logical_shr32(count, 24u32) & 0xFFu32).to_u8())
    iv.push((_logical_shr32(count, 16u32) & 0xFFu32).to_u8())
    iv.push((_logical_shr32(count, 8u32)  & 0xFFu32).to_u8())
    iv.push((count         & 0xFFu32).to_u8())
    iv.push(((bearer.to_u32() << 3) | (direction.to_u32() << 2)).to_u8())
    iv.push(0u8)
    iv.push(0u8)
    iv.push(0u8)
    iv

fn eia3_mac(count: u32, bearer: u8, direction: u8, key: [u8], message: [u8], length_bits: u64) -> u32:
    """EIA3 integrity MAC-I computation.

    Args:
        count:       32-bit COUNT.
        bearer:      5-bit BEARER.
        direction:   1-bit DIRECTION.
        key:         16-byte IK.
        message:     input bytes (ceil(length_bits/8) bytes).
        length_bits: number of bits in message.

    Returns: 32-bit MAC-I.
    """
    val iv = _eia3_iv(count, bearer, direction)

    # Need ceil(length_bits/32) + 2 keystream words (TS 35.222 §6.2)
    val num_ks_words = (length_bits + 31u64) / 32u64 + 2u64
    val ks = zuc_keystream(key, iv, num_ks_words)

    # T is the running MAC accumulator
    var t: u32 = 0u32

    # For each message bit i (0..length_bits-1):
    #   if message bit i is 1, T ^= keystream_word_at_bit_position_i
    # Per TS 35.222 §6.2: T ^= z_i for each bit i where bit i of M is 1
    var bit_i: u64 = 0
    while bit_i < length_bits:
        # Get message bit at position bit_i (MSB first)
        val byte_idx = bit_i / 8u64
        val bit_in_byte = 7u64 - (bit_i & 7u64)
        val msg_byte = _u8_at(message, byte_idx).to_u64()
        val msg_bit = (msg_byte >> bit_in_byte) & 1u64

        if msg_bit == 1u64:
            # Get 32-bit keystream word starting at bit position bit_i
            val word_idx = bit_i / 32u64
            val bit_off  = bit_i & 31u64
            var z_i: u32 = 0u32
            if bit_off == 0u64:
                z_i = ks[word_idx]
            else:
                # Straddles two words: upper part from ks[word_idx], lower from ks[word_idx+1]
                val shift_up = bit_off.to_u32()
                val shift_dn = (32u64 - bit_off).to_u32()
                z_i = (ks[word_idx] << shift_up) | _logical_shr32(ks[word_idx + 1u64], shift_dn)
            t = t ^ z_i

        bit_i = bit_i + 1

    # Final: T ^= z[L..L+31] (the word at bit position L)
    val l_word = length_bits / 32u64
    val l_off  = length_bits & 31u64
    var z_l: u32 = 0u32
    if l_off == 0u64:
        z_l = ks[l_word]
    else:
        val shift_up = l_off.to_u32()
        val shift_dn = (32u64 - l_off).to_u32()
        z_l = (ks[l_word] << shift_up) | _logical_shr32(ks[l_word + 1u64], shift_dn)
    t = t ^ z_l

    # Final step: T ^= last keystream word (the MAC key word)
    # Per TS 35.222 §6.2: MAC = T XOR z_{32*floor(L/32)+32}
    t = t ^ ks[ks.len() - 1u64]

    t
