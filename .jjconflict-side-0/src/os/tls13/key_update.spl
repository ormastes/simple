# KeyUpdate message — RFC 8446 §4.6.3
#
# Implements:
#   KeyUpdateRequest enum  — update_not_requested(0) / update_requested(1)
#   parse_key_update       — decode a 1-byte KeyUpdate body
#   emit_key_update        — build the 5-byte handshake message
#   derive_next_traffic_secret — HKDF-Expand-Label("traffic upd", hash_len)

extern fn rt_bytes_u8_at(arr: [u8], idx: i64) -> i64

use os.tls13.hkdf.{hkdf_expand_label, hkdf_expand_label_sha384}

# ============================================================================
# Handshake type constant
# ============================================================================

val HS_KEY_UPDATE: u8 = 24

# ============================================================================
# KeyUpdateRequest enum  (RFC 8446 §4.6.3)
# Both variants carry a dummy field because Simple's parser requires at least
# one field per enum arm.
# ============================================================================

enum KeyUpdateRequest:
    UpdateNotRequested(unused: u8)
    UpdateRequested(unused: u8)
    Invalid(unused: u8)

# ============================================================================
# parse_key_update
#
# Accepts the KeyUpdate *body* bytes (i.e. the 1-byte payload after stripping
# the 4-byte handshake header).  Returns Invalid for any value other than 0
# or 1; callers MUST treat Invalid as an illegal_parameter alert per §4.6.3.
# ============================================================================

fn parse_key_update(payload: [u8]) -> KeyUpdateRequest:
    """Parse a KeyUpdate message body (RFC 8446 §4.6.3).

    Args:
        payload: 1-byte body (request_update octet).

    Returns:
        KeyUpdateRequest.UpdateNotRequested — byte == 0
        KeyUpdateRequest.UpdateRequested   — byte == 1
        KeyUpdateRequest.Invalid           — any other value or empty payload
    """
    if payload.len() < 1:
        return KeyUpdateRequest.Invalid(unused: 0u8)
    val byte = rt_bytes_u8_at(payload, 0).to_u8()
    if byte == 0u8:
        return KeyUpdateRequest.UpdateNotRequested(unused: 0u8)
    elif byte == 1u8:
        return KeyUpdateRequest.UpdateRequested(unused: 0u8)
    else:
        return KeyUpdateRequest.Invalid(unused: byte)

# ============================================================================
# emit_key_update
#
# Builds the complete handshake-layer KeyUpdate message:
#   HandshakeType  = 24          (1 byte)
#   length         = 0x000001    (3 bytes, big-endian)
#   request_update = 0 or 1     (1 byte)
# Total: 5 bytes.
# ============================================================================

fn emit_key_update(request_update: bool) -> [u8]:
    """Build a TLS 1.3 KeyUpdate handshake message (RFC 8446 §4.6.3).

    Args:
        request_update: true → request_update=1 (peer should also update keys);
                        false → request_update=0 (no response required).

    Returns: 5-byte handshake-layer message.
    """
    var out: [u8] = []
    out.push(HS_KEY_UPDATE)
    out.push(0x00u8)
    out.push(0x00u8)
    out.push(0x01u8)
    if request_update:
        out.push(0x01u8)
    else:
        out.push(0x00u8)
    out

# ============================================================================
# derive_next_traffic_secret
#
# RFC 8446 §7.2:
#   application_traffic_secret_N+1 =
#       HKDF-Expand-Label(application_traffic_secret_N, "traffic upd", "", HashLen)
#
# Dispatches on hash_len: 32 → SHA-256 path, 48 → SHA-384 path.
# ============================================================================

fn derive_next_traffic_secret(current_secret: [u8], hash_len: i64) -> [u8]:
    """Derive the next application traffic secret via KeyUpdate key schedule.

    Args:
        current_secret: current application_traffic_secret_N ([u8], HashLen bytes).
        hash_len: 32 for SHA-256-based cipher suites, 48 for SHA-384.

    Returns: next application_traffic_secret_N+1 ([u8], hash_len bytes).
    """
    var empty_ctx: [u8] = []
    if hash_len == 48:
        return hkdf_expand_label_sha384(current_secret, "traffic upd", empty_ctx, 48u64)
    hkdf_expand_label(current_secret, "traffic upd", empty_ctx, hash_len.to_u64())
