# Dual-Backend Runner — Native vs Browser Engine Comparison
#
# Renders the same compositor scene through two different backends
# and compares the pixel output for visual consistency verification.
#
# Backend A: HostedCompositorBackend (winit pixel buffer, Rust FFI)
# Backend B: BrowserCompositorBackend (Simple [u32] buffer, software)
#
# Uses a backend-swap approach: single compositor, render twice.

use os.compositor.compositor.{Compositor}
use os.compositor.hosted_backend.{HostedCompositorBackend}
use os.compositor.browser_compositor_backend.{BrowserCompositorBackend}
use os.compositor.hosted_input_backend.{HostedInputBackend}
use os.compositor.screenshot_compare.{ComparisonResult, compare_pixel_buffers,
    compare_exact, generate_diff_image, print_comparison_report}

extern fn rt_winit_save_pixels_bmp(path: text, width: i64, height: i64, pixels: [u32]) -> bool

# ============================================================================
# Dual Backend Runner
# ============================================================================

class DualBackendRunner:
    """Coordinates rendering through native and browser backends for comparison.

    Creates a single compositor with demo windows, renders through each
    backend, extracts pixel buffers, and runs comparison analysis.
    """
    native_backend: HostedCompositorBackend
    browser_backend: BrowserCompositorBackend
    input: HostedInputBackend
    sw: i32
    sh: i32
    threshold: i32

impl DualBackendRunner:

    static fn new(native: HostedCompositorBackend, browser: BrowserCompositorBackend,
                  input: HostedInputBackend, width: i32, height: i32) -> DualBackendRunner:
        """Create a dual backend runner with both backends and shared input."""
        DualBackendRunner(
            native_backend: native,
            browser_backend: browser,
            input: input,
            sw: width,
            sh: height,
            threshold: 2
        )

    me set_threshold(t: i32):
        """Set the per-channel comparison threshold (0 = exact match)."""
        self.threshold = t

    me run_comparison(output_dir: text) -> ComparisonResult:
        """Run the full dual-backend comparison.

        1. Create compositor with native backend + demo windows
        2. Render with native backend → extract pixels
        3. Create fresh compositor with browser backend + same windows
        4. Render with browser backend → extract pixels
        5. Compare and generate diff image
        6. Save all 3 BMPs to output_dir

        Returns ComparisonResult.
        """
        print "=== Dual-Backend Comparison ==="
        print "Resolution: {self.sw}x{self.sh}"
        print "Threshold: {self.threshold} per channel"
        print ""

        # --- Step 1: Render with native backend ---
        print "[1/5] Rendering with native backend (winit)..."
        var native_comp = Compositor.with_backends(self.native_backend, self.input, self.sw, self.sh)
        native_comp.create_window("Terminal", 60, 80, 400, 280)
        native_comp.create_window("Hello World", 320, 140, 360, 240)
        native_comp.create_window("File Manager", 520, 320, 320, 200)
        native_comp.render_all()

        # Extract native pixels via the backend trait (no raw winit FFI here)
        val native_raw = self.native_backend.get_pixels()
        var native_pixels: [u32] = []
        var i: i32 = 0
        while i < native_raw.len():
            native_pixels = native_pixels + [native_raw[i].to_u32()]
            i = i + 1
        print "  Native pixels extracted: {native_pixels.len()}"

        # Save native BMP via the backend trait (no raw winit FFI here)
        val native_path = output_dir + "/compare_native.bmp"
        self.native_backend.save_bmp(native_path)
        print "  Saved: {native_path}"

        # --- Step 2: Render with browser backend ---
        print "[2/5] Rendering with browser backend (software)..."
        var browser_comp = Compositor.with_backends(self.browser_backend, self.input, self.sw, self.sh)
        browser_comp.create_window("Terminal", 60, 80, 400, 280)
        browser_comp.create_window("Hello World", 320, 140, 360, 240)
        browser_comp.create_window("File Manager", 520, 320, 320, 200)
        browser_comp.render_all()

        # Extract browser pixels
        val browser_pixels = self.browser_backend.get_pixel_buffer()
        print "  Browser pixels extracted: {browser_pixels.len()}"

        # Save browser BMP
        val browser_path = output_dir + "/compare_browser.bmp"
        val sw64: i64 = self.sw
        val sh64: i64 = self.sh
        rt_winit_save_pixels_bmp(browser_path, sw64, sh64, browser_pixels)
        print "  Saved: {browser_path}"

        # --- Step 3: Compare ---
        print "[3/5] Comparing pixel buffers..."
        val result = compare_pixel_buffers(native_pixels, browser_pixels, self.sw, self.sh, self.threshold)

        # --- Step 4: Generate diff image ---
        print "[4/5] Generating diff image..."
        val diff_pixels = generate_diff_image(native_pixels, browser_pixels, self.sw, self.sh)
        val diff_path = output_dir + "/compare_diff.bmp"
        rt_winit_save_pixels_bmp(diff_path, sw64, sh64, diff_pixels)
        print "  Saved: {diff_path}"

        # --- Step 5: Print report ---
        print "[5/5] Comparison results:"
        print_comparison_report(result)

        result
