#![allow(unnamed_duplicate_typed_args)]
# Window Snap — Edge detection for drag-to-snap
#
# Detects when a cursor is near screen edges during drag and computes
# the target snap layout. Supports halves, quarters, and full-screen snap.

use os.compositor.layout_manager.{WindowLayout}
use std.window_protocol.geometry.{Px}

# ============================================================================
# Snap Zone
# ============================================================================

enum SnapZone:
    None_
    LeftHalf
    RightHalf
    TopHalf
    BottomHalf
    FullScreen
    TopLeftQuarter
    TopRightQuarter
    BottomLeftQuarter
    BottomRightQuarter

# ============================================================================
# Snap Result
# ============================================================================

struct SnapResult:
    """Result of a snap detection: the zone and target layout."""
    zone: SnapZone
    target: WindowLayout

# ============================================================================
# Snap Detection
# ============================================================================

fn detect_snap_zone(cursor_x: Px, cursor_y: Px, screen_w: Px, screen_h: Px, edge_threshold: Px) -> SnapZone:
    """Detect which snap zone the cursor is in based on proximity to edges.

    Returns SnapZone.None_ if not near any edge.
    Corner zones take priority over edge zones.
    """
    val cx = cursor_x.value
    val cy = cursor_y.value
    val sw = screen_w.value
    val sh = screen_h.value
    val et = edge_threshold.value

    val near_left = cx < et
    val near_right = cx > sw - et
    val near_top = cy < et
    val near_bottom = cy > sh - et

    # Corners first (higher priority)
    if near_left and near_top:
        return SnapZone.TopLeftQuarter
    if near_right and near_top:
        return SnapZone.TopRightQuarter
    if near_left and near_bottom:
        return SnapZone.BottomLeftQuarter
    if near_right and near_bottom:
        return SnapZone.BottomRightQuarter

    # Edges
    if near_left:
        return SnapZone.LeftHalf
    if near_right:
        return SnapZone.RightHalf
    if near_top:
        return SnapZone.FullScreen
    if near_bottom:
        return SnapZone.BottomHalf

    SnapZone.None_

# ============================================================================
# Snap Layout Computation
# ============================================================================

fn compute_snap_layout(zone: SnapZone, screen_w: Px, screen_h: Px, taskbar_h: Px) -> WindowLayout:
    """Return the target layout rectangle for a given snap zone."""
    val sw = screen_w.value
    val sh = screen_h.value
    val th = taskbar_h.value
    val usable_h = sh - th
    val half_w = sw / 2
    val half_h = usable_h / 2
    match zone:
        SnapZone.LeftHalf:
            WindowLayout(x: Px(value: 0), y: Px(value: 0), width: Px(value: half_w), height: Px(value: usable_h))
        SnapZone.RightHalf:
            WindowLayout(x: Px(value: half_w), y: Px(value: 0), width: Px(value: half_w), height: Px(value: usable_h))
        SnapZone.TopHalf:
            WindowLayout(x: Px(value: 0), y: Px(value: 0), width: Px(value: sw), height: Px(value: half_h))
        SnapZone.BottomHalf:
            WindowLayout(x: Px(value: 0), y: Px(value: half_h), width: Px(value: sw), height: Px(value: half_h))
        SnapZone.FullScreen:
            WindowLayout(x: Px(value: 0), y: Px(value: 0), width: Px(value: sw), height: Px(value: usable_h))
        SnapZone.TopLeftQuarter:
            WindowLayout(x: Px(value: 0), y: Px(value: 0), width: Px(value: half_w), height: Px(value: half_h))
        SnapZone.TopRightQuarter:
            WindowLayout(x: Px(value: half_w), y: Px(value: 0), width: Px(value: half_w), height: Px(value: half_h))
        SnapZone.BottomLeftQuarter:
            WindowLayout(x: Px(value: 0), y: Px(value: half_h), width: Px(value: half_w), height: Px(value: half_h))
        SnapZone.BottomRightQuarter:
            WindowLayout(x: Px(value: half_w), y: Px(value: half_h), width: Px(value: half_w), height: Px(value: half_h))
        SnapZone.None_:
            WindowLayout(x: Px(value: 0), y: Px(value: 0), width: Px(value: sw), height: Px(value: usable_h))

# ============================================================================
# Snap Result Construction
# ============================================================================

fn snap_at(cursor_x: Px, cursor_y: Px, screen_w: Px, screen_h: Px, taskbar_h: Px, edge_threshold: Px) -> SnapResult:
    """Detect snap zone and compute the target layout in one call."""
    val zone = detect_snap_zone(cursor_x, cursor_y, screen_w, screen_h, edge_threshold)
    val target = compute_snap_layout(zone, screen_w, screen_h, taskbar_h)
    SnapResult(zone: zone, target: target)
