# Linux Personality Syscall ABI Compatibility Contracts for SimpleOS game layer.

class SyscallCapability:
    """Readiness descriptor for a single Linux syscall family."""
    name: text
    category: text
    status: text
    notes: text

    static fn ready(name: text, cat: text) -> SyscallCapability:
        SyscallCapability(name: name, category: cat, status: "ready", notes: "")

    static fn partial(name: text, cat: text, note: text) -> SyscallCapability:
        SyscallCapability(name: name, category: cat, status: "partial", notes: note)

    static fn stub(name: text, cat: text) -> SyscallCapability:
        SyscallCapability(name: name, category: cat, status: "stub", notes: "")

    static fn missing(name: text, cat: text) -> SyscallCapability:
        SyscallCapability(name: name, category: cat, status: "missing", notes: "")

    me is_usable() -> bool:
        self.status == "ready" or self.status == "partial"

    me summary() -> text:
        var note_part = ""
        if self.notes != "":
            note_part = " (" + self.notes + ")"
        "[" + self.status + "] " + self.name + " (" + self.category + ")" + note_part


class LinuxSyscallMatrix:
    """Flat capability matrix for Linux syscall families (up to 16 entries)."""
    count: i64
    s0_name: text
    s1_name: text
    s2_name: text
    s3_name: text
    s4_name: text
    s5_name: text
    s6_name: text
    s7_name: text
    s8_name: text
    s9_name: text
    s10_name: text
    s11_name: text
    s12_name: text
    s13_name: text
    s14_name: text
    s15_name: text
    s0_status: text
    s1_status: text
    s2_status: text
    s3_status: text
    s4_status: text
    s5_status: text
    s6_status: text
    s7_status: text
    s8_status: text
    s9_status: text
    s10_status: text
    s11_status: text
    s12_status: text
    s13_status: text
    s14_status: text
    s15_status: text

    static fn create() -> LinuxSyscallMatrix:
        LinuxSyscallMatrix(
            count: 0,
            s0_name: "", s1_name: "", s2_name: "", s3_name: "",
            s4_name: "", s5_name: "", s6_name: "", s7_name: "",
            s8_name: "", s9_name: "", s10_name: "", s11_name: "",
            s12_name: "", s13_name: "", s14_name: "", s15_name: "",
            s0_status: "", s1_status: "", s2_status: "", s3_status: "",
            s4_status: "", s5_status: "", s6_status: "", s7_status: "",
            s8_status: "", s9_status: "", s10_status: "", s11_status: "",
            s12_status: "", s13_status: "", s14_status: "", s15_status: ""
        )

    me add(name: text, status: text) -> text:
        """Add a syscall entry. Returns '' on success or 'matrix full'."""
        if self.count >= 16:
            return "matrix full"
        if self.count == 0:
            self.s0_name = name
            self.s0_status = status
        if self.count == 1:
            self.s1_name = name
            self.s1_status = status
        if self.count == 2:
            self.s2_name = name
            self.s2_status = status
        if self.count == 3:
            self.s3_name = name
            self.s3_status = status
        if self.count == 4:
            self.s4_name = name
            self.s4_status = status
        if self.count == 5:
            self.s5_name = name
            self.s5_status = status
        if self.count == 6:
            self.s6_name = name
            self.s6_status = status
        if self.count == 7:
            self.s7_name = name
            self.s7_status = status
        if self.count == 8:
            self.s8_name = name
            self.s8_status = status
        if self.count == 9:
            self.s9_name = name
            self.s9_status = status
        if self.count == 10:
            self.s10_name = name
            self.s10_status = status
        if self.count == 11:
            self.s11_name = name
            self.s11_status = status
        if self.count == 12:
            self.s12_name = name
            self.s12_status = status
        if self.count == 13:
            self.s13_name = name
            self.s13_status = status
        if self.count == 14:
            self.s14_name = name
            self.s14_status = status
        if self.count == 15:
            self.s15_name = name
            self.s15_status = status
        self.count = self.count + 1
        ""

    me get_status(name: text) -> text:
        """Return status for a named syscall family, or 'unknown'."""
        if self.s0_name == name:
            return self.s0_status
        if self.s1_name == name:
            return self.s1_status
        if self.s2_name == name:
            return self.s2_status
        if self.s3_name == name:
            return self.s3_status
        if self.s4_name == name:
            return self.s4_status
        if self.s5_name == name:
            return self.s5_status
        if self.s6_name == name:
            return self.s6_status
        if self.s7_name == name:
            return self.s7_status
        if self.s8_name == name:
            return self.s8_status
        if self.s9_name == name:
            return self.s9_status
        if self.s10_name == name:
            return self.s10_status
        if self.s11_name == name:
            return self.s11_status
        if self.s12_name == name:
            return self.s12_status
        if self.s13_name == name:
            return self.s13_status
        if self.s14_name == name:
            return self.s14_status
        if self.s15_name == name:
            return self.s15_status
        "unknown"

    me _status_count(target: text) -> i64:
        var n: i64 = 0
        if self.s0_status == target: n = n + 1
        if self.s1_status == target: n = n + 1
        if self.s2_status == target: n = n + 1
        if self.s3_status == target: n = n + 1
        if self.s4_status == target: n = n + 1
        if self.s5_status == target: n = n + 1
        if self.s6_status == target: n = n + 1
        if self.s7_status == target: n = n + 1
        if self.s8_status == target: n = n + 1
        if self.s9_status == target: n = n + 1
        if self.s10_status == target: n = n + 1
        if self.s11_status == target: n = n + 1
        if self.s12_status == target: n = n + 1
        if self.s13_status == target: n = n + 1
        if self.s14_status == target: n = n + 1
        if self.s15_status == target: n = n + 1
        n

    me ready_count() -> i64:
        self._status_count("ready")

    me partial_count() -> i64:
        self._status_count("partial")

    me missing_count() -> i64:
        self._status_count("missing")

    me coverage_report() -> text:
        val total = self.count
        val rdy = self.ready_count()
        val par = self.partial_count()
        val mis = self.missing_count()
        val stub_n = total - rdy - par - mis
        "syscall matrix: total=" + total.to_text() + " ready=" + rdy.to_text() +
            " partial=" + par.to_text() + " stub=" + stub_n.to_text() +
            " missing=" + mis.to_text()


class LinuxPersonalityContract:
    """Full Linux ABI personality contract for SimpleOS game compatibility."""
    elf_ready: bool
    dynlink_ready: bool
    mmap_status: text
    mprotect_status: text
    futex_status: text
    clone_status: text
    signal_status: text
    epoll_status: text
    eventfd_status: text
    timerfd_status: text
    signalfd_status: text
    ioctl_status: text
    syscall_matrix: LinuxSyscallMatrix

    static fn create() -> LinuxPersonalityContract:
        LinuxPersonalityContract(
            elf_ready: false, dynlink_ready: false,
            mmap_status: "missing", mprotect_status: "missing",
            futex_status: "missing", clone_status: "missing",
            signal_status: "missing", epoll_status: "missing",
            eventfd_status: "missing", timerfd_status: "missing",
            signalfd_status: "missing", ioctl_status: "missing",
            syscall_matrix: LinuxSyscallMatrix.create()
        )

    me evaluate_from_posix() -> text:
        """Set statuses from existing POSIX infra. ELF+dynlink=ready, mmap=partial, rest=stub."""
        self.elf_ready = true
        self.dynlink_ready = true
        self.mmap_status = "partial"
        self.mprotect_status = "stub"
        self.futex_status = "stub"
        self.clone_status = "stub"
        self.signal_status = "stub"
        self.epoll_status = "stub"
        self.eventfd_status = "stub"
        self.timerfd_status = "stub"
        self.signalfd_status = "stub"
        self.ioctl_status = "stub"
        self.syscall_matrix.add("mmap", self.mmap_status)
        self.syscall_matrix.add("mprotect", self.mprotect_status)
        self.syscall_matrix.add("futex", self.futex_status)
        self.syscall_matrix.add("clone", self.clone_status)
        self.syscall_matrix.add("signal", self.signal_status)
        self.syscall_matrix.add("epoll", self.epoll_status)
        self.syscall_matrix.add("eventfd", self.eventfd_status)
        self.syscall_matrix.add("timerfd", self.timerfd_status)
        self.syscall_matrix.add("signalfd", self.signalfd_status)
        self.syscall_matrix.add("ioctl", self.ioctl_status)
        "evaluated"

    me is_game_viable() -> bool:
        """True if ELF + dynlink + mmap + clone + signal are all usable."""
        if self.elf_ready == false:
            return false
        if self.dynlink_ready == false:
            return false
        val mmap_ok = self.mmap_status == "ready" or self.mmap_status == "partial"
        if mmap_ok == false:
            return false
        val clone_ok = self.clone_status == "ready" or self.clone_status == "partial"
        if clone_ok == false:
            return false
        val signal_ok = self.signal_status == "ready" or self.signal_status == "partial"
        if signal_ok == false:
            return false
        true

    me summary() -> text:
        "LinuxPersonalityContract: elf=" + self.elf_ready.to_text() +
            " dynlink=" + self.dynlink_ready.to_text() +
            " mmap=" + self.mmap_status +
            " clone=" + self.clone_status +
            " signal=" + self.signal_status +
            " game_viable=" + self.is_game_viable().to_text()

    me full_report() -> text:
        "=== Linux Personality Contract ===\n" +
            "  elf_ready:      " + self.elf_ready.to_text() + "\n" +
            "  dynlink_ready:  " + self.dynlink_ready.to_text() + "\n" +
            "  mmap:           " + self.mmap_status + "\n" +
            "  mprotect:       " + self.mprotect_status + "\n" +
            "  futex:          " + self.futex_status + "\n" +
            "  clone:          " + self.clone_status + "\n" +
            "  signal:         " + self.signal_status + "\n" +
            "  epoll:          " + self.epoll_status + "\n" +
            "  eventfd:        " + self.eventfd_status + "\n" +
            "  timerfd:        " + self.timerfd_status + "\n" +
            "  signalfd:       " + self.signalfd_status + "\n" +
            "  ioctl:          " + self.ioctl_status + "\n" +
            "  " + self.syscall_matrix.coverage_report() + "\n" +
            "  game_viable:    " + self.is_game_viable().to_text() + "\n"
