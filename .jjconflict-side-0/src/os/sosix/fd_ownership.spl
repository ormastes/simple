# SOSIX file descriptor ownership transfer protocol.
#
# Tracks FD ownership records and pending transfers between processes.
# Does not replace the kernel fd_table; records ownership metadata only.

use os.kernel.errno.{EBADF, EINVAL, ENOMEM}

val SOSIX_MAX_FD_OWNS: u64 = 64
val SOSIX_FD_OWN_HANDLE_SLOT_BITS: u64 = 16
val SOSIX_FD_OWN_HANDLE_SLOT_MASK: u64 = 0xFFFF
val SOSIX_FD_OWN_NO_HANDLE: u64 = 0xFFFFFFFFFFFFFFFF

val SOSIX_FD_OWN_FREE: u8 = 0
val SOSIX_FD_OWN_HELD: u8 = 1
val SOSIX_FD_OWN_TRANSFERRING: u8 = 2
val SOSIX_FD_OWN_TRANSFERRED: u8 = 3

var sosix_fd_own_active: [bool; 64]
var sosix_fd_own_state: [u8; 64]
var sosix_fd_own_owner_pid: [u64; 64]
var sosix_fd_own_target_pid: [u64; 64]
var sosix_fd_own_fd: [i32; 64]
var sosix_fd_own_generations: [u64; 64]

fn sosix_fd_ownership_init():
    """Initialize the SOSIX FD ownership transfer table."""
    var i: u64 = 0
    while i < SOSIX_MAX_FD_OWNS:
        sosix_fd_own_active[i] = false
        sosix_fd_own_state[i] = SOSIX_FD_OWN_FREE
        sosix_fd_own_owner_pid[i] = 0
        sosix_fd_own_target_pid[i] = 0
        sosix_fd_own_fd[i] = -1
        sosix_fd_own_generations[i] = 0
        i = i + 1

fn _sosix_fd_own_handle_slot(handle: u64) -> u64:
    handle & SOSIX_FD_OWN_HANDLE_SLOT_MASK

fn _sosix_fd_own_handle_generation(handle: u64) -> u64:
    handle >> SOSIX_FD_OWN_HANDLE_SLOT_BITS

fn _sosix_fd_own_make_handle(slot: u64) -> u64:
    (sosix_fd_own_generations[slot] << SOSIX_FD_OWN_HANDLE_SLOT_BITS) | slot

fn _sosix_fd_own_valid(handle: u64) -> bool:
    if handle == SOSIX_FD_OWN_NO_HANDLE:
        return false
    val slot = _sosix_fd_own_handle_slot(handle)
    if slot >= SOSIX_MAX_FD_OWNS:
        return false
    if not sosix_fd_own_active[slot]:
        return false
    sosix_fd_own_generations[slot] == _sosix_fd_own_handle_generation(handle)

fn sosix_fd_own_create(owner_pid: u64, fd: i32) -> i64:
    """Register an FD ownership record for owner_pid.

    Returns a handle (>=0) on success, or a negated errno on failure.
    """
    if owner_pid == 0:
        return 0 - EINVAL as i64
    if fd < 0:
        return 0 - EINVAL as i64
    var i: u64 = 0
    while i < SOSIX_MAX_FD_OWNS:
        if not sosix_fd_own_active[i]:
            sosix_fd_own_active[i] = true
            sosix_fd_own_state[i] = SOSIX_FD_OWN_HELD
            sosix_fd_own_owner_pid[i] = owner_pid
            sosix_fd_own_target_pid[i] = 0
            sosix_fd_own_fd[i] = fd
            return _sosix_fd_own_make_handle(i) as i64
        i = i + 1
    0 - ENOMEM as i64

fn sosix_fd_own_begin_transfer(handle: u64, target_pid: u64) -> i64:
    """Begin an FD ownership transfer to target_pid.

    The record transitions from HELD to TRANSFERRING.
    Returns 0 on success, negated errno on failure.
    """
    if not _sosix_fd_own_valid(handle):
        return 0 - EBADF as i64
    if target_pid == 0:
        return 0 - EINVAL as i64
    val slot = _sosix_fd_own_handle_slot(handle)
    if sosix_fd_own_state[slot] != SOSIX_FD_OWN_HELD:
        return 0 - EINVAL as i64
    sosix_fd_own_state[slot] = SOSIX_FD_OWN_TRANSFERRING
    sosix_fd_own_target_pid[slot] = target_pid
    0

fn sosix_fd_own_complete_transfer(handle: u64) -> i64:
    """Complete a pending FD ownership transfer.

    Ownership moves to target_pid; record state becomes TRANSFERRED.
    Returns 0 on success, negated errno on failure.
    """
    if not _sosix_fd_own_valid(handle):
        return 0 - EBADF as i64
    val slot = _sosix_fd_own_handle_slot(handle)
    if sosix_fd_own_state[slot] != SOSIX_FD_OWN_TRANSFERRING:
        return 0 - EINVAL as i64
    sosix_fd_own_owner_pid[slot] = sosix_fd_own_target_pid[slot]
    sosix_fd_own_target_pid[slot] = 0
    sosix_fd_own_state[slot] = SOSIX_FD_OWN_TRANSFERRED
    0

fn sosix_fd_own_cancel_transfer(handle: u64) -> i64:
    """Cancel an in-progress FD ownership transfer, reverting to HELD.

    Returns 0 on success, negated errno on failure.
    """
    if not _sosix_fd_own_valid(handle):
        return 0 - EBADF as i64
    val slot = _sosix_fd_own_handle_slot(handle)
    if sosix_fd_own_state[slot] != SOSIX_FD_OWN_TRANSFERRING:
        return 0 - EINVAL as i64
    sosix_fd_own_target_pid[slot] = 0
    sosix_fd_own_state[slot] = SOSIX_FD_OWN_HELD
    0

fn sosix_fd_own_get_owner(handle: u64) -> i64:
    """Return the current owner PID of the FD, or negated errno."""
    if not _sosix_fd_own_valid(handle):
        return 0 - EBADF as i64
    sosix_fd_own_owner_pid[_sosix_fd_own_handle_slot(handle)] as i64

fn sosix_fd_own_get_fd(handle: u64) -> i32:
    """Return the FD associated with this ownership record, or -1 on invalid handle."""
    if not _sosix_fd_own_valid(handle):
        return -1
    sosix_fd_own_fd[_sosix_fd_own_handle_slot(handle)]

fn sosix_fd_own_get_state(handle: u64) -> i64:
    """Return the ownership state byte, or negated errno."""
    if not _sosix_fd_own_valid(handle):
        return 0 - EBADF as i64
    sosix_fd_own_state[_sosix_fd_own_handle_slot(handle)] as i64

fn sosix_fd_own_close(handle: u64) -> i64:
    """Release an FD ownership record slot.

    Returns 0 on success, negated errno on failure.
    """
    if not _sosix_fd_own_valid(handle):
        return 0 - EBADF as i64
    val slot = _sosix_fd_own_handle_slot(handle)
    sosix_fd_own_active[slot] = false
    sosix_fd_own_state[slot] = SOSIX_FD_OWN_FREE
    sosix_fd_own_owner_pid[slot] = 0
    sosix_fd_own_target_pid[slot] = 0
    sosix_fd_own_fd[slot] = -1
    sosix_fd_own_generations[slot] = sosix_fd_own_generations[slot] + 1
    0

fn sosix_fd_own_handle_slot(handle: u64) -> i64:
    if not _sosix_fd_own_valid(handle):
        return 0 - EBADF as i64
    _sosix_fd_own_handle_slot(handle) as i64

fn sosix_fd_own_handle_generation(handle: u64) -> i64:
    if not _sosix_fd_own_valid(handle):
        return 0 - EBADF as i64
    _sosix_fd_own_handle_generation(handle) as i64
