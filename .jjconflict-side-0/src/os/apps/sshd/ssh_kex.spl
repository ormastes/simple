#![allow(unnamed_duplicate_typed_args)]
# SSH Key Exchange — Curve25519-SHA256 (RFC 8731)
#
# Implements the curve25519-sha256 key exchange method.
# Uses the pure Simple Curve25519 and SHA-256 implementations.
#
# Exchange hash H is computed over:
#   string  V_C   (client version string, without CR LF)
#   string  V_S   (server version string, without CR LF)
#   string  I_C   (client KEXINIT payload)
#   string  I_S   (server KEXINIT payload)
#   string  K_S   (server host key blob)
#   string  Q_C   (client ephemeral public key, 32 bytes)
#   string  Q_S   (server ephemeral public key, 32 bytes)
#   mpint   K     (shared secret)
#
# Session keys are derived per RFC 4253 section 7.2.
#
# Implementation is split across three files:
#   ssh_kex_primitives.spl  — byte helpers, structs, algorithm name builders
#   ssh_kex_crypto.spl      — keygen, ECDH, KDF, host key blobs, DER, signing
#   ssh_kex.spl             — KEXINIT builder + KEX message assembly (this file)

use os.apps.sshd.ssh_packet.{ssh_put_u32, ssh_put_string, ssh_put_text, ssh_put_bool, ssh_put_mpint, ssh_get_string, SshStringResult}
use os.apps.sshd.ssh_kex_primitives.{
    SSH_MSG_KEX_ECDH_INIT, SSH_MSG_KEX_ECDH_REPLY,
    SshKexState, SshSessionKeys, HostKeySet, HostCertificateSet,
    _u8_at, _append_byte, _concat_bytes, _push_bytes,
    _zeroed_32_bytes, _slice_bytes,
    _push_string_bytes, _push_string_32,
    _push_server_kex_algorithms, _push_host_key_algorithms, _push_gcm_cipher_pair,
    _push_none, _push_empty_string, _push_bool_false, _push_zero_u32,
    _host_certificates_empty, host_key_algorithms_with_certificates,
    host_key_set_advertised_algorithms
}
use os.apps.sshd.ssh_kex_random.{ssh_kex_generate_private_key, ssh_kex_generate_keypair}
use os.apps.sshd.ssh_kex_core.{
    ssh_kex_public_from_private, ssh_kex_compute_shared,
    ssh_kex_compute_exchange_hash, ssh_derive_keys
}

# ============================================================================
# KEXINIT Builder (host-key-set aware)
# ============================================================================

fn ssh_build_kexinit_for_host_keys(host_keys: HostKeySet) -> [u8]:
    ssh_build_kexinit_for_host_keys_and_certs(host_keys, HostCertificateSet(
        ssh_ed25519_cert: nil,
        rsa_sha2_256_cert: nil,
        rsa_sha2_512_cert: nil
    ))

fn ssh_build_kexinit_for_host_keys_and_certs(host_keys: HostKeySet, host_certs: HostCertificateSet) -> [u8]:
    """Build SSH_MSG_KEXINIT advertising host key algorithms present in host_keys.

    Wire format is identical to ssh_build_kexinit() in ssh_transport.spl
    except the server_host_key_algorithms field reflects the actual key set.
    Other algorithms are fixed: curve25519-sha256,ext-info-s,kex-strict-s-v00@openssh.com
    KEX, aes256-gcm then aes128-gcm, no MAC, no compression.
    """
    if _host_certificates_empty(host_certs):
        var buf: [u8] = []

        buf = _append_byte(buf, 20)

        var i: u64 = 0
        while i < 16:
            buf = _append_byte(buf, 0)
            i = i + 1

        buf = _push_server_kex_algorithms(buf)
        buf = _push_host_key_algorithms(buf, host_keys)
        buf = _push_gcm_cipher_pair(buf)
        buf = _push_gcm_cipher_pair(buf)
        buf = _push_none(buf)
        buf = _push_none(buf)
        buf = _push_none(buf)
        buf = _push_none(buf)

        # The first empty language list appends correctly through the normal
        # helper path. The remaining zero-only tail bytes are appended from a
        # stable zero buffer because literal/byte-at-a-time growth has proven
        # unreliable on the baremetal live lane.
        buf = _push_empty_string(buf)
        buf = _concat_bytes(buf, _slice_bytes(_zeroed_32_bytes(), 0, 9))
        return buf

    var buf: [u8] = []

    # SSH_MSG_KEXINIT = 20
    buf = _append_byte(buf, 20)

    # 16-byte cookie (zeros)
    var i: u64 = 0
    while i < 16:
        buf = _append_byte(buf, 0)
        i = i + 1

    buf = ssh_put_text(buf, "curve25519-sha256,ext-info-s,kex-strict-s-v00@openssh.com")
    buf = ssh_put_text(buf, host_key_algorithms_with_certificates(host_keys, host_certs))
    buf = ssh_put_text(buf, "aes256-gcm@openssh.com")
    buf = ssh_put_text(buf, "aes256-gcm@openssh.com")
    buf = ssh_put_text(buf, "hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,none")
    buf = ssh_put_text(buf, "hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,none")
    buf = ssh_put_text(buf, "none")
    buf = ssh_put_text(buf, "none")
    buf = ssh_put_text(buf, "")
    buf = ssh_put_text(buf, "")
    buf = ssh_put_bool(buf, false)
    buf = ssh_put_u32(buf, 0)

    buf

# ============================================================================
# KEX Message Builders
# ============================================================================

fn ssh_build_kex_ecdh_reply(host_key_blob: [u8], server_public: [u8], signature: [u8]) -> [u8]:
    """Build SSH_MSG_KEX_ECDH_REPLY payload.

    Fields:
      byte      SSH_MSG_KEX_ECDH_REPLY (31)
      string    K_S (server host key blob)
      string    Q_S (server ephemeral public key)
      string    signature of H
    """
    var buf: [u8] = []
    # Baremetal live lane: write the wire literal directly. Imported constant
    # reachability on this path has proven unreliable and can collapse to 0.
    buf.push(31)
    buf = _push_string_bytes(buf, host_key_blob)
    buf = _push_string_32(buf, server_public)
    buf = _push_string_bytes(buf, signature)
    buf

fn ssh_parse_kex_ecdh_init(data: [u8]) -> Result<[u8], text>:
    """Parse SSH_MSG_KEX_ECDH_INIT. Returns client's ephemeral public key Q_C."""
    if data.len() < 2:
        return Err("KEX_ECDH_INIT too short")
    if _u8_at(data, 0) != SSH_MSG_KEX_ECDH_INIT:
        return Err("not a KEX_ECDH_INIT message")

    val r = ssh_get_string(data, 1)
    match r:
        Ok(pair):
            Ok(pair.data)
        Err(_):
            Err("KEX_ECDH_INIT: bad client public key")

fn ssh_build_newkeys() -> [u8]:
    """Build SSH_MSG_NEWKEYS payload (just the message type byte)."""
    var buf: [u8] = []
    buf.push(21)   # SSH_MSG_NEWKEYS
    buf

export SshSessionKeys, SSH_MSG_KEX_ECDH_INIT, SSH_MSG_KEX_ECDH_REPLY, ssh_kex_generate_private_key, ssh_kex_generate_keypair, ssh_kex_compute_shared, ssh_kex_compute_exchange_hash, ssh_derive_keys
export ssh_build_kex_ecdh_reply, ssh_parse_kex_ecdh_init, ssh_build_newkeys
export ssh_build_kexinit_for_host_keys_and_certs
export host_key_set_advertised_algorithms
