fn _live_openssh_client_version_bytes() -> [u8]:
    serial_println("[sshd-session] version builder start")
    var out: [u8] = []
    out = rt_push_byte(out, 0x53)
    out = rt_push_byte(out, 0x53)
    out = rt_push_byte(out, 0x48)
    out = rt_push_byte(out, 0x2d)
    out = rt_push_byte(out, 0x32)
    out = rt_push_byte(out, 0x2e)
    out = rt_push_byte(out, 0x30)
    out = rt_push_byte(out, 0x2d)
    out = rt_push_byte(out, 0x4f)
    out = rt_push_byte(out, 0x70)
    out = rt_push_byte(out, 0x65)
    out = rt_push_byte(out, 0x6e)
    out = rt_push_byte(out, 0x53)
    out = rt_push_byte(out, 0x53)
    out = rt_push_byte(out, 0x48)
    out = rt_push_byte(out, 0x5f)
    out = rt_push_byte(out, 0x39)
    out = rt_push_byte(out, 0x2e)
    out = rt_push_byte(out, 0x36)
    out = rt_push_byte(out, 0x70)
    out = rt_push_byte(out, 0x31)
    out = rt_push_byte(out, 0x20)
    out = rt_push_byte(out, 0x55)
    out = rt_push_byte(out, 0x62)
    out = rt_push_byte(out, 0x75)
    out = rt_push_byte(out, 0x6e)
    out = rt_push_byte(out, 0x74)
    out = rt_push_byte(out, 0x75)
    out = rt_push_byte(out, 0x2d)
    out = rt_push_byte(out, 0x33)
    out = rt_push_byte(out, 0x75)
    out = rt_push_byte(out, 0x62)
    out = rt_push_byte(out, 0x75)
    out = rt_push_byte(out, 0x6e)
    out = rt_push_byte(out, 0x74)
    out = rt_push_byte(out, 0x75)
    out = rt_push_byte(out, 0x31)
    out = rt_push_byte(out, 0x33)
    out = rt_push_byte(out, 0x2e)
    out = rt_push_byte(out, 0x31)
    out = rt_push_byte(out, 0x36)
    serial_println("[sshd-session] version builder done")
    out

fn _ssh_identification_text_to_bytes_stable(line: text) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < line.len():
        out = rt_push_byte(out, line.char_at(i).to_i64() & 0xFF)
        i = i + 1
    out

fn _ssh_identification_bytes_start_ssh2(data: [u8]) -> bool:
    if data.len() < 8:
        return false
    _u8_at(data, 0) == 0x53 and
        _u8_at(data, 1) == 0x53 and
        _u8_at(data, 2) == 0x48 and
        _u8_at(data, 3) == 0x2D and
        _u8_at(data, 4) == 0x32 and
        _u8_at(data, 5) == 0x2E and
        _u8_at(data, 6) == 0x30 and
        _u8_at(data, 7) == 0x2D

fn _ssh_identification_bytes_trim_crlf(data: [u8]) -> [u8]:
    if data.len() >= 2 and _u8_at(data, data.len() - 2) == 0x0D and _u8_at(data, data.len() - 1) == 0x0A:
        return _slice_range(data, 0, data.len() - 2)
    if data.len() >= 1 and (_u8_at(data, data.len() - 1) == 0x0D or _u8_at(data, data.len() - 1) == 0x0A):
        return _slice_range(data, 0, data.len() - 1)
    _copy_bytes_stable(data)

fn _build_channel_data_stable(recipient: u32, data: [u8]) -> [u8]:
    var payload: [u8] = []
    payload = rt_push_byte(payload, 94)
    payload = _push_u32_be_stable(payload, recipient)
    payload = _push_u32_be_stable(payload, data.len().to_u32())
    # Copy the DATA via the `.push` intrinsic, NOT the `payload =
    # rt_push_byte(payload, ..)` reassignment form: on x86_64 freestanding
    # native-build the reassignment form drops the BYTE_PACKED representation
    # once the array grows large and corrupts the copy — this was the Inc-3
    # getfile 0x53-garbage bug (712-byte /hello.o delivered as garbage while
    # small handshake/exit packets, which stay inline-packed, delivered fine).
    # See _copy_bytes_stable's note. The 9-byte header above stays small enough
    # for the reassignment helpers.
    var i: u64 = 0
    while i < data.len():
        payload.push(_u8_at(data, i))
        i = i + 1
    payload

fn _payload_field_equals_bytes_stable(payload: [u8], field_offset: u64, expected: [u8]) -> bool:
    if field_offset + 4 > payload.len():
        return false
    val field_len = _read_u32_stable(payload, field_offset).to_u64()
    if field_len != expected.len():
        return false
    val start = field_offset + 4
    if start + field_len > payload.len():
        return false
    var i: u64 = 0
    while i < expected.len():
        if _u8_at(payload, start + i) != _u8_at(expected, i):
            return false
        i = i + 1
    true

fn _is_live_channel_open_session(payload: [u8]) -> bool:
    if payload.len() < 24:
        return false
    _u8_at(payload, 0) == 90 and
        _u8_at(payload, 1) == 0 and
        _u8_at(payload, 2) == 0 and
        _u8_at(payload, 3) == 0 and
        _u8_at(payload, 4) == 7 and
        _u8_at(payload, 5) == 0x73 and
        _u8_at(payload, 6) == 0x65 and
        _u8_at(payload, 7) == 0x73 and
        _u8_at(payload, 8) == 0x73 and
        _u8_at(payload, 9) == 0x69 and
        _u8_at(payload, 10) == 0x6F and
        _u8_at(payload, 11) == 0x6E

fn _field_range_equals_bytes_stable(payload: [u8], start: u64, end: u64, expected: [u8]) -> bool:
    if end < start:
        return false
    if end - start != expected.len():
        return false
    var i: u64 = 0
    while i < expected.len():
        if _u8_at(payload, start + i) != _u8_at(expected, i):
            return false
        i = i + 1
    true

# Phase 2e Inc 3: scp-source (`scp -f <path>`) file retrieval. The FAT read
# below is a plain C buffer read (simpleos_fat32_stream_open/stream_read_at
# — the SAME primitive x86_64_fs_exec_spawn_heap already proved works
# POST rt_net_init+vmm+SSH activity, streaming the 124.6 MB clang ELF over
# real SSH, Phase 2e Inc 1), NOT a ring-3 CPL transition, so it is safe to
# call from this DEEP session-dispatch frame (unlike the ring-3 spawn, which
# must be deferred to the shallow accept-loop frame — see
# doc/08_tracking/bug/x64_ssh_kernel_fat32_stream_open_zero.md bug #2).
# x86_64-only: guarded with @cfg so shared sshd.spl/ssh_session.spl still
# compile for the rv64/arm SSH lanes (mirrors sshd.spl's
# _sshd_run_pending_ring3_exec per-arch stub pattern).
@cfg(x86_64)
extern fn simpleos_fat32_stream_open(path: text) -> i64
@cfg(x86_64)
extern fn simpleos_fat32_stream_read_at(file_off: u64, dst: u64, len: u64) -> i64
@cfg(x86_64)
extern fn simpleos_fat32_path_read_buffer_addr() -> u64
@cfg(x86_64)
extern fn mmio_read8(addr: u64) -> u8

fn _scp_ctrl_line(size: i64, name_bytes: [u8]) -> [u8]:
    """Build the scp-source `C0644 <size> <name>\n` control line as raw [u8].
    NEVER via text interpolation: on the x64 freestanding target, interpolating
    an int / dynamic-text field and converting the result to bytes yields an
    EMPTY buffer (same freestanding class as the char_code_at / text-store bugs
    — see doc/08_tracking/bug/x64_freestanding_char_code_at_dynamic_text.md).
    Manual base-10 digits + [u8] concat is the reliable path."""
    var digits: [u8] = []
    var v = size
    if v <= 0:
        digits = _copy_bytes_stable([0x30])
    else:
        while v > 0:
            var db: [u8] = []
            db = rt_push_byte(db, (v % 10) + 0x30)
            digits = rt_bytes_concat(db, digits)
            v = v / 10
    var out = _copy_bytes_stable([0x43, 0x30, 0x36, 0x34, 0x34, 0x20])
    out = rt_bytes_concat(out, digits)
    out = rt_bytes_concat(out, _copy_bytes_stable([0x20]))
    out = rt_bytes_concat(out, name_bytes)
    out = rt_bytes_concat(out, _copy_bytes_stable([0x0A]))
    out

@cfg(x86_64)
fn _scp_read_file_bytes(path: text) -> ([u8], i64):
    val fsize = simpleos_fat32_stream_open(path)
    if fsize <= 0 or fsize > 4194304:
        serial_println("[sshd-session] scp read-open-fail path={path} fsize={fsize}")
        return ([], -1)
    val buf = simpleos_fat32_path_read_buffer_addr()
    if buf == 0.to_u64():
        return ([], -1)
    val n = simpleos_fat32_stream_read_at(0.to_u64(), buf, fsize.to_u64())
    if n != fsize:
        serial_println("[sshd-session] scp read-short path={path} want={fsize} got={n}")
        return ([], -1)
    # Build the [u8] by reading each byte straight from the FAT buffer via
    # mmio_read8 (the proven Inc-1 raw-read idiom) — a Simple-native packed [u8]
    # that _u8_at reads reliably at any stack depth. (`b` is bound before
    # `.to_i64()` only for clarity; a chained form would work too.)
    var out: [u8] = []
    var i: u64 = 0
    while i < fsize.to_u64():
        val b = mmio_read8(buf + i)
        out = rt_push_byte(out, b.to_i64())
        i = i + 1
    (out, fsize)

@cfg(x86)
fn _scp_read_file_bytes(path: text) -> ([u8], i64):
    ([], -1)

@cfg(arm64)
fn _scp_read_file_bytes(path: text) -> ([u8], i64):
    ([], -1)

@cfg(arm32)
fn _scp_read_file_bytes(path: text) -> ([u8], i64):
    ([], -1)

@cfg(riscv64)
fn _scp_read_file_bytes(path: text) -> ([u8], i64):
    ([], -1)

@cfg(riscv32)
fn _scp_read_file_bytes(path: text) -> ([u8], i64):
    ([], -1)

# Raw [u8] scan helpers for the scp -f command — NEVER text.char_at/
# starts_with on dynamically-built text (mis-decodes; see
# doc/08_tracking/bug/x64_freestanding_char_code_at_dynamic_text.md). Mirrors
# sshd.spl's _sshd_tokenize_command idiom (rt_string_to_byte_array +
# rt_bytes_u8_at), just applied inline in this deep dispatch frame — bulk
# byte-array conversion is proven reliable at any stack depth (unlike the
# per-char text accessors), see that doc's workaround note.
fn _scp_last_token_bytes(command: text) -> [u8]:
    """Return the LAST whitespace-delimited token of `command` as raw bytes
    (the scp -f path — handles `scp -f /hello.o`, `scp -pf /hello.o`, etc.,
    since the path is always the final token regardless of flag combos)."""
    val bytes = rt_string_to_byte_array(command)
    var last: [u8] = []
    var cur: [u8] = []
    var i: i64 = 0
    val n = bytes.len().to_i64()
    while i < n:
        val code = rt_bytes_u8_at(bytes, i)
        if code == 32:
            if cur.len() > 0:
                last = cur
                cur = []
        else:
            cur = rt_push_byte(cur, code)
        i = i + 1
    if cur.len() > 0:
        last = cur
    last

fn _scp_basename_bytes(path_bytes: [u8]) -> [u8]:
    """Return the bytes after the last '/' in `path_bytes` (the scp control
    line's basename field)."""
    var last_slash: i64 = -1
    var i: i64 = 0
    val n = path_bytes.len().to_i64()
    while i < n:
        if rt_bytes_u8_at(path_bytes, i) == 0x2F:
            last_slash = i
        i = i + 1
    var out: [u8] = []
    var j = last_slash + 1
    while j < n:
        out = rt_push_byte(out, rt_bytes_u8_at(path_bytes, j))
        j = j + 1
    out

fn _exec_success_output_for_command(command: text) -> [u8]:
    val trimmed = command.trim()
    if trimmed == "simple" or trimmed.starts_with("simple "):
        return _copy_bytes_stable([0x53, 0x45, 0x53, 0x53, 0x49, 0x4F, 0x4E, 0x20, 0x4F, 0x4B, 0x20, 0x73, 0x68, 0x65, 0x6C, 0x6C, 0x20, 0x73, 0x69, 0x6D, 0x70, 0x6C, 0x65, 0x20, 0x70, 0x61, 0x74, 0x68, 0x3D, 0x2F, 0x75, 0x73, 0x72, 0x2F, 0x62, 0x69, 0x6E, 0x2F, 0x73, 0x69, 0x6D, 0x70, 0x6C, 0x65, 0x20, 0x61, 0x6C, 0x69, 0x61, 0x73, 0x3D, 0x2F, 0x53, 0x59, 0x53, 0x2F, 0x41, 0x50, 0x50, 0x53, 0x2F, 0x53, 0x49, 0x4D, 0x50, 0x4C, 0x53, 0x54, 0x43, 0x2E, 0x53, 0x4D, 0x46, 0x0A])
    if trimmed == "simple.smf" or trimmed.starts_with("simple.smf "):
        return _copy_bytes_stable([0x53, 0x45, 0x53, 0x53, 0x49, 0x4F, 0x4E, 0x20, 0x4F, 0x4B, 0x20, 0x73, 0x68, 0x65, 0x6C, 0x6C, 0x20, 0x73, 0x69, 0x6D, 0x70, 0x6C, 0x65, 0x2E, 0x73, 0x6D, 0x66, 0x20, 0x70, 0x61, 0x74, 0x68, 0x3D, 0x2F, 0x75, 0x73, 0x72, 0x2F, 0x62, 0x69, 0x6E, 0x2F, 0x73, 0x69, 0x6D, 0x70, 0x6C, 0x65, 0x2E, 0x73, 0x6D, 0x66, 0x20, 0x61, 0x6C, 0x69, 0x61, 0x73, 0x3D, 0x2F, 0x53, 0x59, 0x53, 0x2F, 0x41, 0x50, 0x50, 0x53, 0x2F, 0x53, 0x49, 0x4D, 0x50, 0x4C, 0x53, 0x54, 0x43, 0x2E, 0x53, 0x4D, 0x46, 0x0A])
    []

