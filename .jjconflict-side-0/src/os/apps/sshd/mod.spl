# SimpleOS SSH Server — Module Root
#
# Complete SSH-2 server implementation for SimpleOS.
# Provides encrypted remote shell access over TCP.
#
# Architecture (bottom-up):
#   ssh_packet    — Binary packet protocol (RFC 4253 section 6)
#   ssh_transport — Version exchange, algorithm negotiation
#   ssh_kex       — Curve25519-SHA256 key exchange (RFC 8731)
#   ssh_cipher    — AES-256-GCM encryption layer
#   ssh_auth      — Password and public key authentication (RFC 4252)
#   ssh_channel   — Channel multiplexing (RFC 4254)
#   ssh_pty       — Pseudo-terminal via POSIX pipes
#   ssh_session   — Per-client connection handler
#   sshd          — Main SSH daemon (listen + accept)

use os.apps.sshd.ssh_packet.{SshPacket, ssh_packet_read, ssh_packet_build, ssh_put_u32, ssh_put_string, ssh_put_text, ssh_put_mpint, ssh_put_bool, ssh_put_byte, ssh_get_u32, ssh_get_string, ssh_get_text}
use os.apps.sshd.ssh_transport.{SshKexInit, SshAlgorithms, SSH_VERSION_STRING, ssh_build_version_string, ssh_build_kexinit, ssh_parse_kexinit, ssh_negotiate_algorithms}
use os.apps.sshd.ssh_kex.{SshKexState, SshSessionKeys, ssh_kex_generate_keypair, ssh_kex_compute_shared, ssh_kex_compute_exchange_hash, ssh_derive_keys}
use os.apps.sshd.ssh_cipher.{SshCipher}
use os.apps.sshd.ssh_auth.{SshUserDb, SshUser, SshAuthRequest}
use os.apps.sshd.ssh_channel.{ChannelTable, SshChannel, ChannelType, ChannelState}
use os.apps.sshd.ssh_pty.{SshPty}
use os.apps.sshd.ssh_session.{SshSession, SessionState}
use os.apps.sshd.sshd.{SshDaemon}
