# =========================================================================
# Shell Application
# =========================================================================

impl ShellApp:
    fn _expand_cmd_substitution(s: text) -> text:
        """Pre-process $(cmd) and `cmd` command substitution before variable expansion."""
        var result = ""
        var i = 0
        while i < s.len():
            val ch = s.slice(i, i + 1)
            if ch == "$" and i + 1 < s.len() and s.slice(i + 1, i + 2) == "(":
                # Find matching closing )
                var depth = 1
                var j = i + 2
                while j < s.len() and depth > 0:
                    val jch = s.slice(j, j + 1)
                    if jch == "(":
                        depth = depth + 1
                    elif jch == ")":
                        depth = depth - 1
                    j = j + 1
                val inner = s.slice(i + 2, j - 1)
                val output = self.execute_capture(inner)
                result = "{result}{output}"
                i = j
            elif ch == "`":
                # Backtick substitution
                var j = i + 1
                while j < s.len() and s.slice(j, j + 1) != "`":
                    j = j + 1
                val inner = s.slice(i + 1, j)
                val output = self.execute_capture(inner)
                result = "{result}{output}"
                i = j + 1
            else:
                result = "{result}{ch}"
                i = i + 1
        return result

    fn execute_capture(cmd: text) -> text:
        """Execute cmd and return its stdout as text (for command substitution)."""
        val trimmed = cmd.trim()
        # Handle pure-compute cases directly — these are the most common in bootstrap scripts
        if trimmed == "pwd":
            return self.cwd
        if trimmed == "hostname":
            return self._get_env("HOSTNAME")
        if trimmed == "uname" or trimmed == "uname -s":
            return "SimpleOS"
        if trimmed == "uname -m":
            return "x86_64"
        if trimmed == "uname -r":
            return "0.1.0"
        if trimmed == "whoami":
            val user = self._get_env("USER")
            return if user == "": "root" else: user
        if trimmed == "date":
            return "Thu Jan  1 00:00:00 UTC 2026"
        if trimmed.starts_with("echo "):
            return trimmed.slice(5, trimmed.len()).trim()
        if trimmed.starts_with("dirname "):
            val path = _unquote_simple(trimmed.slice(8, trimmed.len()).trim())
            return _parent_path(path)
        if trimmed.starts_with("basename "):
            val path = _unquote_simple(trimmed.slice(9, trimmed.len()).trim())
            return _basename_of(path)
        # "cd dir && pwd" — common bootstrap pattern
        if trimmed.contains(" && pwd"):
            val cd_part = trimmed.slice(0, trimmed.len() - 7).trim()
            if cd_part.starts_with("cd "):
                val dir = _unquote_simple(cd_part.slice(3, cd_part.len()).trim())
                return self._resolve_path(dir)
        # Fallback: execute and capture via capture_lines
        val old_lines = self.capture_lines
        self.capture_lines = []
        self.capture_mode = true
        self.execute(trimmed)
        self.capture_mode = false
        var buf = ""
        for line in self.capture_lines:
            if buf == "":
                buf = line
            else:
                buf = "{buf}\n{line}"
        self.capture_lines = old_lines
        # Trim trailing newline
        if buf.ends_with("\n"):
            buf = buf.slice(0, buf.len() - 1)
        return buf

    # -- Path Resolution -----------------------------------------------------

    fn _resolve_path(path: text) -> text:
        """Resolve a relative path against cwd."""
        if path.starts_with("/"):
            return _normalize_path(path)
        if path == "~":
            return self._get_env("HOME")
        if path.starts_with("~/"):
            return "{self._get_env("HOME")}{path.slice(1, path.len())}"
        if path == "..":
            return _parent_path(self.cwd)
        if path == ".":
            return self.cwd
        val full = if self.cwd == "/": "/{path}" else: "{self.cwd}/{path}"
        return _normalize_path(full)

    fn cmd_source(args: [text]):
        """Source (execute) a shell script file."""
        if args.len() == 0:
            self.terminal.write_string("source: usage: source <file> [args...]\n")
            self.last_exit_code = 1
            return
        val path = self._resolve_path(args[0])
        var script_args: [text] = [args[0]]
        var i = 1
        while i < args.len():
            script_args = script_args.push(args[i])
            i = i + 1
        if self.vfs != nil:
            val result = self.vfs.read_text(path)
            if result.is_ok():
                self.execute_script_text(result.unwrap(), script_args)
            else:
                self.terminal.write_string("source: {path}: not found\n")
                self.last_exit_code = 1
        else:
            self.terminal.write_string("source: no filesystem\n")
            self.last_exit_code = 1

    fn execute_script_text(source: text, script_args: [text]):
        """Parse and execute shell script source text."""
        val engine = ScriptEngine.new()
        val stmts = engine.parse(source)
        var i = 0
        while i < stmts.len():
            self._execute_stmt(stmts[i], script_args)
            i = i + 1

    fn _execute_stmt(stmt: Stmt, script_args: [text]):
        """Execute a single parsed statement."""
        match stmt.kind:
            case StmtKind.Command:
                if stmt.args.len() > 0:
                    val raw_cmd = stmt.args[0]
                    val aliased = shell_apply_alias(raw_cmd, self.aliases)
                    var expanded = shell_expand(aliased, self.variables, self.env, self.last_exit_code, script_args)
                    var i = 1
                    while i < stmt.args.len():
                        expanded = "{expanded} {shell_expand(stmt.args[i], self.variables, self.env, self.last_exit_code, script_args)}"
                        i = i + 1
                    self.execute(expanded)
            case StmtKind.Assign:
                val key = stmt.var_name
                val value = shell_expand(stmt.args[0], self.variables, self.env, self.last_exit_code, script_args)
                var new_vars: [(text, text)] = []
                var found = false
                for pair in self.variables:
                    if pair.0 == key:
                        new_vars = new_vars.push((key, value))
                        found = true
                    else:
                        new_vars = new_vars.push(pair)
                if not found:
                    new_vars = new_vars.push((key, value))
                self.variables = new_vars
            case StmtKind.If:
                var executed = false
                for branch in stmt.branches:
                    val cond_expanded = shell_expand(branch.condition, self.variables, self.env, self.last_exit_code, script_args)
                    if cond_expanded != "" and cond_expanded != "0" and cond_expanded != "false":
                        self.execute_script_text(_join_lines(branch.body), script_args)
                        executed = true
                        break
                if not executed:
                    self.execute_script_text(_join_lines(stmt.else_body), script_args)
            case StmtKind.While:
                var keep_going = true
                while keep_going:
                    val cond = shell_expand(stmt.condition, self.variables, self.env, self.last_exit_code, script_args)
                    if cond == "" or cond == "0" or cond == "false":
                        keep_going = false
                    else:
                        self.execute_script_text(_join_lines(stmt.body), script_args)
                        if self.last_exit_code == -1:
                            self.last_exit_code = 0
                            keep_going = false
            case StmtKind.For:
                for item in stmt.items:
                    var new_vars2: [(text, text)] = []
                    var found2 = false
                    for pair in self.variables:
                        if pair.0 == stmt.var_name:
                            new_vars2 = new_vars2.push((stmt.var_name, item))
                            found2 = true
                        else:
                            new_vars2 = new_vars2.push(pair)
                    if not found2:
                        new_vars2 = new_vars2.push((stmt.var_name, item))
                    self.variables = new_vars2
                    self.execute_script_text(_join_lines(stmt.body), script_args)
                    if self.last_exit_code == -1:
                        self.last_exit_code = 0
                        break
            case StmtKind.FnDef:
                val fn_body = _join_lines(stmt.body)
                var new_fns: [(text, text)] = []
                var found3 = false
                for pair in self.shell_functions:
                    if pair.0 == stmt.var_name:
                        new_fns = new_fns.push((stmt.var_name, fn_body))
                        found3 = true
                    else:
                        new_fns = new_fns.push(pair)
                if not found3:
                    new_fns = new_fns.push((stmt.var_name, fn_body))
                self.shell_functions = new_fns
            case StmtKind.Source:
                self.cmd_source(stmt.args)
            case StmtKind.BreakStmt:
                self.last_exit_code = -1
            case StmtKind.ContinueStmt:
                self.last_exit_code = -2
            case StmtKind.ReturnStmt:
                if stmt.args.len() > 0:
                    self.last_exit_code = stmt.args[0].to_i32()
                else:
                    self.last_exit_code = 0
            case _:
                pass

    fn cmd_read(args: [text]):
        """Read a line of input into a variable."""
        if args.len() == 0:
            self.last_exit_code = 0
            return
        val input = self.terminal.read_input()
        val var_name = args[0]
        var new_vars: [(text, text)] = []
        var found = false
        for pair in self.variables:
            if pair.0 == var_name:
                new_vars = new_vars.push((var_name, input))
                found = true
            else:
                new_vars = new_vars.push(pair)
        if not found:
            new_vars = new_vars.push((var_name, input))
        self.variables = new_vars
        self.last_exit_code = 0

    fn cmd_alias(args: [text]):
        """Set or list aliases."""
        if args.len() == 0:
            self.last_exit_code = builtin_alias_list(self.aliases, self.terminal)
            return
        for arg in args:
            val eq_pos = _find_char_pos(arg, "=")
            if eq_pos >= 0:
                val name = arg.slice(0, eq_pos)
                var value = arg.slice(eq_pos + 1, arg.len())
                if value.starts_with("'") and value.len() > 1:
                    value = value.slice(1, value.len() - 1)
                var new_aliases: [(text, text)] = []
                var found = false
                for pair in self.aliases:
                    if pair.0 == name:
                        new_aliases = new_aliases.push((name, value))
                        found = true
                    else:
                        new_aliases = new_aliases.push(pair)
                if not found:
                    new_aliases = new_aliases.push((name, value))
                self.aliases = new_aliases
        self.last_exit_code = 0

    fn cmd_unalias(args: [text]):
        """Remove an alias."""
        for arg in args:
            var new_aliases: [(text, text)] = []
            for pair in self.aliases:
                if pair.0 != arg:
                    new_aliases = new_aliases.push(pair)
            self.aliases = new_aliases
        self.last_exit_code = 0

    fn cmd_shift(args: [text]):
        """Shift positional parameters (no-op for interactive mode)."""
        self.last_exit_code = 0

    fn cmd_trap(args: [text]):
        """Register a signal handler (stored in variables for now)."""
        if args.len() >= 2:
            var new_vars: [(text, text)] = []
            var found = false
            val trap_key = "_trap_{args[1]}"
            for pair in self.variables:
                if pair.0 == trap_key:
                    new_vars = new_vars.push((trap_key, args[0]))
                    found = true
                else:
                    new_vars = new_vars.push(pair)
            if not found:
                new_vars = new_vars.push((trap_key, args[0]))
            self.variables = new_vars
        self.last_exit_code = 0

    fn cmd_wait(args: [text]):
        """Wait for background jobs to complete."""
        self.last_exit_code = 0

    fn cmd_return(args: [text]):
        """Return from a function with optional exit code."""
        if args.len() > 0:
            self.last_exit_code = args[0].to_i32()
        else:
            self.last_exit_code = 0

    fn cmd_set(args: [text]):
        """Set shell options. Supports -e (exit on error) and +e (disable)."""
        for arg in args:
            if arg == "-e" or arg == "-o" or arg == "errexit":
                self.exit_on_error = true
            elif arg == "+e":
                self.exit_on_error = false
        self.last_exit_code = 0

    fn cmd_mkfifo(args: [text]):
        """Create a named pipe (FIFO). Stub — VFS FIFOs not yet supported."""
        if args.len() == 0:
            self.terminal.write_string("mkfifo: usage: mkfifo <name>\n")
            self.last_exit_code = 1
            return
        self.terminal.write_string("mkfifo: not supported on this filesystem\n")
        self.last_exit_code = 1

    # -- UI Construction -----------------------------------------------------

    fn build_ui() -> UISession:
        """Build the shell UI.

        Delegates to the terminal's build_ui with shell-specific status.
        """
        return self.terminal.build_ui()

