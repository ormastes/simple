# Shell Job Control
#
# Manages background jobs, fg/bg commands, signal forwarding.
# Jobs are tracked by ID and PID. The job table is polled after
# each command to report completed background jobs.
#
# MDSOC: feature dimension, shell layer

use os.posix.process_compat.{posix_waitpid, posix_kill, WNOHANG}
use os.posix.signal_compat.{SIGCONT, SIGTERM, SIGKILL}

# ============================================================================
# Job State
# ============================================================================

enum JobState:
    """Current state of a background job."""
    Running
    Stopped
    Done(exit_code: i32)

# ============================================================================
# Job
# ============================================================================

struct Job:
    """A background job in the shell."""
    id: i32
    pid: u64
    command: text
    state: JobState
    notif_id: u64

impl Job:
    fn is_running() -> bool:
        """Check if this job is still running."""
        match self.state:
            JobState.Running: true
            _: false

    fn is_done() -> bool:
        """Check if this job has completed."""
        match self.state:
            JobState.Done(_): true
            _: false

    fn is_stopped() -> bool:
        """Check if this job is stopped."""
        match self.state:
            JobState.Stopped: true
            _: false

    fn state_text() -> text:
        """Return a human-readable state string."""
        match self.state:
            JobState.Running: "Running"
            JobState.Stopped: "Stopped"
            JobState.Done(code): "Done({code})"

# ============================================================================
# Job Table
# ============================================================================

class JobTable:
    """Tracks active background jobs.

    Provides add/remove/query operations and integrates with the
    POSIX waitpid syscall for non-blocking status checks.
    """
    jobs: [Job]
    next_id: i32

impl JobTable:
    static fn new() -> JobTable:
        """Create an empty job table."""
        JobTable(jobs: [], next_id: 1)

    me add(pid: u64, command: text, notif_id: u64) -> i32:
        """Add a new background job. Returns job ID."""
        val id = self.next_id
        self.next_id = self.next_id + 1
        val job = Job(
            id: id,
            pid: pid,
            command: command,
            state: JobState.Running,
            notif_id: notif_id
        )
        self.jobs = self.jobs.push(job)
        id

    me update_status():
        """Check all running jobs for completion (non-blocking).

        Calls posix_waitpid with WNOHANG for each running job.
        If a child exited, updates its state to Done(exit_code).
        """
        var updated: [Job] = []
        var i = 0
        while i < self.jobs.len():
            var job = self.jobs[i]
            match job.state:
                JobState.Running:
                    val status = posix_waitpid(job.pid as i64, WNOHANG)
                    if status >= 0:
                        # Child exited
                        job.state = JobState.Done(exit_code: status as i32)
                    # status < 0 means still running or error, keep Running
                JobState.Stopped:
                    # Check if a stopped job was continued externally
                    val status = posix_waitpid(job.pid as i64, WNOHANG)
                    if status >= 0:
                        job.state = JobState.Done(exit_code: status as i32)
                _:
                    pass_dn
            updated = updated.push(job)
            i = i + 1
        self.jobs = updated

    fn list() -> [Job]:
        """Return all jobs (including completed ones not yet reported)."""
        self.jobs

    me remove_done() -> [Job]:
        """Remove and return completed jobs (for reporting to user).

        Filters the job list, returning Done jobs and keeping the rest.
        """
        var done: [Job] = []
        var remaining: [Job] = []
        var i = 0
        while i < self.jobs.len():
            val job = self.jobs[i]
            if job.is_done():
                done = done.push(job)
            else:
                remaining = remaining.push(job)
            i = i + 1
        self.jobs = remaining
        done

    fn find(id: i32) -> Job?:
        """Find job by ID."""
        var i = 0
        while i < self.jobs.len():
            if self.jobs[i].id == id:
                return self.jobs[i]
            i = i + 1
        nil

    fn find_by_pid(pid: u64) -> Job?:
        """Find job by PID."""
        var i = 0
        while i < self.jobs.len():
            if self.jobs[i].pid == pid:
                return self.jobs[i]
            i = i + 1
        nil

    fn count() -> i32:
        """Return number of active (non-done) jobs."""
        var c: i32 = 0
        var i = 0
        while i < self.jobs.len():
            if not self.jobs[i].is_done():
                c = c + 1
            i = i + 1
        c

    me send_signal(id: i32, sig: i32) -> bool:
        """Send signal to a job's process. Returns true on success."""
        val job = self.find(id)
        if job == nil:
            return false
        val result = posix_kill(job.pid, sig)
        result == 0

    me foreground(id: i32) -> Result<i32, text>:
        """Bring job to foreground. Blocks until job completes.

        If the job is stopped, sends SIGCONT first.
        Then performs a blocking waitpid.
        Returns the exit code on success.
        """
        var job_idx: i32 = -1
        var i = 0
        while i < self.jobs.len():
            if self.jobs[i].id == id:
                job_idx = i as i32
            i = i + 1

        if job_idx < 0:
            return Err("fg: no such job: {id}")

        var job = self.jobs[job_idx as u64]

        # If stopped, resume it
        if job.is_stopped():
            posix_kill(job.pid, SIGCONT)
            job.state = JobState.Running
            self.jobs[job_idx as u64] = job

        # Blocking wait
        val status = posix_waitpid(job.pid as i64, 0)
        if status < 0:
            return Err("fg: waitpid failed for job {id}")

        # Mark done and remove
        job.state = JobState.Done(exit_code: status as i32)
        self.jobs[job_idx as u64] = job
        Ok(status as i32)

    me background(id: i32) -> Result<bool, text>:
        """Resume a stopped job in background.

        Sends SIGCONT to the job's process and marks it as Running.
        """
        var job_idx: i32 = -1
        var i = 0
        while i < self.jobs.len():
            if self.jobs[i].id == id:
                job_idx = i as i32
            i = i + 1

        if job_idx < 0:
            return Err("bg: no such job: {id}")

        var job = self.jobs[job_idx as u64]

        if not job.is_stopped():
            return Err("bg: job {id} is not stopped")

        val result = posix_kill(job.pid, SIGCONT)
        if result != 0:
            return Err("bg: failed to send SIGCONT to job {id}")

        job.state = JobState.Running
        self.jobs[job_idx as u64] = job
        Ok(true)
