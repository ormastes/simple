# Phase 2 W-2: post-FAT32 smoke calls for clang_static and rustc_static.
#
# MDSOC: feature dimension, shell layer

use os.apps.shell.exec.{shell_exec}

extern fn serial_println(msg: text)

pub fn shell_launch_smoke():
    """Phase 2 W-2: smoke-call clang_static and rustc_static via shell."""
    serial_println("[phase-2-clang-version] start")
    val clang_rc = shell_exec("clang_static", ["clang_static", "--version"], [])
    serial_println("[phase-2-clang-version] rc={clang_rc}")
    serial_println("[phase-2-rustc-version] start")
    val rustc_rc = shell_exec("rustc_static", ["rustc_static", "--version"], [])
    serial_println("[phase-2-rustc-version] rc={rustc_rc}")
