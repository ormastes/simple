# contract.spl — Backend-agnostic control types for the smux terminal multiplexer.
#
# Defines public data shapes shared across the service, backends, and adapters.
# No fn main needed — standalone value types.

enum MuxBackendKind:
    NativeShell
    HostTmux
    Stub

class MuxSession:
    id: text
    name: text
    created_at: u64
    generation: int

    me to_text() -> text:
        return "session[" + me.name + "/" + me.id + "]"

    static fn create(sid: text, sname: text) -> MuxSession:
        return MuxSession(id: sid, name: sname, created_at: 0u64, generation: 0)


class MuxWindow:
    id: text
    session_id: text
    name: text
    is_active: bool

    me to_text() -> text:
        return "window[" + me.name + "/" + me.id + "]"

    static fn create(wid: text, sid: text, wname: text) -> MuxWindow:
        return MuxWindow(id: wid, session_id: sid, name: wname, is_active: false)


class MuxPane:
    id: text
    window_id: text
    session_id: text
    backend_kind: MuxBackendKind
    state: text
    cols: int
    rows: int

    me to_text() -> text:
        return "pane[" + me.id + "] " + me.cols.to_text() + "x" + me.rows.to_text()

    static fn create(pid: text, wid: text, sid: text) -> MuxPane:
        return MuxPane(
            id: pid,
            window_id: wid,
            session_id: sid,
            backend_kind: MuxBackendKind.NativeShell,
            state: "running",
            cols: 80,
            rows: 24
        )


class MuxCapture:
    pane_id: text
    content: text
    rows: int

    static fn create(pid: text, lines: text, row_count: int) -> MuxCapture:
        return MuxCapture(pane_id: pid, content: lines, rows: row_count)


class MuxClientAttachment:
    client_id: text
    session_id: text
    attached: bool
    cols: int
    rows: int

    me to_text() -> text:
        return "client[" + me.client_id + "] -> session[" + me.session_id + "]"

    static fn create(cid: text, sid: text, c: int, r: int) -> MuxClientAttachment:
        return MuxClientAttachment(
            client_id: cid,
            session_id: sid,
            attached: true,
            cols: c,
            rows: r
        )


class SmuxMetrics:
    startup_count: int
    last_startup_ns: u64
    resize_count: int
    capture_count: int

    static fn zero() -> SmuxMetrics:
        return SmuxMetrics(
            startup_count: 0,
            last_startup_ns: 0u64,
            resize_count: 0,
            capture_count: 0
        )
