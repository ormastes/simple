# dbd protocol core — pure, socket-free, VFS-free logic for the db daemon.
#
# Reuses the REAL Simple RESP server engine
# (std.nogc_sync_mut.redis.server.RedisServer, the same engine
# src/app/redis_server/main.spl runs hosted): parse_next_request handles the
# wire framing and RedisServer.dispatch handles command semantics. This
# module adds ONLY the durability seam RedisServer lacks (it is a pure
# in-memory store): a write-ahead journal of mutating commands that is
# replayed through the SAME RedisServer.dispatch() at startup. It never
# reimplements RESP parsing, SET/GET/DEL semantics, or reply framing.
#
# Everything here is pure (no rt_net_* externs, no VFS): the transport
# (src/os/apps/dbd/dbd.spl) supplies the socket + the VFS byte store, and
# specs drive these functions directly. That keeps the durable-KV behavior
# verifiable with `simple run <spec>` without a network or a mounted disk.

use std.nogc_sync_mut.redis.server.{RedisServer, parse_next_request}

pub fn dbd_command_is_mutating(cmd: text) -> bool:
    """A command mutates durable state (must be journaled) iff it is SET/DEL."""
    val u = cmd.upper()
    u == "SET" or u == "DEL"

pub fn dbd_encode_journal_line(args: [text]) -> text:
    """Encode one mutating command as a single journal line: SPACE-joined args.

    Returns "" (caller rejects) if any arg contains a space or newline, so the
    line-oriented journal round-trips unambiguously through split(" ")/split("\\n").
    """
    var out = ""
    var i: u64 = 0
    while i < args.len():
        if args[i].find("\n") >= 0 or args[i].find(" ") >= 0:
            return ""
        if i > 0:
            out = out + " "
        out = out + args[i]
        i = i + 1
    out

pub fn dbd_decode_journal_line(line: text) -> [text]:
    """Decode one journal line back into command args (whitespace split)."""
    var args: [text] = []
    for tok in line.split(" "):
        if tok.len() > 0:
            args.push(tok)
    args

class DbdEngine:
    """The real RESP store (RedisServer) plus journal replay.

    dispatch() delegates verbatim to RedisServer.dispatch(); replay_journal()
    re-dispatches each journaled command through that same method — so
    reconstruction after a reboot uses the real engine, never a shadow copy
    of its semantics.
    """
    engine: RedisServer

    static fn new() -> DbdEngine:
        DbdEngine(engine: RedisServer.create())

    me dispatch(args: [text]) -> text:
        self.engine.dispatch(args)

    me replay_journal(log_text: text) -> i64:
        """Replay a durable journal (newline-separated encoded commands) through
        the real engine. Returns the number of commands replayed."""
        var replayed: i64 = 0
        for line in log_text.split("\n"):
            if line.len() > 0:
                val args = dbd_decode_journal_line(line)
                if args.len() > 0:
                    self.engine.dispatch(args)
                    replayed = replayed + 1
        replayed
