# ICMP -- Internet Control Message Protocol
#
# MDSOC: feature dimension, network layer
# Handles ICMP echo request/reply (ping) and error messages.
#
# Packet format:
#   type(1) code(1) checksum(2) identifier(2) sequence(2) [data...]

val ICMP_ECHO_REPLY: u8 = 0
val ICMP_DEST_UNREACHABLE: u8 = 3
val ICMP_ECHO_REQUEST: u8 = 8
val ICMP_TIME_EXCEEDED: u8 = 11

val ICMP_HEADER_SIZE: u64 = 8  # type + code + checksum + id + seq

# ============================================================================
# ICMP Packet
# ============================================================================

struct IcmpPacket:
    """Parsed ICMP echo request or reply."""
    type_: u8
    code: u8
    checksum: u16
    identifier: u16
    sequence: u16
    data: [u8]

# ============================================================================
# Parse
# ============================================================================

fn icmp_parse(data: [u8]) -> Result<IcmpPacket, text>:
    """Parse an ICMP packet from raw bytes.

    Validates minimum length and checksum.
    """
    if data.len() < ICMP_HEADER_SIZE:
        return Err("ICMP packet too short: {data.len()} < {ICMP_HEADER_SIZE}")

    val type_ = data[0]
    val code = data[1]
    val checksum: u16 = (data[2].to_u16() << 8) | data[3].to_u16()
    val identifier: u16 = (data[4].to_u16() << 8) | data[5].to_u16()
    val sequence: u16 = (data[6].to_u16() << 8) | data[7].to_u16()

    # Verify checksum over entire ICMP message
    val computed = icmp_checksum(data)
    if computed != 0:
        return Err("ICMP checksum mismatch")

    # Extract data payload
    var payload: [u8] = []
    var i: u64 = ICMP_HEADER_SIZE
    while i < data.len():
        payload.push(data[i])
        i = i + 1

    Ok(IcmpPacket(
        type_: type_, code: code, checksum: checksum,
        identifier: identifier, sequence: sequence, data: payload
    ))

# ============================================================================
# Build Echo Reply
# ============================================================================

fn icmp_build_echo_reply(request: IcmpPacket) -> [u8]:
    """Build an ICMP echo reply from a received echo request.

    Copies the identifier, sequence, and data from the request.
    Type is set to 0 (echo reply), code to 0.
    """
    var pkt: [u8] = []

    # Type: Echo Reply (0)
    pkt.push(ICMP_ECHO_REPLY)
    # Code: 0
    pkt.push(0)
    # Checksum placeholder
    pkt.push(0)
    pkt.push(0)
    # Identifier (big-endian)
    pkt.push(((request.identifier >> 8) & 0xFF).to_u8())
    pkt.push((request.identifier & 0xFF).to_u8())
    # Sequence (big-endian)
    pkt.push(((request.sequence >> 8) & 0xFF).to_u8())
    pkt.push((request.sequence & 0xFF).to_u8())

    # Copy data from request
    var i: u64 = 0
    while i < request.data.len():
        pkt.push(request.data[i])
        i = i + 1

    # Compute and fill checksum
    val cksum = icmp_checksum(pkt)
    pkt[2] = ((cksum >> 8) & 0xFF).to_u8()
    pkt[3] = (cksum & 0xFF).to_u8()

    pkt

# ============================================================================
# Build Echo Request
# ============================================================================

fn icmp_build_echo_request(id: u16, seq: u16, data: [u8]) -> [u8]:
    """Build an ICMP echo request packet.

    Args:
        id: Identifier (usually PID or unique value)
        seq: Sequence number
        data: Payload data to include
    """
    var pkt: [u8] = []

    # Type: Echo Request (8)
    pkt.push(ICMP_ECHO_REQUEST)
    # Code: 0
    pkt.push(0)
    # Checksum placeholder
    pkt.push(0)
    pkt.push(0)
    # Identifier (big-endian)
    pkt.push(((id >> 8) & 0xFF).to_u8())
    pkt.push((id & 0xFF).to_u8())
    # Sequence (big-endian)
    pkt.push(((seq >> 8) & 0xFF).to_u8())
    pkt.push((seq & 0xFF).to_u8())

    # Payload data
    var i: u64 = 0
    while i < data.len():
        pkt.push(data[i])
        i = i + 1

    # Compute and fill checksum
    val cksum = icmp_checksum(pkt)
    pkt[2] = ((cksum >> 8) & 0xFF).to_u8()
    pkt[3] = (cksum & 0xFF).to_u8()

    pkt

# ============================================================================
# Build Destination Unreachable
# ============================================================================

fn icmp_build_dest_unreachable(code: u8, original_header: [u8]) -> [u8]:
    """Build an ICMP Destination Unreachable message.

    Includes the original IPv4 header + first 8 bytes of original payload
    as required by RFC 792.
    """
    var pkt: [u8] = []

    # Type: Destination Unreachable (3)
    pkt.push(ICMP_DEST_UNREACHABLE)
    # Code
    pkt.push(code)
    # Checksum placeholder
    pkt.push(0)
    pkt.push(0)
    # Unused (4 bytes of zeros for type 3)
    pkt.push(0)
    pkt.push(0)
    pkt.push(0)
    pkt.push(0)

    # Original IP header + first 8 bytes of original datagram
    var i: u64 = 0
    val max_copy: u64 = if original_header.len() < 28: original_header.len() else: 28
    while i < max_copy:
        pkt.push(original_header[i])
        i = i + 1

    # Compute and fill checksum
    val cksum = icmp_checksum(pkt)
    pkt[2] = ((cksum >> 8) & 0xFF).to_u8()
    pkt[3] = (cksum & 0xFF).to_u8()

    pkt

# ============================================================================
# Checksum
# ============================================================================

fn icmp_checksum(data: [u8]) -> u16:
    """Compute the ICMP checksum (same algorithm as IPv4 header checksum).

    One's complement of the one's complement sum of all 16-bit words.
    """
    var sum: u32 = 0
    var i: u64 = 0

    while i + 1 < data.len():
        val word: u32 = (data[i].to_u32() << 8) | data[i + 1].to_u32()
        sum = sum + word
        i = i + 2

    # Handle odd byte
    if i < data.len():
        sum = sum + (data[i].to_u32() << 8)

    # Fold carries
    while (sum >> 16) > 0:
        sum = (sum & 0xFFFF) + (sum >> 16)

    val result: u16 = (~sum & 0xFFFF).to_u16()
    result
