# SCTP -- Stream Control Transmission Protocol (RFC 9260)
#
# MDSOC: feature dimension, network transport layer.
# Sibling of tcp.spl / udp.spl. Consumes the foundation ByteReader/ByteWriter
# (big-endian) and the foundation Port directly.
#
# Wire layout:
#   Common header (12 bytes):
#     src_port(2) dst_port(2) verification_tag(4) checksum(4 = CRC32c)
#   followed by a list of chunks. Each chunk is a TLV:
#     type(1) flags(1) length(2) value(length-4) <pad to 4-byte boundary>
#   The `length` field counts type+flags+length+value but NOT the trailing pad.
#
# Checksum is CRC32c (Castagnoli, poly 0x1EDC6F41 / reversed 0x82F63B78), NOT the
# one's-complement internet checksum. Per RFC 9260 6.8 the 32-bit CRC is placed
# into the checksum field transmitted least-significant-byte first; with a
# big-endian ByteWriter that means we store the byte-reversed CRC integer.
#
# ALPHA ORACLE: no C runtime is vendored (usrsctp license unverified; see design
# note r4_transport_internet.md). Golden test vectors -- including the CRC32c
# known-answer value 0xE3069283 for "123456789" -- were derived INDEPENDENTLY in
# a Python sandbox (bitwise Castagnoli) and are asserted in sctp_spec.spl.

use std.common.net.byte_cursor.{ByteReader, ByteWriter}
use std.common.net.addr.{Port}

# ============================================================================
# Chunk-type constants (integer dispatch, NOT a payload-carrying enum).
# ============================================================================

val SCTP_CHUNK_DATA: u8 = 0
val SCTP_CHUNK_INIT: u8 = 1
val SCTP_CHUNK_INIT_ACK: u8 = 2
val SCTP_CHUNK_SACK: u8 = 3
val SCTP_CHUNK_HEARTBEAT: u8 = 4
val SCTP_CHUNK_HEARTBEAT_ACK: u8 = 5
val SCTP_CHUNK_ABORT: u8 = 6
val SCTP_CHUNK_SHUTDOWN: u8 = 7
val SCTP_CHUNK_SHUTDOWN_ACK: u8 = 8
val SCTP_CHUNK_ERROR: u8 = 9
val SCTP_CHUNK_COOKIE_ECHO: u8 = 10
val SCTP_CHUNK_COOKIE_ACK: u8 = 11
val SCTP_CHUNK_SHUTDOWN_COMPLETE: u8 = 14

val SCTP_COMMON_HEADER_SIZE: u64 = 12

# ============================================================================
# CRC32c (Castagnoli) -- table-driven.
#
# FLAG: promotion candidate for src/lib/common/net (host-agnostic, pure).
# A 256-entry table over [u32] -- exercises array-element correctness + the
# per-byte loop perf. The table is built lazily-once via a builder fn.
# ============================================================================

val SCTP_CRC32C_POLY: u32 = 0x82F63B78  # reversed (LSB-first) Castagnoli poly

fn sctp_crc32c_table() -> [u32]:
    """Build the 256-entry CRC32c lookup table (reversed-bit form)."""
    var table: [u32] = []
    var n: u32 = 0
    while n < 256:
        var crc: u32 = n
        var k: u64 = 0
        while k < 8:
            if (crc & 1) != 0:
                crc = (crc >> 1) ^ SCTP_CRC32C_POLY
            else:
                crc = crc >> 1
            k = k + 1
        table.push(crc)
        n = n + 1
    table

# Built once at module load -- avoids rebuilding the 256-entry table per call.
val SCTP_CRC32C_TABLE: [u32] = sctp_crc32c_table()

fn sctp_crc32c(data: [u8]) -> u32:
    """CRC32c (Castagnoli) over `data`. Returns the raw 32-bit CRC integer.

    Known-answer: sctp_crc32c(b"123456789") == 0xE3069283.
    """
    val table = SCTP_CRC32C_TABLE
    var crc: u32 = 0xFFFFFFFF
    var i: u64 = 0
    while i < data.len():
        val idx: u64 = ((crc ^ data[i].to_u32()) & 0xFF).to_u64()
        crc = (crc >> 8) ^ table[idx]
        i = i + 1
    crc ^ 0xFFFFFFFF

# ============================================================================
# Common header
# ============================================================================

struct SctpCommonHeader:
    """SCTP 12-byte common header."""
    src_port: Port
    dst_port: Port
    verification_tag: u32
    checksum: u32          # CRC32c, stored as the raw CRC integer

fn sctp_build_common_header(h: SctpCommonHeader) -> [u8]:
    """Serialize the 12-byte common header. checksum stored LSB-first per RFC."""
    var w = ByteWriter.new()
    w.write_u16(h.src_port.value)
    w.write_u16(h.dst_port.value)
    w.write_u32(h.verification_tag)
    # CRC32c is transmitted least-significant-byte first -> byte-reversed u32.
    val ck = h.checksum
    w.write_u8((ck & 0xFF).to_u8())
    w.write_u8(((ck >> 8) & 0xFF).to_u8())
    w.write_u8(((ck >> 16) & 0xFF).to_u8())
    w.write_u8(((ck >> 24) & 0xFF).to_u8())
    w.to_bytes()

fn sctp_parse_common_header(data: [u8]) -> Result<SctpCommonHeader, text>:
    """Parse the 12-byte common header."""
    if data.len() < SCTP_COMMON_HEADER_SIZE:
        return Err("SCTP common header too short: {data.len()} < 12")
    var r = ByteReader.new(data)
    val sp = r.read_u16()?
    val dp = r.read_u16()?
    val vtag = r.read_u32()?
    # checksum field is LSB-first on the wire -> reassemble raw CRC integer.
    # BUG(question_op_method_chain_wraps_value): `read_u8()?.to_u32()` mis-wraps
    # the value; unwrap into a val first, then call .to_u32().
    val b0 = r.read_u8()?
    val b1 = r.read_u8()?
    val b2 = r.read_u8()?
    val b3 = r.read_u8()?
    val c0 = b0.to_u32()
    val c1 = b1.to_u32()
    val c2 = b2.to_u32()
    val c3 = b3.to_u32()
    val ck: u32 = c0 | (c1 << 8) | (c2 << 16) | (c3 << 24)
    # BUG(struct_literal_named_arg_shadowed_by_static_new): Port(value: x) is
    # rejected because Port has a `static fn new(v)`; use Port.new instead.
    Ok(SctpCommonHeader(
        src_port: Port.new(sp),
        dst_port: Port.new(dp),
        verification_tag: vtag,
        checksum: ck))

# Compute the CRC32c over a full SCTP packet whose checksum field is zeroed.
fn sctp_packet_checksum(packet: [u8]) -> u32:
    """CRC32c of a complete packet with the 4-byte checksum field (offset 8) zeroed."""
    var buf: [u8] = []
    var i: u64 = 0
    while i < packet.len():
        if i >= 8 and i < 12:
            buf.push(0)
        else:
            buf.push(packet[i])
        i = i + 1
    sctp_crc32c(buf)

# ============================================================================
# Generic chunk (TLV) with 4-byte padding
# ============================================================================

struct SctpChunk:
    """A generic SCTP chunk: type/flags/length + value (length excludes pad)."""
    type_: u8
    flags: u8
    length: u16            # counts the 4-byte header + value, NOT trailing pad
    value: [u8]

# Number of trailing pad bytes to reach a 4-byte boundary for a chunk of
# `length` octets (length already counts the 4-byte chunk header + value).
fn sctp_chunk_pad(length: u16) -> u64:
    val rem: u64 = length.to_u64() % 4
    if rem == 0:
        0
    else:
        4 - rem

fn sctp_build_chunk(c: SctpChunk) -> [u8]:
    """Serialize one chunk including its trailing 4-byte-alignment padding."""
    var w = ByteWriter.new()
    w.write_u8(c.type_)
    w.write_u8(c.flags)
    w.write_u16(c.length)
    w.write_bytes(c.value)
    val pad = sctp_chunk_pad(c.length)
    var p: u64 = 0
    while p < pad:
        w.write_u8(0)
        p = p + 1
    w.to_bytes()

# Parse one chunk starting at data[off..]. Returns (chunk, next_offset) packed
# in a SctpChunkParse. next_off advances past the trailing pad.
struct SctpChunkParse:
    chunk: SctpChunk
    next_off: u64

fn sctp_parse_chunk(data: [u8], off: u64) -> Result<SctpChunkParse, text>:
    if off + 4 > data.len():
        return Err("SCTP chunk truncated header")
    val type_ = data[off]
    val flags = data[off + 1]
    val length: u16 = ((data[off + 2].to_u16() << 8) | data[off + 3].to_u16())
    if length.to_u64() < 4:
        return Err("SCTP chunk length < 4")
    if off + length.to_u64() > data.len():
        return Err("SCTP chunk overruns packet")
    var value: [u8] = []
    var i: u64 = off + 4
    val vend: u64 = off + length.to_u64()
    while i < vend:
        value.push(data[i])
        i = i + 1
    val pad = sctp_chunk_pad(length)
    val next_off: u64 = off + length.to_u64() + pad
    Ok(SctpChunkParse(
        chunk: SctpChunk(type_: type_, flags: flags, length: length, value: value),
        next_off: next_off))

# Parse the chunk list following a common header. `data` is the bytes AFTER the
# 12-byte common header. Walks the TLV list honouring 4-byte padding.
fn sctp_parse_chunks(data: [u8]) -> Result<[SctpChunk], text>:
    var out: [SctpChunk] = []
    var off: u64 = 0
    while off < data.len():
        val p = sctp_parse_chunk(data, off)?
        out.push(p.chunk)
        if p.next_off <= off:
            return Err("SCTP chunk made no progress")
        off = p.next_off
    Ok(out)

# ============================================================================
# Typed chunk bodies
# ============================================================================

struct SctpDataChunk:
    """DATA chunk (type 0) value: tsn(4) sid(2) sseq(2) ppid(4) user_data."""
    tsn: u32
    stream_id: u16
    stream_seq: u16
    ppid: u32
    user_data: [u8]

fn sctp_build_data(d: SctpDataChunk, flags: u8) -> SctpChunk:
    """Build a DATA SctpChunk from a typed body."""
    var w = ByteWriter.new()
    w.write_u32(d.tsn)
    w.write_u16(d.stream_id)
    w.write_u16(d.stream_seq)
    w.write_u32(d.ppid)
    w.write_bytes(d.user_data)
    val value = w.to_bytes()
    val length: u16 = (4 + value.len()).to_u16()
    SctpChunk(type_: SCTP_CHUNK_DATA, flags: flags, length: length, value: value)

fn sctp_parse_data(c: SctpChunk) -> Result<SctpDataChunk, text>:
    if c.type_ != SCTP_CHUNK_DATA:
        return Err("not a DATA chunk")
    if c.value.len() < 12:
        return Err("DATA chunk value too short")
    var r = ByteReader.new(c.value)
    val tsn = r.read_u32()?
    val sid = r.read_u16()?
    val sseq = r.read_u16()?
    val ppid = r.read_u32()?
    val ud = r.read_bytes(r.remaining())?
    Ok(SctpDataChunk(tsn: tsn, stream_id: sid, stream_seq: sseq, ppid: ppid, user_data: ud))

# Nested INIT parameter (TLV: type(2) length(2) value + pad to 4).
struct SctpParam:
    type_: u16
    length: u16            # counts the 4-byte param header + value, NOT pad
    value: [u8]

fn sctp_param_pad(length: u16) -> u64:
    val rem: u64 = length.to_u64() % 4
    if rem == 0:
        0
    else:
        4 - rem

fn sctp_build_param(p: SctpParam) -> [u8]:
    var w = ByteWriter.new()
    w.write_u16(p.type_)
    w.write_u16(p.length)
    w.write_bytes(p.value)
    val pad = sctp_param_pad(p.length)
    var i: u64 = 0
    while i < pad:
        w.write_u8(0)
        i = i + 1
    w.to_bytes()

fn sctp_parse_params(data: [u8]) -> Result<[SctpParam], text>:
    """Walk a nested TLV parameter list (4-byte padded)."""
    var out: [SctpParam] = []
    var off: u64 = 0
    while off + 4 <= data.len():
        val type_: u16 = ((data[off].to_u16() << 8) | data[off + 1].to_u16())
        val length: u16 = ((data[off + 2].to_u16() << 8) | data[off + 3].to_u16())
        if length.to_u64() < 4:
            return Err("SCTP param length < 4")
        if off + length.to_u64() > data.len():
            return Err("SCTP param overruns")
        var value: [u8] = []
        var i: u64 = off + 4
        val vend: u64 = off + length.to_u64()
        while i < vend:
            value.push(data[i])
            i = i + 1
        out.push(SctpParam(type_: type_, length: length, value: value))
        val pad = sctp_param_pad(length)
        off = off + length.to_u64() + pad
    Ok(out)

struct SctpInitChunk:
    """INIT / INIT-ACK (type 1/2) value: initiate_tag(4) a_rwnd(4)
    num_outbound(2) num_inbound(2) initial_tsn(4) params."""
    initiate_tag: u32
    a_rwnd: u32
    num_outbound_streams: u16
    num_inbound_streams: u16
    initial_tsn: u32
    params: [SctpParam]

fn sctp_build_init(init: SctpInitChunk, chunk_type: u8) -> SctpChunk:
    var w = ByteWriter.new()
    w.write_u32(init.initiate_tag)
    w.write_u32(init.a_rwnd)
    w.write_u16(init.num_outbound_streams)
    w.write_u16(init.num_inbound_streams)
    w.write_u32(init.initial_tsn)
    var pi: u64 = 0
    while pi < init.params.len():
        w.write_bytes(sctp_build_param(init.params[pi]))
        pi = pi + 1
    val value = w.to_bytes()
    val length: u16 = (4 + value.len()).to_u16()
    SctpChunk(type_: chunk_type, flags: 0, length: length, value: value)

fn sctp_parse_init(c: SctpChunk) -> Result<SctpInitChunk, text>:
    if c.type_ != SCTP_CHUNK_INIT and c.type_ != SCTP_CHUNK_INIT_ACK:
        return Err("not an INIT/INIT-ACK chunk")
    if c.value.len() < 16:
        return Err("INIT chunk value too short")
    var r = ByteReader.new(c.value)
    val tag = r.read_u32()?
    val rwnd = r.read_u32()?
    val nout = r.read_u16()?
    val nin = r.read_u16()?
    val itsn = r.read_u32()?
    val rest = r.read_bytes(r.remaining())?
    val params = sctp_parse_params(rest)?
    Ok(SctpInitChunk(
        initiate_tag: tag, a_rwnd: rwnd,
        num_outbound_streams: nout, num_inbound_streams: nin,
        initial_tsn: itsn, params: params))

struct SctpSackChunk:
    """SACK (type 3) value: cum_tsn_ack(4) a_rwnd(4) num_gap(2) num_dup(2)
    gap_ack_blocks[num_gap]=(start<<16)|end  dup_tsns[num_dup]."""
    cum_tsn_ack: u32
    a_rwnd: u32
    gap_ack_blocks: [u32]
    dup_tsns: [u32]

fn sctp_build_sack(s: SctpSackChunk) -> SctpChunk:
    var w = ByteWriter.new()
    w.write_u32(s.cum_tsn_ack)
    w.write_u32(s.a_rwnd)
    w.write_u16(s.gap_ack_blocks.len().to_u16())
    w.write_u16(s.dup_tsns.len().to_u16())
    var i: u64 = 0
    while i < s.gap_ack_blocks.len():
        w.write_u32(s.gap_ack_blocks[i])
        i = i + 1
    i = 0
    while i < s.dup_tsns.len():
        w.write_u32(s.dup_tsns[i])
        i = i + 1
    val value = w.to_bytes()
    val length: u16 = (4 + value.len()).to_u16()
    SctpChunk(type_: SCTP_CHUNK_SACK, flags: 0, length: length, value: value)

fn sctp_parse_sack(c: SctpChunk) -> Result<SctpSackChunk, text>:
    if c.type_ != SCTP_CHUNK_SACK:
        return Err("not a SACK chunk")
    if c.value.len() < 12:
        return Err("SACK chunk value too short")
    var r = ByteReader.new(c.value)
    val cum = r.read_u32()?
    val rwnd = r.read_u32()?
    val ngap = r.read_u16()?
    val ndup = r.read_u16()?
    var gaps: [u32] = []
    var i: u64 = 0
    while i < ngap.to_u64():
        gaps.push(r.read_u32()?)
        i = i + 1
    var dups: [u32] = []
    i = 0
    while i < ndup.to_u64():
        dups.push(r.read_u32()?)
        i = i + 1
    Ok(SctpSackChunk(cum_tsn_ack: cum, a_rwnd: rwnd, gap_ack_blocks: gaps, dup_tsns: dups))

struct SctpHeartbeatChunk:
    """HEARTBEAT / HEARTBEAT-ACK (type 4/5) value: nested HB-info params."""
    params: [SctpParam]

fn sctp_build_heartbeat(hb: SctpHeartbeatChunk, chunk_type: u8) -> SctpChunk:
    var w = ByteWriter.new()
    var i: u64 = 0
    while i < hb.params.len():
        w.write_bytes(sctp_build_param(hb.params[i]))
        i = i + 1
    val value = w.to_bytes()
    val length: u16 = (4 + value.len()).to_u16()
    SctpChunk(type_: chunk_type, flags: 0, length: length, value: value)

fn sctp_parse_heartbeat(c: SctpChunk) -> Result<SctpHeartbeatChunk, text>:
    if c.type_ != SCTP_CHUNK_HEARTBEAT and c.type_ != SCTP_CHUNK_HEARTBEAT_ACK:
        return Err("not a HEARTBEAT chunk")
    val params = sctp_parse_params(c.value)?
    Ok(SctpHeartbeatChunk(params: params))

# ============================================================================
# Whole packet
# ============================================================================

struct SctpPacket:
    header: SctpCommonHeader
    chunks: [SctpChunk]

fn sctp_build_packet(pkt: SctpPacket, compute_checksum: bool) -> [u8]:
    """Serialize a full packet. If compute_checksum, fills the CRC32c field."""
    var w = ByteWriter.new()
    w.write_bytes(sctp_build_common_header(pkt.header))
    var i: u64 = 0
    while i < pkt.chunks.len():
        w.write_bytes(sctp_build_chunk(pkt.chunks[i]))
        i = i + 1
    var bytes = w.to_bytes()
    if compute_checksum:
        val crc = sctp_packet_checksum(bytes)
        # store LSB-first at offset 8..12
        bytes[8] = (crc & 0xFF).to_u8()
        bytes[9] = ((crc >> 8) & 0xFF).to_u8()
        bytes[10] = ((crc >> 16) & 0xFF).to_u8()
        bytes[11] = ((crc >> 24) & 0xFF).to_u8()
    bytes

fn sctp_parse_packet(data: [u8]) -> Result<SctpPacket, text>:
    val header = sctp_parse_common_header(data)?
    var rest: [u8] = []
    var i: u64 = SCTP_COMMON_HEADER_SIZE
    while i < data.len():
        rest.push(data[i])
        i = i + 1
    val chunks = sctp_parse_chunks(rest)?
    Ok(SctpPacket(header: header, chunks: chunks))
