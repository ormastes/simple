# ARP -- Address Resolution Protocol
#
# MDSOC: feature dimension, network layer
# Resolves IPv4 addresses to MAC addresses.
# Maintains an ARP cache with aging and eviction.
#
# Packet format (28 bytes for Ethernet/IPv4):
#   hw_type(2) proto_type(2) hw_len(1) proto_len(1) operation(2)
#   sender_mac(6) sender_ip(4) target_mac(6) target_ip(4)

use os.services.netstack.ethernet.{EthAddress}

val ARP_REQUEST: u16 = 1
val ARP_REPLY: u16 = 2
val ARP_HW_ETHERNET: u16 = 1
val ARP_PROTO_IPV4: u16 = 0x0800
val ARP_PACKET_SIZE: u64 = 28

# Maximum age in ticks before an ARP entry is considered stale
val ARP_MAX_AGE: u64 = 300

# ============================================================================
# ARP Table Entry
# ============================================================================

struct ArpEntry:
    """Single ARP cache entry mapping IPv4 to MAC."""
    ip: u32              # IPv4 address (network byte order)
    mac: EthAddress      # Resolved MAC address
    age: u64             # Ticks since last refresh
    valid: bool          # Whether this entry is active

# ============================================================================
# ARP Table
# ============================================================================

struct ArpTable:
    """ARP cache with fixed capacity and LRU-style aging."""
    entries: [ArpEntry]
    capacity: u32
    count: u32

impl ArpTable:
    static fn new(capacity: u32) -> ArpTable:
        """Create an empty ARP table with the given max capacity."""
        ArpTable(entries: [], capacity: capacity, count: 0)

    fn lookup(ip: u32) -> EthAddress?:
        """Look up a MAC address for the given IPv4 address.

        Returns nil if no valid entry exists.
        """
        var i: u64 = 0
        while i < self.entries.len():
            val entry = self.entries[i]
            if entry.valid and entry.ip == ip:
                return entry.mac
            i = i + 1
        nil

    me insert(ip: u32, mac: EthAddress):
        """Insert or update an ARP entry.

        If the IP already exists, updates the MAC and resets age.
        If table is full, evicts the oldest entry.
        """
        # Check for existing entry to update
        var i: u64 = 0
        while i < self.entries.len():
            if self.entries[i].ip == ip:
                self.entries[i] = ArpEntry(ip: ip, mac: mac, age: 0, valid: true)
                return
            i = i + 1

        # Find a free slot (invalid entry)
        i = 0
        while i < self.entries.len():
            if not self.entries[i].valid:
                self.entries[i] = ArpEntry(ip: ip, mac: mac, age: 0, valid: true)
                self.count = self.count + 1
                return
            i = i + 1

        # If under capacity, append
        if self.count < self.capacity:
            self.entries.push(ArpEntry(ip: ip, mac: mac, age: 0, valid: true))
            self.count = self.count + 1
            return

        # Evict oldest entry
        var oldest_idx: u64 = 0
        var oldest_age: u64 = 0
        i = 0
        while i < self.entries.len():
            if self.entries[i].valid and self.entries[i].age > oldest_age:
                oldest_age = self.entries[i].age
                oldest_idx = i
            i = i + 1
        self.entries[oldest_idx] = ArpEntry(ip: ip, mac: mac, age: 0, valid: true)

    me age_entries(ticks: u64):
        """Increment age on all entries and invalidate stale ones."""
        var i: u64 = 0
        while i < self.entries.len():
            if self.entries[i].valid:
                val new_age = self.entries[i].age + ticks
                if new_age > ARP_MAX_AGE:
                    self.entries[i] = ArpEntry(
                        ip: self.entries[i].ip,
                        mac: self.entries[i].mac,
                        age: new_age,
                        valid: false
                    )
                    self.count = self.count - 1
                else:
                    self.entries[i] = ArpEntry(
                        ip: self.entries[i].ip,
                        mac: self.entries[i].mac,
                        age: new_age,
                        valid: true
                    )
            i = i + 1

    me remove(ip: u32):
        """Remove an ARP entry by IP address."""
        var i: u64 = 0
        while i < self.entries.len():
            if self.entries[i].valid and self.entries[i].ip == ip:
                self.entries[i] = ArpEntry(
                    ip: self.entries[i].ip,
                    mac: self.entries[i].mac,
                    age: self.entries[i].age,
                    valid: false
                )
                self.count = self.count - 1
                return
            i = i + 1

# ============================================================================
# ARP Packet
# ============================================================================

struct ArpPacket:
    """Parsed ARP packet."""
    hw_type: u16         # 1 = Ethernet
    proto_type: u16      # 0x0800 = IPv4
    hw_len: u8           # 6 for Ethernet
    proto_len: u8        # 4 for IPv4
    operation: u16       # 1 = request, 2 = reply
    sender_mac: EthAddress
    sender_ip: u32
    target_mac: EthAddress
    target_ip: u32

# ============================================================================
# Parse / Build
# ============================================================================

fn arp_parse(data: [u8]) -> Result<ArpPacket, text>:
    """Parse an ARP packet from raw bytes.

    Expects at least 28 bytes for a standard Ethernet/IPv4 ARP packet.
    All multi-byte fields are big-endian (network byte order).
    """
    if data.len() < ARP_PACKET_SIZE:
        return Err("ARP packet too short: {data.len()} < {ARP_PACKET_SIZE}")

    val hw_type: u16 = (data[0].to_u16() << 8) | data[1].to_u16()
    val proto_type: u16 = (data[2].to_u16() << 8) | data[3].to_u16()
    val hw_len = data[4]
    val proto_len = data[5]
    val operation: u16 = (data[6].to_u16() << 8) | data[7].to_u16()

    # Validate hardware/protocol lengths
    if hw_len != 6:
        return Err("unsupported hardware address length: {hw_len}")
    if proto_len != 4:
        return Err("unsupported protocol address length: {proto_len}")

    # Sender MAC at offset 8, sender IP at offset 14
    val sender_mac = EthAddress.from_bytes(data, 8)
    val sender_ip: u32 = (data[14].to_u32() << 24) | (data[15].to_u32() << 16) |
                         (data[16].to_u32() << 8) | data[17].to_u32()

    # Target MAC at offset 18, target IP at offset 24
    val target_mac = EthAddress.from_bytes(data, 18)
    val target_ip: u32 = (data[24].to_u32() << 24) | (data[25].to_u32() << 16) |
                         (data[26].to_u32() << 8) | data[27].to_u32()

    Ok(ArpPacket(
        hw_type: hw_type, proto_type: proto_type,
        hw_len: hw_len, proto_len: proto_len,
        operation: operation,
        sender_mac: sender_mac, sender_ip: sender_ip,
        target_mac: target_mac, target_ip: target_ip
    ))

fn arp_build_request(sender_mac: EthAddress, sender_ip: u32, target_ip: u32) -> [u8]:
    """Build an ARP request packet.

    Target MAC is set to 00:00:00:00:00:00 per the ARP standard.
    Returns the 28-byte ARP payload (not including Ethernet header).
    """
    var pkt: [u8] = []

    # Hardware type: Ethernet (0x0001)
    pkt.push(0x00)
    pkt.push(0x01)
    # Protocol type: IPv4 (0x0800)
    pkt.push(0x08)
    pkt.push(0x00)
    # Hardware len: 6, Protocol len: 4
    pkt.push(6)
    pkt.push(4)
    # Operation: REQUEST (1)
    pkt.push(0x00)
    pkt.push(0x01)

    # Sender MAC
    val smac = sender_mac.to_bytes()
    var i: u64 = 0
    while i < 6:
        pkt.push(smac[i])
        i = i + 1

    # Sender IP (big-endian)
    pkt.push(((sender_ip >> 24) & 0xFF).to_u8())
    pkt.push(((sender_ip >> 16) & 0xFF).to_u8())
    pkt.push(((sender_ip >> 8) & 0xFF).to_u8())
    pkt.push((sender_ip & 0xFF).to_u8())

    # Target MAC: all zeros (unknown)
    i = 0
    while i < 6:
        pkt.push(0)
        i = i + 1

    # Target IP (big-endian)
    pkt.push(((target_ip >> 24) & 0xFF).to_u8())
    pkt.push(((target_ip >> 16) & 0xFF).to_u8())
    pkt.push(((target_ip >> 8) & 0xFF).to_u8())
    pkt.push((target_ip & 0xFF).to_u8())

    pkt

fn arp_build_reply(sender_mac: EthAddress, sender_ip: u32, target_mac: EthAddress, target_ip: u32) -> [u8]:
    """Build an ARP reply packet.

    Sender is us (responding), target is the original requester.
    Returns the 28-byte ARP payload.
    """
    var pkt: [u8] = []

    # Hardware type: Ethernet (0x0001)
    pkt.push(0x00)
    pkt.push(0x01)
    # Protocol type: IPv4 (0x0800)
    pkt.push(0x08)
    pkt.push(0x00)
    # Hardware len: 6, Protocol len: 4
    pkt.push(6)
    pkt.push(4)
    # Operation: REPLY (2)
    pkt.push(0x00)
    pkt.push(0x02)

    # Sender MAC (us)
    val smac = sender_mac.to_bytes()
    var i: u64 = 0
    while i < 6:
        pkt.push(smac[i])
        i = i + 1

    # Sender IP (us, big-endian)
    pkt.push(((sender_ip >> 24) & 0xFF).to_u8())
    pkt.push(((sender_ip >> 16) & 0xFF).to_u8())
    pkt.push(((sender_ip >> 8) & 0xFF).to_u8())
    pkt.push((sender_ip & 0xFF).to_u8())

    # Target MAC (requester)
    val tmac = target_mac.to_bytes()
    i = 0
    while i < 6:
        pkt.push(tmac[i])
        i = i + 1

    # Target IP (requester, big-endian)
    pkt.push(((target_ip >> 24) & 0xFF).to_u8())
    pkt.push(((target_ip >> 16) & 0xFF).to_u8())
    pkt.push(((target_ip >> 8) & 0xFF).to_u8())
    pkt.push((target_ip & 0xFF).to_u8())

    pkt
