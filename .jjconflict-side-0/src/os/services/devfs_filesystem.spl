# SimpleOS Device Filesystem — VFS `Filesystem`-trait adapter (H4)
"""Adapts the /dev pseudo-filesystem onto the shared VFS `Filesystem` trait so
it composes exactly like FAT32/DBFS through `VfsManager.mount`.

The ECS-backed `DevfsService` models dynamically driver-registered device nodes,
but its generic `ComponentStore<T>` / `Entity` machinery does not lower under
the bootstrap-seed interpreter (Entity/ANY field inference fails), so this trait
adapter keeps a seed-safe plain registry of the well-known character devices
(`null`, `zero`, `urandom`, `console`). A compiled kernel boot can additionally
enumerate driver-registered nodes from `DevfsService`.

Plan: host_os_completeness H4.
"""

use os.services.vfs.vfs.{Filesystem, SeekWhence}
use os.kernel.types.fs_types.{FileFlags, FsNode, FsNodeKind, DirEntry}
use os.services.devfs_service.{DEV_CHAR}

# ---------------------------------------------------------------------------
# Node + open-handle records
# ---------------------------------------------------------------------------

struct DevNode:
    """One well-known /dev node."""
    name: text
    kind: u32
    mode: u16

struct DevHandle:
    """An open device handle bound to a device name."""
    id: u64
    name: text

# ---------------------------------------------------------------------------
# DevFs — Filesystem trait adapter
# ---------------------------------------------------------------------------

class DevFs:
    """/dev pseudo-filesystem exposed through the `Filesystem` trait."""
    var nodes: [DevNode]
    var handles: [DevHandle]
    var next_handle: u64
    var rng_state: u64

    static fn new() -> DevFs:
        DevFs(
            nodes: [
                DevNode(name: "null",    kind: DEV_CHAR, mode: 0o666 as u16),
                DevNode(name: "zero",    kind: DEV_CHAR, mode: 0o666 as u16),
                DevNode(name: "urandom", kind: DEV_CHAR, mode: 0o444 as u16),
                DevNode(name: "console", kind: DEV_CHAR, mode: 0o620 as u16)
            ],
            handles: [],
            next_handle: 1 as u64,
            rng_state: 88172645463325252 as u64)

    me _has(name: text) -> bool:
        for n in self.nodes:
            if n.name == name:
                return true
        false

    me _mode_of(name: text) -> u16:
        for n in self.nodes:
            if n.name == name:
                return n.mode
        0o444 as u16

    me _handle_name(handle: u64) -> text:
        for h in self.handles:
            if h.id == handle:
                return h.name
        ""

# ---------------------------------------------------------------------------
# Filesystem trait impl
# ---------------------------------------------------------------------------

impl Filesystem for DevFs:
    fn fs_name() -> text:
        "devfs"

    fn mount(device: text, options: text) -> Result<bool, text>:
        Result.Ok(true)

    fn unmount() -> Result<bool, text>:
        self.handles = []
        Result.Ok(true)

    fn open(path: text, flags: FileFlags) -> Result<u64, text>:
        if _dev_root(path):
            return Result.Err("EISDIR: /dev")
        val name = _dev_name(path)
        if not self._has(name):
            return Result.Err("ENOENT: {path}")
        val h = self.next_handle
        self.next_handle = self.next_handle + (1 as u64)
        self.handles = self.handles + [DevHandle(id: h, name: name)]
        Result.Ok(h)

    fn read(handle: u64, size: u64) -> Result<[u8], text>:
        val name = self._handle_name(handle)
        if name == "":
            return Result.Err("EBADF")
        if name == "zero":
            return Result.Ok(_zeros(size))
        if name == "urandom":
            var st = self.rng_state
            var out: [u8] = []
            var i: u64 = 0 as u64
            while i < size:
                st = _xorshift(st)
                out = out + [(st & (255 as u64)) as u8]
                i = i + (1 as u64)
            self.rng_state = st
            return Result.Ok(out)
        # null and console read as EOF
        var empty: [u8] = []
        Result.Ok(empty)

    fn write(handle: u64, data: [u8]) -> Result<u64, text>:
        val name = self._handle_name(handle)
        if name == "":
            return Result.Err("EBADF")
        if name == "urandom":
            return Result.Err("EACCES: /dev/urandom is read-only")
        # null, zero, console discard all writes and report full acceptance
        Result.Ok(data.len() as u64)

    fn close(handle: u64) -> Result<bool, text>:
        var kept: [DevHandle] = []
        var removed = false
        for h in self.handles:
            if h.id != handle:
                kept = kept + [h]
            else:
                removed = true
        self.handles = kept
        if removed:
            return Result.Ok(true)
        Result.Err("EBADF")

    fn seek(handle: u64, offset: i64, whence: SeekWhence) -> Result<u64, text>:
        Result.Err("ESPIPE: /dev entries are not seekable")

    fn stat(path: text) -> Result<FsNode, text>:
        if _dev_root(path):
            return Result.Ok(_dev_fs_node(FsNodeKind.Directory, 0o555 as u16))
        val name = _dev_name(path)
        if not self._has(name):
            return Result.Err("ENOENT: {path}")
        Result.Ok(_dev_fs_node(FsNodeKind.Device, self._mode_of(name)))

    fn chmod(path: text, mode: u16) -> Result<bool, text>:
        Result.Err("EROFS: /dev chmod unsupported")

    fn mkdir(path: text) -> Result<bool, text>:
        Result.Err("EROFS: /dev is not writable")

    fn rmdir(path: text) -> Result<bool, text>:
        Result.Err("EROFS: /dev is not writable")

    fn readdir(path: text) -> Result<[DirEntry], text>:
        if not _dev_root(path):
            return Result.Err("ENOTDIR: {path}")
        var entries: [DirEntry] = []
        for n in self.nodes:
            entries = entries + [DirEntry(name: n.name, node: _dev_fs_node(FsNodeKind.Device, n.mode))]
        Result.Ok(entries)

    fn unlink(path: text) -> Result<bool, text>:
        Result.Err("EROFS: /dev is not writable")

    fn rename(old_path: text, new_path: text) -> Result<bool, text>:
        Result.Err("EROFS: /dev is not writable")

    fn symlink(target: text, link_path: text) -> Result<bool, text>:
        Result.Err("EROFS: /dev is not writable")

# ---------------------------------------------------------------------------
# Module helpers
# ---------------------------------------------------------------------------

fn _dev_root(path: text) -> bool:
    """True when the path addresses the /dev directory itself."""
    path == "/" or path == "" or path == "/dev"

fn _dev_name(path: text) -> text:
    """Reduce an absolute or mount-relative path to the bare device name."""
    if path.starts_with("/dev/"):
        return path.slice(5)
    if path.starts_with("/"):
        return path.slice(1)
    path

fn _zeros(n: u64) -> [u8]:
    """Return an array of `n` zero bytes."""
    var out: [u8] = []
    var i: u64 = 0 as u64
    while i < n:
        out = out + [0 as u8]
        i = i + (1 as u64)
    out

fn _xorshift(state: u64) -> u64:
    """One step of a 64-bit xorshift PRNG (bitwise only, no overflow trap)."""
    var x = state
    x = x ^ (x << 13)
    x = x ^ (x >> 7)
    x = x ^ (x << 17)
    x

fn _dev_fs_node(kind: FsNodeKind, mode: u16) -> FsNode:
    FsNode(
        id: 0 as u64,
        kind: kind,
        size: 0 as u64,
        permissions: mode,
        owner: 0 as u32,
        group: 0 as u32,
        created_ns: 0 as u64,
        modified_ns: 0 as u64)
