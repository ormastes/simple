# OsMcpServer UI-access tool handlers plus screenshot/system tools and process tracking.
use os.services.llm.mcp_os_server.*
# OS MCP Server — LLM Control of SimpleOS
#
# MCP server exposing OS operations as tools for LLM control.
# Uses existing MCP SDK (std.nogc_async_mut.mcp) for protocol handling
# and existing VFS service for file operations.
#
# Tools exposed:
#   File:    file_read, file_write, file_list, file_search
#   Process: process_list, process_spawn, process_kill
#   Window:  window_create, window_close, window_list, window_focus
#   Widget:  widget_set, widget_read, widget_action
#   UIAccess: ui_access_snapshot, ui_access_surface, ui_access_find, ui_access_act, ui_access_history, ui_access_observe, ui_access_state, ui_access_query, ui_access_ensure, ui_access_value, ui_access_adapter_snapshot, ui_access_visual_probe
#   Screen:  screenshot, screen_read_text
#   System:  system_info, system_exec

use os.services.vfs.vfs.{VfsManager, VfsMountEntry}
use os.kernel.types.fs_types.{DirEntry, FsNode, FsNodeKind, FileFlags, FileDescriptor}
use os.kernel.types.task_types.{TaskId, TaskState}
use os.kernel.types.syscall_types.{SyscallId}
use os.services.llm.widget_eval.{WidgetDslEvaluator}
use os.services.llm.cli_gui_bridge.{CliGuiBridge}
use os.services.llm.ui_access_resolver.{ui_access_resolve_adapter, ui_access_resolve_visual_probe}
use os.services.llm.tool_registry.{register_os_tools}
use nogc_sync_mut.ui.session.{UISession}
use common.ui.widget.{UITree, WidgetNode, UIEvent}
use common.ui.builder.{build_tree}
use common.ui.access.{UiAccessNode, UiAccessSnapshot, UiAccessSurface, ui_access_find_nodes, ui_access_find_node, ui_access_resolve_action_name, ui_access_snapshot_to_json, ui_access_surface_to_json, ui_access_events_to_json, ui_access_snapshot_to_text, ui_access_query_to_json, ui_access_ensure_result, ui_access_ensure_to_json, ui_access_node_value, ui_access_supports_value, ui_access_value_to_json}
use common.ui.access_source.{ui_access_snapshot_envelope_to_json}
use common.ui.access_adapter.{ui_access_default_adapter_registry}
use common.ui.access_vision.{ui_access_vision_capture_to_json}

extern fn rt_time_now_ms() -> i64
extern fn rt_sleep_ms(ms: i64)

# =========================================================================
# Window Tracking
# =========================================================================

impl OsMcpServer:
    fn tool_ui_access_find(surface_id: text, kind: text, text_query: text, focused_only: text) -> text:
        """Find nodes within the canonical access snapshot."""
        val snapshot = self.bridge.session.access_snapshot()
        val focused = focused_only == "true" or focused_only == "1" or focused_only == "yes"
        val persisted = self.bridge.session.access_search_nodes(surface_id, kind, text_query, 200)
        val matches = match persisted:
            Ok(nodes):
                if not focused:
                    nodes
                else:
                    var focused_nodes: [UiAccessNode] = []
                    for node in nodes:
                        if node.focused:
                            focused_nodes = focused_nodes.push(node)
                    focused_nodes
            Err(_):
                ui_access_find_nodes(snapshot, surface_id, kind, text_query, focused)
        val filtered = UiAccessSnapshot(
            protocol_version: snapshot.protocol_version,
            mode: snapshot.mode,
            active_surface: snapshot.active_surface,
            surfaces: snapshot.surfaces,
            nodes: matches,
            recent_events: []
        )
        return ui_access_snapshot_to_text(filtered)

    me tool_ui_access_act(surface_id: text, canonical_id: text, action: text) -> text:
        """Dispatch a UI action against a canonical node reference."""
        if action == "":
            return "error: missing action"
        var resolved_surface_id = surface_id
        var widget_id = ""
        if canonical_id != "":
            val idx = canonical_id.find("#")
            if idx < 0:
                return "error: invalid canonical_id"
            resolved_surface_id = canonical_id.slice(0, idx)
            widget_id = canonical_id.slice(idx + 1, canonical_id.len())
        if resolved_surface_id == "":
            return "error: missing surface_id"
        if not self.bridge.session.has_surface(resolved_surface_id):
            return "error: surface {resolved_surface_id} not found"
        self.bridge.session.set_active_surface(resolved_surface_id)
        val action_name = if canonical_id != "":
            ui_access_resolve_action_name(self.bridge.session.access_snapshot(), canonical_id, action)
        elif widget_id == "":
            action
        else:
            "{action}_{widget_id}"
        self.bridge.session.dispatch(UIEvent.Action(name: action_name))
        self.bridge.render()
        return "ok: dispatched {action_name}"

    fn tool_ui_access_history(surface_id: text, count_str: text) -> text:
        """Return recent UI access events as JSON."""
        var count = 20
        if count_str != "":
            count = count_str.to_i32()
        val persisted = self.bridge.session.access_persisted_events(surface_id, count.to_i64())
        val events = match persisted:
            Ok(found):
                found
            Err(_):
                if surface_id == "":
                    self.bridge.session.access_recent_events(count)
                else:
                    self.bridge.session.access_recent_surface_events(surface_id, count)
        return ui_access_events_to_json(events)

    fn tool_ui_access_observe(surface_id: text, canonical_id: text, kind: text, text_query: text, focused_only: text) -> text:
        """Declarative read layer over canonical UI access tools."""
        val snapshot = self.bridge.session.access_snapshot()
        if canonical_id != "":
            val node = ui_access_find_node(snapshot, canonical_id)
            if node == nil:
                return "error: canonical node {canonical_id} not found"
            var surfaces: [UiAccessSurface] = []
            for surface in snapshot.surfaces:
                if surface.surface_id == node.surface_id:
                    surfaces = surfaces.push(surface)
            val filtered = UiAccessSnapshot(
                protocol_version: snapshot.protocol_version,
                mode: snapshot.mode,
                active_surface: snapshot.active_surface,
                surfaces: surfaces,
                nodes: [node],
                recent_events: []
            )
            return ui_access_snapshot_to_json(filtered)
        if kind != "" or text_query != "" or focused_only != "":
            return self.tool_ui_access_find(surface_id, kind, text_query, focused_only)
        if surface_id != "":
            return self.tool_ui_access_surface(surface_id)
        return self.tool_ui_access_snapshot()

    me tool_ui_access_state(surface_id: text, canonical_id: text, state_key: text, state_value: text) -> text:
        """Declarative state read/write layer over canonical UI access tools."""
        val snapshot = self.bridge.session.access_snapshot()
        if state_value == "":
            if canonical_id != "":
                val node = ui_access_find_node(snapshot, canonical_id)
                if node == nil:
                    return "error: canonical node {canonical_id} not found"
                if state_key == "":
                    return self.tool_ui_access_observe(surface_id, canonical_id, "", "", "")
                val node_value = _node_state_value(node, state_key)
                if node_value == nil:
                    return "error: unsupported state key {state_key}"
                return "{\"canonical_id\":\"{canonical_id}\",\"state_key\":\"{state_key}\",\"state_value\":\"{node_value}\"}"
            if surface_id != "":
                val surface = _find_surface(snapshot, surface_id)
                if surface == nil:
                    return "error: surface {surface_id} not found"
                if state_key == "":
                    return self.tool_ui_access_surface(surface_id)
                val surface_value = _surface_state_value(surface, state_key)
                if surface_value == nil:
                    return "error: unsupported state key {state_key}"
                return "{\"surface_id\":\"{surface_id}\",\"state_key\":\"{state_key}\",\"state_value\":\"{surface_value}\"}"
            return "error: missing target"

        var resolved_surface_id = surface_id
        if canonical_id != "":
            val idx = canonical_id.find("#")
            if idx < 0:
                return "error: invalid canonical_id"
            resolved_surface_id = canonical_id.slice(0, idx)
        if state_key == "active":
            if resolved_surface_id == "":
                return "error: missing surface_id"
            if not _is_truthy(state_value):
                return "error: unsupported state transition active={state_value}"
            if not self.bridge.session.has_surface(resolved_surface_id):
                return "error: surface {resolved_surface_id} not found"
            self.bridge.session.set_active_surface(resolved_surface_id)
            self.bridge.render()
            return "ok: state active=true on {resolved_surface_id}"

        if canonical_id == "":
            return "error: missing canonical_id"
        if not self.bridge.session.has_surface(resolved_surface_id):
            return "error: surface {resolved_surface_id} not found"
        val node = ui_access_find_node(snapshot, canonical_id)
        if node == nil:
            return "error: canonical node {canonical_id} not found"

        val lower_key = state_key.lower()
        var action = ""
        if lower_key == "focus" or lower_key == "focused":
            if not _is_truthy(state_value):
                return "error: unsupported state transition {state_key}={state_value}"
            action = "focus"
        elif lower_key == "invoke" or lower_key == "invoked" or lower_key == "press" or lower_key == "pressed":
            if not _is_truthy(state_value):
                return "error: unsupported state transition {state_key}={state_value}"
            action = "invoke"
        elif lower_key == "submit" or lower_key == "submitted":
            if not _is_truthy(state_value):
                return "error: unsupported state transition {state_key}={state_value}"
            action = "submit"
        elif lower_key == "select":
            if not _is_truthy(state_value):
                return "error: unsupported state transition {state_key}={state_value}"
            if node.selected:
                return "ok: state {state_key}={state_value} on {canonical_id}"
            action = "select"
        elif lower_key == "selected":
            if _state_matches_toggle_target(node, state_value):
                return "ok: state {state_key}={state_value} on {canonical_id}"
            if _is_truthy(state_value):
                action = "select"
            elif _is_falsy(state_value):
                action = "toggle"
            else:
                return "error: unsupported state transition {state_key}={state_value}"
        elif lower_key == "toggle" or lower_key == "toggled" or lower_key == "checked" or lower_key == "expanded":
            if _state_matches_toggle_target(node, state_value):
                return "ok: state {state_key}={state_value} on {canonical_id}"
            action = "toggle"
        elif lower_key == "action":
            if state_value == "":
                return "error: missing state_value"
            action = state_value
        else:
            return "error: unsupported state key {state_key}"

        self.bridge.session.set_active_surface(resolved_surface_id)
        val action_name = ui_access_resolve_action_name(snapshot, canonical_id, action)
        self.bridge.session.dispatch(UIEvent.Action(name: action_name))
        self.bridge.render()
        return "ok: state {state_key}={state_value} -> {action_name}"

    fn tool_ui_access_query(surface_id: text, canonical_id: text, kind: text, text_query: text, focused_only: text, limit_str: text) -> text:
        """Structured query layer over the canonical UI access snapshot."""
        val snapshot = self.bridge.session.access_snapshot()
        if canonical_id != "":
            val node = ui_access_find_node(snapshot, canonical_id)
            if node == nil:
                return "error: canonical node {canonical_id} not found"
        var limit = 50
        if limit_str != "":
            limit = limit_str.to_i32()
        val focused = _is_truthy(focused_only)
        return ui_access_query_to_json(snapshot, surface_id, canonical_id, kind, text_query, focused, limit)

    fn tool_ui_access_ensure(surface_id: text, canonical_id: text, kind: text, text_query: text, focused_only: text, expectation: text, expected_value: text, limit_str: text, timeout_str: text, poll_str: text) -> text:
        """Semantic ensure layer over the canonical UI access snapshot."""
        var limit = 50
        if limit_str != "":
            limit = limit_str.to_i32()
        var timeout_ms = 0
        if timeout_str != "":
            timeout_ms = timeout_str.to_i64()
        var poll_ms = 25
        if poll_str != "":
            poll_ms = poll_str.to_i64()
        val focused = _is_truthy(focused_only)
        val started = rt_time_now_ms()
        var snapshot = self.bridge.session.access_snapshot()
        var result = ui_access_ensure_result(snapshot, surface_id, canonical_id, kind, text_query, focused, limit, expectation, expected_value)
        while timeout_ms > 0 and not result.satisfied and (rt_time_now_ms() - started) < timeout_ms:
            if poll_ms > 0:
                rt_sleep_ms(poll_ms)
            snapshot = self.bridge.session.access_snapshot()
            result = ui_access_ensure_result(snapshot, surface_id, canonical_id, kind, text_query, focused, limit, expectation, expected_value)
        val elapsed_ms = rt_time_now_ms() - started
        return ui_access_ensure_to_json(snapshot, surface_id, canonical_id, kind, text_query, focused, limit, expectation, expected_value, elapsed_ms)

    me tool_ui_access_value(surface_id: text, canonical_id: text, value: text) -> text:
        """Typed value read/write for canonical value-bearing nodes."""
        if canonical_id == "":
            return "error: missing canonical_id"
        val snapshot = self.bridge.session.access_snapshot()
        val node = ui_access_find_node(snapshot, canonical_id)
        if node == nil:
            return "error: canonical node {canonical_id} not found"
        if not ui_access_supports_value(node):
            return "error: unsupported value target {canonical_id}"
        if value == "":
            return ui_access_value_to_json(snapshot, canonical_id)
        var resolved_surface_id = surface_id
        if resolved_surface_id == "":
            val idx = canonical_id.find("#")
            if idx >= 0:
                resolved_surface_id = canonical_id.slice(0, idx)
        if resolved_surface_id == "":
            return "error: missing surface_id"
        if not self.bridge.session.has_surface(resolved_surface_id):
            return "error: surface {resolved_surface_id} not found"
        val ok = self.bridge.session.set_surface_widget_value(resolved_surface_id, node.widget_id, value)
        if not ok:
            return "error: failed to set value on {canonical_id}"
        self.bridge.session.set_active_surface(resolved_surface_id)
        self.bridge.render()
        val updated_snapshot = self.bridge.session.access_snapshot()
        val payload = ui_access_value_to_json(updated_snapshot, canonical_id)
        return "{\"ok\":true," + payload.slice(1, payload.len())

    fn tool_ui_access_adapter_snapshot(surface_id: text) -> text:
        """Read an additive adapter-backed snapshot envelope."""
        val registry = ui_access_default_adapter_registry()
        val result = ui_access_resolve_adapter(self.bridge.session, registry, surface_id)
        match result:
            Ok(envelope):
                return ui_access_snapshot_envelope_to_json(envelope)
            Err(e):
                return "error: {e}"

    fn tool_ui_access_visual_probe(surface_id: text) -> text:
        """Read a vision-sidecar probe derived from the canonical snapshot."""
        val capture = ui_access_resolve_visual_probe(self.bridge.session, surface_id)
        return ui_access_vision_capture_to_json(capture)
    # =================================================================
    # Screen Tools
    # =================================================================

    fn tool_screenshot() -> text:
        """Return text description of current screen state.
        Lists windows, their positions, and widget tree summaries."""
        if self.windows.len() == 0:
            return "Screen: empty (no windows)"
        val snapshot = self.bridge.session.access_snapshot()
        return ui_access_snapshot_to_text(snapshot)

    fn tool_screen_read_text() -> text:
        """Extract all visible text from screen (accessibility).
        Returns plain text content from all windows."""
        var out = ""
        for w in self.windows:
            val surface_id = w.surface_id
            val tree_opt = self.bridge.session.get_surface(surface_id)
            if tree_opt != nil:
                val tree = tree_opt
                val root = tree.root_node()
                out = "{out}{_extract_text_content(root)}"
        if out == "":
            return "(no visible text)"
        return out

    # =================================================================
    # System Tools
    # =================================================================

    fn tool_system_info() -> text:
        """Memory usage, CPU usage, uptime, hostname."""
        var out = "System Information\n"
        out = "{out}==================\n"
        out = "{out}Hostname:  {self.hostname}\n"
        out = "{out}Uptime:    {self.uptime_sec}s\n"
        out = "{out}Processes: {self.processes.len()}\n"
        out = "{out}Windows:   {self.windows.len()}\n"
        out = "{out}Surfaces:  {self.bridge.session.surface_count()}\n"
        return out

    fn tool_system_exec(command: text) -> text:
        """Execute shell command, return output.
        In OS context, this dispatches to the shell service."""
        return "exec: pending kernel exec syscall (see plan commit A future)"

    me update_uptime(seconds: u64):
        """Update tracked uptime (called by OS tick)."""
        self.uptime_sec = seconds

    me register_process(pid: u64, name: text):
        """Register a process in the tracking list."""
        val proc = ProcessInfo(
            pid: pid,
            name: name,
            state: "Running",
            cpu_pct: "0.0"
        )
        self.processes = self.processes + [proc]

