"""LauncherToolApps — launcher resolution and canonical identity for tool apps.

Models launcher-visible app naming, canonical /sys/apps/<name> exec identity,
and short-name normalization for the six desktop tool apps.
MDSOC: feature dimension, fs_apps layer.
"""

pub class LauncherAppEntry:
    canonical_id: text
    canonical_exec: text
    short_name: text
    launch_state: text
    identity_match: bool

    static fn create(name: text, alias: text) -> LauncherAppEntry:
        LauncherAppEntry(
            canonical_id: name,
            canonical_exec: "/sys/apps/" + name,
            short_name: alias,
            launch_state: "idle",
            identity_match: true
        )

    me launch() -> LauncherAppEntry:
        self.launch_state = "running"
        self

    me is_running() -> bool:
        self.launch_state == "running"

    me is_idle() -> bool:
        self.launch_state == "idle"

    me canonical_exec_path() -> text:
        self.canonical_exec

    me alias_matches_canonical() -> bool:
        self.identity_match and self.canonical_id != ""

    me resolve_from_alias(alias: text) -> text:
        if alias == self.short_name:
            return self.canonical_exec
        if alias == self.canonical_id:
            return self.canonical_exec
        ""

pub class ToolAppRegistry:
    count: i64
    n0: text
    e0: text
    n1: text
    e1: text
    n2: text
    e2: text
    n3: text
    e3: text
    n4: text
    e4: text
    n5: text
    e5: text

    static fn create() -> ToolAppRegistry:
        ToolAppRegistry(
            count: 0,
            n0: "", e0: "",
            n1: "", e1: "",
            n2: "", e2: "",
            n3: "", e3: "",
            n4: "", e4: "",
            n5: "", e5: ""
        )

    me register(entry: LauncherAppEntry) -> i64:
        if self.count == 0:
            self.n0 = entry.canonical_id
            self.e0 = entry.canonical_exec
        if self.count == 1:
            self.n1 = entry.canonical_id
            self.e1 = entry.canonical_exec
        if self.count == 2:
            self.n2 = entry.canonical_id
            self.e2 = entry.canonical_exec
        if self.count == 3:
            self.n3 = entry.canonical_id
            self.e3 = entry.canonical_exec
        if self.count == 4:
            self.n4 = entry.canonical_id
            self.e4 = entry.canonical_exec
        if self.count == 5:
            self.n5 = entry.canonical_id
            self.e5 = entry.canonical_exec
        self.count = self.count + 1
        self.count

    me find_exec(name: text) -> text:
        if self.n0 == name: return self.e0
        if self.n1 == name: return self.e1
        if self.n2 == name: return self.e2
        if self.n3 == name: return self.e3
        if self.n4 == name: return self.e4
        if self.n5 == name: return self.e5
        ""

    me is_registered(name: text) -> bool:
        if self.n0 == name: return true
        if self.n1 == name: return true
        if self.n2 == name: return true
        if self.n3 == name: return true
        if self.n4 == name: return true
        if self.n5 == name: return true
        false

pub fn seed_tool_app_registry(reg: ToolAppRegistry) -> i64:
    reg.register(LauncherAppEntry.create("simple_browser", "sbrowser"))
    reg.register(LauncherAppEntry.create("simple_compiler", "scompiler"))
    reg.register(LauncherAppEntry.create("simple_interpreter", "sinterp"))
    reg.register(LauncherAppEntry.create("simple_loader", "sloader"))
    reg.register(LauncherAppEntry.create("llvm", "llvm"))
    reg.register(LauncherAppEntry.create("rust", "rust"))
