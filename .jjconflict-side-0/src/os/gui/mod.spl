# GUI Module — Cross-platform rendering, input, and shortcut handling
#
# Modules:
#   - render.spl         — Core primitives: shadow buffer, pixel ops, color math, rects
#   - render_shapes.spl  — Gradients, box blur, rounded rects, circle, ring, line
#   - render_effects.spl — Shadow, noise blend, border
#   - input_event.spl    — Unified input event types (Key, KeyEvent, MouseEvent, WmAction)
#   - shortcut.spl       — Shared shortcut handler (keyboard → WmAction mapping)

use os.gui.render.{render_init, render_present, blend_fill, solid_fill, alpha_blend, lerp_color}
use os.gui.render_shapes.{gradient_v, gradient_h, box_blur, rounded_rect_aa, filled_circle, ring, line}
use os.gui.render_effects.{shadow}
use os.gui.input_event.{WmAction}
use os.gui.shortcut.{ShortcutHandler, uart_char_to_action}
