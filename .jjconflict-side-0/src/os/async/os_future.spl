# OS Future — Trait and helpers for OS-level async operations
#
# Defines the core OsFuture trait that all async operations implement.
# Uses notification-based wakeup (OsWaker) instead of host OS primitives.
#
# Also provides concrete helper types:
#   - ReadyFuture<T>: immediately returns Ready(value)
#   - PendingFuture: always returns Pending (for testing)

use os.async.os_poll.{OsPoll}
use os.async.os_waker.{OsWaker}

trait OsFuture<T>:
    """A future that can be polled with an OS notification waker.

    Implementations should:
    1. Check if the operation is complete. If so, return OsPoll.Ready(value).
    2. If not complete, register the waker so it will be signaled when
       the operation completes, then return OsPoll.Pending.
    """
    fn poll(waker: OsWaker) -> OsPoll<T>

# ============================================================================
# ReadyFuture — Immediately complete
# ============================================================================

struct ReadyFuture<T>:
    """A future that is immediately ready with a value.

    Useful for wrapping synchronous results in the async interface,
    or for testing executor logic.
    """
    value: T
    consumed: bool

impl ReadyFuture<T>:
    static fn new(value: T) -> ReadyFuture<T>:
        """Create a future that immediately resolves to the given value."""
        ReadyFuture(value: value, consumed: false)

impl OsFuture<T> for ReadyFuture<T>:
    fn poll(waker: OsWaker) -> OsPoll<T>:
        """Always returns Ready on first poll."""
        if not self.consumed:
            return OsPoll.Ready(self.value)
        OsPoll.Pending

# ============================================================================
# PendingFuture — Never completes
# ============================================================================

struct PendingFuture:
    """A future that never completes. Always returns Pending.

    Useful for testing executor blocking/wakeup behavior.
    The waker is ignored since this future never becomes ready.
    """
    pass_do_nothing

impl OsFuture<i64> for PendingFuture:
    fn poll(waker: OsWaker) -> OsPoll<i64>:
        """Always returns Pending."""
        OsPoll.Pending
