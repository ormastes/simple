class GamePortProfile:
    profile_version: text
    app_id: i64
    app_name: text
    source_name: text
    upstream_url: text
    source_license: text
    rebuild_target: text
    runtime_profile: text
    package_path: text
    source_language: text
    graphics_api: text
    input_api: text
    audio_api: text
    network_api: text
    storage_api: text
    steam_facade_abi: text
    required_capabilities: [text]
    optional_capabilities: [text]

class GamePortReadiness:
    ready: bool
    required_count: i64
    matched_count: i64
    blocker: text

fn _port_contains(items: [text], expected: text) -> bool:
    for item in items:
        if item == expected:
            return true
    false

fn _port_count_matches(required: [text], available: [text]) -> i64:
    var count: i64 = 0
    for item in required:
        if _port_contains(available, item):
            count = count + 1
    count

fn _port_first_missing(required: [text], available: [text]) -> text:
    for item in required:
        if not _port_contains(available, item):
            return item
    ""

pub fn game_port_core_capabilities() -> [text]:
    [
        "simple_native_rebuild",
        "simpleos_smf_packaging",
        "simpleos_guest_spawn",
        "posix_filesystem_subset",
        "input_events_subset",
        "window_or_framebuffer_surface",
        "deterministic_save_data",
        "steam_facade_sffi"
    ]

pub fn game_port_optional_capabilities() -> [text]:
    [
        "sdl2_source_adapter",
        "vulkan_loader",
        "opengl_compat",
        "audio_mixer",
        "bsd_sockets",
        "steam_overlay",
        "steam_achievements",
        "steam_cloud",
        "steam_networking",
        "steam_drm_ticket"
    ]

pub fn game_port_profile(
    app_id: i64,
    app_name: text,
    source_name: text,
    upstream_url: text,
    source_license: text,
    package_path: text
) -> GamePortProfile:
    GamePortProfile(
        profile_version: "steamos-rebuild-v1",
        app_id: app_id,
        app_name: app_name,
        source_name: source_name,
        upstream_url: upstream_url,
        source_license: source_license,
        rebuild_target: "simpleos-native",
        runtime_profile: "SteamLinuxRuntime/soldier-source-rebuild",
        package_path: package_path,
        source_language: "source-rebuild",
        graphics_api: "sdl2_subset",
        input_api: "simple_input_events",
        audio_api: "simple_audio_optional",
        network_api: "simple_bsd_sockets_optional",
        storage_api: "simple_posix_save_data",
        steam_facade_abi: "simple-steam-sffi-v1",
        required_capabilities: game_port_core_capabilities(),
        optional_capabilities: game_port_optional_capabilities()
    )

pub fn game_port_probe(profile: GamePortProfile, available_capabilities: [text]) -> GamePortReadiness:
    val matched = _port_count_matches(profile.required_capabilities, available_capabilities)
    val ready = matched == profile.required_capabilities.len()
    var blocker = ""
    if not ready:
        blocker = "missing game port capability: " + _port_first_missing(profile.required_capabilities, available_capabilities)
    GamePortReadiness(
        ready: ready,
        required_count: profile.required_capabilities.len(),
        matched_count: matched,
        blocker: blocker
    )

pub fn game_port_manifest(profile: GamePortProfile) -> text:
    "port_profile=" + profile.profile_version +
        "\napp_id=" + profile.app_id.to_text() +
        "\napp_name=" + profile.app_name +
        "\nsource=" + profile.source_name +
        "\nupstream=" + profile.upstream_url +
        "\nlicense=" + profile.source_license +
        "\nrebuild_target=" + profile.rebuild_target +
        "\nruntime_profile=" + profile.runtime_profile +
        "\npackage_path=" + profile.package_path +
        "\ngraphics_api=" + profile.graphics_api +
        "\ninput_api=" + profile.input_api +
        "\naudio_api=" + profile.audio_api +
        "\nnetwork_api=" + profile.network_api +
        "\nstorage_api=" + profile.storage_api +
        "\nsteam_facade=" + profile.steam_facade_abi +
        "\nrequired_capabilities=" + profile.required_capabilities.join(",") +
        "\noptional_capabilities=" + profile.optional_capabilities.join(",")

pub fn game_port_marker(profile: GamePortProfile, readiness: GamePortReadiness) -> text:
    "[game-port] profile=" + profile.profile_version +
        " source=" + profile.source_name +
        " license=" + profile.source_license +
        " rebuild_target=" + profile.rebuild_target +
        " package=" + profile.package_path +
        " graphics=" + profile.graphics_api +
        " input=" + profile.input_api +
        " storage=" + profile.storage_api +
        " steam_facade=" + profile.steam_facade_abi +
        " ready=" + readiness.ready.to_text() +
        " caps=" + readiness.matched_count.to_text() + "/" + readiness.required_count.to_text()
