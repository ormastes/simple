use os.game.common.port_contract.{
    GamePortProfile,
    game_port_core_capabilities,
    game_port_manifest,
    game_port_marker,
    game_port_probe,
    game_port_profile
}
use os.game.steam.support_api.{
    SteamApiFacade,
    steam_api_begin_session,
    steam_api_cloud_write,
    steam_api_crash_log,
    steam_api_facade,
    steam_api_friend_identity,
    steam_api_init,
    steam_api_join_lobby,
    steam_api_launch_options,
    steam_api_network_message,
    steam_api_request_drm_ticket,
    steam_api_runtime_env,
    steam_api_unlock_achievement,
    steam_api_write_stat,
    steam_support_api_surface
}

class Steam2048DemoRun:
    source_game: text
    upstream_url: text
    license: text
    port_profile: GamePortProfile
    port_manifest: text
    port_marker: text
    before_row: text
    after_row: text
    score_delta: i64
    steam: SteamApiFacade
    marker: text

pub fn steam_2048_merge_left(row: [i64]) -> [i64]:
    var compact: [i64] = []
    for tile in row:
        if tile != 0:
            compact.push(tile)

    var merged: [i64] = []
    var i = 0
    while i < compact.len():
        if i + 1 < compact.len() and compact[i] == compact[i + 1]:
            merged.push(compact[i] * 2)
            i = i + 2
        else:
            merged.push(compact[i])
            i = i + 1

    while merged.len() < row.len():
        merged.push(0)
    merged

pub fn steam_2048_row_score(before: [i64], after: [i64]) -> i64:
    var before_sum: i64 = 0
    for tile in before:
        before_sum = before_sum + tile
    var after_sum: i64 = 0
    for tile in after:
        after_sum = after_sum + tile
    after_sum - before_sum + 4

pub fn steam_2048_row_text(row: [i64]) -> text:
    var parts: [text] = []
    for tile in row:
        parts.push(tile.to_text())
    parts.join(",")

pub fn steam_2048_demo_run() -> Steam2048DemoRun:
    val before = [2, 2, 0, 0]
    val after = steam_2048_merge_left(before)
    val surface = steam_support_api_surface(2048, "SimpleOS Steam 2048 Smoke", "/games/app_2048/compatdata")
    var steam = steam_api_init(steam_api_facade(surface))
    steam = steam_api_begin_session(steam)
    steam = steam_api_runtime_env(steam, "SteamLinuxRuntime/soldier")
    steam = steam_api_launch_options(steam, "-simpleos-smoke")
    steam = steam_api_friend_identity(steam, "friend-1", "Simple Player")
    steam = steam_api_network_message(steam, "loopback-peer", "reliable", "ready")
    steam = steam_api_unlock_achievement(steam, "FIRST_MERGE")
    steam = steam_api_write_stat(steam, "score", 4)
    steam = steam_api_cloud_write(steam, "save.sdn", 64)
    steam = steam_api_join_lobby(steam, "local-lobby", 1)
    steam = steam_api_request_drm_ticket(steam, "simple-drm-ticket")
    steam = steam_api_crash_log(steam, "/games/app_2048/logs/crash.log")

    val port_profile = steam_2048_port_profile()
    val port_readiness = game_port_probe(port_profile, game_port_core_capabilities())
    val before_text = steam_2048_row_text(before)
    val after_text = steam_2048_row_text(after)
    val marker = steam_2048_expected_marker()
    Steam2048DemoRun(
        source_game: "2048",
        upstream_url: "https://github.com/gabrielecirulli/2048",
        license: "MIT",
        port_profile: port_profile,
        port_manifest: game_port_manifest(port_profile),
        port_marker: game_port_marker(port_profile, port_readiness),
        before_row: before_text,
        after_row: after_text,
        score_delta: 4,
        steam: steam,
        marker: marker
    )

pub fn steam_2048_simpleos_guest_marker_ready(serial: text) -> bool:
    serial.contains("[steam-2048-demo]") and
        serial.contains("source=2048") and
        serial.contains("runtime=SteamLinuxRuntime/soldier") and
        serial.contains("network=true") and
        serial.contains("achievement=true") and
        serial.contains("drm=true")

pub fn steam_2048_demo_marker() -> text:
    steam_2048_demo_run().marker

pub fn steam_2048_port_profile() -> GamePortProfile:
    game_port_profile(
        2048,
        "SimpleOS Steam 2048 Smoke",
        "2048",
        "https://github.com/gabrielecirulli/2048",
        "MIT",
        "/sys/apps/steam_2048"
    )

pub fn steam_2048_port_manifest() -> text:
    steam_2048_demo_run().port_manifest

pub fn steam_2048_port_marker() -> text:
    steam_2048_demo_run().port_marker

pub fn steam_2048_port_guest_marker_ready(serial: text) -> bool:
    serial.contains("[game-port]") and
        serial.contains("profile=steamos-rebuild-v1") and
        serial.contains("source=2048") and
        serial.contains("rebuild_target=simpleos-native") and
        serial.contains("steam_facade=simple-steam-sffi-v1") and
        serial.contains("ready=true")

pub fn steam_2048_expected_marker() -> text:
    "[steam-2048-demo] source=2048 license=MIT board=2,2,0,0->4,0,0,0 score=4 session=true runtime=SteamLinuxRuntime/soldier overlay=true input=true friend=true network=true achievement=true drm=true"
