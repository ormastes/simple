# Truthful support contracts for SimpleOS driver claims.

struct DriverPlatformSummary:
    gpu: text
    gpu_compute: bool
    audio: text
    audio_codec: text
    audio_dma: bool
    audio_period: bool
    keyboard: text
    keyboard_events: bool
    mouse: text
    mouse_events: bool
    exokernel: text
    iommu: text
    app_raw_device: bool

fn driver_platform_summary(gpu: text, gpu_compute: bool, audio: text, audio_codec: text, audio_dma: bool, audio_period: bool, keyboard: text, keyboard_events: bool, mouse: text, mouse_events: bool, exokernel: text, iommu: text, app_raw_device: bool) -> DriverPlatformSummary:
    DriverPlatformSummary(gpu: gpu, gpu_compute: gpu_compute, audio: audio, audio_codec: audio_codec, audio_dma: audio_dma, audio_period: audio_period, keyboard: keyboard, keyboard_events: keyboard_events, mouse: mouse, mouse_events: mouse_events, exokernel: exokernel, iommu: iommu, app_raw_device: app_raw_device)

fn driver_platform_baseline() -> DriverPlatformSummary:
    driver_platform_summary("virtio-gpu", false, "intel-hda", "realtek-hda", true, true, "ps2", true, "ps2", true, "bar,irq,dma,iommu:brokered", "brokered", false)

fn driver_platform_false_claim(s: DriverPlatformSummary) -> bool:
    ((s.gpu == "framebuffer" or s.gpu == "bga" or s.gpu == "virtio-gpu") and s.gpu_compute) or (s.audio_dma and not s.audio_period) or not s.keyboard_events or not s.mouse_events or (s.iommu == "none" and s.app_raw_device)

fn driver_platform_accepts(s: DriverPlatformSummary) -> bool:
    not driver_platform_false_claim(s) and s.audio == "intel-hda" and s.audio_codec == "realtek-hda" and s.keyboard == "ps2" and s.mouse == "ps2" and s.exokernel.contains("bar") and s.exokernel.contains("irq") and s.exokernel.contains("dma")

fn _driver_platform_bool(value: bool) -> text:
    if value:
        "true"
    else:
        "false"

fn driver_platform_marker(s: DriverPlatformSummary) -> text:
    "[driver-platform] gpu=" + s.gpu +
        " gpu_compute=" + _driver_platform_bool(s.gpu_compute) +
        " audio=" + s.audio +
        " audio_codec=" + s.audio_codec +
        " audio_dma=" + _driver_platform_bool(s.audio_dma) +
        " audio_period=" + _driver_platform_bool(s.audio_period) +
        " keyboard=" + s.keyboard +
        " keyboard_events=" + _driver_platform_bool(s.keyboard_events) +
        " mouse=" + s.mouse +
        " mouse_events=" + _driver_platform_bool(s.mouse_events) +
        " exokernel=" + s.exokernel +
        " iommu=" + s.iommu +
        " app_raw_device=" + _driver_platform_bool(s.app_raw_device)

struct CpuAccelFeatures:
    arch: text
    mmx: bool
    sse2: bool
    sse4: bool
    avx2: bool
    neon: bool
    sve: bool
    rvv: bool

fn cpu_accel_features(arch: text, mmx: bool, sse2: bool, sse4: bool, avx2: bool, neon: bool, sve: bool, rvv: bool) -> CpuAccelFeatures:
    CpuAccelFeatures(arch: arch, mmx: mmx, sse2: sse2, sse4: sse4, avx2: avx2, neon: neon, sve: sve, rvv: rvv)

fn cpu_pixel_kernel(f: CpuAccelFeatures) -> text:
    if f.arch == "x86_64" or f.arch == "x86":
        if f.avx2:
            return "x86-avx2"
        if f.sse4:
            return "x86-sse4"
        if f.sse2:
            return "x86-sse2"
        if f.mmx:
            return "x86-mmx-legacy"
    if f.arch == "arm64" or f.arch == "arm32":
        if f.sve:
            return "arm-sve"
        if f.neon:
            return "arm-neon"
    if f.arch == "riscv64" or f.arch == "riscv32":
        if f.rvv:
            return "riscv-rvv"
    "scalar"

fn cpu_audio_kernel(f: CpuAccelFeatures) -> text:
    if f.arch == "x86_64" or f.arch == "x86":
        if f.avx2:
            return "x86-avx2-audio"
        if f.sse2:
            return "x86-sse2-audio"
    if f.arch == "arm64" or f.arch == "arm32":
        if f.sve:
            return "arm-sve-audio"
        if f.neon:
            return "arm-neon-audio"
    if f.arch == "riscv64" or f.arch == "riscv32":
        if f.rvv:
            return "riscv-rvv-audio"
    "scalar-audio"

struct GpuVendorProbe:
    vendor: text
    runtime: bool
    device: bool
    queue: bool
    memory: bool

fn gpu_probe(vendor: text, runtime: bool, device: bool, queue: bool, memory: bool) -> GpuVendorProbe:
    GpuVendorProbe(vendor: vendor, runtime: runtime, device: device, queue: queue, memory: memory)

fn gpu_probe_reason(p: GpuVendorProbe) -> text:
    if p.runtime and p.device and p.queue and p.memory:
        return "supported"
    if not p.runtime:
        return "missing-runtime:" + p.vendor
    if not p.device:
        return "missing-device:" + p.vendor
    if not p.queue:
        return "missing-queue:" + p.vendor
    if not p.memory:
        return "missing-memory:" + p.vendor
    "unsupported:" + p.vendor

fn gpu_probe_cuda(runtime: bool, device: bool, memory: bool) -> GpuVendorProbe:
    gpu_probe("nvidia-cuda", runtime, device, device, memory)

fn gpu_probe_amd(runtime: bool, device: bool, queue: bool, memory: bool) -> GpuVendorProbe:
    gpu_probe("amd-rocm-radv", runtime, device, queue, memory)

fn gpu_probe_intel(runtime: bool, device: bool, queue: bool, memory: bool) -> GpuVendorProbe:
    gpu_probe("intel-anv-level-zero", runtime, device, queue, memory)

fn gpu_probe_qualcomm_arm(runtime: bool, device: bool, queue: bool) -> GpuVendorProbe:
    gpu_probe("qualcomm-arm-freedreno-turnip-panfrost", runtime, device, queue, queue)

fn gpu_probe_riscv(software_vulkan: bool, rvv: bool) -> GpuVendorProbe:
    gpu_probe("riscv", software_vulkan, software_vulkan, software_vulkan, rvv)

struct AudioHdaProbe:
    controller: bool
    codec: bool
    dma: bool
    period: bool
    mixer: text

fn audio_hda_probe(controller: bool, codec: bool, dma: bool, period: bool, mixer: text) -> AudioHdaProbe:
    AudioHdaProbe(controller: controller, codec: codec, dma: dma, period: period, mixer: mixer)

fn audio_hda_reason(p: AudioHdaProbe) -> text:
    if p.controller and p.codec and p.dma and p.period and p.mixer != "none":
        return "supported"
    if not p.controller:
        return "missing-controller:intel-hda"
    if not p.codec:
        return "missing-codec:realtek-hda"
    if not p.dma:
        return "missing-dma-ring:intel-hda"
    if not p.period:
        return "missing-period:intel-hda"
    if p.mixer == "none":
        return "missing-mixer:intel-hda"
    "unsupported:intel-hda"

struct AudioCodecProbe:
    brand: text
    controller: bool
    codec: bool
    dma: bool
    period: bool
    mixer: bool
    cpu_accel: text

fn audio_codec_probe(brand: text, controller: bool, codec: bool, dma: bool, period: bool, mixer: bool, cpu_accel: text) -> AudioCodecProbe:
    AudioCodecProbe(brand: brand, controller: controller, codec: codec, dma: dma, period: period, mixer: mixer, cpu_accel: cpu_accel)

fn audio_probe_realtek_hda(controller: bool, codec: bool, dma: bool, period: bool, mixer: bool, cpu_accel: text) -> AudioCodecProbe:
    audio_codec_probe("realtek-hda", controller, codec, dma, period, mixer, cpu_accel)

fn audio_probe_cirrus_logic_hda(controller: bool, codec: bool, dma: bool, period: bool, mixer: bool, cpu_accel: text) -> AudioCodecProbe:
    audio_codec_probe("cirrus-logic-hda", controller, codec, dma, period, mixer, cpu_accel)

fn audio_codec_reason(p: AudioCodecProbe) -> text:
    if p.controller and p.codec and p.dma and p.period and p.mixer and p.cpu_accel != "scalar-audio":
        return "supported:" + p.brand
    if not p.controller:
        return "missing-controller:" + p.brand
    if not p.codec:
        return "missing-codec:" + p.brand
    if not p.dma:
        return "missing-dma-ring:" + p.brand
    if not p.period:
        return "missing-period:" + p.brand
    if not p.mixer:
        return "missing-mixer:" + p.brand
    if p.cpu_accel == "scalar-audio":
        return "missing-cpu-accel:" + p.brand
    "unsupported:" + p.brand

struct InputProbe:
    bus: text
    keyboard: bool
    mouse: bool
    events: bool
    hotplug: bool
    hidraw: bool

fn input_probe(bus: text, keyboard: bool, mouse: bool, events: bool, hotplug: bool, hidraw: bool) -> InputProbe:
    InputProbe(bus: bus, keyboard: keyboard, mouse: mouse, events: events, hotplug: hotplug, hidraw: hidraw)

fn input_probe_ps2(keyboard: bool, mouse: bool, events: bool) -> InputProbe:
    input_probe("ps2", keyboard, mouse, events, false, false)

fn input_probe_usb_hid(keyboard: bool, mouse: bool, events: bool, hotplug: bool, hidraw: bool) -> InputProbe:
    input_probe("usb-hid", keyboard, mouse, events, hotplug, hidraw)

fn input_probe_reason(p: InputProbe) -> text:
    if p.keyboard and p.mouse and p.events:
        if p.bus == "usb-hid" and (not p.hotplug or not p.hidraw):
            return "partial:" + p.bus
        return "supported:" + p.bus
    if not p.keyboard:
        return "missing-keyboard:" + p.bus
    if not p.mouse:
        return "missing-mouse:" + p.bus
    if not p.events:
        return "missing-events:" + p.bus
    "unsupported:" + p.bus

struct ExokernelDeviceGrant:
    bar: bool
    irq: bool
    dma: bool
    iommu: bool
    broker: bool
    raw_app: bool

fn exokernel_device_grant(bar: bool, irq: bool, dma: bool, iommu: bool, broker: bool, raw_app: bool) -> ExokernelDeviceGrant:
    ExokernelDeviceGrant(bar: bar, irq: irq, dma: dma, iommu: iommu, broker: broker, raw_app: raw_app)

fn exokernel_grant_reason(g: ExokernelDeviceGrant) -> text:
    if g.raw_app and not g.iommu:
        return "unsafe-raw-device-without-iommu"
    if not g.bar:
        return "missing-bar"
    if not g.irq:
        return "missing-irq"
    if not g.dma:
        return "missing-dma"
    if not g.iommu and not g.broker:
        return "missing-iommu-or-broker"
    "supported"

struct DriverTeamLane:
    lane: text
    owner: text
    contract: bool
    tests: bool
    docs: bool
    reviewer: bool

fn driver_team_lane(lane: text, owner: text, contract: bool, tests: bool, docs: bool, reviewer: bool) -> DriverTeamLane:
    DriverTeamLane(lane: lane, owner: owner, contract: contract, tests: tests, docs: docs, reviewer: reviewer)

fn driver_team_lane_ready(l: DriverTeamLane) -> bool:
    l.owner != "" and l.contract and l.tests and l.docs and l.reviewer

fn driver_team_lane_blocker(l: DriverTeamLane) -> text:
    if l.owner == "":
        return "missing-owner:" + l.lane
    if not l.contract:
        return "missing-contract:" + l.lane
    if not l.tests:
        return "missing-tests:" + l.lane
    if not l.docs:
        return "missing-docs:" + l.lane
    if not l.reviewer:
        return "missing-reviewer:" + l.lane
    "ready:" + l.lane

struct DriverTeamPlan:
    gpu: DriverTeamLane
    audio: DriverTeamLane
    input: DriverTeamLane
    exokernel: DriverTeamLane
    mdsoc: DriverTeamLane

fn driver_team_plan(gpu: DriverTeamLane, audio: DriverTeamLane, input: DriverTeamLane, exokernel: DriverTeamLane, mdsoc: DriverTeamLane) -> DriverTeamPlan:
    DriverTeamPlan(gpu: gpu, audio: audio, input: input, exokernel: exokernel, mdsoc: mdsoc)

fn driver_team_plan_ready(p: DriverTeamPlan) -> bool:
    driver_team_lane_ready(p.gpu) and driver_team_lane_ready(p.audio) and driver_team_lane_ready(p.input) and driver_team_lane_ready(p.exokernel) and driver_team_lane_ready(p.mdsoc)

fn driver_team_plan_blocker(p: DriverTeamPlan) -> text:
    if not driver_team_lane_ready(p.gpu):
        return driver_team_lane_blocker(p.gpu)
    if not driver_team_lane_ready(p.audio):
        return driver_team_lane_blocker(p.audio)
    if not driver_team_lane_ready(p.input):
        return driver_team_lane_blocker(p.input)
    if not driver_team_lane_ready(p.exokernel):
        return driver_team_lane_blocker(p.exokernel)
    if not driver_team_lane_ready(p.mdsoc):
        return driver_team_lane_blocker(p.mdsoc)
    "ready"
