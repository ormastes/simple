# VirtIO-Net Async Futures — Notification-based non-blocking frame I/O
#
# MDSOC: feature dimension, drivers layer
#
# Provides OsFuture implementations for VirtIO-net send and receive.
# Each future polls the VirtIO used ring for completion:
#   - VirtioNetRecvFuture: checks RX used ring, copies frame out when ready
#   - VirtioNetSendFuture: submits frame to TX queue, checks TX used ring
#
# The executor is woken by the device IRQ via the notification object
# (notif_id), so no busy-polling is needed between polls.

use os.async.os_poll.{OsPoll}
use os.async.os_waker.{OsWaker}
use os.async.os_future.{OsFuture}
use os.kernel.boot.mmio.{mmio_read8, mmio_read16, mmio_read32, mmio_write8, mmio_write16, mmio_write32}

# VirtIO net header size (legacy: 10 bytes)
val VIRTIO_NET_HDR_SIZE: u64 = 10
val BUFFER_SIZE: u64 = 2048
val VIRTIO_NET_RX_QUEUE: u16 = 0
val VIRTIO_NET_TX_QUEUE: u16 = 1
val VIRTIO_PCI_QUEUE_NOTIFY: u64 = 0x10

# ============================================================================
# VirtioNetRecvFuture — Async frame receive
# ============================================================================

struct VirtioNetRecvFuture:
    """Future that completes when an Ethernet frame is received.

    On each poll:
      1. Check if the RX used ring has advanced past rx_last_used.
      2. If yes: read the used entry, copy frame data (excluding the
         10-byte virtio-net header), repost the descriptor, return Ready.
      3. If no: return Pending. The device IRQ will signal notif_id,
         causing the executor to re-poll.
    """
    # VirtIO-net driver state needed for polling
    rx_used_virt: u64
    rx_last_used: u16
    rx_queue_size: u16
    rx_bufs_virt: u64
    rx_avail_virt: u64
    bar0_virt: u64
    notif_id: u64
    max_len: u64
    completed: bool
    frame_data: [u8]

impl OsFuture<Result<[u8], text>> for VirtioNetRecvFuture:
    fn poll(waker: OsWaker) -> OsPoll<Result<[u8], text>>:
        if self.completed:
            return OsPoll.Ready(value: Ok(self.frame_data))

        # Check used ring for completed RX descriptors
        val used_idx = mmio_read16(self.rx_used_virt + 2)
        if used_idx == self.rx_last_used:
            # No frame yet -- return Pending
            # The device IRQ will signal notif_id, waking the executor
            return OsPoll.Pending

        # Frame available -- read it from the used ring entry
        val ring_idx = self.rx_last_used % self.rx_queue_size
        val used_entry = self.rx_used_virt + 4 + ring_idx.to_u64() * 8
        val desc_id = mmio_read32(used_entry)
        val total_len = mmio_read32(used_entry + 4)

        var this = self
        this.rx_last_used = this.rx_last_used + 1

        val frame_len = total_len.to_u64() - VIRTIO_NET_HDR_SIZE
        if frame_len == 0 or frame_len > this.max_len:
            # Bad frame -- repost descriptor and report error
            repost_rx_desc(
                this.rx_avail_virt, this.rx_queue_size,
                this.bar0_virt, desc_id.to_u16()
            )
            return OsPoll.Ready(value: Err("Frame too large or empty"))

        # Copy frame data from RX buffer (skip virtio-net header)
        var frame: [u8] = []
        val rx_buf = this.rx_bufs_virt + desc_id.to_u64() * BUFFER_SIZE + VIRTIO_NET_HDR_SIZE
        var i: u64 = 0
        while i < frame_len:
            frame.push(mmio_read8(rx_buf + i))
            i = i + 1

        this.completed = true
        this.frame_data = frame

        # Repost the consumed RX descriptor
        repost_rx_desc(
            this.rx_avail_virt, this.rx_queue_size,
            this.bar0_virt, desc_id.to_u16()
        )

        OsPoll.Ready(value: Ok(frame))

# ============================================================================
# VirtioNetSendFuture — Async frame send
# ============================================================================

struct VirtioNetSendFuture:
    """Future that completes when a transmitted frame is consumed by the device.

    On creation the frame has already been submitted to the TX virtqueue.
    Each poll checks whether the device has consumed the descriptor by
    comparing tx_last_used against the TX used ring index.
    """
    tx_used_virt: u64
    tx_last_used: u16
    tx_queue_size: u16
    bar0_virt: u64
    notif_id: u64
    submitted: bool
    completed: bool
    # TX submission state (used on first poll if not yet submitted)
    tx_desc_virt: u64
    tx_avail_virt: u64
    tx_bufs_virt: u64
    tx_bufs_phys: u64
    data_virt: u64
    data_len: u64
    slot: u64

impl OsFuture<Result<bool, text>> for VirtioNetSendFuture:
    fn poll(waker: OsWaker) -> OsPoll<Result<bool, text>>:
        if self.completed:
            return OsPoll.Ready(value: Ok(true))

        var this = self

        # First poll: submit the frame to the TX virtqueue
        if not this.submitted:
            val buf_virt = this.tx_bufs_virt + this.slot * BUFFER_SIZE
            val buf_phys = this.tx_bufs_phys + this.slot * BUFFER_SIZE

            # Write virtio-net header (10 bytes, all zeros = no offload)
            mmio_write32(buf_virt, 0)
            mmio_write32(buf_virt + 4, 0)
            mmio_write16(buf_virt + 8, 0)

            # Copy frame data after the header
            var i: u64 = 0
            while i < this.data_len:
                val byte = mmio_read8(this.data_virt + i)
                mmio_write8(buf_virt + VIRTIO_NET_HDR_SIZE + i, byte)
                i = i + 1

            # Set up TX descriptor
            val desc_off = this.tx_desc_virt + this.slot * 16
            val total_len = VIRTIO_NET_HDR_SIZE + this.data_len
            val phys_low = (buf_phys & 0xFFFFFFFF).to_u32()
            val phys_high = (buf_phys >> 32).to_u32()
            mmio_write32(desc_off, phys_low)
            mmio_write32(desc_off + 4, phys_high)
            mmio_write32(desc_off + 8, total_len.to_u32())
            mmio_write32(desc_off + 12, 0)  # flags=0 (driver-readable), next=0

            # Add to TX available ring
            val avail_idx = mmio_read16(this.tx_avail_virt + 2)
            val ring_slot = this.tx_avail_virt + 4 + (avail_idx % this.tx_queue_size).to_u64() * 2
            mmio_write16(ring_slot, this.slot.to_u16())
            mmio_write16(this.tx_avail_virt + 2, avail_idx + 1)

            # Notify device (TX queue = 1)
            mmio_write16(this.bar0_virt + VIRTIO_PCI_QUEUE_NOTIFY, VIRTIO_NET_TX_QUEUE)

            this.submitted = true

        # Check if device has consumed the TX descriptor
        val used_idx = mmio_read16(this.tx_used_virt + 2)
        if used_idx == this.tx_last_used:
            # Not yet consumed -- return Pending
            return OsPoll.Pending

        # TX completed
        this.tx_last_used = used_idx
        this.completed = true
        OsPoll.Ready(value: Ok(true))

# ============================================================================
# Shared helper — repost an RX descriptor
# ============================================================================

fn repost_rx_desc(rx_avail_virt: u64, rx_queue_size: u16, bar0_virt: u64, desc_idx: u16):
    """Repost a consumed RX descriptor back to the available ring."""
    val avail_idx = mmio_read16(rx_avail_virt + 2)
    val ring_slot = rx_avail_virt + 4 + (avail_idx % rx_queue_size).to_u64() * 2
    mmio_write16(ring_slot, desc_idx)
    mmio_write16(rx_avail_virt + 2, avail_idx + 1)
    mmio_write16(bar0_virt + VIRTIO_PCI_QUEUE_NOTIFY, VIRTIO_NET_RX_QUEUE)
