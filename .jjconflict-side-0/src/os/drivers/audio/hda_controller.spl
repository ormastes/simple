# Intel HD Audio Controller Driver — SimpleOS
# MDSOC: feature dimension, drivers layer
#
# Provides HDA ring buffer management, period timer, mixer, and the
# top-level HdaController skeleton.  No SFFI — pure bookkeeping so the
# driver can be unit-tested in interpreter mode.

# ============================================================================
# HdaRingBuffer — DMA ring buffer descriptor
# ============================================================================

class HdaRingBuffer:
    """DMA ring buffer used for CORB/RIRB descriptor rings."""
    base_addr: i64
    length: i64
    entry_count: i64
    write_pos: i64
    read_pos: i64
    irq_on_completion: bool

impl HdaRingBuffer:
    static fn create(base: i64, len: i64, entries: i64) -> HdaRingBuffer:
        """Allocate a ring buffer descriptor at the given base address."""
        HdaRingBuffer(
            base_addr: base,
            length: len,
            entry_count: entries,
            write_pos: 0,
            read_pos: 0,
            irq_on_completion: false
        )

    me advance_write() -> i64:
        """Advance write_pos by one slot (wraps around entry_count).

        Returns the new write_pos after the advance.
        """
        self.write_pos = (self.write_pos + 1) % self.entry_count
        self.write_pos

    me advance_read() -> i64:
        """Advance read_pos by one slot (wraps around entry_count).

        Returns the new read_pos after the advance.
        """
        self.read_pos = (self.read_pos + 1) % self.entry_count
        self.read_pos

    me is_empty() -> bool:
        """Return true when no pending entries remain."""
        self.read_pos == self.write_pos

    me is_full() -> bool:
        """Return true when the ring is full (write would collide with read)."""
        ((self.write_pos + 1) % self.entry_count) == self.read_pos

    me reset() -> text:
        """Reset both pointers to zero and return a status string."""
        self.write_pos = 0
        self.read_pos = 0
        "ring_reset base=0x" + self.base_addr.to_text() +
            " entries=" + self.entry_count.to_text()

# ============================================================================
# HdaPeriodTimer — audio period / interrupt timer
# ============================================================================

class HdaPeriodTimer:
    """Tracks audio period boundaries and underrun events."""
    sample_rate: i64
    channels: i64
    bits_per_sample: i64
    period_frames: i64
    periods_per_buffer: i64
    elapsed_periods: i64
    underrun_count: i64

impl HdaPeriodTimer:
    static fn create(rate: i64, ch: i64, bits: i64, period: i64, periods: i64) -> HdaPeriodTimer:
        """Create a timer for the given audio format."""
        HdaPeriodTimer(
            sample_rate: rate,
            channels: ch,
            bits_per_sample: bits,
            period_frames: period,
            periods_per_buffer: periods,
            elapsed_periods: 0,
            underrun_count: 0
        )

    me bytes_per_period() -> i64:
        """Return the byte count for one period."""
        self.period_frames * self.channels * (self.bits_per_sample / 8)

    me bytes_per_buffer() -> i64:
        """Return the total DMA buffer size in bytes."""
        self.bytes_per_period() * self.periods_per_buffer

    me tick() -> i64:
        """Increment elapsed_periods by one and return the new count."""
        self.elapsed_periods = self.elapsed_periods + 1
        self.elapsed_periods

    me report_underrun() -> i64:
        """Record one buffer underrun and return the running total."""
        self.underrun_count = self.underrun_count + 1
        self.underrun_count

    me stats() -> text:
        """Return a compact status string."""
        "timer rate=" + self.sample_rate.to_text() +
            " ch=" + self.channels.to_text() +
            " bits=" + self.bits_per_sample.to_text() +
            " period_bytes=" + self.bytes_per_period().to_text() +
            " buf_bytes=" + self.bytes_per_buffer().to_text() +
            " elapsed=" + self.elapsed_periods.to_text() +
            " underruns=" + self.underrun_count.to_text()

# ============================================================================
# HdaMixer — software volume / mute state
# ============================================================================

class HdaMixer:
    """Tracks master, PCM, and mic volume / mute state."""
    master_volume: i64
    master_mute: bool
    pcm_volume: i64
    pcm_mute: bool
    mic_volume: i64
    mic_mute: bool

impl HdaMixer:
    static fn create() -> HdaMixer:
        """Create mixer with conservative defaults (master/pcm 75, mic 50)."""
        HdaMixer(
            master_volume: 75,
            master_mute: false,
            pcm_volume: 75,
            pcm_mute: false,
            mic_volume: 50,
            mic_mute: false
        )

    me set_master(vol: i64, mute: bool) -> text:
        """Set master volume (clamped 0-100) and mute state."""
        var clamped = vol
        if vol < 0:
            clamped = 0
        if vol > 100:
            clamped = 100
        self.master_volume = clamped
        self.master_mute = mute
        ""

    me set_pcm(vol: i64, mute: bool) -> text:
        """Set PCM volume (clamped 0-100) and mute state."""
        var clamped = vol
        if vol < 0:
            clamped = 0
        if vol > 100:
            clamped = 100
        self.pcm_volume = clamped
        self.pcm_mute = mute
        ""

    me set_mic(vol: i64, mute: bool) -> text:
        """Set mic volume (clamped 0-100) and mute state."""
        var clamped = vol
        if vol < 0:
            clamped = 0
        if vol > 100:
            clamped = 100
        self.mic_volume = clamped
        self.mic_mute = mute
        ""

    me effective_volume(channel: text) -> i64:
        """Return effective volume for 'master', 'pcm', or 'mic'.

        Returns 0 when muted, otherwise the stored volume.
        """
        if channel == "master":
            if self.master_mute == false:
                self.master_volume
            else:
                0
        else:
            if channel == "pcm":
                if self.pcm_mute == false:
                    self.pcm_volume
                else:
                    0
            else:
                if self.mic_mute == false:
                    self.mic_volume
                else:
                    0

    me stats() -> text:
        """Return a compact status string for all mixer channels."""
        "mixer master=" + self.master_volume.to_text() +
            " mute=" + self.master_mute.to_text() +
            " pcm=" + self.pcm_volume.to_text() +
            " pcm_mute=" + self.pcm_mute.to_text() +
            " mic=" + self.mic_volume.to_text() +
            " mic_mute=" + self.mic_mute.to_text()

# ============================================================================
# HdaController — top-level HDA controller
# ============================================================================

class HdaController:
    """Intel HD Audio controller skeleton.

    Manages CORB/RIRB ring buffers, the period timer, and the software
    mixer.  Hardware register writes are stubbed; real MMIO will be wired
    in a later pass once the OS memory-map layer is available.
    """
    bar0_addr: i64
    irq_line: i64
    initialized: bool
    codec_count: i64
    stream_count: i64
    corb: HdaRingBuffer
    rirb: HdaRingBuffer
    timer: HdaPeriodTimer
    mixer: HdaMixer
    cpu_accel: text

impl HdaController:
    static fn create(bar0: i64, irq: i64) -> HdaController:
        """Create a controller bound to the given MMIO BAR0 and IRQ."""
        HdaController(
            bar0_addr: bar0,
            irq_line: irq,
            initialized: false,
            codec_count: 0,
            stream_count: 0,
            corb: HdaRingBuffer.create(bar0 + 0x40, 256, 256),
            rirb: HdaRingBuffer.create(bar0 + 0x50, 256, 256),
            timer: HdaPeriodTimer.create(48000, 2, 16, 1024, 4),
            mixer: HdaMixer.create(),
            cpu_accel: "none"
        )

    me initialize() -> text:
        """Reset rings, mark controller ready, and return status."""
        self.corb.reset()
        self.rirb.reset()
        self.initialized = true
        "hda_init ok bar0=0x" + self.bar0_addr.to_text() +
            " irq=" + self.irq_line.to_text()

    me send_verb(codec_addr: i64, node_id: i64, verb: i64) -> text:
        """Enqueue an HDA verb to CORB and return a log string."""
        self.corb.advance_write()
        "hda_verb codec=" + codec_addr.to_text() +
            " node=" + node_id.to_text() +
            " verb=0x" + verb.to_text() +
            " corb_wp=" + self.corb.write_pos.to_text()

    me start_stream(stream_id: i64) -> text:
        """Stub: mark stream active and return status."""
        self.stream_count = self.stream_count + 1
        "hda_stream_start id=" + stream_id.to_text() +
            " active=" + self.stream_count.to_text()

    me stop_stream(stream_id: i64) -> text:
        """Stub: decrement active stream count and return status."""
        if self.stream_count > 0:
            self.stream_count = self.stream_count - 1
        "hda_stream_stop id=" + stream_id.to_text() +
            " active=" + self.stream_count.to_text()

    me stats() -> text:
        """Return a multi-line controller status summary."""
        "hda_controller bar0=0x" + self.bar0_addr.to_text() +
            " irq=" + self.irq_line.to_text() +
            " init=" + self.initialized.to_text() +
            " codecs=" + self.codec_count.to_text() +
            " streams=" + self.stream_count.to_text() +
            " accel=" + self.cpu_accel +
            " | " + self.timer.stats() +
            " | " + self.mixer.stats()
