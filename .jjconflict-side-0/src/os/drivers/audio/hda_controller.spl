# Intel HD Audio Controller Driver — SimpleOS
# MDSOC: feature dimension, drivers layer
#
# Provides HDA ring buffer management, period timer, mixer, and the
# top-level HdaController.  Register offsets/bit meanings follow the Intel
# HD Audio Specification (rev 1.0a) section 3.3 (controller registers) and
# section 3.6 (stream descriptors). MMIO access goes through
# os.kernel.boot.mmio, which transparently runs against an in-memory
# register model when `mmio_reset_for_test()` has put it in test mode — so
# this driver's register-write *sequencing* is host-unit-testable without
# real hardware or a QEMU boot (see hda_controller_spec.spl). What test mode
# cannot exercise: asynchronous hardware behavior QEMU/silicon produce on
# their own (codec presence bits appearing in STATESTS, RIRB entries being
# DMA'd in by the codec after a verb is sent, IRQ line assertion) — those
# need the QEMU `-device intel-hda` lane (scripts/check/check-hda-qemu.shs)
# to prove end-to-end; see that script's header for current gate status.

use os.kernel.boot.mmio.{mmio_read8, mmio_write8, mmio_read16, mmio_write16, mmio_read32, mmio_write32}
use os.drivers.audio.hda_codec_probe.{HdaCodecCapability, RealtekHdaCodec, CirrusHdaCodec}

# ============================================================================
# Register offsets (relative to BAR0) — Intel HD Audio spec section 3.3
# ============================================================================

val HDA_REG_GCAP: i64      = 0x00   # u16 — global capabilities
val HDA_REG_GCTL: i64      = 0x08   # u32 — global control; bit0 = CRST (0=in reset, 1=running)
val HDA_REG_STATESTS: i64  = 0x0E   # u16 — codec presence bitmap (one bit per SDIN/codec addr)
val HDA_REG_INTCTL: i64    = 0x20   # u32 — interrupt control; bit31 GIE, bit30 CIE
val HDA_REG_INTSTS: i64    = 0x24   # u32 — interrupt status (RW1C); bit31 GIS, bit30 CIS
val HDA_REG_CORBLBASE: i64 = 0x40   # u32 — CORB DMA base, low 32 bits
val HDA_REG_CORBUBASE: i64 = 0x44   # u32 — CORB DMA base, high 32 bits
val HDA_REG_CORBWP: i64    = 0x48   # u16 — CORB write pointer
val HDA_REG_CORBRP: i64    = 0x4A   # u16 — CORB read pointer; bit15 = CORBRPRST
val HDA_REG_CORBCTL: i64   = 0x4C   # u8  — CORB control; bit1 = CORBRUN
val HDA_REG_CORBSIZE: i64  = 0x4E   # u8  — CORB size (entry-count encoding)
val HDA_REG_RIRBLBASE: i64 = 0x50   # u32 — RIRB DMA base, low 32 bits
val HDA_REG_RIRBUBASE: i64 = 0x54   # u32 — RIRB DMA base, high 32 bits
val HDA_REG_RIRBWP: i64    = 0x58   # u16 — RIRB write pointer; bit15 = RIRBWPRST
val HDA_REG_RINTCNT: i64   = 0x5A   # u16 — response interrupt count
val HDA_REG_RIRBCTL: i64   = 0x5C   # u8  — RIRB control; bit1 = RIRBDMAEN
val HDA_REG_RIRBSIZE: i64  = 0x5E   # u8  — RIRB size (entry-count encoding)
val HDA_REG_DPLBASE: i64   = 0x70   # u32 — DMA position buffer base, low (bit0 = enable)
val HDA_REG_DPUBASE: i64   = 0x74   # u32 — DMA position buffer base, high
val HDA_SD0_BASE: i64      = 0x80   # first stream descriptor base offset
val HDA_SD_STRIDE: i64     = 0x20   # bytes between consecutive stream descriptors

# Stream descriptor sub-offsets — Intel HD Audio spec section 3.3.35+
val HDA_SD_CTL: i64  = 0x00  # u32 — low 3 bytes CTL (bit1 RUN, bit2 IOCE), byte3 STS (RW1C)
val HDA_SD_LPIB: i64 = 0x04  # u32 — link position in buffer (hardware-updated)
val HDA_SD_CBL: i64  = 0x08  # u32 — cyclic buffer length in bytes
val HDA_SD_LVI: i64  = 0x0C  # u16 — last valid (buffer descriptor list) index
val HDA_SD_FMT: i64  = 0x12  # u16 — stream format (sample rate/bits/channels)
val HDA_SD_BDPL: i64 = 0x18  # u32 — buffer descriptor list pointer, low 32 bits
val HDA_SD_BDPU: i64 = 0x1C  # u32 — buffer descriptor list pointer, high 32 bits

# CORB verb helpers — 32-bit CORB entry = (CAd<<28)|(NID<<20)|(Verb<<8)|Payload
# ("short form" 12-bit verb + 8-bit payload — Intel HD Audio spec 4.4.1).
val HDA_VERB_GET_PARAMETER: i64 = 0xF00
val HDA_PARAM_VENDOR_ID: i64    = 0x00

fn hda_build_corb_entry(codec_addr: i64, node_id: i64, verb: i64, payload: i64) -> u32:
    """Pack a CORB command entry: (codec_addr:4)(node_id:8)(verb:12)(payload:8)."""
    (((codec_addr << 28) | (node_id << 20) | (verb << 8) | payload) as u32)

# ============================================================================
# HdaRingBuffer — DMA ring buffer descriptor
# ============================================================================

class HdaRingBuffer:
    """DMA ring buffer used for CORB/RIRB descriptor rings."""
    base_addr: i64
    length: i64
    entry_count: i64
    write_pos: i64
    read_pos: i64
    irq_on_completion: bool

impl HdaRingBuffer:
    static fn create(base: i64, len: i64, entries: i64) -> HdaRingBuffer:
        """Allocate a ring buffer descriptor at the given base address."""
        HdaRingBuffer(
            base_addr: base,
            length: len,
            entry_count: entries,
            write_pos: 0,
            read_pos: 0,
            irq_on_completion: false
        )

    me advance_write() -> i64:
        """Advance write_pos by one slot (wraps around entry_count).

        Returns the new write_pos after the advance.
        """
        self.write_pos = (self.write_pos + 1) % self.entry_count
        self.write_pos

    me advance_read() -> i64:
        """Advance read_pos by one slot (wraps around entry_count).

        Returns the new read_pos after the advance.
        """
        self.read_pos = (self.read_pos + 1) % self.entry_count
        self.read_pos

    me is_empty() -> bool:
        """Return true when no pending entries remain."""
        self.read_pos == self.write_pos

    me is_full() -> bool:
        """Return true when the ring is full (write would collide with read)."""
        ((self.write_pos + 1) % self.entry_count) == self.read_pos

    me reset() -> text:
        """Reset both pointers to zero and return a status string."""
        self.write_pos = 0
        self.read_pos = 0
        "ring_reset base=0x" + self.base_addr.to_text() +
            " entries=" + self.entry_count.to_text()

# ============================================================================
# HdaPeriodTimer — audio period / interrupt timer
# ============================================================================

class HdaPeriodTimer:
    """Tracks audio period boundaries and underrun events."""
    sample_rate: i64
    channels: i64
    bits_per_sample: i64
    period_frames: i64
    periods_per_buffer: i64
    elapsed_periods: i64
    underrun_count: i64

impl HdaPeriodTimer:
    static fn create(rate: i64, ch: i64, bits: i64, period: i64, periods: i64) -> HdaPeriodTimer:
        """Create a timer for the given audio format."""
        HdaPeriodTimer(
            sample_rate: rate,
            channels: ch,
            bits_per_sample: bits,
            period_frames: period,
            periods_per_buffer: periods,
            elapsed_periods: 0,
            underrun_count: 0
        )

    me bytes_per_period() -> i64:
        """Return the byte count for one period."""
        self.period_frames * self.channels * (self.bits_per_sample / 8)

    me bytes_per_buffer() -> i64:
        """Return the total DMA buffer size in bytes."""
        self.bytes_per_period() * self.periods_per_buffer

    me tick() -> i64:
        """Increment elapsed_periods by one and return the new count."""
        self.elapsed_periods = self.elapsed_periods + 1
        self.elapsed_periods

    me report_underrun() -> i64:
        """Record one buffer underrun and return the running total."""
        self.underrun_count = self.underrun_count + 1
        self.underrun_count

    me stats() -> text:
        """Return a compact status string."""
        "timer rate=" + self.sample_rate.to_text() +
            " ch=" + self.channels.to_text() +
            " bits=" + self.bits_per_sample.to_text() +
            " period_bytes=" + self.bytes_per_period().to_text() +
            " buf_bytes=" + self.bytes_per_buffer().to_text() +
            " elapsed=" + self.elapsed_periods.to_text() +
            " underruns=" + self.underrun_count.to_text()

# ============================================================================
# HdaMixer — software volume / mute state
# ============================================================================

class HdaMixer:
    """Tracks master, PCM, and mic volume / mute state."""
    master_volume: i64
    master_mute: bool
    pcm_volume: i64
    pcm_mute: bool
    mic_volume: i64
    mic_mute: bool

impl HdaMixer:
    static fn create() -> HdaMixer:
        """Create mixer with conservative defaults (master/pcm 75, mic 50)."""
        HdaMixer(
            master_volume: 75,
            master_mute: false,
            pcm_volume: 75,
            pcm_mute: false,
            mic_volume: 50,
            mic_mute: false
        )

    me set_master(vol: i64, mute: bool) -> text:
        """Set master volume (clamped 0-100) and mute state."""
        var clamped = vol
        if vol < 0:
            clamped = 0
        if vol > 100:
            clamped = 100
        self.master_volume = clamped
        self.master_mute = mute
        ""

    me set_pcm(vol: i64, mute: bool) -> text:
        """Set PCM volume (clamped 0-100) and mute state."""
        var clamped = vol
        if vol < 0:
            clamped = 0
        if vol > 100:
            clamped = 100
        self.pcm_volume = clamped
        self.pcm_mute = mute
        ""

    me set_mic(vol: i64, mute: bool) -> text:
        """Set mic volume (clamped 0-100) and mute state."""
        var clamped = vol
        if vol < 0:
            clamped = 0
        if vol > 100:
            clamped = 100
        self.mic_volume = clamped
        self.mic_mute = mute
        ""

    me effective_volume(channel: text) -> i64:
        """Return effective volume for 'master', 'pcm', or 'mic'.

        Returns 0 when muted, otherwise the stored volume.
        """
        if channel == "master":
            if self.master_mute == false:
                self.master_volume
            else:
                0
        else:
            if channel == "pcm":
                if self.pcm_mute == false:
                    self.pcm_volume
                else:
                    0
            else:
                if self.mic_mute == false:
                    self.mic_volume
                else:
                    0

    me stats() -> text:
        """Return a compact status string for all mixer channels."""
        "mixer master=" + self.master_volume.to_text() +
            " mute=" + self.master_mute.to_text() +
            " pcm=" + self.pcm_volume.to_text() +
            " pcm_mute=" + self.pcm_mute.to_text() +
            " mic=" + self.mic_volume.to_text() +
            " mic_mute=" + self.mic_mute.to_text()

# ============================================================================
# HdaController — top-level HDA controller
# ============================================================================

class HdaController:
    """Intel HD Audio controller.

    Manages CORB/RIRB ring buffers, the period timer, and the software
    mixer over real MMIO register writes (os.kernel.boot.mmio), and codec
    identification via a GET_PARAMETER(Vendor ID) verb round trip.
    """
    bar0_addr: i64
    irq_line: i64
    initialized: bool
    codec_count: i64
    stream_count: i64
    corb: HdaRingBuffer
    rirb: HdaRingBuffer
    timer: HdaPeriodTimer
    mixer: HdaMixer
    cpu_accel: text
    codec_addr: i64
    codec_vendor_id: i64
    codec_device_id: i64
    codec_name: text
    irq_count: i64
    last_status: text

impl HdaController:
    static fn create(bar0: i64, irq: i64, corb_dma: i64, rirb_dma: i64) -> HdaController:
        """Create a controller bound to the given MMIO BAR0 and IRQ.

        `corb_dma`/`rirb_dma` must be real DMA-coherent physical RAM
        addresses (from the OS's physical frame allocator) distinct from
        the BAR0 MMIO range — the CORBLBASE/RIRBLBASE *registers* live at
        fixed offsets inside BAR0 (0x40/0x50), but the ring *buffers* they
        point at are ordinary RAM the controller DMAs into/out of, which
        must not overlap the register range itself."""
        HdaController(
            bar0_addr: bar0,
            irq_line: irq,
            initialized: false,
            codec_count: 0,
            stream_count: 0,
            corb: HdaRingBuffer.create(corb_dma, 256, 256),
            rirb: HdaRingBuffer.create(rirb_dma, 256, 256),
            timer: HdaPeriodTimer.create(48000, 2, 16, 1024, 4),
            mixer: HdaMixer.create(),
            cpu_accel: "none",
            codec_addr: -1,
            codec_vendor_id: 0,
            codec_device_id: 0,
            codec_name: "none",
            irq_count: 0,
            last_status: "not_initialized"
        )

    # ------------------------------------------------------------------
    # Register access — every offset is relative to bar0_addr
    # ------------------------------------------------------------------

    me reg_addr(offset: i64) -> u64:
        (self.bar0_addr + offset) as u64

    me read32(offset: i64) -> u32:
        mmio_read32(self.reg_addr(offset))

    me write32(offset: i64, value: u32):
        mmio_write32(self.reg_addr(offset), value)

    me read16(offset: i64) -> u16:
        mmio_read16(self.reg_addr(offset))

    me write16(offset: i64, value: u16):
        mmio_write16(self.reg_addr(offset), value)

    me read8(offset: i64) -> u8:
        mmio_read8(self.reg_addr(offset))

    me write8(offset: i64, value: u8):
        mmio_write8(self.reg_addr(offset), value)

    # ------------------------------------------------------------------
    # Reset — Intel HD Audio spec 4.3 (controller/link reset)
    # ------------------------------------------------------------------

    me reset_controller() -> text:
        """Drive CRST low then high, polling for the hardware to reflect
        exit-from-reset before continuing. Bounded to 1000 polls so a
        non-responsive controller fails fast instead of hanging boot."""
        self.write32(HDA_REG_GCTL, 0u32)
        self.write32(HDA_REG_GCTL, 1u32)
        var tries: i64 = 0
        var ready = false
        while tries < 1000:
            if (self.read32(HDA_REG_GCTL) & 1u32) == 1u32:
                ready = true
                break
            tries = tries + 1
        if ready:
            "hda_reset ok tries=" + tries.to_text()
        else:
            "hda_reset TIMEOUT (CRST never read back set)"

    # ------------------------------------------------------------------
    # CORB / RIRB setup — Intel HD Audio spec 3.3.18-3.3.26 / 4.4
    # ------------------------------------------------------------------

    me setup_corb() -> text:
        """Stop CORB DMA, program its base address + size, reset the read
        pointer, zero the write pointer, then restart CORB DMA."""
        self.write8(HDA_REG_CORBCTL, 0u8)
        self.write32(HDA_REG_CORBLBASE, (self.corb.base_addr as u32))
        self.write32(HDA_REG_CORBUBASE, ((self.corb.base_addr >> 32) as u32))
        self.write8(HDA_REG_CORBSIZE, 2u8)  # 2 = 256 entries (spec-defined encoding)
        self.write16(HDA_REG_CORBRP, 0x8000u16)  # CORBRPRST
        self.write16(HDA_REG_CORBRP, 0u16)
        self.write16(HDA_REG_CORBWP, 0u16)
        self.corb.reset()
        self.write8(HDA_REG_CORBCTL, 2u8)  # CORBRUN
        "hda_corb ok base=0x" + self.corb.base_addr.to_text()

    me setup_rirb() -> text:
        """Stop RIRB DMA, program its base address + size, reset the write
        pointer, then restart RIRB DMA."""
        self.write8(HDA_REG_RIRBCTL, 0u8)
        self.write32(HDA_REG_RIRBLBASE, (self.rirb.base_addr as u32))
        self.write32(HDA_REG_RIRBUBASE, ((self.rirb.base_addr >> 32) as u32))
        self.write8(HDA_REG_RIRBSIZE, 2u8)  # 2 = 256 entries
        self.write16(HDA_REG_RIRBWP, 0x8000u16)  # RIRBWPRST
        self.write16(HDA_REG_RINTCNT, 1u16)  # interrupt after every response
        self.rirb.reset()
        self.write8(HDA_REG_RIRBCTL, 2u8)  # RIRBDMAEN
        "hda_rirb ok base=0x" + self.rirb.base_addr.to_text()

    me setup_interrupts() -> text:
        """Enable the global + controller interrupt bits (per-stream
        interrupt bits are enabled individually in configure_stream)."""
        self.write32(HDA_REG_INTCTL, 0xC0000000u32)  # GIE | CIE
        "hda_intctl ok"

    me setup_position_buffer(dma_addr: i64) -> text:
        """Point DPLBASE/DPUBASE at a DMA buffer for hardware-updated
        stream playback positions, and set the enable bit (bit0 of
        DPLBASE)."""
        self.write32(HDA_REG_DPUBASE, ((dma_addr >> 32) as u32))
        self.write32(HDA_REG_DPLBASE, ((dma_addr | 1) as u32))
        "hda_dpbase ok addr=0x" + dma_addr.to_text()

    # ------------------------------------------------------------------
    # Codec verb round trip — Intel HD Audio spec 4.4/7.3 (Vendor ID)
    # ------------------------------------------------------------------

    me send_verb(codec_addr: i64, node_id: i64, verb: i64, payload: i64) -> text:
        """Write one CORB entry (short-form: 12-bit verb + 8-bit payload)
        and advance CORBWP so the controller DMAs it out to the codec."""
        val entry = hda_build_corb_entry(codec_addr, node_id, verb, payload)
        val slot = self.corb.write_pos
        mmio_write32(self.corb.base_addr as u64 + ((slot as u64) * 4u64), entry)
        self.corb.advance_write()
        self.write16(HDA_REG_CORBWP, self.corb.write_pos as u16)
        "hda_verb codec=" + codec_addr.to_text() +
            " node=" + node_id.to_text() +
            " verb=0x" + verb.to_text() +
            " payload=0x" + payload.to_text() +
            " corb_wp=" + self.corb.write_pos.to_text()

    me probe_codec() -> text:
        """Detect the first present codec via STATESTS, ask it for its
        Vendor ID (GET_PARAMETER, param 0x00), and match the response
        against the known Realtek/Cirrus probe stubs. Response format
        (Intel HD Audio spec 7.3.4.1): bits[31:16] = vendor ID, bits[15:0]
        = device ID."""
        val statests = self.read16(HDA_REG_STATESTS)
        var addr: i64 = -1
        var bit: i64 = 0
        while bit < 15:
            if ((statests as i64) & (1 << bit)) != 0:
                addr = bit
                break
            bit = bit + 1
        if addr < 0:
            self.codec_count = 0
            return "hda_probe no_codec_present (STATESTS=0x" + (statests as i64).to_text() + ")"

        self.codec_addr = addr
        self.send_verb(addr, 0, HDA_VERB_GET_PARAMETER, HDA_PARAM_VENDOR_ID)

        var tries: i64 = 0
        var responded = false
        while tries < 1000:
            if self.read16(HDA_REG_RIRBWP) != (self.rirb.write_pos as u16):
                responded = true
                break
            tries = tries + 1
        if not responded:
            return "hda_probe TIMEOUT waiting for RIRB response"

        val resp = mmio_read32(self.rirb.base_addr as u64 + ((self.rirb.write_pos as u64) * 8u64))
        self.rirb.advance_write()
        self.codec_vendor_id = ((resp as i64) >> 16) & 0xFFFF
        self.codec_device_id = (resp as i64) & 0xFFFF
        self.codec_count = 1

        val realtek = RealtekHdaCodec.probe()
        val cirrus = CirrusHdaCodec.probe()
        if self.codec_vendor_id == realtek.capability.vendor_id:
            self.codec_name = realtek.summary()
        elif self.codec_vendor_id == cirrus.capability.vendor_id:
            self.codec_name = cirrus.summary()
        else:
            self.codec_name = "unknown vid=0x" + self.codec_vendor_id.to_text() +
                " did=0x" + self.codec_device_id.to_text()
        "hda_probe codec_addr=" + addr.to_text() + " " + self.codec_name

    # ------------------------------------------------------------------
    # Stream descriptors — Intel HD Audio spec 3.3.35-3.3.45 / 3.6
    # ------------------------------------------------------------------

    me stream_offset(stream_id: i64) -> i64:
        HDA_SD0_BASE + stream_id * HDA_SD_STRIDE

    me configure_stream(stream_id: i64, bdl_addr: i64, format_bits: u16) -> text:
        """Program one stream descriptor's buffer descriptor list pointer,
        cyclic buffer length, last valid index, and format — everything
        that must be set before the RUN bit (start_stream) is raised."""
        val off = self.stream_offset(stream_id)
        self.write32(off + HDA_SD_BDPL, (bdl_addr as u32))
        self.write32(off + HDA_SD_BDPU, ((bdl_addr >> 32) as u32))
        self.write32(off + HDA_SD_CBL, (self.timer.bytes_per_buffer() as u32))
        self.write16(off + HDA_SD_LVI, ((self.timer.periods_per_buffer - 1) as u16))
        self.write16(off + HDA_SD_FMT, format_bits)
        "hda_stream_cfg id=" + stream_id.to_text() +
            " bdl=0x" + bdl_addr.to_text() +
            " cbl=" + self.timer.bytes_per_buffer().to_text() +
            " lvi=" + (self.timer.periods_per_buffer - 1).to_text()

    me start_stream(stream_id: i64) -> text:
        """Set RUN + IOCE (interrupt on completion) on the stream
        descriptor's control byte and account for it locally."""
        val off = self.stream_offset(stream_id)
        val ctl = self.read32(off + HDA_SD_CTL)
        self.write32(off + HDA_SD_CTL, ctl | 0x06u32)  # RUN | IOCE
        self.stream_count = self.stream_count + 1
        "hda_stream_start id=" + stream_id.to_text() +
            " active=" + self.stream_count.to_text()

    me stop_stream(stream_id: i64) -> text:
        """Clear RUN on the stream descriptor's control byte."""
        val off = self.stream_offset(stream_id)
        val ctl = self.read32(off + HDA_SD_CTL)
        self.write32(off + HDA_SD_CTL, ctl & (0xFFFFFFFDu32))  # ~RUN
        if self.stream_count > 0:
            self.stream_count = self.stream_count - 1
        "hda_stream_stop id=" + stream_id.to_text() +
            " active=" + self.stream_count.to_text()

    # ------------------------------------------------------------------
    # IRQ handling — Intel HD Audio spec 3.3.10 (INTSTS, RW1C)
    # ------------------------------------------------------------------

    me handle_irq() -> text:
        """Read INTSTS, tick the period timer once per set stream bit
        (period-complete IRQ), then acknowledge by writing the same value
        back (registers here are RW1C: writing a 1 clears that bit)."""
        val intsts = self.read32(HDA_REG_INTSTS)
        if intsts == 0u32:
            return "hda_irq spurious"
        var stream_bit: i64 = 0
        var fired: i64 = 0
        while stream_bit < 30:
            if ((intsts as i64) & (1 << stream_bit)) != 0:
                self.timer.tick()
                fired = fired + 1
            stream_bit = stream_bit + 1
        self.write32(HDA_REG_INTSTS, intsts)  # RW1C acknowledge
        self.irq_count = self.irq_count + 1
        "hda_irq ok streams_fired=" + fired.to_text() +
            " total_irqs=" + self.irq_count.to_text() +
            " elapsed_periods=" + self.timer.elapsed_periods.to_text()

    # ------------------------------------------------------------------
    # Top-level init / status
    # ------------------------------------------------------------------

    me initialize() -> text:
        """Full bring-up sequence: reset, CORB/RIRB, interrupts, codec
        probe. Returns a combined status line; `initialized` is only set
        true when every step succeeds (fail-closed — a partially-brought-up
        controller must not be reported as ready)."""
        val r_reset = self.reset_controller()
        val r_corb = self.setup_corb()
        val r_rirb = self.setup_rirb()
        val r_int = self.setup_interrupts()
        val r_codec = self.probe_codec()

        val ok = (
            r_reset.starts_with("hda_reset ok") and
            r_corb.starts_with("hda_corb ok") and
            r_rirb.starts_with("hda_rirb ok") and
            r_int.starts_with("hda_intctl ok") and
            r_codec.starts_with("hda_probe codec_addr=")
        )
        self.initialized = ok
        self.last_status = r_reset + " | " + r_corb + " | " + r_rirb + " | " + r_int + " | " + r_codec
        if ok:
            "hda_init ok bar0=0x" + self.bar0_addr.to_text() + " irq=" + self.irq_line.to_text()
        else:
            "hda_init FAILED bar0=0x" + self.bar0_addr.to_text() + " :: " + self.last_status

    me stats() -> text:
        """Return a multi-line controller status summary."""
        "hda_controller bar0=0x" + self.bar0_addr.to_text() +
            " irq=" + self.irq_line.to_text() +
            " init=" + self.initialized.to_text() +
            " codecs=" + self.codec_count.to_text() +
            " codec=" + self.codec_name +
            " streams=" + self.stream_count.to_text() +
            " irqs=" + self.irq_count.to_text() +
            " accel=" + self.cpu_accel +
            " | " + self.timer.stats() +
            " | " + self.mixer.stats()
