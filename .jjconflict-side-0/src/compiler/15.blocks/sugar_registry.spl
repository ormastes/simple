# Sugar/Desugar Rule Registry
#
# Central registry for dynamic desugar rules loaded from plugins at startup.
# Rules are keyed by name; `pattern_tag` is the AST expr tag used for fast
# filtering in the interpreter's desugar loop.
#
# AC-3a: trivial rule registration and apply_rule public hook.
# AC-3b: PERF-SUGAR-002 gemm_add rule acceptance; Cranelift site marked below.
#
# Usage:
#   val rule = DesugarRule(pattern_tag: 4096, rewrite_fn: 0, name: "my_rule")
#   register_desugar_rule(rule)
#   val out = apply_rule("my_rule", "x ?: y")

# ============================================================================
# Data Types
# ============================================================================

# [STATIC-NEXT] sugar rule registry — dynamic dispatch today; static lowering deferred to next release.
struct RuleRegistry:
    """Singleton table of registered DesugarRules.

    Rules are stored by name. No duplicate names are allowed — a second
    registration with the same name returns false without overwriting.
    `pattern_tag` is the AST expr tag used for fast filtering in the
    interpreter's desugar loop.
    """
    rules: [DesugarRule]


struct DesugarRule:
    """A single desugar rewrite rule.

    Fields:
        name:        Human-readable identifier; used as primary key.
        pattern_tag: AST expr tag that this rule matches (fast pre-filter).
        rewrite_fn:  i64 function pointer obtained via spl_dlsym at startup.
                     Sentinel value 0 means "no native function loaded" —
                     apply_rule falls back to a built-in text rewrite in that
                     case (used for spec-time proof without a real .so).
    """
    name: text
    pattern_tag: i64
    rewrite_fn: i64


# ============================================================================
# Global Singleton
# ============================================================================

var _rule_registry: RuleRegistry = nil

fn rule_registry() -> RuleRegistry:
    """Get the global rule registry (lazy-initialized)."""
    if not has__rule_registry:
        _rule_registry = RuleRegistry(rules: [])
    _rule_registry_value


# ============================================================================
# Registry Operations
# ============================================================================

fn register_desugar_rule(rule: DesugarRule) -> bool:
    """Register a desugar rule.

    Returns true on success. Returns false if a rule with the same name is
    already registered (conservative no-shadow policy).
    """
    var reg = rule_registry()
    for existing in reg.rules:
        if existing.name == rule.name:
            return false
    reg.rules = reg.rules.push(rule)
    true


fn unregister_desugar_rule(name: text) -> bool:
    """Remove a rule by name.

    Returns true if a rule was found and removed, false if not found.
    """
    var reg = rule_registry()
    var new_rules: [DesugarRule] = []
    var found = false
    for r in reg.rules:
        if r.name == name:
            found = true
        else:
            new_rules = new_rules.push(r)
    if found:
        reg.rules = new_rules
    found


fn lookup_rule(name: text) -> DesugarRule?:
    """Look up a rule by name. Returns nil if not found."""
    var reg = rule_registry()
    for r in reg.rules:
        if r.name == name:
            return r
    nil


fn list_rules() -> [text]:
    """Return the names of all registered rules."""
    var reg = rule_registry()
    var names: [text] = []
    for r in reg.rules:
        names = names.push(r.name)
    names


# ============================================================================
# Rule Application
# ============================================================================

fn apply_rule(name: text, input: text) -> text:
    """Apply a named rule to a text-form input.

    Public hook used by specs and the interpreter consultation site.

    Behaviour:
    - If the rule is not found, returns input unchanged.
    - If rewrite_fn == 0 (sentinel / no native fn loaded), falls back to a
      built-in text rewrite keyed on pattern_tag:
        pattern_tag 4096 → null-coalescing rewrite ("?:" → "if/else" form)
        any other tag    → return input unchanged (no match).
    - If rewrite_fn != 0, calls the native function via spl_wffi_call_i64.
      The native function receives the input text as an i64 handle and returns
      a rewritten text handle.  The interpreter path uses this for real loaded
      plugins; the spec path uses the sentinel.
    """
    val maybe_rule = lookup_rule(name)
    if not maybe_rule.?:
        return input

    val r = maybe_rule.unwrap()

    if r.rewrite_fn != 0:
        # Native function path — call via WFFI.
        # Signature: fn(input_handle: i64) -> i64  (text handles)
        # [STATIC-NEXT] sugar rule registry — dynamic dispatch today; static lowering deferred to next release.
        val result_handle = spl_wffi_call_i64(r.rewrite_fn, [input.to_handle()], 1)
        return text.from_handle(result_handle)

    # Sentinel path: built-in text rewrites for spec-time proof.
    # Only pattern_tag 4096 (null-coalescing) has a built-in rewrite.
    if r.pattern_tag == 4096:
        return _builtin_null_coalesce_rewrite(input)

    # No built-in rewrite for this tag — return input unchanged.
    input


# ============================================================================
# Built-in Text Rewrites (sentinel / spec-time only)
# ============================================================================

fn _builtin_null_coalesce_rewrite(input: text) -> text:
    """Rewrite `X ?: Y` to `if (X != nil) { X } else { Y }`.

    This is a minimal text-level proof for AC-3a.  The production path uses a
    native rewrite_fn loaded via spl_dlopen/spl_dlsym; this fallback exists
    solely so the spec can verify the registry fires without a real .so.

    Only handles the simple two-operand case `X ?: Y` (split on " ?: ").
    Returns input unchanged if the pattern is not found.
    """
    val sep = " ?: "
    val idx = input.index_of(sep)
    if idx < 0:
        return input
    val lhs = input.substring(0, idx)
    val rhs = input.substring(idx + sep.len(), input.len())
    "if (" + lhs + " != nil) { " + lhs + " } else { " + rhs + " }"


# ============================================================================
# Interpreter Consultation Helper
# ============================================================================

fn apply_sugar_rules(tag: i64, node_text: text) -> text:
    """Scan all registered rules for a matching pattern_tag and apply the first
    match.  Returns the rewritten text or the original if no rule matches.

    Called from collection_desugar.spl after the built-in rewrite arms.
    See [STATIC-NEXT] marker at the call site in collection_desugar.spl.
    """
    var reg = rule_registry()
    for r in reg.rules:
        if r.pattern_tag == tag:
            return apply_rule(r.name, node_text)
    node_text
