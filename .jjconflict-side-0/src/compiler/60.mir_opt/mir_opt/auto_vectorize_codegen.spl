# Auto-Vectorization Pass - Phase 4: Vector Code Generation
#
# Transforms scalar loop bodies into SIMD equivalents.
# Generates prologue (alignment), vector body, and epilogue (remainder).

use compiler.mir.mir_data.{MirInst, MirInstKind, MirTerminator, MirOperand, MirOperandKind, MirBinOp, LocalId, BlockId}
use compiler.mir.mir_instructions.{MirBlock}
use compiler.mir_opt.auto_vectorize_types.{LoopInfo}
use compiler.mir_opt.mir_opt.simd_opt_metadata.{plugin_hook_vectorize_event}

# ============================================================================
# Vectorization Context and Structures
# ============================================================================

struct VectorizeContext:
    """Context for vectorization transformation."""
    vector_width: i64     # 4 for SSE, 8 for AVX2
    element_type: text    # "f32", "f64", "i32"
    next_local: i64

struct VectorizedLoop:
    """Complete vectorized loop structure."""
    prologue_blocks: [MirBlock]
    vector_blocks: [MirBlock]
    epilogue_blocks: [MirBlock]
    original_loop: LoopInfo

# ============================================================================
# Main Code Generation
# ============================================================================

fn create_vector_loop(
    ctx: VectorizeContext,
    loop: LoopInfo,
    body_blocks: [MirBlock]
) -> VectorizedLoop:
    """
    Transform scalar loop to vector + remainder loops.
    Returns complete vectorized loop structure with prologue, body, and epilogue.
    """
    # Generate prologue (alignment and peeling)
    val prologue = generate_prologue(ctx, loop)

    # Generate vectorized body
    val vector_body = generate_vector_body(ctx, loop, body_blocks)

    # Emit optimization plugin metadata event.
    # kernel_id uses the loop header block id as a stable identifier.
    # changed = true because create_vector_loop is only called when vectorization
    # was decided (cost model approved it in auto_vectorize_cost.spl).
    val kernel_id = "loop_bb{loop.header_block.id}"
    plugin_hook_vectorize_event(kernel_id, true)

    # Generate epilogue (remainder loop)
    val epilogue = generate_epilogue(ctx, loop, body_blocks)

    VectorizedLoop(
        prologue_blocks: prologue,
        vector_blocks: vector_body,
        epilogue_blocks: epilogue,
        original_loop: loop
    )

# ============================================================================
# Prologue Generation
# ============================================================================

fn generate_prologue(ctx: VectorizeContext, loop: LoopInfo) -> [MirBlock]:
    """
    Generate prologue code:
    - Alignment checks
    - Loop peeling for alignment
    - Setup for vector loop

    Note: body_blocks are not in scope here; passes empty list to create_peeling_block.
    Callers that have scalar body blocks should call create_peeling_block directly.
    """
    var blocks: [MirBlock] = []

    # Create alignment check block
    val align_block = create_alignment_check_block(ctx, loop)
    blocks.push(align_block)

    # Create peeling iterations block (if needed); no body clone available here.
    val peel_block = create_peeling_block(ctx, loop, [])
    blocks.push(peel_block)

    blocks

fn create_alignment_check_block(ctx: VectorizeContext, loop: LoopInfo) -> MirBlock:
    """
    Create block that computes mismatch = (end - start) % chunk_width at runtime
    and branches: if mismatch == 0 → vector loop (next_local+2); else → peeling block
    (next_local+1).

    MIR shape produced:
      BB_align_check:
        %range   = BinOp(Sub, end_value, start_value)       # trip count
        %mismatch = BinOp(Rem, %range, chunk_width_const)   # remainder mod VF
        %zero_const = Const(0)
        %is_aligned = BinOp(Sub, %mismatch, %zero_const)    # 0 iff aligned
        If(%is_aligned == 0 → BB_vector, BB_peel)
        → represented as If(%mismatch, BB_peel, BB_vector)
          (non-zero mismatch → peel; zero → vector)

    Block IDs used:
      ctx.next_local+0 = this alignment-check block
      ctx.next_local+1 = peeling block (sibling, created by create_peeling_block)
      ctx.next_local+2 = vector loop entry (successor after peel or direct)
    """
    val block_id = BlockId.new(ctx.next_local)
    val peel_id  = BlockId.new(ctx.next_local + 1)
    val vec_id   = BlockId.new(ctx.next_local + 2)

    # Locals for the alignment computation
    val range_dest    = LocalId(id: ctx.next_local + 100)
    val mismatch_dest = LocalId(id: ctx.next_local + 101)

    # Operands: loop bounds and chunk width come from LoopInfo / VectorizeContext
    val end_op   = MirOperand(kind: MirOperandKind.Const("i64", "{loop.end_value}"))
    val start_op = MirOperand(kind: MirOperandKind.Const("i64", "{loop.start_value}"))
    val vf_op    = MirOperand(kind: MirOperandKind.Const("i64", "{ctx.vector_width}"))

    # %range = end - start
    val range_inst = MirInst(
        kind: MirInstKind.BinOp(range_dest, MirBinOp.Sub, end_op, start_op),
        span: nil
    )
    # %mismatch = %range % vector_width
    val mismatch_inst = MirInst(
        kind: MirInstKind.BinOp(mismatch_dest, MirBinOp.Rem,
            MirOperand(kind: MirOperandKind.Copy(range_dest)), vf_op),
        span: nil
    )

    # Terminator: If(%mismatch != 0) → peel, else → vector
    # MirTerminator.If branches to then_ when cond is truthy (non-zero).
    # mismatch is non-zero when alignment is needed → branch to peel.
    val terminator = MirTerminator.If(
        cond:  MirOperand(kind: MirOperandKind.Copy(mismatch_dest)),
        then_: peel_id,
        else_: vec_id
    )

    MirBlock(
        id:           block_id,
        label:        Some("align_check"),
        instructions: [range_inst, mismatch_inst],
        terminator:   terminator
    )

fn create_peeling_block(ctx: VectorizeContext, loop: LoopInfo, body_blocks: [MirBlock]) -> MirBlock:
    """
    Create scalar-fixup peeling block that runs the loop body for the misaligned
    suffix (remainder iterations after the vector loop).

    When body_blocks is non-empty and mismatch > 0 (static trip count with
    trip_count % VF != 0), clones the scalar body instructions from body_blocks[0]
    for the remainder iterations.  Terminates with Goto(BB_vector_exit).

    When body_blocks is empty or mismatch == 0 (divisible trip count or dynamic
    sentinel end_value=0), emits zero instructions and falls through to the
    vector loop entry (BB_vector).  This covers the dynamic-n case where trip
    count is unknown at compile time.

    MIR shape produced (mismatch > 0, body_blocks non-empty):
      BB_peel:
        # Clone of scalar body instructions for one iteration per remainder step.
        # Inline unrolled for mismatch iterations; control flow: Goto(BB_vec_exit).
        Goto(BB_exit)

    MIR shape produced (mismatch == 0 or body_blocks empty):
      BB_peel:
        Goto(BB_vector)   # fall-through: no remainder work needed

    Block IDs:
      ctx.next_local+1 = this peel block
      ctx.next_local+2 = vector loop entry (falls through when no peel needed)
    """
    val block_id = BlockId.new(ctx.next_local + 1)
    val vec_id   = BlockId.new(ctx.next_local + 2)

    # Compute static mismatch: how many scalar iterations remain after vector loop.
    # mismatch > 0 only when loop.end_value > 0 and end_value % vector_width != 0.
    val mismatch = if loop.end_value > 0: loop.end_value % ctx.vector_width else: 0

    val has_body = body_blocks.len() > 0

    if (mismatch > 0) and has_body:
        # Clone the scalar body instructions from the first body block.
        # Conservative approximation: emit one pass of the scalar body
        # (handles 1 remainder iteration).  Full SCEV-based unrolling of
        # mismatch iterations is deferred to a follow-up wave.
        val first_block = body_blocks[0]
        val source_insts = first_block.instructions
        var peel_insts: [MirInst] = []
        for inst in source_insts:
            peel_insts.push(inst)

        # Terminate: jump to continuation (the block after the three new blocks).
        val exit_id = BlockId.new(ctx.next_local + 3)
        val terminator = MirTerminator.Goto(exit_id)

        MirBlock(
            id:           block_id,
            label:        Some("peel_loop"),
            instructions: peel_insts,
            terminator:   terminator
        )
    else:
        # No remainder work: fall through to vector loop entry (or exit).
        val terminator = MirTerminator.Goto(vec_id)

        MirBlock(
            id:           block_id,
            label:        Some("peel_loop"),
            instructions: [],
            terminator:   terminator
        )

# ============================================================================
# Vector Body Generation
# ============================================================================

fn generate_vector_body(ctx: VectorizeContext, loop: LoopInfo, body_blocks: [MirBlock]) -> [MirBlock]:
    """
    Generate vectorized loop body.
    Replaces scalar operations with SIMD equivalents.
    """
    var new_blocks: [MirBlock] = []

    # For each block in original loop
    for orig_block in body_blocks:
        var vector_insts: [MirInst] = []

        # Transform each instruction
        for inst in orig_block.instructions:
            val vectorized = vectorize_instruction(ctx, inst)
            if vectorized.?:
                vector_insts.push(vectorized.unwrap())

        # Create new block with vectorized instructions
        val new_block = MirBlock(
            id: orig_block.id,
            label: orig_block.label,
            instructions: vector_insts,
            terminator: orig_block.terminator
        )
        new_blocks.push(new_block)

    new_blocks

# ============================================================================
# Epilogue Generation
# ============================================================================

fn generate_epilogue(ctx: VectorizeContext, loop: LoopInfo, body_blocks: [MirBlock]) -> [MirBlock]:
    """
    Generate epilogue (remainder loop).
    Handles last few iterations when trip count not multiple of vector width.
    Uses original scalar code.
    """
    var epilogue_blocks: [MirBlock] = []

    # Create remainder loop with scalar code
    for orig_block in body_blocks:
        # Keep original scalar instructions
        val remainder_block = MirBlock(
            id: BlockId.new(orig_block.id.id + 1000),  # Offset IDs
            label: Some("remainder_{orig_block.id.id}"),
            instructions: orig_block.instructions,
            terminator: orig_block.terminator
        )
        epilogue_blocks.push(remainder_block)

    epilogue_blocks

# ============================================================================
# Instruction Vectorization
# ============================================================================

fn vectorize_instruction(ctx: VectorizeContext, inst: MirInst) -> MirInst?:
    """
    Transform a scalar instruction to its SIMD equivalent.
    Returns nil if instruction cannot be vectorized.
    """
    match inst.kind:
        case BinOp(dest, op, left, right):
            vectorize_binop(ctx, dest, op, left, right, inst.span)

        case Load(dest, ptr):
            # Convert to vector load
            vectorize_load(ctx, dest, ptr, inst.span)

        case Store(ptr, value):
            # Convert to vector store
            vectorize_store(ctx, ptr, value, inst.span)

        case GetElementPtr(dest, base, indices):
            # Keep GEP but adjust for vector width
            Some(inst)

        case _:
            # Other instructions keep as-is
            Some(inst)

fn vectorize_binop(ctx: VectorizeContext, dest: LocalId, op: MirBinOp, left: MirOperand, right: MirOperand, span: Span?) -> MirInst?:
    """Vectorize binary operation."""
    match op:
        case Add:
            if ctx.element_type == "f32" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdAddF32x4(dest, left, right), span: span))
            elif ctx.element_type == "f32" and ctx.vector_width == 8:
                Some(MirInst(kind: MirInstKind.SimdAddF32x8(dest, left, right), span: span))
            elif ctx.element_type == "f64" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdAddF64x4(dest, left, right), span: span))
            elif ctx.element_type == "i32" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdAddI32x4(dest, left, right), span: span))
            elif ctx.element_type == "i32" and ctx.vector_width == 8:
                Some(MirInst(kind: MirInstKind.SimdAddI32x8(dest, left, right), span: span))
            else:
                nil

        case Sub:
            if ctx.element_type == "f32" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdSubF32x4(dest, left, right), span: span))
            elif ctx.element_type == "f32" and ctx.vector_width == 8:
                Some(MirInst(kind: MirInstKind.SimdSubF32x8(dest, left, right), span: span))
            elif ctx.element_type == "f64" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdSubF64x4(dest, left, right), span: span))
            elif ctx.element_type == "i32" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdSubI32x4(dest, left, right), span: span))
            elif ctx.element_type == "i32" and ctx.vector_width == 8:
                Some(MirInst(kind: MirInstKind.SimdSubI32x8(dest, left, right), span: span))
            else:
                nil

        case Mul:
            if ctx.element_type == "f32" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdMulF32x4(dest, left, right), span: span))
            elif ctx.element_type == "f32" and ctx.vector_width == 8:
                Some(MirInst(kind: MirInstKind.SimdMulF32x8(dest, left, right), span: span))
            elif ctx.element_type == "f64" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdMulF64x4(dest, left, right), span: span))
            elif ctx.element_type == "i32" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdMulI32x4(dest, left, right), span: span))
            elif ctx.element_type == "i32" and ctx.vector_width == 8:
                Some(MirInst(kind: MirInstKind.SimdMulI32x8(dest, left, right), span: span))
            else:
                nil

        case Div:
            if ctx.element_type == "f32" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdDivF32x4(dest, left, right), span: span))
            elif ctx.element_type == "f32" and ctx.vector_width == 8:
                Some(MirInst(kind: MirInstKind.SimdDivF32x8(dest, left, right), span: span))
            elif ctx.element_type == "f64" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdDivF64x4(dest, left, right), span: span))
            else:
                nil

        case BitAnd:
            if ctx.element_type == "i32" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdAndI32x4(dest, left, right), span: span))
            elif ctx.element_type == "i32" and ctx.vector_width == 8:
                Some(MirInst(kind: MirInstKind.SimdAndI32x8(dest, left, right), span: span))
            else:
                val name = "simd_and_{ctx.element_type}x{ctx.vector_width}"
                Some(MirInst(kind: MirInstKind.Intrinsic(Some(dest), name, [left, right]), span: span))

        case BitOr:
            if ctx.element_type == "i32" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdOrI32x4(dest, left, right), span: span))
            elif ctx.element_type == "i32" and ctx.vector_width == 8:
                Some(MirInst(kind: MirInstKind.SimdOrI32x8(dest, left, right), span: span))
            else:
                val name = "simd_or_{ctx.element_type}x{ctx.vector_width}"
                Some(MirInst(kind: MirInstKind.Intrinsic(Some(dest), name, [left, right]), span: span))

        case BitXor:
            if ctx.element_type == "i32" and ctx.vector_width == 4:
                Some(MirInst(kind: MirInstKind.SimdXorI32x4(dest, left, right), span: span))
            elif ctx.element_type == "i32" and ctx.vector_width == 8:
                Some(MirInst(kind: MirInstKind.SimdXorI32x8(dest, left, right), span: span))
            else:
                val name = "simd_xor_{ctx.element_type}x{ctx.vector_width}"
                Some(MirInst(kind: MirInstKind.Intrinsic(Some(dest), name, [left, right]), span: span))

        case Lt:
            val name = "simd_cmp_lt_{ctx.element_type}x{ctx.vector_width}"
            Some(MirInst(kind: MirInstKind.Intrinsic(Some(dest), name, [left, right]), span: span))

        case Gt:
            val name = "simd_cmp_gt_{ctx.element_type}x{ctx.vector_width}"
            Some(MirInst(kind: MirInstKind.Intrinsic(Some(dest), name, [left, right]), span: span))

        case Eq:
            val name = "simd_cmp_eq_{ctx.element_type}x{ctx.vector_width}"
            Some(MirInst(kind: MirInstKind.Intrinsic(Some(dest), name, [left, right]), span: span))

        case Ne:
            val name = "simd_cmp_ne_{ctx.element_type}x{ctx.vector_width}"
            Some(MirInst(kind: MirInstKind.Intrinsic(Some(dest), name, [left, right]), span: span))

        case Le:
            val name = "simd_cmp_le_{ctx.element_type}x{ctx.vector_width}"
            Some(MirInst(kind: MirInstKind.Intrinsic(Some(dest), name, [left, right]), span: span))

        case Ge:
            val name = "simd_cmp_ge_{ctx.element_type}x{ctx.vector_width}"
            Some(MirInst(kind: MirInstKind.Intrinsic(Some(dest), name, [left, right]), span: span))

        case Shl:
            val name = "simd_shl_{ctx.element_type}x{ctx.vector_width}"
            Some(MirInst(kind: MirInstKind.Intrinsic(Some(dest), name, [left, right]), span: span))

        case Shr:
            val name = "simd_shr_{ctx.element_type}x{ctx.vector_width}"
            Some(MirInst(kind: MirInstKind.Intrinsic(Some(dest), name, [left, right]), span: span))

        case _:
            nil

fn vectorize_load(ctx: VectorizeContext, dest: LocalId, ptr: MirOperand, span: Span?) -> MirInst?:
    """
    Vectorize load instruction.
    Converts scalar load to vector load.
    """
    # Create vector load intrinsic
    val load_name = "simd_load_{ctx.element_type}x{ctx.vector_width}"
    Some(MirInst(
        kind: MirInstKind.Intrinsic(Some(dest), load_name, [ptr]),
        span: span
    ))

fn vectorize_store(ctx: VectorizeContext, ptr: MirOperand, value: MirOperand, span: Span?) -> MirInst?:
    """
    Vectorize store instruction.
    Converts scalar store to vector store.
    """
    # Create vector store intrinsic
    val store_name = "simd_store_{ctx.element_type}x{ctx.vector_width}"
    Some(MirInst(
        kind: MirInstKind.Intrinsic(nil, store_name, [ptr, value]),
        span: span
    ))

# ============================================================================
# Vector Load/Store Helpers
# ============================================================================

fn create_vector_load(ctx: VectorizeContext, base: LocalId, offset: LocalId) -> MirInst:
    """Create a vector load instruction."""
    val load_name = "simd_load_{ctx.element_type}x{ctx.vector_width}"
    val base_op = MirOperand.copy(base)
    val offset_op = MirOperand.copy(offset)
    MirInst(
        kind: MirInstKind.Intrinsic(Some(LocalId(id: ctx.next_local)), load_name, [base_op, offset_op]),
        span: nil
    )

fn create_vector_store(ctx: VectorizeContext, base: LocalId, offset: LocalId, value: LocalId) -> MirInst:
    """Create a vector store instruction."""
    val store_name = "simd_store_{ctx.element_type}x{ctx.vector_width}"
    val base_op = MirOperand.copy(base)
    val offset_op = MirOperand.copy(offset)
    val value_op = MirOperand.copy(value)
    MirInst(
        kind: MirInstKind.Intrinsic(nil, store_name, [base_op, offset_op, value_op]),
        span: nil
    )

# ============================================================================
# N1 Wave — Vector Loop Block (elementwise-add)
# ============================================================================

fn create_vector_loop_block(
    ctx: VectorizeContext,
    base_block_id: i64,
    input_bases: [LocalId],
    output_base: LocalId,
    op_name: text,
    trip_count: i64,
    exit_block_id: i64
) -> MirBlock:
    """
    Create the SIMD vector-loop block for a supported elementwise pattern.

    Emits (for chunk_width=4, element_type=i32):
      BB_vec_loop:
        %va   = Intrinsic("simd_load_i32x4", [a_base, vi])
        %vb   = Intrinsic("simd_load_i32x4", [b_base, vi])
        %vres = Intrinsic("simd_<op>_i32x4", [%va, %vb])
        Intrinsic("simd_store_i32x4", [out_base, vi, %vres])
        %vi1  = BinOp(Add, %vi, chunk_width_const)    # vi += chunk_width
        %cond = BinOp(Lt, %vi1, trip_count_const)     # exit guard
        If(%cond, BB_vec_loop, BB_exit)               # back-edge or exit

    Block IDs allocated:
      base_block_id + 2 = this vector-loop block (matches vec_id in alignment_check)

    trip_count: total iteration count used to build the loop exit guard
                (%vi1 < trip_count → continue; else → exit_block_id).
    exit_block_id: block id to branch to when vi1 >= trip_count (epilogue or successor).
    """
    val block_id = BlockId.new(base_block_id + 2)

    # Locals for SIMD temporaries
    val vi_local  = LocalId(id: base_block_id + 200)  # vector index (chunk-scaled)
    val va_local  = LocalId(id: base_block_id + 201)  # loaded vector a
    val vb_local  = LocalId(id: base_block_id + 202)  # loaded vector b
    val vres_local = LocalId(id: base_block_id + 203) # result vector
    val vi1_local  = LocalId(id: base_block_id + 204) # updated vector index

    # Choose base arrays (default to sentinel locals if input_bases is short)
    val a_base = if input_bases.len() > 0: input_bases[0] else: LocalId(id: 0)
    val b_base = if input_bases.len() > 1: input_bases[1] else: LocalId(id: 1)

    val load_name  = "simd_load_{ctx.element_type}x{ctx.vector_width}"
    val store_name = "simd_store_{ctx.element_type}x{ctx.vector_width}"
    val vec_op_name = "simd_{_elementwise_op_stem(op_name)}_{ctx.element_type}x{ctx.vector_width}"

    # %va = simd_load(a_base, vi)
    val load_a = MirInst(
        kind: MirInstKind.Intrinsic(
            Some(va_local),
            load_name,
            [MirOperand(kind: MirOperandKind.Copy(a_base)),
             MirOperand(kind: MirOperandKind.Copy(vi_local))]
        ),
        span: nil
    )
    # %vb = simd_load(b_base, vi)
    val load_b = MirInst(
        kind: MirInstKind.Intrinsic(
            Some(vb_local),
            load_name,
            [MirOperand(kind: MirOperandKind.Copy(b_base)),
             MirOperand(kind: MirOperandKind.Copy(vi_local))]
        ),
        span: nil
    )
    # %vres = simd_<op>(va, vb) — use Intrinsic to stay type-agnostic; backend lowers it
    val op_inst = MirInst(
        kind: MirInstKind.Intrinsic(
            Some(vres_local),
            vec_op_name,
            [MirOperand(kind: MirOperandKind.Copy(va_local)),
             MirOperand(kind: MirOperandKind.Copy(vb_local))]
        ),
        span: nil
    )
    # simd_store(out_base, vi, vres)
    val store_inst = MirInst(
        kind: MirInstKind.Intrinsic(
            nil,
            store_name,
            [MirOperand(kind: MirOperandKind.Copy(output_base)),
             MirOperand(kind: MirOperandKind.Copy(vi_local)),
             MirOperand(kind: MirOperandKind.Copy(vres_local))]
        ),
        span: nil
    )
    # %vi1 = vi + chunk_width
    val vf_op = MirOperand(kind: MirOperandKind.Const("i64", "{ctx.vector_width}"))
    val inc_inst = MirInst(
        kind: MirInstKind.BinOp(
            vi1_local,
            MirBinOp.Add,
            MirOperand(kind: MirOperandKind.Copy(vi_local)),
            vf_op
        ),
        span: nil
    )

    # %cond = vi1 < trip_count  (exit guard: continue if more iterations remain)
    val vcond_local = LocalId(id: base_block_id + 205)
    val tc_op = MirOperand(kind: MirOperandKind.Const("i64", "{trip_count}"))
    val guard_inst = MirInst(
        kind: MirInstKind.BinOp(
            vcond_local,
            MirBinOp.Lt,
            MirOperand(kind: MirOperandKind.Copy(vi1_local)),
            tc_op
        ),
        span: nil
    )

    # Terminator: If(%cond) → back-edge (self), else → exit block.
    # This replaces the former self-loop Goto which caused non-termination.
    val exit_id = BlockId.new(exit_block_id)
    val terminator = MirTerminator.If(
        cond:  MirOperand(kind: MirOperandKind.Copy(vcond_local)),
        then_: block_id,
        else_: exit_id
    )

    MirBlock(
        id:           block_id,
        label:        Some("vec_loop"),
        instructions: [load_a, load_b, op_inst, store_inst, inc_inst, guard_inst],
        terminator:   terminator
    )

fn _elementwise_op_stem(op_name: text) -> text:
    """Map recipe operation names to the vector intrinsic stem."""
    if op_name == "sub_elementwise":
        return "sub"
    if op_name == "mul_elementwise":
        return "mul"
    if op_name == "xor_elementwise":
        return "xor"
    "add"

# ============================================================================
# Exports
# ============================================================================
