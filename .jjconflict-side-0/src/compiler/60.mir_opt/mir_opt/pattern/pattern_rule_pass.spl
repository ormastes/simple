# Pattern Rule Pass — Data-Driven MIR Peephole Rewriter (AC-7)
#
# Executes loaded `.opt.json` rule files against a MirModule.  Each rule
# describes a single-instruction pattern (MirPattern) and a rewrite
# (MirRewrite).  Wildcards use the "$name" prefix; first occurrence binds,
# subsequent occurrences enforce equality.
#
# The AC-7 schema extends "simple.opt.mir.v1" with an optional
# `rules: [PatternRule]` array.  A manifest may have zero passes but
# non-zero rules, or both.
#
# "Remove" in MirRewrite.kind_tag means the instruction is dropped entirely
# from the rebuilt block.  There is NO Nop variant in MirInstKind.
# Structural rewrites (BinOp, Copy, etc.) are deferred pending the MIR
# operand builder API; non-Remove rules currently pass the instruction through.
#
# See: doc/05_design/optimizer_manifest_versioned_design.md (AC-7 section)

use compiler.mir.mir_data.{MirInst, MirInstKind, MirOperand, MirOperandKind, MirConstValue, LocalId, BlockId}
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock}

# ============================================================================
# Pattern and rewrite types
# ============================================================================

struct MirPatternSlot:
    """One position in a single-instruction match.

    kind_tag  — instruction kind to match: "BinOp" | "Copy" | "Load" |
                "Intrinsic" | "*" (matches any kind).
    operand_0 — first operand: literal value or "$wildcard" to bind/check.
    operand_1 — second operand (optional).
    dest      — destination local: "$dest" wildcard to bind.
    """
    kind_tag:  text
    operand_0: text?
    operand_1: text?
    dest:      text?

struct MirPattern:
    """Single-instruction peephole pattern.  inst_count is always 1 in AC-7."""
    inst_count: i64
    slots:      [MirPatternSlot]

struct MirRewrite:
    """Describes the replacement for a matched instruction.

    kind_tag == "Remove" drops the instruction from the rebuilt block.
    Any other kind_tag names the replacement MirInstKind.
    dest     — "$dest" bound from match.
    operands — literals or bound wildcard names.
    """
    kind_tag:  text
    dest:      text
    operands:  [text]

struct PatternRule:
    """One named peephole rule loaded from a `.opt.json` file."""
    name:       text
    pattern:    MirPattern
    rewrite:    MirRewrite
    cost_delta: i64
    safety:     text

struct PatternRuleSet:
    """A named collection of rules from one manifest source."""
    source: text
    rules:  [PatternRule]

struct PatternRulePass:
    """Holds all loaded rule sets for the current session."""
    rule_sets: [PatternRuleSet]

# ============================================================================
# Wildcard binding table
# ============================================================================

struct WildcardBinding:
    name:  text
    value: text

fn wildcard_bindings_empty() -> [WildcardBinding]:
    []

fn wildcard_lookup(bindings: [WildcardBinding], name: text) -> text?:
    for b in bindings:
        if b.name == name:
            return Some(b.value)
    nil

fn wildcard_bind(bindings: [WildcardBinding], name: text, value: text) -> [WildcardBinding]?:
    """Bind name -> value.  If name is already bound to a different value, return nil (mismatch)."""
    val existing = wildcard_lookup(bindings, name)
    if existing.?:
        if existing.unwrap() == value:
            Some(bindings)
        else:
            nil
    else:
        Some(bindings.push(WildcardBinding(name: name, value: value)))

fn is_wildcard(s: text) -> bool:
    s.len() > 0 and s.starts_with("$")

# ============================================================================
# Operand key — stable text representation for pattern matching
# ============================================================================

fn operand_text_key(op: MirOperand) -> text:
    match op.kind:
        case Copy(local):
            "copy:{local.id}"
        case Move(local):
            "move:{local.id}"
        case Const(value, _):
            mir_const_value_text_key(value)
        case _:
            "op:unknown"

fn mir_const_value_text_key(value: MirConstValue) -> text:
    match value:
        case Int(v):   "int:{v}"
        case Float(v): "float:{v}"
        case Bool(v):  "bool:{v}"
        case Str(s):   "str:{s}"
        case _:        "const:unknown"

fn local_id_text(local: LocalId) -> text:
    "{local.id}"

# ============================================================================
# Single-slot match
# ============================================================================

fn match_slot_operand(
    pattern_val: text?,
    actual_val: text,
    bindings: [WildcardBinding]
) -> [WildcardBinding]?:
    """Match one operand position against the pattern value.

    nil pattern_val = wildcard matches anything without binding.
    "$name" = bind or enforce equality.
    literal = exact text equality required.
    """
    if not pattern_val.?:
        return Some(bindings)
    val pv = pattern_val.unwrap()
    if is_wildcard(pv):
        wildcard_bind(bindings, pv, actual_val)
    elif pv == actual_val:
        Some(bindings)
    else:
        nil

fn match_slot_against_inst(
    slot: MirPatternSlot,
    inst: MirInst,
    bindings: [WildcardBinding]
) -> [WildcardBinding]?:
    """Try to match one pattern slot against one MIR instruction.

    Returns updated bindings on success, nil on mismatch.
    """
    val kind_matches = (slot.kind_tag == "*") or inst_kind_tag_matches(inst.kind, slot.kind_tag)
    if not kind_matches:
        return nil

    # Extract operand keys and dest from the instruction
    val info = inst_operand_info(inst)

    # Match dest
    var cur_bindings = bindings
    if slot.dest.?:
        val dest_pv = slot.dest.unwrap()
        val dest_actual = info.dest_key
        val maybe = match_slot_operand(Some(dest_pv), dest_actual, cur_bindings)
        if not maybe.?:
            return nil
        cur_bindings = maybe.unwrap()

    # Match operand_0
    val maybe0 = match_slot_operand(slot.operand_0, info.operand_0_key, cur_bindings)
    if not maybe0.?:
        return nil
    cur_bindings = maybe0.unwrap()

    # Match operand_1
    val maybe1 = match_slot_operand(slot.operand_1, info.operand_1_key, cur_bindings)
    if not maybe1.?:
        return nil
    cur_bindings = maybe1.unwrap()

    Some(cur_bindings)

# ============================================================================
# Instruction info extraction
# ============================================================================

struct InstOperandInfo:
    dest_key:      text
    operand_0_key: text
    operand_1_key: text

fn inst_operand_info(inst: MirInst) -> InstOperandInfo:
    match inst.kind:
        case Copy(dest, src):
            InstOperandInfo(
                dest_key:      local_id_text(dest),
                operand_0_key: local_id_text(src),
                operand_1_key: ""
            )
        case BinOp(dest, op, lhs, rhs):
            InstOperandInfo(
                dest_key:      local_id_text(dest),
                operand_0_key: operand_text_key(lhs),
                operand_1_key: operand_text_key(rhs)
            )
        case Load(dest, ptr):
            InstOperandInfo(
                dest_key:      local_id_text(dest),
                operand_0_key: operand_text_key(ptr),
                operand_1_key: ""
            )
        case Intrinsic(dest_opt, name, args):
            val dest_k = if dest_opt.?: local_id_text(dest_opt.unwrap()) else: ""
            val arg0_k = if args.len() > 0: operand_text_key(args[0]) else: ""
            val arg1_k = if args.len() > 1: operand_text_key(args[1]) else: ""
            InstOperandInfo(
                dest_key:      dest_k,
                operand_0_key: arg0_k,
                operand_1_key: arg1_k
            )
        case _:
            InstOperandInfo(dest_key: "", operand_0_key: "", operand_1_key: "")

fn inst_kind_tag_matches(kind: MirInstKind, tag: text) -> bool:
    match kind:
        case Copy(_, _):               tag == "Copy"
        case BinOp(_, _, _, _):        tag == "BinOp"
        case Load(_, _):               tag == "Load"
        case Store(_, _):              tag == "Store"
        case Intrinsic(_, _, _):       tag == "Intrinsic"
        case Call(_, _, _):            tag == "Call"
        case Cast(_, _, _):            tag == "Cast"
        case UnaryOp(_, _, _):         tag == "UnaryOp"
        case _:                        false

# ============================================================================
# Pattern match
# ============================================================================

fn try_match_rule(rule: PatternRule, inst: MirInst) -> [WildcardBinding]?:
    """Try to match a single rule against a single instruction.

    Returns bindings if all slots match, nil otherwise.
    inst_count > 1 is out of scope for AC-7; skip if so.
    """
    if rule.pattern.inst_count != 1:
        return nil
    if rule.pattern.slots.len() == 0:
        return nil
    val slot = rule.pattern.slots[0]
    match_slot_against_inst(slot, inst, wildcard_bindings_empty())

# ============================================================================
# Rewrite application
# ============================================================================

fn apply_rewrite_to_inst(rule: PatternRule, bindings: [WildcardBinding], inst: MirInst) -> MirInst?:
    """Apply the rule's rewrite using the bound wildcard values.

    Returns nil if kind_tag is "Remove" (caller drops the instruction).
    Returns Some(inst) unchanged for any other kind_tag (structural rewrites
    require the MIR operand builder API, which is not yet complete).
    """
    val rw = rule.rewrite
    if rw.kind_tag == "Remove":
        return nil
    # Structural rewrites (BinOp, Copy, etc.) are deferred until the MIR
    # operand builder API lands.  Pass the original instruction through so
    # callers always get a valid result.
    Some(inst)

# ============================================================================
# Block-level pass
# ============================================================================

fn apply_rules_to_block(block: MirBlock, rules: [PatternRule]) -> MirBlock:
    """Apply all rules to each instruction in the block, rebuilding it.

    First matching rule wins; remaining rules are skipped for that instruction.
    """
    var new_insts: [MirInst] = []
    for inst in block.instructions:
        var handled = false
        for rule in rules:
            if not handled:
                val maybe_bindings = try_match_rule(rule, inst)
                if maybe_bindings.?:
                    val new_inst_opt = apply_rewrite_to_inst(rule, maybe_bindings.unwrap(), inst)
                    if val new_inst = new_inst_opt:
                        new_insts = new_insts.push(new_inst)
                    handled = true
        if not handled:
            new_insts = new_insts.push(inst)
    MirBlock(
        id:           block.id,
        label:        block.label,
        instructions: new_insts,
        terminator:   block.terminator
    )

# ============================================================================
# Function-level pass
# ============================================================================

fn apply_rules_to_function(func: MirFunction, rules: [PatternRule]) -> MirFunction:
    """Apply rule set to every block in the function."""
    if rules.len() == 0:
        return func
    var new_blocks: [MirBlock] = []
    for block in func.blocks:
        new_blocks = new_blocks.push(apply_rules_to_block(block, rules))
    MirFunction.with_blocks(func, new_blocks)

# ============================================================================
# Module-level pass entry point
# ============================================================================

fn pattern_rule_pass_run(rule_pass: PatternRulePass, module: MirModule) -> MirModule:
    """Run all loaded rule sets against every function in the module.

    Rules from all registered PatternRuleSets are merged and applied.
    Empty pass (no rule sets) returns module unchanged.
    """
    # Collect all rules across all sets
    var all_rules: [PatternRule] = []
    for rs in rule_pass.rule_sets:
        for rule in rs.rules:
            all_rules = all_rules.push(rule)

    if all_rules.len() == 0:
        return module

    var result = module
    for sym in module.functions.keys():
        result.functions[sym] = apply_rules_to_function(result.functions[sym], all_rules)
    result

fn pattern_rule_pass_new() -> PatternRulePass:
    PatternRulePass(rule_sets: [])

fn pattern_rule_pass_add_rule_set(rule_pass: PatternRulePass, rs: PatternRuleSet) -> PatternRulePass:
    PatternRulePass(rule_sets: rule_pass.rule_sets.push(rs))

fn pattern_rule_set_new(source: text, rules: [PatternRule]) -> PatternRuleSet:
    PatternRuleSet(source: source, rules: rules)

# ============================================================================
# Exports
# ============================================================================

export MirPatternSlot, MirPattern, MirRewrite, PatternRule, PatternRuleSet, PatternRulePass
export WildcardBinding, wildcard_bindings_empty, wildcard_lookup, wildcard_bind
export InstOperandInfo, inst_operand_info, inst_kind_tag_matches
export is_wildcard, operand_text_key, local_id_text
export try_match_rule, apply_rewrite_to_inst
export apply_rules_to_block, apply_rules_to_function
export pattern_rule_pass_run, pattern_rule_pass_new
export pattern_rule_pass_add_rule_set, pattern_rule_set_new
