# Target Optimization Planner — Orchestrator
#
# Builds an optimization plan by combining the target enable matrix,
# legality proofs, and profitability scoring.

use compiler.mir_opt.mir_opt.target_family.{TargetFeatureSet}
use compiler.mir_opt.mir_opt.instruction_family.{
    InstructionFamily, TargetEnableMatrix
}
use compiler.mir_opt.mir_opt.target_profitability.{profitability_score}
use compiler.mir.mir_instructions.{MirModule}

# ============================================================================
# Planning
# ============================================================================

pub fn plan_target_optimizations(fs: TargetFeatureSet, m: TargetEnableMatrix) -> [text]:
    """Build an optimization plan: list of enabled, profitable family IDs.

    Iterates all families in the matrix, keeps only those that are enabled
    and have a positive profitability score.
    Returns a list of family ID strings.
    """
    var plan: [text] = []
    var i = 0
    while i < m.families.len():
        val fam = m.families[i]
        val dec = m.decisions[i]
        if dec.enabled:
            val score = profitability_score(fam, fs)
            if score > 0:
                plan.push(fam.id)
        i = i + 1
    plan

pub fn optimize_module_with_target(module: MirModule, level: i64, triple: text, flags: [text]) -> MirModule:
    """Optimize a module with target-specific instruction selection.

    Stub: returns module unchanged. The planner logic is exercised
    through plan_target_optimizations; full MIR rewriting is a follow-up.
    """
    module
