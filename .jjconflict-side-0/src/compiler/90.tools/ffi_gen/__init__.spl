# FFI Generator Module
#
# Generate Simple FFI wrappers and Rust workspace artifacts from @Lib specs.
#
# Public API:
#   - use compiler.tools.ffi_gen.ffi_gen_workspace.{generate_workspace}
#   - use compiler.tools.ffi_gen.ffi_gen_workspace.{verify_workspace}
#   - use compiler.tools.ffi_gen.main.{CliOptions, RustEnvConfig}
#
# The canonical CLI entrypoint is:
#   simple ffi-gen

# All submodules are automatically available through the module system.
# FFI generation follows the SFFI pattern (Simple FFI) documented in
# doc/07_guide/sffi_patterns.md and emits generated Rust under build/rust/ffi_gen.

# Re-exported from ffi_gen_workspace.spl
export generate_workspace, generate_workspace_root_toml, generate_single_crate
export generate_crate_cargo_toml, generate_crate_lib_stub, verify_workspace

# Re-exported from main.spl
export CliOptions, RustEnvConfig, ffi_log_info, ffi_log_step, ffi_print_error
