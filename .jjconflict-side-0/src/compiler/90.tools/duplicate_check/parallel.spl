# File dispatch for duplicate detection.
#
# Keeps scan scheduling, batching, and worker selection separate from the
# matching logic so the detector can reuse the same shared cache and interner.

use compiler.tools.duplicate_check.config.{DuplicationConfig}
use compiler.tools.duplicate_check.cache.{TokenCacheManager}
use compiler.tools.duplicate_check.detector.{DuplicateBlock, find_duplicates_in_file, new_token_interner}
use compiler.tools.duplicate_check.incremental.{normalize_block_hashes}
use std.nogc_sync_mut.io.process_ops.{shell_output, eprint}

struct ParallelConfig:
    num_workers: i64        # Advisory worker count; 0 triggers CPU auto-detect
    batch_size: i64         # Number of files assigned per dispatch batch
    enabled: bool           # Enables the parallel scheduling path

fn default_parallel_config() -> ParallelConfig:
    ParallelConfig(
        num_workers: 0,      # Let the runner probe CPU count at startup
        batch_size: 10,      # Use a moderate file batch size by default
        enabled: true
    )

fn single_threaded_config() -> ParallelConfig:
    ParallelConfig(
        num_workers: 1,
        batch_size: 1,
        enabled: false
    )

fn detect_cpu_count() -> i64:
    val output = shell_output("nproc 2>/dev/null || echo 4", "").trim()
    val count = int(output)
    if count > 0:
        count
    else:
        4  # Default to 4 if detection fails

fn process_files_parallel(files: [text], config: ParallelConfig, cache_manager: TokenCacheManager, dup_config: DuplicationConfig) -> [DuplicateBlock]:
    val requested_workers = if config.num_workers > 0: config.num_workers else: detect_cpu_count()
    if dup_config.verbose and requested_workers > 1:
        eprint("[INFO] Parallel duplicate scan configured for {requested_workers} workers; runtime is executing the worker batches serially")

    var all_blocks: [DuplicateBlock] = []
    val interner = new_token_interner()
    var i = 0
    while i < files.len():
        val file = files[i]
        val blocks = find_duplicates_in_file(file, dup_config, cache_manager, interner)
        all_blocks.merge(blocks)
        i = i + 1
    normalize_block_hashes(all_blocks)
