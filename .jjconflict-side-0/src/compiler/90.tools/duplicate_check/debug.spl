# Debug flag helpers for duplicate detection.
# Reads `SIMPLE_DUP_DEBUG` on demand so the helper stays stateless.

use std.nogc_sync_mut.io.env_ops.{env_get}
use std.log.{debug}

fn get_debug_flag() -> bool:
    val env_debug = env_get("SIMPLE_DUP_DEBUG")
    env_debug == "1" or env_debug == "true"

fn init_debug():
    # Emit a single banner when duplicate-check tracing is enabled.
    if get_debug_flag():
        debug("dup", "Debug mode enabled (set SIMPLE_DUP_DEBUG=0 to disable)")

fn debug_log(message: text):
    # Keep the hot path simple: only emit messages when tracing is explicitly on.
    if get_debug_flag():
        debug("dup", message)

fn debug_log_progress(current: i64, total: i64, message: text):
    # Throttle progress output so long scans stay readable.
    if get_debug_flag():
        if current % 10 == 0 or current == total:
            debug("dup", "{message} ({current}/{total})")
