# MIR to HWIR — first-stage hardware lowering scaffold.

use compiler.mir.hwir.types.{HwModule, HwPort, HwSignal, HwRegister, HwClockDomain, HwCostModel}

class HwirLowerInput:
    """Minimal MIR function summary consumed by the HWIR foundation slice."""
    function_name: text
    is_hardware_tagged: bool
    input_count: i32
    output_count: i32
    local_count: i32
    clocked_local_count: i32

    static fn hardware(name: text, inputs: i32, outputs: i32, locals: i32, clocked: i32) -> HwirLowerInput:
        return HwirLowerInput(function_name: name, is_hardware_tagged: true, input_count: inputs, output_count: outputs, local_count: locals, clocked_local_count: clocked)

    static fn software(name: text) -> HwirLowerInput:
        return HwirLowerInput(function_name: name, is_hardware_tagged: false, input_count: 0, output_count: 0, local_count: 0, clocked_local_count: 0)

class HwirLowerResult:
    """Result of attempting MIR to HWIR lowering."""
    lowered: bool
    module: HwModule
    fallback_function: text
    reason: text

    me uses_fallback() -> bool:
        return not self.lowered

    static fn fallback(input: HwirLowerInput, reason: text) -> HwirLowerResult:
        return HwirLowerResult(lowered: false, module: HwModule.empty(input.function_name), fallback_function: input.function_name, reason: reason)

    static fn success(module: HwModule) -> HwirLowerResult:
        return HwirLowerResult(lowered: true, module: module, fallback_function: module.fallback_function, reason: "")

fn lower_mir_summary_to_hwir(input: HwirLowerInput) -> HwirLowerResult:
    """Lower a hardware-tagged MIR function summary into an HWIR module.

    Non-hardware functions deliberately keep the existing VHDL compile path as
    fallback.  Full MirFunction lowering will fill the counts from MIR locals
    and blocks once the compiler pipeline selects HWIR.
    """
    if not input.is_hardware_tagged:
        return HwirLowerResult.fallback(input, "function is not hardware tagged")

    val registers = input.clocked_local_count
    val signals = input.local_count - input.clocked_local_count
    val module = HwModule(
        name: input.function_name,
        profile: "balanced",
        port_count: input.input_count + input.output_count,
        signal_count: signals,
        register_count: registers,
        memory_count: 0,
        comb_op_count: 0,
        clock_domain_count: 1,
        fallback_function: input.function_name,
        cost: HwCostModel.empty()
    )
    return HwirLowerResult.success(module)

fn hwir_default_clock_domain() -> HwClockDomain:
    return HwClockDomain.default_domain()

fn hwir_input_port(name: text, type_name: text, bit_width: i32) -> HwPort:
    return HwPort.input(name, type_name, bit_width)

fn hwir_output_port(name: text, type_name: text, bit_width: i32) -> HwPort:
    return HwPort.output(name, type_name, bit_width)

fn hwir_local_to_signal(name: text, type_name: text, bit_width: i32) -> HwSignal:
    return HwSignal.comb(name, type_name, bit_width)

fn hwir_local_to_register(name: text, type_name: text, bit_width: i32, clock_domain: text) -> HwRegister:
    return HwRegister.create(name, type_name, bit_width, clock_domain)
