class DetectionResult:
    language: text
    confidence: f64

    static fn new(language: text, confidence: f64) -> DetectionResult:
        DetectionResult(language: language, confidence: confidence)

class LanguageDetector:
    dummy: i64

    static fn new() -> LanguageDetector:
        LanguageDetector(dummy: 0)

    fn detect(source: text) -> DetectionResult:
        if source.contains("fn "):
            return DetectionResult.new("simple", 0.9)
        if source.contains("def "):
            return DetectionResult.new("python", 0.9)
        if source.contains("let "):
            return DetectionResult.new("rust", 0.8)
        DetectionResult.new("unknown", 0.0)
