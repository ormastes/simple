# Core Simple — Token Kind Constants
#
# Shared core library for interpreter, loader, and compiler.
# Integer constants for token kinds. No enums (they require payload support).
#
# Naming: TOK_ prefix for all token kinds.
# Ranges:
#   1-19:   Literals
#   20-59:  Keywords
#   60-79:  Operators (arithmetic)
#   80-99:  Operators (comparison)
#   100-119: Operators (assignment)
#   120-139: Operators (logical/bitwise)
#   140-159: Delimiters
#   160-179: Punctuation
#   180-199: Indentation/Special

# ===== Literals =====
const TOK_INT_LIT: i64 = 1
const TOK_FLOAT_LIT: i64 = 2
const TOK_STRING_LIT: i64 = 3
const TOK_BOOL_LIT: i64 = 4
const TOK_NIL_LIT: i64 = 5
const TOK_IDENT: i64 = 6
const TOK_SUFFIXED_INT: i64 = 7
const TOK_SUFFIXED_FLOAT: i64 = 8

# ===== Keywords — Declarations =====
const TOK_KW_FN: i64 = 20
const TOK_KW_VAL: i64 = 21
const TOK_KW_VAR: i64 = 22
const TOK_KW_STRUCT: i64 = 23
const TOK_KW_ENUM: i64 = 24
const TOK_KW_EXTERN: i64 = 25
const TOK_KW_EXPORT: i64 = 26
const TOK_KW_USE: i64 = 27
const TOK_KW_IMPORT: i64 = 28
const TOK_KW_PUB: i64 = 29
const TOK_KW_STATIC: i64 = 30
const TOK_KW_CLASS: i64 = 31
const TOK_KW_IMPL: i64 = 32
const TOK_KW_TRAIT: i64 = 33
const TOK_KW_IMPLEMENTS: i64 = 61
const TOK_KW_ME: i64 = 34
const TOK_KW_TYPE: i64 = 35
const TOK_KW_ASM: i64 = 36 # clang-depend passthrough

# ===== Keywords — Control Flow =====
const TOK_KW_IF: i64 = 40
const TOK_KW_ELSE: i64 = 41
const TOK_KW_ELIF: i64 = 42
const TOK_KW_MATCH: i64 = 43
const TOK_KW_CASE: i64 = 44
const TOK_KW_FOR: i64 = 45
const TOK_KW_WHILE: i64 = 46
const TOK_KW_BREAK: i64 = 47
const TOK_KW_CONTINUE: i64 = 48
const TOK_KW_RETURN: i64 = 49
const TOK_KW_IN: i64 = 50
const TOK_KW_LOOP: i64 = 51
const TOK_KW_PASS: i64 = 52
const TOK_KW_ASYNC: i64 = 53
const TOK_KW_AWAIT: i64 = 54
const TOK_KW_YIELD: i64 = 37
const TOK_KW_SPAWN: i64 = 197

# ===== Keywords — Expressions =====
const TOK_KW_AND: i64 = 55
const TOK_KW_OR: i64 = 56
const TOK_KW_NOT: i64 = 57
const TOK_KW_TRUE: i64 = 58
const TOK_KW_FALSE: i64 = 59
const TOK_KW_SELF: i64 = 38
const TOK_KW_IS: i64 = 39

# ===== Operators — Arithmetic =====
const TOK_PLUS: i64 = 60
const TOK_MINUS: i64 = 61
const TOK_STAR: i64 = 62
const TOK_SLASH: i64 = 63
const TOK_PERCENT: i64 = 64
const TOK_STAR_STAR: i64 = 65
const TOK_SHL: i64 = 66  # <<
const TOK_SHR: i64 = 67  # >>

# ===== Operators — Comparison =====
const TOK_EQ: i64 = 80
const TOK_NOT_EQ: i64 = 81
const TOK_LT: i64 = 82
const TOK_GT: i64 = 83
const TOK_LT_EQ: i64 = 84
const TOK_GT_EQ: i64 = 85
const TOK_LT_GENERIC: i64 = 86  # < in generic type context (e.g., class Box<T>)

# ===== Operators — Assignment =====
const TOK_ASSIGN: i64 = 100
const TOK_PLUS_EQ: i64 = 101
const TOK_MINUS_EQ: i64 = 102
const TOK_STAR_EQ: i64 = 103
const TOK_SLASH_EQ: i64 = 104
const TOK_PERCENT_EQ: i64 = 105
const TOK_WALRUS: i64 = 106  # := operator

# ===== Operators — Logical/Bitwise =====
const TOK_AMPERSAND: i64 = 120
const TOK_PIPE: i64 = 121
const TOK_CARET: i64 = 122
const TOK_TILDE: i64 = 123

# ===== Operators — Special =====
const TOK_QUESTION: i64 = 130
const TOK_QUESTION_DOT: i64 = 131
const TOK_QUESTION_QUESTION: i64 = 132
const TOK_DOT_QUESTION: i64 = 133
const TOK_BANG: i64 = 134

# ===== Delimiters =====
const TOK_LPAREN: i64 = 140
const TOK_RPAREN: i64 = 141
const TOK_LBRACE: i64 = 142
const TOK_RBRACE: i64 = 143
const TOK_LBRACKET: i64 = 144
const TOK_RBRACKET: i64 = 145

# ===== Punctuation =====
const TOK_COMMA: i64 = 160
const TOK_COLON: i64 = 161
const TOK_COLON_COLON: i64 = 162
const TOK_SEMICOLON: i64 = 163
const TOK_DOT: i64 = 164
const TOK_DOT_DOT: i64 = 165
const TOK_DOT_DOT_EQ: i64 = 166
const TOK_ARROW: i64 = 167
const TOK_FAT_ARROW: i64 = 168
const TOK_UNDERSCORE: i64 = 169
const TOK_HASH: i64 = 170

# ===== Pipeline =====
const TOK_PIPE_FORWARD: i64 = 175
const TOK_COMPOSE: i64 = 176

# ===== Indentation/Special =====
const TOK_NEWLINE: i64 = 180
const TOK_INDENT: i64 = 181
const TOK_DEDENT: i64 = 182

# ===== Keywords — Pass Variants =====
const TOK_KW_PASS_TODO: i64 = 183
const TOK_KW_PASS_DO_NOTHING: i64 = 184
const TOK_KW_PASS_DN: i64 = 185

const TOK_EOF: i64 = 190
const TOK_ERROR: i64 = 191

# ===== New Keywords (186-189, 194+) =====
const TOK_KW_DEFER: i64 = 186       # defer statement
const TOK_KW_ERRDEFER: i64 = 187    # errdefer statement
const TOK_KW_CONST: i64 = 188       # const binding
const TOK_KW_WHERE: i64 = 189       # where clause

# ===== New Token Kinds (192+) =====
const TOK_LABEL: i64 = 192          # 'label tokens (for labeled break/continue)
const TOK_BACKTICK_IDENT: i64 = 193 # `atom tokens (symbol/atom literals)
const TOK_KW_LAZY: i64 = 194        # lazy keyword
const TOK_KW_DO: i64 = 195          # do block
const TOK_KW_EXTEND: i64 = 196      # extend declaration
const TOK_KW_NEWTYPE: i64 = 198     # newtype wrapper
const TOK_KW_DYN: i64 = 199         # dyn trait type
const TOK_KW_KEYOF: i64 = 200       # keyof type operator
const TOK_KW_STATIC_FOR: i64 = 201  # static_for compile-time loop unrolling
const TOK_KW_COMPTIME: i64 = 202    # comptime expression evaluation
const TOK_KW_MIXIN: i64 = 203       # mixin code generation
const TOK_KW_BIND: i64 = 204    # bind x = expr (monadic bind in CE blocks)
const TOK_KW_CE: i64 = 205      # ce NAME: named computation expression block
const TOK_KW_RECEIVE: i64 = 206 # receive: block (Erlang mailbox receive)
const TOK_KW_AFTER: i64 = 207   # after TIMEOUT: arm inside receive:
const TOK_KW_INTERFACE: i64 = 208  # interface declaration (dynamic-only trait)
const TOK_KW_BITFIELD: i64 = 209   # bitfield packed integer fields
const TOK_AMP_COLON: i64 = 210     # &: method reference operator
const TOK_KW_NEW: i64 = 211        # new allocation expression
const TOK_KW_CLI: i64 = 212        # cli declarative arg parsing block
const TOK_KW_GENERIC: i64 = 213    # generic type parameter declaration
const TOK_KW_LIMITS: i64 = 214     # limits constraint keyword
const TOK_KW_CANDIDATES: i64 = 215 # candidates constraint keyword

# ===== Keywords — AOP =====
const TOK_KW_ON: i64 = 216         # on pc{...} use handler form
const TOK_KW_FORBID: i64 = 217     # forbid pc{...} "message"
const TOK_KW_ALLOW: i64 = 218      # allow pc{...} "message"
const TOK_KW_NEWUNIT: i64 = 219    # nominal custom primitive wrapper with unit suffix

# ===== Aliases (backward compat with lexer/parser) =====
const TOK_AND: i64 = 55
const TOK_OR: i64 = 56
const TOK_NOT: i64 = 57
const TOK_KW_NIL: i64 = 5
const TOK_NEQ: i64 = 81
const TOK_LEQ: i64 = 84
const TOK_GEQ: i64 = 85
const TOK_DOUBLE_STAR: i64 = 65
const TOK_DOUBLE_QUESTION: i64 = 132
const TOK_DOTDOT: i64 = 165
const TOK_DOTDOT_EQ: i64 = 166
const TOK_PLUS_ASSIGN: i64 = 101
const TOK_MINUS_ASSIGN: i64 = 102
const TOK_STAR_ASSIGN: i64 = 103
const TOK_SLASH_ASSIGN: i64 = 104
const TOK_AT: i64 = 171
const TOK_HASH_LBRACKET: i64 = 172
const TOK_DOTDOTDOT: i64 = 173

# ===== Token Kind Name Lookup =====
fn tok_kind_name(kind: i64) -> text:
    if kind == TOK_INT_LIT: return "IntLit"
    if kind == TOK_FLOAT_LIT: return "FloatLit"
    if kind == TOK_STRING_LIT: return "StringLit"
    if kind == TOK_BOOL_LIT: return "BoolLit"
    if kind == TOK_NIL_LIT: return "NilLit"
    if kind == TOK_IDENT: return "Ident"
    if kind == TOK_SUFFIXED_INT: return "SuffixedInt"
    if kind == TOK_SUFFIXED_FLOAT: return "SuffixedFloat"
    if kind == TOK_KW_FN: return "fn"
    if kind == TOK_KW_VAL: return "val"
    if kind == TOK_KW_VAR: return "var"
    if kind == TOK_KW_STRUCT: return "struct"
    if kind == TOK_KW_ENUM: return "enum"
    if kind == TOK_KW_EXTERN: return "extern"
    if kind == TOK_KW_EXPORT: return "export"
    if kind == TOK_KW_USE: return "use"
    if kind == TOK_KW_IMPORT: return "import"
    if kind == TOK_KW_PUB: return "pub"
    if kind == TOK_KW_STATIC: return "static"
    if kind == TOK_KW_CLASS: return "class"
    if kind == TOK_KW_IMPL: return "impl"
    if kind == TOK_KW_TRAIT: return "trait"
    if kind == TOK_KW_IMPLEMENTS: return "implements"
    if kind == TOK_KW_ME: return "me"
    if kind == TOK_KW_TYPE: return "type"
    if kind == TOK_KW_ASM: return "asm"
    if kind == TOK_KW_IF: return "if"
    if kind == TOK_KW_ELSE: return "else"
    if kind == TOK_KW_ELIF: return "elif"
    if kind == TOK_KW_MATCH: return "match"
    if kind == TOK_KW_CASE: return "case"
    if kind == TOK_KW_FOR: return "for"
    if kind == TOK_KW_WHILE: return "while"
    if kind == TOK_KW_BREAK: return "break"
    if kind == TOK_KW_CONTINUE: return "continue"
    if kind == TOK_KW_RETURN: return "return"
    if kind == TOK_KW_IN: return "in"
    if kind == TOK_KW_LOOP: return "loop"
    if kind == TOK_KW_PASS: return "pass"
    if kind == TOK_KW_PASS_TODO: return "pass_todo"
    if kind == TOK_KW_PASS_DO_NOTHING: return "pass_do_nothing"
    if kind == TOK_KW_PASS_DN: return "pass_dn"
    if kind == TOK_KW_ASYNC: return "async"
    if kind == TOK_KW_AWAIT: return "await"
    if kind == TOK_KW_YIELD: return "yield"
    if kind == TOK_KW_SPAWN: return "spawn"
    if kind == TOK_KW_AND: return "and"
    if kind == TOK_KW_OR: return "or"
    if kind == TOK_KW_NOT: return "not"
    if kind == TOK_KW_TRUE: return "true"
    if kind == TOK_KW_FALSE: return "false"
    if kind == TOK_KW_SELF: return "self"
    if kind == TOK_KW_IS: return "is"
    if kind == TOK_PLUS: return "+"
    if kind == TOK_MINUS: return "-"
    if kind == TOK_STAR: return "*"
    if kind == TOK_SLASH: return "/"
    if kind == TOK_PERCENT: return "%"
    if kind == TOK_STAR_STAR: return "**"
    if kind == TOK_EQ: return "=="
    if kind == TOK_NOT_EQ: return "!="
    if kind == TOK_LT: return "<"
    if kind == TOK_LT_GENERIC: return "<"
    if kind == TOK_GT: return ">"
    if kind == TOK_LT_EQ: return "<="
    if kind == TOK_GT_EQ: return ">="
    if kind == TOK_ASSIGN: return "="
    if kind == TOK_PLUS_EQ: return "+="
    if kind == TOK_MINUS_EQ: return "-="
    if kind == TOK_STAR_EQ: return "*="
    if kind == TOK_SLASH_EQ: return "/="
    if kind == TOK_PERCENT_EQ: return "%="
    if kind == TOK_WALRUS: return ":="
    if kind == TOK_AMPERSAND: return "&"
    if kind == TOK_PIPE: return "|"
    if kind == TOK_CARET: return "^"
    if kind == TOK_TILDE: return "~"
    if kind == TOK_QUESTION: return "?"
    if kind == TOK_QUESTION_DOT: return "?."
    if kind == TOK_QUESTION_QUESTION: return "??"
    if kind == TOK_DOT_QUESTION: return ".?"
    if kind == TOK_BANG: return "!"
    if kind == TOK_LPAREN: return "("
    if kind == TOK_RPAREN: return ")"
    if kind == TOK_LBRACE: return "{"
    if kind == TOK_RBRACE: return "}"
    if kind == TOK_LBRACKET: return "["
    if kind == TOK_RBRACKET: return "]"
    if kind == TOK_COMMA: return ","
    if kind == TOK_COLON: return ":"
    if kind == TOK_COLON_COLON: return "::"
    if kind == TOK_SEMICOLON: return ";"
    if kind == TOK_DOT: return "."
    if kind == TOK_DOT_DOT: return ".."
    if kind == TOK_DOT_DOT_EQ: return "..="
    if kind == TOK_ARROW: return "->"
    if kind == TOK_FAT_ARROW: return "=>"
    if kind == TOK_UNDERSCORE: return "_"
    if kind == TOK_HASH: return "#"
    if kind == TOK_PIPE_FORWARD: return "|>"
    if kind == TOK_COMPOSE: return ">>"
    if kind == TOK_NEWLINE: return "Newline"
    if kind == TOK_INDENT: return "Indent"
    if kind == TOK_DEDENT: return "Dedent"
    if kind == TOK_EOF: return "EOF"
    if kind == TOK_ERROR: return "Error"
    if kind == TOK_KW_DEFER: return "defer"
    if kind == TOK_KW_ERRDEFER: return "errdefer"
    if kind == TOK_KW_CONST: return "const"
    if kind == TOK_KW_WHERE: return "where"
    if kind == TOK_LABEL: return "Label"
    if kind == TOK_BACKTICK_IDENT: return "Atom"
    if kind == TOK_KW_LAZY: return "lazy"
    if kind == TOK_KW_DO: return "do"
    if kind == TOK_KW_EXTEND: return "extend"
    if kind == TOK_KW_SPAWN: return "spawn"
    if kind == TOK_KW_NEWTYPE: return "newtype"
    if kind == TOK_KW_NEWUNIT: return "newunit"
    if kind == TOK_KW_DYN: return "dyn"
    if kind == TOK_KW_KEYOF: return "keyof"
    if kind == TOK_KW_STATIC_FOR: return "static_for"
    if kind == TOK_KW_COMPTIME: return "comptime"
    if kind == TOK_KW_MIXIN: return "mixin"
    if kind == TOK_KW_BIND: return "bind"
    if kind == TOK_KW_CE: return "ce"
    if kind == TOK_KW_RECEIVE: return "receive"
    if kind == TOK_KW_AFTER: return "after"
    if kind == TOK_KW_INTERFACE: return "interface"
    if kind == TOK_KW_BITFIELD: return "bitfield"
    if kind == TOK_AMP_COLON: return "&:"
    if kind == TOK_KW_NEW: return "new"
    if kind == TOK_KW_CLI: return "cli"
    if kind == TOK_KW_GENERIC: return "generic"
    if kind == TOK_KW_LIMITS: return "limits"
    if kind == TOK_KW_CANDIDATES: return "candidates"
    if kind == TOK_KW_ON: return "on"
    if kind == TOK_KW_FORBID: return "forbid"
    if kind == TOK_KW_ALLOW: return "allow"
    "Unknown({kind})"

# ===== Keyword Lookup =====
fn keyword_lookup(name: text) -> i64:
    if name == "fn": return TOK_KW_FN
    if name == "val": return TOK_KW_VAL
    if name == "var": return TOK_KW_VAR
    if name == "struct": return TOK_KW_STRUCT
    if name == "enum": return TOK_KW_ENUM
    if name == "extern": return TOK_KW_EXTERN
    if name == "export": return TOK_KW_EXPORT
    if name == "use": return TOK_KW_USE
    if name == "import": return TOK_KW_IMPORT
    if name == "pub": return TOK_KW_PUB
    if name == "static": return TOK_KW_STATIC
    if name == "class": return TOK_KW_CLASS
    if name == "impl": return TOK_KW_IMPL
    if name == "trait": return TOK_KW_TRAIT
    if name == "implements": return TOK_KW_IMPLEMENTS
    if name == "me": return TOK_KW_ME
    if name == "type": return TOK_KW_TYPE
    if name == "asm": return TOK_KW_ASM
    if name == "if": return TOK_KW_IF
    if name == "else": return TOK_KW_ELSE
    if name == "elif": return TOK_KW_ELIF
    if name == "match": return TOK_KW_MATCH
    if name == "case": return TOK_KW_CASE
    if name == "for": return TOK_KW_FOR
    if name == "while": return TOK_KW_WHILE
    if name == "break": return TOK_KW_BREAK
    if name == "continue": return TOK_KW_CONTINUE
    if name == "return": return TOK_KW_RETURN
    if name == "in": return TOK_KW_IN
    if name == "loop": return TOK_KW_LOOP
    if name == "pass": return TOK_KW_PASS
    if name == "pass_todo": return TOK_KW_PASS_TODO
    if name == "pass_do_nothing": return TOK_KW_PASS_DO_NOTHING
    if name == "pass_dn": return TOK_KW_PASS_DN
    if name == "async": return TOK_KW_ASYNC
    if name == "await": return TOK_KW_AWAIT
    if name == "yield": return TOK_KW_YIELD
    if name == "spawn": return TOK_KW_SPAWN
    if name == "and": return TOK_KW_AND
    if name == "or": return TOK_KW_OR
    if name == "not": return TOK_KW_NOT
    if name == "true": return TOK_KW_TRUE
    if name == "false": return TOK_KW_FALSE
    if name == "nil": return TOK_NIL_LIT
    if name == "self": return TOK_KW_SELF
    if name == "is": return TOK_KW_IS
    if name == "defer": return TOK_KW_DEFER
    if name == "errdefer": return TOK_KW_ERRDEFER
    if name == "const": return TOK_KW_CONST
    if name == "where": return TOK_KW_WHERE
    if name == "lazy": return TOK_KW_LAZY
    if name == "do": return TOK_KW_DO
    if name == "extend": return TOK_KW_EXTEND
    if name == "newtype": return TOK_KW_NEWTYPE
    if name == "newunit": return TOK_KW_NEWUNIT
    if name == "dyn": return TOK_KW_DYN
    if name == "keyof": return TOK_KW_KEYOF
    if name == "static_for": return TOK_KW_STATIC_FOR
    if name == "comptime": return TOK_KW_COMPTIME
    if name == "mixin": return TOK_KW_MIXIN
    if name == "bind": return TOK_KW_BIND
    if name == "ce": return TOK_KW_CE
    if name == "receive": return TOK_KW_RECEIVE
    if name == "after": return TOK_KW_AFTER
    if name == "interface": return TOK_KW_INTERFACE
    if name == "bitfield": return TOK_KW_BITFIELD
    if name == "new": return TOK_KW_NEW
    if name == "cli": return TOK_KW_CLI
    if name == "on": return TOK_KW_ON
    if name == "forbid": return TOK_KW_FORBID
    if name == "allow": return TOK_KW_ALLOW
    TOK_IDENT

# ===== Operator Precedence =====
fn tok_precedence(kind: i64) -> i64:
    if kind == TOK_ASSIGN: return 1
    if kind == TOK_PLUS_EQ: return 1
    if kind == TOK_MINUS_EQ: return 1
    if kind == TOK_STAR_EQ: return 1
    if kind == TOK_SLASH_EQ: return 1
    if kind == TOK_PERCENT_EQ: return 1
    if kind == TOK_WALRUS: return 1
    if kind == TOK_KW_OR: return 2
    if kind == TOK_KW_AND: return 3
    if kind == TOK_PIPE: return 4
    if kind == TOK_CARET: return 5
    if kind == TOK_AMPERSAND: return 6
    if kind == TOK_EQ: return 7
    if kind == TOK_NOT_EQ: return 7
    if kind == TOK_LT: return 8
    if kind == TOK_GT: return 8
    if kind == TOK_LT_EQ: return 8
    if kind == TOK_GT_EQ: return 8
    if kind == TOK_KW_IS: return 8
    if kind == TOK_KW_IN: return 8
    if kind == TOK_DOT_DOT: return 9
    if kind == TOK_DOT_DOT_EQ: return 9
    if kind == TOK_PLUS: return 10
    if kind == TOK_MINUS: return 10
    if kind == TOK_STAR: return 11
    if kind == TOK_SLASH: return 11
    if kind == TOK_PERCENT: return 11
    if kind == TOK_STAR_STAR: return 12
    if kind == TOK_PIPE_FORWARD: return 0
    if kind == TOK_COMPOSE: return 0
    0

fn tok_is_right_assoc(kind: i64) -> bool:
    if kind == TOK_STAR_STAR: return true
    if kind == TOK_ASSIGN: return true
    if kind == TOK_PLUS_EQ: return true
    if kind == TOK_MINUS_EQ: return true
    if kind == TOK_STAR_EQ: return true
    if kind == TOK_SLASH_EQ: return true
    if kind == TOK_PERCENT_EQ: return true
    if kind == TOK_WALRUS: return true
    false

# ===== Classification Helpers =====
fn tok_is_literal(kind: i64) -> bool:
    if kind == TOK_INT_LIT: return true
    if kind == TOK_FLOAT_LIT: return true
    if kind == TOK_STRING_LIT: return true
    if kind == TOK_BOOL_LIT: return true
    if kind == TOK_NIL_LIT: return true
    if kind == TOK_SUFFIXED_INT: return true
    if kind == TOK_SUFFIXED_FLOAT: return true
    false

fn tok_is_comparison(kind: i64) -> bool:
    if kind == TOK_EQ: return true
    if kind == TOK_NOT_EQ: return true
    if kind == TOK_LT: return true
    if kind == TOK_GT: return true
    if kind == TOK_LT_EQ: return true
    if kind == TOK_GT_EQ: return true
    false

fn tok_is_assignment(kind: i64) -> bool:
    if kind == TOK_ASSIGN: return true
    if kind == TOK_PLUS_EQ: return true
    if kind == TOK_MINUS_EQ: return true
    if kind == TOK_STAR_EQ: return true
    if kind == TOK_SLASH_EQ: return true
    if kind == TOK_PERCENT_EQ: return true
    if kind == TOK_WALRUS: return true
    false

fn tok_is_additive(kind: i64) -> bool:
    if kind == TOK_PLUS: return true
    if kind == TOK_MINUS: return true
    false

fn tok_is_multiplicative(kind: i64) -> bool:
    if kind == TOK_STAR: return true
    if kind == TOK_SLASH: return true
    if kind == TOK_PERCENT: return true
    false
