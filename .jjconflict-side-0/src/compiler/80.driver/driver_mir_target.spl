# Driver-owned MIR target context derivation.
#
# The driver is the single boundary that may read build state. MIR lowering
# receives the resulting immutable context and never reads environment values
# or probes backend tools itself.

use compiler.common.driver_core_types.{CompileOptions}
use compiler.common.mir_target_context.{MirTargetContext}
use compiler.backend.backend.backend_helpers.{get_effective_backend_name}
use compiler.backend.backend.mir_target_context_provider.{backend_mir_target_context}

fn driver_mir_target_context(options: CompileOptions) -> MirTargetContext:
    val effective_backend = get_effective_backend_name(options.backend, options.release)
    backend_mir_target_context(effective_backend)
