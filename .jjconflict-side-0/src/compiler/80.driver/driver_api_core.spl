#![allow(export_outside_init)]
# Driver API Core - re-exports from dependency tiers.
# Kept for backward compatibility with internal callers.
#
# The original monolithic implementation has been split into 6 dependency tiers:
#   Tier 0: driver_api_types.spl       - externs, find_runtime_lib_dir, helpers
#   Tier 1: driver_api_interpret.spl   - interpret_file, try_load_smf_cached
#   Tier 2: driver_api_compile_single.spl - compile_file, compile_files, jit, check, sdn, smf
#   Tier 3: driver_api_codegen_backends.spl - aot_file, aot_c_file, aot_llvm_file, aot_cuda, aot_vhdl
#   Tier 4: driver_api_native_single.spl - aot_native_file_with_backend, aot_llvm_native_file
#   Tier 5: driver_api_project_build.spl - aot_native_project_with_backend, generate_headers, aot_shared_library

export use compiler.driver.driver_api_types.{find_runtime_lib_dir, _combine_driver_api_process_error}
export use compiler.driver.driver_api_interpret.{interpret_file, try_load_smf_cached}
export use compiler.driver.driver_api_compile_single.{compile_file, compile_files, jit_file, check_file, parse_sdn_file, compile_to_smf}
export use compiler.driver.driver_api_codegen_backends.{aot_file, aot_c_file, aot_llvm_file, aot_cuda_file, aot_vhdl_file}
export use compiler.driver.driver_api_native_single.{aot_native_file_with_backend, aot_llvm_native_file}
export use compiler.driver.driver_api_project_build.{aot_native_project_with_backend, generate_headers, aot_shared_library}
