#![allow(export_outside_init)]
use compiler.driver.driver_bootstrap_helpers.{compiler_driver_create, compiler_driver_run_compile}
use compiler.common.driver_core_types.{CompileMode, CompileOptions, CompileResult, OutputFormat, driver_core_compile_options_default}

fn aot_native_file_with_backend(path: text, output: text, backend: text) -> CompileResult:
    var options = driver_core_compile_options_default()
    options.input_files = [path]
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = OutputFormat.Native
    options.backend = backend
    options.release = true
    options.optimize = true
    options.opt_level = 3
    val driver = compiler_driver_create(options)
    compiler_driver_run_compile(driver)

fn aot_native_project_with_backend(source_dirs: [text], entry: text, output: text, backend: text, strip: bool) -> CompileResult:
    var options = driver_core_compile_options_default()
    var inputs: [text] = []
    for dir in source_dirs:
        inputs = inputs.push(dir)
    inputs = inputs.push(entry)
    options.input_files = inputs
    options.mode = CompileMode.Aot
    options.output_file = Some(output)
    options.output_format = OutputFormat.Native
    options.backend = backend
    options.release = true
    options.optimize = true
    options.opt_level = 3
    val driver = compiler_driver_create(options)
    compiler_driver_run_compile(driver)

export aot_native_file_with_backend
export aot_native_project_with_backend
