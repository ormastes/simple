# CUDA Backend - NVIDIA CUDA/PTX Code Generation
#
# Compiles MIR to CUDA PTX assembly code.
# PTX can be JIT-compiled by NVIDIA driver or assembled offline.

use compiler.mir.mir_data.*
use compiler.mir.mir_instructions.{MirModule, MirFunction, MirBlock}
use compiler.backend.backend_api.*
use compiler.backend.backend.backend_types.{compileerror_backend_error}
use compiler.backend.spec_const_registry.{spec_const_resolve}
use compiler.backend.gpu_backend_metadata.{GpuBackendKernelPlan, gpu_backend_accepts_kernel, gpu_backend_plan_module_kernels, gpu_backend_supports_target}
use compiler.backend.codegen_types.{Codegen, CodegenOutput, CodegenOutputKind}
use compiler.backend.gpu_codegen_types.{GpuCodegen, GpuBarrierScope}
use compiler.backend.cuda_type_mapper.{CudaTypeMapper, cuda_type_mapper_create_sm}
use compiler.backend.cuda.ptx_builder.{PtxBuilder}
use compiler.hir.hir_types.MemorySpace
use compiler.backend.backend.common.type_mapper.{PrimitiveType}

# ============================================================================
# CUDA Backend
# ============================================================================

class CudaBackend:
    """
    CUDA backend for GPU code generation.

    Compiles MIR modules to PTX assembly code for NVIDIA GPUs.
    PTX is a virtual instruction set that gets JIT-compiled to
    native GPU machine code (SASS) by the NVIDIA driver.

    Features:
    - Full MIR instruction support
    - Kernel function generation
    - Device function generation
    - Shared memory allocation
    - Atomic operations
    - Synchronization barriers

    Usage:
        val backend = CudaBackend.create((8, 6))  # SM 8.6
        val result = backend.compile(mir_module)
    """

    type_mapper: CudaTypeMapper
    compute_capability: (i64, i64)
    options: CompileOptions
    function_signatures: Dict<text, MirSignature>

    static fn create(compute_cap: (i64, i64)) -> CudaBackend:
        """Create CUDA backend for specific compute capability."""
        val base = compileoptions_default_options()
        val opts = CompileOptions(target: CodegenTarget.CudaPtx, opt_level: base.opt_level, debug_info: base.debug_info, emit_assembly: base.emit_assembly, emit_llvm_ir: base.emit_llvm_ir, emit_mir: base.emit_mir, verify_output: base.verify_output, target_opt_ctx: base.target_opt_ctx, backend_kind: base.backend_kind, allowed_families: base.allowed_families)
        CudaBackend(
            type_mapper: cuda_type_mapper_create_sm(compute_cap.0, compute_cap.1),
            compute_capability: compute_cap,
            options: opts,
            function_signatures: {}
        )

    static fn create_with_options(compute_cap: (i64, i64), opts: CompileOptions) -> CudaBackend:
        """Create CUDA backend with custom options."""
        CudaBackend(
            type_mapper: cuda_type_mapper_create_sm(compute_cap.0, compute_cap.1),
            compute_capability: compute_cap,
            options: opts,
            function_signatures: {}
        )

    static fn for_target(target: CodegenTarget) -> Result<CudaBackend, CompileError>:
        """Create CUDA backend from target."""
        if target == CodegenTarget.CudaPtx:
            return Ok(CudaBackend.create((8, 6)))
        Err(compileerror_backend_error(
            BackendKind.Cuda,
            "Target is not a CUDA target"
        ))

    me compile(module: MirModule) -> Result<CudaCompiledModule, CompileError>:
        """Compile MIR module to PTX."""
        val plan: GpuBackendKernelPlan = CudaBackend.plan_module_kernels(module)
        if not plan.ready:
            return Err(compileerror_backend_error(BackendKind.Cuda, plan.diagnostic))

        val builder = PtxBuilder.create(self.compute_capability)

        # Emit module header
        builder.emit_module_header(module.name)

        # Collect kernel functions
        var kernels: [CudaKernel] = []
        var device_functions: [CudaDeviceFunction] = []

        # Resolve static direct calls from module declarations instead of
        # destructuring FuncPtr payloads inside a nested MirOperand match. The
        # bootstrap interpreter currently misbinds that payload accessor.
        self.function_signatures = {}
        for signature_symbol in module.functions.keys():
            val signature_func: MirFunction = module.functions[signature_symbol]
            self.function_signatures[signature_func.name] = signature_func.signature

        # BUG-001 fix: Use keys()-based iteration (for (k,v) in dict is broken in compiled mode)
        for symbol in module.functions.keys():
            val func: MirFunction = module.functions[symbol]
            if not CudaBackend.accepts_gpu_kernel_target(func):
                return Err(compileerror_backend_error(
                    BackendKind.Cuda,
                    "CUDA backend cannot compile GPU kernel '{func.name}' with target '{func.gpu_target}'"
                ))
            val result = self.compile_function(builder, func)
            match result:
                case Ok(kern):
                    if kern.is_kernel:
                        kernels = kernels.push(CudaKernel(
                            name: kern.name,
                            ptx: kern.ptx,
                            param_count: func.signature.params.len()
                        ))
                    else:
                        device_functions = device_functions.push(CudaDeviceFunction(
                            name: kern.name,
                            ptx: kern.ptx
                        ))
                case Err(e):
                    return Err(e)

        val ptx_code = builder.build()

        Ok(CudaCompiledModule(
            name: module.name,
            ptx: ptx_code,
            kernels: kernels,
            device_functions: device_functions,
            compute_capability: self.compute_capability
        ))

    me compile_function(builder: PtxBuilder, func: MirFunction) -> Result<CompiledFunction, CompileError>:
        """Compile a single function."""
        val is_kernel = self.is_kernel_function(func)

        for local in func.locals:
            if not self.cuda_type_supported(local.type_):
                return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA backend does not support local type: {local.type_.kind}"))

        if is_kernel:
            builder.emit_kernel_entry(func.name, func.locals)
        else:
            builder.emit_device_function(
                func.name,
                func.locals,
                func.signature.return_type
            )

        # Emit register declarations for locals
        for local in func.locals:
            match local.kind:
                case Arg(_):
                    val reg = "%r{local.id.id}"
                    match local.type_.kind:
                        case Bool:
                            builder.emit_pred_decl(reg)
                            match local.kind:
                                case Arg(index): builder.emit_bool_param_load(reg, index)
                                case _: ()
                        case _:
                            val prim_ty = self.mir_type_to_primitive(local.type_)
                            builder.emit_reg_decl(reg, prim_ty)
                            match local.kind:
                                case Arg(index): builder.emit_param_load(reg, prim_ty, index)
                                case _: ()
                case Var | Temp | Return:
                    self.emit_local_decl(builder, local)

        # Compile each basic block
        for block in func.blocks:
            val label = "BB{block.id.id}"
            builder.emit_label(label)

            for inst in block.instructions:
                val result = self.compile_instruction(builder, inst, func)
                if result.is_err():
                    return Err(result.unwrap_err())

            val terminator_result = self.compile_terminator(builder, block.terminator, is_kernel, func.signature.return_type)
            if terminator_result.is_err():
                return Err(terminator_result.unwrap_err())

        if is_kernel:
            builder.emit_kernel_end()
        else:
            builder.emit_function_end()

        Ok(CompiledFunction(
            name: func.name,
            ptx: "",  # PTX is accumulated in builder
            is_kernel: is_kernel
        ))

    fn is_kernel_function(func: MirFunction) -> bool:
        """Check if function should be compiled as a kernel."""
        if func.is_kernel:
            return true
        # Fallback: heuristic for functions with GPU instructions
        for block in func.blocks:
            for inst in block.instructions:
                match inst.kind:
                    case GpuGlobalId(_, _) | GpuLocalId(_, _) | GpuBlockId(_, _) | GpuBarrier(_) | GpuSharedAlloc(_, _, _) | GpuAtomicOp(_, _, _, _) | GpuAtomicCas(_, _, _, _):
                        return true
                    case _:
                        ()
        false

    static fn accepts_gpu_kernel(func: MirFunction) -> bool:
        gpu_backend_accepts_kernel(BackendKind.Cuda, func)

    static fn accepts_gpu_kernel_target(func: MirFunction) -> bool:
        CudaBackend.accepts_gpu_kernel(func)

    static fn plan_module_kernels(module: MirModule) -> GpuBackendKernelPlan:
        gpu_backend_plan_module_kernels(BackendKind.Cuda, module)

    me emit_local_decl(builder: PtxBuilder, local: MirLocal):
        """Emit local variable declaration."""
        val reg = "%r{local.id.id}"
        match local.type_.kind:
            case I64: builder.emit_reg_decl(reg, PrimitiveType.I64)
            case I32: builder.emit_reg_decl(reg, PrimitiveType.I32)
            case I16: builder.emit_reg_decl(reg, PrimitiveType.I16)
            case I8: builder.emit_reg_decl(reg, PrimitiveType.I8)
            case U64: builder.emit_reg_decl(reg, PrimitiveType.U64)
            case U32: builder.emit_reg_decl(reg, PrimitiveType.U32)
            case U16: builder.emit_reg_decl(reg, PrimitiveType.U16)
            case U8: builder.emit_reg_decl(reg, PrimitiveType.U8)
            case F64: builder.emit_reg_decl(reg, PrimitiveType.F64)
            case F32: builder.emit_reg_decl(reg, PrimitiveType.F32)
            case Bool: builder.emit_pred_decl(reg)
            case _: ()

    me compile_instruction(builder: PtxBuilder, inst: MirInst, func: MirFunction) -> Result<(), CompileError>:
        """Compile a single MIR instruction to PTX."""
        match inst.kind:
            case Const(dest, value, ty):
                match value:
                    case Int(_) | Float(_) | Bool(_): ()
                    case _:
                        return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA backend does not support constant: {value}"))
                self.compile_const(builder, dest, value, ty)

            case Copy(dest, src):
                self.compile_copy(builder, dest, src, self.local_primitive_type(func, dest)?)

            case Move(dest, src):
                self.compile_copy(builder, dest, src, self.local_primitive_type(func, dest)?)  # Same as copy in PTX

            case BinOp(dest, op, left, right):
                match op:
                    case Add | Sub | Mul | Div | Eq | Ne | Lt | Le | Gt | Ge: ()
                    case _:
                        return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA backend does not support binary operation: {op}"))
                self.compile_binop(builder, dest, op, left, right, self.local_primitive_type(func, dest)?)

            case UnaryOp(dest, op, operand):
                match op:
                    case Neg | Not: ()
                    case _:
                        return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA backend does not support unary operation: {op}"))
                self.compile_unaryop(builder, dest, op, operand, self.local_primitive_type(func, dest)?)

            case Load(dest, ptr):
                self.compile_load(builder, dest, ptr, self.local_primitive_type(func, dest)?)

            case Store(ptr, value):
                self.compile_store(builder, ptr, value, self.operand_primitive_type(func, value)?)

            # GPU-specific instructions
            case GpuGlobalId(dest, dim):
                val reg = "%r{dest.id}"
                builder.emit_compute_global_id(reg, dim)

            case GpuLocalId(dest, dim):
                val reg = "%r{dest.id}"
                builder.emit_get_thread_id(reg, dim)

            case GpuBlockId(dest, dim):
                val reg = "%r{dest.id}"
                builder.emit_get_block_id(reg, dim)

            case GpuBlockDim(dest, dim):
                val reg = "%r{dest.id}"
                builder.emit_get_block_dim(reg, dim)

            case GpuGridDim(dest, dim):
                val reg = "%r{dest.id}"
                builder.emit_get_grid_dim(reg, dim)

            case GpuBarrier(scope):
                match scope:
                    case Workgroup:
                        builder.emit_barrier()
                    case Device:
                        builder.emit_membar_gl()
                    case Subgroup:
                        builder.emit_line("bar.warp.sync 0xffffffff;")

            case GpuMemFence(scope):
                match scope:
                    case Workgroup:
                        builder.emit_membar_cta()
                    case Device:
                        builder.emit_membar_gl()
                    case All:
                        builder.emit_membar_sys()
                    case _:
                        builder.emit_membar_cta()

            case GpuSharedAlloc(dest, ty, size):
                if size <= 0:
                    return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA shared allocation size must be positive"))
                val name = "shared_{dest.id}"
                val prim_ty = self.mir_type_to_primitive(ty)
                builder.emit_shared_memory(name, prim_ty, size)
                builder.emit_shared_address("%r{dest.id}", name)

            case GpuAtomicOp(dest, op, ptr, value):
                if op == GpuAtomicOpKind.CompareExchange:
                    return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA compare-exchange requires GpuAtomicCas"))
                self.compile_atomic(builder, dest, op, ptr, value, self.local_primitive_type(func, dest)?)

            case GpuAtomicCas(dest, ptr, expected, desired):
                self.compile_atomic_cas(builder, dest, ptr, expected, desired)

            # --- Function Calls ---

            case Call(dest, func, args):
                val call_result = self.compile_call(builder, dest, func, args)
                if call_result.is_err():
                    return Err(call_result.unwrap_err())

            case CallIndirect(dest, ptr, args, sig):
                return Err(compileerror_backend_error(
                    BackendKind.Cuda,
                    "CUDA backend does not support indirect GPU calls"
                ))

            # --- Aggregate Operations ---

            case Aggregate(dest, kind, operands):
                self.compile_aggregate(builder, dest, kind, operands)

            case GetField(dest, base, field):
                self.compile_get_field(builder, dest, base, field)

            case SetField(base, field, value):
                self.compile_set_field(builder, base, field, value)

            # --- Cast Operations ---

            case Cast(dest, operand, target):
                self.compile_cast(builder, dest, operand, target)

            case Bitcast(dest, operand, target):
                # Bitcast is a reinterpretation, use mov in PTX
                val dest_reg = "%r{dest.id}"
                val src_reg = self.operand_to_reg(builder, operand)
                builder.emit_line("mov.b64 {dest_reg}, {src_reg};")

            # --- Memory Allocation ---

            case Alloc(dest, type_):
                self.compile_alloc(builder, dest, type_)

            case GetElementPtr(dest, base, indices):
                self.compile_gep(builder, dest, base, indices)

            # --- Checked Arithmetic ---

            case CheckedBinOp(dest, op, left, right):
                return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA backend does not support checked arithmetic"))

            # --- Intrinsics ---

            case Intrinsic(dest, name, args):
                val validation = self.validate_intrinsic(name, dest, args.len())
                if validation.is_err():
                    return Err(validation.unwrap_err())
                self.compile_intrinsic(builder, dest, name, args)

            # --- Debug ---

            case DebugValue(local, name):
                builder.emit_comment("debug: {name} = %r{local.id}")

            case Nop:
                ()

            case _:
                return Err(compileerror_backend_error(
                    BackendKind.Cuda,
                    "Unsupported instruction: {inst.kind}"
                ))

        Ok(())

    me compile_const(builder: PtxBuilder, dest: LocalId, value: MirConstValue, ty: MirType):
        """Compile constant load."""
        val reg = "%r{dest.id}"
        match value:
            case Int(v):
                val prim_ty = self.mir_type_to_primitive(ty)
                builder.emit_const_int(reg, prim_ty, v)
            case Float(v):
                val prim_ty = self.mir_type_to_primitive(ty)
                builder.emit_const_float(reg, prim_ty, v)
            case Bool(v):
                val val_int = if v: 1 else: 0
                builder.emit_const_int(reg, PrimitiveType.Bool, val_int)
            case _:
                builder.emit_comment("Unsupported constant type")

    me compile_copy(builder: PtxBuilder, dest: LocalId, src: LocalId, ty: PrimitiveType):
        """Compile copy/move."""
        val dest_reg = "%r{dest.id}"
        val src_reg = "%r{src.id}"
        # Use mov instruction
        val ptx_ty = self.type_mapper.ptx_type(ty)
        builder.emit_line("mov{ptx_ty} {dest_reg}, {src_reg};")

    me compile_binop(builder: PtxBuilder, dest: LocalId, op: MirBinOp, left: MirOperand, right: MirOperand, ty: PrimitiveType):
        """Compile binary operation."""
        val dest_reg = "%r{dest.id}"
        val left_reg = self.operand_to_reg(builder, left)
        val right_reg = self.operand_to_reg(builder, right)

        match op:
            case Add:
                builder.emit_add(dest_reg, ty, left_reg, right_reg)
            case Sub:
                builder.emit_sub(dest_reg, ty, left_reg, right_reg)
            case Mul:
                builder.emit_mul(dest_reg, ty, left_reg, right_reg)
            case Div:
                builder.emit_div(dest_reg, ty, left_reg, right_reg)
            case Eq:
                builder.emit_compare(dest_reg, "eq", ty, left_reg, right_reg)
            case Ne:
                builder.emit_compare(dest_reg, "ne", ty, left_reg, right_reg)
            case Lt:
                builder.emit_compare(dest_reg, "lt", ty, left_reg, right_reg)
            case Le:
                builder.emit_compare(dest_reg, "le", ty, left_reg, right_reg)
            case Gt:
                builder.emit_compare(dest_reg, "gt", ty, left_reg, right_reg)
            case Ge:
                builder.emit_compare(dest_reg, "ge", ty, left_reg, right_reg)
            case _:
                builder.emit_comment("Unsupported binop: {op}")

    me compile_unaryop(builder: PtxBuilder, dest: LocalId, op: MirUnaryOp, operand: MirOperand, ty: PrimitiveType):
        """Compile unary operation."""
        val dest_reg = "%r{dest.id}"
        val src_reg = self.operand_to_reg(builder, operand)
        match op:
            case Neg:
                builder.emit_neg(dest_reg, ty, src_reg)
            case Not:
                builder.emit_line("not.pred {dest_reg}, {src_reg};")
            case _:
                builder.emit_comment("Unsupported unaryop: {op}")

    me compile_load(builder: PtxBuilder, dest: LocalId, ptr: MirOperand, ty: PrimitiveType):
        """Compile load instruction."""
        val dest_reg = "%r{dest.id}"
        val addr_reg = self.operand_to_reg(builder, ptr)
        builder.emit_load(dest_reg, ty, addr_reg, MemorySpace.Global)

    me compile_store(builder: PtxBuilder, ptr: MirOperand, value: MirOperand, ty: PrimitiveType):
        """Compile store instruction."""
        val addr_reg = self.operand_to_reg(builder, ptr)
        val value_reg = self.operand_to_reg(builder, value)
        builder.emit_store(ty, addr_reg, value_reg, MemorySpace.Global)

    me compile_atomic(builder: PtxBuilder, dest: LocalId, op: GpuAtomicOpKind, ptr: MirOperand, value: MirOperand, ty: PrimitiveType):
        """Compile atomic operation."""
        val dest_reg = "%r{dest.id}"
        val addr_reg = self.operand_to_reg(builder, ptr)
        val value_reg = self.operand_to_reg(builder, value)
        match op:
            case Add:
                builder.emit_atomic_add(dest_reg, ty, addr_reg, value_reg, MemorySpace.Global)
            case Sub:
                builder.emit_atomic_sub(dest_reg, ty, addr_reg, value_reg, MemorySpace.Global)
            case And:
                builder.emit_atomic_and(dest_reg, ty, addr_reg, value_reg, MemorySpace.Global)
            case Or:
                builder.emit_atomic_or(dest_reg, ty, addr_reg, value_reg, MemorySpace.Global)
            case Xor:
                builder.emit_atomic_xor(dest_reg, ty, addr_reg, value_reg, MemorySpace.Global)
            case Min:
                builder.emit_atomic_min(dest_reg, ty, addr_reg, value_reg, MemorySpace.Global)
            case Max:
                builder.emit_atomic_max(dest_reg, ty, addr_reg, value_reg, MemorySpace.Global)
            case Exchange:
                builder.emit_atomic_exch(dest_reg, ty, addr_reg, value_reg, MemorySpace.Global)
            case GpuAtomicOpKind.CompareExchange:
                # CAS via GpuAtomicOp is deprecated — use GpuAtomicCas instead
                builder.emit_comment("atom.cas via GpuAtomicOp deprecated; use GpuAtomicCas instruction")
            case _:
                builder.emit_comment("Unsupported atomic op: {op}")

    me compile_atomic_cas(builder: PtxBuilder, dest: LocalId, ptr: MirOperand, expected: MirOperand, desired: MirOperand):
        """Compile atomic compare-and-swap (3-operand CAS)."""
        val dest_reg = "%r{dest.id}"
        val addr_reg = self.operand_to_reg(builder, ptr)
        val cmp_reg = self.operand_to_reg(builder, expected)
        val val_reg = self.operand_to_reg(builder, desired)
        val ty = PrimitiveType.I64
        builder.emit_atomic_cas(dest_reg, ty, addr_reg, cmp_reg, val_reg, MemorySpace.Global)

    me compile_call(builder: PtxBuilder, dest: LocalId?, callee: MirOperand, args: [MirOperand]) -> Result<(), CompileError>:
        """Compile device function call."""
        val arg_regs = args.map(self.operand_to_reg(builder, _))

        var func_name = ""
        var return_ty = PrimitiveType.I64
        var returns_value = false
        var arg_types: [PrimitiveType] = []
        match callee.kind:
            case Const(Str(name), ty):
                func_name = name
                if not self.function_signatures.contains_key(name):
                    return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA direct call target is not defined in the MIR module: {name}"))
                val sig = self.function_signatures[name]
                if sig.params.len() != args.len():
                    return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA direct call argument count does not match its signature"))
                for param_ty in sig.params:
                    if param_ty.kind == MirTypeKind.Bool:
                        return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA direct calls do not yet support boolean parameters"))
                    arg_types = arg_types.push(self.mir_type_to_primitive(param_ty))
                returns_value = sig.return_type.kind != MirTypeKind.Unit
                if sig.return_type.kind == MirTypeKind.Bool:
                    return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA direct calls do not yet support boolean return values"))
                return_ty = self.mir_type_to_primitive(sig.return_type)
            case _:
                return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA direct call requires a statically named callee"))

        if dest.? and not returns_value:
            return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA void device call cannot have a destination"))
        if not dest.? and returns_value:
            return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA value-returning device call requires a destination"))
        if dest.?:
            val dest_reg = "%r{dest.unwrap().id}"
            builder.emit_call(dest_reg, return_ty, func_name, arg_regs, arg_types)
        else:
            builder.emit_call_void(func_name, arg_regs, arg_types)
        Ok(())

    me compile_aggregate(builder: PtxBuilder, dest: LocalId, kind: AggregateKind, operands: [MirOperand]):
        """Compile aggregate construction via local memory."""
        val dest_reg = "%r{dest.id}"
        # Store each field to local memory at offset
        builder.emit_comment("aggregate construct -> {dest_reg}")
        var offset = 0
        for i, operand in operands.enumerate():
            val src_reg = self.operand_to_reg(builder, operand)
            # Store field value at base + offset in local memory
            builder.emit_line("st.local.u64 [{dest_reg}+{offset}], {src_reg};")
            offset = offset + 8

    me compile_get_field(builder: PtxBuilder, dest: LocalId, base: MirOperand, field: i64):
        """Compile field access via offset load."""
        val dest_reg = "%r{dest.id}"
        val base_reg = self.operand_to_reg(builder, base)
        val offset = field * 8
        builder.emit_line("ld.local.u64 {dest_reg}, [{base_reg}+{offset}];")

    me compile_set_field(builder: PtxBuilder, base: MirOperand, field: i64, value: MirOperand):
        """Compile field write via offset store."""
        val base_reg = self.operand_to_reg(builder, base)
        val value_reg = self.operand_to_reg(builder, value)
        val offset = field * 8
        builder.emit_line("st.local.u64 [{base_reg}+{offset}], {value_reg};")

    me compile_cast(builder: PtxBuilder, dest: LocalId, operand: MirOperand, target: MirType):
        """Compile type conversion using PTX cvt instruction."""
        val dest_reg = "%r{dest.id}"
        val src_reg = self.operand_to_reg(builder, operand)
        val dest_ty = self.mir_type_to_primitive(target)
        # Infer source type - default to I64
        val src_ty = PrimitiveType.I64
        builder.emit_convert(dest_reg, dest_ty, src_reg, src_ty)

    me compile_alloc(builder: PtxBuilder, dest: LocalId, type_: MirType):
        """Compile local memory allocation."""
        val dest_reg = "%r{dest.id}"
        val prim_ty = self.mir_type_to_primitive(type_)
        val size = type_.size_bytes()
        val alloc_name = "local_{dest.id}"
        builder.emit_local_alloc(alloc_name, prim_ty, 1)
        # Load address of local allocation into dest register
        builder.emit_line("mov.u64 {dest_reg}, {alloc_name};")

    me compile_gep(builder: PtxBuilder, dest: LocalId, base: MirOperand, indices: [MirOperand]):
        """Compile GetElementPtr - pointer arithmetic with indices."""
        val dest_reg = "%r{dest.id}"
        val base_reg = self.operand_to_reg(builder, base)
        # For simple single-index GEP, compute base + index * element_size
        if indices.len() > 0:
            val idx_reg = self.operand_to_reg(builder, indices[0])
            val tmp = builder.alloc_reg(PrimitiveType.U64)
            builder.emit_reg_decl(tmp, PrimitiveType.U64)
            # Assume 8-byte elements (i64/ptr)
            builder.emit_line("mul.lo.u64 {tmp}, {idx_reg}, 8;")
            builder.emit_line("add.u64 {dest_reg}, {base_reg}, {tmp};")
        else:
            builder.emit_line("mov.u64 {dest_reg}, {base_reg};")

    me compile_intrinsic(builder: PtxBuilder, dest: LocalId?, name: text, args: [MirOperand]):
        """Compile math and GPU intrinsics."""
        val ty = PrimitiveType.F32  # Default to F32 for math intrinsics

        match name:
            case "sin":
                val d = "%r{dest.unwrap().id}"
                val src = self.operand_to_reg(builder, args[0])
                builder.emit_intrinsic_sin(d, ty, src)
            case "cos":
                val d = "%r{dest.unwrap().id}"
                val src = self.operand_to_reg(builder, args[0])
                builder.emit_intrinsic_cos(d, ty, src)
            case "sqrt":
                val d = "%r{dest.unwrap().id}"
                val src = self.operand_to_reg(builder, args[0])
                builder.emit_intrinsic_sqrt(d, ty, src)
            case "abs":
                val d = "%r{dest.unwrap().id}"
                val src = self.operand_to_reg(builder, args[0])
                builder.emit_intrinsic_abs(d, ty, src)
            case "min":
                val d = "%r{dest.unwrap().id}"
                val a = self.operand_to_reg(builder, args[0])
                val b = self.operand_to_reg(builder, args[1])
                builder.emit_intrinsic_min(d, ty, a, b)
            case "max":
                val d = "%r{dest.unwrap().id}"
                val a = self.operand_to_reg(builder, args[0])
                val b = self.operand_to_reg(builder, args[1])
                builder.emit_intrinsic_max(d, ty, a, b)
            case "fma":
                val d = "%r{dest.unwrap().id}"
                val a = self.operand_to_reg(builder, args[0])
                val b = self.operand_to_reg(builder, args[1])
                val c = self.operand_to_reg(builder, args[2])
                builder.emit_intrinsic_fma(d, ty, a, b, c)
            case "exp2":
                val d = "%r{dest.unwrap().id}"
                val src = self.operand_to_reg(builder, args[0])
                builder.emit_intrinsic_ex2(d, ty, src)
            case "log2":
                val d = "%r{dest.unwrap().id}"
                val src = self.operand_to_reg(builder, args[0])
                builder.emit_intrinsic_lg2(d, ty, src)
            case "rcp":
                val d = "%r{dest.unwrap().id}"
                val src = self.operand_to_reg(builder, args[0])
                builder.emit_intrinsic_rcp(d, ty, src)
            # Atomic intrinsics (typed variants)
            case "gpu_atomic_add_i64":
                val d = "%r{dest.unwrap().id}"
                val ptr_reg = self.operand_to_reg(builder, args[0])
                val val_reg = self.operand_to_reg(builder, args[1])
                builder.emit_atomic_add(d, PrimitiveType.I64, ptr_reg, val_reg, MemorySpace.Global)
            case "gpu_atomic_add_i32":
                val d = "%r{dest.unwrap().id}"
                val ptr_reg = self.operand_to_reg(builder, args[0])
                val val_reg = self.operand_to_reg(builder, args[1])
                builder.emit_atomic_add(d, PrimitiveType.I32, ptr_reg, val_reg, MemorySpace.Global)
            case "gpu_atomic_add_f32":
                val d = "%r{dest.unwrap().id}"
                val ptr_reg = self.operand_to_reg(builder, args[0])
                val val_reg = self.operand_to_reg(builder, args[1])
                builder.emit_atomic_add(d, PrimitiveType.F32, ptr_reg, val_reg, MemorySpace.Global)
            case "gpu_atomic_min_i64":
                val d = "%r{dest.unwrap().id}"
                val ptr_reg = self.operand_to_reg(builder, args[0])
                val val_reg = self.operand_to_reg(builder, args[1])
                builder.emit_atomic_min(d, PrimitiveType.I64, ptr_reg, val_reg, MemorySpace.Global)
            case "gpu_atomic_max_i64":
                val d = "%r{dest.unwrap().id}"
                val ptr_reg = self.operand_to_reg(builder, args[0])
                val val_reg = self.operand_to_reg(builder, args[1])
                builder.emit_atomic_max(d, PrimitiveType.I64, ptr_reg, val_reg, MemorySpace.Global)
            case "gpu_atomic_cas_i64":
                val d = "%r{dest.unwrap().id}"
                val ptr_reg = self.operand_to_reg(builder, args[0])
                val cmp_reg = self.operand_to_reg(builder, args[1])
                val val_reg = self.operand_to_reg(builder, args[2])
                builder.emit_atomic_cas(d, PrimitiveType.I64, ptr_reg, cmp_reg, val_reg, MemorySpace.Global)
            # Sub-group / warp intrinsics
            case "gpu_lane_id":
                val d2 = "%r{dest.unwrap().id}"
                builder.emit_reg_decl(d2, PrimitiveType.I32)
                builder.emit_line("mov.u32 {d2}, %laneid;")
            case "gpu_warp_id":
                val d3 = "%r{dest.unwrap().id}"
                builder.emit_reg_decl(d3, PrimitiveType.I32)
                builder.emit_line("mov.u32 {d3}, %warpid;")
            case "gpu_warp_size":
                val d4 = "%r{dest.unwrap().id}"
                builder.emit_reg_decl(d4, PrimitiveType.I32)
                builder.emit_line("mov.u32 {d4}, %WARP_SZ;")
            case "gpu_warp_shuffle":
                val d5 = "%r{dest.unwrap().id}"
                val src5 = self.operand_to_reg(builder, args[0])
                val lane5 = self.operand_to_reg(builder, args[1])
                builder.emit_reg_decl(d5, PrimitiveType.I32)
                builder.emit_line("shfl.sync.idx.b32 {d5}, {src5}, {lane5}, 0x1f, 0xffffffff;")
            case "gpu_warp_shuffle_down":
                val d6 = "%r{dest.unwrap().id}"
                val src6 = self.operand_to_reg(builder, args[0])
                val delta6 = self.operand_to_reg(builder, args[1])
                builder.emit_reg_decl(d6, PrimitiveType.I32)
                builder.emit_line("shfl.sync.down.b32 {d6}, {src6}, {delta6}, 0x1f, 0xffffffff;")
            case "gpu_warp_shuffle_up":
                val d7 = "%r{dest.unwrap().id}"
                val src7 = self.operand_to_reg(builder, args[0])
                val delta7 = self.operand_to_reg(builder, args[1])
                builder.emit_reg_decl(d7, PrimitiveType.I32)
                builder.emit_line("shfl.sync.up.b32 {d7}, {src7}, {delta7}, 0x0, 0xffffffff;")
            case "gpu_warp_shuffle_xor":
                val d8 = "%r{dest.unwrap().id}"
                val src8 = self.operand_to_reg(builder, args[0])
                val mask8 = self.operand_to_reg(builder, args[1])
                builder.emit_reg_decl(d8, PrimitiveType.I32)
                builder.emit_line("shfl.sync.bfly.b32 {d8}, {src8}, {mask8}, 0x1f, 0xffffffff;")
            case "gpu_warp_ballot":
                val d9 = "%r{dest.unwrap().id}"
                val pred9 = self.operand_to_reg(builder, args[0])
                builder.emit_reg_decl(d9, PrimitiveType.I32)
                builder.emit_line("vote.sync.ballot.b32 {d9}, {pred9}, 0xffffffff;")
            case "gpu_warp_reduce_add":
                # Butterfly warp reduction: 5 shfl.sync.bfly steps for warp size 32
                val dra = "%r{dest.unwrap().id}"
                val srcra = self.operand_to_reg(builder, args[0])
                val tmp_ra0 = builder.alloc_reg(PrimitiveType.I32)
                val tmp_ra1 = builder.alloc_reg(PrimitiveType.I32)
                val tmp_ra2 = builder.alloc_reg(PrimitiveType.I32)
                val tmp_ra3 = builder.alloc_reg(PrimitiveType.I32)
                val tmp_ra4 = builder.alloc_reg(PrimitiveType.I32)
                builder.emit_reg_decl(dra, PrimitiveType.I32)
                builder.emit_reg_decl(tmp_ra0, PrimitiveType.I32)
                builder.emit_reg_decl(tmp_ra1, PrimitiveType.I32)
                builder.emit_reg_decl(tmp_ra2, PrimitiveType.I32)
                builder.emit_reg_decl(tmp_ra3, PrimitiveType.I32)
                builder.emit_reg_decl(tmp_ra4, PrimitiveType.I32)
                builder.emit_line("shfl.sync.bfly.b32 {tmp_ra0}, {srcra}, 16, 0x1f, 0xffffffff;")
                builder.emit_line("add.s32 {tmp_ra0}, {srcra}, {tmp_ra0};")
                builder.emit_line("shfl.sync.bfly.b32 {tmp_ra1}, {tmp_ra0}, 8, 0x1f, 0xffffffff;")
                builder.emit_line("add.s32 {tmp_ra1}, {tmp_ra0}, {tmp_ra1};")
                builder.emit_line("shfl.sync.bfly.b32 {tmp_ra2}, {tmp_ra1}, 4, 0x1f, 0xffffffff;")
                builder.emit_line("add.s32 {tmp_ra2}, {tmp_ra1}, {tmp_ra2};")
                builder.emit_line("shfl.sync.bfly.b32 {tmp_ra3}, {tmp_ra2}, 2, 0x1f, 0xffffffff;")
                builder.emit_line("add.s32 {tmp_ra3}, {tmp_ra2}, {tmp_ra3};")
                builder.emit_line("shfl.sync.bfly.b32 {tmp_ra4}, {tmp_ra3}, 1, 0x1f, 0xffffffff;")
                builder.emit_line("add.s32 {dra}, {tmp_ra3}, {tmp_ra4};")
            case "gpu_warp_broadcast":
                # Broadcast: shfl.sync.idx — same as shuffle by lane index
                val dbc = "%r{dest.unwrap().id}"
                val srcbc = self.operand_to_reg(builder, args[0])
                val lanebc = self.operand_to_reg(builder, args[1])
                builder.emit_reg_decl(dbc, PrimitiveType.I32)
                builder.emit_line("shfl.sync.idx.b32 {dbc}, {srcbc}, {lanebc}, 0x1f, 0xffffffff;")
            case "gpu_warp_scan_add":
                # Inclusive prefix scan: 5 shfl.sync.up steps for warp size 32
                val dsc = "%r{dest.unwrap().id}"
                val srcsc = self.operand_to_reg(builder, args[0])
                val tmp_sc0 = builder.alloc_reg(PrimitiveType.I32)
                val tmp_sc1 = builder.alloc_reg(PrimitiveType.I32)
                val tmp_sc2 = builder.alloc_reg(PrimitiveType.I32)
                val tmp_sc3 = builder.alloc_reg(PrimitiveType.I32)
                val tmp_sc4 = builder.alloc_reg(PrimitiveType.I32)
                val lane_sc = builder.alloc_reg(PrimitiveType.I32)
                val pred_sc0 = builder.alloc_pred_reg()
                val pred_sc1 = builder.alloc_pred_reg()
                val pred_sc2 = builder.alloc_pred_reg()
                val pred_sc3 = builder.alloc_pred_reg()
                val pred_sc4 = builder.alloc_pred_reg()
                builder.emit_reg_decl(dsc, PrimitiveType.I32)
                builder.emit_reg_decl(tmp_sc0, PrimitiveType.I32)
                builder.emit_reg_decl(tmp_sc1, PrimitiveType.I32)
                builder.emit_reg_decl(tmp_sc2, PrimitiveType.I32)
                builder.emit_reg_decl(tmp_sc3, PrimitiveType.I32)
                builder.emit_reg_decl(tmp_sc4, PrimitiveType.I32)
                builder.emit_reg_decl(lane_sc, PrimitiveType.I32)
                builder.emit_pred_decl(pred_sc0)
                builder.emit_pred_decl(pred_sc1)
                builder.emit_pred_decl(pred_sc2)
                builder.emit_pred_decl(pred_sc3)
                builder.emit_pred_decl(pred_sc4)
                builder.emit_line("mov.u32 {lane_sc}, %laneid;")
                builder.emit_line("mov.s32 {dsc}, {srcsc};")
                builder.emit_line("shfl.sync.up.b32 {tmp_sc0}, {dsc}, 1, 0x0, 0xffffffff;")
                builder.emit_line("setp.ge.u32 {pred_sc0}, {lane_sc}, 1;")
                builder.emit_line("@{pred_sc0} add.s32 {dsc}, {dsc}, {tmp_sc0};")
                builder.emit_line("shfl.sync.up.b32 {tmp_sc1}, {dsc}, 2, 0x0, 0xffffffff;")
                builder.emit_line("setp.ge.u32 {pred_sc1}, {lane_sc}, 2;")
                builder.emit_line("@{pred_sc1} add.s32 {dsc}, {dsc}, {tmp_sc1};")
                builder.emit_line("shfl.sync.up.b32 {tmp_sc2}, {dsc}, 4, 0x0, 0xffffffff;")
                builder.emit_line("setp.ge.u32 {pred_sc2}, {lane_sc}, 4;")
                builder.emit_line("@{pred_sc2} add.s32 {dsc}, {dsc}, {tmp_sc2};")
                builder.emit_line("shfl.sync.up.b32 {tmp_sc3}, {dsc}, 8, 0x0, 0xffffffff;")
                builder.emit_line("setp.ge.u32 {pred_sc3}, {lane_sc}, 8;")
                builder.emit_line("@{pred_sc3} add.s32 {dsc}, {dsc}, {tmp_sc3};")
                builder.emit_line("shfl.sync.up.b32 {tmp_sc4}, {dsc}, 16, 0x0, 0xffffffff;")
                builder.emit_line("setp.ge.u32 {pred_sc4}, {lane_sc}, 16;")
                builder.emit_line("@{pred_sc4} add.s32 {dsc}, {dsc}, {tmp_sc4};")
            # Specialization constants (W2.5): gpu_spec_const_i64(name, default)
            case "gpu_spec_const_i64":
                val const_name = match args[0].kind:
                    case Const(value, _):
                        match value:
                            case Str(s): s
                            case _: ""
                    case _: ""
                val default_val = match args[1].kind:
                    case Const(value, _):
                        match value:
                            case Int(v): v
                            case _: 0
                    case _: 0
                if const_name == "":
                    builder.emit_comment("gpu_spec_const_i64 requires a string literal constant name")
                else:
                    val resolved = spec_const_resolve(const_name, default_val)
                    if dest.?:
                        val dsc = "%r{dest.unwrap().id}"
                        builder.emit_reg_decl(dsc, PrimitiveType.I64)
                        builder.emit_line("mov.s64 {dsc}, {resolved};")
                    else:
                        builder.emit_comment("gpu_spec_const_i64 discarded (no dest)")
            # Vector load/store (W2.6)
            case "gpu_vec4_load_f32":
                if args.len() < 2:
                    builder.emit_comment("gpu_vec4_load_f32 missing arguments")
                else:
                    if dest.?:
                        val dv4 = "%r{dest.unwrap().id}"
                        val ptr_v4 = self.operand_to_reg(builder, args[0])
                        val idx_v4 = self.operand_to_reg(builder, args[1])
                        val r0 = builder.alloc_reg(PrimitiveType.F32)
                        val r1 = builder.alloc_reg(PrimitiveType.F32)
                        val r2 = builder.alloc_reg(PrimitiveType.F32)
                        val r3 = builder.alloc_reg(PrimitiveType.F32)
                        builder.emit_reg_decl(r0, PrimitiveType.F32)
                        builder.emit_reg_decl(r1, PrimitiveType.F32)
                        builder.emit_reg_decl(r2, PrimitiveType.F32)
                        builder.emit_reg_decl(r3, PrimitiveType.F32)
                        val addr_v4 = builder.alloc_reg(PrimitiveType.U64)
                        builder.emit_reg_decl(addr_v4, PrimitiveType.U64)
                        val off_v4 = builder.alloc_reg(PrimitiveType.U64)
                        builder.emit_reg_decl(off_v4, PrimitiveType.U64)
                        builder.emit_line("mul.lo.u64 {off_v4}, {idx_v4}, 16;")
                        builder.emit_line("add.u64 {addr_v4}, {ptr_v4}, {off_v4};")
                        builder.emit_line("ld.global.v4.f32 {{{r0}, {r1}, {r2}, {r3}}}, [{addr_v4}];")
                        builder.emit_reg_decl(dv4, PrimitiveType.I32)
                        builder.emit_line("mov.u32 {dv4}, 0;")
                    else:
                        builder.emit_comment("gpu_vec4_load_f32 discarded (no dest)")
            case "gpu_vec4_store_f32":
                if args.len() < 6:
                    builder.emit_comment("gpu_vec4_store_f32 missing arguments")
                else:
                    val ptr_vs4 = self.operand_to_reg(builder, args[0])
                    val idx_vs4 = self.operand_to_reg(builder, args[1])
                    val v0s4 = self.operand_to_reg(builder, args[2])
                    val v1s4 = self.operand_to_reg(builder, args[3])
                    val v2s4 = self.operand_to_reg(builder, args[4])
                    val v3s4 = self.operand_to_reg(builder, args[5])
                    val addr_vs4 = builder.alloc_reg(PrimitiveType.U64)
                    builder.emit_reg_decl(addr_vs4, PrimitiveType.U64)
                    val off_vs4 = builder.alloc_reg(PrimitiveType.U64)
                    builder.emit_reg_decl(off_vs4, PrimitiveType.U64)
                    builder.emit_line("mul.lo.u64 {off_vs4}, {idx_vs4}, 16;")
                    builder.emit_line("add.u64 {addr_vs4}, {ptr_vs4}, {off_vs4};")
                    builder.emit_line("st.global.v4.f32 [{addr_vs4}], {{{v0s4}, {v1s4}, {v2s4}, {v3s4}}};")
            case "gpu_vec2_load_f32":
                if args.len() < 2:
                    builder.emit_comment("gpu_vec2_load_f32 missing arguments")
                else:
                    if dest.?:
                        val dv2 = "%r{dest.unwrap().id}"
                        val ptr_v2 = self.operand_to_reg(builder, args[0])
                        val idx_v2 = self.operand_to_reg(builder, args[1])
                        val r0v2 = builder.alloc_reg(PrimitiveType.F32)
                        val r1v2 = builder.alloc_reg(PrimitiveType.F32)
                        builder.emit_reg_decl(r0v2, PrimitiveType.F32)
                        builder.emit_reg_decl(r1v2, PrimitiveType.F32)
                        val addr_v2 = builder.alloc_reg(PrimitiveType.U64)
                        builder.emit_reg_decl(addr_v2, PrimitiveType.U64)
                        val off_v2 = builder.alloc_reg(PrimitiveType.U64)
                        builder.emit_reg_decl(off_v2, PrimitiveType.U64)
                        builder.emit_line("mul.lo.u64 {off_v2}, {idx_v2}, 8;")
                        builder.emit_line("add.u64 {addr_v2}, {ptr_v2}, {off_v2};")
                        builder.emit_line("ld.global.v2.f32 {{{r0v2}, {r1v2}}}, [{addr_v2}];")
                        builder.emit_reg_decl(dv2, PrimitiveType.I32)
                        builder.emit_line("mov.u32 {dv2}, 0;")
                    else:
                        builder.emit_comment("gpu_vec2_load_f32 discarded (no dest)")
            case "gpu_vec2_store_f32":
                if args.len() < 4:
                    builder.emit_comment("gpu_vec2_store_f32 missing arguments")
                else:
                    val ptr_vs2 = self.operand_to_reg(builder, args[0])
                    val idx_vs2 = self.operand_to_reg(builder, args[1])
                    val v0s2 = self.operand_to_reg(builder, args[2])
                    val v1s2 = self.operand_to_reg(builder, args[3])
                    val addr_vs2 = builder.alloc_reg(PrimitiveType.U64)
                    builder.emit_reg_decl(addr_vs2, PrimitiveType.U64)
                    val off_vs2 = builder.alloc_reg(PrimitiveType.U64)
                    builder.emit_reg_decl(off_vs2, PrimitiveType.U64)
                    builder.emit_line("mul.lo.u64 {off_vs2}, {idx_vs2}, 8;")
                    builder.emit_line("add.u64 {addr_vs2}, {ptr_vs2}, {off_vs2};")
                    builder.emit_line("st.global.v2.f32 [{addr_vs2}], {{{v0s2}, {v1s2}}};")
            case _:
                builder.emit_comment("Unknown intrinsic: {name}")

    me compile_terminator(builder: PtxBuilder, term: MirTerminator, is_kernel: bool, return_type: MirType) -> Result<(), CompileError>:
        """Compile block terminator."""
        match term:
            case Ret(value):
                if is_kernel:
                    if value.?:
                        return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA kernels cannot return a value"))
                    builder.emit_exit()
                else:
                    if value.?:
                        val src = self.operand_to_reg(builder, value.unwrap())
                        builder.emit_return_value(self.mir_type_to_primitive(return_type), src)
                    elif return_type.kind != MirTypeKind.Unit:
                        return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA device function must return a value"))
                    builder.emit_ret()
            case Goto(target):
                builder.emit_branch("BB{target.id}")
            case Branch(cond, true_target, false_target):
                val cond_reg = self.operand_to_reg(builder, cond)
                builder.emit_branch_if(cond_reg, "BB{true_target.id}")
                builder.emit_branch("BB{false_target.id}")
            case If(cond, true_target, false_target):
                val cond_reg = self.operand_to_reg(builder, cond)
                builder.emit_branch_if(cond_reg, "BB{true_target.id}")
                builder.emit_branch("BB{false_target.id}")
            case Unreachable:
                builder.emit_line("trap;")
            case _:
                return Err(compileerror_backend_error(
                    BackendKind.Cuda,
                    "CUDA backend does not support terminator: {term}"
                ))
        Ok(())

    me operand_to_reg(builder: PtxBuilder, operand: MirOperand) -> text:
        """Convert operand to register name, materializing constants into temp registers."""
        match operand.kind:
            case Copy(local): "%r{local.id}"
            case Move(local): "%r{local.id}"
            case Const(value, ty):
                # Emit mov to a temp register for constant values
                val prim_ty = self.mir_type_to_primitive(ty)
                val tmp = builder.alloc_reg(prim_ty)
                builder.emit_reg_decl(tmp, prim_ty)
                match value:
                    case Int(v):
                        builder.emit_const_int(tmp, prim_ty, v)
                    case Float(v):
                        builder.emit_const_float(tmp, prim_ty, v)
                    case Bool(v):
                        val int_val = if v: 1 else: 0
                        builder.emit_const_int(tmp, PrimitiveType.Bool, int_val)
                    case _:
                        builder.emit_const_int(tmp, PrimitiveType.I64, 0)
                tmp

    fn mir_type_to_primitive(ty: MirType) -> PrimitiveType:
        """Convert MIR type to PrimitiveType."""
        match ty.kind:
            case I64: PrimitiveType.I64
            case I32: PrimitiveType.I32
            case I16: PrimitiveType.I16
            case I8: PrimitiveType.I8
            case U64: PrimitiveType.U64
            case U32: PrimitiveType.U32
            case U16: PrimitiveType.U16
            case U8: PrimitiveType.U8
            case F64: PrimitiveType.F64
            case F32: PrimitiveType.F32
            case Bool: PrimitiveType.Bool
            case Ptr(_, _) | Ref(_, _) | FuncPtr(_): PrimitiveType.U64
            case _: PrimitiveType.I64

    fn cuda_type_supported(ty: MirType) -> bool:
        match ty.kind:
            case I64 | I32 | I16 | I8 | U64 | U32 | U16 | U8 | F64 | F32 | Bool | Unit | Ptr(_, _) | Ref(_, _) | FuncPtr(_): true
            case _: false

    me local_primitive_type(func: MirFunction, id: LocalId) -> Result<PrimitiveType, CompileError>:
        for local in func.locals:
            if local.id == id:
                return Ok(self.mir_type_to_primitive(local.type_))
        Err(compileerror_backend_error(BackendKind.Cuda, "CUDA MIR references unknown local %{id.id}"))

    me operand_primitive_type(func: MirFunction, operand: MirOperand) -> Result<PrimitiveType, CompileError>:
        match operand.kind:
            case Copy(id) | Move(id): self.local_primitive_type(func, id)
            case Const(_, ty): Ok(self.mir_type_to_primitive(ty))

    me validate_intrinsic(name: text, dest: LocalId?, arg_count: i64) -> Result<(), CompileError>:
        var required_args = -1
        var requires_dest = true
        match name:
            case "sin" | "cos" | "sqrt" | "abs" | "exp2" | "log2" | "rcp" | "gpu_warp_reduce_add" | "gpu_lane_id" | "gpu_warp_id" | "gpu_warp_size": required_args = if name == "gpu_lane_id" or name == "gpu_warp_id" or name == "gpu_warp_size": 0 else: 1
            case "min" | "max" | "gpu_atomic_add_i64" | "gpu_atomic_add_i32" | "gpu_atomic_add_f32" | "gpu_atomic_min_i64" | "gpu_atomic_max_i64" | "gpu_warp_shuffle" | "gpu_warp_shuffle_down" | "gpu_warp_shuffle_up" | "gpu_warp_shuffle_xor" | "gpu_warp_ballot" | "gpu_warp_broadcast" | "gpu_warp_scan_add" | "gpu_spec_const_i64" | "gpu_vec4_load_f32" | "gpu_vec2_load_f32": required_args = 2
            case "fma" | "gpu_atomic_cas_i64": required_args = 3
            case "gpu_vec4_store_f32":
                required_args = 6
                requires_dest = false
            case "gpu_vec2_store_f32":
                required_args = 4
                requires_dest = false
            case _:
                return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA backend does not support intrinsic: {name}"))
        if arg_count < required_args:
            return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA intrinsic '{name}' requires {required_args} arguments"))
        if requires_dest and not dest.?:
            return Err(compileerror_backend_error(BackendKind.Cuda, "CUDA intrinsic '{name}' requires a destination"))
        Ok(())

# ============================================================================
# CUDA Compilation Results
# ============================================================================

struct CudaCompiledModule:
    """Result of CUDA compilation."""
    name: text
    ptx: text
    kernels: [CudaKernel]
    device_functions: [CudaDeviceFunction]
    compute_capability: (i64, i64)

struct CudaKernel:
    """Compiled CUDA kernel."""
    name: text
    ptx: text
    param_count: i64

struct CudaDeviceFunction:
    """Compiled CUDA device function."""
    name: text
    ptx: text

struct CompiledFunction:
    """Internal compiled function result."""
    name: text
    ptx: text
    is_kernel: bool

# ============================================================================
# Codegen Trait Implementation
# ============================================================================

impl Codegen for CudaBackend:
    fn backend_kind() -> BackendKind: BackendKind.Cuda
    fn backend_name() -> text: "cuda"
    fn supports_target(target: CodegenTarget) -> bool:
        gpu_backend_supports_target(BackendKind.Cuda, target)
    fn output_kind() -> CodegenOutputKind: CodegenOutputKind.GpuCode

    me compile_module(module: MirModule) -> Result<CodegenOutput, CompileError>:
        val result = self.compile(module)
        match result:
            case Ok(cuda_module):
                Ok(CodegenOutput.gpu_output(module.name, cuda_module.ptx))
            case Err(e):
                Err(e)

# ============================================================================
# GpuCodegen Trait Implementation
# ============================================================================

impl GpuCodegen for CudaBackend:
    me compile_kernel(func_name: text, body: MirBody) -> Result<text, CompileError>:
        val builder = PtxBuilder.create(self.compute_capability)
        var param_types: [MirType] = []
        var pi = 0
        while pi < body.arg_count:
            val loc: MirLocal = body.locals[pi]
            param_types = param_types.push(loc.type_)
            pi = pi + 1
        val sig = MirSignature(params: param_types, return_type: body.return_ty, is_variadic: false)
        val func = MirFunction(name: func_name, body: body, is_extern: false, signature: sig)
        val result = self.compile_function(builder, func)
        match result:
            case Ok(_):
                Ok(builder.build())
            case Err(e):
                Err(e)

    me compile_device_function(func_name: text, body: MirBody) -> Result<text, CompileError>:
        val builder = PtxBuilder.create(self.compute_capability)
        var param_types2: [MirType] = []
        var pi2 = 0
        while pi2 < body.arg_count:
            val loc2: MirLocal = body.locals[pi2]
            param_types2 = param_types2.push(loc2.type_)
            pi2 = pi2 + 1
        val sig2 = MirSignature(params: param_types2, return_type: body.return_ty, is_variadic: false)
        val func = MirFunction(name: func_name, body: body, is_extern: false, signature: sig2)
        val result = self.compile_function(builder, func)
        match result:
            case Ok(_):
                Ok(builder.build())
            case Err(e):
                Err(e)

    fn compile_gpu_instruction(inst: MirInst) -> text:
        "// cuda instruction"

    fn compile_barrier(scope: GpuBarrierScope) -> text:
        match scope:
            case Workgroup: "bar.sync 0;"
            case Device: "membar.gl;"
            case Subgroup: "bar.warp.sync 0xffffffff;"

    fn compile_atomic(op: GpuAtomicOpKind, dest: LocalId, ptr: MirOperand, value: MirOperand) -> text:
        "// atomic op"

    fn gpu_memory_model() -> text:
        "PTX unified memory"

    fn is_kernel_function(body: MirBody) -> bool:
        val _ = body
        false

# ============================================================================
# Export
# ============================================================================
