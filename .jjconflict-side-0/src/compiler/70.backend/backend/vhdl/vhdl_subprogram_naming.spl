# VHDL subprogram name sanitization and collision detection.
#
# Provides sanitized name containers, collision checks, parameter descriptors,
# and mangled signature handles for use during VHDL subprogram emission.
#
# Library file — no fn main().

# ============================================================================
# VhdlSanitizedName
# ============================================================================

class VhdlSanitizedName:
    original_name: text
    sanitized_name: text
    was_modified: bool
    collision_index: int

    me needs_suffix() -> bool:
        return self.collision_index > 0

    me final_name() -> text:
        if self.collision_index > 0:
            return self.sanitized_name + "_" + self.collision_index.to_text()
        return self.sanitized_name

    me to_text() -> text:
        return self.original_name + " -> " + self.final_name()

    static fn unchanged(name: text) -> VhdlSanitizedName:
        return VhdlSanitizedName(
            original_name: name,
            sanitized_name: name,
            was_modified: false,
            collision_index: 0
        )

    static fn sanitized(orig: text, safe: text) -> VhdlSanitizedName:
        return VhdlSanitizedName(
            original_name: orig,
            sanitized_name: safe,
            was_modified: true,
            collision_index: 0
        )

# ============================================================================
# CollisionCheck
# ============================================================================

class CollisionCheck:
    name_a: text
    name_b: text
    is_collision: bool
    resolution: text

    me has_collision() -> bool:
        return self.is_collision

    me to_text() -> text:
        if self.is_collision:
            return "COLLISION " + self.name_a + " vs " + self.name_b + " resolve=" + self.resolution
        return "OK " + self.name_a

    static fn no_collision(a: text, b: text) -> CollisionCheck:
        return CollisionCheck(
            name_a: a,
            name_b: b,
            is_collision: false,
            resolution: "none"
        )

    static fn collision(a: text, b: text, res: text) -> CollisionCheck:
        return CollisionCheck(
            name_a: a,
            name_b: b,
            is_collision: true,
            resolution: res
        )

# ============================================================================
# SanitizedParam
# ============================================================================

class SanitizedParam:
    param_name: text
    param_type: text
    direction: text
    vhdl_name: text

    me is_output() -> bool:
        return self.direction == "out"

    me is_input() -> bool:
        return self.direction == "in"

    me to_text() -> text:
        return self.vhdl_name + " : " + self.direction + " " + self.param_type

    static fn input(name: text, ptype: text) -> SanitizedParam:
        return SanitizedParam(
            param_name: name,
            param_type: ptype,
            direction: "in",
            vhdl_name: name
        )

    static fn output(name: text, ptype: text) -> SanitizedParam:
        return SanitizedParam(
            param_name: name,
            param_type: ptype,
            direction: "out",
            vhdl_name: name
        )

# ============================================================================
# MangledSignature
# ============================================================================

class MangledSignature:
    base_name: text
    param_hash: int
    mangled_name: text
    is_overloaded: bool

    me to_text() -> text:
        return self.mangled_name

    me matches_base(name: text) -> bool:
        return self.base_name == name

    static fn create(base: text, hash: int) -> MangledSignature:
        return MangledSignature(
            base_name: base,
            param_hash: hash,
            mangled_name: base + "_" + hash.to_text(),
            is_overloaded: false
        )

    static fn overloaded(base: text, hash: int) -> MangledSignature:
        return MangledSignature(
            base_name: base,
            param_hash: hash,
            mangled_name: base + "_ovl_" + hash.to_text(),
            is_overloaded: true
        )
