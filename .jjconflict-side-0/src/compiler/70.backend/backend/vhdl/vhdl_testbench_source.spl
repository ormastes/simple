class SourceMapHook:
    test_name: text
    expectation_index: int
    generated_entity: text
    dut_instance: text
    is_enabled: bool

    me disable() -> SourceMapHook:
        return SourceMapHook(
            test_name: self.test_name,
            expectation_index: self.expectation_index,
            generated_entity: self.generated_entity,
            dut_instance: self.dut_instance,
            is_enabled: false
        )

    me to_text() -> text:
        return "source-map:" + self.test_name + " entity=" + self.generated_entity + " dut=" + self.dut_instance

    static fn create(test: text, idx: int, entity: text, dut: text) -> SourceMapHook:
        return SourceMapHook(
            test_name: test,
            expectation_index: idx,
            generated_entity: entity,
            dut_instance: dut,
            is_enabled: true
        )


class TestDiagnostic:
    diagnostic_kind: text
    message: text
    source_test: text
    source_line: int

    me is_unsupported() -> bool:
        return self.diagnostic_kind == "unsupported"

    me is_collision() -> bool:
        return self.diagnostic_kind == "collision"

    me to_text() -> text:
        return self.diagnostic_kind + ": " + self.message + " at " + self.source_test + ":" + self.source_line.to_text()

    static fn unsupported(msg: text, test: text, line: int) -> TestDiagnostic:
        return TestDiagnostic(
            diagnostic_kind: "unsupported",
            message: msg,
            source_test: test,
            source_line: line
        )

    static fn collision(msg: text, test: text, line: int) -> TestDiagnostic:
        return TestDiagnostic(
            diagnostic_kind: "collision",
            message: msg,
            source_test: test,
            source_line: line
        )

    static fn missing_port(msg: text, test: text, line: int) -> TestDiagnostic:
        return TestDiagnostic(
            diagnostic_kind: "missing_port",
            message: msg,
            source_test: test,
            source_line: line
        )


class ConversionResult:
    test_name: text
    success: bool
    diagnostic_count: int
    output_lines: int

    me has_diagnostics() -> bool:
        return self.diagnostic_count > 0

    me is_clean() -> bool:
        return self.success and self.diagnostic_count == 0

    me to_text() -> text:
        if self.success:
            return "OK " + self.test_name
        return "FAIL " + self.test_name + " (" + self.diagnostic_count.to_text() + " diagnostics)"

    static fn ok(name: text, lines: int) -> ConversionResult:
        return ConversionResult(
            test_name: name,
            success: true,
            diagnostic_count: 0,
            output_lines: lines
        )

    static fn fail(name: text, diags: int) -> ConversionResult:
        return ConversionResult(
            test_name: name,
            success: false,
            diagnostic_count: diags,
            output_lines: 0
        )


class PendingSpec:
    spec_name: text
    category: text
    is_runnable: bool
    blocker: text

    me is_blocked() -> bool:
        return self.is_runnable == false

    me unblock() -> PendingSpec:
        return PendingSpec(
            spec_name: self.spec_name,
            category: self.category,
            is_runnable: true,
            blocker: ""
        )

    me to_text() -> text:
        if self.is_runnable:
            return "READY " + self.spec_name
        return "BLOCKED " + self.spec_name + ": " + self.blocker

    static fn blocked(name: text, cat: text, reason: text) -> PendingSpec:
        return PendingSpec(
            spec_name: name,
            category: cat,
            is_runnable: false,
            blocker: reason
        )

    static fn ready(name: text, cat: text) -> PendingSpec:
        return PendingSpec(
            spec_name: name,
            category: cat,
            is_runnable: true,
            blocker: ""
        )
