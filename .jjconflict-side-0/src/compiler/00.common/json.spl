# Compiler JSON — compiler.common.json
#
# Provides JsonValue and json_parse for use within the compiler.
# Thin re-export of the blocks-layer JsonValue plus the runtime extern.
#
# Consumers:
#   - compiler/60.mir_opt/optimizer_manifest.spl

export use compiler.blocks.value.{JsonValue, JsonKind}

# json_parse is a runtime extern declared here for compiler-layer callers.
extern fn json_parse(input: text) -> Result<JsonValue, text>
