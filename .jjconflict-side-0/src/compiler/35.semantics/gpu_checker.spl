# GPU Kernel Constraint Checker
#
# Validates that functions annotated with @gpu / @gpu_kernel / kernel fn
# conform to the GPU kernel subset. GPU kernels execute on massively
# parallel hardware (CUDA, Vulkan compute) and cannot use features
# that require heap allocation, dynamic dispatch, or host-side I/O.
#
# Checks enforced:
# - No heap allocation (no [] literals, no string concat, no dict/set)
# - No closures or captures
# - No recursion (direct or indirect)
# - No dynamic dispatch (no trait objects, no dyn types)
# - No I/O or FFI calls (except gpu_* builtins)
# - Parameters must be: numeric scalars, arrays of scalars, or structs of scalars
# - No async/await, no spawn, no actors
# - No exceptions (no throw/try-catch)

# ============================================================================
# GPU Check Error
# ============================================================================

enum GpuCheckError:
    """Error detected in a GPU kernel function."""
    HeapAllocation(detail: text, line: i64)
    ClosureCapture(detail: text, line: i64)
    Recursion(fn_name: text, line: i64)
    DynamicDispatch(detail: text, line: i64)
    ForbiddenCall(fn_name: text, line: i64)
    InvalidParamType(param_name: text, type_name: text, line: i64)
    AsyncNotAllowed(detail: text, line: i64)
    ExceptionNotAllowed(detail: text, line: i64)
    StringOperation(detail: text, line: i64)
    UnsupportedFeature(detail: text, line: i64)

impl GpuCheckError:
    fn to_text() -> text:
        match self:
            case HeapAllocation(detail, line):
                "GPU kernel error (line {line}): heap allocation not allowed in GPU kernels: {detail}"
            case ClosureCapture(detail, line):
                "GPU kernel error (line {line}): closures and captures not allowed in GPU kernels: {detail}"
            case Recursion(fn_name, line):
                "GPU kernel error (line {line}): recursion not allowed in GPU kernels: function '{fn_name}' calls itself"
            case DynamicDispatch(detail, line):
                "GPU kernel error (line {line}): dynamic dispatch not allowed in GPU kernels: {detail}"
            case ForbiddenCall(fn_name, line):
                "GPU kernel error (line {line}): function '{fn_name}' cannot be called from GPU kernels (only gpu_* builtins allowed)"
            case InvalidParamType(param_name, type_name, line):
                "GPU kernel error (line {line}): parameter '{param_name}' has type '{type_name}' which is not valid for GPU kernels (use numeric scalars, arrays of scalars, or structs of scalars)"
            case AsyncNotAllowed(detail, line):
                "GPU kernel error (line {line}): async/await/spawn not allowed in GPU kernels: {detail}"
            case ExceptionNotAllowed(detail, line):
                "GPU kernel error (line {line}): throw/try-catch not allowed in GPU kernels: {detail}"
            case StringOperation(detail, line):
                "GPU kernel error (line {line}): string operations not allowed in GPU kernels: {detail}"
            case UnsupportedFeature(detail, line):
                "GPU kernel error (line {line}): {detail}"

    fn line() -> i64:
        match self:
            case HeapAllocation(_, l): l
            case ClosureCapture(_, l): l
            case Recursion(_, l): l
            case DynamicDispatch(_, l): l
            case ForbiddenCall(_, l): l
            case InvalidParamType(_, _, l): l
            case AsyncNotAllowed(_, l): l
            case ExceptionNotAllowed(_, l): l
            case StringOperation(_, l): l
            case UnsupportedFeature(_, l): l

# ============================================================================
# GPU Allowed Types
# ============================================================================

val GPU_SCALAR_TYPES: [text] = [
    "i8", "i16", "i32", "i64",
    "u8", "u16", "u32", "u64",
    "f32", "f64",
    "bool"
]

fn is_gpu_scalar_type(type_name: text) -> bool:
    """Check if a type name is a valid GPU scalar type."""
    for t in GPU_SCALAR_TYPES:
        if t == type_name:
            return true
    false

fn is_gpu_builtin_call(fn_name: text) -> bool:
    """Check if a function name is a GPU builtin intrinsic."""
    fn_name.starts_with("gpu_")

fn is_gpu_allowed_extern(fn_name: text) -> bool:
    """Check if an extern function is allowed in GPU kernels."""
    # Only gpu_* builtins are allowed
    is_gpu_builtin_call(fn_name)

# ============================================================================
# GPU Kernel Checker
# ============================================================================

class GpuKernelChecker:
    """Validates GPU kernel functions for conformance to the GPU subset.

    Usage:
        var checker = GpuKernelChecker.create("my_kernel")
        checker.check_param_type("a", "[f32]", 10)
        checker.check_no_heap_alloc("array literal", 15)
        checker.check_call("print", false, 20)
        if checker.has_errors():
            for err in checker.get_errors():
                eprint(err.to_text())
    """
    kernel_name: text
    errors: [GpuCheckError]

    static fn create(name: text) -> GpuKernelChecker:
        GpuKernelChecker(kernel_name: name, errors: [])

    # ------------------------------------------------------------------
    # Parameter type validation
    # ------------------------------------------------------------------

    me check_param_type(param_name: text, type_name: text, line: i64):
        """Check that a parameter type is valid for GPU kernels.

        Valid types:
        - Numeric scalars: i8, i16, i32, i64, u8, u16, u32, u64, f32, f64, bool
        - Arrays of scalars: [f32], [i32], etc.
        - Structs of scalars (checked structurally elsewhere)
        """
        if is_gpu_scalar_type(type_name):
            return

        # Array of scalar: [T] where T is a scalar
        if type_name.starts_with("[") and type_name.ends_with("]"):
            val inner = type_name[1..type_name.len() - 1]
            if is_gpu_scalar_type(inner):
                return

        # Pointer types for buffers
        if type_name.starts_with("*"):
            return

        self.errors.push(GpuCheckError.InvalidParamType(param_name, type_name, line))

    # ------------------------------------------------------------------
    # Heap allocation checks
    # ------------------------------------------------------------------

    me check_no_heap_alloc(detail: text, line: i64):
        """Report a heap allocation violation."""
        self.errors.push(GpuCheckError.HeapAllocation(detail, line))

    me check_no_array_literal(line: i64):
        """Array literals allocate on the heap."""
        self.errors.push(GpuCheckError.HeapAllocation("array literal []", line))

    me check_no_dict_literal(line: i64):
        """Dict literals allocate on the heap."""
        self.errors.push(GpuCheckError.HeapAllocation("dict literal {}", line))

    me check_no_set_literal(line: i64):
        """Set literals allocate on the heap."""
        self.errors.push(GpuCheckError.HeapAllocation("set literal s{}", line))

    me check_no_string_concat(line: i64):
        """String concatenation allocates."""
        self.errors.push(GpuCheckError.StringOperation("string concatenation", line))

    me check_no_string_interpolation(line: i64):
        """String interpolation allocates."""
        self.errors.push(GpuCheckError.StringOperation("string interpolation", line))

    # ------------------------------------------------------------------
    # Closure / capture checks
    # ------------------------------------------------------------------

    me check_no_closure(detail: text, line: i64):
        """Report a closure/capture violation."""
        self.errors.push(GpuCheckError.ClosureCapture(detail, line))

    me check_no_lambda(line: i64):
        """Lambda expressions create closures."""
        self.errors.push(GpuCheckError.ClosureCapture("lambda expression", line))

    # ------------------------------------------------------------------
    # Recursion checks
    # ------------------------------------------------------------------

    me check_no_recursion(callee_name: text, line: i64):
        """Report a recursive call violation."""
        if callee_name == self.kernel_name:
            self.errors.push(GpuCheckError.Recursion(callee_name, line))

    # ------------------------------------------------------------------
    # Dynamic dispatch checks
    # ------------------------------------------------------------------

    me check_no_dynamic_dispatch(detail: text, line: i64):
        """Report a dynamic dispatch violation."""
        self.errors.push(GpuCheckError.DynamicDispatch(detail, line))

    me check_no_trait_object(type_name: text, line: i64):
        """Trait objects require dynamic dispatch."""
        if type_name.starts_with("dyn "):
            self.errors.push(GpuCheckError.DynamicDispatch("trait object '{type_name}'", line))

    # ------------------------------------------------------------------
    # Call checks (I/O, FFI, non-GPU builtins)
    # ------------------------------------------------------------------

    me check_call(fn_name: text, is_extern: bool, line: i64):
        """Check that a function call is allowed in GPU kernels."""
        # GPU builtins are always allowed
        if is_gpu_builtin_call(fn_name):
            return

        # Extern calls (FFI) are forbidden except gpu_* builtins
        if is_extern:
            self.errors.push(GpuCheckError.ForbiddenCall(fn_name, line))
            return

        # I/O functions are forbidden
        if fn_name == "print" or fn_name == "eprint" or fn_name == "println":
            self.errors.push(GpuCheckError.ForbiddenCall(fn_name, line))
            return

        # File/network/system calls are forbidden
        if fn_name.starts_with("rt_"):
            self.errors.push(GpuCheckError.ForbiddenCall(fn_name, line))

    # ------------------------------------------------------------------
    # Async / exception checks
    # ------------------------------------------------------------------

    me check_no_async(detail: text, line: i64):
        """Report an async/await/spawn violation."""
        self.errors.push(GpuCheckError.AsyncNotAllowed(detail, line))

    me check_no_await(line: i64):
        """Await not allowed in GPU kernels."""
        self.errors.push(GpuCheckError.AsyncNotAllowed("await expression", line))

    me check_no_spawn(line: i64):
        """Spawn not allowed in GPU kernels."""
        self.errors.push(GpuCheckError.AsyncNotAllowed("spawn expression", line))

    me check_no_throw(line: i64):
        """Throw not allowed in GPU kernels."""
        self.errors.push(GpuCheckError.ExceptionNotAllowed("throw statement", line))

    me check_no_try_catch(line: i64):
        """Try-catch not allowed in GPU kernels."""
        self.errors.push(GpuCheckError.ExceptionNotAllowed("try-catch block", line))

    me check_no_yield(line: i64):
        """Yield not allowed in GPU kernels."""
        self.errors.push(GpuCheckError.UnsupportedFeature("yield not allowed in GPU kernels", line))

    # ------------------------------------------------------------------
    # Result accessors
    # ------------------------------------------------------------------

    fn has_errors() -> bool:
        not self.errors.is_empty()

    fn get_errors() -> [GpuCheckError]:
        self.errors

    fn error_count() -> i64:
        self.errors.len()

    fn format_report() -> text:
        """Format all errors as a human-readable report."""
        if self.errors.is_empty():
            return "GPU kernel '{self.kernel_name}': all checks passed"

        var lines: [text] = []
        lines.push("GPU kernel '{self.kernel_name}': {self.errors.len()} error(s) found:")
        for err in self.errors:
            lines.push("  - {err.to_text()}")
        lines.join("\n")

# ============================================================================
# Convenience Functions
# ============================================================================

fn check_gpu_kernel_param(param_name: text, type_name: text) -> GpuCheckError?:
    """Quick check if a parameter type is valid for GPU kernels."""
    if is_gpu_scalar_type(type_name):
        return nil
    if type_name.starts_with("[") and type_name.ends_with("]"):
        val inner = type_name[1..type_name.len() - 1]
        if is_gpu_scalar_type(inner):
            return nil
    if type_name.starts_with("*"):
        return nil
    Some(GpuCheckError.InvalidParamType(param_name, type_name, 0))

fn is_gpu_safe_call(fn_name: text) -> bool:
    """Check if a function call is safe within a GPU kernel."""
    if is_gpu_builtin_call(fn_name):
        return true
    # Math builtins that map to GPU intrinsics
    if fn_name == "abs" or fn_name == "min" or fn_name == "max":
        return true
    if fn_name == "sqrt" or fn_name == "sin" or fn_name == "cos":
        return true
    if fn_name == "exp" or fn_name == "log" or fn_name == "pow":
        return true
    if fn_name == "floor" or fn_name == "ceil" or fn_name == "round":
        return true
    false
