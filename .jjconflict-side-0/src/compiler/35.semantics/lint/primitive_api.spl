# primitive_api Lint
#
# Warns when bare primitives (i64, i32, f64, f32, bool) appear in:
# - Function parameter types (all visibility levels)
# - Function return types (all visibility levels)
# - Struct/class field types (all visibility levels)
#
# Does NOT warn on:
# - Constructor arguments (ActorId(value: 42)) - the literal 42 is fine
# - Expression-level usage of primitives
# - Code annotated with @allow(primitive_api)
# - Pure math functions where all params + return are the same primitive
#   (e.g., fn abs(x: f64) -> f64, fn max(a: i64, b: i64) -> i64)

from ast import {Node, FunctionDef, StructDef, ClassDef, Type, Parameter, Field}

# Bare primitives that should be wrapped in public APIs
val BARE_PRIMITIVES = ["i64", "i32", "i16", "i8", "u64", "u32", "u16", "u8", "f64", "f32"]

struct LintWarning:
    message: text
    item_name: text
    field_or_param: text
    code: text                  # "primitive_api" (default) | "raw_unit"

    fn fmt() -> text:
        val prefix = if self.code == "": "primitive_api" else: self.code
        "{prefix}: {self.message} in '{self.item_name}' ({self.field_or_param})"

fn is_bare_primitive(ty: Type) -> bool:
    """Check if a type is a bare primitive that should be wrapped."""
    match ty:
        case Simple(name):
            for p in BARE_PRIMITIVES:
                if name == p:
                    return true
            false
        case _: false

fn is_pure_math_function(func: FunctionDef) -> bool:
    """Check if a function is a pure math helper where all params and return share the same primitive type.
    Examples: fn abs(x: f64) -> f64, fn max(a: i64, b: i64) -> i64"""
    # Must have at least 1 parameter and a return type
    if func.params.len() == 0:
        return false
    if not func.return_type.?:
        return false

    val ret = func.return_type.unwrap()

    # Return type must be a bare primitive
    if not is_bare_primitive(ret):
        return false

    # Extract return type name
    var ret_name = ""
    match ret:
        case Simple(name): ret_name = name
        case _: return false

    # All parameter types must match the return type
    for param in func.params:
        if not param.ty.?:
            return false
        val ty = param.ty.unwrap()
        match ty:
            case Simple(name):
                if name != ret_name:
                    return false
            case _: return false

    true

fn check_function(func: FunctionDef) -> [LintWarning]:
    """Check a function for bare primitive usage (all visibility levels)."""
    var warnings = []

    # Exempt pure math functions (all params + return are same primitive)
    if is_pure_math_function(func):
        return []

    # Check parameters
    for param in func.params:
        if param.ty.?:
            val ty = param.ty.unwrap()
            if is_bare_primitive(ty):
                warnings.push(LintWarning(
                    message: "bare primitive parameter type",
                    item_name: func.name,
                    field_or_param: "param '{param.name}'",
                    code: "primitive_api"
                ))

    # Check return type
    if func.return_type.?:
        val ret = func.return_type.unwrap()
        if is_bare_primitive(ret):
            warnings.push(LintWarning(
                message: "bare primitive return type",
                item_name: func.name,
                field_or_param: "return type",
                code: "primitive_api"
            ))

    warnings

fn check_struct(struct_def: StructDef) -> [LintWarning]:
    """Check a struct for bare primitive fields (all visibility levels)."""
    var warnings = []

    for field in struct_def.fields:
        if field.ty.?:
            val ty = field.ty.unwrap()
            if is_bare_primitive(ty):
                warnings.push(LintWarning(
                    message: "bare primitive field type",
                    item_name: struct_def.name,
                    field_or_param: "field '{field.name}'",
                    code: "primitive_api"
                ))

    warnings

fn check_class(class_def: ClassDef) -> [LintWarning]:
    """Check a class for bare primitive fields (all visibility levels)."""
    var warnings = []

    for field in class_def.fields:
        if field.ty.?:
            val ty = field.ty.unwrap()
            if is_bare_primitive(ty):
                warnings.push(LintWarning(
                    message: "bare primitive field type",
                    item_name: class_def.name,
                    field_or_param: "field '{field.name}'",
                    code: "primitive_api"
                ))

    warnings

fn check_module_items(items: [Node]) -> [LintWarning]:
    """Run primitive_api lint on all module items."""
    var warnings = []

    for item in items:
        match item:
            case Function(func):
                val fn_warnings = check_function(func)
                for w in fn_warnings:
                    warnings.push(w)
            case Struct(struct_def):
                val s_warnings = check_struct(struct_def)
                for w in s_warnings:
                    warnings.push(w)
            case Class(class_def):
                val c_warnings = check_class(class_def)
                for w in c_warnings:
                    warnings.push(w)
            case _: pass

    warnings

# ---------------------------------------------------------------------------
# raw_unit — call-site lint (unit-system-consolidation AC-4)
# ---------------------------------------------------------------------------
#
# Emits when a raw integer/float literal is passed to a parameter whose type
# is owned by a `unit.*` module (i.e., a unit type). Suppressible via
# `#[allow(raw_unit)]` on the call site / enclosing statement / function /
# module (handled by the shared allow-attr machinery).

fn is_unit_type(ty: Type) -> bool:
    """A type is a 'unit type' if its module path starts with `unit.` after resolution.

    We accept both forms the compiler uses:
      * Qualified(module_path, _): path starts with 'unit.'
      * Simple(name): name looks like 'unit.foo.bar' (seen when unresolved dotted names flow through)."""
    match ty:
        case Qualified(module_path, _):
            module_path.starts_with("unit.")
        case Simple(name):
            name.starts_with("unit.")
        case _("Generic/Function/Tuple/Array types cannot be unit types"): false

fn is_raw_primitive_expr(expr: any) -> bool:
    """True for integer/float literals WITHOUT a unit suffix (ExprInt/ExprFloat
    or AST nodes with kind IntLit/FloatLit). Suffixed literals — `10_km`,
    `1.5_kg` — are treated as already unit-typed and do NOT trigger."""
    match expr:
        case IntLit(_): true
        case FloatLit(_): true
        case ExprInt(_): true
        case ExprFloat(_): true
        # Suffixed literals lower to typed nodes elsewhere; any kind carrying
        # a suffix name is NOT a raw primitive.
        case SuffixedInt(_, _): false
        case SuffixedFloat(_, _): false
        case _("non-literal exprs (calls, vars, casts) already carry a type; only bare literals count as raw"): false

fn check_call_site(callee_name: text, args: [any], callee: FunctionDef) -> [LintWarning]:
    """Emit `raw_unit` warnings for each arg where the callee's matching
    parameter is a unit-typed param and the arg expression is a raw primitive
    literal.

    Caller responsibility: pass the resolved callee's `FunctionDef` plus the
    call's argument expressions (AST nodes) and the callee's printable name.
    This is the direct form used by resolution passes that already have the
    three values in hand (e.g., `HirExpr::Call(callee, args)` in HIR)."""
    var warnings = []
    val params = callee.params
    var i: i64 = 0
    for arg in args:
        if i >= params.len():
            break
        val param = params[i]
        if param.ty.?:
            val ty = param.ty.unwrap()
            if is_unit_type(ty) and is_raw_primitive_expr(arg):
                val unit_name = unit_type_short(ty)
                val msg = "raw primitive passed to unit-typed parameter '{param.name}: {unit_name}'; use '<N>_{unit_name}' postfix or explicit conversion"
                warnings.push(LintWarning(
                    message: msg,
                    item_name: callee_name,
                    field_or_param: "arg #{i} ('{param.name}')",
                    code: "raw_unit"
                ))
        i = i + 1
    warnings

fn unit_type_short(ty: Type) -> text:
    """Last segment of a unit type's module path — i.e., the short unit symbol
    (e.g. 'unit.length.km' → 'km')."""
    var path: text = ""
    match ty:
        case Qualified(module_path, _): path = module_path
        case Simple(name): path = name
        case _("Generic/Function/Tuple types cannot be unit types — empty short symbol"): return ""
    val parts = path.split(".")
    if parts.len() == 0:
        return path
    parts[parts.len() - 1]

