# MDSOC Security Dimension Integration
#
# Compile-time orchestrator for the security AOP dimension.
# Integrates the 5-layer security capsule architecture (crypto, enforcement,
# validation, auth, audit) with the MDSOC weaving engine.
#
# This module:
# 1. Builds a SecurityDimensionDef from the capsule.sdn security section
# 2. Validates security layer ordering and dependency direction
# 3. Merges security AOP aspects into the weaving pipeline
# 4. Provides SecurityGate join point detection for capability-gated code
#
# The security dimension is always woven at compile time when enabled,
# ensuring zero-gap coverage with zero security code in business modules.

use compiler.mdsoc.types.dimension_def.{DimensionDef}
use compiler.mdsoc.types.layer_def.{LayerDef}
use compiler.mdsoc.types.layer_direction.{LayerDirection}
use compiler.mdsoc.types.capsule_rules.{CapsuleRules}
use compiler.mdsoc.types.mdsoc_manifest.{MdsocManifest}
use compiler.mdsoc.types.virtual_capsule.{VirtualCapsule}
use compiler.mdsoc.weaving.weaving_config.{WeavingConfig, weavingconfig_disabled, weavingconfig_with_security_aspects}
use compiler.mdsoc.weaving.join_point_kind.{JoinPointKind}
use compiler.mdsoc.weaving.join_point.{JoinPoint, JoinPointContext}
use compiler.mdsoc.layer_checker.{LayerChecker, check_layer_dep}


# ============================================================================
# Security Dimension Constants
# ============================================================================

val SECURITY_DIMENSION_NAME: text = "security"
val SECURITY_LAYER_COUNT: i64 = 5

val LAYER_CRYPTO: text = "crypto"
val LAYER_ENFORCEMENT: text = "enforcement"
val LAYER_VALIDATION: text = "validation"
val LAYER_AUTH: text = "auth"
val LAYER_AUDIT: text = "audit"


# ============================================================================
# Security Dimension Definition
# ============================================================================

## Build the canonical security dimension definition.
##
## The security dimension has 5 ordered layers with lower_to_upper
## dependency direction: crypto (foundational) through audit (top).
fn security_dimension_def() -> DimensionDef:
    """
    Returns the security MDSOC dimension with 5 layers.

    Layer ordering: crypto -> enforcement -> validation -> auth -> audit
    Direction: lower_to_upper (crypto is foundational, audit sits on top)

    sdoctest:
        val dim = security_dimension_def()
        expect(dim.name).to_equal("security")
        expect(dim.layer.layer_count()).to_equal(5)
    """
    val layer_order = [
        LAYER_CRYPTO,
        LAYER_ENFORCEMENT,
        LAYER_VALIDATION,
        LAYER_AUTH,
        LAYER_AUDIT
    ]

    var layer_def = LayerDef.new(layer_order, LayerDirection.LowerToUpper)
    layer_def.allow_same_layer = true
    layer_def.allow_adjacent_only = false

    var dim = DimensionDef.new(SECURITY_DIMENSION_NAME, "security/{name}")
    dim.dimension_kind = "horizontal"
    dim.layer = layer_def
    dim


## Get the canonical layer ordering for the security dimension.
fn security_layer_order() -> [text]:
    """
    Returns the 5 security layers in dependency order.

    sdoctest:
        val layers = security_layer_order()
        expect(layers.len()).to_equal(5)
        expect(layers[0]).to_equal("crypto")
        expect(layers[4]).to_equal("audit")
    """
    [LAYER_CRYPTO, LAYER_ENFORCEMENT, LAYER_VALIDATION, LAYER_AUTH, LAYER_AUDIT]


## Validate that a layer name is a valid security layer.
fn is_valid_security_layer(layer_name: text) -> bool:
    """
    Checks if the given name is one of the 5 security capsule layers.

    sdoctest:
        expect(is_valid_security_layer("crypto")).to_equal(true)
        expect(is_valid_security_layer("network")).to_equal(false)
    """
    val layers = security_layer_order()
    for l in layers:
        if l == layer_name:
            return true
    false


# ============================================================================
# Security Weaving Integration
# ============================================================================

## Create a security-enhanced weaving config from a base config.
##
## Merges the 6 built-in security AOP aspects (audit, auth, validation)
## into the provided base weaving config. Security aspects are always-on
## when this function is called.
fn enable_security_weaving(base_config: WeavingConfig) -> WeavingConfig:
    """
    Enables security AOP weaving by merging security aspects into base config.

    Adds:
    - Audit: Around advice for HTTP requests, AfterSuccess/AfterError for auth
    - Auth: Before advice for @requires_auth, @requires_capability
    - Validation: Around advice for HTML render, Before for input validation

    sdoctest:
        val base = weavingconfig_disabled()
        val sec = enable_security_weaving(base)
        expect(sec.enabled).to_equal(true)
        expect(sec.before_advices.len()).to_be_greater_than(0)
    """
    weavingconfig_with_security_aspects(base_config)


## Check whether a manifest has the security dimension enabled.
fn has_security_dimension(manifest: MdsocManifest) -> bool:
    """
    Returns true if the manifest declares a security dimension.

    sdoctest:
        val m = MdsocManifest.new("test")
        expect(has_security_dimension(m)).to_equal(false)
    """
    val dim_opt = manifest.get_dimension(SECURITY_DIMENSION_NAME)
    if val Some(dim) = dim_opt:
        return true
    false


# ============================================================================
# Security Layer Checker
# ============================================================================

## Create a LayerChecker configured for the security dimension.
##
## Pre-registers the 5 security capsule modules at their correct layers
## so that dependency violations between security subsystems are caught
## at compile time.
fn security_layer_checker() -> LayerChecker:
    """
    Creates a LayerChecker for the security dimension.

    sdoctest:
        val checker = security_layer_checker()
        expect(checker.has_violations()).to_equal(false)
    """
    val dim = security_dimension_def()
    var checker = LayerChecker.new(dim.layer)

    # Register the 5 security capsule paths
    checker.assign_module_layer("std.security.crypto", LAYER_CRYPTO)
    checker.assign_module_layer("std.security.enforcement", LAYER_ENFORCEMENT)
    checker.assign_module_layer("std.security.validation", LAYER_VALIDATION)
    checker.assign_module_layer("std.security.auth", LAYER_AUTH)
    checker.assign_module_layer("std.security.audit", LAYER_AUDIT)

    checker


## Validate a dependency between two security modules.
##
## Returns nil if the dependency is allowed, or an error message if it
## violates the security layer ordering.
fn check_security_dependency(from_module: text, to_module: text) -> text?:
    """
    Validates that a dependency between security modules respects layer ordering.

    crypto is foundational; audit depends on everything below.
    Direction is lower_to_upper: lower layers may be depended upon by higher layers.

    sdoctest:
        # audit depending on crypto is allowed (higher depends on lower)
        val r1 = check_security_dependency("std.security.audit", "std.security.crypto")
        expect(r1.?).to_equal(false)

        # crypto depending on audit is NOT allowed
        val r2 = check_security_dependency("std.security.crypto", "std.security.audit")
        expect(r2.?).to_equal(true)
    """
    val checker = security_layer_checker()
    val violation = checker.check_dependency(from_module, to_module)
    if val Some(v) = violation:
        return Some(v.message)
    nil


# ============================================================================
# SecurityGate Join Point Detection
# ============================================================================

## Detect SecurityGate join points in a function based on capability attributes.
##
## A SecurityGate join point is created when a function accesses a
## capability-gated resource. The weaving engine uses these to attach
## enforcement advice at compile time.
fn detect_security_gate(function_name: text, module_path: text,
                        attributes: [text]) -> JoinPoint?:
    """
    Scans function attributes for capability requirements and creates
    a SecurityGate JoinPoint if found.

    sdoctest:
        val jp = detect_security_gate("read_file", "std.io",
            ["cap=FileSystemRead", "resource=/data"])
        expect(jp.?).to_equal(true)
    """
    var capability = ""
    var resource = ""

    for attr in attributes:
        if attr.starts_with("cap="):
            capability = attr.slice(4, attr.len())
        else if attr.starts_with("resource="):
            resource = attr.slice(9, attr.len())

    if capability == "":
        return nil

    val kind = JoinPointKind.SecurityGate(
        capability: capability,
        resource: resource
    )

    val ctx = JoinPointContext(
        function_name: function_name,
        module_path: module_path,
        signature: "",
        attributes: attributes,
        effects: []
    )

    Some(JoinPoint(
        kind: kind,
        block_id: 0,
        instruction_index: 0,
        context: ctx
    ))


## Check if a join point is a SecurityGate kind.
fn is_security_gate(jp: JoinPoint) -> bool:
    """
    Returns true if the join point is a SecurityGate.

    sdoctest:
        val kind = JoinPointKind.SecurityGate(capability: "net", resource: "tcp")
        val ctx = JoinPointContext(
            function_name: "send",
            module_path: "net",
            signature: "",
            attributes: [],
            effects: []
        )
        val jp = JoinPoint(kind: kind, block_id: 0, instruction_index: 0, context: ctx)
        expect(is_security_gate(jp)).to_equal(true)
    """
    match jp.kind:
        JoinPointKind.SecurityGate(_, _): true
        _: false


# ============================================================================
# Security Capsule Validation
# ============================================================================

## Validate a complete security dimension configuration.
##
## Checks:
## 1. Exactly 5 layers in the correct order
## 2. Direction is lower_to_upper
## 3. No cycles allowed
## 4. Layering enforcement enabled
fn validate_security_dimension(dim: DimensionDef) -> Result<bool, text>:
    """
    Validates that a dimension definition conforms to security requirements.

    sdoctest:
        val dim = security_dimension_def()
        val result = validate_security_dimension(dim)
        expect(result.is_err()).to_equal(false)
    """
    # Check name
    if dim.name != SECURITY_DIMENSION_NAME:
        return Err("dimension name must be 'security', got '{dim.name}'")

    # Check layer count
    if dim.layer.layer_count() != SECURITY_LAYER_COUNT:
        return Err("security dimension must have exactly {SECURITY_LAYER_COUNT} layers, got {dim.layer.layer_count()}")

    # Check layer ordering
    val expected = security_layer_order()
    var i: i64 = 0
    for layer_name in expected:
        if not dim.layer.has_layer(layer_name):
            return Err("missing security layer: {layer_name}")
        val level = dim.layer.get_level(layer_name)
        if level != i:
            return Err("security layer '{layer_name}' at wrong position: expected {i}, got {level}")
        i = i + 1

    Ok(true)
