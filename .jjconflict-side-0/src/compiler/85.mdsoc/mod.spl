# MDSOC Module — Multi-Dimensional Separation of Concerns
#
# Provides manifest-composed virtual capsules for the Simple compiler.
#
# Modules:
#   types/                — Core types (one struct per file)
#   construct_types/      — Construct dimension types (one struct per file)
#   checker_types/        — Layer checker result types (one struct per file)
#   config.spl            — SDN config parser for capsule.sdn
#   layer_checker.spl     — Layer dependency enforcement
#   layer_doc_checker.spl — Public documentation validation
#   construct_checker.spl — Construct tier enforcement (second dimension)
#   cross_query.spl       — Cross-dimension queries (feature x construct)
#
# Usage (prefer individual imports for one-struct-per-file):
#   use compiler.mdsoc.types.caret_id.{CaretId}
#   use compiler.mdsoc.types.layer_def.{LayerDef}
#   use compiler.mdsoc.types.virtual_capsule.{VirtualCapsule}
#   use compiler.mdsoc.checker_types.layer_violation.{LayerViolation}
#   use compiler.mdsoc.layer_checker.{LayerChecker}
#   use compiler.mdsoc.config.{load_mdsoc_config, parse_mdsoc_sdn}

# Re-export core types (via hub for backward compat)
use compiler.mdsoc.types.*

# Re-export construct dimension types (via hub)
use compiler.mdsoc.construct_types.*
