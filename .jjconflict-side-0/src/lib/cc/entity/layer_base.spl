# cc::Layer — compositor input layer base type.
#
# Mirrors cc::Layer from Chromium (cc/layers/layer.h). A Layer represents a
# 2D rectangular region with paint properties (background color, opacity,
# filters, transform, clip) and is the input to the cc -> viz pipeline.
#
# Compositor-thread impl types (cc::LayerImpl) are distinct; this is the
# main-thread authoring type — produced by Blink, consumed by the
# LayerTreeHost.
#
# NOTE: A sibling file `layer.spl` already defines a narrower Layer type
# (LayerKind, tree-id fields, needs_display). This file provides the richer
# cc::Layer base that mirrors the Chromium header more closely (SkRect bounds,
# SkPoint position, SkColor4f background, opacity, child list, explicit
# LayerId wrapper). Both coexist until the two APIs are unified.

use std.skia.entity.geometry.{SkRect, SkPoint, sk_point}
use std.skia.entity.color.{SkColor4f, sk_color4f}

# ---------------------------------------------------------------------------
# LayerType — tag for the layer's paint contract.
# Mirrors the Chromium cc layer subclass hierarchy (PictureLayer,
# TextureLayer, SolidColorLayer, VideoLayer, ScrollbarLayer, SurfaceLayer).
# `Content` is a generic fallback for layers without a specialized subclass.
# ---------------------------------------------------------------------------

enum LayerType:
    Content
    Picture
    TextureLayer
    SolidColor
    VideoLayer
    ScrollbarLayer
    SurfaceLayer

# ---------------------------------------------------------------------------
# LayerId — typed wrapper so caller sites can't confuse a raw i64 for a
# layer handle. Matches cc::ElementId / cc::Layer::id_ ergonomics.
# ---------------------------------------------------------------------------

class LayerId:
    value: i64

fn layer_id_new(value: i64) -> LayerId:
    LayerId(value: value)

# ---------------------------------------------------------------------------
# Layer — the main-thread compositor input.
#
# `transform_tree_index`, `clip_tree_index`, `effect_tree_index` and
# `scroll_tree_index` point into the cc::PropertyTrees owned by the
# LayerTreeHost. -1 means "not attached yet" (common during construction).
#
# `parent_id` and `children_ids` form the layer tree; the host keeps the
# canonical id->Layer map. `add_child` only mutates the parent side —
# callers are expected to set the child's `parent_id` themselves.
# ---------------------------------------------------------------------------

class Layer:
    id: LayerId
    layer_type: LayerType
    bounds: SkRect
    position: SkPoint
    background_color: SkColor4f
    opacity: f64
    contents_opaque: bool
    is_drawable: bool
    masks_to_bounds: bool
    transform_tree_index: i64
    clip_tree_index: i64
    effect_tree_index: i64
    scroll_tree_index: i64
    parent_id: i64
    children_ids: [i64]

# ---------------------------------------------------------------------------
# Factory — build a Layer with Chromium-style defaults.
#
# Defaults mirror cc::Layer's constructor: opacity 1.0, drawable true,
# contents_opaque false (conservative — the painter sets it when proved),
# masks_to_bounds false, all property-tree indices -1 (unattached),
# no parent, no children.
# ---------------------------------------------------------------------------

fn layer_new(id: LayerId, bounds: SkRect, layer_type: LayerType) -> Layer:
    Layer(
        id: id,
        layer_type: layer_type,
        bounds: bounds,
        position: sk_point(0.0, 0.0),
        background_color: sk_color4f(0.0, 0.0, 0.0, 0.0),
        opacity: 1.0,
        contents_opaque: false,
        is_drawable: true,
        masks_to_bounds: false,
        transform_tree_index: -1,
        clip_tree_index: -1,
        effect_tree_index: -1,
        scroll_tree_index: -1,
        parent_id: -1,
        children_ids: [i64]()
    )

# ---------------------------------------------------------------------------
# Mutators — mirror cc::Layer::SetXxx. Each matches the Chromium setter
# contract: plain field assignment with light validation.
# ---------------------------------------------------------------------------

impl Layer:
    me set_opacity(value: f64):
        # Clamp to [0, 1] — cc does the same in debug builds and viz always
        # treats opacity as saturated.
        val clamped = if value < 0.0: 0.0 else: if value > 1.0: 1.0 else: value
        self.opacity = clamped

    me set_background_color(c: SkColor4f):
        self.background_color = c

    me set_contents_opaque(value: bool):
        self.contents_opaque = value

    me set_is_drawable(value: bool):
        self.is_drawable = value

    me set_masks_to_bounds(value: bool):
        self.masks_to_bounds = value

    me set_position(p: SkPoint):
        self.position = p

    me set_bounds(b: SkRect):
        self.bounds = b

    # Append a child layer id. Caller is expected to set the child Layer's
    # `parent_id` to this Layer's id; the host normally does both halves in
    # one step. Duplicates are not deduplicated (matches cc behavior — a
    # layer should never be re-parented without an intervening remove).
    me add_child(child_id: i64):
        self.children_ids.push(child_id)

    # Linear scan remove — layer trees are shallow in practice, so O(n) is
    # fine. Returns true if the child was present and removed.
    me remove_child(child_id: i64) -> bool:
        var i = 0
        val n = self.children_ids.len().to_i64()
        while i < n:
            if self.children_ids[i] == child_id:
                # Shift-left tail to close the gap.
                var j = i
                while j < n - 1:
                    self.children_ids[j] = self.children_ids[j + 1]
                    j = j + 1
                self.children_ids.pop()
                return true
            i = i + 1
        false

    me is_root() -> bool:
        self.parent_id == -1

    me child_count() -> i64:
        self.children_ids.len().to_i64()
