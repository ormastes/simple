# Skia Geometry Types
#
# SkPoint, SkIPoint, SkSize, SkRect, SkIRect, SkRRect

# ============================================================================
# SkPoint
# ============================================================================

class SkPoint:
    x: f64
    y: f64

fn sk_point(x: f64, y: f64) -> SkPoint:
    SkPoint(x: x, y: y)

fn sk_point_zero() -> SkPoint:
    SkPoint(x: 0.0, y: 0.0)

impl SkPoint:
    fn length() -> f64:
        pass_todo

    fn distance_to(other: SkPoint) -> f64:
        pass_todo

    fn offset(dx: f64, dy: f64) -> SkPoint:
        SkPoint(x: self.x + dx, y: self.y + dy)

    fn to_string() -> text:
        "SkPoint({self.x}, {self.y})"

# ============================================================================
# SkIPoint
# ============================================================================

class SkIPoint:
    x: i64
    y: i64

fn sk_ipoint(x: i64, y: i64) -> SkIPoint:
    SkIPoint(x: x, y: y)

# ============================================================================
# SkSize
# ============================================================================

class SkSize:
    width: f64
    height: f64

fn sk_size(width: f64, height: f64) -> SkSize:
    SkSize(width: width, height: height)

impl SkSize:
    fn is_empty() -> bool:
        self.width <= 0.0 or self.height <= 0.0

    fn to_string() -> text:
        "SkSize({self.width}x{self.height})"

# ============================================================================
# SkISize
# ============================================================================

class SkISize:
    width: i64
    height: i64

fn sk_isize(width: i64, height: i64) -> SkISize:
    SkISize(width: width, height: height)

# ============================================================================
# SkRect
# ============================================================================

class SkRect:
    left: f64
    top: f64
    right: f64
    bottom: f64

fn sk_rect(left: f64, top: f64, right: f64, bottom: f64) -> SkRect:
    SkRect(left: left, top: top, right: right, bottom: bottom)

fn sk_rect_make_wh(w: f64, h: f64) -> SkRect:
    SkRect(left: 0.0, top: 0.0, right: w, bottom: h)

fn sk_rect_make_xywh(x: f64, y: f64, w: f64, h: f64) -> SkRect:
    SkRect(left: x, top: y, right: x + w, bottom: y + h)

impl SkRect:
    fn width() -> f64:
        self.right - self.left

    fn height() -> f64:
        self.bottom - self.top

    fn is_empty() -> bool:
        self.left >= self.right or self.top >= self.bottom

    fn contains_point(pt: SkPoint) -> bool:
        pt.x >= self.left and pt.x < self.right and pt.y >= self.top and pt.y < self.bottom

    fn intersects(other: SkRect) -> bool:
        self.left < other.right and self.right > other.left and
        self.top < other.bottom and self.bottom > other.top

    fn inset(dx: f64, dy: f64) -> SkRect:
        SkRect(left: self.left + dx, top: self.top + dy, right: self.right - dx, bottom: self.bottom - dy)

    fn offset(dx: f64, dy: f64) -> SkRect:
        SkRect(left: self.left + dx, top: self.top + dy, right: self.right + dx, bottom: self.bottom + dy)

    fn to_string() -> text:
        "SkRect({self.left}, {self.top}, {self.right}, {self.bottom})"

# ============================================================================
# SkIRect
# ============================================================================

class SkIRect:
    left: i64
    top: i64
    right: i64
    bottom: i64

fn sk_irect(left: i64, top: i64, right: i64, bottom: i64) -> SkIRect:
    SkIRect(left: left, top: top, right: right, bottom: bottom)

fn sk_irect_make_wh(w: i64, h: i64) -> SkIRect:
    SkIRect(left: 0, top: 0, right: w, bottom: h)

impl SkIRect:
    fn width() -> i64:
        self.right - self.left

    fn height() -> i64:
        self.bottom - self.top

    fn is_empty() -> bool:
        self.left >= self.right or self.top >= self.bottom

# ============================================================================
# SkRRect (Rounded Rect)
# ============================================================================

class SkRRect:
    rect: SkRect
    radius_x: f64
    radius_y: f64

fn sk_rrect_make(rect: SkRect, rx: f64, ry: f64) -> SkRRect:
    SkRRect(rect: rect, radius_x: rx, radius_y: ry)

fn sk_rrect_make_oval(rect: SkRect) -> SkRRect:
    val rx = (rect.right - rect.left) / 2.0
    val ry = (rect.bottom - rect.top) / 2.0
    SkRRect(rect: rect, radius_x: rx, radius_y: ry)

impl SkRRect:
    fn is_rect() -> bool:
        self.radius_x == 0.0 and self.radius_y == 0.0

    fn is_oval() -> bool:
        val w = self.rect.right - self.rect.left
        val h = self.rect.bottom - self.rect.top
        self.radius_x * 2.0 >= w and self.radius_y * 2.0 >= h
