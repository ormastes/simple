# Skia Font
#
# SkFont, SkTypeface — text rendering attributes.

use std.skia.entity.enums.{SkTextEncoding}

# ============================================================================
# SkFontStyle
# ============================================================================

enum SkFontWeight:
    Invisible
    Thin
    ExtraLight
    Light
    Normal
    Medium
    SemiBold
    Bold
    ExtraBold
    Black
    ExtraBlack

enum SkFontWidth:
    UltraCondensed
    ExtraCondensed
    Condensed
    SemiCondensed
    Normal
    SemiExpanded
    Expanded
    ExtraExpanded
    UltraExpanded

enum SkFontSlant:
    Upright
    Italic
    Oblique

class SkFontStyle:
    weight: SkFontWeight
    width: SkFontWidth
    slant: SkFontSlant

fn sk_font_style_normal() -> SkFontStyle:
    SkFontStyle(weight: SkFontWeight.Normal, width: SkFontWidth.Normal, slant: SkFontSlant.Upright)

fn sk_font_style_bold() -> SkFontStyle:
    SkFontStyle(weight: SkFontWeight.Bold, width: SkFontWidth.Normal, slant: SkFontSlant.Upright)

fn sk_font_style_italic() -> SkFontStyle:
    SkFontStyle(weight: SkFontWeight.Normal, width: SkFontWidth.Normal, slant: SkFontSlant.Italic)

fn sk_font_style_bold_italic() -> SkFontStyle:
    SkFontStyle(weight: SkFontWeight.Bold, width: SkFontWidth.Normal, slant: SkFontSlant.Italic)

# ============================================================================
# SkTypeface — font face (family + style)
# ============================================================================

class SkTypeface:
    family_name: text
    style: SkFontStyle

fn sk_typeface_default() -> SkTypeface:
    SkTypeface(family_name: "sans-serif", style: sk_font_style_normal())

fn sk_typeface_from_name(name: text, style: SkFontStyle) -> SkTypeface:
    SkTypeface(family_name: name, style: style)

impl SkTypeface:
    fn is_bold() -> bool:
        self.style.weight == SkFontWeight.Bold or self.style.weight == SkFontWeight.ExtraBold

    fn is_italic() -> bool:
        self.style.slant != SkFontSlant.Upright

# ============================================================================
# SkFont — typeface + size + hinting
# ============================================================================

enum SkFontHinting:
    None
    Slight
    Normal
    Full

class SkFont:
    typeface: SkTypeface
    size: f64
    scale_x: f64
    skew_x: f64
    hinting: SkFontHinting
    edging: bool   # true = anti-alias edge
    subpixel: bool

fn sk_font_new(typeface: SkTypeface, size: f64) -> SkFont:
    SkFont(
        typeface: typeface,
        size: size,
        scale_x: 1.0,
        skew_x: 0.0,
        hinting: SkFontHinting.Normal,
        edging: true,
        subpixel: false
    )

fn sk_font_default() -> SkFont:
    sk_font_new(sk_typeface_default(), 12.0)

impl SkFont:
    fn with_size(size: f64) -> SkFont:
        SkFont(
            typeface: self.typeface,
            size: size,
            scale_x: self.scale_x,
            skew_x: self.skew_x,
            hinting: self.hinting,
            edging: self.edging,
            subpixel: self.subpixel
        )

    fn measure_text(text: text) -> f64:
        pass_todo

    fn count_glyphs(text: text) -> i64:
        pass_todo

    fn to_string() -> text:
        "SkFont({self.typeface.family_name} {self.size}pt)"
