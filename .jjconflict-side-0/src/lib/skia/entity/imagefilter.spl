# Skia ImageFilter
#
# SkImageFilter — pixel-level image effect (blur, drop shadow, etc.)

use std.skia.entity.geometry.{SkRect}

# ============================================================================
# SkImageFilterKind
# ============================================================================

enum SkImageFilterKind:
    Blur
    DropShadow
    ColorFilter
    Compose
    Offset
    Dilate
    Erode
    DisplacementMap
    Blend
    Empty

# ============================================================================
# SkImageFilter
# ============================================================================

class SkImageFilter:
    kind: SkImageFilterKind
    sigma_x: f64
    sigma_y: f64
    dx: f64
    dy: f64
    color: i64
    crop_rect: SkRect?

fn sk_image_filter_blur(sigma_x: f64, sigma_y: f64) -> SkImageFilter:
    SkImageFilter(
        kind: SkImageFilterKind.Blur,
        sigma_x: sigma_x,
        sigma_y: sigma_y,
        dx: 0.0,
        dy: 0.0,
        color: 0,
        crop_rect: nil
    )

fn sk_image_filter_drop_shadow(dx: f64, dy: f64, sigma_x: f64, sigma_y: f64, color: i64) -> SkImageFilter:
    SkImageFilter(
        kind: SkImageFilterKind.DropShadow,
        sigma_x: sigma_x,
        sigma_y: sigma_y,
        dx: dx,
        dy: dy,
        color: color,
        crop_rect: nil
    )

fn sk_image_filter_offset(dx: f64, dy: f64) -> SkImageFilter:
    SkImageFilter(
        kind: SkImageFilterKind.Offset,
        sigma_x: 0.0,
        sigma_y: 0.0,
        dx: dx,
        dy: dy,
        color: 0,
        crop_rect: nil
    )

impl SkImageFilter:
    fn with_crop_rect(rect: SkRect) -> SkImageFilter:
        SkImageFilter(
            kind: self.kind,
            sigma_x: self.sigma_x,
            sigma_y: self.sigma_y,
            dx: self.dx,
            dy: self.dy,
            color: self.color,
            crop_rect: Some(rect)
        )
