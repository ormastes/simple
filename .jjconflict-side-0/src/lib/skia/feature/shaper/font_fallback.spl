# Font fallback chain for script-aware font selection

use std.skia.entity.font.{SkFont, sk_typeface_default, sk_font_new}
use std.skia.feature.shaper.script_detect.{Script}

extern fn rt_font_glyph_index(font_handle: i64, codepoint: i64) -> i64

class FallbackChain:
    primary: SkFont
    fallbacks: [SkFont]

fn fallback_chain_new(primary: SkFont) -> FallbackChain:
    FallbackChain(primary: primary, fallbacks: [])

fn fallback_chain_add(chain: FallbackChain, f: SkFont) -> FallbackChain:
    var new_fallbacks: [SkFont] = []
    for fb in chain.fallbacks:
        new_fallbacks.push(fb)
    new_fallbacks.push(f)
    FallbackChain(primary: chain.primary, fallbacks: new_fallbacks)

fn _contains_any(haystack: text, needles: [text]) -> bool:
    for needle in needles:
        if haystack.contains(needle):
            return true
    false

fn _script_family_score(family_name: text, s: Script) -> i32:
    val lower = family_name.lower()
    if s == Script.Latin:
        return 0
    if s == Script.Arabic:
        if _contains_any(lower, ["arabic", "naskh", "kufi", "amiri", "scheherazade"]):
            return 100
        return 0
    if s == Script.Hebrew:
        if _contains_any(lower, ["hebrew", "ivrit", "taamey", "alef"]):
            return 100
        return 0
    if s == Script.Devanagari:
        if _contains_any(lower, ["devanagari", "hindi", "noto sans devanagari", "noto serif devanagari"]):
            return 100
        return 0
    if s == Script.Thai:
        if _contains_any(lower, ["thai", "sarabun", "krub", "garuda"]):
            return 100
        return 0
    if s == Script.CJK:
        if _contains_any(lower, ["cjk", "jp", "japanese", "han", "song", "ming", "gothic", "sans cjk", "serif cjk", "noto sans cjk"]):
            return 100
        return 0
    if s == Script.Emoji:
        if _contains_any(lower, ["emoji", "color emoji"]):
            return 100
        return 0
    0

fn _font_supports_codepoint(font: SkFont, codepoint: u32) -> bool:
    val handle = font.typeface.font_handle
    if handle == 0:
        return false
    rt_font_glyph_index(handle, codepoint.to_i64()) > 0

fn _font_supports_run(font: SkFont, codepoints: [u32], start: i64, end_idx: i64) -> bool:
    if font.typeface.font_handle == 0:
        return false
    var i = start
    while i < end_idx:
        if not _font_supports_codepoint(font, codepoints[i]):
            return false
        i = i + 1
    true

fn fallback_chain_font_for_script(chain: FallbackChain, s: Script) -> SkFont:
    if s == Script.Latin or s == Script.Common or s == Script.Unknown:
        return chain.primary

    val primary_score = _script_family_score(chain.primary.typeface.family_name, s)
    if primary_score > 0:
        return chain.primary

    var best_font = chain.primary
    var best_score = primary_score
    for fb in chain.fallbacks:
        val score = _script_family_score(fb.typeface.family_name, s)
        if score > best_score:
            best_score = score
            best_font = fb

    if best_score > 0:
        return best_font

    if chain.fallbacks.len() > 0:
        return chain.fallbacks[0]

    chain.primary

fn fallback_chain_font_for_run(chain: FallbackChain, s: Script, codepoints: [u32], start: i64, end_idx: i64) -> SkFont:
    if end_idx <= start:
        return fallback_chain_font_for_script(chain, s)

    if _font_supports_run(chain.primary, codepoints, start: start, end_idx: end_idx):
        return chain.primary

    for fb in chain.fallbacks:
        if _font_supports_run(fb, codepoints, start: start, end_idx: end_idx):
            return fb

    fallback_chain_font_for_script(chain, s)

fn system_default_chain() -> FallbackChain:
    val tf = sk_typeface_default()
    val font = sk_font_new(tf, 12.0)
    FallbackChain(primary: font, fallbacks: [])
