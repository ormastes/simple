# Unicode script detection for text shaping

enum Script:
    Common
    Latin
    Arabic
    Hebrew
    Devanagari
    Thai
    CJK
    Emoji
    Unknown

fn script_of(codepoint: u32) -> Script:
    # U+0000-007F Latin (ASCII)
    if codepoint <= 127:
        Script.Latin
    # U+0590-05FF Hebrew
    else if codepoint >= 1424 and codepoint <= 1535:
        Script.Hebrew
    # U+0600-06FF Arabic
    else if codepoint >= 1536 and codepoint <= 1791:
        Script.Arabic
    # U+0900-097F Devanagari
    else if codepoint >= 2304 and codepoint <= 2431:
        Script.Devanagari
    # U+0E00-0E7F Thai
    else if codepoint >= 3584 and codepoint <= 3711:
        Script.Thai
    # U+4E00-9FFF CJK Unified Ideographs
    else if codepoint >= 19968 and codepoint <= 40959:
        Script.CJK
    # U+1F300-1F9FF Emoji
    else if codepoint >= 127744 and codepoint <= 129535:
        Script.Emoji
    else:
        Script.Unknown

fn script_is_rtl(s: Script) -> bool:
    if s == Script.Arabic:
        true
    else if s == Script.Hebrew:
        true
    else:
        false
