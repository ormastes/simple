# SIMD Module — Standard Library SIMD Facade
#
# Entry point: use std.simd.*
#
# Public API follows C2 §11.2:
#   Vector trait, FixedVec<T>, ScalableVec<T>, Mask<V>, and back-compat aliases.
#
# Note: Simple does not yet support `const N: usize` generics.
# FixedVec<T> uses a runtime `lanes: i32` field.
# Construction: fixedvec_splat(val, n), fixedvec_zero(n), fixedvec_from_array(arr).
# Back-compat aliases are thin wrapper functions (vec4f_splat etc.).
#
# @tag:stdlib
# @tag:simd

import vector
import fixed
import scalable
import mask
import aliases
import profile

# — Core trait —
export Vector

# — Concrete vector types —
export FixedVec
export ScalableVec

# — Mask type —
export Mask

# — Element-type marker traits —
export Numeric
export Float
export Integer
export SignedInt
export SimdElementType
export profile.{SimdTier, detect_profile, profile_name, simd_width}

# — FixedVec construction functions (C2 §1.2) —
export fixedvec_splat
export fixedvec_zero
export fixedvec_from_array
export fixedvec_from_slice

# — ScalableVec construction functions (compat interpreter surface) —
export scalablevec_splat
export scalablevec_splat_n
export scalablevec_zero
export scalablevec_min_lanes
export scalablevec_from_array
export scalablevec_from_fixed

# — Back-compat alias constructors (C2 §11.3) —
# f32 variants
export vec2f_splat, vec4f_splat, vec8f_splat, vec16f_splat
export vec2f_from_array, vec4f_from_array, vec8f_from_array, vec16f_from_array
# f64 variants
export vec2d_splat, vec4d_splat, vec8d_splat
export vec2d_from_array, vec4d_from_array, vec8d_from_array
# i32 variants
export vec4i_splat, vec8i_splat, vec16i_splat
export vec4i_from_array, vec8i_from_array
# u32 variants
export vec4u_splat, vec8u_splat
export vec4u_from_array, vec8u_from_array
