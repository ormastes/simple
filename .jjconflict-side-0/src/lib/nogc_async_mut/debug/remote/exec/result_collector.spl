# Result Collector
#
# Collects and aggregates execution results from remote targets.
# Reads the return register and halt reason after execution completes.
#
# Feature ID: #RJE-006

use std.nogc_async_mut.debug.remote.exec.types.{
    ExecResult, Architecture, return_register_index
}

pub class ResultCollector:
    """Collects execution results from a remote target."""
    arch: Architecture
    read_register_fn: fn(i64) -> Result<i64, text>

    static fn new(arch: Architecture, read_register_fn: fn(i64) -> Result<i64, text>) -> ResultCollector:
        ResultCollector(arch: arch, read_register_fn: read_register_fn)

    fn collect(halt_reason: text, duration_ms: i64) -> Result<ExecResult, text>:
        """Read the return register and build an ExecResult."""
        val ret_idx = return_register_index(self.arch)
        val ret_result = self.read_register_fn(ret_idx)
        match ret_result:
            Ok(ret_value):
                Ok(ExecResult.success(ret_value, duration_ms, halt_reason))
            Err(message):
                Err("failed to read return register: {message}")
