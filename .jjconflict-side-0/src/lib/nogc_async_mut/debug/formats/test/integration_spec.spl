    var b: [u8] = []
    b = b.push(0x1e)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x04)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x04)
    b = b.push(0x01)
    b = b.push(0x00)
    b = b.push(0x10)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x01)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x02)
    b = b.push(0x00)
    b = b.push(0x10)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x80)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b

fn _build_line() -> [u8]:
    var b: [u8] = []
    b = b.push(0x2b)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x03)
    b = b.push(0x00)
    b = b.push(0x13)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x01)
    b = b.push(0x01)
    b = b.push(0xfb)
    b = b.push(0x0e)
    b = b.push(0x0d)
    b = b.push(0x00)
    b = b.push(0x01)
    b = b.push(0x01)
    b = b.push(0x01)
    b = b.push(0x01)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x01)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x01)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x05)
    b = b.push(0x02)
    b = b.push(0x00)
    b = b.push(0x10)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x03)
    b = b.push(0x09)
    b = b.push(0x01)
    b = b.push(0x02)
    b = b.push(0x20)
    b = b.push(0x03)
    b = b.push(0x0a)
    b = b.push(0x01)
    b = b.push(0x00)
    b = b.push(0x01)
    b = b.push(0x01)
    b

fn _make_parser() -> DwarfParser:
    val sections = DwarfSections(
        debug_info: _build_info(),
        debug_abbrev: _build_abbrev(),
        debug_line: _build_line(),
        debug_str: [],
        debug_line_str: [],
        addr_size: 4,
    )
    DwarfParser.from_sections(sections).ok()!

describe "Full pipeline: DwarfParser → Bridge → addr_to_source":
    it "resolves address to source through bridge":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val loc = bridge.addr_to_source(0x1000)
        expect(loc != nil).to_equal(true)
        expect(loc!.line).to_equal(10)

    it "resolves second address through bridge":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val loc = bridge.addr_to_source(0x1020)
        expect(loc != nil).to_equal(true)
        expect(loc!.line).to_equal(20)

    it "function lookup through bridge":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val func = bridge.function_at(0x1000)
        expect(func != nil).to_equal(true)
        expect(func!.low_pc).to_equal(0x1000)

    it "source_to_addr round-trip through bridge":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val loc = bridge.addr_to_source(0x1000)
        expect(loc != nil).to_equal(true)
        if loc != nil:
            val addr = bridge.source_to_addr(loc!.file, loc!.line)
            expect(addr != nil).to_equal(true)

describe "Full pipeline: DwarfParser → Coordinator":
    it "coordinator resolve_source via provider":
        val parser = _make_parser()
        var coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: Some(parser),
        )
        val loc = coord.resolve_source(0x1000)
        expect(loc != nil).to_equal(true)
        expect(loc!.line).to_equal(10)

    it "coordinator resolve_addr via provider":
        val parser = _make_parser()
        var coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: Some(parser),
        )
        val loc = coord.resolve_source(0x1000)
        expect(loc != nil).to_equal(true)
        if loc != nil:
            val addr = coord.resolve_addr(loc!.file, loc!.line)
            expect(addr != nil).to_equal(true)

    it "coordinator resolve_function via provider":
        val parser = _make_parser()
        var coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: Some(parser),
        )
        val func = coord.resolve_function(0x1000)
        expect(func != nil).to_equal(true)
        expect(func!.low_pc).to_equal(0x1000)

    it "coordinator resolve_locals returns empty for no-var data":
        val parser = _make_parser()
        var coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: Some(parser),
        )
        val locals = coord.resolve_locals(0x1000)
        expect(locals.len()).to_equal(0)

describe "Full pipeline: Bridge → format introspection":
    it "format_kind is DWARF":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        expect(bridge.format_kind().to_string()).to_equal("DWARF")

    it "compilation_units count matches":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val units = bridge.compilation_units()
        expect(units.len()).to_equal(1)
        expect(units[0].low_pc).to_equal(0x1000)

    it "line_entries populated":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val entries = bridge.line_entries()
        expect(entries.len() > 0).to_equal(true)

    it "functions_in_range finds subprogram":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val funcs = bridge.functions_in_range(0x0000, 0x2000)
        expect(funcs.len() > 0).to_equal(true)
        expect(funcs[0].low_pc).to_equal(0x1000)

    it "functions_in_range empty for out-of-range":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val funcs = bridge.functions_in_range(0x5000, 0x6000)
        expect(funcs.len()).to_equal(0)

    it "locals_at empty for test data":
        val parser = _make_parser()
        val bridge = DebugInfoBridge.wrap(parser)
        val locals = bridge.locals_at(0x1000)
        expect(locals.len()).to_equal(0)

describe "Coordinator without provider":
    it "resolve_source returns nil":
        val coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: nil,
        )
        val loc = coord.resolve_source(0x1000)
        expect(loc == nil).to_equal(true)

    it "resolve_function returns nil":
        val coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: nil,
        )
        val func = coord.resolve_function(0x1000)
        expect(func == nil).to_equal(true)

    it "resolve_locals returns empty":
        val coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: nil,
        )
        val locals = coord.resolve_locals(0x1000)
        expect(locals.len()).to_equal(0)

    it "resolve_addr returns nil":
        val coord = DebugCoordinator(
            session_manager: nil,
            interpreter_backend: nil,
            smf_backend: nil,
            native_backend: nil,
            remote_backend: nil,
            info_provider: nil,
        )
        val addr = coord.resolve_addr("test.spl", 10)
        expect(addr == nil).to_equal(true)
