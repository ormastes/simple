"""Full pipeline integration tests — ELF→Parser→Bridge→Coordinator."""

use std.debug.coordinator.{DebugCoordinator}
use std.debug.debug_info_bridge.{DebugInfoBridge}
use std.debug.formats.debug_types.{SourceLocation, DebugLineEntry, DebugFunction, DebugVariable, DebugCompilationUnit, DebugFormatKind}
use std.debug.formats.debug_provider.{DebugInfoProvider}
use std.debug.formats.dwarf_parser.{DwarfParser, DwarfSections}

fn _build_abbrev() -> [u8]:
    var b: [u8] = []
    b = b.push(0x01)
    b = b.push(0x11)
    b = b.push(0x01)
    b = b.push(0x11)
    b = b.push(0x01)
    b = b.push(0x12)
    b = b.push(0x06)
    b = b.push(0x10)
    b = b.push(0x17)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x02)
    b = b.push(0x2e)
    b = b.push(0x00)
    b = b.push(0x11)
    b = b.push(0x01)
    b = b.push(0x12)
    b = b.push(0x06)
    b = b.push(0x00)
    b = b.push(0x00)
    b = b.push(0x00)
    b

