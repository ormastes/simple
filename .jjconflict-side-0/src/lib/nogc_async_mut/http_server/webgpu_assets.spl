"""HTTP Server — WebGPU Asset Middleware

@tag:stdlib
@tag:http

Middleware for serving WebGPU assets with correct MIME types:
WGSL shaders, SPIR-V binaries, compressed textures (KTX2, Basis).
Adds cross-origin isolation headers required for SharedArrayBuffer.

Usage:
    use std.http_server.webgpu_assets.{webgpu_mime_type, is_webgpu_asset}
"""

# ============================================================================
# MIME Type Resolution
# ============================================================================

fn webgpu_mime_type(extension: text) -> text:
    if extension == ".wgsl":
        "text/wgsl"
    else if extension == ".glsl" or extension == ".vert" or extension == ".frag":
        "text/plain"
    else if extension == ".spv":
        "application/x-spv"
    else if extension == ".ktx2":
        "image/ktx2"
    else if extension == ".basis":
        "application/octet-stream"
    else if extension == ".dds":
        "image/vnd-ms.dds"
    else:
        ""

fn is_webgpu_asset(extension: text) -> bool:
    val mime = webgpu_mime_type(extension)
    mime != ""

# ============================================================================
# Cross-Origin Isolation Headers
# ============================================================================

fn cross_origin_isolation_headers() -> [[text]]:
    [
        ["Cross-Origin-Opener-Policy", "same-origin"],
        ["Cross-Origin-Embedder-Policy", "require-corp"],
        ["Cross-Origin-Resource-Policy", "cross-origin"]
    ]

# ============================================================================
# Shader File Extension Check
# ============================================================================

fn is_shader_file(extension: text) -> bool:
    extension == ".wgsl" or extension == ".glsl" or extension == ".vert" or extension == ".frag" or extension == ".spv"

fn is_compressed_texture_file(extension: text) -> bool:
    extension == ".ktx2" or extension == ".basis" or extension == ".dds"

# ============================================================================
# Content-Encoding for Compressed Textures
# ============================================================================

fn texture_content_encoding(extension: text) -> text:
    if extension == ".ktx2":
        "identity"
    else if extension == ".basis":
        "identity"
    else:
        ""
