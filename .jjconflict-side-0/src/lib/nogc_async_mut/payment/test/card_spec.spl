use std.spec
use std.io_runtime

enum CardBrand:
    Visa
    Mastercard
    Amex
    Discover
    JCB
    UnionPay
    Unknown

enum ReaderStatus:
    Connected
    Disconnected
    ReadyForCard
    Reading
    Error

enum ReadMethod:
    EMV
    NFC
    MagStripe

struct CardReadResult:
    val success: bool
    val token: text
    val method: ReadMethod
    val error_message: text

fn _char_to_digit(ch: text) -> int:
    if ch == "0": return 0 as int
    if ch == "1": return 1 as int
    if ch == "2": return 2 as int
    if ch == "3": return 3 as int
    if ch == "4": return 4 as int
    if ch == "5": return 5 as int
    if ch == "6": return 6 as int
    if ch == "7": return 7 as int
    if ch == "8": return 8 as int
    if ch == "9": return 9 as int
    return -1 as int

fn _text_to_int(s: text) -> int:
    var result: int = 0 as int
    var i: int = 0 as int
    while i < s.length():
        val d = _char_to_digit(s.char_at(i))
        if d < 0:
            return 0 as int
        result = result * 10 + d
        i = i + 1
    return result

fn luhn_check(card_number: text) -> bool:
    if card_number == "":
        return false
    var sum = 0
    var double_next = false
    var i = card_number.length() - 1
    while i >= 0:
        val ch = card_number.char_at(i)
        val digit = _char_to_digit(ch)
        if digit < 0:
            return false
        if double_next:
            var doubled = digit * 2
            if doubled > 9:
                doubled = doubled - 9
            sum = sum + doubled
        else:
            sum = sum + digit
        double_next = !double_next
        i = i - 1
    return sum > 0 and sum % 10 == 0

fn detect_brand(card_number: text) -> CardBrand:
    if card_number.length() < 4:
        return CardBrand.Unknown
    val d1 = card_number.substring(0, 1)
    val d2 = card_number.substring(0, 2)
    val d4 = card_number.substring(0, 4)
    val d6_raw = if card_number.length() >= 6: card_number.substring(0, 6) else: ""
    if d1 == "4":
        return CardBrand.Visa
    if d2 == "34" or d2 == "37":
        return CardBrand.Amex
    val mc2 = _text_to_int(d2)
    if mc2 >= 51 and mc2 <= 55:
        return CardBrand.Mastercard
    val mc4 = _text_to_int(d4)
    if mc4 >= 2221 and mc4 <= 2720:
        return CardBrand.Mastercard
    if d4 == "6011" or d2 == "65":
        return CardBrand.Discover
    if d2 == "64":
        val d3 = card_number.substring(2, 3)
        val d3v = _text_to_int(d3)
        if d3v >= 4 and d3v <= 9:
            return CardBrand.Discover
    if d6_raw != "":
        val d6v = _text_to_int(d6_raw)
        if d6v >= 622126 and d6v <= 622925:
            return CardBrand.Discover
    val jcb4 = _text_to_int(d4)
    if jcb4 >= 3528 and jcb4 <= 3589:
        return CardBrand.JCB
    if d2 == "62":
        return CardBrand.UnionPay
    return CardBrand.Unknown

fn mask_card_number(card_number: text) -> text:
    val len = card_number.length()
    if len <= 4:
        return card_number
    val last4 = card_number.substring(len - 4, len)
    return "****-****-****-" + last4

fn validate_expiry(month: int, year: int) -> bool:
    if month < 1 or month > 12:
        return false
    if year < 2025:
        return false
    return true

fn extract_last4(card_number: text) -> text:
    val len = card_number.length()
    if len <= 4:
        return card_number
    return card_number.substring(len - 4, len)

struct MockCardReader:
    val connected: bool

fn new_mock_card_reader() -> MockCardReader:
    return MockCardReader { connected: true }

fn mock_reader_status(reader: MockCardReader) -> ReaderStatus:
    if reader.connected:
        return ReaderStatus.Connected
    return ReaderStatus.Disconnected

fn mock_read_card(reader: MockCardReader) -> CardReadResult:
    if !reader.connected:
        return CardReadResult { success: false, token: "", method: ReadMethod.EMV, error_message: "reader disconnected" }
    return CardReadResult { success: true, token: "tok_emv_mock_1234", method: ReadMethod.EMV, error_message: "" }

describe "Card validation and types":

    describe "luhn_check":
        it "validates known-good Visa number":
            expect luhn_check("4111111111111111") == true

        it "validates known-good Mastercard number":
            expect luhn_check("5500000000000004") == true

        it "validates known-good Amex number":
            expect luhn_check("378282246310005") == true

        it "rejects invalid number":
            expect luhn_check("1234567890123456") == false

        it "rejects empty string":
            expect luhn_check("") == false

        it "rejects non-numeric input":
            expect luhn_check("abcd-efgh-ijkl") == false

    describe "detect_brand":
        it "detects Visa (starts with 4)":
            expect detect_brand("4111111111111111") == CardBrand.Visa

        it "detects Mastercard (starts with 51-55)":
            expect detect_brand("5500000000000004") == CardBrand.Mastercard

        it "detects Amex (starts with 34 or 37)":
            expect detect_brand("378282246310005") == CardBrand.Amex

        it "detects Discover (starts with 6011)":
            expect detect_brand("6011111111111117") == CardBrand.Discover

        it "detects JCB (starts with 3528-3589)":
            expect detect_brand("3530111333300000") == CardBrand.JCB

        it "returns Unknown for unrecognized prefix":
            expect detect_brand("9999999999999999") == CardBrand.Unknown

    describe "mask_card_number":
        it "masks all but last 4 digits":
            expect mask_card_number("4111111111111111") == "****-****-****-1111"

        it "handles short numbers":
            expect mask_card_number("1234") == "1234"

    describe "validate_expiry":
        it "accepts future expiry":
            expect validate_expiry(12, 2028) == true

        it "rejects past expiry":
            expect validate_expiry(1, 2020) == false

        it "rejects invalid month":
            expect validate_expiry(13, 2028) == false

        it "rejects zero month":
            expect validate_expiry(0, 2028) == false

    describe "extract_last4":
        it "extracts last 4 digits":
            expect extract_last4("4111111111111111") == "1111"

        it "handles exact 4 chars":
            expect extract_last4("5678") == "5678"

    describe "CardReader (mock)":
        it "connected reader reports Connected":
            val reader = new_mock_card_reader()
            expect mock_reader_status(reader) == ReaderStatus.Connected

        it "connected reader reads card successfully":
            val reader = new_mock_card_reader()
            val result = mock_read_card(reader)
            expect result.success == true
            expect result.token != ""
