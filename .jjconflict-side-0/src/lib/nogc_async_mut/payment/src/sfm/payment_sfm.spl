use std.io_runtime

fn payment_sfm_manifest() -> FeatureManifest:
    val gateway_layer = LayerDescriptor {
        role: "gateway",
        kind: LayerKind.BackService,
        entry_symbol: "gateway_dispatch",
        privileged: true
    }
    val vault_layer = LayerDescriptor {
        role: "vault",
        kind: LayerKind.BackService,
        entry_symbol: "vault_dispatch",
        privileged: true
    }
    val cli_layer = LayerDescriptor {
        role: "cli",
        kind: LayerKind.FrontCli,
        entry_symbol: "cli_payment_main",
        privileged: false
    }
    val agent_layer = LayerDescriptor {
        role: "agent",
        kind: LayerKind.FrontAgent,
        entry_symbol: "handle_payment_tool",
        privileged: false
    }
    return FeatureManifest {
        name: "simple-payment",
        version: "0.1.0",
        security_level: SfmSecurityLevel.Trusted,
        layers: [gateway_layer, vault_layer, cli_layer, agent_layer]
    }
