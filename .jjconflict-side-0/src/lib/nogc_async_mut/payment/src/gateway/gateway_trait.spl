use std.io_runtime

enum PaymentStatus:
    Created
    Authorized
    Captured
    Settled
    Refunded
    Voided
    Failed

struct Amount:
    cents: int
    currency: text

struct PaymentResult:
    success: bool
    status: PaymentStatus
    transaction_id: text
    error_message: text

struct AuthorizeRequest:
    token: text
    amount: Amount
    merchant_ref: text
    idempotency_key: text

struct CaptureRequest:
    transaction_id: text
    amount: Amount

struct RefundRequest:
    transaction_id: text
    amount: Amount
    reason: text

struct VoidRequest:
    transaction_id: text
    reason: text

struct ChargeRequest:
    token: text
    amount: Amount
    merchant_ref: text
    idempotency_key: text

struct TokenizeRequest:
    card_number: text
    expiry_month: int
    expiry_year: int
    cardholder_name: text

struct TokenizeResult:
    success: bool
    token: text
    error_message: text

trait Gateway:
    fn name(self) -> text
    fn authorize(self, req: AuthorizeRequest) -> PaymentResult
    fn capture(self, req: CaptureRequest) -> PaymentResult
    fn charge(self, req: ChargeRequest) -> PaymentResult
    fn refund(self, req: RefundRequest) -> PaymentResult
    fn void_payment(self, req: VoidRequest) -> PaymentResult
    fn tokenize(self, req: TokenizeRequest) -> TokenizeResult
