"""
# No-GC Async Torch SFFI

Compatibility facade over the no-GC sync Torch SFFI backend. Torch runtime
operations are synchronous SFFI calls; async-family Torch modules reuse the
same no-GC backend surface rather than redeclaring runtime hooks.
"""

export use std.nogc_sync_mut.torch.sffi.{
    rt_torch_available, rt_torch_version, rt_torch_cuda_available,
    rt_torch_tensor_zeros, rt_torch_tensor_from_data, rt_torch_tensor_ones,
    rt_torch_tensor_randn, rt_torch_tensor_rand, rt_torch_tensor_full,
    rt_torch_tensor_eye, rt_torch_tensor_arange, rt_torch_tensor_arange_int,
    rt_torch_tensor_linspace, rt_torch_tensor_empty,
    rt_torch_tensor_load, rt_torch_tensor_save,
    rt_dyn_torch_tensor_from_bits_1d,
    rt_torch_stream_create, rt_torch_torchstream_sync,
    rt_torch_torchstream_query, rt_torch_torchstream_free,
    rt_torch_torchtensor_free, rt_torch_torchtensor_clone,
    rt_torch_torchtensor_add, rt_torch_torchtensor_sub,
    rt_torch_torchtensor_mul, rt_torch_torchtensor_div,
    rt_torch_torchtensor_add_scalar, rt_torch_torchtensor_mul_scalar,
    rt_torch_torchtensor_relu, rt_torch_torchtensor_sigmoid, rt_torch_torchtensor_tanh,
    rt_torch_torchtensor_softmax, rt_torch_torchtensor_log_softmax,
    rt_torch_torchtensor_gelu, rt_torch_torchtensor_leaky_relu,
    rt_torch_torchtensor_neg, rt_torch_torchtensor_sqrt, rt_torch_torchtensor_pow,
    rt_torch_torchtensor_abs, rt_torch_torchtensor_exp, rt_torch_torchtensor_log,
    rt_torch_torchtensor_sin, rt_torch_torchtensor_cos, rt_torch_torchtensor_tan,
    rt_torch_torchtensor_asin, rt_torch_torchtensor_acos, rt_torch_torchtensor_atan2,
    rt_torch_torchtensor_matmul, rt_torch_torchtensor_dot,
    rt_torch_torchtensor_transpose, rt_torch_torchtensor_t,
    rt_torch_torchtensor_sum, rt_torch_torchtensor_sum_dim,
    rt_torch_torchtensor_mean, rt_torch_torchtensor_mean_dim,
    rt_torch_torchtensor_argmax, rt_torch_torchtensor_argmin,
    rt_torch_torchtensor_max, rt_torch_torchtensor_min,
    rt_torch_torchtensor_reshape, rt_torch_torchtensor_view,
    rt_torch_torchtensor_permute, rt_torch_torchtensor_contiguous,
    rt_torch_torchtensor_squeeze, rt_torch_torchtensor_squeeze_dim,
    rt_torch_torchtensor_unsqueeze, rt_torch_torchtensor_flatten,
    rt_torch_torchtensor_slice, rt_torch_torchtensor_index_select,
    rt_torch_torchtensor_gather, rt_torch_torchtensor_cat, rt_torch_torchtensor_chunk,
    rt_torch_torchtensor_shape, rt_torch_torchtensor_ndim, rt_torch_torchtensor_numel,
    rt_torch_torchtensor_cuda, rt_torch_torchtensor_cpu, rt_torch_torchtensor_is_cuda,
    rt_torch_torchtensor_to_stream, rt_torch_torchtensor_device,
    rt_torch_torchtensor_inverse, rt_torch_torchtensor_det, rt_torch_torchtensor_eig,
    rt_torch_autograd_set_requires_grad, rt_torch_autograd_requires_grad,
