#![allow(export_outside_init)]
#![allow(unnamed_duplicate_typed_args)]
# MCP Performance Guard
#
# Runtime observability counters and threshold checks for MCP servers.
# Tracks directory walks, file reads, subprocess invocations, and
# request elapsed times.  Emits warnings when thresholds are exceeded.
#
# Usage:
#   val guard = McpPerfGuard(
#       max_dir_walks_per_request: 2,
#       max_file_reads_per_request: 50,
#       max_subprocesses_per_request: 3,
#       max_request_ms: 5000
#   )
#   guard.begin_request()
#   guard.record_dir_walk()
#   guard.record_file_read()
#   val violations = guard.end_request()
#
# All thresholds are configurable.  Debug-only: disable with
# MCP_PERF_GUARD=off environment variable.

extern fn rt_env_get(name: text) -> text
extern fn rt_time_ms() -> i64


# ============================================================================
# PerfViolation
# ============================================================================

struct PerfViolation:
    code: text
    message: text
    count: i64
    threshold: i64

    fn fmt() -> text:
        "[{self.code}] {self.message} (actual: {self.count}, max: {self.threshold})"


# ============================================================================
# McpPerfGuard
# ============================================================================

struct McpPerfGuard:
    max_dir_walks_per_request: i64
    max_file_reads_per_request: i64
    max_subprocesses_per_request: i64
    max_request_ms: i64

    # Internal counters
    _dir_walks: i64
    _file_reads: i64
    _subprocesses: i64
    _request_start_ms: i64
    _total_requests: i64
    _total_violations: i64
    _enabled: bool

    fn is_enabled() -> bool:
        self._enabled

    fn total_requests() -> i64:
        self._total_requests

    fn total_violations() -> i64:
        self._total_violations


# ============================================================================
# Constructor
# ============================================================================

fn mcp_perf_guard_new(max_walks: i64, max_reads: i64, max_procs: i64, max_ms: i64) -> McpPerfGuard:
    """Create a new perf guard with the given thresholds."""
    val env_val = rt_env_get("MCP_PERF_GUARD") ?? ""
    val enabled = env_val != "off"
    McpPerfGuard(
        max_dir_walks_per_request: max_walks,
        max_file_reads_per_request: max_reads,
        max_subprocesses_per_request: max_procs,
        max_request_ms: max_ms,
        _dir_walks: 0,
        _file_reads: 0,
        _subprocesses: 0,
        _request_start_ms: 0,
        _total_requests: 0,
        _total_violations: 0,
        _enabled: enabled
    )

fn mcp_perf_guard_default() -> McpPerfGuard:
    """Create a perf guard with sensible defaults for MCP servers."""
    mcp_perf_guard_new(2, 50, 3, 5000)


# ============================================================================
# Request Lifecycle
# ============================================================================

impl McpPerfGuard:
    me begin_request():
        """Reset per-request counters and start timing."""
        self._dir_walks = 0
        self._file_reads = 0
        self._subprocesses = 0
        self._request_start_ms = rt_time_ms()
        self._total_requests = self._total_requests + 1

    me record_dir_walk():
        """Record a directory walk operation."""
        self._dir_walks = self._dir_walks + 1

    me record_file_read():
        """Record a file read operation."""
        self._file_reads = self._file_reads + 1

    me record_subprocess():
        """Record a subprocess invocation."""
        self._subprocesses = self._subprocesses + 1

    me end_request() -> [PerfViolation]:
        """End the current request and return any threshold violations."""
        if not self._enabled:
            return []

        var violations: [PerfViolation] = []
        val elapsed_ms = rt_time_ms() - self._request_start_ms

        if self._dir_walks > self.max_dir_walks_per_request:
            violations.push(PerfViolation(
                code: "PERF_DIR_WALK",
                message: "too many directory walks in single request",
                count: self._dir_walks,
                threshold: self.max_dir_walks_per_request
            ))

        if self._file_reads > self.max_file_reads_per_request:
            violations.push(PerfViolation(
                code: "PERF_FILE_READ",
                message: "too many file reads in single request",
                count: self._file_reads,
                threshold: self.max_file_reads_per_request
            ))

        if self._subprocesses > self.max_subprocesses_per_request:
            violations.push(PerfViolation(
                code: "PERF_SUBPROCESS",
                message: "too many subprocess invocations in single request",
                count: self._subprocesses,
                threshold: self.max_subprocesses_per_request
            ))

        if elapsed_ms > self.max_request_ms:
            violations.push(PerfViolation(
                code: "PERF_LATENCY",
                message: "request exceeded latency budget",
                count: elapsed_ms,
                threshold: self.max_request_ms
            ))

        self._total_violations = self._total_violations + violations.len()
        violations

    fn snapshot() -> McpPerfSnapshot:
        """Take a snapshot of current counters (useful for diagnostics)."""
        McpPerfSnapshot(
            dir_walks: self._dir_walks,
            file_reads: self._file_reads,
            subprocesses: self._subprocesses,
            total_requests: self._total_requests,
            total_violations: self._total_violations
        )


# ============================================================================
# Snapshot for diagnostics
# ============================================================================

struct McpPerfSnapshot:
    dir_walks: i64
    file_reads: i64
    subprocesses: i64
    total_requests: i64
    total_violations: i64

    fn fmt() -> text:
        "PerfSnapshot(walks={self.dir_walks}, reads={self.file_reads}, procs={self.subprocesses}, reqs={self.total_requests}, violations={self.total_violations})"


# ============================================================================
# Exports
# ============================================================================

export PerfViolation
export McpPerfGuard
export McpPerfSnapshot
export mcp_perf_guard_new
export mcp_perf_guard_default
