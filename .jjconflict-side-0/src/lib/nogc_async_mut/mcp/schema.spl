# MCP Library - Pre-computed Tool Schemas
#
# Pre-computed JSON schemas for all MCP tools.
# Avoids runtime schema generation overhead.

# Pre-computed schemas as constant string
# NOTE: This avoids module-level var access issues in runtime
fn build_tool_schema(name: text, desc: text, props: text, req: text) -> text:
    "{" + "\"name\":\"" + name + "\",\"description\":\"" + desc + "\",\"inputSchema\":{\"type\":\"object\",\"properties\":{" + props + "},\"required\":[" + req + "]}}"

fn concat_with_comma(items: [text]) -> text:
    items.join(",")

fn build_all_schemas() -> text:
    var schemas = []
    schemas.push(build_tool_schema(name: "read_code", desc: "Read a Simple language source file", props: "\"path\":{\"type\":\"string\",\"description\":\"File path\"}", req: "\"path\""))
    schemas.push(build_tool_schema(name: "list_files", desc: "List Simple language files in a directory", props: "\"path\":{\"type\":\"string\",\"description\":\"Directory path\"}", req: ""))
    schemas.push(build_tool_schema(name: "search_code", desc: "Search for code patterns", props: "\"query\":{\"type\":\"string\",\"description\":\"Search query\"}", req: "\"query\""))
    schemas.push(build_tool_schema(name: "file_info", desc: "Get file information", props: "\"path\":{\"type\":\"string\",\"description\":\"File path\"}", req: "\"path\""))
    schemas.push(build_tool_schema(name: "bugdb_get", desc: "Get bug by ID", props: "\"id\":{\"type\":\"string\",\"description\":\"Bug ID\"}", req: "\"id\""))
    schemas.push(build_tool_schema(name: "bugdb_add", desc: "Add new bug", props: "\"bug\":{\"type\":\"string\",\"description\":\"Bug JSON\"}", req: "\"bug\""))
    schemas.push(build_tool_schema(name: "bugdb_update", desc: "Update existing bug", props: "\"id\":{\"type\":\"string\",\"description\":\"Bug ID\"}", req: "\"id\""))
    schemas.push(build_tool_schema(name: "debug_create_session", desc: "Create debug session", props: "", req: ""))
    "[" + concat_with_comma(schemas) + "]"

# No-op init for API compatibility
fn init_core_schemas():
    ()  # No-op - schemas are pre-computed constants

# Get all tool schemas as JSON array (recomputed each call — simple string concat, fast enough)
fn get_all_tool_schemas() -> text:
    build_all_schemas()

# Get tool count
fn get_tool_count() -> i64:
    8  # Pre-computed count

# Export
