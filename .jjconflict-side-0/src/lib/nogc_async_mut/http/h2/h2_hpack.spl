# HPACK Encoder/Decoder — RFC 7541
#
# Static-table-only HPACK for HTTP/2 header compression.
# Dynamic table management is deferred.
#
# Scope:
#   - Static table (61 entries per RFC 7541 Appendix A)
#   - Indexed header field representation (§6.1)
#   - Literal header field without indexing (§6.2.2)
#   - hpack_encode / hpack_decode public API
#
# Depends on: hpack_primitives.spl

use std.http.h2.hpack_primitives.{HpackIntOk, HpackStringOk}

# ============================================================================
# Static table entry
# ============================================================================

class HpackEntry:
    """One entry in the HPACK static table (name + value pair)."""
    name: text
    value: text

class HpackTable:
    """HPACK table. static_entries holds RFC 7541 Appendix A entries (indices 1..61).
    Dynamic table is not used (size = 0)."""
    static_entries: [HpackEntry]

class HpackEncodeResult:
    """Result of encoding a header list."""
    bytes: [u8]

class HpackDecodeResult:
    """Result of decoding a header block."""
    headers: [HpackEntry]
    bytes_consumed: i64

# ============================================================================
# Static table — RFC 7541 Appendix A (61 entries, 1-indexed)
# Index 0 in the array = table index 1.
# ============================================================================

pub fn hpack_static_table() -> HpackTable:
    """Return the RFC 7541 Appendix A static table (61 entries)."""
    var entries: [HpackEntry] = []
    # 1
    entries.push(HpackEntry(name: ":authority", value: ""))
    # 2
    entries.push(HpackEntry(name: ":method", value: "GET"))
    # 3
    entries.push(HpackEntry(name: ":method", value: "POST"))
    # 4
    entries.push(HpackEntry(name: ":path", value: "/"))
    # 5
    entries.push(HpackEntry(name: ":path", value: "/index.html"))
    # 6
    entries.push(HpackEntry(name: ":scheme", value: "http"))
    # 7
    entries.push(HpackEntry(name: ":scheme", value: "https"))
    # 8
    entries.push(HpackEntry(name: ":status", value: "200"))
    # 9
    entries.push(HpackEntry(name: ":status", value: "204"))
    # 10
    entries.push(HpackEntry(name: ":status", value: "206"))
    # 11
    entries.push(HpackEntry(name: ":status", value: "304"))
    # 12
    entries.push(HpackEntry(name: ":status", value: "400"))
    # 13
    entries.push(HpackEntry(name: ":status", value: "404"))
    # 14
    entries.push(HpackEntry(name: ":status", value: "500"))
    # 15
    entries.push(HpackEntry(name: "accept-charset", value: ""))
    # 16
    entries.push(HpackEntry(name: "accept-encoding", value: "gzip, deflate"))
    # 17
    entries.push(HpackEntry(name: "accept-language", value: ""))
    # 18
    entries.push(HpackEntry(name: "accept-ranges", value: ""))
    # 19
    entries.push(HpackEntry(name: "accept", value: ""))
    # 20
    entries.push(HpackEntry(name: "access-control-allow-origin", value: ""))
    # 21
    entries.push(HpackEntry(name: "age", value: ""))
    # 22
    entries.push(HpackEntry(name: "allow", value: ""))
    # 23
    entries.push(HpackEntry(name: "authorization", value: ""))
    # 24
    entries.push(HpackEntry(name: "cache-control", value: ""))
    # 25
    entries.push(HpackEntry(name: "content-disposition", value: ""))
    # 26
    entries.push(HpackEntry(name: "content-encoding", value: ""))
    # 27
    entries.push(HpackEntry(name: "content-language", value: ""))
    # 28
    entries.push(HpackEntry(name: "content-length", value: ""))
    # 29
    entries.push(HpackEntry(name: "content-location", value: ""))
    # 30
    entries.push(HpackEntry(name: "content-range", value: ""))
    # 31
    entries.push(HpackEntry(name: "content-type", value: ""))
    # 32
    entries.push(HpackEntry(name: "cookie", value: ""))
    # 33
    entries.push(HpackEntry(name: "date", value: ""))
    # 34
    entries.push(HpackEntry(name: "etag", value: ""))
    # 35
    entries.push(HpackEntry(name: "expect", value: ""))
    # 36
    entries.push(HpackEntry(name: "expires", value: ""))
    # 37
    entries.push(HpackEntry(name: "from", value: ""))
    # 38
    entries.push(HpackEntry(name: "host", value: ""))
    # 39
    entries.push(HpackEntry(name: "if-match", value: ""))
    # 40
    entries.push(HpackEntry(name: "if-modified-since", value: ""))
    # 41
    entries.push(HpackEntry(name: "if-none-match", value: ""))
    # 42
    entries.push(HpackEntry(name: "if-range", value: ""))
    # 43
    entries.push(HpackEntry(name: "if-unmodified-since", value: ""))
    # 44
    entries.push(HpackEntry(name: "last-modified", value: ""))
    # 45
    entries.push(HpackEntry(name: "link", value: ""))
    # 46
    entries.push(HpackEntry(name: "location", value: ""))
    # 47
    entries.push(HpackEntry(name: "max-forwards", value: ""))
    # 48
    entries.push(HpackEntry(name: "proxy-authenticate", value: ""))
    # 49
    entries.push(HpackEntry(name: "proxy-authorization", value: ""))
    # 50
    entries.push(HpackEntry(name: "range", value: ""))
    # 51
    entries.push(HpackEntry(name: "referer", value: ""))
    # 52
    entries.push(HpackEntry(name: "refresh", value: ""))
    # 53
    entries.push(HpackEntry(name: "retry-after", value: ""))
    # 54
    entries.push(HpackEntry(name: "server", value: ""))
    # 55
    entries.push(HpackEntry(name: "set-cookie", value: ""))
    # 56
    entries.push(HpackEntry(name: "strict-transport-security", value: ""))
    # 57
    entries.push(HpackEntry(name: "transfer-encoding", value: ""))
    # 58
    entries.push(HpackEntry(name: "user-agent", value: ""))
    # 59
    entries.push(HpackEntry(name: "vary", value: ""))
    # 60
    entries.push(HpackEntry(name: "via", value: ""))
    # 61
    entries.push(HpackEntry(name: "www-authenticate", value: ""))
    return HpackTable(static_entries: entries)

# ============================================================================
# Internal helpers — static table lookup
# ============================================================================

fn _hpack_find_exact(table: HpackTable, name: text, value: text) -> i64:
    """Return 1-based static table index for exact (name, value) match, or 0."""
    var i = 0
    while i < table.static_entries.len():
        val e = table.static_entries[i]
        if e.name == name and e.value == value:
            return i + 1
        i = i + 1
    return 0

fn _hpack_find_name(table: HpackTable, name: text) -> i64:
    """Return 1-based static table index for first entry with matching name, or 0."""
    var i = 0
    while i < table.static_entries.len():
        val e = table.static_entries[i]
        if e.name == name:
            return i + 1
        i = i + 1
    return 0

fn _hpack_static_get(table: HpackTable, index: i64) -> HpackEntry:
    """Return static table entry at 1-based index. Caller ensures index is valid."""
    return table.static_entries[index - 1]

# ============================================================================
# Encoder — RFC 7541 §6
# ============================================================================

pub fn hpack_encode(headers: [HpackEntry], table: HpackTable) -> HpackEncodeResult:
    """Encode a list of header fields into an HPACK header block.

    Strategy (static-table-only):
      1. If exact (name, value) match in static table → Indexed Header Field (§6.1)
      2. If name-only match → Literal with static name index + raw value (§6.2.2)
      3. Otherwise → Literal without indexing, both name and value as strings (§6.2.2)
    """
    var out: [u8] = []
    var i = 0
    while i < headers.len():
        val h = headers[i]
        val exact_idx = _hpack_find_exact(table, h.name, h.value)
        if exact_idx > 0:
            # §6.1 Indexed Header Field: bit pattern 1xxxxxxx
            val encoded = hpack_encode_int(exact_idx, 7, 0x80)
            var j = 0
            while j < encoded.len():
                out.push(encoded[j])
                j = j + 1
        else:
            val name_idx = _hpack_find_name(table, h.name)
            if name_idx > 0:
                # §6.2.2 Literal without indexing, name reference: 0000xxxx
                val idx_bytes = hpack_encode_int(name_idx, 4, 0x00)
                var j = 0
                while j < idx_bytes.len():
                    out.push(idx_bytes[j])
                    j = j + 1
                val val_bytes = hpack_encode_string_raw(h.value)
                var k = 0
                while k < val_bytes.len():
                    out.push(val_bytes[k])
                    k = k + 1
            else:
                # §6.2.2 Literal without indexing, new name: 00000000
                out.push(0x00)
                val name_bytes = hpack_encode_string_raw(h.name)
                var j = 0
                while j < name_bytes.len():
                    out.push(name_bytes[j])
                    j = j + 1
                val val_bytes = hpack_encode_string_raw(h.value)
                var k = 0
                while k < val_bytes.len():
                    out.push(val_bytes[k])
                    k = k + 1
        i = i + 1
    return HpackEncodeResult(bytes: out)

# ============================================================================
# Decoder — RFC 7541 §6
# ============================================================================

pub fn hpack_decode(data: [u8], table: HpackTable) -> HpackDecodeResult:
    """Decode an HPACK header block from `data`.

    Dispatches on first byte pattern per RFC 7541 §6:
      1xxxxxxx  — Indexed Header Field (§6.1)
      0000xxxx  — Literal without indexing, name index or new name (§6.2.2)
      0001xxxx  — Literal never indexed (treated same as §6.2.2 here)
      01xxxxxx  — Literal with incremental indexing (§6.2.1, dynamic table ignored)

    Returns decoded headers and total bytes consumed.
    """
    var headers: [HpackEntry] = []
    var pos = 0
    while pos < data.len():
        val first = data[pos] & 0xff
        if (first & 0x80) != 0:
            # §6.1 Indexed Header Field: 1xxxxxxx
            val idx_result = hpack_decode_int(data, pos, 7)
            match idx_result:
                case Err(msg):
                    # Return what we have so far on error
                    return HpackDecodeResult(headers: headers, bytes_consumed: pos)
                case Ok(ok):
                    val oki: HpackIntOk = ok
                    val index = oki.value
                    pos = pos + oki.consumed
                    if index > 0 and index <= table.static_entries.len():
                        val entry = _hpack_static_get(table, index)
                        headers.push(HpackEntry(name: entry.name, value: entry.value))
                    # index 0 is invalid; dynamic table entries ignored (deferred)
        else if (first & 0x40) != 0:
            # §6.2.1 Literal with incremental indexing: 01xxxxxx
            # Name index (6-bit prefix) or 0 = new name
            val idx_result = hpack_decode_int(data, pos, 6)
            match idx_result:
                case Err(msg):
                    return HpackDecodeResult(headers: headers, bytes_consumed: pos)
                case Ok(ok):
                    val oki: HpackIntOk = ok
                    pos = pos + oki.consumed
                    val name_index = oki.value
                    var name = ""
                    if name_index == 0:
                        val name_result = hpack_decode_string(data, pos)
                        match name_result:
                            case Err(msg):
                                return HpackDecodeResult(headers: headers, bytes_consumed: pos)
                            case Ok(sok):
                                val sso: HpackStringOk = sok
                                name = sso.value
                                pos = pos + sso.consumed
                    else:
                        if name_index <= table.static_entries.len():
                            val entry = _hpack_static_get(table, name_index)
                            name = entry.name
                    val val_result = hpack_decode_string(data, pos)
                    match val_result:
                        case Err(msg):
                            return HpackDecodeResult(headers: headers, bytes_consumed: pos)
                        case Ok(sok):
                            val sso: HpackStringOk = sok
                            headers.push(HpackEntry(name: name, value: sso.value))
                            pos = pos + sso.consumed
        else:
            # §6.2.2 / §6.2.3 Literal without indexing or never-indexed: 0000xxxx / 0001xxxx
            # Name index is 4-bit prefix
            val idx_result = hpack_decode_int(data, pos, 4)
            match idx_result:
                case Err(msg):
                    return HpackDecodeResult(headers: headers, bytes_consumed: pos)
                case Ok(ok):
                    val oki: HpackIntOk = ok
                    pos = pos + oki.consumed
                    val name_index = oki.value
                    var name = ""
                    if name_index == 0:
                        val name_result = hpack_decode_string(data, pos)
                        match name_result:
                            case Err(msg):
                                return HpackDecodeResult(headers: headers, bytes_consumed: pos)
                            case Ok(sok):
                                val sso: HpackStringOk = sok
                                name = sso.value
                                pos = pos + sso.consumed
                    else:
                        if name_index <= table.static_entries.len():
                            val entry = _hpack_static_get(table, name_index)
                            name = entry.name
                    val val_result = hpack_decode_string(data, pos)
                    match val_result:
                        case Err(msg):
                            return HpackDecodeResult(headers: headers, bytes_consumed: pos)
                        case Ok(sok):
                            val sso: HpackStringOk = sok
                            headers.push(HpackEntry(name: name, value: sso.value))
                            pos = pos + sso.consumed
    return HpackDecodeResult(headers: headers, bytes_consumed: pos)
