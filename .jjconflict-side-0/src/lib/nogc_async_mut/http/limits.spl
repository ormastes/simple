# HTTP Request Limits and Hardening Configuration
#
# Bounded defaults for request parsing to prevent resource exhaustion.
# All limits are configurable; violations produce structured error results.

# ============================================================================
# Limit Configuration
# ============================================================================

struct HttpLimits:
    max_request_line_bytes: i64
    max_header_count: i64
    max_header_size_bytes: i64
    max_body_bytes: i64
    idle_timeout_seconds: i64
    max_requests_per_connection: i64

fn http_limits_default() -> HttpLimits:
    HttpLimits(
        max_request_line_bytes: 8192,
        max_header_count: 100,
        max_header_size_bytes: 8192,
        max_body_bytes: 10485760,
        idle_timeout_seconds: 60,
        max_requests_per_connection: 100
    )

# ============================================================================
# Parse Error
# ============================================================================

enum HttpParseError:
    RequestLineTooLong(length: i64, limit: i64)
    TooManyHeaders(count: i64, limit: i64)
    HeaderTooLarge(name: text, size: i64, limit: i64)
    BodyTooLarge(size: i64, limit: i64)
    MalformedRequestLine(line: text)
    PathTraversal(path: text)
    InvalidMethod(method: text)
    NullByteInPath(path: text)

fn http_parse_error_status(err: HttpParseError) -> i64:
    match err:
        case RequestLineTooLong(length, limit): 414
        case TooManyHeaders(count, limit): 400
        case HeaderTooLarge(name, size, limit): 400
        case BodyTooLarge(size, limit): 413
        case MalformedRequestLine(line): 400
        case PathTraversal(path): 403
        case InvalidMethod(method): 400
        case NullByteInPath(path): 400

fn http_parse_error_message(err: HttpParseError) -> text:
    match err:
        case RequestLineTooLong(length, limit):
            "request line too long: {length} bytes (limit: {limit})"
        case TooManyHeaders(count, limit):
            "too many headers: {count} (limit: {limit})"
        case HeaderTooLarge(name, size, limit):
            "header '{name}' too large: {size} bytes (limit: {limit})"
        case BodyTooLarge(size, limit):
            "body too large: {size} bytes (limit: {limit})"
        case MalformedRequestLine(line):
            "malformed request line"
        case PathTraversal(path):
            "path traversal rejected: {path}"
        case InvalidMethod(method):
            "invalid HTTP method: {method}"
        case NullByteInPath(path):
            "null byte in request path"

# ============================================================================
# Limit Checks
# ============================================================================

fn check_request_line(line: text, limits: HttpLimits) -> HttpParseError?:
    if line.length() > limits.max_request_line_bytes:
        return Some(HttpParseError.RequestLineTooLong(line.length(), limits.max_request_line_bytes))
    val parts = line.split(" ")
    if parts.length() < 3:
        return Some(HttpParseError.MalformedRequestLine(line))
    nil

fn check_header_count(count: i64, limits: HttpLimits) -> HttpParseError?:
    if count > limits.max_header_count:
        return Some(HttpParseError.TooManyHeaders(count, limits.max_header_count))
    nil

fn check_header_size(name: text, value: text, limits: HttpLimits) -> HttpParseError?:
    val total = name.length() + value.length() + 2
    if total > limits.max_header_size_bytes:
        return Some(HttpParseError.HeaderTooLarge(name, total, limits.max_header_size_bytes))
    nil

fn check_body_size(size: i64, limits: HttpLimits) -> HttpParseError?:
    if size > limits.max_body_bytes:
        return Some(HttpParseError.BodyTooLarge(size, limits.max_body_bytes))
    nil

# ============================================================================
# Exports
# ============================================================================

export HttpLimits, http_limits_default
export HttpParseError, http_parse_error_status, http_parse_error_message
export check_request_line, check_header_count, check_header_size, check_body_size
