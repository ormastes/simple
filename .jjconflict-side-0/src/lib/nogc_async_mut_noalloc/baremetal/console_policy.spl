# Bare-Metal Console Policy
#
# Pure Simple policy for choosing the smallest available debug output path.
# Platform-specific trap/UART mechanics live in syscall.spl or arch capsules.

val BAREMETAL_CONSOLE_NONE: i32 = 0
val BAREMETAL_CONSOLE_SEMIHOST: i32 = 1
val BAREMETAL_CONSOLE_UART: i32 = 2

val BAREMETAL_UART_QEMU_VIRT: u32 = 0x10000000u32
val BAREMETAL_UART_X86_COM1: u32 = 0x000003F8u32

class BaremetalConsoleConfig:
    mode: i32
    uart_base: u32
    newline_crlf: bool

impl BaremetalConsoleConfig:
    static fn none() -> BaremetalConsoleConfig:
        BaremetalConsoleConfig(
            mode: BAREMETAL_CONSOLE_NONE,
            uart_base: 0u32,
            newline_crlf: true
        )

    static fn semihost() -> BaremetalConsoleConfig:
        BaremetalConsoleConfig(
            mode: BAREMETAL_CONSOLE_SEMIHOST,
            uart_base: 0u32,
            newline_crlf: true
        )

    static fn uart(base: u32) -> BaremetalConsoleConfig:
        BaremetalConsoleConfig(
            mode: BAREMETAL_CONSOLE_UART,
            uart_base: base,
            newline_crlf: true
        )

fn baremetal_console_choose(prefer_semihost: bool, semihost_available: bool, uart_base: u32) -> BaremetalConsoleConfig:
    if prefer_semihost and semihost_available:
        return BaremetalConsoleConfig.semihost()
    if uart_base != 0u32:
        return BaremetalConsoleConfig.uart(uart_base)
    if semihost_available:
        return BaremetalConsoleConfig.semihost()
    BaremetalConsoleConfig.none()

fn baremetal_console_is_enabled(config: BaremetalConsoleConfig) -> bool:
    config.mode != BAREMETAL_CONSOLE_NONE

fn baremetal_console_uses_semihost(config: BaremetalConsoleConfig) -> bool:
    config.mode == BAREMETAL_CONSOLE_SEMIHOST

fn baremetal_console_uses_uart(config: BaremetalConsoleConfig) -> bool:
    config.mode == BAREMETAL_CONSOLE_UART
