# Kernel Futex (kfutex) — M1 thread primitive.
#
# Futex-like wait/wake on an address value.
# In interpreter mode: no waiters blocked, so wake always returns 0,
# and wait with matching expected+timeout_ns=0 returns "timeout".
#
# @cover kfutex

# ============================================================================
# Public API
# ============================================================================

fn kfutex_wait(addr: u32, expected: u32, timeout_ns: i64) -> text:
    """Wait if *addr == expected; return immediately on mismatch.

    With timeout_ns=0:
      - Returns "aborted"  if addr != expected (futex value mismatch)
      - Returns "timeout"  if addr == expected (immediate timeout, no real waiter)

    Returns:
        "signaled" | "timeout" | "aborted"
    """
    # In interpreter mode addr is a value, not a pointer.
    # We compare addr itself to expected (matches test intent: addr: u32 = 42, expected=42).
    if addr != expected:
        return "aborted"
    "timeout"

fn kfutex_wake(addr: u32, count: i64) -> i64:
    """Wake up to count waiters blocked on addr.

    Returns:
        Number of waiters actually woken (0 in interpreter mode — no real waiters).
    """
    # No real waiters in interpreter/in-process mode
    0
