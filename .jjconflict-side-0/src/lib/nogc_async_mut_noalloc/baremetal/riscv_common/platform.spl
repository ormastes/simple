# ============================================================================
# RISC-V Platform Contract
# ============================================================================
#
# Defines a shared platform contract for RISC-V systems.  Both RV32 and RV64
# platform descriptions (QEMU virt, SiFive, FPGA boards) compose this struct
# and specialise the XLEN-dependent fields.
# ============================================================================

use std.nogc_async_mut_noalloc.baremetal.riscv_common.xlen.{XlenConfig, XLEN_32, XLEN_64}

# ============================================================================
# Platform identifiers
# ============================================================================

val PLATFORM_QEMU_VIRT: text = "qemu-virt"
val PLATFORM_SIFIVE_U: text  = "sifive-u"
val PLATFORM_FPGA: text      = "fpga-generic"

# ============================================================================
# RiscvPlatform — dual-arch platform contract
# ============================================================================

struct RiscvPlatform:
    """Describes a RISC-V platform with all MMIO addresses, hart count,
    memory layout, and ISA string.  Shared between RV32 and RV64."""
    name: text            # Platform identifier (e.g. "qemu-virt")
    cfg: XlenConfig       # XLEN configuration
    isa_string: text      # e.g. "rv32imac", "rv64gc"
    hart_count: i64       # Number of hardware threads
    ram_base: i64         # Start of main RAM
    ram_size: i64         # RAM size in bytes
    uart_base: i64        # UART0 MMIO base
    plic_base: i64        # PLIC base address
    clint_base: i64       # CLINT base address (timer, IPI)
    virtio_base: i64      # First Virtio device base

impl RiscvPlatform:
    static fn qemu_virt_rv32() -> RiscvPlatform:
        """QEMU virt machine for RV32."""
        RiscvPlatform(
            name: PLATFORM_QEMU_VIRT,
            cfg: XlenConfig.rv32(),
            isa_string: "rv32imac",
            hart_count: 1,
            ram_base: 0x80000000,
            ram_size: 128 * 1024 * 1024,
            uart_base: 0x10000000,
            plic_base: 0x0C000000,
            clint_base: 0x02000000,
            virtio_base: 0x10001000
        )

    static fn qemu_virt_rv64() -> RiscvPlatform:
        """QEMU virt machine for RV64."""
        RiscvPlatform(
            name: PLATFORM_QEMU_VIRT,
            cfg: XlenConfig.rv64(),
            isa_string: "rv64gc",
            hart_count: 1,
            ram_base: 0x80000000,
            ram_size: 128 * 1024 * 1024,
            uart_base: 0x10000000,
            plic_base: 0x0C000000,
            clint_base: 0x02000000,
            virtio_base: 0x10001000
        )

    static fn sifive_u_rv64() -> RiscvPlatform:
        """SiFive U54 (HiFive Unleashed) platform."""
        RiscvPlatform(
            name: PLATFORM_SIFIVE_U,
            cfg: XlenConfig.rv64(),
            isa_string: "rv64gc",
            hart_count: 5,
            ram_base: 0x80000000,
            ram_size: 8 * 1024 * 1024 * 1024,
            uart_base: 0x10010000,
            plic_base: 0x0C000000,
            clint_base: 0x02000000,
            virtio_base: 0
        )

    fn is_rv32() -> bool:
        """Return true if this platform targets RV32."""
        self.cfg.is_rv32()

    fn is_rv64() -> bool:
        """Return true if this platform targets RV64."""
        self.cfg.is_rv64()

    fn xlen() -> i64:
        """Return the XLEN (32 or 64)."""
        self.cfg.xlen

    fn summary() -> text:
        """Return a one-line summary for logging."""
        "{self.name} ({self.isa_string}) harts={self.hart_count} ram=0x{self.ram_base}"

# ============================================================================
# DualArchStatus — reports readiness of both RV32 and RV64
# ============================================================================

struct DualArchStatus:
    """Dual-architecture readiness report."""
    rv32_ready: bool
    rv64_ready: bool
    rv32_platform: text
    rv64_platform: text
    notes: [text]

impl DualArchStatus:
    static fn create() -> DualArchStatus:
        """Create an initial status with both arches not ready."""
        DualArchStatus(
            rv32_ready: false,
            rv64_ready: false,
            rv32_platform: "",
            rv64_platform: "",
            notes: []
        )

    fn mark_rv32(platform_name: text):
        """Mark RV32 as ready with the given platform."""
        self.rv32_ready = true
        self.rv32_platform = platform_name

    fn mark_rv64(platform_name: text):
        """Mark RV64 as ready with the given platform."""
        self.rv64_ready = true
        self.rv64_platform = platform_name

    fn add_note(note: text):
        """Add a status note."""
        self.notes = self.notes + [note]

    fn is_dual_ready() -> bool:
        """Return true if both RV32 and RV64 are ready."""
        self.rv32_ready and self.rv64_ready

    fn summary() -> text:
        """Return a human-readable status summary."""
        var rv32_label = "NOT READY"
        if self.rv32_ready:
            rv32_label = self.rv32_platform
        var rv64_label = "NOT READY"
        if self.rv64_ready:
            rv64_label = self.rv64_platform
        "RV32: {rv32_label} | RV64: {rv64_label}"

export PLATFORM_FPGA, PLATFORM_QEMU_VIRT, PLATFORM_SIFIVE_U
