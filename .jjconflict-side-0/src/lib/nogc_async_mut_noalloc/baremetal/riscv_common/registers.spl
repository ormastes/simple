# ============================================================================
# RISC-V Register File Interface
# ============================================================================
#
# Provides a unified register file abstraction for both RV32 and RV64.
# x0 is hardwired to zero. The register file stores XLEN-wide values as i64
# and truncates on read via XlenConfig.
# ============================================================================

use std.nogc_async_mut_noalloc.baremetal.riscv_common.xlen.XlenConfig

# ============================================================================
# Register count
# ============================================================================

val REG_COUNT: i64 = 32
val REG_PC_INDEX: i64 = 32   # PC stored as virtual register 32

# ============================================================================
# ABI register names (x0..x31)
# ============================================================================

val REG_ZERO: i64 = 0
val REG_RA: i64 = 1
val REG_SP: i64 = 2
val REG_GP: i64 = 3
val REG_TP: i64 = 4
val REG_T0: i64 = 5
val REG_T1: i64 = 6
val REG_T2: i64 = 7
val REG_S0: i64 = 8    # Also FP (frame pointer)
val REG_S1: i64 = 9
val REG_A0: i64 = 10
val REG_A1: i64 = 11
val REG_A2: i64 = 12
val REG_A3: i64 = 13
val REG_A4: i64 = 14
val REG_A5: i64 = 15
val REG_A6: i64 = 16
val REG_A7: i64 = 17
val REG_S2: i64 = 18
val REG_S3: i64 = 19
val REG_S4: i64 = 20
val REG_S5: i64 = 21
val REG_S6: i64 = 22
val REG_S7: i64 = 23
val REG_S8: i64 = 24
val REG_S9: i64 = 25
val REG_S10: i64 = 26
val REG_S11: i64 = 27
val REG_T3: i64 = 28
val REG_T4: i64 = 29
val REG_T5: i64 = 30
val REG_T6: i64 = 31

# ============================================================================
# ABI register name table
# ============================================================================

fn abi_reg_name(index: i64) -> text:
    """Return the ABI name for a register index (0..31)."""
    if index == 0: return "zero"
    if index == 1: return "ra"
    if index == 2: return "sp"
    if index == 3: return "gp"
    if index == 4: return "tp"
    if index == 5: return "t0"
    if index == 6: return "t1"
    if index == 7: return "t2"
    if index == 8: return "s0"
    if index == 9: return "s1"
    if index == 10: return "a0"
    if index == 11: return "a1"
    if index == 12: return "a2"
    if index == 13: return "a3"
    if index == 14: return "a4"
    if index == 15: return "a5"
    if index == 16: return "a6"
    if index == 17: return "a7"
    if index == 18: return "s2"
    if index == 19: return "s3"
    if index == 20: return "s4"
    if index == 21: return "s5"
    if index == 22: return "s6"
    if index == 23: return "s7"
    if index == 24: return "s8"
    if index == 25: return "s9"
    if index == 26: return "s10"
    if index == 27: return "s11"
    if index == 28: return "t3"
    if index == 29: return "t4"
    if index == 30: return "t5"
    if index == 31: return "t6"
    return "x?"

# ============================================================================
# RegisterFile — XLEN-aware integer register file
# ============================================================================

struct RegisterFile:
    """Integer register file with x0 hardwired to zero."""
    regs: [i64]    # x0..x31 stored as i64
    pc: i64        # Program counter
    cfg: XlenConfig

impl RegisterFile:
    static fn create(cfg: XlenConfig) -> RegisterFile:
        """Create a zeroed register file for the given XLEN."""
        var regs: [i64] = []
        var i = 0
        while i < REG_COUNT:
            regs = regs + [0]
            i = i + 1
        RegisterFile(regs: regs, pc: 0, cfg: cfg)

    fn read(index: i64) -> i64:
        """Read register value. x0 always returns 0."""
        if index == REG_ZERO:
            return 0
        if index < 0 or index >= REG_COUNT:
            return 0
        self.cfg.truncate(self.regs[index])

    fn write(index: i64, value: i64):
        """Write a value to a register. Writes to x0 are silently discarded."""
        if index == REG_ZERO:
            return
        if index < 0 or index >= REG_COUNT:
            return
        self.regs[index] = self.cfg.truncate(value)

    fn read_pc() -> i64:
        """Read the program counter."""
        self.cfg.truncate(self.pc)

    fn write_pc(value: i64):
        """Write the program counter."""
        self.pc = self.cfg.truncate(value)

    fn advance_pc():
        """Advance PC by 4 bytes (one standard instruction)."""
        self.pc = self.cfg.truncate(self.pc + 4)

    fn reg_name(index: i64) -> text:
        """Get the ABI name of a register."""
        abi_reg_name(index)

    fn dump_nonzero() -> [text]:
        """Return a list of 'name=value' strings for non-zero registers."""
        var result: [text] = []
        var i = 0
        while i < REG_COUNT:
            val v = self.read(i)
            if v != 0:
                val name = abi_reg_name(i)
                result = result + ["{name}={v}"]
            i = i + 1
        result = result + ["pc={self.pc}"]
        result
