# ============================================================================
# SoC RTL — Ethernet Frame Check Sequence (IEEE 802.3 CRC-32)
# ============================================================================
#
# The FCS block every Ethernet MAC computes in hardware. Written in the
# VHDL-synthesizable subset (u32 / bool / pure functions only) so the VHDL
# backend lowers it to a combinational CRC-step .vhd for FPGA/ASIC, alongside
# soc_rtl/eth_dma_bridge.spl. The per-octet step is fully unrolled (8 bit
# stages) — it synthesizes to the classic fixed XOR/shift network, not a loop.
#
# Reflected CRC-32: poly 0xEDB88320, init 0xFFFFFFFF, reflect-out XOR
# 0xFFFFFFFF (IEEE 802.3 / zlib). Canonical check: FCS("123456789")=0xCBF43926.
# ============================================================================

val ETH_FCS_POLY: u32 = 0xEDB88320     # reflected generator polynomial
val ETH_FCS_INIT: u32 = 0xFFFFFFFF     # CRC register preset
val ETH_FCS_XOROUT: u32 = 0xFFFFFFFF   # reflect-out final XOR

# Preset value loaded into the CRC register at start-of-frame.
fn eth_fcs_init() -> u32:
    ETH_FCS_INIT

# One bit stage of the reflected CRC: combinational, no state.
fn _eth_fcs_bit(c: u32) -> u32:
    if (c & 1u32) != 0u32:
        (c >> 1) ^ ETH_FCS_POLY
    else:
        c >> 1

# Combinational per-octet CRC step: advance the running register by one byte.
# Eight unrolled bit stages → a fixed XOR network in synthesized hardware.
fn eth_fcs_step(crc: u32, octet: u32) -> u32:
    var c: u32 = crc ^ (octet & 0xFFu32)
    c = _eth_fcs_bit(c)
    c = _eth_fcs_bit(c)
    c = _eth_fcs_bit(c)
    c = _eth_fcs_bit(c)
    c = _eth_fcs_bit(c)
    c = _eth_fcs_bit(c)
    c = _eth_fcs_bit(c)
    c = _eth_fcs_bit(c)
    c

# Reflect-out XOR; the register value becomes the transmitted 4-byte FCS.
fn eth_fcs_finalize(crc: u32) -> u32:
    crc ^ ETH_FCS_XOROUT

# Receiver-side validation: recomputed FCS over the payload must equal the
# FCS carried in the frame trailer.
fn eth_fcs_check(computed: u32, received: u32) -> bool:
    computed == received
