# SoC VHDL Generation — Synthesizable VHDL for RISC-V SoC Peripherals
#
# Generates VHDL-2008 text for each SoC component matching the behavioral
# models in soc_rtl/*.spl. Output is suitable for GHDL simulation and
# Xilinx Vivado synthesis (BRAM inference, combinational ROM, etc.).

# Split into the transparent `_SocVhdlGen/` package by semantic role —
# peripheral component generators vs. top-level SoC assembly + testbench —
# to keep each file under the 800-line source limit.
export use lib.hardware.fpga_linux._SocVhdlGen.peripherals.{u32_to_vhdl_hex, generate_bootrom_vhdl, generate_ram_vhdl, generate_uart_vhdl, generate_clint_vhdl, generate_mailbox_vhdl, generate_wb_interconnect_vhdl}
export use lib.hardware.fpga_linux._SocVhdlGen.top_testbench.{generate_soc_top_vhdl, generate_testbench_vhdl, generate_soc_vhdl_bundle}
