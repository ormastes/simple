# CompositorFrame: complete frame output with render passes and metadata

use std.viz.entity.render_pass.{RenderPass}
use std.viz.entity.surface_id.{SurfaceId}
use std.skia.entity.geometry.{SkRect}

class FrameMetadata:
    device_scale_factor: f64
    root_scroll_offset_x: f64
    root_scroll_offset_y: f64
    frame_token: i32

class CompositorFrame:
    metadata: FrameMetadata
    render_pass_list: [RenderPass]
    referenced_surfaces: [SurfaceId]
    device_viewport_rect: SkRect

    static fn empty() -> CompositorFrame:
        val zero_rect = SkRect(left: 0.0, top: 0.0, right: 0.0, bottom: 0.0)
        val meta = FrameMetadata(
            device_scale_factor: 1.0,
            root_scroll_offset_x: 0.0,
            root_scroll_offset_y: 0.0,
            frame_token: 0
        )
        CompositorFrame(
            metadata: meta,
            render_pass_list: [],
            referenced_surfaces: [],
            device_viewport_rect: zero_rect
        )

    me root_render_pass_id() -> i32:
        val n = me.render_pass_list.len().to_i32()
        if n == 0:
            -1
        else:
            me.render_pass_list[(n - 1).to_i64()].id

    me total_quad_count() -> i32:
        var total = 0
        var i = 0
        while i < me.render_pass_list.len().to_i32():
            total = total + me.render_pass_list[i.to_i64()].quad_count()
            i = i + 1
        total
