# Requirement database used by system requirement tracking tests.

extern fn rt_file_write_text(path: text, content: text) -> bool

struct Requirement:
    id: text
    title: text
    category: text
    status: text
    priority: text
    doc_path: text
    plan_path: text
    design_path: text
    system_test: text
    created_at: text
    updated_at: text
    valid: bool

struct RequirementDescription:
    req_id: text
    body: text

class RequirementDatabase:
    requirements: [Requirement]
    descriptions: [RequirementDescription]

    static fn create() -> RequirementDatabase:
        RequirementDatabase(requirements: [], descriptions: [])

    me add_requirement(req: Requirement):
        self.requirements.push(req)

    fn get_requirement(id: text) -> Requirement:
        for req in self.requirements:
            if req.id == id:
                return req
        Requirement(
            id: "", title: "", category: "", status: "", priority: "",
            doc_path: "", plan_path: "", design_path: "", system_test: "",
            created_at: "", updated_at: "", valid: false
        )

    fn next_id() -> text:
        val next_num = self.requirements.len() + 1
        if next_num < 10:
            return "REQ-00{next_num}"
        if next_num < 100:
            return "REQ-0{next_num}"
        return "REQ-{next_num}"

    fn all_requirements() -> [Requirement]:
        var out: [Requirement] = []
        for req in self.requirements:
            if req.valid:
                out.push(req)
        return out

    fn requirements_by_status(status: text) -> [Requirement]:
        var out: [Requirement] = []
        for req in self.requirements:
            if req.valid and req.status == status:
                out.push(req)
        return out

    fn requirements_by_category(category: text) -> [Requirement]:
        var out: [Requirement] = []
        for req in self.requirements:
            if req.valid and req.category == category:
                out.push(req)
        return out

    me add_description(req_id: text, body: text):
        var updated: [RequirementDescription] = []
        var found = false
        for desc in self.descriptions:
            if desc.req_id == req_id:
                updated.push(RequirementDescription(req_id: req_id, body: body))
                found = true
            else:
                updated.push(desc)
        if not found:
            updated.push(RequirementDescription(req_id: req_id, body: body))
        self.descriptions = updated

    fn get_description(req_id: text) -> text:
        for desc in self.descriptions:
            if desc.req_id == req_id:
                return desc.body
        return ""

    fn save() -> bool:
        var text_out = "requirements:\n"
        for req in self.requirements:
            text_out = "{text_out}  - id: {req.id}\n"
            text_out = "{text_out}    title: \"{req.title}\"\n"
            text_out = "{text_out}    status: {req.status}\n"
        rt_file_write_text("/tmp/test_reqdb_save.sdn", text_out)
