# CSS selector matcher — tests whether a DomNode matches a selector string.
#
# Supported subset:
#   - Type selector:        div
#   - Class selector:       .foo
#   - ID selector:          #bar
#   - Universal:            *
#   - Compound:             div.foo     → same element matches both type and class
#   - Descendant combinator: div p       → p anywhere inside div
#   - Child combinator:      ul > li     → li directly under ul
#   - Attribute presence:   [disabled]   → element has the attribute
#   - Pseudo-class:         :hover, :focus (requires InteractionState)
#
# Out of scope: other pseudo-classes (:nth-child, :not, ...), attribute value
# operators (^= $= *=), adjacent-sibling (+), general-sibling (~), namespaces.

use std.lib.blink.dom.node.{DomNode, DomTree, NodeType, Attribute}
use std.lib.blink.dom.interaction_state.{InteractionState, interaction_state_empty}

# ============================================================================
# SimpleSelectorKind — discriminant for the five simple selector types
# ============================================================================

enum SimpleSelectorKind:
    Type
    Class
    Id
    Universal
    AttributePresence
    PseudoClass

# ============================================================================
# SimpleSelector — one atomic selector part
# ============================================================================

class SimpleSelector:
    kind: SimpleSelectorKind
    name: String   # tag/class/id/attr name; empty string for Universal

fn simple_selector_new(kind: SimpleSelectorKind, name: String) -> SimpleSelector:
    SimpleSelector(kind: kind, name: name)

# ============================================================================
# CompoundSelector — one or more simple selectors applied to the same element
# ============================================================================

class CompoundSelector:
    simples: [SimpleSelector]

fn compound_selector_new() -> CompoundSelector:
    CompoundSelector(simples: [SimpleSelector]())

# ============================================================================
# Combinator — relationship between two consecutive compounds
# ============================================================================

enum Combinator:
    Descendant
    Child

# ============================================================================
# ComplexSelector — full selector: compounds joined by combinators
#
# Invariant: combinators.length == compounds.length - 1
# ============================================================================

class ComplexSelector:
    compounds: [CompoundSelector]
    combinators: [Combinator]

fn complex_selector_new() -> ComplexSelector:
    ComplexSelector(
        compounds: [CompoundSelector](),
        combinators: [Combinator]()
    )

# ============================================================================
# Internal: string helpers
# ============================================================================

# Return true if `haystack` contains `needle` as a substring.
fn str_contains_substr(haystack: String, needle: String) -> bool:
    val hlen = haystack.len()
    val nlen = needle.len()
    if nlen == 0:
        return true
    if nlen > hlen:
        return false
    var i = 0
    while i <= hlen - nlen:
        var j = 0
        var match = true
        while j < nlen:
            if haystack[i + j] != needle[j]:
                match = false
                j = nlen   # break inner loop
            j = j + 1
        if match:
            return true
        i = i + 1
    false

# Split `s` by a single-character delimiter `delim`.  Returns a list of
# substrings (including empty strings when delimiters are adjacent).
fn str_split_char(s: String, delim: i64) -> [String]:
    val parts = [String]()
    var start = 0
    var i = 0
    val length = s.len()
    while i < length:
        if s[i].to_i64() == delim:
            parts.push(s.slice(start, i))
            start = i + 1
        i = i + 1
    parts.push(s.slice(start, length))
    parts

# Trim leading and trailing ASCII spaces/tabs from a string.
fn str_trim(s: String) -> String:
    val length = s.len()
    var lo = 0
    while lo < length:
        val ch = s[lo].to_i64()
        if ch != 32 && ch != 9:
            lo = length   # break
        lo = lo + 1
    # Undo the overshoot: lo is now one past the first non-space.
    # Re-scan properly.
    var left = 0
    while left < length:
        val ch = s[left].to_i64()
        if ch != 32 && ch != 9:
            left = length + 1   # signal found
        else:
            left = left + 1
    if left == length:
        # All spaces — return empty string.
        return ""
    left = left - 1   # fix overshoot
    # Intentional re-scan to get correct left index.
    left = 0
    var found_left = false
    while left < length && !found_left:
        val ch = s[left].to_i64()
        if ch != 32 && ch != 9:
            found_left = true
        else:
            left = left + 1
    var right = length - 1
    var found_right = false
    while right >= 0 && !found_right:
        val ch = s[right].to_i64()
        if ch != 32 && ch != 9:
            found_right = true
        else:
            right = right - 1
    if !found_left:
        return ""
    s.slice(left, right + 1)

# Return true if the space-separated token list `class_value` contains `token`.
fn class_list_contains(class_value: String, token: String) -> bool:
    val tokens = str_split_char(class_value, 32)   # space = 0x20
    var i = 0
    while i < tokens.len():
        val t = str_trim(tokens[i])
        if t == token:
            return true
        i = i + 1
    false

# ============================================================================
# Internal: parse a single compound selector string (e.g. "div.foo#bar")
# ============================================================================

# Returns None on error, Some(CompoundSelector) on success.
fn parse_compound(raw: String) -> Option<CompoundSelector>:
    val length = raw.len()
    if length == 0:
        return None
    val compound = compound_selector_new()
    # Walk character by character building token runs.
    # State machine: track what kind of simple is being accumulated.
    # NONE = 0, TYPE = 1, CLASS = 2, ID = 3, ATTR = 4, PSEUDO = 5
    var state = 0
    var token_start = 0
    var i = 0
    while i <= length:
        # Treat end-of-string as a flush signal using a synthetic NUL (0).
        var ch: i64 = 0
        if i < length:
            ch = raw[i].to_i64()
        val flush = i == length || ch == 46 || ch == 35 || ch == 91 || ch == 58   # . # [ :
        if flush && state != 0:
            val token = raw.slice(token_start, i)
            if state == 1:
                # Type selector.
                if token == "*":
                    compound.simples.push(simple_selector_new(SimpleSelectorKind.Universal, ""))
                else:
                    compound.simples.push(simple_selector_new(SimpleSelectorKind.Type, token))
            else if state == 2:
                # Class selector.
                if token.len() == 0:
                    return None
                compound.simples.push(simple_selector_new(SimpleSelectorKind.Class, token))
            else if state == 3:
                # ID selector.
                if token.len() == 0:
                    return None
                compound.simples.push(simple_selector_new(SimpleSelectorKind.Id, token))
            else if state == 4:
                # Attribute presence — strip trailing ']'.
                var attr_name = token
                val tlen = attr_name.len()
                if tlen > 0 && attr_name[tlen - 1].to_i64() == 93:   # ]
                    attr_name = attr_name.slice(0, tlen - 1)
                if attr_name.len() == 0:
                    return None
                compound.simples.push(simple_selector_new(SimpleSelectorKind.AttributePresence, attr_name))
            else if state == 5:
                # Pseudo-class — only :hover and :focus are supported.
                if token != "hover" && token != "focus":
                    return None
                compound.simples.push(simple_selector_new(SimpleSelectorKind.PseudoClass, token))
        if i < length:
            if ch == 46:   # .
                state = 2
                token_start = i + 1
            else if ch == 35:   # #
                state = 3
                token_start = i + 1
            else if ch == 91:   # [
                state = 4
                token_start = i + 1
            else if ch == 58:   # :
                state = 5
                token_start = i + 1
            else if state == 0:
                # Start of a type selector (or universal).
                state = 1
                token_start = i
        i = i + 1
    if compound.simples.len() == 0:
        return None
    Some(compound)

# ============================================================================
# parse_selector — public entry point
# ============================================================================

# Tokenize the selector on whitespace and '>'.  Each whitespace-separated
# segment becomes a CompoundSelector; '>' between segments yields a Child
# combinator; simple adjacency yields a Descendant combinator.
fn parse_selector(selector_text: String) -> Option<ComplexSelector>:
    val complex = complex_selector_new()
    # Split on '>' first, recording Child combinator boundaries.
    # Strategy: walk character by character, collecting segments and
    # recording Child vs Descendant combinators between them.
    val length = selector_text.len()
    if length == 0:
        return None
    # Phase 1: collect tokens separated by whitespace or '>'.
    # A token is either ">" or a non-empty identifier chunk.
    val tokens = [String]()
    val token_kinds = [i64]()   # 0 = compound text, 1 = child-combinator ">"
    var seg_start = 0
    var in_seg = false
    var i = 0
    while i < length:
        val ch = selector_text[i].to_i64()
        val is_space = ch == 32 || ch == 9 || ch == 10 || ch == 13
        val is_gt = ch == 62
        if is_space:
            if in_seg:
                tokens.push(selector_text.slice(seg_start, i))
                token_kinds.push(0)
                in_seg = false
        else if is_gt:
            if in_seg:
                tokens.push(selector_text.slice(seg_start, i))
                token_kinds.push(0)
                in_seg = false
            tokens.push(">")
            token_kinds.push(1)
        else:
            if !in_seg:
                seg_start = i
                in_seg = true
        i = i + 1
    if in_seg:
        tokens.push(selector_text.slice(seg_start, length))
        token_kinds.push(0)
    # Phase 2: build ComplexSelector from tokens.
    # Track whether the previous non-combinator token was separated by spaces
    # (Descendant) or directly preceded by '>' (Child).
    # Between two adjacent compound tokens (no '>' token between them), use
    # Descendant.  If a '>' token appears, use Child.
    var expecting_combinator = false   # true after we push a compound
    var next_combinator_is_child = false
    var prev_was_gt = false
    var j = 0
    while j < tokens.len():
        val kind = token_kinds[j]
        if kind == 1:
            # '>' token — next compound joins with Child combinator.
            next_combinator_is_child = true
            prev_was_gt = true
        else:
            # Compound token.
            val maybe_compound = parse_compound(tokens[j])
            if maybe_compound.is_none():
                return None
            val compound = maybe_compound.unwrap()
            if expecting_combinator:
                # We need a combinator between the previous compound and this one.
                if prev_was_gt:
                    complex.combinators.push(Combinator.Child)
                else:
                    complex.combinators.push(Combinator.Descendant)
            complex.compounds.push(compound)
            expecting_combinator = true
            prev_was_gt = false
            next_combinator_is_child = false
        j = j + 1
    if complex.compounds.len() == 0:
        return None
    Some(complex)

# ============================================================================
# matches_compound — test a single node against a CompoundSelector
# ============================================================================
#
# Backwards-compatible entry point: callers that don't have interaction state
# forward to `matches_compound_with_state` with an empty state. In that case
# any `:hover` / `:focus` pseudo-class cannot match (hovered_id/focused_id
# are -1, and valid DOM ids are >= 0).

fn matches_compound(node: DomNode, compound: CompoundSelector) -> bool:
    matches_compound_with_state(node, node.id, compound, interaction_state_empty())

fn matches_compound_with_state(node: DomNode, node_id: i64, compound: CompoundSelector, state: InteractionState) -> bool:
    var i = 0
    while i < compound.simples.len():
        val simple = compound.simples[i]
        val kind = simple.kind
        if kind == SimpleSelectorKind.Type:
            if node.node_type != NodeType.Element:
                return false
            if node.tag_name != simple.name:
                return false
        else if kind == SimpleSelectorKind.Class:
            # Find "class" attribute and check token list.
            var found_class = false
            var ai = 0
            while ai < node.attributes.len():
                val attr = node.attributes[ai]
                if attr.name == "class":
                    if class_list_contains(attr.value, simple.name):
                        found_class = true
                ai = ai + 1
            if !found_class:
                return false
        else if kind == SimpleSelectorKind.Id:
            var found_id = false
            var ai = 0
            while ai < node.attributes.len():
                val attr = node.attributes[ai]
                if attr.name == "id":
                    if attr.value == simple.name:
                        found_id = true
                ai = ai + 1
            if !found_id:
                return false
        else if kind == SimpleSelectorKind.Universal:
            if node.node_type != NodeType.Element:
                return false
        else if kind == SimpleSelectorKind.AttributePresence:
            var found_attr = false
            var ai = 0
            while ai < node.attributes.len():
                val attr = node.attributes[ai]
                if attr.name == simple.name:
                    found_attr = true
                ai = ai + 1
            if !found_attr:
                return false
        else if kind == SimpleSelectorKind.PseudoClass:
            if node.node_type != NodeType.Element:
                return false
            if simple.name == "hover":
                if state.hovered_id != node_id:
                    return false
            else if simple.name == "focus":
                if state.focused_id != node_id:
                    return false
            else:
                # Any other pseudo-class name cannot match (parser rejects
                # these, but guard defensively).
                return false
        i = i + 1
    true

# ============================================================================
# matches_complex — test a node against a full ComplexSelector
# ============================================================================
#
# Matching is anchored right-to-left:
#   1. The rightmost compound must match `node_id`.
#   2. For each earlier compound + combinator pair, walk up the ancestor chain:
#      - Child:      immediate parent must match.
#      - Descendant: any ancestor (parent or further up) must match.

fn matches_complex(tree: DomTree, node_id: i64, selector: ComplexSelector) -> bool:
    matches_complex_with_state(tree, node_id, selector, interaction_state_empty())

fn matches_complex_with_state(tree: DomTree, node_id: i64, selector: ComplexSelector, state: InteractionState) -> bool:
    val num_compounds = selector.compounds.len()
    if num_compounds == 0:
        return false
    # Check that the rightmost compound matches the candidate node.
    val maybe_node = tree.get_node(node_id)
    if maybe_node.is_none():
        return false
    val node = maybe_node.unwrap()
    val last_idx = num_compounds - 1
    if !matches_compound_with_state(node, node_id, selector.compounds[last_idx], state):
        return false
    if num_compounds == 1:
        return true
    # Walk backward through remaining compounds.
    var current_id = node_id
    var compound_idx = last_idx - 1
    while compound_idx >= 0:
        val combinator = selector.combinators[compound_idx]
        if combinator == Combinator.Child:
            # Immediate parent must match.
            val maybe_current = tree.get_node(current_id)
            if maybe_current.is_none():
                return false
            val parent_id = maybe_current.unwrap().parent
            val maybe_parent = tree.get_node(parent_id)
            if maybe_parent.is_none():
                return false
            val parent_node = maybe_parent.unwrap()
            if !matches_compound_with_state(parent_node, parent_id, selector.compounds[compound_idx], state):
                return false
            current_id = parent_id
        else:
            # Descendant: walk up until we find a matching ancestor.
            val maybe_current = tree.get_node(current_id)
            if maybe_current.is_none():
                return false
            var ancestor_id = maybe_current.unwrap().parent
            var found_ancestor = false
            while ancestor_id >= 0 && !found_ancestor:
                val maybe_anc = tree.get_node(ancestor_id)
                if maybe_anc.is_none():
                    ancestor_id = -1
                else:
                    val anc_node = maybe_anc.unwrap()
                    if matches_compound_with_state(anc_node, ancestor_id, selector.compounds[compound_idx], state):
                        found_ancestor = true
                        current_id = ancestor_id
                    else:
                        ancestor_id = anc_node.parent
            if !found_ancestor:
                return false
        compound_idx = compound_idx - 1
    true
