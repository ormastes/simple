# Privilege IdPath — hierarchical dotted-path identity strings.
#
# An IdPath is a canonical dotted namespace path used to scope authority
# tokens and ACL entries (e.g. "id.public", "app.wiki.notes").

struct IdPath:
    path: text

# Create an IdPath from a dotted-path string.
fn id_path_intern(path: text) -> IdPath:
    IdPath(path: path)

# Convert an IdPath back to its text representation.
fn id_path_to_text(id: IdPath) -> text:
    id.path

# Return true if prefix.path is a proper prefix of or equal to target.path.
# "a.b" covers "a.b.c" and "a.b" but not "a.bc".
fn id_path_prefix_match(prefix: IdPath, target: IdPath) -> bool:
    val p = prefix.path
    val t = target.path
    if p == t:
        return true
    if t.starts_with(p + "."):
        return true
    false
