# Privilege AuthorityToken — capability token minted by an approval broker.
#
# Provides: AuthorityToken, AuthorityLevel, TrustSource, Scope, authority_level_name.

use std.common.privilege.id_path.{IdPath, id_path_intern}
use std.common.privilege.principal.{Principal, PrincipalKind}

enum AuthorityLevel:
    Public
    Read
    Write
    Sensitive
    Admin
    Internal

enum TrustSource:
    Untrusted
    SystemTrusted
    UserTrusted

class Scope:
    one_shot_flag: bool

impl Scope:
    static fn one_shot() -> Scope:
        Scope(one_shot_flag: true)

    static fn persistent() -> Scope:
        Scope(one_shot_flag: false)

class AuthorityToken:
    id_path: IdPath
    level: AuthorityLevel
    principal: Principal
    trust_source: TrustSource
    scope: Scope
    issuer_sig: [u8]

impl AuthorityToken:
    # A zero-trust public token with no elevated authority.
    static fn public() -> AuthorityToken:
        AuthorityToken(
            id_path: id_path_intern("id.public"),
            level: AuthorityLevel.Public,
            principal: Principal(id: "public", kind: PrincipalKind.Anonymous),
            trust_source: TrustSource.Untrusted,
            scope: Scope.persistent(),
            issuer_sig: [])

fn authority_level_name(level: AuthorityLevel) -> text:
    match level:
        AuthorityLevel.Public:     "public"
        AuthorityLevel.Read:       "read"
        AuthorityLevel.Write:      "write"
        AuthorityLevel.Sensitive:  "sensitive"
        AuthorityLevel.Admin:      "admin"
        AuthorityLevel.Internal:   "internal"

fn authority_level_rank(level: AuthorityLevel) -> i64:
    match level:
        AuthorityLevel.Public:    0
        AuthorityLevel.Read:      1
        AuthorityLevel.Write:     2
        AuthorityLevel.Sensitive: 3
        AuthorityLevel.Admin:     4
        AuthorityLevel.Internal:  5

fn is_revoked(token: AuthorityToken) -> bool:
    token.issuer_sig.len() == 0 and token.level != AuthorityLevel.Public

fn trust_source_name(source: TrustSource) -> text:
    match source:
        TrustSource.Untrusted:     "untrusted"
        TrustSource.SystemTrusted: "system"
        TrustSource.UserTrusted:   "user"

export AuthorityToken, AuthorityLevel, TrustSource, Scope
export authority_level_name, authority_level_rank, is_revoked, trust_source_name
