# C Name Matching
#
# Normalized name matching for Simple ↔ C field/struct name resolution.
# Default: case-insensitive, strip underscores/hyphens.
# Strict: exact match.

fn normalize_c_name(name: text) -> text:
    var result = ""
    var i = 0
    while i < name.length:
        val ch = name[i]
        if ch != "_" and ch != "-":
            if ch >= "A" and ch <= "Z":
                val code = ch.char_code_at(0)
                result = result + text.from_char_code(code + 32)
            else:
                result = result + ch
        i = i + 1
    result

fn c_names_match(simple_name: text, c_name: text) -> bool:
    normalize_c_name(simple_name) == normalize_c_name(c_name)

fn c_names_match_strict(simple_name: text, c_name: text) -> bool:
    simple_name == c_name

fn c_find_matching_field(simple_name: text, c_field_names: [text], strict: bool) -> text:
    var i = 0
    while i < c_field_names.length:
        val c_name = c_field_names[i]
        if strict:
            if c_names_match_strict(simple_name, c_name):
                return c_name
        else:
            if c_names_match(simple_name, c_name):
                return c_name
        i = i + 1
    ""

fn c_find_matching_struct(simple_name: text, c_struct_names: [text], strict: bool) -> text:
    c_find_matching_field(simple_name, c_struct_names, strict)
