"""
# Simple Framework JavaScript

Generates the `simple-framework.js` client-side library.
Includes SimpleFetch (auto CSRF), WebSocket reconnect,
and hydration initialization.

## Usage

```simple
val js = generate_framework_js("_csrf_token")
# Serve at /assets/js/simple-framework.js
```
"""

# ============================================================================
# Framework JS Generator
# ============================================================================

fn generate_framework_js(csrf_cookie_name: text) -> text:
    """Generate the simple-framework.js content.

    Includes:
    - SimpleFetch: Wrapper around fetch() with automatic CSRF token injection
    - SimpleWS: WebSocket with auto-reconnect
    - SimpleHydration: Component hydration from data-spl-* attributes

    Args:
        csrf_cookie_name: Name of the CSRF cookie/meta tag

    Returns:
        JavaScript source code
    """
    val js = """// simple-framework.js
// Auto-generated by SimpleWeb Framework
(function(window) {
  'use strict';

  // ========================================================================
  // CSRF Token Management
  // ========================================================================

  function getCsrfToken() {
    // Try meta tag first
    var meta = document.querySelector('meta[name="csrf-token"]');
    if (meta) return meta.getAttribute('content');

    // Try cookie
    var cookies = document.cookie.split(';');
    for (var i = 0; i < cookies.length; i++) {
      var cookie = cookies[i].trim();
      if (cookie.indexOf('""" + csrf_cookie_name + """=') === 0) {
        return cookie.substring('""" + csrf_cookie_name + """'.length + 1);
      }
    }
    return '';
  }

  // ========================================================================
  // SimpleFetch - HTTP Client with Auto CSRF
  // ========================================================================

  var SimpleFetch = {
    _defaultHeaders: {
      'Content-Type': 'application/json',
      'Accept': 'application/json'
    },

    _request: function(method, url, data, options) {
      options = options || {};
      var headers = Object.assign({}, this._defaultHeaders, options.headers || {});

      // Add CSRF token for mutating methods
      if (method !== 'GET' && method !== 'HEAD') {
        headers['X-CSRF-Token'] = getCsrfToken();
      }

      var fetchOptions = {
        method: method,
        headers: headers,
        credentials: 'same-origin'
      };

      if (data && method !== 'GET' && method !== 'HEAD') {
        fetchOptions.body = typeof data === 'string' ? data : JSON.stringify(data);
      }

      return fetch(url, fetchOptions).then(function(response) {
        if (!response.ok) {
          return response.text().then(function(text) {
            var error = new Error(response.statusText || 'Request failed');
            error.status = response.status;
            error.body = text;
            throw error;
          });
        }
        var contentType = response.headers.get('content-type') || '';
        if (contentType.indexOf('application/json') >= 0) {
          return response.json();
        }
        return response.text();
      });
    },

    get: function(url, options) {
      return this._request('GET', url, null, options);
    },

    post: function(url, data, options) {
      return this._request('POST', url, data, options);
    },

    put: function(url, data, options) {
      return this._request('PUT', url, data, options);
    },

    patch: function(url, data, options) {
      return this._request('PATCH', url, data, options);
    },

    del: function(url, options) {
      return this._request('DELETE', url, null, options);
    },

    // Form submission with URL-encoded body
    submitForm: function(url, formData) {
      var headers = {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-CSRF-Token': getCsrfToken()
      };

      var body = '';
      if (formData instanceof FormData) {
        var pairs = [];
        formData.forEach(function(value, key) {
          pairs.push(encodeURIComponent(key) + '=' + encodeURIComponent(value));
        });
        body = pairs.join('&');
      } else if (typeof formData === 'object') {
        var pairs = [];
        Object.keys(formData).forEach(function(key) {
          pairs.push(encodeURIComponent(key) + '=' + encodeURIComponent(formData[key]));
        });
        body = pairs.join('&');
      }

      return fetch(url, {
        method: 'POST',
        headers: headers,
        body: body,
        credentials: 'same-origin'
      });
    }
  };

  // ========================================================================
  // SimpleWS - WebSocket with Auto-Reconnect
  // ========================================================================

  function SimpleWS(url, options) {
    options = options || {};
    this.url = url;
    this.retryInterval = options.retryInterval || 1000;
    this.maxRetries = options.maxRetries || 30;
    this.retries = 0;
    this.ws = null;
    this.handlers = {};
  }

  SimpleWS.prototype.connect = function() {
    var self = this;
    this.ws = new WebSocket(this.url);

    this.ws.onopen = function() {
      self.retries = 0;
      if (self.handlers.open) self.handlers.open();
    };

    this.ws.onmessage = function(event) {
      if (self.handlers.message) self.handlers.message(event.data);
    };

    this.ws.onclose = function() {
      self.ws = null;
      if (self.handlers.close) self.handlers.close();
      if (self.retries < self.maxRetries) {
        self.retries++;
        setTimeout(function() { self.connect(); }, self.retryInterval);
      }
    };

    this.ws.onerror = function(err) {
      if (self.handlers.error) self.handlers.error(err);
      self.ws.close();
    };

    return this;
  };

  SimpleWS.prototype.on = function(event, handler) {
    this.handlers[event] = handler;
    return this;
  };

  SimpleWS.prototype.send = function(data) {
    if (this.ws && this.ws.readyState === WebSocket.OPEN) {
      this.ws.send(typeof data === 'string' ? data : JSON.stringify(data));
    }
    return this;
  };

  SimpleWS.prototype.close = function() {
    this.maxRetries = 0;
    if (this.ws) this.ws.close();
  };

  // ========================================================================
  // Component Hydration
  // ========================================================================

  var _components = {};

  var SimpleHydration = {
    register: function(name, initFn) {
      _components[name] = initFn;
    },

    hydrate: function(root) {
      root = root || document;
      var elements = root.querySelectorAll('[data-spl-component]');
      elements.forEach(function(el) {
        if (el.getAttribute('data-spl-hydrated') === 'true') return;

        var name = el.getAttribute('data-spl-component');
        var propsStr = el.getAttribute('data-spl-props') || '{}';
        var props = {};
        try { props = JSON.parse(propsStr); } catch(e) {}

        if (_components[name]) {
          try {
            _components[name](el, props);
            el.setAttribute('data-spl-hydrated', 'true');
          } catch(err) {
            console.error('[Hydration] Error:', name, err);
          }
        }
      });
    }
  };

  // Auto-hydrate
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      SimpleHydration.hydrate();
    });
  } else {
    SimpleHydration.hydrate();
  }

  // ========================================================================
  // Export
  // ========================================================================

  window.SimpleFetch = SimpleFetch;
  window.SimpleWS = SimpleWS;
  window.SimpleHydration = SimpleHydration;

})(window);
"""
    js

fn generate_framework_js_minified(csrf_cookie_name: text) -> text:
    """Generate a minified version hint.

    In production, run the full JS through a minifier.
    This just returns the same content for now.
    """
    generate_framework_js(csrf_cookie_name)
