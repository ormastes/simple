#![allow(unnamed_duplicate_typed_args)]
"""
# View Model

ViewData wraps a Dict<text, text> and provides builder-pattern
accessors for constructing template data. Converts to the template
engine's context format ([[text]]).

## Usage

```simple
var view = ViewData.new()
view = view.set("title", "Dashboard")
view = view.set("user_name", "Alice")
view = view.set("count", "42")

val ctx = view.to_template_context()
val html = render_nodes(nodes, ctx, registry)
```
"""

# ============================================================================
# ViewData
# ============================================================================

class ViewData:
    """Builder for template rendering data.

    Wraps a Dict<text, text> with convenience methods and
    conversion to the template engine's [[text]] context format.
    """
    data: Dict<text, text>

impl ViewData:
    static fn new() -> ViewData:
        """Create an empty ViewData."""
        ViewData(data: {})

    static fn from_dict(d: Dict<text, text>) -> ViewData:
        """Create ViewData from an existing dict."""
        ViewData(data: d)

    me set(key: text, value: text) -> ViewData:
        """Set a key-value pair.

        Args:
            key: Template variable name
            value: Template variable value

        Returns:
            Self for chaining
        """
        self.data[key] = value
        self

    fn get(key: text) -> text:
        """Get a value by key, returns empty string if missing."""
        self.data.get(key) ?? ""

    fn get_or(key: text, default: text) -> text:
        """Get a value by key with a default fallback.

        Args:
            key: Template variable name
            default: Value to return if key is missing

        Returns:
            Value for key, or default
        """
        val value = self.data.get(key)
        if value != nil:
            return value ?? default
        default

    fn has(key: text) -> bool:
        """Check if a key exists in the view data."""
        self.data.get(key) != nil

    fn keys() -> [text]:
        """Get all keys in the view data."""
        self.data.keys()

    fn to_template_context() -> [[text]]:
        """Convert to the template engine's context format.

        The template engine uses [[text]] where each inner list
        is [key, value].

        Returns:
            Template context as list of [key, value] pairs
        """
        var ctx: [[text]] = []
        for key in self.data.keys():
            val value = self.data.get(key) ?? ""
            ctx.push([key, value])
        ctx

    me merge(other: ViewData) -> ViewData:
        """Merge another ViewData into this one.

        Values from `other` overwrite existing values on key conflict.

        Args:
            other: ViewData to merge in

        Returns:
            Self for chaining
        """
        for key in other.data.keys():
            val value = other.data.get(key) ?? ""
            self.data[key] = value
        self

    me merge_dict(d: Dict<text, text>) -> ViewData:
        """Merge a dict into this ViewData.

        Args:
            d: Dict to merge

        Returns:
            Self for chaining
        """
        for key in d.keys():
            val value = d.get(key) ?? ""
            self.data[key] = value
        self

    fn to_dict() -> Dict<text, text>:
        """Convert back to a plain Dict<text, text>."""
        self.data

    fn len() -> i64:
        """Get the number of entries."""
        self.data.len()

# ============================================================================
# Convenience Functions
# ============================================================================

fn view_data_from_pairs(pairs: [(text, text)]) -> ViewData:
    """Create ViewData from a list of (key, value) tuples.

    Args:
        pairs: List of (key, value) tuples

    Returns:
        ViewData with all pairs set
    """
    var vd = ViewData.new()
    for pair in pairs:
        vd = vd.set(pair.0, pair.1)
    vd

fn dict_to_template_context(d: Dict<text, text>) -> [[text]]:
    """Convert a Dict<text, text> directly to template context format.

    Args:
        d: Dict to convert

    Returns:
        Template context as list of [key, value] pairs
    """
    var ctx: [[text]] = []
    for key in d.keys():
        val value = d.get(key) ?? ""
        ctx.push([key, value])
    ctx
