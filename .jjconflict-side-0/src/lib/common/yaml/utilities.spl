# YAML utilities: string escaping, mapping/sequence operations, and helpers.

use lib.yaml.types.{yaml_string, yaml_sequence, yaml_mapping, is_yaml_mapping, is_yaml_sequence, is_yaml_scalar, yaml_get_scalar_type, yaml_get_scalar_content, yaml_get_sequence_items, yaml_get_mapping_pairs}
use lib.yaml.serialize.{yaml_serialize_block, yaml_serialize_flow}
use lib.yaml.parse.{yaml_parse}

# ---- strings ----

fn yaml_escape_string(s: text) -> text:
    var out = s.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\t", "\\t")
    out = out.replace("\r", "\\r")
    out

fn yaml_unescape_string(s: text) -> text:
    var out = s.replace("\\n", "\n")
    out = out.replace("\\t", "\t")
    out = out.replace("\\r", "\r")
    out = out.replace("\\\\", "\\")
    out

fn yaml_needs_quotes(s: text) -> bool:
    if s == "":
        return true
    if s.contains(":") or s.contains("#") or s.contains("\n"):
        return true
    false

fn yaml_quote_string(s: text, style: text = "double") -> text:
    if style == "single":
        return "'" + s.replace("'", "''") + "'"
    "\"" + yaml_escape_string(s) + "\""

# Two forms: yaml_indent(level, size) -> pad string;
#            yaml_indent(text, level, size) -> text prefixed by level*size spaces.
fn yaml_indent(a: any, level: i64, size: i64 = -1) -> text:
    if size < 0:
        # 2-arg form: a=level, level=size
        val lvl: i64 = a
        val sz: i64 = level
        if lvl <= 0:
            return ""
        var out = ""
        var i = 0
        val total = lvl * sz
        while i < total:
            out = out + " "
            i = i + 1
        return out
    # 3-arg form: indent the text `a` by level*size spaces
    var pad = ""
    var j = 0
    val tot = level * size
    while j < tot:
        pad = pad + " "
        j = j + 1
    pad + a

fn yaml_detect_indentation(s: text) -> i64:
    val lines = _yaml_u_lines(s)
    var i = 0
    while i < lines.length():
        val ln = lines[i]
        var spaces = 0
        var j = 0
        while j < ln.length() and ln.substring(j, j + 1) == " ":
            spaces = spaces + 1
            j = j + 1
        if spaces > 0:
            return spaces
        i = i + 1
    2

fn yaml_validate_indentation(s: text) -> bool:
    not s.contains("\t")

# ---- mapping operations ----

fn yaml_mapping_get(m: any, key: text) -> any:
    val pairs = yaml_get_mapping_pairs(m)
    var i = 0
    while i < pairs.length():
        if pairs[i].0 == key:
            return pairs[i].1
        i = i + 1
    nil

fn yaml_mapping_has(m: any, key: text) -> bool:
    val pairs = yaml_get_mapping_pairs(m)
    var i = 0
    while i < pairs.length():
        if pairs[i].0 == key:
            return true
        i = i + 1
    false

fn yaml_mapping_set(m: any, key: text, value: any) -> any:
    val pairs = yaml_get_mapping_pairs(m)
    var out = []
    var found = false
    var i = 0
    while i < pairs.length():
        if pairs[i].0 == key:
            out.push((key, value))
            found = true
        else:
            out.push(pairs[i])
        i = i + 1
    if not found:
        out.push((key, value))
    yaml_mapping(out)

fn yaml_mapping_remove(m: any, key: text) -> any:
    val pairs = yaml_get_mapping_pairs(m)
    var out = []
    var i = 0
    while i < pairs.length():
        if pairs[i].0 != key:
            out.push(pairs[i])
        i = i + 1
    yaml_mapping(out)

fn yaml_mapping_keys(m: any) -> [any]:
    val pairs = yaml_get_mapping_pairs(m)
    var out = []
    var i = 0
    while i < pairs.length():
        out.push(pairs[i].0)
        i = i + 1
    out

fn yaml_mapping_values(m: any) -> [any]:
    val pairs = yaml_get_mapping_pairs(m)
    var out = []
    var i = 0
    while i < pairs.length():
        out.push(pairs[i].1)
        i = i + 1
    out

fn yaml_mapping_size(m: any) -> i64:
    yaml_get_mapping_pairs(m).length()

fn yaml_mapping_contains_value(m: any, value: any) -> bool:
    val pairs = yaml_get_mapping_pairs(m)
    var i = 0
    while i < pairs.length():
        if yaml_equals(pairs[i].1, value):
            return true
        i = i + 1
    false

fn _yaml_list_has(xs: [any], item: text) -> bool:
    var i = 0
    while i < xs.length():
        if xs[i] == item:
            return true
        i = i + 1
    false

fn yaml_mapping_filter_keys(m: any, keys: [any]) -> any:
    val pairs = yaml_get_mapping_pairs(m)
    var out = []
    var i = 0
    while i < pairs.length():
        if _yaml_list_has(keys, pairs[i].0):
            out.push(pairs[i])
        i = i + 1
    yaml_mapping(out)

fn yaml_mapping_exclude_keys(m: any, keys: [any]) -> any:
    val pairs = yaml_get_mapping_pairs(m)
    var out = []
    var i = 0
    while i < pairs.length():
        if not _yaml_list_has(keys, pairs[i].0):
            out.push(pairs[i])
        i = i + 1
    yaml_mapping(out)

fn yaml_merge_mappings(m1: any, m2: any) -> any:
    var result = m1
    val pairs = yaml_get_mapping_pairs(m2)
    var i = 0
    while i < pairs.length():
        result = yaml_mapping_set(result, pairs[i].0, pairs[i].1)
        i = i + 1
    result

# ---- sequence operations ----

fn yaml_sequence_get(seq: any, idx: i64) -> any:
    val items = yaml_get_sequence_items(seq)
    if idx < 0 or idx >= items.length():
        return nil
    items[idx]

fn yaml_sequence_set(seq: any, idx: i64, value: any) -> any:
    val items = yaml_get_sequence_items(seq)
    var out = []
    var i = 0
    while i < items.length():
        if i == idx:
            out.push(value)
        else:
            out.push(items[i])
        i = i + 1
    yaml_sequence(out)

fn yaml_sequence_append(seq: any, value: any) -> any:
    val items = yaml_get_sequence_items(seq)
    var out = []
    var i = 0
    while i < items.length():
        out.push(items[i])
        i = i + 1
    out.push(value)
    yaml_sequence(out)

fn yaml_sequence_length(seq: any) -> i64:
    yaml_get_sequence_items(seq).length()

fn yaml_sequence_insert(seq: any, idx: i64, value: any) -> any:
    val items = yaml_get_sequence_items(seq)
    var out = []
    var i = 0
    while i < items.length():
        if i == idx:
            out.push(value)
        out.push(items[i])
        i = i + 1
    if idx >= items.length():
        out.push(value)
    yaml_sequence(out)

fn yaml_sequence_remove(seq: any, idx: i64) -> any:
    val items = yaml_get_sequence_items(seq)
    var out = []
    var i = 0
    while i < items.length():
        if i != idx:
            out.push(items[i])
        i = i + 1
    yaml_sequence(out)

fn yaml_sequence_contains(seq: any, value: any) -> bool:
    val items = yaml_get_sequence_items(seq)
    var i = 0
    while i < items.length():
        if yaml_equals(items[i], value):
            return true
        i = i + 1
    false

fn yaml_sequence_index_of(seq: any, value: any) -> i64:
    val items = yaml_get_sequence_items(seq)
    var i = 0
    while i < items.length():
        if yaml_equals(items[i], value):
            return i
        i = i + 1
    -1

fn yaml_sequence_reverse(seq: any) -> any:
    val items = yaml_get_sequence_items(seq)
    var out = []
    var i = items.length() - 1
    while i >= 0:
        out.push(items[i])
        i = i - 1
    yaml_sequence(out)

fn yaml_sequence_slice(seq: any, start: i64, stop: i64) -> any:
    val items = yaml_get_sequence_items(seq)
    var out = []
    var i = start
    while i < stop and i < items.length():
        if i >= 0:
            out.push(items[i])
        i = i + 1
    yaml_sequence(out)

# ---- structural utilities ----

fn yaml_equals(a: any, b: any) -> bool:
    val ta = yaml_get_scalar_type(a)
    val tb = yaml_get_scalar_type(b)
    if ta != tb:
        return false
    if ta == "null":
        return true
    if ta == "sequence":
        val ia = yaml_get_sequence_items(a)
        val ib = yaml_get_sequence_items(b)
        if ia.length() != ib.length():
            return false
        var i = 0
        while i < ia.length():
            if not yaml_equals(ia[i], ib[i]):
                return false
            i = i + 1
        return true
    if ta == "mapping":
        val pa = yaml_get_mapping_pairs(a)
        val pb = yaml_get_mapping_pairs(b)
        if pa.length() != pb.length():
            return false
        var i = 0
        while i < pa.length():
            val key = pa[i].0
            if not yaml_mapping_has(b, key):
                return false
            if not yaml_equals(pa[i].1, yaml_mapping_get(b, key)):
                return false
            i = i + 1
        return true
    yaml_get_scalar_content(a) == yaml_get_scalar_content(b)

fn yaml_deep_copy(v: any) -> any:
    val t = yaml_get_scalar_type(v)
    if t == "sequence":
        var out = []
        for item in yaml_get_sequence_items(v):
            out.push(yaml_deep_copy(item))
        return yaml_sequence(out)
    if t == "mapping":
        var out = []
        for pair in yaml_get_mapping_pairs(v):
            out.push((pair.0, yaml_deep_copy(pair.1)))
        return yaml_mapping(out)
    v

fn yaml_is_empty(v: any) -> bool:
    val t = yaml_get_scalar_type(v)
    if t == "mapping":
        return yaml_get_mapping_pairs(v).length() == 0
    if t == "sequence":
        return yaml_get_sequence_items(v).length() == 0
    false

fn yaml_count_nodes(v: any) -> i64:
    val t = yaml_get_scalar_type(v)
    if t == "sequence":
        var c = 1
        for item in yaml_get_sequence_items(v):
            c = c + yaml_count_nodes(item)
        return c
    if t == "mapping":
        var c = 1
        for pair in yaml_get_mapping_pairs(v):
            c = c + yaml_count_nodes(pair.1)
        return c
    1

fn yaml_depth(v: any) -> i64:
    val t = yaml_get_scalar_type(v)
    if t == "sequence":
        var m = 0
        for item in yaml_get_sequence_items(v):
            val d = yaml_depth(item)
            if d > m:
                m = d
        return 1 + m
    if t == "mapping":
        var m = 0
        for pair in yaml_get_mapping_pairs(v):
            val d = yaml_depth(pair.1)
            if d > m:
                m = d
        return 1 + m
    1

fn yaml_get_nested(v: any, path: [any]) -> any:
    var cur = v
    var i = 0
    while i < path.length():
        if not is_yaml_mapping(cur):
            return nil
        cur = yaml_mapping_get(cur, path[i])
        if cur == nil:
            return nil
        i = i + 1
    cur

fn _yaml_tail(xs: [any]) -> [any]:
    var out = []
    var i = 1
    while i < xs.length():
        out.push(xs[i])
        i = i + 1
    out

fn yaml_set_nested(v: any, path: [any], value: any) -> any:
    if path.length() == 0:
        return value
    val key = path[0]
    if path.length() == 1:
        return yaml_mapping_set(v, key, value)
    var child = yaml_mapping_get(v, key)
    if child == nil or not is_yaml_mapping(child):
        child = yaml_mapping([])
    val newchild = yaml_set_nested(child, _yaml_tail(path), value)
    yaml_mapping_set(v, key, newchild)

fn _yaml_flatten_pairs(m: any, prefix: text) -> [any]:
    var out = []
    for pair in yaml_get_mapping_pairs(m):
        val key = pair.0
        val full = if prefix == "": "{key}" else "{prefix}.{key}"
        if is_yaml_mapping(pair.1):
            for sub in _yaml_flatten_pairs(pair.1, full):
                out.push(sub)
        else:
            out.push((full, pair.1))
    out

fn yaml_flatten_mapping(v: any) -> any:
    if not is_yaml_mapping(v):
        return v
    yaml_mapping(_yaml_flatten_pairs(v, ""))

fn yaml_validate_schema(value: any, schema: any) -> any:
    if schema == nil:
        return (true, "")
    # Plain type-name string schema -> bool (e.g. "string", "number").
    # Match the name set directly; a real yaml_mapping is a tuple and compares
    # unequal here, so it safely falls through to the mapping logic below
    # (calling is_yaml_mapping on a plain text would tuple-index it and crash).
    if schema == "string" or schema == "number" or schema == "boolean" or schema == "null" or schema == "scalar" or schema == "sequence" or schema == "mapping":
        if yaml_get_scalar_type(value) == schema:
            return true
        return false
    val type_spec = yaml_mapping_get(schema, "type")
    if type_spec == nil:
        return (true, "")
    val expected = yaml_get_scalar_content(type_spec)
    if expected == "scalar":
        if is_yaml_scalar(value):
            return (true, "")
        return (false, "expected scalar")
    if yaml_get_scalar_type(value) == expected:
        return (true, "")
    (false, "type mismatch")

# ---- printing / conversion ----

fn yaml_pretty_print(v: any) -> text:
    yaml_serialize_block(v)

fn yaml_compact_print(v: any) -> text:
    yaml_serialize_flow(v)

fn yaml_to_string(v: any) -> text:
    yaml_serialize_block(v)

fn yaml_from_string(s: text) -> any:
    yaml_parse(s)

fn _yaml_u_lines(s: text) -> [text]:
    var out = []
    var cur = ""
    var i = 0
    while i < s.length():
        val ch = s.substring(i, i + 1)
        if ch == "\n":
            out.push(cur)
            cur = ""
        else:
            cur = cur + ch
        i = i + 1
    out.push(cur)
    out
