/// Perf-sugar helpers that wrap the typed bulk-allocation externs.
/// PERF-SUGAR-001 (scilib_port_perf_sugar.md):
/// Provides zero-copy allocation for NDArray factory methods in interpreter mode.
/// Import this instead of push-loop construction for large typed buffers.

extern fn rt_f64_array_alloc(len: i64) -> [f64]
extern fn rt_f32_array_alloc(len: i64) -> [f32]
extern fn rt_i64_array_alloc(len: i64) -> [i64]
extern fn rt_i32_array_alloc(len: i64) -> [i32]

/// Allocate a zero-filled f64 buffer of `len` elements.
/// Returns an empty array if `len` <= 0.
pub fn alloc_f64(len: i64) -> [f64]:
    return rt_f64_array_alloc(len)

/// Allocate a zero-filled f32 buffer of `len` elements.
pub fn alloc_f32(len: i64) -> [f32]:
    return rt_f32_array_alloc(len)

/// Allocate a zero-filled i64 buffer of `len` elements.
pub fn alloc_i64(len: i64) -> [i64]:
    return rt_i64_array_alloc(len)

/// Allocate a zero-filled i32 buffer of `len` elements.
pub fn alloc_i32(len: i64) -> [i32]:
    return rt_i32_array_alloc(len)
