#![allow(unnamed_duplicate_typed_args)]
# Doctest Matcher
#
# Matching functions for doctest output verification.
# Provides exact, wildcard, and exception matching for doctest output.

use std.doctest.parser.Expected

enum MatchResult:
    Pass
    Fail(msg: text)

    fn is_pass() -> bool:
        match self:
            Pass: true
            _: false

    fn is_fail() -> bool:
        not self.is_pass()

    fn get_failure_message() -> text?:
        match self:
            Fail(msg): msg
            _: nil

    fn unwrap_failure() -> text:
        match self:
            Fail(msg): msg
            _: ""

    fn to_string() -> text:
        match self:
            Pass: "Pass"
            Fail(_): "Fail"

    fn description() -> text:
        match self:
            Pass: "Test output matched expected"
            Fail(msg): msg

    fn summary() -> text:
        match self:
            Pass: "MatchResult: Pass"
            Fail(msg): "MatchResult: Fail({msg})"

fn match_output(actual: text, expected: Expected) -> MatchResult:
    """Match actual output against expected output.

    Normalizes whitespace before comparison. Uses exact_match
    (trailing whitespace stripped per line).
    """
    match expected:
        Empty:
            if actual.trim().len() == 0:
                MatchResult.Pass
            else:
                MatchResult.Fail("Expected no output, got:\n{normalize(actual)}")
        Output(value):
            if exact_match(actual, value) or wildcard_match(normalize(actual), normalize(value)):
                MatchResult.Pass
            else:
                MatchResult.Fail(format_mismatch(actual, value))
        Exception(exc_type, _):
            MatchResult.Fail("Expected exception {exc_type}, got output")

fn match_exception(exc_type: text, exc_msg: text, expected: Expected) -> MatchResult:
    """Match actual exception against expected exception.

    Expected can be a type name string or a "Type: message" format.
    """
    match expected:
        Exception(expected_type, expected_msg):
            if exc_type != expected_type:
                return MatchResult.Fail("Expected {expected_type}, got {exc_type}")
            if expected_msg != nil and not exc_msg.contains(expected_msg):
                return MatchResult.Fail("Exception message mismatch: expected {expected_msg}, got {exc_msg}")
            MatchResult.Pass
        Output(_):
            MatchResult.Fail("Expected output, got exception {exc_type}: {exc_msg}")
        Empty:
            MatchResult.Fail("Expected no output, got exception {exc_type}: {exc_msg}")

fn wildcard_match(input: text, pattern: text) -> bool:
    """Match input against a wildcard pattern.

    Supports `.`, `*`, and `...` wildcards.
    """
    wildcard_match_at(input, pattern, 0, 0)

fn wildcard_match_at(input: text, pattern: text, input_pos: i64, pattern_pos: i64) -> bool:
    if pattern_pos >= pattern.len():
        return input_pos >= input.len()

    if pattern_pos + 3 <= pattern.len() and pattern.slice(pattern_pos, pattern_pos + 3) == "...":
        if wildcard_match_at(input, pattern, input_pos, pattern_pos + 3):
            return true
        if input_pos < input.len():
            return wildcard_match_at(input, pattern, input_pos + 1, pattern_pos)
        return false

    val pat = pattern.slice(pattern_pos, pattern_pos + 1)
    if pat == "*":
        if wildcard_match_at(input, pattern, input_pos, pattern_pos + 1):
            return true
        if input_pos < input.len():
            return wildcard_match_at(input, pattern, input_pos + 1, pattern_pos)
        return false

    if input_pos >= input.len():
        return false

    if pat == "." or input.slice(input_pos, input_pos + 1) == pat:
        return wildcard_match_at(input, pattern, input_pos + 1, pattern_pos + 1)

    false

fn exact_match(a: text, b: text) -> bool:
    """Exact match with whitespace normalization."""
    a.trim() == b.trim()

fn normalize(s: text) -> text:
    """Normalize whitespace: strip trailing from each line."""
    var lines = s.split("\n")
    var result = []
    var i = 0
    while i < lines.len():
        result = result.push(lines[i].trim())
        i = i + 1
    result.join("\n").trim()

fn format_mismatch(actual: text, expected: text) -> text:
    val norm_actual = normalize(actual)
    val norm_expected = normalize(expected)
    "Output mismatch\nExpected:\n{norm_expected}\nGot:\n{norm_actual}"
