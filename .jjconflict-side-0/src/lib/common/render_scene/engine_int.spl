# Render Scene Integer Effect Engine — pure i32/i64 implementation.
#
# All operations use integer arithmetic only — NO float types.
# Safe for baremetal targets without an FPU.  Uses 8.8 fixed-point
# where 256 = 1.0 for filter amounts.

use common.render_scene.engine_trait.{EffectEngine}
use common.render_scene.scene.{argb, argb_alpha, argb_red, argb_green, argb_blue}

# ============================================================================
# Integer clamp helper
# ============================================================================

fn clamp_i32(v: i32, lo: i32, hi: i32) -> i32:
    """Clamp v to [lo, hi] range."""
    if v < lo: return lo
    if v > hi: return hi
    v

# ============================================================================
# CORDIC-style sine table (256 entries per quadrant, scaled by 256)
# Integer sin approximation: sin(angle_deg) * 256
# ============================================================================

fn int_sin_256(angle_deg: i32) -> i32:
    """Integer sine approximation. Returns sin(angle) * 256.
    Uses a piecewise linear approximation over quadrants.
    """
    # Normalize angle to 0..359
    var a = angle_deg % 360
    if a < 0:
        a = a + 360

    # Determine quadrant and effective angle within quadrant
    var quadrant = a / 90
    var off = a % 90

    # sin(off_degrees) * 256, linear approximation in quadrant [0..90]
    # sin(0)=0, sin(30)=128, sin(45)=181, sin(60)=222, sin(90)=256
    # Use a simple quadratic-ish piecewise: sin(x) ~ x * (180 - x) * 256 / 8100
    # That gives sin(0)=0, sin(45)=174, sin(90)=256 — close enough for color work
    val sin_val = (off * (180 - off) * 256) / 8100

    if quadrant == 0:
        return sin_val
    if quadrant == 1:
        # sin(90+x) = sin(90-x) = cos(x)
        val mirror = 90 - off
        return (mirror * (180 - mirror) * 256) / 8100
    if quadrant == 2:
        return 0 - sin_val
    # quadrant == 3
    val mirror = 90 - off
    return 0 - ((mirror * (180 - mirror) * 256) / 8100)

fn int_cos_256(angle_deg: i32) -> i32:
    """Integer cosine approximation. Returns cos(angle) * 256."""
    int_sin_256(angle_deg + 90)

# ============================================================================
# IntEffectEngine
# ============================================================================

struct IntEffectEngine:
    """Pure integer effect engine — no floating-point at all.

    Suitable for baremetal targets without an FPU.
    """
    _placeholder: i32

fn int_effect_engine() -> IntEffectEngine:
    """Create a new IntEffectEngine."""
    IntEffectEngine(_placeholder: 0)

impl EffectEngine for IntEffectEngine:
    fn name() -> text:
        "int"

    fn blend_pixel(src: u32, dst: u32) -> u32:
        """Alpha-blend src over dst using integer arithmetic with rounding."""
        val sa = argb_alpha(src)
        if sa == 0:
            return dst
        if sa == 255:
            return src

        val sr = argb_red(src)
        val sg = argb_green(src)
        val sb = argb_blue(src)
        val da = argb_alpha(dst)
        val dr = argb_red(dst)
        val dg = argb_green(dst)
        val db = argb_blue(dst)
        val inv_sa = 255 - sa
        # Rounding: add 127 before dividing by 255
        val out_r = (sr * sa + dr * inv_sa + 127) / 255
        val out_g = (sg * sa + dg * inv_sa + 127) / 255
        val out_b = (sb * sa + db * inv_sa + 127) / 255
        val out_a = sa + (da * inv_sa + 127) / 255
        argb(out_a, out_r, out_g, out_b)

    fn lerp_channel(a: u32, b: u32, t_num: i32, t_den: i32) -> u32:
        """Linearly interpolate a single 8-bit channel using i64 to avoid overflow."""
        val av = (a & 0xFF).to_i64()
        val bv = (b & 0xFF).to_i64()
        if t_den == 0:
            return (av & 0xFF).to_u32()
        val result = av + ((bv - av) * t_num.to_i64()) / t_den.to_i64()
        (result & 0xFF).to_u32()

    fn gradient_color(c1: u32, c2: u32, position: i32, total: i32) -> u32:
        """Compute gradient color at position/total using per-channel lerp."""
        if total <= 1:
            return c1
        val den = total - 1
        val ga = self.lerp_channel(argb_alpha(c1), argb_alpha(c2), position, den)
        val gr = self.lerp_channel(argb_red(c1), argb_red(c2), position, den)
        val gg = self.lerp_channel(argb_green(c1), argb_green(c2), position, den)
        val gb = self.lerp_channel(argb_blue(c1), argb_blue(c2), position, den)
        argb(ga, gr, gg, gb)

    fn shadow_ring_alpha(base_alpha: i32, ring: i32, ring_count: i32) -> i32:
        """Compute shadow ring alpha with quadratic falloff.
        Result = base_alpha * (ring_count - ring) / (ring_count * ring_count).
        """
        if ring_count <= 0:
            return 0
        val num = base_alpha * (ring_count - ring)
        val den = ring_count * ring_count
        if den == 0:
            return 0
        val result = num / den
        clamp_i32(result, 0, 255)

    fn filter_brightness(r: i32, g: i32, b: i32, amount: i32) -> [i32]:
        """Adjust brightness. amount is 8.8 fixed-point (256 = 1.0 = no change)."""
        val out_r = clamp_i32((r * amount) / 256, 0, 255)
        val out_g = clamp_i32((g * amount) / 256, 0, 255)
        val out_b = clamp_i32((b * amount) / 256, 0, 255)
        [out_r, out_g, out_b]

    fn filter_contrast(channel: i32, amount: i32) -> i32:
        """Adjust contrast. amount is 8.8 fixed-point (256 = 1.0 = no change)."""
        clamp_i32(((channel - 128) * amount) / 256 + 128, 0, 255)

    fn filter_grayscale(r: i32, g: i32, b: i32, amount: i32) -> [i32]:
        """Convert to grayscale using BT.709 integer coefficients.
        amount is 8.8 fixed-point: 256 = full grayscale, 0 = no change.
        """
        # BT.709 luminance: (r * 54 + g * 183 + b * 18) / 255
        val lum = (r * 54 + g * 183 + b * 18) / 255
        # Blend between original and grayscale by amount/256
        val out_r = clamp_i32(r + ((lum - r) * amount) / 256, 0, 255)
        val out_g = clamp_i32(g + ((lum - g) * amount) / 256, 0, 255)
        val out_b = clamp_i32(b + ((lum - b) * amount) / 256, 0, 255)
        [out_r, out_g, out_b]

    fn filter_hue_rotate(r: i32, g: i32, b: i32, angle_deg: i32) -> [i32]:
        """Rotate hue by angle_deg degrees using integer sin/cos approximation.
        Uses the standard hue rotation matrix in the RGB color space.
        """
        # Hue rotation matrix (all values scaled by 256):
        # The matrix is:
        #   [ 0.213 + 0.787*cos - 0.213*sin,  0.715 - 0.715*cos - 0.715*sin,  0.072 - 0.072*cos + 0.928*sin ]
        #   [ 0.213 - 0.213*cos + 0.143*sin,  0.715 + 0.285*cos + 0.140*sin,  0.072 - 0.072*cos - 0.283*sin ]
        #   [ 0.213 - 0.213*cos - 0.787*sin,  0.715 - 0.715*cos + 0.715*sin,  0.072 + 0.928*cos + 0.072*sin ]
        # All coefficients scaled by 256 and using integer sin/cos * 256
        val cos_v = int_cos_256(angle_deg)  # cos * 256
        val sin_v = int_sin_256(angle_deg)  # sin * 256

        # Pre-compute matrix elements * 256 * 256 (we'll divide by 256*256 = 65536)
        # Row 0
        val m00 = 55 * 256 + 201 * cos_v - 55 * sin_v   # 0.213*256=55, 0.787*256=201
        val m01 = 183 * 256 - 183 * cos_v - 183 * sin_v  # 0.715*256=183
        val m02 = 18 * 256 - 18 * cos_v + 237 * sin_v    # 0.072*256=18, 0.928*256=237
        # Row 1
        val m10 = 55 * 256 - 55 * cos_v + 37 * sin_v     # 0.143*256=37
        val m11 = 183 * 256 + 73 * cos_v + 36 * sin_v    # 0.285*256=73, 0.140*256=36
        val m12 = 18 * 256 - 18 * cos_v - 72 * sin_v     # 0.283*256=72
        # Row 2
        val m20 = 55 * 256 - 55 * cos_v - 201 * sin_v
        val m21 = 183 * 256 - 183 * cos_v + 183 * sin_v
        val m22 = 18 * 256 + 237 * cos_v + 18 * sin_v

        val out_r = clamp_i32((r * m00 + g * m01 + b * m02) / 65536, 0, 255)
        val out_g = clamp_i32((r * m10 + g * m11 + b * m12) / 65536, 0, 255)
        val out_b = clamp_i32((r * m20 + g * m21 + b * m22) / 65536, 0, 255)
        [out_r, out_g, out_b]

    fn filter_sepia(r: i32, g: i32, b: i32, amount: i32) -> [i32]:
        """Apply sepia tone using integer matrix coefficients scaled by 256.
        amount is 8.8 fixed-point: 256 = full sepia, 0 = no change.
        """
        # Sepia matrix (coefficients * 256):
        # [0.393, 0.769, 0.189]   -> [101, 197, 48]
        # [0.349, 0.686, 0.168]   -> [89, 176, 43]
        # [0.272, 0.534, 0.131]   -> [70, 137, 34]
        val sep_r = clamp_i32((r * 101 + g * 197 + b * 48) / 256, 0, 255)
        val sep_g = clamp_i32((r * 89 + g * 176 + b * 43) / 256, 0, 255)
        val sep_b = clamp_i32((r * 70 + g * 137 + b * 34) / 256, 0, 255)
        # Blend between original and sepia by amount/256
        val out_r = clamp_i32(r + ((sep_r - r) * amount) / 256, 0, 255)
        val out_g = clamp_i32(g + ((sep_g - g) * amount) / 256, 0, 255)
        val out_b = clamp_i32(b + ((sep_b - b) * amount) / 256, 0, 255)
        [out_r, out_g, out_b]
