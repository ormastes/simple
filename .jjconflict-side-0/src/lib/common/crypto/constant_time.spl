# Constant-time comparison utilities to prevent timing side-channel attacks.

use std.common.crypto.types.{text_to_bytes}

# Compare two text values in constant time (timing-safe equality check).
# Returns true iff the values are equal. Comparing strings of different
# lengths always returns false (the length difference itself is not secret).
fn constant_time_compare(a: text, b: text) -> bool:
    val ab = text_to_bytes(a)
    val bb = text_to_bytes(b)
    val la = ab.len()
    val lb = bb.len()
    if la != lb:
        return false
    var diff = 0
    var i = 0
    while i < la:
        diff = diff | (ab[i] ^ bb[i])
        i = i + 1
    diff == 0

# Compare two byte lists in constant time.
# Returns true iff both lists are equal (same length and same bytes).
fn constant_time_compare_bytes(a: [i64], b: [i64]) -> bool:
    val la = a.len()
    val lb = b.len()
    if la != lb:
        return false
    var diff = 0
    var i = 0
    while i < la:
        diff = diff | (a[i] ^ b[i])
        i = i + 1
    diff == 0
