# Typed crypto custom-type barrier.
# Each type wraps a ByteSpan payload and carries behaviour:
# constructor, bytes(), len(), hex(), and constant-time eq where security-relevant.
#
# NOTE: Digest<N> const-generic attempted; Simple generics surface "Unknown type: Id"
# for type parameters on struct definitions (same root as PostingList<Id>/Embedding<D>).
# Fell back to runtime-length Digest. Filed: doc/08_tracking/bug/crypto_digest_generic_struct_2026-06-15.md

use std.common.bytes.span.{ByteSpan}

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

fn _hex_digit(v: i64) -> text:
    if v == 0: "0"
    elif v == 1: "1"
    elif v == 2: "2"
    elif v == 3: "3"
    elif v == 4: "4"
    elif v == 5: "5"
    elif v == 6: "6"
    elif v == 7: "7"
    elif v == 8: "8"
    elif v == 9: "9"
    elif v == 10: "a"
    elif v == 11: "b"
    elif v == 12: "c"
    elif v == 13: "d"
    elif v == 14: "e"
    else: "f"

fn _span_to_hex(span: ByteSpan) -> text:
    var result = ""
    var i = 0
    while i < span.len():
        var b = span.get(i).to_i64()
        result = result + _hex_digit((b / 16) % 16) + _hex_digit(b % 16)
        i = i + 1
    result

fn _hex_char_to_nybble(ch: text) -> i64:
    if ch == "0": return 0
    if ch == "1": return 1
    if ch == "2": return 2
    if ch == "3": return 3
    if ch == "4": return 4
    if ch == "5": return 5
    if ch == "6": return 6
    if ch == "7": return 7
    if ch == "8": return 8
    if ch == "9": return 9
    if ch == "a" or ch == "A": return 10
    if ch == "b" or ch == "B": return 11
    if ch == "c" or ch == "C": return 12
    if ch == "d" or ch == "D": return 13
    if ch == "e" or ch == "E": return 14
    if ch == "f" or ch == "F": return 15
    255

fn _hex_to_bytes(h: text) -> [u8]:
    # Returns a [u8] array so callers can pass it to Type.new([u8]).
    # NOTE: ByteBuffer.push_byte + freeze() produces wrong values in the
    # interpreter, so we accumulate into a plain [u8] array instead.
    var arr: [u8] = []
    if h.len() % 2 != 0:
        return arr
    var i = 0
    while i + 1 < h.len():
        var hi = _hex_char_to_nybble(h[i:i + 1])
        var lo = _hex_char_to_nybble(h[i + 1:i + 2])
        if hi > 15 or lo > 15:
            return []
        arr.push(((hi * 16 + lo) & 255).to_u8())
        i = i + 2
    arr

# Constant-time equality over two ByteSpan values.
# XOR-accumulates all bytes with no early exit.
fn _ct_eq_spans(a: ByteSpan, b: ByteSpan) -> bool:
    if a.len() != b.len():
        return false
    var diff = 0
    var i = 0
    while i < a.len():
        diff = diff | (a.get(i).to_i64() ^ b.get(i).to_i64())
        i = i + 1
    diff == 0

# ---------------------------------------------------------------------------
# Digest — hash output (runtime-length; Digest<N> fell back — see file header)
# ---------------------------------------------------------------------------

struct Digest:
    """Hash output value. Constant-time eq; no early exit."""
    payload: ByteSpan

impl Digest:
    static fn new(data: [u8]) -> Digest:
        Digest(payload: ByteSpan.new(data))

    static fn from_span(span: ByteSpan) -> Digest:
        # NOTE: Digest(payload: span) fails with "unknown argument 'payload'" in
        # interpreter cross-module context when span is a parameter (not a fresh
        # constructor call). Route through new() to avoid the issue.
        Digest.new(span.to_bytes())

    static fn from_hex(h: text) -> Digest:
        Digest.new(_hex_to_bytes(h))

    fn bytes() -> ByteSpan:
        self.payload

    fn len() -> i64:
        self.payload.len()

    fn hex() -> text:
        _span_to_hex(self.payload)

    fn ct_eq(other: Digest) -> bool:
        _ct_eq_spans(self.payload, other.payload)

# ---------------------------------------------------------------------------
# MacTag — MAC output; constant-time eq only
# ---------------------------------------------------------------------------

struct MacTag:
    """Message authentication code tag. Constant-time eq."""
    payload: ByteSpan

impl MacTag:
    static fn new(data: [u8]) -> MacTag:
        MacTag(payload: ByteSpan.new(data))

    static fn from_span(span: ByteSpan) -> MacTag:
        MacTag.new(span.to_bytes())

    static fn from_hex(h: text) -> MacTag:
        MacTag.new(_hex_to_bytes(h))

    fn bytes() -> ByteSpan:
        self.payload

    fn len() -> i64:
        self.payload.len()

    fn hex() -> text:
        _span_to_hex(self.payload)

    fn ct_eq(other: MacTag) -> bool:
        _ct_eq_spans(self.payload, other.payload)

# ---------------------------------------------------------------------------
# AEAD types
# ---------------------------------------------------------------------------

struct Nonce:
    """AEAD nonce. Not secret — no ct_eq required."""
    payload: ByteSpan

impl Nonce:
    static fn new(data: [u8]) -> Nonce:
        Nonce(payload: ByteSpan.new(data))

    static fn from_span(span: ByteSpan) -> Nonce:
        Nonce.new(span.to_bytes())

    static fn from_hex(h: text) -> Nonce:
        Nonce.new(_hex_to_bytes(h))

    fn bytes() -> ByteSpan:
        self.payload

    fn len() -> i64:
        self.payload.len()

    fn hex() -> text:
        _span_to_hex(self.payload)

struct AuthTag:
    """AEAD authentication tag. Constant-time eq for verification."""
    payload: ByteSpan

impl AuthTag:
    static fn new(data: [u8]) -> AuthTag:
        AuthTag(payload: ByteSpan.new(data))

    static fn from_span(span: ByteSpan) -> AuthTag:
        AuthTag.new(span.to_bytes())

    static fn from_hex(h: text) -> AuthTag:
        AuthTag.new(_hex_to_bytes(h))

    fn bytes() -> ByteSpan:
        self.payload

    fn len() -> i64:
        self.payload.len()

    fn hex() -> text:
        _span_to_hex(self.payload)

    fn ct_eq(other: AuthTag) -> bool:
        _ct_eq_spans(self.payload, other.payload)

struct Plaintext:
    """Cleartext payload for AEAD encryption."""
    payload: ByteSpan

impl Plaintext:
    static fn new(data: [u8]) -> Plaintext:
        Plaintext(payload: ByteSpan.new(data))

    static fn from_span(span: ByteSpan) -> Plaintext:
        Plaintext.new(span.to_bytes())

    static fn from_hex(h: text) -> Plaintext:
        Plaintext.new(_hex_to_bytes(h))

    fn bytes() -> ByteSpan:
        self.payload

    fn len() -> i64:
        self.payload.len()

    fn hex() -> text:
        _span_to_hex(self.payload)

struct Ciphertext:
    """Encrypted payload from AEAD encryption."""
    payload: ByteSpan

impl Ciphertext:
    static fn new(data: [u8]) -> Ciphertext:
        Ciphertext(payload: ByteSpan.new(data))

    static fn from_span(span: ByteSpan) -> Ciphertext:
        Ciphertext.new(span.to_bytes())

    static fn from_hex(h: text) -> Ciphertext:
        Ciphertext.new(_hex_to_bytes(h))

    fn bytes() -> ByteSpan:
        self.payload

    fn len() -> i64:
        self.payload.len()

    fn hex() -> text:
        _span_to_hex(self.payload)

# ---------------------------------------------------------------------------
# Asymmetric key types
# ---------------------------------------------------------------------------

struct SecretKey:
    """Asymmetric secret key. Constant-time eq to prevent leakage on comparison."""
    payload: ByteSpan

impl SecretKey:
    static fn new(data: [u8]) -> SecretKey:
        SecretKey(payload: ByteSpan.new(data))

    static fn from_span(span: ByteSpan) -> SecretKey:
        SecretKey.new(span.to_bytes())

    static fn from_hex(h: text) -> SecretKey:
        SecretKey.new(_hex_to_bytes(h))

    fn bytes() -> ByteSpan:
        self.payload

    fn len() -> i64:
        self.payload.len()

    fn hex() -> text:
        _span_to_hex(self.payload)

    fn ct_eq(other: SecretKey) -> bool:
        _ct_eq_spans(self.payload, other.payload)

struct PublicKey:
    """Asymmetric public key. Not secret — no ct_eq required."""
    payload: ByteSpan

impl PublicKey:
    static fn new(data: [u8]) -> PublicKey:
        PublicKey(payload: ByteSpan.new(data))

    static fn from_span(span: ByteSpan) -> PublicKey:
        PublicKey.new(span.to_bytes())

    static fn from_hex(h: text) -> PublicKey:
        PublicKey.new(_hex_to_bytes(h))

    fn bytes() -> ByteSpan:
        self.payload

    fn len() -> i64:
        self.payload.len()

    fn hex() -> text:
        _span_to_hex(self.payload)

struct Signature:
    """Cryptographic signature bytes."""
    payload: ByteSpan

impl Signature:
    static fn new(data: [u8]) -> Signature:
        Signature(payload: ByteSpan.new(data))

    static fn from_span(span: ByteSpan) -> Signature:
        Signature.new(span.to_bytes())

    static fn from_hex(h: text) -> Signature:
        Signature.new(_hex_to_bytes(h))

    fn bytes() -> ByteSpan:
        self.payload

    fn len() -> i64:
        self.payload.len()

    fn hex() -> text:
        _span_to_hex(self.payload)

struct SharedSecret:
    """ECDH or KEM shared secret. Constant-time eq."""
    payload: ByteSpan

impl SharedSecret:
    static fn new(data: [u8]) -> SharedSecret:
        SharedSecret(payload: ByteSpan.new(data))

    static fn from_span(span: ByteSpan) -> SharedSecret:
        SharedSecret.new(span.to_bytes())

    static fn from_hex(h: text) -> SharedSecret:
        SharedSecret.new(_hex_to_bytes(h))

    fn bytes() -> ByteSpan:
        self.payload

    fn len() -> i64:
        self.payload.len()

    fn hex() -> text:
        _span_to_hex(self.payload)

    fn ct_eq(other: SharedSecret) -> bool:
        _ct_eq_spans(self.payload, other.payload)
