#![allow(unnamed_duplicate_typed_args)]
# JavaScript RegExp — Minimal regex engine for basic pattern matching
# Supports: . \d \w \s [abc] [a-z] [^abc] * + ? {n} {n,m} ^ $ | (...) (?:...)
# Flags: g (global), i (case-insensitive), m (multiline)

use std.js.types.js_types.{JsValue}

fn _substr(s: text, start: i64, end_idx: i64) -> text:
    """Subscript-based substring that works in interpreter mode."""
    var result = ""
    var i = start
    while i < end_idx and i < s.len():
        result = result + s[i]
        i = i + 1
    result

# ── RegExp types ───────────────────────────────────────────────────────

class RegExpObj:
    source: text
    flags: text
    global: bool
    ignore_case: bool
    multiline: bool
    last_index: i64

    static fn create(source: text, flags: text) -> RegExpObj:
        var g = false
        var ic = false
        var ml = false
        for ch in flags:
            if ch == "g": g = true
            if ch == "i": ic = true
            if ch == "m": ml = true
        RegExpObj(source: source, flags: flags, global: g, ignore_case: ic, multiline: ml, last_index: 0)

class MatchResult:
    matched: bool
    value: text
    index: i64
    groups: [text]

    static fn no_match() -> MatchResult:
        MatchResult(matched: false, value: "", index: -1, groups: [])

    static fn found(value: text, index: i64) -> MatchResult:
        MatchResult(matched: true, value: value, index: index, groups: [])

# ── Public API ─────────────────────────────────────────────────────────

fn regexp_test(re: RegExpObj, input: text) -> bool:
    """RegExp.prototype.test — returns true if pattern matches."""
    val result = regexp_exec(re, input)
    result.matched

fn regexp_exec(re: RegExpObj, input: text) -> MatchResult:
    """RegExp.prototype.exec — returns first match."""
    val pattern = re.source
    var start = 0
    if re.global:
        start = re.last_index

    var i = start
    val input_len = input.len()
    while i <= input_len:
        val result = _try_match(pattern, 0, input, i, re.ignore_case)
        if result.matched:
            return MatchResult.found(value: _substr(input, i, i + result.value.len()), index: i)
        i = i + 1
    MatchResult.no_match()

fn string_match(input: text, pattern: text, flags: text) -> [text]:
    """String.prototype.match — returns all matches or first match groups."""
    val re = RegExpObj.create(pattern, flags)
    if re.global:
        var results: [text] = []
        var i = 0
        val input_len = input.len()
        while i <= input_len:
            val result = _try_match(pattern, 0, input, i, re.ignore_case)
            if result.matched:
                results.push(_substr(input, i, i + result.value.len()))
                i = i + result.value.len()
                if result.value.len() == 0:
                    i = i + 1
            else:
                i = i + 1
        return results
    # Non-global: return first match
    val result = regexp_exec(re, input)
    if result.matched:
        return [result.value]
    var empty_result: [text] = []
    empty_result

fn string_replace(input: text, pattern: text, replacement: text, flags: text) -> text:
    """String.prototype.replace with regex pattern."""
    val re = RegExpObj.create(pattern, flags)
    var result = ""
    var i = 0
    val input_len = input.len()
    var replaced_once = false
    while i < input_len:
        val m = _try_match(pattern, 0, input, i, re.ignore_case)
        if m.matched and (re.global or not replaced_once):
            result = result + replacement
            val match_len = m.value.len()
            i = i + (if match_len > 0: match_len else: 1)
            replaced_once = true
        else:
            result = result + _substr(input, i, i + 1)
            i = i + 1
    result

fn string_split_regex(input: text, pattern: text) -> [text]:
    """String.prototype.split with regex pattern."""
    var results: [text] = []
    var last = 0
    var i = 0
    val input_len = input.len()
    while i < input_len:
        val m = _try_match(pattern, 0, input, i, false)
        if m.matched and m.value.len() > 0:
            results.push(_substr(input, last, i))
            i = i + m.value.len()
            last = i
        else:
            i = i + 1
    results.push(_substr(input, last, input_len))
    results

# ── Pattern matching engine (recursive backtracking) ───────────────────

fn _try_match(pattern: text, pi: i64, input: text, si: i64, ignore_case: bool) -> MatchResult:
    """Try to match pattern starting at pi against input starting at si."""
    val plen = pattern.len()
    var p = pi
    var s = si
    val slen = input.len()

    while p < plen:
        val pch = _substr(pattern, p, p + 1)

        # Alternation
        if pch == "|":
            # Left side already tried; try right side from original si
            return _try_match(pattern, p + 1, input, si, ignore_case)

        # Anchors
        if pch == "^":
            if s != 0:
                return MatchResult.no_match()
            p = p + 1
            continue
        if pch == "$":
            if s != slen:
                return MatchResult.no_match()
            p = p + 1
            continue

        # Check for quantifier after current atom
        var atom_end = p + 1
        if pch == "\\":
            atom_end = p + 2
        elif pch == "[":
            atom_end = _find_bracket_end(pattern, p)
        elif pch == "(":
            atom_end = _find_group_end(pattern, p)

        var quantifier = ""
        var min_rep = 1
        var max_rep = 1
        if atom_end < plen:
            val qch = _substr(pattern, atom_end, atom_end + 1)
            if qch == "*":
                quantifier = "*"
                min_rep = 0
                max_rep = 9999
            elif qch == "+":
                quantifier = "+"
                min_rep = 1
                max_rep = 9999
            elif qch == "?":
                quantifier = "?"
                min_rep = 0
                max_rep = 1

        if quantifier != "":
            # Greedy match
            var count = 0
            var best_s = s
            while count < max_rep and s < slen:
                if _match_atom(pattern, p, atom_end, input, s, ignore_case):
                    s = s + 1
                    count = count + 1
                else:
                    break
            # Try matching rest of pattern from s backwards (greedy backtrack)
            var try_s = s
            while try_s >= best_s + min_rep:
                val rest = _try_match(pattern, atom_end + 1, input, try_s, ignore_case)
                if rest.matched:
                    return MatchResult.found(value: _substr(input, si, try_s + rest.value.len()), index: si)
                try_s = try_s - 1
            if min_rep == 0:
                val rest = _try_match(pattern, atom_end + 1, input, best_s, ignore_case)
                if rest.matched:
                    return rest
            return MatchResult.no_match()
        else:
            # Single match required
            if s >= slen:
                return MatchResult.no_match()
            if not _match_atom(pattern, p, atom_end, input, s, ignore_case):
                return MatchResult.no_match()
            s = s + 1
            p = atom_end

    MatchResult.found(value: _substr(input, si, s), index: si)

fn _match_atom(pattern: text, start: i64, end_idx: i64, input: text, si: i64, ignore_case: bool) -> bool:
    """Match a single atom (char, escape, class) at position si."""
    val pch = _substr(pattern, start, start + 1)

    # Dot: match any except newline
    if pch == ".":
        val ich = _substr(input, si, si + 1)
        return ich != "\n"

    # Escape sequences
    if pch == "\\":
        if start + 1 >= pattern.len():
            return false
        val ech = _substr(pattern, start + 1, start + 2)
        val ich = _substr(input, si, si + 1)
        match ech:
            "d": return _is_digit(ich)
            "D": return not _is_digit(ich)
            "w": return _is_word(ich)
            "W": return not _is_word(ich)
            "s": return _is_space(ich)
            "S": return not _is_space(ich)
            _: return ich == ech

    # Character class [...]
    if pch == "[":
        return _match_char_class(pattern, start, end_idx, input, si, ignore_case)

    # Literal character
    val ich = _substr(input, si, si + 1)
    if ignore_case:
        return ich.lower() == pch.lower()
    ich == pch

fn _match_char_class(pattern: text, start: i64, end_idx: i64, input: text, si: i64, ignore_case: bool) -> bool:
    """Match a character class [abc], [a-z], [^abc]."""
    val ich = _substr(input, si, si + 1)
    var negate = false
    var p = start + 1
    if p < end_idx and _substr(pattern, p, p + 1) == "^":
        negate = true
        p = p + 1
    var matched = false
    while p < end_idx - 1:
        val c = _substr(pattern, p, p + 1)
        # Range: a-z
        if p + 2 < end_idx - 1 and _substr(pattern, p + 1, p + 2) == "-":
            val c2 = _substr(pattern, p + 2, p + 3)
            var ic = ich
            var lo = c
            var hi = c2
            if ignore_case:
                ic = ich.lower()
                lo = c.lower()
                hi = c2.lower()
            if ic >= lo and ic <= hi:
                matched = true
            p = p + 3
        else:
            var ic = ich
            var cc = c
            if ignore_case:
                ic = ich.lower()
                cc = c.lower()
            if ic == cc:
                matched = true
            p = p + 1
    if negate:
        return not matched
    matched

fn _find_bracket_end(pattern: text, start: i64) -> i64:
    """Find closing ] for character class."""
    var i = start + 1
    val plen = pattern.len()
    if i < plen and _substr(pattern, i, i + 1) == "^":
        i = i + 1
    if i < plen and _substr(pattern, i, i + 1) == "]":
        i = i + 1  # literal ]
    while i < plen:
        if _substr(pattern, i, i + 1) == "]":
            return i + 1
        i = i + 1
    plen

fn _find_group_end(pattern: text, start: i64) -> i64:
    """Find closing ) for group."""
    var depth = 0
    var i = start
    val plen = pattern.len()
    while i < plen:
        val ch = _substr(pattern, i, i + 1)
        if ch == "(":
            depth = depth + 1
        elif ch == ")":
            depth = depth - 1
            if depth == 0:
                return i + 1
        i = i + 1
    plen

# ── Character class helpers ────────────────────────────────────────────

fn _is_digit(ch: text) -> bool:
    ch >= "0" and ch <= "9"

fn _is_word(ch: text) -> bool:
    (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or
    (ch >= "0" and ch <= "9") or ch == "_"

fn _is_space(ch: text) -> bool:
    ch == " " or ch == "\t" or ch == "\n" or ch == "\r"
