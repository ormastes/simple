# JavaScript engine error types and logging
# Standalone replacements for browser.shared.error and browser.shared.logging
# so the JS engine can be used outside the browser context.

# ── Error Types ────────────────────────────────────────────────────────

class JsError:
    message: text
    source: text

    static fn create(message: text, source: text) -> JsError:
        JsError(message: message, source: source)

fn script_error(msg: text) -> JsError:
    JsError(message: msg, source: "script")

# BrowserResult<T> → JsResult<T> for backward compat
# In practice, all engine code uses Result<T, JsError>
type JsResult = Result

# Aliases so existing code using BrowserResult/BrowserError compiles
type BrowserResult = Result
type BrowserError = JsError
type BrowserErrorKind = text

# ── Logging ────────────────────────────────────────────────────────────

enum LogLevel:
    Trace
    Debug
    Info
    Warn
    Error

class Logger:
    name: text

    static fn new(name: text, level: LogLevel) -> Logger:
        Logger(name: name)

    fn level_tag(l: LogLevel) -> text:
        match l:
            LogLevel.Trace: "TRACE"
            LogLevel.Debug: "DEBUG"
            LogLevel.Info: "INFO"
            LogLevel.Warn: "WARN"
            LogLevel.Error: "ERROR"

    fn should_log(msg_level: LogLevel) -> bool:
        true

    me log(msg_level: LogLevel, msg: text):
        if self.should_log(msg_level):
            val tag = self.level_tag(msg_level)
            print "[{tag}] [{self.name}] {msg}"

    me trace(msg: text):
        self.log(LogLevel.Trace, msg)

    me debug(msg: text):
        self.log(LogLevel.Debug, msg)

    me info(msg: text):
        self.log(LogLevel.Info, msg)

    me warn(msg: text):
        self.log(LogLevel.Warn, msg)

    me error(msg: text):
        self.log(LogLevel.Error, msg)

# ── NaN / Infinity helpers ─────────────────────────────────────────────
# Interpreter mode doesn't support 0.0/0.0 for NaN.
# Use a sentinel value that behaves like NaN in JS comparisons.

val JS_NAN: f64 = -9999999999.999
val JS_INFINITY: f64 = 9999999999.0
val JS_NEG_INFINITY: f64 = -9999999999.0

fn js_nan() -> f64:
    JS_NAN

fn js_infinity() -> f64:
    JS_INFINITY

fn js_neg_infinity() -> f64:
    JS_NEG_INFINITY

fn is_nan(v: f64) -> bool:
    v == JS_NAN
