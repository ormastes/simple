# JavaScript Engine — Standard Library Module Root
# Provides a complete JS engine usable by any Simple application.
#
# Usage: use std.js.types.js_types.{JsValue, JsObject, JsProperty}
#        use std.js.engine.interpreter.{JsInterpreter}
#        use std.js.engine.runtime.{JsRuntime}

# ── Type Definitions ───────────────────────────────────────────────────
use std.js.types.js_types.{JsValue, JsObject, JsProperty}
use std.js.types.ast_types.{Expression, Statement, SwitchCase}
use std.js.types.bytecode_types.{OpCode, BytecodeChunk, ConstantPool}
use std.js.types.gc_types.{Generation, GcHeader, GcObject, GcStats}

# ── Engine Components ──────────────────────────────────────────────────
use std.js.engine.js_error.{JsError, script_error, Logger, LogLevel}
use std.js.engine.lexer.{JsLexer}
use std.js.engine.parser.{JsParser}
use std.js.engine.interpreter.{JsInterpreter}
use std.js.engine.vm.{Vm}
use std.js.engine.bytecode_compiler.{BytecodeCompiler}
use std.js.engine.runtime.{JsRuntime}
use std.js.engine.jit.{JitCompiler}
use std.js.engine.gc.{GcHeap}

# ── Builtins ───────────────────────────────────────────────────────────
use std.js.builtins.object.{object_create, object_keys, object_values, object_entries}
use std.js.builtins.json.{json_parse, json_stringify}
use std.js.builtins.promise.{promise_resolve, promise_reject}
use std.js.builtins.error.{create_error, create_type_error, create_reference_error}
