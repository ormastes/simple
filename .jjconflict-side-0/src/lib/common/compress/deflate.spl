# Deflate compress/decompress facade.
#
# Delegates to the in-tree nogc_sync_mut gzip/deflate module.  The two
# functions exposed here match the signatures imported by http-layer consumers.

use std.nogc_sync_mut.compression.gzip.lz77.{lz77_compress}
use std.nogc_sync_mut.compression.gzip.deflate.{deflate_block_fixed}
use std.nogc_sync_mut.compression.gzip.inflate.{inflate}
use std.common.compress.types.{CompressionError}

pub fn deflate_compress_sync_flush(data: [u8]) -> Result<[u8], CompressionError>:
    """Compress `data` with raw deflate (sync-flush mode).

    Uses the fixed-Huffman block writer from the gzip module.
    Returns Ok(compressed_bytes) or Err(CompressionError).
    """
    val tokens = lz77_compress(data, 1)
    val compressed = deflate_block_fixed(tokens, true)
    Ok(compressed)

pub fn deflate_decompress_eof(data: [u8]) -> Result<[u8], CompressionError>:
    """Decompress a raw deflate stream.

    Returns Ok(decompressed_bytes) or Err(CompressionError).
    """
    val maybe = inflate(data)
    if maybe == nil:
        return Err(CompressionError.CorruptData("deflate inflate returned nil"))
    Ok(maybe ?? [])

# Raw-bytes convenience wrappers (Result unwrapped to [u8], [] on error).
pub fn deflate_compress(data: [u8]) -> [u8]:
    deflate_compress_sync_flush(data).unwrap_or([])

pub fn deflate_decompress(data: [u8]) -> [u8]:
    deflate_decompress_eof(data).unwrap_or([])
