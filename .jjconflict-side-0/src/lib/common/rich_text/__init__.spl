# Rich Text Module - Re-exports
#
# Shared attributed text model, serialization, HTML/Markdown export,
# and editor core for the Simple Office suite.

# Types (attributed_text.spl)
export InlineStyle, TextSpan, DocBlock, RichDocument

# Span helpers (attributed_text.spl)
export plain_span, bold_span, italic_span, link_span

# Block helpers (attributed_text.spl)
export paragraph, heading, bullet_list, code_block, horizontal_rule

# Document helpers (attributed_text.spl)
export empty_document

# Plain text extraction (attributed_text.spl)
export block_to_plain_text, spans_to_plain_text
export document_word_count, document_headings

# Serialization (serialize.spl)
export serialize_document, deserialize_document, parse_inline_styles

# HTML export (to_html.spl)
export document_to_html, block_to_html, spans_to_html, span_to_html

# Markdown export (to_markdown.spl)
export document_to_markdown, block_to_markdown, spans_to_markdown

# Editor (editor.spl)
export TextCursor, TextSelection, RichTextEditor
