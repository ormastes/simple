# UI Style and Theme System
#
# Unified theming for all UI backends.
# Defines theme types (colors, spacing, borders, fonts) and
# generates CSS for Web/Electron/VSCode or ANSI for TUI.

use common.ui.color.{UIColor}
use common.ui.theme_registry.{ThemeId, theme_registry}

# =========================================================================
# TUI ANSI Theme Values
# =========================================================================

class UIThemeColors:
    background: UIColor
    foreground: UIColor
    border: text
    accent: UIColor
    panel_bg: text
    hover_bg: text
    error: UIColor
    warning: UIColor
    success: UIColor
    info: UIColor

class Spacing:
    xs: i32
    sm: i32
    md: i32
    lg: i32
    xl: i32

    static fn default_spacing() -> Spacing:
        Spacing(xs: 4, sm: 8, md: 12, lg: 20, xl: 32)

class BorderStyle:
    width: i32
    radius: i32
    style: text

class FontStyle:
    family: text
    size: i32
    weight: text
    line_height: f64

class UITheme:
    """Runtime-visible theme identity used by TUI ANSI adapters."""
    name: text
    colors: UIThemeColors
    spacing: Spacing
    border: BorderStyle
    font: FontStyle

    static fn dark() -> UITheme:
        return UITheme(
            name: "dark",
            colors: UIThemeColors(
                background: UIColor.from_hex("#0A0A0F"),
                foreground: UIColor.from_hex("#F5F5F7"),
                border: "rgba(255,255,255,0.08)",
                accent: UIColor.from_hex("#0A84FF"),
                panel_bg: "rgba(30,30,35,0.72)",
                hover_bg: "rgba(255,255,255,0.06)",
                error: UIColor.from_hex("#FF453A"),
                warning: UIColor.from_hex("#FF9F0A"),
                success: UIColor.from_hex("#30D158"),
                info: UIColor.from_hex("#64D2FF")
            ),
            spacing: Spacing.default_spacing(),
            border: BorderStyle(width: 1, radius: 8, style: "solid"),
            font: FontStyle(family: "system-ui, sans-serif", size: 14, weight: "normal", line_height: 1.4)
        )

    static fn light() -> UITheme:
        return UITheme(
            name: "light",
            colors: UIThemeColors(
                background: UIColor.from_hex("#F2F2F7"),
                foreground: UIColor.from_hex("#000000"),
                border: "#C6C6C8",
                accent: UIColor.from_hex("#007AFF"),
                panel_bg: "#FFFFFF",
                hover_bg: "#E5E5EA",
                error: UIColor.from_hex("#FF3B30"),
                warning: UIColor.from_hex("#FF9500"),
                success: UIColor.from_hex("#34C759"),
                info: UIColor.from_hex("#5AC8FA")
            ),
            spacing: Spacing.default_spacing(),
            border: BorderStyle(width: 1, radius: 8, style: "solid"),
            font: FontStyle(family: "system-ui, sans-serif", size: 14, weight: "normal", line_height: 1.4)
        )

class AnsiTheme:
    """ANSI escape palette consumed by TUI renderers and tests."""
    border: text
    accent: text
    error: text
    warning: text
    success: text
    dim: text
    bold: text
    reset: text
    button: text
    button_focused: text
    checkbox: text
    checkbox_checked: text
    input: text
    input_focused: text
    progress_fill: text
    progress_empty: text
    tab_active: text
    tab_inactive: text
    list_selected: text
    list_item: text
    dialog_border: text
    disabled_fg: text
    error_fg: text
    readonly_fg: text

    static fn from_theme(theme: UITheme) -> AnsiTheme:
        val is_light = theme.name == "light" or theme.name == "glass_light" or theme.name == "ios_light"
        if is_light:
            return AnsiTheme(
                border: "\u{001b}[2m",
                accent: "\u{001b}[34m",
                error: "\u{001b}[31m",
                warning: "\u{001b}[33m",
                success: "\u{001b}[32m",
                dim: "\u{001b}[2m",
                bold: "\u{001b}[1m",
                reset: "\u{001b}[0m",
                button: "\u{001b}[34m",
                button_focused: "\u{001b}[1m\u{001b}[34m",
                checkbox: "\u{001b}[0m",
                checkbox_checked: "\u{001b}[32m",
                input: "\u{001b}[2m",
                input_focused: "\u{001b}[0m",
                progress_fill: "\u{001b}[32m",
                progress_empty: "\u{001b}[2m",
                tab_active: "\u{001b}[1m",
                tab_inactive: "\u{001b}[2m",
                list_selected: "\u{001b}[34m",
                list_item: "\u{001b}[0m",
                dialog_border: "\u{001b}[35m",
                disabled_fg: "\u{001b}[2m",
                error_fg: "\u{001b}[31m",
                readonly_fg: "\u{001b}[2m"
            )
        return AnsiTheme(
            border: "\u{001b}[2m",
            accent: "\u{001b}[36m",
            error: "\u{001b}[31m",
            warning: "\u{001b}[33m",
            success: "\u{001b}[32m",
            dim: "\u{001b}[2m",
            bold: "\u{001b}[1m",
            reset: "\u{001b}[0m",
            button: "\u{001b}[96m",
            button_focused: "\u{001b}[1m\u{001b}[96m",
            checkbox: "\u{001b}[37m",
            checkbox_checked: "\u{001b}[92m",
            input: "\u{001b}[2m",
            input_focused: "\u{001b}[97m",
            progress_fill: "\u{001b}[92m",
            progress_empty: "\u{001b}[2m",
            tab_active: "\u{001b}[1m",
            tab_inactive: "\u{001b}[2m",
            list_selected: "\u{001b}[96m",
            list_item: "\u{001b}[37m",
            dialog_border: "\u{001b}[95m",
            disabled_fg: "\u{001b}[90m",
            error_fg: "\u{001b}[91m",
            readonly_fg: "\u{001b}[2m"
        )

# =========================================================================
# Style Property Values
# =========================================================================

class StyleColor:
    """A color value for a style property, stored as a hex text."""
    value: text

    static fn from_hex(hex: text) -> StyleColor:
        return StyleColor(value: hex)

    static fn transparent() -> StyleColor:
        return StyleColor(value: "transparent")

    static fn inherit() -> StyleColor:
        return StyleColor(value: "inherit")

    fn to_text() -> text:
        return self.value

class StyleLength:
    """A length value with magnitude and unit (px, %, em, rem, auto)."""
    amount: i32
    unit: text

    static fn px(n: i32) -> StyleLength:
        return StyleLength(amount: n, unit: "px")

    static fn pct(n: i32) -> StyleLength:
        return StyleLength(amount: n, unit: "%")

    static fn auto() -> StyleLength:
        return StyleLength(amount: 0, unit: "auto")

    static fn zero() -> StyleLength:
        return StyleLength(amount: 0, unit: "px")

    fn to_text() -> text:
        if self.unit == "auto":
            return "auto"
        return "{self.amount}{self.unit}"

# =========================================================================
# Style Properties (color, font, padding, margin)
# =========================================================================

class ColorStyle:
    """Color-related style properties for a widget."""
    color: text
    background_color: text
    border_color: text
    opacity: f64

    static fn default() -> ColorStyle:
        return ColorStyle(
            color: "inherit",
            background_color: "transparent",
            border_color: "inherit",
            opacity: 1.0
        )

    fn with_color(c: text) -> ColorStyle:
        return ColorStyle(
            color: c,
            background_color: self.background_color,
            border_color: self.border_color,
            opacity: self.opacity
        )

    fn with_background(c: text) -> ColorStyle:
        return ColorStyle(
            color: self.color,
            background_color: c,
            border_color: self.border_color,
            opacity: self.opacity
        )

    fn with_border_color(c: text) -> ColorStyle:
        return ColorStyle(
            color: self.color,
            background_color: self.background_color,
            border_color: c,
            opacity: self.opacity
        )

class FontProperties:
    """Font-related style properties."""
    family: text
    size_px: i32
    weight: text
    style: text
    line_height: f64

    static fn default() -> FontProperties:
        return FontProperties(
            family: "inherit",
            size_px: 14,
            weight: "normal",
            style: "normal",
            line_height: 1.5
        )

    fn with_family(f: text) -> FontProperties:
        return FontProperties(
            family: f,
            size_px: self.size_px,
            weight: self.weight,
            style: self.style,
            line_height: self.line_height
        )

    fn with_size(n: i32) -> FontProperties:
        return FontProperties(
            family: self.family,
            size_px: n,
            weight: self.weight,
            style: self.style,
            line_height: self.line_height
        )

    fn with_weight(w: text) -> FontProperties:
        return FontProperties(
            family: self.family,
            size_px: self.size_px,
            weight: w,
            style: self.style,
            line_height: self.line_height
        )

    fn to_css_text() -> text:
        return "{self.weight} {self.size_px}px/{self.line_height} {self.family}"

class EdgeInsets:
    """Four-sided spacing value (padding or margin)."""
    top: i32
    right: i32
    bottom: i32
    left: i32

    static fn all(n: i32) -> EdgeInsets:
        return EdgeInsets(top: n, right: n, bottom: n, left: n)

    static fn symmetric(vertical: i32, horizontal: i32) -> EdgeInsets:
        return EdgeInsets(top: vertical, right: horizontal, bottom: vertical, left: horizontal)

    static fn zero() -> EdgeInsets:
        return EdgeInsets(top: 0, right: 0, bottom: 0, left: 0)

    static fn only(top: i32, right: i32, bottom: i32, left: i32) -> EdgeInsets:
        return EdgeInsets(top: top, right: right, bottom: bottom, left: left)

    fn to_css_text() -> text:
        if (self.top == self.right and self.right == self.bottom and self.bottom == self.left):
            return "{self.top}px"
        if (self.top == self.bottom and self.left == self.right):
            return "{self.top}px {self.right}px"
        return "{self.top}px {self.right}px {self.bottom}px {self.left}px"

# =========================================================================
# Composite Style Rule
# =========================================================================

class StyleRule:
    """Complete style for a single widget or selector level."""
    color: ColorStyle
    font: FontProperties
    padding: EdgeInsets
    margin: EdgeInsets
    width: text
    height: text
    border_width: i32
    border_radius: i32
    border_style: text
    display: text
    visibility: text

    static fn default() -> StyleRule:
        return StyleRule(
            color: ColorStyle.default(),
            font: FontProperties.default(),
            padding: EdgeInsets.zero(),
            margin: EdgeInsets.zero(),
            width: "auto",
            height: "auto",
            border_width: 0,
            border_radius: 0,
            border_style: "none",
            display: "block",
            visibility: "visible"
        )

    fn is_visible() -> bool:
        return self.visibility != "hidden"

# =========================================================================
# Style Selector
# =========================================================================

class StyleSelector:
    """Identifies which widgets a rule applies to."""
    widget_id: text
    widget_kind: text
    class_name: text
    state: text
    specificity: i32

    static fn by_id(id: text) -> StyleSelector:
        return StyleSelector(
            widget_id: id,
            widget_kind: "",
            class_name: "",
            state: "",
            specificity: 100
        )

    static fn by_kind(kind: text) -> StyleSelector:
        return StyleSelector(
            widget_id: "",
            widget_kind: kind,
            class_name: "",
            state: "",
            specificity: 1
        )

    static fn by_class(cls: text) -> StyleSelector:
        return StyleSelector(
            widget_id: "",
            widget_kind: "",
            class_name: cls,
            state: "",
            specificity: 10
        )

    static fn by_state(kind: text, state: text) -> StyleSelector:
        return StyleSelector(
            widget_id: "",
            widget_kind: kind,
            class_name: "",
            state: state,
            specificity: 11
        )

    fn matches(widget_id: text, widget_kind: text, classes: text, state: text) -> bool:
        """Return true if this selector matches the given widget attributes."""
        if self.widget_id != "" and self.widget_id != widget_id:
            return false
        if self.widget_kind != "" and self.widget_kind != widget_kind:
            return false
        if self.class_name != "" and not classes.contains(self.class_name):
            return false
        if self.state != "" and self.state != state:
            return false
        return true

# =========================================================================
# Style Entry (selector + rule pair)
# =========================================================================

class StyleEntry:
    """A single selector-to-rule mapping in the style sheet."""
    selector: StyleSelector
    rule: StyleRule

    static fn new(sel: StyleSelector, rule: StyleRule) -> StyleEntry:
        return StyleEntry(selector: sel, rule: rule)

# =========================================================================
# Style Sheet
# =========================================================================

class StyleSheet:
    """Ordered list of style entries used for cascade resolution."""
    entries: [StyleEntry]

    static fn new() -> StyleSheet:
        return StyleSheet(entries: [])

    me add(entry: StyleEntry):
        """Append a style entry to the sheet."""
        self.entries = self.entries.push(entry)

    me add_rule(sel: StyleSelector, rule: StyleRule):
        """Convenience: add a selector+rule pair directly."""
        self.entries = self.entries.push(StyleEntry.new(sel, rule))

    fn entry_count() -> i32:
        return self.entries.len()

# =========================================================================
# Style Cascade
# =========================================================================

fn cascade_color(base: ColorStyle, override_val: ColorStyle) -> ColorStyle:
    """Apply override color properties on top of a base, skipping 'inherit'/'transparent' placeholders."""
    var result = base
    if override_val.color != "inherit":
        result = result.with_color(override_val.color)
    if override_val.background_color != "transparent":
        result = result.with_background(override_val.background_color)
    if override_val.border_color != "inherit":
        result = result.with_border_color(override_val.border_color)
    return result

fn cascade_font(base: FontProperties, override_val: FontProperties) -> FontProperties:
    """Apply override font properties on top of a base, skipping sentinel defaults."""
    var result = base
    if override_val.family != "inherit":
        result = result.with_family(override_val.family)
    if override_val.size_px != 14:
        result = result.with_size(override_val.size_px)
    if override_val.weight != "normal":
        result = result.with_weight(override_val.weight)
    return result

fn cascade_rule(base: StyleRule, override_val: StyleRule) -> StyleRule:
    """Merge override_val on top of base, returning a new resolved StyleRule."""
    val c = cascade_color(base.color, override_val.color)
    val f = cascade_font(base.font, override_val.font)
    val pad = if (override_val.padding.top != 0 or override_val.padding.right != 0 or
                   override_val.padding.bottom != 0 or override_val.padding.left != 0):
        override_val.padding
    else:
        base.padding
    val mar = if (override_val.margin.top != 0 or override_val.margin.right != 0 or
                   override_val.margin.bottom != 0 or override_val.margin.left != 0):
        override_val.margin
    else:
        base.margin
    val bw = if override_val.border_width != 0: override_val.border_width else: base.border_width
    val br = if override_val.border_radius != 0: override_val.border_radius else: base.border_radius
    val bs = if override_val.border_style != "none": override_val.border_style else: base.border_style
    val w = if override_val.width != "auto": override_val.width else: base.width
    val h = if override_val.height != "auto": override_val.height else: base.height
    val disp = if override_val.display != "block": override_val.display else: base.display
    val vis = if override_val.visibility != "visible": override_val.visibility else: base.visibility
    return StyleRule(
        color: c,
        font: f,
        padding: pad,
        margin: mar,
        width: w,
        height: h,
        border_width: bw,
        border_radius: br,
        border_style: bs,
        display: disp,
        visibility: vis
    )

# =========================================================================
# Style Matching — resolve effective style for a widget
# =========================================================================

fn resolve_style(
    sheet: StyleSheet,
    widget_id: text,
    widget_kind: text,
    classes: text,
    state: text
) -> StyleRule:
    """Resolve the effective style for a widget by cascading all matching rules in specificity order."""
    var match_count = 0
    for entry in sheet.entries:
        if entry.selector.matches(widget_id, widget_kind, classes, state):
            match_count = match_count + 1

    if match_count == 0:
        return StyleRule.default()

    # Build the matching list already sorted by specificity. Avoid indexed
    # assignment here because native entry-closure builds reject it on this path.
    var matched: [StyleEntry] = []
    for entry in sheet.entries:
        if entry.selector.matches(widget_id, widget_kind, classes, state):
            var next: [StyleEntry] = []
            var inserted = false
            for existing in matched:
                if not inserted and entry.selector.specificity < existing.selector.specificity:
                    next.push(entry)
                    inserted = true
                next.push(existing)
            if not inserted:
                next.push(entry)
            matched = next

    # Cascade all matching rules from lowest to highest specificity
    var resolved = StyleRule.default()
    for entry in matched:
        resolved = cascade_rule(resolved, entry.rule)
    return resolved

fn style_matches(selector: StyleSelector, widget_id: text, widget_kind: text, classes: text, state: text) -> bool:
    """Check whether a single selector matches a widget."""
    return selector.matches(widget_id, widget_kind, classes, state)
