# Taskbar Model — Shared Schema for Host and SimpleOS Desktop Shells
#
# Single source of truth for the taskbar's visible state. Consumed by:
#   * src/os/desktop/shell.spl      — SimpleOS TaskbarShell
#   * src/app/ui.web/taskbar_shell.spl — host TaskbarShell
#
# The shell renders three sections: pinned apps, running apps, tray items.
# Click on a pinned AppRef -> launcher spawn by app_id.
# Click on a running WindowRef -> focus + raise by window_id.

struct AppRef:
    """Pinned launcher entry."""
    app_id: text
    display_name: text
    icon: text

struct WindowRef:
    """Running app entry; tracks minimized state for taskbar grouping."""
    window_id: text
    app_id: text
    title: text
    minimized: bool

struct TrayItem:
    """Tray / status-area entry (clock, notifications, etc)."""
    item_id: text
    label: text
    icon: text

struct TaskbarLaunchError:
    """Most recent launcher error surfaced to taskbar clients."""
    app_id: text
    message: text

struct TaskbarModel:
    """Full taskbar state snapshot."""
    pinned: [AppRef]
    running: [WindowRef]
    tray: [TrayItem]

fn empty_taskbar_model() -> TaskbarModel:
    TaskbarModel(pinned: [], running: [], tray: [])
