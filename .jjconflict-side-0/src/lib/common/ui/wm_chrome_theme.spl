# WM chrome theme accessor — single source of truth for window-manager
# chrome colors (titlebars, borders, desktop/taskbar backgrounds, close
# button). Previously these were hardcoded color literals scattered across
# three render pipelines:
#   - common/ui/window_scene_draw_ir.spl      (Draw IR projection)
#   - common/ui/window_scene.spl              (chrome background hex)
#   - os/compositor/host_compositor_entry.spl (direct backend draw)
#   - os/compositor/wm_scene.spl              (modern theme config)
#
# The defaults returned here reproduce those literals byte-for-byte so that
# all existing bitmap-evidence gates keep passing unchanged. A theme can be
# installed at runtime via register_wm_chrome_theme(); wm_chrome_theme() then
# returns the installed colors, which flows into every chrome pipeline.
#
# Design: composition + a module-level override var (same idiom as
# widget_store_ops.spl). No inheritance.

struct WmChromeColors:
    desktop_bg: u32          # dark desktop backdrop (0xff101418)
    compositor_bg: u32       # slate desktop backdrop (0xff0f172a)
    command_lane: u32        # top command lane fill
    taskbar: u32             # taskbar fill
    text_primary: u32        # clock / title / label text
    title_focused: u32       # focused window titlebar
    title_unfocused: u32     # idle window titlebar
    window_shadow: u32       # window drop shadow
    window_body: u32         # window body fill (draw_ir)
    host_window_body: u32    # window body fill (host compositor)
    accent: u32              # accent (host titlebar + modern accent)
    close_button: u32        # window close control
    background_hex: text     # chrome background as css hex ("#101418")

fn wm_chrome_theme_defaults() -> WmChromeColors:
    WmChromeColors(
        desktop_bg: 0xff101418u32,
        compositor_bg: 0xff0f172au32,
        command_lane: 0xff182027u32,
        taskbar: 0xff151a20u32,
        text_primary: 0xffffffffu32,
        title_focused: 0xff2f80edu32,
        title_unfocused: 0xff25313au32,
        window_shadow: 0x33000000u32,
        window_body: 0xff20262du32,
        host_window_body: 0xff1e293bu32,
        accent: 0xff2563ebu32,
        close_button: 0xffcc3333u32,
        background_hex: "#101418"
    )

# Override slot: empty = use defaults, one element = installed theme.
# List sentinel (same idiom as widget_store_ops.spl's _widget_registry) — the
# only module-global shape that round-trips a struct value correctly under the
# compiled/test interpreter. Reads happen once per scene projection.
var _wm_chrome_override: [WmChromeColors] = []

fn wm_chrome_theme() -> WmChromeColors:
    """Return the active WM chrome colors — the installed theme if one is
    registered, otherwise the byte-identical default literals."""
    if _wm_chrome_override.len() > 0:
        return _wm_chrome_override[0]
    wm_chrome_theme_defaults()

fn register_wm_chrome_theme(colors: WmChromeColors):
    """Install a WM chrome palette. All chrome pipelines pick it up on the
    next scene projection / render."""
    _wm_chrome_override = [colors]

fn reset_wm_chrome_theme():
    """Restore the byte-identical default palette."""
    _wm_chrome_override = []

# =========================================================================
# GUI (CSS) theme bridge — the WM chrome shares the GUI theme's tokens.
#
# The GUI side's source of truth is SimpleTheme (common/ui/simple_theme.spl):
# CSS custom properties (--ui-bg, --ui-fg, --ui-accent, --app-surface,
# --app-surface-hover, --ui-error) backed by GlassDesignTokens. The WM
# chrome derives its palette from those same tokens so switching the GUI
# theme retunes titlebars/taskbar/desktop in one place. Every field falls
# back to the byte-identical default when a token is missing or unparseable
# — with no registration the chrome pipelines are unchanged, so all
# bitmap-evidence gates keep passing.
# =========================================================================

fn _wm_hex_val(c: text) -> i32:
    # Block-form ifs only: single-line `if a == x or a == y: return n` is
    # mis-evaluated by the interpreter (the or-condition matches everything
    # and the function tail is swallowed) — see
    # doc/08_tracking/bug/interp_single_line_if_or_return_2026-07-04.md.
    val lower = c.lower()
    if lower == "0":
        return 0
    if lower == "1":
        return 1
    if lower == "2":
        return 2
    if lower == "3":
        return 3
    if lower == "4":
        return 4
    if lower == "5":
        return 5
    if lower == "6":
        return 6
    if lower == "7":
        return 7
    if lower == "8":
        return 8
    if lower == "9":
        return 9
    if lower == "a":
        return 10
    if lower == "b":
        return 11
    if lower == "c":
        return 12
    if lower == "d":
        return 13
    if lower == "e":
        return 14
    if lower == "f":
        return 15
    -1

fn wm_css_color_to_argb(css: text) -> u32:
    """Parse a #rgb / #rrggbb CSS hex color into opaque ARGB. Returns 0 for
    anything else (0 = "no color" sentinel throughout the chrome pipelines,
    and callers fall back to the default palette)."""
    val s = css.trim()
    if s.len() == 0 or not s.starts_with("#"):
        return 0
    if s.len() == 7:
        val r = _wm_hex_val(s.char_at(1)) * 16 + _wm_hex_val(s.char_at(2))
        val g = _wm_hex_val(s.char_at(3)) * 16 + _wm_hex_val(s.char_at(4))
        val b = _wm_hex_val(s.char_at(5)) * 16 + _wm_hex_val(s.char_at(6))
        if r < 0 or g < 0 or b < 0:
            return 0
        return 0xFF000000u32 | (r.to_u32() << 16) | (g.to_u32() << 8) | b.to_u32()
    if s.len() == 4:
        val r = _wm_hex_val(s.char_at(1))
        val g = _wm_hex_val(s.char_at(2))
        val b = _wm_hex_val(s.char_at(3))
        if r < 0 or g < 0 or b < 0:
            return 0
        return 0xFF000000u32 | ((r * 17).to_u32() << 16) | ((g * 17).to_u32() << 8) | (b * 17).to_u32()
    0

fn _wm_pick(candidate: u32, fallback: u32) -> u32:
    if candidate != 0: candidate else: fallback

fn wm_chrome_colors_from_gui_tokens(bg_hex: text, fg_hex: text, accent_hex: text, surface_hex: text, surface_hover_hex: text, error_hex: text) -> WmChromeColors:
    """Map resolved GUI theme token values (CSS hex strings) onto the WM
    chrome palette. Unparseable/empty tokens keep the default color for
    that slot."""
    val d = wm_chrome_theme_defaults()
    val bg = wm_css_color_to_argb(bg_hex)
    val fg = wm_css_color_to_argb(fg_hex)
    val accent = wm_css_color_to_argb(accent_hex)
    val surface = wm_css_color_to_argb(surface_hex)
    val surface_hover = wm_css_color_to_argb(surface_hover_hex)
    val error_c = wm_css_color_to_argb(error_hex)
    WmChromeColors(
        desktop_bg: _wm_pick(bg, d.desktop_bg),
        compositor_bg: _wm_pick(bg, d.compositor_bg),
        command_lane: _wm_pick(surface, d.command_lane),
        taskbar: _wm_pick(surface, d.taskbar),
        text_primary: _wm_pick(fg, d.text_primary),
        title_focused: _wm_pick(accent, d.title_focused),
        title_unfocused: _wm_pick(surface_hover, d.title_unfocused),
        window_shadow: d.window_shadow,
        window_body: _wm_pick(surface, d.window_body),
        host_window_body: _wm_pick(surface, d.host_window_body),
        accent: _wm_pick(accent, d.accent),
        close_button: _wm_pick(error_c, d.close_button),
        background_hex: if bg != 0: bg_hex.trim() else: d.background_hex
    )
