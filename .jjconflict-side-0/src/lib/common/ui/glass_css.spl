# Glass CSS Generation
#
# Generates comprehensive CSS for glassmorphism-styled widgets.
# Produces CSS custom properties from glass design tokens and
# component-level styles with backdrop-filter blur, translucent
# surfaces, and subtle glass-edge borders.
#
# Sub-modules (all in common.ui):
#   glass_css_components  — core widgets + shell (glass_component_css)
#   glass_css_surfaces    — surface hierarchy + effect classes (glass_surface_css)

use common.ui.glass.tokens.{GlassDesignTokens, StitchMetadata}
use common.ui.glass.theme.{glass_design_tokens, is_glass_theme}
use common.ui.glass_css_components.{glass_component_css}
use common.ui.glass_css_surfaces.{glass_surface_css}

# =========================================================================
# Token CSS Variables
# =========================================================================

fn stitch_font_to_css(font_enum: text) -> text:
    """Convert a Stitch font enum (e.g. SPACE_GROTESK) to a CSS font-family stack."""
    if font_enum == "SPACE_GROTESK":
        return "'Space Grotesk', system-ui, sans-serif"
    if font_enum == "MANROPE":
        return "'Manrope', system-ui, sans-serif"
    if font_enum == "INTER":
        return "'Inter', system-ui, sans-serif"
    return "system-ui, sans-serif"

fn glass_tokens_to_css(tokens: GlassDesignTokens, sds: StitchMetadata) -> text:
    val c = tokens.colors
    val b = tokens.blur
    val r = tokens.radius
    val sh = tokens.shadows
    val sp = tokens.spacing
    val a = tokens.animation

    var css = "  /* Glass Surface Tokens */\n"
    css = "{css}  --glass-surface-primary: {c.surface_primary};\n"
    css = "{css}  --glass-surface-secondary: {c.surface_secondary};\n"
    css = "{css}  --glass-surface-tertiary: {c.surface_tertiary};\n"
    css = "{css}  --glass-surface-elevated: {c.surface_elevated};\n"
    css = "{css}  /* Glass Surface Container Tiers (MD3) */\n"
    css = "{css}  --glass-surface-container-lowest: {c.surface_container_lowest};\n"
    css = "{css}  --glass-surface-container-low: {c.surface_container_low};\n"
    css = "{css}  --glass-surface-container: {c.surface_container};\n"
    css = "{css}  --glass-surface-container-high: {c.surface_container_high};\n"
    css = "{css}  --glass-surface-container-highest: {c.surface_container_highest};\n"
    css = "{css}  /* Glass Text */\n"
    css = "{css}  --glass-text-primary: {c.text_primary};\n"
    css = "{css}  --glass-text-secondary: {c.text_secondary};\n"
    css = "{css}  --glass-text-tertiary: {c.text_tertiary};\n"
    css = "{css}  --glass-on-surface-variant: {c.on_surface_variant};\n"
    css = "{css}  /* Glass Accent */\n"
    css = "{css}  --glass-accent: {c.accent};\n"
    css = "{css}  --glass-accent-hover: {c.accent_hover};\n"
    css = "{css}  /* Glass Semantic */\n"
    css = "{css}  --glass-error: {c.error};\n"
    css = "{css}  --glass-warning: {c.warning};\n"
    css = "{css}  --glass-success: {c.success};\n"
    css = "{css}  --glass-info: {c.info};\n"
    css = "{css}  /* Glass Borders */\n"
    css = "{css}  --glass-border-subtle: {c.border_subtle};\n"
    css = "{css}  --glass-border-prominent: {c.border_prominent};\n"
    css = "{css}  --glass-separator: {c.separator};\n"
    css = "{css}  /* Glass Blur */\n"
    css = "{css}  --glass-blur-surface: {b.surface_blur}px;\n"
    css = "{css}  --glass-blur-elevated: {b.elevated_blur}px;\n"
    css = "{css}  --glass-blur-nav: {b.nav_blur}px;\n"
    css = "{css}  --glass-blur-subtle: {b.subtle_blur}px;\n"
    css = "{css}  /* Glass Radius */\n"
    css = "{css}  --glass-radius-sm: {r.sm}px;\n"
    css = "{css}  --glass-radius-md: {r.md}px;\n"
    css = "{css}  --glass-radius-lg: {r.lg}px;\n"
    css = "{css}  --glass-radius-xl: {r.xl}px;\n"
    css = "{css}  /* Glass Shadows (multi-layer with ring + inset glow) */\n"
    css = "{css}  --glass-shadow-sm: {sh.sm};\n"
    css = "{css}  --glass-shadow-md: {sh.md};\n"
    css = "{css}  --glass-shadow-lg: {sh.lg};\n"
    css = "{css}  --glass-shadow-xl: {sh.xl};\n"
    css = "{css}  /* Glass Spacing */\n"
    css = "{css}  --glass-spacing-xs: {sp.s1}px;\n"
    css = "{css}  --glass-spacing-sm: {sp.s2}px;\n"
    css = "{css}  --glass-spacing-md: {sp.s4}px;\n"
    css = "{css}  --glass-spacing-lg: {sp.s6}px;\n"
    css = "{css}  --glass-spacing-xl: {sp.s8}px;\n"
    css = "{css}  /* Glass Animation */\n"
    css = "{css}  --glass-duration-fast: {a.duration_fast}ms;\n"
    css = "{css}  --glass-duration-normal: {a.duration_normal}ms;\n"
    css = "{css}  --glass-easing: {a.easing_default};\n"
    css = "{css}  /* 5-Level Surface Hierarchy */\n"
    css = "{css}  --surface-0: {c.surface_level_0};\n"
    css = "{css}  --surface-1: {c.surface_level_1};\n"
    css = "{css}  --surface-2: {c.surface_level_2};\n"
    css = "{css}  --surface-3: {c.surface_level_3};\n"
    css = "{css}  --surface-4: {c.surface_level_4};\n"
    css = "{css}  --border: rgba(255,255,255,0.10);\n"
    css = "{css}  --text: rgba(255,255,255,0.92);\n"
    css = "{css}  --muted: rgba(255,255,255,0.62);\n"
    css = "{css}  --accent: {c.accent};\n"
    css = "{css}  --radius-sm: 12px;\n"
    css = "{css}  --radius-md: 16px;\n"
    css = "{css}  --radius-lg: 20px;\n"
    # Glass Typography (Stitch Fidelity)
    css = "{css}  /* Glass Typography — from StitchDesignSystem */\n"
    css = "{css}  --glass-font-headline: {stitch_font_to_css(sds.headline_font)};\n"
    css = "{css}  --glass-font-body: {stitch_font_to_css(sds.body_font)};\n"
    css = "{css}  --glass-font-label: {stitch_font_to_css(sds.label_font)};\n"
    css

# =========================================================================
# Combined Glass CSS Entry Point
# =========================================================================

fn generate_glass_css(theme_name: text) -> text:
    if not is_glass_theme(theme_name):
        return ""
    val tokens = glass_design_tokens(theme_name)
    var sds = StitchMetadata.glass()
    if theme_name == "glass_obsidian_dark":
        sds = StitchMetadata.obsidian()
    else if theme_name == "glass_light":
        sds = StitchMetadata.celestial_ether()
    else if theme_name == "glass_obsidian_light":
        sds = StitchMetadata.celestial_ether()
    var css = "\n/* ===== Glass Design Tokens ===== */\n"
    css = "{css}:root {\n"
    css = "{css}" + glass_tokens_to_css(tokens, sds)
    css = "{css}}\n"
    css = "{css}" + glass_component_css(theme_name)
    css = "{css}" + glass_surface_css()
    css
