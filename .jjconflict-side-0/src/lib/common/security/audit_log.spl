#![allow(unnamed_duplicate_typed_args)]
# Structured security audit logging.
#
# AOP weaving target — business code does NOT call these functions directly.
# The security/audit aspect weaves calls at matched join points.

use std.security.types
use std.json
use std.io.file

## Log a security event to the configured output.
fn log_security_event(entry: AuditEntry, config: AuditConfig):
    if not config.enabled:
        return

    if not meets_severity(entry.severity, config.min_severity):
        return

    val line = format_audit_entry(entry, config.mask_secrets)

    if config.log_to_stdout:
        print line

    if config.log_file != "":
        file.append_text(config.log_file, line + "\n")

## Format an audit entry as structured JSON.
fn format_audit_entry(entry: AuditEntry, mask_secrets: bool) -> text:
    val event_type = event_type_name(entry.event)
    val event_data = event_to_fields(entry.event, mask_secrets)
    val severity_str = severity_name(entry.severity)

    "{\"timestamp_ms\":{entry.timestamp_ms},\"severity\":\"{severity_str}\",\"event\":\"{event_type}\",\"correlation_id\":\"{entry.correlation_id}\",\"module\":\"{entry.module_path}\",\"data\":{event_data}}"

## Extract event type name string.
fn event_type_name(event: SecurityEvent) -> text:
    """
    Returns the string identifier for an event type.

    sdoctest:
        val e = SecurityEvent.CsrfViolation(peer: "p", path: "/")
        expect(event_type_name(e)).to_equal("csrf_violation")
    """
    match event:
        AuthSuccess(_, _): "auth_success"
        AuthFailure(_, _, _): "auth_failure"
        AccessDenied(_, _, _): "access_denied"
        CsrfViolation(_, _): "csrf_violation"
        RateLimitHit(_, _): "rate_limit_hit"
        InputSanitized(_, _): "input_sanitized"
        SessionCreated(_, _): "session_created"
        SessionExpired(_): "session_expired"
        CapabilityDenied(_, _): "capability_denied"
        RequestProcessed(_, _, _): "request_processed"

## Convert event fields to JSON object string.
fn event_to_fields(event: SecurityEvent, mask: bool) -> text:
    match event:
        AuthSuccess(user, peer):
            "{\"user\":\"{user}\",\"peer\":\"{peer}\"}"
        AuthFailure(user, peer, reason):
            val masked_user = if mask: mask_value(user) else: user
            "{\"user\":\"{masked_user}\",\"peer\":\"{peer}\",\"reason\":\"{reason}\"}"
        AccessDenied(resource, capability, peer):
            "{\"resource\":\"{resource}\",\"capability\":\"{capability}\",\"peer\":\"{peer}\"}"
        CsrfViolation(peer, path):
            "{\"peer\":\"{peer}\",\"path\":\"{path}\"}"
        RateLimitHit(peer, path):
            "{\"peer\":\"{peer}\",\"path\":\"{path}\"}"
        InputSanitized(field, original_len):
            "{\"field\":\"{field}\",\"original_len\":{original_len}}"
        SessionCreated(session_id, peer):
            val masked_id = if mask: mask_value(session_id) else: session_id
            "{\"session_id\":\"{masked_id}\",\"peer\":\"{peer}\"}"
        SessionExpired(session_id):
            val masked_id = if mask: mask_value(session_id) else: session_id
            "{\"session_id\":\"{masked_id}\"}"
        CapabilityDenied(capability, window_id):
            "{\"capability\":\"{capability}\",\"window_id\":\"{window_id}\"}"
        RequestProcessed(path, duration_ms, status):
            "{\"path\":\"{path}\",\"duration_ms\":{duration_ms},\"status\":{status}}"

## Mask sensitive values — show first 4 chars, rest as asterisks.
fn mask_value(value: text) -> text:
    """
    Masks sensitive values for safe logging.

    sdoctest:
        expect(mask_value("secret_token")).to_equal("secr****")
        expect(mask_value("ab")).to_equal("****")
    """
    if value.len() <= 4:
        return "****"
    val prefix = value.slice(0, 4)
    "{prefix}****"

## Severity name for JSON output.
fn severity_name(severity: SecuritySeverity) -> text:
    match severity:
        SecuritySeverity.Info: "info"
        SecuritySeverity.Warning: "warning"
        SecuritySeverity.Critical: "critical"

## Check if event severity meets minimum threshold.
fn meets_severity(event_severity: SecuritySeverity, min: SecuritySeverity) -> bool:
    """
    Returns true if event_severity >= min threshold.

    sdoctest:
        expect(meets_severity(SecuritySeverity.Critical, SecuritySeverity.Info)).to_equal(true)
        expect(meets_severity(SecuritySeverity.Info, SecuritySeverity.Warning)).to_equal(false)
    """
    severity_rank(event_severity) >= severity_rank(min)

fn severity_rank(s: SecuritySeverity) -> i64:
    match s:
        SecuritySeverity.Info: 0
        SecuritySeverity.Warning: 1
        SecuritySeverity.Critical: 2
