# Opaque credential handles for secret management.
#
# Credentials are never exposed as raw text values. Instead, they are
# referenced by an opaque CredentialHandle whose internal ID is meaningless
# outside the CredentialStore. The only way to use a credential is via
# the apply() method, which passes the raw value to a callback but never
# returns it — preventing accidental logging, serialization, or display.
#
# Resolution order: environment variable -> ~/.simple/credentials.sdn -> nil

use std.io.file
use std.io.env

# Opaque reference to a stored credential.
#
# The _id field is an internal index into the CredentialStore's vault.
# It carries no information about the credential itself and must not
# be treated as the credential value.
class CredentialHandle:
    _id: i64

    # Check whether this handle points to a valid, loaded credential.
    fn is_valid() -> bool:
        self._id >= 0

# Secure credential store using opaque handles.
#
# Credentials are stored internally and only accessible through the
# apply() callback pattern. This prevents the raw credential from
# leaking into logs, return values, or serialized output.
class CredentialStore:
    _vault: List<text>
    _names: List<text>

    # Create an empty credential store.
    static fn new() -> CredentialStore:
        CredentialStore(
            _vault: [],
            _names: []
        )

    # Resolve a credential by name.
    #
    # Resolution order:
    # 1. Environment variable with the given name
    # 2. Entry in ~/.simple/credentials.sdn (if file exists)
    # 3. nil (credential not found)
    fn resolve(name: text) -> CredentialHandle?:
        """
        Resolves a credential by name. Returns nil if not found.

        sdoctest:
            val store = CredentialStore.new()
            val handle = store.resolve("NONEXISTENT_CREDENTIAL_XYZ")
            expect(handle).to_be_nil()
        """
        # Check if already cached
        var i = 0
        while i < self._names.len():
            if self._names[i] == name:
                return CredentialHandle(_id: i)
            i = i + 1

        # Try environment variable
        val env_val = env.get(name)
        if val value = env_val:
            return self._store_credential(name, value)

        # Try credentials file
        val cred_val = _read_credential_from_file(name)
        if val value = cred_val:
            return self._store_credential(name, value)

        nil

    # Apply a credential's raw value to a callback.
    #
    # This is the ONLY way to access the credential value. The callback
    # receives the raw text but the value is never returned from apply().
    # This prevents accidental exposure through logging or serialization.
    fn apply(handle: CredentialHandle, target: fn(text)):
        if handle._id >= 0 and handle._id < self._vault.len():
            target(self._vault[handle._id])

    # Internal: store a credential and return a handle.
    fn _store_credential(name: text, value: text) -> CredentialHandle:
        val id = self._vault.len()
        self._vault = self._vault.push(value)
        self._names = self._names.push(name)
        CredentialHandle(_id: id)

# Convenience: resolve a credential by name using a default store.
fn resolve_credential(name: text) -> CredentialHandle?:
    val store = CredentialStore.new()
    store.resolve(name)

# Convenience: check whether a credential exists (env or file).
fn credential_exists(name: text) -> bool:
    """
    Returns true if the credential can be resolved from env or file.

    sdoctest:
        expect(credential_exists("NONEXISTENT_CREDENTIAL_XYZ")).to_equal(false)
    """
    val env_val = env.get(name)
    if val _ = env_val:
        return true

    val file_val = _read_credential_from_file(name)
    if val _ = file_val:
        return true

    false

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

# Read a credential from ~/.simple/credentials.sdn.
fn _read_credential_from_file(name: text) -> text?:
    val home = env.get("HOME")
    if val home_dir = home:
        val path = "{home_dir}/.simple/credentials.sdn"
        if file.exists(path):
            val content = file.read_text(path)
            # Simple line-based SDN parsing: name = "value"
            val lines = content.split("\n")
            for line in lines:
                val trimmed = line.trim()
                if trimmed.starts_with(name):
                    val rest = trimmed.slice(name.len(), trimmed.len()).trim()
                    if rest.starts_with("="):
                        val value_part = rest.slice(1, rest.len()).trim()
                        # Strip surrounding quotes if present
                        if value_part.starts_with("\"") and value_part.ends_with("\""):
                            return value_part.slice(1, value_part.len() - 1)
                        return value_part
    nil
