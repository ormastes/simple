# Engine Signal / Event System
#
# Signal: a named event emitter that broadcasts text payloads to registered callbacks.
# SignalConnection: a single registered callback with an integer id.
#
# Usage:
#   var sig = Signal(name: "on_hit", connections: [], next_id: 0, enabled: true)
#   sig.connect(\msg: print "got: {msg}")
#   sig.emit("player")

pub class SignalConnection:
    """A single callback registered with a Signal."""
    id: i64
    callback: fn(text)

pub class Signal:
    """Named event emitter. Connections receive a text payload on emit."""
    name: text
    connections: [SignalConnection]
    next_id: i64
    enabled: bool

impl Signal:
    me connect(callback: fn(text)) -> i64:
        """Register a callback. Returns the connection id for later disconnect."""
        val conn_id = self.next_id
        self.connections.push(SignalConnection(id: conn_id, callback: callback))
        self.next_id = self.next_id + 1
        conn_id

    me disconnect(conn_id: i64):
        """Remove the callback with the given id."""
        var i = 0
        var new_connections: [SignalConnection] = []
        while i < self.connections.len():
            val conn = self.connections[i]
            if conn.id != conn_id:
                new_connections.push(conn)
            i = i + 1
        self.connections = new_connections

    me emit(payload: text):
        """Broadcast payload to all registered callbacks (if enabled)."""
        if not self.enabled:
            return
        var i = 0
        while i < self.connections.len():
            self.connections[i].callback(payload)
            i = i + 1

    me set_enabled(enabled: bool):
        self.enabled = enabled
