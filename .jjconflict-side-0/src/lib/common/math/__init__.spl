# Math module — re-exports all public symbols from math.spl and statistics.spl.
#
# Import path: use std.common.math.{MATH_PI, math_sqrt, mean, median, ...}

export use std.common.math.math.{
    MATH_PI, MATH_E, MATH_TAU, MATH_INF,
    math_sin, math_cos, math_tan,
    math_sqrt, math_cbrt, math_hypot,
    math_pow, math_exp, math_fma,
    math_abs, math_trunc, math_round,
    math_min, math_max, math_clamp, math_lerp
}

export use std.common.math.statistics.{
    mean, median, mode_single, avedev, devsq,
    var_pop, var_sample, stdev_pop, stdev_sample, standardize,
    skew, kurt,
    percentile_inc, quartile_inc, percentrank_inc, trimmean,
    geomean, harmean,
    covar_pop, covar_sample, correl, rsq,
    linfit, slope, intercept, forecast_linear, steyx,
    growth_predict,
    rank_value, large, small,
    fisher, fisher_inv
}
