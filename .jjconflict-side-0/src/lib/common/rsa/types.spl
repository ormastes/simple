#![allow(unnamed_duplicate_typed_args)]
@allow(unnamed_duplicate_typed_args)
# RSA BigInt Types and Basic Operations
#
# BigInt representation using list of limbs (little-endian)
# Base: 2^30 (30 bits per limb to avoid overflow)

val BIGINT_BASE = 1073741824  # 2^30
val BIGINT_BITS_PER_LIMB = 30

fn bigint_from_i64(n: i64) -> list:
    if n == 0:
        return [0]

    var result = []
    var value = n

    while value > 0:
        val limb = value % BIGINT_BASE
        result.push(limb)
        value = value / BIGINT_BASE

    result

fn bigint_zero() -> list:
    [0]

fn bigint_one() -> list:
    [1]

fn bigint_is_zero(a: list) -> bool:
    if a.len() == 0:
        return true
    if a.len() == 1:
        return a[0] == 0
    false

fn bigint_is_one(a: list) -> bool:
    if a.len() != 1:
        return false
    a[0] == 1

fn bigint_compare(a: list, b: list) -> i64:
    val len_a = a.len()
    val len_b = b.len()

    if len_a < len_b:
        return -1
    if len_a > len_b:
        return 1

    var i = len_a - 1
    while i >= 0:
        val limb_a = a[i]
        val limb_b = b[i]

        if limb_a < limb_b:
            return -1
        if limb_a > limb_b:
            return 1

        i = i - 1

    0

fn bigint_normalize(a: list) -> list:
    var len = a.len()

    while len > 1:
        if a[len - 1] != 0:
            break
        len = len - 1

    if len == a.len():
        return a

    var result = []
    var i = 0
    while i < len:
        result.push(a[i])
        i = i + 1

    result

fn bigint_add(a: list, b: list) -> list:
    val len_a = a.len()
    val len_b = b.len()
    var max_len = len_a
    if len_b > max_len:
        max_len = len_b

    var result = []
    var carry = 0
    var i = 0

    while i < max_len:
        var sum = carry

        if i < len_a:
            sum = sum + a[i]

        if i < len_b:
            sum = sum + b[i]

        result.push(sum % BIGINT_BASE)
        carry = sum / BIGINT_BASE
        i = i + 1

    if carry > 0:
        result.push(carry)

    bigint_normalize(result)

fn bigint_sub(a: list, b: list) -> list:
    val cmp = bigint_compare(a, b)
    if cmp <= 0:
        return bigint_zero()

    val len_a = a.len()
    val len_b = b.len()

    var result = []
    var borrow = 0
    var i = 0

    while i < len_a:
        var limb_a = a[i] - borrow
        var limb_b = 0
        if i < len_b:
            limb_b = b[i]

        if limb_a < limb_b:
            limb_a = limb_a + BIGINT_BASE
            borrow = 1
        else:
            borrow = 0

        result.push(limb_a - limb_b)
        i = i + 1

    bigint_normalize(result)

fn bigint_mul(a: list, b: list) -> list:
    if bigint_is_zero(a):
        return bigint_zero()
    if bigint_is_zero(b):
        return bigint_zero()

    val len_a = a.len()
    val len_b = b.len()

    var result = []
    var i = 0
    while i < len_a + len_b:
        result.push(0)
        i = i + 1

    i = 0
    while i < len_a:
        val limb_a = a[i]
        var carry = 0
        var j = 0

        while j < len_b:
            val limb_b = b[j]
            val idx = i + j
            val current = result[idx]

            val prod = limb_a * limb_b + current + carry
            result[idx] = prod % BIGINT_BASE
            carry = prod / BIGINT_BASE
            j = j + 1
        end

        if carry > 0:
            val idx = i + len_b
            result[idx] = result[idx] + carry
        end

        i = i + 1
    end

    bigint_normalize(result)

fn bigint_mul_i64(a: list, n: i64) -> list:
    if n == 0:
        return bigint_zero()
    if n == 1:
        return a

    val len_a = a.len()
    var result = []
    var carry = 0
    var i = 0

    while i < len_a:
        val limb = a[i]
        val prod = limb * n + carry
        result.push(prod % BIGINT_BASE)
        carry = prod / BIGINT_BASE
        i = i + 1
    end

    if carry > 0:
        result.push(carry)
    end

    bigint_normalize(result)

fn bigint_divmod_i64(a: list, n: i64) -> list:
    if n == 0:
        return [bigint_zero(), bigint_zero()]
    if n == 1:
        return [a, bigint_zero()]

    val len_a = a.len()
    var quotient = []
    var remainder = 0
    var i = len_a - 1

    while i >= 0:
        val limb = a[i]
        val dividend = remainder * BIGINT_BASE + limb
        val q = dividend / n
        remainder = dividend % n
        quotient.push(q)
        i = i - 1
    end

    var rev_quotient = []
    i = quotient.len() - 1
    while i >= 0:
        rev_quotient.push(quotient[i])
        i = i - 1
    end

    val norm_quot = bigint_normalize(rev_quotient)
    val remainder_bi = bigint_from_i64(remainder)
    [norm_quot, remainder_bi]
