# ============================================================================
# common/net/addr.spl — typed network address primitives
#
# Consumed by bgp, os netstack (igmp/mld/dhcpv6/ipv6/icmpv6/sctp/dccp).
# All wire emission is big-endian via common/net/byte_cursor.
# ============================================================================

struct Ipv4Addr:
    """IPv4 address as 4 network-order octets."""
    octets: [u8]

impl Ipv4Addr:
    static fn from_bytes(a: u8, b: u8, c: u8, d: u8) -> Ipv4Addr:
        Ipv4Addr(octets: [a, b, c, d])

    static fn from_u32(v: u32) -> Ipv4Addr:
        val x = v.to_u64()
        Ipv4Addr(octets: [((x >> 24) & 0xFF).to_u8(), ((x >> 16) & 0xFF).to_u8(), ((x >> 8) & 0xFF).to_u8(), (x & 0xFF).to_u8()])

    fn to_u32() -> u32:
        var v: u64 = 0
        var i: u64 = 0
        while i < 4:
            v = (v << 8) | self.octets[i].to_u64()
            i = i + 1
        v.to_u32()

struct Ipv6Addr:
    """IPv6 address as 16 network-order octets."""
    octets: [u8]

impl Ipv6Addr:
    static fn from_bytes(bytes: [u8]) -> Result<Ipv6Addr, text>:
        if bytes.len() != 16:
            return Err("Ipv6Addr.from_bytes: need 16 bytes, got {bytes.len()}")
        Ok(Ipv6Addr(octets: bytes))

    static fn from_halves(hi: u64, lo: u64) -> Ipv6Addr:
        var out: [u8] = []
        var i: u64 = 0
        while i < 8:
            out.push(((hi >> ((7 - i) * 8)) & 0xFF).to_u8())
            i = i + 1
        i = 0
        while i < 8:
            out.push(((lo >> ((7 - i) * 8)) & 0xFF).to_u8())
            i = i + 1
        Ipv6Addr(octets: out)

enum IpAddr:
    V4(Ipv4Addr)
    V6(Ipv6Addr)

fn ip_addr_v4(a: Ipv4Addr) -> IpAddr:
    IpAddr.V4(a)

fn ip_addr_v6(a: Ipv6Addr) -> IpAddr:
    IpAddr.V6(a)

fn ip_addr_to_bytes(a: IpAddr) -> [u8]:
    match a:
        case V4(v): v.octets
        case V6(v): v.octets

struct AsNumber:
    """BGP autonomous system number (4-byte capable, RFC 6793)."""
    value: u32

impl AsNumber:
    static fn new(v: u32) -> AsNumber:
        AsNumber(value: v)

export Ipv4Addr, Ipv6Addr, IpAddr, AsNumber
export ip_addr_v4, ip_addr_v6, ip_addr_to_bytes
