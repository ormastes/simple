# Pure List — immutable generic singly-linked list.
#
# Provides: List<T>.

enum List<T>:
    Nil
    Cons(head: T, tail: List<T>)

fn list_empty<T>() -> List<T>:
    List.Nil

fn list_cons<T>(head: T, tail: List<T>) -> List<T>:
    List.Cons(head: head, tail: tail)

fn list_len<T>(l: List<T>) -> i64:
    match l:
        case Nil: 0
        case Cons(_, tail): 1 + list_len(tail)

fn list_is_empty<T>(l: List<T>) -> bool:
    match l:
        case Nil: true
        case _: false

fn list_head<T>(l: List<T>) -> Option<T>:
    match l:
        case Nil: Option.None
        case Cons(head, _): Option.Some(head)

fn list_tail<T>(l: List<T>) -> List<T>:
    match l:
        case Nil: List.Nil
        case Cons(_, tail): tail

fn list_to_array<T>(l: List<T>) -> [T]:
    var out: [T] = []
    var cur = l
    while true:
        match cur:
            case Nil:
                return out
            case Cons(head, tail):
                out.push(head)
                cur = tail
    out

fn list_from_array<T>(arr: [T]) -> List<T>:
    var result: List<T> = List.Nil
    var i = arr.len() - 1
    while i >= 0:
        result = List.Cons(head: arr[i], tail: result)
        i = i - 1
    result
