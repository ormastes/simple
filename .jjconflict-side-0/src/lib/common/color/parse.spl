# Source-backed color validation helpers.

pub fn is_hex_char(ch: text) -> bool:
    val c = ch.to_upper()
    if c == "0": return true
    if c == "1": return true
    if c == "2": return true
    if c == "3": return true
    if c == "4": return true
    if c == "5": return true
    if c == "6": return true
    if c == "7": return true
    if c == "8": return true
    if c == "9": return true
    if c == "A": return true
    if c == "B": return true
    if c == "C": return true
    if c == "D": return true
    if c == "E": return true
    if c == "F": return true
    false

pub fn is_valid_hex(value: text) -> bool:
    var hex = value
    if hex.len() > 0 and hex[0:1] == "#":
        hex = hex[1:hex.len()]
    if hex.len() != 3 and hex.len() != 4 and hex.len() != 6 and hex.len() != 8:
        return false
    var i = 0
    while i < hex.len():
        if not is_hex_char(hex[i:i + 1]):
            return false
        i = i + 1
    true

pub fn is_valid_rgb(r: i64, g: i64, b: i64) -> bool:
    r >= 0 and r <= 255 and g >= 0 and g <= 255 and b >= 0 and b <= 255

pub fn is_valid_hsl(h: i64, s: i64, l: i64) -> bool:
    h >= 0 and h < 360 and s >= 0 and s <= 100 and l >= 0 and l <= 100

pub fn is_valid_hsv(h: i64, s: i64, v: i64) -> bool:
    h >= 0 and h < 360 and s >= 0 and s <= 100 and v >= 0 and v <= 100
