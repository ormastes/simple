# Web DOM interface — platform-independent DOM manipulation API.
#
# Defines the DomBackend trait for creating and modifying HTML elements.
# Implementations:
#   - EngineDomBackend (desktop/web_ui, uses browser engine's Document)
#   - Future: BrowserDomBackend (WASM target, uses JS FFI)

# Opaque handle to a DOM element (i64 node ID internally).
struct WebElement:
    id: i64

    static fn from_id(id: i64) -> WebElement:
        WebElement(id: id)

    fn is_valid() -> bool:
        self.id >= 0

# Opaque handle to a DOM document.
struct WebDocumentHandle:
    id: i64

    static fn from_id(id: i64) -> WebDocumentHandle:
        WebDocumentHandle(id: id)

# Platform-independent DOM manipulation trait.
trait DomBackend:
    # --- Element creation ---
    me create_element(tag: text) -> WebElement
    me create_text_node(content: text) -> WebElement

    # --- Tree manipulation ---
    me append_child(parent: WebElement, child: WebElement)
    me insert_before(parent: WebElement, new_child: WebElement, ref_child: WebElement)
    me remove_child(parent: WebElement, child: WebElement)
    me replace_child(parent: WebElement, new_child: WebElement, old_child: WebElement)

    # --- Attributes ---
    me set_attribute(element: WebElement, name: text, value: text)
    me get_attribute(element: WebElement, name: text) -> Option<text>
    me remove_attribute(element: WebElement, name: text)

    # --- Content ---
    me set_text_content(element: WebElement, content: text)
    me get_text_content(element: WebElement) -> text
    me set_inner_html(element: WebElement, html: text)
    me get_inner_html(element: WebElement) -> text

    # --- CSS classes ---
    me add_class(element: WebElement, class_name: text)
    me remove_class(element: WebElement, class_name: text)
    me has_class(element: WebElement, class_name: text) -> bool

    # --- Style ---
    me set_style(element: WebElement, property: text, value: text)
    me get_style(element: WebElement, property: text) -> text

    # --- Queries ---
    me query_selector(selector: text) -> Option<WebElement>
    me query_selector_all(selector: text) -> List<WebElement>
    me get_element_by_id(id: text) -> Option<WebElement>

    # --- Document access ---
    me body() -> WebElement
    me document_element() -> WebElement

# ============================================================================
# Convenience element constructors
# ============================================================================

fn create_div(backend: DomBackend) -> WebElement:
    backend.create_element("div")

fn create_span(backend: DomBackend) -> WebElement:
    backend.create_element("span")

fn create_p(backend: DomBackend) -> WebElement:
    backend.create_element("p")

fn create_h1(backend: DomBackend) -> WebElement:
    backend.create_element("h1")

fn create_h2(backend: DomBackend) -> WebElement:
    backend.create_element("h2")

fn create_h3(backend: DomBackend) -> WebElement:
    backend.create_element("h3")

fn create_button(backend: DomBackend, label: text) -> WebElement:
    val btn = backend.create_element("button")
    backend.set_text_content(btn, label)
    btn

fn create_input(backend: DomBackend, input_type: text) -> WebElement:
    val el = backend.create_element("input")
    backend.set_attribute(el, "type", input_type)
    el

fn create_img(backend: DomBackend, src: text) -> WebElement:
    val el = backend.create_element("img")
    backend.set_attribute(el, "src", src)
    el

fn create_a(backend: DomBackend, href: text, label: text) -> WebElement:
    val el = backend.create_element("a")
    backend.set_attribute(el, "href", href)
    backend.set_text_content(el, label)
    el

fn create_ul(backend: DomBackend) -> WebElement:
    backend.create_element("ul")

fn create_li(backend: DomBackend, content: text) -> WebElement:
    val el = backend.create_element("li")
    backend.set_text_content(el, content)
    el

fn create_textarea(backend: DomBackend) -> WebElement:
    backend.create_element("textarea")

fn create_select(backend: DomBackend) -> WebElement:
    backend.create_element("select")

fn create_option(backend: DomBackend, value: text, label: text) -> WebElement:
    val el = backend.create_element("option")
    backend.set_attribute(el, "value", value)
    backend.set_text_content(el, label)
    el

fn create_form(backend: DomBackend) -> WebElement:
    backend.create_element("form")

fn create_label(backend: DomBackend, text_content: text, for_id: text) -> WebElement:
    val el = backend.create_element("label")
    backend.set_text_content(el, text_content)
    if for_id.len() > 0:
        backend.set_attribute(el, "for", for_id)
    el
