# Editor LSP Popups — transient hover and signature-help popups.
#
# Provides: LspHoverPopup, LspSignaturePopup and their hidden constructors.

struct LspHoverPopup:
    visible: bool
    line: i64
    col: i64
    content: text
    detail: text

struct LspSignaturePopup:
    visible: bool
    line: i64
    col: i64
    label: text
    detail: text
    active_parameter: text

fn lsp_hover_popup_hidden() -> LspHoverPopup:
    LspHoverPopup(visible: false, line: 0, col: 0, content: "", detail: "")

fn lsp_hover_popup_show(line: i64, col: i64, content: text, detail: text) -> LspHoverPopup:
    LspHoverPopup(visible: true, line: line, col: col, content: content, detail: detail)

fn lsp_signature_popup_hidden() -> LspSignaturePopup:
    LspSignaturePopup(visible: false, line: 0, col: 0, label: "", detail: "", active_parameter: "")

fn lsp_signature_popup_show(line: i64, col: i64, label: text, detail: text, active_parameter: text) -> LspSignaturePopup:
    LspSignaturePopup(visible: true, line: line, col: col, label: label, detail: detail, active_parameter: active_parameter)
