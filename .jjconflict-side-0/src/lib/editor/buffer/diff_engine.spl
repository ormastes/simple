# Editor Buffer Diff Engine
#
# Computes line-level diffs between two text versions for change
# indicators in the gutter and workspace edit preview.

struct DiffHunk:
    kind: text
    old_start: i64
    old_count: i64
    new_start: i64
    new_count: i64
    lines: [text]

struct DiffResult:
    hunks: [DiffHunk]
    added: i64
    removed: i64
    changed: i64

fn diff_engine_compute(old_text: text, new_text: text) -> DiffResult:
    val old_lines = old_text.split("\n")
    val new_lines = new_text.split("\n")
    val old_len = old_lines.len()
    val nn = new_lines.len()
    var hunks: [DiffHunk] = []
    var added = 0
    var removed = 0
    var changed = 0
    # Simple scan: find lines present in one but not the other
    var oi = 0
    var ni = 0
    while oi < old_len or ni < nn:
        if oi < old_len and ni < nn and old_lines[oi] == new_lines[ni]:
            oi = oi + 1
            ni = ni + 1
        elif oi < old_len and ni < nn:
            val hunk = DiffHunk(kind: "change", old_start: oi, old_count: 1, new_start: ni, new_count: 1, lines: [new_lines[ni]])
            hunks.push(hunk)
            changed = changed + 1
            oi = oi + 1
            ni = ni + 1
        elif oi < old_len:
            val hunk = DiffHunk(kind: "delete", old_start: oi, old_count: 1, new_start: ni, new_count: 0, lines: [])
            hunks.push(hunk)
            removed = removed + 1
            oi = oi + 1
        else:
            val hunk = DiffHunk(kind: "add", old_start: oi, old_count: 0, new_start: ni, new_count: 1, lines: [new_lines[ni]])
            hunks.push(hunk)
            added = added + 1
            ni = ni + 1
    DiffResult(hunks: hunks, added: added, removed: removed, changed: changed)

fn diff_engine_line_kind(result: DiffResult, line_index: i64) -> text:
    for hunk in result.hunks:
        if hunk.kind == "add":
            if line_index >= hunk.new_start and line_index < hunk.new_start + hunk.new_count:
                return "add"
        elif hunk.kind == "delete":
            if line_index >= hunk.old_start and line_index < hunk.old_start + hunk.old_count:
                return "delete"
        elif hunk.kind == "change":
            if line_index >= hunk.new_start and line_index < hunk.new_start + hunk.new_count:
                return "change"
    ""

fn diff_result_empty() -> DiffResult:
    DiffResult(hunks: [], added: 0, removed: 0, changed: 0)

fn diff_result_summary(result: DiffResult) -> text:
    "+" + result.added.to_text() + " -" + result.removed.to_text() + " ~" + result.changed.to_text()
