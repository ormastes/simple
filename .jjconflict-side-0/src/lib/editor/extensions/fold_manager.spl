# Editor Fold Manager Extension
#
# Code folding: tracks folded regions, toggles folds, and computes
# visible line ranges for rendering.

struct FoldRegion:
    start_line: i64
    end_line: i64
    folded: bool
    kind: text

struct FoldManager:
    regions: [FoldRegion]

fn fold_manager_new() -> FoldManager:
    FoldManager(regions: [])

fn fold_manager_add_region(manager: FoldManager, start_line: i64, end_line: i64, kind: text) -> FoldManager:
    var regions = manager.regions
    regions.push(FoldRegion(start_line: start_line, end_line: end_line, folded: false, kind: kind))
    FoldManager(regions: regions)

fn fold_manager_toggle(manager: FoldManager, line: i64) -> FoldManager:
    var regions: [FoldRegion] = []
    for r in manager.regions:
        if r.start_line == line:
            regions.push(FoldRegion(
                start_line: r.start_line,
                end_line: r.end_line,
                folded: not r.folded,
                kind: r.kind
            ))
        else:
            regions.push(r)
    FoldManager(regions: regions)

fn fold_manager_is_folded(manager: FoldManager, line: i64) -> bool:
    for r in manager.regions:
        if r.start_line == line and r.folded:
            return true
    false

fn fold_manager_is_hidden(manager: FoldManager, line: i64) -> bool:
    for r in manager.regions:
        if r.folded and line > r.start_line and line <= r.end_line:
            return true
    false
