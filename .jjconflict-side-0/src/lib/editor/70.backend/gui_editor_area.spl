# Lightweight editor-area GUI renderer for embeddable examples and smoke tests.

use std.editor.buffer.buffer.{EditorBuffer}
use std.editor.common.types.{EditorViewport}

fn gui_render_editor_area_basic(buffer: EditorBuffer, language_id: text, viewport: EditorViewport) -> text:
    val escaped_language = _gui_editor_area_escape_html(language_id)
    var html = "<div class=\"editor-area gui-editor-source\" role=\"textbox\" contenteditable=\"true\" spellcheck=\"false\" data-language=\"" + escaped_language + "\">"
    var row = 0
    while row < viewport.height:
        val file_row = buffer.visible_line_at(row)
        if file_row >= 0 and file_row < buffer.line_count():
            val active_class = if file_row == buffer.cursor_row then " active-line" else: ""
            val line_num = str(file_row + 1)
            val line_content = _gui_editor_area_escape_html(buffer.line_at(file_row))
            html = html + "<div class=\"line" + active_class + "\" data-line=\"" + str(file_row) + "\"><span class=\"line-num\">" + line_num + "</span><span class=\"content\">" + line_content + "</span></div>"
        row = row + 1
    html + "</div>"

fn _gui_editor_area_escape_html(value: text) -> text:
    value
        .replace("&", "&amp;")
        .replace("<", "&lt;")
        .replace(">", "&gt;")
        .replace("\"", "&quot;")
