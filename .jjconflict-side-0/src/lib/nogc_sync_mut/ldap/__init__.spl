# LDAP module — RFC 4511 (ASN.1 BER over TCP) + LDAPS secure wrapper.
# Re-exports the public surface for `use std.nogc_sync_mut.ldap.*`.

use std.nogc_sync_mut.ldap.types.{
    LDAP_TAG_BIND_REQUEST, LDAP_TAG_BIND_RESPONSE, LDAP_TAG_UNBIND_REQUEST,
    LDAP_TAG_SEARCH_REQUEST, LDAP_TAG_SEARCH_RES_ENTRY, LDAP_TAG_SEARCH_RES_DONE,
    LDAP_TAG_AUTH_SIMPLE, LDAP_TAG_ENUMERATED,
    LDAP_FILTER_TAG_AND, LDAP_FILTER_TAG_OR, LDAP_FILTER_TAG_NOT,
    LDAP_FILTER_TAG_EQUALITY, LDAP_FILTER_TAG_PRESENT,
    LDAP_OP_BIND_REQUEST, LDAP_OP_BIND_RESPONSE, LDAP_OP_UNBIND_REQUEST,
    LDAP_OP_SEARCH_REQUEST, LDAP_OP_SEARCH_RES_ENTRY, LDAP_OP_SEARCH_RES_DONE,
    LDAP_OP_UNKNOWN,
    LDAP_RESULT_SUCCESS, LDAP_RESULT_PROTOCOL_ERROR, LDAP_RESULT_NO_SUCH_OBJECT,
    LDAP_RESULT_INVALID_CREDENTIALS, LDAP_RESULT_SIZE_LIMIT_EXCEEDED,
    LDAP_RESULT_TIME_LIMIT_EXCEEDED, LDAP_RESULT_OTHER,
    LDAP_SCOPE_BASE_OBJECT, LDAP_SCOPE_SINGLE_LEVEL, LDAP_SCOPE_WHOLE_SUBTREE,
    LDAP_DEREF_NEVER, LDAP_DEREF_ALWAYS,
    LDAP_FILTER_AND, LDAP_FILTER_OR, LDAP_FILTER_NOT,
    LDAP_FILTER_EQUALITY, LDAP_FILTER_PRESENT,
    LDAP_AUTH_SIMPLE, LDAP_AUTH_SASL,
    LdapDn, LdapAttribute, LdapEntry, LdapFilter, LdapResult, LdapControl,
    LdapBindRequest, LdapBindResponse, LdapSearchRequest, LdapSearchResultDone,
    LdapUnbindRequest, LdapMessage, LdapSession,
    ldap_op_kind_of_tag
}

use std.nogc_sync_mut.ldap.build.{
    ldap_text_bytes,
    ldap_tlv, ldap_tlv_bytes,
    ldap_encode_integer, ldap_encode_enumerated, ldap_encode_octet_string,
    ldap_encode_text, ldap_encode_boolean,
    ldap_encode_filter, ldap_encode_filter_bytes,
    ldap_encode_bind_request_bytes, ldap_encode_search_request_bytes,
    ldap_encode_unbind_request_bytes, ldap_encode_bind_response_bytes,
    ldap_encode_search_done_bytes, ldap_encode_search_entry_bytes,
    ldap_encode_message, ldap_encode_bind_request, ldap_encode_search_request,
    ldap_encode_unbind_request
}

use std.nogc_sync_mut.ldap.parse.{
    LdapTlvHeader, LdapDecodedMessage,
    ldap_read_tlv_header, ldap_slice, ldap_decode_int_content, ldap_bytes_to_text,
    ldap_parse_message, ldap_decode_result, ldap_decode_bind_request,
    ldap_decode_filter, ldap_decode_search_request, ldap_decode_search_entry
}

use std.nogc_sync_mut.ldap.secure.{
    LDAPS_DEFAULT_PORT, LDAP_DEFAULT_PORT, LDAP_STARTTLS_OID,
    TlsSessionHandle, LdapsSession,
    ldaps_default_port, ldap_default_port, ldap_starttls_oid
}

