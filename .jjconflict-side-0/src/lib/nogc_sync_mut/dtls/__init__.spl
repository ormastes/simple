# DTLS datagram framing facade (RFC 6347 / RFC 9147).
#
# A typed datagram-framing layer over the existing TLS module. DTLS reuses the
# TLS content-type / handshake-type constants and the TLS handshake & cipher
# functions (composition, not type inheritance -- no struct TlsRecord exists);
# this module adds the genuinely-new record framing, handshake fragmentation,
# and DTLS 1.3 unified header. Anti-replay is the shared common.net type.

export use std.nogc_sync_mut.dtls.types.{DtlsRecord12, DtlsHandshakeFragment, DtlsRecord13}
export use std.nogc_sync_mut.dtls.types.{DTLS_VERSION_1_0, DTLS_VERSION_1_2, DTLS_VERSION_1_3_LEGACY}
export use std.nogc_sync_mut.dtls.types.{DTLS_CONTENT_TYPE_CHANGE_CIPHER_SPEC, DTLS_CONTENT_TYPE_ALERT, DTLS_CONTENT_TYPE_HANDSHAKE, DTLS_CONTENT_TYPE_APPLICATION_DATA, DTLS_CONTENT_TYPE_ACK}
export use std.nogc_sync_mut.dtls.types.{DTLS13_UNIFIED_FIXED_BITS, DTLS13_FLAG_CID, DTLS13_FLAG_SEQ16, DTLS13_FLAG_LENGTH, DTLS13_EPOCH_MASK}
export use std.nogc_sync_mut.dtls.build.{build_dtls_record12, build_dtls_handshake_fragment, build_dtls_record13}
export use std.nogc_sync_mut.dtls.parse.{parse_dtls_record12, parse_dtls_handshake_fragment, parse_dtls_record13}
