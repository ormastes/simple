# std.play.locator — Locator class
#
# Chainable element descriptor. Does NOT resolve eagerly — each action
# (click, fill, type, press, text_content) runs a fresh querySelector so
# the locator works across navigations and re-renders (matches Playwright).

use std.play.cdp.session.{CdpSession}
use std.play.types.{PlayError, LocatorSpec, locator_css, ClickOptions, FillOptions, TypeOptions, PressOptions}

class Locator:
    session: CdpSession
    spec: LocatorSpec

    me _css_selector() -> text:
        if self.spec.strategy == "css":
            return self.spec.selector
        if self.spec.strategy == "test-id":
            return "[data-testid=\"" + self.spec.selector + "\"]"
        if self.spec.strategy == "text":
            return ":has-text(\"" + self.spec.selector + "\")"
        if self.spec.strategy == "role":
            return "[role=\"" + self.spec.selector + "\"]"
        self.spec.selector

    me click() -> Result<(), PlayError>:
        self.session.click_selector(self._css_selector(), "left", 1, 0)

    me click_with(options: ClickOptions) -> Result<(), PlayError>:
        self.session.click_selector(self._css_selector(), options.button, options.click_count, 0)

    me dblclick() -> Result<(), PlayError>:
        self.session.click_selector(self._css_selector(), "left", 2, 0)

    me fill(value: text) -> Result<(), PlayError>:
        self.session.fill_selector(self._css_selector(), value)

    me type_text(value: text) -> Result<(), PlayError>:
        self.session.type_selector(self._css_selector(), value, 0)

    me type_with(value: text, delay_ms: i64) -> Result<(), PlayError>:
        self.session.type_selector(self._css_selector(), value, delay_ms)

    me press(key: text) -> Result<(), PlayError>:
        self.session.press_selector(self._css_selector(), key, 0)

    me focus() -> Result<(), PlayError>:
        self.session.focus_selector(self._css_selector())

    me text_content() -> Result<text, PlayError>:
        self.session.text_content(self._css_selector())

    me inner_text() -> Result<text, PlayError>:
        self.session.text_content(self._css_selector())

    me wait_for() -> Result<(), PlayError>:
        self.session.wait_for_selector(self._css_selector(), 30000)

    me wait_for_with(timeout_ms: i64) -> Result<(), PlayError>:
        self.session.wait_for_selector(self._css_selector(), timeout_ms)

    me count() -> Result<i64, PlayError>:
        val js = "document.querySelectorAll('" + self._css_selector() + "').length"
        val body = self.session.evaluate(js)?
        if not body.contains("\"value\":"): return Ok(0)
        val parts = body.split("\"value\":")
        if parts.length() < 2: return Ok(0)
        val rest = parts[1].trim()
        val num_str = rest.split(",")[0].split("}")[0].split("]")[0].trim()
        if num_str == "": return Ok(0)
        Ok(int(num_str))

    me is_visible() -> Result<bool, PlayError>:
        val js = "(() => { const el = document.querySelector('" + self._css_selector() + "'); if (!el) return false; const r = el.getBoundingClientRect(); return r.width > 0 && r.height > 0; })()"
        val body = self.session.evaluate(js)?
        Ok(body.contains("\"value\":true"))

    me get_by_role(role: text, name: text) -> Locator:
        Locator(
            session: self.session,
            spec: LocatorSpec(selector: role, strategy: "role", nth: -1, has_text: name, has_not_text: "")
        )

    me get_by_text(value: text) -> Locator:
        Locator(
            session: self.session,
            spec: LocatorSpec(selector: value, strategy: "text", nth: -1, has_text: "", has_not_text: "")
        )

    me get_by_test_id(tid: text) -> Locator:
        Locator(
            session: self.session,
            spec: LocatorSpec(selector: tid, strategy: "test-id", nth: -1, has_text: "", has_not_text: "")
        )

    me locator(selector: text) -> Locator:
        Locator(session: self.session, spec: locator_css(self._css_selector() + " " + selector))

    me nth(index: i64) -> Locator:
        var spec = self.spec
        spec.nth = index
        Locator(session: self.session, spec: spec)
