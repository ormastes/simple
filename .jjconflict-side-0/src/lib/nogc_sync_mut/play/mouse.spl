@allow(primitive_api)
# std.play.mouse — Mouse class (mirrors Playwright's Page.mouse)

use std.play.cdp.client.{CdpClient}
use std.play.cdp.domains.{cdp_input_dispatch_mouse, cdp_modifiers_from}
use std.play.types.{PlayError}

class Mouse:
    client: CdpClient
    session_id: text
    x: f64
    y: f64

    me move(x: f64, y: f64) -> Result<(), PlayError>:
        cdp_input_dispatch_mouse(self.client, self.session_id, "mouseMoved", x, y, "none", 0, 0)?
        self.x = x
        self.y = y
        Ok(())

    me down() -> Result<(), PlayError>:
        cdp_input_dispatch_mouse(self.client, self.session_id, "mousePressed", self.x, self.y, "left", 1, 0)?
        Ok(())

    me down_with(button: text) -> Result<(), PlayError>:
        cdp_input_dispatch_mouse(self.client, self.session_id, "mousePressed", self.x, self.y, button, 1, 0)?
        Ok(())

    me up() -> Result<(), PlayError>:
        cdp_input_dispatch_mouse(self.client, self.session_id, "mouseReleased", self.x, self.y, "left", 1, 0)?
        Ok(())

    me up_with(button: text) -> Result<(), PlayError>:
        cdp_input_dispatch_mouse(self.client, self.session_id, "mouseReleased", self.x, self.y, button, 1, 0)?
        Ok(())

    me click(x: f64, y: f64) -> Result<(), PlayError>:
        self.move(x, y)?
        cdp_input_dispatch_mouse(self.client, self.session_id, "mousePressed", x, y, "left", 1, 0)?
        cdp_input_dispatch_mouse(self.client, self.session_id, "mouseReleased", x, y, "left", 1, 0)?
        Ok(())

    me click_with(x: f64, y: f64, button: text, click_count: i64, modifiers: [text]) -> Result<(), PlayError>:
        val m = cdp_modifiers_from(modifiers)
        self.move(x, y)?
        cdp_input_dispatch_mouse(self.client, self.session_id, "mousePressed", x, y, button, click_count, m)?
        cdp_input_dispatch_mouse(self.client, self.session_id, "mouseReleased", x, y, button, click_count, m)?
        Ok(())

    me dblclick(x: f64, y: f64) -> Result<(), PlayError>:
        self.move(x, y)?
        cdp_input_dispatch_mouse(self.client, self.session_id, "mousePressed", x, y, "left", 2, 0)?
        cdp_input_dispatch_mouse(self.client, self.session_id, "mouseReleased", x, y, "left", 2, 0)?
        Ok(())

    me wheel(delta_x: f64, delta_y: f64) -> Result<(), PlayError>:
        cdp_input_dispatch_mouse(self.client, self.session_id, "mouseWheel", self.x, self.y, "none", 0, 0)?
        Ok(())
