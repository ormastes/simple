@allow(primitive_api)
# std.play — Shared Types
#
# Foundation types for the Playwright-compatible automation library.
# Every other module in std.play imports from here.
#
# Design: mirror Playwright's public surface names (LaunchOptions,
# ClickOptions, ScreenshotOptions, ExpectOptions). Method names are
# snake_case to match Simple's stdlib convention and Python Playwright.
#
# Backend kinds (BACKEND_*):
#   cdp    — Chrome DevTools Protocol over WebSocket (Electron/VS Code/Chromium)
#   sdl2   — Simple OS env; drives Simple-native SDL2 apps via ui.test_api HTTP
#   wm     — Native OS window manager via platform CLI shell-out
#   orchestrator — Phase 1 subprocess wrapper around npm/playwright/vscode-test

# ============================================================================
# Backend Kind Constants
# ============================================================================

val BACKEND_CDP = "cdp"
val BACKEND_SDL2 = "sdl2"
val BACKEND_WM = "wm"
val BACKEND_ORCHESTRATOR = "orchestrator"

# ============================================================================
# Session State Constants
# ============================================================================

val STATE_CONFIGURED = "configured"
val STATE_LAUNCHING = "launching"
val STATE_READY = "ready"
val STATE_CLOSING = "closing"
val STATE_CLOSED = "closed"
val STATE_FAILED = "failed"

# ============================================================================
# Default Timeouts (milliseconds)
# ============================================================================

val DEFAULT_EXPECT_TIMEOUT_MS = 5000
val DEFAULT_ACTION_TIMEOUT_MS = 30000
val DEFAULT_NAVIGATION_TIMEOUT_MS = 30000
val DEFAULT_LAUNCH_TIMEOUT_MS = 30000
val DEFAULT_POLL_INTERVAL_MS = 100

# ============================================================================
# Option Structs — 1:1 mirror of Playwright's named options
# ============================================================================

struct LaunchOptions:
    executable_path: text
    args: [text]
    env: [(text, text)]
    cwd: text
    headless: bool
    timeout_ms: i64
    xvfb: bool
    remote_debugging_port: i64
    record_video_dir: text
    trace_dir: text

fn default_launch_options() -> LaunchOptions:
    LaunchOptions(
        executable_path: "",
        args: [],
        env: [],
        cwd: "",
        headless: false,
        timeout_ms: DEFAULT_LAUNCH_TIMEOUT_MS,
        xvfb: true,
        remote_debugging_port: 0,
        record_video_dir: "",
        trace_dir: ""
    )

struct ClickOptions:
    button: text
    click_count: i64
    delay_ms: i64
    modifiers: [text]
    position_x: f64
    position_y: f64
    timeout_ms: i64
    force: bool
    no_wait_after: bool

fn default_click_options() -> ClickOptions:
    ClickOptions(
        button: "left",
        click_count: 1,
        delay_ms: 0,
        modifiers: [],
        position_x: -1.0,
        position_y: -1.0,
        timeout_ms: DEFAULT_ACTION_TIMEOUT_MS,
        force: false,
        no_wait_after: false
    )

struct FillOptions:
    timeout_ms: i64
    force: bool
    no_wait_after: bool

fn default_fill_options() -> FillOptions:
    FillOptions(timeout_ms: DEFAULT_ACTION_TIMEOUT_MS, force: false, no_wait_after: false)

struct TypeOptions:
    delay_ms: i64
    timeout_ms: i64
    no_wait_after: bool

fn default_type_options() -> TypeOptions:
    TypeOptions(delay_ms: 0, timeout_ms: DEFAULT_ACTION_TIMEOUT_MS, no_wait_after: false)

struct PressOptions:
    delay_ms: i64
    timeout_ms: i64
    no_wait_after: bool

fn default_press_options() -> PressOptions:
    PressOptions(delay_ms: 0, timeout_ms: DEFAULT_ACTION_TIMEOUT_MS, no_wait_after: false)

struct ScreenshotOptions:
    path: text
    full_page: bool
    omit_background: bool
    quality: i64
    image_type: text
    clip_x: f64
    clip_y: f64
    clip_width: f64
    clip_height: f64
    timeout_ms: i64

fn default_screenshot_options() -> ScreenshotOptions:
    ScreenshotOptions(
        path: "",
        full_page: false,
        omit_background: false,
        quality: 90,
        image_type: "png",
        clip_x: -1.0,
        clip_y: -1.0,
        clip_width: -1.0,
        clip_height: -1.0,
        timeout_ms: DEFAULT_ACTION_TIMEOUT_MS
    )

struct ExpectOptions:
    timeout_ms: i64
    poll_interval_ms: i64
    message: text

fn default_expect_options() -> ExpectOptions:
    ExpectOptions(
        timeout_ms: DEFAULT_EXPECT_TIMEOUT_MS,
        poll_interval_ms: DEFAULT_POLL_INTERVAL_MS,
        message: ""
    )

struct WaitForOptions:
    state: text
    timeout_ms: i64

fn default_wait_for_options() -> WaitForOptions:
    WaitForOptions(state: "visible", timeout_ms: DEFAULT_ACTION_TIMEOUT_MS)

# ============================================================================
# Backend-neutral window descriptor
# ============================================================================

struct WindowInfo:
    window_id: text
    target_id: text
    title: text
    url: text
    width: i64
    height: i64
    focused: bool

fn empty_window_info() -> WindowInfo:
    WindowInfo(
        window_id: "",
        target_id: "",
        title: "",
        url: "",
        width: 0,
        height: 0,
        focused: false
    )

# ============================================================================
# PlaySession — The central session handle
#
# Mirrors DapSession (src/app/mcp/dap_bridge.spl). One PlaySession per
# launched application, regardless of backend.
# ============================================================================

struct PlaySession:
    id: text
    backend: text
    state: text
    pid: i64
    cwd: text
    executable_path: text
    args: [text]
    ws_url: text
    http_url: text
    artifacts_dir: text
    first_window_id: text
    windows: [WindowInfo]
    created_at_us: i64
    last_activity_us: i64
    stdout_path: text
    stderr_path: text
    console_log_path: text
    cdp_trace_path: text

fn empty_play_session() -> PlaySession:
    PlaySession(
        id: "",
        backend: "",
        state: STATE_CLOSED,
        pid: -1,
        cwd: "",
        executable_path: "",
        args: [],
        ws_url: "",
        http_url: "",
        artifacts_dir: "",
        first_window_id: "",
        windows: [],
        created_at_us: 0,
        last_activity_us: 0,
        stdout_path: "",
        stderr_path: "",
        console_log_path: "",
        cdp_trace_path: ""
    )

# ============================================================================
# PlayError — structured error type
# ============================================================================

struct PlayError:
    code: text
    message: text
    detail: text

fn play_error(code: text, message: text) -> PlayError:
    PlayError(code: code, message: message, detail: "")

fn play_error_with_detail(code: text, message: text, detail: text) -> PlayError:
    PlayError(code: code, message: message, detail: detail)

val ERR_LAUNCH_FAILED = "LAUNCH_FAILED"
val ERR_TIMEOUT = "TIMEOUT"
val ERR_NOT_FOUND = "NOT_FOUND"
val ERR_CDP_PROTOCOL = "CDP_PROTOCOL"
val ERR_CDP_TRANSPORT = "CDP_TRANSPORT"
val ERR_SESSION_CLOSED = "SESSION_CLOSED"
val ERR_BACKEND_UNAVAILABLE = "BACKEND_UNAVAILABLE"
val ERR_INVALID_ARGUMENT = "INVALID_ARGUMENT"
val ERR_ASSERTION = "ASSERTION"

# ============================================================================
# Locator descriptor (backend-neutral)
# ============================================================================

struct LocatorSpec:
    selector: text
    strategy: text
    nth: i64
    has_text: text
    has_not_text: text

fn locator_css(selector: text) -> LocatorSpec:
    LocatorSpec(selector: selector, strategy: "css", nth: -1, has_text: "", has_not_text: "")

fn locator_xpath(expr: text) -> LocatorSpec:
    LocatorSpec(selector: expr, strategy: "xpath", nth: -1, has_text: "", has_not_text: "")

fn locator_role(role: text, name: text) -> LocatorSpec:
    LocatorSpec(
        selector: role,
        strategy: "role",
        nth: -1,
        has_text: name,
        has_not_text: ""
    )

fn locator_text(text_value: text) -> LocatorSpec:
    LocatorSpec(
        selector: text_value,
        strategy: "text",
        nth: -1,
        has_text: "",
        has_not_text: ""
    )

fn locator_test_id(tid: text) -> LocatorSpec:
    LocatorSpec(selector: tid, strategy: "test-id", nth: -1, has_text: "", has_not_text: "")
