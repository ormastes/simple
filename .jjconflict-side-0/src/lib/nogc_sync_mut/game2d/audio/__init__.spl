# std.game2d.audio — Tier-0 sound stub (Wave B)
#
# No audio extern is wired this iteration. `Sound::new(path)` records the
# path for later wiring; `play(sound)` returns `Err(AudioBackendMissing)`.
# Wave-C may wrap `nogc_sync_mut/io/audio_*` if it exists; until then the
# stub keeps the surface stable so AC-1 demos compile.

# AudioError — game2d/audio diagnostic family GAME-AUDIO-NNN
class AudioError:
    code: text
    msg: text

    static fn backend_missing() -> AudioError:
        # GAME-AUDIO-001 — audio backend not yet wired.
        AudioError(
            code: "GAME-AUDIO-001",
            msg: "audio backend not wired (Wave-B Tier-0 stub)"
        )

    static fn missing_file(path: text) -> AudioError:
        AudioError(
            code: "GAME-AUDIO-002",
            msg: "Sound::new could not find file: {path}"
        )


class Sound:
    path: text

    static fn new(path: text) -> Result<Sound, AudioError>:
        if path.len() == 0:
            return Err(AudioError.missing_file(path))
        Ok(Sound(path: path))

    static fn null() -> Sound:
        Sound(path: "")

    fn is_null() -> bool:
        self.path.len() == 0


fn play(s: Sound) -> Result<i64, AudioError>:
    """Tier-0 stub — no audio backend wired this iteration. Always returns
    GAME-AUDIO-001. Once Wave C lands an audio backend this becomes a real
    enqueue.
    """
    val _ = s
    Err(AudioError.backend_missing())
