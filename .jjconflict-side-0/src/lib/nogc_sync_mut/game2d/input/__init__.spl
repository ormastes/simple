# Game2D input module — `std.nogc_sync_mut.game2d.input`
#
# Re-exports `InputSnapshot`, the `Key`/`MouseButton` aliases (which forward
# to engine `KeyCode`/`MouseButtonId`), and the `g.input.*` accessor
# wrappers. Wave-A scope: data + accessors. Wave-B will add `freeze_from`
# overloads that read the live engine `InputManager`.

export snapshot.*
export keys.*
export api.*
