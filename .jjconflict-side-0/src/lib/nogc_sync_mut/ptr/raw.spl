"""
# Raw Pointer Runtime Backend

No-GC sync owner for low-level raw allocation, pointer access, and scalar bit
conversion helpers used by backend SFFI adapters.
"""

pub extern fn rt_alloc(size: i64) -> i64
pub extern fn rt_free(ptr: i64, size: i64)
pub extern fn rt_ptr_read_i64(addr: i64, offset: i64) -> i64
pub extern fn rt_ptr_read_i32(addr: i64, offset: i64) -> i32
pub extern fn rt_ptr_write_i64(addr: i64, offset: i64, value: i64)
pub extern fn f32_from_bits(bits: u32) -> f32
pub extern fn spl_f64_to_bits(value: f64) -> i64
pub extern fn spl_bits_to_f64(bits: i64) -> f64

export rt_alloc, rt_free, rt_ptr_read_i64, rt_ptr_read_i32, rt_ptr_write_i64, f32_from_bits, spl_f64_to_bits, spl_bits_to_f64
