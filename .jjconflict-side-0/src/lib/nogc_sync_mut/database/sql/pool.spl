# Typed SQL Database Library - SQLite Connection Pool
#
# SQLite WAL mode allows N concurrent readers + 1 writer.
# Pool manages parallel arrays: readers[] + reader_in_use[] + one writer slot.

use std.database.sql.types.{DbError, DbValue, DbRow}
use std.database.sql.connection.{Database}

# ============================================================================
# SqlitePoolConfig — pool sizing and timeout parameters
# ============================================================================

struct SqlitePoolConfig:
    max_readers: i64
    idle_timeout_ms: i64
    acquire_timeout_ms: i64

fn pool_config_default() -> SqlitePoolConfig:
    SqlitePoolConfig(
        max_readers: 4,
        idle_timeout_ms: 30000,
        acquire_timeout_ms: 5000,
    )

# ============================================================================
# PoolStats — snapshot of current pool utilization
# ============================================================================

struct PoolStats:
    active_readers: i64
    active_writer: bool
    idle_count: i64
    total_acquired: i64
    total_released: i64

# ============================================================================
# SqlitePool — manages reader + writer Database connections
# ============================================================================

class SqlitePool:
    path: text
    config: SqlitePoolConfig
    readers: [Database]
    reader_in_use: [bool]
    writer: Database
    writer_in_use: bool
    total_acquired: i64
    total_released: i64
    # Guards against double-release and tracks leaked connections
    leaked_connections: i64

    static fn open(path: text, config: SqlitePoolConfig) -> Result<SqlitePool, DbError>:
        val writer = Database.open(path)?

        var readers: [Database] = []
        var reader_in_use: [bool] = []
        var i = 0
        while i < config.max_readers:
            val r = Database.open(path)?
            readers.push(r)
            reader_in_use.push(false)
            i = i + 1

        Ok(SqlitePool(
            path: path,
            config: config,
            readers: readers,
            reader_in_use: reader_in_use,
            writer: writer,
            writer_in_use: false,
            total_acquired: 0,
            total_released: 0,
            leaked_connections: 0,
        ))

    # ------------------------------------------------------------------
    # Acquire a reader connection. Returns Err if all are busy.
    # Caller must call release_reader(index) when done.
    # ------------------------------------------------------------------
    me acquire_reader() -> Result<i64, DbError>:
        var i = 0
        while i < self.reader_in_use.len():
            if not self.reader_in_use[i]:
                self.reader_in_use[i] = true
                self.total_acquired = self.total_acquired + 1
                return Ok(i)
            i = i + 1
        Err(DbError.Other(message: "pool: all reader connections are busy"))

    me release_reader(index: i64):
        if (index >= 0 and index < self.reader_in_use.len()):
            if self.reader_in_use[index]:
                self.reader_in_use[index] = false
                self.total_released = self.total_released + 1
            else:
                # Double-release detected: count it so callers can audit
                self.leaked_connections = self.leaked_connections + 1

    # ------------------------------------------------------------------
    # Acquire the writer connection. Returns Err if already in use.
    # ------------------------------------------------------------------
    me acquire_writer() -> Result<(), DbError>:
        if self.writer_in_use:
            return Err(DbError.Other(message: "pool: writer connection is already in use"))
        self.writer_in_use = true
        self.total_acquired = self.total_acquired + 1
        Ok(())

    me release_writer():
        if self.writer_in_use:
            self.writer_in_use = false
            self.total_released = self.total_released + 1
        else:
            # Double-release detected
            self.leaked_connections = self.leaked_connections + 1

    # ------------------------------------------------------------------
    # Execute a read query on an available reader.
    # ------------------------------------------------------------------
    me query_with_reader(sql: text, params: [DbValue]) -> Result<[DbRow], DbError>:
        val idx = self.acquire_reader()?
        val result = self.readers[idx].query(sql, params)
        self.release_reader(idx)
        result

    # ------------------------------------------------------------------
    # Execute a write on the writer connection.
    # ------------------------------------------------------------------
    me exec_with_writer(sql: text, params: [DbValue]) -> Result<i64, DbError>:
        self.acquire_writer()?
        val result = self.writer.exec(sql, params)
        self.release_writer()
        result

    # ------------------------------------------------------------------
    # Health check — ping each connection with SELECT 1.
    # Returns false if any connection is unhealthy.
    # ------------------------------------------------------------------
    fn health_ping() -> bool:
        val wr = self.writer.query("SELECT 1", [])
        match wr:
            Err(_): return false
            Ok(_): nil
        var i = 0
        while i < self.readers.len():
            val rr = self.readers[i].query("SELECT 1", [])
            match rr:
                Err(_): return false
                Ok(_): nil
            i = i + 1
        true

    fn stats() -> PoolStats:
        var active = 0
        var i = 0
        while i < self.reader_in_use.len():
            if self.reader_in_use[i]:
                active = active + 1
            i = i + 1
        val idle = self.reader_in_use.len() - active
        PoolStats(
            active_readers: active,
            active_writer: self.writer_in_use,
            idle_count: idle,
            total_acquired: self.total_acquired,
            total_released: self.total_released,
        )

    # ------------------------------------------------------------------
    # Safety: force-release all connections back to the pool.
    # Use only in shutdown or after catching a panic-equivalent error.
    # ------------------------------------------------------------------
    me force_release_all():
        var i = 0
        while i < self.reader_in_use.len():
            if self.reader_in_use[i]:
                self.reader_in_use[i] = false
                self.total_released = self.total_released + 1
            i = i + 1
        if self.writer_in_use:
            self.writer_in_use = false
            self.total_released = self.total_released + 1

    # Return true when at least one double-release anomaly was detected.
    fn has_leaked_connections() -> bool:
        self.leaked_connections > 0

    # Return the accumulated double-release anomaly count.
    fn leaked_count() -> i64:
        self.leaked_connections

    # ------------------------------------------------------------------
    # Close all connections. Call when pool is no longer needed.
    # ------------------------------------------------------------------
    me close() -> Result<(), DbError>:
        self.writer.close()?
        var i = 0
        while i < self.readers.len():
            self.readers[i].close()?
            i = i + 1
        Ok(())
