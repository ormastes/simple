# Requirement Database - lightweight in-memory requirement index

extern fn rt_file_write_text(path: text, content: text) -> bool

struct Requirement:
    id: text
    title: text
    category: text
    status: text
    priority: text
    doc_path: text
    plan_path: text
    design_path: text
    system_test: text
    created_at: text
    updated_at: text
    valid: bool

class RequirementDatabase:
    requirements: [Requirement]
    description_ids: [text]
    descriptions: [text]
    path: text

    static fn create() -> RequirementDatabase:
        RequirementDatabase(
            requirements: [],
            description_ids: [],
            descriptions: [],
            path: "/tmp/test_reqdb_save.sdn"
        )

    me add_requirement(req: Requirement):
        self.requirements.push(req)

    fn get_requirement(id: text) -> Requirement:
        for req in self.requirements:
            if req.valid and req.id == id:
                return req
        _empty_requirement()

    fn all_requirements() -> [Requirement]:
        var result: [Requirement] = []
        for req in self.requirements:
            if req.valid:
                result.push(req)
        result

    fn requirements_by_status(status: text) -> [Requirement]:
        var result: [Requirement] = []
        for req in self.requirements:
            if req.valid and req.status == status:
                result.push(req)
        result

    fn requirements_by_category(category: text) -> [Requirement]:
        var result: [Requirement] = []
        for req in self.requirements:
            if req.valid and req.category == category:
                result.push(req)
        result

    fn next_id() -> text:
        _format_req_id(self.requirements.len() + 1)

    me add_description(id: text, description: text):
        var i = 0
        while i < self.description_ids.len():
            if self.description_ids[i] == id:
                self.descriptions[i] = description
                return
            i = i + 1
        self.description_ids.push(id)
        self.descriptions.push(description)

    fn get_description(id: text) -> text:
        var i = 0
        while i < self.description_ids.len():
            if self.description_ids[i] == id:
                return self.descriptions[i]
            i = i + 1
        ""

    fn save() -> bool:
        rt_file_write_text(self.path, _serialize_requirements(self.requirements))

fn _empty_requirement() -> Requirement:
    Requirement(
        id: "",
        title: "",
        category: "",
        status: "",
        priority: "",
        doc_path: "",
        plan_path: "",
        design_path: "",
        system_test: "",
        created_at: "",
        updated_at: "",
        valid: false
    )

fn _format_req_id(n: i64) -> text:
    if n < 10:
        return "REQ-00{n}"
    if n < 100:
        return "REQ-0{n}"
    "REQ-{n}"

fn _serialize_requirements(requirements: [Requirement]) -> text:
    var lines: [text] = []
    lines.push("requirements |id, title, category, status, priority, doc_path, plan_path, design_path, system_test, created_at, updated_at, valid")
    for req in requirements:
        lines.push("    {req.id}, \"{req.title}\", {req.category}, {req.status}, {req.priority}, \"{req.doc_path}\", \"{req.plan_path}\", \"{req.design_path}\", \"{req.system_test}\", {req.created_at}, {req.updated_at}, {req.valid}")
    lines.join("\n") + "\n"
