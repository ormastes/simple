        value,
        state,
        backend,
        expected_backend_generation,
        cpu_fallback_available,
        budget,
        gpu_candidate_document_ids,
        started_us,
        finished_us,
        measured_device_time_us,
        timing_source
    )

fn db_query_offload_execute_vector_validated(request: DbQueryOffloadRequest,
                                            state: GpuWdbQueueState,
                                            registry: GpuWdbLibraryRegistry,
                                            gpu_available: bool,
                                            cpu_fallback_available: bool,
                                            budget: GpuWdbBudget,
                                            gpu_candidate_results: [SearchResult]) -> DbStorageOffloadExecution:
    if request.workload != DbStorageOffloadWorkload.VectorSearch:
        return db_query_cpu_fallback(request, "query-mode-workload-mismatch", state)
    db_storage_execute_vector_validated(
        request.metric,
        request.item_count,
        request.dimensions,
        request.metadata_filter_cpu_owned,
        state,
        registry,
        gpu_available,
        request.wal_generation_current,
        cpu_fallback_available,
        budget,
        request.cpu_vector_results,
        gpu_candidate_results
    )

fn db_query_offload_execute_vector_device_validated(request: DbQueryOffloadRequest,
                                                   state: GpuWdbQueueState,
                                                   backend: GpuWdbDeviceBackend,
                                                   expected_backend_generation: i64,
                                                   cpu_fallback_available: bool,
                                                   budget: GpuWdbBudget,
                                                   gpu_candidate_results: [SearchResult],
                                                   started_us: i64,
                                                   finished_us: i64,
                                                   measured_device_time_us: i64,
                                                   timing_source: text) -> DbStorageVectorDeviceOffloadExecution:
    if request.workload != DbStorageOffloadWorkload.VectorSearch:
        return DbStorageVectorDeviceOffloadExecution(
            execution: db_query_cpu_fallback(request, "query-mode-workload-mismatch", state),
            device_result: gpu_wdb_run_device_batch(
                state,
                backend,
                GpuWdbWorkKind.DbVectorSearch,
                0,
                0,
                -1,
                cpu_fallback_available,
                budget,
                started_us,
                finished_us,
                measured_device_time_us,
                timing_source
            )
        )
    db_storage_execute_vector_with_device_backend_validated(
        request.metric,
        request.item_count,
        request.dimensions,
        request.metadata_filter_cpu_owned,
        state,
        backend,
        request.wal_generation_current,
        expected_backend_generation,
        cpu_fallback_available,
        budget,
        request.cpu_vector_results,
        gpu_candidate_results,
        started_us,
        finished_us,
        measured_device_time_us,
        timing_source
    )

fn db_query_join_aggregate_count_execute(request: DbQueryOffloadRequest,
                                         cpu_count: i64,
                                         state: GpuWdbQueueState,
                                         registry: GpuWdbLibraryRegistry,
                                         gpu_available: bool,
                                         cpu_fallback_available: bool,
                                         budget: GpuWdbBudget) -> DbQueryAggregateOffloadExecution:
    DbQueryAggregateOffloadExecution(
        operator: "join_aggregate_count",
        count: cpu_count,
        row_ids: request.cpu_row_ids,
        offload: db_query_offload_execute(
            request,
            state,
            registry,
            gpu_available,
            cpu_fallback_available,
            budget
        )
    )

fn db_query_offload_execute_scheduled(request: DbQueryOffloadRequest,
                                      state: GpuWdbQueueState,
                                      registry: GpuWdbLibraryRegistry,
                                      gpu_available: bool,
                                      cpu_fallback_available: bool,
                                      budget: GpuWdbBudget,
                                      schedule_class: GpuWdbScheduleClass,
                                      allow_defer: bool) -> DbStorageOffloadExecution:
    if not db_query_mode_matches_workload(request.mode, request.workload):
        return db_query_cpu_fallback(request, "query-mode-workload-mismatch", state)

    val snapshot = GpuWdbRuntimeSnapshot(
        queue_depth: state.queue_depth,
        gpu_available: gpu_available,
        generation_current: request.wal_generation_current,
        cpu_fallback_available: cpu_fallback_available
    )
    val schedule = gpu_wdb_schedule_registered(
        gpu_wdb_schedule_request(
            db_query_work_kind(request),
            db_query_estimated_batch_bytes(request),
            request.item_count,
            schedule_class,
            allow_defer,
            snapshot
        ),
        registry,
        budget
    )

    if schedule.action == GpuWdbScheduleAction.DeferForBatch:
        return db_query_scheduled_result(
            request,
            "gpu_batch_accumulator",
            schedule.reason,
            state
        )

    if schedule.action == GpuWdbScheduleAction.RejectWork:
        return db_query_scheduled_result(
            request,
            "reject",
            schedule.reason,
            state
        )

    db_query_offload_execute(
        request,
        state,
        registry,
        gpu_available,
        cpu_fallback_available,
        budget
    )

fn db_query_offload_execute_accumulating(request: DbQueryOffloadRequest,
                                         state: GpuWdbQueueState,
                                         registry: GpuWdbLibraryRegistry,
                                         gpu_available: bool,
                                         cpu_fallback_available: bool,
                                         budget: GpuWdbBudget,
                                         schedule_class: GpuWdbScheduleClass,
                                         accumulator: GpuWdbBatchAccumulator) -> DbQueryAccumulatedOffloadExecution:
    val execution = db_query_offload_execute_scheduled(
        request,
        state,
        registry,
        gpu_available,
        cpu_fallback_available,
        budget,
        schedule_class,
        true
    )
    val snapshot = GpuWdbRuntimeSnapshot(
        queue_depth: state.queue_depth,
        gpu_available: gpu_available,
        generation_current: request.wal_generation_current,
        cpu_fallback_available: cpu_fallback_available
    )
    val schedule_request = gpu_wdb_schedule_request(
        db_query_work_kind(request),
        db_query_estimated_batch_bytes(request),
        request.item_count,
        schedule_class,
        true,
        snapshot
    )
    val acc_result =
        if execution.dispatch_target == "gpu_batch_accumulator":
            gpu_wdb_batch_accumulator_add(accumulator, schedule_request, budget)
        else:
            GpuWdbBatchAccumulatorResult(
                accepted: false,
                should_flush: false,
                reason: "query-not-deferred",
                accumulator: accumulator
            )
    DbQueryAccumulatedOffloadExecution(
        execution: execution,
        accumulator_result: acc_result
    )
