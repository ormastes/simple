"""Net Server — Connection Module

Transport-layer connection lifecycle and handler trait.
Part of std.nogc_sync_mut.net_server.

Design rule D4: net-server lib is transport plumbing only — no protocol logic.
"""

use std.nogc_sync_mut.io.tcp.{TcpStream}

# ============================================================================
# ConnectionHandler trait
# ============================================================================
"""
Callback trait for handling an accepted TCP connection.

Implementors receive the raw TcpStream for each accepted connection.
Return true to continue accepting more connections; false to stop the
serve loop (graceful stop).

No protocol logic here — the caller decides what to read/write.
"""
trait ConnectionHandler:
    me handle(stream: TcpStream) -> bool

# ============================================================================
# Exports
# ============================================================================

export ConnectionHandler
