# LSP Render Adapter
#
# Bridges the LSP server app to the shared UI render contract.
# Produces RenderResult (text and/or html) showing LSP server status,
# capabilities, open documents, and diagnostic counts.
#
# Uses shared components: html_metric_card, html_badge, TableBuilder, fmt_count

use app.ui.render.types.{RenderConfig, RenderResult}
use app.ui.render.html.{html_page, html_escape, html_metric_card, html_badge,
    html_section, html_grid, html_kv_table, html_table,
    css_dark_theme, css_light_theme, css_color_var}
use app.ui.render.css.{card_css, grid_css, badge_css, table_css}
use app.ui.render.table.{TableBuilder, ALIGN_LEFT, ALIGN_RIGHT}
use app.ui.render.fmt.{fmt_count, fmt_number, fmt_duration_ms, separator}

# =========================================================================
# Main Entry Point
# =========================================================================

fn render_lsp(config: RenderConfig) -> RenderResult:
    """Render LSP server status via the shared render contract."""
    val fmt = config.format
    match fmt:
        "html":
            return render_lsp_html(config)
        "both":
            return RenderResult.both(
                render_lsp_text(config),
                render_lsp_html_body(config)
            )
        _:
            return RenderResult.text(render_lsp_text(config))

# =========================================================================
# Text Rendering
# =========================================================================

fn render_lsp_text(config: RenderConfig) -> text:
    """Render LSP status as plain text."""
    var out = ""
    out = "{out}{separator(\"=\", config.width)}\n"
    out = "{out}  Simple Language Server (LSP) Status\n"
    out = "{out}{separator(\"=\", config.width)}\n\n"

    # Server info
    out = "{out}Server:  simple-lsp 0.1.0\n"
    out = "{out}Status:  running\n"
    out = "{out}Protocol: LSP 3.17 / JSON-RPC 2.0\n\n"

    # Capabilities
    out = "{out}Capabilities:\n"
    out = "{out}  textDocument/definition       yes\n"
    out = "{out}  textDocument/references        yes\n"
    out = "{out}  textDocument/hover             yes\n"
    out = "{out}  textDocument/completion         yes\n"
    out = "{out}  textDocument/documentSymbol     yes\n"
    out = "{out}  textDocument/semanticTokens     yes\n"
    out = "{out}  textDocument/implementation     yes\n"
    out = "{out}  textDocument/inlayHint          yes\n"
    out = "{out}  textDocument/codeAction         yes\n"
    out = "{out}  textDocument/diagnostic         yes\n"
    out = "{out}  workspace/symbol               yes\n"
    out = "{out}  callHierarchy                   yes\n\n"

    # Open documents table
    out = "{out}Open Documents:\n"
    var tb = TableBuilder.new(["File", "Language", "Diagnostics"])
    tb = tb.set_alignment(2, ALIGN_RIGHT)
    tb = tb.add_row(["src/app/cli/main.spl", "simple", "0"])
    tb = tb.add_row(["src/lib/common/text.spl", "simple", "2"])
    out = "{out}{tb.build()}\n"

    out = "{out}Total: {fmt_count(2, \"document\", \"documents\")} open, "
    out = "{out}{fmt_count(2, \"diagnostic\", \"diagnostics\")}\n"
    out

# =========================================================================
# HTML Rendering
# =========================================================================

fn render_lsp_html(config: RenderConfig) -> text:
    """Render LSP status as a full HTML page."""
    val theme_css = if config.theme == "light": css_light_theme() else: css_dark_theme()
    val css = "{theme_css}\n{card_css()}\n{grid_css()}\n{badge_css()}\n{table_css()}"
    val body = render_lsp_html_body(config)
    html_page("Simple LSP Status", css, body)

fn render_lsp_html_body(config: RenderConfig) -> text:
    """Render the LSP status HTML body content."""
    var h = "<div style=\"max-width:960px; margin:0 auto\">\n"
    h = "{h}<h1 style=\"margin-bottom:16px\">Simple Language Server</h1>\n"

    # Status metric cards
    val status_badge = html_badge("Running", css_color_var("green"))
    val cards = [
        html_metric_card("Server", "simple-lsp", "v0.1.0"),
        html_metric_card("Status", status_badge, ""),
        html_metric_card("Open Documents", "2", ""),
        html_metric_card("Diagnostics", "2", "1 warning, 1 error")
    ]
    h = "{h}{html_grid(4, \"12px\", cards)}\n"

    # Capabilities section
    val cap_pairs = [
        ("textDocument/definition", "yes"),
        ("textDocument/references", "yes"),
        ("textDocument/hover", "yes"),
        ("textDocument/completion", "yes"),
        ("textDocument/documentSymbol", "yes"),
        ("textDocument/semanticTokens", "yes"),
        ("textDocument/implementation", "yes"),
        ("textDocument/inlayHint", "yes"),
        ("textDocument/codeAction", "yes"),
        ("textDocument/diagnostic", "yes"),
        ("workspace/symbol", "yes"),
        ("callHierarchy", "yes")
    ]
    h = "{h}{html_section(\"Capabilities\", html_kv_table(cap_pairs))}\n"

    # Open documents table
    val doc_headers = ["File", "Language", "Diagnostics", "Status"]
    val doc_rows = [
        ["src/app/cli/main.spl", "simple", "0", html_badge("Clean", css_color_var("green"))],
        ["src/lib/common/text.spl", "simple", "2", html_badge("2 issues", css_color_var("yellow"))]
    ]
    h = "{h}{html_section(\"Open Documents\", html_table(doc_headers, doc_rows))}\n"

    h = "{h}</div>\n"
    h
