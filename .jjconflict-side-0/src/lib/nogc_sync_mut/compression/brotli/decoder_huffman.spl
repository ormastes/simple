# brotli/decoder_huffman.spl — Simple prefix code (Huffman) tree parsing and symbol decode.
# RFC 7932 §3.4

use std.common.compress.types.{CompressionError}
use std.nogc_sync_mut.compression.brotli.bit_reader.{
    BrotliBitReader,
    BrotliBitsResult,
    brotli_bits_read
}

# -------------------------------------------------------------------------
# Internal: Simple prefix code header (RFC 7932 §3.4)
# -------------------------------------------------------------------------
struct _SimplePrefix:
    # Symbols and lengths in CANONICAL (codeword-ascending) order.
    symbols: [i64]
    lengths: [i64]
    reader: BrotliBitReader

fn _read_simple_prefix(r: BrotliBitReader, alphabet_bits: i64) -> Result<_SimplePrefix, CompressionError>:
    # 2 bits HSKIP code
    val hs_res = brotli_bits_read(r, 2)
    val hs = match hs_res:
        Ok(value):
            value
        Err(error):
            return Err(error)
    if hs.value != 3:
        return Err(CompressionError.UnsupportedFeature("brotli complex prefix code"))
    # 2 bits NSYM-1
    val ns_res = brotli_bits_read(hs.reader, 2)
    val ns = match ns_res:
        Ok(value):
            value
        Err(error):
            return Err(error)
    val nsym = ns.value + 1
    var rdr = ns.reader
    var raw_syms: [i64] = []
    var i = 0
    while i < nsym:
        val s_res = brotli_bits_read(rdr, alphabet_bits)
        val s = match s_res:
            Ok(value):
                value
            Err(error):
                return Err(error)
        raw_syms.push(s.value)
        rdr = s.reader
        i = i + 1
    # Determine codeword lengths
    var lens: [i64] = []
    if nsym == 1:
        lens.push(0)
    elif nsym == 2:
        lens.push(1)
        lens.push(1)
    elif nsym == 3:
        lens.push(1)
        lens.push(2)
        lens.push(2)
    else:
        # nsym == 4: read 1 tree-select bit
        val ts_res = brotli_bits_read(rdr, 1)
        val ts = match ts_res:
            Ok(value):
                value
            Err(error):
                return Err(error)
        rdr = ts.reader
        if ts.value == 0:
            lens.push(2)
            lens.push(2)
            lens.push(2)
            lens.push(2)
        else:
            lens.push(1)
            lens.push(2)
            lens.push(3)
            lens.push(3)
    # Sort symbols ascending (RFC 7932 §3.4).
    var sorted_syms = raw_syms
    var a = 0
    while a < sorted_syms.len():
        var b = a + 1
        while b < sorted_syms.len():
            if sorted_syms[a] > sorted_syms[b]:
                val tmp = sorted_syms[a]
                sorted_syms[a] = sorted_syms[b]
                sorted_syms[b] = tmp
            b = b + 1
        a = a + 1
    Ok(_SimplePrefix(symbols: sorted_syms, lengths: lens, reader: rdr))

# Decode one symbol from a simple prefix tree.
struct _SymReadResult:
    symbol: i64
    reader: BrotliBitReader

fn _decode_symbol(tree: _SimplePrefix, r: BrotliBitReader) -> Result<_SymReadResult, CompressionError>:
    val n = tree.symbols.len()
    if n == 1:
        return Ok(_SymReadResult(symbol: tree.symbols[0], reader: r))
    if n == 2:
        val b_res = brotli_bits_read(r, 1)
        val b = match b_res:
            Ok(value):
                value
            Err(error):
                return Err(error)
        return Ok(_SymReadResult(symbol: tree.symbols[b.value], reader: b.reader))
    if n == 3:
        val b0_res = brotli_bits_read(r, 1)
        val b0 = match b0_res:
            Ok(value):
                value
            Err(error):
                return Err(error)
        if b0.value == 0:
            return Ok(_SymReadResult(symbol: tree.symbols[0], reader: b0.reader))
        val b1_res = brotli_bits_read(b0.reader, 1)
        val b1 = match b1_res:
            Ok(value):
                value
            Err(error):
                return Err(error)
        return Ok(_SymReadResult(symbol: tree.symbols[1 + b1.value], reader: b1.reader))
    # n == 4
    if tree.lengths[0] == 2:
        # All 4 codewords are 2 bits.
        val bb_res = brotli_bits_read(r, 2)
        val bb = match bb_res:
            Ok(value):
                value
            Err(error):
                return Err(error)
        return Ok(_SymReadResult(symbol: tree.symbols[bb.value], reader: bb.reader))
    # tree-select=1: lengths [1,2,3,3]
    val b0_res = brotli_bits_read(r, 1)
    val b0 = match b0_res:
        Ok(value):
            value
        Err(error):
            return Err(error)
    if b0.value == 0:
        return Ok(_SymReadResult(symbol: tree.symbols[0], reader: b0.reader))
    val b1_res = brotli_bits_read(b0.reader, 1)
    val b1 = match b1_res:
        Ok(value):
            value
        Err(error):
            return Err(error)
    if b1.value == 0:
        return Ok(_SymReadResult(symbol: tree.symbols[1], reader: b1.reader))
    val b2_res = brotli_bits_read(b1.reader, 1)
    val b2 = match b2_res:
        Ok(value):
            value
        Err(error):
            return Err(error)
    Ok(_SymReadResult(symbol: tree.symbols[2 + b2.value], reader: b2.reader))
