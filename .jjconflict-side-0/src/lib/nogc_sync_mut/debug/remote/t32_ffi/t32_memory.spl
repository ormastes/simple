@allow(primitive_api)
# T32 Memory Access API FFI — read/write memory, flash, RAM info

use std.ffi.dynamic.{spl_dlsym, spl_wffi_call_i64}
use std.ffi.dynamic_versioned.{VersionedDynLib}
use std.debug.remote.t32_ffi.t32_types.{T32_OK, T32Error, make_t32_error}

extern fn spl_str_to_cstr(s: text) -> i64
extern fn spl_alloc_buffer(size: i64) -> i64
extern fn spl_free_buffer(ptr: i64)
extern fn spl_write_bytes(ptr: i64, data: [i64], len: i64)
extern fn spl_read_bytes(ptr: i64, len: i64) -> [i64]

var _fp_ReadMemory: i64 = 0
var _fp_WriteMemory: i64 = 0
var _fp_ReadMemoryPipe: i64 = 0
var _fp_WriteMemoryPipe: i64 = 0
var _fp_ReadMemoryEx: i64 = 0
var _fp_WriteMemoryEx: i64 = 0
var _fp_SetMemoryAccessClass: i64 = 0
var _fp_GetRam: i64 = 0
var _fp_FlashfileReadMemory: i64 = 0
var _fp_FlashfileWriteMemory: i64 = 0

fn t32_memory_bind(lib: VersionedDynLib) -> [text]:
    var missing: [text] = []
    _fp_ReadMemory = lib.lib.sym("T32_ReadMemory")
    if _fp_ReadMemory == 0: missing.push("T32_ReadMemory")
    _fp_WriteMemory = lib.lib.sym("T32_WriteMemory")
    if _fp_WriteMemory == 0: missing.push("T32_WriteMemory")
    _fp_ReadMemoryPipe = lib.lib.sym("T32_ReadMemoryPipe")
    _fp_WriteMemoryPipe = lib.lib.sym("T32_WriteMemoryPipe")
    _fp_ReadMemoryEx = lib.lib.sym("T32_ReadMemoryEx")
    _fp_WriteMemoryEx = lib.lib.sym("T32_WriteMemoryEx")
    _fp_SetMemoryAccessClass = lib.lib.sym("T32_SetMemoryAccessClass")
    _fp_GetRam = lib.lib.sym("T32_GetRam")
    _fp_FlashfileReadMemory = lib.lib.sym("T32_FlashfileReadMemory")
    _fp_FlashfileWriteMemory = lib.lib.sym("T32_FlashfileWriteMemory")
    missing

fn t32_memory_function_names() -> [text]:
    ["T32_ReadMemory", "T32_WriteMemory", "T32_ReadMemoryPipe", "T32_WriteMemoryPipe",
     "T32_ReadMemoryEx", "T32_WriteMemoryEx", "T32_SetMemoryAccessClass",
     "T32_GetRam", "T32_FlashfileReadMemory", "T32_FlashfileWriteMemory"]

# int T32_ReadMemory(uint32_t addr, int access, uint8_t* buf, int size)
fn t32_read_memory(addr: i64, access: i64, size: i64) -> Result<[i64], T32Error>:
    if _fp_ReadMemory == 0: return Err(make_t32_error(-999))
    val buf = spl_alloc_buffer(size)
    var args: [i64] = [addr, access, buf, size]
    val rc = spl_wffi_call_i64(_fp_ReadMemory, args, 4)
    if rc == T32_OK:
        val data = spl_read_bytes(buf, size)
        spl_free_buffer(buf)
        Ok(data)
    else:
        spl_free_buffer(buf)
        Err(make_t32_error(rc))

# int T32_WriteMemory(uint32_t addr, int access, const uint8_t* buf, int size)
fn t32_write_memory(addr: i64, access: i64, data: [i64]) -> Result<i64, T32Error>:
    if _fp_WriteMemory == 0: return Err(make_t32_error(-999))
    val size = data.len()
    val buf = spl_alloc_buffer(size)
    spl_write_bytes(buf, data, size)
    var args: [i64] = [addr, access, buf, size]
    val rc = spl_wffi_call_i64(_fp_WriteMemory, args, 4)
    spl_free_buffer(buf)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_ReadMemoryPipe(uint32_t addr, int access, uint8_t* buf, int size)
fn t32_read_memory_pipe(addr: i64, access: i64, size: i64) -> Result<[i64], T32Error>:
    if _fp_ReadMemoryPipe == 0: return Err(make_t32_error(-999))
    val buf = spl_alloc_buffer(size)
    var args: [i64] = [addr, access, buf, size]
    val rc = spl_wffi_call_i64(_fp_ReadMemoryPipe, args, 4)
    if rc == T32_OK:
        val data = spl_read_bytes(buf, size)
        spl_free_buffer(buf)
        Ok(data)
    else:
        spl_free_buffer(buf)
        Err(make_t32_error(rc))

# int T32_WriteMemoryPipe(uint32_t addr, int access, const uint8_t* buf, int size)
fn t32_write_memory_pipe(addr: i64, access: i64, data: [i64]) -> Result<i64, T32Error>:
    if _fp_WriteMemoryPipe == 0: return Err(make_t32_error(-999))
    val size = data.len()
    val buf = spl_alloc_buffer(size)
    spl_write_bytes(buf, data, size)
    var args: [i64] = [addr, access, buf, size]
    val rc = spl_wffi_call_i64(_fp_WriteMemoryPipe, args, 4)
    spl_free_buffer(buf)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_ReadMemoryEx(uint32_t addr, uint32_t segment, int access, int attr, uint8_t* buf, int size)
fn t32_read_memory_ex(addr: i64, segment: i64, access: i64, attr: i64, size: i64) -> Result<[i64], T32Error>:
    if _fp_ReadMemoryEx == 0: return Err(make_t32_error(-999))
    val buf = spl_alloc_buffer(size)
    var args: [i64] = [addr, segment, access, attr, buf, size]
    val rc = spl_wffi_call_i64(_fp_ReadMemoryEx, args, 6)
    if rc == T32_OK:
        val data = spl_read_bytes(buf, size)
        spl_free_buffer(buf)
        Ok(data)
    else:
        spl_free_buffer(buf)
        Err(make_t32_error(rc))

# int T32_WriteMemoryEx(uint32_t addr, uint32_t segment, int access, int attr, const uint8_t* buf, int size)
fn t32_write_memory_ex(addr: i64, segment: i64, access: i64, attr: i64, data: [i64]) -> Result<i64, T32Error>:
    if _fp_WriteMemoryEx == 0: return Err(make_t32_error(-999))
    val size = data.len()
    val buf = spl_alloc_buffer(size)
    spl_write_bytes(buf, data, size)
    var args: [i64] = [addr, segment, access, attr, buf, size]
    val rc = spl_wffi_call_i64(_fp_WriteMemoryEx, args, 6)
    spl_free_buffer(buf)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_SetMemoryAccessClass(const char* access_class)
fn t32_set_memory_access_class(class_str: text) -> Result<i64, T32Error>:
    if _fp_SetMemoryAccessClass == 0: return Err(make_t32_error(-999))
    val cls = spl_str_to_cstr(class_str)
    var args: [i64] = [cls]
    val rc = spl_wffi_call_i64(_fp_SetMemoryAccessClass, args, 1)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_GetRam(uint32_t* pstart, uint32_t* pend, uint32_t* paccess)
fn t32_get_ram() -> Result<(i64, i64, i64), T32Error>:
    if _fp_GetRam == 0: return Err(make_t32_error(-999))
    val start_buf = spl_alloc_buffer(8)
    val end_buf = spl_alloc_buffer(8)
    val access_buf = spl_alloc_buffer(8)
    var args: [i64] = [start_buf, end_buf, access_buf]
    val rc = spl_wffi_call_i64(_fp_GetRam, args, 3)
    extern fn spl_read_i32(ptr: i64) -> i64
    if rc == T32_OK:
        val start = spl_read_i32(start_buf)
        val end = spl_read_i32(end_buf)
        val access = spl_read_i32(access_buf)
        spl_free_buffer(start_buf)
        spl_free_buffer(end_buf)
        spl_free_buffer(access_buf)
        Ok((start, end, access))
    else:
        spl_free_buffer(start_buf)
        spl_free_buffer(end_buf)
        spl_free_buffer(access_buf)
        Err(make_t32_error(rc))

# int T32_FlashfileReadMemory(uint32_t addr, uint8_t* buf, int size)
fn t32_flashfile_read_memory(addr: i64, size: i64) -> Result<[i64], T32Error>:
    if _fp_FlashfileReadMemory == 0: return Err(make_t32_error(-999))
    val buf = spl_alloc_buffer(size)
    var args: [i64] = [addr, buf, size]
    val rc = spl_wffi_call_i64(_fp_FlashfileReadMemory, args, 3)
    if rc == T32_OK:
        val data = spl_read_bytes(buf, size)
        spl_free_buffer(buf)
        Ok(data)
    else:
        spl_free_buffer(buf)
        Err(make_t32_error(rc))

# int T32_FlashfileWriteMemory(uint32_t addr, const uint8_t* buf, int size)
fn t32_flashfile_write_memory(addr: i64, data: [i64]) -> Result<i64, T32Error>:
    if _fp_FlashfileWriteMemory == 0: return Err(make_t32_error(-999))
    val size = data.len()
    val buf = spl_alloc_buffer(size)
    spl_write_bytes(buf, data, size)
    var args: [i64] = [addr, buf, size]
    val rc = spl_wffi_call_i64(_fp_FlashfileWriteMemory, args, 3)
    spl_free_buffer(buf)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))
