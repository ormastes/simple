# int T32_TAPAccessSetInfo(int p1, int p2, int p3, int p4, int p5, int p6, int p7, int p8)
fn t32_tap_access_set_info(p1: i64, p2: i64, p3: i64, p4: i64, p5: i64, p6: i64, p7: i64, p8: i64) -> Result<i64, T32Error>:
    if _fp_TAPAccessSetInfo == 0: return Err(make_t32_error(-999))
    var args: [i64] = [p1, p2, p3, p4, p5, p6, p7, p8]
    val rc = spl_wffi_call_i64(_fp_TAPAccessSetInfo, args, 8)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_TAPAccessShiftRaw(handle, bits, tms*, tdi*, tdo*, flags)
# tms/tdi are input byte arrays, tdo is output byte array. Size = (bits+7)/8.
fn t32_tap_access_shift_raw(handle: i64, bits: i64, tms_data: [i64], tdi_data: [i64]) -> Result<[i64], T32Error>:
    if _fp_TAPAccessShiftRaw == 0: return Err(make_t32_error(-999))
    val byte_len = (bits + 7) / 8
    val tms_buf = spl_alloc_buffer(byte_len)
    val tdi_buf = spl_alloc_buffer(byte_len)
    val tdo_buf = spl_alloc_buffer(byte_len)
    var i: i64 = 0
    while i < byte_len and i < tms_data.len():
        spl_write_u8(tms_buf, i, tms_data[i])
        i = i + 1
    i = 0
    while i < byte_len and i < tdi_data.len():
        spl_write_u8(tdi_buf, i, tdi_data[i])
        i = i + 1
    var args: [i64] = [handle, bits, tms_buf, tdi_buf, tdo_buf, 0]
    val rc = spl_wffi_call_i64(_fp_TAPAccessShiftRaw, args, 6)
    if rc == T32_OK:
        var result: [i64] = []
        i = 0
        while i < byte_len:
            result.push(spl_read_u8(tdo_buf, i))
            i = i + 1
        spl_free_buffer(tms_buf)
        spl_free_buffer(tdi_buf)
        spl_free_buffer(tdo_buf)
        Ok(result)
    else:
        spl_free_buffer(tms_buf)
        spl_free_buffer(tdi_buf)
        spl_free_buffer(tdo_buf)
        Err(make_t32_error(rc))

# int T32_TAPAccessShiftIR(handle, bits, out*, in*)
fn t32_tap_access_shift_ir(handle: i64, bits: i64, out_data: [i64]) -> Result<[i64], T32Error>:
    if _fp_TAPAccessShiftIR == 0: return Err(make_t32_error(-999))
    val byte_len = (bits + 7) / 8
    val out_buf = spl_alloc_buffer(byte_len)
    val in_buf = spl_alloc_buffer(byte_len)
    var i: i64 = 0
    while i < byte_len and i < out_data.len():
        spl_write_u8(out_buf, i, out_data[i])
        i = i + 1
    var args: [i64] = [handle, bits, out_buf, in_buf]
    val rc = spl_wffi_call_i64(_fp_TAPAccessShiftIR, args, 4)
    if rc == T32_OK:
        var result: [i64] = []
        i = 0
        while i < byte_len:
            result.push(spl_read_u8(in_buf, i))
            i = i + 1
        spl_free_buffer(out_buf)
        spl_free_buffer(in_buf)
        Ok(result)
    else:
        spl_free_buffer(out_buf)
        spl_free_buffer(in_buf)
        Err(make_t32_error(rc))

# int T32_TAPAccessShiftDR(handle, bits, out*, in*)
fn t32_tap_access_shift_dr(handle: i64, bits: i64, out_data: [i64]) -> Result<[i64], T32Error>:
    if _fp_TAPAccessShiftDR == 0: return Err(make_t32_error(-999))
    val byte_len = (bits + 7) / 8
