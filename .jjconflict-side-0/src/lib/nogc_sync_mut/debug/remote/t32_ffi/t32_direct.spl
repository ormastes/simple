# int T32_DAPAccessScan(handle, instance, rw, reg, data_in, data_out*)
fn t32_dap_access_scan(handle: i64, instance: i64, rw: i64, reg: i64, data_in: i64) -> Result<i64, T32Error>:
    if _fp_DAPAccessScan == 0: return Err(make_t32_error(-999))
    val out_buf = spl_alloc_buffer(8)
    var args: [i64] = [handle, instance, rw, reg, data_in, data_in, out_buf]
    val rc = spl_wffi_call_i64(_fp_DAPAccessScan, args, 7)
    if rc == T32_OK:
        val result = spl_read_i32(out_buf)
        spl_free_buffer(out_buf)
        Ok(result)
    else:
        spl_free_buffer(out_buf)
        Err(make_t32_error(rc))

# int T32_I2CAccess(handle, instance, action, device_id, cmd_data*, cmd_len, data*, data_len)
fn t32_i2c_access(handle: i64, instance: i64, action: i64, device_id: i64, cmd_data: [i64], data_len: i64) -> Result<[i64], T32Error>:
    if _fp_I2CAccess == 0: return Err(make_t32_error(-999))
    val cmd_len = cmd_data.len()
    val cmd_buf = spl_alloc_buffer(cmd_len)
    var i: i64 = 0
    while i < cmd_len:
        spl_write_u8(cmd_buf, i, cmd_data[i])
        i = i + 1
    val data_buf = spl_alloc_buffer(data_len)
    var args: [i64] = [handle, instance, action, device_id, cmd_buf, cmd_len, data_buf, data_len]
    val rc = spl_wffi_call_i64(_fp_I2CAccess, args, 8)
    if rc == T32_OK:
        var result: [i64] = []
        i = 0
        while i < data_len:
            result.push(spl_read_u8(data_buf, i))
            i = i + 1
        spl_free_buffer(cmd_buf)
        spl_free_buffer(data_buf)
        Ok(result)
    else:
        spl_free_buffer(cmd_buf)
        spl_free_buffer(data_buf)
        Err(make_t32_error(rc))

# int T32_DAPAccessInitSWD(uint32_t handle, int instance)
fn t32_dap_access_init_swd(handle: i64, instance: i64) -> Result<i64, T32Error>:
    if _fp_DAPAccessInitSWD == 0: return Err(make_t32_error(-999))
    var args: [i64] = [handle, instance]
    val rc = spl_wffi_call_i64(_fp_DAPAccessInitSWD, args, 2)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_ExecuteLua(const char* filename, int mode)
fn t32_execute_lua(filename: text, mode: i64) -> Result<i64, T32Error>:
    if _fp_ExecuteLua == 0: return Err(make_t32_error(-999))
    val fname = spl_str_to_cstr(filename)
    var args: [i64] = [fname, mode]
    val rc = spl_wffi_call_i64(_fp_ExecuteLua, args, 2)
    if rc == T32_OK: Ok(rc) else: Err(make_t32_error(rc))

# int T32_GetSocketHandle(void) -> socket fd
fn t32_get_socket_handle() -> Result<i64, T32Error>:
    if _fp_GetSocketHandle == 0: return Err(make_t32_error(-999))
    var args: [i64] = []
    val rc = spl_wffi_call_i64(_fp_GetSocketHandle, args, 0)
    # Returns socket handle (>=0) or negative error
    if rc >= 0: Ok(rc) else: Err(make_t32_error(rc))
