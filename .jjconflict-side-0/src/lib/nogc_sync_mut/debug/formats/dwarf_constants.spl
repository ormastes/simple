val DW_AT_accessibility: i64 = 0x32
val DW_AT_artificial: i64 = 0x33
val DW_AT_byte_size: i64 = 0x0b
val DW_AT_bit_size: i64 = 0x0d
val DW_AT_data_member_location: i64 = 0x38
val DW_AT_decl_file: i64 = 0x3a
