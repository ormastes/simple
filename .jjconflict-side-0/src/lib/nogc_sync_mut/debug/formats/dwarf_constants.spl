# DWARF Constants
# Tag, attribute, form, and line number program constants from the DWARF specification.

# ============================================================================
# Tags (DW_TAG_*)
# ============================================================================

val DW_TAG_array_type: i64 = 0x01
val DW_TAG_class_type: i64 = 0x02
val DW_TAG_entry_point: i64 = 0x03
val DW_TAG_enumeration_type: i64 = 0x04
val DW_TAG_formal_parameter: i64 = 0x05
val DW_TAG_lexical_block: i64 = 0x0b
val DW_TAG_member: i64 = 0x0d
val DW_TAG_pointer_type: i64 = 0x0f
val DW_TAG_reference_type: i64 = 0x10
val DW_TAG_compile_unit: i64 = 0x11
val DW_TAG_structure_type: i64 = 0x13
val DW_TAG_subroutine_type: i64 = 0x15
val DW_TAG_typedef: i64 = 0x16
val DW_TAG_union_type: i64 = 0x17
val DW_TAG_variable: i64 = 0x34
val DW_TAG_subprogram: i64 = 0x2e
val DW_TAG_base_type: i64 = 0x24
val DW_TAG_const_type: i64 = 0x26
val DW_TAG_volatile_type: i64 = 0x35
val DW_TAG_namespace: i64 = 0x39
val DW_TAG_inlined_subroutine: i64 = 0x1d
val DW_TAG_subrange_type: i64 = 0x21
val DW_TAG_unspecified_parameters: i64 = 0x18

