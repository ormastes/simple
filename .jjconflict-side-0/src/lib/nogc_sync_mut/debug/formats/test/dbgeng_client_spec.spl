#![allow(primitive_api)]
use std.io_runtime
use std.nogc_sync_mut.spec.{describe, it, expect}
use std.nogc_sync_mut.debug.remote.protocol.dbgeng.DbgEngClient

fn main():
    describe("DbgEngClient platform error"):
        it("returns correct error message"):
            val msg = DbgEngClient._platform_error()
            expect(msg).to_equal("DbgEng only supported on Windows")

        it("error message contains Windows"):
            val msg = DbgEngClient._platform_error()
            expect(msg).to_contain("Windows")

    describe("DbgEngClient connect"):
        it("returns error on non-Windows platform"):
            val result = DbgEngClient.connect("localhost", 5555)
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_equal("DbgEng only supported on Windows")

    describe("DbgEngClient attach_pid"):
        it("returns error on non-Windows platform"):
            val result = DbgEngClient.attach_pid(1234)
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_equal("DbgEng only supported on Windows")

    describe("DbgEngClient launch"):
        it("returns error on non-Windows platform"):
            val result = DbgEngClient.launch("notepad.exe", [])
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_equal("DbgEng only supported on Windows")

        it("returns error with arguments"):
            val result = DbgEngClient.launch("test.exe", ["--debug", "--verbose"])
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_contain("Windows")

    describe("DbgEngClient load_dump"):
        it("returns error on non-Windows platform"):
            val result = DbgEngClient.load_dump("crash.dmp")
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_equal("DbgEng only supported on Windows")

    describe("DbgEngClient field construction"):
        it("creates client with correct host"):
            val client = DbgEngClient(
                host: "192.168.1.100",
                port: 5555,
                connected: false,
                target_pid: 0,
                platform: "linux"
            )
            expect(client.host).to_equal("192.168.1.100")

        it("creates client with correct port"):
            val client = DbgEngClient(
                host: "localhost",
                port: 4444,
                connected: false,
                target_pid: 0,
                platform: "linux"
            )
            expect(client.port).to_equal(4444)

        it("creates client not connected by default"):
            val client = DbgEngClient(
                host: "",
                port: 0,
                connected: false,
                target_pid: 0,
                platform: "linux"
            )
            expect(client.is_connected()).to_equal(false)

        it("creates client with target pid"):
            val client = DbgEngClient(
                host: "localhost",
                port: 5555,
                connected: false,
                target_pid: 9876,
                platform: "windows"
            )
            expect(client.target_pid).to_equal(9876)

    describe("DbgEngClient method error paths"):
        it("resume returns platform error"):
            val client = DbgEngClient(
                host: "", port: 0, connected: false,
                target_pid: 0, platform: "linux"
            )
            val result = client.resume()
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_contain("Windows")

        it("halt returns platform error"):
            val client = DbgEngClient(
                host: "", port: 0, connected: false,
                target_pid: 0, platform: "linux"
            )
            val result = client.halt()
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_contain("Windows")

        it("set_breakpoint returns platform error"):
            val client = DbgEngClient(
                host: "", port: 0, connected: false,
                target_pid: 0, platform: "linux"
            )
            val result = client.set_breakpoint("main.spl", 10)
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_contain("Windows")

        it("read_memory returns platform error"):
            val client = DbgEngClient(
                host: "", port: 0, connected: false,
                target_pid: 0, platform: "linux"
            )
            val result = client.read_memory(0, 16)
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_contain("Windows")

        it("execute_command returns platform error"):
            val client = DbgEngClient(
                host: "", port: 0, connected: false,
                target_pid: 0, platform: "linux"
            )
            val result = client.execute_command("!analyze -v")
            match result:
                Ok(_): expect(true).to_equal(false)
                Err(e): expect(e).to_contain("Windows")
