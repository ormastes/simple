# NoGC Torch Module
#
# PyTorch FFI integration with unique ownership (no GC).
# Bare T = unique_pointer (single owner, RAII).
# Same API surface as gc_async_mut/torch by convention.
#
# Public API:
#   use std.nogc_sync_mut.torch.mod.{Tensor, Linear, Conv2d, ...}
#   use std.nogc_sync_mut.torch.ops.{cross_entropy_loss_tensor, ...}
#   use std.nogc_sync_mut.torch.optim.{SGDOptimizer, AdamOptimizer}
#   use std.nogc_sync_mut.torch.backend  # TorchBackend impl
#
# For backend-agnostic code:
#   use std.common.torch.interface.{TorchBackend}
#   bind TorchBackend = NogcTorchOps

# Re-exported from backend.spl
export NogcTorchOps

# Re-exported from mod.spl
export Tensor
export Linear
export Conv2d
export MaxPool2d
export BatchNorm2d
export Dropout
export MSELoss
export CrossEntropyLoss
export SGD
export Adam
export RMSprop
export Stream
export Sequential
export torch_available
export torch_version
export cuda_available
export no_grad
export set_seed
export manual_seed

# Re-exported from ops.spl
export cross_entropy_loss_tensor, compute_mse_loss_tensor
export rms_norm, clip_grad_norm, compute_accuracy
export lr_warmup_linear, lr_warmup_cosine

# Re-exported from optim.spl
export SGDOptimizer, AdamOptimizer

# Re-exported from torch_training.spl
export MSELoss, CrossEntropyLoss
export SGD, Adam, RMSprop
export Stream, Sequential
export no_grad, set_seed, manual_seed
