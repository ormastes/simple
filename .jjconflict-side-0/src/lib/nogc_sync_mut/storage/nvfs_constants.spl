# Canonical NVFS/DBFS storage ordinals shared by storage users.
#
# Kept in std storage so production callers and system specs do not depend on
# example package modules for durable on-disk policy constants.

val STORAGE_CLASS_DB_WAL: i64 = 1
val STORAGE_CLASS_META_DURABLE: i64 = 2
val STORAGE_CLASS_DB_TEMP: i64 = 3

val DURABILITY_DATA_DURABLE: i64 = 1
