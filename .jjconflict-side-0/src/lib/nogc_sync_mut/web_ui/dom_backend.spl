# EngineDomBackend — stdlib-local DOM backend for desktop web_ui apps.

use std.common.web.dom.{DomBackend, WebElement}
use std.common.web.event.{EventBackend, WebEvent, WebEventType}
use common.web.node_types.{DomNode, NodeKind}
use common.web.logging.{Logger, LogLevel}

# Event listener entry for the engine backend.
class EngineEventListener:
    element_id: i64
    event_type: WebEventType
    handler: fn(WebEvent)

    static fn create(element_id: i64, event_type: WebEventType, handler: fn(WebEvent)) -> EngineEventListener:
        EngineEventListener(element_id: element_id, event_type: event_type, handler: handler)

class WebUiAttr:
    name: text
    value: text

    static fn create(name: text, value: text) -> WebUiAttr:
        WebUiAttr(name: name, value: value)

class WebUiDomRecord:
    node: DomNode
    tag: text
    text_content: text
    attrs: [WebUiAttr]

    static fn create(id: i64, kind: NodeKind, tag: text, text_content: text) -> WebUiDomRecord:
        WebUiDomRecord(
            node: DomNode.create(id, kind, -1, tag),
            tag: tag,
            text_content: text_content,
            attrs: []
        )

class EngineDomBackend:
    nodes: [WebUiDomRecord]
    next_id: i64
    logger: Logger
    dirty: bool
    listeners: List<EngineEventListener>
    body_id: i64
    root_id: i64

    static fn create(logger: Logger) -> EngineDomBackend:
        val doc_id = 1
        val html_id = 2
        val body_id = 3
        var doc = WebUiDomRecord.create(doc_id, NodeKind.Document, "#document", "")
        var html = WebUiDomRecord.create(html_id, NodeKind.Element, "html", "")
        var body = WebUiDomRecord.create(body_id, NodeKind.Element, "body", "")
        doc.node.children.push(html_id)
        html.node.parent_id = doc_id
        html.node.children.push(body_id)
        body.node.parent_id = html_id
        EngineDomBackend(
            nodes: [doc, html, body],
            next_id: 4,
            logger: logger,
            dirty: false,
            listeners: [],
            body_id: body_id,
            root_id: html_id
        )

    fn find_index(node_id: i64) -> i64:
        var i = 0
        while i < self.nodes.len():
            if self.nodes[i].node.id == node_id:
                return i
            i = i + 1
        -1

    fn attr_value(node_id: i64, name: text) -> Option<text>:
        val idx = self.find_index(node_id)
        if idx < 0:
            return nil
        for attr in self.nodes[idx].attrs:
            if attr.name == name:
                return Some(attr.value)
        nil

    me set_attr_value(node_id: i64, name: text, value: text):
        val idx = self.find_index(node_id)
        if idx < 0:
            return
        var attrs: [WebUiAttr] = []
        var found = false
        for attr in self.nodes[idx].attrs:
            if attr.name == name:
                attrs.push(WebUiAttr.create(name, value))
                found = true
            else:
                attrs.push(attr)
        if not found:
            attrs.push(WebUiAttr.create(name, value))
        self.nodes[idx].attrs = attrs

    me remove_attr_value(node_id: i64, name: text):
        val idx = self.find_index(node_id)
        if idx < 0:
            return
        var attrs: [WebUiAttr] = []
        for attr in self.nodes[idx].attrs:
            if attr.name != name:
                attrs.push(attr)
        self.nodes[idx].attrs = attrs

    me append_child_id(parent_id: i64, child_id: i64):
        val pidx = self.find_index(parent_id)
        val cidx = self.find_index(child_id)
        if pidx < 0 or cidx < 0:
            return
        self.nodes[pidx].node.children.push(child_id)
        self.nodes[cidx].node.parent_id = parent_id

    me detach_child_id(parent_id: i64, child_id: i64):
        val pidx = self.find_index(parent_id)
        if pidx < 0:
            return
        var children: [i64] = []
        for id in self.nodes[pidx].node.children:
            if id != child_id:
                children.push(id)
        self.nodes[pidx].node.children = children
        val cidx = self.find_index(child_id)
        if cidx >= 0:
            self.nodes[cidx].node.parent_id = -1

    fn matches_selector(rec: WebUiDomRecord, selector: text) -> bool:
        if selector.starts_with("#"):
            val id_value = selector.substring(1)
            match self.attr_value(rec.node.id, "id"):
                Some(v): return v == id_value
                nil: return false
        if selector.starts_with("."):
            val class_value = selector.substring(1)
            match self.attr_value(rec.node.id, "class"):
                Some(v): return v.contains(class_value)
                nil: return false
        rec.tag == selector

    # Check if mutations occurred since last render.
    fn is_dirty() -> bool: self.dirty

    # Clear dirty flag after rendering.
    me clear_dirty():
        self.dirty = false

    # Dispatch a click event to matching listeners.
    me dispatch_click(element_id: i64, x: i64, y: i64):
        val event = WebEvent.click(element_id, x, y)
        for listener in self.listeners:
            if listener.element_id == element_id:
                match listener.event_type:
                    WebEventType.Click: listener.handler(event)
                    _: pass_dn

impl DomBackend for EngineDomBackend:
    me create_element(tag: text) -> WebElement:
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.nodes.push(WebUiDomRecord.create(id, NodeKind.Element, tag, ""))
        self.dirty = true
        WebElement.from_id(id)

    me create_text_node(content: text) -> WebElement:
        val id = self.next_id
        self.next_id = self.next_id + 1
        self.nodes.push(WebUiDomRecord.create(id, NodeKind.Text, "#text", content))
        self.dirty = true
        WebElement.from_id(id)

    me append_child(parent: WebElement, child: WebElement):
        self.append_child_id(parent.id, child.id)
        self.dirty = true

    me insert_before(parent: WebElement, new_child: WebElement, ref_child: WebElement):
        val pidx = self.find_index(parent.id)
        val nidx = self.find_index(new_child.id)
        if pidx >= 0 and nidx >= 0:
            var children: [i64] = []
            var inserted = false
            for id in self.nodes[pidx].node.children:
                if id == ref_child.id:
                    children.push(new_child.id)
                    inserted = true
                children.push(id)
            if not inserted:
                children.push(new_child.id)
            self.nodes[pidx].node.children = children
            self.nodes[nidx].node.parent_id = parent.id
        self.dirty = true

    me remove_child(parent: WebElement, child: WebElement):
        self.detach_child_id(parent.id, child.id)
        self.dirty = true

    me replace_child(parent: WebElement, new_child: WebElement, old_child: WebElement):
        val pidx = self.find_index(parent.id)
        val nidx = self.find_index(new_child.id)
        if pidx >= 0 and nidx >= 0:
            var children: [i64] = []
            for id in self.nodes[pidx].node.children:
                if id == old_child.id:
                    children.push(new_child.id)
                else:
                    children.push(id)
            self.nodes[pidx].node.children = children
            self.nodes[nidx].node.parent_id = parent.id
        self.dirty = true

    me set_attribute(element: WebElement, name: text, value: text):
        self.set_attr_value(element.id, name, value)
        self.dirty = true

    me get_attribute(element: WebElement, name: text) -> Option<text>:
        self.attr_value(element.id, name)

    me remove_attribute(element: WebElement, name: text):
        self.remove_attr_value(element.id, name)
        self.dirty = true

    me set_text_content(element: WebElement, content: text):
        val idx = self.find_index(element.id)
        if idx >= 0:
            self.nodes[idx].text_content = content
        self.dirty = true

    me get_text_content(element: WebElement) -> text:
        val idx = self.find_index(element.id)
        if idx < 0:
            return ""
        self.nodes[idx].text_content

    me set_inner_html(element: WebElement, html: text):
        val idx = self.find_index(element.id)
        if idx >= 0:
            self.nodes[idx].text_content = html
        self.dirty = true

    me get_inner_html(element: WebElement) -> text:
        self.get_text_content(element)

    me add_class(element: WebElement, class_name: text):
        val existing = self.get_attribute(element, "class")
        match existing:
            Some(v):
                if not v.contains(class_name):
                    self.set_attr_value(element.id, "class", "{v} {class_name}")
            nil:
                self.set_attr_value(element.id, "class", class_name)
        self.dirty = true

    me remove_class(element: WebElement, class_name: text):
        val existing = self.get_attribute(element, "class")
        match existing:
            Some(v):
                self.set_attr_value(element.id, "class", v.replace(class_name, "").trim())
            nil:
                pass_dn
        self.dirty = true

    me has_class(element: WebElement, class_name: text) -> bool:
        val class_attr = self.get_attribute(element, "class")
        match class_attr:
            Some(classes): classes.contains(class_name)
            nil: false

    me set_style(element: WebElement, property: text, value: text):
        val current = self.get_attribute(element, "style")
        match current:
            Some(v): self.set_attr_value(element.id, "style", "{v}; {property}: {value}")
            nil: self.set_attr_value(element.id, "style", "{property}: {value}")
        self.dirty = true

    me get_style(element: WebElement, property: text) -> text:
        match self.get_attribute(element, "style"):
            Some(v): v
            nil: ""

    me query_selector(selector: text) -> Option<WebElement>:
        for rec in self.nodes:
            if self.matches_selector(rec, selector):
                return Some(WebElement.from_id(rec.node.id))
        nil

    me query_selector_all(selector: text) -> List<WebElement>:
        var elements: List<WebElement> = []
        for rec in self.nodes:
            if self.matches_selector(rec, selector):
                elements.push(WebElement.from_id(rec.node.id))
        elements

    me get_element_by_id(id: text) -> Option<WebElement>:
        self.query_selector("#{id}")

    me body() -> WebElement:
        WebElement.from_id(self.body_id)

    me document_element() -> WebElement:
        WebElement.from_id(self.root_id)

impl EventBackend for EngineDomBackend:
    me on(element: WebElement, event_type: WebEventType, handler: fn(WebEvent)):
        val listener = EngineEventListener.create(element.id, event_type, handler)
        self.listeners.push(listener)

    me off(element: WebElement, event_type: WebEventType):
        var kept: List<EngineEventListener> = []
        for listener in self.listeners:
            val matches = listener.element_id == element.id
            if not matches:
                kept.push(listener)
        self.listeners = kept

    me on_click(element: WebElement, handler: fn(WebEvent)):
        self.on(element, WebEventType.Click, handler)

    me on_input(element: WebElement, handler: fn(WebEvent)):
        self.on(element, WebEventType.Input, handler)

    me on_change(element: WebElement, handler: fn(WebEvent)):
        self.on(element, WebEventType.Change, handler)

    me on_submit(element: WebElement, handler: fn(WebEvent)):
        self.on(element, WebEventType.Submit, handler)

    me on_keydown(element: WebElement, handler: fn(WebEvent)):
        self.on(element, WebEventType.KeyDown, handler)

    me on_keyup(element: WebElement, handler: fn(WebEvent)):
        self.on(element, WebEventType.KeyUp, handler)
