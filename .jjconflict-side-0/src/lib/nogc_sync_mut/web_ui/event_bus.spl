# In-process pub/sub event bus for web_ui.
# Supports global events and window-scoped events.

# A registered event listener.
class EventListener:
    id: i64
    event_name: text
    window_label: text
    handler: fn(text)

    static fn create(id: i64, event_name: text, window_label: text, handler: fn(text)) -> EventListener:
        EventListener(id: id, event_name: event_name, window_label: window_label, handler: handler)

# Event bus with listen/emit/unlisten.
class EventBus:
    listeners: List<EventListener>
    next_listener_id: i64

    static fn create() -> EventBus:
        EventBus(listeners: List<EventListener>(), next_listener_id: 1)

    # Register a global listener. Returns listener ID for unlisten.
    me listen(event_name: text, handler: fn(text)) -> i64:
        val id = self.next_listener_id
        self.next_listener_id = self.next_listener_id + 1
        val listener = EventListener.create(id, event_name, "", handler)
        self.listeners.push(listener)
        id

    # Register a window-scoped listener.
    me listen_window(window_label: text, event_name: text, handler: fn(text)) -> i64:
        val id = self.next_listener_id
        self.next_listener_id = self.next_listener_id + 1
        val listener = EventListener.create(id, event_name, window_label, handler)
        self.listeners.push(listener)
        id

    # Remove a listener by ID.
    me unlisten(listener_id: i64):
        var kept = List<EventListener>()
        for listener in self.listeners:
            if listener.id != listener_id:
                kept.push(listener)
        self.listeners = kept

    # Emit a global event to all matching listeners (global only).
    me emit(event_name: text, payload: text):
        for listener in self.listeners:
            if listener.event_name == event_name:
                if listener.window_label.len() == 0:
                    listener.handler(payload)

    # Emit to a specific window's listeners plus global listeners.
    me emit_to(window_label: text, event_name: text, payload: text):
        for listener in self.listeners:
            if listener.event_name == event_name:
                val label = listener.window_label
                if label.len() == 0 or label == window_label:
                    listener.handler(payload)

    # Emit to all listeners regardless of window scope.
    me emit_all(event_name: text, payload: text):
        for listener in self.listeners:
            if listener.event_name == event_name:
                listener.handler(payload)

    # Get count of registered listeners.
    fn listener_count() -> i64:
        self.listeners.len()
