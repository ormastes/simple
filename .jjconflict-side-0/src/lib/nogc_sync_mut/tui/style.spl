#![allow(unnamed_duplicate_typed_args)]
"""TUI Style Module - Colors and text styling via ANSI escape codes.

@tag:stdlib
@tag:tui

Provides color definitions, style composition, and ANSI rendering for
terminal UI text. Supports 8 basic colors plus RGB, and attributes
like bold, italic, underline, and dim.

# Usage

```simple
use std.tui.style.*

val s = make_style(COLOR_RED, COLOR_NONE, true, false, false, false)
val output = styled("Error!", s)
print output
```
"""

# ============================================================================
# Color Constants (foreground codes)
# ============================================================================

val COLOR_NONE: i64 = -1
val COLOR_BLACK: i64 = 0
val COLOR_RED: i64 = 1
val COLOR_GREEN: i64 = 2
val COLOR_YELLOW: i64 = 3
val COLOR_BLUE: i64 = 4
val COLOR_MAGENTA: i64 = 5
val COLOR_CYAN: i64 = 6
val COLOR_WHITE: i64 = 7

# ============================================================================
# RGB Color
# ============================================================================

struct RgbColor:
    """An RGB color with 8-bit channels.

    Fields:
        r: Red channel (0-255)
        g: Green channel (0-255)
        b: Blue channel (0-255)
    """
    r: i64
    g: i64
    b: i64

# ============================================================================
# Style
# ============================================================================

struct Style:
    """Text style combining foreground, background, and attributes.

    Fields:
        fg: Foreground color constant (COLOR_NONE for default)
        bg: Background color constant (COLOR_NONE for default)
        bold: Whether text is bold
        italic: Whether text is italic
        underline: Whether text is underlined
        dim: Whether text is dimmed
        fg_rgb: Optional RGB foreground (used when fg == -2)
        bg_rgb: Optional RGB background (used when bg == -2)
    """
    fg: i64
    bg: i64
    bold: bool
    italic: bool
    underline: bool
    dim: bool
    fg_rgb: RgbColor
    bg_rgb: RgbColor

# ============================================================================
# Sentinel for RGB mode
# ============================================================================

val COLOR_RGB: i64 = -2

# ============================================================================
# Factory Functions
# ============================================================================

fn make_style(fg: i64, bg: i64, bold: bool, italic: bool, underline: bool, dim: bool) -> Style:
    """Create a style with basic color constants.

    Args:
        fg: Foreground color (COLOR_RED, COLOR_NONE, etc.)
        bg: Background color (COLOR_RED, COLOR_NONE, etc.)
        bold: Enable bold
        italic: Enable italic
        underline: Enable underline
        dim: Enable dim

    Returns:
        Style with the given attributes
    """
    Style(
        fg: fg,
        bg: bg,
        bold: bold,
        italic: italic,
        underline: underline,
        dim: dim,
        fg_rgb: RgbColor(r: 0, g: 0, b: 0),
        bg_rgb: RgbColor(r: 0, g: 0, b: 0)
    )

fn make_style_rgb(fg_rgb: RgbColor, bg_rgb: RgbColor, bold: bool, italic: bool, underline: bool, dim: bool) -> Style:
    """Create a style with RGB colors.

    Args:
        fg_rgb: Foreground RGB color
        bg_rgb: Background RGB color
        bold: Enable bold
        italic: Enable italic
        underline: Enable underline
        dim: Enable dim

    Returns:
        Style with RGB colors
    """
    Style(
        fg: COLOR_RGB,
        bg: COLOR_RGB,
        bold: bold,
        italic: italic,
        underline: underline,
        dim: dim,
        fg_rgb: fg_rgb,
        bg_rgb: bg_rgb
    )

fn default_style() -> Style:
    """Create a style with no modifications (default terminal appearance)."""
    make_style(COLOR_NONE, COLOR_NONE, false, false, false, false)

fn fg_style(color: i64) -> Style:
    """Create a style with only foreground color set."""
    make_style(color, COLOR_NONE, false, false, false, false)

fn bold_style() -> Style:
    """Create a bold style with default colors."""
    make_style(COLOR_NONE, COLOR_NONE, true, false, false, false)

# ============================================================================
# ANSI Code Generation
# ============================================================================

fn fg_ansi_code(color: i64) -> text:
    """Convert a basic color constant to an ANSI foreground code.

    Args:
        color: Color constant (COLOR_BLACK through COLOR_WHITE)

    Returns:
        ANSI escape sequence for foreground color, or "" for COLOR_NONE
    """
    if color == COLOR_NONE:
        return ""
    val code = 30 + color
    "\033[{code}m"

fn bg_ansi_code(color: i64) -> text:
    """Convert a basic color constant to an ANSI background code.

    Args:
        color: Color constant (COLOR_BLACK through COLOR_WHITE)

    Returns:
        ANSI escape sequence for background color, or "" for COLOR_NONE
    """
    if color == COLOR_NONE:
        return ""
    val code = 40 + color
    "\033[{code}m"

fn fg_rgb_ansi_code(rgb: RgbColor) -> text:
    """Generate ANSI 24-bit foreground color code.

    Args:
        rgb: RGB color

    Returns:
        ANSI escape sequence for 24-bit foreground color
    """
    "\033[38;2;{rgb.r};{rgb.g};{rgb.b}m"

fn bg_rgb_ansi_code(rgb: RgbColor) -> text:
    """Generate ANSI 24-bit background color code.

    Args:
        rgb: RGB color

    Returns:
        ANSI escape sequence for 24-bit background color
    """
    "\033[48;2;{rgb.r};{rgb.g};{rgb.b}m"

# ============================================================================
# Style Application
# ============================================================================

fn style_to_ansi(s: Style) -> text:
    """Convert a Style to its ANSI escape prefix string.

    Concatenates all relevant ANSI codes for the style's attributes.

    Args:
        s: Style to convert

    Returns:
        Combined ANSI escape sequence string
    """
    var result = ""

    # Bold
    if s.bold:
        result = "{result}\033[1m"

    # Dim
    if s.dim:
        result = "{result}\033[2m"

    # Italic
    if s.italic:
        result = "{result}\033[3m"

    # Underline
    if s.underline:
        result = "{result}\033[4m"

    # Foreground
    if s.fg == COLOR_RGB:
        result = "{result}{fg_rgb_ansi_code(s.fg_rgb)}"
    else:
        if s.fg != COLOR_NONE:
            result = "{result}{fg_ansi_code(s.fg)}"

    # Background
    if s.bg == COLOR_RGB:
        result = "{result}{bg_rgb_ansi_code(s.bg_rgb)}"
    else:
        if s.bg != COLOR_NONE:
            result = "{result}{bg_ansi_code(s.bg)}"

    result

fn styled(content: text, s: Style) -> text:
    """Wrap text with ANSI escape codes for the given style.

    Args:
        content: The text to style
        s: Style to apply

    Returns:
        Text wrapped with ANSI prefix and reset suffix

    Example:
        val s = fg_style(COLOR_RED)
        print styled("error", s)  # prints red text
    """
    val prefix = style_to_ansi(s)
    if prefix == "":
        return content
    "{prefix}{content}\033[0m"

# ============================================================================
# Styled Text Segment
# ============================================================================

struct StyledSegment:
    """A segment of text with an associated style.

    Used to build styled lines composed of multiple differently-styled segments.

    Fields:
        content: The text content
        style: The style to render this segment with
    """
    content: text
    style: Style

struct StyledLine:
    """A line composed of styled segments.

    Fields:
        segments: List of StyledSegment making up this line
    """
    segments: [StyledSegment]

fn make_segment(content: text, style: Style) -> StyledSegment:
    """Create a styled text segment."""
    StyledSegment(content: content, style: style)

fn make_plain_segment(content: text) -> StyledSegment:
    """Create a plain (unstyled) text segment."""
    StyledSegment(content: content, style: default_style())

fn make_line(segments: [StyledSegment]) -> StyledLine:
    """Create a styled line from segments."""
    StyledLine(segments: segments)

fn make_plain_line(content: text) -> StyledLine:
    """Create a line with a single unstyled segment."""
    StyledLine(segments: [make_plain_segment(content)])

fn make_styled_line(content: text, style: Style) -> StyledLine:
    """Create a line with a single styled segment."""
    StyledLine(segments: [make_segment(content, style)])

fn render_line(line: StyledLine) -> text:
    """Render a StyledLine to a string with ANSI escape codes.

    Args:
        line: The styled line to render

    Returns:
        Text string with embedded ANSI codes
    """
    var result = ""
    var i = 0
    while i < len(line.segments):
        val seg = line.segments[i]
        result = "{result}{styled(seg.content, seg.style)}"
        i = i + 1
    result

fn render_lines(lines: [StyledLine]) -> text:
    """Render multiple StyledLines joined by newlines.

    Args:
        lines: List of styled lines

    Returns:
        Newline-separated rendered text
    """
    var result = ""
    var i = 0
    while i < len(lines):
        if i > 0:
            result = "{result}\n"
        result = "{result}{render_line(lines[i])}"
        i = i + 1
    result
