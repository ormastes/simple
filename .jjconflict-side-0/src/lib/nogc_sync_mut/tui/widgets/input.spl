"""TUI Input Widget - Single-line text input field.

@tag:stdlib
@tag:tui

Provides a text input field with cursor tracking, character insertion
and deletion, and styled rendering.

# Usage

```simple
use std.tui.widgets.input.*
use std.tui.widget.{make_rect}
use std.tui.style.{fg_style, COLOR_WHITE}

var inp = make_input_widget("Enter name: ", fg_style(COLOR_WHITE))
inp = input_insert_char(inp, "H")
inp = input_insert_char(inp, "i")
val lines = input_render(inp, make_rect(0, 0, 40, 1))
```
"""

use std.tui.style.{Style, StyledLine, StyledSegment, default_style,
                     make_segment, make_line, make_styled_line}
use std.tui.widget.{Rect, pad_or_truncate}

# ============================================================================
# Input Widget
# ============================================================================

struct InputWidget:
    """A single-line text input field.

    Fields:
        prompt: Prompt text displayed before the input
        value: Current input text value
        cursor_pos: Cursor position within value (0 = before first char)
        style: Style for the input text
        focused: Whether the input currently has focus
    """
    prompt: text
    value: text
    cursor_pos: i64
    style: Style
    focused: bool

fn make_input_widget(prompt: text, style: Style) -> InputWidget:
    """Create an empty input widget.

    Args:
        prompt: Prompt text to display before input
        style: Style for the input text

    Returns:
        InputWidget with empty value and cursor at position 0
    """
    InputWidget(
        prompt: prompt,
        value: "",
        cursor_pos: 0,
        style: style,
        focused: true
    )

fn make_input_widget_with_value(prompt: text, value: text, style: Style) -> InputWidget:
    """Create an input widget with an initial value.

    Args:
        prompt: Prompt text
        value: Initial text value
        style: Style for the input text

    Returns:
        InputWidget with cursor at end of value
    """
    InputWidget(
        prompt: prompt,
        value: value,
        cursor_pos: len(value),
        style: style,
        focused: true
    )

# ============================================================================
# Text Editing
# ============================================================================

fn input_insert_char(widget: InputWidget, ch: text) -> InputWidget:
    """Insert a character at the cursor position.

    Args:
        widget: The input widget
        ch: Character to insert (single character string)

    Returns:
        Updated InputWidget with character inserted
    """
    val before = substring(widget.value, 0, widget.cursor_pos)
    val after = substring(widget.value, widget.cursor_pos, len(widget.value))
    val new_value = "{before}{ch}{after}"
    InputWidget(
        prompt: widget.prompt,
        value: new_value,
        cursor_pos: widget.cursor_pos + len(ch),
        style: widget.style,
        focused: widget.focused
    )

fn input_delete_back(widget: InputWidget) -> InputWidget:
    """Delete the character before the cursor (backspace).

    Args:
        widget: The input widget

    Returns:
        Updated InputWidget with character deleted
    """
    if widget.cursor_pos <= 0:
        return widget
    val before = substring(widget.value, 0, widget.cursor_pos - 1)
    val after = substring(widget.value, widget.cursor_pos, len(widget.value))
    val new_value = "{before}{after}"
    InputWidget(
        prompt: widget.prompt,
        value: new_value,
        cursor_pos: widget.cursor_pos - 1,
        style: widget.style,
        focused: widget.focused
    )

fn input_delete_forward(widget: InputWidget) -> InputWidget:
    """Delete the character at the cursor position (delete key).

    Args:
        widget: The input widget

    Returns:
        Updated InputWidget with character deleted
    """
    if widget.cursor_pos >= len(widget.value):
        return widget
    val before = substring(widget.value, 0, widget.cursor_pos)
    val after = substring(widget.value, widget.cursor_pos + 1, len(widget.value))
    val new_value = "{before}{after}"
    InputWidget(
        prompt: widget.prompt,
        value: new_value,
        cursor_pos: widget.cursor_pos,
        style: widget.style,
        focused: widget.focused
    )

# ============================================================================
# Cursor Movement
# ============================================================================

fn input_move_left(widget: InputWidget) -> InputWidget:
    """Move cursor one position to the left."""
    if widget.cursor_pos <= 0:
        return widget
    InputWidget(
        prompt: widget.prompt,
        value: widget.value,
        cursor_pos: widget.cursor_pos - 1,
        style: widget.style,
        focused: widget.focused
    )

fn input_move_right(widget: InputWidget) -> InputWidget:
    """Move cursor one position to the right."""
    if widget.cursor_pos >= len(widget.value):
        return widget
    InputWidget(
        prompt: widget.prompt,
        value: widget.value,
        cursor_pos: widget.cursor_pos + 1,
        style: widget.style,
        focused: widget.focused
    )

fn input_move_home(widget: InputWidget) -> InputWidget:
    """Move cursor to the beginning of the input."""
    InputWidget(
        prompt: widget.prompt,
        value: widget.value,
        cursor_pos: 0,
        style: widget.style,
        focused: widget.focused
    )

fn input_move_end(widget: InputWidget) -> InputWidget:
    """Move cursor to the end of the input."""
    InputWidget(
        prompt: widget.prompt,
        value: widget.value,
        cursor_pos: len(widget.value),
        style: widget.style,
        focused: widget.focused
    )

# ============================================================================
# Focus
# ============================================================================

fn input_set_focus(widget: InputWidget, focused: bool) -> InputWidget:
    """Set the focus state of the input widget.

    Args:
        widget: The input widget
        focused: Whether the input should be focused

    Returns:
        Updated InputWidget
    """
    InputWidget(
        prompt: widget.prompt,
        value: widget.value,
        cursor_pos: widget.cursor_pos,
        style: widget.style,
        focused: focused
    )

fn input_clear(widget: InputWidget) -> InputWidget:
    """Clear the input value and reset cursor.

    Returns:
        InputWidget with empty value
    """
    InputWidget(
        prompt: widget.prompt,
        value: "",
        cursor_pos: 0,
        style: widget.style,
        focused: widget.focused
    )

# ============================================================================
# Rendering
# ============================================================================

fn input_render(widget: InputWidget, area: Rect) -> [StyledLine]:
    """Render an InputWidget into styled lines.

    Displays the prompt followed by the value. When focused, a cursor
    indicator is shown. Scrolls horizontally if the text exceeds width.

    Args:
        widget: The input widget
        area: Target area (only first row is used)

    Returns:
        List of StyledLine (one line for the input)
    """
    val prompt_len = len(widget.prompt)
    val available_width = area.width - prompt_len
    var result: [StyledLine] = []

    if available_width <= 0:
        # Not enough space for anything; just show truncated prompt
        val truncated_prompt = pad_or_truncate(widget.prompt, area.width)
        result = result + [make_styled_line(truncated_prompt, widget.style)]
        # Fill remaining rows
        var i = 1
        while i < area.height:
            result = result + [make_styled_line(pad_or_truncate("", area.width), default_style())]
            i = i + 1
        return result

    # Calculate visible portion of value
    var display_start: i64 = 0
    if widget.cursor_pos > available_width - 1:
        display_start = widget.cursor_pos - available_width + 1

    val visible_value = substring(widget.value, display_start, len(widget.value))
    val display_text = pad_or_truncate(visible_value, available_width)

    # Build line with prompt + value
    var segments: [StyledSegment] = []
    segments = segments + [make_segment(widget.prompt, default_style())]
    segments = segments + [make_segment(display_text, widget.style)]
    result = result + [make_line(segments)]

    # Fill remaining rows with blanks
    var row = 1
    while row < area.height:
        result = result + [make_styled_line(pad_or_truncate("", area.width), default_style())]
        row = row + 1

    result

fn input_cursor_screen_col(widget: InputWidget, area: Rect) -> i64:
    """Calculate the screen column of the cursor.

    Useful for positioning the terminal cursor after rendering.

    Args:
        widget: The input widget
        area: The area where the input was rendered

    Returns:
        Column position (0-based) where the cursor should appear
    """
    val prompt_len = len(widget.prompt)
    val available_width = area.width - prompt_len
    if available_width <= 0:
        return area.x

    var display_start: i64 = 0
    if widget.cursor_pos > available_width - 1:
        display_start = widget.cursor_pos - available_width + 1

    val visible_cursor = widget.cursor_pos - display_start
    area.x + prompt_len + visible_cursor
