# wave2_dispatch.spl — Wave 2 dispatch: scalar fallback + width decomposition
#
# Closes the dispatch gap where rt_simd_add_i32x4 / rt_simd_sub_i32x4 /
# rt_simd_mul_i32x4 (and i32x8 siblings) are declared as externs but have
# no interpreter dispatch arm.  Consumers can use these pure-Simple fallback
# functions instead of trapping on the FFI dispatcher.
#
# Also provides width-decomposition fallback for f32x8 and f64x4 operations
# on hosts without AVX, by splitting wider vectors into narrower ones that
# the existing rt_simd_*_f32x4 externs can handle.
#
# @tag:stdlib
# @tag:simd

use std.simd

# ============================================================================
# i32x4 Scalar Fallback  (AC-1)
# ============================================================================

fn scalar_add_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
    """Pure-Simple add for i32x4 — no extern call."""
    vec4i_from_array([a.lane(0) + b.lane(0), a.lane(1) + b.lane(1), a.lane(2) + b.lane(2), a.lane(3) + b.lane(3)])

fn scalar_sub_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
    """Pure-Simple subtract for i32x4 — no extern call."""
    vec4i_from_array([a.lane(0) - b.lane(0), a.lane(1) - b.lane(1), a.lane(2) - b.lane(2), a.lane(3) - b.lane(3)])

fn scalar_mul_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
    """Pure-Simple multiply for i32x4 — no extern call."""
    vec4i_from_array([a.lane(0) * b.lane(0), a.lane(1) * b.lane(1), a.lane(2) * b.lane(2), a.lane(3) * b.lane(3)])

# ============================================================================
# i32x8 Scalar Fallback  (AC-2)
# ============================================================================

fn scalar_add_i32x8(a: Vec8i, b: Vec8i) -> Vec8i:
    """Pure-Simple add for i32x8 — no extern call."""
    vec8i_from_array([a.lane(0) + b.lane(0), a.lane(1) + b.lane(1), a.lane(2) + b.lane(2), a.lane(3) + b.lane(3), a.lane(4) + b.lane(4), a.lane(5) + b.lane(5), a.lane(6) + b.lane(6), a.lane(7) + b.lane(7)])

fn scalar_sub_i32x8(a: Vec8i, b: Vec8i) -> Vec8i:
    """Pure-Simple subtract for i32x8 — no extern call."""
    vec8i_from_array([a.lane(0) - b.lane(0), a.lane(1) - b.lane(1), a.lane(2) - b.lane(2), a.lane(3) - b.lane(3), a.lane(4) - b.lane(4), a.lane(5) - b.lane(5), a.lane(6) - b.lane(6), a.lane(7) - b.lane(7)])

fn scalar_mul_i32x8(a: Vec8i, b: Vec8i) -> Vec8i:
    """Pure-Simple multiply for i32x8 — no extern call."""
    vec8i_from_array([a.lane(0) * b.lane(0), a.lane(1) * b.lane(1), a.lane(2) * b.lane(2), a.lane(3) * b.lane(3), a.lane(4) * b.lane(4), a.lane(5) * b.lane(5), a.lane(6) * b.lane(6), a.lane(7) * b.lane(7)])

# ============================================================================
# f32x8 Width Decomposition Fallback  (AC-4)
# ============================================================================

fn decompose_f32x8_add(a: Vec8f, b: Vec8f) -> Vec8f:
    """Add two Vec8f by decomposing into scalar f32 arithmetic.
    Used on hosts without AVX where rt_simd_add_f32x8 may not dispatch."""
    vec8f_from_array([a.lane(0) + b.lane(0), a.lane(1) + b.lane(1), a.lane(2) + b.lane(2), a.lane(3) + b.lane(3), a.lane(4) + b.lane(4), a.lane(5) + b.lane(5), a.lane(6) + b.lane(6), a.lane(7) + b.lane(7)])

fn decompose_f32x8_sub(a: Vec8f, b: Vec8f) -> Vec8f:
    """Subtract two Vec8f by decomposing into scalar f32 arithmetic."""
    vec8f_from_array([a.lane(0) - b.lane(0), a.lane(1) - b.lane(1), a.lane(2) - b.lane(2), a.lane(3) - b.lane(3), a.lane(4) - b.lane(4), a.lane(5) - b.lane(5), a.lane(6) - b.lane(6), a.lane(7) - b.lane(7)])

fn decompose_f32x8_mul(a: Vec8f, b: Vec8f) -> Vec8f:
    """Multiply two Vec8f by decomposing into scalar f32 arithmetic."""
    vec8f_from_array([a.lane(0) * b.lane(0), a.lane(1) * b.lane(1), a.lane(2) * b.lane(2), a.lane(3) * b.lane(3), a.lane(4) * b.lane(4), a.lane(5) * b.lane(5), a.lane(6) * b.lane(6), a.lane(7) * b.lane(7)])

# ============================================================================
# f64x4 Width Decomposition Fallback  (AC-5)
# ============================================================================

fn decompose_f64x4_add(a: Vec4d, b: Vec4d) -> Vec4d:
    """Add two Vec4d by decomposing into scalar f64 arithmetic.
    Used on hosts without AVX where rt_simd_add_f64x4 may not dispatch."""
    vec4d_from_array([a.lane(0) + b.lane(0), a.lane(1) + b.lane(1), a.lane(2) + b.lane(2), a.lane(3) + b.lane(3)])

fn decompose_f64x4_sub(a: Vec4d, b: Vec4d) -> Vec4d:
    """Subtract two Vec4d by decomposing into scalar f64 arithmetic."""
    vec4d_from_array([a.lane(0) - b.lane(0), a.lane(1) - b.lane(1), a.lane(2) - b.lane(2), a.lane(3) - b.lane(3)])

fn decompose_f64x4_mul(a: Vec4d, b: Vec4d) -> Vec4d:
    """Multiply two Vec4d by decomposing into scalar f64 arithmetic."""
    vec4d_from_array([a.lane(0) * b.lane(0), a.lane(1) * b.lane(1), a.lane(2) * b.lane(2), a.lane(3) * b.lane(3)])

# ============================================================================
# Wave2Dispatcher — width-aware dispatch with scalar fallback  (AC-3)
# ============================================================================

class Wave2Dispatcher:
    """Selects scalar fallback vs SIMD tier for i32x4/i32x8/f32x8/f64x4 ops.
    When the active tier is 'scalar' (or externs are unavailable), uses the
    pure-Simple field-arithmetic implementations above.  When a hardware tier
    is active, delegates to the rt_simd_* extern wrappers in simd.spl."""
    active_tier: text
    use_scalar_i32: bool
    use_scalar_f32x8: bool
    use_scalar_f64x4: bool

impl Wave2Dispatcher:
    static fn create() -> Wave2Dispatcher:
        """Auto-detect: use scalar fallback for integer ops (externs missing),
        and decomposition for wider FP when AVX is not confirmed."""
        val tier = profile_name()
        val has_wide = has_avx2()
        Wave2Dispatcher(
            active_tier: tier,
            use_scalar_i32: true,
            use_scalar_f32x8: has_wide == false,
            use_scalar_f64x4: has_wide == false
        )

    static fn force_scalar() -> Wave2Dispatcher:
        """Force all operations through scalar fallback (testing/debug)."""
        Wave2Dispatcher(
            active_tier: "scalar",
            use_scalar_i32: true,
            use_scalar_f32x8: true,
            use_scalar_f64x4: true
        )

    static fn with_tier(tier: text, wide_available: bool) -> Wave2Dispatcher:
        """Explicit tier selection for codegen integration."""
        Wave2Dispatcher(
            active_tier: tier,
            use_scalar_i32: true,
            use_scalar_f32x8: wide_available == false,
            use_scalar_f64x4: wide_available == false
        )

    # -- i32x4 dispatch (always scalar until externs are backfilled) --

    me add_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
        """Dispatch i32x4 add: scalar fallback (extern gap)."""
        scalar_add_i32x4(a, b)

    me sub_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
        """Dispatch i32x4 sub: scalar fallback (extern gap)."""
        scalar_sub_i32x4(a, b)

    me mul_i32x4(a: Vec4i, b: Vec4i) -> Vec4i:
        """Dispatch i32x4 mul: scalar fallback (extern gap)."""
        scalar_mul_i32x4(a, b)

    # -- i32x8 dispatch (always scalar until externs are backfilled) --

    me add_i32x8(a: Vec8i, b: Vec8i) -> Vec8i:
        """Dispatch i32x8 add: scalar fallback (extern gap)."""
        scalar_add_i32x8(a, b)

    me sub_i32x8(a: Vec8i, b: Vec8i) -> Vec8i:
        """Dispatch i32x8 sub: scalar fallback (extern gap)."""
        scalar_sub_i32x8(a, b)

    me mul_i32x8(a: Vec8i, b: Vec8i) -> Vec8i:
        """Dispatch i32x8 mul: scalar fallback (extern gap)."""
        scalar_mul_i32x8(a, b)

    # -- f32x8 dispatch (scalar decomposition vs hardware) --

    me add_f32x8(a: Vec8f, b: Vec8f) -> Vec8f:
        """Dispatch f32x8 add: decomposition fallback or hardware."""
        if self.use_scalar_f32x8 == true:
            decompose_f32x8_add(a, b)
        else:
            simd_add_f32x8(a, b)

    me sub_f32x8(a: Vec8f, b: Vec8f) -> Vec8f:
        """Dispatch f32x8 sub: decomposition fallback or hardware."""
        if self.use_scalar_f32x8 == true:
            decompose_f32x8_sub(a, b)
        else:
            simd_sub_f32x8(a, b)

    me mul_f32x8(a: Vec8f, b: Vec8f) -> Vec8f:
        """Dispatch f32x8 mul: decomposition fallback or hardware."""
        if self.use_scalar_f32x8 == true:
            decompose_f32x8_mul(a, b)
        else:
            simd_mul_f32x8(a, b)

    # -- f64x4 dispatch (scalar decomposition vs hardware) --

    me add_f64x4(a: Vec4d, b: Vec4d) -> Vec4d:
        """Dispatch f64x4 add: decomposition fallback or hardware."""
        if self.use_scalar_f64x4 == true:
            decompose_f64x4_add(a, b)
        else:
            simd_add_f64x4(a, b)

    me sub_f64x4(a: Vec4d, b: Vec4d) -> Vec4d:
        """Dispatch f64x4 sub: decomposition fallback or hardware."""
        if self.use_scalar_f64x4 == true:
            decompose_f64x4_sub(a, b)
        else:
            simd_sub_f64x4(a, b)

    me mul_f64x4(a: Vec4d, b: Vec4d) -> Vec4d:
        """Dispatch f64x4 mul: decomposition fallback or hardware."""
        if self.use_scalar_f64x4 == true:
            decompose_f64x4_mul(a, b)
        else:
            simd_mul_f64x4(a, b)

    # -- summary --

    me summary() -> text:
        """Human-readable dispatch configuration."""
        "Wave2Dispatcher tier=" + self.active_tier +
            " scalar_i32=" + self.use_scalar_i32.to_text() +
            " scalar_f32x8=" + self.use_scalar_f32x8.to_text() +
            " scalar_f64x4=" + self.use_scalar_f64x4.to_text()
