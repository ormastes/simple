# ============================================================================
# game_net/demo_sim.spl — minimal deterministic 2D integrator entity
#
# Netcode plan P2 calls for "a fixed-step sim (game2d/loop step fn)" that is
# "callable standalone for replay". Per implementation-lane guidance this is
# a MINIMAL deterministic demo sim (a 2D integrator), deliberately NOT coupled
# to rollball or the game2d/loop App trait — the netcode vertical slice only
# needs a pure, side-effect-free step function that client prediction, server
# authority, and rewind-and-replay can all call identically.
#
# `sim_step` is pure: same (state, input, dt) always produces the same
# SimState, which is the entire determinism argument the plan leans on
# (rollball already proved bit-identical replay for this f32 arithmetic
# shape).
# ============================================================================

val SPEED: f32 = 5.0

struct SimState:
    """One entity's simulated position/velocity."""
    entity_id: u32
    pos_x: f32
    pos_y: f32
    vel_x: f32
    vel_y: f32

fn sim_state_new(entity_id: u32) -> SimState:
    SimState(entity_id: entity_id, pos_x: 0.0, pos_y: 0.0, vel_x: 0.0, vel_y: 0.0)

fn sim_step(state: SimState, move_x: f32, move_y: f32, dt: f32) -> SimState:
    """Pure fixed-step integrator: velocity = input * SPEED, position += velocity * dt."""
    val vx = move_x * SPEED
    val vy = move_y * SPEED
    val px = state.pos_x + vx * dt
    val py = state.pos_y + vy * dt
    SimState(entity_id: state.entity_id, pos_x: px, pos_y: py, vel_x: vx, vel_y: vy)

export SPEED
export SimState
export sim_state_new, sim_step
