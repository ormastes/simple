# AOP deny advice — woven at matched join points by the MDSOC weaving engine.
#
# These functions are NOT called directly by business code.
# The capsule.sdn weaving rules inject them at compile time.
#
# The @deny_all annotation triggers unconditional rejection of all requests
# to an endpoint, used for maintenance mode or deprecated endpoints.

use std.security.types.{SecurityEvent, AuditEntry, AuditConfig}
use std.security.audit_log.{log_security_event}
use compiler.mdsoc.weaving.join_point.{JoinPointContext}

## Before advice that unconditionally denies access.
##
## Used for @deny_all annotated handlers, typically during maintenance
## windows or for deprecated endpoints. Logs an AccessDenied event
## and returns an error before the handler can execute.
## Woven at: execution(*.handle_request) & within(std.http.**) & annotation(@deny_all)
fn deny_all_before(ctx: JoinPointContext):
    val config = AuditConfig.default()

    val peer_addr = _extract_peer(ctx)

    val event = SecurityEvent.AccessDenied(
        resource: ctx.function_name,
        capability: "all",
        peer: peer_addr
    )

    val entry = AuditEntry.new(
        event: event,
        correlation_id: _generate_deny_id(ctx),
        module_path: ctx.module_path
    )

    log_security_event(entry, config)
    return Err("endpoint is in maintenance mode")

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

## Extract peer address from join point attributes.
fn _extract_peer(ctx: JoinPointContext) -> text:
    for attr in ctx.attributes:
        if attr.starts_with("peer="):
            return attr.slice(5, attr.len())
    "maintenance"

## Generate a correlation ID for deny events.
fn _generate_deny_id(ctx: JoinPointContext) -> text:
    use std.nogc_sync_mut.io.time_ops.{current_time_ms}
    val ts = current_time_ms()
    "{ts}-deny-{ctx.module_path}"
