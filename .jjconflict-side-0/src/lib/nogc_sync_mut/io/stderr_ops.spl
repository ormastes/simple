# Minimal stderr facade — lets apps log errors without importing std.log
# (keeps MCP-style handshake closures small) and without direct rt_* externs
# in app code (direct-rt gates in scripts/check/check-mcp-native-smoke.shs).

extern fn rt_stderr_write(s: text)
extern fn rt_stderr_flush()

pub fn stderr_write(s: text):
    rt_stderr_write(s)

pub fn stderr_flush():
    rt_stderr_flush()
