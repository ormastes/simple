# fs.nvfs.extent_map — logical-to-physical extent mapping.
#
# Every file is described by a sequence of ExtentMapEntry rows, one per
# contiguous (arena_id, offset, length) run. The ExtentMap trait is the
# lookup / update surface. Concrete impl lives in
# examples/nvfs/src/core/extent.spl.
#
# Source: doc/05_design/nvfs_design.md §3 (classes & extents).

struct ExtentMapEntry:
    """One extent — a contiguous physical run backing a logical byte range.

    Fields:
      logical_off  — byte offset within the logical file.
      arena_id     — backing ArenaHandle.id.
      phys_off     — byte offset inside the backing arena.
      length       — extent length in bytes.
      generation   — generation stamp when this extent was published.
    """
    logical_off: i64
    arena_id: i64
    phys_off: i64
    length: i64
    generation: i64

trait ExtentMap:
    """Lookup / insert / truncate extents for a single logical object."""
    fn lookup(logical_off: i64) -> ExtentMapEntry
    fn insert(entry: ExtentMapEntry) -> bool
    fn truncate(new_length: i64) -> bool
    fn total_length() -> i64
