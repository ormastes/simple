# NSIS Backend
#
# Uses makensis (Nullsoft Scriptable Install System) to generate
# Windows .exe installers from Linux.
#
# Install: apt install nsis

use std.io_runtime (process_run, file_exists, file_read, file_write, dir_create)

use lib.nogc_sync_mut.package.installer.types (InstallerConfig, InstallerResult, InstallerPlatform)
use lib.nogc_sync_mut.package.installer.staging (create_staging_dir, clean_staging_dir)


fn build_with_nsis(config: InstallerConfig) -> InstallerResult:
    """Build a Windows .exe installer using NSIS."""

    val platform = InstallerPlatform.WindowsExe

    # Create staging directory
    val staging_result = create_staging_dir(config, platform)
    if staging_result.is_err():
        return InstallerResult(
            platform: platform,
            success: false,
            output_path: "",
            message: staging_result.err()
        )

    val staging_path = staging_result.ok()

    # Ensure output directory exists
    dir_create(config.output_dir, recursive: true)

    # Read and process NSIS template
    val template_path = "config/packaging/windows/simple.nsi"
    if not file_exists(template_path):
        clean_staging_dir(config, platform)
        return InstallerResult(
            platform: platform,
            success: false,
            output_path: "",
            message: "NSIS template not found at {template_path}"
        )

    val template = file_read(template_path)

    # Substitute variables in template
    var script = template
    script = script.replace("${VERSION}", config.version)
    script = script.replace("${PACKAGE_NAME}", config.package_name)
    script = script.replace("${DISPLAY_NAME}", "Simple Language")
    script = script.replace("${DESCRIPTION}", config.description)
    script = script.replace("${PUBLISHER}", config.maintainer)
    script = script.replace("${HOMEPAGE}", config.homepage)
    script = script.replace("${SOURCE_DIR}", staging_path)
    script = script.replace("${OUTPUT_DIR}", config.output_dir)

    # Write processed script
    val script_path = "{config.output_dir}/simple-installer.nsi"
    file_write(script_path, script)

    # Output file path
    val output_file = "{config.output_dir}/{config.package_name}-{config.version}-setup.exe"

    # Run makensis
    val (stdout, stderr, code) = process_run("makensis", [
        "-NOCD",
        "-DOUTFILE={output_file}",
        script_path
    ])

    # Clean up staging and temp script
    clean_staging_dir(config, platform)

    if code != 0:
        return InstallerResult(
            platform: platform,
            success: false,
            output_path: "",
            message: "makensis failed (exit {code}): {stderr}"
        )

    InstallerResult(
        platform: platform,
        success: true,
        output_path: output_file,
        message: "Built Windows installer successfully"
    )
