# Installer Package Generator
#
# Cross-platform installation package generator for the Simple compiler.
# Generates native packages for Ubuntu (.deb), Windows (.exe), macOS (.pkg),
# and FreeBSD (.txz) using FPM + NSIS from Linux.
#
# Public API:
#   - build_installer(platform, config) -> InstallerResult
#   - build_all_installers(config) -> [InstallerResult]
#   - detect_tools() -> ToolAvailability
#   - default_installer_config() -> InstallerConfig
#
# Usage:
#   bin/simple build installer --platform=all
#   bin/simple build installer --platform=deb

# Re-export types
export InstallerPlatform, InstallerConfig, InstallerResult, ToolAvailability
export default_config

# Re-export tool detection
export detect_all_tools, check_tool_for_platform, print_tool_status

# Re-export public API
export build_installer, build_all_installers

use lib.nogc_sync_mut.package.installer.types (
    InstallerPlatform, InstallerConfig, InstallerResult, ToolAvailability, default_config
)
use lib.nogc_sync_mut.package.installer.tool_detect (
    detect_all_tools, check_tool_for_platform, print_tool_status
)
use lib.nogc_sync_mut.package.installer.backend_fpm (build_with_fpm)
use lib.nogc_sync_mut.package.installer.backend_nsis (build_with_nsis)
use lib.nogc_sync_mut.package.installer.backend_dpkg (build_with_dpkg)


fn build_installer(platform: InstallerPlatform, config: InstallerConfig) -> InstallerResult:
    """Build an installer package for a single platform.
    Automatically selects the best available backend."""

    val tools = detect_all_tools()

    # Check tool availability
    val tool_check = check_tool_for_platform(platform, tools)
    if tool_check.is_err():
        return InstallerResult(
            platform: platform,
            success: false,
            output_path: "",
            message: "Missing tool: {tool_check.err()}"
        )

    # Route to appropriate backend
    match platform:
        case InstallerPlatform.WindowsExe:
            build_with_nsis(config)

        case InstallerPlatform.Deb:
            # Prefer FPM, fall back to dpkg-deb
            if tools.fpm_available:
                build_with_fpm(config, platform)
            else:
                build_with_dpkg(config)

        case InstallerPlatform.Rpm | InstallerPlatform.MacosPkg | InstallerPlatform.FreeBsd:
            build_with_fpm(config, platform)

        case _:
            InstallerResult(
                platform: platform,
                success: false,
                output_path: "",
                message: "Unknown platform: {platform.to_string()}"
            )


fn build_all_installers(config: InstallerConfig) -> [InstallerResult]:
    """Build installer packages for all platforms.
    Skips platforms where required tools are missing."""

    val tools = detect_all_tools()
    var results: [InstallerResult] = []

    for platform in InstallerPlatform.all():
        val tool_check = check_tool_for_platform(platform, tools)
        if tool_check.is_ok():
            val result = build_installer(platform, config)
            results = results + [result]
        else:
            results = results + [InstallerResult(
                platform: platform,
                success: false,
                output_path: "",
                message: "Skipped: {tool_check.err()}"
            )]

    results
