# Engine3D — Top-level engine that owns all 3D subsystems
#
# The user-facing entry point for the Simple 3D game engine.
# Creates and manages the window, renderer, scene graph, component
# registry, physics world, input manager, audio system, and resources.
#
# Usage:
#   var engine = Engine3D.create("My 3D Game", 800, 600)
#   val node_id = engine.create_node("player")
#   val mesh_id = engine.create_mesh_node("cube", cube_mesh, material)
#   engine.destroy()

use std.common.engine.ids.{NodeId}
use std.common.engine.math3d.{Vec3, Quaternion}
use std.nogc_sync_mut.engine.scene.node3d.{Node3D, NodeStore3D}
use std.nogc_sync_mut.engine.component.registry3d.{ComponentRegistry3D, Component3D}
use std.nogc_sync_mut.engine.component.mesh.{MeshData}
use std.nogc_sync_mut.engine.render.material3d.{Material3D}
use std.nogc_sync_mut.engine.physics.world3d.{PhysicsWorld3D}
use std.nogc_sync_mut.engine.physics.types3d.{PhysicsConfig3D, default_physics_config_3d}
use std.nogc_sync_mut.engine.input.input_manager.{InputManager}
use std.nogc_sync_mut.engine.audio.audio_manager.{AudioManager}
use std.nogc_sync_mut.engine.audio.types.{AudioConfig, default_audio_config}
use std.nogc_sync_mut.engine.render.renderer3d.{ForwardRenderer3D}
use std.nogc_sync_mut.engine.resource.manager.{ResourceManager}
use std.nogc_sync_mut.io.window_ffi.{
    EventLoop, Window,
    window_create_event_loop, window_create, window_destroy,
    window_destroy_event_loop
}

# ============================================================================
# Engine3D
# ============================================================================

class Engine3D:
    """Top-level engine owning all 3D game subsystems.

    Provides a simple API for creating nodes, attaching components,
    and managing the game lifecycle. Subsystem fields are public so
    the game loop and user code can access them directly.
    """
    nodes: NodeStore3D
    components: ComponentRegistry3D
    physics: PhysicsWorld3D
    input: InputManager
    audio: AudioManager
    renderer: ForwardRenderer3D
    resources: ResourceManager
    window_handle: i64
    event_loop_handle: i64

impl Engine3D:
    static fn create(title: text, width: i64, height: i64) -> Engine3D:
        """Create an engine with default physics and audio configs.

        Opens a window, initializes all subsystems, and returns a ready
        engine. Use with GameLoop3D.run() to start the game.

        Args:
            title: Window title
            width: Window width in pixels
            height: Window height in pixels

        Returns:
            A fully initialized Engine3D
        """
        Engine3D.create_with_config(
            title, width, height,
            default_physics_config_3d(),
            default_audio_config()
        )

    static fn create_with_config(title: text, width: i64, height: i64, physics_config: PhysicsConfig3D, audio_config: AudioConfig) -> Engine3D:
        """Create an engine with custom physics and audio configs.

        Args:
            title: Window title
            width: Window width in pixels
            height: Window height in pixels
            physics_config: Physics world parameters
            audio_config: Audio system parameters

        Returns:
            A fully initialized Engine3D
        """
        # Create window system
        val event_loop = window_create_event_loop()
        val window = window_create(event_loop, width, height, title)

        # Create all subsystems
        val nodes = NodeStore3D.create()
        val components = ComponentRegistry3D.create()
        val physics = PhysicsWorld3D.create(physics_config)
        val input = InputManager.create(event_loop.handle)
        val audio = AudioManager.create(audio_config)
        val renderer = ForwardRenderer3D.create(width, height)
        val resources = ResourceManager.create("assets")

        Engine3D(
            nodes: nodes,
            components: components,
            physics: physics,
            input: input,
            audio: audio,
            renderer: renderer,
            resources: resources,
            window_handle: window.handle,
            event_loop_handle: event_loop.handle
        )

    # ========================================================================
    # Scene Graph Helpers
    # ========================================================================

    me create_node(name: text) -> NodeId:
        """Create a new node in the 3D scene graph.

        Args:
            name: Human-readable name for the node

        Returns:
            NodeId handle for the new node
        """
        self.nodes.create_node(name)

    fn get_node(id: NodeId) -> Node3D?:
        """Look up a node by its handle.

        Args:
            id: NodeId from a previous create_node call

        Returns:
            The Node3D, or nil if not found
        """
        self.nodes.get_node(id)

    # ========================================================================
    # Component Helpers
    # ========================================================================

    me attach_component(node_id: NodeId, component: Component3D):
        """Attach a component to a node.

        Args:
            node_id: Target node
            component: Component to attach
        """
        self.components.attach(node_id, component)

    me create_mesh_node(name: text, mesh: MeshData, material: Material3D) -> NodeId:
        """Create a node with a Mesh component attached.

        Convenience method that creates a node, builds a Mesh component
        from the given mesh data and material, and attaches it.

        Args:
            name: Node name
            mesh: Mesh geometry data
            material: Surface material

        Returns:
            NodeId of the newly created mesh node
        """
        val node_id = self.nodes.create_node(name)
        self.components.attach(node_id, Component3D.Mesh(mesh: mesh, material: material))
        node_id

    # ========================================================================
    # Lifecycle
    # ========================================================================

    me destroy():
        """Shut down all subsystems and close the window.

        Must be called when the game exits to release FFI resources.
        """
        self.input.destroy()
        self.physics.destroy()
        self.audio.destroy()
        val event_loop = EventLoop(
            handle: self.event_loop_handle,
            is_valid: self.event_loop_handle != 0
        )
        val window = Window(
            handle: self.window_handle,
            event_loop: event_loop,
            is_valid: self.window_handle != 0
        )
        window_destroy(window)
        window_destroy_event_loop(event_loop)
