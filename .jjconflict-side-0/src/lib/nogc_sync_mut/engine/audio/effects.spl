# Effects — Audio effect types and chain
#
# Defines filter and time-based audio effects as structs, an enum
# to hold any effect variant, and a mutable EffectsChain to manage
# an ordered list of effects for a bus or sound.
#
# Usage:
#   var chain = EffectsChain.empty()
#   chain.add(AudioEffect.LowPass(effect: LowPassEffect(cutoff_hz: 800.0)))
#   chain.add(AudioEffect.Reverb(effect: ReverbEffect(decay_seconds: 1.5, wet_dry_mix: 0.3)))

# ============================================================================
# Effect structs
# ============================================================================

struct LowPassEffect:
    """Low-pass filter that attenuates frequencies above cutoff_hz."""
    cutoff_hz: f64

struct HighPassEffect:
    """High-pass filter that attenuates frequencies below cutoff_hz."""
    cutoff_hz: f64

struct ReverbEffect:
    """Reverb effect with decay time and wet/dry mix.

    wet_dry_mix ranges from 0.0 (fully dry) to 1.0 (fully wet).
    """
    decay_seconds: f64
    wet_dry_mix: f64

struct DelayEffect:
    """Delay (echo) effect with time in milliseconds and feedback amount.

    feedback ranges from 0.0 (single echo) to 1.0 (infinite repeats).
    """
    time_ms: f64
    feedback: f64

# ============================================================================
# AudioEffect enum
# ============================================================================

enum AudioEffect:
    """Union of all audio effect types."""
    LowPass(effect: LowPassEffect)
    HighPass(effect: HighPassEffect)
    Reverb(effect: ReverbEffect)
    Delay(effect: DelayEffect)

# ============================================================================
# EffectsChain — Ordered list of effects
# ============================================================================

class EffectsChain:
    """An ordered chain of audio effects applied to a bus or sound.

    Effects are applied in insertion order.
    """
    effects: [AudioEffect]

impl EffectsChain:
    static fn empty() -> EffectsChain:
        """Create an empty effects chain."""
        EffectsChain(effects: [])

    me add(effect: AudioEffect):
        """Append an effect to the end of the chain."""
        self.effects.push(effect)

    me remove_at(index: i32):
        """Remove the effect at the given index.

        No-op if index is out of bounds.
        """
        if index < 0:
            return
        if index >= self.effects.len():
            return
        var new_list: [AudioEffect] = []
        var i = 0
        while i < self.effects.len():
            if i != index:
                new_list.push(self.effects[i])
            i = i + 1
        self.effects = new_list

    me clear():
        """Remove all effects from the chain."""
        self.effects = []

    fn count() -> i32:
        """Return the number of effects in the chain."""
        self.effects.len()
