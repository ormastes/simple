# Skeletal Animation — Animation Blender
#
# Manages layered animation blending. Each layer has a clip name,
# weight, and current time. The blender does not evaluate clips
# directly — it stores blend state for an external evaluator.

# --------------------------------------------------------------------------
# BlendLayer — single animation layer
# --------------------------------------------------------------------------

struct BlendLayer:
    clip_name: text
    weight: f64
    time: f64

# --------------------------------------------------------------------------
# AnimationBlender — layered blend state
# --------------------------------------------------------------------------

class AnimationBlender:
    layers: [BlendLayer]
    bone_count: i32

impl AnimationBlender:
    static fn new(bone_count: i32) -> AnimationBlender:
        AnimationBlender(
            layers: [],
            bone_count: bone_count
        )

    me add_layer(clip_name: text, weight: f64) -> i32:
        val idx: i32 = self.layers.len()
        val layer = BlendLayer(
            clip_name: clip_name,
            weight: weight,
            time: 0.0
        )
        self.layers.push(layer)
        idx

    me set_layer_weight(index: i32, weight: f64):
        if index < 0:
            return
        if index >= self.layers.len():
            return
        val old = self.layers[index]
        self.layers[index] = BlendLayer(
            clip_name: old.clip_name,
            weight: weight,
            time: old.time
        )

    me set_layer_time(index: i32, time: f64):
        if index < 0:
            return
        if index >= self.layers.len():
            return
        val old = self.layers[index]
        self.layers[index] = BlendLayer(
            clip_name: old.clip_name,
            weight: old.weight,
            time: time
        )

    fn layer_count() -> i32:
        self.layers.len()

    fn get_layer(index: i32) -> BlendLayer?:
        if index < 0:
            return nil
        if index >= self.layers.len():
            return nil
        self.layers[index]

    me remove_layer(index: i32) -> bool:
        if index < 0:
            return false
        if index >= self.layers.len():
            return false
        self.layers.remove(index)
        true

    me clear():
        self.layers = []
