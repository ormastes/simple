@allow(primitive_api)
# 3D Mesh & Light Components
#
# Vertex3D, MeshData (with primitive generators), and LightData.
#
# Usage:
#   val cube = create_cube(1.0)
#   val plane = create_plane(10.0, 10.0)
#   val sphere = create_sphere(1.0, 16, 8)
#   val sun = directional_light(Vec3(x: 0.0, y: -1.0, z: 0.0), EngineColor.white(), 1.0)

use std.common.engine.math3d.{Vec3}
use std.common.engine.color.{EngineColor}
use std.common.math.{MATH_PI}

# ============================================================================
# Pure math helpers
# ============================================================================

val _EPSILON = 0.0000000001

fn _sin(x: f64) -> f64:
    """Taylor series sine approximation."""
    var a = x
    val two_pi = MATH_PI * 2.0
    while a > MATH_PI:
        a = a - two_pi
    while a < -MATH_PI:
        a = a + two_pi
    val x2 = a * a
    val x3 = a * x2
    val x5 = x3 * x2
    val x7 = x5 * x2
    val x9 = x7 * x2
    val x11 = x9 * x2
    val x13 = x11 * x2
    a - x3 / 6.0 + x5 / 120.0 - x7 / 5040.0 + x9 / 362880.0 - x11 / 39916800.0 + x13 / 6227020800.0

fn _cos(x: f64) -> f64:
    _sin(x + MATH_PI / 2.0)

# ============================================================================
# Vertex3D
# ============================================================================

class Vertex3D:
    position: Vec3
    normal: Vec3
    uv_x: f64
    uv_y: f64
    color: EngineColor

impl Vertex3D:
    static fn create(pos: Vec3, norm: Vec3, u: f64, v: f64) -> Vertex3D:
        Vertex3D(
            position: pos,
            normal: norm,
            uv_x: u,
            uv_y: v,
            color: EngineColor.white()
        )

    static fn with_color(pos: Vec3, norm: Vec3, u: f64, v: f64, col: EngineColor) -> Vertex3D:
        Vertex3D(
            position: pos,
            normal: norm,
            uv_x: u,
            uv_y: v,
            color: col
        )

# ============================================================================
# MeshData
# ============================================================================

class MeshData:
    vertices: [Vertex3D]
    indices: [i64]
    aabb_min: Vec3
    aabb_max: Vec3

impl MeshData:
    fn vertex_count() -> i64:
        self.vertices.len()

    fn index_count() -> i64:
        self.indices.len()

# ============================================================================
# Primitive generators
# ============================================================================

fn compute_aabb(mesh: MeshData) -> MeshData:
    """Recompute AABB from vertices."""
    if mesh.vertices.len() == 0:
        return MeshData(
            vertices: mesh.vertices,
            indices: mesh.indices,
            aabb_min: Vec3.zero(),
            aabb_max: Vec3.zero()
        )

    val first = mesh.vertices[0].position
    var min_x = first.x
    var min_y = first.y
    var min_z = first.z
    var max_x = first.x
    var max_y = first.y
    var max_z = first.z

    var i = 1
    while i < mesh.vertices.len():
        val p = mesh.vertices[i].position
        if p.x < min_x:
            min_x = p.x
        if p.y < min_y:
            min_y = p.y
        if p.z < min_z:
            min_z = p.z
        if p.x > max_x:
            max_x = p.x
        if p.y > max_y:
            max_y = p.y
        if p.z > max_z:
            max_z = p.z
        i = i + 1

    MeshData(
        vertices: mesh.vertices,
        indices: mesh.indices,
        aabb_min: Vec3(x: min_x, y: min_y, z: min_z),
        aabb_max: Vec3(x: max_x, y: max_y, z: max_z)
    )

fn create_cube(size: f64) -> MeshData:
    """Create a cube with 24 vertices (4 per face, proper normals), 36 indices."""
    val h = size / 2.0
    var verts: [Vertex3D] = []
    var idxs: [i64] = []

    # Front face (+Z)
    val nf = Vec3(x: 0.0, y: 0.0, z: 1.0)
    verts.push(Vertex3D.create(Vec3(x: -h, y: -h, z: h), nf, 0.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: h, y: -h, z: h), nf, 1.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: h, y: h, z: h), nf, 1.0, 1.0))
    verts.push(Vertex3D.create(Vec3(x: -h, y: h, z: h), nf, 0.0, 1.0))

    # Back face (-Z)
    val nb = Vec3(x: 0.0, y: 0.0, z: -1.0)
    verts.push(Vertex3D.create(Vec3(x: h, y: -h, z: -h), nb, 0.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: -h, y: -h, z: -h), nb, 1.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: -h, y: h, z: -h), nb, 1.0, 1.0))
    verts.push(Vertex3D.create(Vec3(x: h, y: h, z: -h), nb, 0.0, 1.0))

    # Right face (+X)
    val nr = Vec3(x: 1.0, y: 0.0, z: 0.0)
    verts.push(Vertex3D.create(Vec3(x: h, y: -h, z: h), nr, 0.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: h, y: -h, z: -h), nr, 1.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: h, y: h, z: -h), nr, 1.0, 1.0))
    verts.push(Vertex3D.create(Vec3(x: h, y: h, z: h), nr, 0.0, 1.0))

    # Left face (-X)
    val nl = Vec3(x: -1.0, y: 0.0, z: 0.0)
    verts.push(Vertex3D.create(Vec3(x: -h, y: -h, z: -h), nl, 0.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: -h, y: -h, z: h), nl, 1.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: -h, y: h, z: h), nl, 1.0, 1.0))
    verts.push(Vertex3D.create(Vec3(x: -h, y: h, z: -h), nl, 0.0, 1.0))

    # Top face (+Y)
    val nt = Vec3(x: 0.0, y: 1.0, z: 0.0)
    verts.push(Vertex3D.create(Vec3(x: -h, y: h, z: h), nt, 0.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: h, y: h, z: h), nt, 1.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: h, y: h, z: -h), nt, 1.0, 1.0))
    verts.push(Vertex3D.create(Vec3(x: -h, y: h, z: -h), nt, 0.0, 1.0))

    # Bottom face (-Y)
    val nbot = Vec3(x: 0.0, y: -1.0, z: 0.0)
    verts.push(Vertex3D.create(Vec3(x: -h, y: -h, z: -h), nbot, 0.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: h, y: -h, z: -h), nbot, 1.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: h, y: -h, z: h), nbot, 1.0, 1.0))
    verts.push(Vertex3D.create(Vec3(x: -h, y: -h, z: h), nbot, 0.0, 1.0))

    # Indices: 2 triangles per face, 6 faces = 36 indices
    var face = 0
    while face < 6:
        val base = face * 4
        idxs.push(base)
        idxs.push(base + 1)
        idxs.push(base + 2)
        idxs.push(base)
        idxs.push(base + 2)
        idxs.push(base + 3)
        face = face + 1

    val raw = MeshData(
        vertices: verts,
        indices: idxs,
        aabb_min: Vec3.zero(),
        aabb_max: Vec3.zero()
    )
    compute_aabb(raw)

fn create_plane(width: f64, height: f64) -> MeshData:
    """Create a plane on XZ with 4 vertices, 6 indices, normal pointing up (+Y)."""
    val hw = width / 2.0
    val hh = height / 2.0
    val n = Vec3(x: 0.0, y: 1.0, z: 0.0)

    var verts: [Vertex3D] = []
    verts.push(Vertex3D.create(Vec3(x: -hw, y: 0.0, z: -hh), n, 0.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: hw, y: 0.0, z: -hh), n, 1.0, 0.0))
    verts.push(Vertex3D.create(Vec3(x: hw, y: 0.0, z: hh), n, 1.0, 1.0))
    verts.push(Vertex3D.create(Vec3(x: -hw, y: 0.0, z: hh), n, 0.0, 1.0))

    var idxs: [i64] = [0, 1, 2, 0, 2, 3]

    val raw = MeshData(
        vertices: verts,
        indices: idxs,
        aabb_min: Vec3.zero(),
        aabb_max: Vec3.zero()
    )
    compute_aabb(raw)

fn create_sphere(radius: f64, segments: i64, rings: i64) -> MeshData:
    """Create a UV sphere."""
    var verts: [Vertex3D] = []
    var idxs: [i64] = []

    var ring = 0
    while ring <= rings:
        val v_ratio = ring / (rings * 1.0)
        val phi = MATH_PI * v_ratio
        val sin_phi = _sin(phi)
        val cos_phi = _cos(phi)

        var seg = 0
        while seg <= segments:
            val u_ratio = seg / (segments * 1.0)
            val theta = 2.0 * MATH_PI * u_ratio

            val x = radius * sin_phi * _cos(theta)
            val y = radius * cos_phi
            val z = radius * sin_phi * _sin(theta)

            val nx = sin_phi * _cos(theta)
            val ny = cos_phi
            val nz = sin_phi * _sin(theta)

            val pos = Vec3(x: x, y: y, z: z)
            val norm = Vec3(x: nx, y: ny, z: nz)
            verts.push(Vertex3D.create(pos, norm, u_ratio, v_ratio))

            seg = seg + 1
        ring = ring + 1

    # Generate indices
    var r = 0
    while r < rings:
        var s = 0
        while s < segments:
            val row_len = segments + 1
            val curr = r * row_len + s
            val next_row = (r + 1) * row_len + s

            idxs.push(curr)
            idxs.push(next_row)
            idxs.push(curr + 1)

            idxs.push(curr + 1)
            idxs.push(next_row)
            idxs.push(next_row + 1)

            s = s + 1
        r = r + 1

    val raw = MeshData(
        vertices: verts,
        indices: idxs,
        aabb_min: Vec3.zero(),
        aabb_max: Vec3.zero()
    )
    compute_aabb(raw)

# ============================================================================
# LightData
# ============================================================================

class LightData:
    light_type: i64
    color: EngineColor
    intensity: f64
    range: f64
    inner_cone: f64
    outer_cone: f64
    direction: Vec3

fn directional_light(dir: Vec3, color: EngineColor, intensity: f64) -> LightData:
    """Create a directional light (type=0)."""
    LightData(
        light_type: 0,
        color: color,
        intensity: intensity,
        range: 0.0,
        inner_cone: 0.0,
        outer_cone: 0.0,
        direction: dir.normalize()
    )

fn point_light(color: EngineColor, intensity: f64, range: f64) -> LightData:
    """Create a point light (type=1)."""
    LightData(
        light_type: 1,
        color: color,
        intensity: intensity,
        range: range,
        inner_cone: 0.0,
        outer_cone: 0.0,
        direction: Vec3.zero()
    )

fn spot_light(dir: Vec3, color: EngineColor, intensity: f64, range: f64, inner_cone: f64, outer_cone: f64) -> LightData:
    """Create a spot light (type=2)."""
    LightData(
        light_type: 2,
        color: color,
        intensity: intensity,
        range: range,
        inner_cone: inner_cone,
        outer_cone: outer_cone,
        direction: dir.normalize()
    )
