# glTF Document — Top-Level Container for Parsed glTF/GLB Assets
#
# Holds meshes, materials, skins, animations, and scene nodes
# extracted from a glTF 2.0 document.

use std.nogc_sync_mut.engine.resource.gltf_types.{GltfMesh, GltfMaterial, GltfSkin, GltfAnimation, GltfNode}

# ============================================================================
# Document
# ============================================================================

class GltfDocument:
    meshes: [GltfMesh]
    materials: [GltfMaterial]
    skins: [GltfSkin]
    animations: [GltfAnimation]
    nodes: [GltfNode]
    scene_name: text

impl GltfDocument:
    static fn new(scene_name: text) -> GltfDocument:
        GltfDocument(
            meshes: [],
            materials: [],
            skins: [],
            animations: [],
            nodes: [],
            scene_name: scene_name
        )

    me add_mesh(mesh: GltfMesh) -> i32:
        val idx = self.meshes.len()
        self.meshes.push(mesh)
        idx

    me add_material(mat: GltfMaterial) -> i32:
        val idx = self.materials.len()
        self.materials.push(mat)
        idx

    me add_skin(skin: GltfSkin) -> i32:
        val idx = self.skins.len()
        self.skins.push(skin)
        idx

    me add_animation(anim: GltfAnimation) -> i32:
        val idx = self.animations.len()
        self.animations.push(anim)
        idx

    me add_node(node: GltfNode) -> i32:
        val idx = self.nodes.len()
        self.nodes.push(node)
        idx

    fn get_mesh(index: i32) -> GltfMesh?:
        if index < 0 or index >= self.meshes.len():
            return nil
        self.meshes[index]

    fn get_material(index: i32) -> GltfMaterial?:
        if index < 0 or index >= self.materials.len():
            return nil
        self.materials[index]

    fn get_skin(index: i32) -> GltfSkin?:
        if index < 0 or index >= self.skins.len():
            return nil
        self.skins[index]

    fn get_animation(index: i32) -> GltfAnimation?:
        if index < 0 or index >= self.animations.len():
            return nil
        self.animations[index]

    fn mesh_count() -> i32:
        self.meshes.len()

    fn material_count() -> i32:
        self.materials.len()

    fn node_count() -> i32:
        self.nodes.len()

    fn has_animations() -> bool:
        self.animations.len() > 0

    fn has_skins() -> bool:
        self.skins.len() > 0
