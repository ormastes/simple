# Visual Scripting — built-in node type definitions

use std.nogc_sync_mut.engine.scripting.visual_graph.{VisualNode}

fn create_event_node(id: i32, event_name: text) -> VisualNode:
    var node = VisualNode.new(id, "event", event_name)
    node.add_output("exec", "execution")
    node

fn create_branch_node(id: i32) -> VisualNode:
    var node = VisualNode.new(id, "branch", "Branch")
    node.add_input("condition", "bool")
    node.add_input("exec", "execution")
    node.add_output("true", "execution")
    node.add_output("false", "execution")
    node

fn create_set_variable_node(id: i32, var_name: text) -> VisualNode:
    var node = VisualNode.new(id, "set_var", var_name)
    node.add_input("exec", "execution")
    node.add_input("value", "any")
    node.add_output("exec", "execution")
    node

fn create_get_variable_node(id: i32, var_name: text) -> VisualNode:
    var node = VisualNode.new(id, "get_var", var_name)
    node.add_output("value", "any")
    node

fn create_math_node(id: i32, operation: text) -> VisualNode:
    var node = VisualNode.new(id, "math", operation)
    node.add_input("a", "float")
    node.add_input("b", "float")
    node.add_output("result", "float")
    node

fn create_print_node(id: i32) -> VisualNode:
    var node = VisualNode.new(id, "print", "Print")
    node.add_input("exec", "execution")
    node.add_input("message", "text")
    node.add_output("exec", "execution")
    node
