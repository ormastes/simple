# GPU Render Bridge — Connects batch renderer to GPU Context
#
# Manages GPU resource lifecycle and provides frame-level GPU operations.
# The bridge holds handles to persistent GPU resources (render pass, pipeline,
# swapchain) and provides methods to upload batch data and issue draw calls.
#
# When no GPU is available (ctx_handle == 0), all operations are no-ops
# and the engine falls back to software rendering.

use std.common.engine.color.{EngineColor}
use std.gc_async_mut.gpu.context.{Context}
use std.gc_async_mut.gpu.graphics.{
    GpuFormat, GpuTextureUsage, GpuTextureDesc, GpuTexture,
    GpuRenderPassDesc, GpuRenderPass, GpuLoadOp, GpuStoreOp,
    GpuBlendMode, GpuTopology, GpuVertexFormat, GpuVertexAttribute,
    GpuVertexLayout, GpuShaderStage, GpuShader,
    GpuPipelineDesc, GpuGraphicsPipeline,
    GpuSwapchainDesc, GpuSwapchain, GpuFramebuffer
}
use std.nogc_sync_mut.engine.render.gpu_pipeline.{SpriteBatch, GpuVertex2D}
use std.nogc_sync_mut.engine.render.types.{DrawStats}

# ============================================================================
# GPU Render State — persistent resources for a frame
# ============================================================================

class GpuRenderState:
    render_pass: GpuRenderPass
    pipeline: GpuGraphicsPipeline
    swapchain: GpuSwapchain
    framebuffer: GpuFramebuffer
    color_texture: GpuTexture
    is_initialized: bool
    screen_width: i64
    screen_height: i64
    last_error: text

impl GpuRenderState:
    static fn uninitialized() -> GpuRenderState:
        GpuRenderState(
            render_pass: GpuRenderPass(handle: 0),
            pipeline: GpuGraphicsPipeline(handle: 0),
            swapchain: GpuSwapchain(handle: 0, width: 0, height: 0, format: GpuFormat.RGBA8),
            framebuffer: GpuFramebuffer(handle: 0, width: 0, height: 0),
            color_texture: GpuTexture(handle: 0, width: 0, height: 0, format: GpuFormat.RGBA8),
            is_initialized: false,
            screen_width: 0,
            screen_height: 0,
            last_error: "GPU backend is unavailable"
        )

    fn is_valid() -> bool:
        self.is_initialized and self.render_pass.is_valid()

# ============================================================================
# Initialization — create GPU resources via Context
# ============================================================================

fn init_gpu_render_state(ctx: Context, width: i64, height: i64, window_handle: i64) -> GpuRenderState:
    # Create render pass
    val rp_desc = GpuRenderPassDesc(
        color_format: GpuFormat.BGRA8,
        has_depth: false,
        depth_format: GpuFormat.Depth32F,
        clear_r: 0.0, clear_g: 0.0, clear_b: 0.0, clear_a: 1.0,
        load_op: GpuLoadOp.Clear,
        store_op: GpuStoreOp.Store
    )
    val render_pass = ctx.create_render_pass(rp_desc)

    # Create swapchain
    val sc_desc = GpuSwapchainDesc(
        window_handle: window_handle,
        width: width,
        height: height,
        format: GpuFormat.BGRA8,
        vsync: true
    )
    val swapchain = ctx.create_swapchain(sc_desc)

    # Create color texture for framebuffer attachment
    val tex_desc = GpuTextureDesc(width: width, height: height, format: GpuFormat.BGRA8, usage: GpuTextureUsage.RenderTarget)
    val color_texture = ctx.create_texture(tex_desc)

    # Create framebuffer
    val framebuffer = ctx.create_framebuffer(render_pass, color_texture)

    # Create pipeline (placeholder shaders — handle 0 until SPIR-V compilation is wired)
    val vs = GpuShader(handle: 0, stage: GpuShaderStage.Vertex)
    val fs = GpuShader(handle: 0, stage: GpuShaderStage.Fragment)
    val vertex_layout = GpuVertexLayout(
        stride: 32,
        attributes: [
            GpuVertexAttribute(location: 0, format: GpuVertexFormat.Float2, offset: 0),
            GpuVertexAttribute(location: 1, format: GpuVertexFormat.Float2, offset: 8),
            GpuVertexAttribute(location: 2, format: GpuVertexFormat.Float4, offset: 16)
        ]
    )
    val pipe_desc = GpuPipelineDesc(
        vertex_shader: vs, fragment_shader: fs,
        blend_mode: GpuBlendMode.AlphaBlend,
        vertex_layout: vertex_layout,
        topology: GpuTopology.TriangleList,
        render_pass: render_pass
    )
    val pipeline = ctx.create_graphics_pipeline(pipe_desc)

    GpuRenderState(
        render_pass: render_pass,
        pipeline: pipeline,
        swapchain: swapchain,
        framebuffer: framebuffer,
        color_texture: color_texture,
        is_initialized: true,
        screen_width: width,
        screen_height: height,
        last_error: ""
    )

# ============================================================================
# Frame Operations
# ============================================================================

fn begin_gpu_frame(ctx: Context, state: GpuRenderState, clear_color: EngineColor):
    if not state.is_initialized:
        return
    ctx.begin_render_pass(state.render_pass, state.framebuffer, clear_color.r, clear_color.g, clear_color.b, clear_color.a)
    ctx.bind_pipeline(state.pipeline)

fn submit_gpu_batch(ctx: Context, state: GpuRenderState, batch: SpriteBatch) -> DrawStats:
    if not state.is_initialized:
        return DrawStats.zero()
    val tri_count = batch.indices.len() / 3
    ctx.draw_indexed(batch.indices.len())
    DrawStats(draw_calls: 1, triangles: tri_count, vertices: batch.vertices.len())

fn end_gpu_frame(ctx: Context, state: GpuRenderState):
    if not state.is_initialized:
        return
    ctx.end_render_pass()
    ctx.present(state.swapchain)

fn destroy_gpu_render_state(ctx: Context, state: GpuRenderState):
    if not state.is_initialized:
        return
    ctx.destroy_texture(state.color_texture)

# ============================================================================
# Batch Data Conversion
# ============================================================================

fn flatten_batch_vertices(batch: SpriteBatch) -> [f64]:
    # Convert [GpuVertex2D] to flat [f64] for GPU upload
    # Each vertex: pos_x, pos_y, uv_x, uv_y, color_r, color_g, color_b, color_a
    var result: [f64] = []
    var i = 0
    while i < batch.vertices.len():
        val v = batch.vertices[i]
        result.push(v.pos_x)
        result.push(v.pos_y)
        result.push(v.uv_x)
        result.push(v.uv_y)
        result.push(v.color_r)
        result.push(v.color_g)
        result.push(v.color_b)
        result.push(v.color_a)
        i = i + 1
    result
