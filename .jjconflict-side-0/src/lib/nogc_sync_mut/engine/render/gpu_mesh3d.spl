# GPU Mesh Upload and Draw Dispatch
#
# Provides GpuMeshHandle and helpers to upload vertex/index data to the GPU
# and dispatch indexed and instanced draw calls through RenderBackend3D.

use std.nogc_sync_mut.engine.render.backend3d.{
    RenderBackend3D, BufferHandle, RenderPassHandle, PipelineHandle
}
use std.nogc_sync_mut.binary_io.{f32_to_bits}

# ============================================================================
# GpuMeshHandle — opaque handles to vertex and index buffers on the GPU
# ============================================================================

class GpuMeshHandle:
    vbuf: BufferHandle
    ibuf: BufferHandle
    index_count: i64

    static fn invalid() -> GpuMeshHandle:
        GpuMeshHandle(
            vbuf: BufferHandle.invalid(),
            ibuf: BufferHandle.invalid(),
            index_count: 0
        )

    fn is_valid() -> bool:
        self.vbuf.id >= 0 and self.ibuf.id >= 0 and self.index_count > 0

# ============================================================================
# GpuMeshPool — registry of named mesh handles
#
# Allows callers to upload meshes by name and look them up at draw time
# without keeping raw GpuMeshHandle values scattered across the codebase.
# ============================================================================

class MeshEntry:
    name: text
    handle: GpuMeshHandle

class GpuMeshPool:
    entries: [MeshEntry]

impl GpuMeshPool:
    static fn new() -> GpuMeshPool:
        GpuMeshPool(entries: [])

    # Register a pre-uploaded mesh handle under a name.
    me insert(name: text, handle: GpuMeshHandle):
        var i = 0
        while i < self.entries.len():
            if self.entries[i].name == name:
                self.entries[i] = MeshEntry(name: name, handle: handle)
                return
            i = i + 1
        self.entries.push(MeshEntry(name: name, handle: handle))

    # Look up a mesh by name; returns nil if not found.
    fn get(name: text) -> GpuMeshHandle?:
        var i = 0
        while i < self.entries.len():
            if self.entries[i].name == name:
                return self.entries[i].handle
            i = i + 1
        nil

    # Remove a mesh entry by name; returns true if it existed.
    me remove(name: text) -> bool:
        var new_entries: [MeshEntry] = []
        var found = false
        var i = 0
        while i < self.entries.len():
            if self.entries[i].name == name:
                found = true
            else:
                new_entries.push(self.entries[i])
            i = i + 1
        self.entries = new_entries
        found

    fn count() -> i64:
        self.entries.len()

# ============================================================================
# gpu_mesh_upload — allocate and upload vertex + index buffers
#
# vertices: flat f32 array (x, y, z, nx, ny, nz, u, v per vertex — 8 floats)
# indices:  flat i64 array of triangle indices
#
# Wire format is little-endian: 8 packed f32 values per vertex and u32 indices.
# ============================================================================

fn gpu_mesh_upload(backend: RenderBackend3D, vertices: [f32], indices: [i64]) -> GpuMeshHandle:
    # Each f32 is 4 bytes; each i64 index is 4 bytes (GPU i32 index buffer)
    val vbyte_count = vertices.len() * 4
    val ibyte_count = indices.len() * 4

    val vbuf = backend.create_vertex_buffer(vbyte_count)
    val ibuf = backend.create_index_buffer(ibyte_count)

    var vbytes: [u8] = []
    var vi = 0
    while vi < vertices.len():
        val bits = f32_to_bits(vertices[vi])
        vbytes.push((bits & 0xffu32) as u8)
        vbytes.push(((bits >> 8) & 0xffu32) as u8)
        vbytes.push(((bits >> 16) & 0xffu32) as u8)
        vbytes.push(((bits >> 24) & 0xffu32) as u8)
        vi = vi + 1

    var ibytes: [u8] = []
    var ii = 0
    while ii < indices.len():
        val bits = indices[ii] as u32
        ibytes.push((bits & 0xffu32) as u8)
        ibytes.push(((bits >> 8) & 0xffu32) as u8)
        ibytes.push(((bits >> 16) & 0xffu32) as u8)
        ibytes.push(((bits >> 24) & 0xffu32) as u8)
        ii = ii + 1

    backend.upload_buffer(vbuf, vbytes, 0)
    backend.upload_buffer(ibuf, ibytes, 0)

    GpuMeshHandle(
        vbuf: vbuf,
        ibuf: ibuf,
        index_count: indices.len()
    )

# ============================================================================
# gpu_mesh_upload_and_register — upload and insert into a pool in one call
# ============================================================================

fn gpu_mesh_upload_and_register(backend: RenderBackend3D, pool: GpuMeshPool, name: text, vertices: [f32], indices: [i64]) -> GpuMeshHandle:
    val handle = gpu_mesh_upload(backend, vertices, indices)
    pool.insert(name, handle)
    handle

# ============================================================================
# gpu_mesh_draw — bind buffers and issue an indexed draw call
#
# Binds vertex buffer at slot 0, index buffer, MVP uniform at slot 0,
# then draws all indices.
# ============================================================================

fn gpu_mesh_draw(backend: RenderBackend3D, rph: RenderPassHandle, mesh: GpuMeshHandle, mvp_buf: BufferHandle, pipeline: PipelineHandle):
    backend.set_pipeline(rph, pipeline)
    backend.bind_vertex_buffer(rph, mesh.vbuf, 0)
    backend.bind_index_buffer(rph, mesh.ibuf)
    backend.bind_uniform_buffer(rph, mvp_buf, 0)
    backend.draw_indexed(rph, mesh.index_count, 0)

# ============================================================================
# gpu_mesh_draw_subrange — draw a subset of indices (for LOD or multi-material)
#
# index_start: first index to draw (must be 0-aligned within the index buffer)
# index_count: number of indices to draw from index_start
# ============================================================================

fn gpu_mesh_draw_subrange(backend: RenderBackend3D, rph: RenderPassHandle, mesh: GpuMeshHandle, mvp_buf: BufferHandle, pipeline: PipelineHandle, index_start: i64, index_count: i64):
    backend.set_pipeline(rph, pipeline)
    backend.bind_vertex_buffer(rph, mesh.vbuf, 0)
    backend.bind_index_buffer(rph, mesh.ibuf)
    backend.bind_uniform_buffer(rph, mvp_buf, 0)
    backend.draw_indexed(rph, index_count, index_start)

# ============================================================================
# gpu_mesh_free — invalidate handles (GPU-side cleanup is backend-managed)
# ============================================================================

fn gpu_mesh_free(handle: GpuMeshHandle) -> GpuMeshHandle:
    GpuMeshHandle.invalid()
