# Global i18n Accessor
#
# Provides a simple API for the common use case: a single global bundle.
# Call i18n_init() once at app startup, then use t() and t_fmt() anywhere.
#
# Usage:
#   use std.i18n.global.{i18n_init, t, t_fmt}
#
#   i18n_init(".", "ko")
#   print t("greeting")
#   print t_fmt("user.welcome", {"name": "Alice"})

import std.i18n.bundle

# ============================================================================
# Global State
# ============================================================================

var _global_bundle: ResourceBundle = nil
var _global_initialized: bool = false

# ============================================================================
# Initialization
# ============================================================================

"""Initialize the global i18n bundle.

Call once at app startup:
    i18n_init(".", "ko")

Args:
    base_dir: Directory containing i18n/ folder
    locale: Locale code (e.g. "en", "ko", "ja")

Returns:
    Ok(()) on success, Err(message) on failure
"""
fn i18n_init(base_dir: text, locale: text) -> Result<bool, text>:
    val result = bundle.ResourceBundle.load(base_dir, locale)
    match result:
        case Ok(b):
            _global_bundle = b
            _global_initialized = true
            return Ok(true)
        case Err(e):
            return Err(e)
    Err("unexpected error")

"""Initialize from environment (auto-detect locale).

Uses detect_locale() to determine the locale from environment variables.

Args:
    base_dir: Directory containing i18n/ folder

Returns:
    Ok(()) on success, Err(message) on failure
"""
fn i18n_init_auto(base_dir: text) -> Result<bool, text>:
    val locale = bundle.detect_locale()
    i18n_init(base_dir, locale)

# ============================================================================
# Translation Functions
# ============================================================================

"""Get translated message from global bundle.

Returns the key itself if the global bundle is not initialized.

Usage:
    val msg = t("greeting")
    val msg = t("user.welcome")
"""
fn t(key: text) -> text:
    if _global_initialized:
        return _global_bundle.get(key)
    key

"""Get translated message with parameter substitution.

Returns the key itself if the global bundle is not initialized.

Usage:
    val msg = t_fmt("user.welcome", {"name": "Alice"})
"""
fn t_fmt(key: text, params: Dict<text, text>) -> text:
    if _global_initialized:
        return _global_bundle.get_fmt(key, params)
    key

# ============================================================================
# Query Functions
# ============================================================================

"""Check if the global bundle has been initialized."""
fn i18n_is_initialized() -> bool:
    _global_initialized

"""Get the current locale of the global bundle.

Returns empty string if not initialized.
"""
fn i18n_current_locale() -> text:
    if _global_initialized:
        return _global_bundle.current_locale()
    ""

"""Check if a key exists in the global bundle."""
fn i18n_has_key(key: text) -> bool:
    if _global_initialized:
        return _global_bundle.has_key(key)
    false
