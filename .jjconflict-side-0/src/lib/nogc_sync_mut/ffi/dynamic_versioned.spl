@allow(unnamed_duplicate_typed_args)
@allow(primitive_api)
# Versioned Dynamic Library Loader
#
# Extends DynLib to support:
#   - Version-aware loading (.so.1.0.0, .so.1, .so fallback chain)
#   - Platform-specific extensions (.so, .dll, .dylib)
#   - Multiple versions loaded simultaneously
#   - Platform-specific library search paths

use std.ffi.dynamic.{DynLib, platform_lib_extension, platform_name}

extern fn rt_env_get(key: text) -> text

# ============================================================================
# Library Version
# ============================================================================

struct LibVersion:
    major: i64
    minor: i64
    patch: i64

fn lib_version(major: i64, minor: i64, patch: i64) -> LibVersion:
    LibVersion(major: major, minor: minor, patch: patch)

fn lib_version_any() -> LibVersion:
    LibVersion(major: 0, minor: 0, patch: 0)

fn lib_version_string(v: LibVersion) -> text:
    if v.major == 0 and v.minor == 0 and v.patch == 0:
        return "any"
    if v.minor == 0 and v.patch == 0:
        return "{v.major}"
    if v.patch == 0:
        return "{v.major}.{v.minor}"
    "{v.major}.{v.minor}.{v.patch}"

# ============================================================================
# VersionedDynLib
# ============================================================================

class VersionedDynLib:
    lib: DynLib
    name: text
    version: LibVersion
    path: text

impl VersionedDynLib:
    static fn load_versioned(name: text, version: LibVersion) -> VersionedDynLib?:
        val candidates = build_candidate_paths(name, version)
        var i = 0
        while i < candidates.len():
            val path = candidates[i]
            val lib = DynLib.load(path)
            if lib.?:
                return VersionedDynLib(lib: lib.unwrap(), name: name, version: version, path: path)
            i = i + 1
        nil

    static fn load_best(name: text) -> VersionedDynLib?:
        VersionedDynLib.load_versioned(name, lib_version_any())

    static fn load_path(path: text, name: text) -> VersionedDynLib?:
        val lib = DynLib.load(path)
        if lib.?:
            return VersionedDynLib(lib: lib.unwrap(), name: name, version: lib_version_any(), path: path)
        nil

    fn has_symbol(name: text) -> bool:
        self.lib.sym(name) != 0

    fn count_symbols(names: [text]) -> i64:
        var count: i64 = 0
        var i = 0
        while i < names.len():
            if self.has_symbol(names[i]):
                count = count + 1
            i = i + 1
        count

    fn missing_symbols(names: [text]) -> [text]:
        var missing: [text] = []
        var i = 0
        while i < names.len():
            if not self.has_symbol(names[i]):
                missing.push(names[i])
            i = i + 1
        missing

# ============================================================================
# MultiVersionLoader
# ============================================================================

var _multi_libs: {text: VersionedDynLib} = {}

class MultiVersionLoader:
    pass_dn

impl MultiVersionLoader:
    static fn instance() -> MultiVersionLoader:
        MultiVersionLoader()

    fn load(name: text, version: LibVersion) -> VersionedDynLib?:
        val key = "{name}:{lib_version_string(version)}"
        if _multi_libs.contains(key):
            return _multi_libs[key]
        val lib = VersionedDynLib.load_versioned(name, version)
        if lib.?:
            val v = lib.unwrap()
            _multi_libs[key] = v
            return v
        nil

    fn load_best(name: text) -> VersionedDynLib?:
        val key = "{name}:any"
        if _multi_libs.contains(key):
            return _multi_libs[key]
        val lib = VersionedDynLib.load_best(name)
        if lib.?:
            val v = lib.unwrap()
            _multi_libs[key] = v
            return v
        nil

    fn load_path(path: text, name: text) -> VersionedDynLib?:
        if _multi_libs.contains(path):
            return _multi_libs[path]
        val lib = VersionedDynLib.load_path(path, name)
        if lib.?:
            val v = lib.unwrap()
            _multi_libs[path] = v
            return v
        nil

    fn get(name: text, version: LibVersion) -> VersionedDynLib?:
        val key = "{name}:{lib_version_string(version)}"
        if _multi_libs.contains(key):
            return _multi_libs[key]
        nil

    fn loaded_keys() -> [text]:
        var keys: [text] = []
        for key in _multi_libs:
            keys.push(key)
        keys

# ============================================================================
# Path Resolution
# ============================================================================

fn build_candidate_paths(name: text, version: LibVersion) -> [text]:
    val ext = platform_lib_extension()
    val plat = platform_name()
    val search_dirs = library_search_paths()
    var candidates: [text] = []

    var di = 0
    while di < search_dirs.len():
        val dir = search_dirs[di]
        if plat == "linux" or plat == "freebsd":
            if version.major > 0 and version.minor > 0 and version.patch > 0:
                candidates.push("{dir}/lib{name}.so.{version.major}.{version.minor}.{version.patch}")
            if version.major > 0:
                candidates.push("{dir}/lib{name}.so.{version.major}")
            candidates.push("{dir}/lib{name}.so")
            candidates.push("{dir}/{name}.so")
        elif plat == "macos":
            if version.major > 0 and version.minor > 0 and version.patch > 0:
                candidates.push("{dir}/lib{name}.{version.major}.{version.minor}.{version.patch}.dylib")
            if version.major > 0:
                candidates.push("{dir}/lib{name}.{version.major}.dylib")
            candidates.push("{dir}/lib{name}.dylib")
            candidates.push("{dir}/{name}.dylib")
        elif plat == "windows":
            candidates.push("{dir}/{name}.dll")
            candidates.push("{dir}/lib{name}.dll")
        di = di + 1

    # Bare name fallback (let dlopen search system paths)
    if plat == "windows":
        candidates.push("{name}.dll")
    elif plat == "macos":
        candidates.push("lib{name}.dylib")
        candidates.push("{name}.dylib")
    else:
        candidates.push("lib{name}.so")
        candidates.push("{name}.so")
    candidates

fn library_search_paths() -> [text]:
    var paths: [text] = []
    val simple_path = rt_env_get("SIMPLE_LIB_PATH")
    if simple_path != "":
        val parts = simple_path.split(":")
        var i = 0
        while i < parts.len():
            if parts[i] != "":
                paths.push(parts[i])
            i = i + 1
    val plat = platform_name()
    if plat == "linux" or plat == "freebsd":
        val ldpath = rt_env_get("LD_LIBRARY_PATH")
        if ldpath != "":
            val parts = ldpath.split(":")
            var i = 0
            while i < parts.len():
                if parts[i] != "":
                    paths.push(parts[i])
                i = i + 1
        paths.push("/usr/local/lib")
        paths.push("/usr/lib")
    elif plat == "macos":
        val dyldpath = rt_env_get("DYLD_LIBRARY_PATH")
        if dyldpath != "":
            val parts = dyldpath.split(":")
            var i = 0
            while i < parts.len():
                if parts[i] != "":
                    paths.push(parts[i])
                i = i + 1
        paths.push("/usr/local/lib")
        paths.push("/opt/homebrew/lib")
    elif plat == "windows":
        val winpath = rt_env_get("PATH")
        if winpath != "":
            val parts = winpath.split(";")
            var i = 0
            while i < parts.len():
                if parts[i] != "":
                    paths.push(parts[i])
                i = i + 1
    val t32_lib = rt_env_get("T32_API_LIB")
    if t32_lib != "":
        paths.push(t32_lib)
    paths.push("/opt/t32/demo/api/capi/dll")
    paths
