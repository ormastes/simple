# Shim: std.platform → nogc_sync_mut.platform
# Explicit re-export shim — glob import alone does not re-export in interpreter mode.
# Move-to-__init__.spl blocked: interpreter-mode resolver does not pick up
# sibling-file symbols re-exported via __init__.spl. Exports must stay here
# for `use std.platform.{...}` to resolve at runtime. See:
#   doc/08_tracking/bug/loader_init_sibling_export_2026-04-28.md
# (lint: L:export_outside_init)
use nogc_sync_mut.platform.{
    is_windows, is_unix, is_macos, is_linux,
    get_host_os, get_host_arch,
    dir_sep, path_sep, exe_ext, lib_ext,
    normalize_path, is_absolute_path, join_path, resolve_command
}

export is_windows, is_unix, is_macos, is_linux
export get_host_os, get_host_arch, dir_sep, path_sep, exe_ext, lib_ext
export normalize_path, is_absolute_path, join_path, resolve_command
