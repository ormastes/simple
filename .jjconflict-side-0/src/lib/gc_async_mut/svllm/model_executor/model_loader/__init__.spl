# @gc — module uses GC runtime
#
# model_loader — mirrors vllm/model_executor/model_loader/
#
# Phase A1 scope:
#   - tensor_pack.spl  : sealed on-disk format svllm serves from
#   - manifest.spl     : SDN-formatted manifest parser (chunks, tensors, hashes)
#   - safetensors.spl  : minimal reader for upstream safetensors checkpoints
#   - weight_utils.spl : dtype + element-size helpers
#   - loader.spl       : top-level load_model_from_pack(path) orchestration
#
# All filesystem access goes through svllm.nvfs_client (the shim contract);
# no direct FAT32/host-FS calls here. This keeps the loader portable across
# bring-up FAT32 and the target nvfs.

export TensorPack, TensorInfo, ChunkInfo, Dtype, dtype_element_size
export TensorPackManifest, ManifestError
export SafetensorsHeader, SafetensorsError
export LoaderError, LoadResult, TensorStreamSegment, TensorStreamPlan, load_model_from_pack, load_model_from_pack_streamed, load_tensor_bytes_from_pack, load_tensor_stream_plan_from_pack, load_tensor_stream_plan_from_manifest_text
export SvllmStreamingReadiness, svllm_streaming_readiness_from_pack, svllm_streaming_readiness_from_local_pack, svllm_streaming_readiness_from_statuses, svllm_streaming_readiness_from_manifest_text
