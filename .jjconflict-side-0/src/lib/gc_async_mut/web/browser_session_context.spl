# Browser session secure-context helper.
#
# Extracted from browser_session.spl — kept separate so BrowserRuntimeState.create
# can call it without pulling in the full session module.

fn browser_session_is_secure_context(url: text) -> bool:
    if url.starts_with("https://"):
        return true
    if url.starts_with("http://localhost") or url.starts_with("http://127.0.0.1"):
        return true
    if url.starts_with("file://") or url.starts_with("about:"):
        return true
    false
