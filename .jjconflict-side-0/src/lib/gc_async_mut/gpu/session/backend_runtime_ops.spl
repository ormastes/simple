#[runtime_intrinsics]
extern fn rt_metal_create_device() -> i64
extern fn rt_metal_submit(handle: i64, cmd_count: i64) -> text
extern fn rt_metal_present(handle: i64) -> text
extern fn rt_metal_cleanup(handle: i64) -> i64
extern fn rt_cuda_device_init(device_id: i64) -> i64
extern fn rt_cuda_submit(handle: i64, cmd_count: i64) -> text
extern fn rt_cuda_cleanup(handle: i64) -> i64
extern fn rt_vk_create_device() -> i64
extern fn rt_vk_submit(handle: i64, cmd_count: i64) -> text
extern fn rt_vk_present(handle: i64) -> text
extern fn rt_vk_cleanup(handle: i64) -> i64
extern fn rt_webgpu_create_device() -> i64
extern fn rt_webgpu_submit(handle: i64, cmd_count: i64) -> text
extern fn rt_webgpu_present(handle: i64) -> text
extern fn rt_webgpu_cleanup(handle: i64) -> i64

pub fn backend_metal_create_device() -> i64:
    rt_metal_create_device()

pub fn backend_metal_submit(handle: i64, cmd_count: i64) -> text:
    rt_metal_submit(handle, cmd_count)

pub fn backend_metal_present(handle: i64) -> text:
    rt_metal_present(handle)

pub fn backend_metal_cleanup(handle: i64) -> i64:
    rt_metal_cleanup(handle)

pub fn backend_cuda_device_init(device_id: i64) -> i64:
    rt_cuda_device_init(device_id)

pub fn backend_cuda_submit(handle: i64, cmd_count: i64) -> text:
    rt_cuda_submit(handle, cmd_count)

pub fn backend_cuda_cleanup(handle: i64) -> i64:
    rt_cuda_cleanup(handle)

pub fn backend_vulkan_create_device() -> i64:
    rt_vk_create_device()

pub fn backend_vulkan_submit(handle: i64, cmd_count: i64) -> text:
    rt_vk_submit(handle, cmd_count)

pub fn backend_vulkan_present(handle: i64) -> text:
    rt_vk_present(handle)

pub fn backend_vulkan_cleanup(handle: i64) -> i64:
    rt_vk_cleanup(handle)

pub fn backend_webgpu_create_device() -> i64:
    rt_webgpu_create_device()

pub fn backend_webgpu_submit(handle: i64, cmd_count: i64) -> text:
    rt_webgpu_submit(handle, cmd_count)

pub fn backend_webgpu_present(handle: i64) -> text:
    rt_webgpu_present(handle)

pub fn backend_webgpu_cleanup(handle: i64) -> i64:
    rt_webgpu_cleanup(handle)
