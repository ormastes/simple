# ============================================================================
# Synchronization
# ============================================================================

fn gpu_sync_threads():
    """Synchronize all threads within the current block.

    All threads in the block must reach this barrier before any
    thread can proceed past it. This is required when threads
    in the same block communicate through shared memory.

    Equivalent to:
    - CUDA: __syncthreads()
    - SPIR-V: OpControlBarrier (Workgroup scope)
    - OpenCL: barrier(CLK_LOCAL_MEM_FENCE)

    WARNING: All threads in the block MUST reach this barrier.
    Calling it inside divergent control flow (where some threads
    skip the barrier) is undefined behavior.
    """
    pass_todo

# ============================================================================
# Shared Memory
# ============================================================================

fn gpu_shared_memory<T>(size: i32) -> [T]:
    """Allocate shared memory visible to all threads in the current block.

    Shared memory is much faster than global GPU memory but is limited
    in size (typically 48KB-96KB per block). All threads in the same
    block see the same shared memory region.

    Args:
        size: Number of elements of type T to allocate

    Returns:
        A mutable array of T in shared memory

    Equivalent to:
    - CUDA: __shared__ T arr[size]
    - SPIR-V: Variable with Workgroup storage class
    - OpenCL: __local T arr[size]

    Note: The size must be a compile-time constant or a value
    known at kernel launch time (dynamic shared memory).
    """
    pass_todo

# ============================================================================
# Derived Thread Index Helpers
# ============================================================================

fn gpu_global_id_x() -> i32:
    """Get the global thread index in X: block_id * block_dim + thread_id.

    This is the most common way to index into global arrays from a kernel.
    """
    gpu_block_id_x() * gpu_block_dim_x() + gpu_thread_id_x()

fn gpu_global_id_y() -> i32:
    """Get the global thread index in Y: block_id * block_dim + thread_id."""
    gpu_block_id_y() * gpu_block_dim_y() + gpu_thread_id_y()

fn gpu_global_id_z() -> i32:
    """Get the global thread index in Z: block_id * block_dim + thread_id."""
    gpu_block_id_z() * gpu_block_dim_z() + gpu_thread_id_z()

fn gpu_global_size_x() -> i32:
    """Get the total number of threads in X: grid_dim * block_dim."""
    gpu_grid_dim_x() * gpu_block_dim_x()

fn gpu_global_size_y() -> i32:
    """Get the total number of threads in Y: grid_dim * block_dim."""
    gpu_grid_dim_y() * gpu_block_dim_y()

fn gpu_global_size_z() -> i32:
    """Get the total number of threads in Z: grid_dim * block_dim."""
    gpu_grid_dim_z() * gpu_block_dim_z()
