# GPU Built-in Functions (Intrinsics)
#
# These are GPU kernel intrinsic functions that map directly to hardware
# instructions on CUDA, Vulkan compute, or other GPU backends.
#
# They are only valid inside @gpu / @gpu_kernel / kernel fn functions.
# Calling them from host code is a compile error caught by the GPU checker.
#
# Thread Identification:
#   gpu_thread_id_{x,y,z}()   - Thread index within the block
#   gpu_block_id_{x,y,z}()    - Block index within the grid
#   gpu_block_dim_{x,y,z}()   - Number of threads per block
#   gpu_grid_dim_{x,y,z}()    - Number of blocks in the grid
#
# Synchronization:
#   gpu_sync_threads()         - Block-level barrier (all threads in block)
#
# Shared Memory:
#   gpu_shared_memory<T>(size) - Allocate block-shared memory
#
# These declarations are stubs; actual lowering happens in the SPIR-V/PTX
# backend via GpuIntrinsicKind in the compiler pipeline.

# ============================================================================
# Thread Identification - X Dimension
# ============================================================================

fn gpu_thread_id_x() -> i32:
    """Get the thread index in the X dimension within the current block.

    Equivalent to:
    - CUDA: threadIdx.x
    - SPIR-V: gl_LocalInvocationID.x
    - OpenCL: get_local_id(0)
    """
    pass_todo

