# camera3d.spl — Camera descriptor for perspective and orthographic projections
# All float values stored as fixed-point integers (* 1000).
# projection: "perspective" | "orthographic"

use std.io

class Camera3D:
    camera_id: i64
    name: text
    projection: text
    fov_degrees: i64
    near_plane: i64
    far_plane: i64
    aspect_w: i64
    aspect_h: i64
    pos_x: i64
    pos_y: i64
    pos_z: i64
    look_x: i64
    look_y: i64
    look_z: i64
    up_x: i64
    up_y: i64
    up_z: i64

    static fn create(name: text, projection: text) -> Camera3D:
        return Camera3D(
            camera_id: -1,
            name: name,
            projection: projection,
            fov_degrees: 60000,
            near_plane: 100,
            far_plane: 1000000,
            aspect_w: 16,
            aspect_h: 9,
            pos_x: 0, pos_y: 0, pos_z: 5000,
            look_x: 0, look_y: 0, look_z: 0,
            up_x: 0, up_y: 1000, up_z: 0
        )

    static fn perspective(name: text, fov: i64, near: i64, far: i64) -> Camera3D:
        return Camera3D(
            camera_id: -1,
            name: name,
            projection: "perspective",
            fov_degrees: fov,
            near_plane: near,
            far_plane: far,
            aspect_w: 16,
            aspect_h: 9,
            pos_x: 0, pos_y: 0, pos_z: 5000,
            look_x: 0, look_y: 0, look_z: 0,
            up_x: 0, up_y: 1000, up_z: 0
        )

    static fn orthographic(name: text, near: i64, far: i64) -> Camera3D:
        return Camera3D(
            camera_id: -1,
            name: name,
            projection: "orthographic",
            fov_degrees: 0,
            near_plane: near,
            far_plane: far,
            aspect_w: 16,
            aspect_h: 9,
            pos_x: 0, pos_y: 0, pos_z: 5000,
            look_x: 0, look_y: 0, look_z: 0,
            up_x: 0, up_y: 1000, up_z: 0
        )

    me set_position(x: i64, y: i64, z: i64) -> Camera3D:
        self.pos_x = x
        self.pos_y = y
        self.pos_z = z
        return self

    me look_at(x: i64, y: i64, z: i64) -> Camera3D:
        self.look_x = x
        self.look_y = y
        self.look_z = z
        return self

    me set_aspect(w: i64, h: i64) -> Camera3D:
        self.aspect_w = w
        self.aspect_h = h
        return self

    me info() -> text:
        return "Camera3D(id=" + self.camera_id.to_text() +
               " name=" + self.name +
               " proj=" + self.projection +
               " fov=" + self.fov_degrees.to_text() +
               " near=" + self.near_plane.to_text() +
               " far=" + self.far_plane.to_text() +
               " aspect=" + self.aspect_w.to_text() + ":" + self.aspect_h.to_text() + ")"
