# scene_graph3d.spl — Scene node and scene graph skeletons for the 3D engine
# Position/rotation/scale stored as fixed-point integers (* 1000).
# parent_id == -1 means root node; mesh_id/material_id == -1 means absent.

use std.io

class SceneNode3D:
    node_id: i64
    name: text
    parent_id: i64
    mesh_id: i64
    material_id: i64
    pos_x: i64
    pos_y: i64
    pos_z: i64
    rot_x: i64
    rot_y: i64
    rot_z: i64
    scale_x: i64
    scale_y: i64
    scale_z: i64
    visible: bool
    children_count: i64

    static fn create(name: text) -> SceneNode3D:
        return SceneNode3D(
            node_id: -1,
            name: name,
            parent_id: -1,
            mesh_id: -1,
            material_id: -1,
            pos_x: 0, pos_y: 0, pos_z: 0,
            rot_x: 0, rot_y: 0, rot_z: 0,
            scale_x: 1000, scale_y: 1000, scale_z: 1000,
            visible: true,
            children_count: 0
        )

    static fn root() -> SceneNode3D:
        return SceneNode3D(
            node_id: 0,
            name: "root",
            parent_id: -1,
            mesh_id: -1,
            material_id: -1,
            pos_x: 0, pos_y: 0, pos_z: 0,
            rot_x: 0, rot_y: 0, rot_z: 0,
            scale_x: 1000, scale_y: 1000, scale_z: 1000,
            visible: true,
            children_count: 0
        )

    me set_position(x: i64, y: i64, z: i64) -> SceneNode3D:
        self.pos_x = x
        self.pos_y = y
        self.pos_z = z
        return self

    me set_rotation(rx: i64, ry: i64, rz: i64) -> SceneNode3D:
        self.rot_x = rx
        self.rot_y = ry
        self.rot_z = rz
        return self

    me set_mesh(mesh_id: i64, material_id: i64) -> SceneNode3D:
        self.mesh_id = mesh_id
        self.material_id = material_id
        return self

    me info() -> text:
        return "SceneNode3D(id=" + self.node_id.to_text() +
               " name=" + self.name +
               " parent=" + self.parent_id.to_text() +
               " mesh=" + self.mesh_id.to_text() +
               " pos=" + self.pos_x.to_text() + "," + self.pos_y.to_text() + "," + self.pos_z.to_text() +
               " visible=" + self.visible.to_text() + ")"


class SceneGraph3D:
    root: SceneNode3D
    node_count: i64
    session_id: i64

    static fn create(session_id: i64) -> SceneGraph3D:
        return SceneGraph3D(
            root: SceneNode3D.root(),
            node_count: 1,
            session_id: session_id
        )

    me add_node(node: SceneNode3D, parent_id: i64) -> i64:
        val new_id = self.node_count
        self.node_count = self.node_count + 1
        return new_id

    me remove_node(node_id: i64) -> text:
        if node_id <= 0:
            return "error: cannot remove root or invalid node"
        return ""

    me node_count() -> i64:
        return self.node_count

    me info() -> text:
        return "SceneGraph3D(session=" + self.session_id.to_text() +
               " nodes=" + self.node_count.to_text() + ")"
