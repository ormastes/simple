# 3D Engine — Engine Facade
#
# High-level entry point that auto-selects the best available 3D rendering
# backend and delegates all operations to it.
#
# Backend priority: CPU scene renderer plus optional Vulkan font adapter.
#
# Usage:
#   use std.gpu.engine3d.engine.{Engine3D}
#
#   var engine = Engine3D.create(800, 600)
#   engine.clear(0xFF000000)
#   engine.present()
#   val pixels = engine.read_pixels()
#
# @tag:stdlib
# @tag:api
# @tag:gpu

use std.gpu.engine3d.backend.{RenderBackend3D}
use std.gpu.engine3d.backend_cpu.{CpuBackend3D}
use std.gpu.engine3d.types3d.{Vertex3D, Material3DParams, LightParams3D, mat4_identity, mat4_mul}
use std.gpu.engine3d.resource_pool.{ResourcePool3D, TextureHandle3D, BufferHandle3D, ShaderHandle3D, PipelineHandle3D}
use std.gpu.engine3d.texture3d.{TextureDescriptor3D, SamplerDescriptor3D, TextureView3D}
use std.gpu.engine3d.texture3d.{TEX_DIM_2D, TEX_DIM_3D, TEX_DIM_CUBE, TEX_FMT_RGBA8_UNORM, TEX_FMT_DEPTH32_FLOAT}
use std.gpu.engine3d.texture3d.{TEX_USAGE_TEXTURE_BINDING, TEX_USAGE_COPY_DST}
use std.gc_async_mut.text_layout.font_renderer.{
    FontCacheStats, FontGlyphRun, FontRenderBatch, FontRenderConfig, FontRenderer,
    font_execution_plan, font_render_config_selection_supported
}
use std.common.gpu.font_atlas_composite.{font_atlas_subrect_pixels, font_destination_origin}
use std.gpu.engine3d.color3d.{blend3d}
use std.gpu.engine3d.vulkan_font_adapter.{VulkanFontAdapter3D, VulkanFontAdapter3DEvidence}

fn engine3d_font_frame_target_allows(current: text, requested: text) -> bool:
    current == "" or current == requested

fn engine3d_font_completion_target(completed: bool, cpu_fallback_count: i64) -> text:
    if completed: return "vulkan"
    if cpu_fallback_count > 0: return "cpu"
    "unavailable"

class _PendingFontCpuFallback:
    x: i32
    y: i32
    batch: FontRenderBatch
    already_drawn: bool

# ============================================================================
# Engine3D
# ============================================================================

class Engine3D:
    """3D rendering engine with automatic backend selection.

    Creates the best available backend at initialization time. All rendering
    methods delegate to the active backend through the RenderBackend3D trait.

    Lifecycle:
        1. Engine3D.create(width, height)  — auto-detect and init backend
        2. clear(), submit_triangle(), present() — render frames
        3. shutdown()                      — release resources

    Example:
        var engine = Engine3D.create(800, 600)
        engine.clear(0xFF333333)
        engine.present()
        val pixels = engine.read_pixels()
        engine.shutdown()
    """

    _cpu: CpuBackend3D
    _backend_name: text
    _w: i32
    _h: i32
    _resources: ResourcePool3D
    _font_renderer: FontRenderer? = nil
    _vulkan_font: VulkanFontAdapter3D? = nil
    _vulkan_font_evidence: VulkanFontAdapter3DEvidence? = nil
    _font_cpu_comparator: bool = false
    _vulkan_pixels: [u32] = []
    _font_frame_target: text = ""
    _font_readback_target: text = ""
    last_font_execution_attempts: [text] = []
    last_font_execution_target: text = ""
    _pending_font_cpu_fallbacks: [_PendingFontCpuFallback] = []
    _view: [f32]
    _proj: [f32]

    me fonts() -> FontRenderer:
        val active = self._font_renderer
        if active != nil:
            return active
        val created = FontRenderer.new()
        self._font_renderer = created
        created

    # ========================================================================
    # Constructors
    # ========================================================================

    static fn create(width: i32, height: i32) -> Engine3D:
        """Create engine with auto-detected best backend.

        The CPU scene renderer remains the portable default. Call
        `create_with_backend(..., "vulkan")` for native font composition.

        Args:
            width: Framebuffer width in pixels
            height: Framebuffer height in pixels

        Returns:
            Initialized Engine3D
        """
        Engine3D.create_with_backend(width, height, "cpu")

    static fn create_with_backend(width: i32, height: i32, backend_name: text) -> Engine3D:
        """Create engine with a specific backend.

        Args:
            width: Framebuffer width in pixels
            height: Framebuffer height in pixels
            backend_name: `"cpu"`, `"vulkan"`, or `"vulkan-font"`; both
                Vulkan aliases install the font adapter while retaining the
                CPU scene renderer

        Returns:
            Initialized Engine3D (falls back to cpu for unknown names)
        """
        var cpu = CpuBackend3D.create()
        cpu.init(width, height)
        var engine = Engine3D(
            _cpu: cpu,
            _backend_name: "cpu",
            _w: width,
            _h: height,
            _resources: ResourcePool3D.create(),
            _view: mat4_identity(),
            _proj: mat4_identity()
        )
        if backend_name == "vulkan" or backend_name == "vulkan-font":
            engine.install_vulkan_font_backend()
        engine

    # ========================================================================
    # Backend Info
    # ========================================================================

    fn backend_name() -> text:
        """Get the honest scene/font backend identity."""
        self._backend_name

    me install_vulkan_font_backend() -> bool:
        val installed = self._vulkan_font
        if installed != nil:
            return installed.?.ready
        var adapter = VulkanFontAdapter3D.create(self._w, self._h)
        if not adapter.ready:
            adapter.shutdown()
            return false
        self._vulkan_font = adapter
        self._backend_name = "vulkan-font"
        true

    me enable_font_cpu_comparator(enabled: bool):
        self._font_cpu_comparator = enabled

    fn vulkan_font_evidence() -> VulkanFontAdapter3DEvidence?:
        self._vulkan_font_evidence

    fn font_execution_attempts() -> [text]: self.last_font_execution_attempts
    fn font_execution_target() -> text: self.last_font_execution_target

    # ========================================================================
    # Core — Identity & Lifecycle
    # ========================================================================

    fn name() -> text:
        self._cpu.name()

    me init(width: i32, height: i32) -> bool:
        val initialized = self._cpu.init(width, height)
        if initialized:
            self._w = width
            self._h = height
        initialized

    me shutdown():
        self.unload_font()
        val active = self._vulkan_font
        if active != nil:
            var vulkan = active.?
            vulkan.shutdown()
        self._vulkan_font = nil
        self._pending_font_cpu_fallbacks = []
        self._cpu.shutdown()

    me begin_frame():
        self._cpu.begin_frame()
        self._vulkan_pixels = []
        self._vulkan_font_evidence = nil
        self._font_frame_target = ""
        self._font_readback_target = ""
        self._pending_font_cpu_fallbacks = []
        self.last_font_execution_attempts = []
        self.last_font_execution_target = ""
        val active = self._vulkan_font
        if active != nil:
            var vulkan = active.?
            if not vulkan.begin_frame():
                vulkan.reason = "vulkan-font-frame-begin-failed"
            self._vulkan_font = vulkan

    me end_frame():
        val active = self._vulkan_font
        if active != nil:
            var vulkan = active.?
            val evidence = vulkan.end_frame()
            self._vulkan_font_evidence = evidence
            self._vulkan_pixels = []
            val expected_bytes = self._w.to_i64() * self._h.to_i64() * 4
            val completed = (self._font_frame_target == "vulkan" and evidence.ready and
                evidence.hud_draws + evidence.world_draws > 0 and
                evidence.pixels_rgba8.len() == expected_bytes)
            val completion_target = engine3d_font_completion_target(
                completed, self._pending_font_cpu_fallbacks.len()
            )
            if self._font_frame_target == "vulkan":
                var completion_attempts = self.last_font_execution_attempts
                val completion_reason = if evidence.reason == "": "completion-failed" else: evidence.reason
                completion_attempts.push(if completed: "vulkan:success" else: "vulkan:" + completion_reason)
                self.last_font_execution_attempts = completion_attempts
            if completion_target == "vulkan":
                var i: i64 = 0
                while i + 3 < evidence.pixels_rgba8.len():
                    val r = evidence.pixels_rgba8[i].to_u32()
                    val g = evidence.pixels_rgba8[i + 1].to_u32()
                    val b = evidence.pixels_rgba8[i + 2].to_u32()
                    val a = evidence.pixels_rgba8[i + 3].to_u32()
                    self._vulkan_pixels.push((a << 24u32) | (r << 16u32) | (g << 8u32) | b)
                    i = i + 4
                self._font_readback_target = "vulkan"
                self.last_font_execution_target = "vulkan"
            elif completion_target == "cpu":
                var replayed = true
                for pending in self._pending_font_cpu_fallbacks:
                    if not pending.already_drawn and not self._draw_font_batch_hud(pending.x, pending.y, pending.batch):
                        replayed = false
                if replayed:
                    self._font_frame_target = "cpu"
                    self._font_readback_target = "cpu"
                    self.last_font_execution_target = "cpu"
                    var fallback_attempts = self.last_font_execution_attempts
                    fallback_attempts.push("cpu:deferred-success")
                    self.last_font_execution_attempts = fallback_attempts
                else:
                    self._font_readback_target = "unavailable"
                    self.last_font_execution_target = ""
            elif self._font_frame_target == "vulkan":
                self._font_readback_target = "unavailable"
                self.last_font_execution_target = ""
            self._pending_font_cpu_fallbacks = []
            self._vulkan_font = vulkan
        self._cpu.end_frame()

    me present():
        self._cpu.present()

    # ========================================================================
    # Core — View
    # ========================================================================

    me set_camera(view: [f32], proj: [f32]):
        self._view = view
        self._proj = proj
        self._cpu.set_camera(view, proj)

    me set_viewport(x: i32, y: i32, w: i32, h: i32):
        self._cpu.set_viewport(x, y, w, h)

    # ========================================================================
    # Core — Clear
    # ========================================================================

    me clear(color: u32):
        self._cpu.clear(color)

    me clear_depth():
        self._cpu.clear_depth()

    # ========================================================================
    # Core — Geometry Submission
    # ========================================================================

    me submit_triangle(v0: Vertex3D, v1: Vertex3D, v2: Vertex3D, material: Material3DParams, model: [f32]):
        self._cpu.submit_triangle(v0, v1, v2, material, model)

    # ========================================================================
    # Core — Lighting
    # ========================================================================

    me set_lights(lights: [LightParams3D]):
        self._cpu.set_lights(lights)

    me set_ambient(color: u32, intensity: f32):
        self._cpu.set_ambient(color, intensity)

    # ========================================================================
    # Core — Render State
    # ========================================================================

    me set_depth_test(enabled: bool):
        self._cpu.set_depth_test(enabled)

    me set_cull_mode(mode: i32):
        self._cpu.set_cull_mode(mode)

    me set_blend_mode(mode: i32):
        self._cpu.set_blend_mode(mode)

    # ========================================================================
    # Core — Stencil
    # ========================================================================

    me set_stencil_mask(mask: [u8], w: i32, h: i32):
        self._cpu.set_stencil_mask(mask, w, h)

    me clear_stencil_mask():
        self._cpu.clear_stencil_mask()

    # ========================================================================
    # Core — Render Target
    # ========================================================================

    me set_render_target(pixels: [u32], w: i32, h: i32):
        self._cpu.set_render_target(pixels, w, h)

    me reset_render_target():
        self._cpu.reset_render_target()

    # ========================================================================
    # Core — Pixel I/O
    # ========================================================================

    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        self._cpu.draw_image(x, y, w, h, pixels)

    me load_font(path: text) -> bool:
        val fonts = self.fonts()
        val loaded = fonts.try_load_runtime_ttf(path)
        self._font_renderer = fonts
        loaded

    me unload_font():
        val active = self._font_renderer
        if active != nil:
            val fonts = active
            fonts.clear_ttf()
        self._font_renderer = nil

    me font_cache_stats() -> FontCacheStats:
        val fonts = self.fonts()
        val stats = fonts.cache_stats()
        self._font_renderer = fonts
        stats

    me _draw_font_batch_hud(x: i32, y: i32, batch: FontRenderBatch) -> bool:
        if not batch.material_supported() or batch.is_empty():
            return false
        val target_w = self._cpu.width()
        val target_h = self._cpu.height()
        var target = self._cpu.read_pixels()
        var drawn = false
        var i = 0
        while i < batch.quads.len():
            val quad = batch.quads[i]
            val dst_x = font_destination_origin(x, quad.dst_x, quad.width)
            val dst_y = font_destination_origin(y, quad.dst_y, quad.height)
            if (dst_x != nil and dst_y != nil and quad.width > 0 and quad.height > 0 and
                dst_x.?.to_i64() < target_w.to_i64() and dst_y.?.to_i64() < target_h.to_i64() and
                dst_x.?.to_i64() + quad.width.to_i64() > 0 and dst_y.?.to_i64() + quad.height.to_i64() > 0):
                val pixels = font_atlas_subrect_pixels(batch.atlas_pixels, batch.atlas_width, batch.atlas_height,
                    quad.atlas_x, quad.atlas_y, quad.width, quad.height, quad.color)
                if pixels.len() > 0:
                    var row = 0
                    while row < quad.height:
                        var col = 0
                        while col < quad.width:
                            val tx = dst_x.?.to_i64() + col.to_i64()
                            val ty = dst_y.?.to_i64() + row.to_i64()
                            if tx >= 0 and tx < target_w.to_i64() and ty >= 0 and ty < target_h.to_i64():
                                val src = pixels[row * quad.width + col]
                                val target_index = ty * target_w.to_i64() + tx
                                if src != 0u32 and target_index.to_i64() < target.len():
                                    target[target_index] = blend3d(src, target[target_index])
                                    drawn = true
                            col = col + 1
                        row = row + 1
            i = i + 1
        if drawn:
            self._cpu.draw_image(0, 0, target_w, target_h, target)
        drawn

    me _draw_font_batch_policy(x: i32, y: i32, depth: f32, world: bool,
                               batch: FontRenderBatch, plan: [text]) -> bool:
        if not batch.material_supported() or plan.len() == 0:
            return false
        var attempts: [text] = []
        var winner = ""
        for target in plan:
            if not engine3d_font_frame_target_allows(self._font_frame_target, target):
                attempts.push(target + ":frame-target=" + self._font_frame_target)
            elif target == "vulkan":
                val active = self._vulkan_font
                if active == nil:
                    attempts.push("vulkan:unavailable")
                else:
                    var vulkan = active.?
                    val drawn = if world:
                        vulkan.draw_world(x, y, depth, batch)
                    else:
                        vulkan.draw_hud(x, y, batch)
                    self._vulkan_font = vulkan
                    attempts.push(if drawn: "vulkan:pending" else: "vulkan:failed")
                    if drawn:
                        winner = "vulkan-pending"
                        self._font_frame_target = "vulkan"
                        var cpu_ready = false
                        if self._font_cpu_comparator and plan.contains("cpu"):
                            cpu_ready = self._draw_font_batch_hud(x, y, batch)
                        if plan.contains("cpu"):
                            self._pending_font_cpu_fallbacks.push(
                                _PendingFontCpuFallback(x: x, y: y, batch: batch, already_drawn: cpu_ready)
                            )
            elif target == "cpu":
                val drawn = self._draw_font_batch_hud(x, y, batch)
                attempts.push(if drawn: "cpu:success" else: "cpu:failed")
                if drawn:
                    winner = "cpu"
                    self._font_frame_target = "cpu"
            if winner != "":
                break
        self.last_font_execution_attempts = attempts
        self.last_font_execution_target = winner
        if winner == "vulkan-pending":
            self._font_readback_target = "vulkan-pending"
        elif winner == "cpu":
            self._font_readback_target = "cpu"
        winner != ""

    me draw_glyph_run_hud(x: i32, y: i32, run: FontGlyphRun, color: u32, font_size: i32) -> bool:
        val fonts = self.fonts()
        val batch = fonts.prepare_glyph_run(run, color, font_size)
        self._font_renderer = fonts
        self._draw_font_batch_policy(x, y, 0.0f32, false, batch, ["vulkan", "cpu"])

    me draw_text_hud(x: i32, y: i32, content: text, color: u32, font_size: i32) -> bool:
        self.draw_text_hud_configured(
            x, y, content, color, FontRenderConfig.default_for_size(font_size)
        )

    me draw_text_hud_configured(x: i32, y: i32, content: text, color: u32, config: FontRenderConfig) -> bool:
        val plan = font_execution_plan(config, ["vulkan", "cpu"])
        if plan.len() == 0 or not font_render_config_selection_supported(config):
            return false
        val fonts = self.fonts()
        val batch = fonts.prepare_text_configured(content, color, config)
        self._font_renderer = fonts
        self._draw_font_batch_policy(x, y, 0.0f32, false, batch, plan)

    fn _font_world_screen(x: f32, y: f32, z: f32) -> (bool, i32, i32, f32):
        val target_w = self._cpu.width()
        val target_h = self._cpu.height()
        if self._view.len() != 16 or self._proj.len() != 16 or target_w <= 0 or target_h <= 0:
            return (false, 0, 0, 0.0f32)
        val vp = mat4_mul(self._proj, self._view)
        val clip_x = vp[0] * x + vp[4] * y + vp[8] * z + vp[12]
        val clip_y = vp[1] * x + vp[5] * y + vp[9] * z + vp[13]
        val clip_z = vp[2] * x + vp[6] * y + vp[10] * z + vp[14]
        val clip_w = vp[3] * x + vp[7] * y + vp[11] * z + vp[15]
        if clip_w <= 0.0:
            return (false, 0, 0, 0.0f32)
        val ndc_x = clip_x / clip_w
        val ndc_y = clip_y / clip_w
        val ndc_z = clip_z / clip_w
        if ndc_x < -1.0 or ndc_x > 1.0 or ndc_y < -1.0 or ndc_y > 1.0 or ndc_z < -1.0 or ndc_z > 1.0:
            return (false, 0, 0, 0.0f32)
        val screen_x = ((ndc_x + 1.0) * (target_w as f32) / 2.0) as i32
        val screen_y = ((1.0 - ndc_y) * (target_h as f32) / 2.0) as i32
        (true, screen_x, screen_y, ndc_z)

    me draw_text_world(x: f32, y: f32, z: f32, content: text, color: u32, font_size: i32) -> bool:
        self.draw_text_world_configured(
            x, y, z, content, color, FontRenderConfig.default_for_size(font_size)
        )

    me draw_text_world_configured(x: f32, y: f32, z: f32, content: text, color: u32, config: FontRenderConfig) -> bool:
        val plan = font_execution_plan(config, ["vulkan", "cpu"])
        if plan.len() == 0 or not font_render_config_selection_supported(config):
            return false
        val projected = self._font_world_screen(x, y, z)
        if not projected.0:
            return false
        val fonts = self.fonts()
        val batch = fonts.prepare_text_configured(content, color, config)
        self._font_renderer = fonts
        self._draw_font_batch_policy(projected.1, projected.2, projected.3, true, batch, plan)

    me draw_glyph_run_world(x: f32, y: f32, z: f32, run: FontGlyphRun, color: u32, font_size: i32) -> bool:
        val projected = self._font_world_screen(x, y, z)
        if not projected.0:
            return false
        val fonts = self.fonts()
        val batch = fonts.prepare_glyph_run(run, color, font_size)
        self._font_renderer = fonts
        self._draw_font_batch_policy(projected.1, projected.2, projected.3, true, batch, ["vulkan", "cpu"])

    fn read_pixels() -> [u32]:
        if self._font_readback_target == "vulkan-pending" or self._font_readback_target == "unavailable":
            return []
        if (self._font_readback_target == "vulkan" and self._vulkan_font != nil and
            self._vulkan_pixels.len() == self._w.to_i64() * self._h.to_i64()):
            return self._vulkan_pixels
        self._cpu.read_pixels()

    fn read_cpu_comparator_pixels() -> [u32]:
        self._cpu.read_pixels()

    fn read_depth() -> [f32]:
        self._cpu.read_depth()

    fn width() -> i32:
        self._cpu.width()

    fn height() -> i32:
        self._cpu.height()

    # ========================================================================
    # Advanced — Primitive Shapes
    # ========================================================================

    me draw_cube(model: [f32], material: Material3DParams):
        self._cpu.draw_cube(model, material)

    me draw_sphere(model: [f32], material: Material3DParams, segments: i32):
        self._cpu.draw_sphere(model, material, segments)

    me draw_plane(model: [f32], material: Material3DParams):
        self._cpu.draw_plane(model, material)

    me draw_cylinder(model: [f32], material: Material3DParams, segments: i32):
        self._cpu.draw_cylinder(model, material, segments)

    me draw_cone(model: [f32], material: Material3DParams, segments: i32):
        self._cpu.draw_cone(model, material, segments)

    # ========================================================================
    # Advanced — Wireframe & Lines
    # ========================================================================

    me draw_line_3d(x1: f32, y1: f32, z1: f32, x2: f32, y2: f32, z2: f32, color: u32, thickness: f32):
        self._cpu.draw_line_3d(x1, y1, z1, x2, y2, z2, color, thickness)

    me draw_wireframe(vertices: [Vertex3D], indices: [u32], model: [f32], color: u32):
        self._cpu.draw_wireframe(vertices, indices, model, color)

    # ========================================================================
    # Advanced — Mesh Submission
    # ========================================================================

    me submit_indexed_mesh(vertices: [Vertex3D], indices: [u32], material: Material3DParams, model: [f32]):
        self._cpu.submit_indexed_mesh(vertices, indices, material, model)

    me submit_mesh_instanced(vertices: [Vertex3D], indices: [u32], transforms: [[f32]], count: i32, material: Material3DParams):
        self._cpu.submit_mesh_instanced(vertices, indices, transforms, count, material)

    # ========================================================================
    # Advanced — Textures
    # ========================================================================

    me create_texture(w: i32, h: i32, pixels: [u32]) -> i32:
        self._cpu.create_texture(w, h, pixels)

    me delete_texture(id: i32):
        self._cpu.delete_texture(id)

    # ========================================================================
    # Advanced — Shadows
    # ========================================================================

    me begin_shadow_pass(light_view_proj: [f32], shadow_map_size: i32):
        self._cpu.begin_shadow_pass(light_view_proj, shadow_map_size)

    me end_shadow_pass():
        self._cpu.end_shadow_pass()

    me submit_shadow_caster(vertices: [Vertex3D], indices: [u32], model: [f32]):
        self._cpu.submit_shadow_caster(vertices, indices, model)

    # ========================================================================
    # Advanced — Post-Processing
    # ========================================================================

    me apply_fog(color: u32, density: f32, near: f32, far: f32):
        self._cpu.apply_fog(color, density, near, far)

    me apply_bloom(threshold: f32, intensity: f32):
        self._cpu.apply_bloom(threshold, intensity)

    me apply_tonemap(exposure: f32):
        self._cpu.apply_tonemap(exposure)

    # ========================================================================
    # Advanced — Compute
    # ========================================================================

    me create_compute_kernel(src: text) -> i32:
        self._cpu.create_compute_kernel(src)

    me dispatch_compute(kernel_id: i32, x: i32, y: i32, z: i32):
        self._cpu.dispatch_compute(kernel_id, x, y, z)

    # ========================================================================
    # Advanced — Textures (extended)
    # ========================================================================

    me bind_texture(slot: i32, texture_id: i32):
        self._cpu.bind_texture(slot, texture_id)

    me create_depth_texture(w: i32, h: i32) -> i32:
        self._cpu.create_depth_texture(w, h)

    me create_cubemap(size: i32, faces: [[u32]]) -> i32:
        self._cpu.create_cubemap(size, faces)

    me generate_mipmaps(texture_id: i32):
        self._cpu.generate_mipmaps(texture_id)

    # ========================================================================
    # Advanced — Shader / Pipeline
    # ========================================================================

    me create_shader(vertex_src: text, fragment_src: text) -> i32:
        self._cpu.create_shader(vertex_src, fragment_src)

    me delete_shader(shader_id: i32):
        self._cpu.delete_shader(shader_id)

    me create_pipeline(shader_id: i32, depth_test: bool, blend_mode: i32, cull_mode: i32) -> i32:
        self._cpu.create_pipeline(shader_id, depth_test, blend_mode, cull_mode)

    me bind_pipeline(pipeline_id: i32):
        self._cpu.bind_pipeline(pipeline_id)

    # ========================================================================
    # Advanced — Buffer Management
    # ========================================================================

    me create_storage_buffer(size: i32) -> i32:
        self._cpu.create_storage_buffer(size)

    me update_buffer(buffer_id: i32, data: [u8]):
        self._cpu.update_buffer(buffer_id, data)

    me read_buffer(buffer_id: i32) -> [u8]:
        self._cpu.read_buffer(buffer_id)

    # ========================================================================
    # Advanced — Render Pass
    # ========================================================================

    me begin_render_pass(color_target: i32, depth_target: i32):
        self._cpu.begin_render_pass(color_target, depth_target)

    me end_render_pass():
        self._cpu.end_render_pass()

    # ========================================================================
    # Advanced — Post-Processing (extended)
    # ========================================================================

    me apply_ssao(radius: f32, bias: f32, intensity: f32):
        self._cpu.apply_ssao(radius, bias, intensity)

    me apply_fxaa():
        self._cpu.apply_fxaa()

    me apply_ssr(max_steps: i32, thickness: f32):
        self._cpu.apply_ssr(max_steps, thickness)

    # ========================================================================
    # Advanced — Occlusion
    # ========================================================================

    me occlusion_query(x: i32, y: i32, w: i32, h: i32) -> i32:
        self._cpu.occlusion_query(x, y, w, h)

    # ========================================================================
    # Advanced — Animation
    # ========================================================================

    me upload_bone_transforms(bones: [[f32]], count: i32):
        self._cpu.upload_bone_transforms(bones, count)

    # ========================================================================
    # Advanced — GPU-Driven Rendering
    # ========================================================================

    me draw_indirect(buffer_id: i32, offset: i32, count: i32):
        self._cpu.draw_indirect(buffer_id, offset, count)

    # ========================================================================
    # Advanced — Synchronization
    # ========================================================================

    me pipeline_barrier():
        self._cpu.pipeline_barrier()

    # ========================================================================
    # Resource Pool — High-Level API
    # ========================================================================

    me load_texture(w: i32, h: i32, pixels: [u32]) -> TextureHandle3D:
        val gpu_id = self._cpu.create_texture(w, h, pixels)
        self._resources.allocate_texture(w, h, 1, TEX_FMT_RGBA8_UNORM, 1, gpu_id)

    me load_texture_3d(w: i32, h: i32, depth: i32, pixels: [u32]) -> TextureHandle3D:
        val gpu_id = self._cpu.create_texture(w, h, pixels)
        self._resources.allocate_texture(w, h, depth, TEX_FMT_RGBA8_UNORM, 1, gpu_id)

    me load_cubemap(size: i32, faces: [[u32]]) -> TextureHandle3D:
        val gpu_id = self._cpu.create_cubemap(size, faces)
        self._resources.allocate_texture(size, size, 6, TEX_FMT_RGBA8_UNORM, 1, gpu_id)

    me load_depth_texture(w: i32, h: i32) -> TextureHandle3D:
        val gpu_id = self._cpu.create_depth_texture(w, h)
        self._resources.allocate_texture(w, h, 1, TEX_FMT_DEPTH32_FLOAT, 1, gpu_id)

    me unload_texture(handle: TextureHandle3D):
        self._cpu.delete_texture(handle.gpu_id)
        self._resources.free_texture(handle.id)

    me load_shader(vertex_src: text, fragment_src: text) -> ShaderHandle3D:
        val gpu_id = self._cpu.create_shader(vertex_src, fragment_src)
        self._resources.allocate_shader(vertex_src, fragment_src, gpu_id)

    me unload_shader(handle: ShaderHandle3D):
        self._cpu.delete_shader(handle.gpu_id)
        self._resources.free_shader(handle.id)

    me load_pipeline(shader: ShaderHandle3D, depth_test: bool, blend_mode: i32, cull_mode: i32) -> PipelineHandle3D:
        val gpu_id = self._cpu.create_pipeline(shader.gpu_id, depth_test, blend_mode, cull_mode)
        self._resources.allocate_pipeline(shader.gpu_id, depth_test, blend_mode, cull_mode, gpu_id)

    me load_buffer(size: i32) -> BufferHandle3D:
        val gpu_id = self._cpu.create_storage_buffer(size)
        self._resources.allocate_buffer(size, 0, gpu_id)

    me unload_buffer(handle: BufferHandle3D):
        self._resources.free_buffer(handle.id)

    me gc_resources(frame_threshold: i32):
        self._resources.gc_unused(frame_threshold)

    me touch_resource(id: i32):
        self._resources.touch(id)

    fn resource_pool() -> ResourcePool3D:
        self._resources

    # ========================================================================
    # Extended Texture Ops (Chrome WebGPU parity)
    # ========================================================================

    me create_texture_ex(desc: TextureDescriptor3D, data: [u8]) -> i32:
        self._cpu.create_texture_ex(desc, data)

    me create_sampler(desc: SamplerDescriptor3D) -> i32:
        self._cpu.create_sampler(desc)

    me create_texture_view(texture_id: i32, dimension: i32, format: i32, base_mip: i32, mip_count: i32, base_layer: i32, layer_count: i32) -> i32:
        self._cpu.create_texture_view(texture_id, dimension, format, base_mip, mip_count, base_layer, layer_count)

    me destroy_texture_ex(texture_id: i32):
        self._cpu.destroy_texture_ex(texture_id)

    me destroy_sampler(sampler_id: i32):
        self._cpu.destroy_sampler(sampler_id)

    me write_texture(texture_id: i32, x: i32, y: i32, z: i32, w: i32, h: i32, d: i32, data: [u8]):
        self._cpu.write_texture(texture_id, x, y, z, w, h, d, data)

    me copy_texture_to_texture(src_id: i32, dst_id: i32, src_origin: [i32], dst_origin: [i32], copy_size: [i32]):
        self._cpu.copy_texture_to_texture(src_id, dst_id, src_origin, dst_origin, copy_size)

    me generate_mipmaps_ex(texture_id: i32, format: i32):
        self._cpu.generate_mipmaps_ex(texture_id, format)

    me compress_texture(texture_id: i32, target_format: i32) -> i32:
        self._cpu.compress_texture(texture_id, target_format)

    me read_texture(texture_id: i32, mip: i32, layer: i32) -> [u8]:
        self._cpu.read_texture(texture_id, mip, layer)
