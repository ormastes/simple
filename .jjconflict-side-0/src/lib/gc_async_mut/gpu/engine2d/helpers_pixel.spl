"""2D Engine — Shared Pixel Buffer Helpers

Pure functions for pixel buffer index calculation, safe pixel reads/writes
(bounds-checked, no backend state), and alpha-compositing utilities.

The RGBA pack/unpack/blend primitives live in `color.spl`. This module
adds the buffer-level helpers that are duplicated in every CPU/software
backend: safe get, safe set, and blend-over using explicit parameters
instead of capturing backend state.

Usage:
    use std.gpu.engine2d.helpers_pixel.{
        buf_get_pixel, buf_set_pixel, buf_set_pixel_blend,
        alpha_premultiply, alpha_unpremultiply
    }

@tag:stdlib
@tag:gpu
"""

use std.gpu.engine2d.color.{color_r, color_g, color_b, color_a, rgba, blend}

# ============================================================================
# Safe Pixel Buffer Access
# ============================================================================

fn buf_get_pixel(buf: [u32], x: i32, y: i32, w: i32, h: i32) -> u32:
    """Read a pixel at (x, y). Returns 0 (transparent black) if out of bounds."""
    if x < 0 or y < 0 or x >= w or y >= h:
        return 0u32
    val idx = y * w + x
    if idx < 0 or idx >= buf.len():
        return 0u32
    buf[idx]

fn buf_set_pixel(mut buf: [u32], x: i32, y: i32, w: i32, h: i32, color: u32) -> [u32]:
    """Write a pixel at (x, y), silently ignoring out-of-bounds coordinates."""
    if x < 0 or y < 0 or x >= w or y >= h:
        return buf
    val idx = y * w + x
    if idx < 0 or idx >= buf.len():
        return buf
    buf[idx] = color
    buf

fn buf_set_pixel_blend(mut buf: [u32], x: i32, y: i32, w: i32, h: i32, color: u32) -> [u32]:
    """Alpha-blend `color` over the existing pixel at (x, y). Bounds-safe."""
    if x < 0 or y < 0 or x >= w or y >= h:
        return buf
    val idx = y * w + x
    if idx < 0 or idx >= buf.len():
        return buf
    val dst = buf[idx]
    buf[idx] = blend(color, dst)
    buf

# ============================================================================
# Alpha Compositing
# ============================================================================

fn alpha_premultiply(color: u32) -> u32:
    """Return color with RGB channels pre-multiplied by alpha.

    Pre-multiplied alpha is the canonical form for compositing pipelines.
    A fully opaque or fully transparent color is returned unchanged.
    """
    val a = color_a(color)
    if a == 255:
        return color
    if a == 0:
        return 0u32
    val r = color_r(color) * a / 255
    val g = color_g(color) * a / 255
    val b = color_b(color) * a / 255
    rgba(r, g, b, a)

fn alpha_unpremultiply(color: u32) -> u32:
    """Undo pre-multiplication: restore straight-alpha RGB from premultiplied.

    Returns transparent black for zero-alpha input to avoid division by zero.
    """
    val a = color_a(color)
    if a == 0:
        return 0u32
    if a == 255:
        return color
    val r = color_r(color) * 255 / a
    val g = color_g(color) * 255 / a
    val b = color_b(color) * 255 / a
    rgba(r, g, b, a)

fn alpha_composite_over(src: u32, dst: u32) -> u32:
    """Porter-Duff src-over composite. Equivalent to color.blend but explicit."""
    blend(src, dst)

# ============================================================================
# Pixel Conversion Helpers
# ============================================================================

fn u32_to_i64(v: u32) -> i64:
    """Widen u32 to i64 for GPU argument packing (avoids per-backend cast)."""
    v as i64

fn i32_to_i64(v: i32) -> i64:
    """Widen i32 to i64 for GPU kernel argument packing."""
    v as i64

fn pixels_to_bytes(pixel_count: i64) -> i64:
    """Convert a pixel count to byte count (4 bytes per RGBA pixel)."""
    pixel_count * 4

fn bytes_to_pixels(byte_count: i64) -> i64:
    """Convert a byte count to pixel count (4 bytes per RGBA pixel)."""
    byte_count / 4
