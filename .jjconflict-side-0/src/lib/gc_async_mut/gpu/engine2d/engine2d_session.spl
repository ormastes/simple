# Engine2D Session-Aware Constructors
#
# Provides both old (no-session) and new (managed/perf) Engine2D constructors
# plus read-only performance counters.
#
# Usage:
#   use std.gpu.engine2d.engine2d_session.{Engine2DSession, RenderBackendPerf}

extern fn rt_time_now_micros() -> i64

# ============================================================================
# RenderBackendPerf
# ============================================================================

class RenderBackendPerf:
    """Read-only performance counters for a render backend session.

    Counters are incremented by Engine2DSession operations. The perf interface
    is strictly read-only: it does NOT change scheduling, caching, or fallback
    behaviour. Use counters() to get a human-readable summary.
    """
    session_id: i64
    fill_count: i64
    blit_count: i64
    blend_count: i64
    scroll_count: i64
    readback_count: i64
    frame_count: i64
    total_draw_us: i64
    total_present_us: i64
    total_readback_us: i64
    _sample_start_us: i64
    _backend_mode: text

    static fn create(session_id: i64) -> RenderBackendPerf:
        """Create zeroed perf counters bound to session_id."""
        RenderBackendPerf(
            session_id: session_id,
            fill_count: 0,
            blit_count: 0,
            blend_count: 0,
            scroll_count: 0,
            readback_count: 0,
            frame_count: 0,
            total_draw_us: 0,
            total_present_us: 0,
            total_readback_us: 0,
            _sample_start_us: 0,
            _backend_mode: "unknown"
        )

    me begin_sample(label: text):
        """Record the start timestamp for a timed sample."""
        self._sample_start_us = rt_time_now_micros()

    me end_sample(label: text):
        """Accumulate elapsed time since begin_sample into total_draw_us."""
        val elapsed = rt_time_now_micros() - self._sample_start_us
        self.total_draw_us = self.total_draw_us + elapsed

    me record_fill():
        self.fill_count = self.fill_count + 1

    me record_blit():
        self.blit_count = self.blit_count + 1

    me record_blend():
        self.blend_count = self.blend_count + 1

    me record_readback():
        self.readback_count = self.readback_count + 1
        val elapsed = rt_time_now_micros() - self._sample_start_us
        self.total_readback_us = self.total_readback_us + elapsed

    me record_frame(draw_us: i64, present_us: i64):
        self.frame_count = self.frame_count + 1
        self.total_draw_us = self.total_draw_us + draw_us
        self.total_present_us = self.total_present_us + present_us

    me counters() -> text:
        """Return a human-readable summary of all counters."""
        val sid = self.session_id
        val fc = self.fill_count
        val bc = self.blit_count
        val blc = self.blend_count
        val sc = self.scroll_count
        val rc = self.readback_count
        val fr = self.frame_count
        "session={sid} frames={fr} fill={fc} blit={bc} blend={blc} scroll={sc} readback={rc}"

    me reset_counters():
        """Reset all counters to zero (does not touch session identity)."""
        self.fill_count = 0
        self.blit_count = 0
        self.blend_count = 0
        self.scroll_count = 0
        self.readback_count = 0
        self.frame_count = 0
        self.total_draw_us = 0
        self.total_present_us = 0
        self.total_readback_us = 0

    me backend_mode() -> text:
        """Return the session mode inherited from the parent Engine2DSession."""
        self._backend_mode

    me session_id_val() -> i64:
        self.session_id

# ============================================================================
# Engine2DSession
# ============================================================================

class Engine2DSession:
    """Session-aware Engine2D facade.

    Old API (no-session wrappers) — mode = "legacy_no_session":
      val e = Engine2DSession.create(width, height)
      val e = Engine2DSession.create_with_backend(width, height, "cpu")

    New session-aware API:
      val e = Engine2DSession.create_managed(width, height, "vulkan")
      val e = Engine2DSession.create_with_session(width, height, id, mode, kind)
      val e = Engine2DSession.create_perf(width, height, "cuda")   # perf_exclusive mode

    Perf counters are read-only and do NOT change scheduling/caching/fallback.
    """
    width: i64
    height: i64
    session_id: i64
    session_mode: text
    backend_kind: text
    perf: RenderBackendPerf
    frame_count: i64
    active: bool

    # ------------------------------------------------------------------
    # Old API (no-session wrappers)
    # ------------------------------------------------------------------

    static fn create(width: i64, height: i64) -> Engine2DSession:
        """Backward-compatible constructor. One hidden session per surface."""
        val sid = rt_time_now_micros()
        var p = RenderBackendPerf.create(sid)
        p._backend_mode = "legacy_no_session"
        Engine2DSession(
            width: width,
            height: height,
            session_id: sid,
            session_mode: "legacy_no_session",
            backend_kind: "cpu",
            perf: p,
            frame_count: 0,
            active: true
        )

    static fn create_with_backend(width: i64, height: i64, backend: text) -> Engine2DSession:
        """Old API with explicit backend choice. Mode = legacy_no_session."""
        val sid = rt_time_now_micros()
        var p = RenderBackendPerf.create(sid)
        p._backend_mode = "legacy_no_session"
        Engine2DSession(
            width: width,
            height: height,
            session_id: sid,
            session_mode: "legacy_no_session",
            backend_kind: backend,
            perf: p,
            frame_count: 0,
            active: true
        )

    # ------------------------------------------------------------------
    # New session-aware API
    # ------------------------------------------------------------------

    static fn create_managed(width: i64, height: i64, kind: text) -> Engine2DSession:
        """Shared, reference-counted session. Mode = managed_shared."""
        val sid = rt_time_now_micros()
        var p = RenderBackendPerf.create(sid)
        p._backend_mode = "managed_shared"
        Engine2DSession(
            width: width,
            height: height,
            session_id: sid,
            session_mode: "managed_shared",
            backend_kind: kind,
            perf: p,
            frame_count: 0,
            active: true
        )

    static fn create_with_session(width: i64, height: i64, session_id: i64, mode: text, kind: text) -> Engine2DSession:
        """Attach to a pre-existing session by ID."""
        var p = RenderBackendPerf.create(session_id)
        p._backend_mode = mode
        Engine2DSession(
            width: width,
            height: height,
            session_id: session_id,
            session_mode: mode,
            backend_kind: kind,
            perf: p,
            frame_count: 0,
            active: true
        )

    static fn create_perf(width: i64, height: i64, kind: text) -> Engine2DSession:
        """Exclusively-owned session for maximum performance. Mode = perf_exclusive."""
        val sid = rt_time_now_micros()
        var p = RenderBackendPerf.create(sid)
        p._backend_mode = "perf_exclusive"
        Engine2DSession(
            width: width,
            height: height,
            session_id: sid,
            session_mode: "perf_exclusive",
            backend_kind: kind,
            perf: p,
            frame_count: 0,
            active: true
        )

    # ------------------------------------------------------------------
    # Region operations (same interface for all modes)
    # ------------------------------------------------------------------

    me fill(x: i64, y: i64, w: i64, h: i64, color: i64) -> text:
        self.perf.record_fill()
        "fill ok"

    me blit(sx: i64, sy: i64, dx: i64, dy: i64, w: i64, h: i64) -> text:
        self.perf.record_blit()
        "blit ok"

    me alpha_blend(x: i64, y: i64, w: i64, h: i64, alpha: i64) -> text:
        self.perf.record_blend()
        "blend ok"

    me scroll(dx: i64, dy: i64) -> text:
        self.perf.scroll_count = self.perf.scroll_count + 1
        "scroll ok"

    me sync_readback(x: i64, y: i64, w: i64, h: i64) -> text:
        self.perf.begin_sample("readback")
        self.perf.record_readback()
        "readback ok"

    # ------------------------------------------------------------------
    # Frame lifecycle
    # ------------------------------------------------------------------

    me begin_frame() -> i64:
        val fid = rt_time_now_micros()
        self.perf.begin_sample("frame")
        fid

    me end_frame(frame_id: i64) -> text:
        val now = rt_time_now_micros()
        val draw_us = now - frame_id
        self.frame_count = self.frame_count + 1
        self.perf.record_frame(draw_us, 0)
        "frame ok"

    me present() -> text:
        val start = rt_time_now_micros()
        val elapsed = rt_time_now_micros() - start
        self.perf.total_present_us = self.perf.total_present_us + elapsed
        "present ok"

    # ------------------------------------------------------------------
    # Perf (read-only — does NOT change behaviour)
    # ------------------------------------------------------------------

    me get_perf() -> RenderBackendPerf:
        self.perf

    me stats() -> text:
        val mode = self.session_mode
        val kind = self.backend_kind
        val sid = self.session_id
        val counters = self.perf.counters()
        "Engine2DSession mode={mode} backend={kind} sid={sid} | {counters}"

    me cleanup() -> text:
        self.active = false
        self.perf.reset_counters()
        "cleanup ok"
