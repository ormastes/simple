"""Draw IR host/GPU event-flow evidence adapter.

Also hosts the SOSIX seal-before-share primitive for the host draw-IR payload
(#39 Gap #1). A draw-IR command buffer is built (unsealed), then sealed once;
after seal it is immutable and readable, mirroring SharedDataset semantics
(src/os/kernel/ipc/shared_dataset.spl: write-gate :98, one-way seal :126-133,
read-rejects-unless-sealed :160). Used by the SIMPLE_SOSIX_GPU_LANE routing to
turn the raw payload_text into an immutable command buffer before it enters the
runtime GPU queue. Pure: no Metal, no bit-exact pixel path touched.
"""

use std.env.variables.{env_get}
use std.gpu.engine2d.backend_lane.{
    ENGINE2D_HOST_GPU_LANE_GPU,
    ENGINE2D_HOST_GPU_LANE_HOST,
    Engine2dHostGpuLaneResult,
    engine2d_host_gpu_lane_schedule
}
use std.gpu.engine2d.host_gpu_event_queue.{
    Engine2dHostGpuEvent,
    Engine2dHostGpuHandlerDecision,
    Engine2dHostGpuQueueSubmitEvidence,
    Engine2dHostGpuQueueReceiptEvidence,
    Engine2dHostGpuRuntimeQueue,
    Engine2dHostGpuRuntimeSubmitResult,
    Engine2dHostGpuRuntimeDrainResult,
    engine2d_host_gpu_event,
    engine2d_host_gpu_event_handler_decision,
    engine2d_host_gpu_event_submit,
    engine2d_host_gpu_event_receipt,
    engine2d_host_gpu_event_submit_to_runtime_payload_text,
    engine2d_host_gpu_runtime_drain
}

# ---------------------------------------------------------------------------
# SOSIX seal-before-share command buffer (#39 Gap #1)
# ---------------------------------------------------------------------------

# Immutable draw-IR command buffer. state: "building" (writable) | "sealed"
# (immutable, readable). payload_hash is computed at seal time so a sealed
# buffer carries a stable content identity for the runtime queue.
struct SealedDrawIrPayload:
    state: text
    payload_text: text
    payload_hash: i64

# djb2 content hash over the payload chars — deterministic, matches the i64
# payload_hash the runtime queue already threads (host_gpu_event_queue.spl).
fn _draw_ir_payload_hash(payload_text: text) -> i64:
    var h: i64 = 5381
    val n = payload_text.len()
    var i: i64 = 0
    while i < n:
        val c = payload_text.char_code_at(i).to_i64()
        h = ((h * 33) + c) & 0x7FFFFFFFFFFFFFFF
        i = i + 1
    h

# Start a new (writable, unsealed) command buffer.
fn draw_ir_payload_new() -> SealedDrawIrPayload:
    SealedDrawIrPayload(state: "building", payload_text: "", payload_hash: 0)

# Append to a building buffer. Post-seal writes are REJECTED (returned
# unchanged) — the seal-before-share immutability gate (shared_dataset.spl:98).
fn draw_ir_payload_write(buf: SealedDrawIrPayload, more: text) -> SealedDrawIrPayload:
    if buf.state != "building":
        return buf
    SealedDrawIrPayload(state: "building", payload_text: buf.payload_text + more, payload_hash: 0)

# One-way seal: building -> sealed, computing the content hash. A second seal is
# a no-op (idempotent, matching shared_dataset.spl:126-133).
fn draw_ir_payload_seal(buf: SealedDrawIrPayload) -> SealedDrawIrPayload:
    if buf.state != "building":
        return buf
    SealedDrawIrPayload(state: "sealed", payload_text: buf.payload_text, payload_hash: _draw_ir_payload_hash(buf.payload_text))

# Read the sealed payload. An unsealed buffer reads as "" — reads require a
# sealed dataset (shared_dataset.spl:160).
fn draw_ir_payload_read(buf: SealedDrawIrPayload) -> text:
    if buf.state != "sealed":
        return ""
    buf.payload_text

fn draw_ir_payload_is_sealed(buf: SealedDrawIrPayload) -> bool:
    buf.state == "sealed"

# Convenience: build -> write -> seal in one call (the common host-lane path).
fn engine2d_host_gpu_seal_draw_ir_payload(payload_text: text) -> SealedDrawIrPayload:
    val building = draw_ir_payload_write(draw_ir_payload_new(), payload_text)
    draw_ir_payload_seal(building)

# The SIMPLE_SOSIX_GPU_LANE flag: when set, the host draw-IR event flow seals
# the payload and routes it through the runtime GPU queue (Gap #2). Default OFF
# — the legacy evidence-only path is byte-unchanged. Idiom matches
# backend_metal.spl:194.
fn engine2d_sosix_gpu_lane_enabled() -> bool:
    (env_get("SIMPLE_SOSIX_GPU_LANE") ?? "") == "1"

struct Engine2dHostGpuDrawIrEventFlowEvidence:
    event: Engine2dHostGpuEvent
    lane_result: Engine2dHostGpuLaneResult
    decision: Engine2dHostGpuHandlerDecision
    submit: Engine2dHostGpuQueueSubmitEvidence
    receipt: Engine2dHostGpuQueueReceiptEvidence

fn _engine2d_draw_ir_requested_lane(coarse_batch: bool, mutates_host_semantics: bool, stale_target_cache: bool, unresolved_target: bool) -> text:
    if mutates_host_semantics or stale_target_cache or unresolved_target:
        return ENGINE2D_HOST_GPU_LANE_HOST
    if coarse_batch:
        return ENGINE2D_HOST_GPU_LANE_GPU
    ENGINE2D_HOST_GPU_LANE_HOST

fn engine2d_host_gpu_draw_ir_event_flow(event_id: text, operation: text, packet_bytes: i64, max_packet_bytes: i64, coarse_batch: bool, mutates_host_semantics: bool, stale_target_cache: bool, unresolved_target: bool, strict_backend_available: bool, baseline_ms: i64) -> Engine2dHostGpuDrawIrEventFlowEvidence:
    val requested_lane = _engine2d_draw_ir_requested_lane(coarse_batch, mutates_host_semantics, stale_target_cache, unresolved_target)
    val event = engine2d_host_gpu_event(event_id, requested_lane, operation, packet_bytes, max_packet_bytes, mutates_host_semantics, stale_target_cache, unresolved_target, strict_backend_available)
    val lane_result = engine2d_host_gpu_lane_schedule(ENGINE2D_HOST_GPU_LANE_HOST, requested_lane, operation, packet_bytes, max_packet_bytes, mutates_host_semantics, false, strict_backend_available, baseline_ms)
    val decision = engine2d_host_gpu_event_handler_decision(event, lane_result)
    val submit = engine2d_host_gpu_event_submit(decision, lane_result)
    val receipt = engine2d_host_gpu_event_receipt(submit, lane_result)
    Engine2dHostGpuDrawIrEventFlowEvidence(event: event, lane_result: lane_result, decision: decision, submit: submit, receipt: receipt)

fn engine2d_host_gpu_draw_ir_event_flow_summary(evidence: Engine2dHostGpuDrawIrEventFlowEvidence) -> text:
    "event={evidence.event.event_id};requested={evidence.event.requested_lane};decision={evidence.decision.target_lane};queued={evidence.submit.queued};gpu_batched={evidence.receipt.gpu_batched};reason={evidence.decision.reason}"

# ---------------------------------------------------------------------------
# SOSIX GPU lane routing (#39 Gap #2 — migrate existing GPU offload)
# ---------------------------------------------------------------------------
# When the SIMPLE_SOSIX_GPU_LANE flag is on, the host draw-IR event flow no
# longer stops at evidence: it SEALS the payload (Gap #1) and routes the sealed
# command buffer through the EXISTING runtime GPU queue
# (host_gpu_event_queue.spl submit→submit_pending→complete_pending→drain,
# COMPLETED=3) — no new queue, no backend_metal op-body change. The sealed
# bytes+hash that come back out of drain PROVE the seal-before-share buffer
# survived the queue roundtrip intact. The env flag is checked by the render-path
# caller (engine2d_sosix_gpu_lane_enabled); this function does the routing so it
# stays deterministically testable on a cpu backend (like draw_ir_runtime_queue_spec).
struct Engine2dHostGpuSosixLaneResult:
    sealed: bool
    sealed_hash: i64
    submitted: bool
    submit_status: text
    drained: i64
    drain_status: text
    drain_payload_hash: i64
    drain_payload_text: text
    completed: bool
    diagnostic: text

fn engine2d_host_gpu_sosix_lane_route(queue: Engine2dHostGpuRuntimeQueue, event_id: text, operation: text, packet_bytes: i64, max_packet_bytes: i64, coarse_batch: bool, mutates_host_semantics: bool, stale_target_cache: bool, unresolved_target: bool, strict_backend_available: bool, baseline_ms: i64, payload_text: text) -> Engine2dHostGpuSosixLaneResult:
    val sealed = engine2d_host_gpu_seal_draw_ir_payload(payload_text)
    val evidence = engine2d_host_gpu_draw_ir_event_flow(event_id, operation, packet_bytes, max_packet_bytes, coarse_batch, mutates_host_semantics, stale_target_cache, unresolved_target, strict_backend_available, baseline_ms)
    # Only the sealed read-gate can hand the payload bytes to the queue — an
    # unsealed buffer would read "" (shared_dataset.spl:160 semantics).
    val submit = engine2d_host_gpu_event_submit_to_runtime_payload_text(queue, evidence.decision, evidence.lane_result, sealed.payload_hash, draw_ir_payload_read(sealed))
    if not submit.submitted:
        # Backpressure / host-lane / runtime-unavailable ⇒ fall back to the CPU
        # mirror (never a hang). Honest status, no fabricated completion.
        return Engine2dHostGpuSosixLaneResult(sealed: draw_ir_payload_is_sealed(sealed), sealed_hash: sealed.payload_hash, submitted: false, submit_status: submit.status, drained: 0, drain_status: "not_submitted", drain_payload_hash: 0, drain_payload_text: "", completed: false, diagnostic: submit.diagnostic)
    # Drain directly after emit: the runtime drain auto-progresses submit+complete
    # in one FFI step — mirrors the proven production path
    # (draw_ir_runtime_queue.spl:120-128). An explicit submit_pending/complete_pending
    # pair before drain leaves the packet in a state the runtime drain won't take.
    val drain = engine2d_host_gpu_runtime_drain(queue, 1)
    val completed = drain.drained > 0 and drain.status == "completed"
    Engine2dHostGpuSosixLaneResult(sealed: draw_ir_payload_is_sealed(sealed), sealed_hash: sealed.payload_hash, submitted: true, submit_status: submit.status, drained: drain.drained, drain_status: drain.status, drain_payload_hash: drain.last_payload_hash, drain_payload_text: drain.last_payload_text, completed: completed, diagnostic: "sosix gpu lane sealed draw-ir routed through runtime queue to completion")

fn engine2d_host_gpu_sosix_lane_summary(result: Engine2dHostGpuSosixLaneResult) -> text:
    "sealed={result.sealed};sealed_hash={result.sealed_hash};submitted={result.submitted};submit_status={result.submit_status};drained={result.drained};drain_status={result.drain_status};completed={result.completed};diagnostic={result.diagnostic}"

export Engine2dHostGpuDrawIrEventFlowEvidence
export engine2d_host_gpu_draw_ir_event_flow
export engine2d_host_gpu_draw_ir_event_flow_summary
export SealedDrawIrPayload
export draw_ir_payload_new
export draw_ir_payload_write
export draw_ir_payload_seal
export draw_ir_payload_read
export draw_ir_payload_is_sealed
export engine2d_host_gpu_seal_draw_ir_payload
export engine2d_sosix_gpu_lane_enabled
export Engine2dHostGpuSosixLaneResult
export engine2d_host_gpu_sosix_lane_route
export engine2d_host_gpu_sosix_lane_summary
