# 2D Engine — Metal backend facade.
#
# Probes Metal strictly and exposes a RenderBackend-compatible surface. The
# current Simple-level readback path keeps a CPU mirror for deterministic parity;
# native command encoding lives behind the MetalSession facade.

use std.gc_async_mut.gpu.engine2d.backend.{RenderBackend, Engine2DExtended, Engine2DReadback, engine2d_readback, engine2d_readback_with_handle, ReadbackSource, readback_source_label}
use std.gpu.engine2d.backend_software.{SoftwareBackend}
use std.gpu.engine2d.backend_probe.{BackendProbeResult}
use std.gpu.engine2d.glyph.{glyph_height, glyph_advance, glyph_atlas_dense_values, glyph_atlas_index_for_char_code}
use std.gpu.engine2d.backend_metal_runtime_ops.{metal_buffer_download_ptr, metal_buffer_upload_ptr, metal_set_bytes_ptr, metal_u32s_from_ptr, metal_write_u32s_to_ptr, gpu_lut_pack_dense, gpu_lut_free, gpu_lut_dense_byte_len}
use std.gpu.engine2d.backend_capability.{BackendCapability, Engine2dBackendKind, backend_capability_default, OP_INDEXED_FILL, OP_GLYPH_ATLAS_BLIT, OP_DRAW_GRADIENT_RECT, OP_DRAW_ROUNDED_RECT, OP_DRAW_IMAGE}
use std.gc_async_mut.gpu.engine2d.metal_session.{MetalSession}
use std.gpu.engine2d.backend_metal_font.{MetalFontBackendState}
use std.gc_async_mut.text_layout.font_renderer.{FontRenderBatch}
use std.gc_async_mut.env.platform.{is_macos}
use std.env.variables.{env_get}
use std.gc_async_mut.io.metal_sffi.{
    metal_sffi_alloc_buffer, metal_sffi_free_buffer,
    metal_sffi_create_command_buffer, metal_sffi_destroy_command_buffer,
    metal_sffi_commit_command_buffer,
    metal_sffi_wait_completed, metal_sffi_dispatch_compute,
    metal_sffi_create_compute_encoder, metal_sffi_end_compute_encoder,
    metal_sffi_destroy_compute_encoder,
    metal_sffi_set_buffer, metal_sffi_set_bytes,
    metal_sffi_quarantine_submission, metal_sffi_reap_submission_quarantine,
    metal_sffi_release_uncommitted_submission
}

extern fn rt_alloc(size: i64) -> i64
extern fn rt_free(ptr: i64) -> i64
extern fn rt_ptr_write_i32(ptr: i64, offset: i64, value: i64) -> i64
extern fn rt_ptr_read_i64(ptr: i64, offset: i64) -> i64

# SFFI sibling-cdylib bridge for the bulk pixel-upload path (SIMPLE_BULK_UPLOAD
# =cdylib). These externs ARE registered on the deployed self-hosted binary
# (verified 2026-07-06); the one-call upload extern rt_write_u32s_to_raw is NOT,
# which is why draw_image degrades to one FFI round-trip per pixel by default.
extern fn spl_dlopen(path: text) -> i64
extern fn spl_dlsym(handle: i64, name: text) -> i64
extern fn spl_wffi_call_i64(fptr: i64, args: [i64], nargs: i64) -> i64

# Lazy process-global cache for the spl_gpu_transfer cdylib. -2 = not yet
# attempted, -1 = attempted and failed, >= 0 = loaded dlopen handle. The
# interpreter is single-threaded during a frame paint, so this state is
# race-free. (Kept inline in this module — the deployed binary only discovers
# stdlib modules baked in at its build time, so a fresh sibling module would be
# invisible; a new file inside an already-known module is fine.)
var _bulk_handle: i64 = -2
var _bulk_begin: i64 = 0
var _bulk_write8: i64 = 0
var _bulk_write1: i64 = 0

fn _bulk_candidate_paths() -> [text]:
    var out: [text] = []
    val override = env_get("SIMPLE_SPL_GPU_TRANSFER_PATH") ?? ""
    if override != "":
        out.push(override)
    out.push("build/sffi/libspl_gpu_transfer.dylib")
    out.push("build/sffi/libspl_gpu_transfer.so")
    out.push("build/sffi/libspl_gpu_transfer.dll")
    out

fn _bulk_ensure_loaded() -> bool:
    if _bulk_handle == -1:
        return false
    if _bulk_handle >= 0:
        return true
    var h: i64 = 0
    val paths = _bulk_candidate_paths()
    var pi = 0
    while pi < paths.len() and h == 0:
        h = spl_dlopen(paths[pi])
        pi = pi + 1
    if h == 0:
        _bulk_handle = -1
        return false
    val fb = spl_dlsym(h, "spl_gpu_stage_begin")
    val fw8 = spl_dlsym(h, "spl_gpu_stage_write8")
    val fw1 = spl_dlsym(h, "spl_gpu_stage_write1")
    if fb == 0 or fw8 == 0 or fw1 == 0:
        _bulk_handle = -1
        return false
    _bulk_handle = h
    _bulk_begin = fb
    _bulk_write8 = fw8
    _bulk_write1 = fw1
    true

# Copy `count` u32 pixels from `pixels` into host byte buffer `host` (little-
# endian, pixel i at host+i*4) via the spl_gpu_transfer cdylib, 16 pixels per
# FFI call. Byte layout is identical to the per-pixel metal_host_write_i32 loop
# (a packed i64 carries two pixels as lo | (hi << 32), stored little-endian), so
# the result is bit-exact. Returns false if the cdylib is unavailable — the
# caller raises a loud error rather than silently falling back per-pixel.
fn bulk_upload_u32s(host: i64, pixels: [u32], count: i64) -> bool:
    if not _bulk_ensure_loaded():
        return false
    spl_wffi_call_i64(_bulk_begin, [host], 1)
    val n = count.to_i32()
    val n16 = (n / 16) * 16
    var j = 0
    while j < n16:
        val a = pixels[j].to_i64() | (pixels[j + 1].to_i64() << 32)
        val b = pixels[j + 2].to_i64() | (pixels[j + 3].to_i64() << 32)
        val c = pixels[j + 4].to_i64() | (pixels[j + 5].to_i64() << 32)
        val d = pixels[j + 6].to_i64() | (pixels[j + 7].to_i64() << 32)
        val e = pixels[j + 8].to_i64() | (pixels[j + 9].to_i64() << 32)
        val f = pixels[j + 10].to_i64() | (pixels[j + 11].to_i64() << 32)
        val g = pixels[j + 12].to_i64() | (pixels[j + 13].to_i64() << 32)
        val hh = pixels[j + 14].to_i64() | (pixels[j + 15].to_i64() << 32)
        spl_wffi_call_i64(_bulk_write8, [a, b, c, d, e, f, g, hh], 8)
        j = j + 16
    while j < n:
        if j + 1 < n:
            val v = pixels[j].to_i64() | (pixels[j + 1].to_i64() << 32)
            spl_wffi_call_i64(_bulk_write1, [(j * 4).to_i64(), v], 2)
        else:
            # Lone trailing pixel (odd total_pixels): spl_gpu_stage_write1
            # always performs an 8-byte store, which would write 4 bytes past
            # the end of a host buffer sized exactly total_pixels*4 bytes.
            # Use the existing 4-byte-safe path for this final pixel instead.
            metal_host_write_i32(host, j * 4, pixels[j].to_i64())
        j = j + 2
    true

# High-resolution (antialiased) text uses the VGA 8x16 glyph provider — the same
# glyph source the shared font rasterizer uses — as a coverage field that is
# bilinearly upsampled to the target pixel size (smooth glyph edges), instead of
# the integer-scaled 5x7 bitmap that draw_text emits (blocky at large sizes).
extern fn rt_gui_get_glyph_8x16(ch: i32) -> [u8]

# 0.0 when the source glyph bit at (sx, sy) is clear, 1.0 when set.
fn _hires_glyph_bit(rows: [u8], sx: i32, sy: i32) -> f64:
    if sx < 0 or sx > 7 or sy < 0 or sy > 15:
        return 0.0
    val bits = rows[sy] as i32
    val mask = 0x80 >> sx
    if (bits & mask) != 0:
        return 1.0
    0.0

# Bilinear coverage (0..256) of the 8x16 glyph sampled at destination pixel
# (dx, dy) inside a cell_w x cell_h target cell. Bilinear interpolation of the
# binary coverage field yields smooth, non-blocky edges when upscaled.
fn _hires_glyph_coverage(rows: [u8], dx: i32, dy: i32, cell_w: i32, cell_h: i32) -> i32:
    if rows.len() < 16:
        return 0
    var fx = ((dx.to_f64() + 0.5) / cell_w.to_f64()) * 8.0 - 0.5
    var fy = ((dy.to_f64() + 0.5) / cell_h.to_f64()) * 16.0 - 0.5
    if fx < 0.0:
        fx = 0.0
    if fy < 0.0:
        fy = 0.0
    if fx > 7.0:
        fx = 7.0
    if fy > 15.0:
        fy = 15.0
    val x0 = fx.to_i32()
    val y0 = fy.to_i32()
    var x1 = x0 + 1
    var y1 = y0 + 1
    if x1 > 7:
        x1 = 7
    if y1 > 15:
        y1 = 15
    val tx = fx - x0.to_f64()
    val ty = fy - y0.to_f64()
    val p00 = _hires_glyph_bit(rows, x0, y0)
    val p10 = _hires_glyph_bit(rows, x1, y0)
    val p01 = _hires_glyph_bit(rows, x0, y1)
    val p11 = _hires_glyph_bit(rows, x1, y1)
    val top = p00 * (1.0 - tx) + p10 * tx
    val bot = p01 * (1.0 - tx) + p11 * tx
    val cov = top * (1.0 - ty) + bot * ty
    var out = (cov * 256.0).to_i32()
    if out < 0:
        out = 0
    if out > 256:
        out = 256
    out

# fg over bg composite for one 8-bit channel, cov in 0..256.
fn _hires_blend_channel(fg: i32, bg: i32, cov: i32) -> i32:
    (fg * cov + bg * (256 - cov)) / 256

fn metal_host_alloc(size: i64) -> i64:
    rt_alloc(size)

fn metal_host_free(ptr: i64) -> i64:
    rt_free(ptr)

fn metal_host_write_i32(ptr: i64, offset: i64, value: i64) -> i64:
    rt_ptr_write_i32(ptr, offset, value)

fn metal_host_read_i64(ptr: i64, offset: i64) -> i64:
    rt_ptr_read_i64(ptr, offset)

fn _metal_env_flag(name: text) -> bool:
    (env_get(name) ?? "") == "1"

enum MetalErrorKind:
    NotAvailable
    DeviceLost
    ShaderCompile
    NoDevice
    PipelineCreate
    AllocFailed
    Other
    None

fn metal_classify_error(err: text) -> MetalErrorKind:
    if err.contains("not available") or err.contains("SFFI not available"):
        return MetalErrorKind.NotAvailable
    if err.contains("device lost") or err.contains("device creation failed"):
        return MetalErrorKind.DeviceLost
    if err.contains("shader") or err.contains("compilation"):
        return MetalErrorKind.ShaderCompile
    if err.contains("No Metal") or err.contains("no device") or err.contains("no devices"):
        return MetalErrorKind.NoDevice
    if err.contains("pipeline"):
        return MetalErrorKind.PipelineCreate
    if err.contains("alloc") or err.contains("framebuffer allocation") or err.contains("mirror"):
        return MetalErrorKind.AllocFailed
    if err.len() == 0:
        return MetalErrorKind.None
    MetalErrorKind.Other

fn _metal_status_message(code: i64) -> text:
    if code == 1:
        return "Metal SFFI not available"
    if code == 2:
        return "Metal runtime init failed"
    if code == 3:
        return "No Metal devices found"
    if code == 4:
        return "Metal device creation failed"
    if code == 5:
        return "Metal command queue creation failed"
    if code == 6:
        return "Metal shader compilation failed"
    if code == 7:
        return "Metal compute pipeline creation failed"
    "Metal initialization failed"

fn _metal_i64(v: i32) -> i64:
    v as i64

fn _metal_i32_to_u8(v: i32) -> u8:
    v as u8

fn _metal_pack_i32_le(mut buf: [u8], offset: i32, v: i32) -> i32:
    buf[offset] = _metal_i32_to_u8(v & 0xFF)
    buf[offset + 1] = _metal_i32_to_u8((v >> 8) & 0xFF)
    buf[offset + 2] = _metal_i32_to_u8((v >> 16) & 0xFF)
    buf[offset + 3] = _metal_i32_to_u8((v >> 24) & 0xFF)
    offset + 4

fn _metal_pack_u32_le(mut buf: [u8], offset: i32, v: u32) -> i32:
    _metal_pack_i32_le(buf, offset, v as i32)

fn _metal_pack_clear_params(color: u32, fb_w: i32, fb_h: i32) -> [u8]:
    var buf: [u8] = [0u8; 12]
    var off = 0
    off = _metal_pack_u32_le(buf, off, color)
    off = _metal_pack_i32_le(buf, off, fb_w)
    off = _metal_pack_i32_le(buf, off, fb_h)
    buf

fn _metal_pack_rect_params(x: i32, y: i32, w: i32, h: i32, color: u32, fb_w: i32, fb_h: i32) -> [u8]:
    var buf: [u8] = [0u8; 28]
    var off = 0
    off = _metal_pack_i32_le(buf, off, x)
    off = _metal_pack_i32_le(buf, off, y)
    off = _metal_pack_i32_le(buf, off, w)
    off = _metal_pack_i32_le(buf, off, h)
    off = _metal_pack_u32_le(buf, off, color)
    off = _metal_pack_i32_le(buf, off, fb_w)
    off = _metal_pack_i32_le(buf, off, fb_h)
    buf

fn probe_metal() -> BackendProbeResult:
    if not is_macos():
        var r = BackendProbeResult.unavailable("metal", "Metal requires macOS")
        r.api_name = "metal"
        r.feature_gate = "macos"
        r.shader_format = "msl"
        return r
    var session = MetalSession.create("legacy_no_session")
    if session.init():
        session.release()
        var ok = BackendProbeResult.success("metal", "Metal initialized")
        ok.api_name = "metal"
        ok.feature_gate = "metal_runtime"
        ok.shader_format = "msl"
        return ok
    val status = session.error_code()
    var fail = BackendProbeResult.failed("metal", _metal_status_message(status))
    fail.api_name = "metal"
    fail.feature_gate = "metal_runtime"
    fail.shader_format = "msl"
    fail

# GPU-dict pilot (design §3.4 loud-fail): a palette this large is refused —
# indexed_fill falls through to the CPU-lane mirror instead of silently
# truncating or wrapping the LUT. 65536 entries is far beyond any real
# palette use (8-bit index space tops out at 256) and keeps the device
# buffer bounded.
val GPU_LUT_MAX_ENTRIES: i32 = 65536

class MetalBackend:
    mirror: SoftwareBackend
    session: MetalSession
    command_queue: i64
    d_framebuffer: i64
    w: i32
    h: i32
    clip_x: i32
    clip_y: i32
    clip_w: i32
    clip_h: i32
    clip_enabled: bool
    dirty: bool
    initialized: bool
    gpu_frame_complete: bool
    pending_composite_command: i64
    pending_composite_encoder: i64
    pending_composite_source: i64
    last_probe: BackendProbeResult
    last_error: text
    lut_buffer: i64     # device buffer handle for the uploaded palette GpuLut
    lut_version: i64    # caller-supplied version of the currently-uploaded LUT; -1 = none
    lut_count: i32      # entry count of the currently-uploaded LUT (size-change detection)
    glyph_lut_buffer: i64  # device buffer handle for the glyph atlas GpuLut (design W4);
                           # uploaded once at init — the 5x7 font table never changes, so
                           # unlike lut_buffer/lut_version above it carries no per-call
                           # version/count (init-time upload IS the invalidation contract)
    font: MetalFontBackendState
    # Appended to preserve the native field offsets of the existing backend ABI.
    gpu_only: bool

    static fn create() -> MetalBackend:
        val backend = make_metal_backend()
        backend

fn make_metal_backend() -> MetalBackend:
    val mirror = SoftwareBackend.create()
    val session = MetalSession.create("legacy_no_session")
    val probe = BackendProbeResult.unavailable("metal", "not probed")
    val font = MetalFontBackendState.create()
    val backend = MetalBackend(
        mirror: mirror,
        session: session,
        command_queue: 0,
        d_framebuffer: 0,
        w: 0,
        h: 0,
        clip_x: 0,
        clip_y: 0,
        clip_w: 0,
        clip_h: 0,
        clip_enabled: false,
        gpu_only: false,
        dirty: false,
        initialized: false,
        gpu_frame_complete: false,
        pending_composite_command: 0,
        pending_composite_encoder: 0,
        pending_composite_source: 0,
        last_probe: probe,
        last_error: "",
        lut_buffer: 0,
        lut_version: -1,
        lut_count: 0,
        glyph_lut_buffer: 0,
        font: font
    )
    backend

impl RenderBackend for MetalBackend:
    fn name() -> text:
        "metal"

    me init(width: i32, height: i32) -> bool:
        if not is_macos():
            self.last_probe = probe_metal()
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal requires macOS"
            return false
        if not metal_sffi_reap_submission_quarantine():
            self.last_error = "deferred Metal submission cleanup is still pending"
            return false
        self.font.release()
        val session_initialized = self.session.init()
        if not session_initialized:
            val status = self.session.error_code()
            val msg = _metal_status_message(status)
            self.last_probe = BackendProbeResult.failed("metal", msg)
            self.last_probe.api_name = "metal"
            self.last_probe.feature_gate = "metal_runtime"
            self.last_probe.shader_format = "msl"
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = msg
            return false
        val total = width * height
        val bytes = _metal_i64(total) * 4
        self.d_framebuffer = metal_sffi_alloc_buffer(self.session.device, bytes)
        if self.d_framebuffer == 0:
            self.session.release()
            self.last_probe = BackendProbeResult.failed("metal", "Metal framebuffer allocation failed")
            self.last_probe.api_name = "metal"
            self.last_probe.feature_gate = "metal_runtime"
            self.last_probe.shader_format = "msl"
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal framebuffer allocation failed"
            return false
        if not self.mirror.init(width, height):
            metal_sffi_free_buffer(self.d_framebuffer)
            self.d_framebuffer = 0
            self.session.release()
            self.last_probe = BackendProbeResult.failed("metal", "Metal mirror surface allocation failed")
            self.last_probe.api_name = "metal"
            self.last_probe.feature_gate = "metal_runtime"
            self.last_probe.shader_format = "msl"
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal mirror surface allocation failed"
            return false
        self.command_queue = self.session.command_queue
        self.w = width
        self.h = height
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = width
        self.clip_h = height
        self.clip_enabled = false
        self.gpu_only = false
        self.dirty = false
        self.initialized = true
        self.gpu_frame_complete = false
        self.mirror.clear(0x00000000u32)
        if not self._dispatch_metal_clear(0x00000000u32):
            self.last_error = "Metal transparent surface initialization failed"
            self.shutdown()
            return false
        self.gpu_frame_complete = true
        self.dirty = true
        self.last_error = ""
        self.last_probe = BackendProbeResult.success("metal", "Metal initialized")
        self.last_probe.api_name = "metal"
        self.last_probe.feature_gate = "metal_runtime"
        self.last_probe.shader_format = "msl"
        # GPU-dict use case #2 (design W4): upload the glyph atlas exactly
        # once per backend lifetime — the 5x7 font table is a compile-time
        # constant, so init-time upload IS the version/invalidation contract
        # (design §3.3). A compile/upload failure here must not fail the rest
        # of Metal init (loud fall-through, §3.4): draw_text() checks
        # glyph_lut_buffer directly and falls through to the CPU-lane mirror
        # when it is 0.
        if self.session.pipe_glyph_atlas_blit != 0:
            self.glyph_lut_buffer = self._upload_glyph_atlas()
        self.initialized

    me init_with_session(width: i32, height: i32, session: MetalSession) -> bool:
        """Create a transparent surface on an already-initialized shared session."""
        if width <= 0 or height <= 0:
            self.last_error = "invalid Metal framebuffer dimensions"
            return false
        if self.initialized or self.d_framebuffer != 0 or self.pending_composite_command != 0:
            self.last_error = "Metal backend surface is already initialized"
            return false
        if not session.is_valid():
            self.last_error = "Metal shared session is not initialized"
            return false
        if not metal_sffi_reap_submission_quarantine():
            self.last_error = "deferred Metal submission cleanup is still pending"
            return false

        self.session = session.retain()
        self.command_queue = self.session.command_queue
        self.w = width
        self.h = height
        self.gpu_only = false
        val bytes = width.to_i64() * height.to_i64() * 4
        self.d_framebuffer = metal_sffi_alloc_buffer(self.session.device, bytes)
        if self.d_framebuffer == 0:
            self.session.release()
            self.command_queue = 0
            self.w = 0
            self.h = 0
            self.last_error = "Metal framebuffer allocation failed"
            return false
        if not self.mirror.init(width, height):
            metal_sffi_free_buffer(self.d_framebuffer)
            self.d_framebuffer = 0
            self.session.release()
            self.command_queue = 0
            self.w = 0
            self.h = 0
            self.last_error = "Metal mirror surface allocation failed"
            return false

        self.initialized = true
        self.dirty = false
        self.gpu_frame_complete = false
        self.mirror.clear(0x00000000u32)
        val cleared = self._dispatch_metal_clear(0x00000000u32)
        if not cleared:
            self.last_error = "Metal transparent surface initialization failed"
            self.shutdown()
            return false
        self.gpu_frame_complete = true
        self.dirty = true
        self.last_error = ""
        self.last_probe = BackendProbeResult.success("metal", "Metal shared surface initialized")
        self.last_probe.api_name = "metal"
        self.last_probe.feature_gate = "metal_runtime"
        self.last_probe.shader_format = "msl"
        if self.session.pipe_glyph_atlas_blit != 0:
            self.glyph_lut_buffer = self._upload_glyph_atlas()
        true

    me shutdown():
        if self.pending_composite_command != 0:
            if not metal_sffi_wait_completed(self.pending_composite_command):
                if not metal_sffi_quarantine_submission(
                    self.pending_composite_command,
                    self.pending_composite_encoder,
                    self.pending_composite_source,
                    self.d_framebuffer
                ):
                    return
                self.pending_composite_command = 0
                self.pending_composite_encoder = 0
                self.pending_composite_source = 0
                self.d_framebuffer = 0
                # A terminal Metal error is reclaimable immediately; a truly
                # unknown registry handle remains owned by the global facade
                # and blocks the next surface initialization until proven safe.
                metal_sffi_reap_submission_quarantine()
            else:
                if self.pending_composite_source != 0:
                    metal_sffi_free_buffer(self.pending_composite_source)
                if self.pending_composite_encoder != 0:
                    metal_sffi_destroy_compute_encoder(self.pending_composite_encoder)
                metal_sffi_destroy_command_buffer(self.pending_composite_command)
                self.pending_composite_command = 0
                self.pending_composite_encoder = 0
                self.pending_composite_source = 0
        self.mirror.shutdown()
        self.font.release()
        if self.d_framebuffer != 0:
            metal_sffi_free_buffer(self.d_framebuffer)
            self.d_framebuffer = 0
        if self.lut_buffer != 0:
            metal_sffi_free_buffer(self.lut_buffer)
            self.lut_buffer = 0
        self.lut_version = -1
        self.lut_count = 0
        if self.glyph_lut_buffer != 0:
            metal_sffi_free_buffer(self.glyph_lut_buffer)
            self.glyph_lut_buffer = 0
        self.session.release()
        self.command_queue = 0
        self.w = 0
        self.h = 0
        self.gpu_only = false
        self.dirty = false
        self.initialized = false
        self.gpu_frame_complete = false

    me clear(color: u32):
        if not self.gpu_only:
            self.mirror.clear(color)
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_clear != 0:
            self.gpu_frame_complete = self._dispatch_metal_clear(color)
            self.dirty = true
        else:
            self.gpu_frame_complete = false
            if not self.initialized:
                self.last_error = "MetalBackend not initialized"
    me draw_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        if not self.gpu_only:
            self.mirror.draw_rect(x, y, w, h, color)
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_rect_outline != 0:
            self.gpu_frame_complete = self.gpu_frame_complete and self._dispatch_metal_rect_outline(x, y, w, h, color)
            self.dirty = true
        else:
            self.gpu_frame_complete = false
    me draw_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32):
        if not self.gpu_only:
            self.mirror.draw_rect_filled(x, y, w, h, color)
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_rect_filled != 0:
            self.gpu_frame_complete = self.gpu_frame_complete and self._dispatch_metal_rect_filled(x, y, w, h, color)
            self.dirty = true
        else:
            self.gpu_frame_complete = false
    me draw_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32):
        if not self.gpu_only:
            self.mirror.draw_line(x1, y1, x2, y2, color, thickness)
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_line != 0:
            self.gpu_frame_complete = self.gpu_frame_complete and self._dispatch_metal_line(x1, y1, x2, y2, color, thickness)
            self.dirty = true
        else:
            self.gpu_frame_complete = false
    me draw_circle(cx: i32, cy: i32, r: i32, color: u32):
        if not self.gpu_only:
            self.mirror.draw_circle(cx, cy, r, color)
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_circle != 0:
            self.gpu_frame_complete = self.gpu_frame_complete and self._dispatch_metal_circle(cx, cy, r, color, false)
            self.dirty = true
        else:
            self.gpu_frame_complete = false
    me draw_circle_filled(cx: i32, cy: i32, r: i32, color: u32):
        if not self.gpu_only:
            self.mirror.draw_circle_filled(cx, cy, r, color)
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_circle_filled != 0:
            self.gpu_frame_complete = self.gpu_frame_complete and self._dispatch_metal_circle(cx, cy, r, color, true)
            self.dirty = true
        else:
            self.gpu_frame_complete = false
    me draw_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32):
        if not self.gpu_only:
            self.mirror.draw_rounded_rect(x, y, w, h, radius, color)
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_rounded_rect != 0:
            self.gpu_frame_complete = self.gpu_frame_complete and self._dispatch_metal_rounded_rect(x, y, w, h, radius, color)
            self.dirty = true
        else:
            self.gpu_frame_complete = false
    me draw_triangle_filled(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32):
        if not self.gpu_only:
            self.mirror.draw_triangle_filled(x1, y1, x2, y2, x3, y3, color)
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_triangle != 0:
            self.gpu_frame_complete = self.gpu_frame_complete and self._dispatch_metal_triangle(x1, y1, x2, y2, x3, y3, color)
            self.dirty = true
        else:
            self.gpu_frame_complete = false
    me draw_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32):
        if not self.gpu_only:
            self.mirror.draw_gradient_rect(x, y, w, h, top_color, bottom_color)
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_gradient != 0:
            self.gpu_frame_complete = self.gpu_frame_complete and self._dispatch_metal_gradient_rect(x, y, w, h, top_color, bottom_color)
            self.dirty = true
        else:
            self.gpu_frame_complete = false
    me draw_text(x: i32, y: i32, text_val: text, color: u32, font_size: i32):
        if not self.gpu_only:
            self.mirror.draw_text(x, y, text_val, color, font_size)
        # GPU-dict use case #2 (design W4): one kernel_glyph_atlas_blit
        # dispatch for the whole string, gated on the atlas pipeline AND the
        # uploaded buffer — no other fallback path. A missing pipeline/buffer
        # is the normal D2 CPU-lane fallthrough (design §3.4): outside explicit
        # GPU-only mode the mirror already holds the correct pixels, so
        # read_pixels() falls back to it. (Deliberately NOT gated on
        # pipe_rect_filled — the former
        # per-lit-glyph-pixel rect_filled dispatch path is retired.)
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_glyph_atlas_blit != 0 and self.glyph_lut_buffer != 0:
            self.gpu_frame_complete = self.gpu_frame_complete and self._dispatch_metal_glyph_atlas_blit(x, y, text_val, color, font_size)
            self.dirty = true
        else:
            self.gpu_frame_complete = false
    me draw_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        if not self.gpu_only:
            self.mirror.draw_image(x, y, w, h, pixels)
        if self.initialized and self.d_framebuffer != 0 and self.session.pipe_blit != 0:
            self.gpu_frame_complete = self.gpu_frame_complete and self._dispatch_metal_image(x, y, w, h, pixels)
            self.dirty = true
        else:
            self.gpu_frame_complete = false
    me draw_image_blend(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        if self.gpu_only:
            # The emulation helper reads the destination before blending. A
            # GPU-only destination has no mirror readback contract, so refuse
            # the unsupported operation instead of indexing an empty buffer.
            self.gpu_frame_complete = false
            return
        emu_draw_image_blend(self, x, y, w, h, pixels)
    me set_clip(x: i32, y: i32, w: i32, h: i32):
        if not self.gpu_only:
            self.mirror.set_clip(x, y, w, h)
        self.clip_x = x
        self.clip_y = y
        self.clip_w = w
        self.clip_h = h
        self.clip_enabled = true
    me clear_clip():
        if not self.gpu_only:
            self.mirror.clear_clip()
        self.clip_x = 0
        self.clip_y = 0
        self.clip_w = self.w
        self.clip_h = self.h
        self.clip_enabled = false
    me set_mask(mask_pixels: [u8], w: i32, h: i32):
        if not self.gpu_only:
            self.mirror.set_mask(mask_pixels, w, h)
        self.gpu_frame_complete = false
    me clear_mask():
        if not self.gpu_only:
            self.mirror.clear_mask()
        self.gpu_frame_complete = false
    me present():
        if not self.gpu_only:
            self.mirror.present()
    fn read_pixels() -> [u32]:
        # Checksum-free: read_pixels_with_source() runs an O(n) interpreted
        # checksum loop (engine2d_readback_with_handle) — ~8.8s at 1024x768 and
        # ~80s at Retina physical. Pixel-only callers skip it; evidence rows
        # that need the checksum call read_pixels_with_source() explicitly.
        if self.gpu_frame_complete:
            val gpu_pixels = self.read_pixels_gpu_only()
            if gpu_pixels.len() == (self.w * self.h):
                return gpu_pixels
        if self.gpu_only:
            var empty: [u32] = []
            return empty
        self.mirror.read_pixels()

    fn read_pixels_with_source() -> Engine2DReadback:
        if self.gpu_frame_complete:
            val gpu_pixels = self.read_pixels_gpu_only()
            if gpu_pixels.len() == (self.w * self.h):
                val source = readback_source_label(ReadbackSource.DeviceReadback)
                val readback = engine2d_readback_with_handle(gpu_pixels, source, self.d_framebuffer)
                return readback
        if self.gpu_only:
            var empty: [u32] = []
            val source = readback_source_label(ReadbackSource.DeviceReadback)
            return engine2d_readback_with_handle(empty, source, self.d_framebuffer)
        val mirror_pixels = self.mirror.read_pixels()
        val source = readback_source_label(ReadbackSource.CpuMirror)
        val readback = engine2d_readback(mirror_pixels, source)
        readback
    fn width() -> i32:
        if self.w > 0:
            return self.w
        self.mirror.width()
    fn height() -> i32:
        if self.h > 0:
            return self.h
        self.mirror.height()

impl MetalBackend:
    fn device_framebuffer_handle() -> i64:
        if self.initialized and self.d_framebuffer != 0:
            return self.d_framebuffer
        0

    me draw_image_blend_checked(x: i32, y: i32, w: i32, h: i32, pixels: [u32], opacity_milli: i32) -> bool:
        val right = x.to_i64() + w.to_i64()
        val bottom = y.to_i64() + h.to_i64()
        val exact_pixels = w.to_i64() * h.to_i64()
        if (not self.initialized or not self.gpu_frame_complete or
            self.d_framebuffer == 0 or self.session.pipe_image_composite == 0):
            self.gpu_frame_complete = false
            return false
        if (x < 0 or y < 0 or w <= 0 or h <= 0 or right > self.w.to_i64() or
            bottom > self.h.to_i64() or pixels.len() != exact_pixels or
            opacity_milli <= 0 or opacity_milli > 1000):
            self.gpu_frame_complete = false
            return false
        val completed = self._dispatch_metal_image_composite(x, y, w, h, pixels, opacity_milli)
        self.gpu_frame_complete = completed
        self.dirty = self.dirty or completed
        completed
    me invalidate_font_atlas():
        self.font.invalidate()

    me draw_font_batch(origin_x: i32, origin_y: i32, batch: FontRenderBatch) -> i64:
        if not self.initialized or not self.gpu_frame_complete:
            return 0
        val done = self.font.draw_font_batch(self.session, self.d_framebuffer, self.mirror,
            not self.gpu_only, self.w, self.h, origin_x, origin_y, batch)
        if done > 0:
            self.dirty = true
        done

    # True when the device framebuffer is the sole source of truth. The mirror
    # retains full dimensions for ABI/fallback stability but is not rasterized.
    fn _gpu_only_mode() -> bool:
        self.initialized and self.d_framebuffer != 0 and self.gpu_only

    # Honest self-description (D3/backend_capability.spl): an op is only
    # advertised as accelerated when the device is present AND its compute
    # pipeline actually compiled (and, for glyph_atlas_blit, its persistent
    # buffer actually uploaded). A backend that lists an op in
    # accelerated_ops while its bind/dispatch fails at runtime would be a
    # honesty violation (design §3.4) — see indexed_fill()/draw_text() below,
    # which flip gpu_frame_complete false rather than claim success on failure.
    fn capability() -> BackendCapability:
        if self.initialized:
            var ops: [text] = []
            if self.session.pipe_indexed_fill != 0:
                ops.push(OP_INDEXED_FILL)
            if self.session.pipe_glyph_atlas_blit != 0 and self.glyph_lut_buffer != 0:
                ops.push(OP_GLYPH_ATLAS_BLIT)
            # W3: draw_gradient_rect is a plain kernel (kernel_draw_gradient_rect,
            # no GpuLut) — pipe_gradient is created alongside the other core
            # pipelines in MetalSession.init() (metal_session.spl), so this is
            # a genuine "device present and this pipeline actually compiled"
            # signal, not a bookkeeping-only add.
            if self.session.pipe_gradient != 0:
                ops.push(OP_DRAW_GRADIENT_RECT)
            # Rounded-rect FILL parity fix (2026-07-07): kernel_draw_rounded_rect
            # is likewise a plain kernel, no GpuLut — same "pipeline actually
            # compiled" honesty signal as gradient above.
            if self.session.pipe_rounded_rect != 0:
                ops.push(OP_DRAW_ROUNDED_RECT)
            # draw_image parity-coverage close (2026-07-07 sweep): kernel_blit_image
            # is likewise a plain kernel (raw clipped copy, no GpuLut) — same
            # "pipeline actually compiled" honesty signal as gradient/rounded_rect
            # above. draw_image() (above) already gates its GPU dispatch on this
            # same self.session.pipe_blit != 0 check.
            if self.session.pipe_blit != 0:
                ops.push(OP_DRAW_IMAGE)
            if ops.len() > 0:
                return BackendCapability(kind: Engine2dBackendKind.RealGpu, device_present: true, accelerated_ops: ops)
        backend_capability_default()

    # GPU-dict pilot (design §3/§4): buffer-backed palette LUT `indexed_fill`.
    # `idx` is a row-major w*h byte buffer of palette indices; `palette` is the
    # ARGB color table; `palette_version` is the caller's version tag for the
    # LUT upload/invalidation contract (design §3.3) — re-upload only happens
    # when the version (or entry count) changes, never per-primitive/per-frame.
    me indexed_fill(x: i32, y: i32, w: i32, h: i32, idx: [u8], palette: [u32], palette_version: i64):
        # CPU-lane mirror: retain the SoftwareBackend oracle outside explicit
        # GPU-only mode so the mirror remains a valid fallback/readback source.
        if not self.gpu_only:
            self.mirror.indexed_fill(x, y, w, h, idx, palette)
        if w <= 0 or h <= 0:
            return
        if not self.initialized or self.d_framebuffer == 0 or self.session.pipe_indexed_fill == 0:
            # Loud fall-through (design §3.4): no device/pipeline — capability()
            # already reports indexed_fill as unaccelerated, so this is the
            # normal D2 CPU-lane path, not a special case. Do NOT flip
            # gpu_frame_complete for the "gpu-only mode, clip is a no-op" style
            # exception below — indexed_fill has no such prior exception, so a
            # miss here means normal mode falls back to the mirror; explicit
            # GPU-only mode fails closed with an empty readback.
            self.gpu_frame_complete = false
            return
        val count = palette.len().to_i32()
        if count > GPU_LUT_MAX_ENTRIES:
            # Loud fall-through: an oversized LUT is refused outright rather
            # than silently truncated/wrapped (design §3.4). In normal mode the
            # mirror already has the correct pixels; GPU-only mode fails closed.
            # This print makes the refusal observable instead of a silent
            # wrong-pixel GPU write.
            print "backend_metal: indexed_fill palette has {count} entries > GPU_LUT_MAX_ENTRIES={GPU_LUT_MAX_ENTRIES}; refusing GPU dispatch (CPU-lane result stands)"
            self.gpu_frame_complete = false
            return
        if not self._ensure_lut_uploaded(palette, palette_version):
            self.gpu_frame_complete = false
            return
        val ok = self._dispatch_metal_indexed_fill(x, y, w, h, idx)
        self.gpu_frame_complete = self.gpu_frame_complete and ok
        self.dirty = true

    # Upload/invalidation contract (design §3.3): re-upload only when the
    # caller's version (or the palette's entry count) differs from what is
    # currently bound. Persistent-session idiom — never rebuilds/re-uploads
    # per primitive or per frame when unchanged.
    me _ensure_lut_uploaded(palette: [u32], version: i64) -> bool:
        val count = palette.len().to_i32()
        if self.lut_buffer != 0 and self.lut_version == version and self.lut_count == count:
            return true
        val byte_len = gpu_lut_dense_byte_len(count)
        val host = gpu_lut_pack_dense(palette)
        if host == 0:
            return false
        if self.lut_buffer != 0:
            metal_sffi_free_buffer(self.lut_buffer)
            self.lut_buffer = 0
        val dev_buf = metal_sffi_alloc_buffer(self.session.device, byte_len)
        if dev_buf == 0:
            gpu_lut_free(host)
            return false
        val uploaded = metal_buffer_upload_ptr(dev_buf, host, byte_len)
        gpu_lut_free(host)
        if uploaded == 0:
            metal_sffi_free_buffer(dev_buf)
            return false
        self.lut_buffer = dev_buf
        self.lut_version = version
        self.lut_count = count
        true

    # GPU-dict use case #2 (design W4): upload the glyph atlas dense GpuLut
    # exactly once (called from init() only, guarded by pipe_glyph_atlas_blit
    # != 0). Reuses gpu_lut_pack_dense unchanged — same dense kind=0/
    # value_stride=1 layout as the indexed_fill palette LUT, just with row-bit
    # values keyed by glyph_index*glyph_height()+row (glyph.spl
    # glyph_atlas_dense_values()) instead of ARGB colors keyed by palette index.
    me _upload_glyph_atlas() -> i64:
        val values = glyph_atlas_dense_values()
        val byte_len = gpu_lut_dense_byte_len(values.len().to_i32())
        val host = gpu_lut_pack_dense(values)
        if host == 0:
            return 0
        val dev_buf = metal_sffi_alloc_buffer(self.session.device, byte_len)
        if dev_buf == 0:
            gpu_lut_free(host)
            return 0
        val uploaded = metal_buffer_upload_ptr(dev_buf, host, byte_len)
        gpu_lut_free(host)
        if uploaded == 0:
            metal_sffi_free_buffer(dev_buf)
            return 0
        dev_buf

    # Uploads the per-call index framebuffer (buffer 2) and dispatches
    # kernel_indexed_fill with the persistent LUT bound as buffer 3.
    me _dispatch_metal_indexed_fill(x: i32, y: i32, w: i32, h: i32, idx: [u8]) -> bool:
        val total = w * h
        if idx.len() < total:
            return false
        val total_i64 = _metal_i64(total)
        val idx_buf = metal_sffi_alloc_buffer(self.session.device, total_i64)
        if idx_buf == 0:
            return false
        # Host staging buffer is rounded up to a 4-byte multiple so every
        # packing write below can safely store a full i32 word (rt_ptr_write_i32
        # always writes 4 bytes) without overrunning the allocation on a
        # non-multiple-of-4 total; only the real `total_i64` bytes are then
        # uploaded to the device buffer (which IS sized exactly `total_i64`),
        # so the pad bytes never reach the GPU.
        val padded_len = _metal_i64(((total + 3) / 4) * 4)
        val host = metal_host_alloc(padded_len)
        if host == 0:
            metal_sffi_free_buffer(idx_buf)
            return false
        # Pack 4 indices per host write (one rt_ptr_write_i32 call per 4 bytes)
        # rather than one FFI call per byte — the same "avoid a per-element
        # FFI hop" idiom the rest of this file follows for host-buffer packing.
        var i = 0
        while i < total:
            val b0 = idx[i].to_i64()
            var b1: i64 = 0
            var b2: i64 = 0
            var b3: i64 = 0
            if i + 1 < total:
                b1 = idx[i + 1].to_i64()
            if i + 2 < total:
                b2 = idx[i + 2].to_i64()
            if i + 3 < total:
                b3 = idx[i + 3].to_i64()
            val word = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)
            metal_host_write_i32(host, _metal_i64(i), word)
            i = i + 4
        if metal_buffer_upload_ptr(idx_buf, host, total_i64) == 0:
            metal_host_free(host)
            metal_sffi_free_buffer(idx_buf)
            return false
        metal_host_free(host)
        val params = metal_host_alloc(24)
        if params == 0:
            metal_sffi_free_buffer(idx_buf)
            return false
        metal_host_write_i32(params, 0, x as i64)
        metal_host_write_i32(params, 4, y as i64)
        metal_host_write_i32(params, 8, w as i64)
        metal_host_write_i32(params, 12, h as i64)
        metal_host_write_i32(params, 16, self.w as i64)
        metal_host_write_i32(params, 20, self.h as i64)
        val lut = self.lut_buffer
        val pipeline = self.session.pipe_indexed_fill
        val ok = self._dispatch_metal_aux_image_checked(pipeline, idx_buf, lut, params, 24, w, h)
        metal_host_free(params)
        ok

    me read_pixels_gpu_only() -> [u32]:
        if not self.initialized or self.d_framebuffer == 0:
            self.last_error = "Metal GPU-only readback unavailable: backend not initialized or framebuffer missing"
            return []
        val total_i32 = self.w * self.h
        val total_pixels = _metal_i64(total_i32)
        val byte_size = total_pixels * 4
        val host = metal_host_alloc(byte_size + 8)
        if host == 0:
            self.last_error = "Metal GPU-only readback host allocation failed"
            return []
        val ok = metal_buffer_download_ptr(host, self.d_framebuffer, byte_size)
        if ok == 0:
            metal_host_free(host)
            self.last_error = "Metal GPU-only framebuffer download failed"
            return []
        # One-call fast path: rt_u32s_from_raw builds the whole [u32] Rust-side.
        # The per-8-byte metal_host_read_i64 loop below costs ~1.4s at 1024x768
        # and 90s+ at Retina physical resolution (3.67M interpreted FFI
        # round-trips). The extern only exists in runtimes built >= 2026-07-03,
        # and unknown externs are a hard error at call time, so it is opt-in via
        # SIMPLE_ONE_CALL_READBACK=1 (set by gates/apps that pin a modern
        # driver). Flip to default-on once the self-hosted bin/simple is
        # redeployed (blocked on the stage-2 bootstrap bug).
        val one_call = _metal_env_flag("SIMPLE_ONE_CALL_READBACK")
        if one_call:
            val fast_pixels = metal_u32s_from_ptr(host, total_pixels)
            metal_host_free(host)
            if fast_pixels.len() != total_i32:
                self.last_error = "Metal GPU-only one-call conversion length mismatch"
                return []
            self.last_error = ""
            return fast_pixels
        var pixels: [u32] = [0u32; total_i32]
        var i: i64 = 0
        while i < total_pixels:
            val pair = metal_host_read_i64(host, i * 4)
            pixels[i as i32] = (pair & 0xFFFFFFFF) as u32
            i = i + 1
            if i < total_pixels:
                pixels[i as i32] = ((pair >> 32) & 0xFFFFFFFF) as u32
                i = i + 1
        metal_host_free(host)
        self.last_error = ""
        pixels

    # Disable CPU mirror rasterization. At native Retina resolution the mirror
    # would duplicate millions of pixels of work per op under the interpreter.
    # Retain its full-sized storage as a stable fallback/readback object; only
    # the device framebuffer is mutated while gpu_only is true.
    me use_gpu_only():
        # Keep full-sized fallback storage so device readback remains ABI-stable;
        # draw methods use gpu_only to skip CPU mirror rasterization entirely.
        self.gpu_only = true

    # Blit a host RGBA pixel block (block_w x block_h, u32/pixel) into the GPU
    # framebuffer at (x, y) via the kernel_blit_image compute pipeline. One
    # device buffer + one dispatch: the pixels land in d_framebuffer so the
    # GPU-only readback shows them (no CPU-mirror dependence).
    me _dispatch_metal_blit(x: i32, y: i32, block_w: i32, block_h: i32, host_ptr: i64, byte_size: i64) -> bool:
        if block_w <= 0 or block_h <= 0:
            return true
        if self.pending_composite_command != 0:
            return false
        val src_buf = metal_sffi_alloc_buffer(self.session.device, byte_size)
        if src_buf == 0:
            return false
        if metal_buffer_upload_ptr(src_buf, host_ptr, byte_size) == 0:
            metal_sffi_free_buffer(src_buf)
            return false
        val params = metal_host_alloc(24)
        if params == 0:
            metal_sffi_free_buffer(src_buf)
            return false
        metal_host_write_i32(params, 0, x as i64)
        metal_host_write_i32(params, 4, y as i64)
        metal_host_write_i32(params, 8, block_w as i64)
        metal_host_write_i32(params, 12, block_h as i64)
        metal_host_write_i32(params, 16, self.w as i64)
        metal_host_write_i32(params, 20, self.h as i64)
        val q = self.command_queue
        val fb = self.d_framebuffer
        val pipeline = self.session.pipe_blit
        val cmd = metal_sffi_create_command_buffer(q)
        if cmd == 0:
            metal_host_free(params)
            metal_sffi_free_buffer(src_buf)
            return false
        val encoder = metal_sffi_create_compute_encoder(cmd)
        if encoder == 0:
            metal_host_free(params)
            metal_sffi_free_buffer(src_buf)
            metal_sffi_destroy_command_buffer(cmd)
            return false
        var encoded = metal_sffi_set_buffer(encoder, fb, 0, 0)
        encoded = encoded and (metal_set_bytes_ptr(encoder, params, 24, 1) != 0)
        encoded = encoded and metal_sffi_set_buffer(encoder, src_buf, 0, 2)
        encoded = encoded and self._bind_metal_clip(encoder)
        val bx = 16
        val by = 16
        val gx = ((_metal_i64(block_w) + bx - 1) / bx) * bx
        val gy = ((_metal_i64(block_h) + by - 1) / by) * by
        if encoded:
            encoded = metal_sffi_dispatch_compute(encoder, pipeline, gx, gy, 1, bx, by, 1)
        encoded = encoded and metal_sffi_end_compute_encoder(encoder)
        metal_host_free(params)
        if not encoded:
            metal_sffi_free_buffer(src_buf)
            metal_sffi_destroy_compute_encoder(encoder)
            metal_sffi_destroy_command_buffer(cmd)
            return false
        self.pending_composite_command = cmd
        self.pending_composite_encoder = encoder
        self.pending_composite_source = src_buf
        val committed = metal_sffi_commit_command_buffer(cmd)
        if not committed:
            metal_sffi_release_uncommitted_submission(cmd, encoder, src_buf)
            self.pending_composite_command = 0
            self.pending_composite_encoder = 0
            self.pending_composite_source = 0
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal image blit commit failed"
            return false
        if not metal_sffi_wait_completed(cmd):
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal image blit completion unknown"
            return false
        metal_sffi_free_buffer(src_buf)
        metal_sffi_destroy_compute_encoder(encoder)
        metal_sffi_destroy_command_buffer(cmd)
        self.pending_composite_command = 0
        self.pending_composite_encoder = 0
        self.pending_composite_source = 0
        true

    me _dispatch_metal_image_composite(x: i32, y: i32, w: i32, h: i32, pixels: [u32], opacity_milli: i32) -> bool:
        val total_pixels = w.to_i64() * h.to_i64()
        val byte_size = total_pixels * 4
        val host = metal_host_alloc(byte_size)
        if host == 0:
            return false
        if _metal_env_flag("SIMPLE_ONE_CALL_UPLOAD"):
            if metal_write_u32s_to_ptr(host, pixels) != total_pixels:
                metal_host_free(host)
                return false
        elif (env_get("SIMPLE_BULK_UPLOAD") ?? "") == "cdylib":
            if not bulk_upload_u32s(host, pixels, total_pixels):
                metal_host_free(host)
                return false
        else:
            var i: i64 = 0
            while i < total_pixels:
                metal_host_write_i32(host, i * 4, pixels[i as i32].to_i64())
                i = i + 1

        val src_buf = metal_sffi_alloc_buffer(self.session.device, byte_size)
        if src_buf == 0:
            metal_host_free(host)
            return false
        if metal_buffer_upload_ptr(src_buf, host, byte_size) == 0:
            metal_host_free(host)
            metal_sffi_free_buffer(src_buf)
            return false
        metal_host_free(host)

        val params = metal_host_alloc(28)
        if params == 0:
            metal_sffi_free_buffer(src_buf)
            return false
        metal_host_write_i32(params, 0, x.to_i64())
        metal_host_write_i32(params, 4, y.to_i64())
        metal_host_write_i32(params, 8, w.to_i64())
        metal_host_write_i32(params, 12, h.to_i64())
        metal_host_write_i32(params, 16, self.w.to_i64())
        metal_host_write_i32(params, 20, self.h.to_i64())
        metal_host_write_i32(params, 24, opacity_milli.to_i64())

        val cmd = metal_sffi_create_command_buffer(self.command_queue)
        if cmd == 0:
            metal_host_free(params)
            metal_sffi_free_buffer(src_buf)
            return false
        val encoder = metal_sffi_create_compute_encoder(cmd)
        if encoder == 0:
            metal_host_free(params)
            metal_sffi_free_buffer(src_buf)
            metal_sffi_destroy_command_buffer(cmd)
            return false
        var encoded = metal_sffi_set_buffer(encoder, self.d_framebuffer, 0, 0)
        encoded = encoded and (metal_set_bytes_ptr(encoder, params, 28, 1) != 0)
        encoded = encoded and metal_sffi_set_buffer(encoder, src_buf, 0, 2)
        encoded = encoded and self._bind_metal_clip(encoder)
        if encoded:
            val bx = 16
            val by = 16
            val gx = ((w.to_i64() + bx - 1) / bx) * bx
            val gy = ((h.to_i64() + by - 1) / by) * by
            encoded = metal_sffi_dispatch_compute(encoder, self.session.pipe_image_composite, gx, gy, 1, bx, by, 1)
        encoded = encoded and metal_sffi_end_compute_encoder(encoder)
        metal_host_free(params)
        if not encoded:
            metal_sffi_free_buffer(src_buf)
            metal_sffi_destroy_compute_encoder(encoder)
            metal_sffi_destroy_command_buffer(cmd)
            return false

        # Ownership transfers to the deferred path only after commit succeeds.
        # A missing command handle cannot submit and is reclaimed immediately.
        self.pending_composite_command = cmd
        self.pending_composite_encoder = encoder
        self.pending_composite_source = src_buf
        val committed = metal_sffi_commit_command_buffer(cmd)
        if not committed:
            metal_sffi_release_uncommitted_submission(cmd, encoder, src_buf)
            self.pending_composite_command = 0
            self.pending_composite_encoder = 0
            self.pending_composite_source = 0
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal image composite commit failed"
            return false
        if not metal_sffi_wait_completed(cmd):
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal image composite completion unknown"
            return false
        metal_sffi_free_buffer(src_buf)
        metal_sffi_destroy_compute_encoder(encoder)
        metal_sffi_destroy_command_buffer(cmd)
        self.pending_composite_command = 0
        self.pending_composite_encoder = 0
        self.pending_composite_source = 0
        true

    # Draw a host RGBA pixel block (w x h, u32/pixel, row-major, same layout as
    # SoftwareBackend.draw_image) into the GPU framebuffer at (x, y) via the
    # kernel_blit_image compute pipeline. Packs the [u32] Simple array into a
    # raw host byte buffer (per-pixel write, same proven pattern draw_text_hires
    # already uses below) and reuses _dispatch_metal_blit for upload+dispatch.
    me _dispatch_metal_image(x: i32, y: i32, w: i32, h: i32, pixels: [u32]) -> bool:
        if w <= 0 or h <= 0:
            return true
        val total_i32 = w * h
        if pixels.len() < total_i32:
            return false
        val total_pixels = _metal_i64(total_i32)
        val byte_size = total_pixels * 4
        val host = metal_host_alloc(byte_size)
        if host == 0:
            return false
        # One-call pack: copy the whole [u32] block into the host buffer
        # Rust-side. The per-pixel metal_host_write_i32 loop below costs one
        # interpreted FFI round-trip per pixel (~480K for one 800x600 frame —
        # minutes of pure dispatch overhead). Gated on its OWN opt-in flag
        # (SIMPLE_ONE_CALL_UPLOAD), NOT on SIMPLE_ONE_CALL_READBACK: the
        # download extern (rt_u32s_from_raw) and the upload extern
        # (rt_write_u32s_to_raw) were added to the runtime at different times,
        # and a deployed runtime can export the first without the second (bit-
        # verified 2026-07-06: readback one-call works while draw_image upload
        # hard-errors "unknown extern function: rt_write_u32s_to_raw" mid-
        # frame). Unknown externs are a hard error at call time, so each fast
        # path must be gated by a flag that pins exactly its own extern.
        if _metal_env_flag("SIMPLE_ONE_CALL_UPLOAD"):
            val wrote = metal_write_u32s_to_ptr(host, pixels)
            if wrote < total_pixels:
                metal_host_free(host)
                return false
        elif (env_get("SIMPLE_BULK_UPLOAD") ?? "") == "cdylib":
            # Sibling-cdylib bulk staging (16 px per FFI call) — works on the
            # DEPLOYED binary, which lacks the rt_write_u32s_to_raw one-call
            # upload extern. Loud error (not a silent per-pixel fallback) if the
            # cdylib is missing while the mode is explicitly requested.
            if not bulk_upload_u32s(host, pixels, total_pixels):
                metal_host_free(host)
                print "backend_metal: SIMPLE_BULK_UPLOAD=cdylib requested but libspl_gpu_transfer could not be loaded — build it with: sh scripts/build/build_spl_gpu_transfer.shs (or set SIMPLE_SPL_GPU_TRANSFER_PATH)"
                return false
        else:
            var i: i64 = 0
            while i < total_pixels:
                val v = pixels[i as i32] as i64
                metal_host_write_i32(host, i * 4, v)
                i = i + 1
        val ok = self._dispatch_metal_blit(x, y, w, h, host, byte_size)
        metal_host_free(host)
        ok

    # Draw antialiased, high-resolution text into the GPU framebuffer. Unlike
    # draw_text (integer-scaled 5x7 bitmap cells → blocky at large px_size), this
    # bilinearly upsamples the 8x16 glyph coverage to `px_size` and composites the
    # text color over `bg` (the known solid background behind the text), so glyph
    # edges stay smooth. Intended for large sizes; small text should keep draw_text.
    me draw_text_hires(x: i32, y: i32, text_val: text, color: u32, px_size: i32, bg: u32):
        var mscale = px_size / 16
        if mscale < 1:
            mscale = 1
        if not self.gpu_only:
            self.mirror.draw_text(x, y, text_val, color, mscale)
        if not self.initialized or self.d_framebuffer == 0 or self.session.pipe_blit == 0:
            self.gpu_frame_complete = false
            return
        val text_len = text_val.len()
        if text_len <= 0:
            return
        var cell_h = px_size
        if cell_h < 1:
            cell_h = 1
        var cell_w = px_size / 2
        if cell_w < 1:
            cell_w = 1
        val spacing = 1 + cell_w / 8
        val advance = cell_w + spacing
        val block_w = advance * text_len.to_i32()
        val block_h = cell_h
        val px_count = _metal_i64(block_w) * _metal_i64(block_h)
        val byte_size = px_count * 4
        val host = metal_host_alloc(byte_size)
        if host == 0:
            self.gpu_frame_complete = false
            return
        val fr = ((color >> 16) & 0xFFu32) as i32
        val fg_c = ((color >> 8) & 0xFFu32) as i32
        val fb_c = (color & 0xFFu32) as i32
        val br = ((bg >> 16) & 0xFFu32) as i32
        val bg_c = ((bg >> 8) & 0xFFu32) as i32
        val bb_c = (bg & 0xFFu32) as i32
        val alpha = ((bg >> 24) & 0xFFu32) as i32
        val bg_word = bg as i64
        var ci = 0
        while ci < text_len:
            val code = text_val.char_code_at(ci)
            val rows = rt_gui_get_glyph_8x16(code.to_i32())
            val cell_x0 = ci.to_i32() * advance
            var dy = 0
            while dy < cell_h:
                val row_base = _metal_i64(dy) * _metal_i64(block_w)
                var dx = 0
                while dx < advance:
                    val bx = cell_x0 + dx
                    val idx = (row_base + _metal_i64(bx)) * 4
                    if dx >= cell_w:
                        metal_host_write_i32(host, idx, bg_word)
                    else:
                        val cov = _hires_glyph_coverage(rows, dx, dy, cell_w, cell_h)
                        if cov <= 0:
                            metal_host_write_i32(host, idx, bg_word)
                        else:
                            val rr = _hires_blend_channel(fr, br, cov)
                            val gg = _hires_blend_channel(fg_c, bg_c, cov)
                            val bbb = _hires_blend_channel(fb_c, bb_c, cov)
                            val outc = (alpha.to_i64() << 24) | (rr.to_i64() << 16) | (gg.to_i64() << 8) | bbb.to_i64()
                            metal_host_write_i32(host, idx, outc)
                    dx = dx + 1
                dy = dy + 1
            ci = ci + 1
        val ok = self._dispatch_metal_blit(x, y, block_w, block_h, host, byte_size)
        metal_host_free(host)
        self.gpu_frame_complete = self.gpu_frame_complete and ok

    me _dispatch_metal_clear(color: u32) -> bool:
        val params = metal_host_alloc(12)
        if params == 0:
            return false
        metal_host_write_i32(params, 0, color as i64)
        metal_host_write_i32(params, 4, self.w as i64)
        metal_host_write_i32(params, 8, self.h as i64)
        val pipeline = self.session.pipe_clear
        val threads = _metal_i64(self.w) * _metal_i64(self.h)
        val ok = self._dispatch_metal_1d(pipeline, threads, 256, params, 12)
        metal_host_free(params)
        ok

    me _dispatch_metal_rect_filled(x: i32, y: i32, w: i32, h: i32, color: u32) -> bool:
        if w <= 0 or h <= 0:
            return true
        val params = metal_host_alloc(28)
        if params == 0:
            return false
        metal_host_write_i32(params, 0, x as i64)
        metal_host_write_i32(params, 4, y as i64)
        metal_host_write_i32(params, 8, w as i64)
        metal_host_write_i32(params, 12, h as i64)
        metal_host_write_i32(params, 16, color as i64)
        metal_host_write_i32(params, 20, self.w as i64)
        metal_host_write_i32(params, 24, self.h as i64)
        val pipeline = self.session.pipe_rect_filled
        val ok = self._dispatch_metal_2d(pipeline, w, h, params, 28)
        metal_host_free(params)
        ok

    me _dispatch_metal_rect_outline(x: i32, y: i32, w: i32, h: i32, color: u32) -> bool:
        if w <= 0 or h <= 0:
            return true
        val params = metal_host_alloc(28)
        if params == 0:
            return false
        metal_host_write_i32(params, 0, x as i64)
        metal_host_write_i32(params, 4, y as i64)
        metal_host_write_i32(params, 8, w as i64)
        metal_host_write_i32(params, 12, h as i64)
        metal_host_write_i32(params, 16, color as i64)
        metal_host_write_i32(params, 20, self.w as i64)
        metal_host_write_i32(params, 24, self.h as i64)
        val pipeline = self.session.pipe_rect_outline
        val ok = self._dispatch_metal_2d(pipeline, w, h, params, 28)
        metal_host_free(params)
        ok

    me _dispatch_metal_line(x1: i32, y1: i32, x2: i32, y2: i32, color: u32, thickness: i32) -> bool:
        val params = metal_host_alloc(32)
        if params == 0:
            return false
        metal_host_write_i32(params, 0, x1 as i64)
        metal_host_write_i32(params, 4, y1 as i64)
        metal_host_write_i32(params, 8, x2 as i64)
        metal_host_write_i32(params, 12, y2 as i64)
        metal_host_write_i32(params, 16, color as i64)
        metal_host_write_i32(params, 20, thickness as i64)
        metal_host_write_i32(params, 24, self.w as i64)
        metal_host_write_i32(params, 28, self.h as i64)
        var dx = x2 - x1
        if dx < 0:
            dx = 0 - dx
        var dy = y2 - y1
        if dy < 0:
            dy = 0 - dy
        var steps = dx
        if dy > steps:
            steps = dy
        if steps <= 0:
            steps = 1
        val pipeline = self.session.pipe_line
        val ok = self._dispatch_metal_1d(pipeline, (steps + 1) as i64, 256, params, 32)
        metal_host_free(params)
        ok

    me _dispatch_metal_circle(cx: i32, cy: i32, r: i32, color: u32, filled: bool) -> bool:
        if r <= 0:
            return true
        val params = metal_host_alloc(28)
        if params == 0:
            return false
        metal_host_write_i32(params, 0, cx as i64)
        metal_host_write_i32(params, 4, cy as i64)
        metal_host_write_i32(params, 8, r as i64)
        metal_host_write_i32(params, 12, color as i64)
        metal_host_write_i32(params, 16, self.w as i64)
        metal_host_write_i32(params, 20, self.h as i64)
        if filled:
            metal_host_write_i32(params, 24, 1)
        else:
            metal_host_write_i32(params, 24, 0)
        # Snapshot the selected pipeline before command allocation so dispatch
        # uses one stable session state throughout the submission.
        var ok = true
        if filled:
            # Filled circle: per-pixel distance test over the (2r+1)^2 bounding box.
            val pipe_f = self.session.pipe_circle_filled
            val extent = 2 * r + 1
            ok = self._dispatch_metal_2d(pipe_f, extent, extent, params, 28)
        else:
            # Outline: 1D midpoint-replay kernel; thread i = midpoint iteration i.
            # r+1 threads is a safe upper bound (extras self-cull on px < py).
            val pipe_o = self.session.pipe_circle
            ok = self._dispatch_metal_1d(pipe_o, (r + 1) as i64, 256, params, 28)
        metal_host_free(params)
        ok

    me _dispatch_metal_rounded_rect(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32) -> bool:
        if w <= 0 or h <= 0:
            return true
        val params = metal_host_alloc(32)
        if params == 0:
            return false
        metal_host_write_i32(params, 0, x as i64)
        metal_host_write_i32(params, 4, y as i64)
        metal_host_write_i32(params, 8, w as i64)
        metal_host_write_i32(params, 12, h as i64)
        metal_host_write_i32(params, 16, radius as i64)
        metal_host_write_i32(params, 20, color as i64)
        metal_host_write_i32(params, 24, self.w as i64)
        metal_host_write_i32(params, 28, self.h as i64)
        # Fill kernel: 2D dispatch over the [0,w) x [0,h) bounding box; each
        # pixel runs the band/corner-arc membership test. Bit-exact with the
        # CPU emu_draw_rounded_rect reference (same idiom as
        # _dispatch_metal_rounded_rect_outline below).
        val pipeline = self.session.pipe_rounded_rect
        val ok = self._dispatch_metal_2d(pipeline, w, h, params, 32)
        metal_host_free(params)
        ok

    me _dispatch_metal_rounded_rect_outline(x: i32, y: i32, w: i32, h: i32, radius: i32, color: u32, thickness: i32) -> bool:
        if w <= 0 or h <= 0:
            return true
        # RoundedRectOutlineParams: x,y,w,h,radius,color,thickness,fb_w,fb_h (9 i32 = 36 bytes)
        val params = metal_host_alloc(36)
        if params == 0:
            return false
        metal_host_write_i32(params, 0, x as i64)
        metal_host_write_i32(params, 4, y as i64)
        metal_host_write_i32(params, 8, w as i64)
        metal_host_write_i32(params, 12, h as i64)
        metal_host_write_i32(params, 16, radius as i64)
        metal_host_write_i32(params, 20, color as i64)
        metal_host_write_i32(params, 24, thickness as i64)
        metal_host_write_i32(params, 28, self.w as i64)
        metal_host_write_i32(params, 32, self.h as i64)
        # 2D dispatch over the rect bounding box; each pixel runs the union
        # inclusion test (edges + corner arcs). Bit-exact with the CPU mirror.
        val pipeline = self.session.pipe_rounded_rect_outline
        val ok = self._dispatch_metal_2d(pipeline, w, h, params, 36)
        metal_host_free(params)
        ok

    me _dispatch_metal_triangle(x1: i32, y1: i32, x2: i32, y2: i32, x3: i32, y3: i32, color: u32) -> bool:
        # Integer barycentric fill over the triangle bounding box (2D dispatch).
        var min_x = x1
        if x2 < min_x: min_x = x2
        if x3 < min_x: min_x = x3
        var max_x = x1
        if x2 > max_x: max_x = x2
        if x3 > max_x: max_x = x3
        var min_y = y1
        if y2 < min_y: min_y = y2
        if y3 < min_y: min_y = y3
        var max_y = y1
        if y2 > max_y: max_y = y2
        if y3 > max_y: max_y = y3
        val bw = max_x - min_x + 1
        val bh = max_y - min_y + 1
        if bw <= 0 or bh <= 0:
            return true
        val params = metal_host_alloc(44)
        if params == 0:
            return false
        metal_host_write_i32(params, 0, x1 as i64)
        metal_host_write_i32(params, 4, y1 as i64)
        metal_host_write_i32(params, 8, x2 as i64)
        metal_host_write_i32(params, 12, y2 as i64)
        metal_host_write_i32(params, 16, x3 as i64)
        metal_host_write_i32(params, 20, y3 as i64)
        metal_host_write_i32(params, 24, color as i64)
        metal_host_write_i32(params, 28, self.w as i64)
        metal_host_write_i32(params, 32, self.h as i64)
        metal_host_write_i32(params, 36, min_x as i64)
        metal_host_write_i32(params, 40, min_y as i64)
        val pipeline = self.session.pipe_triangle
        val ok = self._dispatch_metal_2d(pipeline, bw, bh, params, 44)
        metal_host_free(params)
        ok

    me _dispatch_metal_gradient_rect(x: i32, y: i32, w: i32, h: i32, top_color: u32, bottom_color: u32) -> bool:
        if w <= 0 or h <= 0:
            return true
        val params = metal_host_alloc(32)
        if params == 0:
            return false
        metal_host_write_i32(params, 0, x as i64)
        metal_host_write_i32(params, 4, y as i64)
        metal_host_write_i32(params, 8, w as i64)
        metal_host_write_i32(params, 12, h as i64)
        metal_host_write_i32(params, 16, top_color as i64)
        metal_host_write_i32(params, 20, bottom_color as i64)
        metal_host_write_i32(params, 24, self.w as i64)
        metal_host_write_i32(params, 28, self.h as i64)
        val pipeline = self.session.pipe_gradient
        val ok = self._dispatch_metal_2d(pipeline, w, h, params, 32)
        metal_host_free(params)
        ok

    # GPU-dict use case #2 (design W4): ONE kernel_glyph_atlas_blit dispatch
    # for the whole string, replacing the former N-dispatch (one
    # kernel_draw_rect_filled per lit glyph pixel) path. Uploads the small
    # per-call codepoint->atlas-index buffer (buffer 2) and binds the
    # PERSISTENT glyph atlas GpuLut (buffer 3, uploaded once at init by
    # _upload_glyph_atlas()).
    me _dispatch_metal_glyph_atlas_blit(x: i32, y: i32, text_val: text, color: u32, font_size: i32) -> bool:
        val gh = glyph_height()
        var scale = font_size / gh
        if scale < 1:
            scale = 1
        val advance = glyph_advance(scale)
        val text_len = text_val.len()
        val text_len_i32 = text_len.to_i32()
        if text_len_i32 <= 0:
            return true
        val text_w = text_len_i32 * advance
        val text_h = gh * scale
        if text_w <= 0 or text_h <= 0:
            return true
        val cp_bytes = _metal_i64(text_len_i32) * 4
        val cp_host = metal_host_alloc(cp_bytes)
        if cp_host == 0:
            return false
        var i: i64 = 0
        while i < text_len:
            val code = text_val.char_code_at(i)
            val gi = glyph_atlas_index_for_char_code(code)
            metal_host_write_i32(cp_host, i * 4, gi.to_i64())
            i = i + 1
        val cp_buf = metal_sffi_alloc_buffer(self.session.device, cp_bytes)
        if cp_buf == 0:
            metal_host_free(cp_host)
            return false
        if metal_buffer_upload_ptr(cp_buf, cp_host, cp_bytes) == 0:
            metal_host_free(cp_host)
            metal_sffi_free_buffer(cp_buf)
            return false
        metal_host_free(cp_host)
        val params = metal_host_alloc(36)
        if params == 0:
            metal_sffi_free_buffer(cp_buf)
            return false
        metal_host_write_i32(params, 0, x as i64)
        metal_host_write_i32(params, 4, y as i64)
        metal_host_write_i32(params, 8, text_len_i32 as i64)
        metal_host_write_i32(params, 12, scale as i64)
        metal_host_write_i32(params, 16, advance as i64)
        metal_host_write_i32(params, 20, gh as i64)
        metal_host_write_i32(params, 24, color as i64)
        metal_host_write_i32(params, 28, self.w as i64)
        metal_host_write_i32(params, 32, self.h as i64)
        val atlas = self.glyph_lut_buffer
        val pipeline = self.session.pipe_glyph_atlas_blit
        val ok = self._dispatch_metal_aux_image_checked(pipeline, cp_buf, atlas, params, 36, text_w, text_h)
        metal_host_free(params)
        ok

    me _dispatch_metal_aux_image_checked(pipeline: i64, source: i64, auxiliary: i64, params: i64, params_len: i64, w: i32, h: i32) -> bool:
        if self.pending_composite_command != 0:
            metal_sffi_free_buffer(source)
            return false
        val cmd = metal_sffi_create_command_buffer(self.command_queue)
        if cmd == 0:
            metal_sffi_free_buffer(source)
            return false
        val encoder = metal_sffi_create_compute_encoder(cmd)
        if encoder == 0:
            metal_sffi_free_buffer(source)
            metal_sffi_destroy_command_buffer(cmd)
            return false
        var encoded = metal_sffi_set_buffer(encoder, self.d_framebuffer, 0, 0)
        encoded = encoded and (metal_set_bytes_ptr(encoder, params, params_len, 1) != 0)
        encoded = encoded and metal_sffi_set_buffer(encoder, source, 0, 2)
        encoded = encoded and metal_sffi_set_buffer(encoder, auxiliary, 0, 3)
        encoded = encoded and self._bind_metal_clip(encoder)
        val block_x = 16
        val block_y = 16
        val grid_x = ((_metal_i64(w) + block_x - 1) / block_x) * block_x
        val grid_y = ((_metal_i64(h) + block_y - 1) / block_y) * block_y
        if encoded:
            encoded = metal_sffi_dispatch_compute(encoder, pipeline, grid_x, grid_y, 1, block_x, block_y, 1)
        encoded = encoded and metal_sffi_end_compute_encoder(encoder)
        if not encoded:
            metal_sffi_free_buffer(source)
            metal_sffi_destroy_compute_encoder(encoder)
            metal_sffi_destroy_command_buffer(cmd)
            return false
        self.pending_composite_command = cmd
        self.pending_composite_encoder = encoder
        self.pending_composite_source = source
        val committed = metal_sffi_commit_command_buffer(cmd)
        if not committed:
            metal_sffi_release_uncommitted_submission(cmd, encoder, source)
            self.pending_composite_command = 0
            self.pending_composite_encoder = 0
            self.pending_composite_source = 0
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal auxiliary image commit failed"
            return false
        if not metal_sffi_wait_completed(cmd):
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal auxiliary image completion unknown"
            return false
        metal_sffi_free_buffer(source)
        metal_sffi_destroy_compute_encoder(encoder)
        metal_sffi_destroy_command_buffer(cmd)
        self.pending_composite_command = 0
        self.pending_composite_encoder = 0
        self.pending_composite_source = 0
        true

    me _bind_metal_clip(encoder: i64) -> bool:
        val params = metal_host_alloc(20)
        if params == 0:
            return false
        metal_host_write_i32(params, 0, self.clip_x as i64)
        metal_host_write_i32(params, 4, self.clip_y as i64)
        metal_host_write_i32(params, 8, self.clip_w as i64)
        metal_host_write_i32(params, 12, self.clip_h as i64)
        val enabled = if self.clip_enabled: 1 else: 0
        metal_host_write_i32(params, 16, enabled)
        val bound = metal_set_bytes_ptr(encoder, params, 20, 4) != 0
        metal_host_free(params)
        bound

    me _dispatch_metal_1d(pipeline: i64, threads: i64, block_x: i64, params: i64, params_len: i64) -> bool:
        # Snapshot queue and framebuffer handles before allocating command
        # objects so all failure paths operate on one submission state.
        if self.pending_composite_command != 0:
            return false
        val q = self.command_queue
        val fb = self.d_framebuffer
        val cmd = metal_sffi_create_command_buffer(q)
        if cmd == 0:
            return false
        val encoder = metal_sffi_create_compute_encoder(cmd)
        if encoder == 0:
            metal_sffi_destroy_command_buffer(cmd)
            return false
        var encoded = metal_sffi_set_buffer(encoder, fb, 0, 0)
        encoded = encoded and (metal_set_bytes_ptr(encoder, params, params_len, 1) != 0)
        encoded = encoded and self._bind_metal_clip(encoder)
        if encoded:
            encoded = metal_sffi_dispatch_compute(encoder, pipeline, threads, 1, 1, block_x, 1, 1)
        encoded = encoded and metal_sffi_end_compute_encoder(encoder)
        if not encoded:
            metal_sffi_destroy_compute_encoder(encoder)
            metal_sffi_destroy_command_buffer(cmd)
            return false
        self.pending_composite_command = cmd
        self.pending_composite_encoder = encoder
        self.pending_composite_source = 0
        val committed = metal_sffi_commit_command_buffer(cmd)
        if not committed:
            metal_sffi_release_uncommitted_submission(cmd, encoder, 0)
            self.pending_composite_command = 0
            self.pending_composite_encoder = 0
            self.pending_composite_source = 0
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal 1D dispatch commit failed"
            return false
        if not metal_sffi_wait_completed(cmd):
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal 1D dispatch completion unknown"
            return false
        metal_sffi_destroy_compute_encoder(encoder)
        metal_sffi_destroy_command_buffer(cmd)
        self.pending_composite_command = 0
        self.pending_composite_encoder = 0
        true

    me _dispatch_metal_2d(pipeline: i64, w: i32, h: i32, params: i64, params_len: i64) -> bool:
        if self.pending_composite_command != 0:
            return false
        val q = self.command_queue
        val fb = self.d_framebuffer
        val cmd = metal_sffi_create_command_buffer(q)
        if cmd == 0:
            return false
        val encoder = metal_sffi_create_compute_encoder(cmd)
        if encoder == 0:
            metal_sffi_destroy_command_buffer(cmd)
            return false
        var encoded = metal_sffi_set_buffer(encoder, fb, 0, 0)
        encoded = encoded and (metal_set_bytes_ptr(encoder, params, params_len, 1) != 0)
        encoded = encoded and self._bind_metal_clip(encoder)
        val block_x = 16
        val block_y = 16
        val grid_x = ((_metal_i64(w) + block_x - 1) / block_x) * block_x
        val grid_y = ((_metal_i64(h) + block_y - 1) / block_y) * block_y
        if encoded:
            encoded = metal_sffi_dispatch_compute(encoder, pipeline, grid_x, grid_y, 1, block_x, block_y, 1)
        encoded = encoded and metal_sffi_end_compute_encoder(encoder)
        if not encoded:
            metal_sffi_destroy_compute_encoder(encoder)
            metal_sffi_destroy_command_buffer(cmd)
            return false
        self.pending_composite_command = cmd
        self.pending_composite_encoder = encoder
        self.pending_composite_source = 0
        val committed = metal_sffi_commit_command_buffer(cmd)
        if not committed:
            metal_sffi_release_uncommitted_submission(cmd, encoder, 0)
            self.pending_composite_command = 0
            self.pending_composite_encoder = 0
            self.pending_composite_source = 0
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal 2D dispatch commit failed"
            return false
        if not metal_sffi_wait_completed(cmd):
            self.initialized = false
            self.gpu_frame_complete = false
            self.last_error = "Metal 2D dispatch completion unknown"
            return false
        metal_sffi_destroy_compute_encoder(encoder)
        metal_sffi_destroy_command_buffer(cmd)
        self.pending_composite_command = 0
        self.pending_composite_encoder = 0
        true

