# engine2d — Multi-Backend 2D Rendering Engine
#
# @tag:stdlib
# @tag:api
# @tag:gpu
#
# Abstract 2D rendering with automatic backend selection.
# Supports CUDA, Vulkan, OpenGL, optimized software, and CPU fallback.
#
# Public API
# ----------
#
# Engine:
#   use std.gpu.engine2d.engine.{Engine2D}
#
# Backends:
#   use std.gpu.engine2d.backend.{RenderBackend}
#   use std.gpu.engine2d.backend_cpu.{CpuBackend}
#   use std.gpu.engine2d.backend_cuda.{CudaBackend}
#   use std.gpu.engine2d.backend_rocm.{RocmBackend}
#   use std.gpu.engine2d.backend_metal.{MetalBackend}
#   use std.gpu.engine2d.backend_vulkan.{VulkanBackend}
#   use std.gpu.engine2d.backend_opengl.{OpenGLBackend}
#   use std.gpu.engine2d.backend_intel.{IntelBackend}
#   use std.gpu.engine2d.backend_software.{SoftwareBackend}
#
# Color utilities:
#   use std.gpu.engine2d.color.{rgba, rgb, blend, lerp_color, hex_to_color}
#
# Compositing:
#   use std.gpu.engine2d.compositor.{Layer, Compositor}
#
# Submodules
# ----------
#
# - backend:          RenderBackend trait
# - backend_cpu:      Pure CPU software renderer
# - backend_cuda:     CUDA GPU renderer
# - backend_rocm:     ROCm/HIP GPU renderer (AMD)
# - backend_metal:    Metal GPU renderer (Apple)
# - backend_vulkan:   Vulkan GPU renderer (compute shaders)
# - backend_opengl:   OpenGL GPU renderer (FBO offscreen)
# - backend_intel:    Intel oneAPI GPU renderer
# - backend_software: Optimized software renderer (tile-based)
# - engine:           Engine2D facade with auto-detection
# - color:            Color utilities (ARGB packing, blending, hex)
# - compositor:       Layer compositing with alpha blend

# Engine facade
export Engine2D

# Backend trait
export RenderBackend

# Backend implementations
export CpuBackend
export CudaBackend
export RocmBackend
export MetalBackend
export VulkanBackend
export OpenGLBackend
export IntelBackend
export SoftwareBackend

# Color utilities
export rgba, rgb
export color_r, color_g, color_b, color_a
export blend, lerp_color
export hex_to_color, color_to_hex
export color_black, color_white, color_red, color_green, color_blue
export color_yellow, color_cyan, color_magenta, color_transparent, color_gray

# Compositor
export Layer, Compositor
