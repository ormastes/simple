# ROCm Session
#
# Shared HIP/ROCm state boundary for Engine2D compute sessions. The default
# constructor is fail-closed so interpreter and non-AMD hosts can exercise the
# contract without resolving HIP runtime externs.

use std.gc_async_mut.gpu.engine2d.backend_session.{BackendSessionKind}
use std.gc_async_mut.gpu.engine2d.generated_kernel_dispatch.{
    GENERATED_2D_ALPHA, GENERATED_2D_BITMAP_GLYPH_RASTER, GENERATED_2D_COPY, GENERATED_2D_FILL, GENERATED_2D_SCROLL,
    Generated2DSessionRuntimeProvenance,
    generated_2d_session_launch_gate,
    generated_2d_session_runtime_provenance
}
use std.gc_async_mut.gpu.engine2d.session_support.{gpu_session_launch_gate_status, gpu_session_readback_status}
use std.gc_async_mut.gpu.engine2d.sffi_rocm.{RocmFfi}

extern fn rt_ptr_read_i64(addr: i64, offset: i64) -> i64

fn rocm_host_read_i64(addr: i64, offset: i64) -> i64:
    rt_ptr_read_i64(addr, offset)

fn rocm_session_read_i64(addr: i64, offset: i64) -> i64:
    rocm_host_read_i64(addr, offset)

class RocmSessionEvidence:
    operation: text
    success: bool
    status_code: text
    reason: text
    device: i64
    module: i64
    kernel: i64
    generation: i64
    readback_available: bool
    expected_checksum: i64
    actual_checksum: i64

    static fn create(operation: text, success: bool, status_code: text, reason: text, device: i64, module: i64, kernel: i64, generation: i64, readback_available: bool, expected_checksum: i64, actual_checksum: i64) -> RocmSessionEvidence:
        RocmSessionEvidence(
            operation: operation,
            success: success,
            status_code: status_code,
            reason: reason,
            device: device,
            module: module,
            kernel: kernel,
            generation: generation,
            readback_available: readback_available,
            expected_checksum: expected_checksum,
            actual_checksum: actual_checksum
        )

    fn diagnostic_text() -> text:
        "RocmSessionEvidence[op={self.operation} success={self.success.to_text()} status={self.status_code} reason={self.reason} device={self.device} module={self.module} kernel={self.kernel} generation={self.generation} readback={self.readback_available.to_text()} expected={self.expected_checksum} actual={self.actual_checksum}]"

class RocmSession:
    device: i64
    module_cache: i64
    kernel_cache: i64
    stream: i64
    ref_count: i64
    is_initialized: bool
    generation: i64
    ffi: RocmFfi?

    static fn create() -> RocmSession:
        RocmSession(
            device: 0,
            module_cache: 0,
            kernel_cache: 0,
            stream: 0,
            ref_count: 0,
            is_initialized: false,
            generation: 0,
            ffi: nil
        )

    me init_evidence() -> RocmSessionEvidence:
        val rc = self.init()
        if rc == 0:
            return self._evidence("init", true, "initialized", "rocm-session-initialized", 0, true, 0, 0)
        if self.ffi == nil:
            return self._evidence("init", false, "missing-ffi", "missing-rocm-ffi", 0, false, 0, 0)
        if not self.ffi.is_available():
            return self._evidence("init", false, "runtime-unavailable", "rocm-runtime-unavailable", 0, false, 0, 0)
        if self.ffi.device_count() < 1:
            return self._evidence("init", false, "device-unavailable", "rocm-device-unavailable", 0, false, 0, 0)
        self._evidence("init", false, "init-failed", "rocm-init-failed", 0, false, 0, 0)

    static fn create_with_ffi(ffi: RocmFfi) -> RocmSession:
        val session = RocmSession.create()
        session.ffi = ffi
        session

    fn kind() -> BackendSessionKind:
        BackendSessionKind.Rocm

    fn is_available() -> bool:
        if self.ffi == nil:
            return false
        self.ffi.is_available()

    me init() -> i64:
        if self.ffi == nil:
            return 1
        if not self.ffi.init():
            return 1
        if self.ffi.device_count() < 1:
            return 1
        self.device = 0
        self.module_cache = 0
        self.stream = 0
        self.ref_count = 1
        self.is_initialized = true
        self.generation = self.generation + 1
        0

    me retain() -> RocmSession:
        self.ref_count = self.ref_count + 1
        self

    me release():
        if self.ref_count <= 0:
            return
        self.ref_count = self.ref_count - 1
        if self.ref_count == 0:
            self._cleanup()

    me is_valid() -> bool:
        self.is_initialized and self.ffi != nil

    me load_module(source: text) -> i64:
        if self.ffi == nil:
            return 0
        if source == "":
            return 0
        val module = self.ffi.module_load(source)
        if module == 0:
            return 0
        self.module_cache = module
        module

    me load_module_evidence(source: text) -> RocmSessionEvidence:
        val module = self.load_module(source)
        if module != 0:
            return self._evidence("load_module", true, "loaded", "rocm-module-loaded", 0, true, 0, 0)
        if self.ffi == nil:
            return self._evidence("load_module", false, "missing-ffi", "missing-rocm-ffi", 0, false, 0, 0)
        if source == "":
            return self._evidence("load_module", false, "empty-source", "missing-rocm-module-source", 0, false, 0, 0)
        self._evidence("load_module", false, "load-failed", "rocm-generated-module-load-failed", 0, false, 0, 0)

    me synchronize() -> i64:
        if self.ffi == nil:
            return 1
        if self.ffi.synchronize():
            0
        else:
            1

    me synchronize_evidence() -> RocmSessionEvidence:
        val rc = self.synchronize()
        if rc == 0:
            return self._evidence("synchronize", true, "synchronized", "rocm-device-synchronized", 0, true, 0, 0)
        if self.ffi == nil:
            return self._evidence("synchronize", false, "missing-ffi", "missing-rocm-ffi", 0, false, 0, 0)
        self._evidence("synchronize", false, "sync-failed", "rocm-device-sync-failed", 0, false, 0, 0)

    me shutdown():
        self.ref_count = 0
        self._cleanup()

    me launch_kernel(name: text, gx: i64, gy: i64, bx: i64, by: i64) -> i64:
        if self.ffi == nil:
            return 1
        if self.module_cache == 0:
            return 1
        val kernel = self.ffi.kernel_get(self.module_cache, name)
        if kernel == 0:
            return 1
        self.kernel_cache = kernel
        if self.ffi.launch_kernel(name, gx, gy, 1, bx, by, 1, 0):
            0
        else:
            1

    me launch_generated_2d(op: text, width: i64, height: i64, args_ptr: i64) -> i64:
        val gate = generated_2d_session_launch_gate("rocm", op, width, height, self.is_valid(), self.module_cache != 0, args_ptr)
        if not gate.ready:
            return 1
        if op == GENERATED_2D_BITMAP_GLYPH_RASTER and not self._generated_bitmap_glyph_raster_args_valid(args_ptr, width, height):
            return 1
        val kernel = self.ffi.kernel_get(self.module_cache, gate.plan.entry_name)
        if kernel == 0:
            return 1
        self.kernel_cache = kernel
        if self.ffi.launch_kernel_args(kernel, gate.plan.grid_x, gate.plan.grid_y, gate.plan.grid_z, gate.plan.block_x, gate.plan.block_y, gate.plan.block_z, 0, args_ptr):
            0
        else:
            1

    me launch_generated_2d_evidence(op: text, width: i64, height: i64, args_ptr: i64) -> RocmSessionEvidence:
        val operation = "launch_generated_2d:{op}"
        val gate = generated_2d_session_launch_gate("rocm", op, width, height, self.is_valid(), self.module_cache != 0, args_ptr)
        val status = gpu_session_launch_gate_status(
            "rocm",
            gate,
            self.ffi == nil,
            "missing-rocm-ffi",
            "runtime-not-ready",
            "rocm-runtime-not-ready",
            "missing-module",
            "missing-rocm-generated-module"
        )
        if not status.ready:
            return self._evidence(operation, false, status.status_code, status.reason, 0, false, 0, 0)
        if op == GENERATED_2D_BITMAP_GLYPH_RASTER and not self._generated_bitmap_glyph_raster_args_valid(args_ptr, width, height):
            return self._evidence(operation, false, "invalid-bitmap-glyph-args", "invalid-rocm-bitmap-glyph-raster-args", 0, false, 0, 0)
        val rc = self.launch_generated_2d(op, width, height, args_ptr)
        if rc == 0:
            return self._evidence(operation, true, "submitted", "rocm-generated-2d-kernel-submitted", self.kernel_cache, true, 0, 0)
        if self.kernel_cache == 0:
            return self._evidence(operation, false, "missing-kernel", "rocm-generated-2d-kernel-get-failed", 0, false, 0, 0)
        self._evidence(operation, false, "submit-failed", "rocm-generated-2d-kernel-submit-failed", self.kernel_cache, false, 0, 0)

    me launch_generated_2d_runtime_provenance(op: text, width: i64, height: i64, args_ptr: i64) -> Generated2DSessionRuntimeProvenance:
        generated_2d_session_runtime_provenance("rocm", op, width, height, self.is_valid(), self.module_cache != 0, args_ptr)

    me fill_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_FILL, width, height, args_ptr)

    me copy_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_COPY, width, height, args_ptr)

    me alpha_blend_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_ALPHA, width, height, args_ptr)

    me scroll_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_SCROLL, width, height, args_ptr)

    me bitmap_glyph_raster_kernel(width: i64, height: i64, args_ptr: i64) -> i64:
        self.launch_generated_2d(GENERATED_2D_BITMAP_GLYPH_RASTER, width, height, args_ptr)

    me alloc(size: i64) -> i64:
        if self.ffi == nil or size <= 0:
            return 0
        self.ffi.mem_alloc(size)

    me free(ptr: i64):
        if self.ffi == nil or ptr == 0:
            return
        self.ffi.mem_free(ptr)

    me read_pixels(buffer: i64, pixels: [u32], byte_size: i64) -> bool:
        if self.ffi == nil or buffer == 0 or byte_size <= 0:
            return false
        self.ffi.read_pixels(buffer, pixels, byte_size)

    me read_pixels_evidence(buffer: i64, pixels: [u32], byte_size: i64, expected_checksum: i64, actual_checksum: i64) -> RocmSessionEvidence:
        if self.ffi == nil:
            return self._evidence("read_pixels", false, "missing-ffi", "missing-rocm-ffi", 0, false, expected_checksum, actual_checksum)
        if buffer == 0:
            return self._evidence("read_pixels", false, "missing-buffer", "missing-rocm-device-buffer", 0, false, expected_checksum, actual_checksum)
        if byte_size <= 0:
            return self._evidence("read_pixels", false, "invalid-size", "invalid-rocm-readback-size", 0, false, expected_checksum, actual_checksum)
        if not self.read_pixels(buffer, pixels, byte_size):
            return self._evidence("read_pixels", false, "readback-failed", "rocm-device-readback-failed", 0, false, expected_checksum, actual_checksum)
        self.readback_evidence(true, expected_checksum, actual_checksum)

    fn readback_evidence(readback_available: bool, expected_checksum: i64, actual_checksum: i64) -> RocmSessionEvidence:
        val status = gpu_session_readback_status(
            "rocm",
            readback_available,
            expected_checksum,
            actual_checksum,
            "rocm-device-readback-required",
            "rocm-device-readback-checksum-required",
            "rocm-readback-checksum-matched",
            "rocm-device-readback-checksum-mismatch"
        )
        self._evidence("readback", status.success, status.status_code, status.reason, 0, status.readback_available, expected_checksum, actual_checksum)

    me _cleanup():
        self.module_cache = 0
        self.kernel_cache = 0
        self.device = 0
        self.stream = 0
        self.is_initialized = false
        self.generation = self.generation + 1

    me _generated_bitmap_glyph_raster_args_valid(args_ptr: i64, width: i64, height: i64) -> bool:
        if args_ptr == 0 or width <= 0 or height <= 0:
            return false
        val glyph_bits = rocm_session_read_i64(args_ptr, 0)
        val dst = rocm_session_read_i64(args_ptr, 8)
        val arg_width = rocm_session_read_i64(args_ptr, 16)
        val arg_height = rocm_session_read_i64(args_ptr, 24)
        val glyph_count = rocm_session_read_i64(args_ptr, 32)
        val font_size = rocm_session_read_i64(args_ptr, 40)
        glyph_bits != 0 and dst != 0 and arg_width == width and arg_height == height and glyph_count > 0 and font_size > 0

    fn _evidence(operation: text, success: bool, status_code: text, reason: text, kernel: i64, readback_available: bool, expected_checksum: i64, actual_checksum: i64) -> RocmSessionEvidence:
        RocmSessionEvidence.create(
            operation,
            success,
            status_code,
            reason,
            self.device,
            self.module_cache,
            kernel,
            self.generation,
            readback_available,
            expected_checksum,
            actual_checksum
        )
