# Engine2D VirtIO-GPU surface contract.
#
# Owned by the portable GPU library so the Engine2D VirtIO backend can depend on
# a stable surface API while the OS driver owns MMIO and device details.

trait VirtioGpu2DSurface:
    fn virtio_gpu_initialized() -> bool
    fn virtio_gpu_width() -> i32
    fn virtio_gpu_height() -> i32
    fn virtio_gpu_resource_id() -> u32
    fn virtio_gpu_fb_virt() -> u64
    fn virtio_gpu_fb_size() -> u64
    fn virtio_gpu_read_fb_argb(pixel_index: u64) -> u32
    fn virtio_gpu_write_fb_argb(pixel_index: u64, color: u32)
    fn virtio_gpu_flush()
