
# HTML Fallback Block Renderer
#
# Simple block-level div/span renderer used as a fallback when the full
# DOM -> Layout -> Paint pipeline produces an empty scene. Parses raw HTML
# tags and applies CSS style rules to produce pixel output directly.

use std.gc_async_mut.gpu.browser_engine.browser_renderer_utils.{
    browser_renderer_find_char, br_find_str,
    browser_renderer_split_spaces,
    br_tag_attr_value, br_merge_style_text,
    br_style_property_value, br_style_px_or_default}
use std.gc_async_mut.gpu.browser_engine.render_fixtures.{
    br_fill_rect, br_style_background_argb, br_style_color_argb}
use std.gc_async_mut.gpu.browser_engine.style_rule_index.{
    br_style_block_rule_for_class, br_style_block_rule_for_id,
    br_style_block_rule_for_tag, br_style_block_rule_for_universal,
    br_style_block_rule_for_tag_class, br_style_block_rule_for_tag_id,
    br_style_block_rule_for_descendant, br_style_block_rule_for_child,
    br_style_block_rule_for_body_child_div,
    br_style_block_rule_for_body_descendant_div,
    br_style_block_rule_for_ancestor_child_div,
    br_style_block_rule_for_adjacent_body_sibling_div,
    br_style_block_rule_for_general_body_sibling_div,
    br_style_block_rule_for_has_descendant,
    br_style_block_rule_for_not_self,
    br_style_block_rule_for_attr_self,
    br_style_block_rule_for_empty_self,
    br_style_block_rule_for_first_child_self,
    br_style_block_rule_for_last_child_self,
    br_style_block_rule_for_only_child_self,
    br_style_block_rule_for_nth_child_self,
    br_style_block_rule_for_multi_class,
    br_style_block_rule_for_selector}

# =========================================================================
# Main fallback renderer
# =========================================================================

fn br_render_simple_block_fallback_pixels(html: text, width: i32, height: i32) -> [u32]:
    val fill = br_body_background_argb_or_default(html, 0xFFFFFFFFu32)
    var pixels: [u32] = [fill; width * height]
    val lower = html.lower()
    val margin = br_body_margin_px(html)
    var cursor_y = margin
    var search_pos: i64 = 0
    var div_index = 0
    val div_count = br_count_fallback_divs(lower)
    while search_pos < html.len():
        val div_pos = br_find_str(lower, "<div", search_pos)
        if div_pos >= 999999999:
            return pixels
        val tag_end = browser_renderer_find_char(html, ">", div_pos)
        if tag_end >= 999999999:
            return pixels
        val tag_content = html.slice(div_pos + 1, tag_end)
        val inline_style = br_tag_attr_value(tag_content, "style")
        val universal_style = br_style_block_rule_for_universal(html)
        val tag_style = br_style_block_rule_for_tag(html, "div")
        val class_value = br_tag_attr_value(tag_content, "class")
        val class_style = br_style_block_rule_for_class(html, class_value)
        val compound_class_style = br_style_block_rule_for_tag_class(html, "div", class_value)
        val multi_class_style = br_style_block_rule_for_multi_class(html, class_value)
        val id_value = br_tag_attr_value(tag_content, "id")
        val id_style = br_style_block_rule_for_id(html, id_value)
        val tag_id_style = br_style_block_rule_for_tag_id(html, "div", id_value)
        val body_child_style = br_style_block_rule_for_body_child_div(html, div_pos, class_value, id_value)
        val descendant_style = br_style_block_rule_for_body_descendant_div(html, div_pos, class_value, id_value)
        val ancestor_child_style = br_style_block_rule_for_ancestor_child_div(html, div_pos, class_value, id_value)
        val adjacent_sibling_style = br_style_block_rule_for_adjacent_body_sibling_div(html, div_pos, class_value, id_value)
        val general_sibling_style = br_style_block_rule_for_general_body_sibling_div(html, div_pos, class_value, id_value)
        val has_style = br_style_block_rule_for_has_descendant(html, "div", tag_end + 1)
        val not_style = br_style_block_rule_for_not_self(html, "div", tag_content)
        val attr_style = br_style_block_rule_for_attr_self(html, "div", tag_content)
        val empty_style = br_style_block_rule_for_empty_self(html, "div", tag_content, tag_end + 1)
        val first_child_style = br_style_block_rule_for_first_child_self(html, "div", tag_content, div_index == 0)
        val last_child_style = br_style_block_rule_for_last_child_self(html, "div", tag_content, div_count > 0 and div_index == div_count - 1)
        val only_child_style = br_style_block_rule_for_only_child_self(html, "div", tag_content, div_count == 1 and div_index == 0)
        val nth_child_style = br_style_block_rule_for_nth_child_self(html, "div", tag_content, div_index + 1)
        val matched_style = br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(universal_style, tag_style), class_style), compound_class_style), multi_class_style), id_style), tag_id_style), body_child_style), descendant_style), ancestor_child_style), adjacent_sibling_style), general_sibling_style), attr_style), empty_style), first_child_style), last_child_style), only_child_style), nth_child_style), has_style), not_style)
        val style = br_merge_style_text(matched_style, inline_style)
        val block_w = br_style_px_or_default(style, "width", width - margin * 2)
        var text_val = br_div_fallback_text(html, tag_end + 1)
        val before_text = br_pseudo_content_text(html, "div", class_value, id_value, "before")
        val after_text = br_pseudo_content_text(html, "div", class_value, id_value, "after")
        text_val = before_text + text_val + after_text
        var block_h = br_style_px_or_default(style, "height", 0)
        val text_style = br_merge_style_text(style, br_first_span_style_before_div_close(html, tag_end + 1, tag_content))
        val font_size = br_style_px_or_default(text_style, "font-size", br_body_font_size_px(html))
        val has_ellipsis = br_style_property_value(style, "text-overflow") == "ellipsis"
        val has_wrap = br_should_wrap_text(style)
        var line_count = 1
        if text_val.len() > 0 and has_wrap and not has_ellipsis:
            val wrapped = br_fallback_wrap_lines(text_val, block_w, font_size)
            line_count = wrapped.len()
        if block_h <= 0 and text_val.len() > 0:
            block_h = (font_size + 4) * line_count
        val block_bg = br_style_background_argb(html, style)
        if block_w > 0 and block_h > 0 and block_bg != 0x00000000u32:
            pixels = br_fill_rect(pixels, width, height, margin, cursor_y, block_w, block_h, block_bg)
        if text_val.len() > 0:
            val text_color = br_style_color_argb(html, text_style, br_body_color_argb(html))
            if has_ellipsis:
                val truncated = br_apply_text_overflow_ellipsis(text_val, block_w, font_size)
                pixels = br_draw_block_text(pixels, width, height, margin, cursor_y, truncated, text_color, font_size)
            else if has_wrap:
                val lines = br_fallback_wrap_lines(text_val, block_w, font_size)
                var li = 0
                while li < lines.len():
                    val line = lines[li]
                    val line_y = cursor_y + li * (font_size + 4)
                    pixels = br_draw_block_text(pixels, width, height, margin, line_y, line, text_color, font_size)
                    li = li + 1
            else:
                pixels = br_draw_block_text(pixels, width, height, margin, cursor_y, text_val, text_color, font_size)
        if block_h > 0:
            cursor_y = cursor_y + block_h
        div_index = div_index + 1
        search_pos = tag_end + 1
    pixels

# =========================================================================
# Helpers
# =========================================================================

fn br_count_fallback_divs(lower_html: text) -> i32:
    var count = 0
    var search_pos: i64 = 0
    while search_pos < lower_html.len():
        val div_pos = br_find_str(lower_html, "<div", search_pos)
        if div_pos >= 999999999:
            return count
        count = count + 1
        search_pos = div_pos + 4
    count

fn br_char_advance_px(font_size: i32) -> i32:
    if font_size <= 8:
        return 5
    8

fn br_strip_css_quoted_string(value: text) -> text:
    val trimmed = value.trim()
    if trimmed.len() < 2:
        return ""
    val first = trimmed.char_at(0)
    val last = trimmed.char_at(trimmed.len() - 1)
    if (first == "\"" and last == "\"") or (first == "'" and last == "'"):
        return trimmed.slice(1, trimmed.len() - 1)
    ""

fn br_pseudo_content_text(html: text, tag: text, class_value: text, id_value: text, position: text) -> text:
    var merged = ""
    val tag_sel = tag + "::" + position
    val tag_rule = br_style_block_rule_for_selector(html, tag_sel)
    if tag_rule.len() > 0:
        merged = br_merge_style_text(merged, tag_rule)
    if class_value.len() > 0:
        val cls_sel = "." + class_value + "::" + position
        val cls_rule = br_style_block_rule_for_selector(html, cls_sel)
        if cls_rule.len() > 0:
            merged = br_merge_style_text(merged, cls_rule)
        val tc_sel = tag + "." + class_value + "::" + position
        val tc_rule = br_style_block_rule_for_selector(html, tc_sel)
        if tc_rule.len() > 0:
            merged = br_merge_style_text(merged, tc_rule)
    if id_value.len() > 0:
        val id_sel = "#" + id_value + "::" + position
        val id_rule = br_style_block_rule_for_selector(html, id_sel)
        if id_rule.len() > 0:
            merged = br_merge_style_text(merged, id_rule)
    if merged.len() == 0:
        return ""
    val content_val = br_style_property_value(merged, "content")
    if content_val.len() == 0 or content_val == "none":
        return ""
    br_strip_css_quoted_string(content_val)

fn br_apply_text_overflow_ellipsis(text_val: text, block_w: i32, font_size: i32) -> text:
    val adv = br_char_advance_px(font_size)
    val max_chars = block_w / adv
    if max_chars <= 3:
        return "..."
    if text_val.len() > max_chars:
        return text_val.slice(0, max_chars - 3) + "..."
    text_val

fn br_should_wrap_text(style: text) -> bool:
    val wb = br_style_property_value(style, "word-break")
    if wb == "break-all":
        return true
    val ow = br_style_property_value(style, "overflow-wrap")
    ow == "break-word"

fn br_draw_block_text(pixels: [u32], width: i32, height: i32, x: i32, y: i32, text_val: text, color: u32, font_size: i32) -> [u32]:
    val adv = br_char_advance_px(font_size)
    val glyph_h = font_size
    var out = pixels
    var cx = x
    var ci: i64 = 0
    while ci < text_val.len():
        val glyph_w = adv - 1
        if glyph_w > 0 and glyph_h > 0:
            out = br_fill_rect(out, width, height, cx, y, glyph_w, glyph_h, color)
        cx = cx + adv
        ci = ci + 1
    out

fn br_fallback_wrap_lines(text_val: text, block_w: i32, font_size: i32) -> [text]:
    val adv = br_char_advance_px(font_size)
    if adv <= 0 or block_w <= 0:
        return [text_val]
    val chars_per_line = block_w / adv
    if chars_per_line <= 0:
        return [text_val]
    if text_val.len() <= chars_per_line:
        return [text_val]
    var lines: [text] = []
    var pos: i64 = 0
    while pos < text_val.len():
        var end = pos + chars_per_line
        if end > text_val.len():
            end = text_val.len()
        lines.push(text_val.slice(pos, end))
        pos = end
    lines

# =========================================================================
# Body style helpers
# =========================================================================

fn br_body_background_argb_or_default(html: text, fallback: u32) -> u32:
    val body_style = br_combined_body_style(html)
    val bg = br_style_background_argb(html, body_style)
    if bg != 0x00000000u32:
        return bg
    fallback

fn br_body_margin_px(html: text) -> i32:
    val body_style = br_combined_body_style(html)
    val margin = br_style_px_or_default(body_style, "margin", 8)
    if margin < 0:
        return 0
    margin

fn br_body_color_argb(html: text) -> u32:
    br_style_color_argb(html, br_combined_body_style(html), 0xFF000000u32)

fn br_body_font_size_px(html: text) -> i32:
    br_style_px_or_default(br_combined_body_style(html), "font-size", 16)

fn br_combined_body_style(html: text) -> text:
    br_merge_style_text(br_style_block_rule_for_tag(html, "body"), br_first_tag_attr_value(html, "body", "style"))

# =========================================================================
# HTML attribute / style parsing helpers
# =========================================================================

fn br_first_tag_attr_value(html: text, tag: text, attr: text) -> text:
    val lower = html.lower()
    val pos = br_find_str(lower, "<" + tag, 0)
    if pos >= 999999999:
        return ""
    val tag_end = browser_renderer_find_char(html, ">", pos)
    if tag_end >= 999999999:
        return ""
    br_tag_attr_value(html.slice(pos + 1, tag_end), attr)

fn br_div_direct_text(html: text, content_start: i64) -> text:
    val lower = html.lower()
    val close_pos = br_find_str(lower, "</div", content_start)
    if close_pos >= 999999999:
        return ""
    val raw = html.slice(content_start, close_pos)
    if raw.contains("<"):
        return ""
    raw.trim()

fn br_div_fallback_text(html: text, content_start: i64) -> text:
    val direct = br_div_direct_text(html, content_start)
    if direct.len() > 0:
        return direct
    br_first_span_text_before_div_close(html, content_start)

fn br_first_span_text_before_div_close(html: text, content_start: i64) -> text:
    val span_bounds = br_first_span_bounds_before_div_close(html, content_start)
    val span_open_end = span_bounds.0
    val span_close = span_bounds.1
    if span_open_end < 0 or span_close < 0:
        return ""
    val raw = html.slice(span_open_end + 1, span_close)
    if raw.contains("<"):
        return ""
    raw.trim()

fn br_first_span_style_before_div_close(html: text, content_start: i64, parent_tag_content: text) -> text:
    val span_bounds = br_first_span_bounds_before_div_close(html, content_start)
    val span_open = span_bounds.2
    val span_open_end = span_bounds.0
    if span_open < 0 or span_open_end < 0:
        return ""
    val tag_content = html.slice(span_open + 1, span_open_end)
    val inline_style = br_tag_attr_value(tag_content, "style")
    val tag_style = br_style_block_rule_for_tag(html, "span")
    val class_value = br_tag_attr_value(tag_content, "class")
    val class_style = br_style_block_rule_for_class(html, class_value)
    val compound_class_style = br_style_block_rule_for_tag_class(html, "span", class_value)
    val multi_class_style = br_style_block_rule_for_multi_class(html, class_value)
    val id_value = br_tag_attr_value(tag_content, "id")
    val id_style = br_style_block_rule_for_id(html, id_value)
    val tag_id_style = br_style_block_rule_for_tag_id(html, "span", id_value)
    val attr_style = br_style_block_rule_for_attr_self(html, "span", tag_content)
    val descendant_style = br_span_descendant_style(html, parent_tag_content)
    br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(br_merge_style_text(tag_style, class_style), compound_class_style), multi_class_style), descendant_style), id_style), tag_id_style), attr_style), inline_style)

fn br_span_descendant_style(html: text, parent_tag_content: text) -> text:
    var out = br_style_block_rule_for_descendant(html, "div", "span")
    out = br_merge_style_text(out, br_style_block_rule_for_child(html, "div", "span"))
    val parent_class = br_tag_attr_value(parent_tag_content, "class")
    val classes = browser_renderer_split_spaces(parent_class)
    var idx = 0
    while idx < classes.len():
        out = br_merge_style_text(out, br_style_block_rule_for_descendant(html, "." + classes[idx], "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_descendant(html, "div." + classes[idx], "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_child(html, "." + classes[idx], "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_child(html, "div." + classes[idx], "span"))
        idx = idx + 1
    val parent_id = br_tag_attr_value(parent_tag_content, "id").trim()
    if parent_id.len() > 0:
        out = br_merge_style_text(out, br_style_block_rule_for_descendant(html, "#" + parent_id, "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_descendant(html, "div#" + parent_id, "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_child(html, "#" + parent_id, "span"))
        out = br_merge_style_text(out, br_style_block_rule_for_child(html, "div#" + parent_id, "span"))
    out

fn br_first_span_bounds_before_div_close(html: text, content_start: i64) -> (i64, i64, i64):
    val lower = html.lower()
    val div_close = br_find_str(lower, "</div", content_start)
    if div_close >= 999999999:
        return (-1, -1, -1)
    val span_open = br_find_str(lower, "<span", content_start)
    if span_open >= div_close:
        return (-1, -1, -1)
    val span_open_end = browser_renderer_find_char(html, ">", span_open)
    if span_open_end >= 999999999 or span_open_end >= div_close:
        return (-1, -1, -1)
    val span_close = br_find_str(lower, "</span", span_open_end + 1)
    if span_close >= div_close:
        return (-1, -1, -1)
    (span_open_end, span_close, span_open)
