"""
# ScriptHost

Top-level Simple-script integration host for the browser engine (M15).
Owns ConsoleBuffer, EventLoop, and ScriptRunner; exposes execute/tick/inject_dom_event surface.

Replaces the JS engine approach — instead reuses the Simple compiler/interpreter
to run <script> tag content as Simple language code.
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, BeDomEvent}
use std.gc_async_mut.gpu.browser_engine.script.console_buffer.{ConsoleBuffer}
use std.gc_async_mut.gpu.browser_engine.script.event_loop.{EventLoop}
use std.gc_async_mut.gpu.browser_engine.script.script_runner.{ScriptRunner, run_script, run_script_file, script_runner_dom_dirty, script_runner_clear_dirty}
use std.gc_async_mut.gpu.browser_engine.script.event_api.{event_dispatch}
use std.gc_async_mut.gpu.browser_engine.net.fetch_dispatch.{FetchDispatch}
use std.gc_async_mut.gpu.browser_engine.script.network_api.{ScriptFetchRequest,
    ScriptFetchResponse, fetch_send, script_fetch_to_net_request,
    script_response_from_net}
use std.gc_async_mut.gpu.browser_engine.script.dom_api.{node_set_text_content,
    node_class_list_add, node_class_list_remove, node_class_list_contains}

pub fn script_host_apply_event_action(node: BeDomNode, action: text) -> BeDomNode:
    """Apply one deterministic listener action to the target DOM node."""
    if action.starts_with("set-text:"):
        return node_set_text_content(node, action.substring(9, action.len()))
    if action.starts_with("set-attr:"):
        val payload = action.substring(9, action.len())
        val separator = payload.index_of("=")
        if separator >= 0:
            var next = node
            next.set_attr(payload.substring(0, separator), payload.substring(separator + 1, payload.len()))
            return next
        return node
    if action.starts_with("remove-attr:"):
        var next = node
        next.remove_attr(action.substring(12, action.len()))
        return next
    if action.starts_with("add-class:"):
        return node_class_list_add(node, action.substring(10, action.len()))
    if action.starts_with("remove-class:"):
        return node_class_list_remove(node, action.substring(13, action.len()))
    if action.starts_with("toggle-class:"):
        val cls = action.substring(13, action.len())
        if node_class_list_contains(node, cls):
            return node_class_list_remove(node, cls)
        return node_class_list_add(node, cls)
    node

pub class ScriptHost:
    """Host that manages Simple-script execution, event loop, and console buffer.

    Fields:
        _dom_root      - current DOM root (updated on execute)
        _event_loop    - macrotask/rAF queue
        _console_buf   - bounded console.log ring buffer
        _dom_dirty     - true if scripts have mutated the DOM since last clear
        _runner        - ScriptRunner that executes Simple code
        fetch_dispatch - optional FetchDispatch for fetch() API (D-4)
    """
    _dom_root: BeDomNode
    _event_loop: EventLoop
    _console_buf: ConsoleBuffer
    _dom_dirty: bool
    _runner: ScriptRunner
    fetch_dispatch: FetchDispatch?

    static fn new() -> ScriptHost:
        """Create a ScriptHost with an empty div root."""
        ScriptHost(
            _dom_root: BeDomNode.element("div"),
            _event_loop: EventLoop.new(),
            _console_buf: ConsoleBuffer.new(),
            _dom_dirty: false,
            _runner: ScriptRunner.new(),
            fetch_dispatch: nil
        )

    me execute(source: text, dom_root: BeDomNode):
        """Parse and run a Simple script block against dom_root.

        Stores dom_root as the current root. Delegates to ScriptRunner
        which wraps source with imports and calls rt_process_run.
        Console stdout is captured into the host's console buffer.
        """
        self._dom_root = dom_root
        if source.trim().len() == 0:
            return
        self._runner.dom_root = dom_root
        self._runner.console_buffer = self._console_buf
        self._runner.event_loop = self._event_loop
        val stdout = run_script(self._runner, source)
        if stdout.len() > 0:
            self._console_buf.append("log", stdout, 0)
        self._dom_dirty = true

    me execute_file(path: text, dom_root: BeDomNode):
        """Execute a Simple script file (for <script src="...">)."""
        self._dom_root = dom_root
        self._runner.dom_root = dom_root
        self._runner.console_buffer = self._console_buf
        self._runner.event_loop = self._event_loop
        val stdout = run_script_file(self._runner, path)
        if stdout.len() > 0:
            self._console_buf.append("log", stdout, 0)
        self._dom_dirty = true

    me tick(now_micros: i64):
        """Fire expired timers, drain microtasks, flush rAF callbacks.

        Drains expired timers and rAF slots from the event loop.
        Callback execution is logged but not dispatched (no callback registry yet).
        """
        val fired_timers = self._event_loop.drain_expired(now_micros)
        val fired_rafs = self._event_loop.drain_raf()
        if fired_timers.len() > 0 or fired_rafs.len() > 0:
            self._dom_dirty = true

    me inject_dom_event(event: BeDomEvent):
        """Dispatch a DOM event into registered event listeners.

        Collects triggered action strings from target-phase dispatch.
        """
        val actions = event_dispatch(self._dom_root, event)
        for action in actions:
            self._dom_root = script_host_apply_event_action(self._dom_root, action)
        if actions.len() == 0:
            return
        self._dom_dirty = true

    me dom_root() -> BeDomNode:
        """Return the current (possibly script-mutated) DOM root."""
        self._dom_root

    me dom_dirty() -> bool:
        """True if scripts have mutated the DOM since last clear_dirty."""
        self._dom_dirty

    me clear_dirty():
        """Reset the dom_dirty flag."""
        self._dom_dirty = false

    me console_buffer() -> ConsoleBuffer:
        """Read-only access to the console log buffer."""
        self._console_buf

    me event_loop() -> EventLoop:
        """Access to the event loop for timer inspection."""
        self._event_loop

    me runner() -> ScriptRunner:
        """Access to the underlying ScriptRunner."""
        self._runner

    me set_fetch_dispatch(d: FetchDispatch):
        """Wire a FetchDispatch implementation for fetch() calls (D-4)."""
        self.fetch_dispatch = Some(d)

    me fetch(request: ScriptFetchRequest) -> ScriptFetchResponse:
        """Dispatch a fetch request or return the fail-closed zero response."""
        if val dispatch = self.fetch_dispatch:
            return script_response_from_net(dispatch.dispatch(script_fetch_to_net_request(request)))
        fetch_send(request)
