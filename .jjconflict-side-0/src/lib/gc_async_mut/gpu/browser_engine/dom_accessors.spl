use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, StyleProps}

fn be_dom_add_child(mut parent: BeDomNode, child: BeDomNode):
    """Append a child node to parent.children and set child.parent_id."""
    var c = child
    c.parent_id = parent.node_id
    parent.children.push(c)

fn be_dom_get_children(node: BeDomNode) -> [BeDomNode]:
    """Return the direct children of a node."""
    node.children

fn be_dom_remove_child(mut parent: BeDomNode, child_id: i64):
    """Remove the first child with the given node_id from parent.children."""
    val kept_count = be_dom_child_count_except(parent, child_id)
    if kept_count == 0:
        parent.children = []
        return
    var new_children: [BeDomNode] = [parent.children[0]; kept_count]
    var i = 0
    var out_idx = 0
    val child_count = parent.children.len()
    while i < child_count:
        val child = parent.children[i]
        if child.node_id != child_id:
            new_children[out_idx] = child
            out_idx = out_idx + 1
        i = i + 1
    parent.children = new_children

fn be_dom_child_count_except(parent: BeDomNode, child_id: i64) -> i32:
    var count = 0
    var i = 0
    val child_count = parent.children.len()
    while i < child_count:
        if parent.children[i].node_id != child_id:
            count = count + 1
        i = i + 1
    count

fn be_dom_insert_before(mut parent: BeDomNode, new_child: BeDomNode, ref_id: i64):
    """Insert new_child immediately before the child with ref_id."""
    val child_count = parent.children.len()
    val output_count = child_count + 1
    var new_children: [BeDomNode] = [new_child; output_count]
    var inserted = false
    var i = 0
    var out_idx = 0
    var nc = new_child
    nc.parent_id = parent.node_id
    while i < child_count:
        if parent.children[i].node_id == ref_id:
            new_children[out_idx] = nc
            out_idx = out_idx + 1
            inserted = true
        new_children[out_idx] = parent.children[i]
        out_idx = out_idx + 1
        i = i + 1
    if not inserted:
        new_children[out_idx] = nc
    parent.children = new_children

fn be_dom_set_attr(mut node: BeDomNode, name: text, value: text):
    """Set an attribute on a node."""
    node.attributes[name] = value

fn be_dom_get_attr(node: BeDomNode, name: text) -> text:
    """Get an attribute value, returning "" if absent."""
    node.attributes.get(name) ?? ""

fn be_dom_set_style(mut node: BeDomNode, style: StyleProps):
    """Replace the node's inline style."""
    node.style = style

fn be_dom_get_style(node: BeDomNode) -> StyleProps:
    """Return the node's current inline style."""
    node.style

fn be_dom_set_text_content(mut node: BeDomNode, text_content: text):
    """Set the text content of a node (clears children, sets data)."""
    node.children = []
    node.data = text_content

fn be_dom_get_text_content(node: BeDomNode) -> text:
    """Return the text content: data for text nodes, or concatenated child text."""
    if node.is_text():
        return node.data
    val child_count = node.children.len()
    if child_count == 0:
        return ""
    var parts: [text] = [""; child_count]
    var i = 0
    while i < child_count:
        parts[i] = be_dom_get_text_content(node.children[i])
        i = i + 1
    parts.join("")

fn be_dom_find_by_id(root: BeDomNode, node_id: i64) -> BeDomNode?:
    """DFS search for a node with the given node_id."""
    if root.node_id == node_id:
        return Some(root)
    var i = 0
    val child_count = root.children.len()
    while i < child_count:
        val found = be_dom_find_by_id(root.children[i], node_id)
        if found != nil:
            return found
        i = i + 1
    nil

fn be_dom_find_by_tag(root: BeDomNode, tag_name: text) -> [BeDomNode]:
    """Collect all descendant nodes with the given tag name."""
    val result_count = be_dom_count_by_tag(root, tag_name)
    if result_count == 0:
        return []
    var result: [BeDomNode] = [root; result_count]
    var out_idx = 0
    if root.tag_name == tag_name:
        result[out_idx] = root
        out_idx = out_idx + 1
    var i = 0
    val child_count = root.children.len()
    while i < child_count:
        val children_found = be_dom_find_by_tag(root.children[i], tag_name)
        var j = 0
        val found_count = children_found.len()
        while j < found_count:
            result[out_idx] = children_found[j]
            out_idx = out_idx + 1
            j = j + 1
        i = i + 1
    result

fn be_dom_count_by_tag(root: BeDomNode, tag_name: text) -> i32:
    var count = 0
    if root.tag_name == tag_name:
        count = count + 1
    var i = 0
    val child_count = root.children.len()
    while i < child_count:
        count = count + be_dom_count_by_tag(root.children[i], tag_name)
        i = i + 1
    count

fn be_dom_get_tag(node: BeDomNode) -> text:
    node.tag_name

fn be_dom_get_id(node: BeDomNode) -> text:
    node.attributes.get("id") ?? ""

fn be_dom_get_display(node: BeDomNode) -> text:
    if node.style.display == "":
        return "block"
    node.style.display

fn be_dom_get_classes(node: BeDomNode) -> [text]:
    val class_text = node.attributes.get("class") ?? ""
    if class_text == "":
        return []
    class_text.split(" ")

fn be_dom_has_attr(node: BeDomNode, name: text) -> bool:
    node.attributes.has(name)

fn be_dom_get_visibility(node: BeDomNode) -> text:
    "visible"

fn be_dom_get_bg_color(node: BeDomNode) -> text:
    node.style.background_color

fn be_dom_get_opacity(node: BeDomNode) -> f64:
    1.0

fn be_dom_get_border_radius(node: BeDomNode) -> f64:
    0.0

fn be_dom_get_padding_left(node: BeDomNode) -> f64:
    node.style.padding_left

fn be_dom_get_padding_top(node: BeDomNode) -> f64:
    node.style.padding_top

fn be_dom_get_padding_h(node: BeDomNode) -> f64:
    node.style.padding_left + node.style.padding_right

fn be_dom_get_padding_v(node: BeDomNode) -> f64:
    node.style.padding_top + node.style.padding_bottom

fn be_dom_get_box_shadows(node: BeDomNode) -> [text]:
    []

fn be_dom_get_backdrop_blur(node: BeDomNode) -> f64:
    0.0

fn be_dom_get_has_gradient(node: BeDomNode) -> bool:
    false

fn be_dom_get_gradient_c1(node: BeDomNode) -> text:
    node.style.background_color

fn be_dom_get_gradient_c2(node: BeDomNode) -> text:
    node.style.background_color

fn be_dom_get_border_width(node: BeDomNode) -> f64:
    node.style.border_width

fn be_dom_get_border_color(node: BeDomNode) -> text:
    node.style.border_color

fn be_dom_get_border_style(node: BeDomNode) -> text:
    node.style.border_style

fn be_dom_get_color(node: BeDomNode) -> text:
    node.style.color

fn be_dom_get_font_size(node: BeDomNode) -> f64:
    node.style.font_size

fn be_dom_get_text_decoration(node: BeDomNode) -> text:
    "none"

fn be_dom_query_selector(node: BeDomNode, selector: text) -> BeDomNode?:
    if selector.starts_with("#") and be_dom_get_id(node) == selector.substring(1, selector.len()):
        return Some(node)
    if node.tag_name == selector:
        return Some(node)
    for child in node.children:
        val found = be_dom_query_selector(child, selector)
        if found.?:
            return found
    nil

fn be_dom_dispatch_event_actions(node: BeDomNode, event_type: text) -> [text]:
    val normalized = event_type.trim().lower()
    var actions: [text] = []
    var i = 0
    while i < node.event_listener_types.len():
        if node.event_listener_types[i] == normalized:
            actions.push(node.event_listener_actions[i])
        i = i + 1
    actions

fn be_dom_get_is_text(node: BeDomNode) -> bool:
    node.tag_name == "#text"

fn be_dom_get_text(node: BeDomNode) -> text:
    node.data

fn be_dom_set_children(node: BeDomNode, children: [BeDomNode]) -> BeDomNode:
    BeDomNode(
        node_id: node.node_id,
        tag_name: node.tag_name,
        attributes: node.attributes,
        style: node.style,
        children: children,
        data: node.data,
        parent_id: node.parent_id,
        event_listener_types: node.event_listener_types,
        event_listener_actions: node.event_listener_actions,
        event_listener_capture: node.event_listener_capture)

export be_dom_add_child, be_dom_get_children, be_dom_remove_child, be_dom_insert_before
export be_dom_set_attr, be_dom_get_attr, be_dom_set_style, be_dom_get_style
export be_dom_set_text_content, be_dom_get_text_content
export be_dom_find_by_id, be_dom_find_by_tag
export be_dom_get_tag, be_dom_get_is_text, be_dom_get_text, be_dom_set_children
export be_dom_get_id, be_dom_get_display, be_dom_get_classes
export be_dom_has_attr, be_dom_get_visibility, be_dom_get_bg_color
export be_dom_get_opacity
export be_dom_get_border_radius
export be_dom_get_padding_left, be_dom_get_padding_top
export be_dom_get_padding_h, be_dom_get_padding_v
export be_dom_get_box_shadows, be_dom_get_backdrop_blur
export be_dom_get_has_gradient, be_dom_get_gradient_c1, be_dom_get_gradient_c2
export be_dom_get_border_width, be_dom_get_border_color, be_dom_get_border_style
export be_dom_get_color, be_dom_get_font_size, be_dom_get_text_decoration
export be_dom_query_selector, be_dom_dispatch_event_actions
