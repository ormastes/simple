# Simple Web Renderer
#
# Canonical Simple Web facade over the browser engine pipeline.  Callers use
# this module instead of depending directly on host DOM or SimpleOS framebuffer
# details:
#
#   app/widget/html -> browser engine -> RenderScene -> pixels/Engine2D backend

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer, BeRenderResult}
use common.render_scene.scene.{RenderScene}

class SimpleWebRenderResult:
    format: text
    width: i32
    height: i32
    pixels: [u32]
    scene: RenderScene
    warnings: [text]

class SimpleWebRenderer:
    width: i32
    height: i32
    backend_name: text
    browser: BrowserRenderer

    static fn create(width: i32, height: i32) -> SimpleWebRenderer:
        SimpleWebRenderer(
            width: width,
            height: height,
            backend_name: "software",
            browser: BrowserRenderer.create(width, height)
        )

    static fn create_with_backend(width: i32, height: i32, backend_name: text) -> SimpleWebRenderer:
        SimpleWebRenderer(
            width: width,
            height: height,
            backend_name: backend_name,
            browser: BrowserRenderer.create_with_backend(width, height, backend_name)
        )

    me resize(width: i32, height: i32):
        self.width = width
        self.height = height
        self.browser.resize(width, height)

    me render_html_to_scene(html: text) -> RenderScene:
        self.browser.render_html(html).to_scene()

    me render_html_to_pixels(html: text) -> [u32]:
        self.browser.render_html_to_pixels(html).pixel_data

    me render_url_to_pixels(url: text) -> [u32]:
        self.render_html_to_pixels(simple_web_default_page_html(url))

fn simple_web_renderer_create(width: i32, height: i32) -> SimpleWebRenderer:
    SimpleWebRenderer.create(width, height)

fn simple_web_render_html_to_scene(html: text, width: i32, height: i32) -> RenderScene:
    val renderer = SimpleWebRenderer.create(width, height)
    renderer.render_html_to_scene(html)

fn simple_web_render_html_to_pixels(html: text, width: i32, height: i32) -> [u32]:
    val renderer = SimpleWebRenderer.create(width, height)
    renderer.render_html_to_pixels(html)

fn simple_web_render_url_to_pixels(url: text, width: i32, height: i32) -> [u32]:
    val renderer = SimpleWebRenderer.create(width, height)
    renderer.render_url_to_pixels(url)

fn simple_web_default_page_html(url: text) -> text:
    var label = url
    if label.len() == 0:
        label = "about:blank"
    "<html><body style='margin:0; background-color:#101820; color:#f3f4f6;'><div style='height:28px; background-color:#2050a0; color:#ffffff;'> {label}</div><div style='height:96px; background-color:#182230; color:#44ff44;'> Simple Web Renderer</div><div style='height:96px; background-color:#1f2937; color:#e0e0f0;'> RenderScene + Engine2D ready</div></body></html>"
