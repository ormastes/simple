"""
# Fetch Request and Response Types

Entity types for the Fetch API: FetchRequest, FetchResponse, RequestMode.
FetchResponse.body is [u8] throughout; decode to text via body_text() at the
parse boundary.
"""

#![allow(REQC001)]

use std.gc_async_mut.gpu.browser_engine.net.entity.url_types.{Url}

extern fn rt_bytes_to_text(data: [u8]) -> text

pub enum HttpMethod:
    """Standard HTTP methods."""
    Get
    Post
    Put
    Delete
    Head
    Options
    Patch

pub enum RequestMode:
    """CORS mode for a fetch request."""
    Navigate
    SameOrigin
    NoCors
    Cors

pub class FetchRequest:
    """An HTTP fetch request with method, URL, headers, body, and CORS mode.

    Fields:
        method      - HTTP method string (GET, POST, PUT, etc.)
        url         - parsed target URL
        headers     - raw HTTP headers string
        body        - request body bytes
        mode        - CORS mode
        credentials - credentials mode string (omit, same-origin, include)
    """
    method: text
    url: Url
    headers: text
    body: [u8]
    mode: RequestMode
    credentials: text

pub class FetchResponse:
    """An HTTP fetch response with status, headers, and binary-safe body.

    Fields:
        status  - HTTP status code (0 = no network / noop)
        headers - raw response headers string
        body    - response body as raw bytes ([u8]); decode via body_text()
    """
    status: i64
    headers: text
    body: [u8]

    me fn body_text() -> text:
        """Decode the body bytes to text at this explicit boundary."""
        if self.body.len() == 0:
            return ""
        return rt_bytes_to_text(self.body)
