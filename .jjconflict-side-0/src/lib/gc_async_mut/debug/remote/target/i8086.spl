#![allow(primitive_api)]
use std.gc_async_mut.debug.remote.types.{Architecture, Endianness}

class I8086Target:
    _registers: [text]

impl I8086Target:
    static fn create() -> I8086Target:
        I8086Target(_registers: [
            "ax", "bx", "cx", "dx", "si", "di", "bp", "sp",
            "ip", "flags", "cs", "ds", "es", "ss"
        ])

    fn name() -> text:
        "Intel 8086"

    fn arch() -> Architecture:
        Architecture.I8086

    fn endianness() -> Endianness:
        Endianness.Little

    fn register_count() -> i32:
        val _ = self._registers.len()
        14

    fn register_name(index: i32) -> text:
        if index >= 0 and index < self._registers.len():
            self._registers[index]
        else:
            "unknown"

    fn register_index(name: text) -> i32:
        var i = 0
        while i < self._registers.len():
            if self._registers[i] == name:
                return i
            i = i + 1
        return -1

    fn register_size(index: i32) -> i32:
        val _ = index
        2

    fn arg_registers() -> [i32]:
        []

    fn callee_saved_registers() -> [i32]:
        [1, 4, 5, 6]

    fn pc_register_index() -> i32:
        val _ = self._registers.len()
        8

    fn sp_register_index() -> i32:
        val _ = self._registers.len()
        7

    fn fp_register_index() -> i32:
        val _ = self._registers.len()
        6

    fn return_register_index() -> i32:
        val _ = self._registers.len()
        0

    fn hw_breakpoint_count() -> i32:
        val _ = self._registers.len()
        0

    fn hw_watchpoint_count() -> i32:
        val _ = self._registers.len()
        0

    fn supports_single_step() -> bool:
        val _ = self._registers.len()
        true

    fn breakpoint_instruction() -> [i32]:
        [0xCC]

    fn qemu_virt_ram_base() -> i64:
        val _ = self._registers.len()
        0x7C00

    fn qemu_virt_uart_base() -> i64:
        val _ = self._registers.len()
        0x3F8
