@allow(unnamed_duplicate_typed_args) # reason: positional API -- arg order is conventional
# GPU Memory Management API — hub module
#
# High-level GPU memory management for Simple language.
# SFFI pattern:
#   CUDA runtime hooks (owned by the no-GC backend SFFI layer)
#   fn cuda_* (low-level wrappers in gpu_sffi.spl)
#   GpuPtr, gpu_init, gpu_alloc, etc. (gpu_types.spl + gpu_ops.spl)
#
# Provides safe GPU memory management with automatic error checking.

use gc_async_mut.gpu_sffi.{
    cuda_init,
    cuda_device_get,
    cuda_device_count,
    cuda_device_name,
    cuda_device_compute_capability,
    cuda_ctx_create,
    cuda_ctx_destroy,
    cuda_ctx_synchronize,
    cuda_mem_alloc,
    cuda_mem_free,
    cuda_memcpy_htod,
    cuda_memcpy_dtoh,
    cuda_memcpy_dtod,
    cuda_memset,
    cuda_module_load,
    cuda_module_load_data,
    cuda_module_unload,
    cuda_launch_kernel,
    cuda_sync,
    cuda_get_error_string
}
use gc_async_mut.gpu_types.{
    GpuError,
    GpuDevice,
    GpuContext,
    GpuPtr,
    GpuModule,
    GpuLaunchConfig,
    GpuBuffer
}
use gc_async_mut.gpu_ops.{
    gpu_init,
    gpu_alloc,
    gpu_free,
    gpu_upload,
    gpu_download,
    gpu_memset,
    gpu_launch,
    gpu_sync,
    gpu_device_name,
    gpu_device_compute_capability,
    gpu_device_total_memory,
    gpu_set_device,
    gpu_device_count,
    gpu_upload_f32,
    gpu_download_f32,
    gpu_upload_i32,
    gpu_upload_i64,
    gpu_upload_f64,
    gpu_download_i32,
    gpu_download_i64,
    gpu_download_f64,
    gpu_alloc_f32,
    gpu_alloc_i32,
    gpu_alloc_i64,
    gpu_alloc_f64,
    gpu_memset_f32,
    gpu_memset_i32,
    gpu_copy_f32,
    gpu_copy_i32,
    gpu_copy,
    gpu_block_id_x,
    gpu_block_id_y,
    gpu_block_id_z,
    gpu_block_dim_x,
    gpu_block_dim_y,
    gpu_block_dim_z,
    gpu_local_id_x,
    gpu_local_id_y,
    gpu_local_id_z,
    gpu_thread_id_x,
    gpu_thread_id_y,
    gpu_thread_id_z,
    gpu_grid_dim_x,
    gpu_grid_dim_y,
    gpu_grid_dim_z,
    gpu_global_id_x,
    gpu_global_id_y,
    gpu_global_id_z,
    gpu_syncthreads,
    gpu_barrier,
    gpu_load_f32,
    gpu_store_f32,
    gpu_atomic_add_i64,
    gpu_atomic_add_i32,
    gpu_atomic_add_f32,
    gpu_atomic_min_i64,
    gpu_atomic_max_i64,
    gpu_atomic_cas_i64,
    gpu_load_f64,
    gpu_store_f64,
    gpu_load_i64,
    gpu_store_i64,
    gpu_load_i32,
    gpu_store_i32,
    gpu_shared_array_f32,
    gpu_shared_store_f32,
    gpu_shared_load_f32,
    gpu_shared_array_i32,
    gpu_shared_store_i32,
    gpu_shared_load_i32,
    gpu_gemm,
    gpu_dot,
    gpu_axpy,
    gpu_map,
    gpu_reduce,
    gpu_scan,
    gpu_filter,
    gpu_sort
}
