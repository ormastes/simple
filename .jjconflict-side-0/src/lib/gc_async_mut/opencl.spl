# OpenCL Module — GC async variant
#
# Re-exports the canonical OpenCL bindings from the no-GC sync layer. OpenCL
# calls are synchronous backend operations; GC async users share the same handle
# API instead of owning duplicate extern declarations.

export use std.nogc_sync_mut.opencl.mod.{
    opencl_available, opencl_platform_count,
    opencl_create_context, opencl_create_queue,
    opencl_create_program, opencl_build_program, opencl_create_kernel,
    opencl_mem_alloc, opencl_mem_free,
    opencl_write_buffer, opencl_read_buffer,
    opencl_set_kernel_arg_i64, opencl_set_kernel_arg_buffer,
    opencl_enqueue_ndrange, opencl_finish,
    opencl_release_kernel, opencl_release_program,
    opencl_release_queue, opencl_release_context
}
