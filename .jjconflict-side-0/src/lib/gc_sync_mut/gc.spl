# GC Re-Export for gc_sync_mut
#
# The full GC implementation lives in nogc_sync_mut/gc.spl (655 lines).
# This module re-exports it so gc_sync_mut code can import GC types directly.
# The module loader fallback chain handles the actual resolution.

use std.gc.{GcHeap, GcConfig, GcStats, GcPtr, GcColor, GcObjectHeader}

# Re-export all GC types — they resolve to nogc_sync_mut/gc.spl via fallback
export GcHeap
export GcConfig
export GcStats
export GcPtr
export GcColor
export GcObjectHeader
