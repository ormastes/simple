# Core JS runtime value types for the Simple Browser JS engine.

enum JsValue:
    Undefined
    Null
    Boolean(v: bool)
    Number(v: f64)
    String(v: text)
    Object(id: i64)
    Array(id: i64)
    Function(id: i64)

class JsProperty:
    key: text
    value: JsValue
    enumerable: bool

class JsObject:
    properties: [JsProperty]
