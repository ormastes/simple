# Web Runtime Adapter — per-connection server-side state and patch emission.
#
# Holds the session_id, reference to the UISession, last ack sequence, and
# the output BoundedChannel. Encodes snapshots and patch batches according to
# the wire protocol defined in doc/04_architecture/ui_web_protocol.md §5-6.

use common.ui.session.{UISession}
use common.ui.snapshot_wire.{encode_snapshot}
use common.ui.patch_wire.{encode_envelope, PatchEnvelope}
use common.ui.patch_stream.{PatchSinceResult}
use app.ui.web.bounded_channel.{BoundedChannel}
use app.ui.web.taskbar_runtime.{host_taskbar_runtime_is_enabled, host_taskbar_runtime_taskbar_frame}

# =========================================================================
# WebRuntimeAdapter
# =========================================================================

class WebRuntimeAdapter:
    session_id: text
    session: UISession
    grant_id: text
    last_ack_sequence: i64
    last_snapshot_revision: u64
    last_taskbar_frame: text
    out: BoundedChannel<text>

    static fn new(session_id: text, session: UISession, grant_id: text, out: BoundedChannel<text>) -> WebRuntimeAdapter:
        return WebRuntimeAdapter(
            session_id: session_id,
            session: session,
            grant_id: grant_id,
            last_ack_sequence: 0,
            last_snapshot_revision: 0,
            last_taskbar_frame: "",
            out: out
        )

impl WebRuntimeAdapter:

    me send_snapshot(self):
        """Emit the initial full snapshot frame."""
        val snap = self.session.access_snapshot()
        val rev = self.session.patch_stream.snapshot_revision
        val payload = encode_snapshot(snap, rev)
        val frame = _make_frame("snapshot", self.session_id, "null", payload)
        self.last_snapshot_revision = rev
        self.out.send(frame)
        self._emit_taskbar_model()

    me emit_patches(self):
        """Encode queued patches and send as patch_batch frame.
        If the snapshot revision has bumped (structural reset) send snapshot instead."""
        val current_rev = self.session.patch_stream.snapshot_revision
        if current_rev != self.last_snapshot_revision:
            self.send_snapshot()
            return
        val snap = self.session.access_snapshot()
        val events = self.session.access_events
        val result = self.session.patch_stream.patches_since(snap, events, self.last_ack_sequence)
        if result.snapshot != nil:
            self.send_snapshot()
            return
        if result.patches.len() == 0:
            self._emit_taskbar_model()
            return
        val from_seq = self.last_ack_sequence + 1
        var to_seq = from_seq
        for _ in result.patches:
            to_seq = to_seq + 1
        to_seq = to_seq - 1
        val envelope = PatchEnvelope(
            session_id: self.session_id,
            snapshot_revision: current_rev,
            from_sequence: from_seq,
            to_sequence: to_seq,
            patches: result.patches
        )
        val env_json = encode_envelope(envelope)
        val seq_str = "{from_seq}"
        val frame = _make_frame("patch_batch", self.session_id, seq_str, env_json)
        self.out.send(frame)
        self._emit_taskbar_model()

    me on_ack(self, last_applied: i64):
        """Update last_ack_sequence from a client ack message."""
        if last_applied > self.last_ack_sequence:
            self.last_ack_sequence = last_applied

    me on_resume(self, revision: u64, last_sequence: i64):
        """Handle resume_session from client.
        Delegates to patch_stream.patches_since; emits snapshot or patch_batch."""
        val snap = self.session.access_snapshot()
        val events = self.session.access_events
        val current_rev = self.session.patch_stream.snapshot_revision
        if revision != current_rev:
            self.send_snapshot()
            return
        val result = self.session.patch_stream.patches_since(snap, events, last_sequence)
        if result.snapshot != nil:
            self.send_snapshot()
            return
        if result.patches.len() == 0:
            self._emit_taskbar_model()
            return
        val from_seq = last_sequence + 1
        var to_seq = from_seq
        for _ in result.patches:
            to_seq = to_seq + 1
        to_seq = to_seq - 1
        val envelope = PatchEnvelope(
            session_id: self.session_id,
            snapshot_revision: current_rev,
            from_sequence: from_seq,
            to_sequence: to_seq,
            patches: result.patches
        )
        val env_json = encode_envelope(envelope)
        val seq_str = "{from_seq}"
        val frame = _make_frame("patch_batch", self.session_id, seq_str, env_json)
        self.out.send(frame)
        self.last_ack_sequence = last_sequence
        self._emit_taskbar_model()

    me close(self, reason: text):
        """Send final error frame and mark closed."""
        val esc = _esc(reason)
        val payload = "{\"code\": \"CLOSED\", \"message\": \"{esc}\", \"retry_after_ms\": 0}"
        val frame = _make_frame("error", self.session_id, "null", payload)
        self.out.send(frame)

    me _emit_taskbar_model(self):
        if not host_taskbar_runtime_is_enabled():
            return
        val frame = host_taskbar_runtime_taskbar_frame(self.session_id, self.session)
        if frame == self.last_taskbar_frame:
            return
        self.last_taskbar_frame = frame
        self.out.send(frame)

# =========================================================================
# Private frame builder
# =========================================================================

fn _make_frame(msg_type: text, session_id: text, seq: text, payload: text) -> text:
    """Build the top-level wire envelope: { t, v, s, seq, payload }."""
    return "{\"t\": \"{msg_type}\", \"v\": 1, \"s\": \"{session_id}\", \"seq\": {seq}, \"payload\": {payload}}"

fn _esc(s: text) -> text:
    var r = ""
    var i = 0
    while i < s.len():
        val ch = s[i]
        if ch == "\"":
            r = "{r}\\\""
        elif ch == "\\":
            r = "{r}\\\\"
        elif ch == "\n":
            r = "{r}\\n"
        elif ch == "\r":
            r = "{r}\\r"
        elif ch == "\t":
            r = "{r}\\t"
        else:
            r = "{r}{ch}"
        i = i + 1
    return r
