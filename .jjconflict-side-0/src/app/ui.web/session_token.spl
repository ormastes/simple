# Session Token — HMAC-SHA256-signed bearer tokens for the Web UI.
#
# Token format (URL-safe, dot-separated):
#   <token_id>.<grant_id>.<origin_b64>.<expires_at_ms>.<signature_hex>
#
# HMAC primitive: common.crypto.hmac::hmac_sha256_bytes(key, message)
#   Path: src/lib/common/crypto/hmac.spl
#   hex encoding: common.crypto.types::bytes_to_hex
#
# Secret source: env SIMPLE_UI_WEB_TOKEN_SECRET (required in TLS mode;
#   in plain-TCP dev mode a random-looking secret is derived from startup time
#   and a warning is logged).

use app.ui.web.origin_guard.{AuthError}
use common.crypto.hmac.{hmac_sha256_bytes}
use common.crypto.types.{bytes_to_hex, text_to_bytes}
use common.crypto.constant_time.{constant_time_compare}
use std.io_runtime.{env_get}

extern fn rt_random_hex(len: i64) -> text   # runtime: N CSPRNG bytes hex-encoded (OsRng)
extern fn rt_time_ms() -> u64               # runtime: current epoch milliseconds

fn random_hex(len: i64) -> text:
    """Produce N bytes' worth of cryptographically-secure random hex (2*N chars).
    Backed by the Rust runtime's OsRng (OS CSPRNG)."""
    return session_token_runtime_random_hex(len)

fn auth_time_ms() -> u64:
    return session_token_runtime_time_ms()

fn session_token_runtime_random_hex(len: i64) -> text:
    return rt_random_hex(len)

fn session_token_runtime_time_ms() -> u64:
    return rt_time_ms()

# =========================================================================
# SessionToken
# =========================================================================

val TOKEN_TTL_DEFAULT_MS: u64 = 3600000u64  # 1 hour
export TOKEN_TTL_DEFAULT_MS

class SessionToken:
    token_id: text       # opaque 32-byte random, hex-encoded (64 hex chars)
    grant_id: text       # CapabilityPolicy grant id
    origin: text
    expires_at_ms: u64
    signature: text      # HMAC-SHA256 over (token_id || "." || grant_id || "." || origin || "." || str(expires_at_ms))

    static fn issue(grant_id: text, origin: text, ttl_ms: u64, secret: text) -> SessionToken:
        """Mint a new signed SessionToken."""
        val token_id = random_hex(32)
        val exp = auth_time_ms() + ttl_ms
        val payload = _token_payload(token_id, grant_id, origin, exp)
        val sig = _sign_payload(secret, payload)
        return SessionToken(
            token_id: token_id,
            grant_id: grant_id,
            origin: origin,
            expires_at_ms: exp,
            signature: sig
        )

    fn serialize(self) -> text:
        """Serialize to dot-separated URL-safe string."""
        val origin_enc = _url_encode(self.origin)
        return "{self.token_id}.{self.grant_id}.{origin_enc}.{self.expires_at_ms}.{self.signature}"

    static fn parse(s: text) -> Result<SessionToken, AuthError>:
        """Parse a serialized token string."""
        var first = -1
        var second = -1
        var third = -1
        var fourth = -1
        var i = 0
        val s_len = s.len()
        while i < s_len:
            if s.slice(i, i + 1) == ".":
                if first < 0:
                    first = i
                else:
                    if second < 0:
                        second = i
                    else:
                        if third < 0:
                            third = i
                        else:
                            if fourth < 0:
                                fourth = i
                            else:
                                return Err(AuthError.InvalidToken)
            i = i + 1
        if first < 0 or second < 0 or third < 0 or fourth < 0:
            return Err(AuthError.InvalidToken)
        val token_id = s.slice(0, first)
        val grant_id = s.slice(first + 1, second)
        val origin = _url_decode(s.slice(second + 1, third))
        val exp_str = s.slice(third + 1, fourth)
        val sig = s.slice(fourth + 1, s_len)
        if token_id == "" or grant_id == "" or exp_str == "" or sig == "":
            return Err(AuthError.InvalidToken)
        val exp = _parse_u64(exp_str)
        return Ok(SessionToken(
            token_id: token_id,
            grant_id: grant_id,
            origin: origin,
            expires_at_ms: exp,
            signature: sig
        ))

# =========================================================================
# verify — top-level function per contract
# =========================================================================

fn verify(serialized: text, origin: text, secret: text, now_ms: u64) -> Result<SessionToken, AuthError>:
    """Verify a serialized token: parse, check expiry, check origin, verify HMAC."""
    val tok_result = SessionToken.parse(serialized)
    match tok_result:
        Err(e): return Err(e)
        Ok(tok):
            if tok.expires_at_ms < now_ms:
                return Err(AuthError.ExpiredToken)
            if tok.origin != origin:
                return Err(AuthError.OriginMismatch)
            val payload = _token_payload(tok.token_id, tok.grant_id, tok.origin, tok.expires_at_ms)
            val expected_sig = _sign_payload(secret, payload)
            if expected_sig != tok.signature and not constant_time_compare(expected_sig, tok.signature):
                return Err(AuthError.InvalidToken)
            return Ok(tok)

# =========================================================================
# load_secret — read HMAC secret from env; dev-mode fallback
# =========================================================================

fn _allow_insecure_dev_secret_flag(raw: text) -> bool:
    val v = raw.trim().lower()
    return v == "1" or v == "true" or v == "yes"

fn _missing_secret_fatal(tls_mode: bool, allow_insecure_dev_secret: bool) -> bool:
    return tls_mode or not allow_insecure_dev_secret

fn load_secret_with_policy(tls_mode: bool, allow_insecure_dev_secret: bool) -> text:
    """Read SIMPLE_UI_WEB_TOKEN_SECRET from env.
    Missing secrets fail closed unless SIMPLE_UI_WEB_ALLOW_INSECURE_DEV_SECRET
    explicitly opts a non-TLS local dev server into an ephemeral fallback."""
    val s = env_get("SIMPLE_UI_WEB_TOKEN_SECRET") ?? ""
    if s != "":
        return s
    if _missing_secret_fatal(tls_mode, allow_insecure_dev_secret):
        print "FATAL: SIMPLE_UI_WEB_TOKEN_SECRET env var is required; set SIMPLE_UI_WEB_ALLOW_INSECURE_DEV_SECRET=1 only for local non-TLS development"
        return ""
    print "WARNING: SIMPLE_UI_WEB_TOKEN_SECRET unset; using insecure dev secret. Do not use in production."
    return "dev-insecure-secret-" + random_hex(8)

fn load_secret(tls_mode: bool) -> text:
    val allow_raw = env_get("SIMPLE_UI_WEB_ALLOW_INSECURE_DEV_SECRET") ?? ""
    return load_secret_with_policy(tls_mode, _allow_insecure_dev_secret_flag(allow_raw))

# =========================================================================
# Private helpers
# =========================================================================

fn _token_payload(token_id: text, grant_id: text, origin: text, exp: u64) -> text:
    return "{token_id}.{grant_id}.{origin}.{exp}"

fn _sign_payload(secret: text, payload: text) -> text:
    return bytes_to_hex(hmac_sha256_bytes(text_to_bytes(secret), text_to_bytes(payload)))

fn _url_encode(s: text) -> text:
    """Minimal percent-encode: replace '.' with '%2E' so origin dots don't split."""
    var result = ""
    var i = 0
    val s_len = s.len()
    while i < s_len:
        val ch = s[i]
        if ch == ".":
            result = "{result}%2E"
        else:
            result = "{result}{ch}"
        i = i + 1
    return result

fn _url_decode(s: text) -> text:
    """Decode %2E back to '.'."""
    var result = ""
    var i = 0
    val s_len = s.len()
    while i < s_len:
        if (i + 2 < s_len) and s[i] == "%" and s[i+1] == "2" and (s[i+2] == "E" or s[i+2] == "e"):
            result = "{result}."
            i = i + 3
        else:
            result = "{result}{s[i]}"
            i = i + 1
    return result

fn _parse_u64(s: text) -> u64:
    if s == "":
        return 0 as u64
    var i = 0
    var acc: u64 = 0 as u64
    val s_len = s.len()
    while i < s_len:
        val digit = _digit(s.slice(i, i + 1))
        if digit < 0:
            break
        acc = (acc * (10 as u64)) + (digit as u64)
        i = i + 1
    return acc

fn _digit(ch: text) -> i64:
    if ch == "0": return 0 as i64
    if ch == "1": return 1 as i64
    if ch == "2": return 2 as i64
    if ch == "3": return 3 as i64
    if ch == "4": return 4 as i64
    if ch == "5": return 5 as i64
    if ch == "6": return 6 as i64
    if ch == "7": return 7 as i64
    if ch == "8": return 8 as i64
    if ch == "9": return 9 as i64
    return -1 as i64
