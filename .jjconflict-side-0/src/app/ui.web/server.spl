# Web UI Server
#
# HTTP server serving the web UI with WebSocket support
# for live updates. Watches the .ui.sdn file for changes.

use std.nogc_sync_mut.io.tcp.{TcpListener, TcpStream}
use std.nogc_async_mut.concurrent.thread.{thread_spawn_with_args}
use common.ui.widget.{UIState, UITree, UIEvent, UIMode}
use nogc_sync_mut.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.state.{update_state}
use common.ui.event.{process_event}
use app.ui.web.html.{generate_html_page, generate_wm_html_page}
use app.ui.web.ws_handler.{handle_ws_upgrade, handle_ws_wm_upgrade, is_ws_upgrade_request, ui_web_ws_upgrade_method_allowed, ui_web_ws_upgrade_path_allowed, extract_ws_key, compute_ws_accept}
use app.ui.web.async_ws.{parse_ws_event}
use app.ui.render.html_widgets.{render_html_tree}
use app.ui.web.origin_guard.{OriginGuard}
use app.ui.web.session_token.{SessionToken, load_secret, TOKEN_TTL_DEFAULT_MS}
use std.nogc_sync_mut.io.tls_sffi.{rt_tls_server_create}
use nogc_sync_mut.ui.session.{UISession}
use nogc_sync_mut.ui.access_store.{ui_access_store_runtime_open_with_override}
use common.text_advanced.{escape_json}
use common.ui.widget.{UITree}
use nogc_sync_mut.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.state.{init_state}
use app.ui.web.async_server.{AsyncWebServer}
use app.ui.web.wm_bridge.{WmBridge}
use app.ui.web.ui_routes.{dispatch_ui_route, ui_web_request_authorized, ui_web_resume_body_status}
use app.ui.web.tls_serve_loop.{serve_tls, ConnStream}
use app.ui.web.auth_params.{UI_WEB_MAX_REQUEST_HEAD_BYTES, ui_web_content_length, ui_web_body_exceeds_unauth_limit, ui_web_request_body_status, ui_web_login_rate_decision, ui_web_auth_json_field, ui_web_ws_response_protocol, ui_web_ws_frame_payload_allowed, ui_web_request_id, ui_web_request_head_allowed, ui_web_request_line_allowed, ui_web_header_line_allowed, ui_web_json_security_headers, ui_web_static_script_security_headers, ui_web_html_security_headers}
use app.ui.web.taskbar_runtime.{host_taskbar_runtime_enable, host_taskbar_runtime_hides_desktop, host_taskbar_runtime_hides_taskbar, host_taskbar_runtime_mode_name, host_taskbar_runtime_native_window_html}
use app.ui.web.json.{state_to_json, widgets_to_json}
use os.compositor.host_compositor_entry.{HostBackendKind}
use common.ui.web_render_api.{WEB_RENDER_TARGET_SIMPLE_WEB, WebRenderRequest, web_render_body_html}
use std.io_runtime.{env_get, file_exists, get_args, read_file, write_file}

extern fn rt_text_to_bytes(s: text) -> [u8]
extern fn rt_bytes_to_text(data: [u8]) -> text
extern fn rt_time_ms() -> u64

fn web_server_time_ms() -> u64:
    rt_time_ms()

fn web_server_text_to_bytes(s: text) -> [u8]:
    rt_text_to_bytes(s)

fn web_server_bytes_to_text(data: [u8]) -> text:
    rt_bytes_to_text(data)

fn web_server_tls_create(port: i64, cert_path: text, key_path: text) -> i64:
    rt_tls_server_create(port, cert_path, key_path)

var _wm_login_rate_window_start_ms: u64 = 0u64
var _wm_login_rate_attempt_count: i64 = 0

fn send_ws_tcp_frame(stream: TcpStream, message: text) -> bool:
    """Send a text message as one unmasked RFC6455 frame over a raw TcpStream
    (server->client frames are never masked). Avoids ConnStream (whose
    write_all_bytes path can't downcast its Any-typed stream in the interpreter)."""
    val payload = web_server_text_to_bytes(message)
    val len = payload.len()
    var frame: [u8] = [0x81]
    if len < 126:
        frame.push(len & 0xFF)
    elif len < 65536:
        frame.push(126)
        frame.push((len / 256) & 0xFF)
        frame.push(len & 0xFF)
    else:
        frame.push(127)
        frame.push(0)
        frame.push(0)
        frame.push(0)
        frame.push(0)
        frame.push((len / 16777216) & 0xFF)
        frame.push((len / 65536) & 0xFF)
        frame.push((len / 256) & 0xFF)
        frame.push(len & 0xFF)
    frame = frame + payload
    match stream.write_all(frame):
        Err(_):
            return false
        Ok(()):
            match stream.flush():
                Err(_):
                    return false
                Ok(()):
                    return true

fn ws_read_exact(stream: TcpStream, n: i64) -> [u8]:
    """Read exactly n bytes via read() (not peek). Returns [] on EOF/error.
    Peek-based reads break subsequent writes in the interpreter, so the WS
    frame reader must use read()."""
    if n <= 0:
        return []
    var buf: [u8] = [0u8; n]
    var filled = 0
    while filled < n:
        val remaining = n - filled
        match stream.read(remaining):
            Ok(chunk):
                val chunk_len = chunk.len()
                if chunk_len == 0:
                    return []
                var chunk_idx = 0
                while chunk_idx < chunk_len:
                    buf[filled + chunk_idx] = chunk[chunk_idx]
                    chunk_idx = chunk_idx + 1
                filled = filled + chunk_len
            Err(_):
                return []
    return buf

fn ws_read_text_frame(stream: TcpStream) -> text?:
    """Read one client->server WebSocket frame (read()-based) and return its
    unmasked text payload. nil on close/EOF, empty string for control frames."""
    val hh = ws_read_exact(stream, 2)
    if hh.len() < 2:
        return nil
    val opcode = hh[0] & 0x0F
    val masked = (hh[1] & 0x80) != 0
    var plen: i64 = (hh[1] & 0x7F) as i64
    if plen == 126:
        val e = ws_read_exact(stream, 2)
        if e.len() < 2:
            return nil
        plen = ((e[0] as i64) * 256) + (e[1] as i64)
    elif plen == 127:
        val e = ws_read_exact(stream, 8)
        if e.len() < 8:
            return nil
        plen = 0
        var bi = 0
        while bi < 8:
            plen = (plen * 256) + e[bi]
            bi = bi + 1
    if not ui_web_ws_frame_payload_allowed(plen):
        return nil
    var maskkey: [u8] = []
    if masked:
        maskkey = ws_read_exact(stream, 4)
        if maskkey.len() < 4:
            return nil
    if opcode == 8:
        return nil
    if plen == 0:
        return ""
    var payload = ws_read_exact(stream, plen)
    val payload_len = payload.len()
    if payload_len < plen:
        return nil
    if masked:
        var i = 0
        while i < payload_len:
            payload[i] = payload[i] ^ maskkey[i % 4]
            i = i + 1
    return web_server_bytes_to_text(payload)

fn parse_request_line(request_line: text) -> (text, text):
    var method = ""
    var path = ""
    var idx = 0
    for part in request_line.split(" "):
        if idx == 0:
            method = part
        elif idx == 1:
            path = part
            break
        idx = idx + 1
    return (method, path)

# =========================================================================
# Web Server
# =========================================================================

class WebServer:
    file_path: text
    port: i32
    state: UIState
    session: UISession
    last_file_content: text
    wm_mode: bool
    origin_guard: OriginGuard
    token_secret: text
    login_rate_window_start_ms: u64
    login_rate_attempt_count: i64

    static fn build_state(tree: UITree) -> UIState:
        val ids = tree.all_widget_ids()
        var initial_focus = ""
        for id in ids:
            if initial_focus == "":
                initial_focus = id
        return UIState(
            tree: tree,
            mode: UIMode.Normal,
            focused_id: initial_focus,
            command_buffer: ""
        )

    static fn new(file_path: text, port: i32, wm_mode: bool) -> Result<WebServer, text>:
        return WebServer.new_with_access_store_path(file_path, port, wm_mode, "")

    static fn new_with_access_store_path(file_path: text, port: i32, wm_mode: bool, access_db_path: text) -> Result<WebServer, text>:
        val tree_result = parse_ui_to_tree(file_path)
        match tree_result:
            Err(e):
                return Err(e)
            Ok(tree):
                val state = WebServer.build_state(tree)
                var session = UISession.new(tree)
                session.set_active_backend("web")
                val store = ui_access_store_runtime_open_with_override(access_db_path, file_path, "web")
                if store != nil:
                    session.attach_access_store(store)
                val content = if file_exists(file_path):
                    read_file(file_path)
                else:
                    ""
                val secret = load_secret(false)
                if secret == "":
                    return Err("SIMPLE_UI_WEB_TOKEN_SECRET is required unless SIMPLE_UI_WEB_ALLOW_INSECURE_DEV_SECRET=1 is set for local development")
                return Ok(WebServer(
                    file_path: file_path,
                    port: port,
                    state: state,
                    session: session,
                    last_file_content: content,
                    wm_mode: wm_mode,
                    origin_guard: OriginGuard.from_env(),
                    token_secret: secret,
                    login_rate_window_start_ms: 0u64,
                    login_rate_attempt_count: 0
                ))

    fn start():
        """Start the HTTP server."""
        print "Starting UI Web Server on port {self.port}..."
        print "Open http://localhost:{self.port} in your browser"
        print "Press Ctrl+C to stop"
        print ""

        match TcpListener.bind("0.0.0.0:{self.port}"):
            Err(e):
                print "Error: Failed to bind to port {self.port}: {e}"
                return
            Ok(listener):
                self.serve_loop(listener)

    fn serve_loop(listener: TcpListener):
        """Main server loop."""
        loop:
            match listener.accept():
                Ok(stream):
                    # Handle synchronously. thread_spawn_with_args marshals the TcpStream
                    # into the worker as a boxed object whose writes don't deliver
                    # in the interpreter; one connection at a time is fine for a
                    # local UI dev server and keeps the WS loop on a live fd.
                    # Keep the call on this instance so per-server state such
                    # as login rate counters and file-change state persists.
                    self.handle_connection(stream)
                Err(e):
                    print "Accept error: {e}"

    static fn handle_connection_thread(server: WebServer, stream: TcpStream):
        server.handle_connection(stream)

    fn send_http(stream: TcpStream, response: text):
        """Write an HTTP response in <=8KB chunks via write_all. A single large
        write after read_head's read() does not deliver in the interpreter;
        chunked writes (each within the delivering size) do."""
        val bytes = web_server_text_to_bytes(response)
        val total = bytes.len()
        var off = 0
        while off < total:
            var end = off + 8192
            if end > total:
                end = total
            val chunk_len = end - off
            var chunk: [u8] = [0u8; chunk_len]
            var j = off
            while j < end:
                chunk[j - off] = bytes[j]
                j = j + 1
            match stream.write_all(chunk):
                Err(_):
                    return
                Ok(()):
                    pass_do_nothing("chunk write succeeded; continue streaming response")
            match stream.flush():
                Err(_):
                    return
                Ok(()):
                    pass_do_nothing("chunk flush succeeded; advance to next chunk")
            off = end

    fn send_small_http(stream: TcpStream, response: text):
        match stream.write_all(web_server_text_to_bytes(response)):
            Err(e):
                print "HTTP write error: {e}"
            Ok(()):
                match stream.flush():
                    Err(e):
                        print "HTTP flush error: {e}"
                    Ok(()):
                        pass_do_nothing("small HTTP response flushed")

    fn read_head(stream: TcpStream) -> Result<(text, text, text, bool, text), text>:
        """Read the HTTP request head (request line + headers) in chunks up to
        the blank line, returning (method, path, headers, is_ws, initial_body).

        Uses read() rather than read_line: the interpreter's peek-based
        read_line breaks subsequent socket writes after a multi-line read loop,
        so reading the head in one shot keeps responses deliverable. The same
        read may include part or all of a small POST body; callers must consume
        that initial body before trying to read more from the socket."""
        var raw = ""
        var attempts = 0
        var head_done = false
        while not head_done and attempts < 64:
            attempts = attempts + 1
            match stream.read(4096):
                Ok(chunk):
                    if chunk.len() == 0:
                        head_done = true
                    else:
                        raw = "{raw}{web_server_bytes_to_text(chunk)}"
                        if not ui_web_request_head_allowed(raw.len()):
                            return Err("request_head_too_large")
                        if raw.contains("\r\n\r\n"):
                            head_done = true
                Err(_):
                    head_done = true
        if raw == "":
            return Err("empty request")
        val sep = raw.index_of("\r\n\r\n")
        if sep < 0 and raw.len() >= UI_WEB_MAX_REQUEST_HEAD_BYTES:
            return Err("request_head_too_large")
        val head = if sep >= 0: raw[0:sep] else: raw
        val initial_body = if sep >= 0: raw.slice(sep + 4, raw.len()) else: ""
        val head_lines = head.split("\r\n")
        val head_line_count = head_lines.len()
        val request_line = if head_line_count > 0: head_lines[0] else: ""
        if not ui_web_request_line_allowed(request_line.len()):
            return Err("request_head_too_large")
        val request = parse_request_line(request_line)
        var headers = ""
        var is_ws = false
        var hi = 1
        while hi < head_line_count:
            val header_line = head_lines[hi]
            if not ui_web_header_line_allowed(header_line.len()):
                return Err("request_head_too_large")
            headers = "{headers}{header_line}\n"
            if is_ws_upgrade_request(headers):
                is_ws = true
            hi = hi + 1
        return Ok((request.0, request.1, headers, is_ws, initial_body))

    me handle_connection(stream: TcpStream):
        """Handle a single HTTP connection."""
        match self.read_head(stream):
            Err(e):
                if e == "request_head_too_large":
                    val too_large = _simple_response(413, "application/json", "{\"error\": \"request_head_too_large\"}")
                    self.send_small_http(stream, too_large)
                    return
                print "Error reading request: {e}"
            Ok(parsed):
                # Check for file changes before each response
                self.check_file_changes()

                val method = parsed.0
                val path = parsed.1
                val headers = parsed.2
                val is_ws = parsed.3
                val initial_body = parsed.4
                if method == "" or path == "":
                    return

                if path == "/ui/login" and method == "POST":
                    self.handle_login(stream, headers, initial_body)
                    return

                if is_ws:
                    if not ui_web_ws_upgrade_path_allowed(path):
                        val not_found = _simple_response(404, "application/json", "{\"error\": \"not_found\"}")
                        self.send_small_http(stream, not_found)
                        return
                    if not ui_web_ws_upgrade_method_allowed(method):
                        val method_not_allowed = _simple_response(405, "application/json", "{\"error\": \"method_not_allowed\"}")
                        self.send_small_http(stream, method_not_allowed)
                        return
                    if self.wm_mode:
                        handle_ws_wm_upgrade(ConnStream.from_tcp(stream), path, headers, self.origin_guard, self.token_secret)
                    else:
                        self.serve_ws_tcp(stream, path, headers)
                    return

                if path.starts_with("/wm/native_window"):
                    val body = _native_window_html(path)
                    val response = _simple_response(200, "text/html", body)
                    match stream.write_text(response):
                        Err(e):
                            print "HTTP write error: {e}"
                        Ok(()):
                            pass_do_nothing("native-window HTML response written")
                    return

                if path == "/ui/resume" and method == "POST":
                    var ui_body = initial_body
                    val body_status = ui_web_request_body_status(headers)
                    if body_status == "invalid_request_framing":
                        val bad_framing = _simple_response(400, "application/json", "{\"error\": \"invalid_request_framing\"}")
                        self.send_small_http(stream, bad_framing)
                        return
                    if body_status == "request_body_too_large":
                        val too_large = _simple_response(413, "application/json", "{\"error\": \"request_body_too_large\"}")
                        self.send_small_http(stream, too_large)
                        return
                    val ui_content_length = ui_web_content_length(headers)
                    if ui_content_length > ui_body.len():
                        match stream.read_exact(ui_content_length - ui_body.len()):
                            Ok(b): ui_body = "{ui_body}{b}"
                            Err(_): ui_body = ui_body
                    self.handle_resume(stream, path, headers, ui_body)
                    return

                match path:
                    "/wm.js":
                        val wm_js = read_file("src/app/ui.web/wm.js")
                        val js_response = _simple_response(200, "application/javascript", wm_js)
                        match stream.write_text(js_response):
                            Err(e):
                                print "HTTP write error: " + str(e)
                            Ok(()):
                                pass_do_nothing("wm.js response written")
                    "/retained_renderer.js":
                        val renderer_js = read_file("src/app/ui.web/retained_renderer.js")
                        val renderer_response = _simple_response(200, "application/javascript", renderer_js)
                        match stream.write_text(renderer_response):
                            Err(e):
                                print "HTTP write error: " + str(e)
                            Ok(()):
                                pass_do_nothing("retained renderer response written")
                    "/":
                        val payload = if self.wm_mode:
                            generate_wm_html_page(self.state.tree.theme_name(), self.state.tree.title_text(), self.port)
                        else:
                            generate_html_page(self.state, self.port)
                        val payload_text = "{payload}"
                        var response_headers = "HTTP/1.1 200 OK\r\n"
                        response_headers = "{response_headers}Content-Type: text/html\r\n"
                        response_headers = "{response_headers}{ui_web_html_security_headers(\"text/html\")}"
                        response_headers = "{response_headers}Content-Length: {payload_text.len()}\r\n"
                        response_headers = "{response_headers}Connection: close\r\n"
                        response_headers = "{response_headers}\r\n"
                        val response = "{response_headers}{payload_text}"
                        self.send_http(stream, response)
                    "/api/state":
                        if not ui_web_request_authorized(headers, path, self.origin_guard, self.token_secret, web_server_time_ms()):
                            val response = _simple_response(403, "application/json", "{\"error\": \"forbidden\"}")
                            self.send_small_http(stream, response)
                            return
                        val payload = state_to_json(self.state)
                        val payload_text = "{payload}"
                        var headers = "HTTP/1.1 200 OK\r\n"
                        headers = "{headers}Content-Type: application/json\r\n"
                        headers = "{headers}Content-Length: {payload_text.len()}\r\n"
                        headers = "{headers}Connection: close\r\n"
                        headers = "{headers}\r\n"
                        val response = "{headers}{payload_text}"
                        match stream.write_text(response):
                            Err(e):
                                print "HTTP write error: {e}"
                            Ok(()):
                                pass_do_nothing("test API response written")
                    "/api/widgets":
                        if not ui_web_request_authorized(headers, path, self.origin_guard, self.token_secret, web_server_time_ms()):
                            val response = _simple_response(403, "application/json", "{\"error\": \"forbidden\"}")
                            self.send_small_http(stream, response)
                            return
                        val payload = widgets_to_json(self.state)
                        val payload_text = "{payload}"
                        var headers = "HTTP/1.1 200 OK\r\n"
                        headers = "{headers}Content-Type: application/json\r\n"
                        headers = "{headers}Content-Length: {payload_text.len()}\r\n"
                        headers = "{headers}Connection: close\r\n"
                        headers = "{headers}\r\n"
                        val response = "{headers}{payload_text}"
                        match stream.write_text(response):
                            Err(e):
                                print "HTTP write error: {e}"
                            Ok(()):
                                pass_do_nothing("widgets API response written")
                    _:
                        val response = _simple_response(404, "application/json", "{\"error\": \"not_found\"}")
                        match stream.write_text(response):
                            Err(e):
                                print "HTTP write error: {e}"
                            Ok(()):
                                pass_do_nothing("404 response written")

                match stream.close():
                    Err(e):
                        print "Close error: {e}"
                    Ok(()):
                        pass_do_nothing("HTTP connection closed")

    me serve_ws_tcp(stream: TcpStream, path: text, headers: text):
        """Complete the WebSocket handshake on the raw TcpStream, then run the
        interactive loop: read client action frames, apply them via update_state,
        and push the re-rendered widget tree back. Operates on TcpStream directly
        (not ConnStream) and requires the same origin-bound bearer policy as
        `/ui/ws`, while preserving the legacy render-frame protocol."""
        if not ui_web_request_authorized(headers, path, self.origin_guard, self.token_secret, web_server_time_ms()):
            val forbidden = _simple_response(403, "application/json", "{\"error\": \"forbidden\"}")
            self.send_small_http(stream, forbidden)
            return
        val key = extract_ws_key(headers)
        if key == "":
            return
        val accept = compute_ws_accept(key)
        var response = "HTTP/1.1 101 Switching Protocols\r\n"
        response = "{response}Upgrade: websocket\r\n"
        response = "{response}Connection: Upgrade\r\n"
        response = "{response}Sec-WebSocket-Accept: {accept}\r\n"
        val protocol = ui_web_ws_response_protocol(headers)
        if protocol != "":
            response = "{response}Sec-WebSocket-Protocol: {protocol}\r\n"
        response = "{response}\r\n"
        match stream.write_text(response):
            Err(_):
                return
            Ok(()):
                pass_do_nothing("WebSocket upgrade response written")
        match stream.flush():
            Err(_):
                return
            Ok(()):
                pass_do_nothing("WebSocket upgrade response flushed")

        # Initial snapshot, then process client events until disconnect.
        self.push_ws_render(stream)
        loop:
            val msg = ws_read_text_frame(stream)
            if msg == nil:
                break
            val event = parse_ws_event(msg)
            if event != nil:
                self.check_file_changes()
                self.state = update_state(self.state, event)
                self.push_ws_render(stream)

    me push_ws_render(stream: TcpStream):
        """Render the current widget tree and push the legacy browser render frame."""
        val body = render_html_tree(self.state.tree.root_node(), self.state)
        val req = WebRenderRequest.html(WEB_RENDER_TARGET_SIMPLE_WEB, "", body, "", "", 0, 0)
        val render_body = web_render_body_html(req)
        val msg = "{\"type\":\"render\",\"target\":\"" + escape_json(WEB_RENDER_TARGET_SIMPLE_WEB) + "\",\"surface_id\":\"\",\"html\":\"" + escape_json(render_body) + "\"}"
        send_ws_tcp_frame(stream, msg)

    fn handle_login(stream: TcpStream, headers: text, initial_body: text):
        """POST /ui/login — issue a bearer token for a pre-minted capability grant.
        Body JSON must contain a 'capability_grant' field.
        Returns: { "token": "...", "expires_at": N }"""
        match self.origin_guard.check(headers):
            Err(_):
                val resp = _simple_response_for_request(403, "application/json", "{\"error\": \"forbidden_origin\"}", headers)
                self.send_small_http(stream, resp)
                return
            Ok(origin):
                val body_status = ui_web_request_body_status(headers)
                if body_status == "invalid_request_framing":
                    val bad_framing = _simple_response_for_request(400, "application/json", "{\"error\": \"invalid_request_framing\"}", headers)
                    self.send_small_http(stream, bad_framing)
                    return
                if body_status == "request_body_too_large":
                    val too_large = _simple_response_for_request(413, "application/json", "{\"error\": \"request_body_too_large\"}", headers)
                    self.send_small_http(stream, too_large)
                    return
                val rate = ui_web_login_rate_decision(self.login_rate_window_start_ms, self.login_rate_attempt_count, web_server_time_ms())
                self.login_rate_window_start_ms = rate.1
                self.login_rate_attempt_count = rate.2
                if not rate.0:
                    val limited = _simple_response_for_request(429, "application/json", "{\"error\": \"login_rate_limited\"}", headers)
                    self.send_small_http(stream, limited)
                    return
                var body = initial_body
                val content_length = ui_web_content_length(headers)
                if content_length > body.len():
                    match stream.read_exact(content_length - body.len()):
                        Ok(b): body = "{body}{b}"
                        Err(_): body = body

                # Extract capability_grant from JSON body
                val grant_id = ui_web_auth_json_field(body, "capability_grant")
                if grant_id == "":
                    val resp = _simple_response_for_request(400, "application/json", "{\"error\": \"missing capability_grant\"}", headers)
                    self.send_small_http(stream, resp)
                    return

                val tok = SessionToken.issue(grant_id, origin, TOKEN_TTL_DEFAULT_MS, self.token_secret)
                val serialized = tok.serialize()
                val body_json = "{\"token\": \"{serialized}\", \"expires_at\": {tok.expires_at_ms}}"
                val resp = _simple_response_for_request(200, "application/json", body_json, headers)
                self.send_small_http(stream, resp)

    fn handle_resume(stream: TcpStream, path: text, headers: text, body: text):
        if not ui_web_request_authorized(headers, path, self.origin_guard, self.token_secret, web_server_time_ms()):
            val forbidden = _simple_response_for_request(403, "application/json", "{\"error\": \"forbidden\"}", headers)
            self.send_small_http(stream, forbidden)
            return
        val resume_status = ui_web_resume_body_status(body)
        if resume_status == "body_too_large":
            val too_large = _simple_response_for_request(413, "application/json", "{\"error\": \"request_body_too_large\"}", headers)
            self.send_small_http(stream, too_large)
            return
        if resume_status != "ok":
            val bad = _simple_response_for_request(400, "application/json", "{\"error\": \"invalid_resume_body\"}", headers)
            self.send_small_http(stream, bad)
            return
        val session_id = ui_web_auth_json_field(body, "session_id")
        val rev_str = ui_web_auth_json_field(body, "snapshot_revision")
        val seq_str = ui_web_auth_json_field(body, "last_sequence")
        val body_json = "{\"session_id\": \"{session_id}\", \"snapshot_revision\": {rev_str}, \"last_sequence\": {seq_str}}"
        val resp = _simple_response_for_request(200, "application/json", body_json, headers)
        self.send_small_http(stream, resp)

    fn check_file_changes():
        """Check if the .ui.sdn file has changed."""
        if not file_exists(self.file_path):
            return

        val current_content = read_file(self.file_path)
        if current_content != self.last_file_content:
            self.last_file_content = current_content
            val tree_result = parse_ui_to_tree(self.file_path)
            match tree_result:
                Ok(new_tree):
                    self.state = WebServer.build_state(new_tree)
                    self.session = UISession.new(new_tree)
                    self.session.set_active_backend("web")
                Err(e):
                    # Keep old state on parse error
                    print "Warning: UI parse error: {e}"

# =========================================================================
# Response and JSON helpers
# =========================================================================

fn _simple_response(status: i32, content_type: text, body: text) -> text:
    return _simple_response_with_request_id(status, content_type, body, "")

fn _simple_response_for_request(status: i32, content_type: text, body: text, headers: text) -> text:
    return _simple_response_with_request_id(status, content_type, body, ui_web_request_id(headers, "uiweb"))

fn _simple_response_with_request_id(status: i32, content_type: text, body: text, request_id: text) -> text:
    val status_text = match status:
        200: "OK"
        400: "Bad Request"
        403: "Forbidden"
        404: "Not Found"
        405: "Method Not Allowed"
        413: "Payload Too Large"
        429: "Too Many Requests"
        _: "OK"
    var r = "HTTP/1.1 {status} {status_text}\r\n"
    r = "{r}Content-Type: {content_type}\r\n"
    if request_id != "":
        r = "{r}X-Request-Id: {request_id}\r\n"
    r = "{r}{ui_web_json_security_headers(content_type)}"
    r = "{r}{ui_web_static_script_security_headers(content_type)}"
    r = "{r}{ui_web_html_security_headers(content_type)}"
    r = "{r}Content-Length: {body.len()}\r\n"
    r = "{r}Connection: close\r\n"
    r = "{r}\r\n"
    r = "{r}{body}"
    return r

# =========================================================================
# Shared WM helpers
# =========================================================================

fn shared_wm_requested_web(args: [text], env_val: text) -> bool:
    for a in args:
        if a == "--shared-wm":
            return true
    env_val == "1"

fn shared_wm_backend_kind_web() -> HostBackendKind:
    HostBackendKind.WebCanvas

fn _shared_wm_requested(args: [text]) -> bool:
    val env_val = env_get("SIMPLE_UI_WEB_SHARED_WM") ?? ""
    shared_wm_requested_web(args, env_val)

fn parse_web_port_or_default(value: text) -> i64:
    val trimmed = value.trim()
    if trimmed == "":
        return 8080
    for ch in trimmed:
        if ch < "0" or ch > "9":
            return 8080
    val parsed = trimmed.to_int() ?? 8080
    if parsed <= 0 or parsed > 65535:
        return 8080
    parsed

fn run_shared_wm_web(title: text) -> i64:
    """Start the shared WM web server.
    Constructs a UISession backed by an empty tree, wires WmBridge and
    OriginGuard, then runs the AsyncWebServer with /ui/* dispatch enabled."""
    val port_str = env_get("SIMPLE_UI_WEB_PORT") ?? "8080"
    val port = parse_web_port_or_default(port_str)

    val guard = OriginGuard.from_env()
    val secret = load_secret(false)
    if secret == "":
        print "Error: SIMPLE_UI_WEB_TOKEN_SECRET is required unless SIMPLE_UI_WEB_ALLOW_INSECURE_DEV_SECRET=1 is set for local development"
        return 1
    val mode_name = env_get("SIMPLE_UI_WEB_SHELL_MODE") ?? "embedded"
    val backend_name = env_get("SIMPLE_UI_BACKEND") ?? ""
    val electron_env = env_get("SIMPLE_HOST_ELECTRON_AVAILABLE") ?? ""
    val electron_available = backend_name == "electron" or electron_env == "1"
    host_taskbar_runtime_enable(mode_name, electron_available)

    # Build a minimal UISession without a file on disk
    val session_result = _make_wm_session()
    val session = match session_result:
        Err(e):
            print "Error: failed to create WM session: {e}"
            return 1
        Ok(s): s

    print "Starting Shared WM Web Server on port {port}..."
    print "Title: {title}"
    print "Open http://localhost:{port}/ui/ws in a WM-capable browser client"
    print "Press Ctrl+C to stop"
    print ""

    match TcpListener.bind("0.0.0.0:{port}"):
        Err(e):
            print "Error: Failed to bind to port {port}: {e}"
            return 1
        Ok(listener):
            _wm_serve_loop(listener, session, guard, secret)

    return 0

fn _make_wm_session() -> Result<UISession, text>:
    """Create a UISession for the shared WM mode.
    Uses an in-memory empty tree if no default file is found."""
    val default_path = env_get("SIMPLE_UI_WEB_DEFAULT_UI") ?? ""
    if default_path != "" and file_exists(default_path):
        val tree_result = parse_ui_to_tree(default_path)
        match tree_result:
            Err(e): return Err(e)
            Ok(tree):
                var session = UISession.new(tree)
                session.set_active_backend("web")
                return Ok(session)
    # Fallback: parse minimal inline UI
    val fallback = "ui { title: \"SimpleOS WM\" }"
    val tmp_path = "/tmp/simple_wm_default.sdn"
    # Write a minimal file for the parser (runtime file write)
    _write_temp_ui(tmp_path)
    if file_exists(tmp_path):
        val tree_result = parse_ui_to_tree(tmp_path)
        match tree_result:
            Err(_): pass_do_nothing("default UI parse failed; return fallback error below")
            Ok(tree):
                var session = UISession.new(tree)
                session.set_active_backend("web")
                return Ok(session)
    return Err("no default UI file; set SIMPLE_UI_WEB_DEFAULT_UI env var")

fn _write_temp_ui(path: text):
    """Write a minimal .sdn UI file to disk for the fallback session."""
    # Use the same minimal .sdn content that parse_ui_to_tree can handle
    val content = "ui {\n" +
        "  title: \"SimpleOS WM\"\n" +
        "  panel main {\n" +
        "    text banner \"Shared host taskbar runtime\"\n" +
        "  }\n" +
        "}\n"
    val _ = write_file(path, content)

fn _wm_serve_loop(listener: TcpListener, session: UISession, guard: OriginGuard, secret: text):
    """Accept and dispatch connections for the shared WM server."""
    loop:
        match listener.accept():
            Err(e):
                print "Accept error: {e}"
            Ok(stream):
                _wm_handle_connection(stream, session, guard, secret)

fn _wm_handle_connection(stream: TcpStream, session: UISession, guard: OriginGuard, secret: text):
    """Handle one HTTP connection in the shared WM server."""
    match _wm_read_head(stream):
        Err(e):
            if e == "request_head_too_large":
                val too_large = _simple_response(413, "application/json", "{\"error\": \"request_head_too_large\"}")
                stream.write_text(too_large)
            return
        Ok(parsed):
            val method = parsed.0
            val path = parsed.1
            val headers = parsed.2
            val initial_body = parsed.3
            if method == "" or path == "":
                return

            if path == "/ui/login" and method == "POST":
                _wm_handle_login(stream, headers, initial_body, guard, secret)
                return

            if path == "/" or path == "/index.html":
                val payload = _decorate_host_shell_html(
                    generate_wm_html_page("glass_dark", "SimpleOS WM", 0)
                )
                val response = _simple_response(200, "text/html", payload)
                stream.write_text(response)
                return

            if path == "/wm.js":
                val wm_js = read_file("src/app/ui.web/wm.js")
                val response = _simple_response(200, "application/javascript", wm_js)
                stream.write_text(response)
                return

            if path == "/retained_renderer.js":
                val renderer_js = read_file("src/app/ui.web/retained_renderer.js")
                val response = _simple_response(200, "application/javascript", renderer_js)
                stream.write_text(response)
                return

            if path.starts_with("/wm/native_window"):
                val body = _native_window_html(path)
                val response = _simple_response(200, "text/html", body)
                stream.write_text(response)
                return

            if path.starts_with("/ui/"):
                var body = initial_body
                if method == "POST":
                    val body_status = ui_web_request_body_status(headers)
                    if body_status == "invalid_request_framing":
                        val bad_framing = _simple_response(400, "application/json", "{\"error\": \"invalid_request_framing\"}")
                        stream.write_text(bad_framing)
                        return
                    if body_status == "request_body_too_large":
                        val too_large = _simple_response(413, "application/json", "{\"error\": \"request_body_too_large\"}")
                        stream.write_text(too_large)
                        return
                    body = _wm_read_remaining_body(stream, headers, body)
                if path == "/ui/resume" and method == "POST":
                    _wm_handle_resume(stream, path, headers, body, guard, secret)
                    return
                val handled = dispatch_ui_route(path, method, headers, body, ConnStream.from_tcp(stream), session, guard, secret)
                if handled:
                    return

            # 404 fallback
            val not_found = _simple_response(404, "application/json", "{\"error\": \"not_found\"}")
            stream.write_text(not_found)

fn _wm_read_head(stream: TcpStream) -> Result<(text, text, text, text), text>:
    var raw = ""
    var attempts = 0
    while attempts < 16:
        attempts = attempts + 1
        match stream.read(4096):
            Ok(chunk):
                if chunk.len() == 0:
                    break
                raw = "{raw}{web_server_bytes_to_text(chunk)}"
                if not ui_web_request_head_allowed(raw.len()):
                    return Err("request_head_too_large")
                if raw.contains("\r\n\r\n"):
                    break
            Err(_):
                break
    if raw == "":
        return Err("empty_request")
    val sep = raw.index_of("\r\n\r\n")
    if sep < 0:
        if raw.len() >= UI_WEB_MAX_REQUEST_HEAD_BYTES:
            return Err("request_head_too_large")
        return Err("incomplete_request_head")
    val head = raw.slice(0, sep)
    val initial_body = raw.slice(sep + 4, raw.len())
    val head_lines = head.split("\r\n")
    val request_line = if head_lines.len() > 0: head_lines[0] else: ""
    if not ui_web_request_line_allowed(request_line.len()):
        return Err("request_head_too_large")
    val request = parse_request_line(request_line)
    var headers = ""
    var hi = 1
    while hi < head_lines.len():
        if not ui_web_header_line_allowed(head_lines[hi].len()):
            return Err("request_head_too_large")
        headers = "{headers}{head_lines[hi]}\n"
        hi = hi + 1
    return Ok((request.0, request.1, headers, initial_body))

fn _wm_handle_login(stream: TcpStream, headers: text, initial_body: text, guard: OriginGuard, secret: text):
    """POST /ui/login in shared WM mode."""
    var origin = ""
    match guard.check(headers):
        Ok(o): origin = o
        Err(_):
            val resp = _simple_response(403, "application/json", "{\"error\": \"forbidden_origin\"}")
            stream.write_text(resp)
            return
    val body_status = ui_web_request_body_status(headers)
    if body_status == "invalid_request_framing":
        val bad_framing = _simple_response(400, "application/json", "{\"error\": \"invalid_request_framing\"}")
        stream.write_text(bad_framing)
        return
    if body_status == "request_body_too_large":
        val too_large = _simple_response(413, "application/json", "{\"error\": \"request_body_too_large\"}")
        stream.write_text(too_large)
        return
    val _body = _wm_read_remaining_body(stream, headers, initial_body)
    val rate = ui_web_login_rate_decision(_wm_login_rate_window_start_ms, _wm_login_rate_attempt_count, web_server_time_ms())
    _wm_login_rate_window_start_ms = rate.1
    _wm_login_rate_attempt_count = rate.2
    if not rate.0:
        val limited = _simple_response(429, "application/json", "{\"error\": \"login_rate_limited\"}")
        stream.write_text(limited)
        return
    val tok = SessionToken.issue("wm-default", origin, TOKEN_TTL_DEFAULT_MS, secret)
    val serialized = tok.serialize()
    val body_json = "{\"token\": \"{serialized}\", \"expires_at\": {tok.expires_at_ms}}"
    val resp = _simple_response(200, "application/json", body_json)
    stream.write_text(resp)

fn _wm_handle_resume(stream: TcpStream, path: text, headers: text, body: text, guard: OriginGuard, secret: text):
    if not ui_web_request_authorized(headers, path, guard, secret, web_server_time_ms()):
        val forbidden = _simple_response(403, "application/json", "{\"error\": \"forbidden\"}")
        stream.write_text(forbidden)
        return
    val resume_status = ui_web_resume_body_status(body)
    if resume_status == "body_too_large":
        val too_large = _simple_response(413, "application/json", "{\"error\": \"request_body_too_large\"}")
        stream.write_text(too_large)
        return
    if resume_status != "ok":
        val bad = _simple_response(400, "application/json", "{\"error\": \"invalid_resume_body\"}")
        stream.write_text(bad)
        return
    val session_id = ui_web_auth_json_field(body, "session_id")
    val rev_str = ui_web_auth_json_field(body, "snapshot_revision")
    val seq_str = ui_web_auth_json_field(body, "last_sequence")
    val body_json = "{\"session_id\": \"{session_id}\", \"snapshot_revision\": {rev_str}, \"last_sequence\": {seq_str}}"
    val response = _simple_response(200, "application/json", body_json)
    stream.write_text(response)

fn _wm_read_body(stream: TcpStream, headers: text) -> text:
    val content_length = ui_web_content_length(headers)
    if content_length <= 0:
        return ""
    match stream.read_exact(content_length):
        Ok(b): return b
        Err(_): return ""

fn _wm_read_remaining_body(stream: TcpStream, headers: text, initial_body: text) -> text:
    val content_length = ui_web_content_length(headers)
    if content_length <= initial_body.len():
        return initial_body
    match stream.read_exact(content_length - initial_body.len()):
        Ok(b): return "{initial_body}{b}"
        Err(_): return initial_body

fn _native_window_html(path: text) -> text:
    val app_id = _query_value(path, "app_id")
    val html = host_taskbar_runtime_native_window_html(app_id)
    if html != nil:
        return html
    return "<!doctype html><html><body style='font-family:monospace;padding:24px'>" +
        "<h1>Unsupported app</h1><p>" + escape_json(app_id) + "</p></body></html>"

fn _decorate_host_shell_html(html: text) -> text:
    val mode_name = host_taskbar_runtime_mode_name()
    var body_class = "wm-shell-{mode_name}"
    var extra_style = ""
    if host_taskbar_runtime_hides_desktop():
        extra_style = "#wm-desktop { display: none !important; }\n" +
            "body.wm-shell-{mode_name} { overflow: hidden; }\n" +
            "body.wm-shell-{mode_name} #wm-taskbar { left: 12px; right: 12px; transform: none; justify-content: center; }\n"
    if host_taskbar_runtime_hides_taskbar():
        extra_style = extra_style +
            "body.wm-shell-hidden_taskbar #wm-taskbar { display: none !important; }\n"
    var updated = html.replace("<body>", "<body class=\"{body_class}\">")
    if extra_style != "":
        updated = updated.replace("</style>", "{extra_style}</style>")
    updated

fn _query_value(path: text, key: text) -> text:
    val q_idx = path.find("?")
    if q_idx < 0:
        return ""
    val query = path.slice(q_idx + 1, path.len())
    for part in query.split("&"):
        val kv = part.split("=")
        if kv.len() >= 2 and kv[0] == key:
            return _url_decode(kv[1])
    return ""

fn _url_decode(s: text) -> text:
    var out = s
    out = out.replace("%2F", "/")
    out = out.replace("%2f", "/")
    out = out.replace("%20", " ")
    out = out.replace("+", " ")
    out = out.replace("%26", "&")
    out = out.replace("%3D", "=")
    out = out.replace("%3d", "=")
    out = out.replace("%3F", "?")
    out = out.replace("%3f", "?")
    out

# =========================================================================
# Entry Point
# =========================================================================

fn run_web(file_path: text, port: i32) -> i64:
    return run_web_with_access_store(file_path, port, "")

fn _tls_requested(args: [text]) -> bool:
    for a in args:
        if a == "--tls" or a == "--https":
            return true
    false

fn run_web_with_access_store(file_path: text, port: i32, access_db_path: text) -> i64:
    """Start web server mode for a .ui.sdn file.
    If --tls/--https is present, constructs a TLS listener using
    SIMPLE_UI_WEB_TLS_CERT and SIMPLE_UI_WEB_TLS_KEY env vars."""
    val args = get_args()
    if _shared_wm_requested(args):
        return run_shared_wm_web("simple ui web")
    if not file_exists(file_path):
        print "Error: File not found: " + file_path
        return 1

    val use_tls = _tls_requested(args)
    if use_tls:
        val cert_path = env_get("SIMPLE_UI_WEB_TLS_CERT") ?? ""
        val key_path = env_get("SIMPLE_UI_WEB_TLS_KEY") ?? ""
        if cert_path == "":
            print "Error: SIMPLE_UI_WEB_TLS_CERT env var is required for TLS mode"
            return 1
        if key_path == "":
            print "Error: SIMPLE_UI_WEB_TLS_KEY env var is required for TLS mode"
            return 1
        val secret = load_secret(true)
        if secret == "":
            return 1
        val tls_handle = web_server_tls_create(port as i64, cert_path, key_path)
        if tls_handle <= 0:
            print "Error: Failed to create TLS server on port {port}"
            return 1
        print "Starting TLS UI Web Server on port {port}..."
        print "Open https://localhost:{port} in your browser"
        print "Press Ctrl+C to stop"
        return serve_tls(file_path, port, tls_handle, access_db_path)

    val server_result = WebServer.new_with_access_store_path(file_path, port, false, access_db_path)
    match server_result:
        Err(e):
            print "Error: " + str(e)
            return 1
        Ok(server0):
            val server: WebServer = server0
            server.start()
            return 0

fn run_web_wm(file_path: text, port: i32) -> i64:
    """Start web server in window manager mode.
    Serves a WM desktop with floating, draggable windows."""
    if not file_exists(file_path):
        print "Error: File not found: " + file_path
        return 1

    val server_result = WebServer.new(file_path, port, true)
    match server_result:
        Err(e):
            print "Error: " + str(e)
            return 1
        Ok(server0):
            val server: WebServer = server0
            server.start()
            return 0
