# SDoctest coverage helpers.

fn validate_tag_format(tag: text) -> bool:
    val parts = tag.split(":")
    if parts.len() != 2:
        return false
    val category = parts[0]
    val name = parts[1]
    if not (category == "stdlib" or category == "core" or category == "feature"):
        return false
    if name.len() == 0:
        return false
    name == name.to_lowercase()

fn _basename_without_ext(path: text) -> text:
    val parts = path.split("/")
    var name = parts[-1]
    if name.ends_with(".spl"):
        name = name[:-4]
    if name == "mod":
        if parts.len() >= 2:
            name = parts[-2]
    name

fn suggest_missing_tags(path: text) -> [text]:
    val name = _basename_without_ext(path)
    if path.contains("/std/") or path.starts_with("src/std/"):
        return ["stdlib:{name}"]
    if path.contains("/core/") or path.starts_with("src/core/"):
        return ["core:{name}"]
    if path.contains("/app/") or path.starts_with("src/app/"):
        return ["feature:{name}"]
    []

fn _decl_name_after_prefix(line: text, prefix: text) -> text:
    var rest = line.trim()[prefix.len():].trim()
    val paren = rest.index_of("(") ?? -1
    val colon = rest.index_of(":") ?? -1
    var end = rest.len()
    if paren >= 0 and paren < end:
        end = paren
    if colon >= 0 and colon < end:
        end = colon
    rest[0:end].trim()

fn extract_function_names_from_code(code: text) -> [text]:
    var names: [text] = []
    val lines = code.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("pub fn "):
            names.push(_decl_name_after_prefix(trimmed, "pub fn "))
        elif trimmed.starts_with("fn "):
            names.push(_decl_name_after_prefix(trimmed, "fn "))
        elif trimmed.starts_with("class "):
            names.push(_decl_name_after_prefix(trimmed, "class "))
        elif trimmed.starts_with("struct "):
            names.push(_decl_name_after_prefix(trimmed, "struct "))
        elif trimmed.starts_with("enum "):
            names.push(_decl_name_after_prefix(trimmed, "enum "))
    names

fn match_functions_to_sdoctest(public_funcs: [text], blocks: [text]) -> ([text], [text]):
    var matched: [text] = []
    var missing: [text] = []
    var block_names: [text] = []
    for block in blocks:
        val names = extract_function_names_from_code(block)
        for name in names:
            block_names.push(name)
    for func in public_funcs:
        var found = false
        for name in block_names:
            if name == func:
                found = true
        if found:
            matched.push(func)
        else:
            missing.push(func)
    (matched, missing)
