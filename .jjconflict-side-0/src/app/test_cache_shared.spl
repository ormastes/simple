# Shared Test Cache — app.test_cache_shared
#
# Shared data structures and helpers for the test result cache.
# Used by test_runner_new/test_result_cache.spl, test_daemon/cache.spl,
# test_incremental_state_shared.spl, and test_runner_files.spl.

use app.io.mod.{rt_file_read_text, rt_file_write_text, rt_file_stat}

# ============================================================================
# Version
# ============================================================================

val TEST_RESULT_CACHE_VERSION: i64 = 3

# ============================================================================
# TestCacheEntry
# ============================================================================

struct TestCacheEntry:
    """Cached result for a single test file."""
    test_path: text
    dep_hash: text           # Hash of dep_paths mtimes for staleness check
    result_status: i64       # 0=pass, 1=fail, 2=error, 3=skip
    passed: i64
    failed: i64
    skipped: i64
    duration_ms: i64
    output: text
    cached_at: i64           # Unix micros when entry was written

fn stale_entry(test_path: text) -> TestCacheEntry:
    """Return a sentinel entry representing a stale/missing cache result."""
    TestCacheEntry(
        test_path: test_path,
        dep_hash: "",
        result_status: -1,
        passed: 0,
        failed: 0,
        skipped: 0,
        duration_ms: 0,
        output: "",
        cached_at: 0
    )

# ============================================================================
# Helpers
# ============================================================================

fn _dep_hash(test_path: text, dep_paths: [text]) -> text:
    """Build a simple fingerprint from file mtimes."""
    var h: text = ""
    val stat = rt_file_stat(test_path)
    h = h + stat.to_string()
    for p in dep_paths:
        val s = rt_file_stat(p)
        h = h + ":" + s.to_string()
    h

# ============================================================================
# Shared cache operations
# ============================================================================

fn shared_cache_check_freshness(entries: {text: TestCacheEntry}, test_path: text, dep_paths: [text]) -> TestCacheEntry:
    """Return the cached entry if still fresh, or a stale sentinel."""
    if not entries.?[test_path]:
        return stale_entry(test_path)
    val entry = entries[test_path]
    val current_hash = _dep_hash(test_path, dep_paths)
    if entry.dep_hash != current_hash:
        return stale_entry(test_path)
    entry

fn shared_cache_build_entry(test_path: text, dep_paths: [text], status: i64, passed: i64, failed: i64, skipped: i64, duration_ms: i64, output: text) -> TestCacheEntry:
    """Build a new cache entry for the given test result."""
    TestCacheEntry(
        test_path: test_path,
        dep_hash: _dep_hash(test_path, dep_paths),
        result_status: status,
        passed: passed,
        failed: failed,
        skipped: skipped,
        duration_ms: duration_ms,
        output: output,
        cached_at: 0
    )

fn shared_cache_save(entries: {text: TestCacheEntry}, cache_path: text):
    """Serialize entries to a line-based cache file."""
    var lines: [text] = []
    lines = lines.push("version:{TEST_RESULT_CACHE_VERSION}")
    for key in entries.keys():
        val e = entries[key]
        val line = "{e.test_path}|{e.dep_hash}|{e.result_status}|{e.passed}|{e.failed}|{e.skipped}|{e.duration_ms}"
        lines = lines.push(line)
    rt_file_write_text(cache_path, lines.join("\n"))

fn shared_cache_load_entries(cache_path: text) -> {text: TestCacheEntry}:
    """Load entries from a cache file. Returns empty dict on any error."""
    var entries: {text: TestCacheEntry} = {}
    val raw = rt_file_read_text(cache_path)
    if raw == "":
        return entries
    val lines = raw.split("\n")
    for line in lines:
        if line.starts_with("version:"):
            pass_dn
        elif line.len() > 0:
            val parts = line.split("|")
            if parts.len() >= 7:
                val entry = TestCacheEntry(
                    test_path: parts[0],
                    dep_hash: parts[1],
                    result_status: parts[2].to_int() ?? -1,
                    passed: parts[3].to_int() ?? 0,
                    failed: parts[4].to_int() ?? 0,
                    skipped: parts[5].to_int() ?? 0,
                    duration_ms: parts[6].to_int() ?? 0,
                    output: "",
                    cached_at: 0
                )
                entries[entry.test_path] = entry
    entries
