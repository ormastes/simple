# Lua Shared Library Builder
#
# Compiles a Simple source file to a shared library (.so/.dylib) suitable
# for loading into Lua/LuaJIT.
#
# Pipeline:
#   Simple source (.spl)
#     -> aot_c_file() -> C source (.c)
#     -> cc -c -fPIC    -> object file (.o)
#     -> link_to_shared -> shared library (.so)
#
# Usage:
#   bin/simple run src/app/compile/lua_shared_lib.spl <source.spl> <output.so> [--verbose]
#
# Example:
#   bin/simple run src/app/compile/lua_shared_lib.spl \
#       examples/06_io/ffi/lua_native_module.spl libsimpledemo.so

extern fn rt_cli_get_args() -> [text]
extern fn rt_getpid() -> i64

use std.io_runtime.{shell, file_exists, file_delete, env_get, host_os}
use std.string_builder.{StringBuilder}
use compiler.driver.driver.{aot_c_file}
use compiler.driver.driver_types.{CompileResult}
use compiler.backend.linker._LinkerWrapper.shared_linking.{link_to_shared}
use compiler.backend.linker._LinkerWrapper.native_linking.{NativeLinkConfig, find_runtime_lib_dir}

fn find_c_compiler() -> text:
    """Find an available C compiler (clang or gcc)."""
    val candidates = ["clang", "clang-18", "clang-17", "clang-16", "gcc"]
    for cc in candidates:
        val res = shell("which {cc} 2>/dev/null")
        if res.exit_code == 0 and res.stdout.len() > 0:
            return cc
    ""

fn main() -> i64:
    val args = rt_cli_get_args()
    # args[0] = binary, args[1] = script path, args[2] = source, args[3] = output
    if args.len() < 4:
        print "Usage: lua_shared_lib.spl <source.spl> <output.so> [--verbose]"
        return 1

    val source_file = args[2]
    val output_file = args[3]
    var verbose = false
    var i = 4
    while i < args.len():
        if args[i] == "--verbose" or args[i] == "-v":
            verbose = true
        i = i + 1

    # -------------------------------------------------------------------------
    # Step 1: Generate C source via the MIR C backend
    # -------------------------------------------------------------------------
    val pid = rt_getpid()
    val temp_c = "/tmp/spl_lua_{pid}.c"

    if verbose:
        print "[lua-shared] Step 1: Generating C from {source_file} -> {temp_c}"

    val c_result = aot_c_file(source_file, temp_c)
    match c_result:
        case CompileResult.Success(_):
            pass
        case _:
            val errors = c_result.get_errors()
            for err in errors:
                print "[lua-shared] ERROR: {err}"
            return 1

    if verbose:
        print "[lua-shared] C source generated: {temp_c}"

    # -------------------------------------------------------------------------
    # Step 2: Compile C source to a position-independent object file
    # -------------------------------------------------------------------------
    val temp_obj = "/tmp/spl_lua_{pid}.o"
    val cc = find_c_compiler()
    if cc == "":
        print "[lua-shared] ERROR: No C compiler found (tried clang, gcc)"
        file_delete(temp_c)
        return 1

    # -fPIC required for shared libraries; -DSPL_SHARED_LIBRARY activates the
    # auto-init constructor preamble emitted by _CBackendTranslate/instruction_lowering.spl
    val compile_cmd = "{cc} -std=gnu11 -fPIC -DSPL_SHARED_LIBRARY -I src/runtime/ -c '{temp_c}' -o '{temp_obj}' 2>&1"
    if verbose:
        print "[lua-shared] Step 2: {compile_cmd}"

    val compile_res = shell(compile_cmd)
    if compile_res.exit_code != 0:
        print "[lua-shared] ERROR: C compilation failed"
        print compile_res.stdout
        file_delete(temp_c)
        return 1

    file_delete(temp_c)

    # -------------------------------------------------------------------------
    # Step 3: Link the object file into a shared library
    # -------------------------------------------------------------------------
    var cfg = NativeLinkConfig.default()
    cfg.verbose = verbose
    # Shared lib does not need the full runtime (avoid DT_NEEDED on
    # libsimple_compiler.so which may not be on the host ld.so path).
    # Pass "none" to suppress the automatic runtime-lib injection.
    cfg.runtime_path = "none"
    cfg.extra_flags = ["-lpthread", "-ldl", "-lm"]

    val link_result = link_to_shared([temp_obj], output_file, cfg)
    file_delete(temp_obj)

    match link_result:
        case Ok(_):
            if verbose:
                print "[lua-shared] Shared library built: {output_file}"
            0
        case Err(msg):
            print "[lua-shared] ERROR: link_to_shared failed: {msg}"
            1
