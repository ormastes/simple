# Generated-C section map consumption for Simple-owned native layout.

struct NativeLayoutSectionMapEntry:
    symbol_name: text
    macro_name: text
    section_name: text
    valid: bool
    reason: text

struct NativeLayoutSectionMapApplication:
    enabled: bool
    applied_count: i64
    diagnostic_count: i64
    c_source: text
    diagnostics: [text]

fn _native_layout_c_line_is_function_entry(line: text) -> bool:
    val trimmed = line.trim()
    if not trimmed.contains("(") or not trimmed.contains(")") or not trimmed.contains("{"):
        return false
    if trimmed.starts_with("if ") or trimmed.starts_with("if("):
        return false
    if trimmed.starts_with("for ") or trimmed.starts_with("for("):
        return false
    if trimmed.starts_with("while ") or trimmed.starts_with("while("):
        return false
    if trimmed.starts_with("switch ") or trimmed.starts_with("switch("):
        return false
    if trimmed.starts_with("typedef "):
        return false
    if trimmed.ends_with(";"):
        return false
    trimmed.starts_with("int ") or trimmed.starts_with("void ") or trimmed.starts_with("static ") or trimmed.starts_with("RtVal ")

fn _native_layout_c_function_name(line: text) -> text:
    val before_paren_end = line.index_of("(") ?? -1
    if before_paren_end < 0:
        return ""
    val before_paren = line[0:before_paren_end].trim()
    val parts = before_paren.split(" ")
    if parts.len() == 0:
        return ""
    var name = parts[parts.len() - 1].trim()
    name = name.replace("*", "")
    name

fn _native_layout_macro_symbol_name(macro_name: text) -> text:
    val prefix = "SIMPLE_LAYOUT_SECTION_"
    if macro_name.starts_with(prefix):
        return macro_name[prefix.len():]
    ""

fn _native_layout_section_from_macro_line(line: text) -> text:
    val marker = "section(\""
    val start = line.index_of(marker) ?? -1
    if start < 0:
        return ""
    val value_start = start + marker.len()
    val rest = line[value_start:]
    val end = rest.index_of("\"") ?? -1
    if end < 0:
        return ""
    rest[0:end]

fn native_layout_section_map_entry_from_line(line: text) -> NativeLayoutSectionMapEntry:
    val trimmed = line.trim()
    if not trimmed.starts_with("#define SIMPLE_LAYOUT_SECTION_"):
        return NativeLayoutSectionMapEntry(symbol_name: "", macro_name: "", section_name: "", valid: false, reason: "not_section_map_define")
    val parts = trimmed.split(" ")
    if parts.len() < 3:
        return NativeLayoutSectionMapEntry(symbol_name: "", macro_name: "", section_name: "", valid: false, reason: "malformed_define")
    val macro_name = parts[1].trim()
    val symbol_name = _native_layout_macro_symbol_name(macro_name)
    val section_name = _native_layout_section_from_macro_line(trimmed)
    if symbol_name == "":
        return NativeLayoutSectionMapEntry(symbol_name: symbol_name, macro_name: macro_name, section_name: section_name, valid: false, reason: "missing_symbol")
    if section_name == "" or not section_name.starts_with(".text.simple."):
        return NativeLayoutSectionMapEntry(symbol_name: symbol_name, macro_name: macro_name, section_name: section_name, valid: false, reason: "invalid_section")
    NativeLayoutSectionMapEntry(symbol_name: symbol_name, macro_name: macro_name, section_name: section_name, valid: true, reason: "ok")

fn native_layout_section_map_entries(section_map_text: text) -> [NativeLayoutSectionMapEntry]:
    var entries: [NativeLayoutSectionMapEntry] = []
    val lines = section_map_text.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i].trim()
        if line.starts_with("#define SIMPLE_LAYOUT_SECTION_"):
            entries.push(native_layout_section_map_entry_from_line(line))
        i = i + 1
    entries

fn _native_layout_section_map_entry_for_symbol(entries: [NativeLayoutSectionMapEntry], symbol_name: text) -> NativeLayoutSectionMapEntry:
    var i = 0
    while i < entries.len():
        if entries[i].valid and entries[i].symbol_name == symbol_name:
            return entries[i]
        i = i + 1
    NativeLayoutSectionMapEntry(symbol_name: symbol_name, macro_name: "", section_name: "", valid: false, reason: "missing_section_map_entry")

fn _native_layout_section_map_symbol_applied(applied_symbols: [text], symbol_name: text) -> bool:
    applied_symbols.contains(symbol_name)

fn _native_layout_section_map_macro_definition(entry: NativeLayoutSectionMapEntry) -> text:
    "#define " + entry.macro_name + " __attribute__((section(\"" + entry.section_name + "\"), used))"

fn native_layout_apply_c_section_map(c_source: text, section_map_text: text, enabled: bool) -> NativeLayoutSectionMapApplication:
    if not enabled:
        return NativeLayoutSectionMapApplication(enabled: false, applied_count: 0, diagnostic_count: 0, c_source: c_source, diagnostics: [])

    val entries = native_layout_section_map_entries(section_map_text)
    var diagnostics: [text] = []
    var macro_definitions: [text] = []
    var valid_count = 0
    var entry_i = 0
    while entry_i < entries.len():
        if entries[entry_i].valid:
            valid_count = valid_count + 1
            macro_definitions.push(_native_layout_section_map_macro_definition(entries[entry_i]))
        else:
            diagnostics.push("invalid_section_map_entry:" + entries[entry_i].reason)
        entry_i = entry_i + 1
    if valid_count == 0:
        diagnostics.push("empty_section_map")
        return NativeLayoutSectionMapApplication(enabled: true, applied_count: 0, diagnostic_count: diagnostics.len(), c_source: c_source, diagnostics: diagnostics)

    var output: [text] = []
    var applied_symbols: [text] = []
    val lines = c_source.split("\n")
    var i = 0
    while i < lines.len():
        val line = lines[i]
        if _native_layout_c_line_is_function_entry(line):
            val function_name = _native_layout_c_function_name(line)
            val entry = _native_layout_section_map_entry_for_symbol(entries, function_name)
            if entry.valid:
                output.push(entry.macro_name + " " + line)
                applied_symbols.push(function_name)
            else:
                output.push(line)
        else:
            output.push(line)
        i = i + 1

    entry_i = 0
    while entry_i < entries.len():
        if entries[entry_i].valid and not _native_layout_section_map_symbol_applied(applied_symbols, entries[entry_i].symbol_name):
            diagnostics.push("unused_section_map_entry:" + entries[entry_i].symbol_name)
        entry_i = entry_i + 1

    NativeLayoutSectionMapApplication(
        enabled: true,
        applied_count: applied_symbols.len(),
        diagnostic_count: diagnostics.len(),
        c_source: macro_definitions.join("\n") + "\n" + output.join("\n"),
        diagnostics: diagnostics
    )
