# Power CLI entrypoint.
# Startup-light command planner for source-mode help and readiness probes.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}

val TOOL_NAME = "Simple Power"
val TOOL_VERSION = "0.1.0"
val DEFAULT_CONFIG_PATH = "config/t32/t32_terminal.sdn"

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("power", log_opts.error)
        return 1

    val args = power_clean_log_args(raw_args)
    if args.len() > 0 and (args[0] == "--help" or args[0] == "-h" or args[0] == "help"):
        print_help_with_progress(log_opts.progress)
        return 0
    if args.len() > 0 and (args[0] == "--version" or args[0] == "-v"):
        if log_opts.log_mode == "json":
            print "{\"command\":\"power\",\"status\":\"ok\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            print "{TOOL_NAME} v{TOOL_VERSION}"
        return 0

    val unknown = power_first_unknown_option(args)
    if unknown != "":
        val message = "Unknown power option: {unknown}"
        power_print_error(log_opts.log_mode, message)
        return 1

    if args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"power\",\"status\":\"ready\",\"tool\":\"{TOOL_NAME}\",\"version\":\"{TOOL_VERSION}\"}"
        else:
            val progress = render_progress(log_opts.progress, 1, 1, "power")
            if progress != "":
                print progress
            print "{TOOL_NAME} v{TOOL_VERSION}"
            print "Ready for power command planning."
        return 0

    val op = power_operation_arg(args)
    if not power_is_command(op):
        val message = "Unknown power command: {op}"
        power_print_error(log_opts.log_mode, message)
        return 1

    val config_path = power_config_arg(args)
    val target = power_target_arg(args)
    if op != "list" and target == "":
        val message = "Power command {op} requires a target"
        power_print_error(log_opts.log_mode, message)
        return 1

    if log_opts.log_mode == "json":
        print "{\"command\":\"power\",\"status\":\"planned\",\"operation\":\"{op}\",\"target\":\"{target}\",\"config\":\"{config_path}\"}"
    else:
        val progress = render_progress(log_opts.progress, 1, 1, "power-plan")
        if progress != "":
            print progress
        print "Power operation: {op}"
        if target != "":
            print "Target: {target}"
        print "Config: {config_path}"
    0

fn print_help():
    print "{TOOL_NAME}"
    print ""
    print "Usage: simple power <command> [target] [options]"
    print ""
    print "Commands:"
    print "  on <name>       Power on a target"
    print "  off <name>      Power off a target"
    print "  reset <name>    Reset a target"
    print "  state <name>    Query power state"
    print "  toggle <name>   Toggle power state"
    print "  list            List configured power targets"
    print ""
    print "Options:"
    print "  -h, --help          Show this help message"
    print "  -v, --version       Show version information"
    print "  --config <PATH>     Power config path (default: {DEFAULT_CONFIG_PATH})"
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn print_help_with_progress(progress_mode: text):
    val progress = render_progress(progress_mode, 0, 1, "usage")
    if progress != "":
        print progress
    print_help()

fn power_print_error(log_mode: text, message: text):
    if log_mode == "json":
        print "{\"command\":\"power\",\"status\":\"error\",\"message\":\"{message}\"}"
    else:
        error("power", message)

fn power_is_command(op: text) -> bool:
    op == "on" or op == "off" or op == "reset" or op == "state" or
        op == "toggle" or op == "list"

fn power_operation_arg(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--config":
            i = i + 2
        elif arg.starts_with("--config="):
            i = i + 1
        elif arg.starts_with("-"):
            i = i + 1
        else:
            return arg
    ""

fn power_target_arg(args: [text]) -> text:
    var found_op = false
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--config":
            i = i + 2
        elif arg.starts_with("--config="):
            i = i + 1
        elif arg.starts_with("-"):
            i = i + 1
        elif not found_op:
            found_op = true
            i = i + 1
        else:
            return arg
    ""

fn power_config_arg(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--config" and i + 1 < args.len():
            return args[i + 1]
        if arg.starts_with("--config="):
            return arg.substring("--config=".len())
        i = i + 1
    DEFAULT_CONFIG_PATH

fn power_first_unknown_option(args: [text]) -> text:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--config":
            i = i + 2
        elif arg.starts_with("--config="):
            i = i + 1
        elif arg.starts_with("-"):
            return arg
        else:
            i = i + 1
    ""

fn power_is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn power_clean_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if power_is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
