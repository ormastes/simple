#![allow(unnamed_duplicate_typed_args)]
"""Secret Scanner — detect hardcoded secrets in source files

Integrated scanner for `simple lint --secrets`. Detects API keys,
tokens, private keys, connection strings, and high-entropy strings.

Usage:
    val scanner = SecretScanner.default()
    val matches = scanner.scan_directory("src/")
    print format_results(matches)
"""

use std.fs.{read_file, list_dir, is_file, is_dir}

# --- Data Types ---

class SecretMatch:
    """A single detected secret occurrence."""
    file: text
    line: i64
    pattern_name: text
    matched_text: text
    severity: text

class SecretPattern:
    """A regex-like pattern for detecting a specific secret type."""
    name: text
    pattern: text
    severity: text
    description: text

class SecretScanner:
    """Scans files and directories for hardcoded secrets."""
    patterns: [SecretPattern]
    ignore_paths: [text]
    ignore_extensions: [text]

    static fn default() -> SecretScanner:
        """Create a scanner with default patterns and ignore rules."""
        SecretScanner(
            patterns: default_patterns(),
            ignore_paths: default_ignore_paths(),
            ignore_extensions: default_ignore_extensions()
        )

    me scan_file(path: text) -> [SecretMatch]:
        """Scan a single file for secrets. Skips binary files."""
        var matches: [SecretMatch] = []

        if not is_file(path):
            return matches

        # Skip ignored extensions
        for ext in self.ignore_extensions:
            if path.ends_with(ext):
                return matches

        # Skip ignored paths
        for ignored in self.ignore_paths:
            if path.contains(ignored):
                return matches

        val content = read_file(path)
        if content == "":
            return matches

        # Skip binary files (check for null bytes in first 8K)
        val check_len = if content.len() < 8192: content.len() else: 8192
        val prefix = content[0:check_len]
        if prefix.contains("\0"):
            return matches

        val is_test = path.ends_with("_spec.spl") or path.ends_with("_test.spl")
        val lines = content.split("\n")
        var line_num = 0

        for line in lines:
            line_num = line_num + 1
            val trimmed = line.trim()

            # Skip empty lines and comments
            if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("//"):
                pass_dn
            else:
                # Skip lines with @allow(hardcoded_secret) annotation
                if trimmed.contains("@allow(hardcoded_secret)"):
                    pass_dn
                else:
                    for pat in self.patterns:
                        # Skip high-entropy checks for test files
                        if is_test and (pat.name == "high_entropy_hex" or pat.name == "high_entropy_base64" or pat.name == "jwt_token"):
                            pass_dn
                        else:
                            if match_pattern(line, pat):
                                val masked = mask_secret(extract_match(line, pat))
                                matches.push(SecretMatch(
                                    file: path,
                                    line: line_num,
                                    pattern_name: pat.name,
                                    matched_text: masked,
                                    severity: pat.severity
                                ))

        matches

    me scan_directory(path: text) -> [SecretMatch]:
        """Recursively scan a directory for secrets."""
        var matches: [SecretMatch] = []

        if not is_dir(path):
            return matches

        val entries = list_dir(path)
        for entry in entries:
            val full_path = "{path}/{entry}"

            # Skip ignored paths
            var should_skip = false
            for ignored in self.ignore_paths:
                if full_path.contains(ignored):
                    should_skip = true

            if not should_skip:
                if is_dir(full_path):
                    val sub_matches = self.scan_directory(full_path)
                    for m in sub_matches:
                        matches.push(m)
                elif is_file(full_path):
                    val file_matches = self.scan_file(full_path)
                    for m in file_matches:
                        matches.push(m)

        matches

    me scan_staged_files() -> [SecretMatch]:
        """Scan only git-staged files for secrets."""
        var matches: [SecretMatch] = []

        # Get staged files from git
        val staged = git_staged_files()
        for file in staged:
            val file_matches = self.scan_file(file)
            for m in file_matches:
                matches.push(m)

        matches

# --- Pattern Matching ---

fn match_pattern(line: text, pat: SecretPattern) -> bool:
    """Check if a line matches a secret pattern.

    Uses string-based matching since the Simple runtime does not have
    a full regex engine available in all build modes.
    """
    match pat.name:
        "aws_access_key":
            line.contains("AKIA") and has_alphanum_run(line, "AKIA", 16)
        "github_token_ghp":
            line.contains("ghp_") and has_alphanum_run(line, "ghp_", 36)
        "github_token_gho":
            line.contains("gho_") and has_alphanum_run(line, "gho_", 36)
        "github_token_ghs":
            line.contains("ghs_") and has_alphanum_run(line, "ghs_", 36)
        "github_token_ghr":
            line.contains("ghr_") and has_alphanum_run(line, "ghr_", 36)
        "anthropic_key":
            line.contains("sk-ant-") and has_alphanum_run(line, "sk-ant-", 20)
        "openai_key":
            line.contains("sk-") and has_alphanum_run(line, "sk-", 20) and not line.contains("sk-ant-")
        "google_api_key":
            line.contains("AIza") and has_alphanum_run(line, "AIza", 35)
        "private_key":
            line.contains("-----BEGIN") and line.contains("PRIVATE KEY-----")
        "slack_token_xoxb":
            line.contains("xoxb-") and has_alphanum_run(line, "xoxb-", 10)
        "slack_token_xoxp":
            line.contains("xoxp-") and has_alphanum_run(line, "xoxp-", 10)
        "slack_token_xoxs":
            line.contains("xoxs-") and has_alphanum_run(line, "xoxs-", 10)
        "stripe_secret_key":
            line.contains("sk_live_") and has_alphanum_run(line, "sk_live_", 20)
        "stripe_publishable_key":
            line.contains("pk_live_") and has_alphanum_run(line, "pk_live_", 20)
        "connection_string":
            has_connection_string(line)
        "high_entropy_hex":
            has_long_hex(line, 64) and not is_safe_hex_context(line)
        "high_entropy_base64":
            has_long_base64(line, 40) and not is_safe_base64_context(line)
        "jwt_token":
            has_jwt_pattern(line)
        "database_password":
            has_db_password(line)
        _:
            false

fn extract_match(line: text, pat: SecretPattern) -> text:
    """Extract the matched secret fragment from a line."""
    match pat.name:
        "aws_access_key":
            extract_after_prefix(line, "AKIA", 16)
        "github_token_ghp":
            extract_after_prefix(line, "ghp_", 36)
        "github_token_gho":
            extract_after_prefix(line, "gho_", 36)
        "github_token_ghs":
            extract_after_prefix(line, "ghs_", 36)
        "github_token_ghr":
            extract_after_prefix(line, "ghr_", 36)
        "anthropic_key":
            extract_after_prefix(line, "sk-ant-", 24)
        "openai_key":
            extract_after_prefix(line, "sk-", 24)
        "private_key":
            "-----BEGIN PRIVATE KEY-----"
        "connection_string":
            "://***:***@..."
        _:
            val trimmed = line.trim()
            if trimmed.len() > 20:
                trimmed[0:20]
            else:
                trimmed

fn extract_after_prefix(line: text, prefix: text, max_len: i64) -> text:
    """Extract characters after a prefix up to max_len."""
    val idx = line.find(prefix)
    if idx < 0:
        return prefix
    val start = idx
    val end_limit = start + prefix.len() + max_len
    val end = if end_limit < line.len(): end_limit else: line.len()
    line[start:end]

# --- String analysis helpers ---

fn has_alphanum_run(line: text, prefix: text, min_len: i64) -> bool:
    """Check if there are at least min_len alphanumeric chars after prefix."""
    val idx = line.find(prefix)
    if idx < 0:
        return false
    val after_start = idx + prefix.len()
    if after_start + min_len > line.len():
        return false
    var count = 0
    var i = after_start
    while i < line.len() and count < min_len:
        val ch = line[i:i + 1]
        if is_alphanum_char(ch):
            count = count + 1
            i = i + 1
        else:
            return false
    count >= min_len

fn is_alphanum_char(ch: text) -> bool:
    """Check if a single character is alphanumeric, hyphen, or underscore."""
    if ch.len() != 1:
        return false
    val c = ch[0:1]
    (c >= "a" and c <= "z") or (c >= "A" and c <= "Z") or (c >= "0" and c <= "9") or c == "-" or c == "_"

fn has_connection_string(line: text) -> bool:
    """Check for connection strings with embedded credentials."""
    if not line.contains("://"):
        return false
    if not line.contains("@"):
        return false
    # Skip safe patterns
    if line.contains("://localhost") or line.contains("://example"):
        return false
    if line.contains("://user:pass") or line.contains("://{"):
        return false
    if line.contains("git@"):
        return false
    # Look for ://....:....@ pattern
    val proto_idx = line.find("://")
    val at_idx = line.find("@")
    if proto_idx >= 0 and at_idx > proto_idx:
        val between = line[proto_idx + 3:at_idx]
        if between.contains(":"):
            return true
    false

fn has_long_hex(line: text, min_len: i64) -> bool:
    """Check for hex strings longer than min_len."""
    var run = 0
    for i in 0..line.len():
        val ch = line[i:i + 1]
        if is_hex_char(ch):
            run = run + 1
            if run >= min_len:
                return true
        else:
            run = 0
    false

fn is_hex_char(ch: text) -> bool:
    """Check if a character is a hex digit."""
    (ch >= "0" and ch <= "9") or (ch >= "a" and ch <= "f") or (ch >= "A" and ch <= "F")

fn is_safe_hex_context(line: text) -> bool:
    """Check if a hex string is in a known-safe context."""
    val lower = line.lower()
    (lower.contains("checksum") or lower.contains("hash") or
     lower.contains("sha256") or lower.contains("sha512") or
     lower.contains("digest") or lower.contains("fingerprint") or
     lower.contains("expected"))

fn has_long_base64(line: text, min_len: i64) -> bool:
    """Check for base64-like strings longer than min_len."""
    var run = 0
    for i in 0..line.len():
        val ch = line[i:i + 1]
        if is_base64_char(ch):
            run = run + 1
            if run >= min_len:
                return true
        else:
            run = 0
    false

fn is_base64_char(ch: text) -> bool:
    """Check if a character is valid in base64."""
    (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "+" or ch == "/" or ch == "="

fn is_safe_base64_context(line: text) -> bool:
    """Check if a base64 string is in a known-safe context."""
    val lower = line.lower()
    (lower.contains("base64") or lower.contains("encode") or
     lower.contains("decode") or lower.contains("test") or
     lower.contains("example") or lower.contains("mock") or
     lower.contains("fixture") or lower.contains("checksum") or
     lower.contains("hash") or lower.contains("pub_key") or
     lower.contains("public_key") or lower.contains("pattern") or
     lower.contains("regex") or lower.contains("match"))

fn has_jwt_pattern(line: text) -> bool:
    """Check for JWT-like patterns: three base64url segments separated by dots."""
    # JWT format: xxxxx.yyyyy.zzzzz (each segment is base64url, >= 10 chars)
    val parts = line.split(".")
    if parts.len() < 3:
        return false
    # Check if any 3 consecutive parts look like JWT segments
    for i in 0..parts.len() - 2:
        val p1 = parts[i].trim()
        val p2 = parts[i + 1].trim()
        val p3 = parts[i + 2].trim()
        if p1.len() >= 10 and p2.len() >= 10 and p3.len() >= 10:
            if is_base64url_segment(p1) and is_base64url_segment(p2) and is_base64url_segment(p3):
                return true
    false

fn is_base64url_segment(s: text) -> bool:
    """Check if a string looks like a base64url segment."""
    if s.len() < 10:
        return false
    var valid_count = 0
    for i in 0..s.len():
        val ch = s[i:i + 1]
        if is_base64_char(ch) or ch == "-" or ch == "_":
            valid_count = valid_count + 1
    # At least 80% of chars should be valid base64url
    valid_count * 100 / s.len() >= 80

fn has_db_password(line: text) -> bool:
    """Check for database password patterns in connection strings."""
    val lower = line.lower()
    if lower.contains("password=") or lower.contains("pwd="):
        # Skip empty passwords and placeholders
        if lower.contains("password=''") or lower.contains("password=\"\""):
            return false
        if lower.contains("password=$") or lower.contains("password={"):
            return false
        if lower.contains("pwd=''") or lower.contains("pwd=\"\""):
            return false
        return true
    false

# --- Git integration ---

fn git_staged_files() -> [text]:
    """Get list of staged files from git."""
    # This would call git diff --cached --name-only
    # For now, returns empty list — real implementation uses process FFI
    []

# --- Default patterns ---

fn default_patterns() -> [SecretPattern]:
    """Return the default set of secret detection patterns."""
    [
        SecretPattern(
            name: "aws_access_key",
            pattern: "AKIA[0-9A-Z]{16}",
            severity: "critical",
            description: "AWS Access Key ID"
        ),
        SecretPattern(
            name: "github_token_ghp",
            pattern: "ghp_[A-Za-z0-9]{36}",
            severity: "critical",
            description: "GitHub Personal Access Token"
        ),
        SecretPattern(
            name: "github_token_gho",
            pattern: "gho_[A-Za-z0-9]{36}",
            severity: "critical",
            description: "GitHub OAuth Token"
        ),
        SecretPattern(
            name: "github_token_ghs",
            pattern: "ghs_[A-Za-z0-9]{36}",
            severity: "critical",
            description: "GitHub App Installation Token"
        ),
        SecretPattern(
            name: "github_token_ghr",
            pattern: "ghr_[A-Za-z0-9]{36}",
            severity: "critical",
            description: "GitHub Refresh Token"
        ),
        SecretPattern(
            name: "anthropic_key",
            pattern: "sk-ant-[A-Za-z0-9-]+",
            severity: "critical",
            description: "Anthropic API Key"
        ),
        SecretPattern(
            name: "openai_key",
            pattern: "sk-[A-Za-z0-9]{20,}",
            severity: "critical",
            description: "OpenAI API Key"
        ),
        SecretPattern(
            name: "google_api_key",
            pattern: "AIza[0-9A-Za-z_-]{35}",
            severity: "critical",
            description: "Google API Key"
        ),
        SecretPattern(
            name: "private_key",
            pattern: "-----BEGIN.*PRIVATE KEY-----",
            severity: "critical",
            description: "Private Key (PEM format)"
        ),
        SecretPattern(
            name: "slack_token_xoxb",
            pattern: "xoxb-[A-Za-z0-9-]+",
            severity: "critical",
            description: "Slack Bot Token"
        ),
        SecretPattern(
            name: "slack_token_xoxp",
            pattern: "xoxp-[A-Za-z0-9-]+",
            severity: "critical",
            description: "Slack User Token"
        ),
        SecretPattern(
            name: "slack_token_xoxs",
            pattern: "xoxs-[A-Za-z0-9-]+",
            severity: "critical",
            description: "Slack Session Token"
        ),
        SecretPattern(
            name: "stripe_secret_key",
            pattern: "sk_live_[A-Za-z0-9]+",
            severity: "critical",
            description: "Stripe Secret Key (live)"
        ),
        SecretPattern(
            name: "stripe_publishable_key",
            pattern: "pk_live_[A-Za-z0-9]+",
            severity: "critical",
            description: "Stripe Publishable Key (live)"
        ),
        SecretPattern(
            name: "connection_string",
            pattern: "://[^/]*:[^@]*@",
            severity: "warning",
            description: "Connection string with embedded credentials"
        ),
        SecretPattern(
            name: "database_password",
            pattern: "password=...",
            severity: "warning",
            description: "Database password in connection config"
        ),
        SecretPattern(
            name: "jwt_token",
            pattern: "eyJ...",
            severity: "warning",
            description: "JWT token (3 base64 segments)"
        ),
        SecretPattern(
            name: "high_entropy_hex",
            pattern: "[0-9a-fA-F]{64,}",
            severity: "warning",
            description: "High-entropy hex string (possible key)"
        ),
        SecretPattern(
            name: "high_entropy_base64",
            pattern: "[A-Za-z0-9+/=]{40,}",
            severity: "warning",
            description: "High-entropy base64-like string (possible key)"
        )
    ]

fn default_ignore_paths() -> [text]:
    """Paths to skip during scanning."""
    [
        ".git/",
        ".jj/",
        "node_modules/",
        "target/",
        "build/",
        ".simple/",
        "vendor/"
    ]

fn default_ignore_extensions() -> [text]:
    """File extensions to skip (binary/generated)."""
    [
        ".o", ".a", ".so", ".dylib", ".dll",
        ".exe", ".bin",
        ".png", ".jpg", ".jpeg", ".gif", ".ico", ".bmp",
        ".pdf", ".zip", ".tar", ".gz", ".bz2",
        ".wasm", ".smf", ".spk",
        ".pyc", ".class"
    ]

# --- Formatting ---

fn mask_secret(s: text) -> text:
    """Mask a secret string, showing only the first 4 characters.

    Example: "ghp_abcdefghij..." -> "ghp_****"
    """
    if s.len() <= 4:
        return "****"
    "{s[0:4]}****"

fn format_results(matches: [SecretMatch]) -> text:
    """Format scan results for CLI output."""
    if matches.len() == 0:
        return "Secret scan passed: no secrets found"

    var output = "Secret scan failed: {matches.len()} potential secret(s) found\n\n"

    for m in matches:
        val severity_tag = if m.severity == "critical": "[CRITICAL]" else: "[WARNING]"
        output = output + "{severity_tag} {m.file}:{m.line} -- {m.pattern_name}: {m.matched_text}\n"

    output = output + "\nTo fix:\n"
    output = output + "  1. Remove the secret from the file\n"
    output = output + "  2. Use environment variables or ~/.simple/credentials.sdn instead\n"
    output = output + "  3. Add @allow(hardcoded_secret) above the line for false positives\n"
    output

fn format_results_json(matches: [SecretMatch]) -> text:
    """Format scan results as JSON."""
    if matches.len() == 0:
        return "{\"count\": 0, \"matches\": []}"

    var items: [text] = []
    for m in matches:
        items.push("{\"file\": \"{m.file}\", \"line\": {m.line}, \"pattern\": \"{m.pattern_name}\", \"severity\": \"{m.severity}\"}")

    val joined = items.join(", ")
    "{\"count\": {matches.len()}, \"matches\": [{joined}]}"
