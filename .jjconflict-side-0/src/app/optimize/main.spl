# Simple CLI - optimize command
# General-purpose optimizer: MIR passes, DB query patterns, and general optimizations.

use std.cli.cli_util.{get_cli_args}
use std.io.{file_exists}
use app.optimize.analyze.{optimize_analyze, optimize_db_analyze, optimize_full_analyze}
use app.optimize.compare.{optimize_compare}
use app.optimize.apply.{optimize_apply}
use app.optimize.profile_layout_cli.{profile_layout_write_manifest_file, profile_layout_write_artifact_file}

fn print_optimize_help():
    print "Usage: simple optimize <file.spl> [options]"
    print ""
    print "Analyze and optimize Simple source files across multiple domains."
    print ""
    print "Options:"
    print "  --compare             Benchmark Simple codegen vs C codegen"
    print "  --apply               Auto-apply safe optimization passes"
    print "  --db-analyze          Analyze DB query patterns (linear scans, missing indexes)"
    print "  --full                Full analysis: MIR + DB + general patterns combined"
    print "  --layout-plan         Build pure-Simple profile-guided executable layout manifest"
    print "  --profile=PATH        .sprof profile input for --layout-plan"
    print "  --manifest=PATH       Native/settlement executable metadata input for --layout-plan"
    print "  --out=PATH            Output manifest path for --layout-plan"
    print "  --order-out=PATH      Optional native symbol order output for --layout-plan"
    print "  --c-section-map-out=PATH  Optional generated-C section map output for --layout-plan"
    print "  --passes=P1,P2,...    Comma-separated list of MIR passes to run"
    print "  --level=O0|O1|O2|O3  MIR optimization level (default: O2)"
    print "  -h, --help            Show this help"
    print ""
    print "Optimization levels (MIR):"
    print "  O0  None        (no MIR passes)"
    print "  O1  Basic       (dce, const_fold)"
    print "  O2  Standard    (+ copy_prop, cse, inlining)  [default]"
    print "  O3  Aggressive  (+ loop opts, bounds elim)"
    print ""
    print "Examples:"
    print "  simple optimize src/app/web/server.spl"
    print "  simple optimize src/app/web/server.spl --compare"
    print "  simple optimize src/app/web/server.spl --db-analyze"
    print "  simple optimize src/app/web/server.spl --full --level=O3"
    print "  simple optimize src/app/web/server.spl --apply --level=O3"
    print "  simple optimize app.bin --layout-plan --profile=run.sprof --manifest=app.layout --out=app.opt.layout"

struct OptimizeArgs:
    file_path:    text
    do_compare:   bool
    do_apply:     bool
    do_db_analyze: bool
    do_full:      bool
    do_layout_plan: bool
    profile_path:  text
    manifest_path: text
    out_path:      text
    order_out_path: text
    c_section_map_out_path: text
    passes:       [text]
    level:        text    # "O0"|"O1"|"O2"|"O3"

fn parse_flag_value(args: [text], prefix: text) -> text:
    var i = 0
    while i < args.len():
        val a = args[i]
        if a.starts_with(prefix):
            return a[prefix.len():]
        i = i + 1
    ""

fn has_flag(args: [text], flag: text) -> bool:
    var i = 0
    while i < args.len():
        if args[i] == flag:
            return true
        i = i + 1
    false

fn split_passes(passes_str: text) -> [text]:
    if passes_str == "":
        return []
    passes_str.split(",")

fn parse_optimize_args(args: [text]) -> OptimizeArgs:
    # Under the main Simple launcher args[0] is "optimize"; under the native
    # standalone optimizer binary the file is args[0].
    var file_path = ""
    var i = if args.len() > 0 and args[0] == "optimize": 1 else: 0
    while i < args.len():
        val a = args[i]
        if not a.starts_with("-"):
            file_path = a
        i = i + 1

    val level_raw = parse_flag_value(args, "--level=")
    val level = if level_raw == "": "O2" else: level_raw

    val passes_raw = parse_flag_value(args, "--passes=")
    val passes = split_passes(passes_raw)

    OptimizeArgs(
        file_path:    file_path,
        do_compare:   has_flag(args, "--compare"),
        do_apply:     has_flag(args, "--apply"),
        do_db_analyze: has_flag(args, "--db-analyze"),
        do_full:      has_flag(args, "--full"),
        do_layout_plan: has_flag(args, "--layout-plan"),
        profile_path:  parse_flag_value(args, "--profile="),
        manifest_path: parse_flag_value(args, "--manifest="),
        out_path:      parse_flag_value(args, "--out="),
        order_out_path: parse_flag_value(args, "--order-out="),
        c_section_map_out_path: parse_flag_value(args, "--c-section-map-out="),
        passes:       passes,
        level:        level
    )

fn run_profile_layout_command(opt_args: OptimizeArgs) -> i64:
    if opt_args.profile_path == "":
        print "Error: --layout-plan requires --profile=PATH"
        return 1
    if opt_args.manifest_path == "":
        print "Error: --layout-plan requires --manifest=PATH"
        return 1
    if opt_args.out_path == "":
        print "Error: --layout-plan requires --out=PATH"
        return 1
    if not file_exists(opt_args.profile_path):
        print "Error: profile not found: {opt_args.profile_path}"
        return 1
    if not file_exists(opt_args.manifest_path):
        print "Error: manifest not found: {opt_args.manifest_path}"
        return 1

    val result = profile_layout_write_manifest_file(
        opt_args.manifest_path,
        opt_args.profile_path,
        opt_args.out_path,
        4096,
        8192,
        500,
        2
    )
    if result.status != "ok":
        print "Error: layout plan failed: {result.diagnostics.join(\",\")}"
        return 1
    print "Wrote layout manifest: {opt_args.out_path}"
    if opt_args.order_out_path != "":
        val order_result = profile_layout_write_artifact_file(
            opt_args.manifest_path,
            opt_args.profile_path,
            opt_args.order_out_path,
            "native-symbol-order",
            4096,
            8192,
            500,
            2
        )
        if order_result.status != "ok":
            print "Error: symbol order failed: {order_result.diagnostics.join(\",\")}"
            return 1
        print "Wrote native symbol order: {opt_args.order_out_path}"
    if opt_args.c_section_map_out_path != "":
        val c_result = profile_layout_write_artifact_file(
            opt_args.manifest_path,
            opt_args.profile_path,
            opt_args.c_section_map_out_path,
            "simple-c-section-map",
            4096,
            8192,
            500,
            2
        )
        if c_result.status != "ok":
            print "Error: C section map failed: {c_result.diagnostics.join(\",\")}"
            return 1
        print "Wrote C section map: {opt_args.c_section_map_out_path}"
    0

fn run_optimize_command(opt_args: OptimizeArgs) -> i64:
    if not file_exists(opt_args.file_path):
        print "Error: file not found: {opt_args.file_path}"
        return 1

    var exit_code = 0

    if opt_args.do_layout_plan:
        exit_code = run_profile_layout_command(opt_args)
    elif opt_args.do_compare:
        exit_code = optimize_compare(opt_args.file_path)
    elif opt_args.do_apply:
        exit_code = optimize_apply(opt_args.file_path, opt_args.passes, opt_args.level)
    elif opt_args.do_db_analyze:
        exit_code = optimize_db_analyze(opt_args.file_path)
    elif opt_args.do_full:
        exit_code = optimize_full_analyze(opt_args.file_path, opt_args.level)
    else:
        exit_code = optimize_analyze(opt_args.file_path, opt_args.level)

    exit_code

fn main() -> i64:
    val args = get_cli_args()

    if args.len() == 0:
        print_optimize_help()
        return 0

    # Check for help flag anywhere in args
    var hi = 0
    while hi < args.len():
        if args[hi] == "-h" or args[hi] == "--help":
            print_optimize_help()
            return 0
        hi = hi + 1

    val opt_args = parse_optimize_args(args)
    if opt_args.file_path != "":
        return run_optimize_command(opt_args)
    else:
        print_optimize_help()
        return 1
