# Publisher-like Master Pages / Templates
#
# A master page is a small, reusable set of TextFrame "stamps" (e.g. a running
# header and a footer with a page-number placeholder) that gets merged onto
# every content page of a document, Publisher/InDesign-style. Master frames
# are copied in FIRST (underneath the page's own content frames), and any
# occurrence of the literal placeholder token `#` in a master frame's text is
# substituted with the page number before the frame is stamped down.
#
# Placeholder token: the literal character `#` (chosen over `{page}` to avoid
# the string-interpolation brace trap — see language quirks). A master frame
# whose text is "Page #" becomes "Page 1", "Page 2", ... once applied.
#
# This module only composes the already-landed page_layout primitives
# (Page, TextFrame, page_new, frame_new, page_add_frame) — it does not
# reimplement page/frame storage or text flow.

use app.office.publisher.page_layout.{Page, TextFrame, page_new, page_add_frame, frame_new}

# =========================================================================
# Core Struct
# =========================================================================

struct MasterPage:
    id: text
    frames: [TextFrame]

# =========================================================================
# Constructors
# =========================================================================

fn master_new(id: text) -> MasterPage:
    """Create an empty master page with the given id."""
    return MasterPage(id: id, frames: [])

fn master_add_frame(master: MasterPage, frame: TextFrame) -> MasterPage:
    """Append a template frame to the master. Returns the updated master."""
    var new_frames: [TextFrame] = []
    for f in master.frames:
        new_frames.push(f)
    new_frames.push(frame)
    return MasterPage(id: master.id, frames: new_frames)

# =========================================================================
# Queries
# =========================================================================

fn master_frame_count(master: MasterPage) -> i32:
    """Return the number of template frames on the master."""
    var count: i32 = 0
    for f in master.frames:
        count = count + 1
    return count

# =========================================================================
# Apply
# =========================================================================

fn apply_master(master: MasterPage, page: Page, page_number: i32) -> Page:
    """Merge master's frames into page (master frames stamped down first,
    underneath the page's own content frames), substituting the `#`
    placeholder token in each master frame's text with page_number. Returns
    a new Page; the original page and master are not mutated."""
    var result = page_new(page.width, page.height)
    for mf in master.frames:
        val stamped_text = mf.text.replace("#", page_number.to_text())
        val stamped_frame = TextFrame(id: mf.id, x: mf.x, y: mf.y, w: mf.w, h: mf.h, text: stamped_text, next_id: mf.next_id)
        result = page_add_frame(result, stamped_frame)
    for f in page.frames:
        result = page_add_frame(result, f)
    return result

fn apply_master_to_all(master: MasterPage, pages: [Page], start_number: i32) -> [Page]:
    """Apply master to each page in pages, numbering sequentially from
    start_number. Returns the new list of merged pages."""
    var results: [Page] = []
    var number = start_number
    for p in pages:
        results.push(apply_master(master, p, number))
        number = number + 1
    return results
