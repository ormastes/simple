# Publisher-like Newspaper Columns
#
# Newspaper-style multi-column text layout built entirely on top of the
# already-landed page_layout primitives (Page, TextFrame, page_new,
# frame_new, page_add_frame, page_flow_text, frame_text, page_render_html).
# A column layout is just N equal-width, full-height TextFrames placed
# left-to-right across the page and chained together via next_id, so text
# poured into the first column overflows into the next column, and so on —
# no new storage or flow logic is introduced here.

use app.office.publisher.page_layout.{Page, page_new, frame_new, page_add_frame, page_flow_text, frame_text, page_render_html}

# =========================================================================
# Column Layout
# =========================================================================

fn page_with_columns(page_w: i32, page_h: i32, num_cols: i32, gutter: i32, margin: i32) -> Page:
    """Build a page of the given size containing `num_cols` equal-width
    column frames ("col0", "col1", ...) laid left-to-right inside `margin`,
    separated by `gutter`, each chained to the next via next_id so flowed
    text overflows column-to-column. The last column's next_id is ""."""
    val avail_w = page_w - 2 * margin - (num_cols - 1) * gutter
    val col_w = avail_w / num_cols
    val col_h = page_h - 2 * margin
    var page = page_new(page_w, page_h)
    var i: i32 = 0
    while i < num_cols:
        val col_x = margin + i * (col_w + gutter)
        val col_id = "col" + i.to_text()
        val next_id = if i + 1 < num_cols: "col" + (i + 1).to_text() else: ""
        val col_frame = frame_new(col_id, col_x, margin, col_w, col_h, next_id)
        page = page_add_frame(page, col_frame)
        i = i + 1
    return page

# =========================================================================
# Text Flow
# =========================================================================

fn flow_into_columns(page: Page, content: text) -> Page:
    """Flow `content` starting at the first column ("col0"), overflowing
    across the linked column chain. Returns the updated page."""
    return page_flow_text(page, "col0", content)

# =========================================================================
# Queries
# =========================================================================

fn column_text(page: Page, col_index: i32) -> text:
    """Convenience accessor for the text content of column `col_index`."""
    val col_id = "col" + col_index.to_text()
    return frame_text(page, col_id)

# =========================================================================
# HTML Rendering
# =========================================================================

fn columns_render_html(page: Page) -> text:
    """Render the column page as HTML; columns are just positioned frames,
    so this delegates directly to page_render_html."""
    return page_render_html(page)
