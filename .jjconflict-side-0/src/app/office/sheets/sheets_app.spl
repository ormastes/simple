# Simple Sheets Application
#
# Spreadsheet app with cell grid, formula bar, and formatting toolbar.

use common.ui.builder.{column, row, panel, label, text_widget, tabs, statusbar, scroll, table_widget, button}
use common.ui.ios.builder.{navigation_bar, search_bar}
use common.ui.widget.{UITree, UIEvent, WidgetNode}
use common.ui.builder.{build_tree_with_title, with_flex}
use app.office.sheets.spreadsheet.{Workbook, Sheet}
use app.office.sheets.cell.{Cell, CellValue, CellRef, CellStyle, cell_ref_to_string, col_to_letter, cell_display_text, parse_cell_ref}
use app.office.sheets.formula.{evaluate_formula}

# =========================================================================
# Application State
# =========================================================================

class SheetsApp:
    workbook: Workbook
    active_cell: CellRef
    editing: bool
    formula_text: text
    scroll_row: i32
    scroll_col: i32
    visible_rows: i32
    visible_cols: i32
    modified: bool
    file_path: text

impl SheetsApp:

    static fn new() -> SheetsApp:
        """Create a new Sheets application with an empty workbook."""
        SheetsApp(
            workbook: Workbook.new("Untitled Spreadsheet"),
            active_cell: CellRef(col: 0, row: 0),
            editing: false,
            formula_text: "",
            scroll_row: 0,
            scroll_col: 0,
            visible_rows: 30,
            visible_cols: 20,
            modified: false,
            file_path: ""
        )

    fn build_ui() -> UITree:
        """Build the full spreadsheet UI tree."""
        val active_ref_str = cell_ref_to_string(self.active_cell)

        # Navigation bar with save button
        val save_btn = button("btn_save", "Save", "save")
        val nav = navigation_bar("nav", "Simple Sheets", [], [save_btn])

        # Formula bar: cell reference label + formula input
        val ref_label = label("cell_ref_label", active_ref_str)
        val formula_display = text_widget("formula_input", _formula_bar_text(self))
        val formula_bar = row("formula_bar", [ref_label, with_flex(formula_display, 1)])

        # Grid
        val headers = self.build_grid_headers()
        val rows = self.build_grid_rows()
        val grid_widget = table_widget("cell_grid", headers, rows)
        val grid_children: [WidgetNode] = [grid_widget]
        val grid_scroll = scroll("grid_scroll", 600, grid_children)

        # Sheet tabs
        var tab_names: [text] = []
        for sheet in self.workbook.sheets:
            tab_names = tab_names.push(sheet.name)
        val sheet_tabs = tabs("sheet_tabs", tab_names)

        # Status bar with summary
        val status_text = _build_status_text(self)

        val status = statusbar("status", status_text, "Simple Sheets v1.0")

        # Root layout
        val root = column("root", [
            nav,
            formula_bar,
            grid_scroll,
            sheet_tabs,
            status
        ])

        build_tree_with_title(root, "Simple Sheets", "ios_light")

    fn build_grid_headers() -> [text]:
        """Build column headers: ['', 'A', 'B', 'C', ...] for visible columns."""
        var headers: [text] = [""]  # Empty header for row number column
        var c = 0
        while c < self.visible_cols:
            val col_idx = self.scroll_col + c
            headers = headers.push(col_to_letter(col_idx))
            c = c + 1
        headers

    fn build_grid_rows() -> [[text]]:
        """Build grid row data: [[row_num, cell_text, ...], ...] for visible rows."""
        var rows: [[text]] = []
        val sheet = self.workbook.active()
        var r = 0
        while r < self.visible_rows:
            val row_idx = self.scroll_row + r
            var row_data: [text] = ["{row_idx + 1}"]
            var c = 0
            while c < self.visible_cols:
                val col_idx = self.scroll_col + c
                val ref_val = CellRef(col: col_idx, row: row_idx)
                val ref_str = cell_ref_to_string(ref_val)
                val cell = sheet.get_cell(ref_str)
                val display = cell_display_text(cell)
                row_data = row_data.push(display)
                c = c + 1
            rows = rows.push(row_data)
            r = r + 1
        rows

    me handle_event(event: UIEvent):
        """Handle a UI event."""
        match event:
            UIEvent.Action(name):
                if name == "save":
                    self.modified = false
                elif name == "confirm_edit":
                    self.confirm_edit()
                elif name == "cancel_edit":
                    self.cancel_edit()
                elif name.starts_with("cell_click:"):
                    val ref_str = name.substring(11)
                    val ref_val = parse_cell_ref(ref_str)
                    if ref_val != nil:
                        self.navigate_to(ref_val.col, ref_val.row)
            UIEvent.KeyPress(key):
                if key == "Enter":
                    if self.editing:
                        self.confirm_edit()
                    else:
                        self.enter_edit_mode()
                elif key == "Escape":
                    if self.editing:
                        self.cancel_edit()
                elif key == "Tab":
                    self.navigate_to(self.active_cell.col + 1, self.active_cell.row)
                elif key == "ArrowUp":
                    if self.active_cell.row > 0:
                        self.navigate_to(self.active_cell.col, self.active_cell.row - 1)
                elif key == "ArrowDown":
                    self.navigate_to(self.active_cell.col, self.active_cell.row + 1)
                elif key == "ArrowLeft":
                    if self.active_cell.col > 0:
                        self.navigate_to(self.active_cell.col - 1, self.active_cell.row)
                elif key == "ArrowRight":
                    self.navigate_to(self.active_cell.col + 1, self.active_cell.row)
            _:
                pass_do_nothing

    me navigate_to(col: i32, row: i32):
        """Change the active cell and update scroll position if needed."""
        var c = col
        var r = row
        if c < 0:
            c = 0
        if r < 0:
            r = 0
        self.active_cell = CellRef(col: c, row: r)
        # Update formula text to the cell's current value
        val ref_str = cell_ref_to_string(self.active_cell)
        val cell = self.workbook.active().get_cell(ref_str)
        match cell.value:
            CellValue.FormulaVal(expr, cached_display):
                self.formula_text = "={expr}"
            CellValue.NumberVal(value):
                self.formula_text = "{value}"
            CellValue.TextVal(value):
                self.formula_text = value
            CellValue.BoolVal(value):
                self.formula_text = if value: "TRUE" else: "FALSE"
            _:
                self.formula_text = ""
        # Adjust scroll to keep active cell visible
        if c < self.scroll_col:
            self.scroll_col = c
        if c >= self.scroll_col + self.visible_cols:
            self.scroll_col = c - self.visible_cols + 1
        if r < self.scroll_row:
            self.scroll_row = r
        if r >= self.scroll_row + self.visible_rows:
            self.scroll_row = r - self.visible_rows + 1

    me enter_edit_mode():
        """Start editing the formula bar for the active cell."""
        self.editing = true
        val ref_str = cell_ref_to_string(self.active_cell)
        val cell = self.workbook.active().get_cell(ref_str)
        match cell.value:
            CellValue.FormulaVal(expr, cached_display):
                self.formula_text = "={expr}"
            CellValue.NumberVal(value):
                self.formula_text = "{value}"
            CellValue.TextVal(value):
                self.formula_text = value
            CellValue.BoolVal(value):
                self.formula_text = if value: "TRUE" else: "FALSE"
            _:
                self.formula_text = ""

    me confirm_edit():
        """Apply the formula bar value to the active cell and recalculate formulas."""
        self.editing = false
        val ref_str = cell_ref_to_string(self.active_cell)
        self.workbook.active().set_value(ref_str, self.formula_text)
        # Recalculate formulas in the active sheet
        _recalculate_formulas(self.workbook.active())
        self.modified = true

    me cancel_edit():
        """Discard formula bar changes and exit edit mode."""
        self.editing = false
        # Reset formula text to current cell value
        val ref_str = cell_ref_to_string(self.active_cell)
        val cell = self.workbook.active().get_cell(ref_str)
        match cell.value:
            CellValue.FormulaVal(expr, cached_display):
                self.formula_text = "={expr}"
            CellValue.NumberVal(value):
                self.formula_text = "{value}"
            CellValue.TextVal(value):
                self.formula_text = value
            _:
                self.formula_text = ""

# =========================================================================
# Internal Helpers
# =========================================================================

fn _build_status_text(app: SheetsApp) -> text:
    """Build the status bar text showing cell count and selection summary."""
    val sheet = app.workbook.active()
    val count = sheet.cell_count()
    val ref_str = cell_ref_to_string(app.active_cell)
    val cell = sheet.get_cell(ref_str)
    val display = cell_display_text(cell)
    var status = "Ready"
    if app.editing:
        status = "Editing"
    if app.modified:
        status = "{status} *"
    "{status} | Cells: {count} | {ref_str}: {display}"

fn _formula_bar_text(app: SheetsApp) -> text:
    if app.formula_text != "":
        return app.formula_text
    "Enter value or formula..."

fn _recalculate_formulas(sheet: Sheet):
    """Recalculate all formula cells in the sheet, updating their cached display."""
    for key in sheet.cells.keys():
        val cell = sheet.get_cell(key)
        match cell.value:
            CellValue.FormulaVal(expr, cached_display):
                val result = evaluate_formula(expr, sheet)
                var display = ""
                match result:
                    CellValue.NumberVal(value):
                        val int_val = value.to_i64()
                        val diff = value - int_val.to_f64()
                        if diff == 0.0:
                            display = "{int_val}"
                        else:
                            display = "{value}"
                    CellValue.BoolVal(value):
                        display = if value: "TRUE" else: "FALSE"
                    CellValue.TextVal(value):
                        display = value
                    CellValue.ErrorVal(message):
                        display = "#ERR: {message}"
                    _:
                        display = ""
                val updated_cell = Cell(
                    value: CellValue.FormulaVal(expr: expr, cached_display: display),
                    style: cell.style
                )
                sheet.set_cell(key, updated_cell)
            _:
                pass_do_nothing
