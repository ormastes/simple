# Data Validation Rules
#
# Parallel-array registry for Excel-style data validation: list dropdowns,
# number ranges, date ranges, text length constraints, and custom formulas.
# Keys map cell references (A1) or column letters (A) to ValidationRuleSpec entries.
#
# Storage idiom: parallel arrays (keys/specs), not Dict-in-struct, per the
# pattern in cell_format.spl. Allows copy-return semantics for macro API.

use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{Cell, CellValue, cell_display_text}

# =========================================================================
# Validation Rule Spec
# =========================================================================

struct ValidationRuleSpec:
    """A single validation rule applied to a cell or column.

    Fields:
        kind: Validation type: "list", "whole_number", "decimal", "date",
              "text_length", or "custom_formula".
        list_values: Comma-separated allowed values (for kind="list").
        min: Minimum value for whole_number/decimal/date/text_length.
        max: Maximum value for whole_number/decimal/date/text_length.
        formula_text: Formula text for kind="custom_formula" (stored,
                      evaluation is not yet wired).
        message: User-facing error message when validation fails.
    """
    kind: text
    list_values: text
    min: f64
    max: f64
    formula_text: text
    message: text

fn default_validation_spec() -> ValidationRuleSpec:
    """An empty spec with no constraints."""
    ValidationRuleSpec(kind: "", list_values: "", min: 0.0, max: 0.0,
                       formula_text: "", message: "")

# =========================================================================
# Validation Rules Container
# =========================================================================

struct ValidationRules:
    """Cell/column -> ValidationRuleSpec mapping, stored as parallel arrays."""
    keys: [text]
    specs: [ValidationRuleSpec]

fn empty_validation_rules() -> ValidationRules:
    """An empty validation container with no rules."""
    ValidationRules(keys: [], specs: [])

# =========================================================================
# Core API
# =========================================================================

fn validation_add(rules: ValidationRules, target_ref: text, kind: text,
                  list_values: text, min: f64, max: f64,
                  formula_text: text, message: text) -> ValidationRules:
    """Add or replace a validation rule for a cell or column.

    Args:
        rules: The ValidationRules container to update.
        target_ref: Cell reference (A1) or column (A).
        kind: Validation type.
        list_values: Comma-separated list (for kind="list").
        min: Minimum value.
        max: Maximum value.
        formula_text: Custom formula (for kind="custom_formula").
        message: Error message.

    Returns a new ValidationRules container (copy semantics).
    """
    val key = target_ref.upper()
    var keys = rules.keys
    var specs = rules.specs
    var i = 0
    var found_idx = -1
    while i < keys.len():
        if keys[i] == key:
            found_idx = i
        i = i + 1
    val spec = ValidationRuleSpec(kind: kind, list_values: list_values,
                                  min: min, max: max,
                                  formula_text: formula_text, message: message)
    if found_idx >= 0:
        specs[found_idx] = spec
    else:
        keys.push(key)
        specs.push(spec)
    ValidationRules(keys: keys, specs: specs)

fn validation_remove(rules: ValidationRules, target_ref: text) -> ValidationRules:
    """Remove a validation rule for a cell or column.

    Returns a new ValidationRules container.
    """
    val key = target_ref.upper()
    var keys: [text] = []
    var specs: [ValidationRuleSpec] = []
    var i = 0
    while i < rules.keys.len():
        if rules.keys[i] != key:
            keys.push(rules.keys[i])
            specs.push(rules.specs[i])
        i = i + 1
    ValidationRules(keys: keys, specs: specs)

fn _validation_find_rule(rules: ValidationRules, cell_ref: text) -> ValidationRuleSpec?:
    """Find a rule for a cell ref (exact match) or its column (prefix match)."""
    val key = cell_ref.upper()
    var i = 0
    while i < rules.keys.len():
        if rules.keys[i] == key:
            return rules.specs[i]
        i = i + 1
    val col = _validation_extract_column(key)
    i = 0
    while i < rules.keys.len():
        if rules.keys[i] == col:
            return rules.specs[i]
        i = i + 1
    nil

fn _validation_extract_column(cell_ref: text) -> text:
    """Extract column letters from a cell ref (A1 -> A, AB12 -> AB)."""
    var col = ""
    var i = 0
    while i < cell_ref.len():
        val ch = cell_ref.slice(i, i + 1)
        if ch >= "A" and ch <= "Z":
            col = "{col}{ch}"
        else:
            break
        i = i + 1
    col

fn _validation_parse_number(text_val: text) -> (bool, f64):
    """Try to parse text as a number. Returns (ok, value)."""
    if text_val == "":
        return (false, 0.0)
    if text_val.contains("."):
        val parts = text_val.split(".")
        if parts.len() == 2:
            val whole = parts[0].to_f64()
            val frac = parts[1].to_f64()
            var denom = 1.0
            var digits = parts[1].len()
            var d = 0
            while d < digits:
                denom = denom * 10.0
                d = d + 1
            return (true, whole + frac / denom)
    (true, text_val.to_f64())

fn _validation_is_integer(text_val: text) -> bool:
    """Check if text represents an integer (no decimal point)."""
    if text_val == "" or text_val.contains("."):
        return false
    match text_val.to_i64():
        _:
            true
        _:
            false

fn validation_check(rules: ValidationRules, sheet: Sheet, cell_ref: text,
                    proposed_text: text) -> (bool, text):
    """Validate a proposed cell value against applicable rules.

    Returns (true, "") if valid, or (false, error_message) if not.
    """
    val rule = _validation_find_rule(rules, cell_ref)
    if rule != nil:
        val spec = rule
        if spec.kind == "list":
            val allowed = spec.list_values.split(",")
            var i = 0
            var found = false
            while i < allowed.len():
                if allowed[i].trim() == proposed_text:
                    found = true
                i = i + 1
            if not found:
                return (false, spec.message)
        if spec.kind == "whole_number":
            if not _validation_is_integer(proposed_text):
                return (false, spec.message)
            val parse_result = _validation_parse_number(proposed_text)
            if parse_result.0:
                if parse_result.1 < spec.min or parse_result.1 > spec.max:
                    return (false, spec.message)
            else:
                return (false, spec.message)
        if spec.kind == "decimal":
            val parse_result = _validation_parse_number(proposed_text)
            if parse_result.0:
                if parse_result.1 < spec.min or parse_result.1 > spec.max:
                    return (false, spec.message)
            else:
                return (false, spec.message)
        if spec.kind == "date":
            val parse_result = _validation_parse_number(proposed_text)
            if parse_result.0:
                if parse_result.1 < spec.min or parse_result.1 > spec.max:
                    return (false, spec.message)
            else:
                return (false, spec.message)
        if spec.kind == "text_length":
            val len_val = proposed_text.len().to_f64()
            if len_val < spec.min or len_val > spec.max:
                return (false, spec.message)
        if spec.kind == "custom_formula":
            pass
    (true, "")

fn validation_list_values(rules: ValidationRules, cell_ref: text) -> [text]:
    """Extract the list of allowed values for a list validation rule.

    Returns empty array if no rule or rule is not a list kind.
    """
    val rule = _validation_find_rule(rules, cell_ref)
    if rule != nil:
        if rule.kind == "list":
            val items = rule.list_values.split(",")
            var result: [text] = []
            var i = 0
            while i < items.len():
                result.push(items[i].trim())
                i = i + 1
            return result
    []

fn validate_sheet(rules: ValidationRules, sheet: Sheet) -> [(ref: text, message: text)]:
    """Validate all cells in a sheet against applicable rules.

    Iterates the sheet's used range and collects violations.
    Returns a list of (cell_ref, error_message) tuples for failed cells.
    """
    var violations: [(ref: text, message: text)] = []
    val cell_keys = sheet.cells.keys()
    var i = 0
    while i < cell_keys.len():
        val cell_ref = cell_keys[i]
        val cell = sheet.get_cell(cell_ref)
        val display_text = cell_display_text(cell)
        val check_result = validation_check(rules, sheet, cell_ref, display_text)
        if not check_result.ok:
            violations.push((ref: cell_ref, message: check_result.message))
        i = i + 1
    violations
