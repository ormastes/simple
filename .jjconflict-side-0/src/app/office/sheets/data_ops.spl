# Data Operations
#
# Sort ranges and filter rows in spreadsheets.

use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{Cell, CellValue, CellRef, CellStyle, parse_cell_ref, cell_ref_to_string, cell_display_text, empty_cell, text_cell, number_cell, default_style}
use app.office.sheets.cell_ref.{CellRange, parse_range}
use common.office.number.{office_parse_signed_decimal_f64}

# =========================================================================
# Sort Range
# =========================================================================

fn sheet_sort_range(sheet: Sheet, range_a1: text, key_col: i32, ascending: bool, has_header: bool) -> Sheet:
    """Sort rows in a range by a key column.

    Args:
        sheet: The Sheet to sort
        range_a1: Range in A1 notation (e.g. "A1:C10")
        key_col: 0-based column within the range
        ascending: true for ascending, false for descending
        has_header: if true, first row stays in place

    Returns a new Sheet with sorted rows.
    """
    val range = parse_range(range_a1)
    if range == nil:
        return sheet

    val rng = range
    # Normalize range bounds
    val min_col = _min_i32(rng.start.col, rng.end_ref.col)
    val max_col = _max_i32(rng.start.col, rng.end_ref.col)
    val min_row = _min_i32(rng.start.row, rng.end_ref.row)
    val max_row = _max_i32(rng.start.row, rng.end_ref.row)

    # Validate key_col
    if key_col < 0 or key_col > (max_col - min_col):
        return sheet

    # Capture rows as arrays of cells
    var rows: [[Cell]] = []

    var r = min_row
    while r <= max_row:
        var row_cells: [Cell] = []
        var c = min_col
        while c <= max_col:
            val ref = CellRef(col: c, row: r)
            val ref_str = cell_ref_to_string(ref)
            val cell = sheet.get_cell(ref_str)
            row_cells.push(cell)
            c = c + 1
        rows.push(row_cells)
        r = r + 1

    # Sort rows (stable insertion sort)
    var start_idx = 0
    if has_header:
        start_idx = 1

    var i = start_idx + 1
    while i < rows.len():
        val key_row = rows[i]

        var j = i - 1
        while j >= start_idx:
            val comp_row = rows[j]
            val cmp = _compare_row_cells(comp_row, key_row, key_col, ascending)
            if cmp <= 0:
                break
            rows[j + 1] = comp_row
            j = j - 1

        rows[j + 1] = key_row
        i = i + 1

    # Write sorted rows back to sheet
    var result = sheet
    var row_idx = 0
    while row_idx < rows.len():
        val row_cells = rows[row_idx]
        var col_idx = 0
        var c = min_col
        while c <= max_col:
            val ref = CellRef(col: c, row: min_row + row_idx)
            val ref_str = cell_ref_to_string(ref)
            if col_idx < row_cells.len():
                result.set_cell(ref_str, row_cells[col_idx])
            col_idx = col_idx + 1
            c = c + 1
        row_idx = row_idx + 1

    result

# =========================================================================
# Filter Rows
# =========================================================================

fn sheet_filter_rows(sheet: Sheet, range_a1: text, col: i32, criteria: text) -> [i64]:
    """Filter rows by criteria in a column.

    Args:
        sheet: The Sheet to filter
        range_a1: Range in A1 notation (e.g. "A1:C10")
        col: 0-based column within the range
        criteria: ">5", "<=3", "<>x", or bare value (case-insensitive equality)

    Returns 1-based sheet row numbers that match the criteria.
    """
    val range = parse_range(range_a1)
    if range == nil:
        return []

    val rng = range
    # Normalize range bounds
    val min_col = _min_i32(rng.start.col, rng.end_ref.col)
    val max_col = _max_i32(rng.start.col, rng.end_ref.col)
    val min_row = _min_i32(rng.start.row, rng.end_ref.row)
    val max_row = _max_i32(rng.start.row, rng.end_ref.row)

    # Validate col
    if col < 0 or col > (max_col - min_col):
        return []

    var result: [i64] = []

    var r = min_row
    while r <= max_row:
        val actual_col = min_col + col
        val ref = CellRef(col: actual_col, row: r)
        val ref_str = cell_ref_to_string(ref)
        val cell = sheet.get_cell(ref_str)

        if _cell_matches_criteria(cell, criteria):
            result.push((r + 1).to_i64())

        r = r + 1

    result

# =========================================================================
# Internal Helpers
# =========================================================================

fn _min_i32(a: i32, b: i32) -> i32:
    if a < b:
        return a
    b

fn _max_i32(a: i32, b: i32) -> i32:
    if a > b:
        return a
    b

fn _compare_row_cells(row1: [Cell], row2: [Cell], key_col: i32, ascending: bool) -> i32:
    """Compare two rows by key column. Returns < 0 if row1 < row2, > 0 if row1 > row2, 0 if equal.
    Result is negated if descending."""
    if key_col < 0 or key_col >= row1.len() or key_col >= row2.len():
        return 0

    val cell1 = row1[key_col]
    val cell2 = row2[key_col]

    val cmp = _compare_cells(cell1, cell2)
    val result = if ascending:
        cmp
    else:
        -cmp
    result

fn _compare_cells(c1: Cell, c2: Cell) -> i32:
    """Compare two cells for sorting.
    Numbers sort numerically, text sorts lexicographically.
    Numbers sort before text.
    Empty cells sort last.
    Returns < 0 if c1 < c2, > 0 if c1 > c2, 0 if equal."""

    match c1.value:
        CellValue.Empty:
            match c2.value:
                CellValue.Empty:
                    return 0
                _:
                    return 1  # Empty sorts last
        CellValue.NumberVal(v1):
            match c2.value:
                CellValue.Empty:
                    return -1
                CellValue.NumberVal(v2):
                    if v1 < v2:
                        return -1
                    if v1 > v2:
                        return 1
                    return 0
                _:
                    return -1  # Numbers sort before text
        CellValue.TextVal(t1):
            match c2.value:
                CellValue.Empty:
                    return -1
                CellValue.NumberVal(_):
                    return 1  # Text sorts after numbers
                CellValue.TextVal(t2):
                    val lower1 = t1.lower()
                    val lower2 = t2.lower()
                    if lower1 < lower2:
                        return -1
                    if lower1 > lower2:
                        return 1
                    return 0
                _:
                    val lower1 = t1.lower()
                    val lower2 = cell_display_text(c2).lower()
                    if lower1 < lower2:
                        return -1
                    if lower1 > lower2:
                        return 1
                    return 0
        _:
            # BoolVal, FormulaVal, ErrorVal: compare by display text
            match c2.value:
                CellValue.Empty:
                    return -1
                CellValue.NumberVal(_):
                    return 1
                _:
                    val t1 = cell_display_text(c1).lower()
                    val t2 = cell_display_text(c2).lower()
                    if t1 < t2:
                        return -1
                    if t1 > t2:
                        return 1
                    return 0

fn _cell_matches_criteria(cell: Cell, criteria: text) -> bool:
    """Check if a cell matches the criteria (">5", "<=3", "<>x", or bare value)."""
    val trimmed = criteria.trim()

    # Check for comparison operators
    if trimmed.starts_with(">="):
        val val_str = trimmed.substring(2)
        val target = _parse_cell_value(val_str)
        return _compare_cells(cell, target) >= 0

    if trimmed.starts_with("<="):
        val val_str = trimmed.substring(2)
        val target = _parse_cell_value(val_str)
        return _compare_cells(cell, target) <= 0

    if trimmed.starts_with("<>"):
        val val_str = trimmed.substring(2)
        val target = _parse_cell_value(val_str)
        return _compare_cells(cell, target) != 0

    if trimmed.starts_with(">"):
        val val_str = trimmed.substring(1)
        val target = _parse_cell_value(val_str)
        return _compare_cells(cell, target) > 0

    if trimmed.starts_with("<"):
        val val_str = trimmed.substring(1)
        val target = _parse_cell_value(val_str)
        return _compare_cells(cell, target) < 0

    # Bare value: case-insensitive equality
    val display = cell_display_text(cell).lower()
    display == trimmed.lower()

fn _parse_cell_value(s: text) -> Cell:
    """Parse a string into a Cell value (number, text, or empty)."""
    val trimmed = s.trim()
    if trimmed.len() == 0:
        return empty_cell()

    # Try to parse as number
    val num = _try_parse_number(trimmed)
    if num != nil:
        return number_cell(num)

    # Otherwise text
    return text_cell(trimmed)

fn _try_parse_number(s: text) -> f64?:
    """Try to parse a number from text."""
    if s.len() == 0:
        return nil
    var has_dot = false
    var has_digit = false
    var i = 0

    # Allow leading minus
    if s.char_at(0) == "-":
        if s.len() == 1:
            return nil
        i = 1

    while i < s.len():
        val c = s.char_at(i)
        if c == ".":
            if has_dot:
                return nil
            has_dot = true
        elif _is_digit(c):
            has_digit = true
        else:
            return nil
        i = i + 1

    if not has_digit:
        return nil

    # Parse using stdlib
    return office_parse_signed_decimal_f64(s)

fn _is_digit(c: text) -> bool:
    (c == "0" or c == "1" or c == "2" or c == "3" or c == "4" or
     c == "5" or c == "6" or c == "7" or c == "8" or c == "9")

# =========================================================================
# Find & Replace
# =========================================================================

fn _cell_is_formula(cell: Cell) -> bool:
    """True when the cell holds a formula (protected from value replacement)."""
    match cell.value:
        CellValue.FormulaVal(expr, cached):
            true
        _:
            false

fn _ci_replace_all(haystack: text, needle: text, replacement: text) -> text:
    """Case-insensitive replace-all: matches needle ignoring case, substitutes
    replacement verbatim. Scans left-to-right (no index_of in the runtime)."""
    if needle.len() == 0:
        return haystack
    val nlow = needle.lower()
    var result = ""
    var i = 0
    while i < haystack.len():
        val window = haystack.slice(i, i + needle.len())
        if window.len() == needle.len() and window.lower() == nlow:
            result = "{result}{replacement}"
            i = i + needle.len()
        else:
            result = "{result}{haystack.char_at(i)}"
            i = i + 1
    result

fn sheet_find(sheet: Sheet, needle: text, match_case: bool) -> [text]:
    """A1 refs (row-major over the used range) whose display text contains
    needle. Case-insensitive unless match_case is true. Empty needle → []."""
    if needle.len() == 0:
        return []
    val range_a1 = sheet.used_range()
    val range = parse_range(range_a1)
    if range == nil:
        return []
    val rng = range
    val min_col = _min_i32(rng.start.col, rng.end_ref.col)
    val max_col = _max_i32(rng.start.col, rng.end_ref.col)
    val min_row = _min_i32(rng.start.row, rng.end_ref.row)
    val max_row = _max_i32(rng.start.row, rng.end_ref.row)
    val nlow = needle.lower()

    var result: [text] = []
    var r = min_row
    while r <= max_row:
        var c = min_col
        while c <= max_col:
            val ref = CellRef(col: c, row: r)
            val ref_str = cell_ref_to_string(ref)
            val cell = sheet.get_cell(ref_str)
            val display = cell_display_text(cell)
            var hit = false
            if match_case:
                hit = display.contains(needle)
            else:
                hit = display.lower().contains(nlow)
            if hit:
                result.push(ref_str)
            c = c + 1
        r = r + 1
    result

fn sheet_replace(sheet: Sheet, needle: text, replacement: text, match_case: bool) -> Sheet:
    """Replace needle with replacement in the display value of every non-formula
    cell in the used range (formula cells are left untouched). Returns the
    mutated sheet (Sheet is a class, but the return preserves the codebase's
    return-the-object convention)."""
    var result_sheet = sheet
    if needle.len() == 0:
        return result_sheet
    val range_a1 = result_sheet.used_range()
    val range = parse_range(range_a1)
    if range == nil:
        return result_sheet
    val rng = range
    val min_col = _min_i32(rng.start.col, rng.end_ref.col)
    val max_col = _max_i32(rng.start.col, rng.end_ref.col)
    val min_row = _min_i32(rng.start.row, rng.end_ref.row)
    val max_row = _max_i32(rng.start.row, rng.end_ref.row)

    var r = min_row
    while r <= max_row:
        var c = min_col
        while c <= max_col:
            val ref = CellRef(col: c, row: r)
            val ref_str = cell_ref_to_string(ref)
            val cell = result_sheet.get_cell(ref_str)
            if not _cell_is_formula(cell):
                val display = cell_display_text(cell)
                var matched = false
                if match_case:
                    matched = display.contains(needle)
                else:
                    matched = display.lower().contains(needle.lower())
                if matched:
                    var replaced = ""
                    if match_case:
                        replaced = display.replace(needle, replacement)
                    else:
                        replaced = _ci_replace_all(display, needle, replacement)
                    result_sheet.set_value(ref_str, replaced)
            c = c + 1
        r = r + 1
    result_sheet
