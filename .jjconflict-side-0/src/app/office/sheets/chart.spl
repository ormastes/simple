# Calc Charts — SVG charts from a sheet range
#
# Pure model->SVG transform: labels from one column range, values from another
# (e.g. chart_from_ranges(sheet, "A2:A4", "B2:B4")). Column/line/area charts
# carry a numeric Y axis with "nice" rounded ticks, category/X labels, and a
# series legend; scatter (XY) plots two numeric ranges as points; pie uses a
# stroke-dasharray donut with a category legend. No external assets.

use app.office.sheets.spreadsheet.{Sheet}
use app.office.sheets.cell.{cell_display_text, CellValue}
use app.office.sheets.cell_ref.{parse_range, expand_range_refs}

struct ChartSeries:
    labels: [text]
    values: [f64]
    name: text

struct ChartXY:
    xs: [f64]
    ys: [f64]
    name: text

fn _cell_number(sheet: Sheet, ref_str: text) -> f64:
    val cell = sheet.get_cell(ref_str)
    match cell.value:
        CellValue.NumberVal(value):
            return value
        CellValue.FormulaVal(expr, cached_display):
            # Use the cached computed display when numeric
            val d = cached_display
            if d.len() > 0:
                val parsed = d.to_f64()
                return parsed
            return 0.0
        _:
            return 0.0

fn chart_series_from_ranges(sheet: Sheet, label_range: text, value_range: text) -> ChartSeries:
    """Collect labels and numeric values from two same-length cell ranges."""
    var labels: [text] = []
    var values: [f64] = []
    val lr = parse_range(label_range)
    val vr = parse_range(value_range)
    if lr != nil:
        for ref_str in expand_range_refs(lr):
            labels.push(cell_display_text(sheet.get_cell(ref_str)))
    if vr != nil:
        for ref_str in expand_range_refs(vr):
            values.push(_cell_number(sheet, ref_str))
    ChartSeries(labels: labels, values: values, name: "Series 1")

fn chart_xy_from_ranges(sheet: Sheet, x_range: text, y_range: text) -> ChartXY:
    """Collect two numeric columns (X then Y) for a scatter plot."""
    var xs: [f64] = []
    var ys: [f64] = []
    val xrg = parse_range(x_range)
    val yrg = parse_range(y_range)
    if xrg != nil:
        for ref_str in expand_range_refs(xrg):
            xs.push(_cell_number(sheet, ref_str))
    if yrg != nil:
        for ref_str in expand_range_refs(yrg):
            ys.push(_cell_number(sheet, ref_str))
    ChartXY(xs: xs, ys: ys, name: "Series 1")

fn _svg_escape(s: text) -> text:
    var r = s
    r = r.replace("&", "&amp;")
    r = r.replace("<", "&lt;")
    r = r.replace(">", "&gt;")
    r

fn _fmt_val(v: f64) -> text:
    val i = v.to_i64()
    if v - i.to_f64() == 0.0:
        return "{i}"
    "{v}"

val _PIE_COLORS = ["#2b579a", "#217346", "#b7472a", "#c9a000", "#6d2c91", "#0079bf"]

# ---------------------------------------------------------------------------
# Axis math: "nice" rounded tick steps (1/2/5 x 10^k covering the range).
# ---------------------------------------------------------------------------

fn _nice_step(range_v: f64, target_ticks: i64) -> f64:
    """Pick a nice tick step (1, 2, or 5 times a power of ten) so a value
    range splits into roughly `target_ticks` intervals."""
    if range_v <= 0.0:
        return 1.0
    val raw = range_v / target_ticks.to_f64()
    var mag = 1.0
    while mag * 10.0 <= raw:
        mag = mag * 10.0
    while mag > raw:
        mag = mag / 10.0
    val residual = raw / mag
    var nice = 10.0
    if residual < 1.5:
        nice = 1.0
    elif residual < 3.0:
        nice = 2.0
    elif residual < 7.0:
        nice = 5.0
    nice * mag

fn _floor_to_step(v: f64, step: f64) -> f64:
    var k = (v / step).to_i64()
    val kf = k.to_f64() * step
    if kf > v:
        k = k - 1
    k.to_f64() * step

fn _ceil_to_step(v: f64, step: f64) -> f64:
    var k = (v / step).to_i64()
    val kf = k.to_f64() * step
    if kf < v:
        k = k + 1
    k.to_f64() * step

fn _axis_ticks(min_v: f64, max_v: f64) -> [f64]:
    """Return 4-6 evenly spaced "nice" tick values covering [min_v, max_v]."""
    var span = max_v - min_v
    if span <= 0.0:
        span = if max_v > 0.0: max_v else: 1.0
    val step = _nice_step(span, 4)
    val lo = _floor_to_step(min_v, step)
    val hi = _ceil_to_step(max_v, step)
    var ticks: [f64] = []
    var t = lo
    val limit = hi + step * 0.001
    var guard = 0
    while t <= limit and guard < 64:
        ticks.push(t)
        t = t + step
        guard = guard + 1
    ticks

# ---------------------------------------------------------------------------
# Shared SVG fragments: Y axis (ticks + gridlines), legend swatch.
# ---------------------------------------------------------------------------

fn _y_axis_svg(ml: i64, plot_w: i64, baseline: i64, plot_h: i64, axis_max: f64, ticks: [f64]) -> text:
    var s = ""
    for t in ticks:
        val frac = t / axis_max
        val off = (frac * plot_h.to_f64()).to_i64()
        val gy = baseline - off
        val lx = ml + plot_w
        s = "{s}<line x1=\"{ml}\" y1=\"{gy}\" x2=\"{lx}\" y2=\"{gy}\" stroke=\"#e5e7eb\" stroke-width=\"1\"/>"
        val ly = gy + 4
        val tx = ml - 6
        val lab = _fmt_val(t)
        s = "{s}<text x=\"{tx}\" y=\"{ly}\" font-size=\"11\" fill=\"#6b7280\" text-anchor=\"end\">{lab}</text>"
    s

fn _legend_svg(name: text, color: text, lx: i64, ly: i64) -> text:
    val safe = _svg_escape(name)
    val tx = lx + 18
    val ty = ly + 11
    var s = "<g class=\"legend\">"
    s = "{s}<rect x=\"{lx}\" y=\"{ly}\" width=\"12\" height=\"12\" fill=\"{color}\" rx=\"2\"/>"
    s = "{s}<text x=\"{tx}\" y=\"{ty}\" font-size=\"12\">{safe}</text>"
    s = "{s}</g>"
    s

fn _no_data_svg() -> text:
    "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"420\" height=\"40\"><text x=\"10\" y=\"25\" font-size=\"13\">no data</text></svg>"

# ---------------------------------------------------------------------------
# Column (bar) chart — vertical bars, numeric Y axis, category X labels.
# ---------------------------------------------------------------------------

fn render_bar_chart_svg(series: ChartSeries, title: text) -> text:
    """Render the series as a self-contained SVG column chart with a numeric Y
    axis (nice ticks), category labels under the X axis, and a series legend."""
    val n = series.values.len()
    if n == 0:
        return _no_data_svg()
    var max_v = 0.0
    for v in series.values:
        if v > max_v:
            max_v = v
    val ticks = _axis_ticks(0.0, max_v)
    var axis_max = ticks[ticks.len() - 1]
    if axis_max <= 0.0:
        axis_max = 1.0
    val w = 460
    val h = 300
    val ml = 50
    val mr = 110
    val mt = 34
    val mb = 44
    val plot_w = w - ml - mr
    val plot_h = h - mt - mb
    val baseline = mt + plot_h
    val safe_title = _svg_escape(title)
    var out = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{w}\" height=\"{h}\" font-family=\"sans-serif\">"
    out = "{out}<text x=\"10\" y=\"22\" font-size=\"15\" font-weight=\"600\">{safe_title}</text>"
    out = "{out}{_y_axis_svg(ml, plot_w, baseline, plot_h, axis_max, ticks)}"
    val axis_right = ml + plot_w
    out = "{out}<line x1=\"{ml}\" y1=\"{baseline}\" x2=\"{axis_right}\" y2=\"{baseline}\" stroke=\"#9ca3af\" stroke-width=\"1\"/>"
    out = "{out}<line x1=\"{ml}\" y1=\"{mt}\" x2=\"{ml}\" y2=\"{baseline}\" stroke=\"#9ca3af\" stroke-width=\"1\"/>"
    val slot = plot_w / n
    val bar_w = slot * 55 / 100
    val color = _PIE_COLORS[0]
    var i = 0
    while i < n:
        val v = series.values[i]
        val cx = ml + i * slot + slot / 2
        val bar_x = cx - bar_w / 2
        val bh = ((v / axis_max) * plot_h.to_f64()).to_i64()
        val bar_y = baseline - bh
        out = "{out}<rect x=\"{bar_x}\" y=\"{bar_y}\" width=\"{bar_w}\" height=\"{bh}\" fill=\"{color}\" rx=\"2\"/>"
        val vlab = _fmt_val(v)
        val vy = bar_y - 4
        out = "{out}<text x=\"{cx}\" y=\"{vy}\" font-size=\"12\" fill=\"#4b5563\" text-anchor=\"middle\">{vlab}</text>"
        val label = _svg_escape(if i < series.labels.len(): series.labels[i] else: "")
        val cy_lab = baseline + 16
        out = "{out}<text x=\"{cx}\" y=\"{cy_lab}\" font-size=\"12\" fill=\"#4b5563\" text-anchor=\"middle\">{label}</text>"
        i = i + 1
    val lx = w - mr + 8
    out = "{out}{_legend_svg(series.name, color, lx, mt)}"
    "{out}</svg>"

fn sheet_bar_chart_svg(sheet: Sheet, label_range: text, value_range: text, title: text) -> text:
    """One-call chart: ranges in, SVG out."""
    render_bar_chart_svg(chart_series_from_ranges(sheet, label_range, value_range), title)

# ---------------------------------------------------------------------------
# Line chart — polyline over a numeric Y axis with category X labels.
# ---------------------------------------------------------------------------

fn render_line_chart_svg(series: ChartSeries, title: text) -> text:
    """A polyline chart: values plotted left to right over a numeric Y axis,
    labels on the x axis, plus a series legend."""
    val n = series.values.len()
    if n == 0:
        return _no_data_svg()
    var max_v = 0.0
    for v in series.values:
        if v > max_v:
            max_v = v
    val ticks = _axis_ticks(0.0, max_v)
    var axis_max = ticks[ticks.len() - 1]
    if axis_max <= 0.0:
        axis_max = 1.0
    val w = 460
    val h = 300
    val ml = 50
    val mr = 110
    val mt = 34
    val mb = 44
    val plot_w = w - ml - mr
    val plot_h = h - mt - mb
    val baseline = mt + plot_h
    val step_x = if n > 1: plot_w / (n - 1) else: 0
    var points = ""
    var i = 0
    while i < n:
        val x = ml + i * step_x
        val off = ((series.values[i] / axis_max) * plot_h.to_f64()).to_i64()
        val y = baseline - off
        points = if i == 0: "{x},{y}" else: "{points} {x},{y}"
        i = i + 1
    val safe_title = _svg_escape(title)
    var out = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{w}\" height=\"{h}\" font-family=\"sans-serif\">"
    out = "{out}<text x=\"10\" y=\"22\" font-size=\"15\" font-weight=\"600\">{safe_title}</text>"
    out = "{out}{_y_axis_svg(ml, plot_w, baseline, plot_h, axis_max, ticks)}"
    val axis_right = ml + plot_w
    out = "{out}<line x1=\"{ml}\" y1=\"{baseline}\" x2=\"{axis_right}\" y2=\"{baseline}\" stroke=\"#9ca3af\" stroke-width=\"1\"/>"
    out = "{out}<line x1=\"{ml}\" y1=\"{mt}\" x2=\"{ml}\" y2=\"{baseline}\" stroke=\"#9ca3af\" stroke-width=\"1\"/>"
    val color = _PIE_COLORS[0]
    out = "{out}<polyline points=\"{points}\" fill=\"none\" stroke=\"{color}\" stroke-width=\"2.5\"/>"
    i = 0
    while i < n:
        val x = ml + i * step_x
        val label = _svg_escape(if i < series.labels.len(): series.labels[i] else: "")
        val ly = baseline + 16
        out = "{out}<text x=\"{x}\" y=\"{ly}\" font-size=\"12\" fill=\"#4b5563\" text-anchor=\"middle\">{label}</text>"
        i = i + 1
    val lx = w - mr + 8
    out = "{out}{_legend_svg(series.name, color, lx, mt)}"
    "{out}</svg>"

fn sheet_line_chart_svg(sheet: Sheet, label_range: text, value_range: text, title: text) -> text:
    render_line_chart_svg(chart_series_from_ranges(sheet, label_range, value_range), title)

# ---------------------------------------------------------------------------
# Area chart — line filled down to the baseline.
# ---------------------------------------------------------------------------

fn render_area_chart_svg(series: ChartSeries, title: text) -> text:
    """Like the line chart but the area between the line and the baseline is
    filled with a translucent polygon; numeric Y axis, X labels, legend."""
    val n = series.values.len()
    if n == 0:
        return _no_data_svg()
    var max_v = 0.0
    for v in series.values:
        if v > max_v:
            max_v = v
    val ticks = _axis_ticks(0.0, max_v)
    var axis_max = ticks[ticks.len() - 1]
    if axis_max <= 0.0:
        axis_max = 1.0
    val w = 460
    val h = 300
    val ml = 50
    val mr = 110
    val mt = 34
    val mb = 44
    val plot_w = w - ml - mr
    val plot_h = h - mt - mb
    val baseline = mt + plot_h
    val step_x = if n > 1: plot_w / (n - 1) else: 0
    var line_pts = ""
    var poly = "{ml},{baseline}"
    var last_x = ml
    var i = 0
    while i < n:
        val x = ml + i * step_x
        val off = ((series.values[i] / axis_max) * plot_h.to_f64()).to_i64()
        val y = baseline - off
        line_pts = if i == 0: "{x},{y}" else: "{line_pts} {x},{y}"
        poly = "{poly} {x},{y}"
        last_x = x
        i = i + 1
    poly = "{poly} {last_x},{baseline}"
    val safe_title = _svg_escape(title)
    var out = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{w}\" height=\"{h}\" font-family=\"sans-serif\">"
    out = "{out}<text x=\"10\" y=\"22\" font-size=\"15\" font-weight=\"600\">{safe_title}</text>"
    out = "{out}{_y_axis_svg(ml, plot_w, baseline, plot_h, axis_max, ticks)}"
    val axis_right = ml + plot_w
    out = "{out}<line x1=\"{ml}\" y1=\"{baseline}\" x2=\"{axis_right}\" y2=\"{baseline}\" stroke=\"#9ca3af\" stroke-width=\"1\"/>"
    out = "{out}<line x1=\"{ml}\" y1=\"{mt}\" x2=\"{ml}\" y2=\"{baseline}\" stroke=\"#9ca3af\" stroke-width=\"1\"/>"
    val color = _PIE_COLORS[0]
    out = "{out}<polygon points=\"{poly}\" fill=\"{color}\" fill-opacity=\"0.28\" stroke=\"none\"/>"
    out = "{out}<polyline points=\"{line_pts}\" fill=\"none\" stroke=\"{color}\" stroke-width=\"2.5\"/>"
    i = 0
    while i < n:
        val x = ml + i * step_x
        val label = _svg_escape(if i < series.labels.len(): series.labels[i] else: "")
        val ly = baseline + 16
        out = "{out}<text x=\"{x}\" y=\"{ly}\" font-size=\"12\" fill=\"#4b5563\" text-anchor=\"middle\">{label}</text>"
        i = i + 1
    val lx = w - mr + 8
    out = "{out}{_legend_svg(series.name, color, lx, mt)}"
    "{out}</svg>"

fn sheet_area_chart_svg(sheet: Sheet, label_range: text, value_range: text, title: text) -> text:
    render_area_chart_svg(chart_series_from_ranges(sheet, label_range, value_range), title)

# ---------------------------------------------------------------------------
# Scatter (XY) chart — two numeric columns as points on proportional axes.
# ---------------------------------------------------------------------------

fn render_scatter_chart_svg(xy: ChartXY, title: text) -> text:
    """Plot (x, y) pairs as small circles with proportional axis mapping,
    numeric Y ticks, numeric X ticks/labels, and a series legend."""
    var n = xy.xs.len()
    if xy.ys.len() < n:
        n = xy.ys.len()
    if n == 0:
        return _no_data_svg()
    var x_min = xy.xs[0]
    var x_max = xy.xs[0]
    var y_max = 0.0
    var j = 0
    while j < n:
        val xv = xy.xs[j]
        val yv = xy.ys[j]
        if xv < x_min:
            x_min = xv
        if xv > x_max:
            x_max = xv
        if yv > y_max:
            y_max = yv
        j = j + 1
    val yticks = _axis_ticks(0.0, y_max)
    var y_axis_max = yticks[yticks.len() - 1]
    if y_axis_max <= 0.0:
        y_axis_max = 1.0
    val xticks = _axis_ticks(x_min, x_max)
    var x_axis_min = xticks[0]
    var x_axis_max = xticks[xticks.len() - 1]
    if x_axis_max <= x_axis_min:
        x_axis_max = x_axis_min + 1.0
    val w = 460
    val h = 300
    val ml = 50
    val mr = 110
    val mt = 34
    val mb = 44
    val plot_w = w - ml - mr
    val plot_h = h - mt - mb
    val baseline = mt + plot_h
    val safe_title = _svg_escape(title)
    var out = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{w}\" height=\"{h}\" font-family=\"sans-serif\">"
    out = "{out}<text x=\"10\" y=\"22\" font-size=\"15\" font-weight=\"600\">{safe_title}</text>"
    out = "{out}{_y_axis_svg(ml, plot_w, baseline, plot_h, y_axis_max, yticks)}"
    val axis_right = ml + plot_w
    out = "{out}<line x1=\"{ml}\" y1=\"{baseline}\" x2=\"{axis_right}\" y2=\"{baseline}\" stroke=\"#9ca3af\" stroke-width=\"1\"/>"
    out = "{out}<line x1=\"{ml}\" y1=\"{mt}\" x2=\"{ml}\" y2=\"{baseline}\" stroke=\"#9ca3af\" stroke-width=\"1\"/>"
    val x_span = x_axis_max - x_axis_min
    # X axis ticks + labels
    for t in xticks:
        val fx = (t - x_axis_min) / x_span
        val px = ml + (fx * plot_w.to_f64()).to_i64()
        val ty = baseline + 16
        val xlab = _fmt_val(t)
        out = "{out}<text x=\"{px}\" y=\"{ty}\" font-size=\"11\" fill=\"#6b7280\" text-anchor=\"middle\">{xlab}</text>"
    val color = _PIE_COLORS[0]
    var i = 0
    while i < n:
        val xv = xy.xs[i]
        val yv = xy.ys[i]
        val fx = (xv - x_axis_min) / x_span
        val px = ml + (fx * plot_w.to_f64()).to_i64()
        val off = ((yv / y_axis_max) * plot_h.to_f64()).to_i64()
        val py = baseline - off
        out = "{out}<circle cx=\"{px}\" cy=\"{py}\" r=\"4\" fill=\"{color}\"/>"
        i = i + 1
    val lx = w - mr + 8
    out = "{out}{_legend_svg(xy.name, color, lx, mt)}"
    "{out}</svg>"

fn sheet_scatter_chart_svg(sheet: Sheet, x_range: text, y_range: text, title: text) -> text:
    """One-call scatter chart: two numeric ranges in, SVG out."""
    render_scatter_chart_svg(chart_xy_from_ranges(sheet, x_range, y_range), title)

# ---------------------------------------------------------------------------
# Pie chart — dasharray donut segments with a category legend.
# ---------------------------------------------------------------------------

fn render_pie_chart_svg(series: ChartSeries, title: text) -> text:
    """A pie chart via stroke-dasharray donut segments (no trig needed);
    legend carries labels and values."""
    val n = series.values.len()
    var total = 0.0
    for v in series.values:
        if v > 0.0:
            total = total + v
    if n == 0 or total <= 0.0:
        return _no_data_svg()
    # circumference for r=80
    val circ = 2.0 * 3.141592653589793 * 80.0
    val safe_title = _svg_escape(title)
    var out = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"480\" height=\"260\" font-family=\"sans-serif\">"
    out = "{out}<text x=\"10\" y=\"20\" font-size=\"15\" font-weight=\"600\">{safe_title}</text>"
    var offset = 0.0
    var i = 0
    while i < n:
        val v = series.values[i]
        if v > 0.0:
            val frac = v / total
            val seg = frac * circ
            val gap = circ - seg
            val color = _PIE_COLORS[i % _PIE_COLORS.len()]
            out = "{out}<circle cx=\"140\" cy=\"150\" r=\"80\" fill=\"none\" stroke=\"{color}\" stroke-width=\"56\" stroke-dasharray=\"{seg} {gap}\" stroke-dashoffset=\"{0.0 - offset}\" transform=\"rotate(-90 140 150)\"/>"
            offset = offset + seg
        i = i + 1
    # legend
    out = "{out}<g class=\"legend\">"
    var y = 60
    i = 0
    while i < n:
        val label = _svg_escape(if i < series.labels.len(): series.labels[i] else: "")
        val color = _PIE_COLORS[i % _PIE_COLORS.len()]
        val ry = y - 10
        out = "{out}<rect x=\"270\" y=\"{ry}\" width=\"12\" height=\"12\" fill=\"{color}\"/>"
        val vlab = _fmt_val(series.values[i])
        out = "{out}<text x=\"290\" y=\"{y}\" font-size=\"13\">{label}: {vlab}</text>"
        y = y + 24
        i = i + 1
    out = "{out}</g>"
    "{out}</svg>"

fn sheet_pie_chart_svg(sheet: Sheet, label_range: text, value_range: text, title: text) -> text:
    render_pie_chart_svg(chart_series_from_ranges(sheet, label_range, value_range), title)

# ---------------------------------------------------------------------------
# Stacked column chart — one segment per series per category, stacked
# bottom-up; Y axis scales to the max stacked total.
# ---------------------------------------------------------------------------

fn sheet_stacked_bar_chart_svg(sheet: Sheet, label_range: text, value_ranges: text, title: text) -> text:
    """Stacked column chart. value_ranges is a comma-separated list of A1
    ranges, one per series (e.g. "B1:B2,C1:C2"). Each category's segments
    stack bottom-up in series order, one palette color per series; the Y axis
    gets nice ticks up to the max stacked total, and each series gets a
    legend entry."""
    var labels: [text] = []
    val lr = parse_range(label_range)
    if lr != nil:
        for ref_str in expand_range_refs(lr):
            labels.push(cell_display_text(sheet.get_cell(ref_str)))
    val n_cats = labels.len()
    # Flat row-major values: vals[s * n_cats + c] (local array only; no
    # array params cross call boundaries).
    var vals: [f64] = []
    var n_series = 0
    val range_parts = value_ranges.split(",")
    for range_str in range_parts:
        val rtrim = range_str.trim()
        val vr = parse_range(rtrim)
        if vr != nil and n_cats > 0:
            var col = 0
            for ref_str in expand_range_refs(vr):
                if col < n_cats:
                    vals.push(_cell_number(sheet, ref_str))
                    col = col + 1
            while col < n_cats:
                vals.push(0.0)
                col = col + 1
            n_series = n_series + 1
    if n_cats == 0 or n_series == 0:
        return _no_data_svg()
    # Y axis scales to the max stacked TOTAL across categories.
    var max_total = 0.0
    var c = 0
    while c < n_cats:
        var tot = 0.0
        var s = 0
        while s < n_series:
            val v = vals[s * n_cats + c]
            if v > 0.0:
                tot = tot + v
            s = s + 1
        if tot > max_total:
            max_total = tot
        c = c + 1
    val ticks = _axis_ticks(0.0, max_total)
    var axis_max = ticks[ticks.len() - 1]
    if axis_max <= 0.0:
        axis_max = 1.0
    val w = 460
    val h = 300
    val ml = 50
    val mr = 110
    val mt = 34
    val mb = 44
    val plot_w = w - ml - mr
    val plot_h = h - mt - mb
    val baseline = mt + plot_h
    val safe_title = _svg_escape(title)
    var out = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{w}\" height=\"{h}\" font-family=\"sans-serif\">"
    out = "{out}<text x=\"10\" y=\"22\" font-size=\"15\" font-weight=\"600\">{safe_title}</text>"
    out = "{out}{_y_axis_svg(ml, plot_w, baseline, plot_h, axis_max, ticks)}"
    val axis_right = ml + plot_w
    out = "{out}<line x1=\"{ml}\" y1=\"{baseline}\" x2=\"{axis_right}\" y2=\"{baseline}\" stroke=\"#9ca3af\" stroke-width=\"1\"/>"
    out = "{out}<line x1=\"{ml}\" y1=\"{mt}\" x2=\"{ml}\" y2=\"{baseline}\" stroke=\"#9ca3af\" stroke-width=\"1\"/>"
    val slot = plot_w / n_cats
    val bar_w = slot * 55 / 100
    c = 0
    while c < n_cats:
        val cx = ml + c * slot + slot / 2
        val bar_x = cx - bar_w / 2
        var cursor = baseline
        var s = 0
        while s < n_series:
            val v = vals[s * n_cats + c]
            if v > 0.0:
                val seg_h = ((v / axis_max) * plot_h.to_f64()).to_i64()
                val seg_y = cursor - seg_h
                val color = _PIE_COLORS[s % _PIE_COLORS.len()]
                out = "{out}<rect class=\"seg\" x=\"{bar_x}\" y=\"{seg_y}\" width=\"{bar_w}\" height=\"{seg_h}\" fill=\"{color}\" rx=\"1\"/>"
                cursor = seg_y
            s = s + 1
        val label = _svg_escape(labels[c])
        val cy_lab = baseline + 16
        out = "{out}<text x=\"{cx}\" y=\"{cy_lab}\" font-size=\"12\" fill=\"#4b5563\" text-anchor=\"middle\">{label}</text>"
        c = c + 1
    # One legend entry per series.
    val lx = w - mr + 8
    var ly = mt
    var s2 = 0
    while s2 < n_series:
        val color = _PIE_COLORS[s2 % _PIE_COLORS.len()]
        val ser_no = s2 + 1
        val ser_name = "Series {ser_no}"
        out = "{out}{_legend_svg(ser_name, color, lx, ly)}"
        ly = ly + 20
        s2 = s2 + 1
    "{out}</svg>"

# ---------------------------------------------------------------------------
# Horizontal bar chart — bars grow rightward, category labels on the left,
# numeric X axis with value ticks.
# ---------------------------------------------------------------------------

fn render_hbar_chart_svg(series: ChartSeries, title: text) -> text:
    """Horizontal bar chart: one bar per category growing rightward from the
    left margin, category labels left of the axis, nice numeric ticks along
    the bottom X axis, and a series legend."""
    val n = series.values.len()
    if n == 0:
        return _no_data_svg()
    var max_v = 0.0
    for v in series.values:
        if v > max_v:
            max_v = v
    val ticks = _axis_ticks(0.0, max_v)
    var axis_max = ticks[ticks.len() - 1]
    if axis_max <= 0.0:
        axis_max = 1.0
    val w = 460
    val h = 300
    val ml = 95
    val mr = 110
    val mt = 34
    val mb = 44
    val plot_w = w - ml - mr
    val plot_h = h - mt - mb
    val baseline = mt + plot_h
    val safe_title = _svg_escape(title)
    var out = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{w}\" height=\"{h}\" font-family=\"sans-serif\">"
    out = "{out}<text x=\"10\" y=\"22\" font-size=\"15\" font-weight=\"600\">{safe_title}</text>"
    # Value ticks run along the X axis: vertical gridlines + bottom labels.
    for t in ticks:
        val frac = t / axis_max
        val px = ml + (frac * plot_w.to_f64()).to_i64()
        out = "{out}<line x1=\"{px}\" y1=\"{mt}\" x2=\"{px}\" y2=\"{baseline}\" stroke=\"#e5e7eb\" stroke-width=\"1\"/>"
        val ty = baseline + 16
        val lab = _fmt_val(t)
        out = "{out}<text x=\"{px}\" y=\"{ty}\" font-size=\"11\" fill=\"#6b7280\" text-anchor=\"middle\">{lab}</text>"
    val axis_right = ml + plot_w
    out = "{out}<line x1=\"{ml}\" y1=\"{baseline}\" x2=\"{axis_right}\" y2=\"{baseline}\" stroke=\"#9ca3af\" stroke-width=\"1\"/>"
    out = "{out}<line x1=\"{ml}\" y1=\"{mt}\" x2=\"{ml}\" y2=\"{baseline}\" stroke=\"#9ca3af\" stroke-width=\"1\"/>"
    val slot = plot_h / n
    val bar_h = slot * 55 / 100
    val color = _PIE_COLORS[0]
    var i = 0
    while i < n:
        val v = series.values[i]
        val cy = mt + i * slot + slot / 2
        val bar_y = cy - bar_h / 2
        val bw = ((v / axis_max) * plot_w.to_f64()).to_i64()
        out = "{out}<rect class=\"hbar\" x=\"{ml}\" y=\"{bar_y}\" width=\"{bw}\" height=\"{bar_h}\" fill=\"{color}\" rx=\"2\"/>"
        val vlab = _fmt_val(v)
        val vx = ml + bw + 4
        val vy = cy + 4
        out = "{out}<text x=\"{vx}\" y=\"{vy}\" font-size=\"12\" fill=\"#4b5563\" text-anchor=\"start\">{vlab}</text>"
        val label = _svg_escape(if i < series.labels.len(): series.labels[i] else: "")
        val lx_cat = ml - 6
        out = "{out}<text x=\"{lx_cat}\" y=\"{vy}\" font-size=\"12\" fill=\"#4b5563\" text-anchor=\"end\">{label}</text>"
        i = i + 1
    val lx = w - mr + 8
    out = "{out}{_legend_svg(series.name, color, lx, mt)}"
    "{out}</svg>"

fn sheet_hbar_chart_svg(sheet: Sheet, label_range: text, value_range: text, title: text) -> text:
    """One-call horizontal bar chart: ranges in, SVG out."""
    render_hbar_chart_svg(chart_series_from_ranges(sheet, label_range, value_range), title)

# ---------------------------------------------------------------------------
# Donut chart — pie's dasharray technique with a thinner stroke (larger
# inner radius) and the grand total in the center.
# ---------------------------------------------------------------------------

fn render_donut_chart_svg(series: ChartSeries, title: text) -> text:
    """Donut chart: stroke-dasharray ring segments like the pie but with a
    thin stroke (large hole); the center shows the grand total. Legend
    carries labels and values."""
    val n = series.values.len()
    var total = 0.0
    for v in series.values:
        if v > 0.0:
            total = total + v
    if n == 0 or total <= 0.0:
        return _no_data_svg()
    # circumference for r=80; stroke 30 leaves a 65px-radius hole
    val circ = 2.0 * 3.141592653589793 * 80.0
    val safe_title = _svg_escape(title)
    var out = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"480\" height=\"260\" font-family=\"sans-serif\">"
    out = "{out}<text x=\"10\" y=\"20\" font-size=\"15\" font-weight=\"600\">{safe_title}</text>"
    var offset = 0.0
    var i = 0
    while i < n:
        val v = series.values[i]
        if v > 0.0:
            val frac = v / total
            val seg = frac * circ
            val gap = circ - seg
            val color = _PIE_COLORS[i % _PIE_COLORS.len()]
            out = "{out}<circle cx=\"140\" cy=\"150\" r=\"80\" fill=\"none\" stroke=\"{color}\" stroke-width=\"30\" stroke-dasharray=\"{seg} {gap}\" stroke-dashoffset=\"{0.0 - offset}\" transform=\"rotate(-90 140 150)\"/>"
            offset = offset + seg
        i = i + 1
    # grand total in the donut hole
    val tot_lab = _fmt_val(total)
    out = "{out}<text x=\"140\" y=\"157\" font-size=\"22\" font-weight=\"600\" fill=\"#111827\" text-anchor=\"middle\">{tot_lab}</text>"
    # legend
    out = "{out}<g class=\"legend\">"
    var y = 60
    i = 0
    while i < n:
        val label = _svg_escape(if i < series.labels.len(): series.labels[i] else: "")
        val color = _PIE_COLORS[i % _PIE_COLORS.len()]
        val ry = y - 10
        out = "{out}<rect x=\"270\" y=\"{ry}\" width=\"12\" height=\"12\" fill=\"{color}\"/>"
        val vlab = _fmt_val(series.values[i])
        out = "{out}<text x=\"290\" y=\"{y}\" font-size=\"13\">{label}: {vlab}</text>"
        y = y + 24
        i = i + 1
    out = "{out}</g>"
    "{out}</svg>"

fn sheet_donut_chart_svg(sheet: Sheet, label_range: text, value_range: text, title: text) -> text:
    """One-call donut chart: ranges in, SVG out."""
    render_donut_chart_svg(chart_series_from_ranges(sheet, label_range, value_range), title)
