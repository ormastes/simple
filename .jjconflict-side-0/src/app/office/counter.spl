# Simple Office Counter
#
# Small deterministic counter surface used by the Office launcher. The counter is
# intentionally state-local: every transition returns or mutates explicit state,
# and unknown actions fail closed without changing the value.

use common.ui.widget.{UITree, UIEvent}
use common.ui.builder.{column, row, label, button, statusbar, build_tree_with_title}
use common.ui.theme_registry.{ThemeId, theme_id_key}
use common.ui.ios.builder.{navigation_bar}

struct CounterTransition:
    value: i64
    status: text
    changed: bool

class CounterApp:
    value: i64
    modified: bool

impl CounterApp:
    static fn new() -> CounterApp:
        CounterApp(value: 0, modified: false)

    me build_ui() -> UITree:
        val nav = navigation_bar("nav", "Simple Counter", [], [])
        val controls = row("counter_controls", [
            button("counter_dec", "-", "counter_decrement"),
            label("counter_value", "{me.value}"),
            button("counter_inc", "+", "counter_increment"),
            button("counter_reset", "Reset", "counter_reset")
        ])
        val status = statusbar("statusbar", "Counter value {me.value}", if me.modified: "Modified" else: "Saved")
        val root = column("root", [nav, controls, status])
        build_tree_with_title(root, "Simple Counter", theme_id_key(ThemeId.IOSLight))

    me handle_event(event: UIEvent):
        match event:
            UIEvent.Action(name):
                val transition = counter_apply_action(me.value, name)
                if transition.changed:
                    me.value = transition.value
                    me.modified = true
            _:
                pass_do_nothing("non-action UI events do not affect the counter app")

fn counter_apply_action(value: i64, action: text) -> CounterTransition:
    if action == "counter_increment":
        return CounterTransition(value: value + 1, status: "incremented", changed: true)
    if action == "counter_decrement":
        return CounterTransition(value: value - 1, status: "decremented", changed: true)
    if action == "counter_reset":
        return CounterTransition(value: 0, status: "reset", changed: value != 0)
    CounterTransition(value: value, status: "unsupported", changed: false)
