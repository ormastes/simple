"""On-slide animation build sequence (the PowerPoint "Animation Pane" order).

Distinct from `slides.transitions` (slide-to-slide advance timing): this
module models the ordered entrance/emphasis/exit effects applied to
elements WITHIN a single slide, i.e. the per-element build order.

## Timing convention (hand-computable, documented here so the spec's
## hand-computed numbers can be checked against the code)

Each step's `finish` time is the only value tracked while folding over the
list; a step's `start` time is always derivable as `finish - duration_ms`
(delay is folded into `start`, i.e. `start = anchor + delay_ms` and
`finish = start + duration_ms`).

For step `i` (0-based), the anchor depends on `trigger`:
- index 0: anchor = 0 (nothing precedes the first step).
- `"withPrevious"`: anchor = start time of step `i-1` (same click group,
  starts simultaneously with the previous step, then still honors its own
  delay_ms on top of that anchor).
- `"afterPrevious"`: anchor = finish time of step `i-1` (starts once the
  previous step's own duration+delay have elapsed).
- `"onClick"`: anchor = the running max finish time over ALL steps seen so
  far (i.e. "starts after all prior steps complete" — a new click group
  never starts before every earlier step, including parallel
  `withPrevious` chains, has finished).

Then: `start_i = anchor + delay_ms_i`, `finish_i = start_i + duration_ms_i`.

`sequence_click_count` counts only `"onClick"` steps: `withPrevious` and
`afterPrevious` steps ride along on an existing click and add no new click.

`sequence_total_ms` is the max finish time across all steps (0 for an empty
sequence).
"""

struct AnimStep:
    target_id: text
    effect: text
    category: text
    trigger: text
    duration_ms: i32
    delay_ms: i32

fn anim_step_new(target_id: text, effect: text, category: text, trigger: text, duration_ms: i32, delay_ms: i32) -> AnimStep:
    return AnimStep(target_id: target_id, effect: effect, category: category, trigger: trigger, duration_ms: duration_ms, delay_ms: delay_ms)

struct AnimSequence:
    steps: [AnimStep]

fn anim_sequence_new() -> AnimSequence:
    return AnimSequence(steps: [])

fn anim_sequence_add(seq: AnimSequence, step: AnimStep) -> AnimSequence:
    var steps = seq.steps
    steps.push(step)
    return AnimSequence(steps: steps)

fn sequence_click_count(seq: AnimSequence) -> i32:
    var count = 0
    for step in seq.steps:
        if step.trigger == "onClick":
            count = count + 1
    return count

# Folds the whole list and returns each step's absolute finish time
# (start_i = finish_i - duration_ms_i). See module docstring for the rule.
fn compute_finish_ms(seq: AnimSequence) -> [i32]:
    var finishes: [i32] = []
    var max_finish_so_far = 0
    for i in 0..seq.steps.len():
        val step = seq.steps[i]
        var anchor = 0
        if i > 0:
            val prev = seq.steps[i - 1]
            val prev_finish = finishes[i - 1]
            val prev_start = prev_finish - prev.duration_ms
            if step.trigger == "withPrevious":
                anchor = prev_start
            elif step.trigger == "afterPrevious":
                anchor = prev_finish
            else:
                anchor = max_finish_so_far
        val this_start = anchor + step.delay_ms
        val this_finish = this_start + step.duration_ms
        finishes.push(this_finish)
        if this_finish > max_finish_so_far:
            max_finish_so_far = this_finish
    return finishes

fn step_start_time_ms(seq: AnimSequence, index: i32) -> i32:
    val finishes = compute_finish_ms(seq)
    val step = seq.steps[index]
    return finishes[index] - step.duration_ms

fn sequence_total_ms(seq: AnimSequence) -> i32:
    val finishes = compute_finish_ms(seq)
    var total = 0
    for finish in finishes:
        if finish > total:
            total = finish
    return total

fn sequence_to_xml(seq: AnimSequence) -> text:
    var parts: [text] = ["<p:timing>"]
    for step in seq.steps:
        val par = "<p:par><p:cTn presetClass=\"{step.category}\" nodeType=\"{step.trigger}\" dur=\"{step.duration_ms}\" delay=\"{step.delay_ms}\"><p:animEffect transition=\"{step.effect}\"/><p:tgtEl spid=\"{step.target_id}\"/></p:cTn></p:par>"
        parts.push(par)
    parts.push("</p:timing>")
    return parts.join("")

fn sequence_summary(seq: AnimSequence) -> [text]:
    var lines: [text] = []
    for i in 0..seq.steps.len():
        val step = seq.steps[i]
        val start = step_start_time_ms(seq, i)
        val line_text = "{step.target_id} {step.effect} ({step.category}, {step.trigger}) @{start}ms +{step.duration_ms}ms"
        lines.push(line_text)
    return lines
