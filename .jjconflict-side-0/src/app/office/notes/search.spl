# Notes — full-text search over a Notebook.
#
# notes_search(nb, query) returns one hit line per matching page, formatted
# "section|title|<matching line>":
#   - matching is a case-insensitive substring test;
#   - a page whose TITLE matches hits with the title as the matching line;
#   - otherwise the FIRST matching block (plain text) is the matching line;
#   - at most one hit per page (title match wins over body match);
#   - an empty query returns no hits.

use app.office.notes.notebook.{Notebook}
use common.rich_text.attributed_text.{block_to_plain_text}

fn notes_search(nb: Notebook, query: text) -> [text]:
    var hits: [text] = []
    if query.len() == 0:
        return hits
    val q = query.lower()
    var i = 0
    while i < nb.page_titles.len():
        val title = nb.page_titles[i]
        val sidx = nb.page_sections[i]
        val section = nb.section_names[sidx]
        var matching_line = ""
        val title_lower = title.lower()
        if title_lower.contains(q):
            matching_line = title
        else:
            val doc = nb.page_docs[i]
            for block in doc.blocks:
                if matching_line == "":
                    val plain = block_to_plain_text(block)
                    val plain_lower = plain.lower()
                    if plain_lower.contains(q):
                        matching_line = plain
        if matching_line.len() > 0:
            hits.push(section + "|" + title + "|" + matching_line)
        i = i + 1
    hits
