# Simple simulator/oracle CLI
#
# This is a thin entrypoint that exposes shared RISC-V machine profile data
# and delegates simulator-oracle runs to the existing `simple os` path.

use app.io.cli_ops.{cli_get_args}
use std.log.{error}
use app.sim.profile.{print_sim_help, print_targets, show_profile_by_arch, run_oracle_by_arch, boot_linux_by_arch}

fn get_cli_args() -> [text]:
    val all_args = cli_get_args()
    var args = []
    var start_idx = 1
    if all_args.len() > 1 and all_args[1].ends_with("main.spl"):
        start_idx = 2
    elif all_args.len() > 1 and all_args[1] == "sim":
        start_idx = 2
    var i = start_idx
    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1
    args

fn parse_arch_arg(args: [text]) -> text:
    for arg in args:
        if arg.starts_with("--arch="):
            return arg[7:]
        if arg.starts_with("--target="):
            return arg[9:]
    var i = 0
    while i < args.len() - 1:
        if args[i] == "--arch" or args[i] == "--target":
            return args[i + 1]
        i = i + 1
    "riscv64"

fn print_help():
    print_sim_help()

fn handle_show(args: [text]) -> i64:
    val arch_name = parse_arch_arg(args)
    if show_profile_by_arch(arch_name):
        0
    else:
        error("sim", "unknown shared machine profile '{arch_name}'")
        print "Run 'simple sim targets' for supported profiles."
        1

fn handle_run(args: [text]) -> i64:
    val arch_name = parse_arch_arg(args)
    run_oracle_by_arch(arch_name)

fn handle_boot_linux(args: [text]) -> i64:
    val arch_name = parse_arch_arg(args)
    boot_linux_by_arch(arch_name)

fn main() -> i64:
    val args = get_cli_args()

    if args.len() == 0:
        print_help()
        return 0

    val subcommand = args[0]
    val rest = if args.len() > 1: args[1:] else: []

    match subcommand:
        case "targets" | "list":
            print_targets()
            0
        case "show" | "profile":
            handle_show(rest)
        case "run":
            handle_run(rest)
        case "boot-linux":
            handle_boot_linux(rest)
        case "-h":
            print_help()
            0
        case "--help":
            print_help()
            0
        case "help":
            print_help()
            0
        case _:
            error("sim", "unknown subcommand '{subcommand}'")
            print ""
            print_help()
            1
