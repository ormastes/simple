# snpm run — Run project scripts

use app.snpm.config.{SnpmConfig}
use app.snpm.manifest.{parse_manifest}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn cmd_run(config: SnpmConfig, args: [text]):
    """Run a named script from package.sdn."""
    if args.len() == 0:
        _list_scripts(config)
        return

    val script_name = args[0]

    if not rt_file_exists(config.manifest_name):
        print "snpm: no {config.manifest_name} found"
        return

    val manifest_result = parse_manifest(config.manifest_name)
    match manifest_result:
        Err(msg):
            print "snpm: {msg}"
            return
        Ok(manifest):
            var i = 0
            while i < manifest.scripts.len():
                val script = manifest.scripts[i]
                if script.first == script_name:
                    print "> {script.second}"
                    val result = rt_process_run("sh", ["-c", script.second])
                    if result.0 != "":
                        print result.0
                    if result.1 != "":
                        print result.1
                    if result.2 != 0:
                        print "snpm: script '{script_name}' exited with code {result.2}"
                    return
                i = i + 1
            print "snpm: missing script '{script_name}'"
            _list_scripts(config)

fn _list_scripts(config: SnpmConfig):
    """List available scripts."""
    if not rt_file_exists(config.manifest_name):
        print "snpm: no {config.manifest_name} found"
        return
    val manifest_result = parse_manifest(config.manifest_name)
    match manifest_result:
        Ok(manifest):
            if manifest.scripts.len() == 0:
                print "snpm: no scripts defined"
                return
            print "Available scripts:"
            var i = 0
            while i < manifest.scripts.len():
                val s = manifest.scripts[i]
                print "  {s.first}: {s.second}"
                i = i + 1
        Err(msg):
            print "snpm: {msg}"
