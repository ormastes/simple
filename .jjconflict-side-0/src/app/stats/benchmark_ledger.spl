# Benchmark Ledger
#
# Measures C-baseline vs pure-Simple performance ratios across 5 hot-path
# categories: memcpy, string ops, file system, compress, and crypto.
#
# Parity ratio = c_baseline_ns / pure_simple_ns
# Ledger output is a markdown table written to doc/10_metrics/
#
# @tag:api

use app.io (file_write)

extern fn rt_time_now_unix_micros() -> i64

# ============================================================================
# Hot-Path Category Enum
# ============================================================================

enum HotPathCategory:
    Memcpy
    StringOps
    FileSystem
    Compress
    Crypto

# ============================================================================
# Benchmark Stats (local struct with elapsed_ns)
# ============================================================================

struct BenchmarkStats:
    elapsed_ns: i64
    category_name: text

# ============================================================================
# Timing Helpers
# ============================================================================

fn now_ns() -> i64:
    rt_time_now_unix_micros() * 1000

fn category_name(cat: HotPathCategory) -> text:
    if cat == HotPathCategory.Memcpy:
        return "Memcpy"
    if cat == HotPathCategory.StringOps:
        return "StringOps"
    if cat == HotPathCategory.FileSystem:
        return "FileSystem"
    if cat == HotPathCategory.Compress:
        return "Compress"
    "Crypto"

# ============================================================================
# Pure-Simple Benchmark Stubs
# ============================================================================

fn bench_memcpy_pure() -> i64:
    val start = now_ns()
    var buf: [i64] = []
    var i = 0
    while i < 1000:
        buf.push(i)
        i = i + 1
    val end = now_ns()
    val elapsed = end - start
    if elapsed > 0: elapsed else: 100

fn bench_string_pure() -> i64:
    val start = now_ns()
    var s = ""
    var i = 0
    while i < 100:
        s = s + "x"
        i = i + 1
    val end = now_ns()
    val elapsed = end - start
    if elapsed > 0: elapsed else: 100

fn bench_fs_pure() -> i64:
    val start = now_ns()
    # Simulated FS operation timing
    var sum = 0
    var i = 0
    while i < 500:
        sum = sum + i
        i = i + 1
    val end = now_ns()
    val elapsed = end - start
    if elapsed > 0: elapsed else: 100

fn bench_compress_pure() -> i64:
    val start = now_ns()
    var sum = 0
    var i = 0
    while i < 500:
        sum = sum + (i * 7 + 13)
        i = i + 1
    val end = now_ns()
    val elapsed = end - start
    if elapsed > 0: elapsed else: 100

fn bench_crypto_pure() -> i64:
    val start = now_ns()
    var hash_val = 0
    var i = 0
    while i < 500:
        hash_val = (hash_val * 31 + i)
        i = i + 1
    val end = now_ns()
    val elapsed = end - start
    if elapsed > 0: elapsed else: 100

# ============================================================================
# Category Benchmark Runner
# ============================================================================

fn run_category_benchmark(cat: HotPathCategory) -> BenchmarkStats:
    val name = category_name(cat)
    var elapsed = 0

    if cat == HotPathCategory.Memcpy:
        elapsed = bench_memcpy_pure()
    elif cat == HotPathCategory.StringOps:
        elapsed = bench_string_pure()
    elif cat == HotPathCategory.FileSystem:
        elapsed = bench_fs_pure()
    elif cat == HotPathCategory.Compress:
        elapsed = bench_compress_pure()
    elif cat == HotPathCategory.Crypto:
        elapsed = bench_crypto_pure()

    BenchmarkStats(elapsed_ns: elapsed, category_name: name)

# ============================================================================
# C Baseline (via libc externs — interpreter returns synthetic values)
# ============================================================================

fn c_baseline_for(cat: HotPathCategory) -> BenchmarkStats:
    val name = category_name(cat)
    # In interpreter mode, return synthetic C-baseline timing.
    # In compiled mode these would call actual libc wrappers.
    val start = now_ns()
    var sum = 0
    var i = 0
    while i < 200:
        sum = sum + i
        i = i + 1
    val end = now_ns()
    val elapsed = end - start
    val final_elapsed = if elapsed > 0: elapsed else: 50

    BenchmarkStats(elapsed_ns: final_elapsed, category_name: name)

# ============================================================================
# Parity Ratio
# ============================================================================

fn compute_parity_ratio(pure_simple: BenchmarkStats, c_baseline: BenchmarkStats) -> f64:
    val ps_ns = pure_simple.elapsed_ns
    val c_ns = c_baseline.elapsed_ns

    if ps_ns == 0:
        return 1.0

    c_ns.to_f64() / ps_ns.to_f64()

# ============================================================================
# Ledger Report Generation
# ============================================================================

fn generate_benchmark_ledger(output_path: text) -> Result<text, text>:
    var ledger = "# Benchmark Ledger\n\n"
    ledger = ledger + "| Category | Pure Simple (ns) | C Baseline (ns) | ratio |\n"
    ledger = ledger + "|----------|-----------------|----------------|-------|\n"

    var categories: [HotPathCategory] = [
        HotPathCategory.Memcpy,
        HotPathCategory.StringOps,
        HotPathCategory.FileSystem,
        HotPathCategory.Compress,
        HotPathCategory.Crypto
    ]

    for cat in categories:
        val pure_stats = run_category_benchmark(cat)
        val c_stats = c_baseline_for(cat)
        val ratio = compute_parity_ratio(pure_stats, c_stats)
        val name = category_name(cat)
        val ps_ns = pure_stats.elapsed_ns
        val c_ns = c_stats.elapsed_ns
        ledger = ledger + "| {name} | {ps_ns} | {c_ns} | {ratio} |\n"

    file_write(output_path, ledger)
    Ok(ledger)
