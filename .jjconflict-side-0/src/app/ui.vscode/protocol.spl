# VSCode Webview Message Protocol
#
# Defines the message types exchanged between the Simple UI backend
# and the VSCode TypeScript webview host.

use common.ui.widget.{UIEvent}

# =========================================================================
# Message Parsing (from webview → Simple)
# =========================================================================

fn parse_webview_message(msg_type: text, payload: text) -> UIEvent?:
    """Parse a message from the VSCode webview into a UIEvent."""
    match msg_type:
        "keypress" =>
            return UIEvent.KeyPress(key: payload)
        "action" =>
            return UIEvent.Action(name: payload)
        "resize" =>
            # payload format: "width,height"
            val parts = payload.split(",")
            if parts.len() == 2:
                val w = parts[0].trim().to_int()
                val h = parts[1].trim().to_int()
                return UIEvent.Resize(width: w, height: h)
            return nil
        "quit" =>
            return UIEvent.Quit
        _ =>
            return nil

# =========================================================================
# Message Building (Simple → webview)
# =========================================================================

fn build_render_message(html: text) -> text:
    """Build a render message to send to the webview."""
    return "{\"type\": \"render\", \"html\": \"{escape_json(html)}\"}"

fn build_state_message(mode: text, focused_id: text) -> text:
    """Build a state update message."""
    return "{\"type\": \"state\", \"mode\": \"{mode}\", \"focusedId\": \"{focused_id}\"}"

fn escape_json(s: text) -> text:
    """Escape a string for JSON."""
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s[i]
        match ch:
            "\"" =>
                result = "{result}\\\""
            "\\" =>
                result = "{result}\\\\"
            "\n" =>
                result = "{result}\\n"
            "\r" =>
                result = "{result}\\r"
            "\t" =>
                result = "{result}\\t"
            _ =>
                result = "{result}{ch}"
        i = i + 1
    return result
