# Grammar Doc Generator — Reads grammar_keywords.sdn and generates grammar docs
#
# Generates:
#   doc/06_spec/app/compiler/modules/grammar/grammar_reference.md — Complete keyword/operator reference
#   doc/06_spec/app/compiler/modules/grammar/keyword_reference.md — All keywords in one table
#   doc/06_spec/app/compiler/modules/grammar/treesitter_status.md — Tree-sitter consistency report
#
# CLI:
#   bin/simple grammar-doc                  — Generate all docs
#   bin/simple grammar-doc --treesitter     — Tree-sitter status report
#   bin/simple grammar-doc --format=json    — JSON output

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_cli_get_args() -> [text]

# =========================================================================
# Pure helper functions (no module state access)
# =========================================================================

fn get_operator_symbol(name: text) -> text:
    if name == "plus": return "+"
    if name == "minus": return "-"
    if name == "star": return "*"
    if name == "slash": return "/"
    if name == "percent": return "%"
    if name == "star_star": return "**"
    if name == "shl": return "<<"
    if name == "shr": return ">>"
    if name == "eq": return "=="
    if name == "not_eq": return "!="
    if name == "lt": return "<"
    if name == "gt": return ">"
    if name == "lt_eq": return "<="
    if name == "gt_eq": return ">="
    if name == "assign": return "="
    if name == "plus_eq": return "+="
    if name == "minus_eq": return "-="
    if name == "star_eq": return "*="
    if name == "slash_eq": return "/="
    if name == "percent_eq": return "%="
    if name == "walrus": return ":="
    if name == "ampersand": return "&"
    if name == "pipe": return "|"
    if name == "caret": return "^"
    if name == "tilde": return "~"
    if name == "question": return "?"
    if name == "question_dot": return "?."
    if name == "question_question": return "??"
    if name == "dot_question": return ".?"
    if name == "pipe_forward": return "|>"
    if name == "compose": return ">>"
    if name == "dot_dot": return ".."
    if name == "dot_dot_eq": return "..="
    if name == "dot_plus": return ".+"
    if name == "dot_minus": return ".-"
    if name == "dot_star": return ".*"
    if name == "dot_slash": return "./"
    if name == "dot_caret": return ".^"
    if name == "at": return "@"
    if name == "triple_less": return "<<<"
    if name == "triple_greater": return ">>>"
    if name == "layer_connect": return "~>"
    return name

fn get_keyword_description(name: text) -> text:
    if name == "fn": return "Function definition"
    if name == "val": return "Immutable binding"
    if name == "var": return "Mutable binding"
    if name == "struct": return "Struct definition"
    if name == "enum": return "Enum definition"
    if name == "class": return "Class definition (struct with methods)"
    if name == "impl": return "Method implementation block"
    if name == "extern": return "External function declaration (FFI)"
    if name == "use": return "Module import"
    if name == "export": return "Symbol export"
    if name == "import": return "Legacy import keyword (use use)"
    if name == "trait": return "Trait definition"
    if name == "pub": return "Public visibility modifier"
    if name == "static": return "Static method or binding"
    if name == "me": return "Mutable self method"
    if name == "type": return "Type alias"
    if name == "asm": return "Inline assembly block"
    if name == "implements": return "Trait implementation declaration"
    if name == "mod": return "Module definition"
    if name == "const": return "Compile-time constant"
    if name == "bitfield": return "Packed bit struct"
    if name == "kernel": return "GPU kernel function"
    if name == "shared": return "GPU shared memory"
    if name == "unsafe": return "Unsafe block"
    if name == "actor": return "Actor definition (concurrency)"
    if name == "unit": return "Unit type definition"
    if name == "if": return "Conditional branch"
    if name == "elif": return "Else-if branch"
    if name == "else": return "Else branch"
    if name == "for": return "For loop"
    if name == "while": return "While loop"
    if name == "match": return "Pattern match expression"
    if name == "case": return "Match arm"
    if name == "return": return "Return from function"
    if name == "break": return "Break out of loop"
    if name == "continue": return "Skip to next iteration"
    if name == "in": return "Membership / iteration operator"
    if name == "loop": return "Infinite loop"
    if name == "pass": return "No-op placeholder"
    if name == "pass_todo": return "Unimplemented placeholder (TODO)"
    if name == "pass_do_nothing": return "Intentional no-op"
    if name == "pass_dn": return "Alias for pass_do_nothing"
    if name == "and": return "Logical AND"
    if name == "or": return "Logical OR"
    if name == "not": return "Logical NOT"
    if name == "self": return "Current instance reference"
    if name == "is": return "Type check operator"
    if name == "async": return "Async function modifier"
    if name == "await": return "Await async expression"
    if name == "yield": return "Yield from generator"
    if name == "spawn": return "Spawn actor/task"
    if name == "try": return "Legacy/internal parser compatibility keyword"
    if name == "catch": return "Legacy/internal parser compatibility keyword"
    if name == "throw": return "Legacy/internal parser compatibility keyword"
    if name == "with": return "Legacy/internal parser compatibility keyword"
    if name == "finally": return "Legacy/internal parser compatibility keyword"
    if name == "panic": return "Legacy/internal parser compatibility keyword"
    if name == "true": return "Boolean true literal"
    if name == "false": return "Boolean false literal"
    if name == "nil": return "Null/none value"
    if name == "as": return "Type cast operator"
    if name == "xor": return "Bitwise XOR operator"
    if name == "from": return "Import source specifier"
    if name == "super": return "Parent module reference"
    if name == "Some": return "Option type wrapper"
    if name == "Ok": return "Result success wrapper"
    if name == "Err": return "Result error wrapper"
    if name == "None": return "Legacy/internal nil alias"
    if name == "loss": return "Neural network loss block"
    if name == "nograd": return "Disable gradient computation"
    return ""

fn get_keyword_example(name: text) -> text:
    if name == "fn": return "`fn square(x: i64) -> i64: x * x`"
    if name == "val": return "`val name = \"Alice\"`"
    if name == "var": return "`var count = 0`"
    if name == "struct": return "`struct Point: x: i64; y: i64`"
    if name == "enum": return "`enum Color: Red; Green; Blue`"
    if name == "class": return "`class Dog: name: text`"
    if name == "impl": return "`impl Point: fn len(): ...`"
    if name == "extern": return "`extern fn rt_print(s: text)`"
    if name == "use": return "`use std.math.{sqrt, abs}`"
    if name == "export": return "`export my_fn, MyType`"
    if name == "trait": return "`trait Printable: fn print():`"
    if name == "if": return "`if x > 0: print \"positive\"`"
    if name == "for": return "`for item in items: print item`"
    if name == "match": return "`match value: case 1: ...`"
    if name == "return": return "`return result`"
    if name == "and": return "`if a and b: ...`"
    if name == "true": return "`val done = true`"
    if name == "nil": return "`var result = nil`"
    if name == "async": return "`async fn fetch():`"
    if name == "spawn": return "`spawn worker()`"
    return ""

fn is_legacy_internal_keyword(name: text) -> bool:
    if name == "try": return true
    if name == "catch": return true
    if name == "throw": return true
    if name == "with": return true
    if name == "finally": return true
    if name == "panic": return true
    if name == "None": return true
    return false

fn legacy_internal_note(name: text) -> text:
    if name == "None": return "Parser compatibility alias; public docs use nil"
    return "Recognized for compatibility/internal use; not canonical public syntax"

fn is_parser_recognized_nonpublic_keyword(name: text) -> bool:
    if name == "extends": return true
    if name == "where": return true
    if name == "bind": return true
    if name == "dyn": return true
    return false

fn collect_treesitter_keywords(ts_text: text) -> [text]:
    """Extract quoted keywords from a tree-sitter query file."""
    var ts_keywords: [text] = []
    val ts_lines = ts_text.split("\n")
    for ts_line in ts_lines:
        var rest = ts_line
        while true:
            val start_idx = rest.index_of("\"") ?? -1
            if start_idx < 0:
                break
            val after_start = rest.slice(start_idx + 1, rest.len())
            val end_idx = after_start.index_of("\"") ?? -1
            if end_idx < 0:
                break
            val ts_kw = after_start.slice(0, end_idx)
            rest = after_start.slice(end_idx + 1, after_start.len())

            var is_alpha = false
            if ts_kw.len() > 0:
                val first_ch = ts_kw.slice(0, 1)
                if first_ch >= "a" and first_ch <= "z": is_alpha = true
                if first_ch >= "A" and first_ch <= "Z": is_alpha = true
            if is_alpha:
                var already = false
                for existing in ts_keywords:
                    if existing == ts_kw:
                        already = true
                        break
                if not already:
                    ts_keywords.push(ts_kw)
    ts_keywords

fn get_asm_description(name: text) -> text:
    if name == "asm_single_line": return "Single-line asm statement (`asm \"nop\"`)"
    if name == "asm_indented_block": return "Indented asm block (`asm:\\n    \"nop\"`)"
    if name == "asm_braced_block": return "Braced asm block (`asm { \"nop\" }`)"
    if name == "asm_match": return "Target-conditional asm (`asm match: case [x86_64]: ...`)"
    if name == "asm_assert": return "Target assertion (`asm assert [x86_64, linux]`)"
    if name == "asm_operands": return "Register operands (`in(reg) var, out(reg) var`)"
    if name == "asm_clobbers": return "Clobber lists (`clobbers: [\"eax\"]`)"
    if name == "asm_options": return "Asm options (`options: [volatile, noreturn]`)"
    if name == "asm_register_alloc": return "Compiler register allocation"
    if name == "asm_target_validation": return "Per-arch instruction validation"
    return name

fn get_asm_kind(name: text) -> text:
    if name == "asm_single_line": return "clang-depend"
    if name == "asm_indented_block": return "clang-depend"
    if name == "asm_braced_block": return "clang-depend"
    if name == "asm_match": return "clang-depend"
    if name == "asm_assert": return "clang-depend"
    return "compiler-depend"

fn get_llf_description(name: text) -> text:
    if name == "bitfield": return "Packed bit-level struct declarations"
    if name == "union_type_operator": return "Union type operator (`A | B | C`)"
    if name == "union_declaration": return "C-style `union {}` declaration"
    if name == "packed_attr": return "`@packed` attribute for struct layout"
    if name == "repr_attr": return "`@repr(C)` representation attribute"
    if name == "align_attr": return "`@align(N)` alignment attribute"
    if name == "volatile_asm": return "Volatile asm via C passthrough"
    if name == "volatile_attr": return "`@volatile` attribute for MMIO"
    return name

# =========================================================================
# Main entry point — all state managed inline
# =========================================================================

fn main() -> i64:
    val all_args = rt_cli_get_args()
    var start_idx = 1
    if all_args.len() > 1:
        if all_args[1].ends_with(".spl"):
            start_idx = 2
    var args: [text] = []
    var arg_idx = 0
    for a in all_args:
        if arg_idx >= start_idx:
            args.push(a)
        arg_idx = arg_idx + 1

    val sdn_path = "doc/06_spec/app/compiler/modules/grammar/grammar_keywords.sdn"
    val out_dir = "doc/06_spec/app/compiler/modules/grammar"

    # Parse flags
    var do_treesitter = false
    var format = "md"
    for arg in args:
        if arg == "--treesitter":
            do_treesitter = true
        elif arg.starts_with("--format="):
            format = arg.slice(9, arg.len())

    # Read and parse SDN source of truth — all state local to main
    val sdn_text = rt_file_read_text(sdn_path) ?? ""
    if sdn_text == "":
        print "Error: could not read {sdn_path}"
        return 1

    # Parse SDN inline (module var writes don't persist across function calls)
    var kw_names: [text] = []
    var kw_phases: [text] = []
    var kw_categories: [text] = []
    var op_names: [text] = []
    var op_phases: [text] = []
    var op_symbols: [text] = []
    var ct_names: [text] = []
    var ct_phases: [text] = []
    var aspirational_keywords: [text] = []
    var asm_names: [text] = []
    var asm_phases: [text] = []
    var llf_names: [text] = []
    var llf_phases: [text] = []

    var current_section = ""
    var current_subsection = ""
    val sdn_lines = sdn_text.split("\n")
    for sdn_line in sdn_lines:
        val trimmed = sdn_line.trim()
        if trimmed == "": continue
        if trimmed.starts_with("#"): continue
        if trimmed.starts_with("["):
            var header = trimmed.replace("[", "")
            header = header.replace("]", "")
            val parts = header.split(".")
            current_section = parts[0]
            if parts.len() > 1:
                current_subsection = parts[1]
            else:
                current_subsection = ""
            continue
        if trimmed.contains("="):
            val eq_idx = trimmed.index_of("=") ?? -1
            if eq_idx > 0:
                val key = trimmed.slice(0, eq_idx).trim()
                var value_part = trimmed.slice(eq_idx + 1, trimmed.len()).trim()
                value_part = value_part.replace("\"", "")
                if current_section == "keywords":
                    kw_names.push(key)
                    kw_phases.push(value_part)
                    kw_categories.push(current_subsection)
                elif current_section == "operators":
                    op_names.push(key)
                    op_phases.push(value_part)
                    op_symbols.push(get_operator_symbol(key))
                elif current_section == "constructs":
                    ct_names.push(key)
                    ct_phases.push(value_part)
                elif current_section == "asm_capabilities":
                    asm_names.push(key)
                    asm_phases.push(value_part)
                elif current_section == "low_level_features":
                    llf_names.push(key)
                    llf_phases.push(value_part)
                elif current_section == "treesitter_aspirational":
                    if key == "keywords":
                        val kw_list = value_part.split(", ")
                        for kw in kw_list:
                            val cleaned = kw.trim()
                            if cleaned != "":
                                aspirational_keywords.push(cleaned)

    print "Parsed {kw_names.len()} keywords, {op_names.len()} operators, {ct_names.len()} constructs, {asm_names.len()} asm capabilities, {llf_names.len()} low-level features"

    # JSON output mode
    if format == "json":
        var json_parts: [text] = []
        json_parts.push("{\n  \"keywords\": [\n")
        var ki = 0
        for kw_name in kw_names:
            var comma = ","
            if ki == kw_names.len() - 1: comma = ""
            val cat = kw_categories[ki]
            val desc = get_keyword_description(kw_name)
            json_parts.push("    {\"name\": \"{kw_name}\", \"category\": \"{cat}\"}{comma}\n")
            ki = ki + 1
        json_parts.push("  ]\n}\n")
        print json_parts.join("")
        return 0

    # Tree-sitter mode
    if do_treesitter:
        val ts_path = "src/compiler/10.frontend/parser/treesitter/queries/highlights.scm"
        val ts_text = rt_file_read_text(ts_path) ?? ""
        if ts_text == "":
            print "Error: could not read {ts_path}"
            return 1
        val ts_keywords = collect_treesitter_keywords(ts_text)
        # Generate status report
        var status_parts: [text] = []
        status_parts.push("# Tree-sitter Keyword Status\n\n")
        status_parts.push("*Cross-reference between `highlights.scm` and `grammar_keywords.sdn`.*\n\n")
        status_parts.push("*Generated by `bin/simple grammar-doc --treesitter`.*\n\n---\n\n")
        # Cross-reference
        var impl_kws: [text] = []
        var asp_kws: [text] = []
        var miss_kws: [text] = []
        for ts_kw in ts_keywords:
            var found = false
            for kn in kw_names:
                if kn == ts_kw:
                    found = true
                    break
            if found:
                impl_kws.push(ts_kw)
            else:
                asp_kws.push(ts_kw)
        for kn in kw_names:
            var in_ts = false
            for ts_kw in ts_keywords:
                if ts_kw == kn:
                    in_ts = true
                    break
            if not in_ts:
                miss_kws.push(kn)
        status_parts.push("## Implemented ({impl_kws.len()} keywords)\n\n")
        status_parts.push("| Keyword |\n|---------|\n")
        for imp in impl_kws:
            status_parts.push("| `{imp}` |\n")
        status_parts.push("\n## Aspirational ({asp_kws.len()} keywords)\n\n")
        status_parts.push("| Keyword | Notes |\n|---------|-------|\n")
        for asp in asp_kws:
            if is_parser_recognized_nonpublic_keyword(asp):
                status_parts.push("| `{asp}` | Recognized by parser/token tables; keep as internal or legacy syntax |\n")
            else:
                status_parts.push("| `{asp}` | In highlights.scm only |\n")
        status_parts.push("\n## Missing from highlights.scm ({miss_kws.len()} keywords)\n\n")
        status_parts.push("| Keyword |\n|---------|\n")
        for miss in miss_kws:
            status_parts.push("| `{miss}` |\n")
        val status_path = "{out_dir}/treesitter_status.md"
        rt_file_write_text(status_path, status_parts.join(""))
        print "Generated {status_path} ({ts_keywords.len()} tree-sitter keywords analyzed)"
        return 0

    # Generate grammar reference doc
    var out_parts: [text] = []
    out_parts.push("# Simple Language Grammar Reference\n\n")
    out_parts.push("*Generated by `bin/simple grammar-doc` from `doc/06_spec/app/compiler/modules/grammar/grammar_keywords.sdn`.*\n\n")
    out_parts.push("*Status policy: legacy/internal keywords are listed for parser compatibility but are not part of the canonical public syntax used in guides.*\n\n---\n\n")
    # Keywords table
    out_parts.push("## Keywords\n\n")
    out_parts.push("| Keyword | Category | Status | Description | Example |\n")
    out_parts.push("|---------|----------|--------|-------------|---------|\n")
    var ki4 = 0
    for kw_name in kw_names:
        val cat = kw_categories[ki4]
        val desc = get_keyword_description(kw_name)
        val example = get_keyword_example(kw_name)
        val status = if is_legacy_internal_keyword(kw_name): "legacy/internal" else: "current"
        out_parts.push("| `{kw_name}` | {cat} | {status} | {desc} | {example} |\n")
        ki4 = ki4 + 1
    out_parts.push("\n## Operators\n\n")
    out_parts.push("| Operator | Symbol |\n|----------|--------|\n")
    var oi = 0
    for op_name in op_names:
        val symbol = op_symbols[oi]
        out_parts.push("| {op_name} | `{symbol}` |\n")
        oi = oi + 1
    out_parts.push("\n## Constructs\n\n")
    out_parts.push("| Construct |\n|-----------|\n")
    for ct_name in ct_names:
        out_parts.push("| {ct_name} |\n")
    # Asm capabilities table
    if asm_names.len() > 0:
        out_parts.push("\n## Assembly Capabilities\n\n")
        out_parts.push("| Capability | Kind | Description |\n")
        out_parts.push("|------------|------|-------------|\n")
        var ai2 = 0
        for an in asm_names:
            val at = asm_phases[ai2]
            if at != "none":
                val ad = get_asm_description(an)
                val ak = get_asm_kind(an)
                out_parts.push("| {an} | {ak} | {ad} |\n")
            ai2 = ai2 + 1

    # Low-level features table
    var has_llf = false
    var li = 0
    for ln in llf_names:
        if llf_phases[li] != "none":
            has_llf = true
            break
        li = li + 1
    if has_llf:
        out_parts.push("\n## Low-Level Features\n\n")
        out_parts.push("| Feature | Description |\n")
        out_parts.push("|---------|-------------|\n")
        var li2 = 0
        for ln in llf_names:
            if llf_phases[li2] != "none":
                val ld = get_llf_description(ln)
                out_parts.push("| {ln} | {ld} |\n")
            li2 = li2 + 1

    # Not-yet-implemented features
    var has_none = false
    var ni = 0
    for ln in llf_names:
        if llf_phases[ni] == "none":
            has_none = true
            break
        ni = ni + 1
    if has_none:
        out_parts.push("\n### Not Yet Implemented\n\n")
        out_parts.push("| Feature | Status | Description |\n")
        out_parts.push("|---------|--------|-------------|\n")
        var ni2 = 0
        for ln in llf_names:
            if llf_phases[ni2] == "none":
                val ld = get_llf_description(ln)
                out_parts.push("| {ln} | not implemented | {ld} |\n")
            ni2 = ni2 + 1

    out_parts.push("\n---\n\n**Summary:** {kw_names.len()} keywords, {op_names.len()} operators, {ct_names.len()} constructs\n")
    val grammar_path = "{out_dir}/grammar_reference.md"
    rt_file_write_text(grammar_path, out_parts.join(""))
    print "Generated {grammar_path}"

    # Generate keyword reference
    var ref_parts: [text] = []
    ref_parts.push("# Simple Language - Keyword Reference\n\n")
    ref_parts.push("*All keywords, sorted by category.*\n\n")
    ref_parts.push("*Generated by `bin/simple grammar-doc` from `doc/06_spec/app/compiler/modules/grammar/grammar_keywords.sdn`.*\n\n")
    ref_parts.push("*Status policy: legacy/internal keywords are listed for parser compatibility but are not part of the canonical public syntax used in guides.*\n\n---\n\n")
    ref_parts.push("## Keywords\n\n")
    ref_parts.push("| Keyword | Category | Status | Description |\n")
    ref_parts.push("|---------|----------|--------|-------------|\n")
    var ki6 = 0
    for kw_name in kw_names:
        val cat = kw_categories[ki6]
        val desc = get_keyword_description(kw_name)
        val status = if is_legacy_internal_keyword(kw_name): "legacy/internal" else: "current"
        ref_parts.push("| `{kw_name}` | {cat} | {status} | {desc} |\n")
        ki6 = ki6 + 1
    ref_parts.push("\n## Operators\n\n")
    ref_parts.push("| Name | Symbol |\n|------|--------|\n")
    var oi3 = 0
    for op_name in op_names:
        val symbol = op_symbols[oi3]
        ref_parts.push("| {op_name} | `{symbol}` |\n")
        oi3 = oi3 + 1
    ref_parts.push("\n## Constructs\n\n")
    ref_parts.push("| Construct |\n|-----------|\n")
    for ct_name in ct_names:
        ref_parts.push("| {ct_name} |\n")
    ref_parts.push("\n---\n\n**Total:** {kw_names.len()} keywords\n")
    val ref_path = "{out_dir}/keyword_reference.md"
    rt_file_write_text(ref_path, ref_parts.join(""))
    print "Generated {ref_path}"

    # Also generate treesitter status
    val ts_path2 = "src/compiler/10.frontend/parser/treesitter/queries/highlights.scm"
    val ts_text2 = rt_file_read_text(ts_path2) ?? ""
    if ts_text2 != "":
        val ts_kws = collect_treesitter_keywords(ts_text2)
        var st_parts: [text] = []
        st_parts.push("# Tree-sitter Keyword Status\n\n")
        st_parts.push("*Cross-reference between `highlights.scm` and `grammar_keywords.sdn`.*\n\n")
        st_parts.push("*Generated by `bin/simple grammar-doc`.*\n\n---\n\n")
        var imp2: [text] = []
        var asp2: [text] = []
        var mis2: [text] = []
        for tw in ts_kws:
            var found2 = false
            for kn in kw_names:
                if kn == tw:
                    found2 = true
                    break
            if found2:
                imp2.push(tw)
            else:
                asp2.push(tw)
        for kn in kw_names:
            var found_in_ts = false
            for tw in ts_kws:
                if tw == kn:
                    found_in_ts = true
                    break
            if not found_in_ts:
                mis2.push(kn)
        st_parts.push("## Implemented ({imp2.len()} keywords)\n\n")
        st_parts.push("| Keyword |\n|---------|\n")
        for iw in imp2:
            st_parts.push("| `{iw}` |\n")
        st_parts.push("\n## Aspirational ({asp2.len()} keywords)\n\n")
        st_parts.push("| Keyword | Notes |\n|---------|-------|\n")
        for aw in asp2:
            if is_parser_recognized_nonpublic_keyword(aw):
                st_parts.push("| `{aw}` | Recognized by parser/token tables; keep as internal or legacy syntax |\n")
            else:
                st_parts.push("| `{aw}` | In highlights.scm only |\n")
        st_parts.push("\n## Missing from highlights.scm ({mis2.len()} keywords)\n\n")
        st_parts.push("| Keyword |\n|---------|\n")
        for mw in mis2:
            st_parts.push("| `{mw}` |\n")
        val st_path = "{out_dir}/treesitter_status.md"
        rt_file_write_text(st_path, st_parts.join(""))
        print "Generated {st_path}"

    print "Done."
    0
