use .main_lazy_json
use .tool_registry
use .tool_table

fn _mcp_static_prop(param_name: text) -> text:
    jp(param_name, jo2(jp("type", js("string")), jp("description", js(param_name))))

fn _mcp_static_append_prop(props: text, required_json: text, param_name: text) -> text:
    val separator = if props == "": "" else: ","
    props + separator + _mcp_static_prop(param_name: param_name)

fn _mcp_static_props(required_json: text) -> text:
    var props = ""
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "program")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "target_type")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "session_id")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "breakpoint_id")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "file")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "line")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "mode")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "enabled")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "condition")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "expression")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "action")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "name")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "value")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "item_names")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "item_name")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "module")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "elf_path")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "script")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "command")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "function_name")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "url")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "path")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "target_dir")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "app_path")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "selector")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "text")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "key")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "js")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "x")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "y")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "base_url")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "widget_id")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "canonical_id")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "old_string")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "new_string")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "edits")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "query")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "task_id")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "prompt")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "signal")
    props = _mcp_static_append_prop(props: props, required_json: required_json, param_name: "package")
    LB() + props + RB()

fn _mcp_static_tool_schema(name: text, desc: text, required_json: text) -> text:
    val input_schema = jo3(
        jp("type", js("object")),
        jp("properties", _mcp_static_props(required_json: required_json)),
        jp("required", required_json)
    )
    val annotations = jo4(
        jp("readOnlyHint", "false"),
        jp("destructiveHint", "false"),
        jp("idempotentHint", "true"),
        jp("openWorldHint", "false")
    )
    jo4(
        jp("name", js(name)),
        jp("description", js(desc)),
        jp("inputSchema", input_schema),
        jp("annotations", annotations)
    )

fn _mcp_static_tools_result() -> text:
    val entries = get_tool_table()
    var tools: [text] = []
    for entry in entries:
        tools.push(_mcp_static_tool_schema(name: entry.name, desc: entry.description, required_json: entry.required_json))
    "{\"tools\":[" + tools.join(",") + "]}"
