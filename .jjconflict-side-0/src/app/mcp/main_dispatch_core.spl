use .main_lazy_json

fn dispatch_tool_core(id: text, tool_name: text, body: text) -> text:
    if tool_name == "":
        return make_tool_error(id, -32602, "Missing tool name")
    if tool_name == "simple_pipe":
        return _dispatch_simple_pipe_core(id, body)
    if tool_name == "simple_search":
        return _dispatch_simple_search_core(id, body)
    make_tool_error(id, -32601, "Unknown core tool: " + tool_name)

fn _dispatch_simple_pipe_core(id: text, body: text) -> text:
    val query = extract_field(body, "query")
    val file = extract_field(body, "file")
    if query != "" or file != "":
        return _dispatch_simple_search_core(id, body)
    make_tool_result(id, "simple_pipe\nstatus: ready\nspipe: linked\nsurfaces: search, codebase, context, ponytail\n")

fn _dispatch_simple_search_core(id: text, body: text) -> text:
    val query = extract_field(body, "query")
    val file = extract_field(body, "file")
    if query == "":
        return make_tool_error(id, -32602, "Missing query")
    var cmd = "timeout 15 grep -rn '" + query + "' src/ --include='*.spl' 2>/dev/null | head -50"
    if file != "":
        cmd = "timeout 10 grep -n '" + query + "' " + file + " 2>/dev/null | head -50"
    var out = ""
    var _u: i64 = 0
    (out, _u) = shell_cmd(cmd)
    if out.trim() == "":
        out = "No results found."
    make_tool_result(id, out)

export dispatch_tool_core
