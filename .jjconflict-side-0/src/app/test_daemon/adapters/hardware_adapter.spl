# Test Daemon Hardware Adapter — OpenOCD + TRACE32 debug sessions
#
# Manages hardware debug sessions for on-target testing. Both adapters
# use exclusive lease semantics with max 1 session per board.
# OpenOCD connects via GDB port, TRACE32 via RCL (Remote Control Line).

use app.test_daemon.session_types.{
    SessionKey, SessionDescriptor, SessionLease, TestSessionMeta,
    SESSION_KIND_OPENOCD, SESSION_KIND_TRACE32, LEASE_IDLE, LEASE_ACTIVE,
    REUSE_SHARED_WITH_RESET, REUSE_EXCLUSIVE_REUSED,
    RESET_HARD, RESET_RELOAD_BINARY,
    session_key_to_id, session_lease_new,
    reuse_mode_from_name, reset_policy_from_name
}
use app.test_daemon.session_adapter.{SessionAdapter, session_adapter_new}
use app.test_daemon.types.{TestResult, TRESP_COMPLETED, TRESP_FAILED}
use std.debug.remote.protocol.trace32.{Trace32Client}
use app.debug.remote.types.{DebugConfig}

extern fn rt_time_now_unix_micros() -> i64
extern fn rt_process_spawn_async(cmd: text, args: [text], env: {text: text}) -> i64
extern fn rt_process_kill(pid: i64) -> bool
extern fn rt_process_is_alive(pid: i64) -> bool
extern fn rt_sleep_ms(ms: i64)
extern fn rt_shell_exec(cmd: text) -> text
extern fn rt_shell_exit_code() -> i64
extern fn rt_tcp_connect(host: text, port: i64) -> bool

# ============================================================================
# OpenOCD Adapter
# ============================================================================

val OPENOCD_DEFAULT_GDB_PORT: i64 = 3333
val OPENOCD_DEFAULT_TELNET_PORT: i64 = 4444
val OPENOCD_STARTUP_WAIT_MS: i64 = 2000

class OpenocdAdapter:
    base: SessionAdapter
    gdb_port: i64
    telnet_port: i64

fn openocd_adapter_new() -> OpenocdAdapter:
    OpenocdAdapter(
        base: session_adapter_new(SESSION_KIND_OPENOCD, "openocd"),
        gdb_port: OPENOCD_DEFAULT_GDB_PORT,
        telnet_port: OPENOCD_DEFAULT_TELNET_PORT
    )

fn openocd_adapter_with_ports(gdb_port: i64, telnet_port: i64) -> OpenocdAdapter:
    OpenocdAdapter(
        base: session_adapter_new(SESSION_KIND_OPENOCD, "openocd"),
        gdb_port: gdb_port,
        telnet_port: telnet_port
    )

impl OpenocdAdapter:
    fn can_handle(meta: TestSessionMeta) -> bool:
        self.base.kind == meta.session_kind

    fn session_key(meta: TestSessionMeta) -> SessionKey:
        """
        OpenOCD sessions are keyed by board target. Each physical board
        can only have one active debug session.
        """
        SessionKey(
            kind: SESSION_KIND_OPENOCD,
            target: meta.target,
            artifact_hash: meta.artifact,
            env_profile: "",
            reuse_mode: REUSE_SHARED_WITH_RESET,
            reset_policy: RESET_HARD
        )

    me start(desc: SessionDescriptor) -> SessionLease:
        """
        Starts OpenOCD with the appropriate config for the target board.
        Waits for the GDB port to become available.
        """
        var lease = session_lease_new(desc.key)

        val target = desc.key.target
        val config_file = desc.config["openocd_cfg"] ?? ""

        if config_file == "" and target == "":
            return lease

        # Build OpenOCD command
        val effective_cfg = if config_file != "": config_file
            else: self.default_config_for_target(target)

        val gdb_port_str = desc.config["gdb_port"] ?? "{self.gdb_port}"
        val telnet_port_str = desc.config["telnet_port"] ?? "{self.telnet_port}"

        val args = [
            "-f", effective_cfg,
            "-c", "gdb_port {gdb_port_str}",
            "-c", "telnet_port {telnet_port_str}"
        ]

        val env: {text: text} = {}
        val pid = rt_process_spawn_async("openocd", args, env)

        if pid <= 0:
            return lease

        # Wait for OpenOCD to start and listen on GDB port
        rt_sleep_ms(OPENOCD_STARTUP_WAIT_MS)

        val effective_gdb_port = gdb_port_str.to_i64() ?? self.gdb_port
        val connected = self.wait_for_gdb_port("localhost", effective_gdb_port, 10)

        if not connected:
            rt_process_kill(pid)
            return lease

        val now = rt_time_now_unix_micros()
        SessionLease(
            session_id: session_key_to_id(desc.key),
            key: desc.key,
            pid: pid,
            qmp_socket: "localhost:{effective_gdb_port}",
            status: LEASE_ACTIVE,
            snapshot_name: "",
            created_at: now,
            last_used_at: now,
            test_count: 0
        )

    fn health(lease: SessionLease) -> bool:
        """
        Checks OpenOCD health by verifying the process is alive
        and the GDB port is reachable.
        """
        if lease.pid <= 0:
            return false
        if not rt_process_is_alive(lease.pid):
            return false

        # Try connecting to the GDB port
        val parts = lease.qmp_socket.split(":")
        if parts.len() < 2:
            return false
        val host = parts[0]
        val port = parts[1].to_i64() ?? OPENOCD_DEFAULT_GDB_PORT
        rt_tcp_connect(host, port)

    me reset(lease: SessionLease, policy: i64) -> bool:
        """
        Resets the target via OpenOCD telnet interface.
        RESET_HARD: sends 'monitor reset halt' via GDB
        RESET_RELOAD_BINARY: sends reset + reflash
        """
        if policy == RESET_HARD:
            val cmd = "echo 'reset halt' | nc localhost {self.telnet_port}"
            rt_shell_exec(cmd)
            val exit_code = rt_shell_exit_code()
            rt_sleep_ms(500)
            return exit_code == 0

        if policy == RESET_RELOAD_BINARY:
            # Reset and reload the binary
            val binary = lease.key.artifact_hash
            val reset_cmd = "echo 'reset halt' | nc localhost {self.telnet_port}"
            rt_shell_exec(reset_cmd)
            rt_sleep_ms(500)

            if binary != "":
                val flash_cmd = "echo 'program {binary} verify reset' | nc localhost {self.telnet_port}"
                rt_shell_exec(flash_cmd)
                val exit_code = rt_shell_exit_code()
                rt_sleep_ms(1000)
                return exit_code == 0
            return true

        false

    me execute(lease: SessionLease, test_path: text, timeout_ms: i64) -> TestResult:
        """
        Executes a test against the OpenOCD-managed target.
        Sets GDB_PORT env var for the test to connect.
        """
        val gdb_endpoint = lease.qmp_socket
        val cmd = "GDB_PORT={gdb_endpoint} bin/simple test {test_path} 2>&1"

        val start = rt_time_now_unix_micros()
        val output = rt_shell_exec(cmd)
        val exit_code = rt_shell_exit_code()
        val duration_ms = (rt_time_now_unix_micros() - start) / 1000

        val status = if exit_code == 0: TRESP_COMPLETED else: TRESP_FAILED
        val passed = if exit_code == 0: 1 else: 0
        val failed = if exit_code != 0: 1 else: 0

        TestResult(
            test_path: test_path,
            status: status,
            passed: passed,
            failed: failed,
            skipped: 0,
            duration_ms: duration_ms,
            output: output,
            cached: false
        )

    me stop(lease: SessionLease) -> bool:
        """
        Shuts down OpenOCD cleanly via telnet, then kills the process.
        """
        # Try graceful shutdown via telnet
        val shutdown_cmd = "echo 'shutdown' | nc localhost {self.telnet_port}"
        rt_shell_exec(shutdown_cmd)
        rt_sleep_ms(500)

        if lease.pid > 0:
            rt_process_kill(lease.pid)
        true

    # --- Private helpers ---

    fn default_config_for_target(target: text) -> text:
        """
        Returns the default OpenOCD config file path for a given target.
        """
        if target.contains("stm32"):
            return "board/stm32f4discovery.cfg"
        if target.contains("zynq") or target.contains("zedboard"):
            return "board/digilent_zedboard.cfg"
        if target.contains("riscv") or target.contains("rv32") or target.contains("rv64"):
            return "target/riscv.cfg"
        if target.contains("arm") or target.contains("cortex"):
            return "target/cortex_m.cfg"
        # Generic fallback
        "target/generic.cfg"

    fn wait_for_gdb_port(host: text, port: i64, max_retries: i64) -> bool:
        """
        Polls the GDB port until it accepts connections.
        """
        var attempt = 0
        while attempt < max_retries:
            if rt_tcp_connect(host, port):
                return true
            rt_sleep_ms(500)
            attempt = attempt + 1
        false

# ============================================================================
# TRACE32 Adapter
# ============================================================================

val T32_DEFAULT_RCL_PORT: i64 = 20000
val T32_DEFAULT_HOST: text = "localhost"
val T32_DEFAULT_INSTALL_DIR: text = "/opt/t32"
val T32_DEFAULT_STARTUP_WAIT_MS: i64 = 3000
val T32_DEFAULT_MAX_RETRIES: i64 = 15
val T32_DEFAULT_RETRY_INTERVAL_MS: i64 = 500
val T32_DEFAULT_RESET_SETTLE_MS: i64 = 1000
val T32_DEFAULT_FLASH_SETTLE_MS: i64 = 1000

# Configurable settings for the TRACE32 test adapter.
# All fields have sensible defaults; override via SDN config or constructor.
struct Trace32AdapterConfig:
    t32_host: text
    rcl_port: i64
    t32_install_dir: text
    startup_wait_ms: i64
    max_retries: i64
    retry_interval_ms: i64
    reset_settle_ms: i64
    flash_settle_ms: i64
    practice_script: text
    reuse_mode: i64
    reset_policy: i64

fn trace32_adapter_config_default() -> Trace32AdapterConfig:
    Trace32AdapterConfig(
        t32_host: T32_DEFAULT_HOST,
        rcl_port: T32_DEFAULT_RCL_PORT,
        t32_install_dir: T32_DEFAULT_INSTALL_DIR,
        startup_wait_ms: T32_DEFAULT_STARTUP_WAIT_MS,
        max_retries: T32_DEFAULT_MAX_RETRIES,
        retry_interval_ms: T32_DEFAULT_RETRY_INTERVAL_MS,
        reset_settle_ms: T32_DEFAULT_RESET_SETTLE_MS,
        flash_settle_ms: T32_DEFAULT_FLASH_SETTLE_MS,
        practice_script: "",
        reuse_mode: REUSE_EXCLUSIVE_REUSED,
        reset_policy: RESET_RELOAD_BINARY
    )

fn trace32_adapter_config_from_map(m: {text: text}) -> Trace32AdapterConfig:
    """Build a Trace32AdapterConfig from a string map (SDN config section).
    Missing keys fall back to defaults."""
    val defaults = trace32_adapter_config_default()
    Trace32AdapterConfig(
        t32_host: m["t32_host"] ?? defaults.t32_host,
        rcl_port: (m["rcl_port"] ?? "").to_i64() ?? defaults.rcl_port,
        t32_install_dir: m["t32_install_dir"] ?? defaults.t32_install_dir,
        startup_wait_ms: (m["startup_wait_ms"] ?? "").to_i64() ?? defaults.startup_wait_ms,
        max_retries: (m["max_retries"] ?? "").to_i64() ?? defaults.max_retries,
        retry_interval_ms: (m["retry_interval_ms"] ?? "").to_i64() ?? defaults.retry_interval_ms,
        reset_settle_ms: (m["reset_settle_ms"] ?? "").to_i64() ?? defaults.reset_settle_ms,
        flash_settle_ms: (m["flash_settle_ms"] ?? "").to_i64() ?? defaults.flash_settle_ms,
        practice_script: m["practice_script"] ?? defaults.practice_script,
        reuse_mode: if (m["reuse_mode"] ?? "") != "": reuse_mode_from_name(m["reuse_mode"] ?? "") else: defaults.reuse_mode,
        reset_policy: if (m["reset_policy"] ?? "") != "": reset_policy_from_name(m["reset_policy"] ?? "") else: defaults.reset_policy
    )

class Trace32Adapter:
    base: SessionAdapter
    cfg: Trace32AdapterConfig

fn trace32_adapter_new() -> Trace32Adapter:
    Trace32Adapter(
        base: session_adapter_new(SESSION_KIND_TRACE32, "trace32"),
        cfg: trace32_adapter_config_default()
    )

fn trace32_adapter_with_config(config: Trace32AdapterConfig) -> Trace32Adapter:
    Trace32Adapter(
        base: session_adapter_new(SESSION_KIND_TRACE32, "trace32"),
        cfg: config
    )

fn trace32_adapter_from_map(m: {text: text}) -> Trace32Adapter:
    """Create a Trace32Adapter from a string map (SDN config section)."""
    trace32_adapter_with_config(trace32_adapter_config_from_map(m))

impl Trace32Adapter:
    fn can_handle(meta: TestSessionMeta) -> bool:
        self.base.kind == meta.session_kind

    fn session_key(meta: TestSessionMeta) -> SessionKey:
        """
        TRACE32 sessions are keyed by board target. Each physical board
        can only have one active debug session (exclusive).
        """
        SessionKey(
            kind: SESSION_KIND_TRACE32,
            target: meta.target,
            artifact_hash: meta.artifact,
            env_profile: "",
            reuse_mode: self.cfg.reuse_mode,
            reset_policy: self.cfg.reset_policy
        )

    me start(desc: SessionDescriptor) -> SessionLease:
        """
        Starts TRACE32 PowerView and connects via RCL (Remote Control Line).
        Waits for the RCL port to become available, then optionally runs
        a startup PRACTICE script.
        """
        var lease = session_lease_new(desc.key)

        val target = desc.key.target
        val config_file = desc.config["t32_config"] ?? ""
        val practice = desc.config["practice_script"] ?? self.cfg.practice_script

        # Determine TRACE32 executable based on target architecture
        val t32_exe = self.t32_executable_for_target(target)
        val install_dir = desc.config["t32_install_dir"] ?? self.cfg.t32_install_dir
        val t32_path = "{install_dir}/bin/pc_linux64/{t32_exe}"

        val host = desc.config["t32_host"] ?? self.cfg.t32_host
        val rcl_port = (desc.config["rcl_port"] ?? "").to_i64() ?? self.cfg.rcl_port

        # Build args: config file, RCL port
        var args: [text] = []
        if config_file != "":
            args.push("-c")
            args.push(config_file)

        args.push("-s")
        args.push("RCL=NETTCP")
        args.push("PORT={rcl_port}")

        val env: {text: text} = {}
        env["T32SYS"] = install_dir
        val pid = rt_process_spawn_async(t32_path, args, env)

        if pid <= 0:
            return lease

        # Wait for TRACE32 to initialize
        rt_sleep_ms(self.cfg.startup_wait_ms)

        val connected = self.wait_for_rcl_port(host, rcl_port, self.cfg.max_retries)

        if not connected:
            rt_process_kill(pid)
            return lease

        # Run startup PRACTICE script if provided
        if practice != "":
            val client = self.connect_client(host, rcl_port)
            match client:
                Ok(c):
                    c.do_script(practice)
                    c.disconnect()
                    rt_sleep_ms(self.cfg.reset_settle_ms)
                Err(_):
                    pass_dn

        val now = rt_time_now_unix_micros()
        SessionLease(
            session_id: session_key_to_id(desc.key),
            key: desc.key,
            pid: pid,
            qmp_socket: "{host}:{rcl_port}",
            status: LEASE_ACTIVE,
            snapshot_name: "",
            created_at: now,
            last_used_at: now,
            test_count: 0
        )

    fn health(lease: SessionLease) -> bool:
        """
        Checks TRACE32 health by verifying the process is alive
        and t32rem can connect via the RCL port.
        """
        if lease.pid <= 0:
            return false
        if not rt_process_is_alive(lease.pid):
            return false

        val endpoint = self.parse_endpoint(lease.qmp_socket)
        val client = self.connect_client(endpoint.host, endpoint.port)
        match client:
            Ok(c):
                c.disconnect()
                true
            Err(_):
                false

    me reset(lease: SessionLease, policy: i64) -> bool:
        """
        Resets the target via TRACE32 RCL interface using Trace32Client.
        RESET_HARD: sends SYStem.RESetTarget
        RESET_RELOAD_BINARY: resets target and reloads binary via Data.LOAD
        """
        val endpoint = self.parse_endpoint(lease.qmp_socket)
        val client = self.connect_client(endpoint.host, endpoint.port)
        match client:
            Err(_):
                return false
            Ok(c):
                if policy == RESET_HARD:
                    val r = c.run_command("SYStem.RESetTarget")
                    c.disconnect()
                    rt_sleep_ms(self.cfg.reset_settle_ms)
                    match r:
                        Ok(_): return true
                        Err(_): return false

                if policy == RESET_RELOAD_BINARY:
                    val reset_r = c.run_command("SYStem.RESetTarget")
                    match reset_r:
                        Err(_):
                            c.disconnect()
                            return false
                        Ok(_):
                            pass_dn
                    rt_sleep_ms(self.cfg.reset_settle_ms)

                    val binary = lease.key.artifact_hash
                    if binary != "":
                        val flash_r = c.run_command("Data.LOAD.Elf {binary}")
                        rt_sleep_ms(self.cfg.flash_settle_ms)
                        match flash_r:
                            Err(_):
                                c.disconnect()
                                return false
                            Ok(_):
                                pass_dn

                    val pc_r = c.run_command("Register.Set PC Reset")
                    c.disconnect()
                    rt_sleep_ms(200)
                    match pc_r:
                        Ok(_): return true
                        Err(_): return false

                c.disconnect()
                false

    me execute(lease: SessionLease, test_path: text, timeout_ms: i64) -> TestResult:
        """
        Executes a test against the TRACE32-managed target.
        Sets T32_RCL_PORT env var for the test to connect.
        """
        val rcl_endpoint = lease.qmp_socket
        val cmd = "T32_RCL_PORT={rcl_endpoint} bin/simple test {test_path} 2>&1"

        val start = rt_time_now_unix_micros()
        val output = rt_shell_exec(cmd)
        val exit_code = rt_shell_exit_code()
        val duration_ms = (rt_time_now_unix_micros() - start) / 1000

        val status = if exit_code == 0: TRESP_COMPLETED else: TRESP_FAILED
        val passed = if exit_code == 0: 1 else: 0
        val failed = if exit_code != 0: 1 else: 0

        TestResult(
            test_path: test_path,
            status: status,
            passed: passed,
            failed: failed,
            skipped: 0,
            duration_ms: duration_ms,
            output: output,
            cached: false
        )

    me stop(lease: SessionLease) -> bool:
        """
        Shuts down TRACE32 cleanly via RCL QUIT command, then kills process.
        """
        val endpoint = self.parse_endpoint(lease.qmp_socket)
        val client = self.connect_client(endpoint.host, endpoint.port)
        match client:
            Ok(c):
                c.run_command("QUIT")
                c.disconnect()
                rt_sleep_ms(self.cfg.reset_settle_ms)
            Err(_):
                pass_dn

        if lease.pid > 0:
            rt_process_kill(lease.pid)
        true

    # --- Private helpers ---

    fn t32_executable_for_target(target: text) -> text:
        """
        Returns the TRACE32 executable name for the given target architecture.
        """
        if target.contains("arm") or target.contains("cortex"):
            return "t32marm"
        if target.contains("riscv") or target.contains("rv32") or target.contains("rv64"):
            return "t32mriscv"
        if target.contains("x86") or target.contains("amd64"):
            return "t32mx86"
        if target.contains("ppc") or target.contains("powerpc"):
            return "t32mppc"
        # Generic ARM as default (most common embedded target)
        "t32marm"

    fn connect_client(host: text, port: i64) -> Result<Trace32Client, text>:
        """
        Creates a Trace32Client connected to the given host:port.
        """
        val debug_config = DebugConfig(
            host: host,
            port: port,
            program: "",
            args: [],
            debugger: "t32",
            remote: true
        )
        Trace32Client.connect(debug_config)

    fn parse_endpoint(socket: text) -> Trace32Endpoint:
        """Parse a 'host:port' string into host and port."""
        val parts = socket.split(":")
        if parts.len() >= 2:
            Trace32Endpoint(
                host: parts[0],
                port: parts[1].to_i64() ?? self.cfg.rcl_port
            )
        else:
            Trace32Endpoint(host: self.cfg.t32_host, port: self.cfg.rcl_port)

    fn wait_for_rcl_port(host: text, port: i64, max_retries: i64) -> bool:
        """
        Polls the RCL port until it accepts connections.
        """
        var attempt = 0
        while attempt < max_retries:
            if rt_tcp_connect(host, port):
                return true
            rt_sleep_ms(self.cfg.retry_interval_ms)
            attempt = attempt + 1
        false

# Internal helper for parsed host:port endpoint
struct Trace32Endpoint:
    host: text
    port: i64
