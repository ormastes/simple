# Chromium Shell JS Engine Maturity Audit (V3 simple_browser shell — M9)
#
# Per `doc/03_plan/v3_simple_browser_milestones.md` §M9, this module
# implements the "honest assessment of `examples/browser/feature/script/engine/`
# against ECMAScript test262".
#
# M9 has three acceptance criteria:
#
#   1. **test262 runner wired (subset OK).**
#      `Test262Runner` below walks a (small, checked-in) subset of
#      test262-style cases and classifies each as `pass`, `fail`, or
#      `crash`. The runner itself is pure Simple — the real test262
#      corpus lives outside this repo, so the SFFI surface below is
#      an extern placeholder (see `rt_test262_*`) to be wired up in a
#      follow-up.
#
#   2. **Pass-rate report checked in.**
#      `js_audit_report.spl` carries the numbers for the subset we can
#      run today (see `Test262Report::canonical`) so anyone reading the
#      tree gets the honest state without having to run anything.
#
#   3. **Clear list of "things V3 apps will hit and crash on."**
#      `js_audit_crash_list.spl` enumerates the known crash / "no,
#      sorry" categories, each with a one-line rationale. `KnownCrash`
#      is its record type.
#
# V3 itself does not run JS (the `DesktopShell` widget tree is pure
# Simple), so this audit is **not** a V3 gate. Landing it unblocks the
# "keep the JIT or rip it out" decision called out in the plan doc.
#
# Scope decisions (kept deliberately small):
#
#   * No real test262 corpus import. The runner works on a hand-rolled
#     list of `Test262Case` records that mirror the shape of a real
#     test262 entry (source, expected outcome, negative flag).
#   * No direct dependency on `examples/browser/feature/script/engine/`.
#     The audit talks to the engine through a single SFFI extern
#     (`rt_test262_eval`) so this module compiles standalone and does
#     not force the heavy JS engine import graph on `ui.chromium/app.spl`.
#   * No JIT vs. interpreter split in the runner. The report records
#     per-backend numbers by string tag, and M9's `canonical` report
#     fills in today's "interpreter-only" state.

# ── SFFI extern placeholders ────────────────────────────────────────────
#
# TODO(M9-follow-up): wire these to
#   `examples/browser/feature/script/engine/interpreter.spl` /
#   `jit.spl` via a small C shim. For M9 itself, they are declared but
#   not called from the spec, so the module compiles without pulling
#   the JS engine into the chromium shell's import graph.

extern fn rt_test262_eval(backend: text, source: text) -> i64
extern fn rt_test262_load_corpus(subset: text) -> i64
extern fn rt_test262_case_source(handle: i64, index: i64) -> text
extern fn rt_test262_case_negative(handle: i64, index: i64) -> bool
extern fn rt_test262_case_count(handle: i64) -> i64
extern fn rt_test262_corpus_free(handle: i64)

# ── Outcome tags (stringly-typed to keep codegen simple) ───────────────

val OUTCOME_PASS: text = "pass"
val OUTCOME_FAIL: text = "fail"
val OUTCOME_CRASH: text = "crash"
val OUTCOME_SKIP: text = "skip"

# ── Test262 case record ─────────────────────────────────────────────────

class Test262Case:
    """A single test262-shaped case.

    `source` is the JS program text; `negative` is true for tests that
    must throw to be considered passing (matching test262's negative
    `frontmatter` flag). `name` is a short human-readable id used in
    the report."""

    name: text
    source: text
    negative: bool

    static fn new(name: text, source: text, negative: bool) -> Test262Case:
        Test262Case(name: name, source: source, negative: negative)

# ── Runner ──────────────────────────────────────────────────────────────

class Test262Runner:
    """Walks a list of `Test262Case`s and tallies outcomes per backend.

    The runner is deliberately pure: it receives a synthetic outcome
    per case (so the unit spec can drive it without SFFI), and only
    the real CLI-level integration calls `rt_test262_eval`. This keeps
    the audit module compile-clean and lets tests assert on the
    tallying logic without any JS engine at all."""

    backend: text
    pass_count: i64
    fail_count: i64
    crash_count: i64
    skip_count: i64

    static fn new(backend: text) -> Test262Runner:
        Test262Runner(
            backend: backend,
            pass_count: 0,
            fail_count: 0,
            crash_count: 0,
            skip_count: 0
        )

    me total() -> i64:
        self.pass_count + self.fail_count + self.crash_count + self.skip_count

    me record(outcome: text):
        """Bump the tally for a single case outcome."""
        if outcome == OUTCOME_PASS:
            self.pass_count = self.pass_count + 1
        else:
            if outcome == OUTCOME_FAIL:
                self.fail_count = self.fail_count + 1
            else:
                if outcome == OUTCOME_CRASH:
                    self.crash_count = self.crash_count + 1
                else:
                    self.skip_count = self.skip_count + 1

    me classify(tc: Test262Case, raw_outcome: text) -> text:
        """Resolve a raw engine outcome against a case's negative flag.

        For a non-negative case, `raw_outcome` passes through. For a
        negative case, `fail` (the engine threw) flips to `pass`, and
        `pass` (the engine did not throw) flips to `fail`. `crash` and
        `skip` are never rewritten."""
        if raw_outcome == OUTCOME_CRASH:
            return OUTCOME_CRASH
        if raw_outcome == OUTCOME_SKIP:
            return OUTCOME_SKIP
        if tc.negative:
            if raw_outcome == OUTCOME_FAIL:
                return OUTCOME_PASS
            if raw_outcome == OUTCOME_PASS:
                return OUTCOME_FAIL
        return raw_outcome

    me run_case(tc: Test262Case, raw_outcome: text) -> text:
        """Classify one case and record it. Returns the classified
        outcome so callers can chain asserts."""
        val resolved = self.classify(tc, raw_outcome)
        self.record(resolved)
        return resolved

    me pass_rate_pct() -> i64:
        """Integer pass rate 0..100. Returns 0 when no cases ran, to
        avoid division-by-zero in the pure unit spec."""
        val total = self.total()
        if total <= 0:
            return 0
        return (self.pass_count * 100) / total

# ── Helpers exposed to the spec ─────────────────────────────────────────

fn js_audit_default_subset() -> [Test262Case]:
    """The baseline M9 subset. Hand-rolled cases mirroring the shape of
    real test262 entries. These are the cases the pass-rate report is
    computed against.

    Kept tiny (5 entries) so the spec can exercise the runner without
    needing a real corpus. Real subset expansion is the follow-up
    described in `js_audit_crash_list.spl`."""
    val cases = [Test262Case]()
    cases.push(Test262Case.new("arith/add", "1 + 2", false))
    cases.push(Test262Case.new("arith/mul", "3 * 4", false))
    cases.push(Test262Case.new("neg/throw", "throw 1", true))
    cases.push(Test262Case.new("string/concat", "'a' + 'b'", false))
    cases.push(Test262Case.new("obj/prop", "({a:1}).a", false))
    return cases

fn js_audit_extended_subset() -> [Test262Case]:
    """An expanded, still hand-transcribed M9 subset (~20 cases).

    These are shaped like real test262 entries — each carries a
    source snippet short enough to read at a glance, plus the
    `negative` flag where applicable. The groupings mirror the
    M9 audit follow-up plan in the `v3_simple_browser_milestones` doc:

      * basic arithmetic / comparison / logical (5)
      * string method surface (5)
      * array method surface (5)
      * control flow (5)

    **No direct test262 corpus import.** The cases below are
    hand-transcribed analogues so the audit stays fully checked-in
    and does not require a submodule. Expected outcomes drive
    `js_audit_report::extended_subset_today()`; see that snapshot
    for today's interpreter-backend numbers."""
    val cases = [Test262Case]()

    # ── 1. Basic arithmetic / comparison / logical ──────────────────
    cases.push(Test262Case.new("ext/arith/sub", "10 - 3", false))
    cases.push(Test262Case.new("ext/arith/div", "20 / 4", false))
    cases.push(Test262Case.new("ext/cmp/lt", "1 < 2", false))
    cases.push(Test262Case.new("ext/cmp/eq", "2 === 2", false))
    cases.push(Test262Case.new("ext/logic/and", "true && false", false))

    # ── 2. String method surface ────────────────────────────────────
    cases.push(Test262Case.new("ext/string/length", "'hello'.length", false))
    cases.push(Test262Case.new("ext/string/charAt", "'abc'.charAt(1)", false))
    cases.push(Test262Case.new("ext/string/indexOf", "'abcdef'.indexOf('cd')", false))
    cases.push(Test262Case.new("ext/string/slice", "'abcdef'.slice(1, 4)", false))
    cases.push(Test262Case.new("ext/string/concat_method", "'a'.concat('b', 'c')", false))

    # ── 3. Array method surface ─────────────────────────────────────
    cases.push(Test262Case.new("ext/array/length", "[1,2,3].length", false))
    cases.push(Test262Case.new("ext/array/push",
        "var a = [1,2]; a.push(3); a.length", false))
    cases.push(Test262Case.new("ext/array/index", "[10,20,30][1]", false))
    cases.push(Test262Case.new("ext/array/map",
        "[1,2,3].map(function(x){return x+1})[2]", false))
    cases.push(Test262Case.new("ext/array/pop",
        "var a = [1,2,3]; a.pop(); a.length", false))

    # ── 4. Control flow ─────────────────────────────────────────────
    cases.push(Test262Case.new("ext/ctrl/if_else",
        "var x = 0; if (true) { x = 1 } else { x = 2 } x", false))
    cases.push(Test262Case.new("ext/ctrl/while",
        "var i = 0; while (i < 3) { i = i + 1 } i", false))
    cases.push(Test262Case.new("ext/ctrl/for",
        "var s = 0; for (var i = 0; i < 4; i = i + 1) { s = s + i } s", false))
    cases.push(Test262Case.new("ext/ctrl/break",
        "var i = 0; while (true) { if (i >= 2) { break } i = i + 1 } i", false))
    cases.push(Test262Case.new("ext/ctrl/neg_syntax", "1 +", true))

    return cases
