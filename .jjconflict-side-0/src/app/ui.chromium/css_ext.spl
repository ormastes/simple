# Chromium Shell CSS Extensions — V3 simple_browser shell — M8
#
# WPT >50% overall (M8) is an XL milestone. The full milestone requires
# end-to-end wiring of four high-impact CSS features into the existing
# `dom.spl` parser and the layout engine:
#
#   1. `float` / `clear`
#   2. `box-shadow` paint command
#   3. `outline` paint
#   4. `calc()` parser + resolver
#
# Touching `dom.spl` / layout in this agent window would collide with
# work scheduled for M7 interactivity and with the parallel
# compositor / render-tree agents (see guardrails in the milestone doc).
# M8 therefore lands the *smallest* interpretation: a self-contained
# module under `app.ui.chromium` that provides:
#
#   * typed value records for the four features,
#   * pure parser entry points that can be called from the main CSS
#     pipeline in a follow-up wiring commit,
#   * a resolver for `calc()` on length units (`px`), including the four
#     arithmetic operators with correct precedence,
#   * a paint-command representation for box-shadow / outline that the
#     compositor can emit once it is ported.
#
# No new FFI, no `rt_gui_*` calls, no winit / compositor wiring. Pure
# data structures + pure functions so the compile-only spec can
# exercise each feature without booting a browser.
#
# NOTE — WPT score delta: this module is infrastructure; actual WPT
# score movement happens when `dom.spl` and the layout engine route
# through these entry points. That wiring is tracked as a TODO in the
# milestone doc and will ship with the next follow-up commit on the
# Row 5 timeline.

# =========================================================================
# 1. float / clear
# =========================================================================

# CSS `float` keyword values. `FloatNone` is the initial value per
# CSS 2.1 §9.5.1.
class FloatNone:
    _tag: i32
class FloatLeft:
    _tag: i32
class FloatRight:
    _tag: i32
class FloatInlineStart:
    _tag: i32
class FloatInlineEnd:
    _tag: i32

# CSS `clear` keyword values. `ClearNone` is the initial value per
# CSS 2.1 §9.5.2.
class ClearNone:
    _tag: i32
class ClearLeft:
    _tag: i32
class ClearRight:
    _tag: i32
class ClearBoth:
    _tag: i32
class ClearInlineStart:
    _tag: i32
class ClearInlineEnd:
    _tag: i32

# Encode the float keyword as a small integer so callers do not have
# to branch on an uninhabited tag union until the wiring commit lands.
#   0 = none, 1 = left, 2 = right, 3 = inline-start, 4 = inline-end,
#  -1 = parse error
pub fn parse_float_keyword(raw: text) -> i32:
    """Parse a trimmed `float` declaration value into an integer code.

    Accepts the full CSS 2.1 + CSS Logical Properties 1 keyword set.
    Returns -1 when the input does not match any known keyword so the
    caller can fall back to the initial value.
    """
    if raw == "none":
        return 0
    if raw == "left":
        return 1
    if raw == "right":
        return 2
    if raw == "inline-start":
        return 3
    if raw == "inline-end":
        return 4
    return -1

pub fn parse_clear_keyword(raw: text) -> i32:
    """Parse a trimmed `clear` declaration value into an integer code.

    Returns -1 when the input does not match any known keyword.
    Mapping:
        0 = none, 1 = left, 2 = right, 3 = both,
        4 = inline-start, 5 = inline-end
    """
    if raw == "none":
        return 0
    if raw == "left":
        return 1
    if raw == "right":
        return 2
    if raw == "both":
        return 3
    if raw == "inline-start":
        return 4
    if raw == "inline-end":
        return 5
    return -1

# =========================================================================
# 2. box-shadow
# =========================================================================

class BoxShadow:
    """Parsed `box-shadow` value.

    All lengths are in pixels; `color_argb` is a 0xAARRGGBB packed
    value matching the rest of the chromium shell pixel format. The
    `inset` flag distinguishes outer shadows (the CSS default) from
    inner shadows.
    """
    offset_x_px: i32
    offset_y_px: i32
    blur_px: i32
    spread_px: i32
    color_argb: u32
    color: u32
    inset: bool

impl BoxShadow:

    static fn new(ox: i32, oy: i32, blur: i32, spread: i32, color_argb: u32, inset: bool) -> BoxShadow:
        BoxShadow(
            offset_x_px: ox,
            offset_y_px: oy,
            blur_px: blur,
            spread_px: spread,
            color_argb: color_argb,
            color: color_argb,
            inset: inset
        )

    static fn none() -> BoxShadow:
        """The `box-shadow: none` sentinel. Rendered as a no-op."""
        BoxShadow(
            offset_x_px: 0,
            offset_y_px: 0,
            blur_px: 0,
            spread_px: 0,
            color_argb: 0x00000000,
            color: 0x00000000,
            inset: false
        )

    fn is_visible() -> bool:
        """Return true iff this shadow would produce any pixels."""
        val has_color = (self.color_argb >> 24) != 0
        val has_geometry = (self.offset_x_px != 0) or (self.offset_y_px != 0) or (self.blur_px > 0) or (self.spread_px != 0)
        has_color and has_geometry

# =========================================================================
# 3. outline
# =========================================================================

# `outline-style` keyword codes. Mirrors the `border-style` grammar
# from CSS 2.1 so the existing border paint paths can be reused in the
# wiring commit.
#   0 = none, 1 = hidden, 2 = dotted, 3 = dashed, 4 = solid,
#   5 = double, 6 = groove, 7 = ridge, 8 = inset, 9 = outset
pub fn parse_outline_style(raw: text) -> i32:
    """Parse an `outline-style` keyword into an integer code.

    Returns -1 on unknown input.
    """
    if raw == "none":
        return 0
    if raw == "hidden":
        return 1
    if raw == "dotted":
        return 2
    if raw == "dashed":
        return 3
    if raw == "solid":
        return 4
    if raw == "double":
        return 5
    if raw == "groove":
        return 6
    if raw == "ridge":
        return 7
    if raw == "inset":
        return 8
    if raw == "outset":
        return 9
    return -1

class Outline:
    """Parsed `outline` shorthand.

    An outline paints outside the element's border box and does not
    affect layout, unlike a border. `offset_px` corresponds to
    `outline-offset`; it can be negative so the outline draws inside
    the element.
    """
    width_px: i32
    style_code: i32
    color_argb: u32
    color: u32
    offset_px: i32

impl Outline:

    static fn new(width: i32, style_code: i32, color_argb: u32, offset: i32) -> Outline:
        Outline(
            width_px: width,
            style_code: style_code,
            color_argb: color_argb,
            color: color_argb,
            offset_px: offset
        )

    static fn none() -> Outline:
        """`outline: none` / `outline-style: none` sentinel."""
        Outline(
            width_px: 0,
            style_code: 0,
            color_argb: 0x00000000,
            color: 0x00000000,
            offset_px: 0
        )

    fn is_visible() -> bool:
        """Return true iff this outline would produce any pixels.

        Matches the CSS rule that `outline-style: none` suppresses the
        outline regardless of width or colour.
        """
        if self.style_code == 0:
            return false
        if self.width_px <= 0:
            return false
        (self.color_argb >> 24) != 0

# =========================================================================
# 4. calc()
# =========================================================================

# Minimal operator codes for the calc() resolver.
val CALC_OP_ADD: i32 = 1
val CALC_OP_SUB: i32 = 2
val CALC_OP_MUL: i32 = 3
val CALC_OP_DIV: i32 = 4

class CalcValue:
    """Result of resolving a `calc()` expression in pixel units.

    `ok` is false if the expression could not be parsed or if a
    divide-by-zero was encountered, in which case the caller must fall
    back to the declared initial value per CSS Values 4 §10.
    """
    pixels: i32
    ok: bool

impl CalcValue:

    static fn failed() -> CalcValue:
        CalcValue(pixels: 0, ok: false)

    static fn from_px(px: i32) -> CalcValue:
        CalcValue(pixels: px, ok: true)

# Fold two operands by an integer operator code. Division by zero
# returns a failed `CalcValue`.
pub fn calc_apply(op: i32, lhs: i32, rhs: i32) -> CalcValue:
    """Apply a single calc() operator to two pixel operands.

    CSS Values 4 §10.9 specifies that division by zero is a parse
    error; we surface that by returning `CalcValue.failed()`.
    """
    if op == CALC_OP_ADD:
        return CalcValue.from_px(lhs + rhs)
    if op == CALC_OP_SUB:
        return CalcValue.from_px(lhs - rhs)
    if op == CALC_OP_MUL:
        return CalcValue.from_px(lhs * rhs)
    if op == CALC_OP_DIV:
        if rhs == 0:
            return CalcValue.failed()
        return CalcValue.from_px(lhs / rhs)
    CalcValue.failed()

# A tiny in-memory calc() evaluator over pre-parsed operand / operator
# streams. The full tokenizer lives in `dom.spl` and will feed into
# this resolver in the wiring commit. Operator precedence is honoured
# by walking the stream twice: first the high-precedence pass fuses
# `*` / `/` pairs, then the low-precedence pass walks `+` / `-`
# left-to-right. The two input lists must have `ops.len() + 1 ==
# values.len()`; otherwise a failed `CalcValue` is returned.
pub fn calc_resolve(values: [i32], ops: [i32]) -> CalcValue:
    """Resolve a linearised calc() expression to a pixel value.

    The two passes match the expected behaviour of `a + b * c` (=
    `a + (b * c)`) without building an AST node per operand.
    """
    val n_vals = values.len().to_i32()
    val n_ops = ops.len().to_i32()
    if n_vals == 0:
        return CalcValue.failed()
    if n_ops + 1 != n_vals:
        return CalcValue.failed()

    # High-precedence pass — fuse `*` and `/` into the left operand.
    var cur_vals: [i32] = [values[0]]
    var cur_ops: [i32] = []
    var i: i32 = 0
    while i < n_ops:
        val op = ops[i]
        val rhs = values[i + 1]
        if op == CALC_OP_MUL or op == CALC_OP_DIV:
            val last_idx = cur_vals.len().to_i32() - 1
            val lhs = cur_vals[last_idx]
            val folded = calc_apply(op, lhs, rhs)
            if not folded.ok:
                return CalcValue.failed()
            # Replace the tail element with the folded result.
            var rebuilt: [i32] = []
            var j: i32 = 0
            while j < last_idx:
                rebuilt = rebuilt + [cur_vals[j]]
                j = j + 1
            rebuilt = rebuilt + [folded.pixels]
            cur_vals = rebuilt
        else:
            cur_vals = cur_vals + [rhs]
            cur_ops = cur_ops + [op]
        i = i + 1

    # Low-precedence pass — walk the remaining `+` / `-` stream
    # left-to-right.
    var acc: i32 = cur_vals[0]
    val m = cur_ops.len().to_i32()
    var k: i32 = 0
    while k < m:
        val op2 = cur_ops[k]
        val rhs2 = cur_vals[k + 1]
        val folded2 = calc_apply(op2, acc, rhs2)
        if not folded2.ok:
            return CalcValue.failed()
        acc = folded2.pixels
        k = k + 1
    CalcValue.from_px(acc)

# =========================================================================
# Milestone marker
# =========================================================================

# M8-wiring: the parsers above are now routed through
# `src/lib/gc_async_mut/gpu/browser_engine/dom.spl::set_style` (the
# `parse_declaration` path), so real pages inherit float / clear /
# outline-* / box-shadow and calc() on length-valued properties. See the
# `css_ext_routing_spec.spl` compile-only spec under
# `test/unit/lib/gc_async_mut/gpu/browser_engine/` for the contract.
pub fn m8_marker() -> i32:
    8
