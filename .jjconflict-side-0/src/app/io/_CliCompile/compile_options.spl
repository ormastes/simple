# Shared native compilation option helpers.
use compiler.mir_opt.mod (optimizationpipeline_inventory_lines)

fn cli_native_default_opt_level() -> i64:
    3

fn cli_parse_opt_level(level: text) -> i64?:
    if level == "none" or level == "0":
        return Some(0)
    if level == "basic" or level == "1":
        return Some(1)
    if level == "standard" or level == "2" or level == "speed":
        return Some(2)
    if level == "aggressive" or level == "3" or level == "max":
        return Some(3)
    nil

fn cli_print_shared_opt_level_help():
    print "  --opt-level=<level>  Optimization level: none, basic, standard, aggressive"

fn cli_print_shared_optimization_inventory(command: text):
    print "Simple optimization guide"
    print "========================="
    print "Native executable default profile: aggressive"
    print "  Applied when building an executable without an explicit --opt-level."
    print "Native profile mapping:"
    print "  none       -> debug build mode, layout optimization disabled"
    print "  basic      -> release build mode, layout optimization disabled"
    print "  standard   -> release build mode, layout optimization disabled"
    print "  aggressive -> release build mode, layout optimization enabled"
    print ""
    print "Implemented optimization inventory:"
    print "  - [syntax] async desugar (basic, inventory-only)"
    print "  - [syntax] placeholder lambda rewrite (basic, inventory-only)"
    print "  - [syntax] collection pattern desugar (basic, inventory-only)"
    for line in optimizationpipeline_inventory_lines():
        print line
    print "  - [native] release build mode (basic, native-default)"
    print "  - [native] 4KB layout optimization (aggressive, native-default)"
    if command == "compile":
        print ""
        print "Entry-point notes:"
        print "  - Native executable builds default to aggressive on native backends."
        print "  - Release MIR/self-hosted builds normalize to standard unless --opt-level overrides it."
