# Feature Registry — runtime DI for optional I/O capabilities
#
# Typed port registry with noop defaults.
# Call init_features() at startup to probe and register available features.
#
# GPU priority: CUDA > Vulkan > noop (first available wins)

use app.io.feature_ports.{GpuComputePort, AudioPort, WindowPort}
use std.gc_async_mut.io.cuda_sffi.{cuda_available, cuda_device_count, cuda_device_info, cuda_sync, rt_cuda_malloc, rt_cuda_free, CudaDeviceInfo}
use std.gc_async_mut.io.vulkan_sffi.{vulkan_available, vulkan_device_count, vulkan_device_info, rt_vulkan_alloc_buffer, rt_vulkan_free_buffer, VulkanDeviceInfo}

var _gpu = nil
var _audio = nil
var _window = nil

# ============================================================================
# Noop port factories (fallbacks when feature is unavailable)
# ============================================================================

fn noop_gpu_port() -> GpuComputePort:
    GpuComputePort(
        name: "none",
        is_available_fn: \: false,
        device_count_fn: \: 0,
        device_name_fn: \_: "unavailable",
        alloc_fn: \_: 0,
        free_fn: \_: true,
        sync_fn: \: true
    )

fn cuda_port_device_name(id: i64) -> text:
    val info: CudaDeviceInfo = cuda_device_info(id)
    info.name

fn cuda_port_alloc(size: i64) -> i64:
    rt_cuda_malloc(size)

fn cuda_port_free(ptr: i64) -> bool:
    rt_cuda_free(ptr)

fn make_cuda_port() -> GpuComputePort:
    GpuComputePort(
        name: "cuda",
        is_available_fn: cuda_available,
        device_count_fn: cuda_device_count,
        device_name_fn: cuda_port_device_name,
        alloc_fn: cuda_port_alloc,
        free_fn: cuda_port_free,
        sync_fn: cuda_sync
    )

fn vulkan_port_device_name(id: i64) -> text:
    val info: VulkanDeviceInfo = vulkan_device_info(id)
    info.name

fn vulkan_port_alloc(size: i64) -> i64:
    rt_vulkan_alloc_buffer(size, 1)

fn vulkan_port_free(handle: i64) -> bool:
    rt_vulkan_free_buffer(handle)

fn vulkan_port_sync() -> bool:
    true

fn make_vulkan_port() -> GpuComputePort:
    GpuComputePort(
        name: "vulkan",
        is_available_fn: vulkan_available,
        device_count_fn: vulkan_device_count,
        device_name_fn: vulkan_port_device_name,
        alloc_fn: vulkan_port_alloc,
        free_fn: vulkan_port_free,
        sync_fn: vulkan_port_sync
    )

fn noop_audio_port() -> AudioPort:
    AudioPort(
        name: "none",
        is_available_fn: \: false,
        init_fn: \: 0,
        shutdown_fn: \_: true
    )

fn noop_window_port() -> WindowPort:
    WindowPort(
        name: "none",
        is_available_fn: \: false
    )

# ============================================================================
# Registration
# ============================================================================

fn register_gpu(port: GpuComputePort):
    _gpu = port

fn register_audio(port: AudioPort):
    _audio = port

fn register_window(port: WindowPort):
    _window = port

# ============================================================================
# Port accessors (return noop default if not registered)
# ============================================================================

fn gpu_port() -> GpuComputePort:
    _gpu ?? noop_gpu_port()

fn audio_port() -> AudioPort:
    _audio ?? noop_audio_port()

fn window_port() -> WindowPort:
    _window ?? noop_window_port()

# ============================================================================
# Feature initialization (call once at program startup)
# ============================================================================

fn init_features():
    if cuda_available():
        register_gpu(make_cuda_port())
    elif vulkan_available():
        register_gpu(make_vulkan_port())
    # else: noop_gpu_port is the default
