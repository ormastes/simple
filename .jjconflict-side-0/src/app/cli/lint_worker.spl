# Heavy lint/fmt/fix worker for src/app/cli/lint_entry.spl.
#
# This file intentionally imports compiler-backed command implementations. The
# public command entry handles help before spawning this worker so startup/help
# does not load the compiler graph.

use std.cli.cli_util (get_cli_args)
use app.io.cli_lint_commands.{run_lint_command, run_fmt_command, run_fix_command}

fn main() -> i64:
    val all_args = get_cli_args()

    var args = []
    var i = 0
    if all_args.len() > 0 and all_args[0].ends_with("lint_worker.spl"):
        i = 1

    while i < all_args.len():
        args.push(all_args[i])
        i = i + 1

    if args.len() == 0:
        print "Usage: simple lint|fmt|fix [options] [path]"
        return 1

    val command = args[0]
    if command == "lint":
        return run_lint_command(args)
    elif command == "fmt":
        return run_fmt_command(args)
    elif command == "fix":
        return run_fix_command(args)
    else:
        print "Unknown command: {command}"
        return 1
