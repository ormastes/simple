# Lightweight entrypoint for `simple check`.

use std.cli.cli_util.{get_cli_args}
use std.nogc_sync_mut.io.file_ops.{file_exists}
use app.io.process_ops.{process_run_timeout}

val OUTPUT_LIMIT = 12000
val CHECK_WORKER_TIMEOUT_MS = 300000

# Spawn the worker via the REAL release binary path, not the bin/simple
# symlink: with a symlinked argv0 the worker's _cli_driver_binary() sibling
# lookup (simple_seed next to argv0) misses the seed, so its `run` grinds
# in-process with the slow self-hosted frontend instead of delegating
# (300s timeout per file). The real release path always has simple_seed
# as a sibling, so delegation works there.
fn resolve_worker_binary() -> text:
    val (os_out, _os_err, os_code) = process_run_timeout("uname", ["-s"], 10000)
    val (arch_out, _arch_err, arch_code) = process_run_timeout("uname", ["-m"], 10000)
    if os_code != 0 or arch_code != 0:
        return "bin/simple"
    val os_name = os_out.trim()
    var arch = arch_out.trim()
    if arch == "arm64":
        arch = "aarch64"
    if arch == "amd64":
        arch = "x86_64"
    var triple = ""
    if os_name == "Darwin":
        triple = "{arch}-apple-darwin"
    elif os_name == "Linux":
        triple = "{arch}-unknown-linux-gnu"
    elif os_name == "FreeBSD":
        triple = "{arch}-unknown-freebsd"
    else:
        return "bin/simple"
    val candidate = "bin/release/{triple}/simple"
    if file_exists(candidate):
        return candidate
    "bin/simple"

fn print_help():
    print "Usage: simple check <file.spl> [file2.spl ...]"
    print ""
    print "Parse and validate Simple source files."
    print ""
    print "Options:"
    print "  --human | --llm | --json     Select log rendering mode"
    print "  --progress <summary|count|dot|none>"
    print "  -h, --help                   Show this help"

fn normalize_args(args: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if (i == 0 and arg.ends_with("check_entry.spl")) or arg == "check":
            i = i + 1
            continue
        out.push(arg)
        i = i + 1
    out

fn wants_json(args: [text]) -> bool:
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--json" or arg == "--log-mode=json":
            return true
        if arg == "--log-mode" and i + 1 < args.len() and args[i + 1] == "json":
            return true
        i = i + 1
    false

fn last_json_line(output: text) -> text:
    var found = ""
    val lines = output.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed.starts_with("{") and trimmed.ends_with("}"):
            found = trimmed
    found

fn print_bounded_stdout(output: text, as_json: bool):
    if output.len() == 0:
        return
    if as_json:
        val json = last_json_line(output)
        if json != "":
            print json
            return
    if output.len() <= OUTPUT_LIMIT:
        print output
        return
    print output[0:OUTPUT_LIMIT]
    print "[stdout truncated by check entry]"

fn print_bounded_stderr(output: text):
    if output.len() == 0:
        return
    if output.len() > OUTPUT_LIMIT:
        eprint output[0:OUTPUT_LIMIT]
        eprint "[stderr truncated by check entry]"
    else:
        eprint output

fn is_check_option(arg: text) -> bool:
    if arg == "--human" or arg == "--llm" or arg == "--json":
        return true
    if arg == "--quiet" or arg == "--verbose" or arg == "--dots":
        return true
    if arg == "--count" or arg == "--no-progress":
        return true
    if arg.starts_with("--log-mode=") or arg.starts_with("--surface="):
        return true
    arg.starts_with("--progress=")

fn check_files_from_args(args: [text]) -> [text]:
    var files: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
            i = i + 1
        elif is_check_option(arg):
            val _skip = 0
        elif not arg.starts_with("-"):
            files.push(arg)
        i = i + 1
    files

fn run_single_worker(worker_bin: text, args: [text], as_json: bool) -> i64:
    var worker_args = ["run", "src/app/check/main.spl"]
    for arg in args:
        worker_args.push(arg)
    val (stdout, stderr, code) = process_run_timeout(worker_bin, worker_args, CHECK_WORKER_TIMEOUT_MS)
    print_bounded_stdout(stdout, as_json)
    if code != 0:
        print_bounded_stderr(stderr)
    code as i64

fn main() -> i64:
    val args = normalize_args(get_cli_args())
    if args.len() == 0 or args.contains("-h") or args.contains("--help"):
        print_help()
        return 0

    val as_json = wants_json(args)
    val files = check_files_from_args(args)
    val worker_bin = resolve_worker_binary()
    if files.len() <= 1:
        return run_single_worker(worker_bin, args, as_json)

    var checked = 0
    var errors = 0
    var files_with_errors = 0
    for file in files:
        var single_args: [text] = []
        single_args.push(file)
        if as_json:
            single_args.push("--json")
        var worker_args = ["run", "src/app/check/main.spl"]
        for arg in single_args:
            worker_args.push(arg)
        val (stdout, stderr, code) = process_run_timeout(worker_bin, worker_args, CHECK_WORKER_TIMEOUT_MS)
        if not as_json:
            print_bounded_stdout(stdout, false)
        if code != 0:
            print_bounded_stderr(stderr)
        checked = checked + 1
        if code != 0:
            errors = errors + 1
            files_with_errors = files_with_errors + 1

    if as_json:
        val status = if errors == 0: "ok" else: "error"
        print "{\"command\":\"check\",\"status\":\"{status}\",\"checked\":{checked},\"files\":{files.len()},\"errors\":{errors},\"files_with_errors\":{files_with_errors}}"
    if errors == 0:
        return 0
    1
