# Tauri IPC Protocol
#
# Re-exports the IPC protocol used by both Electron and Tauri backends.
# Tauri-specific extensions can be added here in the future.

use app.ui.ipc.protocol.{IpcMessageKind, parse_ipc_message, build_ipc_render,
    build_ipc_dialog, build_ipc_notification, build_ipc_window_control,
    build_ipc_file_dialog, extract_json_field, escape_ipc_json}
