# Renderer capability metadata for optional implementation modules.
#
# This module intentionally does not import HTML widget or CSS implementation
# modules. It gives callers a stable capability boundary they can inspect
# without retaining implementation code in non-HTML closures.

class RendererCapability:
    id: text
    implementation_module: text
    artifact_id: text
    default_autoload: bool

    me to_text() -> text:
        return self.id + ":" + self.implementation_module + ":" + self.artifact_id + ":" + self.default_autoload.to_text()

fn renderer_capability_html_widgets() -> RendererCapability:
    RendererCapability(
        id: "html_renderer",
        implementation_module: "app.ui.render.html_widgets",
        artifact_id: "web_renderer",
        default_autoload: false
    )

fn renderer_capability_css_provider() -> RendererCapability:
    RendererCapability(
        id: "css_provider",
        implementation_module: "app.ui.render.css",
        artifact_id: "web_renderer",
        default_autoload: false
    )

fn renderer_capability_tui_widgets() -> RendererCapability:
    RendererCapability(
        id: "tui_renderer",
        implementation_module: "app.ui.render.tui_widgets",
        artifact_id: "tui_renderer",
        default_autoload: true
    )

fn renderer_capability_allows_module(cap: RendererCapability, module_name: text) -> bool:
    module_name == cap.implementation_module or module_name.starts_with(cap.implementation_module + ".")

fn renderer_capability_is_lazy(cap: RendererCapability) -> bool:
    not cap.default_autoload

export RendererCapability
export renderer_capability_html_widgets, renderer_capability_css_provider, renderer_capability_tui_widgets
export renderer_capability_allows_module, renderer_capability_is_lazy
