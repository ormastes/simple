# IDE capability registry.
#
# This is product-level metadata only: each capability points at the existing
# implementation owner so the IDE can expose app/plugin support without forking
# renderers, document models, spreadsheets, slide decks, dashboards, or DB code.

struct IdeCapability:
    id: text
    label: text
    plugin_kind: text
    owner_module: text
    compatible_with: [text]
    feature_check: text

fn ide_capability_new(id: text, label: text, plugin_kind: text, owner_module: text, compatible_with: [text], feature_check: text) -> IdeCapability:
    IdeCapability(
        id: id,
        label: label,
        plugin_kind: plugin_kind,
        owner_module: owner_module,
        compatible_with: compatible_with,
        feature_check: feature_check
    )

fn ide_capabilities() -> [IdeCapability]:
    [
        ide_capability_new(
            "sheets",
            "Calc Spreadsheet",
            "office-app",
            "app.office.sheets",
            ["excel", "xlsx", "tabular", "csv"],
            ""
        ),
        ide_capability_new(
            "markdown",
            "Markdown/Writer",
            "document-renderer",
            "std.editor.render.md_renderer",
            ["md", "markdown", "writer", "html"],
            ""
        ),
        ide_capability_new(
            "slides",
            "Impress/PPT",
            "office-app",
            "app.office.slides",
            ["ppt", "presentation", "slides"],
            ""
        ),
        ide_capability_new(
            "draw-sdd",
            "Draw/SDD",
            "diagram-app",
            "std.editor.services.sdn_graph",
            ["draw", "sdd", "sdn"],
            ""
        ),
        ide_capability_new(
            "designer",
            "Designer",
            "designer-app",
            "std.common.markdown_visual_editor",
            ["html", "css", "ui"],
            ""
        ),
        ide_capability_new(
            "base",
            "Base",
            "database-app",
            "std.editor.core.session_db",
            ["table", "database", "import"],
            ""
        ),
        ide_capability_new(
            "math",
            "Math",
            "formula-app",
            "std.common.math_repr",
            ["formula", "mathml"],
            ""
        ),
        ide_capability_new(
            "mail",
            "Mail",
            "mail-app",
            "std.hardware.soc_rtl.mailbox",
            ["message", "folder", "compose"],
            ""
        ),
        ide_capability_new(
            "planner",
            "Planner",
            "planner-app",
            "std.nogc_sync_mut.db.query_planner",
            ["task", "board", "calendar"],
            ""
        ),
        ide_capability_new(
            "agent-dashboard",
            "Agent Dashboard",
            "dashboard",
            "app.editor.mcp_tools",
            ["agent", "dashboard", "mcp"],
            ""
        ),
        ide_capability_new(
            "db-admin",
            "Database Admin",
            "database",
            "std.editor.core.session_db",
            ["embedded-db", "simple-db", "portal-db"],
            ""
        )
    ]

fn ide_capability_count() -> i64:
    ide_capabilities().len()

fn ide_capability_ids() -> [text]:
    var ids: [text] = []
    for cap in ide_capabilities():
        ids.push(cap.id)
    ids

fn ide_capability_report() -> [text]:
    var lines: [text] = []
    for cap in ide_capabilities():
        val compat = cap.compatible_with.join(", ")
        lines.push(cap.id + ": " + cap.label + " [" + cap.plugin_kind + "] -> " + cap.owner_module + " (" + compat + ")")
        lines.push("  check: " + cap.feature_check)
    lines

# Returns true when a capability entry has non-empty required fields.
fn ide_capability_valid(cap: IdeCapability) -> bool:
    cap.id != "" and cap.label != "" and cap.owner_module != "" and cap.plugin_kind != ""

# Returns true when both preview pane dimensions are positive (sane defaults).
fn ide_preview_bounds_valid(width: i64, height: i64) -> bool:
    width > 0 and height > 0

# Returns the count of capabilities that pass ide_capability_valid.
fn ide_capability_valid_count() -> i64:
    var count: i64 = 0
    for cap in ide_capabilities():
        if ide_capability_valid(cap):
            count = count + 1
    count
