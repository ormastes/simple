# gui_readability_oracle.spl — Readability oracle for GUI screenshots.
#
# Analyzes a PPM image to check:
# 1. Image is not blank (>=2 distinct colors, ink coverage above threshold)
# 2. Text-like regions exist (rows with alternating ink/background runs)
# 3. No full-viewport overflow (content ink not clipped at all four edges)
#
# Usage: bin/simple run src/app/test/gui_readability_oracle.spl <ppm_file>
# Exits 0 on pass, 1 on fail. Prints metrics to stdout.

use std.common.image.ppm_decode.{decode_ppm_to_argb, PpmImage}
use std.nogc_sync_mut.sffi.io.{file_read_bytes}
use std.cli.cli_util.{get_cli_args}

# ARGB to grayscale (simple luminance)
fn to_grayscale(argb: u32) -> u8:
    val r = (argb >> 16) & 0xFF
    val g = (argb >> 8) & 0xFF
    val b = argb & 0xFF
    # Standard luminance: 0.299*R + 0.587*G + 0.114*B
    (((r * 77 + g * 150 + b * 29) >> 8) & 0xFF) as u8

# Decide if a grayscale value is "ink" (dark) or "background" (light)
# Threshold: 128 (middle gray)
fn is_ink(gray: u8) -> bool:
    gray < 128

# Count distinct colors in the image
fn count_distinct_colors(pixels: [u32]) -> i64:
    var colors: [bool] = [false; 256]
    for p in pixels:
        val gray = to_grayscale(p)
        colors[gray as i64] = true
    var count: i64 = 0
    for c in colors:
        if c:
            count = count + 1
    count

# Calculate ink coverage (fraction of ink pixels)
fn ink_coverage(pixels: [u32]) -> f64:
    var ink_count: i64 = 0
    for p in pixels:
        if is_ink(to_grayscale(p)):
            ink_count = ink_count + 1
    (ink_count as f64) / (pixels.len() as f64)

# Check for text-like regions: sample rows for alternating ink/bg runs (optimization: sample every 10th row)
# A "text-like" row has at least 3 run transitions (implies columns/characters)
fn has_text_like_regions(img: PpmImage) -> bool:
    var text_rows = 0
    var sampled_rows = 0
    var y = 0
    while y < img.height:
        sampled_rows = sampled_rows + 1
        var runs = 1
        var prev_is_ink = is_ink(to_grayscale(img.pixels[y * img.width + 0]))
        var x = 1
        while x < img.width:
            val curr_is_ink = is_ink(to_grayscale(img.pixels[y * img.width + x]))
            if curr_is_ink != prev_is_ink:
                runs = runs + 1
            prev_is_ink = curr_is_ink
            x = x + 1
        # If a row has >=3 transitions, it might contain text
        if runs >= 3:
            text_rows = text_rows + 1
        # Sample every 10th row for large images (optimization)
        y = if img.height > 200: y + 10 else: y + 1
    # Consider it text-like if >=10% of sampled rows have >=3 run transitions
    if sampled_rows == 0:
        return false
    text_rows * 10 >= sampled_rows

# Check for clipping: background edges suggest overflow
# Scan border rows/cols; if they're mostly non-background, content may be clipped.
# dark_theme: true when the image background is dark (light text) — polarity flips.
fn check_no_clipping(img: PpmImage, dark_theme: bool) -> bool:
    # Sample border pixels (outer 2 pixels on each edge)
    var border_pixels: [u32] = []
    # Top edge
    var x = 0
    while x < img.width:
        border_pixels.push(img.pixels[0 * img.width + x])
        border_pixels.push(img.pixels[1 * img.width + x])
        x = x + 1
    # Bottom edge
    x = 0
    while x < img.width:
        border_pixels.push(img.pixels[(img.height - 2) * img.width + x])
        border_pixels.push(img.pixels[(img.height - 1) * img.width + x])
        x = x + 1
    # Left edge
    var y = 2
    while y < img.height - 2:
        border_pixels.push(img.pixels[y * img.width + 0])
        border_pixels.push(img.pixels[y * img.width + 1])
        y = y + 1
    # Right edge
    y = 2
    while y < img.height - 2:
        border_pixels.push(img.pixels[y * img.width + (img.width - 2)])
        border_pixels.push(img.pixels[y * img.width + (img.width - 1)])
        y = y + 1
    # Borders should be mostly background; if mostly content, likely clipped
    val border_dark = ink_coverage(border_pixels)
    val border_bg = if dark_theme: border_dark else: 1.0 - border_dark
    border_bg > 0.2

fn main() -> i64:
    val args = get_cli_args()
    if args.len() < 1:
        print "usage: bin/simple run src/app/test/gui_readability_oracle.spl <ppm_file>"
        return 1

    val ppm_path = args[0]
    print "Analyzing: {ppm_path}"

    val data = file_read_bytes(ppm_path)
    if data.len() == 0:
        print "error: failed to read file"
        return 1

    val img_result = decode_ppm_to_argb(data)
    if img_result.is_err():
        print "error: failed to decode PPM: {img_result.unwrap_err()}"
        return 1

    val img = img_result.unwrap()
    print "Image: {img.width}x{img.height}"

    # Check 1: not blank
    val color_count = count_distinct_colors(img.pixels)
    val pass_colors = color_count >= 2
    print "color_count={color_count} pass={pass_colors}"

    # Check 2: effective ink = minority polarity (handles dark and light themes)
    val dark_frac = ink_coverage(img.pixels)
    val dark_theme = dark_frac > 0.5
    val cov = if dark_theme: 1.0 - dark_frac else: dark_frac
    print "dark_theme={dark_theme}"
    # Calibrated against the 640x480 showcase capture: legible UI text is ~1-2%
    # of pixels; 0.5% still distinguishes real content from a blank frame.
    val pass_coverage = cov > 0.005
    print "ink_coverage={cov} pass={pass_coverage}"

    # Check 3: text-like regions (optional hint, not required for pass)
    val has_text = has_text_like_regions(img)
    print "has_text_like_regions={has_text}"

    # Check 4: no clipping at edges
    val no_clip = check_no_clipping(img, dark_theme)
    print "no_clipping_at_edges={no_clip} pass={no_clip}"

    # Summary: require colors, coverage, and no clipping; text regions are a hint
    val all_pass = pass_colors and pass_coverage and no_clip
    print "overall={if all_pass: "pass" else: "fail"}"

    if all_pass:
        return 0
    else:
        return 1
