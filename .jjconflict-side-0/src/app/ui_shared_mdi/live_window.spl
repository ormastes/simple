# Native live-window host for the shared MDI HTML producer.

use app.ui_shared_mdi.desktop_html.{shared_mdi_desktop_html}
use app.ui_shared_mdi.terminal_window_html.{shared_mdi_terminal_window_html}
use app.ui_shared_mdi.live_window_event_policy.{LIVE_CLICK_TARGET_NONE, LIVE_CLICK_TARGET_TITLEBAR, LIVE_CLICK_TARGET_BODY, shared_mdi_live_completed_click_target, shared_mdi_live_events_complete}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{simple_web_layout_render_html_software_pixels}
use std.io.window_winit.{WinitLoop, WinitWindow, winit_loop_new, winit_loop_free, winit_window_new, winit_window_free, winit_present_rgba, winit_wait_input}
use std.nogc_sync_mut.io_runtime.{env_get, file_write}
use std.nogc_sync_mut.io.time_ops.{time_now_unix_micros}

val LIVE_WIDTH: i32 = 640
val LIVE_HEIGHT: i32 = 512

fn _pack_pixels(src: [u32]) -> [i64]:
    var packed: [i64] = [0; src.len()]
    var i = 0
    while i < src.len():
        packed[i] = src[i].to_i64() & 0xFFFFFF
        i = i + 1
    packed

fn _live_html(keyboard_events: i64, pointer_events: i64, click_events: i64, titlebar_click_events: i64, body_click_events: i64) -> text:
    val window_style = "position:absolute;left:30px;top:48px;width:580px;height:350px;border:1px solid rgb(52,211,153);border-radius:7px;background:rgb(11,13,16);overflow:hidden;box-sizing:border-box;z-index:3;"
    val terminal = "<div id=\"terminal-live-window\" style=\"" + window_style + "\">" + shared_mdi_terminal_window_html() + "</div>"
    val event_complete = shared_mdi_live_events_complete(keyboard_events, pointer_events, click_events, titlebar_click_events, body_click_events)
    val evidence_color = if event_complete: "rgb(255,73,171)" else: "rgb(148,163,184)"
    val evidence_style = "position:absolute;left:30px;top:410px;color:{evidence_color};font:14px monospace;z-index:6;"
    val evidence = "<div id=\"native-event-evidence\" style=\"{evidence_style}\">keyboard={keyboard_events} pointer={pointer_events} click={click_events} titlebar={titlebar_click_events} body={body_click_events}</div>"
    shared_mdi_desktop_html("simple-web", terminal + evidence)

fn _write_event_evidence(path: text, keyboard_events: i64, pointer_events: i64, click_events: i64, titlebar_click_events: i64, body_click_events: i64):
    if path != "":
        val content = "keyboard_events={keyboard_events}\npointer_events={pointer_events}\nclick_events={click_events}\ntitlebar_click_events={titlebar_click_events}\nbody_click_events={body_click_events}\n"
        val _ = file_write(path, content)

fn run_shared_mdi_live_window() -> i64:
    var keyboard_events = 0
    var pointer_events = 0
    var click_events = 0
    var titlebar_click_events = 0
    var body_click_events = 0
    var cursor_x = 0.0
    var cursor_y = 0.0
    val event_evidence_path = env_get("SIMPLE_GUI_EVENT_EVIDENCE_PATH")
    var pixels = simple_web_layout_render_html_software_pixels(_live_html(keyboard_events, pointer_events, click_events, titlebar_click_events, body_click_events), LIVE_WIDTH, LIVE_HEIGHT)
    if pixels.len() != LIVE_WIDTH * LIVE_HEIGHT:
        return 1
    var packed = _pack_pixels(pixels)
    val lp = winit_loop_new()
    if not lp.is_valid:
        return 2
    val win = winit_window_new(lp, LIVE_WIDTH.to_i64(), LIVE_HEIGHT.to_i64(), "SimpleGui")
    if not win.is_valid:
        winit_loop_free(lp)
        return 3
    if not winit_present_rgba(win, LIVE_WIDTH.to_i64(), LIVE_HEIGHT.to_i64(), packed):
        winit_window_free(win)
        winit_loop_free(lp)
        return 5
    _write_event_evidence(event_evidence_path, keyboard_events, pointer_events, click_events, titlebar_click_events, body_click_events)
    var running = true
    var render_failed = false
    var present_failed = false
    var iterations = 0
    val end_at = time_now_unix_micros() + 60000000
    while running and time_now_unix_micros() < end_at:
        val input = winit_wait_input(lp, 8)
        if input.close:
            running = false
        val old_keyboard_events = keyboard_events
        val old_pointer_events = pointer_events
        val old_click_events = click_events
        val old_titlebar_click_events = titlebar_click_events
        val old_body_click_events = body_click_events
        keyboard_events = keyboard_events + input.keys.len()
        pointer_events = pointer_events + input.mouse_moves
        if input.mouse_moves > 0:
            cursor_x = input.mouse_x
            cursor_y = input.mouse_y
        var click_i = 0
        while click_i < input.click_pressed.len() and click_i < input.click_buttons.len():
            var click_x = cursor_x
            var click_y = cursor_y
            if click_i < input.click_x.len() and click_i < input.click_y.len():
                val batched_x = input.click_x[click_i]
                val batched_y = input.click_y[click_i]
                if batched_x != 0.0 or batched_y != 0.0:
                    click_x = batched_x
                    click_y = batched_y
            val target = shared_mdi_live_completed_click_target(input.click_buttons[click_i], input.click_pressed[click_i], click_x, click_y)
            if target != LIVE_CLICK_TARGET_NONE:
                click_events = click_events + 1
                if target == LIVE_CLICK_TARGET_TITLEBAR:
                    titlebar_click_events = titlebar_click_events + 1
                if target == LIVE_CLICK_TARGET_BODY:
                    body_click_events = body_click_events + 1
            click_i = click_i + 1
        if keyboard_events != old_keyboard_events or pointer_events != old_pointer_events or click_events != old_click_events or titlebar_click_events != old_titlebar_click_events or body_click_events != old_body_click_events:
            pixels = simple_web_layout_render_html_software_pixels(_live_html(keyboard_events, pointer_events, click_events, titlebar_click_events, body_click_events), LIVE_WIDTH, LIVE_HEIGHT)
            if pixels.len() == LIVE_WIDTH * LIVE_HEIGHT:
                packed = _pack_pixels(pixels)
                if winit_present_rgba(win, LIVE_WIDTH.to_i64(), LIVE_HEIGHT.to_i64(), packed):
                    _write_event_evidence(event_evidence_path, keyboard_events, pointer_events, click_events, titlebar_click_events, body_click_events)
                else:
                    present_failed = true
                    running = false
            else:
                render_failed = true
                running = false
        if iterations % 200 == 0:
            if not winit_present_rgba(win, LIVE_WIDTH.to_i64(), LIVE_HEIGHT.to_i64(), packed):
                present_failed = true
                running = false
        iterations = iterations + 1
    winit_window_free(win)
    winit_loop_free(lp)
    if render_failed:
        return 4
    if present_failed:
        return 5
    0

fn main() -> i64:
    run_shared_mdi_live_window()
