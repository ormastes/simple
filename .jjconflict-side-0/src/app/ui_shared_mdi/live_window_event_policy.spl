# Pure event-classification policy for the shared MDI live-window evidence host.

pub val LIVE_CLICK_TARGET_NONE: i64 = 0
pub val LIVE_CLICK_TARGET_TITLEBAR: i64 = 1
pub val LIVE_CLICK_TARGET_BODY: i64 = 2
pub val LIVE_PRIMARY_MOUSE_BUTTON: i64 = 0

# Client-pixel hitboxes for the shared terminal fragment. They cover the
# right-aligned titlebar button/input and the body button/input; native window
# chrome is removed before winit reports cursor coordinates.
val TITLEBAR_CONTROL_X_MIN = 430.0
val TITLEBAR_CONTROL_X_MAX = 610.0
val TITLEBAR_CONTROL_Y_MIN = 48.0
val TITLEBAR_CONTROL_Y_MAX = 90.0
val BODY_CONTROL_X_MIN = 30.0
val BODY_CONTROL_X_MAX = 220.0
val BODY_CONTROL_Y_MIN = 170.0
val BODY_CONTROL_Y_MAX = 250.0

fn _inside_live_control(x: f64, y: f64, min_x: f64, max_x: f64, min_y: f64, max_y: f64) -> bool:
    x >= min_x and x <= max_x and y >= min_y and y <= max_y

pub fn shared_mdi_live_click_target(x: f64, y: f64) -> i64:
    if _inside_live_control(x, y, TITLEBAR_CONTROL_X_MIN, TITLEBAR_CONTROL_X_MAX, TITLEBAR_CONTROL_Y_MIN, TITLEBAR_CONTROL_Y_MAX):
        return LIVE_CLICK_TARGET_TITLEBAR
    if _inside_live_control(x, y, BODY_CONTROL_X_MIN, BODY_CONTROL_X_MAX, BODY_CONTROL_Y_MIN, BODY_CONTROL_Y_MAX):
        return LIVE_CLICK_TARGET_BODY
    LIVE_CLICK_TARGET_NONE

pub fn shared_mdi_live_completed_click_target(button: i64, pressed: bool, x: f64, y: f64) -> i64:
    if pressed or button != LIVE_PRIMARY_MOUSE_BUTTON:
        return LIVE_CLICK_TARGET_NONE
    shared_mdi_live_click_target(x, y)

pub fn shared_mdi_live_events_complete(keyboard_events: i64, pointer_events: i64, click_events: i64, titlebar_click_events: i64, body_click_events: i64) -> bool:
    keyboard_events > 0 and pointer_events > 0 and click_events > 0 and titlebar_click_events > 0 and body_click_events > 0
