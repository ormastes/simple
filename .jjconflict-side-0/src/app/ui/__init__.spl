# UI Module - Re-exports
# Re-export from sub-modules for convenient access
#
# NOTE: Backend runner functions (run_tauri, run_web, run_tui, run_electron,
# run_headless) are NOT re-exported here. Import them directly from their
# backend packages (e.g., `use app.ui.tauri.app.{run_tauri}`).
# Bare exports of those symbols caused the interpreter to preload ALL
# sibling files searching for definitions, creating a loading storm.

use common.ui.widget.{WidgetKind, LayoutKind, UIMode, UIEvent}
use common.ui.widget.{WidgetNode, UITree, UIState, WidgetRect}
use common.ui.parse.sdn.{parse_ui_file}
use common.ui.parse.sdn_tree.{parse_ui_to_tree}
use common.ui.layout.{compute_layout}
use common.ui.state.{init_state, update_state}

# Core types and functionality
export WidgetKind, LayoutKind, UIMode, UIEvent
export WidgetNode, UITree, UIState, WidgetRect

# Parser
export parse_ui_file, parse_ui_to_tree

# Layout
export compute_layout

# State management
export init_state, update_state
