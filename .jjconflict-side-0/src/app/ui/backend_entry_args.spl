extern fn rt_cli_get_args() -> [text]

class UiBackendEntryArgs:
    file_path: text
    port: i32
    access_db_path: text
    sub_args: [text]

pub fn ui_backend_entry_args() -> UiBackendEntryArgs:
    val args = rt_cli_get_args()
    var file_path = ""
    var port = 3000
    var access_db_path = ""
    var sub_args: [text] = []
    var prev = ""
    var collect_sub = false

    for arg in args:
        if collect_sub:
            sub_args = sub_args.push(arg)
            continue

        if prev == "file":
            file_path = arg
            prev = ""
            continue
        if prev == "port":
            port = arg.to_int()
            prev = ""
            continue
        if prev == "access":
            access_db_path = arg
            prev = ""
            continue

        if arg == "--":
            collect_sub = true
        elif arg == "--file":
            prev = "file"
        elif arg.starts_with("--file="):
            file_path = arg[7:]
        elif arg == "--port":
            prev = "port"
        elif arg.starts_with("--port="):
            port = arg[7:].to_int()
        elif arg == "--ui-access-db":
            prev = "access"
        elif arg.starts_with("--ui-access-db="):
            access_db_path = arg[15:]

    UiBackendEntryArgs(file_path: file_path, port: port, access_db_path: access_db_path, sub_args: sub_args)
