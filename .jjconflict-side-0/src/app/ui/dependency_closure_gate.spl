class UiModuleSource:
    name: text
    source: text

class UiDependencyPolicy:
    root_module: text
    forbidden_prefixes: [text]
    forbidden_terms: [text]

class UiDependencyReport:
    root_module: text
    module_count: i64
    violation_count: i64
    summary: text

fn ui_dependency_module_matches(module_name: text, prefix: text) -> bool:
    if module_name == prefix:
        return true
    val marker = prefix + "."
    return module_name.starts_with(marker)

fn ui_dependency_trim(value: text) -> text:
    var out = value
    while out.starts_with(" "):
        out = out.slice(1, out.len())
    while out.ends_with(" "):
        out = out.slice(0, out.len() - 1)
    out

fn ui_dependency_normalize_import(line: text) -> text:
    var dep = ui_dependency_trim(line)
    if dep.starts_with("export use "):
        dep = dep.slice(7, dep.len())
    if dep.starts_with("use "):
        dep = dep.slice(4, dep.len())
    val brace_parts = dep.split("{")
    if brace_parts.len() > 0:
        dep = brace_parts[0]
    val semi_parts = dep.split(";")
    if semi_parts.len() > 0:
        dep = semi_parts[0]
    dep = ui_dependency_trim(dep)
    if dep.ends_with(".*"):
        dep = dep.slice(0, dep.len() - 2)
    while dep.ends_with("."):
        dep = dep.slice(0, dep.len() - 1)
    dep

fn ui_dependency_extract_imports(source: text) -> [text]:
    var imports: [text] = []
    val lines = source.split("\n")
    var idx = 0
    while idx < lines.len():
        val line = ui_dependency_trim(lines[idx])
        if line.starts_with("use ") or line.starts_with("export use "):
            val dep = ui_dependency_normalize_import(line)
            if dep != "":
                imports.push(dep)
        idx = idx + 1
    imports

fn ui_dependency_find_source(modules: [UiModuleSource], name: text) -> UiModuleSource?:
    var idx = 0
    while idx < modules.len():
        val module = modules[idx]
        if module.name == name:
            return module
        idx = idx + 1
    nil

fn ui_dependency_resolve_module(modules: [UiModuleSource], dep: text) -> text:
    var best = ""
    var idx = 0
    while idx < modules.len():
        val candidate = modules[idx].name
        if dep == candidate or dep.starts_with(candidate + "."):
            if candidate.len() > best.len():
                best = candidate
        idx = idx + 1
    best

fn ui_dependency_seen(values: [text], value: text) -> bool:
    var idx = 0
    while idx < values.len():
        if values[idx] == value:
            return true
        idx = idx + 1
    false

fn ui_dependency_direct_imports(modules: [UiModuleSource], name: text) -> [text]:
    val source = ui_dependency_find_source(modules, name)
    if val module = source:
        return ui_dependency_extract_imports(module.source)
    []

fn ui_dependency_imports_module(imports: [text], module_name: text) -> bool:
    var idx = 0
    while idx < imports.len():
        val dep = imports[idx]
        if dep == module_name or dep.starts_with(module_name + "."):
            return true
        idx = idx + 1
    false

fn ui_dependency_is_forbidden(policy: UiDependencyPolicy, module_name: text) -> bool:
    var idx = 0
    while idx < policy.forbidden_prefixes.len():
        if ui_dependency_module_matches(module_name, policy.forbidden_prefixes[idx]):
            return true
        idx = idx + 1
    var term_idx = 0
    while term_idx < policy.forbidden_terms.len():
        if module_name.contains(policy.forbidden_terms[term_idx]):
            return true
        term_idx = term_idx + 1
    false

fn ui_dependency_report(modules: [UiModuleSource], policy: UiDependencyPolicy) -> UiDependencyReport:
    var visited: [text] = []
    var stack: [text] = [policy.root_module]
    var violations: [text] = []
    while stack.len() > 0:
        val current = stack[stack.len() - 1]
        stack.pop()
        if not ui_dependency_seen(visited, current):
            visited.push(current)
            if ui_dependency_is_forbidden(policy, current):
                violations.push(current)
            val source = ui_dependency_find_source(modules, current)
            if val module = source:
                val imports = ui_dependency_extract_imports(module.source)
                var idx = 0
                while idx < imports.len():
                    val resolved = ui_dependency_resolve_module(modules, imports[idx])
                    if resolved != "" and not ui_dependency_seen(visited, resolved):
                        stack.push(resolved)
                    elif resolved == "" and ui_dependency_is_forbidden(policy, imports[idx]):
                        if not ui_dependency_seen(violations, imports[idx]):
                            violations.push(imports[idx])
                    idx = idx + 1
    var summary = "root=" + policy.root_module + " modules=" + visited.len().to_text() + " violations=" + violations.len().to_text()
    if violations.len() > 0:
        summary = summary + " forbidden=" + violations.join(",")
    UiDependencyReport(
        root_module: policy.root_module,
        module_count: visited.len(),
        violation_count: violations.len(),
        summary: summary
    )

export UiModuleSource, UiDependencyPolicy, UiDependencyReport
export ui_dependency_module_matches, ui_dependency_extract_imports, ui_dependency_direct_imports, ui_dependency_imports_module, ui_dependency_report
