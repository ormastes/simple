# Simple CLI - os command
#
# Dedicated lightweight entrypoint for `simple os ...` so the wrapper does not
# depend on the larger self-hosted CLI surface.

use std.cli.cli_util (get_cli_args)
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use os.cli.{handle_os}
use std.log.{error}

fn main() -> i64:
    val raw_args = get_cli_args()
    val command_args =
        if raw_args.len() > 0 and raw_args[0] == "os":
            raw_args[1:]
        else:
            raw_args

    val log_opts = parse_log_options(command_args)
    if not log_opts.valid:
        error("os", log_opts.error)
        return 1

    val os_args = clean_shared_log_args(command_args)
    if os_args.len() == 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"os\",\"status\":\"usage\"}"
            return 0
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print progress
        print_os_wrapper_help()
        return 0

    if os_args.len() > 0 and (os_args[0] == "--help" or os_args[0] == "-h" or os_args[0] == "help"):
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print progress
        print_os_wrapper_help()
        return 0

    if log_opts.log_mode == "json" and os_args[0] == "targets":
        print "{\"command\":\"os\",\"status\":\"ok\",\"action\":\"targets\"}"
        return 0

    handle_os(os_args)

fn print_os_wrapper_help():
    handle_os(["help"])
    print ""
    print "Shared log options:"
    for line in log_options_help():
        print "  {line}"

fn is_shared_log_arg(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn clean_shared_log_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if is_shared_log_arg(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned
