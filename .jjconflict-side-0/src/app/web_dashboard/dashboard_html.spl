# Dashboard HTML Generator
#
# Generates the unified web dashboard HTML with:
# - Project status (server-side rendered via shared dashboard.views)
# - Tmux terminal panels with read/write via WebSocket
# - Web terminal with keyboard input
# - GUI viewer for TUI apps
#
# Status rendering is delegated to dashboard.views/status.spl (shared with CLI).
# Only tmux/terminal/GUI views are web-specific.

fn generate_full_dashboard_html(port: i32, status_html: text, vcs_html: text, tmux_card_html: text) -> text:
    var h: [text] = []
    h.push("<!DOCTYPE html>")
    h.push("<html lang=\"en\">")
    h.push("<head>")
    h.push("<meta charset=\"utf-8\">")
    h.push("<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">")
    h.push("<title>Simple Compiler Dashboard</title>")
    h.push("<style>")
    h.push(_css())
    h.push("</style>")
    h.push("</head>")
    h.push("<body>")
    h.push(_header_html(vcs_html))
    h.push("<div class=\"layout\">")
    h.push(_sidebar_html())
    h.push("<main class=\"main\">")
    h.push("<div id=\"view-status\" class=\"view active\">")
    # Server-side rendered status from shared dashboard.views
    h.push(status_html)
    h.push(tmux_card_html)
    h.push("</div>")
    h.push("<div id=\"view-terminal\" class=\"view\">")
    h.push(_terminal_view_html())
    h.push("</div>")
    h.push("<div id=\"view-gui\" class=\"view\">")
    h.push(_gui_view_html())
    h.push("</div>")
    h.push("</main>")
    h.push("</div>")
    h.push("<script>")
    h.push(_javascript(port))
    h.push("</script>")
    h.push("</body>")
    h.push("</html>")
    h.join("\n")

# =========================================================================
# CSS
# =========================================================================

fn _css() -> text:
    var c: [text] = []
    c.push("* { margin: 0; padding: 0; box-sizing: border-box; }")
    c.push(":root { --bg: #0d1117; --surface: #161b22; --border: #30363d; --text: #e6edf3; --text-dim: #8b949e; --accent: #58a6ff; --green: #3fb950; --yellow: #d29922; --red: #f85149; --purple: #bc8cff; }")
    c.push("body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; background: var(--bg); color: var(--text); height: 100vh; overflow: hidden; }")
    c.push("a { color: var(--accent); text-decoration: none; }")

    # Header
    c.push(".header { display: flex; align-items: center; justify-content: space-between; padding: 8px 16px; background: var(--surface); border-bottom: 1px solid var(--border); height: 48px; }")
    c.push(".header h1 { font-size: 16px; font-weight: 600; }")
    c.push(".header .status-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 8px; }")
    c.push(".header .status-dot.ok { background: var(--green); }")
    c.push(".header .status-dot.warn { background: var(--yellow); }")
    c.push(".header .status-dot.err { background: var(--red); }")
    c.push(".header-right { display: flex; align-items: center; gap: 12px; font-size: 13px; color: var(--text-dim); }")

    # Layout
    c.push(".layout { display: flex; height: calc(100vh - 48px); }")
    c.push(".sidebar { width: 200px; background: var(--surface); border-right: 1px solid var(--border); padding: 8px 0; flex-shrink: 0; }")
    c.push(".sidebar-item { display: flex; align-items: center; padding: 8px 16px; cursor: pointer; color: var(--text-dim); font-size: 14px; border-left: 2px solid transparent; }")
    c.push(".sidebar-item:hover { background: rgba(88,166,255,0.1); color: var(--text); }")
    c.push(".sidebar-item.active { color: var(--text); border-left-color: var(--accent); background: rgba(88,166,255,0.05); }")
    c.push(".sidebar-item .icon { margin-right: 8px; font-size: 16px; }")
    c.push(".sidebar-section { padding: 12px 16px 4px; font-size: 11px; text-transform: uppercase; color: var(--text-dim); letter-spacing: 0.5px; }")

    # Main
    c.push(".main { flex: 1; overflow-y: auto; padding: 16px; }")
    c.push(".view { display: none; }")
    c.push(".view.active { display: block; }")

    # Cards
    c.push(".card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; margin-bottom: 16px; }")
    c.push(".card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 16px; }")
    c.push(".card h3 { font-size: 13px; color: var(--text-dim); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.3px; }")
    c.push(".card .value { font-size: 28px; font-weight: 700; }")
    c.push(".card .sub { font-size: 12px; color: var(--text-dim); margin-top: 4px; }")
    c.push(".card .value.green { color: var(--green); }")
    c.push(".card .value.yellow { color: var(--yellow); }")
    c.push(".card .value.red { color: var(--red); }")
    c.push(".card .value.accent { color: var(--accent); }")
    c.push(".card .value.purple { color: var(--purple); }")

    # Progress bar
    c.push(".progress-bar { height: 6px; background: var(--border); border-radius: 3px; margin-top: 8px; overflow: hidden; }")
    c.push(".progress-bar .fill { height: 100%; border-radius: 3px; transition: width 0.5s ease; }")

    # Alerts panel
    c.push(".alerts-panel { margin-top: 16px; }")
    c.push(".alert { padding: 10px 14px; border-radius: 6px; margin-bottom: 8px; font-size: 13px; display: flex; align-items: center; }")
    c.push(".alert-critical { background: rgba(248,81,73,0.1); border: 1px solid rgba(248,81,73,0.3); }")
    c.push(".alert-warning { background: rgba(210,153,34,0.1); border: 1px solid rgba(210,153,34,0.3); }")
    c.push(".alert-info { background: rgba(88,166,255,0.1); border: 1px solid rgba(88,166,255,0.3); }")
    c.push(".alert .alert-icon { margin-right: 8px; }")

    # Tables
    c.push(".data-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 12px; }")
    c.push(".data-table th { text-align: left; padding: 8px 12px; background: rgba(88,166,255,0.05); border-bottom: 1px solid var(--border); color: var(--text-dim); font-weight: 500; }")
    c.push(".data-table td { padding: 8px 12px; border-bottom: 1px solid var(--border); }")
    c.push(".data-table tr:hover td { background: rgba(88,166,255,0.03); }")
    c.push(".badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 500; }")
    c.push(".badge-green { background: rgba(63,185,80,0.2); color: var(--green); }")
    c.push(".badge-yellow { background: rgba(210,153,34,0.2); color: var(--yellow); }")
    c.push(".badge-red { background: rgba(248,81,73,0.2); color: var(--red); }")
    c.push(".badge-blue { background: rgba(88,166,255,0.2); color: var(--accent); }")

    # Terminal
    c.push(".terminal-container { display: flex; flex-direction: column; height: calc(100vh - 100px); }")
    c.push(".terminal-toolbar { display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: var(--surface); border: 1px solid var(--border); border-radius: 8px 8px 0 0; }")
    c.push(".terminal-toolbar select, .terminal-toolbar button { background: var(--bg); color: var(--text); border: 1px solid var(--border); padding: 4px 10px; border-radius: 4px; font-size: 13px; cursor: pointer; }")
    c.push(".terminal-toolbar button:hover { background: rgba(88,166,255,0.1); border-color: var(--accent); }")
    c.push(".terminal-toolbar label { font-size: 12px; color: var(--text-dim); }")
    c.push(".terminal-output { flex: 1; background: #000; color: #0f0; font-family: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace; font-size: 14px; line-height: 1.4; padding: 12px; overflow-y: auto; white-space: pre-wrap; word-wrap: break-word; border: 1px solid var(--border); border-top: none; }")
    c.push(".terminal-input-bar { display: flex; align-items: center; background: #111; border: 1px solid var(--border); border-top: none; border-radius: 0 0 8px 8px; padding: 6px 12px; }")
    c.push(".terminal-input-bar .prompt { color: var(--green); margin-right: 8px; font-family: monospace; font-size: 14px; }")
    c.push(".terminal-input-bar input { flex: 1; background: transparent; color: var(--text); border: none; outline: none; font-family: monospace; font-size: 14px; }")
    c.push(".terminal-status { display: flex; align-items: center; gap: 12px; margin-left: auto; font-size: 11px; color: var(--text-dim); }")

    # GUI Viewer
    c.push(".gui-viewer { height: calc(100vh - 100px); background: var(--surface); border: 1px solid var(--border); border-radius: 8px; display: flex; flex-direction: column; }")
    c.push(".gui-toolbar { display: flex; align-items: center; gap: 8px; padding: 8px 12px; border-bottom: 1px solid var(--border); }")
    c.push(".gui-toolbar input { flex: 1; background: var(--bg); color: var(--text); border: 1px solid var(--border); padding: 6px 10px; border-radius: 4px; font-size: 13px; }")
    c.push(".gui-frame { flex: 1; display: flex; align-items: center; justify-content: center; color: var(--text-dim); font-size: 14px; }")
    c.push(".gui-frame iframe { width: 100%; height: 100%; border: none; }")

    # Misc
    c.push(".section-title { font-size: 15px; font-weight: 600; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }")
    c.push(".section-title .count { background: var(--border); padding: 2px 8px; border-radius: 10px; font-size: 12px; font-weight: 400; color: var(--text-dim); }")
    c.push(".empty-state { text-align: center; padding: 40px; color: var(--text-dim); }")
    c.push(".refresh-btn { cursor: pointer; color: var(--text-dim); font-size: 13px; }")
    c.push(".refresh-btn:hover { color: var(--accent); }")
    c.join("\n")

# =========================================================================
# HTML Sections
# =========================================================================

fn _header_html(vcs_html: text) -> text:
    var h: [text] = []
    h.push("<header class=\"header\">")
    h.push("  <div style=\"display:flex;align-items:center\">")
    h.push("    <span class=\"status-dot ok\"></span>")
    h.push("    <h1>Simple Compiler Dashboard</h1>")
    h.push("  </div>")
    h.push("  <div class=\"header-right\">")
    h.push("    <span>{vcs_html}</span>")
    h.push("    <a href=\"/\" class=\"refresh-btn\">Refresh</a>")
    h.push("  </div>")
    h.push("</header>")
    h.join("\n")

fn _sidebar_html() -> text:
    var h: [text] = []
    h.push("<nav class=\"sidebar\">")
    h.push("  <div class=\"sidebar-section\">Overview</div>")
    h.push("  <div class=\"sidebar-item active\" onclick=\"switchView('status', this)\"><span class=\"icon\">&#9673;</span> Status</div>")
    h.push("  <div class=\"sidebar-section\">Tools</div>")
    h.push("  <div class=\"sidebar-item\" onclick=\"switchView('terminal', this)\"><span class=\"icon\">&#9638;</span> Terminal</div>")
    h.push("  <div class=\"sidebar-item\" onclick=\"switchView('gui', this)\"><span class=\"icon\">&#9635;</span> GUI Viewer</div>")
    h.push("  <div class=\"sidebar-section\">LLM</div>")
    h.push("  <div class=\"sidebar-item\" onclick=\"window.location='/agents'\"><span class=\"icon\">&#9881;</span> Agents</div>")
    h.push("</nav>")
    h.join("\n")

fn _terminal_view_html() -> text:
    var h: [text] = []
    h.push("<div class=\"terminal-container\">")
    h.push("  <div class=\"terminal-toolbar\">")
    h.push("    <label>Session:</label>")
    h.push("    <select id=\"tmux-session\" onchange=\"tmuxSessionChanged()\"><option>--</option></select>")
    h.push("    <label>Window:</label>")
    h.push("    <select id=\"tmux-window\" onchange=\"tmuxWindowChanged()\"><option>0</option></select>")
    h.push("    <label>Pane:</label>")
    h.push("    <select id=\"tmux-pane\" onchange=\"tmuxPaneChanged()\"><option>0</option></select>")
    h.push("    <button onclick=\"tmuxRefresh()\">Refresh</button>")
    h.push("    <button onclick=\"tmuxConnect()\">Connect WS</button>")
    h.push("    <div class=\"terminal-status\">")
    h.push("      <span id=\"term-status\">Disconnected</span>")
    h.push("      <span id=\"term-size\">--</span>")
    h.push("    </div>")
    h.push("  </div>")
    h.push("  <div class=\"terminal-output\" id=\"terminal-output\" tabindex=\"0\"></div>")
    h.push("  <div class=\"terminal-input-bar\">")
    h.push("    <span class=\"prompt\">$</span>")
    h.push("    <input type=\"text\" id=\"terminal-input\" placeholder=\"Type command and press Enter...\" autocomplete=\"off\" spellcheck=\"false\">")
    h.push("  </div>")
    h.push("</div>")
    h.join("\n")

fn _gui_view_html() -> text:
    var h: [text] = []
    h.push("<div class=\"gui-viewer\">")
    h.push("  <div class=\"gui-toolbar\">")
    h.push("    <label style=\"font-size:13px;color:var(--text-dim)\">URL:</label>")
    h.push("    <input type=\"text\" id=\"gui-url\" placeholder=\"http://localhost:PORT\" value=\"\">")
    h.push("    <button onclick=\"loadGuiUrl()\" style=\"background:var(--bg);color:var(--text);border:1px solid var(--border);padding:6px 14px;border-radius:4px;cursor:pointer\">Load</button>")
    h.push("    <button onclick=\"refreshGuiFrame()\" style=\"background:var(--bg);color:var(--text);border:1px solid var(--border);padding:6px 14px;border-radius:4px;cursor:pointer\">Reload</button>")
    h.push("  </div>")
    h.push("  <div class=\"gui-frame\" id=\"gui-frame\">")
    h.push("    <div class=\"empty-state\">Enter a URL above to load a web GUI</div>")
    h.push("  </div>")
    h.push("</div>")
    h.join("\n")

# =========================================================================
# JavaScript
# =========================================================================

fn _javascript(port: i32) -> text:
    var j: [text] = []

    # View switching
    j.push("function switchView(name, node) {")
    j.push("  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));")
    j.push("  document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active'));")
    j.push("  document.getElementById('view-' + name).classList.add('active');")
    j.push("  if (node) node.classList.add('active');")
    j.push("  if (name === 'terminal') loadTmuxSessions();")
    j.push("}")

    # Tmux terminal (web-specific — no TUI equivalent)
    j.push("let termWs = null;")
    j.push("async function loadTmuxSessions() {")
    j.push("  try {")
    j.push("    const sessions = await fetch('/api/tmux/sessions').then(r => r.json());")
    j.push("    const sel = document.getElementById('tmux-session');")
    j.push("    sel.innerHTML = sessions.map(s => '<option value=\"' + s.name + '\">' + s.name + ' (' + s.windows + ' windows)' + (s.attached ? ' *' : '') + '</option>').join('');")
    j.push("    if (sessions.length > 0) tmuxSessionChanged();")
    j.push("  } catch(e) { console.error('tmux sessions error', e); }")
    j.push("}")

    j.push("async function tmuxSessionChanged() {")
    j.push("  const session = document.getElementById('tmux-session').value;")
    j.push("  try {")
    j.push("    const res = await fetch('/api/tmux/windows?session=' + encodeURIComponent(session));")
    j.push("    const windows = await res.json();")
    j.push("    const sel = document.getElementById('tmux-window');")
    j.push("    sel.innerHTML = windows.map(w => '<option value=\"' + w.index + '\">' + w.index + ': ' + w.name + (w.active ? ' *' : '') + '</option>').join('');")
    j.push("    tmuxWindowChanged();")
    j.push("  } catch(e) {}")
    j.push("}")

    j.push("async function tmuxWindowChanged() {")
    j.push("  const session = document.getElementById('tmux-session').value;")
    j.push("  const win = document.getElementById('tmux-window').value;")
    j.push("  try {")
    j.push("    const res = await fetch('/api/tmux/panes?session=' + encodeURIComponent(session) + '&window=' + win);")
    j.push("    const panes = await res.json();")
    j.push("    const sel = document.getElementById('tmux-pane');")
    j.push("    sel.innerHTML = panes.map(p => '<option value=\"' + p.index + '\">' + p.index + ': ' + p.command + ' (' + p.width + 'x' + p.height + ')' + (p.active ? ' *' : '') + '</option>').join('');")
    j.push("    document.getElementById('term-size').textContent = panes.length > 0 ? panes[0].width + 'x' + panes[0].height : '--';")
    j.push("  } catch(e) {}")
    j.push("}")

    j.push("function tmuxPaneChanged() {")
    j.push("  tmuxRefresh();")
    j.push("}")

    j.push("async function tmuxRefresh() {")
    j.push("  const session = document.getElementById('tmux-session').value;")
    j.push("  const win = document.getElementById('tmux-window').value;")
    j.push("  const pane = document.getElementById('tmux-pane').value;")
    j.push("  try {")
    j.push("    const res = await fetch('/api/tmux/capture?session=' + encodeURIComponent(session) + '&window=' + win + '&pane=' + pane);")
    j.push("    const data = await res.json();")
    j.push("    document.getElementById('terminal-output').textContent = data.content;")
    j.push("    document.getElementById('terminal-output').scrollTop = document.getElementById('terminal-output').scrollHeight;")
    j.push("  } catch(e) { console.error('capture error', e); }")
    j.push("}")

    # WebSocket terminal connection
    j.push("function tmuxConnect() {")
    j.push("  if (termWs) { termWs.close(); termWs = null; }")
    j.push("  const session = document.getElementById('tmux-session').value;")
    j.push("  const win = document.getElementById('tmux-window').value;")
    j.push("  const pane = document.getElementById('tmux-pane').value;")
    j.push("  const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';")
    j.push("  const url = proto + '//' + location.host + '/ws/terminal?session=' + encodeURIComponent(session) + '&window=' + win + '&pane=' + pane;")
    j.push("  termWs = new WebSocket(url);")
    j.push("  document.getElementById('term-status').textContent = 'Connecting...';")
    j.push("  termWs.onopen = () => { document.getElementById('term-status').textContent = 'Connected'; };")
    j.push("  termWs.onclose = () => { document.getElementById('term-status').textContent = 'Disconnected'; termWs = null; };")
    j.push("  termWs.onerror = () => { document.getElementById('term-status').textContent = 'Error'; };")
    j.push("  termWs.onmessage = (ev) => {")
    j.push("    try {")
    j.push("      const msg = JSON.parse(ev.data);")
    j.push("      if (msg.type === 'output') {")
    j.push("        document.getElementById('terminal-output').textContent = msg.content;")
    j.push("        document.getElementById('terminal-output').scrollTop = document.getElementById('terminal-output').scrollHeight;")
    j.push("      } else if (msg.type === 'error') {")
    j.push("        document.getElementById('terminal-output').textContent = 'Error: ' + msg.message;")
    j.push("      }")
    j.push("    } catch(e) {}")
    j.push("  };")
    j.push("}")

    # Terminal input handling
    j.push("document.addEventListener('DOMContentLoaded', () => {")
    j.push("  const input = document.getElementById('terminal-input');")
    j.push("  input.addEventListener('keydown', (e) => {")
    j.push("    if (e.key === 'Enter') {")
    j.push("      const cmd = input.value;")
    j.push("      input.value = '';")
    j.push("      if (termWs && termWs.readyState === 1) {")
    j.push("        termWs.send(JSON.stringify({type: 'text', text: cmd}));")
    j.push("        setTimeout(() => termWs.send(JSON.stringify({type: 'enter'})), 50);")
    j.push("        setTimeout(() => termWs.send(JSON.stringify({type: 'refresh'})), 300);")
    j.push("      } else {")
    j.push("        sendCommandHttp(cmd);")
    j.push("      }")
    j.push("    }")
    j.push("  });")

    # Direct key capture on terminal output
    j.push("  document.getElementById('terminal-output').addEventListener('keydown', (e) => {")
    j.push("    if (termWs && termWs.readyState === 1) {")
    j.push("      e.preventDefault();")
    j.push("      let key = e.key;")
    j.push("      if (key === 'Enter') key = 'Enter';")
    j.push("      else if (key === 'Backspace') key = 'BSpace';")
    j.push("      else if (key === 'Escape') key = 'Escape';")
    j.push("      else if (key === 'Tab') key = 'Tab';")
    j.push("      else if (key === 'ArrowUp') key = 'Up';")
    j.push("      else if (key === 'ArrowDown') key = 'Down';")
    j.push("      else if (key === 'ArrowLeft') key = 'Left';")
    j.push("      else if (key === 'ArrowRight') key = 'Right';")
    j.push("      else if (e.ctrlKey) key = 'C-' + key;")
    j.push("      else if (key.length > 1) return;")
    j.push("      termWs.send(JSON.stringify({type: 'key', key: key}));")
    j.push("      setTimeout(() => termWs.send(JSON.stringify({type: 'refresh'})), 100);")
    j.push("    }")
    j.push("  });")
    j.push("});")

    # HTTP fallback for command sending
    j.push("async function sendCommandHttp(cmd) {")
    j.push("  const session = document.getElementById('tmux-session').value;")
    j.push("  const win = document.getElementById('tmux-window').value;")
    j.push("  const pane = document.getElementById('tmux-pane').value;")
    j.push("  try {")
    j.push("    await fetch('/api/tmux/send-command', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({session: session, window: win, pane: pane, command: cmd}) });")
    j.push("    setTimeout(() => tmuxRefresh(), 500);")
    j.push("  } catch(e) { console.error('send error', e); }")
    j.push("}")

    # GUI viewer
    j.push("function loadGuiUrl() {")
    j.push("  const url = document.getElementById('gui-url').value;")
    j.push("  if (!url) return;")
    j.push("  document.getElementById('gui-frame').innerHTML = '<iframe src=\"' + url + '\" sandbox=\"allow-scripts allow-same-origin allow-forms\"></iframe>';")
    j.push("}")
    j.push("function refreshGuiFrame() {")
    j.push("  const iframe = document.querySelector('#gui-frame iframe');")
    j.push("  if (iframe) iframe.src = iframe.src;")
    j.push("}")

    # Auto-refresh reloads page to get fresh server-rendered status
    j.push("setTimeout(() => location.reload(), 30000);")

    j.join("\n")
