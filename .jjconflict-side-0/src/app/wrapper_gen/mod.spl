#![allow(unnamed_duplicate_typed_args)]
# Wrapper Generator - Main Entry Point
#
# Generates SFFI wrappers for external libraries.
# Supports both C++ libraries (via cxx bridge) and Rust crates (direct FFI).
#
# Input: Wrapper spec file (.wrapper_spec)
#
# Usage:
#   simple wrapper-gen <spec_file> [OPTIONS]
#
# Options:
#   --output=<dir>      Output directory (default: auto-detect)
#   --dry-run           Print generated code without writing
#   --verbose           Enable verbose logging
#   --verify            Verify Rust code compiles
#   --help              Show this help message
#
# Example:
#   simple wrapper-gen torch.wrapper_spec --dry-run

use std.cli.cli_util.{get_cli_args}

# Import wrapper generator modules
use app.wrapper_gen.spec_parser.{parse_wrapper_spec, WrapperSpec}

extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
extern fn rt_file_exists(path: text) -> bool
extern fn rt_dir_create_all(path: text) -> bool
extern fn rt_env_get(key: text) -> text

fn file_read(path: text) -> text:
    rt_file_read_text(path)

fn file_write(path: text, content: text) -> bool:
    rt_file_write_text(path, content)

fn file_exists(path: text) -> bool:
    rt_file_exists(path)

fn dir_create_all(path: text) -> bool:
    rt_dir_create_all(path)

fn env_get(key: text) -> text:
    rt_env_get(key)

# ============================================================================
# CLI Options
# ============================================================================

class WrapperGenOptions:
    spec_file: text
    output_dir: text
    dry_run: bool
    verbose: bool
    verify: bool
    show_help: bool

fn actual_args() -> [text]:
    val all_args = get_cli_args()
    var args: [text] = []
    var seen_command = false
    var i = 0
    while i < all_args.len():
        val arg = all_args[i]
        if arg == "wrapper-gen":
            seen_command = true
        elif seen_command:
            args.push(arg)
        i = i + 1
    args

fn parse_args(args: [text]) -> WrapperGenOptions:
    var spec_file = ""
    var output_dir = ""
    var dry_run = false
    var verbose = false
    var verify = false
    var show_help = false

    for arg in args:
        if arg == "-h" or arg == "--help":
            show_help = true
        elif arg.starts_with("--output="):
            output_dir = arg.substring(9)
        elif arg == "--dry-run":
            dry_run = true
        elif arg == "--verbose":
            verbose = true
        elif arg == "--verify":
            verify = true
        elif not arg.starts_with("--") and not arg.starts_with("-"):
            spec_file = arg

    WrapperGenOptions(
        spec_file: spec_file,
        output_dir: output_dir,
        dry_run: dry_run,
        verbose: verbose,
        verify: verify,
        show_help: show_help
    )

fn shared_library_filename(spec: WrapperSpec) -> text:
    val os_name = env_get("OS") ?? ""
    if os_name.lower().contains("windows"):
        return "simple_" + spec.name + "_ffi.dll"
    if os_name.lower().contains("darwin") or os_name.lower().contains("mac"):
        return "libsimple_" + spec.name + "_ffi.dylib"
    "libsimple_" + spec.name + "_ffi.so"

fn scaffold_output_dir(spec: WrapperSpec, output_dir: text) -> text:
    if output_dir != "":
        return output_dir
    ".build/plugins/" + spec.name

fn collect_exported_functions(spec: WrapperSpec) -> [text]:
    var exported: [text] = []
    for func in spec.functions:
        exported.push("rt_" + spec.name + "_" + func.name)
    for method in spec.methods:
        exported.push("rt_" + spec.name + "_" + method.name)
    exported

fn functions_to_sdn(functions: [text]) -> text:
    if functions.len() == 0:
        return "[]"
    "[" + functions.join(", ") + "]"

fn emit_plugin_manifest(spec: WrapperSpec, output_dir: text) -> text:
    val library_path = output_dir + "/" + shared_library_filename(spec)
    val functions = collect_exported_functions(spec)
    var lines: [text] = []
    lines.push("plugins:")
    lines.push("    -")
    lines.push("        name: " + spec.name)
    lines.push("        library: " + library_path)
    lines.push("        version: \"" + spec.version + "\"")
    lines.push("        functions: " + functions_to_sdn(functions))
    lines.join("\n") + "\n"

fn emit_generation_summary(spec: WrapperSpec, output_dir: text) -> text:
    val functions = collect_exported_functions(spec)
    var lines: [text] = []
    lines.push("wrapper: " + spec.name)
    lines.push("lang: " + spec.lang)
    lines.push("library: " + shared_library_filename(spec))
    lines.push("output_dir: " + output_dir)
    lines.push("functions: " + functions.join(", "))
    lines.join("\n") + "\n"

# ============================================================================
# Main Entry Point
# ============================================================================

fn main():
    val args = actual_args()
    val opts = parse_args(args)

    if opts.show_help:
        print_help()
        return

    if opts.spec_file == "":
        print "Error: No spec file provided"
        print "Usage: simple wrapper-gen <spec_file> [OPTIONS]"
        return

    if not file_exists(opts.spec_file):
        print "Error: Spec file not found: {opts.spec_file}"
        return

    # Parse spec file
    val content = file_read(opts.spec_file)
    val spec = parse_wrapper_spec(content)

    if opts.verbose:
        print "Parsed spec for library: {spec.name} (lang: {spec.lang})"
        print "Handle types: {spec.handle_types.len()}"
        print "Functions: {spec.functions.len()}"
        print "Methods: {spec.methods.len()}"

    val resolved_output_dir = scaffold_output_dir(spec, opts.output_dir)
    val manifest = emit_plugin_manifest(spec, resolved_output_dir)
    val summary = emit_generation_summary(spec, resolved_output_dir)

    if opts.dry_run:
        print "--- manifest.sdn ---"
        print manifest
        print "--- wrapper_info.txt ---"
        print summary
        return

    if not dir_create_all(resolved_output_dir):
        print "Error: failed to create output directory: {resolved_output_dir}"
        return

    val manifest_path = resolved_output_dir + "/manifest.sdn"
    val summary_path = resolved_output_dir + "/wrapper_info.txt"
    if not file_write(manifest_path, manifest):
        print "Error: failed to write manifest: {manifest_path}"
        return
    if not file_write(summary_path, summary):
        print "Error: failed to write wrapper summary: {summary_path}"
        return

    print "Generated manifest: {manifest_path}"
    print "Generated summary: {summary_path}"
    print "Wrapper generation complete for '{spec.name}'"

# ============================================================================
# Help
# ============================================================================

fn print_help():
    print "Simple SFFI Wrapper Generator"
    print ""
    print "Generates SFFI wrappers for external libraries"
    print ""
    print "Usage: simple wrapper-gen <spec_file> [OPTIONS]"
    print ""
    print "Options:"
    print "  --dry-run          Print code without writing files"
    print "  --verbose          Enable verbose output"
    print "  --verify           Verify Rust code compiles"
    print "  -h, --help         Show this help"
    print ""
    print "Spec file lang field:"
    print "  lang: cpp   Use cxx bridge for C++ libraries (default)"
    print "  lang: rust  Use direct Rust FFI for Rust crates"
    print ""
    print "Examples:"
    print "  simple wrapper-gen torch.wrapper_spec --dry-run"
    print "  simple wrapper-gen torch.wrapper_spec --verbose"
