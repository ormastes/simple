use common.proton_runtime_subsystems.{proton_fixture_non_wine_runtime_evidence}
use nogc_async_mut.proton_session.{proton_session_launch_handoff_with_exec_env, proton_session_plan, proton_session_request_new}
use common.wine_simpleos_exec_env_gate.{wine_simpleos_exec_env_fixture_evidence}
use app.io.cli_ops (cli_get_args)
use std.cli.log_modes.{parse_log_options, log_options_help}
use std.log.{error}

extern fn stdout_write(data: text)

fn print_help():
    print "Usage: simple proton-session-plan [options]"
    print ""
    print "Run the Proton session planning fixture."
    print ""
    print "Options:"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help   Show this help"

fn main() -> i64:
    val args = cli_get_args()
    val log_opts = parse_log_options(args)
    if not log_opts.valid:
        error("proton-session-plan", log_opts.error)
        return 1
    for arg in args:
        if arg == "-h" or arg == "--help":
            print_help()
            return 0
    val request = proton_session_request_new("480", "steamapps/compatdata/480/pfx", "hl2.exe", ["-novid"])
    val plan = proton_session_plan(request, proton_fixture_non_wine_runtime_evidence())
    val handoff = proton_session_launch_handoff_with_exec_env(plan, true, wine_simpleos_exec_env_fixture_evidence())
    if handoff.ok:
        stdout_write("app_id={handoff.app_id}\n")
        stdout_write("prefix={handoff.compat_prefix}\n")
        stdout_write("command={handoff.launch_command}\n")
        stdout_write("status={handoff.status}\n")
        stdout_write("exec_env=mdsoc-ready\n")
        stdout_write("container={handoff.container_profile}\n")
        stdout_write("features={handoff.runtime_features}\n")
        return 0
    print "proton-session-plan failed: {handoff.error}"
    1
