# Package Manager - Manifest (package.sdn) Parser
#
# Parses the package manifest from SDN format.
# Fields: name, version, description, author, license, dependencies.

use std.sdn.{parse, parse_file, SdnValue, SdnError}
use app.pkg.version.{SemVer, VersionConstraint}

# A single dependency entry
struct Dependency:
    name: text
    version_constraint: text        # Raw constraint string (e.g., "^1.0.0", "*")
    git_url: text                   # Git URL (empty if not a git dep)
    git_branch: text                # Git branch (default "main")
    git_tag: text                   # Git tag (empty if not specified)
    git_rev: text                   # Git commit rev (empty if not specified)
    path: text                      # Local path dependency (empty if not path dep)

impl Dependency:
    fn is_git() -> bool:
        self.git_url != ""

    fn is_path() -> bool:
        self.path != ""

    fn is_registry() -> bool:
        not self.is_git() and not self.is_path()

    fn cache_key() -> text:
        """Key for local cache directory naming."""
        if self.is_git():
            # Use sanitized git URL + branch/tag/rev
            var key = self.git_url
            key = key.replace("https://", "")
            key = key.replace("http://", "")
            key = key.replace("git@", "")
            key = key.replace(":", "-")
            key = key.replace("/", "-")
            key = key.replace(".git", "")
            if self.git_tag != "":
                key = "{key}-{self.git_tag}"
            elif self.git_rev != "":
                key = "{key}-{self.git_rev}"
            elif self.git_branch != "" and self.git_branch != "main":
                key = "{key}-{self.git_branch}"
            key
        elif self.is_path():
            "path-{self.name}"
        else:
            "{self.name}-{self.version_constraint}"

    fn to_text() -> text:
        if self.is_git():
            var s = "{self.name} (git: {self.git_url}"
            if self.git_tag != "":
                s = "{s}, tag: {self.git_tag}"
            elif self.git_rev != "":
                s = "{s}, rev: {self.git_rev}"
            elif self.git_branch != "main":
                s = "{s}, branch: {self.git_branch}"
            "{s})"
        elif self.is_path():
            "{self.name} (path: {self.path})"
        else:
            "{self.name} ({self.version_constraint})"


# Package manifest (parsed from package.sdn)
struct PackageManifest:
    name: text
    version: text
    description: text
    author: text
    license: text
    main_entry: text
    dependencies: [Dependency]
    dev_dependencies: [Dependency]

impl PackageManifest:
    static fn empty() -> PackageManifest:
        PackageManifest(
            name: "",
            version: "0.1.0",
            description: "",
            author: "",
            license: "",
            main_entry: "src/main.spl",
            dependencies: [],
            dev_dependencies: []
        )

    fn find_dep(dep_name: text) -> Dependency?:
        """Find a dependency by name in regular deps."""
        for dep in self.dependencies:
            if dep.name == dep_name:
                return Some(dep)
        nil

    fn find_dev_dep(dep_name: text) -> Dependency?:
        """Find a dependency by name in dev deps."""
        for dep in self.dev_dependencies:
            if dep.name == dep_name:
                return Some(dep)
        nil

    fn has_dep(dep_name: text) -> bool:
        self.find_dep(dep_name).? or self.find_dev_dep(dep_name).?


# Parse dependency dict entry from SDN value
fn parse_dep_entry(name: text, value: SdnValue) -> Dependency:
    var version_constraint = "*"
    var git_url = ""
    var git_branch = "main"
    var git_tag = ""
    var git_rev = ""
    var path = ""

    match value:
        case SdnValue.String(s):
            # Simple version constraint: "http: ^1.0"
            version_constraint = s
        case SdnValue.Dict(d):
            # Complex dependency: {git: "...", branch: "main"}
            val ver = d.get("version")
            if ver.?:
                match ver.unwrap():
                    case SdnValue.String(s): version_constraint = s
                    case _: pass

            val git = d.get("git")
            if git.?:
                match git.unwrap():
                    case SdnValue.String(s): git_url = s
                    case _: pass

            val branch = d.get("branch")
            if branch.?:
                match branch.unwrap():
                    case SdnValue.String(s): git_branch = s
                    case _: pass

            val tag = d.get("tag")
            if tag.?:
                match tag.unwrap():
                    case SdnValue.String(s): git_tag = s
                    case _: pass

            val rev = d.get("rev")
            if rev.?:
                match rev.unwrap():
                    case SdnValue.String(s): git_rev = s
                    case _: pass

            val p = d.get("path")
            if p.?:
                match p.unwrap():
                    case SdnValue.String(s): path = s
                    case _: pass
        case _:
            pass

    Dependency(
        name: name,
        version_constraint: version_constraint,
        git_url: git_url,
        git_branch: git_branch,
        git_tag: git_tag,
        git_rev: git_rev,
        path: path
    )


# Parse a dependencies section (dict of name -> constraint/config)
fn parse_deps_dict(value: SdnValue?) -> [Dependency]:
    var deps: [Dependency] = []
    if not value.?:
        return deps
    match value.unwrap():
        case SdnValue.Dict(d):
            for (name, v) in d:
                deps.push(parse_dep_entry(name, v))
        case _:
            pass
    deps


# Parse package.sdn from source text
fn parse_manifest(source: text) -> Result<PackageManifest, text>:
    val result = parse(source)
    match result:
        case Err(e):
            return Err("Failed to parse package.sdn: {e.message()}")
        case Ok(root):
            var name = ""
            var version = "0.1.0"
            var description = ""
            var author = ""
            var license = ""
            var main_entry = "src/main.spl"

            # Extract package section
            val pkg = root.get("package")
            if pkg.?:
                val pkg_val = pkg.unwrap()
                val n = pkg_val.get("name")
                if n.?:
                    match n.unwrap():
                        case SdnValue.String(s): name = s
                        case _: pass

                val v = pkg_val.get("version")
                if v.?:
                    match v.unwrap():
                        case SdnValue.String(s): version = s
                        case _: pass

                val desc = pkg_val.get("description")
                if desc.?:
                    match desc.unwrap():
                        case SdnValue.String(s): description = s
                        case _: pass

                val auth = pkg_val.get("author")
                if auth.?:
                    match auth.unwrap():
                        case SdnValue.String(s): author = s
                        case _: pass

                val lic = pkg_val.get("license")
                if lic.?:
                    match lic.unwrap():
                        case SdnValue.String(s): license = s
                        case _: pass

                val main = pkg_val.get("main")
                if main.?:
                    match main.unwrap():
                        case SdnValue.String(s): main_entry = s
                        case _: pass

            # Parse dependencies
            val deps = parse_deps_dict(root.get("dependencies"))
            val dev_deps = parse_deps_dict(root.get("dev_dependencies"))

            Ok(PackageManifest(
                name: name,
                version: version,
                description: description,
                author: author,
                license: license,
                main_entry: main_entry,
                dependencies: deps,
                dev_dependencies: dev_deps
            ))


# Parse package.sdn from file path
fn parse_manifest_file(path: text) -> Result<PackageManifest, text>:
    extern fn rt_file_read_text(path: text) -> text
    extern fn rt_file_exists(path: text) -> bool

    if not rt_file_exists(path):
        return Err("Manifest file not found: {path}")
    val source = rt_file_read_text(path)
    if source == "" or source == nil:
        return Err("Manifest file is empty: {path}")
    parse_manifest(source)


# Generate package.sdn content for a new project
fn generate_manifest(name: text, version: text, description: text, author: text, license: text) -> text:
    var lines: [text] = []
    lines.push("package:")
    lines.push("    name: {name}")
    lines.push("    version: {version}")
    if description != "":
        lines.push("    description: \"{description}\"")
    if author != "":
        lines.push("    author: \"{author}\"")
    if license != "":
        lines.push("    license: {license}")
    lines.push("    main: src/main.spl")
    lines.push("")
    lines.push("dependencies:")
    lines.push("")
    lines.push("dev_dependencies:")
    lines.push("")
    lines.join("\n")
