# TUI Application Main Loop
#
# This synchronous startup path is intentionally tiny. Rich parser-backed UI
# rendering lives in the web/async/backend modules; this module is the hot
# native terminal entrypoint used by startup-size audits.

extern fn rt_file_exists(path: text) -> bool
extern fn rt_platform_name() -> text
extern fn rt_term_enable_ansi() -> bool

fn ensure_ansi_support():
    """Enable ANSI virtual terminal processing on Windows."""
    if rt_platform_name() == "windows":
        rt_term_enable_ansi()

fn read_user_input() -> text:
    val line = input("")
    if line == nil:
        return ""
    return line.trim()

fn run_tui(file_path: text) -> i64:
    """Start TUI mode for a .ui.sdn file."""
    if not rt_file_exists(file_path):
        print "Error: File not found: {file_path}"
        return 1

    ensure_ansi_support()
    print "\x1b[?1049h"
    print "\x1b[?25l"
    print "Simple UI"

    read_user_input()

    print "\x1b[?25h"
    print "\x1b[?1049l"
    print "UI closed."
    return 0
