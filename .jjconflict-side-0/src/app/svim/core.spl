# svim shared editor core
#
# Editor-native public vocabulary backed by a shared session model.
# This v1 foundation keeps editing logic in the core so host TUI and
# future shells can reuse the same state and command surface.

# Transparent _SvimCore/ package: files resolve as if in app.svim, split by role.
export use app.svim._SvimCore.model.*
export use app.svim._SvimCore.session_commands.*
export use app.svim._SvimCore.session_operators.*
export use app.svim._SvimCore.text_ops.*
