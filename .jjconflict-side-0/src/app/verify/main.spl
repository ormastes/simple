# Simple CLI - verify command
#
# Production-readiness verification focused on current changes. For MCP/LSP and
# tool-server changes, this command requires wrapper audit, request-path audit,
# and performance evidence artifacts before returning PASS.

use std.cli.cli_util.{get_cli_args}
use std.cli.log_modes.{parse_log_options, log_options_help, render_progress}
use std.log.{error}
use app.verify.full_verify.{run_full_verify}
use verification.state.{VerificationState}
use verification.proof_unit.{ProofUnit, ProofUnitSet}
use verification.report.{VerificationReport, ReportLevel}

fn print_help():
    print "Usage: simple verify [options] [file ...]"
    print ""
    print "Verifies current changes for production-readiness."
    print ""
    print "Options:"
    print "  --all                 Run the tooling gate for the full project scope"
    print "  --files=a,b,c         Override changed-file discovery with an explicit file list"
    print "  --no-write-report     Do not write doc/09_report/verify output"
    print "  --lean-status         Show Lean verification status report"
    print "  --detail              With --lean-status: show theorem-level detail"
    print "  --format=sdn          With --lean-status: output machine-readable SDN"
    for line in log_options_help():
        print "  {line}"
    print "  -h, --help            Show this help"

fn _is_log_option(arg: text) -> bool:
    arg == "--human" or arg == "--llm" or arg == "--json" or
        arg == "--tui" or arg == "--stdout" or arg == "--quiet" or
        arg == "--verbose" or arg == "--dots" or arg == "--count" or
        arg == "--no-progress" or arg == "--log-mode" or arg == "--surface" or
        arg == "--progress" or arg.starts_with("--log-mode=") or
        arg.starts_with("--surface=") or arg.starts_with("--progress=")

fn clean_args(args: [text]) -> [text]:
    var cleaned: [text] = []
    var i = 0
    while i < args.len():
        val arg = args[i]
        if _is_log_option(arg):
            if arg == "--log-mode" or arg == "--surface" or arg == "--progress":
                i = i + 1
        else:
            cleaned.push(arg)
        i = i + 1
    cleaned

fn main() -> i64:
    val raw_args = get_cli_args()
    val log_opts = parse_log_options(raw_args)
    if not log_opts.valid:
        error("verify", log_opts.error)
        return 1

    val args = clean_args(raw_args)

    if args.len() == 0 and raw_args.len() > 0:
        if log_opts.log_mode == "json":
            print "{\"command\":\"verify\",\"status\":\"usage\"}"
            return 0
        val progress = render_progress(log_opts.progress, 0, 1, "usage")
        if progress != "":
            print progress
        print_help()
        return 0

    for arg in args:
        if arg == "-h" or arg == "--help":
            print_help()
            return 0

    for arg in args:
        if arg == "--lean-status":
            return run_lean_status(args)

    run_full_verify(args)

# --lean-status: Lean verification status report
fn run_lean_status(args: [text]) -> i64:
    val units = discover_proof_units()

    # Determine detail level
    var level = ReportLevel.File
    for arg in args:
        if arg == "--detail":
            level = ReportLevel.Theorem

    # Determine output format
    var use_sdn = false
    for arg in args:
        if arg == "--format=sdn":
            use_sdn = true

    val timestamp = "2026-04-04T00:00:00Z"  # Stable report timestamp until std.time is available here.
    val report = VerificationReport.from_units(
        "Lean Verification Status", "project", units, timestamp
    )

    if use_sdn:
        print report.render_sdn()
    else:
        print report.render(level)

    # Return non-zero if any unit has failed state
    val counts = units.state_counts()
    if counts.failed > 0:
        1
    else:
        0

# Discover transient generated proof units from build/verification/generated/.
# Checked-in Lean proof/model sources live under src/verification/.
fn discover_proof_units() -> ProofUnitSet:
    use std.io_runtime.{file_exists, read_dir, read_file}

    var units = ProofUnitSet.empty()
    val gen_dir = "build/verification/generated"

    if not file_exists(gen_dir):
        return units

    val entries = read_dir(gen_dir)
    for entry in entries:
        if entry.ends_with(".lean"):
            val lean_path = "{gen_dir}/{entry}"
            val module_name = entry.replace(".lean", "")
            val unit = ProofUnit.create(
                source_file="(discovered)",
                source_symbol="*",
                lean_module="Verification.{module_name}",
                lean_file=lean_path
            ).with_state(VerificationState.NotChecked)
            units = units.add(unit)

    units
