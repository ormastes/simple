# Simple CLI - verify command
#
# Lightweight public entrypoint. Keep full verification imports in
# src/app/verify/worker.spl so help/status/list do not load the verification
# gate graph.

use std.cli.cli_util.{get_cli_args}
use app.io.process_ops.{process_run_timeout}

fn print_help():
    print "Usage: simple verify [command|options] [file ...]"
    print ""
    print "Commands:"
    print "  status        Show generated Lean artifact status"
    print "  list          List generated Lean artifacts"
    print "  check         Run gen-lean verify"
    print "  regenerate    Run gen-lean write --force"
    print "  quality       Run production quality verification"
    print ""
    print "Options:"
    print "  --all                 Run the tooling gate for the full project scope"
    print "  --files=a,b,c         Override changed-file discovery with an explicit file list"
    print "  --no-write-report     Do not write doc/09_report/verify output"
    print "  --lean-status         Show Lean verification status report"
    print "  -h, --help            Show this help"

fn strip_command_token(args: [text]) -> [text]:
    if args.len() > 0 and args[0] == "verify":
        args[1:]
    else:
        args

fn run_process(args: [text]) -> i64:
    val (stdout, stderr, code) = process_run_timeout("bin/simple", args, 120000)
    if stdout.len() > 0:
        print stdout
    if stderr.len() > 0:
        eprint stderr
    code as i64

fn lean_files() -> [text]:
    val script = "if [ -d build/verification/generated ]; then find build/verification/generated -name '*.lean' -type f | sort; fi"
    val (stdout, _stderr, code) = process_run_timeout("sh", ["-c", script], 10000)
    if code != 0 or stdout.trim() == "":
        []
    else:
        stdout.trim().split("\n")

fn verify_status() -> i64:
    val files = lean_files()
    print "Verification Status"
    print "==================="
    print ""
    print "Generated Lean proof units: {files.len()}"
    print "Verified: 0"
    print "Failed: 0"
    print "Not checked: {files.len()}"
    0

fn verify_list() -> i64:
    val files = lean_files()
    print "Verification Artifact Inventory"
    print "==============================="
    print ""
    for path in files:
        print "  {path}"
    print ""
    print "Total artifacts: {files.len()}"
    0

fn run_worker(args: [text]) -> i64:
    var worker_args = ["run", "src/app/verify/worker.spl"]
    for arg in args:
        worker_args.push(arg)
    run_process(worker_args)

fn main() -> i64:
    val args = strip_command_token(get_cli_args())

    if args.len() == 0:
        return run_worker(args)

    for arg in args:
        if arg == "-h" or arg == "--help":
            print_help()
            return 0

    val sub = args[0]
    if sub == "status":
        return verify_status()
    elif sub == "list":
        return verify_list()
    elif sub == "check":
        return run_process(["gen-lean", "verify"])
    elif sub == "regenerate":
        var forwarded = ["gen-lean", "write", "--force"]
        if args.len() > 1:
            for arg in args[1:]:
                forwarded.push(arg)
        return run_process(forwarded)
    elif sub == "quality":
        return run_worker(args[1:])

    run_worker(args)
