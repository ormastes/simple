use app.io.mod.{file_exists, file_read, file_write, dir_create_all, process_run}
use compiler.tools.lint.main.{lint_accessor_and_parent_names, normalize_lint_line, indent_width}
use compiler.tools.fix.rules.impl_.lint_stub.{check_stub_impl_text}

struct TestQualityFinding:
    level: text
    subject: text
    message: text

struct TestQualityVerifyReport:
    scope: text
    scanned_files: [text]
    findings: [TestQualityFinding]
    failures: i64
    warnings: i64
    passes: i64
    status: text

struct VisibleDebtRegistryEntry:
    path: text
    pattern_class: text
    reason: text

val VISIBLE_DEBT_REGISTRY = "scripts/visible_debt_registry.sdn"
val TEST_VISIBLE_DEBT_REGISTRY = "build/test-fixtures/verify_quality/visible_debt_registry.sdn"

fn make_quality_finding(level: text, subject: text, message: text) -> TestQualityFinding:
    TestQualityFinding(level: level, subject: subject, message: message)

fn quality_count(findings: [TestQualityFinding], level: text) -> i64:
    var count = 0
    for finding in findings:
        if finding.level == level:
            count = count + 1
    count

fn quality_status(findings: [TestQualityFinding]) -> text:
    if quality_count(findings, "FAIL") > 0:
        return "FAIL"
    if quality_count(findings, "WARN") > 0:
        return "WARN"
    "PASS"

fn quality_report_from_findings(scope: text, scanned_files: [text], findings: [TestQualityFinding]) -> TestQualityVerifyReport:
    TestQualityVerifyReport(
        scope: scope,
        scanned_files: scanned_files,
        findings: findings,
        failures: quality_count(findings, "FAIL"),
        warnings: quality_count(findings, "WARN"),
        passes: quality_count(findings, "PASS"),
        status: quality_status(findings)
    )

fn is_visible_debt_scope(path: text) -> bool:
    path.starts_with("src/os/") or path.starts_with("examples/09_embedded/simple_os/") or path.starts_with("test/") or path.starts_with("doc/") or path.starts_with("build/test-fixtures/verify_quality/")

fn default_visible_debt_scopes() -> [text]:
    ["src/os", "examples/09_embedded/simple_os", "test", "doc"]

fn collect_quality_scan_paths(files: [text], full_scan: bool) -> [text]:
    if full_scan:
        return default_visible_debt_scopes()

    var paths: [text] = []
    for path in files:
        if is_visible_debt_scope(path) and file_exists(path):
            paths.push(path)
    paths

fn visible_debt_rg_pattern() -> text:
    "pass_todo|pass_do_nothing|pass_dn|TODO|FIXME|not implemented|placeholder|stub|dummy|expect\\(true\\)\\.to_equal\\(true\\)|\\.to_equal\\(true\\)|\\.to_equal\\(false\\)|\\.to_be\\(true\\)|\\.to_be\\(false\\)|check\\(true,"

fn classify_visible_debt(line: text) -> text:
    val lower = line.lower()
    if lower.contains("expect(true).to_equal(true)") or lower.contains("check(true,"):
        return "tautological_assertion"
    if lower.contains(".to_equal(true)") or lower.contains(".to_equal(false)") or lower.contains(".to_be(true)") or lower.contains(".to_be(false)"):
        return "boolean_wrapper_assertion"
    if lower.contains("pass_todo") or lower.contains("pass_do_nothing") or lower.contains("pass_dn"):
        return "pass_marker"
    if lower.contains("todo") or lower.contains("fixme"):
        return "tracking_keyword"
    if lower.contains("not implemented"):
        return "incomplete_message"
    if lower.contains("placeholder"):
        return "placeholder"
    if lower.contains("stub"):
        return "stub"
    if lower.contains("dummy"):
        return "dummy"
    "debt"

fn parse_registry_line(line: text) -> VisibleDebtRegistryEntry:
    val parts = line.split("\"")
    if parts.len() < 6:
        return VisibleDebtRegistryEntry(path: "", pattern_class: "", reason: "")
    VisibleDebtRegistryEntry(path: parts[1], pattern_class: parts[3], reason: parts[5])

fn load_visible_debt_registry(path: text) -> [VisibleDebtRegistryEntry]:
    var registry_path = path
    if not file_exists(registry_path) and file_exists(TEST_VISIBLE_DEBT_REGISTRY):
        registry_path = TEST_VISIBLE_DEBT_REGISTRY
    if not file_exists(registry_path):
        return []

    var entries: [VisibleDebtRegistryEntry] = []
    for line in file_read(registry_path).split("\n"):
        val trimmed = line.trim()
        if trimmed == "" or trimmed.starts_with("#") or trimmed.starts_with("visible_debt_registry"):
            continue
        val entry = parse_registry_line(trimmed)
        if entry.path != "" and entry.pattern_class != "":
            entries.push(entry)
    entries

fn is_registered_visible_debt(path: text, pattern_class: text, registry: [VisibleDebtRegistryEntry]) -> bool:
    for entry in registry:
        if entry.path == path and entry.pattern_class == pattern_class:
            return true
    false

fn visible_debt_registry_reason(path: text, pattern_class: text, registry: [VisibleDebtRegistryEntry]) -> text:
    for entry in registry:
        if entry.path == path and entry.pattern_class == pattern_class:
            return entry.reason
    ""

fn parse_rg_path(line: text) -> text:
    val parts = line.split(":")
    if parts.len() < 1:
        return ""
    parts[0]

fn parse_rg_line_number(line: text) -> text:
    val parts = line.split(":")
    if parts.len() < 2:
        return ""
    parts[1]

fn run_visible_debt_rg(paths: [text]) -> (text, i64):
    if paths.len() == 0:
        return ("", 1)

    var args = ["-n", "--with-filename", "--ignore-case", "--no-heading", visible_debt_rg_pattern()]
    args.push("-g")
    args.push("!doc/10_metrics/dashboard/history/**")
    args.push("-g")
    args.push("!doc/09_report/**")
    args.push("-g")
    args.push("!src/compiler_rust/vendor/**")
    args.push("-g")
    args.push("!**/summary.txt")
    for path in paths:
        args.push(path)

    val (stdout, _stderr, exit_code) = process_run("rg", args)
    (stdout, exit_code)

fn run_linter_candidate_rg(paths: [text]) -> (text, i64):
    if paths.len() == 0:
        return ("", 1)

    var args = ["-l", "--glob", "*.spl", "expect\\(|pass_todo|pass_do_nothing|pass_dn|print|it \"|fn |class |get_|set_|is_|@name_checked"]
    args.push("-g")
    args.push("!src/compiler_rust/vendor/**")
    args.push("-g")
    args.push("!**/summary.txt")
    for path in paths:
        args.push(path)

    val (stdout, _stderr, exit_code) = process_run("rg", args)
    (stdout, exit_code)

fn collect_linter_quality_findings(paths: [text]) -> [TestQualityFinding]:
    var findings: [TestQualityFinding] = []
    val (stdout, exit_code) = run_linter_candidate_rg(paths)
    if exit_code != 0 and stdout.trim() == "":
        return findings

    for line in stdout.split("\n"):
        val path = line.trim()
        if path == "" or not file_exists(path):
            continue
        val source = file_read(path)
        if source == "":
            continue

        for finding in collect_spipe_body_quality_findings(path, source):
            findings.push(finding)

        for fix in check_stub_impl_text(source, path):
            findings.push(make_quality_finding(
                "FAIL",
                path,
                "stub_impl: function body is a trivial stub"
            ))

        val warnings = lint_accessor_and_parent_names(path, source)
        for warning in warnings:
            findings.push(make_quality_finding(
                "WARN",
                "{path}:{warning.line}",
                "{warning.code}: {warning.message}"
            ))
    findings

fn collect_spipe_body_quality_findings(path: text, source: text) -> [TestQualityFinding]:
    var findings: [TestQualityFinding] = []
    if not (path.ends_with("_spec.spl") or path.contains("/test/") or path.starts_with("test/")):
        return findings

    val lines = source.split("\n")
    var line_num = 1
    for line in lines:
        val normalized = normalize_lint_line(line.trim())
        if normalized.contains("print\"[skip]") or normalized.contains("print(\"[skip]") or normalized.contains("print\"skip:") or normalized.contains("print(\"skip:"):
            findings.push(make_quality_finding(
                "FAIL",
                "{path}:{line_num}",
                "SPIPE004: print-based skip placeholder in spec/example"
            ))
        line_num = line_num + 1

    var i = 0
    while i < lines.len():
        val line = lines[i]
        val trimmed = line.trim()
        if not (trimmed.starts_with("it \"") or trimmed.starts_with("slow_it \"")):
            i = i + 1
            continue

        val header_indent = indent_width(line)
        var j = i + 1
        var has_real_assertion = false
        var has_sanctioned_skip = false
        while j < lines.len():
            val body_line = lines[j]
            val body_trimmed = body_line.trim()
            if body_trimmed != "" and not body_trimmed.starts_with("#") and indent_width(body_line) <= header_indent:
                break
            val normalized = normalize_lint_line(body_trimmed)
            if normalized.contains("expect(") or normalized.contains("expect_not(") or normalized.contains("to_equal(") or normalized.contains("to_be(") or normalized.contains("is_equal(") or normalized.contains("to_contain(") or normalized.contains("to_start_with(") or normalized.contains("to_end_with(") or normalized.contains("to_be_greater_than(") or normalized.contains("to_be_less_than("):
                has_real_assertion = true
            if normalized == "skip:" or normalized.starts_with("skip:") or normalized.contains("return\"skip:") or normalized.contains("return'skip:"):
                has_sanctioned_skip = true
            j = j + 1

        if not has_real_assertion and not has_sanctioned_skip:
            val example_line = i + 1
            findings.push(make_quality_finding(
                "FAIL",
                "{path}:{example_line}",
                "SPIPE005: SPipe example has no real assertion or sanctioned skip"
            ))
        i = j
    findings

fn build_test_quality_verify_report(scope: text, files: [text], full_scan: bool) -> TestQualityVerifyReport:
    val scan_paths = collect_quality_scan_paths(files, full_scan)
    var findings: [TestQualityFinding] = []

    if scan_paths.len() == 0:
        findings.push(make_quality_finding("PASS", scope, "No visible-debt target files selected"))
        return quality_report_from_findings(scope, scan_paths, findings)

    val registry = load_visible_debt_registry(VISIBLE_DEBT_REGISTRY)
    for finding in collect_linter_quality_findings(scan_paths):
        findings.push(finding)

    val (stdout, exit_code) = run_visible_debt_rg(scan_paths)
    if exit_code != 0 and stdout.trim() == "":
        if findings.len() == 0:
            findings.push(make_quality_finding("PASS", scope, "No visible debt markers found"))
        return quality_report_from_findings(scope, scan_paths, findings)

    var registered_count = 0
    for line in stdout.split("\n"):
        val trimmed = line.trim()
        if trimmed == "":
            continue
        val path = parse_rg_path(trimmed)
        val line_number = parse_rg_line_number(trimmed)
        val pattern_class = classify_visible_debt(trimmed)
        if is_registered_visible_debt(path, pattern_class, registry):
            registered_count = registered_count + 1
            findings.push(make_quality_finding(
                "WARN",
                "{path}:{line_number}",
                "registered visible debt marker ({pattern_class}): {visible_debt_registry_reason(path, pattern_class, registry)}"
            ))
        else:
            findings.push(make_quality_finding(
                "FAIL",
                "{path}:{line_number}",
                "unregistered visible debt marker ({pattern_class})"
            ))

    if findings.len() == 0:
        findings.push(make_quality_finding(
            "PASS",
            scope,
            "Visible debt gate passed ({registered_count} registered marker(s))"
        ))

    quality_report_from_findings(scope, scan_paths, findings)

fn render_test_quality_verify_report(report: TestQualityVerifyReport) -> text:
    var lines: [text] = []
    lines.push("=== Verification Report: Visible Debt ===")
    lines.push("")
    lines.push("Scope: {report.scope}")
    lines.push("Scanned paths:")
    for path in report.scanned_files:
        lines.push("  - {path}")
    lines.push("")
    for finding in report.findings:
        lines.push("[{finding.level}] {finding.subject} - {finding.message}")
    lines.push("")
    lines.push("STATUS: {report.status} ({report.failures} failures, {report.warnings} warnings)")
    lines.join("\n")

fn write_test_quality_verify_report(report: TestQualityVerifyReport, report_dir: text) -> text:
    val _ = dir_create_all(report_dir)
    val report_path = "{report_dir}/visible_debt_verify_latest.md"
    val ok = file_write(report_path, render_test_quality_verify_report(report))
    if ok:
        report_path
    else:
        ""

export TestQualityFinding, TestQualityVerifyReport, VisibleDebtRegistryEntry
export build_test_quality_verify_report, render_test_quality_verify_report, write_test_quality_verify_report
