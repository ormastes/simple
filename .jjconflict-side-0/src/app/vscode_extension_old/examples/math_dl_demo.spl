# Deep Learning Equations Demo
# Common DL/ML equations using math blocks

# ── Loss Functions ──

# 1. Cross-entropy loss
val ce_loss = loss{ -frac(1,n) * sum(y[i] * log(p[i]), i=1..n) }

# 2. KL Divergence
val kl = loss{ sum(p[i] * log(frac(p[i], q[i])), i=1..n) }

# 3. MSE Loss
val mse = loss{ frac(1,n) * sum((y[i] - hat(y)[i])^2, i=1..n) }

# 4. Focal Loss
val focal = loss{ -alpha[t] * (1-p[t])^gamma * log(p[t]) }

# 5. Huber Loss (piecewise)
val huber = loss{ cases(frac(1,2) * x^2, abs(x) leq delta; delta * (abs(x) - frac(1,2) * delta), otherwise) }

# ── Activations ──

# 6. Sigmoid
val sigmoid = m{ sigma(x) = frac(1, 1 + exp(-x)) }

# 7. Softmax
val softmax_eq = m{ softmax(z[i]) = frac(exp(z[i]), sum(exp(z[j]), j=1..K)) }

# 8. GELU
val gelu = m{ frac(x,2) * (1 + tanh(sqrt(frac(2,pi)) * (x + 0.044715 * x^3))) }

# 9. ReLU (piecewise)
val relu = m{ cases(0, x leq 0; x, x > 0) }

# ── Optimization ──

# 10. Gradient descent
val gd = m{ theta = theta - eta * nabla L(theta) }

# 11. Adam (moment estimates)
val adam_m = m{ hat(m)[t] = frac(m[t], 1 - beta[1]^t) }
val adam_v = m{ hat(v)[t] = frac(v[t], 1 - beta[2]^t) }
val adam_update = m{ theta[t+1] = theta[t] - frac(eta, sqrt(hat(v)[t]) + epsilon) * hat(m)[t] }

# ── Attention ──

# 12. Scaled dot-product attention
val attn = m{ softmax(frac(Q @ K', sqrt(d[k]))) @ V }

# ── Normalization ──

# 13. Layer Norm
val ln = m{ frac(x - bar(x), sqrt(sigma^2 + epsilon)) * gamma + beta }

# 14. Batch Norm
val bn = m{ hat(x)[i] = frac(x[i] - mu[B], sqrt(sigma[B]^2 + epsilon)) }

# ── Regularization ──

# 15. L1 + L2 (Elastic Net)
val elastic = m{ L + lambda[1] * sum(abs(w[i])) + lambda[2] * sum(w[i]^2) }

# ── Probability ──

# 16. Bayes' Theorem
val bayes = m{ P(A mid B) = frac(P(B mid A) * P(A), P(B)) }

# 17. Gaussian PDF
val gauss = m{ frac(1, sigma * sqrt(2*pi)) * exp(frac(-(x-mu)^2, 2*sigma^2)) }

# 18. Expected value
val ev = m{ expect(X) = sum(x[i] * P(x[i]), i=1..n) }

# ── Calculus ──

# 19. Partial derivative (shorthand)
val grad = m{ dd(L, theta) = dd(L, hat(y)) * dd(hat(y), theta) }

# 20. Integral
val area = m{ integral(f(x), x=a..b) }
