use app.llm_runtime.manifest.{LlmRuntimeManifest, LlmRuntimeAdapter}
use app.mcp.main_lazy_json.{LB, RB, jp, js}
use std.common.torch.dyn_sffi_ops.{dyn_torch_available}
use std.io_runtime.{file_exists}

pub class LlmRuntimeProbeResult:
    status: text
    reason: text
    base_model: text
    endpoint_status: text
    chat_template_status: text
    lora_adapter_count: i64
    dynamic_lora_status: text
    torch_ready: text
    evidence_jsonl: text

pub fn llm_runtime_probe_manifest(manifest: LlmRuntimeManifest) -> LlmRuntimeProbeResult:
    llm_runtime_probe_manifest_with_torch_check(manifest, true)

pub fn llm_runtime_probe_manifest_with_torch_check(manifest: LlmRuntimeManifest, check_torch: bool) -> LlmRuntimeProbeResult:
    val torch_status = if check_torch: _runtime_torch_status() else: "unchecked"
    llm_runtime_probe_manifest_with_torch_status(manifest, torch_status)

pub fn llm_runtime_probe_manifest_with_torch_status(manifest: LlmRuntimeManifest, torch_status: text) -> LlmRuntimeProbeResult:
    val required_status = _required_status(manifest)
    val chat_template_status = _optional_file_status(manifest.chat_template)
    val adapter_status = _adapter_status(manifest.lora_adapters)
    val dynamic_status = _dynamic_status(manifest.dynamic_lora)
    val normalized_torch_status = _normalized_torch_status(torch_status)
    val status = _overall_status(required_status, adapter_status, dynamic_status, normalized_torch_status)
    val reason = _reason(status, required_status, adapter_status, dynamic_status, normalized_torch_status)
    val endpoint_status = _endpoint_status(manifest.endpoint)
    val result = LlmRuntimeProbeResult(
        status: status,
        reason: reason,
        base_model: _public_text(manifest.base_model, "missing"),
        endpoint_status: endpoint_status,
        chat_template_status: chat_template_status,
        lora_adapter_count: manifest.lora_adapters.len(),
        dynamic_lora_status: dynamic_status,
        torch_ready: normalized_torch_status,
        evidence_jsonl: ""
    )
    result.evidence_jsonl = llm_runtime_probe_jsonl_event(result)
    result

fn _runtime_torch_status() -> text:
    if dyn_torch_available():
        return "ready"
    "unavailable"

fn _normalized_torch_status(torch_status: text) -> text:
    val status = torch_status.trim().to_lower()
    if status == "ready" or status == "unchecked" or status == "unavailable" or status == "blocked":
        return status
    "blocked"

pub fn llm_runtime_probe_jsonl_event(result: LlmRuntimeProbeResult) -> text:
    LB() +
    jp("event", js("llm_runtime_vllm_readiness")) +
    "," + jp("status", js(result.status)) +
    "," + jp("reason", js(result.reason)) +
    "," + jp("base_model", js(result.base_model)) +
    "," + jp("endpoint", js(result.endpoint_status)) +
    "," + jp("chat_template", js(result.chat_template_status)) +
    "," + jp("lora_adapter_count", str(result.lora_adapter_count)) +
    "," + jp("dynamic_lora", js(result.dynamic_lora_status)) +
    "," + jp("torch_ready", js(result.torch_ready)) +
    RB() + "\n"

fn _required_status(manifest: LlmRuntimeManifest) -> text:
    if manifest.base_model.trim() == "":
        return "missing_base_model"
    if manifest.endpoint.trim() == "":
        return "missing_endpoint"
    if _endpoint_status(manifest.endpoint) == "invalid":
        return "invalid_endpoint"
    if manifest.invalid_adapter_count > 0:
        return "invalid_adapter_entry"
    "ok"

fn _endpoint_status(endpoint: text) -> text:
    val value = endpoint.trim()
    if value == "":
        return "missing"
    if value.starts_with("http://") or value.starts_with("https://"):
        if value.contains(" "):
            return "invalid"
        return "configured"
    "invalid"

fn _optional_file_status(path: text) -> text:
    if path.trim() == "":
        return "none"
    if file_exists(path):
        return "present"
    "missing"

fn _adapter_status(adapters: [LlmRuntimeAdapter]) -> text:
    for adapter in adapters:
        if adapter.name.trim() == "":
            return "missing_adapter_name"
        if adapter.path.trim() == "":
            return "missing_adapter_path"
        if not file_exists(adapter.path):
            return "missing_adapter_path"
    "ok"

fn _dynamic_status(mode: text) -> text:
    if mode == "trusted":
        return "trusted"
    if mode == "disabled":
        return "disabled"
    "blocked"

fn _overall_status(required_status: text, adapter_status: text, dynamic_status: text, torch_status: text) -> text:
    if required_status != "ok":
        return "missing"
    if adapter_status != "ok":
        return "missing"
    if dynamic_status == "blocked":
        return "blocked"
    if torch_status == "unavailable":
        return "blocked"
    if torch_status == "blocked":
        return "blocked"
    "ready"

fn _reason(status: text, required_status: text, adapter_status: text, dynamic_status: text, torch_status: text) -> text:
    if required_status != "ok":
        return required_status
    if adapter_status != "ok":
        return adapter_status
    if dynamic_status == "blocked":
        return "dynamic_lora_requires_trusted_mode"
    if torch_status == "unavailable":
        return "torch_unavailable"
    if torch_status == "blocked":
        return "torch_or_svllm_placeholder_blocker"
    if status == "ready":
        return "static_manifest_ready"
    "readiness_unknown"

fn _public_text(value: text, fallback: text) -> text:
    if value.trim() == "":
        return fallback
    if _looks_sensitive(value):
        return "redacted"
    value

fn _looks_sensitive(value: text) -> bool:
    val lower = value.to_lower()
    lower.contains("token") or lower.contains("apikey") or lower.contains("api_key") or lower.contains("password") or lower.contains("secret") or lower.contains("@") or value.contains("/") or value.starts_with("~") or value.contains("\\")

export LlmRuntimeProbeResult
export llm_runtime_probe_manifest, llm_runtime_probe_manifest_with_torch_check, llm_runtime_probe_manifest_with_torch_status, llm_runtime_probe_jsonl_event
