fn ctrl_debug_hydrate_dap_response(ctrl: EditorController, response_json: text) -> EditorAction:
    val session = editor_debug_first_session(ctrl.debug_registry)
    if editor_debug_session_id(session) == 0:
        ctrl.status_msg = "no debug session"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    if not editor_debug_dap_response_success(response_json):
        ctrl.status_msg = "debug response failed: " + editor_debug_dap_response_command(response_json)
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    val command = editor_debug_dap_response_command(response_json)
    if command == "stackTrace":
        ctrl.debug_registry = editor_debug_update_stack_frames(ctrl.debug_registry, editor_debug_session_id(session), editor_debug_stack_frames_from_dap_response(response_json))
        ctrl_show_debug_session_panel(ctrl, "debug stack")
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    if command == "scopes":
        ctrl.debug_registry = editor_debug_update_scopes(ctrl.debug_registry, editor_debug_session_id(session), editor_debug_scopes_from_dap_response(response_json))
        ctrl_show_debug_session_panel(ctrl, "debug scopes")
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    if command == "variables":
        ctrl.debug_registry = editor_debug_update_scope_variables(ctrl.debug_registry, editor_debug_session_id(session), "Locals", editor_debug_variables_from_dap_response(response_json))
        ctrl_show_debug_session_panel(ctrl, "debug variables: Locals")
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    if command == "evaluate":
        val value = editor_debug_evaluate_result_from_dap_response(response_json)
        if ctrl.debug_pending_watch_expressions.len() > 0:
            val expression = ctrl.debug_pending_watch_expressions[0]
            ctrl.debug_pending_watch_expressions = _editor_text_list_without_first(ctrl.debug_pending_watch_expressions)
            ctrl.debug_registry = editor_debug_update_watch(ctrl.debug_registry, editor_debug_session_id(session), expression, value, "ok")
            ctrl_show_debug_session_panel(ctrl, "watch refreshed: " + expression)
            return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
        ctrl.debug_registry = editor_debug_console_append(ctrl.debug_registry, editor_debug_session_id(session), "evaluate-result", value)
        ctrl_show_debug_session_panel(ctrl, "debug evaluate result")
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    ctrl.status_msg = "debug response ignored: " + command
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_debug_hydrate_dap_event(ctrl: EditorController, event_json: text) -> EditorAction:
    val session = editor_debug_first_session(ctrl.debug_registry)
    if editor_debug_session_id(session) == 0:
        ctrl.status_msg = "no debug session"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    if editor_debug_dap_message_type(event_json) != "event":
        ctrl.status_msg = "debug event ignored"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    val event = editor_debug_dap_event_name(event_json)
    val status = editor_debug_dap_event_status(event_json)
    if status == "":
        ctrl.status_msg = "debug event ignored: " + event
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    ctrl.debug_registry = editor_debug_set_status(ctrl.debug_registry, editor_debug_session_id(session), status)
    ctrl.debug_status = status
    ctrl_show_debug_session_panel(ctrl, editor_debug_dap_event_summary(event_json))
    if status == "paused":
        val event_status = ctrl.status_msg
        ctrl_debug_refresh_watches(ctrl)
        ctrl.status_msg = event_status
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_debug_set_exception_filters(ctrl: EditorController, filters: [text]) -> EditorAction:
    val session = editor_debug_first_session(ctrl.debug_registry)
    if editor_debug_session_id(session) == 0:
        ctrl.status_msg = "no debug session"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    ctrl.debug_registry = editor_debug_set_exception_filters(ctrl.debug_registry, editor_debug_session_id(session), filters)
    var dap = ctrl.debug_dap_client
    if dap.running:
        val requested = editor_debug_dap_client_set_exception_breakpoints(dap, filters)
        dap = requested.0
        ctrl.debug_dap_client = dap
    ctrl_show_debug_session_panel(ctrl, "exception breakpoints set")
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_debug_poll_dap_client(ctrl: EditorController) -> EditorAction:
    val action = ctrl_poll_debug_dap_client(ctrl)
    if action.redraw:
        return action
    ctrl.status_msg = "no debug messages"
    EditorAction(redraw: false, quit: false, status_msg: ctrl.status_msg)

fn ctrl_poll_debug_dap_client(ctrl: EditorController) -> EditorAction:
    var messages: [EditorDebugDapInboundMessage] = []
    if ctrl.debug_process_pid > 0:
        if editor_debug_process_wait_simple_stopped(ctrl.debug_process_pid):
            ctrl.debug_status = "paused"
            ctrl.status_msg = "debug stopped: entry"
            return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
        return EditorAction(redraw: false, quit: false, status_msg: ctrl.status_msg)
    else:
        var dap = ctrl.debug_dap_client
        val polled = editor_debug_dap_client_poll_messages(dap)
        dap = polled.0
        messages = polled.1
        ctrl.debug_dap_client = dap
    var updated = false
    for message in messages:
        val message_type = editor_debug_dap_inbound_message_type(message)
        val raw_json = editor_debug_dap_inbound_raw_json(message)
        if message_type == "response":
            val action = ctrl_debug_hydrate_dap_response(ctrl, raw_json)
            if action.redraw:
                updated = true
        elif message_type == "event":
            val event_action = ctrl_debug_hydrate_dap_event(ctrl, raw_json)
            if event_action.redraw:
                updated = true
    if updated:
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    EditorAction(redraw: false, quit: false, status_msg: ctrl.status_msg)

fn ctrl_debug_request_stack_trace(ctrl: EditorController) -> EditorAction:
    val session = editor_debug_first_session(ctrl.debug_registry)
    if editor_debug_session_id(session) == 0:
        ctrl.status_msg = "no debug session"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    var dap = ctrl.debug_dap_client
    if not dap.running:
        ctrl.status_msg = "debug adapter not running"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    val requested = editor_debug_dap_client_stack_trace(dap, 1)
    dap = requested.0
    ctrl.debug_dap_client = dap
    ctrl.status_msg = "debug stack requested"
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

