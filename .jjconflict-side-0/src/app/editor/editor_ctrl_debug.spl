fn ctrl_debug_sync_active_breakpoints(ctrl: EditorController) -> EditorAction:
    val session = editor_debug_first_session(ctrl.debug_registry)
    if editor_debug_session_id(session) == 0:
        ctrl.status_msg = "no debug session"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    var dap = ctrl.debug_dap_client
    if not dap.running:
        ctrl.status_msg = "debug adapter not running"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    var synced_paths: [text] = []
    val breakpoints = editor_debug_session_breakpoints(session)
    for bp in breakpoints:
        val bp_path = editor_debug_breakpoint_path(bp)
        if bp_path != "" and not _editor_text_list_contains(synced_paths, bp_path):
            val synced = editor_debug_dap_client_set_breakpoints(dap, bp_path, breakpoints)
            dap = synced.0
            synced_paths.push(bp_path)
    ctrl.debug_dap_client = dap
    ctrl.status_msg = "debug breakpoints requested"
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_debug_continue(ctrl: EditorController) -> EditorAction:
    val session = editor_debug_first_session(ctrl.debug_registry)
    if editor_debug_session_id(session) == 0:
        ctrl.status_msg = "no debug session"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    ctrl.debug_registry = editor_debug_continue(ctrl.debug_registry, editor_debug_session_id(session))
    var dap = ctrl.debug_dap_client
    if dap.running:
        val requested = editor_debug_dap_client_continue_thread(dap, 1)
        dap = requested.0
        ctrl.debug_dap_client = dap
    ctrl.debug_status = "running"
    ctrl.status_msg = "debug continue"
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

