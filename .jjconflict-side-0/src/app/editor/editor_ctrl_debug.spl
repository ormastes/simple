fn ctrl_debug_step(ctrl: EditorController, step_kind: text) -> EditorAction:
    val session = editor_debug_first_session(ctrl.debug_registry)
    if editor_debug_session_id(session) == 0:
        ctrl.status_msg = "no debug session"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    ctrl.debug_registry = editor_debug_step(ctrl.debug_registry, editor_debug_session_id(session), step_kind)
    var dap = ctrl.debug_dap_client
    if dap.running:
        val requested = editor_debug_dap_client_step_thread(dap, step_kind, 1)
        dap = requested.0
        ctrl.debug_dap_client = dap
    ctrl.debug_status = "stepping"
    ctrl.status_msg = "debug " + step_kind
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_debug_terminate_first(ctrl: EditorController) -> EditorAction:
    val session = editor_debug_first_session(ctrl.debug_registry)
    if editor_debug_session_id(session) == 0:
        ctrl.status_msg = "no debug session"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    var dap = ctrl.debug_dap_client
    if dap.running:
        val requested = editor_debug_dap_client_disconnect(dap)
        dap = requested.0
    ctrl.debug_registry = editor_debug_registry_terminate(ctrl.debug_registry, editor_debug_session_id(session))
    if ctrl.debug_process_pid > 0:
        ctrl.debug_dap_client = editor_debug_dap_stop_process_pid(ctrl.debug_process_pid)
    else:
        dap.running = false
        ctrl.debug_dap_client = dap
    ctrl_debug_store_client_for_session(ctrl, editor_debug_session_id(session), ctrl.debug_dap_client)
    ctrl.debug_process_pid = 0
    ctrl.debug_status = "terminated"
    ctrl.status_msg = "debug terminated"
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_debug_restart_first(ctrl: EditorController) -> EditorAction:
    val session = editor_debug_first_session(ctrl.debug_registry)
    if editor_debug_session_id(session) == 0:
        ctrl.status_msg = "no debug session"
        return EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)
    ctrl.debug_registry = editor_debug_registry_restart(ctrl.debug_registry, editor_debug_session_id(session))
    var dap = ctrl.debug_dap_client
    dap.start()
    val restarted = editor_debug_dap_client_restart(dap)
    dap = restarted.0
    val initialized = editor_debug_dap_client_initialize(dap)
    dap = initialized.0
    val launched = editor_debug_dap_client_launch(dap, editor_debug_session_config(session))
    dap = launched.0
    ctrl.debug_dap_client = dap
    ctrl_debug_store_client_for_session(ctrl, editor_debug_session_id(session), dap)
    ctrl.debug_status = "restarting"
    ctrl.status_msg = "debug restart"
    EditorAction(redraw: true, quit: false, status_msg: ctrl.status_msg)

fn ctrl_debug_store_client_for_session(ctrl: EditorController, session_id: i64, dap: EditorDebugDapClient):
    val index = session_id - 1
    if index < 0:
        return
    while ctrl.debug_dap_clients.len() <= index:
        ctrl.debug_dap_clients.push(EditorDebugDapClient.new())
    ctrl.debug_dap_clients[index] = dap
