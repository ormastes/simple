#![allow(unnamed_duplicate_typed_args)]
# Assistant Dashboard Status Subview

use app.dashboard.assistant_collectors.{
    AssistantDashboardSnapshot, assistant_session_by_id
}
use app.dashboard.views.assistant_common.{
    assistant_session_summary, assistant_session_summary_html,
    assistant_short_id, assistant_surface_label, assistant_surface_plain,
    assistant_threshold_css_color
}
use app.ui.render.types.{RenderConfig}
use app.ui.render.html.{html_escape}
use app.ui.render.ansi.{
    BOLD, CYAN, GREEN, YELLOW, RED, RESET
}

fn assistant_status_text(snapshot: AssistantDashboardSnapshot, config: RenderConfig) -> text:
    var out = ""
    out = "{out}{assistant_text_header(snapshot)}\n\n"
    out = "{out}{assistant_text_overview(snapshot)}\n"
    if snapshot.warnings.len() > 0:
        out = "{out}\n{assistant_text_warnings(snapshot)}\n"
    out

fn assistant_status_html(snapshot: AssistantDashboardSnapshot, config: RenderConfig) -> text:
    var h = ""
    h = "{h}{assistant_html_header(snapshot)}"
    h = "{h}{assistant_html_overview(snapshot)}"
    if snapshot.warnings.len() > 0:
        h = "{h}{assistant_html_warnings(snapshot)}"
    h

fn assistant_text_header(snapshot: AssistantDashboardSnapshot) -> text:
    var out = ""
    out = "{out}{BOLD}{CYAN}Assistant Dashboard{RESET}\n"
    out = "{out}Source: {snapshot.source_label} | State: {assistant_surface_label(snapshot.surface_state)} | Selected: {assistant_short_id(snapshot.selected_session_id)}"
    out

fn assistant_text_overview(snapshot: AssistantDashboardSnapshot) -> text:
    var out = ""
    out = "{out}{BOLD}Overview{RESET}\n"
    out = "{out}  Sessions: {snapshot.total_sessions}  Live: {snapshot.live_sessions}  Replay: {snapshot.replay_sessions}  Degraded: {snapshot.degraded_sessions}\n"
    out = "{out}  Events: {snapshot.total_events}\n"
    out = "{out}  Collected: {snapshot.collected_at}\n"
    if snapshot.selected_session_id != "":
        val session = assistant_session_by_id(snapshot.sessions, snapshot.selected_session_id)
        if session != nil:
            out = "{out}  Focus: {assistant_session_summary(session)}\n"
    out

fn assistant_text_warnings(snapshot: AssistantDashboardSnapshot) -> text:
    var out = "{BOLD}{YELLOW}Warnings{RESET}\n"
    for warning in snapshot.warnings:
        out = "{out}  {warning}\n"
    out

fn assistant_html_header(snapshot: AssistantDashboardSnapshot) -> text:
    var h = ""
    h = "{h}<h1>Assistant Dashboard</h1>\n"
    h = "{h}<div class=\"subtitle\">Source: {html_escape(snapshot.source_label)} | State: {html_escape(assistant_surface_plain(snapshot.surface_state))} | Selected: {html_escape(assistant_short_id(snapshot.selected_session_id))}</div>\n"
    h

fn assistant_html_overview(snapshot: AssistantDashboardSnapshot) -> text:
    val live_pct = if snapshot.total_sessions > 0: (snapshot.live_sessions * 100) / snapshot.total_sessions else: 0
    val replay_pct = if snapshot.total_sessions > 0: (snapshot.replay_sessions * 100) / snapshot.total_sessions else: 0
    val degraded_pct = if snapshot.total_sessions > 0: (snapshot.degraded_sessions * 100) / snapshot.total_sessions else: 0
    val live_css = assistant_threshold_css_color(live_pct as f64)
    val replay_css = assistant_threshold_css_color(replay_pct as f64)
    val degraded_css = assistant_threshold_css_color(degraded_pct as f64)

    var h = "<div class=\"card-grid\">"
    h = "{h}<div class=\"card\"><h3>Sessions</h3><div class=\"value\">{snapshot.total_sessions}</div><div class=\"sub\">Collected {snapshot.collected_at}</div></div>"
    h = "{h}<div class=\"card\"><h3>Live</h3><div class=\"value\" style=\"color:{live_css}\">{snapshot.live_sessions}</div><div class=\"sub\">{live_pct}% of sessions</div></div>"
    h = "{h}<div class=\"card\"><h3>Replay</h3><div class=\"value\" style=\"color:{replay_css}\">{snapshot.replay_sessions}</div><div class=\"sub\">{replay_pct}% of sessions</div></div>"
    h = "{h}<div class=\"card\"><h3>Degraded</h3><div class=\"value\" style=\"color:{degraded_css}\">{snapshot.degraded_sessions}</div><div class=\"sub\">{degraded_pct}% of sessions</div></div>"
    h = "{h}<div class=\"card\"><h3>Events</h3><div class=\"value\">{snapshot.total_events}</div><div class=\"sub\">Recent timeline and task tree are derived from transcript replay</div></div>"
    h = "{h}</div>"
    if snapshot.selected_session_id != "":
        val session = assistant_session_by_id(snapshot.sessions, snapshot.selected_session_id)
        if session != nil:
            h = "{h}<div class=\"card\" style=\"margin-top:12px\"><div class=\"section-title\">Focused Session</div><div class=\"sub\">{assistant_session_summary_html(session)}</div></div>"
    h

fn assistant_html_warnings(snapshot: AssistantDashboardSnapshot) -> text:
    var h = "<div class=\"card\" style=\"margin-top:12px\">"
    h = "{h}<div class=\"section-title\">Warnings</div>"
    for warning in snapshot.warnings:
        h = "{h}<div class=\"alert alert-warning\">{html_escape(warning)}</div>"
    h = "{h}</div>"
    h
