const AGENT_TOOL_SOURCE_LINES = 1397
const AGENT_TOOL_NAME = "Agent"
const LEGACY_AGENT_TOOL_NAME = "Task"

fn userFacingNameRoute(subagentType: text) -> text:
    if subagentType == "" || subagentType == "worker":
        return AGENT_TOOL_NAME
    subagentType

fn userFacingNameBackgroundColorRoute(subagentType: text) -> text:
    if subagentType == "":
        return "nil"
    if subagentType == "verification":
        return "blue"
    if subagentType == "plan":
        return "purple"
    "gray"

fn outputSchemaAcceptsRoute(status: text) -> bool:
    status == "completed" || status == "async_launched" || status == "remote_launched" || status == "rejected" || status == "error"

fn renderAgentResultRoute(status: text, taskId: text, sessionUrl: text, description: text, prompt: text, outputFile: text, toolUseCount: i64, tokenCount: i64, durationMs: i64) -> text:
    if status == "remote_launched":
        return "Remote agent launched " + taskId + " " + sessionUrl + " " + description + " " + prompt + " " + outputFile
    if status == "async_launched":
        return "Backgrounded agent " + prompt
    if status == "completed":
        return "Done (" + toolUseCount.to_text() + " tool uses · " + tokenCount.to_text() + " tokens · " + durationMs.to_text() + " ms)"
    if status == "rejected":
        return "Agent rejected"
    if status == "error":
        return "Agent error"
    "Unknown agent result"

fn renderToolUseRoute(description: text, prompt: text) -> text:
    if description == "" || prompt == "":
        return "nil"
    description + " " + prompt

fn renderToolUseTagRoute(mainModel: text, overrideModel: text) -> text:
    if overrideModel != "" && overrideModel != mainModel:
        return overrideModel
    "nil"

fn progressSummaryRoute(terminalTooSmall: bool) -> text:
    if terminalTooSmall:
        return "initializing"
    "expanded progress"

fn groupedUseRoute(allAsyncLaunches: bool) -> text:
    if allAsyncLaunches:
        return "background agents launched"
    "finished agents"

fn agentToolSourceLinesModeled() -> i64:
    AGENT_TOOL_SOURCE_LINES
