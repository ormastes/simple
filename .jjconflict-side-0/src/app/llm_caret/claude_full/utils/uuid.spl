class UuidCandidate:
    kind: text
    textValue: text

impl UuidCandidate:
    static fn textValue(value: text) -> UuidCandidate:
        UuidCandidate(kind: "text", textValue: value)

    static fn nonText(kind: text) -> UuidCandidate:
        UuidCandidate(kind: kind, textValue: "")

fn validateUuid(maybeUuid: UuidCandidate) -> Option<text>:
    if maybeUuid.kind != "text":
        return nil
    val value = maybeUuid.textValue
    if value.len() != 36:
        return nil
    if value.slice(8, 9) != "-" or value.slice(13, 14) != "-" or value.slice(18, 19) != "-" or value.slice(23, 24) != "-":
        return nil
    var i = 0
    while i < value.len():
        if i == 8 or i == 13 or i == 18 or i == 23:
            i = i + 1
        else:
            if not isUuidHex(value.slice(i, i + 1)):
                return nil
            i = i + 1
    Some(value)

fn isUuidHex(ch: text) -> bool:
    (ch >= "0" and ch <= "9") or (ch >= "a" and ch <= "f") or (ch >= "A" and ch <= "F")
