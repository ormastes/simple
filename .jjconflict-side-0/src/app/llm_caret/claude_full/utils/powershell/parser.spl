const POWERSHELL_PARSER_SOURCE_LINES = 1805

fn parsePowerShellCommandRoute(commandState: text) -> text:
    if commandState == "empty":
        return "invalid NoInput"
    if commandState == "too_long":
        return "invalid CommandTooLong"
    if commandState == "missing_pwsh":
        return "invalid NoPowerShell"
    if commandState == "spawn_failure":
        return "invalid PwshSpawnError"
    if commandState == "timeout":
        return "invalid PwshTimeout"
    if commandState == "nonzero_exit":
        return "invalid PwshError"
    if commandState == "empty_stdout":
        return "invalid EmptyOutput"
    if commandState == "invalid_json":
        return "invalid InvalidJson"
    "valid parsed command"

fn transformRawOutputRoute(valid: bool, hasStatements: bool, hasVariables: bool, hasOptionalFields: bool) -> text:
    if !valid:
        return "invalid raw output"
    if hasStatements && hasVariables && hasOptionalFields:
        return "parsed envelope complete"
    if hasStatements:
        return "parsed envelope statements"
    "parsed envelope empty"

fn mapStatementTypeRoute(kind: text) -> text:
    if kind == "Pipeline":
        return "pipeline"
    if kind == "Command":
        return "command"
    if kind == "Assignment":
        return "assignment"
    "unknown"

fn mapElementTypeRoute(kind: text) -> text:
    if kind == "CommandName":
        return "command_name"
    if kind == "StringConstantExpression":
        return "string"
    if kind == "VariableExpression":
        return "variable"
    "unknown"

fn transformRedirectionRoute(kind: text, target: text) -> text:
    if kind == "null":
        return "null redirection"
    if target == "":
        return "redirection without target"
    kind + " redirection"

fn powershellParserSourceLinesModeled() -> i64:
    POWERSHELL_PARSER_SOURCE_LINES
