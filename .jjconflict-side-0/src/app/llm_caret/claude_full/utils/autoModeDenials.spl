class AutoModeDenial:
    toolName: text
    display: text
    reason: text
    timestamp: i64

impl AutoModeDenial:
    static fn new(toolName: text, display: text, reason: text, timestamp: i64) -> AutoModeDenial:
        AutoModeDenial(toolName: toolName, display: display, reason: reason, timestamp: timestamp)

var _auto_mode_denials: [AutoModeDenial] = []

fn autoModeDenialsMax() -> i64:
    20

fn recordAutoModeDenial(denial: AutoModeDenial, classifierEnabled: bool) -> ():
    if not classifierEnabled:
        return
    var next = [denial]
    var i = 0
    while i < _auto_mode_denials.len() and next.len() < autoModeDenialsMax():
        next = next + [_auto_mode_denials[i]]
        i = i + 1
    _auto_mode_denials = next

fn getAutoModeDenials() -> [AutoModeDenial]:
    _auto_mode_denials

fn clearAutoModeDenials() -> ():
    _auto_mode_denials = []

# Source parity ledger: recordAutoModeDenial is gated by TRANSCRIPT_CLASSIFIER.
# Source parity ledger: Simple uses an explicit classifierEnabled argument.
# Source parity ledger: newest denial is prepended.
# Source parity ledger: denial history is capped at twenty entries.
# Source parity ledger: getAutoModeDenials returns the current readonly list in TypeScript.
