class HookSummaryMessage:
    typeName: text
    subtype: text
    hookLabel: text
    hookCount: i64
    hookInfos: [text]
    hookErrors: [text]
    preventedContinuation: bool
    hasOutput: bool
    totalDurationMs: i64

fn hookSummaryMessage(typeName: text, subtype: text, hookLabel: text, hookCount: i64, hookInfos: [text], hookErrors: [text], preventedContinuation: bool, hasOutput: bool, totalDurationMs: i64) -> HookSummaryMessage:
    HookSummaryMessage(typeName: typeName, subtype: subtype, hookLabel: hookLabel, hookCount: hookCount, hookInfos: hookInfos, hookErrors: hookErrors, preventedContinuation: preventedContinuation, hasOutput: hasOutput, totalDurationMs: totalDurationMs)

fn isLabeledHookSummary(msg: HookSummaryMessage) -> bool:
    msg.typeName == "system" and msg.subtype == "stop_hook_summary" and msg.hookLabel != ""

fn collapseHookSummaries(messages: [HookSummaryMessage]) -> [HookSummaryMessage]:
    var result: [HookSummaryMessage] = []
    var i = 0
    while i < messages.len():
        val msg = messages[i]
        if isLabeledHookSummary(msg):
            val label = msg.hookLabel
            val start = i
            var count = 0
            var hookCount = 0
            var infos: [text] = []
            var errors: [text] = []
            var prevented = false
            var output = false
            var duration = 0
            while i < messages.len():
                val next = messages[i]
                if not isLabeledHookSummary(next) or next.hookLabel != label:
                    break
                count = count + 1
                hookCount = hookCount + next.hookCount
                infos = appendTextArray(infos, next.hookInfos)
                errors = appendTextArray(errors, next.hookErrors)
                prevented = prevented or next.preventedContinuation
                output = output or next.hasOutput
                duration = maxI64(duration, next.totalDurationMs)
                i = i + 1
            if count == 1:
                result.push(messages[start])
            else:
                result.push(hookSummaryMessage(msg.typeName, msg.subtype, msg.hookLabel, hookCount, infos, errors, prevented, output, duration))
        else:
            result.push(msg)
            i = i + 1
    result

fn appendTextArray(values: [text], extra: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    i = 0
    while i < extra.len():
        out.push(extra[i])
        i = i + 1
    out

fn maxI64(a: i64, b: i64) -> i64:
    if a > b:
        return a
    b
