class AutoUpdaterError:
    name: text
    message: text

impl AutoUpdaterError:
    static fn new(message: text) -> AutoUpdaterError: AutoUpdaterError(name: "AutoUpdaterError", message: message)

class AutoUpdaterResult:
    version: text
    status: text
    notifications: [text]

impl AutoUpdaterResult:
    static fn new(version: text, status: text, notifications: [text]) -> AutoUpdaterResult: AutoUpdaterResult(version: version, status: status, notifications: notifications)

class MaxVersionConfig:
    external: text
    ant: text
    externalMessage: text
    antMessage: text

impl MaxVersionConfig:
    static fn new(external: text, ant: text, externalMessage: text, antMessage: text) -> MaxVersionConfig: MaxVersionConfig(external: external, ant: ant, externalMessage: externalMessage, antMessage: antMessage)

fn gcsBucketUrl() -> text:
    "https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases"

fn isInstallStatus(value: text) -> bool:
    value == "success" or value == "no_permissions" or value == "install_failed" or value == "in_progress"

