use app.llm_caret.claude_full.utils.format.{formatFileSize}

fn getFormatDescription(kind: text, schema: Option<text>) -> text:
    if kind == "toolResult":
        return "Plain text"
    val schemaText = schema ?? ""
    if kind == "structuredContent":
        if schemaText != "":
            return "JSON with schema: " + schemaText
        return "JSON"
    if kind == "contentArray":
        if schemaText != "":
            return "JSON array with schema: " + schemaText
        return "JSON array"
    ""

fn _formatIntWithCommas(value: i64) -> text:
    val raw = value.to_text()
    var result = ""
    var i = raw.len() - 1
    var group = 0
    while i >= 0:
        if group == 3:
            result = "," + result
            group = 0
        result = raw[i:i + 1] + result
        group = group + 1
        i = i - 1
    result

fn getLargeOutputInstructions(rawOutputPath: text, contentLength: i64, formatDescription: text, maxReadLength: Option<i64>) -> text:
    val baseInstructions =
        "Error: result (" + _formatIntWithCommas(contentLength) + " characters) exceeds maximum allowed tokens. Output has been saved to " + rawOutputPath + ".\n" +
        "Format: " + formatDescription + "\n" +
        "Use offset and limit parameters to read specific portions of the file, search within it for specific content, and jq to make structured queries.\n" +
        "REQUIREMENTS FOR SUMMARIZATION/ANALYSIS/REVIEW:\n" +
        "- You MUST read the content from the file at " + rawOutputPath + " in sequential chunks until 100% of the content has been read.\n"

    val limit = maxReadLength ?? 0
    var truncationWarning = "- If you receive truncation warnings when reading the file, reduce the chunk size until you have read 100% of the content without truncation.\n"
    if limit > 0:
        truncationWarning = "- If you receive truncation warnings when reading the file (\"[N lines truncated]\"), reduce the chunk size until you have read 100% of the content without truncation ***DO NOT PROCEED UNTIL YOU HAVE DONE THIS***. Bash output is limited to " + _formatIntWithCommas(limit) + " chars.\n"

    val completionRequirement = "- Before producing ANY summary or analysis, you MUST explicitly describe what portion of the content you have read. ***If you did not read the entire content, you MUST explicitly state this.***\n"
    baseInstructions + truncationWarning + completionRequirement

fn extensionForMimeType(mimeType: Option<text>) -> text:
    if val value = mimeType:
        val mt = value.split(";")[0].trim().lower()
        if mt == "application/pdf":
            return "pdf"
        if mt == "application/json":
            return "json"
        if mt == "text/csv":
            return "csv"
        if mt == "text/plain":
            return "txt"
        if mt == "text/html":
            return "html"
        if mt == "text/markdown":
            return "md"
        if mt == "application/zip":
            return "zip"
        if mt == "application/vnd.openxmlformats-officedocument.wordprocessingml.document":
            return "docx"
        if mt == "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet":
            return "xlsx"
        if mt == "application/vnd.openxmlformats-officedocument.presentationml.presentation":
            return "pptx"
        if mt == "application/msword":
            return "doc"
        if mt == "application/vnd.ms-excel":
            return "xls"
        if mt == "audio/mpeg":
            return "mp3"
        if mt == "audio/wav":
            return "wav"
        if mt == "audio/ogg":
            return "ogg"
        if mt == "video/mp4":
            return "mp4"
        if mt == "video/webm":
            return "webm"
        if mt == "image/png":
            return "png"
        if mt == "image/jpeg":
            return "jpg"
        if mt == "image/gif":
            return "gif"
        if mt == "image/webp":
            return "webp"
        if mt == "image/svg+xml":
            return "svg"
    "bin"

fn isBinaryContentType(contentType: text) -> bool:
    if contentType == "":
        return false
    val mt = contentType.split(";")[0].trim().lower()
    if mt.starts_with("text/"):
        return false
    if mt.ends_with("+json") or mt == "application/json":
        return false
    if mt.ends_with("+xml") or mt == "application/xml":
        return false
    if mt.starts_with("application/javascript"):
        return false
    if mt == "application/x-www-form-urlencoded":
        return false
    true

fn getBinaryBlobSavedMessage(filepath: text, mimeType: Option<text>, size: i64, sourceDescription: text) -> text:
    val mt = mimeType ?? "unknown type"
    sourceDescription + "Binary content (" + mt + ", " + formatFileSize(size) + ") saved to " + filepath

export getFormatDescription, getLargeOutputInstructions
export extensionForMimeType, isBinaryContentType
export getBinaryBlobSavedMessage
