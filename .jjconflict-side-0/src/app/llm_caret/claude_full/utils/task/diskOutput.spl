"""
Claude full disk task output parity surface.
"""

const DEFAULT_MAX_READ_BYTES = 8388608
const MAX_TASK_OUTPUT_BYTES = 5368709120
const MAX_TASK_OUTPUT_BYTES_DISPLAY = "5GB"

class DiskTaskOutput:
    path: text
    queue: [text]
    bytesWritten: i64
    capped: bool
    initialized: bool
    canceled: bool
    flushedChunks: [text]

impl DiskTaskOutput:
    static fn new(taskId: text, taskOutputDir: text) -> DiskTaskOutput:
        DiskTaskOutput(path: getTaskOutputPath(taskOutputDir, taskId), queue: [], bytesWritten: 0, capped: false, initialized: false, canceled: false, flushedChunks: [])

    fn append(content: text) -> DiskTaskOutput:
        var next = self.copy()
        if next.capped:
            return next
        next.bytesWritten = next.bytesWritten + content.len()
        if next.bytesWritten > MAX_TASK_OUTPUT_BYTES:
            next.capped = true
            next.queue.push("\n[output truncated: exceeded " + MAX_TASK_OUTPUT_BYTES_DISPLAY + " disk cap]\n")
        else:
            next.queue.push(content)
        next.initialized = true
        next

    fn flush() -> DiskTaskOutput:
        var next = self.copy()
        var i = 0
        while i < next.queue.len():
            next.flushedChunks.push(next.queue[i])
            i = i + 1
        next.queue = []
        next

    fn cancel() -> DiskTaskOutput:
        var next = self.copy()
        next.queue = []
        next.canceled = true
        next

    fn getStdout(maxReadBytes: i64) -> text:
        val joined = joinTaskChunks(self.flushedChunks)
        if maxReadBytes > 0 and joined.len() > maxReadBytes:
            return joined.slice(joined.len() - maxReadBytes, joined.len())
        joined

    fn copy() -> DiskTaskOutput:
        DiskTaskOutput(
            path: self.path,
            queue: copyTaskChunks(self.queue),
            bytesWritten: self.bytesWritten,
            capped: self.capped,
            initialized: self.initialized,
            canceled: self.canceled,
            flushedChunks: copyTaskChunks(self.flushedChunks),
        )

fn getTaskOutputDir(projectTempDir: text, sessionId: text) -> text:
    projectTempDir + "/" + sessionId + "/tasks"

fn getTaskOutputPath(taskOutputDir: text, taskId: text) -> text:
    taskOutputDir + "/" + taskId + ".output"

fn makeTaskOutputTruncationMessage() -> text:
    "\n[output truncated: exceeded " + MAX_TASK_OUTPUT_BYTES_DISPLAY + " disk cap]\n"

fn copyTaskChunks(values: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn joinTaskChunks(values: [text]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        out = out + values[i]
        i = i + 1
    out

fn diskOutputSourceLinesModeled() -> i64:
    451
