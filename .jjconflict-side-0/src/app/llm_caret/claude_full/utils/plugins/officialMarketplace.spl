"""
Claude full official marketplace constants.
"""

class OfficialMarketplaceSource:
    source: text
    repo: text

fn officialMarketplaceSource() -> OfficialMarketplaceSource:
    OfficialMarketplaceSource(source: "github", repo: "anthropics/claude-plugins-official")

fn officialMarketplaceName() -> text:
    "claude-plugins-official"
