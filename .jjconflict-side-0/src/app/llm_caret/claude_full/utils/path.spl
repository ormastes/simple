"""
Claude full path utility parity.
"""

fn containsPathTraversal(path: text) -> bool:
    var segment = ""
    var i = 0
    while i < path.len():
        val ch = path.slice(i, i + 1)
        if ch == "/" or ch == "\\":
            if segment == "..":
                return true
            segment = ""
        else:
            segment = segment + ch
        i = i + 1
    segment == ".."
