class DenialTrackingState:
    consecutiveDenials: i64
    totalDenials: i64

    static fn new(consecutiveDenials: i64, totalDenials: i64) -> DenialTrackingState:
        DenialTrackingState(consecutiveDenials: consecutiveDenials, totalDenials: totalDenials)

fn denialMaxConsecutive() -> i64:
    3

fn denialMaxTotal() -> i64:
    20

fn createDenialTrackingState() -> DenialTrackingState:
    DenialTrackingState.new(0, 0)

fn recordDenial(state: DenialTrackingState) -> DenialTrackingState:
    DenialTrackingState.new(state.consecutiveDenials + 1, state.totalDenials + 1)

fn recordSuccess(state: DenialTrackingState) -> DenialTrackingState:
    if state.consecutiveDenials == 0:
        return state
    DenialTrackingState.new(0, state.totalDenials)

fn shouldFallbackToPrompting(state: DenialTrackingState) -> bool:
    state.consecutiveDenials >= denialMaxConsecutive() or state.totalDenials >= denialMaxTotal()
