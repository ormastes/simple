"""
Claude full slow operation logging parity surface.
"""

class SlowOperation:
    description: text
    durationMs: f64

impl SlowOperation:
    static fn new(description: text, durationMs: f64) -> SlowOperation:
        SlowOperation(description: description, durationMs: durationMs)

class TemplateValue:
    kind: text
    value: text
    size: i64

impl TemplateValue:
    static fn scalar(value: text) -> TemplateValue:
        TemplateValue(kind: "scalar", value: value, size: 0)

    static fn string(value: text) -> TemplateValue:
        TemplateValue(kind: "string", value: value, size: value.len())

    static fn array(size: i64) -> TemplateValue:
        TemplateValue(kind: "array", value: "", size: size)

    static fn object(keyCount: i64) -> TemplateValue:
        TemplateValue(kind: "object", value: "", size: keyCount)

class AntSlowLogger:
    startTimeMs: f64
    strings: [text]
    values: [TemplateValue]
    stack: text
    thresholdMs: f64
    isLogging: bool
    loggedOperations: [SlowOperation]

impl AntSlowLogger:
    static fn new(startTimeMs: f64, strings: [text], values: [TemplateValue], stack: text, thresholdMs: f64) -> AntSlowLogger:
        AntSlowLogger(startTimeMs: startTimeMs, strings: strings, values: values, stack: stack, thresholdMs: thresholdMs, isLogging: false, loggedOperations: [])

    me dispose(nowMs: f64) -> bool:
        val duration = nowMs - me.startTimeMs
        if duration > me.thresholdMs and not me.isLogging:
            me.isLogging = true
            val description = buildDescription(me.strings, me.values) + callerFrame(me.stack)
            me.loggedOperations.push(SlowOperation.new(description, duration))
            me.isLogging = false
            return true
        false

    me lastDescription() -> text:
        if me.loggedOperations.len() == 0:
            return ""
        me.loggedOperations[me.loggedOperations.len() - 1].description

    me lastDurationMs() -> f64:
        if me.loggedOperations.len() == 0:
            return 0.0
        me.loggedOperations[me.loggedOperations.len() - 1].durationMs

class NoopSlowLogger:
    disposed: bool

impl NoopSlowLogger:
    static fn new() -> NoopSlowLogger:
        NoopSlowLogger(disposed: false)

    me dispose(_nowMs: f64) -> bool:
        me.disposed = true
        false

fn slowOperationThresholdMs(envValue: text, nodeEnv: text, userType: text) -> f64:
    if val value = envValue.parse_f64():
        if value >= 0.0:
            return value
    if nodeEnv == "development":
        return 20.0
    if userType == "ant":
        return 300.0
    999999999999.0

fn callerFrame(stack: text) -> text:
    if stack == "":
        return ""
    val lines = stack.split("\n")
    for line in lines:
        if line.contains("slowOperations"):
            continue
        val trimmed = line.trim()
        if trimmed.contains(":"):
            return " @ " + trimmed
    ""

fn renderTemplateValue(value: TemplateValue) -> text:
    if value.kind == "array":
        return "Array[{value.size}]"
    if value.kind == "object":
        return "Object{" + value.size.to_text() + " keys}"
    if value.kind == "string":
        if value.value.len() > 80:
            return value.value.slice(0, 80) + "..."
        return value.value
    value.value

fn buildDescription(strings: [text], values: [TemplateValue]) -> text:
    var result = ""
    var i = 0
    while i < strings.len():
        result = result + strings[i]
        if i < values.len():
            result = result + renderTemplateValue(values[i])
        i = i + 1
    result

fn slowLoggingAnt(startTimeMs: f64, strings: [text], values: [TemplateValue], stack: text, thresholdMs: f64) -> AntSlowLogger:
    AntSlowLogger.new(startTimeMs, strings, values, stack, thresholdMs)

fn slowLoggingExternal() -> NoopSlowLogger:
    NoopSlowLogger.new()

fn slowOperationsSourceLinesModeled() -> i64:
    286
