class DirectMemberMessage:
    recipient_name: text
    message: text

fn parse_direct_member_message(input: text) -> Option<DirectMemberMessage>:
    if input.len() < 4:
        return nil
    if input.slice(0, 1) != "@":
        return nil

    var i = 1
    while i < input.len() and isDirectMemberNameChar(input.slice(i, i + 1)):
        i = i + 1
    if i == 1:
        return nil
    if i >= input.len() or not isDirectMemberWhitespace(input.slice(i, i + 1)):
        return nil

    val message = input.slice(i + 1, input.len()).trim()
    if message == "":
        return nil
    DirectMemberMessage(recipient_name: input.slice(1, i), message: message)

fn isDirectMemberNameChar(ch: text) -> bool:
    (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or (ch >= "0" and ch <= "9") or ch == "_" or ch == "-"

fn isDirectMemberWhitespace(ch: text) -> bool:
    val code = ch.char_code_at(0)
    code == 9 or code == 10 or code == 11 or code == 12 or code == 13 or code == 32
