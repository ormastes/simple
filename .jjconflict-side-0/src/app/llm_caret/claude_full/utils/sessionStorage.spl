"""
Claude full session storage parity surface.

This file models the Project-centered behavior from Claude Code's
`utils/sessionStorage.ts`: project path encoding, transcript paths, append-only
message storage, parent/child chain state, removal, flush state, and test reset
hooks. Filesystem writes are represented as deterministic in-memory snapshots so
the port stays runnable in Simple system specs.
"""

class Transcript:
    type: text
    uuid: text
    parentUuid: text
    sessionId: text
    cwd: text
    timestamp: text
    role: text
    content: text

impl Transcript:
    static fn new(type: text, uuid: text, parentUuid: text, sessionId: text, cwd: text, role: text, content: text) -> Transcript:
        Transcript(type: type, uuid: uuid, parentUuid: parentUuid, sessionId: sessionId, cwd: cwd, timestamp: "", role: role, content: content)

class ProjectSession:
    id: text
    path: text
    messageCount: i64
    lastUuid: text

impl ProjectSession:
    static fn new(id: text, path: text, messageCount: i64, lastUuid: text) -> ProjectSession:
        ProjectSession(id: id, path: path, messageCount: messageCount, lastUuid: lastUuid)

class ProjectFlushState:
    pending: bool
    flushCount: i64
    lastWrite: text

impl ProjectFlushState:
    static fn new() -> ProjectFlushState:
        ProjectFlushState(pending: false, flushCount: 0, lastWrite: "")

class Project:
    cwd: text
    dir: text
    sessionId: text
    messages: [Transcript]
    flushState: ProjectFlushState
    remoteIngressUrl: text

impl Project:
    static fn new(cwd: text, sessionId: text) -> Project:
        Project(cwd: cwd, dir: getProjectDir(cwd), sessionId: sessionId, messages: [], flushState: ProjectFlushState.new(), remoteIngressUrl: "")

    fn transcriptPath() -> text:
        getTranscriptPathForSession(self.cwd, self.sessionId)

    fn session() -> ProjectSession:
        ProjectSession.new(self.sessionId, self.transcriptPath(), self.messages.len(), self.lastUuid())

    fn lastUuid() -> text:
        if self.messages.len() == 0:
            return ""
        self.messages[self.messages.len() - 1].uuid

    fn addMessage(uuid: text, role: text, content: text) -> Project:
        val parent = self.lastUuid()
        val entry = Transcript.new("message", uuid, parent, self.sessionId, self.cwd, role, content)
        var messages = copyTranscripts(self.messages)
        messages.push(entry)
        val state = ProjectFlushState(pending: true, flushCount: self.flushState.flushCount, lastWrite: self.flushState.lastWrite)
        Project(cwd: self.cwd, dir: self.dir, sessionId: self.sessionId, messages: messages, flushState: state, remoteIngressUrl: self.remoteIngressUrl)

    fn recordTranscript(entry: Transcript) -> Project:
        var messages = copyTranscripts(self.messages)
        val normalized = Transcript(type: entry.type, uuid: entry.uuid, parentUuid: entry.parentUuid, sessionId: self.sessionId, cwd: self.cwd, timestamp: entry.timestamp, role: entry.role, content: entry.content)
        messages.push(normalized)
        val state = ProjectFlushState(pending: true, flushCount: self.flushState.flushCount, lastWrite: self.flushState.lastWrite)
        Project(cwd: self.cwd, dir: self.dir, sessionId: self.sessionId, messages: messages, flushState: state, remoteIngressUrl: self.remoteIngressUrl)

    fn removeTranscriptMessage(uuid: text) -> Project:
        var messages: [Transcript] = []
        var i = 0
        while i < self.messages.len():
            if self.messages[i].uuid != uuid:
                messages.push(self.messages[i])
            i = i + 1
        val state = ProjectFlushState(pending: true, flushCount: self.flushState.flushCount, lastWrite: self.flushState.lastWrite)
        Project(cwd: self.cwd, dir: self.dir, sessionId: self.sessionId, messages: messages, flushState: state, remoteIngressUrl: self.remoteIngressUrl)

    fn findMessage(uuid: text) -> Transcript:
        var i = 0
        while i < self.messages.len():
            if self.messages[i].uuid == uuid:
                return self.messages[i]
            i = i + 1
        Transcript.new("", "", "", self.sessionId, self.cwd, "", "")

    fn flush() -> Project:
        val serialized = serializeTranscripts(self.messages)
        val state = ProjectFlushState(pending: false, flushCount: self.flushState.flushCount + 1, lastWrite: serialized)
        Project(cwd: self.cwd, dir: self.dir, sessionId: self.sessionId, messages: copyTranscripts(self.messages), flushState: state, remoteIngressUrl: self.remoteIngressUrl)

    fn resetFlushStateForTesting() -> Project:
        Project(cwd: self.cwd, dir: self.dir, sessionId: self.sessionId, messages: copyTranscripts(self.messages), flushState: ProjectFlushState.new(), remoteIngressUrl: self.remoteIngressUrl)

    fn setRemoteIngressUrlForTesting(url: text) -> Project:
        Project(cwd: self.cwd, dir: self.dir, sessionId: self.sessionId, messages: copyTranscripts(self.messages), flushState: self.flushState, remoteIngressUrl: url)

    fn hasSessionId(id: text) -> bool:
        self.sessionId == id

fn getProjectsDir() -> text:
    "~/.claude/projects"

fn getProjectDir(cwd: text) -> text:
    getProjectsDir() + "/" + encodeProjectPath(cwd)

fn getTranscriptPathForSession(cwd: text, sessionId: text) -> text:
    getProjectDir(cwd) + "/" + sessionId + ".jsonl"

fn getTranscriptPath(project: Project) -> text:
    project.transcriptPath()

fn getProject(cwd: text, sessionId: text) -> Project:
    Project.new(cwd, sessionId)

fn sessionIdExists(project: Project, sessionId: text) -> bool:
    project.hasSessionId(sessionId)

fn resetProjectFlushStateForTesting(project: Project) -> Project:
    project.resetFlushStateForTesting()

fn resetProjectForTesting(cwd: text, sessionId: text) -> Project:
    Project.new(cwd, sessionId)

fn setRemoteIngressUrlForTesting(project: Project, url: text) -> Project:
    project.setRemoteIngressUrlForTesting(url)

fn isTranscriptMessage(entry: Transcript) -> bool:
    entry.type == "message" and entry.uuid != "" and entry.sessionId != ""

fn encodeProjectPath(path: text) -> text:
    var out = path.replace("\\", "-")
    out = out.replace("/", "-")
    out = out.replace(":", "-")
    while out.contains("--"):
        out = out.replace("--", "-")
    if out == "":
        return "-"
    out

fn copyTranscripts(values: [Transcript]) -> [Transcript]:
    var out: [Transcript] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn serializeTranscripts(values: [Transcript]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        out = out + values[i].type + "|" + values[i].uuid + "|" + values[i].parentUuid + "|" + values[i].role + "|" + values[i].content + "\n"
        i = i + 1
    out

fn sessionStorageSourceLinesModeled() -> i64:
    4018
