"""
Claude full telemetry instrumentation parity surface.
"""

const DEFAULT_METRICS_EXPORT_INTERVAL_MS = 60000
const DEFAULT_LOGS_EXPORT_INTERVAL_MS = 5000
const DEFAULT_TRACES_EXPORT_INTERVAL_MS = 5000

class TelemetryTimeoutError:
    name: text
    message: text

impl TelemetryTimeoutError:
    static fn new(message: text) -> TelemetryTimeoutError:
        TelemetryTimeoutError(name: "TelemetryTimeoutError", message: message)

class TelemetryBootstrapEnv:
    userType: text
    antMetricsExporter: text
    antLogsExporter: text
    antTracesExporter: text
    antOtlpProtocol: text
    antOtlpEndpoint: text
    antOtlpHeaders: text
    metricsExporter: text
    logsExporter: text
    tracesExporter: text
    otlpProtocol: text
    otlpEndpoint: text
    otlpHeaders: text
    temporalityPreference: text

impl TelemetryBootstrapEnv:
    static fn new(userType: text) -> TelemetryBootstrapEnv:
        TelemetryBootstrapEnv(userType: userType, antMetricsExporter: "", antLogsExporter: "", antTracesExporter: "", antOtlpProtocol: "", antOtlpEndpoint: "", antOtlpHeaders: "", metricsExporter: "", logsExporter: "", tracesExporter: "", otlpProtocol: "", otlpEndpoint: "", otlpHeaders: "", temporalityPreference: "")

    fn bootstrapTelemetry() -> TelemetryBootstrapEnv:
        var next = self.copy()
        if next.userType == "ant":
            if next.antMetricsExporter != "":
                next.metricsExporter = next.antMetricsExporter
            if next.antLogsExporter != "":
                next.logsExporter = next.antLogsExporter
            if next.antTracesExporter != "":
                next.tracesExporter = next.antTracesExporter
            if next.antOtlpProtocol != "":
                next.otlpProtocol = next.antOtlpProtocol
            if next.antOtlpEndpoint != "":
                next.otlpEndpoint = next.antOtlpEndpoint
            if next.antOtlpHeaders != "":
                next.otlpHeaders = next.antOtlpHeaders
        if next.temporalityPreference == "":
            next.temporalityPreference = "delta"
        next

    fn copy() -> TelemetryBootstrapEnv:
        TelemetryBootstrapEnv(userType: self.userType, antMetricsExporter: self.antMetricsExporter, antLogsExporter: self.antLogsExporter, antTracesExporter: self.antTracesExporter, antOtlpProtocol: self.antOtlpProtocol, antOtlpEndpoint: self.antOtlpEndpoint, antOtlpHeaders: self.antOtlpHeaders, metricsExporter: self.metricsExporter, logsExporter: self.logsExporter, tracesExporter: self.tracesExporter, otlpProtocol: self.otlpProtocol, otlpEndpoint: self.otlpEndpoint, otlpHeaders: self.otlpHeaders, temporalityPreference: self.temporalityPreference)

fn telemetryTimeout(ms: i64, message: text) -> TelemetryTimeoutError:
    TelemetryTimeoutError.new(message)

fn parseExporterTypes(value: text) -> [text]:
    var out: [text] = []
    val trimmed = value.trim()
    val parts = trimmed.split(",")
    var i = 0
    while i < parts.len():
        val part = parts[i].trim()
        if part != "" and part != "none":
            out.push(part)
        i = i + 1
    out

