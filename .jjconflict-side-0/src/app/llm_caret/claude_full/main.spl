const CLAUDE_MAIN_SOURCE_LINES = 4683

class PendingConnect:
    target: text
    timeoutMs: i64

impl PendingConnect:
    static fn new(target: text, timeoutMs: i64) -> PendingConnect:
        PendingConnect(target: target, timeoutMs: timeoutMs)

class PendingAssistantChat:
    prompt: text
    headless: bool

impl PendingAssistantChat:
    static fn new(prompt: text, headless: bool) -> PendingAssistantChat:
        PendingAssistantChat(prompt: prompt, headless: headless)

class PendingSSH:
    host: text
    port: i64

impl PendingSSH:
    static fn new(host: text, port: i64) -> PendingSSH:
        PendingSSH(host: host, port: port)

class TeammateOptions:
    enabled: bool
    mode: text

impl TeammateOptions:
    static fn new(enabled: bool, mode: text) -> TeammateOptions:
        TeammateOptions(enabled: enabled, mode: mode)

fn getTeammateUtilsRoute(enabled: bool) -> text:
    if enabled:
        return "teammate utils enabled"
    "teammate utils disabled"

fn getTeammatePromptAddendumRoute(mode: text) -> text:
    if mode == "brief":
        return "teammate brief addendum"
    if mode == "full":
        return "teammate full addendum"
    "no teammate addendum"

fn getTeammateModeSnapshotRoute(enabled: bool, mode: text) -> text:
    if enabled:
        return "teammate mode " + mode
    "teammate off"

fn logManagedSettingsRoute(hasManaged: bool, verbose: bool) -> text:
    if hasManaged && verbose:
        return "log managed settings verbose"
    if hasManaged:
        return "log managed settings"
    "no managed settings log"

fn isBeingDebuggedRoute(hasInspectArg: bool, envDebug: bool) -> bool:
    hasInspectArg || envDebug

fn hasInspectArgRoute(args: text) -> bool:
    args.contains("--inspect")

fn logStartupTelemetryRoute(headless: bool, sdkUrl: bool, certEnv: bool) -> text:
    if headless:
        return "startup telemetry headless"
    if sdkUrl:
        return "startup telemetry sdk"
    if certEnv:
        return "startup telemetry cert env"
    "startup telemetry interactive"

fn runMigrationsRoute(settingsLoaded: bool, migrationNeeded: bool) -> text:
    if !settingsLoaded:
        return "skip migrations before settings"
    if migrationNeeded:
        return "run migrations"
    "migrations current"

fn prefetchSystemContextIfSafeRoute(headless: bool, offline: bool, trusted: bool) -> text:
    if headless || offline || !trusted:
        return "skip unsafe prefetch"
    "prefetch system context"

fn startDeferredPrefetchesRoute(hasNetwork: bool, hasPlugins: bool) -> text:
    if hasNetwork && hasPlugins:
        return "prefetch network plugins"
    if hasNetwork:
        return "prefetch network"
    "defer no prefetch"

fn loadSettingsFromFlagRoute(hasFlag: bool, valid: bool) -> text:
    if !hasFlag:
        return "load default settings"
    if valid:
        return "load settings from flag"
    "settings flag error"

fn loadSettingSourcesFromFlagRoute(hasSources: bool, hasErrors: bool) -> text:
    if hasErrors:
        return "format setting source errors"
    if hasSources:
        return "load setting sources"
    "no setting source flag"

fn initializeEntrypointRoute(debugged: bool, migrationsOk: bool) -> text:
    if debugged:
        return "debug gate exits before normal setup"
    if !migrationsOk:
        return "initialize entrypoint migration failure"
    "initialize entrypoint"

fn entrypointModeRoute(printMode: bool, initOnly: bool, sdkUrl: bool, stdinTTY: bool) -> text:
    if printMode:
        return "print forces non interactive entrypoint"
    if initOnly:
        return "init only entrypoint"
    if sdkUrl:
        return "sdk url non interactive entrypoint"
    if !stdinTTY:
        return "non tty non interactive entrypoint"
    "interactive entrypoint"

fn argvRewriteRoute(arg: text) -> text:
    if arg.starts_with("cc://") || arg.starts_with("cc+unix://"):
        return "rewrite cc deep link"
    if arg == "assistant":
        return "rewrite assistant pending chat"
    if arg == "ssh":
        return "rewrite ssh pending connection"
    "normal argv"

fn preActionReadinessRoute(mdm: bool, keychain: bool, initialized: bool, migrations: bool, startupSync: bool) -> text:
    if mdm && keychain && initialized && migrations && startupSync:
        return "preAction readiness complete"
    "preAction waits for startup readiness"

fn mainRoute(help: bool, version: bool, headless: bool, repl: bool) -> text:
    if help:
        return "print help"
    if version:
        return "print version"
    if headless:
        return "run headless query"
    if repl:
        return "launch repl"
    "run default main"

fn printModeRoute(printMode: bool, ccUrl: bool) -> text:
    if printMode && !ccUrl:
        return "print fast path skips subcommand parse"
    if printMode:
        return "print deep link parse path"
    "normal parser dispatch"

fn headlessContractRoute(streamJson: bool, json: bool, inputOk: bool, outputOk: bool) -> text:
    if (streamJson || json) && (!inputOk || !outputOk):
        return "reject invalid headless json contract"
    if streamJson:
        return "stream json headless contract"
    if json:
        return "json headless contract"
    "text headless contract"

fn headlessExecutionRoute(nonInteractive: bool, continuation: bool, sdk: bool) -> text:
    if !nonInteractive:
        return "not headless execution"
    if continuation:
        return "runHeadless continuation"
    if sdk:
        return "runHeadless sdk"
    "runHeadless query"

fn fileAuthRoute(hasFile: bool, hasSessionToken: bool) -> text:
    if hasFile && !hasSessionToken:
        return "file flag hard error missing session token"
    if hasFile:
        return "file flag authorized"
    "no file flag"

fn mcpConfigPolicyRoute(validJson: bool, reservedName: bool, enterpriseBlocked: bool) -> text:
    if !validJson:
        return "mcp config invalid exits"
    if reservedName:
        return "mcp reserved name blocked"
    if enterpriseBlocked:
        return "mcp enterprise combination blocked"
    "mcp config accepted"

fn getInputPromptRoute(stdinTTY: bool, promptArg: bool) -> text:
    if promptArg:
        return "use prompt arg"
    if stdinTTY:
        return "prompt interactively"
    "read stdin prompt"

fn runRoute(configOk: bool, commandMode: bool, headless: bool) -> text:
    if !configOk:
        return "exit config error"
    if commandMode:
        return "run command mode"
    if headless:
        return "run headless mode"
    "run interactive mode"

fn parseChannelEntriesRoute(entries: i64, invalid: bool) -> text:
    if invalid:
        return "channel parse error"
    if entries > 0:
        return "parsed channel entries"
    "no channel entries"

fn connectMcpBatchRoute(configCount: i64, timedOut: bool) -> text:
    if timedOut:
        return "mcp connect timeout"
    if configCount > 0:
        return "connect mcp batch"
    "no mcp configs"

fn mcpRuntimeRoute(interactive: bool, claudeAi: bool, duplicate: bool, timedOut: bool) -> text:
    if duplicate:
        return "mcp duplicate signature cleanup"
    if timedOut:
        return "claudeai bounded timeout"
    if interactive && claudeAi:
        return "interactive merge claudeai connectors"
    if !interactive:
        return "headless wait regular mcp"
    "interactive local mcp"

fn claudeaiConnectRoute(hasUrl: bool, timedOut: bool) -> text:
    if timedOut:
        return "claudeai connect timeout"
    if hasUrl:
        return "connect claudeai remote"
    "skip claudeai connect"

fn remotePolicyRoute(remote: bool, policyAllowed: bool, hasDescriptor: bool) -> text:
    if remote && !policyAllowed:
        return "remote policy denied"
    if remote && !hasDescriptor:
        return "remote missing descriptor hard fail"
    if remote:
        return "remote session allowed"
    "not remote"

fn getAccessTokenRoute(hasCached: bool, remote: bool, failed: bool) -> text:
    if failed:
        return "access token failed"
    if remote:
        return "access token for remote"
    if hasCached:
        return "cached access token"
    "request access token"

fn shutdownRoute(hasSessionHooks: bool, hasMcp: bool, signal: text) -> text:
    if signal != "":
        return "shutdown from signal"
    if hasSessionHooks:
        return "run session end hooks shutdown"
    if hasMcp:
        return "shutdown mcp clients"
    "shutdown clean"

fn maybeActivateProactiveRoute(enabled: bool, hasPrompt: bool) -> text:
    if enabled && hasPrompt:
        return "activate proactive mode"
    if enabled:
        return "proactive waiting"
    "proactive disabled"

fn maybeActivateBriefRoute(enabled: bool, hasContext: bool) -> text:
    if enabled && hasContext:
        return "activate brief mode"
    if enabled:
        return "brief waiting"
    "brief disabled"

fn extractTeammateOptionsRoute(cowork: bool, brief: bool) -> text:
    if cowork && brief:
        return "teammate cowork brief"
    if cowork:
        return "teammate cowork"
    if brief:
        return "teammate brief"
    "no teammate options"

fn teammateFlagValidationRoute(agentId: bool, agentName: bool, teamName: bool) -> text:
    if agentId && agentName && teamName:
        return "teammate flags complete"
    if agentId || agentName || teamName:
        return "teammate flags partial hard fail"
    "no teammate flags"

fn mainSourceLinesModeled() -> i64:
    CLAUDE_MAIN_SOURCE_LINES
