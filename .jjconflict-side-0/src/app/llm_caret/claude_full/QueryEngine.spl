"""
QueryEngine parity model for Claude SDK/headless query lifecycle.

Models the stateful public contract: mutable messages, permission denials,
usage accumulation, structured-output hook decision, interrupt, model changes,
read-file cache preservation, and one-shot ask wrapper behavior.
"""

class QueryEngineConfig:
    cwd: text
    tools: [text]
    commands: [text]
    mcpClients: [text]
    agents: [text]
    initialMessages: [text]
    readFileCache: text
    customSystemPrompt: text
    appendSystemPrompt: text
    userSpecifiedModel: text
    fallbackModel: text
    thinkingConfig: text
    maxTurns: i64
    maxBudgetUsd: i64
    taskBudgetTotal: i64
    jsonSchema: text
    verbose: bool
    replayUserMessages: bool
    includePartialMessages: bool
    orphanedPermission: text
    sessionId: text

impl QueryEngineConfig:
    static fn new(cwd: text, tools: [text]) -> QueryEngineConfig:
        QueryEngineConfig(
            cwd: cwd,
            tools: tools,
            commands: [],
            mcpClients: [],
            agents: [],
            initialMessages: [],
            readFileCache: "",
            customSystemPrompt: "",
            appendSystemPrompt: "",
            userSpecifiedModel: "",
            fallbackModel: "",
            thinkingConfig: "",
            maxTurns: 0,
            maxBudgetUsd: 0,
            taskBudgetTotal: 0,
            jsonSchema: "",
            verbose: false,
            replayUserMessages: false,
            includePartialMessages: false,
            orphanedPermission: "",
            sessionId: "session_1"
        )

class SDKMessage:
    type: text
    subtype: text
    content: text
    sessionId: text
    uuid: text
    permissionDenials: [SDKPermissionDenial]
    usageInputTokens: i64
    usageOutputTokens: i64
    structuredOutput: text
    isError: bool

impl SDKMessage:
    static fn user(content: text, uuid: text, sessionId: text) -> SDKMessage:
        SDKMessage(type: "user", subtype: "", content: content, sessionId: sessionId, uuid: uuid, permissionDenials: [], usageInputTokens: 0, usageOutputTokens: 0, structuredOutput: "", isError: false)

    static fn assistant(content: text, sessionId: text) -> SDKMessage:
        SDKMessage(type: "assistant", subtype: "", content: content, sessionId: sessionId, uuid: "", permissionDenials: [], usageInputTokens: 0, usageOutputTokens: 0, structuredOutput: "", isError: false)

    static fn result(content: text, sessionId: text, denials: [SDKPermissionDenial], usage: Usage, structuredOutput: text, isError: bool) -> SDKMessage:
        SDKMessage(type: "result", subtype: "success", content: content, sessionId: sessionId, uuid: "uuid-result", permissionDenials: denials, usageInputTokens: usage.inputTokens, usageOutputTokens: usage.outputTokens, structuredOutput: structuredOutput, isError: isError)

class SDKPermissionDenial:
    toolName: text
    toolUseId: text
    toolInput: text

impl SDKPermissionDenial:
    static fn new(toolName: text, toolUseId: text, toolInput: text) -> SDKPermissionDenial:
        SDKPermissionDenial(toolName: sdkCompatToolName(toolName), toolUseId: toolUseId, toolInput: toolInput)

class Usage:
    inputTokens: i64
    outputTokens: i64

impl Usage:
    static fn empty() -> Usage:
        Usage(inputTokens: 0, outputTokens: 0)

    me add(inputTokens: i64, outputTokens: i64) -> Usage:
        Usage(inputTokens: me.inputTokens + inputTokens, outputTokens: me.outputTokens + outputTokens)

class AbortControllerModel:
    aborted: bool

impl AbortControllerModel:
    static fn new() -> AbortControllerModel:
        AbortControllerModel(aborted: false)

    me abort() -> ():
        me.aborted = true

class SubmitOptions:
    uuid: text
    isMeta: bool

impl SubmitOptions:
    static fn new(uuid: text, isMeta: bool) -> SubmitOptions:
        SubmitOptions(uuid: uuid, isMeta: isMeta)

class QueryEngine:
    config: QueryEngineConfig
    mutableMessages: [text]
    abortController: AbortControllerModel
    permissionDenials: [SDKPermissionDenial]
    totalUsage: Usage
    hasHandledOrphanedPermission: bool
    readFileState: text
    discoveredSkillNames: [text]
    loadedNestedMemoryPaths: [text]
    structuredOutputRegistered: bool

impl QueryEngine:
    static fn new(config: QueryEngineConfig) -> QueryEngine:
        QueryEngine(
            config: config,
            mutableMessages: config.initialMessages,
            abortController: AbortControllerModel.new(),
            permissionDenials: [],
            totalUsage: Usage.empty(),
            hasHandledOrphanedPermission: false,
            readFileState: config.readFileCache,
            discoveredSkillNames: [],
            loadedNestedMemoryPaths: [],
            structuredOutputRegistered: false
        )

    me submitMessage(prompt: text, options: SubmitOptions) -> [SDKMessage]:
        me.discoveredSkillNames = []
        val uuid = chooseUuid(options.uuid)
        me.mutableMessages = appendText(me.mutableMessages, prompt)
        me.totalUsage = me.totalUsage.add(prompt.len(), 1)
        if me.config.orphanedPermission != "" and not me.hasHandledOrphanedPermission:
            me.permissionDenials = appendDenial(me.permissionDenials, SDKPermissionDenial.new(me.config.orphanedPermission, "orphaned", "{}"))
            me.hasHandledOrphanedPermission = true
        if me.config.jsonSchema != "" and hasStructuredOutputTool(me.config.tools):
            me.structuredOutputRegistered = true
        val assistantText = "response:" + prompt
        me.mutableMessages = appendText(me.mutableMessages, assistantText)
        val structured = structuredOutputFor(me.config.jsonSchema, me.config.tools)
        [
            SDKMessage.user(prompt, uuid, me.config.sessionId),
            SDKMessage.assistant(assistantText, me.config.sessionId),
            SDKMessage.result(assistantText, me.config.sessionId, me.permissionDenials, me.totalUsage, structured, false)
        ]

    me denyPermission(toolName: text, toolUseId: text, toolInput: text) -> ():
        me.permissionDenials = appendDenial(me.permissionDenials, SDKPermissionDenial.new(toolName, toolUseId, toolInput))

    me interrupt() -> ():
        me.abortController.abort()

    me getMessages() -> [text]:
        me.mutableMessages

    me getReadFileState() -> text:
        me.readFileState

    me getSessionId() -> text:
        me.config.sessionId

    me setModel(model: text) -> ():
        me.config.userSpecifiedModel = model

fn hasStructuredOutputTool(tools: [text]) -> bool:
    var i = 0
    while i < tools.len():
        if toolMatchesName(tools[i], "structured_output"):
            return true
        i = i + 1
    false

fn ask(config: QueryEngineConfig, prompt: text) -> [SDKMessage]:
    val engine = QueryEngine.new(config)
    engine.submitMessage(prompt, SubmitOptions.new("ask-uuid", false))

fn appendText(values: [text], value: text) -> [text]:
    var out: [text] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn appendDenial(values: [SDKPermissionDenial], value: SDKPermissionDenial) -> [SDKPermissionDenial]:
    var out: [SDKPermissionDenial] = []
    var i = 0
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out.push(value)
    out

fn chooseUuid(uuid: text) -> text:
    if uuid == "":
        return "uuid-user"
    uuid

fn sdkCompatToolName(toolName: text) -> text:
    if toolName == "Bash":
        return "bash"
    if toolName == "Read":
        return "read"
    toolName

fn toolMatchesName(toolName: text, expected: text) -> bool:
    toolName == expected or toolName == "SyntheticOutputTool"

fn structuredOutputFor(jsonSchema: text, tools: [text]) -> text:
    if jsonSchema != "" and hasStructuredOutputTool(tools):
        return "enforced"
    ""

fn queryEngineSourceLinesModeled() -> i64:
    1295
