class File:
    fileId: text
    relativePath: text

impl File:
    static fn new(fileId: text, relativePath: text) -> File:
        File(fileId: fileId, relativePath: relativePath)

class FilesApiConfig:
    oauthToken: text
    baseUrl: text
    sessionId: text

impl FilesApiConfig:
    static fn new(oauthToken: text, sessionId: text) -> FilesApiConfig:
        FilesApiConfig(oauthToken: oauthToken, baseUrl: "", sessionId: sessionId)

class DownloadResult:
    fileId: text
    path: text
    success: bool
    error: text
    bytesWritten: i64

impl DownloadResult:
    static fn ok(fileId: text, path: text, bytesWritten: i64) -> DownloadResult:
        DownloadResult(fileId: fileId, path: path, success: true, error: "", bytesWritten: bytesWritten)

    static fn fail(fileId: text, path: text, error: text) -> DownloadResult:
        DownloadResult(fileId: fileId, path: path, success: false, error: error, bytesWritten: 0)

class RetryResult:
    done: bool
    value: text
    error: text

impl RetryResult:
    static fn ok(value: text) -> RetryResult:
        RetryResult(done: true, value: value, error: "")

    static fn again(error: text) -> RetryResult:
        RetryResult(done: false, value: "", error: error)

class UploadResult:
    path: text
    fileId: text
    size: i64
    success: bool
    error: text

impl UploadResult:
    static fn ok(path: text, fileId: text, size: i64) -> UploadResult:
        UploadResult(path: path, fileId: fileId, size: size, success: true, error: "")

    static fn fail(path: text, error: text) -> UploadResult:
        UploadResult(path: path, fileId: "", size: 0, success: false, error: error)

class UploadNonRetriableError:
    message: text
    name: text

impl UploadNonRetriableError:
    static fn new(message: text) -> UploadNonRetriableError:
        UploadNonRetriableError(message: message, name: "UploadNonRetriableError")

class FileMetadata:
    filename: text
    fileId: text
    size: i64

impl FileMetadata:
    static fn new(filename: text, fileId: text, size: i64) -> FileMetadata:
        FileMetadata(filename: filename, fileId: fileId, size: size)

class FilesApiResponse:
    status: i64
    body: text
    bytes: i64
    fileId: text
    retriableError: text
    canceled: bool

impl FilesApiResponse:
    static fn okFile(bytes: i64) -> FilesApiResponse:
        FilesApiResponse(status: 200, body: "", bytes: bytes, fileId: "", retriableError: "", canceled: false)

    static fn okUpload(status: i64, fileId: text) -> FilesApiResponse:
        FilesApiResponse(status: status, body: "", bytes: 0, fileId: fileId, retriableError: "", canceled: false)

    static fn status(status: i64) -> FilesApiResponse:
        FilesApiResponse(status: status, body: "", bytes: 0, fileId: "", retriableError: "", canceled: false)

    static fn network(error: text) -> FilesApiResponse:
        FilesApiResponse(status: 0, body: "", bytes: 0, fileId: "", retriableError: error, canceled: false)

    static fn cancel() -> FilesApiResponse:
        FilesApiResponse(status: 0, body: "", bytes: 0, fileId: "", retriableError: "", canceled: true)

class FilesApiPage:
    files: [FileMetadata]
    hasMore: bool

impl FilesApiPage:
    static fn new(files: [FileMetadata], hasMore: bool) -> FilesApiPage:
        FilesApiPage(files: files, hasMore: hasMore)

class FilesApiClient:
    config: FilesApiConfig
    cwd: text
    envAnthropicBaseUrl: text
    envClaudeCodeApiBaseUrl: text
    downloadPlan: [FilesApiResponse]
    uploadPlan: [FilesApiResponse]
    listPlan: [FilesApiPage]
    readPlan: [FilesApiResponse]
    writes: [text]
    mkdirs: [text]
    requests: [text]
    sleeps: [i64]
    analytics: [text]
    debug: [text]
    boundary: text

impl FilesApiClient:
    static fn new(config: FilesApiConfig) -> FilesApiClient:
        FilesApiClient(config: config, cwd: "/workspace", envAnthropicBaseUrl: "", envClaudeCodeApiBaseUrl: "", downloadPlan: [], uploadPlan: [], listPlan: [], readPlan: [], writes: [], mkdirs: [], requests: [], sleeps: [], analytics: [], debug: [], boundary: "uuid")

    me getDefaultApiBaseUrl() -> text:
        if me.envAnthropicBaseUrl != "":
            return me.envAnthropicBaseUrl
        if me.envClaudeCodeApiBaseUrl != "":
            return me.envClaudeCodeApiBaseUrl
        "https://api.anthropic.com"

    me baseUrl() -> text:
        if me.config.baseUrl != "":
            return me.config.baseUrl
        me.getDefaultApiBaseUrl()

    me logDebugError(message: text) -> ():
        me.debug.push("[files-api] " + message + "|error")

    me logDebug(message: text) -> ():
        me.debug.push("[files-api] " + message)

    me retryWithBackoff(operation: text, attempts: [RetryResult]) -> RetryResult:
        var lastError = ""
        var i = 0
        while i < attempts.len() and i < maxRetries():
            val result = attempts[i]
            if result.done:
                return result
            if result.error != "":
                lastError = result.error
            else:
                lastError = operation + " failed"
            if i < maxRetries() - 1:
                me.sleeps.push(baseDelayMs() * pow2(i))
            i = i + 1
        RetryResult.again(lastError + " after " + maxRetries().to_text() + " attempts")

    me downloadFile(fileId: text) -> RetryResult:
        val url = me.baseUrl() + "/v1/files/" + fileId + "/content"
        me.requests.push("GET " + url + " " + filesApiBetaHeader())
        var retryInputs: [RetryResult] = []
        var i = 0
        while i < me.downloadPlan.len():
            val response = me.downloadPlan[i]
            if response.status == 200:
                retryInputs.push(RetryResult.ok(response.bytes.to_text()))
            elif response.status == 404:
                return RetryResult.again("File not found: " + fileId)
            elif response.status == 401:
                return RetryResult.again("Authentication failed: invalid or missing API key")
            elif response.status == 403:
                return RetryResult.again("Access denied to file: " + fileId)
            elif response.retriableError != "":
                retryInputs.push(RetryResult.again(response.retriableError))
            else:
                retryInputs.push(RetryResult.again("status " + response.status.to_text()))
            i = i + 1
        me.retryWithBackoff("Download file " + fileId, retryInputs)

    me buildDownloadPath(sessionId: text, relativePath: text) -> text:
        val normalized = normalizePath(relativePath)
        if normalized.starts_with("..") or normalized.contains("/../"):
            me.logDebugError("Invalid file path: " + relativePath + ". Path must not traverse above workspace")
            return ""
        val uploadsBase = me.cwd + "/" + sessionId + "/uploads"
        val cleanPath = stripUploadPrefix(normalized, uploadsBase)
        uploadsBase + "/" + cleanPath

    me downloadAndSaveFile(attachment: File) -> DownloadResult:
        val fullPath = me.buildDownloadPath(me.config.sessionId, attachment.relativePath)
        if fullPath == "":
            return DownloadResult.fail(attachment.fileId, "", "Invalid file path: " + attachment.relativePath)
        val content = me.downloadFile(attachment.fileId)
        if not content.done:
            me.logDebugError("Failed to download file " + attachment.fileId + ": " + content.error)
            return DownloadResult.fail(attachment.fileId, fullPath, content.error)
        val bytes = content.value.to_i64()
        val parent = dirname(fullPath)
        me.mkdirs.push(parent)
        me.writes.push(fullPath + ":" + bytes.to_text())
        DownloadResult.ok(attachment.fileId, fullPath, bytes)

    me downloadSessionFiles(files: [File], concurrency: i64) -> [DownloadResult]:
        var results: [DownloadResult] = []
        if files.len() == 0:
            return results
        me.logDebug("Downloading " + files.len().to_text() + " file(s) for session " + me.config.sessionId)
        var i = 0
        while i < files.len():
            results.push(me.downloadAndSaveFile(files[i]))
            i = i + 1
        me.logDebug("Downloaded " + countDownloadSuccess(results).to_text() + "/" + files.len().to_text() + " file(s)")
        results

    me uploadFile(filePath: text, relativePath: text) -> UploadResult:
        val read = me.nextRead(filePath)
        if read.retriableError != "":
            me.analytics.push("tengu_file_upload_failed:file_read")
            return UploadResult.fail(relativePath, read.retriableError)
        if read.bytes > maxFileSizeBytes():
            me.analytics.push("tengu_file_upload_failed:file_too_large")
            return UploadResult.fail(relativePath, "File exceeds maximum size of " + maxFileSizeBytes().to_text() + " bytes (actual: " + read.bytes.to_text() + ")")
        val url = me.baseUrl() + "/v1/files"
        val boundary = "----FormBoundary" + me.boundary
        me.requests.push("POST " + url + " multipart/form-data; boundary=" + boundary)
        var retryInputs: [RetryResult] = []
        while me.uploadPlan.len() > 0:
            val response = me.uploadPlan[0]
            me.uploadPlan = dropFirstResponse(me.uploadPlan)
            val attempt = me.uploadAttemptResult(response, relativePath, read.bytes)
            if attempt.name == "UploadNonRetriableError":
                return UploadResult.fail(relativePath, attempt.message)
            if attempt.done:
                return UploadResult.ok(relativePath, attempt.value, read.bytes)
            retryInputs.push(RetryResult(done: attempt.done, value: attempt.value, error: attempt.error))
        val result = me.retryWithBackoff("Upload file " + relativePath, retryInputs)
        if result.done:
            return UploadResult.ok(relativePath, result.value, read.bytes)
        me.analytics.push("tengu_file_upload_failed:network")
        UploadResult.fail(relativePath, result.error)

    me uploadAttemptResult(response: FilesApiResponse, relativePath: text, size: i64) -> RetryUploadAttempt:
        if response.canceled:
            return RetryUploadAttempt.nonRetriable("Upload canceled")
        if response.status == 200 or response.status == 201:
            if response.fileId == "":
                return RetryUploadAttempt.retry("Upload succeeded but no file ID returned")
            return RetryUploadAttempt.done(response.fileId)
        if response.status == 401:
            me.analytics.push("tengu_file_upload_failed:auth")
            return RetryUploadAttempt.nonRetriable("Authentication failed: invalid or missing API key")
        if response.status == 403:
            me.analytics.push("tengu_file_upload_failed:forbidden")
            return RetryUploadAttempt.nonRetriable("Access denied for upload")
        if response.status == 413:
            me.analytics.push("tengu_file_upload_failed:size")
            return RetryUploadAttempt.nonRetriable("File too large for upload")
        if response.retriableError != "":
            return RetryUploadAttempt.retry(response.retriableError)
        RetryUploadAttempt.retry("status " + response.status.to_text())

    me uploadSessionFiles(files: [LocalUploadFile], concurrency: i64) -> [UploadResult]:
        var results: [UploadResult] = []
        if files.len() == 0:
            return results
        me.logDebug("Uploading " + files.len().to_text() + " file(s) for session " + me.config.sessionId)
        var i = 0
        while i < files.len():
            results.push(me.uploadFile(files[i].path, files[i].relativePath))
            i = i + 1
        me.logDebug("Uploaded " + countUploadSuccess(results).to_text() + "/" + files.len().to_text() + " file(s)")
        results

    me listFilesCreatedAfter(afterCreatedAt: text) -> [FileMetadata]:
        var allFiles: [FileMetadata] = []
        var afterId = ""
        var pageIndex = 0
        while pageIndex < me.listPlan.len():
            var request = "GET " + me.baseUrl() + "/v1/files?after_created_at=" + afterCreatedAt
            if afterId != "":
                request = request + "&after_id=" + afterId
            me.requests.push(request)
            val page = me.listPlan[pageIndex]
            var i = 0
            while i < page.files.len():
                allFiles.push(page.files[i])
                i = i + 1
            if not page.hasMore:
                return allFiles
            if page.files.len() == 0:
                return allFiles
            afterId = page.files[page.files.len() - 1].fileId
            pageIndex = pageIndex + 1
        allFiles

    me parseFileSpecs(fileSpecs: [text]) -> [File]:
        parseFileSpecs(fileSpecs)

    me nextRead(filePath: text) -> FilesApiResponse:
        if me.readPlan.len() == 0:
            return FilesApiResponse.okFile(0)
        val first = me.readPlan[0]
        me.readPlan = dropFirstResponse(me.readPlan)
        first

class RetryUploadAttempt:
    done: bool
    value: text
    error: text
    name: text
    message: text

impl RetryUploadAttempt:
    static fn done(value: text) -> RetryUploadAttempt:
        RetryUploadAttempt(done: true, value: value, error: "", name: "", message: "")

    static fn retry(error: text) -> RetryUploadAttempt:
        RetryUploadAttempt(done: false, value: "", error: error, name: "", message: "")

    static fn nonRetriable(message: text) -> RetryUploadAttempt:
        RetryUploadAttempt(done: false, value: "", error: "", name: "UploadNonRetriableError", message: message)

class LocalUploadFile:
    path: text
    relativePath: text

impl LocalUploadFile:
    static fn new(path: text, relativePath: text) -> LocalUploadFile:
        LocalUploadFile(path: path, relativePath: relativePath)

fn getDefaultApiBaseUrl(anthropicBaseUrl: text, claudeCodeApiBaseUrl: text) -> text:
    if anthropicBaseUrl != "":
        return anthropicBaseUrl
    if claudeCodeApiBaseUrl != "":
        return claudeCodeApiBaseUrl
    "https://api.anthropic.com"

fn logDebugError(message: text) -> text:
    "[files-api] " + message + "|error"

fn logDebug(message: text) -> text:
    "[files-api] " + message

fn retryWithBackoff(client: FilesApiClient, operation: text, attempts: [RetryResult]) -> RetryResult:
    client.retryWithBackoff(operation, attempts)

fn buildDownloadPath(basePath: text, sessionId: text, relativePath: text) -> text:
    val client = FilesApiClient.new(FilesApiConfig.new("", sessionId))
    client.cwd = basePath
    client.buildDownloadPath(sessionId, relativePath)

fn matchedPrefix(normalized: text, uploadsBase: text) -> text:
    if normalized.starts_with(uploadsBase + "/"):
        return uploadsBase + "/"
    if normalized.starts_with("/uploads/"):
        return "/uploads/"
    ""

fn parallelWithLimitText(items: [text], concurrency: i64) -> [text]:
    var results: [text] = []
    var i = 0
    while i < items.len():
        results.push(items[i])
        i = i + 1
    results

fn worker(index: i64) -> i64:
    index + 1

fn successCountDownload(results: [DownloadResult]) -> i64:
    countDownloadSuccess(results)

fn successCountUpload(results: [UploadResult]) -> i64:
    countUploadSuccess(results)

fn parseFileSpecs(fileSpecs: [text]) -> [File]:
    val expanded = expandedSpecs(fileSpecs)
    var files: [File] = []
    var i = 0
    while i < expanded.len():
        val spec = expanded[i]
        val colon = spec.find(":")
        if colon > 0 and colon < spec.len() - 1:
            files.push(File.new(spec.slice(0, colon), spec.slice(colon + 1, spec.len())))
        i = i + 1
    files

fn expandedSpecs(fileSpecs: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < fileSpecs.len():
        val parts = fileSpecs[i].split(" ")
        var j = 0
        while j < parts.len():
            if parts[j] != "":
                out.push(parts[j])
            j = j + 1
        i = i + 1
    out

fn filesApiBetaHeader() -> text:
    "files-api-2025-04-14,oauth-2025-04-20"

fn anthropicVersion() -> text:
    "2023-06-01"

fn maxRetries() -> i64:
    3

fn baseDelayMs() -> i64:
    500

fn maxFileSizeBytes() -> i64:
    524288000

fn defaultConcurrency() -> i64:
    5

fn normalizePath(path: text) -> text:
    path

fn stripUploadPrefix(normalized: text, uploadsBase: text) -> text:
    val prefix = matchedPrefix(normalized, uploadsBase)
    if prefix != "":
        return normalized.slice(prefix.len(), normalized.len())
    normalized

fn dirname(path: text) -> text:
    val slash = path.rfind("/")
    if slash <= 0:
        return "."
    path.slice(0, slash)

fn countDownloadSuccess(results: [DownloadResult]) -> i64:
    var count = 0
    var i = 0
    while i < results.len():
        if results[i].success:
            count = count + 1
        i = i + 1
    count

fn countUploadSuccess(results: [UploadResult]) -> i64:
    var count = 0
    var i = 0
    while i < results.len():
        if results[i].success:
            count = count + 1
        i = i + 1
    count

fn dropFirstResponse(values: [FilesApiResponse]) -> [FilesApiResponse]:
    var out: [FilesApiResponse] = []
    var i = 1
    while i < values.len():
        out.push(values[i])
        i = i + 1
    out

fn pow2(exp: i64) -> i64:
    var out = 1
    var i = 0
    while i < exp:
        out = out * 2
        i = i + 1
    out

fn filesApiSourceLinesModeled() -> i64:
    748

