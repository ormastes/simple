"""
Claude full bridge status utility parity model.
"""

const BRIDGE_STATUS_UTIL_SOURCE_LINES = 163
const TOOL_DISPLAY_EXPIRY_MS = 30000
const SHIMMER_INTERVAL_MS = 150
const FAILED_FOOTER_TEXT = "Something went wrong, please try again"

class BridgeStatusInfo:
    label: text
    color: text

impl BridgeStatusInfo:
    static fn new(label: text, color: text) -> BridgeStatusInfo:
        BridgeStatusInfo(label: label, color: color)

class ShimmerSegments:
    before: text
    shimmer: text
    after_text: text

impl ShimmerSegments:
    static fn new(before: text, shimmer: text, after: text) -> ShimmerSegments:
        ShimmerSegments(before: before, shimmer: shimmer, after_text: after)

fn abbreviateActivity(summary: text) -> text:
    if summary.len() <= 30:
        return summary
    summary.slice(0, 30)

fn buildBridgeConnectUrl(environmentId: text, ingressUrl: text) -> text:
    var base = ingressUrl
    if base == "":
        base = "https://claude.ai"
    base + "/code?bridge=" + environmentId

fn compatRemoteSessionId(sessionId: text) -> text:
    if sessionId.starts_with("cse_"):
        return "session_" + sessionId.slice(4, sessionId.len())
    sessionId

fn buildBridgeSessionUrl(sessionId: text, environmentId: text, ingressUrl: text) -> text:
    var base = ingressUrl
    if base == "":
        base = "https://claude.ai"
    base + "/chat/" + compatRemoteSessionId(sessionId) + "?bridge=" + environmentId

fn computeGlimmerIndex(tick: i64, messageWidth: i64) -> i64:
    val cycleLength = messageWidth + 20
    messageWidth + 10 - (tick % cycleLength)

fn computeShimmerSegments(textValue: text, glimmerIndex: i64) -> ShimmerSegments:
    val shimmerStart = glimmerIndex - 1
    val shimmerEnd = glimmerIndex + 1
    if shimmerStart >= textValue.len() or shimmerEnd < 0:
        return ShimmerSegments.new(textValue, "", "")
    var before = ""
    var shimmer = ""
    var after = ""
    var i = 0
    while i < textValue.len():
        val ch = textValue.slice(i, i + 1)
        if i < shimmerStart:
            before = before + ch
        else if i > shimmerEnd:
            after = after + ch
        else:
            shimmer = shimmer + ch
        i = i + 1
    ShimmerSegments.new(before, shimmer, after)

fn getBridgeStatus(error: text, connected: bool, sessionActive: bool, reconnecting: bool) -> BridgeStatusInfo:
    if error != "":
        return BridgeStatusInfo.new("Remote Control failed", "error")
    if reconnecting:
        return BridgeStatusInfo.new("Remote Control reconnecting", "warning")
    if sessionActive or connected:
        return BridgeStatusInfo.new("Remote Control active", "success")
    BridgeStatusInfo.new("Remote Control connecting...", "warning")

fn buildIdleFooterText(url: text) -> text:
    "Code everywhere with the Claude app or " + url

fn buildActiveFooterText(url: text) -> text:
    "Continue coding in the Claude app or " + url

fn wrapWithOsc8Link(label: text, url: text) -> text:
    "\u001b]8;;" + url + "\u0007" + label + "\u001b]8;;\u0007"

fn bridgeStatusUtilSourceLinesModeled() -> i64:
    BRIDGE_STATUS_UTIL_SOURCE_LINES
