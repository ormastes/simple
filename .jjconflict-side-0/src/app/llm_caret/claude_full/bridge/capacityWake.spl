"""
Claude full bridge capacity wake parity model.
"""

const CAPACITY_WAKE_SOURCE_LINES = 56

class CapacityWakeState:
    outer_aborted: bool
    wake_aborted: bool
    generation: i64

impl CapacityWakeState:
    static fn new(outerAborted: bool, wakeAborted: bool, generation: i64) -> CapacityWakeState:
        CapacityWakeState(outer_aborted: outerAborted, wake_aborted: wakeAborted, generation: generation)

class CapacitySignal:
    aborted: bool
    cleanup_needed: bool
    generation: i64

impl CapacitySignal:
    static fn new(aborted: bool, cleanupNeeded: bool, generation: i64) -> CapacitySignal:
        CapacitySignal(aborted: aborted, cleanup_needed: cleanupNeeded, generation: generation)

fn capacityWakeInitial() -> CapacityWakeState:
    CapacityWakeState.new(false, false, 0)

fn capacityWakeSignal(state: CapacityWakeState) -> CapacitySignal:
    if state.outer_aborted:
        return CapacitySignal.new(true, false, state.generation)
    if state.wake_aborted:
        return CapacitySignal.new(true, false, state.generation)
    CapacitySignal.new(false, true, state.generation)

fn capacityWakeWake(state: CapacityWakeState) -> CapacityWakeState:
    CapacityWakeState.new(state.outer_aborted, false, state.generation + 1)

fn capacityWakeAbortOuter(state: CapacityWakeState) -> CapacityWakeState:
    CapacityWakeState.new(true, state.wake_aborted, state.generation)

fn capacityWakeAbortCurrent(state: CapacityWakeState) -> CapacityWakeState:
    CapacityWakeState.new(state.outer_aborted, true, state.generation)

fn capacityWakeCleanup(signal: CapacitySignal) -> bool:
    signal.cleanup_needed

fn capacityWakeSourceLinesModeled() -> i64:
    CAPACITY_WAKE_SOURCE_LINES
