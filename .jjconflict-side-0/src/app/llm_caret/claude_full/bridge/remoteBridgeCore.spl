"""
Deterministic remoteBridgeCore.ts parity surface for env-less bridge core.
"""

const REMOTE_BRIDGE_CORE_SOURCE_LINES: i64 = 1008
const REMOTE_BRIDGE_RETRY_MAX: i64 = 3

class RemoteOAuthHeaders:
    Authorization: text
    Content_Type: text
    anthropic_version: text

impl RemoteOAuthHeaders:
    static fn new(token: text) -> RemoteOAuthHeaders:
        RemoteOAuthHeaders(Authorization: "Bearer " + token, Content_Type: "application/json", anthropic_version: "2023-06-01")

class EnvLessBridgeParams:
    sessionId: text
    sessionUrl: text
    accessToken: text
    workerJwt: text
    apiBaseUrl: text
    connectCause: text

impl EnvLessBridgeParams:
    static fn new(sessionId: text, sessionUrl: text, accessToken: text) -> EnvLessBridgeParams:
        EnvLessBridgeParams(sessionId: sessionId, sessionUrl: sessionUrl, accessToken: accessToken, workerJwt: "", apiBaseUrl: "", connectCause: "initial")

    me withRemoteCredentials(workerJwt: text, apiBaseUrl: text) -> EnvLessBridgeParams:
        EnvLessBridgeParams(sessionId: me.sessionId, sessionUrl: me.sessionUrl, accessToken: me.accessToken, workerJwt: workerJwt, apiBaseUrl: apiBaseUrl, connectCause: me.connectCause)

class RemoteBridgeCoreHandle:
    connected: bool
    closed: bool
    events: [text]
    flushes: i64
    retries: i64

impl RemoteBridgeCoreHandle:
    static fn new(events: [text]) -> RemoteBridgeCoreHandle:
        RemoteBridgeCoreHandle(connected: true, closed: false, events: events, flushes: 0, retries: 0)

    me rebuildTransport(cause: text) -> ():
        me.connected = true
        me.events = me.events + ["rebuild:" + cause]

    me recoverFromAuthFailure(refreshed: bool) -> bool:
        if refreshed:
            me.events = me.events + ["auth:recovered"]
            return true
        me.events = me.events + ["auth:failed"]
        false

    me drainFlushGate() -> ():
        me.flushes = me.flushes + 1
        me.events = me.events + ["flush"]

    me flushHistory() -> [text]:
        me.events

    me teardown(reason: text) -> ():
        me.closed = true
        me.connected = false
        me.events = me.events + ["teardown:" + reason]

class RemoteCredentialsResult:
    ok: bool
    workerJwt: text
    apiBaseUrl: text
    workerEpoch: i64
    error: text

impl RemoteCredentialsResult:
    static fn ok(workerJwt: text, apiBaseUrl: text, workerEpoch: i64) -> RemoteCredentialsResult:
        RemoteCredentialsResult(ok: true, workerJwt: workerJwt, apiBaseUrl: apiBaseUrl, workerEpoch: workerEpoch, error: "")

    static fn failed(error: text) -> RemoteCredentialsResult:
        RemoteCredentialsResult(ok: false, workerJwt: "", apiBaseUrl: "", workerEpoch: 0, error: error)

class ArchiveStatus:
    ok: bool
    status: text

impl ArchiveStatus:
    static fn new(ok: bool, status: text) -> ArchiveStatus:
        ArchiveStatus(ok: ok, status: status)

class ArchiveTelemetryStatus:
    sent: bool
    status: text

impl ArchiveTelemetryStatus:
    static fn new(sent: bool, status: text) -> ArchiveTelemetryStatus:
        ArchiveTelemetryStatus(sent: sent, status: status)

fn oauthHeaders(token: text) -> RemoteOAuthHeaders:
    RemoteOAuthHeaders.new(token)

fn initEnvLessBridgeCore(params: EnvLessBridgeParams) -> RemoteBridgeCoreHandle:
    var events = ["connect:" + params.connectCause]
    if params.workerJwt != "":
        events = events + ["credentials:remote"]
    RemoteBridgeCoreHandle.new(events)

fn onConnectTimeout(elapsedMs: i64, timeoutMs: i64) -> bool:
    elapsedMs >= timeoutMs

fn wireTransportCallbacks(handle: RemoteBridgeCoreHandle, callbacks: [text]) -> RemoteBridgeCoreHandle:
    var i = 0
    while i < callbacks.len():
        handle.events = handle.events + ["callback:" + callbacks[i]]
        i = i + 1
    handle

fn withRetry(failuresBeforeSuccess: i64) -> i64:
    var attempts = 0
    while attempts < REMOTE_BRIDGE_RETRY_MAX:
        attempts = attempts + 1
        if failuresBeforeSuccess < attempts:
            return attempts
    attempts

fn fetchRemoteCredentials(workerJwt: text, apiBaseUrl: text, workerEpoch: i64) -> RemoteCredentialsResult:
    if workerJwt == "" or apiBaseUrl == "":
        return RemoteCredentialsResult.failed("missing remote credentials")
    if workerEpoch < 0:
        return RemoteCredentialsResult.failed("invalid worker epoch")
    RemoteCredentialsResult.ok(workerJwt, apiBaseUrl, workerEpoch)

fn archiveSession(sessionId: text, responseStatus: i64) -> ArchiveStatus:
    if sessionId == "":
        return ArchiveStatus.new(false, "missing-session")
    if responseStatus >= 200 and responseStatus < 300:
        return ArchiveStatus.new(true, "archived")
    ArchiveStatus.new(false, "archive-failed")

fn remoteBridgeCoreSourceLinesModeled() -> i64:
    REMOTE_BRIDGE_CORE_SOURCE_LINES

