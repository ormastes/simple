class PromptValue:
    role: text
    content: text

impl PromptValue:
    static fn new(role: text, content: text) -> PromptValue:
        PromptValue(role: role, content: content)

fn trackReceivedMessageUuid(received: [text], uuid: text) -> [text]:
    var out = received
    if uuid == "":
        return out
    var i = 0
    while i < out.len():
        if out[i] == uuid:
            return out
        i = i + 1
    out.push(uuid)
    out

fn toBlocks(value: PromptValue) -> [text]:
    if value.content == "":
        return []
    value.content.split("\n")

fn joinPromptValues(values: [PromptValue]) -> text:
    var out = ""
    var i = 0
    while i < values.len():
        if out != "":
            out = out + "\n"
        out = out + values[i].content
        i = i + 1
    out

fn canBatchWith(left: PromptValue, right: PromptValue) -> bool:
    left.role == right.role and left.role != "tool"

fn sendControlResponseSuccess(requestId: text, body: text) -> text:
    "control_response|" + requestId + "|success|" + body

fn sendControlResponseError(requestId: text, message: text) -> text:
    "control_response|" + requestId + "|error|" + message

fn removeInterruptedMessage(messages: [text]) -> [text]:
    var out: [text] = []
    var i = 0
    while i < messages.len():
        if messages[i] != "interrupted":
            out.push(messages[i])
        i = i + 1
    out

fn toScopedConfig(scope: text, name: text) -> text:
    scope + ":" + name

fn printSourceLinesModeled() -> i64:
    5594
