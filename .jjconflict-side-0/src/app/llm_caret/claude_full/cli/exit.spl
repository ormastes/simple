class CliExitResult:
    code: i64
    stdout: text
    stderr: text
    returnedNever: bool

impl CliExitResult:
    static fn new(code: i64, stdout: text, stderr: text) -> CliExitResult:
        CliExitResult(code: code, stdout: stdout, stderr: stderr, returnedNever: true)

fn cliError(msg: text) -> CliExitResult:
    if msg == "":
        return CliExitResult.new(1, "", "")
    CliExitResult.new(1, "", msg)

fn cliOk(msg: text) -> CliExitResult:
    if msg == "":
        return CliExitResult.new(0, "", "")
    CliExitResult.new(0, msg + "\n", "")

fn cliErrorExitCode() -> i64:
    1

fn cliOkExitCode() -> i64:
    0

fn cliErrorOutputTarget() -> text:
    "stderr"

fn cliOkOutputTarget() -> text:
    "stdout"

fn cliOkAddsNewline() -> bool:
    true

fn centralizedCliExitPoint() -> bool:
    true

fn processExitLintSuppressedHere() -> bool:
    true

fn testsSpyOnProcessExit() -> bool:
    true

fn testsSpyOnConsoleError() -> bool:
    true

fn testsSpyOnStdoutWrite() -> bool:
    true

fn neverReturnTypePurpose() -> text:
    "lets TypeScript narrow control flow at call sites"

fn copiedHandlerBlockReplaced() -> text:
    "print + lint-suppress + exit"
