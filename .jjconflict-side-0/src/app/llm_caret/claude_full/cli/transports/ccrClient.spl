class CCRInitError:
    reason: text
    message: text

impl CCRInitError:
    static fn new(reason: text) -> CCRInitError:
        CCRInitError(reason: reason, message: "CCRClient init failed: " + reason)

class EventPayload:
    uuid: text
    type: text
    session_id: text
    parent_tool_use_id: text
    event_type: text
    index: i64
    text: text
    message_id: text

impl EventPayload:
    static fn new(uuid: text, type: text) -> EventPayload:
        EventPayload(uuid: uuid, type: type, session_id: "", parent_tool_use_id: "", event_type: "", index: 0, text: "", message_id: "")

    static fn streamMessageStart(uuid: text, sessionId: text, parentToolUseId: text, messageId: text) -> EventPayload:
        EventPayload(uuid: uuid, type: "stream_event", session_id: sessionId, parent_tool_use_id: parentToolUseId, event_type: "message_start", index: 0, text: "", message_id: messageId)

    static fn streamTextDelta(uuid: text, sessionId: text, parentToolUseId: text, index: i64, text: text) -> EventPayload:
        EventPayload(uuid: uuid, type: "stream_event", session_id: sessionId, parent_tool_use_id: parentToolUseId, event_type: "content_block_delta", index: index, text: text, message_id: "")

    static fn assistant(sessionId: text, parentToolUseId: text, messageId: text) -> EventPayload:
        EventPayload(uuid: "", type: "assistant", session_id: sessionId, parent_tool_use_id: parentToolUseId, event_type: "", index: 0, text: "", message_id: messageId)

class ClientEvent:
    payload: EventPayload
    ephemeral: bool

impl ClientEvent:
    static fn new(payload: EventPayload, ephemeral: bool) -> ClientEvent:
        ClientEvent(payload: payload, ephemeral: ephemeral)

class StreamBlock:
    message_id: text
    index: i64
    chunks: [text]

impl StreamBlock:
    static fn new(messageId: text, index: i64) -> StreamBlock:
        StreamBlock(message_id: messageId, index: index, chunks: [])

    fn joined() -> text:
        joinText(self.chunks)

class StreamScope:
    scope: text
    message_id: text

impl StreamScope:
    static fn new(scope: text, messageId: text) -> StreamScope:
        StreamScope(scope: scope, message_id: messageId)

class StreamAccumulatorState:
    blocks: [StreamBlock]
    scopes: [StreamScope]

impl StreamAccumulatorState:
    static fn new() -> StreamAccumulatorState:
        StreamAccumulatorState(blocks: [], scopes: [])

class RequestResult:
    ok: bool
    retryAfterMs: i64

impl RequestResult:
    static fn ok() -> RequestResult:
        RequestResult(ok: true, retryAfterMs: 0)

    static fn failed(retryAfterMs: i64) -> RequestResult:
        RequestResult(ok: false, retryAfterMs: retryAfterMs)

class WorkerEvent:
    payload: EventPayload
    is_compaction: bool
    agent_id: text

impl WorkerEvent:
    static fn new(payload: EventPayload, isCompaction: bool, agentId: text) -> WorkerEvent:
        WorkerEvent(payload: payload, is_compaction: isCompaction, agent_id: agentId)

class InternalEvent:
    event_id: text
    event_type: text
    payload_type: text
    is_compaction: bool
    created_at: text
    agent_id: text

impl InternalEvent:
    static fn new(eventId: text, eventType: text) -> InternalEvent:
        InternalEvent(event_id: eventId, event_type: eventType, payload_type: "", is_compaction: false, created_at: "", agent_id: "")

class ListInternalEventsResponse:
    data: [InternalEvent]
    next_cursor: text

impl ListInternalEventsResponse:
    static fn new(data: [InternalEvent], nextCursor: text) -> ListInternalEventsResponse:
        ListInternalEventsResponse(data: data, next_cursor: nextCursor)

class WorkerStateResponse:
    external_metadata: [text]

impl WorkerStateResponse:
    static fn new(externalMetadata: [text]) -> WorkerStateResponse:
        WorkerStateResponse(external_metadata: externalMetadata)

class CCRClient:
    workerEpoch: i64
    heartbeatIntervalMs: i64
    heartbeatJitterFractionPct: i64
    heartbeatStarted: bool
    heartbeatInFlight: bool
    closed: bool
    consecutiveAuthFailures: i64
    currentState: text
    sessionBaseUrl: text
    sessionId: text
    authHeaders: [text]
    streamEventBuffer: [EventPayload]
    streamTextAccumulator: StreamAccumulatorState
    clientEvents: [ClientEvent]
    internalEvents: [WorkerEvent]
    deliveryEvents: [text]
    workerPatches: [text]
    epochMismatchCount: i64

impl CCRClient:
    static fn new(sessionUrl: text, authHeaders: [text]) -> CCRClient:
        val base = normalizeSessionUrl(sessionUrl)
        CCRClient(
            workerEpoch: 0,
            heartbeatIntervalMs: defaultHeartbeatIntervalMs(),
            heartbeatJitterFractionPct: 0,
            heartbeatStarted: false,
            heartbeatInFlight: false,
            closed: false,
            consecutiveAuthFailures: 0,
            currentState: "",
            sessionBaseUrl: base,
            sessionId: lastPathSegment(base),
            authHeaders: authHeaders,
            streamEventBuffer: [],
            streamTextAccumulator: createStreamAccumulator(),
            clientEvents: [],
            internalEvents: [],
            deliveryEvents: [],
            workerPatches: [],
            epochMismatchCount: 0
        )

    static fn withHeartbeat(sessionUrl: text, authHeaders: [text], intervalMs: i64, jitterPct: i64) -> CCRClient:
        val client = CCRClient.new(sessionUrl, authHeaders)
        client.heartbeatIntervalMs = intervalMs
        client.heartbeatJitterFractionPct = jitterPct
        client

    me initialize(epoch: i64) -> CCRInitError?:
        if me.authHeaders.len() == 0:
            return Some(CCRInitError.new("no_auth_headers"))
        if epoch < 0:
            return Some(CCRInitError.new("missing_epoch"))
        me.workerEpoch = epoch
        val result = me.requestStatus(200, 0)
        if not result.ok:
            return Some(CCRInitError.new("worker_register_failed"))
        me.currentState = "idle"
        me.startHeartbeat()
        nil

    me initializeWithRegisterStatus(epoch: i64, status: i64) -> CCRInitError?:
        if me.authHeaders.len() == 0:
            return Some(CCRInitError.new("no_auth_headers"))
        if epoch < 0:
            return Some(CCRInitError.new("missing_epoch"))
        me.workerEpoch = epoch
        val result = me.requestStatus(status, 0)
        if not result.ok:
            return Some(CCRInitError.new("worker_register_failed"))
        me.currentState = "idle"
        me.startHeartbeat()
        nil

    me requestStatus(status: i64, retryAfterSeconds: i64) -> RequestResult:
        if me.authHeaders.len() == 0:
            return RequestResult.failed(0)
        if status >= 200 and status < 300:
            me.consecutiveAuthFailures = 0
            return RequestResult.ok()
        if status == 409:
            me.handleEpochMismatch()
        if status == 401 or status == 403:
            me.consecutiveAuthFailures = me.consecutiveAuthFailures + 1
            if me.consecutiveAuthFailures >= maxConsecutiveAuthFailures():
                me.handleEpochMismatch()
        if status == 429 and retryAfterSeconds >= 0:
            return RequestResult.failed(retryAfterSeconds * 1000)
        RequestResult.failed(0)

    me reportState(state: text, details: text) -> nil:
        if state == me.currentState and details == "":
            return
        me.currentState = state
        if details == "":
            me.workerPatches.push("worker_status=" + state)
        else:
            me.workerPatches.push("worker_status=" + state + ";requires_action_details=" + details)

    me reportMetadata(metadata: text) -> nil:
        me.workerPatches.push("external_metadata=" + metadata)

    me startHeartbeat() -> nil:
        me.stopHeartbeat()
        me.heartbeatStarted = true

    me stopHeartbeat() -> nil:
        me.heartbeatStarted = false

    me sendHeartbeat() -> nil:
        if me.heartbeatInFlight:
            return
        me.heartbeatInFlight = true
        me.requestStatus(200, 0)
        me.heartbeatInFlight = false

    me writeEvent(message: EventPayload) -> nil:
        if message.type == "stream_event":
            me.streamEventBuffer.push(message)
            return
        me.flushStreamEventBuffer()
        if message.type == "assistant":
            clearStreamAccumulatorForMessage(me.streamTextAccumulator, message)
        me.clientEvents.push(me.toClientEvent(message))

    me toClientEvent(message: EventPayload) -> ClientEvent:
        var payload = message
        if payload.uuid == "":
            payload.uuid = generatedUuid()
        ClientEvent.new(payload, false)

    me flushStreamEventBuffer() -> nil:
        if me.streamEventBuffer.len() == 0:
            return
        val buffered = me.streamEventBuffer
        me.streamEventBuffer = []
        val payloads = accumulateStreamEvents(buffered, me.streamTextAccumulator)
        for payload in payloads:
            me.clientEvents.push(ClientEvent.new(payload, true))

    me writeInternalEvent(eventType: text, payloadType: text, isCompaction: bool, agentId: text) -> nil:
        val payload = EventPayload.new(generatedUuid(), eventType)
        payload.event_type = payloadType
        me.internalEvents.push(WorkerEvent.new(payload, isCompaction, agentId))

    fn flushInternalEvents() -> nil:
        nil

    me flush() -> nil:
        me.flushStreamEventBuffer()

    fn readInternalEvents() -> [InternalEvent]:
        []

    fn readSubagentInternalEvents() -> [InternalEvent]:
        []

    me paginatedGet(first: ListInternalEventsResponse, second: ListInternalEventsResponse) -> [InternalEvent]:
        var out: [InternalEvent] = []
        for event in first.data:
            out.push(event)
        if first.next_cursor != "":
            for event in second.data:
                out.push(event)
        out

    me getWithRetry(statuses: [i64]) -> bool:
        for status in statuses:
            if status >= 200 and status < 300:
                return true
            if status == 409:
                me.handleEpochMismatch()
        false

    me reportDelivery(eventId: text, status: text) -> nil:
        me.deliveryEvents.push(eventId + ":" + status)

    fn getWorkerEpoch() -> i64:
        self.workerEpoch

    fn internalEventsPending() -> i64:
        self.internalEvents.len()

    me close() -> nil:
        me.closed = true
        me.stopHeartbeat()
        me.streamEventBuffer = []
        me.streamTextAccumulator.blocks = []
        me.streamTextAccumulator.scopes = []

    me handleEpochMismatch() -> nil:
        me.epochMismatchCount = me.epochMismatchCount + 1
        me.closed = true

fn alwaysValidStatus() -> bool:
    true

fn createStreamAccumulator() -> StreamAccumulatorState:
    StreamAccumulatorState.new()

fn scopeKey(message: EventPayload) -> text:
    message.session_id + ":" + message.parent_tool_use_id

fn accumulateStreamEvents(buffer: [EventPayload], state: StreamAccumulatorState) -> [EventPayload]:
    var out: [EventPayload] = []
    var activeScope = ""
    var activeMessageId = ""
    var activeBlockIndex = -1
    var activeBlockText = ""
    for msg in buffer:
        if msg.event_type == "message_start":
            activeScope = scopeKey(msg)
            activeMessageId = msg.message_id
            activeBlockIndex = -1
            activeBlockText = ""
            rememberScope(state, scopeKey(msg), msg.message_id)
            removeMessageBlocks(state, msg.message_id)
            out.push(msg)
        else:
            if msg.event_type == "content_block_delta" and msg.text != "":
                var messageId = findScopeMessage(state, scopeKey(msg))
                if messageId == "" and scopeKey(msg) == activeScope:
                    messageId = activeMessageId
                if messageId == "":
                    out.push(msg)
                else:
                    if activeBlockIndex != msg.index:
                        activeBlockIndex = msg.index
                        activeBlockText = existingBlockText(state, messageId, msg.index)
                    activeBlockText = activeBlockText + msg.text
                    out.push(EventPayload(
                        uuid: msg.uuid,
                        type: "stream_event",
                        session_id: msg.session_id,
                        parent_tool_use_id: msg.parent_tool_use_id,
                        event_type: "content_block_delta",
                        index: msg.index,
                        text: activeBlockText,
                        message_id: messageId
                    ))
            else:
                out.push(msg)
    out

fn clearStreamAccumulatorForMessage(state: StreamAccumulatorState, assistant: EventPayload) -> nil:
    removeMessageBlocks(state, assistant.message_id)
    val key = scopeKey(assistant)
    var scopes: [StreamScope] = []
    for item in state.scopes:
        if not (item.scope == key and item.message_id == assistant.message_id):
            scopes.push(item)
    state.scopes = scopes
    return

fn rememberScope(state: StreamAccumulatorState, key: text, messageId: text) -> nil:
    var scopes: [StreamScope] = []
    for item in state.scopes:
        if item.scope != key:
            scopes.push(item)
    scopes.push(StreamScope.new(key, messageId))
    state.scopes = scopes

fn findScopeMessage(state: StreamAccumulatorState, key: text) -> text:
    for item in state.scopes:
        if item.scope == key:
            return item.message_id
    ""

fn findOrCreateBlock(state: StreamAccumulatorState, messageId: text, index: i64) -> StreamBlock:
    for block in state.blocks:
        if block.message_id == messageId and block.index == index:
            return block
    val block = StreamBlock.new(messageId, index)
    state.blocks.push(block)
    block

fn appendBlockText(state: StreamAccumulatorState, messageId: text, index: i64, text: text) -> text:
    var i = 0
    while i < state.blocks.len():
        if state.blocks[i].message_id == messageId and state.blocks[i].index == index:
            val block = state.blocks[i]
            block.chunks.push(text)
            state.blocks[i] = block
            return block.joined()
        i = i + 1
    val block = StreamBlock.new(messageId, index)
    block.chunks.push(text)
    state.blocks.push(block)
    block.joined()

fn existingBlockText(state: StreamAccumulatorState, messageId: text, index: i64) -> text:
    for block in state.blocks:
        if block.message_id == messageId and block.index == index:
            return block.joined()
    ""

fn removeMessageBlocks(state: StreamAccumulatorState, messageId: text) -> nil:
    var blocks: [StreamBlock] = []
    for block in state.blocks:
        if block.message_id != messageId:
            blocks.push(block)
    state.blocks = blocks

fn joinText(parts: [text]) -> text:
    var out = ""
    for part in parts:
        out = out + part
    out

fn normalizeSessionUrl(url: text) -> text:
    var out = url
    while out.ends_with("/") and out.len() > 0:
        out = out.slice(0, out.len() - 1)
    out

fn lastPathSegment(url: text) -> text:
    val parts = url.split("/")
    if parts.len() == 0:
        return ""
    parts[parts.len() - 1]

fn generatedUuid() -> text:
    "generated-uuid"

fn defaultHeartbeatIntervalMs() -> i64:
    20000

fn streamEventFlushIntervalMs() -> i64:
    100

fn maxConsecutiveAuthFailures() -> i64:
    10

fn ccrInitFailReasons() -> [text]:
    ["no_auth_headers", "missing_epoch", "worker_register_failed"]

fn requestContentTypeHeader() -> text:
    "Content-Type: application/json"

fn requestAnthropicVersionHeader() -> text:
    "anthropic-version: 2023-06-01"

fn requestUserAgentHeaderRequired() -> bool:
    true

fn workerPath() -> text:
    "/worker"

fn workerHeartbeatPath() -> text:
    "/worker/heartbeat"

fn workerEventsPath() -> text:
    "/worker/events"

fn workerInternalEventsPath() -> text:
    "/worker/internal-events"

fn workerDeliveryPath() -> text:
    "/worker/events/delivery"

fn streamEventsAreBuffered() -> bool:
    true

fn textDeltasEmitFullSnapshots() -> bool:
    true

fn assistantMessageClearsAccumulator() -> bool:
    true

fn nonStreamWriteFlushesBufferedStreamEvents() -> bool:
    true

fn deliveryAckRegisteredInConstructor() -> bool:
    true

fn initializeRequiresAuthHeaders() -> bool:
    true

fn initializeRequiresWorkerEpoch() -> bool:
    true

fn initializeStartsHeartbeatAfterWorkerPut() -> bool:
    true

fn requestReturnsRetryAfterMilliseconds() -> bool:
    true

fn authFailureThresholdExits() -> bool:
    true

fn closeClearsTimersQueuesAndAccumulator() -> bool:
    true

fn ccrClientSourceLinesModeled() -> i64:
    998

