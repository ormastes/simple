class OAuthTokens:
    accessToken: text
    scopes: [text]
    hasProfile: bool
    hasTokenAccount: bool
    storageWarning: text

impl OAuthTokens:
    static fn new(accessToken: text, scopes: [text]) -> OAuthTokens:
        OAuthTokens(accessToken: accessToken, scopes: scopes, hasProfile: false, hasTokenAccount: false, storageWarning: "")

    me withProfile() -> OAuthTokens:
        OAuthTokens(accessToken: me.accessToken, scopes: me.scopes, hasProfile: true, hasTokenAccount: me.hasTokenAccount, storageWarning: me.storageWarning)

    me withTokenAccount() -> OAuthTokens:
        OAuthTokens(accessToken: me.accessToken, scopes: me.scopes, hasProfile: me.hasProfile, hasTokenAccount: true, storageWarning: me.storageWarning)

    me withWarning(warning: text) -> OAuthTokens:
        OAuthTokens(accessToken: me.accessToken, scopes: me.scopes, hasProfile: me.hasProfile, hasTokenAccount: me.hasTokenAccount, storageWarning: warning)

class InstallOAuthResult:
    loggedOutFirst: bool
    storedAccountInfo: bool
    usedProfile: bool
    usedTokenAccountFallback: bool
    savedTokens: bool
    clearedTokenCache: bool
    loggedStorageWarning: bool
    fetchedRoles: bool
    fetchedFirstTokenDate: bool
    createdApiKey: bool
    clearedAuthCaches: bool
    error: text

impl InstallOAuthResult:
    static fn ok(tokens: OAuthTokens) -> InstallOAuthResult:
        val claudeAi = shouldUseClaudeAIAuth(tokens.scopes)
        InstallOAuthResult(loggedOutFirst: true, storedAccountInfo: tokens.hasProfile or tokens.hasTokenAccount, usedProfile: tokens.hasProfile, usedTokenAccountFallback: (not tokens.hasProfile) and tokens.hasTokenAccount, savedTokens: true, clearedTokenCache: true, loggedStorageWarning: tokens.storageWarning != "", fetchedRoles: true, fetchedFirstTokenDate: claudeAi, createdApiKey: not claudeAi, clearedAuthCaches: true, error: "")

    static fn failed(error: text) -> InstallOAuthResult:
        InstallOAuthResult(loggedOutFirst: true, storedAccountInfo: false, usedProfile: false, usedTokenAccountFallback: false, savedTokens: false, clearedTokenCache: false, loggedStorageWarning: false, fetchedRoles: false, fetchedFirstTokenDate: false, createdApiKey: false, clearedAuthCaches: false, error: error)

class AuthLoginRequest:
    email: text
    sso: bool
    useConsole: bool
    claudeai: bool
    forceLoginMethod: text
    forceLoginOrgUUID: text
    envRefreshToken: text
    envScopes: text
    envRefreshSucceeds: bool
    orgValid: bool
    oauthFlowSucceeds: bool

impl AuthLoginRequest:
    static fn new() -> AuthLoginRequest:
        AuthLoginRequest(email: "", sso: false, useConsole: false, claudeai: false, forceLoginMethod: "", forceLoginOrgUUID: "", envRefreshToken: "", envScopes: "", envRefreshSucceeds: true, orgValid: true, oauthFlowSucceeds: true)

    me withConsole() -> AuthLoginRequest:
        AuthLoginRequest(email: me.email, sso: me.sso, useConsole: true, claudeai: me.claudeai, forceLoginMethod: me.forceLoginMethod, forceLoginOrgUUID: me.forceLoginOrgUUID, envRefreshToken: me.envRefreshToken, envScopes: me.envScopes, envRefreshSucceeds: me.envRefreshSucceeds, orgValid: me.orgValid, oauthFlowSucceeds: me.oauthFlowSucceeds)

    me withClaudeAiFlag() -> AuthLoginRequest:
        AuthLoginRequest(email: me.email, sso: me.sso, useConsole: me.useConsole, claudeai: true, forceLoginMethod: me.forceLoginMethod, forceLoginOrgUUID: me.forceLoginOrgUUID, envRefreshToken: me.envRefreshToken, envScopes: me.envScopes, envRefreshSucceeds: me.envRefreshSucceeds, orgValid: me.orgValid, oauthFlowSucceeds: me.oauthFlowSucceeds)

    me withEnvRefresh(token: text, scopes: text) -> AuthLoginRequest:
        AuthLoginRequest(email: me.email, sso: me.sso, useConsole: me.useConsole, claudeai: me.claudeai, forceLoginMethod: me.forceLoginMethod, forceLoginOrgUUID: me.forceLoginOrgUUID, envRefreshToken: token, envScopes: scopes, envRefreshSucceeds: me.envRefreshSucceeds, orgValid: me.orgValid, oauthFlowSucceeds: me.oauthFlowSucceeds)

    me withForceMethod(method: text) -> AuthLoginRequest:
        AuthLoginRequest(email: me.email, sso: me.sso, useConsole: me.useConsole, claudeai: me.claudeai, forceLoginMethod: method, forceLoginOrgUUID: me.forceLoginOrgUUID, envRefreshToken: me.envRefreshToken, envScopes: me.envScopes, envRefreshSucceeds: me.envRefreshSucceeds, orgValid: me.orgValid, oauthFlowSucceeds: me.oauthFlowSucceeds)

    me withEmail(email: text) -> AuthLoginRequest:
        AuthLoginRequest(email: email, sso: me.sso, useConsole: me.useConsole, claudeai: me.claudeai, forceLoginMethod: me.forceLoginMethod, forceLoginOrgUUID: me.forceLoginOrgUUID, envRefreshToken: me.envRefreshToken, envScopes: me.envScopes, envRefreshSucceeds: me.envRefreshSucceeds, orgValid: me.orgValid, oauthFlowSucceeds: me.oauthFlowSucceeds)

    me withSso() -> AuthLoginRequest:
        AuthLoginRequest(email: me.email, sso: true, useConsole: me.useConsole, claudeai: me.claudeai, forceLoginMethod: me.forceLoginMethod, forceLoginOrgUUID: me.forceLoginOrgUUID, envRefreshToken: me.envRefreshToken, envScopes: me.envScopes, envRefreshSucceeds: me.envRefreshSucceeds, orgValid: me.orgValid, oauthFlowSucceeds: me.oauthFlowSucceeds)

class AuthLoginResult:
    code: i64
    stdout: text
    stderr: text
    loginWithClaudeAi: bool
    loginMethod: text
    usedEnvRefreshToken: bool
    markedOnboardingComplete: bool
    cleanedUpOAuthService: bool
    eventName: text

impl AuthLoginResult:
    static fn ok(loginWithClaudeAi: bool, usedEnvRefreshToken: bool, loginMethod: text) -> AuthLoginResult:
        AuthLoginResult(code: 0, stdout: "Login successful.\n", stderr: "", loginWithClaudeAi: loginWithClaudeAi, loginMethod: loginMethod, usedEnvRefreshToken: usedEnvRefreshToken, markedOnboardingComplete: usedEnvRefreshToken, cleanedUpOAuthService: not usedEnvRefreshToken, eventName: "tengu_oauth_success")

    static fn failed(message: text, loginWithClaudeAi: bool, usedEnvRefreshToken: bool) -> AuthLoginResult:
        AuthLoginResult(code: 1, stdout: "", stderr: message, loginWithClaudeAi: loginWithClaudeAi, loginMethod: "", usedEnvRefreshToken: usedEnvRefreshToken, markedOnboardingComplete: false, cleanedUpOAuthService: not usedEnvRefreshToken, eventName: "")

class AuthStatusInput:
    authTokenSource: text
    hasToken: bool
    apiKeySource: text
    hasApiKeyEnvVar: bool
    usingThirdParty: bool
    isHomespace: bool
    email: text
    orgId: text
    orgName: text
    subscriptionType: text
    apiProvider: text

impl AuthStatusInput:
    static fn none() -> AuthStatusInput:
        AuthStatusInput(authTokenSource: "none", hasToken: false, apiKeySource: "none", hasApiKeyEnvVar: false, usingThirdParty: false, isHomespace: false, email: "", orgId: "", orgName: "", subscriptionType: "", apiProvider: "anthropic")

    me withClaudeAi(email: text, orgId: text, orgName: text, subscriptionType: text) -> AuthStatusInput:
        AuthStatusInput(authTokenSource: "claude.ai", hasToken: true, apiKeySource: me.apiKeySource, hasApiKeyEnvVar: me.hasApiKeyEnvVar, usingThirdParty: me.usingThirdParty, isHomespace: me.isHomespace, email: email, orgId: orgId, orgName: orgName, subscriptionType: subscriptionType, apiProvider: me.apiProvider)

    me withApiKeyEnv() -> AuthStatusInput:
        AuthStatusInput(authTokenSource: me.authTokenSource, hasToken: me.hasToken, apiKeySource: me.apiKeySource, hasApiKeyEnvVar: true, usingThirdParty: me.usingThirdParty, isHomespace: me.isHomespace, email: me.email, orgId: me.orgId, orgName: me.orgName, subscriptionType: me.subscriptionType, apiProvider: me.apiProvider)

    me withApiKeySource(source: text) -> AuthStatusInput:
        AuthStatusInput(authTokenSource: me.authTokenSource, hasToken: me.hasToken, apiKeySource: source, hasApiKeyEnvVar: me.hasApiKeyEnvVar, usingThirdParty: me.usingThirdParty, isHomespace: me.isHomespace, email: me.email, orgId: me.orgId, orgName: me.orgName, subscriptionType: me.subscriptionType, apiProvider: me.apiProvider)

    me withThirdParty() -> AuthStatusInput:
        AuthStatusInput(authTokenSource: me.authTokenSource, hasToken: me.hasToken, apiKeySource: me.apiKeySource, hasApiKeyEnvVar: me.hasApiKeyEnvVar, usingThirdParty: true, isHomespace: me.isHomespace, email: me.email, orgId: me.orgId, orgName: me.orgName, subscriptionType: me.subscriptionType, apiProvider: me.apiProvider)

class AuthStatusResult:
    code: i64
    output: text
    loggedIn: bool
    authMethod: text
    apiKeySource: text

impl AuthStatusResult:
    static fn new(code: i64, output: text, loggedIn: bool, authMethod: text, apiKeySource: text) -> AuthStatusResult:
        AuthStatusResult(code: code, output: output, loggedIn: loggedIn, authMethod: authMethod, apiKeySource: apiKeySource)

class AuthLogoutResult:
    code: i64
    stdout: text
    stderr: text

impl AuthLogoutResult:
    static fn ok() -> AuthLogoutResult:
        AuthLogoutResult(code: 0, stdout: "Successfully logged out from your Anthropic account.\n", stderr: "")

    static fn failed() -> AuthLogoutResult:
        AuthLogoutResult(code: 1, stdout: "", stderr: "Failed to log out.\n")

fn installOAuthTokens(tokens: OAuthTokens, apiKeyCreated: bool) -> InstallOAuthResult:
    if not shouldUseClaudeAIAuth(tokens.scopes) and not apiKeyCreated:
        return InstallOAuthResult.failed("Unable to create API key. The server accepted the request but did not return a key.")
    InstallOAuthResult.ok(tokens)

fn shouldUseClaudeAIAuth(scopes: [text]) -> bool:
    var i = 0
    while i < scopes.len():
        if scopes[i] == "user:sessions:claude_code":
            return true
        i = i + 1
    false

fn authLogin(req: AuthLoginRequest) -> AuthLoginResult:
    if req.useConsole and req.claudeai:
        return AuthLoginResult.failed("Error: --console and --claudeai cannot be used together.\n", false, false)
    val loginWithClaudeAi = resolveLoginWithClaudeAi(req.forceLoginMethod, req.useConsole)
    if req.envRefreshToken != "":
        if req.envScopes == "":
            return AuthLoginResult.failed(missingEnvScopesMessage(), loginWithClaudeAi, true)
        if not req.envRefreshSucceeds:
            return AuthLoginResult.failed("Login failed: refresh failed\n", loginWithClaudeAi, true)
        if not req.orgValid:
            return AuthLoginResult.failed("Invalid organization\n", loginWithClaudeAi, true)
        return AuthLoginResult.ok(loginWithClaudeAi, true, "")
    if not req.oauthFlowSucceeds:
        return AuthLoginResult.failed("Login failed: oauth failed\n", loginWithClaudeAi, false)
    if not req.orgValid:
        return AuthLoginResult.failed("Invalid organization\n", loginWithClaudeAi, false)
    AuthLoginResult.ok(loginWithClaudeAi, false, ifText(req.sso, "sso", ""))

fn resolveLoginWithClaudeAi(forceLoginMethod: text, useConsole: bool) -> bool:
    if forceLoginMethod != "":
        return forceLoginMethod == "claudeai"
    not useConsole

fn authStatus(input: AuthStatusInput, textMode: bool) -> AuthStatusResult:
    val method = authMethod(input)
    val resolvedApiKey = resolvedApiKeySource(input)
    val loggedIn = input.hasToken or input.apiKeySource != "none" or (input.hasApiKeyEnvVar and not input.isHomespace) or input.usingThirdParty
    if textMode:
        if not loggedIn:
            return AuthStatusResult.new(1, "Not logged in. Run claude auth login to authenticate.\n", false, method, resolvedApiKey)
        if resolvedApiKey != "":
            return AuthStatusResult.new(0, "API key: " + resolvedApiKey + "\n", true, method, resolvedApiKey)
        return AuthStatusResult.new(0, "Auth method: " + method + "\n", true, method, resolvedApiKey)
    AuthStatusResult.new(ifInt(loggedIn, 0, 1), authStatusJson(loggedIn, method, input.apiProvider, resolvedApiKey, input), loggedIn, method, resolvedApiKey)

fn authMethod(input: AuthStatusInput) -> text:
    if input.usingThirdParty:
        return "third_party"
    if input.authTokenSource == "claude.ai":
        return "claude.ai"
    if input.authTokenSource == "apiKeyHelper":
        return "api_key_helper"
    if input.authTokenSource != "none":
        return "oauth_token"
    if input.apiKeySource == "ANTHROPIC_API_KEY" or (input.hasApiKeyEnvVar and not input.isHomespace):
        return "api_key"
    if input.apiKeySource == "/login managed key":
        return "claude.ai"
    "none"

fn resolvedApiKeySource(input: AuthStatusInput) -> text:
    if input.apiKeySource != "none":
        return input.apiKeySource
    if input.hasApiKeyEnvVar and not input.isHomespace:
        return "ANTHROPIC_API_KEY"
    ""

fn authStatusJson(loggedIn: bool, method: text, provider: text, apiKeySource: text, input: AuthStatusInput) -> text:
    var out = "{\"loggedIn\":" + boolText(loggedIn) + ",\"authMethod\":\"" + method + "\",\"apiProvider\":\"" + provider + "\""
    if apiKeySource != "":
        out = out + ",\"apiKeySource\":\"" + apiKeySource + "\""
    if method == "claude.ai":
        out = out + ",\"email\":\"" + input.email + "\",\"orgId\":\"" + input.orgId + "\",\"orgName\":\"" + input.orgName + "\",\"subscriptionType\":\"" + input.subscriptionType + "\""
    out + "}\n"

fn authLogout(success: bool) -> AuthLogoutResult:
    if success:
        return AuthLogoutResult.ok()
    AuthLogoutResult.failed()

fn missingEnvScopesMessage() -> text:
    "CLAUDE_CODE_OAUTH_SCOPES is required when using CLAUDE_CODE_OAUTH_REFRESH_TOKEN.\nSet it to the space-separated scopes the refresh token was issued with\n(e.g. \"user:inference\" or \"user:profile user:inference user:sessions:claude_code user:mcp_servers\").\n"

fn browserOpenMessage(url: text) -> text:
    "Opening browser to sign in...\nIf the browser didn't open, visit: " + url + "\n"

fn loginSuccessMessage() -> text:
    "Login successful.\n"

fn loginFailedPrefix() -> text:
    "Login failed: "

fn forceLoginConflictMessage() -> text:
    "Error: --console and --claudeai cannot be used together.\n"

fn logoutSuccessMessage() -> text:
    "Successfully logged out from your Anthropic account.\n"

fn logoutFailedMessage() -> text:
    "Failed to log out.\n"

fn notLoggedInMessage() -> text:
    "Not logged in. Run claude auth login to authenticate.\n"

fn oauthFlowStartEvent() -> text:
    "tengu_oauth_flow_start"

fn oauthSuccessEvent() -> text:
    "tengu_oauth_success"

fn oauthStorageWarningEvent() -> text:
    "tengu_oauth_storage_warning"

fn loginFromRefreshTokenEvent() -> text:
    "tengu_login_from_refresh_token"

fn refreshTokenEnvName() -> text:
    "CLAUDE_CODE_OAUTH_REFRESH_TOKEN"

fn refreshScopesEnvName() -> text:
    "CLAUDE_CODE_OAUTH_SCOPES"

fn apiKeyEnvName() -> text:
    "ANTHROPIC_API_KEY"

fn consoleFlagName() -> text:
    "--console"

fn claudeAiFlagName() -> text:
    "--claudeai"

fn ssoLoginMethod() -> text:
    "sso"

fn forceLoginMethodSetting() -> text:
    "forceLoginMethod"

fn forceLoginOrgSetting() -> text:
    "forceLoginOrgUUID"

fn clearOnboardingOnLogout() -> bool:
    false

fn envRefreshMarksOnboardingComplete() -> bool:
    true

fn oauthServiceCleanupInFinally() -> bool:
    true

fn rolesFailureIsNonFatal() -> bool:
    true

fn firstTokenDateFailureIsNonFatal() -> bool:
    true

fn consoleApiKeyCreationIsCritical() -> bool:
    true

fn homespaceIgnoresApiKeyEnvVar() -> bool:
    true

fn textStatusUsesAccountAndProviderProperties() -> bool:
    true

fn jsonStatusIncludesClaudeAiAccountFields() -> bool:
    true

fn authStatusExitCode(loggedIn: bool) -> i64:
    if loggedIn:
        return 0
    1

fn boolText(value: bool) -> text:
    if value:
        return "true"
    "false"

fn ifText(condition: bool, yes: text, no: text) -> text:
    if condition:
        return yes
    no

fn ifInt(condition: bool, yes: i64, no: i64) -> i64:
    if condition:
        return yes
    no
