fn ndjsonSafeStringify(json: text) -> text:
    escapeJsLineTerminators(json)

fn escapeJsLineTerminators(json: text) -> text:
    var out = ""
    var i = 0
    while i < json.len():
        val ch = json.slice(i, i + 1)
        if ch == lineSeparatorChar():
            out = out + "\\u2028"
        else:
            if ch == paragraphSeparatorChar():
                out = out + "\\u2029"
            else:
                out = out + ch
        i = i + 1
    out

fn lineSeparatorChar() -> text:
    " "

fn paragraphSeparatorChar() -> text:
    " "

fn escapedLineSeparator() -> text:
    "\\u2028"

fn escapedParagraphSeparator() -> text:
    "\\u2029"

fn jsLineTerminatorsPattern() -> text:
    "\\u2028|\\u2029"

fn usesSingleAlternationRegexInSource() -> bool:
    true

fn preservesJsonParseValue() -> bool:
    true

fn protectsOneMessagePerLineTransports() -> bool:
    true

fn ndjsonSafeStringifySourceLinesModeled() -> i64:
    32

# Source parity note: JSON.stringify can emit U+2028 raw.
# Source parity note: JSON.stringify can emit U+2029 raw.
# Source parity note: ECMA-262 line splitting can treat both as terminators.
# Source parity note: ProcessTransport skips non-JSON fragments.
# Source parity note: escaped form remains equivalent JSON.
# Source parity note: source uses one regex alternation for both code points.
