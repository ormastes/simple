"""
Claude full config command descriptor parity.
"""

class ConfigCommandDescriptor:
    aliases: [text]
    typeName: text
    name: text
    description: text
    loadPath: text

impl ConfigCommandDescriptor:
    static fn new() -> ConfigCommandDescriptor:
        ConfigCommandDescriptor(aliases: ["settings"], typeName: "local-jsx", name: "config", description: "Open config panel", loadPath: "./config.js")

fn configIndexSourceLinesModeled() -> i64:
    11
