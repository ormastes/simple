"""
Claude full security-review command parity.
"""

class SecurityReviewCommand:
    name: text
    description: text
    argumentHint: text
    supportsNonInteractive: bool
    allowedTools: [text]

impl SecurityReviewCommand:
    static fn new() -> SecurityReviewCommand:
        SecurityReviewCommand(name: "security-review", description: "Review code for security vulnerabilities", argumentHint: "[path]", supportsNonInteractive: true, allowedTools: ["Read", "Grep", "Glob"])

class SecurityReviewRequest:
    target: text
    prompt: text
    allowedTools: [text]
    blocked: bool
    message: text

impl SecurityReviewRequest:
    static fn new(target: text, prompt: text, allowedTools: [text], blocked: bool, message: text) -> SecurityReviewRequest:
        SecurityReviewRequest(target: target, prompt: prompt, allowedTools: allowedTools, blocked: blocked, message: message)

fn securityReviewCommand() -> SecurityReviewCommand:
    SecurityReviewCommand.new()

fn securityReviewTarget(args: text) -> text:
    val trimmed = args.trim()
    if trimmed == "":
        return "."
    trimmed

fn securityReviewPrompt(target: text) -> text:
    "Perform a security review of " + target + ". Focus on injection, auth, secrets, unsafe file/process access, dependency risk, and data exposure. Return only confirmed issues with file references and concrete fixes."

fn callSecurityReview(args: text, workspaceTrusted: bool) -> SecurityReviewRequest:
    val command = securityReviewCommand()
    val target = securityReviewTarget(args)
    if not workspaceTrusted:
        return SecurityReviewRequest.new(target, "", [], true, "security-review requires a trusted workspace")
    SecurityReviewRequest.new(target, securityReviewPrompt(target), command.allowedTools, false, "queued security review")

fn securityReviewSourceLinesModeled() -> i64:
    243
