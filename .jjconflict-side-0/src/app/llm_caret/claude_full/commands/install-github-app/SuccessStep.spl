"""
Claude full install-github-app SuccessStep parity.
"""

fn successStepTitle() -> text:
    "Claude GitHub App installed"

fn successStepCommandTitle() -> text:
    "Install GitHub App"

fn successStepStatus() -> text:
    "success"

fn successStepWorkflowPath() -> text:
    ".github/workflows/claude.yml"

fn successStepSecretName(secretName: text) -> text:
    val value = secretName.trim()
    if value == "":
        return "ANTHROPIC_API_KEY"
    value

fn successStepRepoLine(repo: text) -> text:
    "Repository: " + repo.trim()

fn successStepWorkflowLine(action: text) -> text:
    if action.trim() == "skip":
        return "Workflow file was not changed"
    "Workflow file configured at " + successStepWorkflowPath()

fn successStepSecretLine(secretName: text) -> text:
    "Secret configured: " + successStepSecretName(secretName)

fn successStepDonePrompt() -> text:
    "Press Enter to finish"

fn successStepSummary(repo: text, secretName: text, action: text) -> text:
    successStepRepoLine(repo) + "\n" + successStepSecretLine(secretName) + "\n" + successStepWorkflowLine(action)

fn successStepSourceLinesModeled() -> i64:
    95
