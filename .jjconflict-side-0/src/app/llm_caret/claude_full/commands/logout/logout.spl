"""
Claude full logout command parity.
"""

class LogoutResult:
    message: text
    clearedCredentials: bool

impl LogoutResult:
    static fn new(message: text, clearedCredentials: bool) -> LogoutResult:
        LogoutResult(message: message, clearedCredentials: clearedCredentials)

fn logoutCommandName() -> text:
    "logout"

fn runLogoutCommand(isAuthenticated: bool) -> LogoutResult:
    if not isAuthenticated:
        return LogoutResult.new("Not logged in", false)
    LogoutResult.new("Logged out", true)

fn logoutSourceLinesModeled() -> i64:
    81
