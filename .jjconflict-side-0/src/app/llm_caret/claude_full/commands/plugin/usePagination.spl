"""
Claude full plugin usePagination parity.
"""

class PaginationState:
    page: i64
    pageSize: i64
    total: i64

impl PaginationState:
    static fn new(page: i64, pageSize: i64, total: i64) -> PaginationState:
        PaginationState(page: page, pageSize: pageSize, total: total)

fn paginationTotalPages(state: PaginationState) -> i64:
    if state.pageSize <= 0:
        return 0
    val full = state.total / state.pageSize
    if state.total % state.pageSize == 0:
        return full
    full + 1

fn paginationCanNext(state: PaginationState) -> bool:
    state.page < paginationTotalPages(state)

fn paginationCanPrevious(state: PaginationState) -> bool:
    state.page > 1

fn usePaginationSourceLinesModeled() -> i64:
    171
