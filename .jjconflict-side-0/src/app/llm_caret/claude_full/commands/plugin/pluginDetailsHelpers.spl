"""
Claude full pluginDetailsHelpers parity.
"""

class PluginDetails:
    name: text
    version: text
    description: text
    trusted: bool

impl PluginDetails:
    static fn new(name: text, version: text, description: text, trusted: bool) -> PluginDetails:
        PluginDetails(name: name, version: version, description: description, trusted: trusted)

fn pluginDetailsTitle(details: PluginDetails) -> text:
    details.name + "@" + details.version

fn pluginTrustLabel(details: PluginDetails) -> text:
    if details.trusted:
        return "trusted"
    "untrusted"

fn pluginDetailsSummary(details: PluginDetails) -> text:
    pluginDetailsTitle(details) + " " + pluginTrustLabel(details) + " " + details.description

fn pluginDetailsHelpersSourceLinesModeled() -> i64:
    116
