"""
Claude full plugin PluginSettings parity model.
"""

const PLUGIN_SETTINGS_SOURCE_LINES = 1071

class PluginSettingsMarketplace:
    name: text
    sourceKind: text
    location: text
    scope: text

impl PluginSettingsMarketplace:
    static fn new(name: text, sourceKind: text, location: text, scope: text) -> PluginSettingsMarketplace:
        PluginSettingsMarketplace(name, sourceKind, location, scope)

class PluginSettingsError:
    message: text
    pluginName: text
    marketplaceName: text
    transient: bool

impl PluginSettingsError:
    static fn new(message: text, pluginName: text, marketplaceName: text, transient: bool) -> PluginSettingsError:
        PluginSettingsError(message, pluginName, marketplaceName, transient)

class PluginSettingsAction:
    label: text
    command: text
    destructive: bool

impl PluginSettingsAction:
    static fn new(label: text, command: text, destructive: bool) -> PluginSettingsAction:
        PluginSettingsAction(label, command, destructive)

class PluginSettingsViewState:
    tab: text
    selectedIndex: i64
    hasErrors: bool

impl PluginSettingsViewState:
    static fn new(tab: text, selectedIndex: i64, hasErrors: bool) -> PluginSettingsViewState:
        PluginSettingsViewState(tab, selectedIndex, hasErrors)

fn pluginSettingsMarketplaceSourceInfo(item: PluginSettingsMarketplace) -> text:
    if item.sourceKind == "github":
        return "GitHub (" + item.location + ")"
    if item.sourceKind == "git":
        return "Git (" + item.location + ")"
    if item.sourceKind == "url":
        return "URL (" + item.location + ")"
    if item.sourceKind == "directory":
        return "Directory (" + item.location + ")"
    if item.sourceKind == "file":
        return "File (" + item.location + ")"
    item.sourceKind + " (" + item.location + ")"

fn pluginSettingsBuildMarketplaceAction(item: PluginSettingsMarketplace) -> PluginSettingsAction:
    PluginSettingsAction.new("Remove marketplace " + item.name, "remove-marketplace:" + item.name + ":" + item.scope, true)

fn pluginSettingsBuildPluginAction(pluginId: text, enabled: bool) -> PluginSettingsAction:
    if enabled:
        return PluginSettingsAction.new("Disable " + pluginId, "disable-plugin:" + pluginId, false)
    PluginSettingsAction.new("Enable " + pluginId, "enable-plugin:" + pluginId, false)

fn pluginSettingsIsTransientError(message: text) -> bool:
    message.contains("timeout") or message.contains("network") or message.contains("ECONNRESET") or message.contains("rate limit")

fn pluginSettingsGetPluginNameFromError(message: text) -> text:
    val marker = "plugin "
    val idx = pluginSettingsIndexOf(message, marker)
    if idx < 0:
        return ""
    val rest = message.substring(idx + marker.len(), message.len())
    val space = pluginSettingsIndexOf(rest, " ")
    if space < 0:
        return rest
    rest.substring(0, space)

fn pluginSettingsBuildErrorRows(errors: [text]) -> [PluginSettingsError]:
    var out: [PluginSettingsError] = []
    var i = 0
    while i < errors.len():
        val message = errors[i]
        out.push(PluginSettingsError.new(message, pluginSettingsGetPluginNameFromError(message), "", pluginSettingsIsTransientError(message)))
        i = i + 1
    out

fn pluginSettingsRemoveMarketplace(items: [PluginSettingsMarketplace], name: text) -> [PluginSettingsMarketplace]:
    var out: [PluginSettingsMarketplace] = []
    var i = 0
    while i < items.len():
        if items[i].name != name:
            out.push(items[i])
        i = i + 1
    out

fn pluginSettingsInitialTab(hasErrors: bool) -> text:
    if hasErrors:
        return "errors"
    "plugins"

fn pluginSettingsInitialViewState(hasErrors: bool) -> PluginSettingsViewState:
    PluginSettingsViewState.new(pluginSettingsInitialTab(hasErrors), 0, hasErrors)

fn pluginSettingsIndexOf(value: text, needle: text) -> i64:
    var i = 0
    while i <= value.len() - needle.len():
        if value.substring(i, i + needle.len()) == needle:
            return i
        i = i + 1
    -1

fn pluginSettingsSourceLinesModeled() -> i64:
    PLUGIN_SETTINGS_SOURCE_LINES
