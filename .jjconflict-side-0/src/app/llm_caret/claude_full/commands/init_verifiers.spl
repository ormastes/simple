"""
Import-safe alias for the hyphenated init-verifiers command model.
"""

class InitVerifierCommandDescriptor:
    typeName: text
    name: text
    description: text
    contentLength: i64
    progressMessage: text
    source: text

    static fn new() -> InitVerifierCommandDescriptor:
        InitVerifierCommandDescriptor(typeName: "prompt", name: "init-verifiers", description: "Create verifier skill(s) for automated verification of code changes", contentLength: 0, progressMessage: "analyzing your project and creating verifier skills", source: "builtin")

class InitVerifierPromptPart:
    typeName: text
    textValue: text

    static fn text(textValue: text) -> InitVerifierPromptPart:
        InitVerifierPromptPart(typeName: "text", textValue: textValue)

fn initVerifiersCommand() -> InitVerifierCommandDescriptor:
    InitVerifierCommandDescriptor.new()

fn initVerifiersPrompt() -> text:
    "Use the TodoWrite tool to track your progress through this multi-step task.\n\n## Goal\n\nCreate one or more verifier skills that can be used by the Verify agent to automatically verify code changes in this project or folder.\n\nDo NOT create verifiers for unit tests or typechecking. Focus on functional verification: web UI (Playwright), CLI (Tmux), and API (HTTP) verifiers.\n\n## Phase 1: Auto-Detection\n\nScan top-level directories and detect project type, stack, application type, existing verification tools, dev server configuration, and installed verification packages.\n\n## Phase 2: Verification Tool Setup\n\nFor web apps, choose or install browser automation. For CLI tools, check asciinema and tmux. For API services, check curl and httpie.\n\n## Phase 3: Interactive Q&A\n\nUse AskUserQuestion to confirm verifier name, project-specific commands and URLs, and authentication details.\n\n## Phase 4: Generate Verifier Skill\n\nAll verifier skills are created in the project root's .claude/skills/ directory at .claude/skills/<verifier-name>/SKILL.md. Include project context, setup instructions, authentication, reporting, cleanup, and self-update guidance. Report PASS or FAIL for each step using the format specified in the verification plan.\n\nverifier-playwright allowed tools include Bash(npm:*), Bash(yarn:*), Bash(pnpm:*), Bash(bun:*), mcp__playwright__*, Read, Glob, Grep.\nverifier-cli allowed tools include Tmux, Bash(asciinema:*), Read, Glob, Grep.\nverifier-api allowed tools include Bash(curl:*), Bash(http:*), Bash(npm:*), Bash(yarn:*), Read, Glob, Grep.\n\n## Phase 5: Confirm Creation\n\nAfter writing the skill file(s), inform the user where each skill was created, how the Verify agent discovers them, that they can edit the skills, rerun /init-verifiers, and rely on self-update for stale verifier instructions."

fn getPromptForInitVerifiersCommand() -> [InitVerifierPromptPart]:
    [InitVerifierPromptPart.text(initVerifiersPrompt())]

fn initVerifiersSourceLinesModeled() -> i64:
    262
