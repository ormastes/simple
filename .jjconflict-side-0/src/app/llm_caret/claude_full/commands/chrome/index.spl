class ChromeCommand:
    typeName: text
    name: text
    description: text
    availability: [text]
    loadPath: text
    enabled: bool

    static fn new(nonInteractiveSession: bool) -> ChromeCommand:
        ChromeCommand(typeName: "local-jsx", name: "chrome", description: "Claude in Chrome (Beta) settings", availability: ["claude-ai"], loadPath: "./chrome.js", enabled: not nonInteractiveSession)

fn chromeCommand(nonInteractiveSession: bool) -> ChromeCommand:
    ChromeCommand.new(nonInteractiveSession)

fn chromeIndexSourceLinesModeled() -> i64:
    13
