"""
Claude full shutdown message parity model.
"""

const SHUTDOWN_MESSAGE_SOURCE_LINES = 131

class ShutdownMessage:
    kind: text
    from_name: text
    reason: text

impl ShutdownMessage:
    static fn new(kind: text, fromName: text, reason: text) -> ShutdownMessage:
        ShutdownMessage(kind: kind, from_name: fromName, reason: reason)

class ShutdownRender:
    visible: bool
    title: text
    reason_line: text
    footer: text
    border_color: text

impl ShutdownRender:
    static fn hidden() -> ShutdownRender:
        ShutdownRender(visible: false, title: "", reason_line: "", footer: "", border_color: "")

    static fn request(fromName: text, reason: text) -> ShutdownRender:
        var reasonLine = ""
        if reason != "":
            reasonLine = "Reason: " + reason
        ShutdownRender(visible: true, title: "Shutdown request from " + fromName, reason_line: reasonLine, footer: "", border_color: "warning")

    static fn rejected(fromName: text, reason: text) -> ShutdownRender:
        ShutdownRender(visible: true, title: "Shutdown rejected by " + fromName, reason_line: "Reason: " + reason, footer: "Teammate is continuing to work. You may request shutdown again later.", border_color: "subtle")

fn parseShutdownMessage(content: text) -> ShutdownMessage:
    if content.starts_with("shutdown-request:"):
        val body = content.slice("shutdown-request:".len(), content.len())
        val parts = body.split("|")
        if parts.len() > 1:
            return ShutdownMessage.new("request", parts[0], parts[1])
        if parts.len() == 1:
            return ShutdownMessage.new("request", parts[0], "")
    if content.starts_with("shutdown-approved:"):
        return ShutdownMessage.new("approved", content.slice("shutdown-approved:".len(), content.len()), "")
    if content.starts_with("shutdown-rejected:"):
        val body = content.slice("shutdown-rejected:".len(), content.len())
        val parts = body.split("|")
        if parts.len() > 1:
            return ShutdownMessage.new("rejected", parts[0], parts[1])
    ShutdownMessage.new("", "", "")

fn isShutdownRequest(content: text) -> bool:
    parseShutdownMessage(content).kind == "request"

fn isShutdownApproved(content: text) -> bool:
    parseShutdownMessage(content).kind == "approved"

fn isShutdownRejected(content: text) -> bool:
    parseShutdownMessage(content).kind == "rejected"

fn tryRenderShutdownMessage(content: text) -> ShutdownRender:
    val msg = parseShutdownMessage(content)
    if msg.kind == "request":
        return ShutdownRender.request(msg.from_name, msg.reason)
    if msg.kind == "approved":
        return ShutdownRender.hidden()
    if msg.kind == "rejected":
        return ShutdownRender.rejected(msg.from_name, msg.reason)
    ShutdownRender.hidden()

fn getShutdownMessageSummary(content: text) -> text:
    val msg = parseShutdownMessage(content)
    if msg.kind == "request":
        if msg.reason != "":
            return "[Shutdown Request from " + msg.from_name + "] " + msg.reason
        return "[Shutdown Request from " + msg.from_name + "]"
    if msg.kind == "approved":
        return "[Shutdown Approved] " + msg.from_name + " is now exiting"
    if msg.kind == "rejected":
        return "[Shutdown Rejected] " + msg.from_name + ": " + msg.reason
    ""

fn shutdownMessageSourceLinesModeled() -> i64:
    SHUTDOWN_MESSAGE_SOURCE_LINES
