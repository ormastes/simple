"""
Claude full user plan message parity model.
"""

const USER_PLAN_MESSAGE_SOURCE_LINES = 41

class UserPlanRender:
    header: text
    plan_content: text
    border_color: text
    border_style: text
    margin_top: i64
    padding_x: i64
    flex_direction: text

impl UserPlanRender:
    static fn new(planContent: text, addMargin: bool) -> UserPlanRender:
        var margin = 0
        if addMargin:
            margin = 1
        UserPlanRender(header: "Plan to implement", plan_content: planContent, border_color: "planMode", border_style: "round", margin_top: margin, padding_x: 1, flex_direction: "column")

fn userPlanMessage(planContent: text, addMargin: bool) -> UserPlanRender:
    UserPlanRender.new(planContent, addMargin)

fn userPlanMessageSourceLinesModeled() -> i64:
    USER_PLAN_MESSAGE_SOURCE_LINES
