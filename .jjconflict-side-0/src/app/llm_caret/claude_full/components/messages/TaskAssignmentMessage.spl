"""
Claude full task assignment message parity model.
"""

const TASK_ASSIGNMENT_MESSAGE_SOURCE_LINES = 75

class TaskAssignment:
    task_id: text
    assigned_by: text
    subject: text
    description: text

impl TaskAssignment:
    static fn new(taskId: text, assignedBy: text, subject: text, description: text) -> TaskAssignment:
        TaskAssignment(task_id: taskId, assigned_by: assignedBy, subject: subject, description: description)

class TaskAssignmentRender:
    visible: bool
    header: text
    subject: text
    description: text
    border_color: text
    margin_y: i64

impl TaskAssignmentRender:
    static fn hidden() -> TaskAssignmentRender:
        TaskAssignmentRender(visible: false, header: "", subject: "", description: "", border_color: "", margin_y: 0)

    static fn new(header: text, subject: text, description: text) -> TaskAssignmentRender:
        TaskAssignmentRender(visible: true, header: header, subject: subject, description: description, border_color: "cyan_FOR_SUBAGENTS_ONLY", margin_y: 1)

fn taskAssignmentDisplay(assignment: TaskAssignment) -> TaskAssignmentRender:
    TaskAssignmentRender.new("Task #" + assignment.task_id + " assigned by " + assignment.assigned_by, assignment.subject, assignment.description)

fn parseTaskAssignment(content: text) -> TaskAssignment:
    val prefix = "task:"
    if not content.starts_with(prefix):
        return TaskAssignment.new("", "", "", "")
    val body = content.slice(prefix.len(), content.len())
    val parts = body.split("|")
    if parts.len() < 3:
        return TaskAssignment.new("", "", "", "")
    var description = ""
    if parts.len() > 3:
        description = parts[3]
    TaskAssignment.new(parts[0], parts[1], parts[2], description)

fn taskAssignmentPresent(assignment: TaskAssignment) -> bool:
    assignment.task_id != "" and assignment.assigned_by != "" and assignment.subject != ""

fn tryRenderTaskAssignmentMessage(content: text) -> TaskAssignmentRender:
    val assignment = parseTaskAssignment(content)
    if taskAssignmentPresent(assignment):
        return taskAssignmentDisplay(assignment)
    TaskAssignmentRender.hidden()

fn getTaskAssignmentSummary(content: text) -> text:
    val assignment = parseTaskAssignment(content)
    if taskAssignmentPresent(assignment):
        return "[Task Assigned] #" + assignment.task_id + " - " + assignment.subject
    ""

fn taskAssignmentMessageSourceLinesModeled() -> i64:
    TASK_ASSIGNMENT_MESSAGE_SOURCE_LINES
