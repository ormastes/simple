"""
Claude full rejected tool-use message parity model.
"""

const REJECTED_TOOL_USE_MESSAGE_SOURCE_LINES = 15

class RejectedToolUseRender:
    text: text
    dim: bool
    response_height: i64

impl RejectedToolUseRender:
    static fn new() -> RejectedToolUseRender:
        RejectedToolUseRender(text: "Tool use rejected", dim: true, response_height: 1)

fn rejectedToolUseMessage() -> RejectedToolUseRender:
    RejectedToolUseRender.new()

fn rejectedToolUseMessageSourceLinesModeled() -> i64:
    REJECTED_TOOL_USE_MESSAGE_SOURCE_LINES
