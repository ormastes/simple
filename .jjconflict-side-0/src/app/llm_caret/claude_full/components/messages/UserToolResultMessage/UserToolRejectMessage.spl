"""
Claude full user tool reject message parity model.
"""

const USER_TOOL_REJECT_MESSAGE_SOURCE_LINES = 94

class UserToolRejectRender:
    fallback: bool
    rendered: text
    columns: i64
    messages_count: i64
    progress_messages_filtered: bool
    style: text
    theme: text
    is_transcript_mode: bool

impl UserToolRejectRender:
    static fn fallback() -> UserToolRejectRender:
        UserToolRejectRender(fallback: true, rendered: "FallbackToolUseRejectedMessage", columns: 0, messages_count: 0, progress_messages_filtered: false, style: "", theme: "", is_transcript_mode: false)

    static fn custom(rendered: text, columns: i64, style: text, theme: text, isTranscriptMode: bool) -> UserToolRejectRender:
        UserToolRejectRender(fallback: false, rendered: rendered, columns: columns, messages_count: 0, progress_messages_filtered: true, style: style, theme: theme, is_transcript_mode: isTranscriptMode)

fn userToolRejectMessage(hasTool: bool, hasRejectedRenderer: bool, inputParsed: bool, customRendered: text, columns: i64, style: text, theme: text, isTranscriptMode: bool) -> UserToolRejectRender:
    if !hasTool || !hasRejectedRenderer:
        return UserToolRejectRender.fallback()
    if !inputParsed:
        return UserToolRejectRender.fallback()
    val rendered = customRendered.trim()
    if rendered == "":
        return UserToolRejectRender.fallback()
    UserToolRejectRender.custom(rendered, columns, style, theme, isTranscriptMode)

fn userToolRejectMessageSourceLinesModeled() -> i64:
    USER_TOOL_REJECT_MESSAGE_SOURCE_LINES
