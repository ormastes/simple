"""
Claude full CustomSelect useSelectNavigation parity.
"""

class SelectNavigationOption:
    value: text
    label: text
    disabled: bool

impl SelectNavigationOption:
    static fn new(value: text, label: text, disabled: bool) -> SelectNavigationOption:
        SelectNavigationOption(value: value.trim(), label: label.trim(), disabled: disabled)

    static fn enabled(value: text, label: text) -> SelectNavigationOption:
        SelectNavigationOption(value: value.trim(), label: label.trim(), disabled: false)

    static fn unavailable(value: text, label: text) -> SelectNavigationOption:
        SelectNavigationOption(value: value.trim(), label: label.trim(), disabled: true)

class SelectNavigationState:
    options: [SelectNavigationOption]
    activeIndex: i64

impl SelectNavigationState:
    static fn new(options: [SelectNavigationOption], activeIndex: i64) -> SelectNavigationState:
        SelectNavigationState(options: options, activeIndex: normalizeSelectNavigationIndex(options, activeIndex))

    me next() -> SelectNavigationState:
        SelectNavigationState(options: self.options, activeIndex: nextSelectNavigationIndex(self.options, self.activeIndex))

    me previous() -> SelectNavigationState:
        SelectNavigationState(options: self.options, activeIndex: previousSelectNavigationIndex(self.options, self.activeIndex))

    me home() -> SelectNavigationState:
        SelectNavigationState(options: self.options, activeIndex: homeSelectNavigationIndex(self.options))

    me end() -> SelectNavigationState:
        SelectNavigationState(options: self.options, activeIndex: endSelectNavigationIndex(self.options))

    me activeValue() -> text:
        selectNavigationValueAt(self.options, self.activeIndex)

    me isEmpty() -> bool:
        firstEnabledSelectNavigationIndex(self.options) == -1

fn createSelectNavigationState(options: [SelectNavigationOption], activeValue: text) -> SelectNavigationState:
    SelectNavigationState.new(options, selectNavigationIndexByValue(options, activeValue))

fn selectNavigationEnabled(option: SelectNavigationOption) -> bool:
    not option.disabled

fn firstEnabledSelectNavigationIndex(options: [SelectNavigationOption]) -> i64:
    var i = 0
    while i < options.len():
        if selectNavigationEnabled(options[i]):
            return i
        i = i + 1
    -1

fn lastEnabledSelectNavigationIndex(options: [SelectNavigationOption]) -> i64:
    var i = options.len() - 1
    while i >= 0:
        if selectNavigationEnabled(options[i]):
            return i
        i = i - 1
    -1

fn normalizeSelectNavigationIndex(options: [SelectNavigationOption], index: i64) -> i64:
    if options.len() == 0:
        return -1
    if index >= 0 and index < options.len() and selectNavigationEnabled(options[index]):
        return index
    firstEnabledSelectNavigationIndex(options)

fn nextSelectNavigationIndex(options: [SelectNavigationOption], currentIndex: i64) -> i64:
    if options.len() == 0:
        return -1
    var index = currentIndex + 1
    if currentIndex < 0 or currentIndex >= options.len():
        index = 0
    var scanned = 0
    while scanned < options.len():
        if index >= options.len():
            index = 0
        if selectNavigationEnabled(options[index]):
            return index
        index = index + 1
        scanned = scanned + 1
    -1

fn previousSelectNavigationIndex(options: [SelectNavigationOption], currentIndex: i64) -> i64:
    if options.len() == 0:
        return -1
    var index = currentIndex - 1
    if currentIndex < 0 or currentIndex >= options.len():
        index = options.len() - 1
    var scanned = 0
    while scanned < options.len():
        if index < 0:
            index = options.len() - 1
        if selectNavigationEnabled(options[index]):
            return index
        index = index - 1
        scanned = scanned + 1
    -1

fn homeSelectNavigationIndex(options: [SelectNavigationOption]) -> i64:
    firstEnabledSelectNavigationIndex(options)

fn endSelectNavigationIndex(options: [SelectNavigationOption]) -> i64:
    lastEnabledSelectNavigationIndex(options)

fn selectNavigationIndexByValue(options: [SelectNavigationOption], value: text) -> i64:
    var i = 0
    val wanted = value.trim()
    while i < options.len():
        if options[i].value == wanted and selectNavigationEnabled(options[i]):
            return i
        i = i + 1
    firstEnabledSelectNavigationIndex(options)

fn selectNavigationValueAt(options: [SelectNavigationOption], index: i64) -> text:
    if index < 0 or index >= options.len():
        return ""
    if options[index].disabled:
        return ""
    options[index].value

fn sampleSelectNavigationOptions() -> [SelectNavigationOption]:
    [
        SelectNavigationOption.enabled("alpha", "Alpha"),
        SelectNavigationOption.unavailable("beta", "Beta"),
        SelectNavigationOption.enabled("gamma", "Gamma"),
        SelectNavigationOption.unavailable("delta", "Delta"),
        SelectNavigationOption.enabled("epsilon", "Epsilon"),
    ]

fn useSelectNavigationModeledSourceFile() -> text:
    "src/components/CustomSelect/use-select-navigation.ts"

fn useSelectNavigationModeledHookName() -> text:
    "useSelectNavigation"

fn useSelectNavigationModeledSourceHelper() -> text:
    "getNextSelectableOption"

fn useSelectNavigationSourceLinesModeled() -> i64:
    653
