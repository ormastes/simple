"""
Claude full CustomSelect single-select parity.
"""

class CustomSelectChoice:
    value: text
    label: text
    disabled: bool

impl CustomSelectChoice:
    static fn new(value: text, label: text, disabled: bool) -> CustomSelectChoice:
        CustomSelectChoice(value: value.trim(), label: label.trim(), disabled: disabled)

fn customSelectChoiceLabel(choice: CustomSelectChoice) -> text:
    if choice.label == "":
        return choice.value
    choice.label

fn customSelectChoiceMatches(choice: CustomSelectChoice, query: text) -> bool:
    val needle = query.trim().lower()
    if needle == "":
        return true
    customSelectChoiceLabel(choice).lower().contains(needle) or choice.value.lower().contains(needle)

class CustomSelectState:
    options: [CustomSelectChoice]
    open: bool
    disabled: bool
    filter: text
    highlighted_index: i64
    selected_value: text
    has_selected_value: bool
    placeholder: text

impl CustomSelectState:
    static fn new(options: [CustomSelectChoice], placeholder: text) -> CustomSelectState:
        CustomSelectState(options: options, open: false, disabled: false, filter: "", highlighted_index: -1, selected_value: "", has_selected_value: false, placeholder: placeholder)

    static fn disabled(options: [CustomSelectChoice], placeholder: text) -> CustomSelectState:
        CustomSelectState(options: options, open: false, disabled: true, filter: "", highlighted_index: -1, selected_value: "", has_selected_value: false, placeholder: placeholder)

    me set_disabled(disabled: bool):
        self.disabled = disabled
        if disabled:
            self.open = false
            self.highlighted_index = -1

    me open_menu():
        if self.disabled:
            return
        self.open = true
        self.highlight_first_enabled()

    me close_menu():
        self.open = false
        self.highlighted_index = -1

    me toggle_menu():
        if self.open:
            self.close_menu()
        else:
            self.open_menu()

    me set_filter(query: text):
        if self.disabled:
            return
        self.filter = query.trim()
        if self.open:
            self.highlight_first_enabled()

    fn filtered_options() -> [CustomSelectChoice]:
        var out: [CustomSelectChoice] = []
        for option in self.options:
            if customSelectChoiceMatches(option, self.filter):
                out.push(option)
        out

    fn option_count() -> i64:
        self.options.len()

    fn filtered_count() -> i64:
        self.filtered_options().len()

    fn selected_label() -> text:
        if not self.has_selected_value:
            return ""
        for option in self.options:
            if option.value == self.selected_value:
                return customSelectChoiceLabel(option)
        self.selected_value

    fn display_label() -> text:
        val label = self.selected_label()
        if label == "":
            return self.placeholder
        label

    fn highlighted_label() -> text:
        val filtered = self.filtered_options()
        if self.highlighted_index < 0 or self.highlighted_index >= filtered.len():
            return ""
        customSelectChoiceLabel(filtered[self.highlighted_index])

    fn highlighted_value() -> text:
        val filtered = self.filtered_options()
        if self.highlighted_index < 0 or self.highlighted_index >= filtered.len():
            return ""
        filtered[self.highlighted_index].value

    me highlight_first_enabled():
        val filtered = self.filtered_options()
        self.highlighted_index = -1
        var i = 0
        while i < filtered.len():
            if not filtered[i].disabled:
                self.highlighted_index = i
                return
            i = i + 1

    me move_highlight(delta: i64):
        if self.disabled or not self.open:
            return
        val filtered = self.filtered_options()
        if filtered.len() == 0:
            self.highlighted_index = -1
            return
        var next = self.highlighted_index + delta
        if next < 0:
            next = filtered.len() - 1
        if next >= filtered.len():
            next = 0
        var attempts = 0
        while attempts < filtered.len():
            if not filtered[next].disabled:
                self.highlighted_index = next
                return
            next = next + delta
            if next < 0:
                next = filtered.len() - 1
            if next >= filtered.len():
                next = 0
            attempts = attempts + 1
        self.highlighted_index = -1

    me select_highlighted() -> bool:
        val filtered = self.filtered_options()
        if self.disabled or self.highlighted_index < 0 or self.highlighted_index >= filtered.len():
            return false
        val option = filtered[self.highlighted_index]
        if option.disabled:
            return false
        self.selected_value = option.value
        self.has_selected_value = true
        self.close_menu()
        true

    me select_value(value: text) -> bool:
        if self.disabled:
            return false
        for option in self.options:
            if option.value == value and not option.disabled:
                self.selected_value = option.value
                self.has_selected_value = true
                self.close_menu()
                return true
        false

    me clear_selection():
        if self.disabled:
            return
        self.selected_value = ""
        self.has_selected_value = false

fn customSelectSelectSourceLinesModeled() -> i64:
    689

fn customSelectSelectSourceSummary() -> text:
    "single select: open closed highlighted selected filtered disabled display source"

