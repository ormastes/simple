class BypassPermissionsState:
    enabled: bool
    acknowledged: bool

impl BypassPermissionsState:
    static fn new(enabled: bool, acknowledged: bool) -> BypassPermissionsState:
        BypassPermissionsState(enabled: enabled, acknowledged: acknowledged)

fn bypassPermissionsDialogVisible(state: BypassPermissionsState) -> bool:
    state.enabled and not state.acknowledged

fn bypassPermissionsDialogMessage(state: BypassPermissionsState) -> text:
    if bypassPermissionsDialogVisible(state):
        return "Bypass permissions mode requires confirmation"
    "Bypass permissions dialog hidden"

