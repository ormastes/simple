"""
Claude full LogoV2 guest passes upsell parity.
"""

class GuestPassesUpsellState:
    passes_available: i64
    dismissed: bool
    plan: text

impl GuestPassesUpsellState:
    static fn new(passesAvailable: i64, dismissed: bool, plan: text) -> GuestPassesUpsellState:
        GuestPassesUpsellState(passes_available: guestPassesCount(passesAvailable), dismissed: dismissed, plan: guestPassesPlan(plan))

fn guestPassesCount(count: i64) -> i64:
    if count < 0:
        return 0
    count

fn guestPassesPlan(plan: text) -> text:
    val clean = plan.trim().lower()
    if clean == "":
        return "pro"
    clean

fn guestPassesUpsellVisible(state: GuestPassesUpsellState) -> bool:
    state.passes_available > 0 and not state.dismissed

fn guestPassesUpsellAction(state: GuestPassesUpsellState) -> text:
    if state.plan == "team":
        return "Invite teammate"
    "Share guest pass"

fn guestPassesUpsellSummary(state: GuestPassesUpsellState) -> text:
    if not guestPassesUpsellVisible(state):
        return "guest-passes hidden"
    "guest-passes " + state.passes_available.to_text() + " action=" + guestPassesUpsellAction(state)

fn guestPassesUpsellSourceLinesModeled() -> i64:
    69
