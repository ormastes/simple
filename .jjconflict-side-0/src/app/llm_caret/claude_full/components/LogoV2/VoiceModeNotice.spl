"""
Claude full LogoV2 voice mode notice parity.
"""

class VoiceModeNoticeState:
    active: bool
    muted: bool
    device: text

impl VoiceModeNoticeState:
    static fn new(active: bool, muted: bool, device: text) -> VoiceModeNoticeState:
        VoiceModeNoticeState(active: active, muted: muted, device: voiceModeDevice(device))

fn voiceModeDevice(device: text) -> text:
    val clean = device.trim()
    if clean == "":
        return "default microphone"
    clean

fn voiceModeNoticeVisible(state: VoiceModeNoticeState) -> bool:
    state.active

fn voiceModeNoticeTone(state: VoiceModeNoticeState) -> text:
    if not state.active:
        return "neutral"
    if state.muted:
        return "warning"
    "success"

fn voiceModeNoticeSummary(state: VoiceModeNoticeState) -> text:
    if not voiceModeNoticeVisible(state):
        return "voice-mode inactive"
    "voice-mode " + voiceModeNoticeTone(state) + " device=" + state.device

fn voiceModeNoticeSourceLinesModeled() -> i64:
    67
