"""
Claude full CtrlOToExpand component parity.
"""

fn ctrlOToExpandLabel(expanded: bool) -> text:
    if expanded:
        return "Ctrl+O to collapse"
    "Ctrl+O to expand"

fn ctrlOToExpandVisible(hasMore: bool) -> bool:
    hasMore

fn ctrlOToExpandSourceLinesModeled() -> i64:
    50
