"""
Claude full AutoUpdater component parity.
"""

class AutoUpdateState:
    currentVersion: text
    nextVersion: text
    checking: bool

impl AutoUpdateState:
    static fn new(currentVersion: text, nextVersion: text, checking: bool) -> AutoUpdateState:
        AutoUpdateState(currentVersion: currentVersion.trim(), nextVersion: nextVersion.trim(), checking: checking)

fn autoUpdateAvailable(state: AutoUpdateState) -> bool:
    state.nextVersion != "" and state.nextVersion != state.currentVersion

fn autoUpdaterStatus(state: AutoUpdateState) -> text:
    if state.checking:
        return "Checking for updates"
    if autoUpdateAvailable(state):
        return "Update available: " + state.nextVersion
    "Claude Code is up to date"

fn autoUpdaterSourceLinesModeled() -> i64:
    197
