"""
Importable alias for Claude full TypeStep parity.
"""

fn normalizeAgentKind(raw: text) -> text:
    val value = raw.trim().to_lower()
    if value == "general" or value == "specialist" or value == "reviewer":
        return value
    "general"

fn typeStepSummary(raw: text) -> text:
    "Type: " + normalizeAgentKind(raw)

fn typeStepSourceLinesModeled() -> i64:
    102
