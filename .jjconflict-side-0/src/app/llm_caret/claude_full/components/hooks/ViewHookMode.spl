"""
Claude full hooks ViewHookMode parity.
"""

class HookViewState:
    name: text
    event_mode: text
    hook_mode: text
    matcher: text
    enabled: bool

impl HookViewState:
    static fn new(name: text, eventMode: text, hookMode: text, matcher: text, enabled: bool) -> HookViewState:
        HookViewState(name: name.trim(), event_mode: eventMode.trim(), hook_mode: hookMode.trim(), matcher: matcher.trim(), enabled: enabled)

fn hookViewTitle(state: HookViewState) -> text:
    if state.name == "":
        return "Unnamed hook"
    state.name

fn hookViewStatus(state: HookViewState) -> text:
    if state.enabled:
        return "enabled"
    "disabled"

fn hookViewSummary(state: HookViewState) -> text:
    hookViewTitle(state) + " " + hookViewStatus(state) + " " + state.event_mode + " " + state.hook_mode

fn hookViewCanEdit(state: HookViewState) -> bool:
    state.name != ""

fn viewHookModeSourceLinesModeled() -> i64:
    198
