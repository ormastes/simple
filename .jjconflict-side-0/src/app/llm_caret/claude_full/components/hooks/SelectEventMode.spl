"""
Claude full hooks SelectEventMode parity.
"""

fn normalizeHookEventMode(mode: text) -> text:
    val clean = mode.trim()
    if clean == "pre" or clean == "post" or clean == "notification":
        return clean
    "pre"

fn hookEventModeLabel(mode: text) -> text:
    val clean = normalizeHookEventMode(mode)
    if clean == "pre":
        return "Before event"
    if clean == "post":
        return "After event"
    "Notification event"

fn hookEventModeCanRun(mode: text, enabled: bool) -> bool:
    enabled and normalizeHookEventMode(mode) != ""

fn selectEventModeSourceLinesModeled() -> i64:
    126
