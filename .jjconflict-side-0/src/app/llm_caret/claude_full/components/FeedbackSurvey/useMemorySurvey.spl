"""
Claude full useMemorySurvey parity.
"""

class MemorySurveyState:
    enabled: bool
    memory_count: i64
    dismissed: bool
    rating: i64
    note: text

impl MemorySurveyState:
    static fn new(enabled: bool, memoryCount: i64, dismissed: bool, rating: i64, note: text) -> MemorySurveyState:
        MemorySurveyState(enabled: enabled, memory_count: clampMemoryCount(memoryCount), dismissed: dismissed, rating: clampMemorySurveyRating(rating), note: note.trim())

fn clampMemoryCount(count: i64) -> i64:
    if count < 0:
        return 0
    count

fn clampMemorySurveyRating(rating: i64) -> i64:
    if rating < 0:
        return 0
    if rating > 5:
        return 5
    rating

fn memorySurveyVisible(state: MemorySurveyState) -> bool:
    state.enabled and not state.dismissed and state.memory_count > 0

fn memorySurveyPrompt(state: MemorySurveyState) -> text:
    if not memorySurveyVisible(state):
        return "Memory survey hidden"
    "Rate " + state.memory_count.to_text() + " remembered item(s)"

fn memorySurveyCanSubmit(state: MemorySurveyState) -> bool:
    memorySurveyVisible(state) and state.rating > 0

fn memorySurveySubmit(state: MemorySurveyState) -> MemorySurveyState:
    if memorySurveyCanSubmit(state):
        return MemorySurveyState.new(state.enabled, state.memory_count, true, state.rating, state.note)
    state

fn useMemorySurveySourceLinesModeled() -> i64:
    212
