"""
Claude full useSurveyState parity.
"""

class SurveyState:
    open: bool
    rating: i64
    comment: text
    submitted: bool

impl SurveyState:
    static fn new(open: bool, rating: i64, comment: text, submitted: bool) -> SurveyState:
        SurveyState(open: open, rating: clampSurveyRating(rating), comment: comment.trim(), submitted: submitted)

fn clampSurveyRating(rating: i64) -> i64:
    if rating < 0:
        return 0
    if rating > 5:
        return 5
    rating

fn surveyStateCanSubmit(state: SurveyState) -> bool:
    state.open and not state.submitted and state.rating > 0

fn surveyStateWithRating(state: SurveyState, rating: i64) -> SurveyState:
    SurveyState.new(state.open, rating, state.comment, state.submitted)

fn surveyStateSubmit(state: SurveyState) -> SurveyState:
    if surveyStateCanSubmit(state):
        return SurveyState.new(false, state.rating, state.comment, true)
    state

fn useSurveyStateSourceLinesModeled() -> i64:
    99
