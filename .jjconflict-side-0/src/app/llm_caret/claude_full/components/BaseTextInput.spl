"""
Claude full BaseTextInput component parity.
"""

class BaseTextInputState:
    value: text
    placeholder: text
    disabled: bool

impl BaseTextInputState:
    static fn new(value: text, placeholder: text, disabled: bool) -> BaseTextInputState:
        BaseTextInputState(value: value, placeholder: placeholder, disabled: disabled)

fn baseTextInputDisplay(state: BaseTextInputState) -> text:
    if state.value.trim() == "":
        return state.placeholder
    state.value

fn baseTextInputCanEdit(state: BaseTextInputState) -> bool:
    not state.disabled

fn baseTextInputSourceLinesModeled() -> i64:
    135
