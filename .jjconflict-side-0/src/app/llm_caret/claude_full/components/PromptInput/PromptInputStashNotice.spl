class PromptInputStashNoticeView:
    visible: bool
    paddingLeft: i64
    dim: bool
    glyph: text
    sourceGlyph: text
    text: text

impl PromptInputStashNoticeView:
    static fn new(visible: bool, paddingLeft: i64, dim: bool, glyph: text, sourceGlyph: text, text: text) -> PromptInputStashNoticeView:
        PromptInputStashNoticeView(visible: visible, paddingLeft: paddingLeft, dim: dim, glyph: glyph, sourceGlyph: sourceGlyph, text: text)

fn PromptInputStashNotice(hasStash: bool) -> PromptInputStashNoticeView:
    if not hasStash:
        return PromptInputStashNoticeView.new(false, 0, false, "", "figures.pointerSmall", "")
    PromptInputStashNoticeView.new(true, 2, true, ">", "figures.pointerSmall", "Stashed (auto-restores after submit)")

fn promptInputStashNoticeText(hasStash: bool) -> text:
    val view = PromptInputStashNotice(hasStash)
    if not view.visible:
        return ""
    view.glyph + " " + view.text
