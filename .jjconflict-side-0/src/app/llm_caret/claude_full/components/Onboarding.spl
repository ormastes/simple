"""
Claude full Onboarding component parity surface.
"""

type OnboardingStepId = text

class OnboardingFlowState:
    current_step_index: i64
    oauth_enabled: bool
    skip_oauth: bool
    api_key_needs_approval: bool
    terminal_setup_enabled: bool
    theme_selected: bool
    completed: bool

impl OnboardingFlowState:
    static fn new(oauthEnabled: bool, apiKeyNeedsApproval: bool, terminalSetupEnabled: bool) -> OnboardingFlowState:
        OnboardingFlowState(
            current_step_index: 0,
            oauth_enabled: oauthEnabled,
            skip_oauth: false,
            api_key_needs_approval: apiKeyNeedsApproval,
            terminal_setup_enabled: terminalSetupEnabled,
            theme_selected: false,
            completed: false,
        )

fn onboardingStepCount(state: OnboardingFlowState) -> i64:
    2 + (if state.oauth_enabled: 2 else: 0) + (if state.api_key_needs_approval: 1 else: 0) + (if state.terminal_setup_enabled: 1 else: 0)

fn onboardingStepIdAt(state: OnboardingFlowState, index: i64) -> OnboardingStepId:
    var cursor = index
    if state.oauth_enabled:
        if cursor == 0:
            return "preflight"
        cursor = cursor - 1
    if cursor == 0:
        return "theme"
    cursor = cursor - 1
    if state.api_key_needs_approval:
        if cursor == 0:
            return "api-key"
        cursor = cursor - 1
    if state.oauth_enabled:
        if cursor == 0:
            return "oauth"
        cursor = cursor - 1
    if cursor == 0:
        return "security"
    cursor = cursor - 1
    if state.terminal_setup_enabled and cursor == 0:
        return "terminal-setup"
    ""

fn onboardingCurrentStepId(state: OnboardingFlowState) -> OnboardingStepId:
    onboardingStepIdAt(state, state.current_step_index)

fn onboardingCanContinue(state: OnboardingFlowState) -> bool:
    (not state.completed) and onboardingCurrentStepId(state) != ""

fn onboardingAdvance(state: OnboardingFlowState) -> OnboardingFlowState:
    if state.current_step_index >= onboardingStepCount(state) - 1:
        return onboardingComplete(state)
    OnboardingFlowState(
        current_step_index: state.current_step_index + 1,
        oauth_enabled: state.oauth_enabled,
        skip_oauth: state.skip_oauth,
        api_key_needs_approval: state.api_key_needs_approval,
        terminal_setup_enabled: state.terminal_setup_enabled,
        theme_selected: state.theme_selected,
        completed: state.completed,
    )

fn onboardingSelectTheme(state: OnboardingFlowState) -> OnboardingFlowState:
    OnboardingFlowState(
        current_step_index: state.current_step_index + 1,
        oauth_enabled: state.oauth_enabled,
        skip_oauth: state.skip_oauth,
        api_key_needs_approval: state.api_key_needs_approval,
        terminal_setup_enabled: state.terminal_setup_enabled,
        theme_selected: true,
        completed: state.completed,
    )

fn onboardingApproveApiKey(state: OnboardingFlowState, approved: bool) -> OnboardingFlowState:
    OnboardingFlowState(
        current_step_index: state.current_step_index + 1,
        oauth_enabled: state.oauth_enabled,
        skip_oauth: approved or state.skip_oauth,
        api_key_needs_approval: state.api_key_needs_approval,
        terminal_setup_enabled: state.terminal_setup_enabled,
        theme_selected: state.theme_selected,
        completed: state.completed,
    )

fn onboardingSkipOAuth(state: OnboardingFlowState) -> OnboardingFlowState:
    OnboardingFlowState(
        current_step_index: state.current_step_index + 1,
        oauth_enabled: state.oauth_enabled,
        skip_oauth: true,
        api_key_needs_approval: state.api_key_needs_approval,
        terminal_setup_enabled: state.terminal_setup_enabled,
        theme_selected: state.theme_selected,
        completed: state.completed,
    )

fn onboardingComplete(state: OnboardingFlowState) -> OnboardingFlowState:
    OnboardingFlowState(
        current_step_index: onboardingStepCount(state) - 1,
        oauth_enabled: state.oauth_enabled,
        skip_oauth: state.skip_oauth,
        api_key_needs_approval: state.api_key_needs_approval,
        terminal_setup_enabled: state.terminal_setup_enabled,
        theme_selected: state.theme_selected,
        completed: true,
    )

fn onboardingSummary(state: OnboardingFlowState) -> text:
    onboardingCurrentStepId(state) + ":" + state.current_step_index.to_text()

fn onboardingSourceLinesModeled() -> i64:
    243
