"""
Claude full MCP stdio server menu parity.
"""

class MCPStdioServerState:
    name: text
    client_type: text
    command: text
    args: [text]
    tools_count: i64
    prompts_count: i64
    resources_count: i64
    reconnecting: bool
    borderless: bool

impl MCPStdioServerState:
    static fn new(name: text, clientType: text, command: text, args: [text], toolsCount: i64, promptsCount: i64, resourcesCount: i64, reconnecting: bool, borderless: bool) -> MCPStdioServerState:
        MCPStdioServerState(name: name.trim(), client_type: normalizeMcpStdioClientType(clientType), command: command.trim(), args: args, tools_count: clampMcpStdioCount(toolsCount), prompts_count: clampMcpStdioCount(promptsCount), resources_count: clampMcpStdioCount(resourcesCount), reconnecting: reconnecting, borderless: borderless)

fn clampMcpStdioCount(count: i64) -> i64:
    if count < 0:
        return 0
    count

fn normalizeMcpStdioClientType(value: text) -> text:
    val clean = value.trim().lower()
    if clean == "disabled" or clean == "connected" or clean == "pending" or clean == "failed":
        return clean
    "failed"

fn mcpStdioStatusLabel(state: MCPStdioServerState) -> text:
    if state.client_type == "disabled":
        return "disabled"
    if state.client_type == "connected":
        return "connected"
    if state.client_type == "pending":
        return "connecting"
    "failed"

fn mcpStdioMenuOptions(state: MCPStdioServerState) -> [text]:
    var options: [text] = []
    if state.client_type != "disabled" and state.tools_count > 0:
        options.push("tools:View tools")
    if state.client_type != "disabled":
        options.push("reconnectMcpServer:Reconnect")
    if state.client_type == "disabled":
        options.push("toggle-enabled:Enable")
    else:
        options.push("toggle-enabled:Disable")
    if options.len() == 0:
        options.push("back:Back")
    options

fn mcpStdioArgsLine(state: MCPStdioServerState) -> text:
    var out = ""
    var i = 0
    while i < state.args.len():
        if i > 0:
            out = out + " "
        out = out + state.args[i]
        i = i + 1
    out

fn mcpStdioCapabilitiesSummary(state: MCPStdioServerState) -> text:
    if state.client_type != "connected":
        return "Capabilities: none"
    "tools=" + state.tools_count.to_text() + " prompts=" + state.prompts_count.to_text() + " resources=" + state.resources_count.to_text()

fn mcpStdioSummary(state: MCPStdioServerState) -> text:
    if state.reconnecting:
        return "Reconnecting to " + state.name
    state.name + " status=" + mcpStdioStatusLabel(state) + " command=" + state.command

fn mcpStdioServerMenuSourceLinesModeled() -> i64:
    176
