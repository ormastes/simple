"""
Claude full NativeAutoUpdater parity model.
"""

const NATIVE_AUTO_UPDATER_SOURCE_LINES = 192

class NativeAutoUpdaterState:
    is_checking: bool
    current_version: text
    latest_version: text
    warning: text
    result_kind: text
    error_message: text
    disabled: bool
    lock_contention: bool
    verbose: bool
    channel: text

impl NativeAutoUpdaterState:
    static fn new(isChecking: bool, currentVersion: text, latestVersion: text, warning: text, resultKind: text, errorMessage: text, disabled: bool, lockContention: bool, verbose: bool, channel: text) -> NativeAutoUpdaterState:
        NativeAutoUpdaterState(is_checking: isChecking, current_version: currentVersion, latest_version: latestVersion, warning: warning, result_kind: resultKind, error_message: errorMessage, disabled: disabled, lock_contention: lockContention, verbose: verbose, channel: channel)

fn nativeAutoUpdaterShouldRender(state: NativeAutoUpdaterState) -> bool:
    if state.disabled or state.lock_contention:
        false
    else:
        state.warning != "" or state.result_kind != "" or (state.is_checking and state.current_version != "" and state.latest_version != "")

fn nativeAutoUpdaterErrorType(message: text) -> text:
    val lower = message.lower()
    if lower.contains("checksum"):
        "checksum_mismatch"
    else if lower.contains("permission") or lower.contains("denied"):
        "permission_denied"
    else if lower.contains("network") or lower.contains("timeout"):
        "network"
    else:
        "install_failed"

fn nativeAutoUpdaterStatusMessage(state: NativeAutoUpdaterState) -> text:
    if not nativeAutoUpdaterShouldRender(state):
        ""
    else if state.warning != "":
        state.warning
    else if state.result_kind == "success":
        "Update installed. Restart Claude Code to use the latest version."
    else if state.result_kind == "install_failed":
        "Update failed. Run /status for details."
    else if state.is_checking:
        "current: " + state.current_version + " · " + state.channel + ": " + state.latest_version + "\nChecking for updates"
    else:
        ""

fn nativeAutoUpdaterSourceLinesModeled() -> i64:
    NATIVE_AUTO_UPDATER_SOURCE_LINES
