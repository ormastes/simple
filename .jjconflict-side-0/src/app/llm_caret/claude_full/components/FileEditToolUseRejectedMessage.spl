"""
Claude full FileEditToolUseRejectedMessage parity.
"""

class FileEditRejectedState:
    path: text
    reason: text
    user: text
    can_retry: bool

impl FileEditRejectedState:
    static fn new(path: text, reason: text, user: text, canRetry: bool) -> FileEditRejectedState:
        FileEditRejectedState(path: path.trim(), reason: reason.trim(), user: user.trim(), can_retry: canRetry)

fn fileEditRejectedPath(state: FileEditRejectedState) -> text:
    if state.path == "":
        return "unknown file"
    state.path

fn fileEditRejectedReason(state: FileEditRejectedState) -> text:
    if state.reason == "":
        return "Edit rejected"
    state.reason

fn fileEditRejectedTitle(state: FileEditRejectedState) -> text:
    "Rejected edit for " + fileEditRejectedPath(state)

fn fileEditRejectedAction(state: FileEditRejectedState) -> text:
    if state.can_retry:
        return "Revise edit"
    "Dismiss"

fn fileEditRejectedSummary(state: FileEditRejectedState) -> text:
    if state.user == "":
        return fileEditRejectedTitle(state) + " by user: " + fileEditRejectedReason(state)
    fileEditRejectedTitle(state) + " by " + state.user + ": " + fileEditRejectedReason(state)

fn fileEditToolUseRejectedMessageSourceLinesModeled() -> i64:
    169
