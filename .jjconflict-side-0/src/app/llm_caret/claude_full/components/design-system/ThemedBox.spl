"""
Claude full design-system ThemedBox parity.
"""

class ThemedBoxState:
    theme: text
    padding: i64
    outlined: bool

impl ThemedBoxState:
    static fn new(theme: text, padding: i64, outlined: bool) -> ThemedBoxState:
        ThemedBoxState(theme: theme.trim(), padding: padding, outlined: outlined)

fn themedBoxTheme(state: ThemedBoxState) -> text:
    if state.theme == "":
        return "default"
    state.theme

fn themedBoxPadding(state: ThemedBoxState) -> i64:
    if state.padding < 0:
        return 0
    if state.padding > 8:
        return 8
    state.padding

fn themedBoxClassName(state: ThemedBoxState) -> text:
    val base = "box-" + themedBoxTheme(state)
    if state.outlined:
        return base + " outlined"
    base

fn themedBoxSummary(state: ThemedBoxState) -> text:
    themedBoxClassName(state) + " p" + themedBoxPadding(state).to_text()

fn themedBoxSourceLinesModeled() -> i64:
    155
