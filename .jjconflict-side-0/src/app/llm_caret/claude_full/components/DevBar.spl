"""
Claude full DevBar parity.
"""

fn devBarVisible(enabled: bool, environment: text) -> bool:
    enabled and environment.trim() != "production"

fn devBarLabel(environment: text, branch: text) -> text:
    val env = environment.trim()
    val cleanBranch = branch.trim()
    if cleanBranch == "":
        return env
    env + " " + cleanBranch

fn devBarTone(environment: text) -> text:
    if environment.trim() == "staging":
        return "warning"
    if environment.trim() == "development":
        return "info"
    "muted"

fn devBarSourceLinesModeled() -> i64:
    48
