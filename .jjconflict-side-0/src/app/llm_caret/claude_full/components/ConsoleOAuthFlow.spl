"""
Claude full ConsoleOAuthFlow component parity.
"""

class ConsoleOAuthProvider:
    id: text
    name: text
    authUrl: text
    codeLabel: text
    source: text

impl ConsoleOAuthProvider:
    static fn new(id: text, name: text, authUrl: text, codeLabel: text, source: text) -> ConsoleOAuthProvider:
        ConsoleOAuthProvider(id: normalizeConsoleOAuthProviderId(id), name: consoleOAuthProviderName(name), authUrl: authUrl.trim(), codeLabel: consoleOAuthCodeLabel(codeLabel), source: consoleOAuthSource(source))

class ConsoleOAuthFlowState:
    provider: ConsoleOAuthProvider
    status: text
    authUrl: text
    userCode: text
    copied: bool
    opened: bool
    error: text

impl ConsoleOAuthFlowState:
    static fn new(provider: ConsoleOAuthProvider, status: text, authUrl: text, userCode: text, copied: bool, opened: bool, error: text) -> ConsoleOAuthFlowState:
        ConsoleOAuthFlowState(provider: provider, status: consoleOAuthNormalizeStatus(status), authUrl: consoleOAuthUrl(authUrl, provider.authUrl), userCode: consoleOAuthCode(userCode), copied: copied, opened: opened, error: error.trim())

    me withStatus(status: text, error: text) -> ConsoleOAuthFlowState:
        ConsoleOAuthFlowState.new(me.provider, status, me.authUrl, me.userCode, me.copied, me.opened, error)

    me copyCode() -> ConsoleOAuthFlowState:
        ConsoleOAuthFlowState.new(me.provider, me.status, me.authUrl, me.userCode, true, me.opened, me.error)

    me openUrl() -> ConsoleOAuthFlowState:
        ConsoleOAuthFlowState.new(me.provider, me.status, me.authUrl, me.userCode, me.copied, true, me.error)

fn consoleOAuthAnthropicProvider() -> ConsoleOAuthProvider:
    ConsoleOAuthProvider.new("anthropic", "Anthropic", "https://console.anthropic.com/oauth/authorize", "code", "ConsoleOAuthFlow")

fn consoleOAuthProviderName(value: text) -> text:
    val clean = value.trim()
    if clean == "":
        return "Anthropic"
    clean

fn normalizeConsoleOAuthProviderId(value: text) -> text:
    val clean = value.trim()
    if clean == "":
        return "anthropic"
    clean

fn consoleOAuthCodeLabel(value: text) -> text:
    val clean = value.trim()
    if clean == "":
        return "code"
    clean

fn consoleOAuthSource(value: text) -> text:
    val clean = value.trim()
    if clean == "":
        return "ConsoleOAuthFlow"
    clean

fn consoleOAuthSourceHelper(provider: ConsoleOAuthProvider) -> text:
    provider.source + ":" + provider.id

fn consoleOAuthInitialStatus() -> text:
    "idle"

fn consoleOAuthWaitingStatus() -> text:
    "waiting"

fn consoleOAuthOpeningStatus() -> text:
    "opening-browser"

fn consoleOAuthCopiedStatus() -> text:
    "copied-code"

fn consoleOAuthSuccessStatus() -> text:
    "success"

fn consoleOAuthErrorStatus() -> text:
    "error"

fn consoleOAuthNormalizeStatus(status: text) -> text:
    val value = status.trim()
    if value == "idle" or value == "opening-browser" or value == "waiting" or value == "copied-code" or value == "success" or value == "error" or value == "cancelled":
        return value
    "idle"

fn consoleOAuthUrl(authUrl: text, fallbackUrl: text) -> text:
    val clean = authUrl.trim()
    if clean == "":
        return fallbackUrl.trim()
    clean

fn consoleOAuthCode(userCode: text) -> text:
    userCode.trim()

fn consoleOAuthTitle(provider: ConsoleOAuthProvider) -> text:
    "Sign in with " + provider.name

fn consoleOAuthStepLabel(status: text) -> text:
    val value = consoleOAuthNormalizeStatus(status)
    if value == "opening-browser":
        return "Opening browser"
    if value == "waiting":
        return "Waiting for browser authorization"
    if value == "copied-code":
        return "Code copied"
    if value == "success":
        return "Authenticated"
    if value == "error":
        return "Authentication failed"
    if value == "cancelled":
        return "Authentication cancelled"
    "Ready to sign in"

fn consoleOAuthStatusLine(state: ConsoleOAuthFlowState) -> text:
    if state.status == "error":
        return consoleOAuthErrorLine(state.error)
    if state.status == "success":
        return state.provider.name + " authentication complete"
    consoleOAuthStepLabel(state.status)

fn consoleOAuthInstruction(state: ConsoleOAuthFlowState) -> text:
    if state.userCode == "":
        return "Open " + state.authUrl + " to continue"
    "Open " + state.authUrl + " and enter " + state.provider.codeLabel + " " + state.userCode

fn consoleOAuthCopyAction(state: ConsoleOAuthFlowState) -> text:
    if state.userCode == "":
        return "copy-disabled"
    "copy-code:" + state.userCode

fn consoleOAuthOpenAction(state: ConsoleOAuthFlowState) -> text:
    if state.authUrl == "":
        return "open-disabled"
    "open-url:" + state.authUrl

fn consoleOAuthPrimaryAction(status: text) -> text:
    val value = consoleOAuthNormalizeStatus(status)
    if value == "success":
        return "continue"
    if value == "error" or value == "cancelled":
        return "retry"
    "wait"

fn consoleOAuthCanCopy(state: ConsoleOAuthFlowState) -> bool:
    state.userCode != "" and state.status != "success"

fn consoleOAuthCanOpen(state: ConsoleOAuthFlowState) -> bool:
    state.authUrl != "" and state.status != "success"

fn consoleOAuthErrorLine(error: text) -> text:
    val clean = error.trim()
    if clean == "":
        return "Authentication failed"
    "Authentication failed: " + clean

fn consoleOAuthRenderSummary(state: ConsoleOAuthFlowState) -> text:
    consoleOAuthTitle(state.provider) + " | " + consoleOAuthStatusLine(state) + " | " + consoleOAuthInstruction(state)

fn consoleOAuthSourceLinesModeled() -> i64:
    630
