"""
Claude full FallbackPermissionRequest parity model.
"""

const FALLBACK_PERMISSION_REQUEST_SOURCE_LINES = 332

class FallbackPermissionRequestOption:
    label: text
    value: text

impl FallbackPermissionRequestOption:
    static fn new(label: text, value: text) -> FallbackPermissionRequestOption:
        FallbackPermissionRequestOption(label: label, value: value)

class FallbackPermissionRequest:
    tool_name: text
    user_facing_name: text
    tool_message: text
    description: text
    permission_result: text
    worker_badge: text
    original_cwd: text
    show_always_allow_options: bool
    is_mcp: bool

impl FallbackPermissionRequest:
    static fn new(toolName: text, userFacingName: text, toolMessage: text, description: text, permissionResult: text, workerBadge: text, originalCwd: text, showAlwaysAllowOptions: bool, isMcp: bool) -> FallbackPermissionRequest:
        FallbackPermissionRequest(tool_name: toolName, user_facing_name: userFacingName, tool_message: toolMessage, description: description, permission_result: permissionResult, worker_badge: workerBadge, original_cwd: originalCwd, show_always_allow_options: showAlwaysAllowOptions, is_mcp: isMcp)

class FallbackPermissionRequestRender:
    title: text
    user_facing_name: text
    tool_message: text
    description: text
    rule_explanation: text
    worker_badge: text
    tool_analytics_name: text
    is_mcp: bool
    original_cwd: text
    options: [FallbackPermissionRequestOption]

impl FallbackPermissionRequestRender:
    static fn new(title: text, userFacingName: text, toolMessage: text, description: text, ruleExplanation: text, workerBadge: text, toolAnalyticsName: text, isMcp: bool, originalCwd: text, options: [FallbackPermissionRequestOption]) -> FallbackPermissionRequestRender:
        FallbackPermissionRequestRender(title: title, user_facing_name: userFacingName, tool_message: toolMessage, description: description, rule_explanation: ruleExplanation, worker_badge: workerBadge, tool_analytics_name: toolAnalyticsName, is_mcp: isMcp, original_cwd: originalCwd, options: options)

class FallbackPermissionRequestResponse:
    value: text
    done: bool
    rejected: bool
    event: text
    allow_rule_tool_name: text
    feedback: text

impl FallbackPermissionRequestResponse:
    static fn new(value: text, done: bool, rejected: bool, event: text, allowRuleToolName: text, feedback: text) -> FallbackPermissionRequestResponse:
        FallbackPermissionRequestResponse(value: value, done: done, rejected: rejected, event: event, allow_rule_tool_name: allowRuleToolName, feedback: feedback)

fn fallbackPermissionRequestStripMcpSuffix(name: text) -> text:
    if name.ends_with(" (MCP)"):
        name.substring(0, name.len() - 6)
    else:
        name

fn fallbackPermissionRequestDisplayDescription(description: text) -> text:
    var out = ""
    var lineIndex = 0
    for line in description.split("\n"):
        if lineIndex >= 3:
            return out
        if out != "":
            out = out + "\n"
        out = out + line
        lineIndex = lineIndex + 1
    out

fn fallbackPermissionRequestAlwaysAllowLabel(userFacingName: text, originalCwd: text) -> text:
    "Yes, and don't ask again for " + userFacingName + " commands in " + originalCwd

fn fallbackPermissionRequestOptions(request: FallbackPermissionRequest) -> [FallbackPermissionRequestOption]:
    var options: [FallbackPermissionRequestOption] = [FallbackPermissionRequestOption.new("Yes", "yes")]
    if request.show_always_allow_options:
        options.push(FallbackPermissionRequestOption.new(fallbackPermissionRequestAlwaysAllowLabel(fallbackPermissionRequestStripMcpSuffix(request.user_facing_name), request.original_cwd), "yes-dont-ask-again"))
    options.push(FallbackPermissionRequestOption.new("No", "no"))
    options

fn fallbackPermissionRequest(request: FallbackPermissionRequest) -> FallbackPermissionRequestRender:
    val userFacingName = fallbackPermissionRequestStripMcpSuffix(request.user_facing_name)
    FallbackPermissionRequestRender.new("Tool use", userFacingName, request.tool_message, fallbackPermissionRequestDisplayDescription(request.description), request.permission_result, request.worker_badge, request.tool_name, request.is_mcp, request.original_cwd, fallbackPermissionRequestOptions(request))

fn fallbackPermissionRequestResponse(request: FallbackPermissionRequest, value: text, feedback: text) -> FallbackPermissionRequestResponse:
    if value == "yes":
        FallbackPermissionRequestResponse.new("yes", true, false, "accept", "", feedback)
    else if value == "yes-dont-ask-again":
        FallbackPermissionRequestResponse.new("yes-dont-ask-again", true, false, "accept", request.tool_name, feedback)
    else:
        FallbackPermissionRequestResponse.new("no", true, true, "reject", "", feedback)

fn fallbackPermissionRequestCancel(request: FallbackPermissionRequest) -> FallbackPermissionRequestResponse:
    fallbackPermissionRequestResponse(request, "no", "")

fn fallbackPermissionRequestSourceLinesModeled() -> i64:
    FALLBACK_PERMISSION_REQUEST_SOURCE_LINES
