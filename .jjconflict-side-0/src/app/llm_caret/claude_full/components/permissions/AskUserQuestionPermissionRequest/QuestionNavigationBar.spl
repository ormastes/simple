"""
Claude full AskUserQuestion QuestionNavigationBar parity model.
"""

const QUESTION_NAVIGATION_BAR_SOURCE_LINES = 177

class QuestionNavQuestion:
    question: text
    header: text

impl QuestionNavQuestion:
    static fn new(question: text, header: text) -> QuestionNavQuestion:
        QuestionNavQuestion(question: question, header: header)

class QuestionNavAnswer:
    question: text
    answer: text

impl QuestionNavAnswer:
    static fn new(question: text, answer: text) -> QuestionNavAnswer:
        QuestionNavAnswer(question: question, answer: answer)

class QuestionNavTab:
    label: text
    selected: bool
    answered: bool

impl QuestionNavTab:
    static fn new(label: text, selected: bool, answered: bool) -> QuestionNavTab:
        QuestionNavTab(label: label, selected: selected, answered: answered)

class QuestionNavigationBarRender:
    left_arrow_active: bool
    right_arrow_active: bool
    hide_arrows: bool
    submit_visible: bool
    submit_selected: bool
    tab_labels: [text]
    tabs: [QuestionNavTab]

impl QuestionNavigationBarRender:
    static fn new(leftArrowActive: bool, rightArrowActive: bool, hideArrows: bool, submitVisible: bool, submitSelected: bool, tabLabels: [text], tabs: [QuestionNavTab]) -> QuestionNavigationBarRender:
        QuestionNavigationBarRender(left_arrow_active: leftArrowActive, right_arrow_active: rightArrowActive, hide_arrows: hideArrows, submit_visible: submitVisible, submit_selected: submitSelected, tab_labels: tabLabels, tabs: tabs)

fn questionNavHeader(question: QuestionNavQuestion, index: i64) -> text:
    if question.header != "":
        question.header
    else:
        "Q" + (index + 1).to_text()

fn questionNavTruncate(value: text, maxWidth: i64) -> text:
    if maxWidth <= 0:
        ""
    else if value.len() <= maxWidth:
        value
    else:
        value.substring(0, maxWidth)

fn questionNavigationTabLabels(questions: [QuestionNavQuestion], currentQuestionIndex: i64, columns: i64, hideSubmitTab: bool) -> [text]:
    val submitWidth = if hideSubmitTab: 0 else: 9
    val available = columns - 4 - submitWidth
    var labels: [text] = []
    var i = 0
    for question in questions:
        val header = questionNavHeader(question, i)
        if available <= 0:
            labels.push(if i == currentQuestionIndex: questionNavTruncate(header, 3) else: "")
        else:
            labels.push(questionNavTruncate(header, available))
        i = i + 1
    labels

fn questionNavigationHasAnswer(answers: [QuestionNavAnswer], question: text) -> bool:
    for answer in answers:
        if answer.question == question and answer.answer != "":
            return true
    false

fn questionNavigationTabs(questions: [QuestionNavQuestion], currentQuestionIndex: i64, answers: [QuestionNavAnswer], labels: [text]) -> [QuestionNavTab]:
    var tabs: [QuestionNavTab] = []
    var i = 0
    for question in questions:
        val label = if i < labels.len(): labels[i] else: questionNavHeader(question, i)
        tabs.push(QuestionNavTab.new(label, i == currentQuestionIndex, questionNavigationHasAnswer(answers, question.question)))
        i = i + 1
    tabs

fn questionNavigationBar(questions: [QuestionNavQuestion], currentQuestionIndex: i64, answers: [QuestionNavAnswer], columns: i64, hideSubmitTab: bool) -> QuestionNavigationBarRender:
    val labels = questionNavigationTabLabels(questions, currentQuestionIndex, columns, hideSubmitTab)
    val hideArrows = questions.len() == 1 and hideSubmitTab
    QuestionNavigationBarRender.new(currentQuestionIndex > 0, currentQuestionIndex < questions.len(), hideArrows, not hideSubmitTab, currentQuestionIndex == questions.len(), labels, questionNavigationTabs(questions, currentQuestionIndex, answers, labels))

fn questionNavigationBarSourceLinesModeled() -> i64:
    QUESTION_NAVIGATION_BAR_SOURCE_LINES
