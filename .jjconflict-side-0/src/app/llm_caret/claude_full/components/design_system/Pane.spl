"""
Importable alias for design-system Pane parity.
"""

class PaneState:
    title: text
    active: bool
    compact: bool

impl PaneState:
    static fn new(title: text, active: bool, compact: bool) -> PaneState:
        PaneState(title: title.trim(), active: active, compact: compact)

fn paneTitle(state: PaneState) -> text:
    if state.title == "":
        return "Untitled pane"
    state.title

fn paneVisible(state: PaneState) -> bool:
    state.active

fn paneDensity(state: PaneState) -> text:
    if state.compact:
        return "compact"
    "comfortable"

fn paneSummary(state: PaneState) -> text:
    paneTitle(state) + " " + paneDensity(state)

fn paneSourceLinesModeled() -> i64:
    76
