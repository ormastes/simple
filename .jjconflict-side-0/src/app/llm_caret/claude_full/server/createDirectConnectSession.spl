class DirectConnectError:
    name: text
    message: text

impl DirectConnectError:
    static fn new(message: text) -> DirectConnectError:
        DirectConnectError(name: "DirectConnectError", message: message)

class DirectConnectRequest:
    serverUrl: text
    authToken: text
    cwd: text
    dangerouslySkipPermissions: bool

class DirectConnectConfig:
    serverUrl: text
    sessionId: text
    wsUrl: text
    authToken: text

class DirectConnectResult:
    ok: bool
    config: DirectConnectConfig
    workDir: text
    error: DirectConnectError?
    requestUrl: text
    requestBody: text
    authorizationHeader: text

fn createDirectConnectSession(request: DirectConnectRequest, networkOk: bool, httpOk: bool, status: i64, statusText: text, sessionId: text, wsUrl: text, workDir: text, schemaOk: bool, networkError: text) -> DirectConnectResult:
    val requestUrl = request.serverUrl + "/sessions"
    val body = directConnectRequestBody(request.cwd, request.dangerouslySkipPermissions)
    val authHeader = authorizationHeader(request.authToken)
    val emptyConfig = DirectConnectConfig(serverUrl: "", sessionId: "", wsUrl: "", authToken: "")
    if not networkOk:
        return DirectConnectResult(ok: false, config: emptyConfig, workDir: "", error: Some(DirectConnectError.new("Failed to connect to server at " + request.serverUrl + ": " + networkError)), requestUrl: requestUrl, requestBody: body, authorizationHeader: authHeader)
    if not httpOk:
        return DirectConnectResult(ok: false, config: emptyConfig, workDir: "", error: Some(DirectConnectError.new("Failed to create session: " + status.to_text() + " " + statusText)), requestUrl: requestUrl, requestBody: body, authorizationHeader: authHeader)
    if not schemaOk:
        return DirectConnectResult(ok: false, config: emptyConfig, workDir: "", error: Some(DirectConnectError.new("Invalid session response: schema validation failed")), requestUrl: requestUrl, requestBody: body, authorizationHeader: authHeader)
    DirectConnectResult(ok: true, config: DirectConnectConfig(serverUrl: request.serverUrl, sessionId: sessionId, wsUrl: wsUrl, authToken: request.authToken), workDir: workDir, error: nil, requestUrl: requestUrl, requestBody: body, authorizationHeader: authHeader)

fn directConnectRequest(serverUrl: text, authToken: text, cwd: text, dangerouslySkipPermissions: bool) -> DirectConnectRequest:
    DirectConnectRequest(serverUrl: serverUrl, authToken: authToken, cwd: cwd, dangerouslySkipPermissions: dangerouslySkipPermissions)

fn directConnectRequestBody(cwd: text, dangerouslySkipPermissions: bool) -> text:
    if dangerouslySkipPermissions:
        return "{\"cwd\":\"" + cwd + "\",\"dangerously_skip_permissions\":true}"
    "{\"cwd\":\"" + cwd + "\"}"

fn authorizationHeader(authToken: text) -> text:
    if authToken == "":
        return ""
    "Bearer " + authToken

fn createDirectConnectSessionSourceLinesModeled() -> i64:
    88

# Source parity note: POST target is `${serverUrl}/sessions`.
# Source parity note: request always sends content-type application/json.
# Source parity note: auth token becomes `Authorization: Bearer <token>` when present.
# Source parity note: dangerouslySkipPermissions maps to dangerously_skip_permissions.
# Source parity note: network, HTTP, and schema failures throw DirectConnectError.
# Source parity note: successful response returns DirectConnectConfig plus workDir.
