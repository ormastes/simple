"""
# Download Stat Model

Tracks download counts per package version per day.
Implements DbCodec<DownloadStat> for repository operations.
"""

use std.database.sql.types.{DbValue, DbRow, DbError}
use std.database.sql.schema.{TableSchema}
use std.database.sql.codec.{DbCodec}

# ============================================================================
# DownloadStat Entity
# ============================================================================

class DownloadStat:
    """Daily download count for a specific package version."""
    id: i64
    package_id: i64
    version: text
    date: text
    count: i64

fn new_download_stat(package_id: i64, version: text, date: text) -> DownloadStat:
    """Create a new DownloadStat with count of 0."""
    DownloadStat(
        id: 0,
        package_id: package_id,
        version: version,
        date: date,
        count: 0
    )

# ============================================================================
# DownloadStatCodec — DbCodec<DownloadStat> implementation
# ============================================================================

class DownloadStatCodec with DbCodec<DownloadStat>:
    """Codec for encoding/decoding DownloadStat entities."""

    fn table_name() -> text:
        "download_stats"

    fn schema() -> TableSchema:
        var s = TableSchema.new("download_stats")
        s = s.id_col()
        s = s.int_col("package_id")
        s = s.text_col("version")
        s = s.text_col("date")
        s = s.int_col("count")
        s

    fn columns() -> [text]:
        ["package_id", "version", "date", "count"]

    fn encode(entity: DownloadStat) -> [DbValue]:
        [
            DbValue.Integer(value: entity.package_id),
            DbValue.Text(value: entity.version),
            DbValue.Text(value: entity.date),
            DbValue.Integer(value: entity.count)
        ]

    fn decode(row: DbRow) -> Result<DownloadStat, DbError>:
        val id = row.get_int("id") ?? 0
        val package_id = row.get_int("package_id") ?? 0
        val version = row.get_text("version")
        val date = row.get_text("date")
        val count = row.get_int("count") ?? 0

        Ok(DownloadStat(
            id: id,
            package_id: package_id,
            version: version ?? "",
            date: date ?? "",
            count: count
        ))
