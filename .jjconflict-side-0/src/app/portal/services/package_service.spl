"""
# Package Service

Package CRUD operations, search, and download tracking.
"""

use std.database.sql.connection.{Database}
use std.database.sql.types.{DbValue, DbError}
use std.web_framework.pagination.{Paginator, PagedResult}
use portal.models.package_model.{Package, PackageCodec, PackageVersion, PackageVersionCodec}

# ============================================================================
# Package Queries
# ============================================================================

fn search_packages(db: Database, query: text, page: i64) -> Result<PagedResult<Package>, text>:
    """Search packages by name or description with pagination.

    Args:
        db: Database connection
        query: Search term (empty string returns all)
        page: Page number (1-based)

    Returns:
        Ok(PagedResult) with matching packages
    """
    val per_page = 20

    # Count total matches
    var count_sql = "SELECT COUNT(*) FROM packages"
    var count_params: [DbValue] = []
    if query.len() > 0:
        count_sql = "SELECT COUNT(*) FROM packages WHERE name LIKE ? OR description LIKE ?"
        val pattern = "%" + query + "%"
        count_params = [
            DbValue.Text(value: pattern),
            DbValue.Text(value: pattern)
        ]

    val count_result = db.query(count_sql, count_params)
    var total = 0
    match count_result:
        Ok(rows):
            if rows.len() > 0:
                total = rows[0].get_int("COUNT(*)") ?? 0
        Err(e):
            return Err("Database error counting packages")

    val paginator = Paginator.new(page, per_page, total)
    val offset = paginator.offset()

    # Fetch page of results
    var select_sql = "SELECT * FROM packages ORDER BY downloads DESC, name ASC LIMIT ? OFFSET ?"
    var select_params: [DbValue] = [
        DbValue.Integer(value: per_page),
        DbValue.Integer(value: offset)
    ]
    if query.len() > 0:
        select_sql = "SELECT * FROM packages WHERE name LIKE ? OR description LIKE ? ORDER BY downloads DESC, name ASC LIMIT ? OFFSET ?"
        val pattern = "%" + query + "%"
        select_params = [
            DbValue.Text(value: pattern),
            DbValue.Text(value: pattern),
            DbValue.Integer(value: per_page),
            DbValue.Integer(value: offset)
        ]

    val select_result = db.query(select_sql, select_params)
    match select_result:
        Ok(rows):
            val codec = PackageCodec()
            var packages: [Package] = []
            for row in rows:
                val pkg_result = codec.decode(row)
                match pkg_result:
                    Ok(pkg): packages.push(pkg)
                    Err(e): pass_do_nothing
            Ok(PagedResult(items: packages, paginator: paginator))
        Err(e):
            Err("Database error searching packages")

fn get_package(db: Database, name: text) -> Result<Package?, text>:
    """Find a package by name.

    Args:
        db: Database connection
        name: Package name

    Returns:
        Ok(Some(package)) if found, Ok(nil) otherwise
    """
    val sql = "SELECT * FROM packages WHERE name = ? LIMIT 1"
    val params: [DbValue] = [DbValue.Text(value: name)]
    val result = db.query(sql, params)

    match result:
        Ok(rows):
            if rows.len() == 0:
                return Ok(nil)
            val codec = PackageCodec()
            val pkg_result = codec.decode(rows[0])
            match pkg_result:
                Ok(pkg): Ok(Some(pkg))
                Err(e): Err("Failed to decode package")
        Err(e):
            Err("Database error fetching package")

fn get_package_versions(db: Database, package_id: i64) -> Result<[PackageVersion], text>:
    """Get all versions of a package, ordered newest first.

    Args:
        db: Database connection
        package_id: Package ID

    Returns:
        Ok(versions) ordered by creation date descending
    """
    val sql = "SELECT * FROM package_versions WHERE package_id = ? ORDER BY created_at DESC"
    val params: [DbValue] = [DbValue.Integer(value: package_id)]
    val result = db.query(sql, params)

    match result:
        Ok(rows):
            val codec = PackageVersionCodec()
            var versions: [PackageVersion] = []
            for row in rows:
                val v_result = codec.decode(row)
                match v_result:
                    Ok(v): versions.push(v)
                    Err(e): pass_do_nothing
            Ok(versions)
        Err(e):
            Err("Database error fetching versions")

fn get_popular_packages(db: Database, limit: i64) -> Result<[Package], text>:
    """Get the most downloaded packages.

    Args:
        db: Database connection
        limit: Maximum number of packages to return

    Returns:
        Ok(packages) ordered by download count descending
    """
    val sql = "SELECT * FROM packages ORDER BY downloads DESC LIMIT ?"
    val params: [DbValue] = [DbValue.Integer(value: limit)]
    val result = db.query(sql, params)

    match result:
        Ok(rows):
            val codec = PackageCodec()
            var packages: [Package] = []
            for row in rows:
                val pkg_result = codec.decode(row)
                match pkg_result:
                    Ok(pkg): packages.push(pkg)
                    Err(e): pass_do_nothing
            Ok(packages)
        Err(e):
            Err("Database error fetching popular packages")

