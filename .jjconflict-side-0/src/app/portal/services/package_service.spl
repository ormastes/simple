fn get_user_packages(db: Database, user_id: i64) -> Result<[Package], text>:
    """Get all packages owned by a user.

    Args:
        db: Database connection
        user_id: Owner user ID

    Returns:
        Ok(packages) owned by the user
    """
    val sql = "SELECT * FROM packages WHERE owner_id = ? ORDER BY name ASC"
    val params: [DbValue] = [DbValue.Integer(value: user_id)]
    val result = db.query(sql, params)

    match result:
        Ok(rows):
            val codec = PackageCodec()
            var packages: [Package] = []
            for row in rows:
                val pkg_result = codec.decode(row)
                match pkg_result:
                    Ok(pkg): packages.push(pkg)
                    Err(e): pass_do_nothing
            Ok(packages)
        Err(e):
            Err("Database error fetching user packages")

fn publish_package(db: Database, name: text, description: text, version: text, owner_id: i64, readme: text) -> Result<i64, text>:
    """Publish a new package or new version of an existing package.

    If the package does not exist, creates it. Then adds the version.

    Args:
        db: Database connection
        name: Package name
        description: Package description
        version: Version string (e.g., "1.0.0")
        owner_id: User ID of the publisher
        readme: README content for the version

    Returns:
        Ok(package_id) on success
    """
    # Check if package exists
    val existing = get_package(db, name)?
    var package_id: i64 = 0

    if existing != nil:
        val pkg = existing ?? return Err("Internal error")
        # Verify ownership
        if pkg.owner_id != owner_id:
            return Err("You do not own this package")
        package_id = pkg.id

        # Update package metadata
        val update_sql = "UPDATE packages SET description = ?, latest_version = ?, updated_at = datetime('now') WHERE id = ?"
        val update_params: [DbValue] = [
            DbValue.Text(value: description),
            DbValue.Text(value: version),
            DbValue.Integer(value: package_id)
        ]
        val update_result = db.exec(update_sql, update_params)
        match update_result:
            Ok(_): pass_do_nothing
            Err(e): return Err("Failed to update package")
    else:
        # Create new package
        val insert_sql = "INSERT INTO packages (name, description, latest_version, owner_id, downloads) VALUES (?, ?, ?, ?, 0)"
        val insert_params: [DbValue] = [
            DbValue.Text(value: name),
            DbValue.Text(value: description),
            DbValue.Text(value: version),
            DbValue.Integer(value: owner_id)
        ]
        val insert_result = db.exec(insert_sql, insert_params)
        match insert_result:
            Ok(_):
                package_id = db.last_insert_rowid()
            Err(e):
                return Err("Failed to create package")

    # Insert version record
    val version_sql = "INSERT INTO package_versions (package_id, version, readme) VALUES (?, ?, ?)"
    val version_params: [DbValue] = [
        DbValue.Integer(value: package_id),
        DbValue.Text(value: version),
        DbValue.Text(value: readme)
    ]
    val version_result = db.exec(version_sql, version_params)
    match version_result:
        Ok(_): Ok(package_id)
        Err(e): Err("Failed to create package version (version may already exist)")

fn increment_downloads(db: Database, package_id: i64, version: text):
    """Record a download for a package version.

    Increments the daily download counter and the total package downloads.

    Args:
        db: Database connection
        package_id: Package ID
        version: Version string that was downloaded
    """
    val today = current_date_text()

    # Upsert daily download stat
    val upsert_sql = "INSERT INTO download_stats (package_id, version, date, count) " +
        "VALUES (?, ?, ?, 1) " +
        "ON CONFLICT(package_id, version, date) DO UPDATE SET count = count + 1"
    val upsert_params: [DbValue] = [
        DbValue.Integer(value: package_id),
        DbValue.Text(value: version),
        DbValue.Text(value: today)
    ]
    val _upsert = db.exec(upsert_sql, upsert_params)

    # Increment total downloads on package
    val update_sql = "UPDATE packages SET downloads = downloads + 1 WHERE id = ?"
    val update_params: [DbValue] = [DbValue.Integer(value: package_id)]
    val _update = db.exec(update_sql, update_params)

fn total_package_count(db: Database) -> i64:
    """Get the total number of packages in the registry."""
    val sql = "SELECT COUNT(*) FROM packages"
    val result = db.query(sql, [])
    match result:
        Ok(rows):
            if rows.len() > 0:
                return rows[0].get_int("COUNT(*)") ?? 0
            0
        Err(e): 0

fn total_download_count(db: Database) -> i64:
    """Get the total number of downloads across all packages."""
    val sql = "SELECT COALESCE(SUM(downloads), 0) as total FROM packages"
    val result = db.query(sql, [])
    match result:
        Ok(rows):
            if rows.len() > 0:
                return rows[0].get_int("total") ?? 0
            0
        Err(e): 0

fn current_date_text() -> text:
    """Get current date as YYYY-MM-DD text. Uses timestamp approximation."""
    val ts = current_timestamp()
    # Approximate date from Unix timestamp
    val days = ts / 86400
    val year = 1970 + (days / 365)
    "{year}-01-01"

extern fn current_timestamp() -> i64
