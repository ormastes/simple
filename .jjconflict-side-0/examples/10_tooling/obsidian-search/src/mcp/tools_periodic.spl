# MCP Tool schemas — 3 periodic & template tools (Phase E)
#
# Defines tool schemas for daily_note, periodic_note, apply_template.

use src.util.json_helpers.{js, jp, jo, jo1, jo2, jo3, ja, LB, RB, SB_L, SB_R}

# --- Tool schema builder helpers ---

fn make_string_prop(description: text) -> text:
    jo2(jp("type", js("string")), jp("description", js(description)))

fn make_tool_periodic(name: text, description: text, props: text, required: text) -> text:
    val schema = jo3(
        jp("type", js("object")),
        jp("properties", props),
        jp("required", required)
    )
    val annotations = jo3(
        jp("readOnlyHint", "false"),
        jp("destructiveHint", "false"),
        jp("idempotentHint", "false")
    )
    var tool_obj = LB()
    tool_obj = tool_obj + jp("name", js(name))
    tool_obj = tool_obj + "," + jp("description", js(description))
    tool_obj = tool_obj + "," + jp("inputSchema", schema)
    tool_obj = tool_obj + "," + jp("annotations", annotations)
    tool_obj = tool_obj + RB()
    tool_obj

# --- Periodic tool schemas ---

fn make_periodic_tools() -> [text]:
    var tools: [text] = []

    # 1. daily_note
    var dn_props = LB()
    dn_props = dn_props + jp("date", make_string_prop("Date in YYYY-MM-DD format. Omit for today."))
    dn_props = dn_props + "," + jp("content", make_string_prop("Content for the daily note (used when action is 'create')"))
    dn_props = dn_props + "," + jp("action", make_string_prop("Action to perform: 'read' (default) or 'create'"))
    dn_props = dn_props + RB()
    tools.push(make_tool_periodic(
        "daily_note",
        "Read or create a daily note. Omit date for today.",
        dn_props,
        ja([])
    ))

    # 2. periodic_note
    var pn_props = LB()
    pn_props = pn_props + jp("period", make_string_prop("Period type: 'weekly', 'monthly', 'quarterly', or 'yearly'"))
    pn_props = pn_props + "," + jp("date", make_string_prop("Reference date in YYYY-MM-DD format. Omit for today."))
    pn_props = pn_props + "," + jp("action", make_string_prop("Action: 'read' (default), 'create', or 'list'"))
    pn_props = pn_props + "," + jp("content", make_string_prop("Content for the note (used when action is 'create')"))
    pn_props = pn_props + "," + jp("limit", make_string_prop("Maximum number of notes to return for 'list' action (default 10)"))
    pn_props = pn_props + RB()
    tools.push(make_tool_periodic(
        "periodic_note",
        "Access periodic notes (weekly, monthly, quarterly, yearly)",
        pn_props,
        ja([js("period")])
    ))

    # 3. apply_template
    var at_props = LB()
    at_props = at_props + jp("template", make_string_prop("Relative path to the template file in the vault (e.g. 'templates/meeting.md')"))
    at_props = at_props + "," + jp("target", make_string_prop("Relative path for the new note to create"))
    at_props = at_props + "," + jp("variables", make_string_prop("Comma-separated key=value pairs for template variable substitution (e.g. 'title=Standup,project=Alpha')"))
    at_props = at_props + RB()
    tools.push(make_tool_periodic(
        "apply_template",
        "Apply a vault template to create a new note with variable substitution",
        at_props,
        ja([js("template"), js("target")])
    ))

    tools
