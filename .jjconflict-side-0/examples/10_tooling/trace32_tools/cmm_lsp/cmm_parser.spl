# CMM (PRACTICE Script) Parser — Public facade

use cmm_ast.{CmmProgram}
use cmm_parser_runtime.{parse_cmm_source as runtime_parse_cmm_source, parse_cmm_file as runtime_parse_cmm_file}

fn parse_cmm_source(source: text) -> CmmProgram:
    runtime_parse_cmm_source(source)

fn parse_cmm_file(path: text) -> CmmProgram:
    runtime_parse_cmm_file(path)
