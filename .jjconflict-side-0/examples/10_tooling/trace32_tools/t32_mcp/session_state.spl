# TRACE32 MCP session state shared by protocol, CLI bridge, and tool handlers.

class McpT32Core:
    core_id: text
    label: text
    instance_binding: text

class McpT32Session:
    id: text
    host: text
    port: i64
    intercom_name: text
    architecture: text
    connected: bool
    cores: [McpT32Core]

class McpT32HistoryItem:
    command: text
    result: text
    session_id: text
    core_id: text
    request_id: text

var MCP_T32_SESSIONS: [McpT32Session] = []
var MCP_T32_CURRENT_SESSION = ""
var MCP_T32_CURRENT_CORE = ""
var MCP_T32_HISTORY: [McpT32HistoryItem] = []
var MCP_T32_AREA_READY = false
var MCP_T32_AREA_NAME = ""

export McpT32Core, McpT32Session, McpT32HistoryItem
export MCP_T32_SESSIONS, MCP_T32_CURRENT_SESSION, MCP_T32_CURRENT_CORE
export MCP_T32_HISTORY, MCP_T32_AREA_READY, MCP_T32_AREA_NAME
