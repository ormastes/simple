#![allow(unnamed_duplicate_typed_args)]
# Storage types for web storage APIs.
# Models localStorage, sessionStorage, and origin-scoped IndexedDB stores.

use std.js.types.pair.{Pair}

enum StorageKind:
    Local
    Session
    IndexedDb

class StorageArea:
    kind: StorageKind
    origin: text
    entries: [Pair<text, text>]

    static fn create(kind: StorageKind, origin: text) -> StorageArea:
        StorageArea(kind: kind, origin: origin, entries: [])

class IndexedDbObjectStore:
    name: text
    entries: [Pair<text, text>]

    static fn create(name: text) -> IndexedDbObjectStore:
        IndexedDbObjectStore(name: name, entries: [])

class IndexedDbSchema:
    origin: text
    name: text
    version: i64
    object_stores: [IndexedDbObjectStore]

    static fn create(origin: text, name: text, version: i64) -> IndexedDbSchema:
        IndexedDbSchema(origin: origin, name: name, version: version, object_stores: [])
