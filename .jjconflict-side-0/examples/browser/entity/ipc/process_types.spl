#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Process identification and state types for multi-process browser architecture.
# Each browser subsystem runs in its own process with a unique ProcessId.

enum ProcessKind:
    Browser
    Renderer
    Network
    Gpu
    Utility

enum ProcessState:
    Starting
    Running
    Suspended
    Crashed
    Terminated

class ProcessId:
    id: i64
    kind: ProcessKind

    static fn create(id: i64, kind: ProcessKind) -> ProcessId:
        ProcessId(id: id, kind: kind)

class ProcessInfo:
    pid: ProcessId
    state: ProcessState
    memory_usage: i64

    static fn create(pid: ProcessId, state: ProcessState, memory_usage: i64) -> ProcessInfo:
        ProcessInfo(pid: pid, state: state, memory_usage: memory_usage)
