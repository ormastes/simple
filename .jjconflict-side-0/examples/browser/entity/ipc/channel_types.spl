# IPC channel abstractions for inter-process communication.
# Channels connect two processes; handles provide generation-checked references;
# shared buffers allow zero-copy data transfer between processes.

class IpcChannel:
    id: i64
    src: ProcessId
    dst: ProcessId
    is_open: bool

    static fn create(id: i64, src: ProcessId, dst: ProcessId) -> IpcChannel:
        IpcChannel(id: id, src: src, dst: dst, is_open: true)

class IpcHandle:
    channel_id: i64
    generation: i64

    static fn create(channel_id: i64, generation: i64) -> IpcHandle:
        IpcHandle(channel_id: channel_id, generation: generation)

class SharedBuffer:
    id: i64
    size: i64
    owner: ProcessId

    static fn create(id: i64, size: i64, owner: ProcessId) -> SharedBuffer:
        SharedBuffer(id: id, size: size, owner: owner)
