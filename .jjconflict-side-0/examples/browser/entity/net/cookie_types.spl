#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Cookie types for HTTP state management.
# Models cookie attributes, scoping, and jar storage per RFC 6265.

enum SameSite:
    Strict
    Lax
    None

class Cookie:
    name: text
    value: text
    domain: text
    path: text
    expires: i64
    secure: bool
    http_only: bool
    same_site: SameSite

    static fn create(name: text, value: text, domain: text) -> Cookie:
        Cookie(
            name: name, value: value, domain: domain,
            path: "/", expires: 0, secure: false,
            http_only: false, same_site: SameSite.Lax
        )

class CookieScope:
    domain: text
    path: text

    static fn create(domain: text, path: text) -> CookieScope:
        CookieScope(domain: domain, path: path)

class CookieJar:
    cookies: [Cookie]

    static fn empty() -> CookieJar:
        CookieJar(cookies: [Cookie]())
