# CSS Containment — contain property resolution.
#
# CSS Containment Level 2 defines how an element can isolate
# its subtree from the rest of the document for layout, paint,
# style, and size calculations.
#
# Spec: https://www.w3.org/TR/css-contain-2/
#
# Values:
#   none     — no containment
#   size     — element size doesn't depend on children
#   layout   — element layout doesn't affect siblings
#   style    — counters/quotes don't escape
#   paint    — content clips to content box
#   content  — layout + style + paint
#   strict   — size + layout + style + paint

# =========================================================================
# Containment Flags
# =========================================================================

class ContainmentFlags:
    size: bool
    layout: bool
    style: bool
    paint: bool

    static fn none() -> ContainmentFlags:
        ContainmentFlags(size: false, layout: false, style: false, paint: false)

    static fn from_text(value: text) -> ContainmentFlags:
        val lower = value.to_lower().trim()

        if lower == "none":
            return ContainmentFlags.none()

        if lower == "strict":
            return ContainmentFlags(size: true, layout: true, style: true, paint: true)

        if lower == "content":
            return ContainmentFlags(size: false, layout: true, style: true, paint: true)

        # Parse individual keywords
        var flags = ContainmentFlags.none()
        if lower.contains("size"):
            flags.size = true
        if lower.contains("layout"):
            flags.layout = true
        if lower.contains("style"):
            flags.style = true
        if lower.contains("paint"):
            flags.paint = true
        flags

    fn has_any() -> bool:
        self.size or self.layout or self.style or self.paint

    fn should_skip_children_for_size() -> bool:
        """If size containment is set, the element's size doesn't depend on children."""
        self.size

    fn should_clip_paint() -> bool:
        """If paint containment is set, content is clipped to the content box."""
        self.paint

    fn creates_stacking_context() -> bool:
        """Paint and layout containment create a stacking context."""
        self.paint or self.layout

    fn creates_formatting_context() -> bool:
        """Layout containment creates an independent formatting context."""
        self.layout

# =========================================================================
# Container Query Types (CSS Containment Level 3)
# =========================================================================

enum ContainerType:
    Normal    # Not a query container
    InlineSize  # Responds to inline-axis size queries
    Size      # Responds to both axis size queries

fn parse_container_type(value: text) -> ContainerType:
    val lower = value.to_lower().trim()
    match lower:
        "inline-size": ContainerType.InlineSize
        "size": ContainerType.Size
        _: ContainerType.Normal

class ContainerInfo:
    """Information about a container for container queries."""
    name: text
    container_type: ContainerType
    width: f64
    height: f64

    static fn none() -> ContainerInfo:
        ContainerInfo(name: "", container_type: ContainerType.Normal, width: 0.0, height: 0.0)

    fn is_query_container() -> bool:
        match self.container_type:
            ContainerType.Normal: false
            _: true

    fn matches_name(query_name: text) -> bool:
        if query_name == "":
            return true  # unnamed query matches any container
        self.name == query_name
