#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# CSS Generated Content — ::before and ::after pseudo-elements.
# Before layout, walks the DOM tree and inserts pseudo-element child nodes
# based on matched CSS rules containing content declarations.
#
# Depends on:
#   entity/dom/node_types.spl    — DomNode, NodeKind, Element, TextNode
#   entity/dom/css_types.spl     — CSSValue, CSSDeclaration, CSSRule, Selector, SelectorPart
#   entity/dom/attribute_types.spl — Attr
#   feature/dom/document.spl     — Document, NodeStore
#   shared/logging.spl           — Logger, LogLevel

# --- StyleMap — per-node mapping of pseudo-element declarations ---------------

# Keyed list of (node_id, pseudo_name) -> declarations.
# pseudo_name is "before" or "after".
class StyleEntry:
    node_id: i64
    pseudo: text
    declarations: [CSSDeclaration]

    static fn create(node_id: i64, pseudo: text, declarations: [CSSDeclaration]) -> StyleEntry:
        StyleEntry(node_id: node_id, pseudo: pseudo, declarations: declarations)

class StyleMap:
    entries: [StyleEntry]

    static fn empty() -> StyleMap:
        StyleMap(entries: [StyleEntry]())

    me add(node_id: i64, pseudo: text, declarations: [CSSDeclaration]):
        self.entries.push(StyleEntry.create(node_id, pseudo, declarations))

    # Look up declarations for a (node_id, pseudo) pair.
    fn get(node_id: i64, pseudo: text) -> [CSSDeclaration]?:
        var i = 0
        while i < self.entries.len():
            val entry = self.entries.get(i)
            if entry.node_id == node_id and entry.pseudo == pseudo:
                return entry.declarations
            i = i + 1
        nil

    # Return all entries for a given node_id (both before and after).
    fn get_all_for_node(node_id: i64) -> [StyleEntry]:
        var result = [StyleEntry]()
        var i = 0
        while i < self.entries.len():
            val entry = self.entries.get(i)
            if entry.node_id == node_id:
                result.push(entry)
            i = i + 1
        result

# --- InteractionState — tracks hover/focus/active for :pseudo-class ----------

class InteractionState:
    hovered_ids: [i64]
    focused_id: i64
    active_id: i64

    static fn none() -> InteractionState:
        InteractionState(hovered_ids: [i64](), focused_id: -1, active_id: -1)

    static fn create(hovered_ids: [i64], focused_id: i64, active_id: i64) -> InteractionState:
        InteractionState(hovered_ids: hovered_ids, focused_id: focused_id, active_id: active_id)

    fn is_hovered(node_id: i64) -> bool:
        var i = 0
        while i < self.hovered_ids.len():
            if self.hovered_ids.get(i) == node_id:
                return true
            i = i + 1
        false

    fn is_focused(node_id: i64) -> bool:
        self.focused_id == node_id

    fn is_active(node_id: i64) -> bool:
        self.active_id == node_id

# --- Quote tracking ---

class QuoteTracker:
    depth: i64

    static fn new() -> QuoteTracker:
        QuoteTracker(depth: 0)

    fn open_quote() -> text:
        if self.depth % 2 == 0:
            return "\u201C"  # left double quotation mark
        return "\u2018"      # left single quotation mark

    fn close_quote() -> text:
        if self.depth % 2 == 0:
            return "\u201D"  # right double quotation mark
        return "\u2019"      # right single quotation mark

    me push():
        self.depth = self.depth + 1

    me pop():
        if self.depth > 0:
            self.depth = self.depth - 1

# --- Counter state ---

class CounterMap:
    names: [text]
    values: [i64]

    static fn empty() -> CounterMap:
        CounterMap(names: [text](), values: [i64]())

    me get(name: text) -> i64:
        var i = 0
        while i < self.names.len():
            if self.names.get(i) == name:
                return self.values.get(i)
            i = i + 1
        # Counter not found: auto-create at 0
        self.names.push(name)
        self.values.push(0)
        0

    me increment(name: text):
        var i = 0
        while i < self.names.len():
            if self.names.get(i) == name:
                self.values.set(i, self.values.get(i) + 1)
                return
            i = i + 1
        # Counter not found: auto-create at 1
        self.names.push(name)
        self.values.push(1)

    me set_value(name: text, value: i64):
        var i = 0
        while i < self.names.len():
            if self.names.get(i) == name:
                self.values.set(i, value)
                return
            i = i + 1
        self.names.push(name)
        self.values.push(value)

    me reset(name: text):
        self.set_value(name, 0)

# --- Content value parser ---

# Parse the CSS `content` property value into displayable text.
# Handles:
#   "string"        — quoted string literal
#   attr(name)      — attribute value from the element
#   counter(name)   — current counter value (decimal)
#   open-quote      — opening quotation mark (depth-tracked)
#   close-quote     — closing quotation mark (depth-tracked)
#   none / normal   — empty (no generated content)
#   concatenation   — space-separated values are concatenated
fn parse_content_value(value: text) -> text:
    parse_content_value_with_context(value, nil, QuoteTracker.new(), CounterMap.empty())

# Full parser with element context for attr() and state for counters/quotes.
fn parse_content_value_with_context(value: text, element: Element?, quotes: QuoteTracker, counters: CounterMap) -> text:
    val trimmed = value.trim()

    # none or normal produce no content
    if trimmed == "none" or trimmed == "normal":
        return ""

    # Single quoted string: "..." or '...'
    if is_quoted_string(trimmed):
        return unquote_string(trimmed)

    # Tokenize and concatenate multiple content values
    val tokens = tokenize_content(trimmed)
    var result = ""
    var i = 0
    while i < tokens.len():
        val token = tokens.get(i)
        result = result + resolve_content_token(token, element, quotes, counters)
        i = i + 1
    result

# Check if a string is wrapped in matching quotes.
fn is_quoted_string(s: text) -> bool:
    if s.len() < 2:
        return false
    val first = s.substring(0, 1)
    val last = s.substring(s.len() - 1, s.len())
    (first == "\"" and last == "\"") or (first == "'" and last == "'")

# Remove surrounding quotes and unescape basic sequences.
fn unquote_string(s: text) -> text:
    if s.len() < 2:
        return s
    val inner = s.substring(1, s.len() - 1)
    unescape_css_string(inner)

# Unescape CSS string escape sequences: \\, \n, \t, \".
fn unescape_css_string(s: text) -> text:
    var result = ""
    var i = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch == "\\" and i + 1 < s.len():
            val next = s.substring(i + 1, i + 2)
            if next == "n":
                result = result + "\n"
                i = i + 2
            else if next == "t":
                result = result + "\t"
                i = i + 2
            else if next == "\\":
                result = result + "\\"
                i = i + 2
            else if next == "\"":
                result = result + "\""
                i = i + 2
            else if next == "'":
                result = result + "'"
                i = i + 2
            else:
                # Unknown escape: pass through
                result = result + next
                i = i + 2
        else:
            result = result + ch
            i = i + 1
    result

# Tokenize a content value string into individual tokens.
# Handles quoted strings, functional notation (attr(), counter()), and keywords.
fn tokenize_content(s: text) -> [text]:
    var tokens = [text]()
    var i = 0
    val len = s.len()

    while i < len:
        val ch = s.substring(i, i + 1)

        # Skip whitespace between tokens
        if ch == " " or ch == "\t":
            i = i + 1
        # Quoted string
        else if ch == "\"" or ch == "'":
            val end = find_closing_quote(s, i, ch)
            tokens.push(s.substring(i, end + 1))
            i = end + 1
        # Functional notation: name(...)
        else if is_alpha(ch):
            val token_end = find_token_end(s, i)
            tokens.push(s.substring(i, token_end))
            i = token_end
        else:
            # Skip unexpected characters
            i = i + 1

    tokens

# Find the closing quote matching the opening quote at position start.
fn find_closing_quote(s: text, start: i64, quote: text) -> i64:
    var i = start + 1
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch == "\\" and i + 1 < s.len():
            i = i + 2  # skip escaped character
        else if ch == quote:
            return i
        else:
            i = i + 1
    # No closing quote found; return end of string
    s.len() - 1

# Find the end of a keyword or function token (including parenthesized args).
fn find_token_end(s: text, start: i64) -> i64:
    var i = start
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch == "(":
            # Find matching closing paren
            var depth = 1
            i = i + 1
            while i < s.len() and depth > 0:
                val pc = s.substring(i, i + 1)
                if pc == "(":
                    depth = depth + 1
                else if pc == ")":
                    depth = depth - 1
                i = i + 1
            return i
        else if ch == " " or ch == "\t":
            return i
        else:
            i = i + 1
    s.len()

# Check if a character is a letter or hyphen (keyword chars).
fn is_alpha(ch: text) -> bool:
    if ch.len() != 1:
        return false
    val c = ch.to_lower()
    (c >= "a" and c <= "z") or c == "-" or c == "_"

# Resolve a single content token to text.
fn resolve_content_token(token: text, element: Element?, quotes: QuoteTracker, counters: CounterMap) -> text:
    # Quoted string
    if is_quoted_string(token):
        return unquote_string(token)

    # attr(name)
    if token.starts_with("attr(") and token.ends_with(")"):
        val attr_name = token.substring(5, token.len() - 1).trim()
        match element:
            Some(elem):
                val attr_val = find_attribute(elem, attr_name)
                match attr_val:
                    Some(v): return v
                    nil: return ""
            nil:
                return ""

    # counter(name)
    if token.starts_with("counter(") and token.ends_with(")"):
        val counter_name = token.substring(8, token.len() - 1).trim()
        val count_val = counters.get(counter_name)
        return "{count_val}"

    # counters(name, separator)
    if token.starts_with("counters(") and token.ends_with(")"):
        val args = token.substring(9, token.len() - 1).trim()
        val comma_pos = args.find(",")
        if comma_pos >= 0:
            val counter_name = args.substring(0, comma_pos).trim()
            val count_val = counters.get(counter_name)
            return "{count_val}"
        return ""

    # open-quote
    if token == "open-quote":
        val q = quotes.open_quote()
        quotes.push()
        return q

    # close-quote
    if token == "close-quote":
        quotes.pop()
        return quotes.close_quote()

    # no-open-quote / no-close-quote — affect depth but produce no text
    if token == "no-open-quote":
        quotes.push()
        return ""

    if token == "no-close-quote":
        quotes.pop()
        return ""

    # none / normal
    if token == "none" or token == "normal":
        return ""

    # Unknown token — return empty
    ""

# Find an attribute value on an element by name.
fn find_attribute(elem: Element, name: text) -> text?:
    var i = 0
    while i < elem.attributes.len():
        val attr = elem.attributes.get(i)
        if attr.name == name:
            return attr.value
        i = i + 1
    nil

# --- Pseudo-element node creation ---

# Create a pseudo-element as a DomNode containing a text child.
# Returns a pair of (element_node, text_node) IDs that should be
# allocated through the Document's NodeStore.
fn create_pseudo_node(tag: text, content: text, node_id: i64) -> DomNode:
    # Create a virtual element node for the pseudo-element.
    # The tag is "::before" or "::after", the data holds the generated text.
    # node_id is the ID to assign.
    DomNode(
        id: node_id,
        kind: NodeKind.Element,
        parent_id: -1,
        children: [i64](),
        data: content
    )

# --- GeneratedContentResolver ---

class GeneratedContentResolver:
    logger: Logger

    static fn new(logger: Logger) -> GeneratedContentResolver:
        GeneratedContentResolver(logger: logger)

    # Walk the DOM tree and insert ::before / ::after pseudo-element nodes
    # for every element that has matching generated-content rules.
    me resolve(doc: Document, matched_styles: StyleMap):
        self.logger.info("GeneratedContentResolver: starting pass")
        var quotes = QuoteTracker.new()
        var counters = CounterMap.empty()

        # Collect all element node IDs in document order
        val all_nodes = collect_element_ids(doc)
        var processed = 0

        var i = 0
        while i < all_nodes.len():
            val nid = all_nodes.get(i)
            val modified = self.process_node(nid, doc, matched_styles, quotes, counters)
            if modified:
                processed = processed + 1
            i = i + 1

        self.logger.info("GeneratedContentResolver: inserted pseudo-elements for {processed} nodes")

    # Process a single element node: check for ::before and ::after,
    # and insert generated child nodes.
    me process_node(node_id: i64, doc: Document, styles: StyleMap, quotes: QuoteTracker, counters: CounterMap) -> bool:
        var inserted = false

        # Handle counter-reset and counter-increment from regular styles
        self.apply_counter_properties(node_id, styles, counters)

        # Check ::before
        val before_decls = styles.get(node_id, "before")
        match before_decls:
            Some(decls):
                val content = extract_content_value(decls)
                if content.len() > 0:
                    val elem = doc.node_store.get_element(node_id)
                    val resolved = parse_content_value_with_context(content, elem, quotes, counters)
                    if resolved.len() > 0:
                        self.insert_before_pseudo(node_id, resolved, doc)
                        inserted = true
                        self.logger.debug("Inserted ::before for node {node_id}: \"{resolved}\"")
            nil: pass_dn

        # Check ::after
        val after_decls = styles.get(node_id, "after")
        match after_decls:
            Some(decls):
                val content = extract_content_value(decls)
                if content.len() > 0:
                    val elem = doc.node_store.get_element(node_id)
                    val resolved = parse_content_value_with_context(content, elem, quotes, counters)
                    if resolved.len() > 0:
                        self.insert_after_pseudo(node_id, resolved, doc)
                        inserted = true
                        self.logger.debug("Inserted ::after for node {node_id}: \"{resolved}\"")
            nil: pass_dn

        inserted

    # Apply counter-reset and counter-increment declarations for a node.
    me apply_counter_properties(node_id: i64, styles: StyleMap, counters: CounterMap):
        # Check entries for this node (non-pseudo entries use pseudo="" but
        # we scan all entries matching this node_id for counter directives).
        val entries = styles.get_all_for_node(node_id)
        var i = 0
        while i < entries.len():
            val entry = entries.get(i)
            var j = 0
            while j < entry.declarations.len():
                val decl = entry.declarations.get(j)
                if decl.property == "counter-reset":
                    val name = css_value_to_text(decl.value)
                    counters.reset(name)
                else if decl.property == "counter-increment":
                    val name = css_value_to_text(decl.value)
                    counters.increment(name)
                j = j + 1
            i = i + 1

    # Insert a ::before pseudo-element as the first child of the target node.
    me insert_before_pseudo(parent_id: i64, content: text, doc: Document):
        # Allocate the pseudo-element node
        val pseudo_id = doc.node_store.allocate_node(NodeKind.Element, "::before")
        doc.node_store.elements.push(Element.create(pseudo_id, "::before", ""))

        # Allocate the text child
        val text_id = doc.node_store.allocate_node(NodeKind.Text, content)
        doc.node_store.texts.push(TextNode.create(text_id, content))

        # Set text node's parent to pseudo-element
        val text_node = doc.node_store.get_node(text_id)
        match text_node:
            Some(tn):
                doc.node_store.update_node(text_id, DomNode(id: tn.id, kind: tn.kind, parent_id: pseudo_id, children: tn.children, data: tn.data))
            nil: pass_dn

        # Add text as child of pseudo-element
        val pseudo_node = doc.node_store.get_node(pseudo_id)
        match pseudo_node:
            Some(pn):
                var ch = [i64]()
                ch.push(text_id)
                doc.node_store.update_node(pseudo_id, DomNode(id: pn.id, kind: pn.kind, parent_id: parent_id, children: ch, data: pn.data))
            nil: pass_dn

        # Insert pseudo-element as first child of parent
        val parent_node = doc.node_store.get_node(parent_id)
        match parent_node:
            Some(pn):
                var new_children = [i64]()
                new_children.push(pseudo_id)
                var ci = 0
                while ci < pn.children.len():
                    new_children.push(pn.children.get(ci))
                    ci = ci + 1
                doc.node_store.update_node(parent_id, DomNode(id: pn.id, kind: pn.kind, parent_id: pn.parent_id, children: new_children, data: pn.data))
            nil: pass_dn

    # Insert an ::after pseudo-element as the last child of the target node.
    me insert_after_pseudo(parent_id: i64, content: text, doc: Document):
        # Allocate the pseudo-element node
        val pseudo_id = doc.node_store.allocate_node(NodeKind.Element, "::after")
        doc.node_store.elements.push(Element.create(pseudo_id, "::after", ""))

        # Allocate the text child
        val text_id = doc.node_store.allocate_node(NodeKind.Text, content)
        doc.node_store.texts.push(TextNode.create(text_id, content))

        # Set text node's parent to pseudo-element
        val text_node = doc.node_store.get_node(text_id)
        match text_node:
            Some(tn):
                doc.node_store.update_node(text_id, DomNode(id: tn.id, kind: tn.kind, parent_id: pseudo_id, children: tn.children, data: tn.data))
            nil: pass_dn

        # Add text as child of pseudo-element
        val pseudo_node = doc.node_store.get_node(pseudo_id)
        match pseudo_node:
            Some(pn):
                var ch = [i64]()
                ch.push(text_id)
                doc.node_store.update_node(pseudo_id, DomNode(id: pn.id, kind: pn.kind, parent_id: parent_id, children: ch, data: pn.data))
            nil: pass_dn

        # Append pseudo-element as last child of parent
        val parent_node = doc.node_store.get_node(parent_id)
        match parent_node:
            Some(pn):
                var new_children = [i64]()
                var ci = 0
                while ci < pn.children.len():
                    new_children.push(pn.children.get(ci))
                    ci = ci + 1
                new_children.push(pseudo_id)
                doc.node_store.update_node(parent_id, DomNode(id: pn.id, kind: pn.kind, parent_id: pn.parent_id, children: new_children, data: pn.data))
            nil: pass_dn

# --- Helpers ---

# Extract the content property value from a list of declarations.
fn extract_content_value(decls: [CSSDeclaration]) -> text:
    var i = 0
    while i < decls.len():
        val decl = decls.get(i)
        if decl.property == "content":
            return css_value_to_text(decl.value)
        i = i + 1
    ""

# Convert a CSSValue to its text representation for content parsing.
fn css_value_to_text(value: CSSValue) -> text:
    match value:
        CSSValue.Keyword(v): v
        CSSValue.Number(v): "{v}"
        CSSValue.Length(v, unit): "{v}{unit}"
        CSSValue.Percentage(v): "{v}%"
        CSSValue.Url(v): "url({v})"
        CSSValue.Function(name, args):
            var arg_strs = ""
            var i = 0
            while i < args.len():
                if i > 0:
                    arg_strs = arg_strs + ", "
                arg_strs = arg_strs + css_value_to_text(args.get(i))
                i = i + 1
            "{name}({arg_strs})"
        CSSValue.List(values):
            var result = ""
            var i = 0
            while i < values.len():
                if i > 0:
                    result = result + " "
                result = result + css_value_to_text(values.get(i))
                i = i + 1
            result
        CSSValue.Var(name, _): "var({name})"
        CSSValue.Inherit: "inherit"
        CSSValue.Initial: "initial"
        CSSValue.Unset: "unset"
        CSSValue.Color(_): ""

# Collect all element node IDs from the document in depth-first order.
fn collect_element_ids(doc: Document) -> [i64]:
    var result = [i64]()
    var stack = [i64]()
    stack.push(doc.root_id)

    while stack.len() > 0:
        val current = stack.pop()
        val node = doc.node_store.get_node(current)
        match node:
            Some(n):
                # Only process element nodes
                match n.kind:
                    NodeKind.Element:
                        result.push(current)
                    _: pass_dn

                # Push children in reverse order for correct depth-first traversal
                var ci = n.children.len() - 1
                while ci >= 0:
                    stack.push(n.children.get(ci))
                    ci = ci - 1
            nil: pass_dn

    result
