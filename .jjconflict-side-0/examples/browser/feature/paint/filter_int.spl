#![allow(unnamed_duplicate_typed_args)]
# Integer-only CSS filter pipeline.
# All color transformations use i32/i64 arithmetic with 256-scale fixed-point.
# No f64/f32 types appear anywhere in this module.
# Pixel format: ARGB 0xAARRGGBB.
# Spec: https://www.w3.org/TR/filter-effects-1/

use examples.browser.feature.paint.filter.{FilterFunction}
use std.common.color.types.{Color, from_rgb, from_rgba}
use std.common.math.{math_abs, math_max, math_min}

# =========================================================================
# Integer sine/cosine lookup table (CORDIC-style, 90 entries per quadrant)
# Values are sin(i * 1deg) * 256, for i in 0..89
# =========================================================================

fn _sin_table_entry(index: i32) -> i32:
    """Return sin(index degrees) * 256 for index 0-90."""
    # Pre-computed integer table: sin(0..90 deg) * 256
    # Each entry = round(sin(i * pi/180) * 256)
    match index:
        0: 0
        1: 4
        2: 9
        3: 13
        4: 18
        5: 22
        6: 27
        7: 31
        8: 36
        9: 40
        10: 44
        11: 49
        12: 53
        13: 57
        14: 62
        15: 66
        16: 70
        17: 74
        18: 79
        19: 83
        20: 88
        21: 91
        22: 95
        23: 99
        24: 104
        25: 108
        26: 111
        27: 115
        28: 119
        29: 123
        30: 128
        31: 131
        32: 135
        33: 139
        34: 142
        35: 147
        36: 150
        37: 153
        38: 157
        39: 160
        40: 164
        41: 167
        42: 171
        43: 174
        44: 177
        45: 181
        46: 184
        47: 187
        48: 190
        49: 193
        50: 196
        51: 199
        52: 202
        53: 204
        54: 207
        55: 210
        56: 212
        57: 215
        58: 217
        59: 219
        60: 222
        61: 224
        62: 226
        63: 228
        64: 230
        65: 232
        66: 234
        67: 235
        68: 237
        69: 239
        70: 240
        71: 242
        72: 243
        73: 244
        74: 246
        75: 247
        76: 248
        77: 249
        78: 250
        79: 251
        80: 252
        81: 252
        82: 253
        83: 254
        84: 254
        85: 255
        86: 255
        87: 255
        88: 256
        89: 256
        90: 256
        _: 0

fn _sin_int(angle_deg: i32) -> i32:
    """Integer sine: returns sin(angle) * 256. Supports any angle via quadrant mapping."""
    var a = angle_deg
    # Normalize to 0-359
    while a < 0:
        a = a + 360
    while a >= 360:
        a = a - 360

    if a <= 90:
        return _sin_table_entry(a)
    if a <= 180:
        return _sin_table_entry(180 - a)
    if a <= 270:
        return -_sin_table_entry(a - 180)
    return -_sin_table_entry(360 - a)

fn _cos_int(angle_deg: i32) -> i32:
    """Integer cosine: returns cos(angle) * 256."""
    _sin_int(angle_deg + 90)

# =========================================================================
# Per-pixel color filter application (pure integer)
# =========================================================================

fn apply_color_filter_int(pixel: u32, filters: [FilterFunction]) -> u32:
    """Apply a chain of color filters to an ARGB pixel using only integer math.

    Brightness/contrast/saturation use 256-scale fixed-point.
    Hue-rotate uses the integer lookup table for sin/cos.
    Blur and drop-shadow are spatial and skipped.
    """
    var r = _extract_r_fi(pixel)
    var g = _extract_g_fi(pixel)
    var b = _extract_b_fi(pixel)
    var a = _extract_a_fi(pixel)

    for filter in filters:
        match filter:
            FilterFunction.Brightness(amount):
                # amount is f64, convert to fp8: amount * 256
                val amount_fp8 = _f64_amount_to_fp8(amount)
                r = _clamp_ch_i32(r * amount_fp8 / 256)
                g = _clamp_ch_i32(g * amount_fp8 / 256)
                b = _clamp_ch_i32(b * amount_fp8 / 256)

            FilterFunction.Contrast(amount):
                val amount_fp8 = _f64_amount_to_fp8(amount)
                r = _clamp_ch_i32(((r - 128) * amount_fp8) / 256 + 128)
                g = _clamp_ch_i32(((g - 128) * amount_fp8) / 256 + 128)
                b = _clamp_ch_i32(((b - 128) * amount_fp8) / 256 + 128)

            FilterFunction.Grayscale(amount):
                val amount_fp8 = _f64_amount_to_fp8(amount)
                val clamped = _min_i32_fi(amount_fp8, 256)
                # BT.709 integer luminance: 54/255 r + 183/255 g + 18/255 b
                val lum = (r * 54 + g * 183 + b * 18) / 255
                r = _clamp_ch_i32(r + (lum - r) * clamped / 256)
                g = _clamp_ch_i32(g + (lum - g) * clamped / 256)
                b = _clamp_ch_i32(b + (lum - b) * clamped / 256)

            FilterFunction.HueRotate(angle):
                val angle_i = _f64_angle_to_i32(angle)
                val cos_v = _cos_int(angle_i)
                val sin_v = _sin_int(angle_i)
                # Hue rotation matrix (coefficients * 256, BT.709 luminance weights)
                # Matrix from spec, all multiplied by 256:
                #   [54 + 201*c - 54*s,  183 - 183*c - 183*s, 18 - 18*c + 237*s]
                #   [54 - 54*c + 36*s,   183 + 73*c + 36*s,   18 - 18*c - 72*s ]
                #   [54 - 54*c - 201*s,  183 - 183*c + 183*s, 18 + 237*c + 18*s]
                # But coefficients are already *256 via cos/sin table, so divide by 256 twice.
                val m00 = 54 * 256 + 201 * cos_v - 54 * sin_v
                val m01 = 183 * 256 - 183 * cos_v - 183 * sin_v
                val m02 = 18 * 256 - 18 * cos_v + 237 * sin_v
                val m10 = 54 * 256 - 54 * cos_v + 36 * sin_v
                val m11 = 183 * 256 + 73 * cos_v + 36 * sin_v
                val m12 = 18 * 256 - 18 * cos_v - 72 * sin_v
                val m20 = 54 * 256 - 54 * cos_v - 201 * sin_v
                val m21 = 183 * 256 - 183 * cos_v + 183 * sin_v
                val m22 = 18 * 256 + 237 * cos_v + 18 * sin_v
                # Apply matrix; result divided by 256*255 to normalize
                val nr = (r * m00 + g * m01 + b * m02) / (256 * 255)
                val ng = (r * m10 + g * m11 + b * m12) / (256 * 255)
                val nb = (r * m20 + g * m21 + b * m22) / (256 * 255)
                r = _clamp_ch_i32(nr)
                g = _clamp_ch_i32(ng)
                b = _clamp_ch_i32(nb)

            FilterFunction.Invert(amount):
                val amount_fp8 = _f64_amount_to_fp8(amount)
                val clamped = _min_i32_fi(amount_fp8, 256)
                r = _clamp_ch_i32(r + (255 - 2 * r) * clamped / 256)
                g = _clamp_ch_i32(g + (255 - 2 * g) * clamped / 256)
                b = _clamp_ch_i32(b + (255 - 2 * b) * clamped / 256)

            FilterFunction.Opacity(amount):
                val amount_fp8 = _f64_amount_to_fp8(amount)
                val clamped = _min_i32_fi(amount_fp8, 256)
                a = _clamp_ch_i32(a * clamped / 256)

            FilterFunction.Saturate(amount):
                val amount_fp8 = _f64_amount_to_fp8(amount)
                val lum = (r * 54 + g * 183 + b * 18) / 255
                r = _clamp_ch_i32(lum + (r - lum) * amount_fp8 / 256)
                g = _clamp_ch_i32(lum + (g - lum) * amount_fp8 / 256)
                b = _clamp_ch_i32(lum + (b - lum) * amount_fp8 / 256)

            FilterFunction.Sepia(amount):
                val amount_fp8 = _f64_amount_to_fp8(amount)
                val clamped = _min_i32_fi(amount_fp8, 256)
                # Sepia matrix integer coefficients (divide by 100):
                # [100, 89, 69] -> sr
                # [77, 69, 54]  -> sg
                # [60, 54, 42]  -> sb
                val sr = _clamp_ch_i32((r * 100 + g * 89 + b * 69) / 100)
                val sg = _clamp_ch_i32((r * 77 + g * 69 + b * 54) / 100)
                val sb = _clamp_ch_i32((r * 60 + g * 54 + b * 42) / 100)
                r = _clamp_ch_i32(r + (sr - r) * clamped / 256)
                g = _clamp_ch_i32(g + (sg - g) * clamped / 256)
                b = _clamp_ch_i32(b + (sb - b) * clamped / 256)

            FilterFunction.Blur(_):
                # Spatial filter -- no-op at per-pixel level
                pass_dn

            FilterFunction.DropShadow(_, _, _, _):
                # Spatial filter -- no-op at per-pixel level
                pass_dn

    _pack_argb_fi(a, r, g, b)

fn apply_color_filter_int_to_color(color: Color, filters: [FilterFunction]) -> Color:
    """Convenience: apply integer filters to a Color value."""
    val pixel = _color_to_argb_fi(color)
    val result = apply_color_filter_int(pixel, filters)
    _argb_to_color_fi(result)

# =========================================================================
# Amount conversion (f64 filter params to integer)
# =========================================================================

fn _f64_amount_to_fp8(amount: f64) -> i32:
    """Convert f64 amount (e.g. 1.0, 0.5, 1.2) to 8.8 fixed-point i32.

    We use a simple iterative method to avoid float-to-int dependency.
    """
    if amount <= 0.0:
        return 0
    if amount >= 10.0:
        return 2560
    # amount * 256 via iterative approach
    var result: i32 = 0
    var remaining = amount * 256.0
    while remaining >= 1000.0:
        result = result + 1000
        remaining = remaining - 1000.0
    while remaining >= 1.0:
        result = result + 1
        remaining = remaining - 1.0
    result

fn _f64_angle_to_i32(angle: f64) -> i32:
    """Convert f64 angle in degrees to i32."""
    if angle >= 0.0:
        var result: i32 = 0
        var remaining = angle
        while remaining >= 1000.0:
            result = result + 1000
            remaining = remaining - 1000.0
        while remaining >= 1.0:
            result = result + 1
            remaining = remaining - 1.0
        return result
    var result: i32 = 0
    var remaining = -angle
    while remaining >= 1000.0:
        result = result + 1000
        remaining = remaining - 1000.0
    while remaining >= 1.0:
        result = result + 1
        remaining = remaining - 1.0
    -result

# =========================================================================
# Pixel manipulation (ARGB: 0xAARRGGBB)
# =========================================================================

fn _extract_a_fi(pixel: u32) -> i32:
    ((pixel / 16777216) % 256).to_i32()

fn _extract_r_fi(pixel: u32) -> i32:
    ((pixel / 65536) % 256).to_i32()

fn _extract_g_fi(pixel: u32) -> i32:
    ((pixel / 256) % 256).to_i32()

fn _extract_b_fi(pixel: u32) -> i32:
    (pixel % 256).to_i32()

fn _pack_argb_fi(a: i32, r: i32, g: i32, b: i32) -> u32:
    val au = _clamp_ch_i32(a).to_u32()
    val ru = _clamp_ch_i32(r).to_u32()
    val gu = _clamp_ch_i32(g).to_u32()
    val bu = _clamp_ch_i32(b).to_u32()
    au * 16777216 + ru * 65536 + gu * 256 + bu

fn _clamp_ch_i32(v: i32) -> i32:
    if v < 0:
        return 0
    if v > 255:
        return 255
    v

fn _min_i32_fi(a: i32, b: i32) -> i32:
    if a < b: a else: b

fn _max_i32_fi(a: i32, b: i32) -> i32:
    if a > b: a else: b

fn _color_to_argb_fi(color: Color) -> u32:
    _pack_argb_fi(color.a.to_i32(), color.r.to_i32(), color.g.to_i32(), color.b.to_i32())

fn _argb_to_color_fi(pixel: u32) -> Color:
    from_rgba(
        _extract_r_fi(pixel).to_i64(),
        _extract_g_fi(pixel).to_i64(),
        _extract_b_fi(pixel).to_i64(),
        _extract_a_fi(pixel).to_i64()
    )
