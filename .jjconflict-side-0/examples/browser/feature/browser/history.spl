#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# Session and persistent history manager for the Simple Browser Platform.
# Tracks visited URLs with titles, timestamps, visit counts, and search.

use sbp.shared.error.{BrowserResult, BrowserError, BrowserErrorKind}
use sbp.shared.logging.{Logger, LogLevel}
use sbp.entity.browser.navigation_types.NavigationEntry

class HistoryEntry:
    url: text
    title: text
    timestamp: i64
    visit_count: i64

    static fn create(url: text, title: text, timestamp: i64) -> HistoryEntry:
        HistoryEntry(url: url, title: title, timestamp: timestamp, visit_count: 1)

class VisitCount:
    url: text
    count: i64
    last_visit: i64

    static fn create(url: text) -> VisitCount:
        VisitCount(url: url, count: 0, last_visit: 0)

class HistoryManager:
    entries: [HistoryEntry]
    visit_counts: [VisitCount]
    max_entries: i64
    logger: Logger

    static fn new(max_entries: i64, logger: Logger) -> HistoryManager:
        HistoryManager(
            entries: [HistoryEntry](),
            visit_counts: [VisitCount](),
            max_entries: max_entries,
            logger: logger
        )

    me add_entry(url: text, title: text, timestamp: i64):
        # Evict oldest entry if at capacity
        if self.entries.len() >= self.max_entries:
            self.entries.remove(0)
        val entry = HistoryEntry.create(url: url, title: title, timestamp: timestamp)
        self.entries.push(entry)
        self.increment_visit(url, timestamp)
        self.logger.debug("History entry added: {title} ({url})")

    me remove_entry(url: text):
        var idx = -1
        for i in 0..self.entries.len():
            if self.entries[i].url == url:
                idx = i
        if idx >= 0:
            self.entries.remove(idx)
            self.logger.debug("History entry removed: {url}")

    fn search(query: text) -> [HistoryEntry]:
        var results = [HistoryEntry]()
        val q = query.to_lower()
        for entry in self.entries:
            if entry.title.to_lower().contains(q) or entry.url.to_lower().contains(q):
                results.push(entry)
        results

    fn get_recent(count: i64) -> [HistoryEntry]:
        var results = [HistoryEntry]()
        val start = if self.entries.len() > count: self.entries.len() - count else: 0
        for i in start..self.entries.len():
            results.push(self.entries[i])
        # Return in reverse chronological order
        var reversed = [HistoryEntry]()
        var i = results.len() - 1
        while i >= 0:
            reversed.push(results[i])
            i = i - 1
        reversed

    fn get_most_visited(count: i64) -> [HistoryEntry]:
        # Sort visit_counts by count descending, return matching history entries
        var sorted_visits = [VisitCount]()
        for vc in self.visit_counts:
            sorted_visits.push(vc)
        # Simple insertion sort by count descending
        for i in 1..sorted_visits.len():
            var j = i
            while j > 0 and sorted_visits[j].count > sorted_visits[j - 1].count:
                val tmp = sorted_visits[j]
                sorted_visits[j] = sorted_visits[j - 1]
                sorted_visits[j - 1] = tmp
                j = j - 1
        var results = [HistoryEntry]()
        val limit = if count < sorted_visits.len(): count else: sorted_visits.len()
        for i in 0..limit:
            val url = sorted_visits[i].url
            # Find most recent entry for this URL
            var latest: HistoryEntry? = nil
            for entry in self.entries:
                if entry.url == url:
                    latest = Some(entry)
            if val e = latest:
                results.push(e)
        results

    me clear_range(from: i64, to: i64):
        var i = self.entries.len() - 1
        while i >= 0:
            val ts = self.entries[i].timestamp
            if ts >= from and ts <= to:
                self.entries.remove(i)
            i = i - 1
        self.logger.info("Cleared history range from={from} to={to}")

    me clear_all():
        self.entries = [HistoryEntry]()
        self.visit_counts = [VisitCount]()
        self.logger.info("All history cleared")

    fn get_entry_count() -> i64:
        self.entries.len()

    me increment_visit(url: text, timestamp: i64):
        for i in 0..self.visit_counts.len():
            if self.visit_counts[i].url == url:
                self.visit_counts[i].count = self.visit_counts[i].count + 1
                self.visit_counts[i].last_visit = timestamp
                return
        # New URL — create visit count entry
        val vc = VisitCount(url: url, count: 1, last_visit: timestamp)
        self.visit_counts.push(vc)

    fn get_visit_count(url: text) -> i64:
        for vc in self.visit_counts:
            if vc.url == url:
                return vc.count
        0
