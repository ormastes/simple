    # ===================================================================
    # InTemplate mode — inside <template>
    # ===================================================================

    me process_in_template(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                self.process_in_body(token)
            HtmlToken.CommentToken(data):
                self.process_in_body(token)
            HtmlToken.Doctype(name, public_id, system_id, force_quirks):
                self.process_in_body(token)
            HtmlToken.StartTag(name, attributes, self_closing):
                match name:
                    "base":
                        self.process_in_head(token)
                    "basefont":
                        self.process_in_head(token)
                    "link":
                        self.process_in_head(token)
                    "meta":
                        self.process_in_head(token)
                    "script":
                        self.process_in_head(token)
                    "style":
                        self.process_in_head(token)
                    "template":
                        self.process_in_head(token)
                    "title":
                        self.process_in_head(token)
                    "caption":
                        self.push_template_mode_and_switch(InsertionMode.InTable, token)
                    "colgroup":
                        self.push_template_mode_and_switch(InsertionMode.InColumnGroup, token)
                    "col":
                        self.push_template_mode_and_switch(InsertionMode.InColumnGroup, token)
                    "tbody":
                        self.push_template_mode_and_switch(InsertionMode.InTableBody, token)
                    "tfoot":
                        self.push_template_mode_and_switch(InsertionMode.InTableBody, token)
                    "thead":
                        self.push_template_mode_and_switch(InsertionMode.InTableBody, token)
                    "tr":
                        self.push_template_mode_and_switch(InsertionMode.InRow, token)
                    "td":
                        self.push_template_mode_and_switch(InsertionMode.InCell, token)
                    "th":
                        self.push_template_mode_and_switch(InsertionMode.InCell, token)
                    _:
                        self.push_template_mode_and_switch(InsertionMode.InBody, token)
            HtmlToken.EndTag(name):
                match name:
                    "template":
                        self.process_in_head(token)
                    _:
                        self.logger.warn("InTemplate: unexpected </{name}>, ignoring")
            HtmlToken.Eof:
                if not self.has_template_on_stack():
                    pass_do_nothing  # stop parsing
                else:
                    self.logger.warn("InTemplate: EOF with open template")
                    self.pop_until("template")
                    self.clear_formatting_to_marker()
                    self.pop_template_mode()
                    self.reset_insertion_mode()
                    self.process_token(token)

    me push_template_mode_and_switch(mode: InsertionMode, token: HtmlToken):
        # Pop current template insertion mode, push new one, switch, reprocess
        self.pop_template_mode()
        self.template_modes.push(mode)
        self.insertion_mode = mode
        self.process_token(token)

    me pop_template_mode():
        if self.template_modes.len() > 0:
            self.template_modes.pop()

    fn has_template_on_stack() -> bool:
        var idx = self.open_elements.len() - 1
        while idx >= 0:
            val node_id = self.open_elements.get(idx)
            val node_tag = self.get_element_tag(node_id)
            if node_tag == "template":
                return true
            idx = idx - 1
        false

    # ===================================================================
    # InFrameset mode — inside <frameset>
    # ===================================================================

    me process_in_frameset(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                if self.is_whitespace(data):
                    self.insert_text(data)
                else:
                    self.logger.warn("InFrameset: non-whitespace character, ignoring")
            HtmlToken.CommentToken(data):
                self.insert_comment(data)
            HtmlToken.Doctype(name, public_id, system_id, force_quirks):
                self.logger.warn("InFrameset: unexpected doctype, ignoring")
            HtmlToken.StartTag(name, attributes, self_closing):
                match name:
                    "html":
                        self.process_in_body(token)
                    "frameset":
                        self.insert_element("frameset", attributes)
                    "frame":
                        self.insert_element("frame", attributes)
                        self.pop_current()  # frame is void
                    "noframes":
                        # Process as InHead (raw text)
                        self.insert_element("noframes", attributes)
                        self.original_insertion_mode = self.insertion_mode
                        self.insertion_mode = InsertionMode.Text
                    _:
                        self.logger.warn("InFrameset: unexpected <{name}>, ignoring")
            HtmlToken.EndTag(name):
                match name:
                    "frameset":
                        if self.current_node() == self.open_elements.get(0):
                            # Fragment case: do not pop the root html element
                            self.logger.warn("InFrameset: </frameset> on root element, ignoring")
                        else:
                            self.pop_current()
                            val cn = self.current_node()
                            val cn_tag = self.get_element_tag(cn)
                            if cn_tag != "frameset":
                                self.insertion_mode = InsertionMode.AfterFrameset
                    _:
                        self.logger.warn("InFrameset: unexpected </{name}>, ignoring")
            HtmlToken.Eof:
                if self.current_node() != self.open_elements.get(0):
                    self.logger.warn("InFrameset: EOF with open frameset")

    # ===================================================================
    # AfterFrameset mode — after </frameset>
    # ===================================================================

    me process_after_frameset(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                if self.is_whitespace(data):
                    self.insert_text(data)
                else:
                    self.logger.warn("AfterFrameset: non-whitespace character, ignoring")
            HtmlToken.CommentToken(data):
                self.insert_comment(data)
            HtmlToken.Doctype(name, public_id, system_id, force_quirks):
                self.logger.warn("AfterFrameset: unexpected doctype, ignoring")
            HtmlToken.StartTag(name, attributes, self_closing):
                match name:
                    "html":
                        self.process_in_body(token)
                    "noframes":
                        # Process as InHead (raw text)
                        self.insert_element("noframes", attributes)
                        self.original_insertion_mode = self.insertion_mode
                        self.insertion_mode = InsertionMode.Text
                    _:
                        self.logger.warn("AfterFrameset: unexpected <{name}>, ignoring")
            HtmlToken.EndTag(name):
                match name:
                    "html":
                        self.insertion_mode = InsertionMode.AfterAfterFrameset
                    _:
                        self.logger.warn("AfterFrameset: unexpected </{name}>, ignoring")
            HtmlToken.Eof:
                pass_do_nothing  # Stop parsing

    # ===================================================================
    # AfterAfterBody mode — after </html> in body context
    # ===================================================================

    me process_after_after_body(token: HtmlToken):
        match token:
            HtmlToken.CommentToken(data):
                # Append comment to the document node
                val comment_id = self.create_node(NodeKind.Comment, data)
                self.append_child(self.document_node, comment_id)
            HtmlToken.Doctype(name, public_id, system_id, force_quirks):
                self.process_in_body(token)
            HtmlToken.Character(data):
                if self.is_whitespace(data):
                    self.process_in_body(token)
                else:
                    self.logger.warn("AfterAfterBody: non-whitespace character, switching to InBody")
                    self.insertion_mode = InsertionMode.InBody
                    self.process_in_body(token)
            HtmlToken.StartTag(name, attributes, self_closing):
                if name == "html":
                    self.process_in_body(token)
                else:
                    self.logger.warn("AfterAfterBody: unexpected <{name}>, switching to InBody")
                    self.insertion_mode = InsertionMode.InBody
                    self.process_in_body(token)
            HtmlToken.Eof:
                pass_do_nothing  # Stop parsing
            _:
                self.logger.warn("AfterAfterBody: unexpected token, switching to InBody")
                self.insertion_mode = InsertionMode.InBody
                self.process_in_body(token)

    # ===================================================================
    # AfterAfterFrameset mode — after </html> in frameset context
    # ===================================================================

    me process_after_after_frameset(token: HtmlToken):
        match token:
            HtmlToken.CommentToken(data):
                # Append comment to the document node
                val comment_id = self.create_node(NodeKind.Comment, data)
                self.append_child(self.document_node, comment_id)
            HtmlToken.Doctype(name, public_id, system_id, force_quirks):
                self.process_in_body(token)
            HtmlToken.Character(data):
                if self.is_whitespace(data):
                    self.process_in_body(token)
                else:
                    self.logger.warn("AfterAfterFrameset: non-whitespace character, ignoring")
            HtmlToken.StartTag(name, attributes, self_closing):
                match name:
                    "html":
                        self.process_in_body(token)
                    "noframes":
                        # Process as InHead
                        self.process_in_head(token)
                    _:
                        self.logger.warn("AfterAfterFrameset: unexpected <{name}>, ignoring")
            HtmlToken.Eof:
                pass_do_nothing  # Stop parsing
            _:
                self.logger.warn("AfterAfterFrameset: unexpected token, ignoring")

    # ===================================================================
    # Node / tree manipulation methods
    # ===================================================================

    me create_node(kind: NodeKind, data: text) -> i64:
        val id = self.next_node_id
        self.next_node_id = self.next_node_id + 1
        val node = DomNode.create(id, kind, -1, data)
        self.nodes.push(node)
        self.logger.trace("Create node id={id} kind={kind} data=\"{data}\"")
        id

    me create_element(tag: text, attrs: [Attr]) -> i64:
        val id = self.create_node(NodeKind.Element, tag)
        val elem = Element(node_id: id, tag_name: tag, attributes: attrs, ns: "http://www.w3.org/1999/xhtml")
        self.elements.push(elem)
        id

    me insert_element(tag: text, attrs: [Attr]) -> i64:
        val id = self.create_element(tag, attrs)
        val parent_id = self.appropriate_insert_point()
        self.append_child(parent_id, id)
        self.open_elements.push(id)
        self.logger.debug("Insert element <{tag}> id={id} parent={parent_id}")
        id

    me insert_text(data: text):
        val parent_id = self.appropriate_insert_point()
        # Try to merge with previous text node
        if self.nodes.len() > 0 and parent_id >= 0:
            val parent_node = self.get_node(parent_id)
            if parent_node.children.len() > 0:
                val last_child_id = parent_node.children.get(parent_node.children.len() - 1)
                val last_child = self.get_node(last_child_id)
                if last_child.kind == NodeKind.Text:
                    # Merge text — update the existing node's data
                    self.update_node_data(last_child_id, last_child.data + data)
                    return
        # Create new text node
        val text_id = self.create_node(NodeKind.Text, data)
        self.append_child(parent_id, text_id)

    me insert_comment(data: text):
        val parent_id = self.appropriate_insert_point()
        val comment_id = self.create_node(NodeKind.Comment, data)
        self.append_child(parent_id, comment_id)

    fn current_node() -> i64:
        if self.open_elements.len() == 0:
            return -1
        self.open_elements.get(self.open_elements.len() - 1)

    fn appropriate_insert_point() -> i64:
        # Foster parenting: when enabled and current node is a table-context element,
        # find the table element and insert before it (i.e. into its parent).
        if self.foster_parenting:
            val cn = self.current_node()
            if cn >= 0:
                val cn_tag = self.get_element_tag(cn)
                if (cn_tag == "table" or cn_tag == "tbody" or cn_tag == "tfoot" or cn_tag == "thead" or cn_tag == "tr"):
                    # Find the table element in the stack
                    var idx = self.open_elements.len() - 1
                    while idx >= 0:
                        val node_id = self.open_elements.get(idx)
                        val node_tag = self.get_element_tag(node_id)
                        if node_tag == "table":
                            # Insert into the parent of the table element
                            val table_node = self.get_node(node_id)
                            if table_node.parent_id >= 0:
                                return table_node.parent_id
                            # If table has no parent, use the element before it in the stack
                            if idx > 0:
                                return self.open_elements.get(idx - 1)
                            return self.document_node
                        idx = idx - 1
        val cn = self.current_node()
        if cn >= 0:
            return cn
        self.document_node

    me pop_current():
        if self.open_elements.len() > 0:
            val popped = self.open_elements.pop()
            val tag = self.get_element_tag(popped)
            self.logger.trace("Pop element <{tag}> id={popped}")

    me pop_until(tag: text):
        var guard = 0
        while guard < 1000:
            guard = guard + 1
            if self.open_elements.len() == 0:
                return
            val top = self.current_node()
            val top_tag = self.get_element_tag(top)
            self.open_elements.pop()
            self.logger.trace("Pop until <{tag}>: popped <{top_tag}> id={top}")
            if top_tag == tag:
                return

    me has_in_scope(tag: text) -> bool:
        self.has_in_scope_with_list(tag, SCOPE_ELEMENTS)

    me has_in_button_scope(tag: text) -> bool:
        self.has_in_scope_with_list(tag, BUTTON_SCOPE_ELEMENTS)

    me has_in_table_scope(tag: text) -> bool:
        self.has_in_scope_with_list(tag, TABLE_SCOPE_ELEMENTS)

    me has_in_list_item_scope(tag: text) -> bool:
        # List item scope adds <ol> and <ul> to scope elements
        var idx = self.open_elements.len() - 1
        while idx >= 0:
            val node_id = self.open_elements.get(idx)
            val node_tag = self.get_element_tag(node_id)
            if node_tag == tag:
                return true
            if (SCOPE_ELEMENTS.contains(node_tag) or node_tag == "ol" or node_tag == "ul"):
                return false
            idx = idx - 1
        false

    fn has_in_scope_with_list(tag: text, scope_list: [text]) -> bool:
        var idx = self.open_elements.len() - 1
        while idx >= 0:
            val node_id = self.open_elements.get(idx)
            val node_tag = self.get_element_tag(node_id)
            if node_tag == tag:
                return true
            if scope_list.contains(node_tag):
                return false
            idx = idx - 1
        false

    me generate_implied_end_tags(except: text):
        var guard = 0
        while guard < 100:
            guard = guard + 1
            if self.open_elements.len() == 0:
                return
            val top_id = self.current_node()
            val top_tag = self.get_element_tag(top_id)
            if top_tag == except:
                return
            if IMPLIED_END_TAG_ELEMENTS.contains(top_tag):
                self.pop_current()
            else:
                return

    # ===================================================================
    # Helper methods for InBody tag processing
    # ===================================================================

    me handle_heading(name: text, attributes: [Attr]):
        self.close_p_if_in_button_scope()
        # If current node is a heading, close it (no nested headings)
        val cn = self.current_node()
        if cn >= 0:
            val cn_tag = self.get_element_tag(cn)
            if HEADING_ELEMENTS.contains(cn_tag):
                self.logger.warn("InBody: nested heading <{name}> inside <{cn_tag}>, closing")
                self.pop_current()
        self.insert_element(name, attributes)

    me close_p_if_in_button_scope():
        if self.has_in_button_scope("p"):
            self.generate_implied_end_tags("p")
            self.pop_until("p")

    me close_block_element(name: text):
        if self.has_in_scope(name):
            self.generate_implied_end_tags("")
            self.pop_until(name)
        else:
            self.logger.warn("InBody: </{name}> without matching open element")

    me close_heading():
        # Close any heading element in scope
        var found = false
        var idx = self.open_elements.len() - 1
        while idx >= 0 and not found:
            val node_id = self.open_elements.get(idx)
            val node_tag = self.get_element_tag(node_id)
            if HEADING_ELEMENTS.contains(node_tag):
                found = true
            if SCOPE_ELEMENTS.contains(node_tag):
                idx = -1  # break
            idx = idx - 1
        if found:
            self.generate_implied_end_tags("")
            # Pop until we find a heading element
            var guard = 0
            while guard < 100:
                guard = guard + 1
                if self.open_elements.len() == 0:
                    return
                val top_id = self.current_node()
                val top_tag = self.get_element_tag(top_id)
                self.pop_current()
                if HEADING_ELEMENTS.contains(top_tag):
                    return

    me close_inline_element(name: text):
        # Use the adoption agency algorithm for formatting elements (WHATWG 13.2.6.4.7).
        # This correctly handles misnested tags like <b>1<i>2</b>3</i>.
        self.run_adoption_agency(name)

    # Adoption agency algorithm (WHATWG spec section 13.2.6.4.7).
    # Handles misnested formatting elements by reparenting nodes.
    me run_adoption_agency(tag: text):
        # Outer loop: run up to 8 times
        var outer = 0
        while outer < 8:
            outer = outer + 1

            # Step 1: Find the formatting element in the active formatting list
            var formatting_idx = -1
            var fi = self.active_formatting.len() - 1
            while fi >= 0:
                val node_id = self.active_formatting.get(fi)
                val node_tag = self.get_element_tag(node_id)
                if node_tag == tag:
                    formatting_idx = fi
                    fi = -1  # break
                else:
                    fi = fi - 1

            if formatting_idx < 0:
                # No formatting element found — fall back to simple close
                if self.has_in_scope(tag):
                    self.generate_implied_end_tags("")
                    self.pop_until(tag)
                else:
                    self.logger.trace("adoption_agency: </{tag}> not in scope, ignoring")
                return

            val formatting_id = self.active_formatting.get(formatting_idx)

            # Check if the formatting element is in the stack of open elements
            var stack_idx = -1
            var si = self.open_elements.len() - 1
            while si >= 0:
                if self.open_elements.get(si) == formatting_id:
                    stack_idx = si
                    si = -1  # break
                else:
                    si = si - 1

            if stack_idx < 0:
                # Not in stack — remove from formatting list and return
                self._remove_from_active_formatting(formatting_idx)
                return

            if not self.has_in_scope(tag):
                self.logger.trace("adoption_agency: <{tag}> not in scope")
                return

            # Step 2: Find the furthest block — first block-level element
            # in the stack after the formatting element
            var furthest_block_idx = -1
            var bi = stack_idx + 1
            while bi < self.open_elements.len():
                val bid = self.open_elements.get(bi)
                val btag = self.get_element_tag(bid)
                if _is_special_element(btag):
                    furthest_block_idx = bi
                    bi = self.open_elements.len()  # break
                else:
                    bi = bi + 1

            # Step 3: If no furthest block, pop until formatting element
            if furthest_block_idx < 0:
                # Pop elements from the stack up to and including formatting_id
                var guard = 0
                while guard < 1000 and self.open_elements.len() > 0:
                    guard = guard + 1
                    val top = self.open_elements.get(self.open_elements.len() - 1)
                    self.open_elements.pop()
                    if top == formatting_id:
                        guard = 1000  # break
                self._remove_from_active_formatting(formatting_idx)
                return

            # Step 4: Inner loop — reparent nodes
            val furthest_block_id = self.open_elements.get(furthest_block_idx)
            # Common ancestor is the element just before the formatting element
            val common_ancestor_id = self.open_elements.get(stack_idx - 1)

            # Remove the formatting element from the open elements stack
            var new_open = [i64]()
            var oi = 0
            while oi < self.open_elements.len():
                if oi != stack_idx:
                    new_open.push(self.open_elements.get(oi))
                oi = oi + 1
            self.open_elements = new_open

            # Move the furthest block's children into a new formatting element,
            # then append the new element as a child of the furthest block.
            val new_elem_id = self.create_element(tag, [Attr]())
            # Reparent: move all children of furthest_block into the new element
            val fb_node = self.get_node(furthest_block_id)
            var child_idx = 0
            while child_idx < fb_node.children.len():
                val child_id = fb_node.children.get(child_idx)
                self.append_child(new_elem_id, child_id)
                child_idx = child_idx + 1
            # Clear the furthest block's children list
            var ni = 0
            while ni < self.nodes.len():
                var node = self.nodes.get(ni)
                if node.id == furthest_block_id:
                    node.children = [i64]()
                ni = ni + 1
            # Append new element as the sole child of the furthest block
            self.append_child(furthest_block_id, new_elem_id)

            # Update the active formatting list: replace the old formatting
            # element with the new one
            self._remove_from_active_formatting(formatting_idx)
            self.active_formatting.push(new_elem_id)

            self.logger.trace("adoption_agency: reparented under <{tag}> id={new_elem_id}")
            return  # One pass is enough for most cases

    me _remove_from_active_formatting(idx: i64):
        var new_list = [i64]()
        var i = 0
        while i < self.active_formatting.len():
            if i != idx:
                new_list.push(self.active_formatting.get(i))
            i = i + 1
        self.active_formatting = new_list

    # ===================================================================
    # Table context helpers
    # ===================================================================

    me clear_stack_to_table_context():
        # Pop elements until current node is table, template, or html
        var guard = 0
        while guard < 1000:
            guard = guard + 1
            if self.open_elements.len() == 0:
                return
            val cn = self.current_node()
            val cn_tag = self.get_element_tag(cn)
            if (cn_tag == "table" or cn_tag == "template" or cn_tag == "html"):
                return
            self.pop_current()

    me clear_stack_to_table_body_context():
        # Pop elements until current node is tbody, tfoot, thead, template, or html
        var guard = 0
        while guard < 1000:
            guard = guard + 1
            if self.open_elements.len() == 0:
                return
            val cn = self.current_node()
            val cn_tag = self.get_element_tag(cn)
            if (cn_tag == "tbody" or cn_tag == "tfoot" or cn_tag == "thead" or cn_tag == "template" or cn_tag == "html"):
                return
            self.pop_current()

    me clear_stack_to_table_row_context():
        # Pop elements until current node is tr, template, or html
        var guard = 0
        while guard < 1000:
            guard = guard + 1
            if self.open_elements.len() == 0:
                return
            val cn = self.current_node()
            val cn_tag = self.get_element_tag(cn)
            if (cn_tag == "tr" or cn_tag == "template" or cn_tag == "html"):
                return
            self.pop_current()

    me clear_formatting_to_marker():
        # Pop active formatting elements until a marker (-1) is found
        var guard = 0
        while guard < 1000:
            guard = guard + 1
            if self.active_formatting.len() == 0:
                return
            val entry = self.active_formatting.pop()
            if entry == -1:
                return

    me reset_insertion_mode():
        # Walk the stack of open elements from bottom to top and set insertion mode
        # based on the first matching element found (simplified algorithm)
        var idx = self.open_elements.len() - 1
        var last = true
        while idx >= 0:
            val node_id = self.open_elements.get(idx)
            val node_tag = self.get_element_tag(node_id)
            if node_tag == "select":
                # Walk back up to find context
                var inner_idx = idx - 1
                while inner_idx >= 0:
                    val ancestor_id = self.open_elements.get(inner_idx)
                    val ancestor_tag = self.get_element_tag(ancestor_id)
                    if ancestor_tag == "template":
                        self.insertion_mode = InsertionMode.InSelect
                        return
                    if (ancestor_tag == "table" or ancestor_tag == "tbody" or ancestor_tag == "tfoot" or ancestor_tag == "thead" or ancestor_tag == "tr"):
                        self.insertion_mode = InsertionMode.InSelectInTable
                        return
                    inner_idx = inner_idx - 1
                self.insertion_mode = InsertionMode.InSelect
                return
            if (node_tag == "td" or node_tag == "th"):
                if not last:
                    self.insertion_mode = InsertionMode.InCell
                    return
            if node_tag == "tr":
                self.insertion_mode = InsertionMode.InRow
                return
            if (node_tag == "tbody" or node_tag == "thead" or node_tag == "tfoot"):
                self.insertion_mode = InsertionMode.InTableBody
                return
            if node_tag == "caption":
                self.insertion_mode = InsertionMode.InCaption
                return
            if node_tag == "colgroup":
                self.insertion_mode = InsertionMode.InColumnGroup
                return
            if node_tag == "table":
                self.insertion_mode = InsertionMode.InTable
                return
            if node_tag == "template":
                if self.template_modes.len() > 0:
                    self.insertion_mode = self.template_modes.get(self.template_modes.len() - 1)
                else:
                    self.insertion_mode = InsertionMode.InBody
                return
            if node_tag == "head":
                if not last:
                    self.insertion_mode = InsertionMode.InHead
                    return
            if node_tag == "body":
                self.insertion_mode = InsertionMode.InBody
                return
            if node_tag == "frameset":
                self.insertion_mode = InsertionMode.InFrameset
                return
            if node_tag == "html":
                if self.head_element == -1:
                    self.insertion_mode = InsertionMode.BeforeHead
                else:
                    self.insertion_mode = InsertionMode.AfterHead
                return
            if idx == 0:
                # Last node (fragment case)
                self.insertion_mode = InsertionMode.InBody
                return
            last = false
            idx = idx - 1
        # Fallback
        self.insertion_mode = InsertionMode.InBody

    # ===================================================================
    # Node access helpers
    # ===================================================================

    fn get_node(id: i64) -> DomNode:
        # Linear scan — sufficient for typical document sizes
        var idx = 0
        while idx < self.nodes.len():
            val node = self.nodes.get(idx)
            if node.id == id:
                return node
            idx = idx + 1
        # Fallback: return a dummy node (should not happen in valid trees)
        DomNode.create(-1, NodeKind.Document, -1, "")

    fn get_element_tag(node_id: i64) -> text:
        # Look up element tag name by node id
        var idx = 0
        while idx < self.elements.len():
            val elem = self.elements.get(idx)
            if elem.node_id == node_id:
                return elem.tag_name
            idx = idx + 1
        # If not an element node, return the node data
        val node = self.get_node(node_id)
        node.data

    me append_child(parent_id: i64, child_id: i64):
        # Update parent's children list and child's parent_id
        var idx = 0
        while idx < self.nodes.len():
            var node = self.nodes.get(idx)
            if node.id == parent_id:
                node.children.push(child_id)
            if node.id == child_id:
                node.parent_id = parent_id
            idx = idx + 1

    me remove_child(parent_id: i64, child_id: i64):
        # Remove child_id from parent's children list and clear child's parent_id
        var idx = 0
        while idx < self.nodes.len():
            var node = self.nodes.get(idx)
            if node.id == parent_id:
                var new_children = [i64]()
                var ci = 0
                while ci < node.children.len():
                    val cid = node.children.get(ci)
                    if cid != child_id:
                        new_children.push(cid)
                    ci = ci + 1
                node.children = new_children
            if node.id == child_id:
                node.parent_id = -1
            idx = idx + 1

    me update_node_data(node_id: i64, new_data: text):
        var idx = 0
        while idx < self.nodes.len():
            var node = self.nodes.get(idx)
            if node.id == node_id:
                node.data = new_data
                return
            idx = idx + 1

    # ===================================================================
    # Utility
    # ===================================================================

    fn is_whitespace(data: text) -> bool:
        if data.len() == 0:
            return true
        var idx = 0
        while idx < data.len():
            val c = data.char_at(idx)
            if (c != " " and c != "\t" and c != "\n" and c != "\r"):
                return false
            idx = idx + 1
        true

# ---------------------------------------------------------------------------
# Module-level helpers
# ---------------------------------------------------------------------------

# Check if a tag is a "special" element per the HTML5 spec.
# Special elements create scope boundaries for the adoption agency algorithm.
fn _is_special_element(tag: text) -> bool:
    match tag:
        "address": true
        "applet": true
        "area": true
        "article": true
        "aside": true
        "base": true
        "blockquote": true
        "body": true
        "br": true
        "button": true
        "caption": true
        "center": true
        "col": true
        "colgroup": true
        "dd": true
        "details": true
        "dir": true
        "div": true
        "dl": true
        "dt": true
        "fieldset": true
        "figcaption": true
        "figure": true
        "footer": true
        "form": true
        "h1": true
        "h2": true
        "h3": true
        "h4": true
        "h5": true
        "h6": true
        "head": true
        "header": true
        "hr": true
        "html": true
        "iframe": true
        "img": true
        "input": true
        "li": true
        "link": true
        "listing": true
        "main": true
        "marquee": true
        "meta": true
        "nav": true
        "object": true
        "ol": true
        "p": true
        "pre": true
        "script": true
        "section": true
        "select": true
        "source": true
        "style": true
        "summary": true
        "table": true
        "tbody": true
        "td": true
        "template": true
        "textarea": true
        "tfoot": true
        "th": true
        "thead": true
        "title": true
        "tr": true
        "ul": true
        _: false
