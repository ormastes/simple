                            self.process_in_table(token)
                        else:
                            self.logger.warn("InColumnGroup: unexpected <{name}>, ignoring")
            HtmlToken.EndTag(name):
                match name:
                    "colgroup":
                        val cn = self.current_node()
                        val cn_tag = self.get_element_tag(cn)
                        if cn_tag == "colgroup":
                            self.pop_current()
                            self.insertion_mode = InsertionMode.InTable
                        else:
                            self.logger.warn("InColumnGroup: </colgroup> without <colgroup> on stack")
                    "col":
                        self.logger.warn("InColumnGroup: unexpected </col>, ignoring")
                    "template":
                        self.process_in_head(token)
                    _:
                        # Act as if </colgroup> was seen
                        val cn = self.current_node()
                        val cn_tag = self.get_element_tag(cn)
                        if cn_tag == "colgroup":
                            self.pop_current()
                            self.insertion_mode = InsertionMode.InTable
                            self.process_in_table(token)
                        else:
                            self.logger.warn("InColumnGroup: unexpected </{name}>, ignoring")
            HtmlToken.Eof:
                self.process_in_body(token)
            _:
                val cn = self.current_node()
                val cn_tag = self.get_element_tag(cn)
                if cn_tag == "colgroup":
                    self.pop_current()
                    self.insertion_mode = InsertionMode.InTable
                    self.process_in_table(token)

    # ===================================================================
    # InTableBody mode — inside <tbody>, <thead>, or <tfoot>
    # ===================================================================

    me process_in_table_body(token: HtmlToken):
        match token:
            HtmlToken.StartTag(name, attributes, self_closing):
                match name:
                    "tr":
                        self.clear_stack_to_table_body_context()
                        self.insert_element("tr", attributes)
                        self.insertion_mode = InsertionMode.InRow
                    "td":
                        # Implied <tr>
                        self.logger.warn("InTableBody: <td> without <tr>, inserting implied <tr>")
                        self.clear_stack_to_table_body_context()
                        self.insert_element("tr", [Attr]())
                        self.insertion_mode = InsertionMode.InRow
                        self.process_in_row(token)
                    "th":
                        # Implied <tr>
                        self.logger.warn("InTableBody: <th> without <tr>, inserting implied <tr>")
                        self.clear_stack_to_table_body_context()
                        self.insert_element("tr", [Attr]())
                        self.insertion_mode = InsertionMode.InRow
                        self.process_in_row(token)
                    "caption":
                        self.close_table_body_and_reprocess(token)
                    "col":
