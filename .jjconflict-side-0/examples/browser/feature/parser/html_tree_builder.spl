    me close_cell_and_reprocess(token: HtmlToken):
        # Close the current td or th, switch to InRow, reprocess
        if self.has_in_table_scope("td"):
            self.generate_implied_end_tags("")
            self.pop_until("td")
            self.clear_formatting_to_marker()
            self.insertion_mode = InsertionMode.InRow
            self.process_in_row(token)
        else if self.has_in_table_scope("th"):
            self.generate_implied_end_tags("")
            self.pop_until("th")
            self.clear_formatting_to_marker()
            self.insertion_mode = InsertionMode.InRow
            self.process_in_row(token)
        else:
            self.logger.warn("InCell: no td/th in table scope to close")

    # ===================================================================
    # InSelect mode — inside <select>
    # ===================================================================

    me process_in_select(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                if data == "\0":
                    self.logger.warn("InSelect: null character, ignoring")
                else:
                    self.insert_text(data)
            HtmlToken.CommentToken(data):
                self.insert_comment(data)
            HtmlToken.Doctype(name, public_id, system_id, force_quirks):
                self.logger.warn("InSelect: unexpected doctype, ignoring")
            HtmlToken.StartTag(name, attributes, self_closing):
                match name:
                    "html":
                        self.process_in_body(token)
                    "option":
                        # Close previous option if current node is option
                        val cn = self.current_node()
                        val cn_tag = self.get_element_tag(cn)
                        if cn_tag == "option":
                            self.pop_current()
                        self.insert_element("option", attributes)
                    "optgroup":
                        # Close previous option if current
                        val cn = self.current_node()
                        val cn_tag = self.get_element_tag(cn)
                        if cn_tag == "option":
                            self.pop_current()
                        # Close previous optgroup if current
                        val cn2 = self.current_node()
                        val cn2_tag = self.get_element_tag(cn2)
                        if cn2_tag == "optgroup":
                            self.pop_current()
                        self.insert_element("optgroup", attributes)
                    "select":
                        # Act as if </select> was seen
                        self.logger.warn("InSelect: nested <select>, closing current")
                        if self.has_in_scope("select"):
                            self.pop_until("select")
                            self.reset_insertion_mode()
                    "input":
                        # Close select, reprocess
                        self.logger.warn("InSelect: <input>, closing select")
                        if self.has_in_scope("select"):
                            self.pop_until("select")
                            self.reset_insertion_mode()
                            self.process_token(token)
                    "textarea":
                        self.logger.warn("InSelect: <textarea>, closing select")
                        if self.has_in_scope("select"):
                            self.pop_until("select")
                            self.reset_insertion_mode()
                            self.process_token(token)
                    "script":
                        self.process_in_head(token)
                    "template":
                        self.process_in_head(token)
                    _:
                        self.logger.warn("InSelect: unexpected <{name}>, ignoring")
            HtmlToken.EndTag(name):
                match name:
                    "optgroup":
                        # If current is option inside optgroup, pop option first
                        val cn = self.current_node()
                        val cn_tag = self.get_element_tag(cn)
                        if cn_tag == "option":
                            # Check if parent is optgroup
                            if self.open_elements.len() >= 2:
                                val parent_id = self.open_elements.get(self.open_elements.len() - 2)
                                val parent_tag = self.get_element_tag(parent_id)
                                if parent_tag == "optgroup":
                                    self.pop_current()
                        val cn2 = self.current_node()
                        val cn2_tag = self.get_element_tag(cn2)
                        if cn2_tag == "optgroup":
                            self.pop_current()
                        else:
                            self.logger.warn("InSelect: </optgroup> without matching <optgroup>")
                    "option":
                        val cn = self.current_node()
                        val cn_tag = self.get_element_tag(cn)
                        if cn_tag == "option":
                            self.pop_current()
                        else:
                            self.logger.warn("InSelect: </option> without matching <option>")
                    "select":
                        if self.has_in_scope("select"):
                            self.pop_until("select")
                            self.reset_insertion_mode()
                        else:
                            self.logger.warn("InSelect: </select> without <select> in scope")
                    "template":
                        self.process_in_head(token)
                    _:
                        self.logger.warn("InSelect: unexpected </{name}>, ignoring")
            HtmlToken.Eof:
                self.process_in_body(token)

