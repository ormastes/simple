# HTML5 Tree Builder — tree construction algorithm for building the DOM.
#
# Compliance level: Implements the core insertion modes from WHATWG HTML5
# specification section 13.2.6 (Tree construction). Covers the primary
# document lifecycle modes: Initial, BeforeHtml, BeforeHead, InHead,
# AfterHead, InBody, Text, AfterBody. InBody handles the most common
# HTML elements including headings, paragraphs, lists, tables, forms,
# inline elements, void elements, and raw text elements (script/style).
#
# All 22 insertion modes are implemented. The adoption agency algorithm
# and full active formatting element reconstruction are simplified
# (inline elements use scope-based closing instead of the full algorithm).
#
# Depends on:
#   examples/browser/entity/dom/node_types.spl       (DomNode, Element, NodeKind)
#   examples/browser/entity/dom/attribute_types.spl   (Attr)
#   examples/browser/feature/parser/html_tokenizer.spl (HtmlTokenizer, HtmlToken)
#   examples/browser/shared/error.spl                 (BrowserResult, parse_error)
#   examples/browser/shared/logging.spl               (Logger)

use examples.browser.entity.dom.node_types
use examples.browser.entity.dom.attribute_types
use examples.browser.feature.parser.html_tokenizer
use examples.browser.shared.error
use examples.browser.shared.logging

# ---------------------------------------------------------------------------
# InsertionMode — the tree construction insertion modes
# ---------------------------------------------------------------------------

enum InsertionMode:
    Initial
    BeforeHtml
    BeforeHead
    InHead
    InHeadNoscript
    AfterHead
    InBody
    Text
    InTable
    InTableText
    InCaption
    InColumnGroup
    InTableBody
    InRow
    InCell
    InSelect
    InSelectInTable
    InTemplate
    AfterBody
    InFrameset
    AfterFrameset
    AfterAfterBody
    AfterAfterFrameset

# ---------------------------------------------------------------------------
# Scope element lists used by the has_in_scope family of checks.
# These are the elements that define scope boundaries in the HTML5 spec.
# ---------------------------------------------------------------------------

val SCOPE_ELEMENTS: [text] = [
    "applet", "caption", "html", "table", "td", "th",
    "marquee", "object", "template"
]

val BUTTON_SCOPE_ELEMENTS: [text] = [
    "applet", "caption", "html", "table", "td", "th",
    "marquee", "object", "template", "button"
]

val TABLE_SCOPE_ELEMENTS: [text] = [
    "html", "table", "template"
]

# Elements with optional end tags that get implied end tags
val IMPLIED_END_TAG_ELEMENTS: [text] = [
    "dd", "dt", "li", "optgroup", "option", "p",
    "rb", "rp", "rt", "rtc"
]

# Void elements that cannot have children
val VOID_ELEMENTS: [text] = [
    "area", "base", "br", "col", "embed", "hr", "img", "input",
    "link", "meta", "param", "source", "track", "wbr"
]

# Raw text elements whose content is not parsed as HTML
val RAW_TEXT_ELEMENTS: [text] = ["script", "style"]

# Heading elements
val HEADING_ELEMENTS: [text] = ["h1", "h2", "h3", "h4", "h5", "h6"]

# ---------------------------------------------------------------------------
# TreeBuilder — the tree construction class
# ---------------------------------------------------------------------------

class TreeBuilder:
    tokenizer: HtmlTokenizer
    insertion_mode: InsertionMode
    open_elements: [i64]
    active_formatting: [i64]
    head_element: i64
    body_element: i64
    document_node: i64
    nodes: [DomNode]
    elements: [Element]
    next_node_id: i64
    foster_parenting: bool
    frameset_ok: bool
    scripting: bool
    original_insertion_mode: InsertionMode
    template_modes: [InsertionMode]
    pending_table_text: text
    pending_table_text_mode: InsertionMode
    logger: Logger

    static fn new(tokenizer: HtmlTokenizer, logger: Logger) -> TreeBuilder:
        TreeBuilder(
            tokenizer: tokenizer,
            insertion_mode: InsertionMode.Initial,
            open_elements: [i64](),
            active_formatting: [i64](),
            head_element: -1,
            body_element: -1,
            document_node: -1,
            nodes: [DomNode](),
            elements: [Element](),
            next_node_id: 0,
            foster_parenting: false,
            frameset_ok: true,
            scripting: false,
            original_insertion_mode: InsertionMode.Initial,
            template_modes: [InsertionMode](),
            pending_table_text: "",
            pending_table_text_mode: InsertionMode.Initial,
            logger: logger
        )

    # ===================================================================
    # Main parse loop
    # ===================================================================

    me parse() -> Result<i64, BrowserError>:
        # Create the document node
        self.document_node = self.create_node(NodeKind.Document, "#document")
        self.logger.info("Starting HTML parse, document node={self.document_node}")

        var done = false
        while not done:
            val token = self.tokenizer.next_token()
            match token:
                HtmlToken.Eof:
                    done = true
                _:
                    self.process_token(token)

        self.logger.info("Parse complete, {self.nodes.len()} nodes created")
        Ok(self.document_node)

    # ===================================================================
    # Token dispatch to current insertion mode
    # ===================================================================

    me process_token(token: HtmlToken):
        match self.insertion_mode:
            InsertionMode.Initial:
                self.process_initial(token)
            InsertionMode.BeforeHtml:
                self.process_before_html(token)
            InsertionMode.BeforeHead:
                self.process_before_head(token)
            InsertionMode.InHead:
                self.process_in_head(token)
            InsertionMode.InHeadNoscript:
                self.process_in_head_noscript(token)
            InsertionMode.AfterHead:
                self.process_after_head(token)
            InsertionMode.InBody:
                self.process_in_body(token)
            InsertionMode.Text:
                self.process_text(token)
            InsertionMode.InTable:
                self.process_in_table(token)
            InsertionMode.InTableText:
                self.process_in_table_text(token)
            InsertionMode.InCaption:
                self.process_in_caption(token)
            InsertionMode.InColumnGroup:
                self.process_in_column_group(token)
            InsertionMode.InTableBody:
                self.process_in_table_body(token)
            InsertionMode.InRow:
                self.process_in_row(token)
            InsertionMode.InCell:
                self.process_in_cell(token)
            InsertionMode.InSelect:
                self.process_in_select(token)
            InsertionMode.InSelectInTable:
                self.process_in_select_in_table(token)
            InsertionMode.InTemplate:
                self.process_in_template(token)
            InsertionMode.AfterBody:
                self.process_after_body(token)
            InsertionMode.InFrameset:
                self.process_in_frameset(token)
            InsertionMode.AfterFrameset:
                self.process_after_frameset(token)
            InsertionMode.AfterAfterBody:
                self.process_after_after_body(token)
            InsertionMode.AfterAfterFrameset:
                self.process_after_after_frameset(token)

    # ===================================================================
    # Initial mode — handle doctype, then switch to BeforeHtml
    # ===================================================================

    me process_initial(token: HtmlToken):
        match token:
            HtmlToken.Doctype(name, public_id, system_id, force_quirks):
                self.logger.debug("Initial: doctype name={name}")
                val comment_id = self.create_node(NodeKind.Comment, "DOCTYPE {name}")
                self.append_child(self.document_node, comment_id)
                self.insertion_mode = InsertionMode.BeforeHtml
            HtmlToken.CommentToken(data):
                val comment_id = self.create_node(NodeKind.Comment, data)
                self.append_child(self.document_node, comment_id)
            HtmlToken.Character(data):
                # Ignore whitespace in Initial mode
                if self.is_whitespace(data):
                    pass_do_nothing
                else:
                    self.insertion_mode = InsertionMode.BeforeHtml
                    self.process_before_html(token)
            _:
                # Any other token: switch to BeforeHtml and reprocess
                self.insertion_mode = InsertionMode.BeforeHtml
                self.process_before_html(token)

    # ===================================================================
    # BeforeHtml mode — insert the html element
    # ===================================================================

    me process_before_html(token: HtmlToken):
        match token:
            HtmlToken.Doctype(name, public_id, system_id, force_quirks):
                self.logger.warn("BeforeHtml: unexpected doctype, ignoring")
            HtmlToken.CommentToken(data):
                val comment_id = self.create_node(NodeKind.Comment, data)
                self.append_child(self.document_node, comment_id)
            HtmlToken.StartTag(name, attributes, self_closing):
                if name == "html":
                    val html_id = self.create_element("html", attributes)
                    self.append_child(self.document_node, html_id)
                    self.open_elements.push(html_id)
                    self.insertion_mode = InsertionMode.BeforeHead
                else:
                    # Implied <html> tag
                    val html_id = self.create_element("html", [Attr]())
                    self.append_child(self.document_node, html_id)
                    self.open_elements.push(html_id)
                    self.insertion_mode = InsertionMode.BeforeHead
                    self.process_before_head(token)
            HtmlToken.Character(data):
                if self.is_whitespace(data):
                    pass_do_nothing
                else:
                    val html_id = self.create_element("html", [Attr]())
                    self.append_child(self.document_node, html_id)
                    self.open_elements.push(html_id)
                    self.insertion_mode = InsertionMode.BeforeHead
                    self.process_before_head(token)
            _:
                # Implied <html>
                val html_id = self.create_element("html", [Attr]())
                self.append_child(self.document_node, html_id)
                self.open_elements.push(html_id)
                self.insertion_mode = InsertionMode.BeforeHead
                self.process_before_head(token)

    # ===================================================================
    # BeforeHead mode — insert the head element
    # ===================================================================

    me process_before_head(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                if self.is_whitespace(data):
                    pass_do_nothing
                else:
                    # Implied <head>
                    self.head_element = self.insert_element("head", [Attr]())
                    self.insertion_mode = InsertionMode.InHead
                    self.process_in_head(token)
            HtmlToken.CommentToken(data):
                self.insert_comment(data)
            HtmlToken.StartTag(name, attributes, self_closing):
                if name == "html":
                    # Merge attributes into existing html element
                    self.process_in_body(token)
                else if name == "head":
                    self.head_element = self.insert_element("head", attributes)
                    self.insertion_mode = InsertionMode.InHead
                else:
                    # Implied <head>
                    self.head_element = self.insert_element("head", [Attr]())
                    self.insertion_mode = InsertionMode.InHead
                    self.process_in_head(token)
            HtmlToken.EndTag(name):
                if (name == "head" or name == "body" or name == "html" or name == "br"):
                    self.head_element = self.insert_element("head", [Attr]())
                    self.insertion_mode = InsertionMode.InHead
                    self.process_in_head(token)
                else:
                    self.logger.warn("BeforeHead: unexpected end tag </{name}>, ignoring")
            _:
                self.head_element = self.insert_element("head", [Attr]())
                self.insertion_mode = InsertionMode.InHead
                self.process_in_head(token)

    # ===================================================================
    # InHead mode — handle head-content elements
    # ===================================================================

    me process_in_head(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                if self.is_whitespace(data):
                    self.insert_text(data)
                else:
                    # Act as if </head> was seen
                    self.pop_current()
                    self.insertion_mode = InsertionMode.AfterHead
                    self.process_after_head(token)
            HtmlToken.CommentToken(data):
                self.insert_comment(data)
            HtmlToken.StartTag(name, attributes, self_closing):
                match name:
                    "html":
                        self.process_in_body(token)
                    "base":
                        self.insert_element(name, attributes)
                        self.pop_current()
                    "basefont":
                        self.insert_element(name, attributes)
                        self.pop_current()
                    "link":
                        self.insert_element(name, attributes)
                        self.pop_current()
                    "meta":
                        self.insert_element(name, attributes)
                        self.pop_current()
                    "title":
                        self.insert_element(name, attributes)
                        self.original_insertion_mode = self.insertion_mode
                        self.insertion_mode = InsertionMode.Text
                    "noscript":
                        if self.scripting:
                            self.insert_element(name, attributes)
                            self.original_insertion_mode = self.insertion_mode
                            self.insertion_mode = InsertionMode.Text
                        else:
                            self.insert_element(name, attributes)
                            self.insertion_mode = InsertionMode.InHeadNoscript
                    "style":
                        self.insert_element(name, attributes)
                        self.original_insertion_mode = self.insertion_mode
                        self.insertion_mode = InsertionMode.Text
                    "script":
                        self.insert_element(name, attributes)
                        self.original_insertion_mode = self.insertion_mode
                        self.insertion_mode = InsertionMode.Text
                    "head":
                        self.logger.warn("InHead: unexpected <head>, ignoring")
                    _:
                        # Act as if </head> was seen
                        self.pop_current()
                        self.insertion_mode = InsertionMode.AfterHead
                        self.process_after_head(token)
            HtmlToken.EndTag(name):
                match name:
                    "head":
                        self.pop_current()
                        self.insertion_mode = InsertionMode.AfterHead
                    "body":
                        self.pop_current()
                        self.insertion_mode = InsertionMode.AfterHead
                        self.process_after_head(token)
                    "html":
                        self.pop_current()
                        self.insertion_mode = InsertionMode.AfterHead
                        self.process_after_head(token)
                    "br":
                        self.pop_current()
                        self.insertion_mode = InsertionMode.AfterHead
                        self.process_after_head(token)
                    _:
                        self.logger.warn("InHead: unexpected end tag </{name}>, ignoring")
            _:
                self.pop_current()
                self.insertion_mode = InsertionMode.AfterHead
                self.process_after_head(token)

    # ===================================================================
    # AfterHead mode — between </head> and <body>
    # ===================================================================

    me process_after_head(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                if self.is_whitespace(data):
                    self.insert_text(data)
                else:
                    self.body_element = self.insert_element("body", [Attr]())
                    self.insertion_mode = InsertionMode.InBody
                    self.process_in_body(token)
            HtmlToken.CommentToken(data):
                self.insert_comment(data)
            HtmlToken.StartTag(name, attributes, self_closing):
                match name:
                    "html":
                        self.process_in_body(token)
                    "body":
                        self.body_element = self.insert_element("body", attributes)
                        self.frameset_ok = false
                        self.insertion_mode = InsertionMode.InBody
                    "frameset":
                        self.insert_element("frameset", attributes)
                        self.insertion_mode = InsertionMode.InFrameset
                    "base":
                        # Push back onto head
                        self.logger.warn("AfterHead: <{name}> should be in head")
                        self.insert_element(name, attributes)
                        self.pop_current()
                    "link":
                        self.logger.warn("AfterHead: <{name}> should be in head")
                        self.insert_element(name, attributes)
                        self.pop_current()
                    "meta":
                        self.logger.warn("AfterHead: <{name}> should be in head")
                        self.insert_element(name, attributes)
                        self.pop_current()
                    "script":
                        self.logger.warn("AfterHead: <script> should be in head")
                        self.insert_element(name, attributes)
                        self.original_insertion_mode = InsertionMode.AfterHead
                        self.insertion_mode = InsertionMode.Text
                    "style":
                        self.logger.warn("AfterHead: <style> should be in head")
                        self.insert_element(name, attributes)
                        self.original_insertion_mode = InsertionMode.AfterHead
                        self.insertion_mode = InsertionMode.Text
                    "title":
                        self.logger.warn("AfterHead: <title> should be in head")
                        self.insert_element(name, attributes)
                        self.original_insertion_mode = InsertionMode.AfterHead
                        self.insertion_mode = InsertionMode.Text
                    "head":
                        self.logger.warn("AfterHead: unexpected <head>, ignoring")
                    _:
                        # Implied <body>
                        self.body_element = self.insert_element("body", [Attr]())
                        self.insertion_mode = InsertionMode.InBody
                        self.process_in_body(token)
            HtmlToken.EndTag(name):
                if (name == "body" or name == "html" or name == "br"):
                    self.body_element = self.insert_element("body", [Attr]())
                    self.insertion_mode = InsertionMode.InBody
                    self.process_in_body(token)
                else:
                    self.logger.warn("AfterHead: unexpected end tag </{name}>, ignoring")
            _:
                self.body_element = self.insert_element("body", [Attr]())
                self.insertion_mode = InsertionMode.InBody
                self.process_in_body(token)

    # ===================================================================
    # InBody mode — the primary mode for document content
    # ===================================================================

    me process_in_body(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                self.frameset_ok = false
                self.insert_text(data)

            HtmlToken.CommentToken(data):
                self.insert_comment(data)

            HtmlToken.Doctype(name, public_id, system_id, force_quirks):
                self.logger.warn("InBody: unexpected doctype, ignoring")

            HtmlToken.StartTag(name, attributes, self_closing):
                self.process_in_body_start_tag(name, attributes, self_closing)

            HtmlToken.EndTag(name):
                self.process_in_body_end_tag(name)

            HtmlToken.Eof:
                pass_do_nothing

    # --- InBody start tag dispatcher ---

    me process_in_body_start_tag(name: text, attributes: [Attr], self_closing: bool):
        match name:
            "html":
                # Merge attributes into existing html element
                self.logger.warn("InBody: unexpected <html>, merging attributes")

            "body":
                # Merge attributes into existing body element
                self.logger.warn("InBody: unexpected <body>, merging attributes")
                self.frameset_ok = false

            "head":
                self.logger.warn("InBody: unexpected <head>, ignoring")

            # --- Block-level elements ---
            "div":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "p":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "section":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "article":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "aside":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "nav":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "main":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "header":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "footer":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "address":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "blockquote":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "pre":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
                self.frameset_ok = false
            "figure":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "figcaption":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)

            # --- Headings ---
            "h1":
                self.handle_heading(name, attributes)
            "h2":
                self.handle_heading(name, attributes)
            "h3":
                self.handle_heading(name, attributes)
            "h4":
                self.handle_heading(name, attributes)
            "h5":
                self.handle_heading(name, attributes)
            "h6":
                self.handle_heading(name, attributes)

            # --- Lists ---
            "ul":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "ol":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "li":
                self.frameset_ok = false
                # Close any open <li> in scope
                if self.has_in_list_item_scope("li"):
                    self.generate_implied_end_tags("li")
                    self.pop_until("li")
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "dl":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "dt":
                self.frameset_ok = false
                if self.has_in_scope("dt"):
                    self.generate_implied_end_tags("dt")
                    self.pop_until("dt")
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "dd":
                self.frameset_ok = false
                if self.has_in_scope("dd"):
                    self.generate_implied_end_tags("dd")
                    self.pop_until("dd")
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)

            # --- Inline elements ---
            "span":
                self.insert_element(name, attributes)
            "a":
                # Adoption agency: if there is already an <a> in the active
                # formatting list, run the adoption agency to close it first
                # (WHATWG 13.2.6.4.7 — handles <a>...<a> misnesting).
                var existing_a = false
                var ai = self.active_formatting.len() - 1
                while ai >= 0:
                    val af_id = self.active_formatting.get(ai)
                    val af_tag = self.get_element_tag(af_id)
                    if af_tag == "a":
                        existing_a = true
                        ai = -1  # break
                    else:
                        ai = ai - 1
                if existing_a:
                    self.run_adoption_agency("a")
                val a_id = self.insert_element(name, attributes)
                self.active_formatting.push(a_id)
            "b":
                val eid = self.insert_element(name, attributes)
                self.active_formatting.push(eid)
            "strong":
                val eid = self.insert_element(name, attributes)
                self.active_formatting.push(eid)
            "i":
                val eid = self.insert_element(name, attributes)
                self.active_formatting.push(eid)
            "em":
                val eid = self.insert_element(name, attributes)
                self.active_formatting.push(eid)
            "u":
                val eid = self.insert_element(name, attributes)
                self.active_formatting.push(eid)
            "s":
                val eid = self.insert_element(name, attributes)
                self.active_formatting.push(eid)
            "small":
                val eid = self.insert_element(name, attributes)
                self.active_formatting.push(eid)
            "code":
                val eid = self.insert_element(name, attributes)
                self.active_formatting.push(eid)
            "abbr":
                self.insert_element(name, attributes)
            "cite":
                self.insert_element(name, attributes)
            "mark":
                self.insert_element(name, attributes)
            "sub":
                self.insert_element(name, attributes)
            "sup":
                self.insert_element(name, attributes)

            # --- Void elements (self-closing, no end tag) ---
            "br":
                self.insert_element(name, attributes)
                self.pop_current()
                self.frameset_ok = false
            "hr":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
                self.pop_current()
                self.frameset_ok = false
            "img":
                self.insert_element(name, attributes)
                self.pop_current()
                self.frameset_ok = false
            "input":
                self.insert_element(name, attributes)
                self.pop_current()
                self.frameset_ok = false
            "embed":
                self.insert_element(name, attributes)
                self.pop_current()
                self.frameset_ok = false
            "wbr":
                self.insert_element(name, attributes)
                self.pop_current()
                self.frameset_ok = false
            "area":
                self.insert_element(name, attributes)
                self.pop_current()
            "source":
                self.insert_element(name, attributes)
                self.pop_current()
            "track":
                self.insert_element(name, attributes)
                self.pop_current()
            "col":
                self.insert_element(name, attributes)
                self.pop_current()
            "param":
                self.insert_element(name, attributes)
                self.pop_current()

            # --- Table elements ---
            "table":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
                self.frameset_ok = false
                self.insertion_mode = InsertionMode.InTable
            "tr":
                self.insert_element(name, attributes)
            "td":
                self.insert_element(name, attributes)
            "th":
                self.insert_element(name, attributes)
            "caption":
                self.insert_element(name, attributes)
            "thead":
                self.insert_element(name, attributes)
            "tbody":
                self.insert_element(name, attributes)
            "tfoot":
                self.insert_element(name, attributes)
            "colgroup":
                self.insert_element(name, attributes)

            # --- Form elements ---
            "form":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "button":
                if self.has_in_scope("button"):
                    self.generate_implied_end_tags("")
                    self.pop_until("button")
                self.insert_element(name, attributes)
                self.frameset_ok = false
            "select":
                self.insert_element(name, attributes)
                self.frameset_ok = false
            "textarea":
                self.insert_element(name, attributes)
                self.frameset_ok = false
            "label":
                self.insert_element(name, attributes)
            "fieldset":
                self.close_p_if_in_button_scope()
                self.insert_element(name, attributes)
            "legend":
                self.insert_element(name, attributes)
            "optgroup":
                self.insert_element(name, attributes)
            "option":
                self.insert_element(name, attributes)

            # --- Meta/Link elements in body ---
            "link":
                self.insert_element(name, attributes)
                self.pop_current()
            "meta":
                self.insert_element(name, attributes)
                self.pop_current()
            "base":
                self.insert_element(name, attributes)
                self.pop_current()

            # --- Raw text elements ---
            "script":
                self.insert_element(name, attributes)
                self.original_insertion_mode = self.insertion_mode
                self.insertion_mode = InsertionMode.Text
            "style":
                self.insert_element(name, attributes)
                self.original_insertion_mode = self.insertion_mode
                self.insertion_mode = InsertionMode.Text
            "title":
                self.insert_element(name, attributes)
                self.original_insertion_mode = self.insertion_mode
                self.insertion_mode = InsertionMode.Text

            # --- Default: insert as generic element ---
            _:
                self.insert_element(name, attributes)

    # --- InBody end tag dispatcher ---

    me process_in_body_end_tag(name: text):
        match name:
            "body":
                if self.has_in_scope("body"):
                    self.insertion_mode = InsertionMode.AfterBody
                else:
                    self.logger.warn("InBody: </body> without <body> in scope")
            "html":
                if self.has_in_scope("body"):
                    self.insertion_mode = InsertionMode.AfterBody
                    self.process_after_body(HtmlToken.EndTag(name: "html"))
                else:
                    self.logger.warn("InBody: </html> without <body> in scope")

            # --- Block end tags with scope checking ---
            "div":
                self.close_block_element(name)
            "p":
                if self.has_in_button_scope("p"):
                    self.generate_implied_end_tags("p")
                    self.pop_until("p")
                else:
                    # Insert an empty <p> per spec
                    self.insert_element("p", [Attr]())
                    self.pop_current()
            "section":
                self.close_block_element(name)
            "article":
                self.close_block_element(name)
            "aside":
                self.close_block_element(name)
            "nav":
                self.close_block_element(name)
            "main":
                self.close_block_element(name)
            "header":
                self.close_block_element(name)
            "footer":
                self.close_block_element(name)
            "address":
                self.close_block_element(name)
            "blockquote":
                self.close_block_element(name)
            "pre":
                self.close_block_element(name)
            "figure":
                self.close_block_element(name)
            "figcaption":
                self.close_block_element(name)

            # --- Heading end tags ---
            "h1":
                self.close_heading()
            "h2":
                self.close_heading()
            "h3":
                self.close_heading()
            "h4":
                self.close_heading()
            "h5":
                self.close_heading()
            "h6":
                self.close_heading()

            # --- List end tags ---
            "ul":
                self.close_block_element(name)
            "ol":
                self.close_block_element(name)
            "li":
                if self.has_in_list_item_scope("li"):
                    self.generate_implied_end_tags("li")
                    self.pop_until("li")
            "dl":
                self.close_block_element(name)
            "dt":
                if self.has_in_scope("dt"):
                    self.generate_implied_end_tags("dt")
                    self.pop_until("dt")
            "dd":
                if self.has_in_scope("dd"):
                    self.generate_implied_end_tags("dd")
                    self.pop_until("dd")

            # --- Table end tags ---
            "table":
                if self.has_in_table_scope("table"):
                    self.pop_until("table")
            "tr":
                if self.has_in_table_scope("tr"):
                    self.pop_until("tr")
            "td":
                if self.has_in_table_scope("td"):
                    self.pop_until("td")
            "th":
                if self.has_in_table_scope("th"):
                    self.pop_until("th")
            "caption":
                if self.has_in_table_scope("caption"):
                    self.pop_until("caption")
            "thead":
                if self.has_in_table_scope("thead"):
                    self.pop_until("thead")
            "tbody":
                if self.has_in_table_scope("tbody"):
                    self.pop_until("tbody")
            "tfoot":
                if self.has_in_table_scope("tfoot"):
                    self.pop_until("tfoot")
            "colgroup":
                if self.has_in_table_scope("colgroup"):
                    self.pop_until("colgroup")

            # --- Form end tags ---
            "form":
                if self.has_in_scope("form"):
                    self.generate_implied_end_tags("")
                    self.pop_until("form")
            "button":
                if self.has_in_scope("button"):
                    self.generate_implied_end_tags("")
                    self.pop_until("button")
            "select":
                if self.has_in_scope("select"):
                    self.pop_until("select")
            "textarea":
                if self.has_in_scope("textarea"):
                    self.pop_until("textarea")
            "fieldset":
                self.close_block_element(name)

            # --- Inline end tags (simplified — full spec uses adoption agency) ---
            "a":
                self.close_inline_element(name)
            "b":
                self.close_inline_element(name)
            "strong":
                self.close_inline_element(name)
            "i":
                self.close_inline_element(name)
            "em":
                self.close_inline_element(name)
            "u":
                self.close_inline_element(name)
            "s":
                self.close_inline_element(name)
            "small":
                self.close_inline_element(name)
            "code":
                self.close_inline_element(name)
            "span":
                self.close_inline_element(name)
            "abbr":
                self.close_inline_element(name)
            "cite":
                self.close_inline_element(name)
            "mark":
                self.close_inline_element(name)
            "sub":
                self.close_inline_element(name)
            "sup":
                self.close_inline_element(name)
            "label":
                self.close_inline_element(name)
            "legend":
                self.close_inline_element(name)
            "optgroup":
                self.close_inline_element(name)
            "option":
                self.close_inline_element(name)

            # --- Void elements should not have end tags ---
            "br":
                self.logger.warn("InBody: unexpected </br>, treating as <br>")
                self.insert_element("br", [Attr]())
                self.pop_current()

            # --- Default: walk up the stack (any other end tag) ---
            _:
                self.close_inline_element(name)

    # ===================================================================
    # Text mode — raw text content (script, style, title, etc.)
    # ===================================================================

    me process_text(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                self.insert_text(data)
            HtmlToken.EndTag(name):
                self.pop_current()
                self.insertion_mode = self.original_insertion_mode
            HtmlToken.Eof:
                self.logger.warn("Text mode: unexpected EOF")
                self.pop_current()
                self.insertion_mode = self.original_insertion_mode
            _:
                pass_do_nothing

    # ===================================================================
    # AfterBody mode — after </body>
    # ===================================================================

    me process_after_body(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                if self.is_whitespace(data):
                    # Process as InBody for whitespace
                    self.insert_text(data)
                else:
                    self.logger.warn("AfterBody: unexpected character, switching to InBody")
                    self.insertion_mode = InsertionMode.InBody
                    self.process_in_body(token)
            HtmlToken.CommentToken(data):
                # Append comment to html element
                val comment_id = self.create_node(NodeKind.Comment, data)
                if self.open_elements.len() > 0:
                    val html_node = self.open_elements.get(0)
                    self.append_child(html_node, comment_id)
                else:
                    self.append_child(self.document_node, comment_id)
            HtmlToken.StartTag(name, attributes, self_closing):
                self.logger.warn("AfterBody: unexpected start tag <{name}>, switching to InBody")
                self.insertion_mode = InsertionMode.InBody
                self.process_in_body(token)
            HtmlToken.EndTag(name):
                if name == "html":
                    self.logger.debug("AfterBody: </html>, parsing complete")
                    # Done — stay in AfterBody
                else:
                    self.logger.warn("AfterBody: unexpected end tag </{name}>, switching to InBody")
                    self.insertion_mode = InsertionMode.InBody
                    self.process_in_body(token)
            _:
                self.insertion_mode = InsertionMode.InBody
                self.process_in_body(token)

    # ===================================================================
    # InHeadNoscript mode — inside <noscript> in <head> with scripting off
    # ===================================================================

    me process_in_head_noscript(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                if self.is_whitespace(data):
                    self.insert_text(data)
                else:
                    # Act as if </noscript> was seen
                    self.logger.warn("InHeadNoscript: non-whitespace character, closing noscript")
                    self.pop_current()
                    self.insertion_mode = InsertionMode.InHead
                    self.process_in_head(token)
            HtmlToken.CommentToken(data):
                self.insert_comment(data)
            HtmlToken.StartTag(name, attributes, self_closing):
                match name:
                    "html":
                        self.process_in_body(token)
                    "link":
                        # Process as InHead
                        self.insert_element(name, attributes)
                        self.pop_current()
                    "meta":
                        self.insert_element(name, attributes)
                        self.pop_current()
                    "style":
                        # Process as InHead — raw text element
                        self.insert_element(name, attributes)
                        self.original_insertion_mode = self.insertion_mode
                        self.insertion_mode = InsertionMode.Text
                    "basefont":
                        self.insert_element(name, attributes)
                        self.pop_current()
                    "head":
                        self.logger.warn("InHeadNoscript: unexpected <head>, ignoring")
                    "noscript":
                        self.logger.warn("InHeadNoscript: unexpected <noscript>, ignoring")
                    _:
                        # Act as if </noscript> was seen, reprocess in InHead
                        self.logger.warn("InHeadNoscript: unexpected <{name}>, closing noscript")
                        self.pop_current()
                        self.insertion_mode = InsertionMode.InHead
                        self.process_in_head(token)
            HtmlToken.EndTag(name):
                match name:
                    "noscript":
                        self.pop_current()
                        self.insertion_mode = InsertionMode.InHead
                    "br":
                        # Act as if </noscript> was seen, reprocess
                        self.pop_current()
                        self.insertion_mode = InsertionMode.InHead
                        self.process_in_head(token)
                    _:
                        self.logger.warn("InHeadNoscript: unexpected </{name}>, ignoring")
            _:
                # Act as if </noscript> was seen
                self.pop_current()
                self.insertion_mode = InsertionMode.InHead
                self.process_in_head(token)

    # ===================================================================
    # InTable mode — handle table structure elements, foster parenting
    # ===================================================================

    me process_in_table(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                # Table character tokens: switch to InTableText
                val cn = self.current_node()
                val cn_tag = self.get_element_tag(cn)
                if (cn_tag == "table" or cn_tag == "tbody" or cn_tag == "tfoot" or cn_tag == "thead" or cn_tag == "tr"):
                    self.pending_table_text = ""
                    self.pending_table_text_mode = self.insertion_mode
                    self.insertion_mode = InsertionMode.InTableText
                    self.process_in_table_text(token)
                else:
                    # Foster parent the character
                    self.foster_parenting = true
                    self.process_in_body(token)
                    self.foster_parenting = false
            HtmlToken.CommentToken(data):
                self.insert_comment(data)
            HtmlToken.Doctype(name, public_id, system_id, force_quirks):
                self.logger.warn("InTable: unexpected doctype, ignoring")
            HtmlToken.StartTag(name, attributes, self_closing):
                match name:
                    "caption":
                        self.clear_stack_to_table_context()
                        self.active_formatting.push(-1)  # marker
                        self.insert_element("caption", attributes)
                        self.insertion_mode = InsertionMode.InCaption
                    "colgroup":
                        self.clear_stack_to_table_context()
                        self.insert_element("colgroup", attributes)
                        self.insertion_mode = InsertionMode.InColumnGroup
                    "col":
                        # Implied <colgroup>
                        self.clear_stack_to_table_context()
                        self.insert_element("colgroup", [Attr]())
                        self.insertion_mode = InsertionMode.InColumnGroup
                        self.process_in_column_group(token)
                    "tbody":
                        self.clear_stack_to_table_context()
                        self.insert_element("tbody", attributes)
                        self.insertion_mode = InsertionMode.InTableBody
                    "thead":
                        self.clear_stack_to_table_context()
                        self.insert_element("thead", attributes)
                        self.insertion_mode = InsertionMode.InTableBody
                    "tfoot":
                        self.clear_stack_to_table_context()
                        self.insert_element("tfoot", attributes)
                        self.insertion_mode = InsertionMode.InTableBody
                    "tr":
                        # Implied <tbody>
                        self.clear_stack_to_table_context()
                        self.insert_element("tbody", [Attr]())
                        self.insertion_mode = InsertionMode.InTableBody
                        self.process_in_table_body(token)
                    "td":
                        # Implied <tbody> then <tr>
                        self.clear_stack_to_table_context()
                        self.insert_element("tbody", [Attr]())
                        self.insertion_mode = InsertionMode.InTableBody
                        self.process_in_table_body(token)
                    "th":
                        # Implied <tbody> then <tr>
                        self.clear_stack_to_table_context()
                        self.insert_element("tbody", [Attr]())
                        self.insertion_mode = InsertionMode.InTableBody
                        self.process_in_table_body(token)
                    "table":
                        # Close current table, reprocess
                        self.logger.warn("InTable: nested <table>, closing current")
                        if self.has_in_table_scope("table"):
                            self.pop_until("table")
                            self.reset_insertion_mode()
                            self.process_token(token)
                    "style":
                        # Process as InHead
                        self.process_in_head(token)
                    "script":
                        self.process_in_head(token)
                    "template":
                        self.process_in_head(token)
                    "input":
                        # Hidden inputs don't foster parent
                        var is_hidden = false
                        var ai = 0
                        while ai < attributes.len():
                            val attr = attributes.get(ai)
                            if (attr.name == "type" and attr.value == "hidden"):
                                is_hidden = true
                            ai = ai + 1
                        if is_hidden:
                            self.logger.warn("InTable: hidden <input>, inserting directly")
                            self.insert_element("input", attributes)
                            self.pop_current()
                        else:
                            # Foster parent
                            self.foster_parenting = true
                            self.process_in_body(token)
                            self.foster_parenting = false
                    "form":
                        self.logger.warn("InTable: <form>, inserting directly")
                        self.insert_element("form", attributes)
                        self.pop_current()
                    _:
                        # Foster parent: process as InBody with foster parenting enabled
                        self.logger.warn("InTable: unexpected <{name}>, foster parenting")
                        self.foster_parenting = true
                        self.process_in_body(token)
                        self.foster_parenting = false
            HtmlToken.EndTag(name):
                match name:
                    "table":
                        if self.has_in_table_scope("table"):
                            self.pop_until("table")
                            self.reset_insertion_mode()
                        else:
                            self.logger.warn("InTable: </table> without <table> in scope")
                    "body":
                        self.logger.warn("InTable: unexpected </body>, ignoring")
                    "caption":
                        self.logger.warn("InTable: unexpected </caption>, ignoring")
                    "col":
                        self.logger.warn("InTable: unexpected </col>, ignoring")
                    "colgroup":
                        self.logger.warn("InTable: unexpected </colgroup>, ignoring")
                    "html":
                        self.logger.warn("InTable: unexpected </html>, ignoring")
                    "tbody":
                        self.logger.warn("InTable: unexpected </tbody>, ignoring")
                    "td":
                        self.logger.warn("InTable: unexpected </td>, ignoring")
                    "tfoot":
                        self.logger.warn("InTable: unexpected </tfoot>, ignoring")
                    "th":
                        self.logger.warn("InTable: unexpected </th>, ignoring")
                    "thead":
                        self.logger.warn("InTable: unexpected </thead>, ignoring")
                    "tr":
                        self.logger.warn("InTable: unexpected </tr>, ignoring")
                    "template":
                        self.process_in_head(token)
                    _:
                        # Foster parent
                        self.logger.warn("InTable: unexpected </{name}>, foster parenting")
                        self.foster_parenting = true
                        self.process_in_body(token)
                        self.foster_parenting = false
            HtmlToken.Eof:
                self.process_in_body(token)

    # ===================================================================
    # InTableText mode — accumulate character tokens for table context
    # ===================================================================

    me process_in_table_text(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                # Accumulate characters into pending buffer
                self.pending_table_text = self.pending_table_text + data
            _:
                # Non-character token: flush pending text and reprocess
                if self.pending_table_text.len() > 0:
                    if self.is_whitespace(self.pending_table_text):
                        # All whitespace — insert as text normally
                        self.insert_text(self.pending_table_text)
                    else:
                        # Has non-whitespace — foster parent each character
                        self.logger.warn("InTableText: non-whitespace text, foster parenting")
                        self.foster_parenting = true
                        self.insert_text(self.pending_table_text)
                        self.foster_parenting = false
                self.pending_table_text = ""
                self.insertion_mode = self.pending_table_text_mode
                self.process_token(token)

    # ===================================================================
    # InCaption mode — inside <caption>
    # ===================================================================

    me process_in_caption(token: HtmlToken):
        match token:
            HtmlToken.StartTag(name, attributes, self_closing):
                match name:
                    "caption":
                        # Close caption, reprocess
                        self.close_caption_and_reprocess(token)
                    "col":
                        self.close_caption_and_reprocess(token)
                    "colgroup":
                        self.close_caption_and_reprocess(token)
                    "tbody":
                        self.close_caption_and_reprocess(token)
                    "td":
                        self.close_caption_and_reprocess(token)
                    "tfoot":
                        self.close_caption_and_reprocess(token)
                    "th":
                        self.close_caption_and_reprocess(token)
                    "thead":
                        self.close_caption_and_reprocess(token)
                    "tr":
                        self.close_caption_and_reprocess(token)
                    "table":
                        self.close_caption_and_reprocess(token)
                    _:
                        # Process as InBody
                        self.process_in_body(token)
            HtmlToken.EndTag(name):
                match name:
                    "caption":
                        if self.has_in_table_scope("caption"):
                            self.generate_implied_end_tags("")
                            self.pop_until("caption")
                            self.clear_formatting_to_marker()
                            self.insertion_mode = InsertionMode.InTable
                        else:
                            self.logger.warn("InCaption: </caption> without <caption> in scope")
                    "table":
                        # Close caption first, then reprocess
                        if self.has_in_table_scope("caption"):
                            self.generate_implied_end_tags("")
                            self.pop_until("caption")
                            self.clear_formatting_to_marker()
                            self.insertion_mode = InsertionMode.InTable
                            self.process_in_table(token)
                        else:
                            self.logger.warn("InCaption: </table> without <caption> in scope")
                    "body":
                        self.logger.warn("InCaption: unexpected </body>, ignoring")
                    "col":
                        self.logger.warn("InCaption: unexpected </col>, ignoring")
                    "colgroup":
                        self.logger.warn("InCaption: unexpected </colgroup>, ignoring")
                    "html":
                        self.logger.warn("InCaption: unexpected </html>, ignoring")
                    "tbody":
                        self.logger.warn("InCaption: unexpected </tbody>, ignoring")
                    "td":
                        self.logger.warn("InCaption: unexpected </td>, ignoring")
                    "tfoot":
                        self.logger.warn("InCaption: unexpected </tfoot>, ignoring")
                    "th":
                        self.logger.warn("InCaption: unexpected </th>, ignoring")
                    "thead":
                        self.logger.warn("InCaption: unexpected </thead>, ignoring")
                    "tr":
                        self.logger.warn("InCaption: unexpected </tr>, ignoring")
                    _:
                        # Process as InBody
                        self.process_in_body(token)
            _:
                # Characters, comments, etc. process as InBody
                self.process_in_body(token)

    me close_caption_and_reprocess(token: HtmlToken):
        if self.has_in_table_scope("caption"):
            self.generate_implied_end_tags("")
            self.pop_until("caption")
            self.clear_formatting_to_marker()
            self.insertion_mode = InsertionMode.InTable
            self.process_in_table(token)
        else:
            self.logger.warn("InCaption: cannot close caption, not in scope")

    # ===================================================================
    # InColumnGroup mode — inside <colgroup>
    # ===================================================================

    me process_in_column_group(token: HtmlToken):
        match token:
            HtmlToken.Character(data):
                if self.is_whitespace(data):
                    self.insert_text(data)
                else:
                    # Act as if </colgroup> was seen
                    val cn = self.current_node()
                    val cn_tag = self.get_element_tag(cn)
                    if cn_tag == "colgroup":
                        self.pop_current()
                        self.insertion_mode = InsertionMode.InTable
                        self.process_in_table(token)
                    else:
                        self.logger.warn("InColumnGroup: unexpected character, ignoring")
            HtmlToken.CommentToken(data):
                self.insert_comment(data)
