#![allow(unnamed_duplicate_typed_args)]

use std.spec
use examples.browser.feature.script.builtins.number.{math_random}

describe "Number and Math builtins":
    describe "Math.random":
        it "returns values in the JavaScript random range":
            val first = math_random()
            val second = math_random()

            expect(first).to_be_greater_than(-0.0000001)
            expect(first).to_be_less_than(1.0)
            expect(second).to_be_greater_than(-0.0000001)
            expect(second).to_be_less_than(1.0)

        it "advances state instead of returning a fixed placeholder":
            val first = math_random()
            val second = math_random()
            val third = math_random()

            expect("{first},{second},{third}" == "0.5,0.5,0.5").to_equal(false)
            expect("{first},{second},{third}" == "{first},{first},{first}").to_equal(false)
