use std.spec

describe "H3Client":
    it "should identify H3 HEADERS frame type":
        # H3 frame type 1 = HEADERS
        val frame_headers = 1
        expect(frame_headers).to_equal(1)

    it "should identify H3 DATA frame type":
        # H3 frame type 0 = DATA
        val frame_data = 0
        expect(frame_data).to_equal(0)

    it "should identify H3 SETTINGS frame type":
        # H3 frame type 4 = SETTINGS
        val frame_settings = 4
        expect(frame_settings).to_equal(4)

    it "should set QPACK max table capacity in settings":
        # QPACK_MAX_TABLE_CAPACITY = 4096 bytes default
        val qpack_max_cap = 4096
        expect(qpack_max_cap).to_equal(4096)
        expect(qpack_max_cap).to_be_greater_than(0)

    it "should use QUIC stream 0 for control stream":
        # H3 unidirectional control stream opens on QUIC stream ID 2 (server) or 3
        # Client-initiated bidirectional request streams start at 0
        val req_stream_0 = 0
        val req_stream_1 = 4
        val diff = req_stream_1 - req_stream_0
        expect(diff).to_equal(4)

    it "should identify QPACK encoder stream type":
        # QPACK encoder stream type byte = 0x02
        val enc_stream_type = 2
        expect(enc_stream_type).to_equal(2)

    it "should identify QPACK decoder stream type":
        # QPACK decoder stream type byte = 0x03
        val dec_stream_type = 3
        expect(dec_stream_type).to_equal(3)
