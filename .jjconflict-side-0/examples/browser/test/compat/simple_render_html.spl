extern fn rt_cli_get_args() -> [text]
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_write_text(path: text, content: text) -> bool
use std.gc_async_mut.gpu.browser_engine.browser_renderer.{BrowserRenderer}
use examples.browser.test.compat.image_export.{export_ppm_text}

fn main() -> i64:
    val argv = rt_cli_get_args()
    if argv.len() < 6:
        return 1

    val input_path = argv[2]
    val output_path = argv[3]
    val width = argv[4].parse_i32() ?? 800
    val height = argv[5].parse_i32() ?? 600

    val html = rt_file_read_text(input_path) ?? ""
    if html.len() == 0:
        return 2

    val renderer = BrowserRenderer.create(width, height)
    val rendered = renderer.render_html_to_pixels(html)
    if rendered.pixel_data.len() == 0:
        return 3

    val ppm = export_ppm_text(output_path, rendered.pixel_data, rendered.width, rendered.height)
    if not rt_file_write_text(output_path, ppm):
        return 4
    0
