"""
# Html Tree Builder

Tests for html tree builder functionality.
"""
#![allow(unnamed_duplicate_typed_args)]
# HTML Tree Builder Tests
#
# Category: Browser Platform Parser
# Status: Active
#
# Validates the HTML tree builder: construction of a DOM tree from tokenized
# HTML input. Tests parse complete HTML strings and verify the resulting tree
# structure (parent-child relationships, element tags, text content).
#
# Run with: bin/simple test examples/browser/test/parser/html_tree_builder_spec.spl

use std.spec
use sbp.feature.parser.html_tree_builder.{parse_html, HtmlDocument}
use sbp.entity.dom.node_types.{DomNode, NodeKind, Element, TextNode, Comment}

# ============================================================================
# Helpers
# ============================================================================

fn find_element_by_tag(doc: HtmlDocument, tag: text) -> DomNode?:
    var i = 0
    while i < doc.nodes.len():
        val node = doc.nodes.get(i)
        if val elem = doc.get_element(node.id):
            if elem.tag_name == tag:
                return Some(node)
        i = i + 1
    nil

fn count_children(doc: HtmlDocument, node_id: i64) -> i64:
    val node = doc.get_node(node_id)
    match node:
        Some(n): n.children.len()
        nil: 0

fn get_child_tag(doc: HtmlDocument, parent_id: i64, index: i64) -> text:
    val parent = doc.get_node(parent_id)
    match parent:
        Some(p):
            if index < p.children.len():
                val child_id = p.children.get(index)
                val elem = doc.get_element(child_id)
                match elem:
                    Some(e): e.tag_name
                    nil: ""
            else:
                ""
        nil: ""

fn get_text_content(doc: HtmlDocument, node_id: i64) -> text:
    val node = doc.get_node(node_id)
    match node:
        Some(n):
            if n.kind == NodeKind.Text:
                n.data
            else:
                ""
        nil: ""

# ============================================================================
# Tree construction basics
# ============================================================================

describe "HtmlTreeBuilder":
    """
    ## Htmltreebuilder Tests

    Validates HtmlTreeBuilder functionality.
    """

    context "simple documents":
        it "builds document from simple HTML":
            val doc = parse_html("<html><head></head><body></body></html>")
            val root = doc.root_node()
            expect(root.?).to_equal(true)

        it "creates html, head, body elements":
            val doc = parse_html("<html><head><title>Test</title></head><body><p>Hello</p></body></html>")
            val html_node = find_element_by_tag(doc, "html")
            expect(html_node.?).to_equal(true)
            val head_node = find_element_by_tag(doc, "head")
            expect(head_node.?).to_equal(true)
            val body_node = find_element_by_tag(doc, "body")
            expect(body_node.?).to_equal(true)

    context "text content":
        it "inserts text content":
            val doc = parse_html("<p>Hello, world!</p>")
            val p_node = find_element_by_tag(doc, "p")
            if val p = p_node:
                val child_count = count_children(doc, p.id)
                expect(child_count).to_be_greater_than(0)
                # First child should be a text node
                val text_id = p.children.get(0)
                val text_content = get_text_content(doc, text_id)
                expect(text_content).to_equal("Hello, world!")
            else:
                expect("p element should exist").to_equal("")

    context "nesting":
        it "builds nested elements":
            val doc = parse_html("<div><span><em>deep</em></span></div>")
            val div_node = find_element_by_tag(doc, "div")
            expect(div_node.?).to_equal(true)
            val span_node = find_element_by_tag(doc, "span")
            expect(span_node.?).to_equal(true)
            val em_node = find_element_by_tag(doc, "em")
            expect(em_node.?).to_equal(true)
            # em should be a descendant of span
            if val em = em_node:
                if val span = span_node:
                    val em_parent = em.parent_id
                    expect(em_parent).to_equal(span.id)
                else:
                    expect("span should exist").to_equal("")
            else:
                expect("em should exist").to_equal("")

    context "auto-closing":
        it "auto-closes p element for block elements":
            # When a <div> is encountered inside a <p>, the <p> should be auto-closed
            val doc = parse_html("<p>text<div>block</div>")
            val p_node = find_element_by_tag(doc, "p")
            val div_node = find_element_by_tag(doc, "div")
            expect(p_node.?).to_equal(true)
            expect(div_node.?).to_equal(true)
            # p and div should be siblings, not nested
            if val p = p_node:
                if val d = div_node:
                    expect(d.parent_id).to_equal(p.parent_id)
                else:
                    expect("div should exist").to_equal("")
            else:
                expect("p should exist").to_equal("")

    context "implicit elements":
        it "handles implicit head and body":
            # Even without explicit <html><head><body>, the tree builder
            # should create them
            val doc = parse_html("<p>Just a paragraph</p>")
            val html_node = find_element_by_tag(doc, "html")
            expect(html_node.?).to_equal(true)
            val body_node = find_element_by_tag(doc, "body")
            expect(body_node.?).to_equal(true)

    context "comment nodes":
        it "inserts comment nodes":
            val doc = parse_html("<div><!-- hello --></div>")
            val div_node = find_element_by_tag(doc, "div")
            if val div = div_node:
                val child_count = count_children(doc, div.id)
                expect(child_count).to_be_greater_than(0)
                val child_id = div.children.get(0)
                val child = doc.get_node(child_id)
                if val c = child:
                    val is_comment = c.kind == NodeKind.Comment
                    expect(is_comment).to_equal(true)
                    expect(c.data).to_equal(" hello ")
                else:
                    expect("comment child should exist").to_equal("")
            else:
                expect("div should exist").to_equal("")

    context "void elements":
        it "handles self-closing elements (br, hr, img)":
            val doc = parse_html("<p>line1<br>line2<hr><img src=\"x.png\">end</p>")
            val br_node = find_element_by_tag(doc, "br")
            expect(br_node.?).to_equal(true)
            val hr_node = find_element_by_tag(doc, "hr")
            expect(hr_node.?).to_equal(true)
            val img_node = find_element_by_tag(doc, "img")
            expect(img_node.?).to_equal(true)

    context "list structure":
        it "builds list structure (ul > li)":
            val doc = parse_html("<ul><li>one</li><li>two</li><li>three</li></ul>")
            val ul_node = find_element_by_tag(doc, "ul")
            if val ul = ul_node:
                val li_count = count_children(doc, ul.id)
                expect(li_count).to_equal(3)
                val first_tag = get_child_tag(doc, ul.id, 0)
                expect(first_tag).to_equal("li")
            else:
                expect("ul should exist").to_equal("")

    context "table structure":
        it "builds table structure":
            val doc = parse_html("<table><tr><td>cell1</td><td>cell2</td></tr></table>")
            val table_node = find_element_by_tag(doc, "table")
            expect(table_node.?).to_equal(true)
            val tr_node = find_element_by_tag(doc, "tr")
            expect(tr_node.?).to_equal(true)
            val td_node = find_element_by_tag(doc, "td")
            expect(td_node.?).to_equal(true)

    context "heading elements":
        it "handles heading elements":
            val doc = parse_html("<h1>Title</h1><h2>Subtitle</h2>")
            val h1_node = find_element_by_tag(doc, "h1")
            expect(h1_node.?).to_equal(true)
            val h2_node = find_element_by_tag(doc, "h2")
            expect(h2_node.?).to_equal(true)

    context "form elements":
        it "builds form with inputs":
            val doc = parse_html("<form action=\"/submit\"><input type=\"text\" name=\"user\"><input type=\"submit\"></form>")
            val form_node = find_element_by_tag(doc, "form")
            expect(form_node.?).to_equal(true)
            val input_node = find_element_by_tag(doc, "input")
            expect(input_node.?).to_equal(true)
            if val form = form_node:
                val child_count = count_children(doc, form.id)
                expect(child_count).to_equal(2)
            else:
                expect("form should exist").to_equal("")
