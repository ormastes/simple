#![allow(REQC001)]
#![allow(REQC004)]
#![allow(unnamed_duplicate_typed_args)]
# SDN configuration loader for the Simple Browser Platform.
# Reads config.sdn and produces a typed BrowserConfig.

use std.io_runtime.{file_read}
use examples.browser.shared.error.{BrowserError, config_error}

class BrowserConfig:
    name: text
    version: text
    homepage: text
    user_agent: text
    tab_limit: i64
    process_model: text
    default_encoding: text
    max_history_entries: i64
    max_connections_per_host: i64
    max_total_connections: i64
    dns_cache_ttl: i64
    http_cache_size_mb: i64
    cookie_policy: text
    connect_timeout_ms: i64
    read_timeout_ms: i64
    gpu_compositing: bool
    hardware_acceleration: bool
    max_texture_size: i64
    tile_size: i64
    target_fps: i64
    csp_default: text
    mixed_content: text

    static fn default() -> BrowserConfig:
        BrowserConfig(
            name: "simple-browser-platform",
            version: "0.1.0",
            homepage: "about:blank",
            user_agent: "SimpleBrowser/0.1 (Simple Language)",
            tab_limit: 64,
            process_model: "site-per-process",
            default_encoding: "utf-8",
            max_history_entries: 1000,
            max_connections_per_host: 6,
            max_total_connections: 64,
            dns_cache_ttl: 300,
            http_cache_size_mb: 256,
            cookie_policy: "same-site-lax",
            connect_timeout_ms: 30000,
            read_timeout_ms: 60000,
            gpu_compositing: true,
            hardware_acceleration: true,
            max_texture_size: 4096,
            tile_size: 256,
            target_fps: 60,
            csp_default: "default-src 'self'",
            mixed_content: "block"
        )

fn load_config(path: text) -> Result<BrowserConfig, BrowserError>:
    val content = file_read(path)
    if content.len() == 0:
        return Err(config_error("Failed to read browser config '{path}'"))

    var config = BrowserConfig.default()
    var section = ""

    for raw_line in content.split("\n"):
        val trimmed = raw_line.trim()
        if trimmed == "" or trimmed.starts_with("#"):
            pass_do_nothing
        else if trimmed.ends_with(":") and not trimmed.contains(": "):
            section = trimmed.substring(0, trimmed.len() - 1)
        else:
            val parts = trimmed.split(":")
            if parts.len() < 2:
                pass_do_nothing
            else:
                val key = parts.get(0).trim()
                val value = _normalize_value(trimmed.substring(key.len() + 1))
                _assign_value(config, section, key, value)

    Ok(config)

fn _assign_value(config: BrowserConfig, section: text, key: text, value: text):
    if section == "project":
        if key == "name" and value.len() > 0:
            config.name = value
        else if key == "version" and value.len() > 0:
            config.version = value
    else if section == "browser":
        if key == "homepage" and value.len() > 0:
            config.homepage = value
        else if key == "user_agent" and value.len() > 0:
            config.user_agent = value
        else if key == "tab_limit":
            config.tab_limit = _parse_int(value, config.tab_limit)
        else if key == "process_model" and value.len() > 0:
            config.process_model = value
        else if key == "default_encoding" and value.len() > 0:
            config.default_encoding = value
        else if key == "max_history_entries":
            config.max_history_entries = _parse_int(value, config.max_history_entries)
    else if section == "network":
        if key == "max_connections_per_host":
            config.max_connections_per_host = _parse_int(value, config.max_connections_per_host)
        else if key == "max_total_connections":
            config.max_total_connections = _parse_int(value, config.max_total_connections)
        else if key == "dns_cache_ttl":
            config.dns_cache_ttl = _parse_int(value, config.dns_cache_ttl)
        else if key == "http_cache_size_mb":
            config.http_cache_size_mb = _parse_int(value, config.http_cache_size_mb)
        else if key == "cookie_policy" and value.len() > 0:
            config.cookie_policy = value
        else if key == "connect_timeout_ms":
            config.connect_timeout_ms = _parse_int(value, config.connect_timeout_ms)
        else if key == "read_timeout_ms":
            config.read_timeout_ms = _parse_int(value, config.read_timeout_ms)
    else if section == "rendering":
        if key == "gpu_compositing":
            config.gpu_compositing = _parse_bool(value, config.gpu_compositing)
        else if key == "hardware_acceleration":
            config.hardware_acceleration = _parse_bool(value, config.hardware_acceleration)
        else if key == "max_texture_size":
            config.max_texture_size = _parse_int(value, config.max_texture_size)
        else if key == "tile_size":
            config.tile_size = _parse_int(value, config.tile_size)
        else if key == "target_fps":
            config.target_fps = _parse_int(value, config.target_fps)
    else if section == "security":
        if key == "csp_default" and value.len() > 0:
            config.csp_default = value
        else if key == "mixed_content" and value.len() > 0:
            config.mixed_content = value

fn _normalize_value(raw: text) -> text:
    var value = raw.trim()
    if value.starts_with("\"") and value.ends_with("\"") and value.len() >= 2:
        value = value.substring(1, value.len() - 1)
    value

fn _parse_int(value: text, fallback: i64) -> i64:
    if value.len() == 0:
        return fallback
    value.to_int()

fn _parse_bool(value: text, fallback: bool) -> bool:
    if value == "true":
        return true
    if value == "false":
        return false
    fallback
