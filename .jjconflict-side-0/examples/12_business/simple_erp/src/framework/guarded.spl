# Business Framework — Guarded Write Core
#
# The ONE gate every business write passes through, regardless of lane
# (CRM, reservation, sale, market, restaurant, ...). A lane contributes only
# its domain validation and an action name; the framework owns the order of
# checks and the failure vocabulary, so every lane fails closed the same way:
#
#   session -> rbac -> domain validation -> idempotency -> accepted
#
# Lanes NEVER hand-roll this sequence (that is how bypass bugs are born).

use framework.registry.{LaneDef, default_lanes}
use framework.org.{default_roles, org_role_can}

# Identity / tenancy context. Composition, not inheritance: lanes embed these
# structs in their own request types as fields.
struct Tenant:
    val id: text
    val name: text

struct Actor:
    val id: i64
    val name: text
    val role: text

struct Session:
    val token: text
    val user_id: i64
    val tenant_id: text
    val active: bool

# Every gate outcome is explicit. reason is machine-readable and closed-set:
# accepted | invalid-session | forbidden | invalid-record | duplicate-key | needs-approval
struct WriteResult:
    val ok: bool
    val reason: text
    val audit_action: text
    val ledger_key: text

# Role policy is registry DATA (framework/org.spl default_roles), evaluated
# against the app's registered lanes (framework/registry.spl). ONE policy
# source: changing a role or adding a business is a registration, not an edit
# here.
fn role_can_for(lanes: [LaneDef], role: text, action: text) -> bool:
    return org_role_can(default_roles(), lanes, role, action)

fn role_can(role: text, action: text) -> bool:
    return role_can_for(default_lanes(), role, action)

fn session_valid(session: Session, tenant: Tenant, user: Actor) -> bool:
    return session.active and session.tenant_id == tenant.id and session.user_id == user.id and session.token.len() > 0

fn key_used(used_keys: [text], key: text) -> bool:
    for k in used_keys:
        if k == key:
            return true
    return false

fn denied(reason: text, action: text) -> WriteResult:
    return WriteResult { ok: false, reason: reason, audit_action: action, ledger_key: "" }

# The shared gate, parameterized by the app's lane registry. `record_valid` is
# the lane's domain validation verdict; `used_keys` is the set of
# already-accepted idempotency keys.
fn gate_write_for(lanes: [LaneDef], session: Session, tenant: Tenant, user: Actor, action: text, record_valid: bool, idempotency_key: text, used_keys: [text]) -> WriteResult:
    if !session_valid(session, tenant, user):
        return denied("invalid-session", action)
    if !role_can_for(lanes, user.role, action):
        return denied("forbidden", action)
    if !record_valid or idempotency_key.len() == 0:
        return denied("invalid-record", action)
    if key_used(used_keys, idempotency_key):
        return denied("duplicate-key", action)
    return WriteResult { ok: true, reason: "accepted", audit_action: action, ledger_key: idempotency_key }

# The stock-suite gate: the registry defaulted to this example's five lanes.
fn gate_write(session: Session, tenant: Tenant, user: Actor, action: text, record_valid: bool, idempotency_key: text, used_keys: [text]) -> WriteResult:
    return gate_write_for(default_lanes(), session, tenant, user, action, record_valid, idempotency_key, used_keys)

# Approval overlay on the shared gate. Runs gate_write first; if it already
# failed, that reason stands. Otherwise a large write (amount >= threshold) by a
# non-approver (and non-admin) is held for approval rather than accepted.
fn gate_write_with_approval(session: Session, tenant: Tenant, user: Actor, action: text, record_valid: bool, idempotency_key: text, used_keys: [text], amount_minor: i64, threshold_minor: i64, approver_role: text) -> WriteResult:
    val base = gate_write(session, tenant, user, action, record_valid, idempotency_key, used_keys)
    if !base.ok:
        return base
    if amount_minor >= threshold_minor and user.role != approver_role and user.role != "admin":
        return denied("needs-approval", action)
    return base
