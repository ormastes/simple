# Hello Async Electron — Channel-Based Electron Backend
#
# Launches the async (non-blocking, channel-based) Electron backend
# on port 3000 with the hello_electron.ui.sdn layout.

use app.ui.electron.async_app.{run_async_electron}

fn main() -> i64:
    return run_async_electron("examples/ui/hello_electron.ui.sdn", 3000)
