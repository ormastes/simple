#![allow(unnamed_duplicate_typed_args)]
# Per-Widget Rendering Demo — Scroll, Textarea
#
# Non-interactive demo that builds a widget tree containing a scroll
# container with 20 text items and two textareas, renders to an 80x24
# TUI screen buffer, and verifies the rendered output contains expected
# markers. Prints PASS/FAIL for each check and returns 0 on all pass.

use common.ui.builder.{column, panel, scroll, textarea, text_widget, build_tree_with_title, with_height}
use common.ui.widget.{UIState}
use common.ui.layout.{compute_layout}
use common.ui.state.{init_state}
use app.ui.tui.screen.{Screen}
use app.ui.render.widgets.{render_tui_tree}

fn build_demo_tree() -> UIState:
    """Build a tree with a scroll container and two textareas inside a panel."""
    # Create 20 text widgets for the scroll container
    var scroll_children: [WidgetNode] = []
    var i = 0
    while i < 20:
        val child = with_height(text_widget("line_{i}", "Line {i + 1}: scroll content item"), 1)
        scroll_children = scroll_children.push(child)
        i = i + 1

    val scroller = scroll("scroller", 8, scroll_children)

    val code_text = "fn main():\n    val x = 42\n    print x\n    return 0"
    val ta_code = textarea("ta_code", code_text, "Enter code...", 6)

    val ta_empty = textarea("ta_empty", "", "Type something here...", 4)

    val content = panel("content", "Scroll & Textarea Demo", [
        scroller,
        ta_code,
        ta_empty
    ])

    val root = column("root", [content])
    val tree = build_tree_with_title(root, "Scroll Textarea Demo", "dark")
    return init_state(tree)

fn check(output: text, needle: text, description: text, failures: i32) -> i32:
    if output.contains(needle):
        print "PASS: {description}"
        return failures
    else:
        print "FAIL: {description} (expected '{needle}')"
        return failures + 1

fn main() -> i64:
    var failures = 0
    val width = 80
    val height = 24

    # Build the widget tree
    val state = build_demo_tree()

    # Verify tree was built
    val ids = state.tree.all_widget_ids()
    if ids.len() > 0:
        print "PASS: tree built with {ids.len()} widgets"
    else:
        print "FAIL: tree has no widgets"
        failures = failures + 1

    # Compute layout
    val rects = compute_layout(state.tree.root_node(), 0, 0, width, height - 1)
    if rects.len() > 0:
        print "PASS: layout computed with {rects.len()} rects"
    else:
        print "FAIL: layout produced no rects"
        failures = failures + 1

    # Render to screen buffer
    var screen = Screen.new(width, height - 1)
    screen = render_tui_tree(screen, state.tree.root_node(), rects, state)
    val output = screen.render()

    if output.len() > 0:
        print "PASS: render produced output ({output.len()} chars)"
    else:
        print "FAIL: render produced empty output"
        failures = failures + 1

    # Print the rendered buffer for visual inspection
    print "--- Rendered Output ---"
    var row_idx = 0
    while row_idx < screen.buffer.len():
        print screen.buffer[row_idx]
        row_idx = row_idx + 1
    print "--- End Output ---"

    # Verify panel title
    failures = check(output, "Scroll", "panel title contains 'Scroll'", failures)

    # Verify scroll content (first visible lines)
    failures = check(output, "Line 1", "scroll shows 'Line 1'", failures)

    # Verify textarea content
    failures = check(output, "fn main", "textarea shows 'fn main'", failures)
    failures = check(output, "val x", "textarea shows 'val x'", failures)

    # Summary
    if failures == 0:
        print "All tests passed."
        return 0
    else:
        print "{failures} test(s) failed."
        return 1
