# Guest Memory Manager
#
# Page-based memory subsystem for emulated guest CPUs.
# Supports:
# - Flat memory (8086 with 20-bit physical addressing)
# - Harvard architecture (AVR with separate program/data memory)
# - Endianness-aware read/write (little-endian for both AVR and 8086)
# - Memory-mapped I/O region delegation to IoController

use core.types.{GuestArch, ADDR_SPACE_DEFAULT, ADDR_SPACE_PROGRAM, ADDR_SPACE_DATA}
use core.mem_op.{Endian}
use guest.cpu_def.{GuestCpuDef, AddrSpaceDef}

# ============================================================================
# Constants
# ============================================================================

val PAGE_SIZE_DEFAULT: i64 = 4096       # 4KB pages for 8086/generic
val PAGE_SIZE_AVR: i64 = 256            # 256-byte pages for AVR

val MMIO_REGION_MAX: i64 = 16           # Maximum number of MMIO regions

# ============================================================================
# Memory Page
# ============================================================================

struct MemoryPage:
    """A single page of guest memory."""
    base_addr: i64
    data: [i64]         # Byte array (each element 0-255)
    writable: bool

impl MemoryPage:
    static fn new(base_addr: i64, size: i64) -> MemoryPage:
        var data: [i64] = []
        for _ in 0..size:
            data.push(0)
        MemoryPage(base_addr: base_addr, data: data, writable: true)

    static fn readonly(base_addr: i64, size: i64) -> MemoryPage:
        var data: [i64] = []
        for _ in 0..size:
            data.push(0)
        MemoryPage(base_addr: base_addr, data: data, writable: false)

    fn contains(addr: i64) -> bool:
        val offset = addr - self.base_addr
        (offset >= 0) & (offset < self.data.len())

    fn read_byte(addr: i64) -> i64:
        val offset = addr - self.base_addr
        self.data[offset] & 0xFF

    me write_byte(addr: i64, value: i64):
        if self.writable:
            val offset = addr - self.base_addr
            self.data[offset] = value & 0xFF

# ============================================================================
# MMIO Region descriptor
# ============================================================================

struct MmioRegion:
    """A memory-mapped I/O region that delegates reads/writes."""
    start_addr: i64
    end_addr: i64           # Exclusive
    addr_space: i64
    device_index: i64       # Index into IoController.devices

impl MmioRegion:
    static fn new(start: i64, end: i64, addr_space: i64, device_index: i64) -> MmioRegion:
        MmioRegion(start_addr: start, end_addr: end, addr_space: addr_space, device_index: device_index)

    fn contains(addr: i64) -> bool:
        (addr >= self.start_addr) & (addr < self.end_addr)

# ============================================================================
# Guest Memory
# ============================================================================

struct GuestMemory:
    """Page-based guest memory manager.

    For flat architectures (8086): single memory array accessed via read/write.
    For Harvard architectures (AVR): separate program_memory and data_memory.
    """
    arch: GuestArch
    page_size: i64
    endian: Endian

    # Flat memory (used for 8086 and as data_memory fallback)
    memory: [i64]           # Flat byte array, indexed by physical address
    memory_size: i64

    # Harvard architecture support (AVR)
    program_memory: [i64]   # Flash / program space (read-only at runtime)
    program_size: i64
    data_memory: [i64]      # SRAM / data space
    data_size: i64

    # MMIO regions
    mmio_regions: [MmioRegion]
    mmio_count: i64

    # Statistics
    read_count: i64
    write_count: i64

impl GuestMemory:
    static fn new(cpu_def: GuestCpuDef) -> GuestMemory:
        """Create memory sized for the given CPU definition."""
        val arch = cpu_def.arch
        val endian = cpu_def.endian
        val page_sz = match arch:
            GuestArch.Avr: PAGE_SIZE_AVR
            _: PAGE_SIZE_DEFAULT

        # Determine memory sizes from address space definitions
        var mem_size: i64 = 0
        var prog_size: i64 = 0
        var data_size: i64 = 0

        for as_ in cpu_def.addr_spaces:
            if as_.id == ADDR_SPACE_DEFAULT:
                mem_size = as_.size
            else if as_.id == ADDR_SPACE_PROGRAM:
                prog_size = as_.size
            else if as_.id == ADDR_SPACE_DATA:
                # AVR data space is the default address space
                data_size = as_.size

        # For AVR, the default address space IS data
        if arch == GuestArch.Avr:
            if data_size == 0:
                data_size = mem_size
            if prog_size == 0:
                prog_size = 32768   # 32KB default Flash

        # Allocate flat memory
        var memory: [i64] = []
        for _ in 0..mem_size:
            memory.push(0)

        # Allocate Harvard memories
        var prog_mem: [i64] = []
        for _ in 0..prog_size:
            prog_mem.push(0)

        var data_mem: [i64] = []
        for _ in 0..data_size:
            data_mem.push(0)

        GuestMemory(
            arch: arch,
            page_size: page_sz,
            endian: endian,
            memory: memory,
            memory_size: mem_size,
            program_memory: prog_mem,
            program_size: prog_size,
            data_memory: data_mem,
            data_size: data_size,
            mmio_regions: [],
            mmio_count: 0,
            read_count: 0,
            write_count: 0
        )

    # ========================================================================
    # MMIO registration
    # ========================================================================

    me register_mmio(start: i64, end: i64, addr_space: i64, device_index: i64):
        """Register a memory-mapped I/O region."""
        if self.mmio_count < MMIO_REGION_MAX:
            self.mmio_regions.push(MmioRegion.new(start, end, addr_space, device_index))
            self.mmio_count = self.mmio_count + 1

    fn find_mmio(addr: i64, addr_space: i64) -> MmioRegion?:
        """Check if an address falls in an MMIO region."""
        for region in self.mmio_regions:
            if region.addr_space == addr_space:
                if region.contains(addr):
                    return Some(region)
        nil

    # ========================================================================
    # Raw byte-level access (flat memory)
    # ========================================================================

    fn _raw_read(addr: i64) -> i64:
        """Read a single byte from flat memory."""
        if (addr >= 0) & (addr < self.memory_size):
            self.memory[addr] & 0xFF
        else:
            0

    me _raw_write(addr: i64, value: i64):
        """Write a single byte to flat memory."""
        if (addr >= 0) & (addr < self.memory_size):
            self.memory[addr] = value & 0xFF

    # ========================================================================
    # Width-aware reads (little-endian)
    # ========================================================================

    me read8(addr: i64) -> i64:
        """Read 8-bit value."""
        self.read_count = self.read_count + 1
        self._raw_read(addr)

    me read16(addr: i64) -> i64:
        """Read 16-bit value (little-endian)."""
        self.read_count = self.read_count + 1
        val lo = self._raw_read(addr)
        val hi = self._raw_read(addr + 1)
        (hi << 8) | lo

    me read32(addr: i64) -> i64:
        """Read 32-bit value (little-endian)."""
        self.read_count = self.read_count + 1
        val b0 = self._raw_read(addr)
        val b1 = self._raw_read(addr + 1)
        val b2 = self._raw_read(addr + 2)
        val b3 = self._raw_read(addr + 3)
        (b3 << 24) | (b2 << 16) | (b1 << 8) | b0

    # ========================================================================
    # Width-aware writes (little-endian)
    # ========================================================================

    me write8(addr: i64, value: i64):
        """Write 8-bit value."""
        self.write_count = self.write_count + 1
        self._raw_write(addr, value)

    me write16(addr: i64, value: i64):
        """Write 16-bit value (little-endian)."""
        self.write_count = self.write_count + 1
        self._raw_write(addr, value & 0xFF)
        self._raw_write(addr + 1, (value >> 8) & 0xFF)

    me write32(addr: i64, value: i64):
        """Write 32-bit value (little-endian)."""
        self.write_count = self.write_count + 1
        self._raw_write(addr, value & 0xFF)
        self._raw_write(addr + 1, (value >> 8) & 0xFF)
        self._raw_write(addr + 2, (value >> 16) & 0xFF)
        self._raw_write(addr + 3, (value >> 24) & 0xFF)

    # ========================================================================
    # Harvard architecture (AVR): separate program and data memory
    # ========================================================================

    me read_program(addr: i64) -> i64:
        """Read a byte from program memory (Flash). Used by LPM instruction."""
        self.read_count = self.read_count + 1
        if (addr >= 0) & (addr < self.program_size):
            self.program_memory[addr] & 0xFF
        else:
            0

    me read_program16(addr: i64) -> i64:
        """Read 16-bit word from program memory (little-endian).
        AVR instructions are 16-bit wide.
        """
        self.read_count = self.read_count + 1
        val lo = if (addr >= 0) & (addr < self.program_size):
            self.program_memory[addr] & 0xFF
        else:
            0
        val hi = if (addr + 1 >= 0) & (addr + 1 < self.program_size):
            self.program_memory[addr + 1] & 0xFF
        else:
            0
        (hi << 8) | lo

    me read_data(addr: i64) -> i64:
        """Read a byte from data memory (SRAM). Used by LD/LDS instructions."""
        self.read_count = self.read_count + 1
        if (addr >= 0) & (addr < self.data_size):
            self.data_memory[addr] & 0xFF
        else:
            0

    me write_data(addr: i64, value: i64):
        """Write a byte to data memory (SRAM). Used by ST/STS instructions."""
        self.write_count = self.write_count + 1
        if (addr >= 0) & (addr < self.data_size):
            self.data_memory[addr] = value & 0xFF

    me read_data16(addr: i64) -> i64:
        """Read 16-bit value from data memory (little-endian)."""
        self.read_count = self.read_count + 1
        var lo: i64 = 0
        var hi: i64 = 0
        if (addr >= 0) & (addr < self.data_size):
            lo = self.data_memory[addr] & 0xFF
        if (addr + 1 >= 0) & (addr + 1 < self.data_size):
            hi = self.data_memory[addr + 1] & 0xFF
        (hi << 8) | lo

    me write_data16(addr: i64, value: i64):
        """Write 16-bit value to data memory (little-endian)."""
        self.write_count = self.write_count + 1
        if (addr >= 0) & (addr < self.data_size):
            self.data_memory[addr] = value & 0xFF
        if (addr + 1 >= 0) & (addr + 1 < self.data_size):
            self.data_memory[addr + 1] = (value >> 8) & 0xFF

    # ========================================================================
    # 8086 segment:offset support
    # ========================================================================

    fn resolve_segoff(seg: i64, off: i64) -> i64:
        """Calculate 20-bit physical address from segment:offset.

        physical = segment * 16 + offset, masked to 1MB (20 bits).
        """
        (seg * 16 + off) & 0xFFFFF

    me read_physical(phys_addr: i64) -> i64:
        """Read a byte using a 20-bit physical address (8086 mode)."""
        val addr = phys_addr & 0xFFFFF
        self.read8(addr)

    me write_physical(phys_addr: i64, value: i64):
        """Write a byte using a 20-bit physical address (8086 mode)."""
        val addr = phys_addr & 0xFFFFF
        self.write8(addr, value)

    me read_physical16(phys_addr: i64) -> i64:
        """Read 16-bit value from physical address (little-endian, 8086)."""
        val addr = phys_addr & 0xFFFFF
        self.read16(addr)

    me write_physical16(phys_addr: i64, value: i64):
        """Write 16-bit value to physical address (little-endian, 8086)."""
        val addr = phys_addr & 0xFFFFF
        self.write16(addr, value)

    me read_segoff(seg: i64, off: i64) -> i64:
        """Read byte via segment:offset addressing."""
        val phys = self.resolve_segoff(seg, off)
        self.read_physical(phys)

    me write_segoff(seg: i64, off: i64, value: i64):
        """Write byte via segment:offset addressing."""
        val phys = self.resolve_segoff(seg, off)
        self.write_physical(phys, value)

    me read_segoff16(seg: i64, off: i64) -> i64:
        """Read 16-bit value via segment:offset addressing (little-endian)."""
        val phys = self.resolve_segoff(seg, off)
        self.read_physical16(phys)

    me write_segoff16(seg: i64, off: i64, value: i64):
        """Write 16-bit value via segment:offset addressing (little-endian)."""
        val phys = self.resolve_segoff(seg, off)
        self.write_physical16(phys, value)

    # ========================================================================
    # Binary loading
    # ========================================================================

    me load_binary(data: [i64], base_addr: i64):
        """Load binary data into flat memory at the given base address."""
        for i in 0..data.len():
            val addr = base_addr + i
            if (addr >= 0) & (addr < self.memory_size):
                self.memory[addr] = data[i] & 0xFF

    me load_program_binary(data: [i64], base_addr: i64):
        """Load binary data into program memory (AVR Flash)."""
        for i in 0..data.len():
            val addr = base_addr + i
            if (addr >= 0) & (addr < self.program_size):
                self.program_memory[addr] = data[i] & 0xFF

    me load_data_binary(data: [i64], base_addr: i64):
        """Load binary data into data memory (AVR SRAM)."""
        for i in 0..data.len():
            val addr = base_addr + i
            if (addr >= 0) & (addr < self.data_size):
                self.data_memory[addr] = data[i] & 0xFF

    # ========================================================================
    # Utilities
    # ========================================================================

    me reset():
        """Zero all memory and reset counters."""
        for i in 0..self.memory_size:
            self.memory[i] = 0
        for i in 0..self.program_size:
            self.program_memory[i] = 0
        for i in 0..self.data_size:
            self.data_memory[i] = 0
        self.read_count = 0
        self.write_count = 0

    fn stats_text() -> text:
        """Return memory statistics as text."""
        var s = "GuestMemory({self.arch})"
        s = s + "\n  flat: {self.memory_size} bytes"
        if self.program_size > 0:
            s = s + "\n  program: {self.program_size} bytes"
        if self.data_size > 0:
            s = s + "\n  data: {self.data_size} bytes"
        s = s + "\n  mmio regions: {self.mmio_count}"
        s = s + "\n  reads: {self.read_count}, writes: {self.write_count}"
        s
