# RTL Bridge
#
# Transform-dimension bridge that moves architecture checkpoints between fast
# execution and RTL-oriented backends.

use guest.cpu_def.{GuestCpuDef, GuestState}
use runtime.memory.{GuestMemory}
use rtl.types.{Rv32Checkpoint}

class RtlStateBridge:
    """Bridge shared architectural state into backend-neutral checkpoints."""

impl RtlStateBridge:
    static fn new() -> RtlStateBridge:
        RtlStateBridge()

    fn make_checkpoint(state: GuestState, memory: GuestMemory, cycle_count: i64, halted: bool) -> Rv32Checkpoint:
        Rv32Checkpoint.from_state(state, memory.memory, memory.read_count, memory.write_count, cycle_count, halted)

    fn restore_state(cpu_def: GuestCpuDef, checkpoint: Rv32Checkpoint) -> GuestState:
        var state = GuestState.new(cpu_def)
        state.reg_values = checkpoint.reg_values
        state.pc = checkpoint.pc
        state

    me restore_memory(memory: GuestMemory, checkpoint: Rv32Checkpoint):
        memory.memory = checkpoint.memory
        memory.read_count = checkpoint.read_count
        memory.write_count = checkpoint.write_count
