"""
.irtc Format Round-trip End-to-End Integration Specification

Exercises the full serialization pipeline: build IR_TC module with builder,
serialize with write_module(), deserialize with read_module(), and verify
the round-tripped module matches the original.

**Feature IDs:** #MLLVM-FMT-E2E
**Category:** Testing
**Status:** Implemented
"""

use std.spec.{describe, it, expect}
use core.types.{IrTcTypeKind, IrTcValue, IrTcCond, GuestArch}
use core.ops.{IrTcOp, IrTcInst}
use core.mem_op.{GuestRegId}
use core.block.{BlockId, IrTcBlock, IrTcFunction, IrTcParam, IrTcModule, IrTcModuleMode}
use core.builder.{IrTcBuilder}
use format.irtc_writer.{write_module}
use format.irtc_reader.{read_module}

# ============================================================================
# Format round-trip — Simple function
# ============================================================================

describe "Format round-trip with simple function":
    """Build a simple function, write to bytes, read back, verify structure."""

    it "round-trips a single-function module":
        var builder = IrTcBuilder.new("rt_simple", IrTcModuleMode.Compilation)
        builder.begin_function("add_i32", [
            IrTcParam.new("a", IrTcTypeKind.I32),
            IrTcParam.new("b", IrTcTypeKind.I32)
        ], IrTcTypeKind.I32)

        val entry = builder.new_block("entry")
        builder.set_block(entry)
        val a = builder.param_value(0)
        val b = builder.param_value(1)
        val result = builder.add(a, b)
        builder.ret(Some(result))
        builder.end_function()

        val module = builder.finish()

        # Write to bytes
        val bytes = write_module(module)

        # Bytes should be non-empty
        expect(bytes.len()).to_be_greater_than(0)

        # Read back
        val read_result = read_module(bytes)
        match read_result:
            Ok(restored):
                # Function count matches
                expect(restored.functions.len()).to_equal(1)
                # Function name matches
                expect(restored.functions[0].name).to_equal("add_i32")
            Err(e):
                # Should not error
                expect(false).to_equal(true)

    it "preserves function parameter count":
        var builder = IrTcBuilder.new("rt_params", IrTcModuleMode.Compilation)
        builder.begin_function("three_params", [
            IrTcParam.new("x", IrTcTypeKind.I32),
            IrTcParam.new("y", IrTcTypeKind.I32),
            IrTcParam.new("z", IrTcTypeKind.I32)
        ], IrTcTypeKind.I32)

        val entry = builder.new_block("entry")
        builder.set_block(entry)
        val x = builder.param_value(0)
        builder.ret(Some(x))
        builder.end_function()

        val module = builder.finish()
        val bytes = write_module(module)
        val read_result = read_module(bytes)
        match read_result:
            Ok(restored):
                expect(restored.functions[0].params.len()).to_equal(3)
            Err(_):
                expect(false).to_equal(true)

# ============================================================================
# Format round-trip — Multiple functions
# ============================================================================

describe "Format round-trip with multiple functions":
    """Build a module with multiple functions, verify all survive round-trip."""

    it "round-trips module with two functions":
        var builder = IrTcBuilder.new("rt_multi", IrTcModuleMode.Compilation)

        # Function 1
        builder.begin_function("func_a", [
            IrTcParam.new("x", IrTcTypeKind.I32)
        ], IrTcTypeKind.I32)
        val entry1 = builder.new_block("entry")
        builder.set_block(entry1)
        val x = builder.param_value(0)
        builder.ret(Some(x))
        builder.end_function()

        # Function 2
        builder.begin_function("func_b", [
            IrTcParam.new("a", IrTcTypeKind.I64),
            IrTcParam.new("b", IrTcTypeKind.I64)
        ], IrTcTypeKind.I64)
        val entry2 = builder.new_block("entry")
        builder.set_block(entry2)
        val a = builder.param_value(0)
        val b = builder.param_value(1)
        val sum = builder.add(a, b)
        builder.ret(Some(sum))
        builder.end_function()

        val module = builder.finish()
        val bytes = write_module(module)
        val read_result = read_module(bytes)

        match read_result:
            Ok(restored):
                expect(restored.functions.len()).to_equal(2)
                expect(restored.functions[0].name).to_equal("func_a")
                expect(restored.functions[1].name).to_equal("func_b")
            Err(_):
                expect(false).to_equal(true)

    it "preserves function names through round-trip":
        var builder = IrTcBuilder.new("rt_names", IrTcModuleMode.Compilation)

        builder.begin_function("alpha", [], IrTcTypeKind.Void)
        val e1 = builder.new_block("entry")
        builder.set_block(e1)
        builder.ret(nil)
        builder.end_function()

        builder.begin_function("beta", [], IrTcTypeKind.Void)
        val e2 = builder.new_block("entry")
        builder.set_block(e2)
        builder.ret(nil)
        builder.end_function()

        builder.begin_function("gamma", [], IrTcTypeKind.Void)
        val e3 = builder.new_block("entry")
        builder.set_block(e3)
        builder.ret(nil)
        builder.end_function()

        val module = builder.finish()
        val bytes = write_module(module)
        val read_result = read_module(bytes)

        match read_result:
            Ok(restored):
                expect(restored.functions.len()).to_equal(3)
                expect(restored.functions[0].name).to_equal("alpha")
                expect(restored.functions[1].name).to_equal("beta")
                expect(restored.functions[2].name).to_equal("gamma")
            Err(_):
                expect(false).to_equal(true)

# ============================================================================
# Format round-trip — Block count preservation
# ============================================================================

describe "Format round-trip block structure":
    """Verify block count and structure survive serialization."""

    it "preserves block count for branching function":
        var builder = IrTcBuilder.new("rt_blocks", IrTcModuleMode.Compilation)
        builder.begin_function("brancher", [
            IrTcParam.new("a", IrTcTypeKind.I32),
            IrTcParam.new("b", IrTcTypeKind.I32)
        ], IrTcTypeKind.I32)

        val entry = builder.new_block("entry")
        val then_block = builder.new_block("then")
        val else_block = builder.new_block("else")

        builder.set_block(entry)
        val a = builder.param_value(0)
        val b = builder.param_value(1)
        val cmp = builder.cmp(IrTcCond.Gt, a, b)
        builder.br_cond(cmp, then_block, else_block)

        builder.set_block(then_block)
        builder.ret(Some(a))

        builder.set_block(else_block)
        builder.ret(Some(b))

        builder.end_function()
        val module = builder.finish()

        val original_blocks = module.functions[0].blocks.len()
        expect(original_blocks).to_equal(3)

        val bytes = write_module(module)
        val read_result = read_module(bytes)

        match read_result:
            Ok(restored):
                val restored_blocks = restored.functions[0].blocks.len()
                expect(restored_blocks).to_equal(original_blocks)
            Err(_):
                expect(false).to_equal(true)

# ============================================================================
# Format round-trip — Emulation mode module
# ============================================================================

describe "Format round-trip emulation module":
    """Verify emulation-mode modules with guest state ops survive round-trip."""

    it "round-trips emulation module with guest register ops":
        var builder = IrTcBuilder.new("rt_emu", IrTcModuleMode.Emulation)
        builder.set_target(GuestArch.Avr)

        builder.begin_function("avr_add", [], IrTcTypeKind.Void)
        val entry = builder.new_block("entry")
        builder.set_block(entry)

        val r0_id = GuestRegId.new(GuestArch.Avr, 0, "r0")
        val r1_id = GuestRegId.new(GuestArch.Avr, 1, "r1")
        val r0 = builder.read_guest_reg(r0_id, IrTcTypeKind.I8)
        val r1 = builder.read_guest_reg(r1_id, IrTcTypeKind.I8)
        val sum = builder.add(r0, r1)
        builder.write_guest_reg(r0_id, sum)
        builder.exit_tb(0)

        builder.end_function()
        val module = builder.finish()

        val bytes = write_module(module)
        expect(bytes.len()).to_be_greater_than(0)

        val read_result = read_module(bytes)
        match read_result:
            Ok(restored):
                expect(restored.functions.len()).to_equal(1)
                expect(restored.functions[0].name).to_equal("avr_add")
                # Block count should match
                expect(restored.functions[0].blocks.len()).to_equal(1)
            Err(_):
                expect(false).to_equal(true)

# ============================================================================
# Format round-trip — Byte stability
# ============================================================================

describe "Format byte stability":
    """Verify write -> read -> write produces identical bytes."""

    it "produces identical bytes on double round-trip":
        var builder = IrTcBuilder.new("rt_stable", IrTcModuleMode.Compilation)
        builder.begin_function("identity", [
            IrTcParam.new("x", IrTcTypeKind.I32)
        ], IrTcTypeKind.I32)
        val entry = builder.new_block("entry")
        builder.set_block(entry)
        val x = builder.param_value(0)
        builder.ret(Some(x))
        builder.end_function()

        val module = builder.finish()

        # First write
        val bytes1 = write_module(module)

        # Read back
        val read_result = read_module(bytes1)
        match read_result:
            Ok(restored):
                # Second write
                val bytes2 = write_module(restored)
                # Byte lengths should match
                expect(bytes2.len()).to_equal(bytes1.len())
            Err(_):
                expect(false).to_equal(true)
