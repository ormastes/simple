# Minimal Simple program for RV32I FPGA test
# Computes 3 + 5 and writes result (8) to LED register at 0x80000000

extern fn rt_write_u32(addr: i64, value: i64)

fn main():
    val a = 3
    val b = 5
    val result = a + b
    # Write to memory-mapped LED register
    rt_write_u32(0x80000000, result)
