# x86_64 FAT32 NVMe filesystem-backed SMF execution probe.
#
# Boots via Multiboot1 on q35 with an NVMe disk containing a FAT32 image.
# Each probe calls into the freestanding C stubs (baremetal_stubs.c) which
# exercise the existing NVMe+FAT32 stack and report pass/fail via i64 sentinel.
# Mirrors the riscv64 smoke_entry.spl marker structure exactly.

extern fn serial_println(msg: text)
extern fn rt_debug_exit_success()
extern fn rt_x86_64_nvfs_probe() -> i64
extern fn rt_x86_64_smf_cli_probe() -> i64
extern fn rt_x86_64_smf_cli_load() -> i64
extern fn rt_x86_64_smf_gui_probe() -> i64
extern fn rt_x86_64_native_gui_process_render() -> i64

fn spl_start():
    serial_println("")
    serial_println("=== SimpleOS x86_64 fs-exec boot ===")
    serial_println("SimpleOS x86_64 boot OK")
    if rt_x86_64_nvfs_probe() == 1:
        serial_println("[x86_64-nvfs] image read ok")
    else:
        serial_println("[x86_64-nvfs] image read failed")
        serial_println("TEST FAILED")
        rt_debug_exit_success()
        return
    if rt_x86_64_smf_cli_probe() == 1:
        serial_println("FS_MOUNT_OK")
        serial_println("SMF_DISCOVERY_OK")
    else:
        serial_println("[x86_64-smf] cli launch probe failed")
        serial_println("TEST FAILED")
        rt_debug_exit_success()
        return
    if rt_x86_64_smf_cli_load() == 1:
        serial_println("ELF_LOAD_OK arch=x86_64 app=/sys/apps/hello_world.smf")
        serial_println("SMF_CLI_LAUNCH_OK app=/sys/apps/hello_world.smf")
    else:
        serial_println("[x86_64-smf] cli elf load failed")
        serial_println("TEST FAILED")
        rt_debug_exit_success()
        return
    if rt_x86_64_smf_gui_probe() == 1:
        serial_println("[x86_64-smf] gui package found app=/sys/apps/browser_demo.smf")
    else:
        serial_println("[x86_64-smf] wm gui launch probe failed")
        serial_println("TEST FAILED")
        rt_debug_exit_success()
        return
    if rt_x86_64_native_gui_process_render() == 1:
        serial_println("SMF_WM_GUI_LAUNCH_OK app=/sys/apps/browser_demo.smf pid=1002 wm=x86_64_desktop_shell_contract")
        serial_println("NATIVE_GUI_PROCESS_RENDER_OK app=/sys/apps/browser_demo.smf pid=1002")
    else:
        serial_println("[x86_64-smf] native gui process render failed")
        serial_println("TEST FAILED")
        rt_debug_exit_success()
        return
    serial_println("SIMPLEOS_X86_64_SMF_FS_PASS")
    serial_println("TEST PASSED")
    rt_debug_exit_success()
