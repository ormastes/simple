# ARM32 filesystem executable acceptance entry.
#
# Mirrors the riscv64 smoke_entry pattern: each contract marker is gated behind
# a real capability probe (FAT32 NVFS, SMF CLI ELF load, SMF GUI package, native
# GUI render surface write). Markers are never printed unconditionally.

extern fn serial_println(msg: text)
extern fn rt_qemu_exit_success()
extern fn rt_arm32_nvfs_probe() -> i64
extern fn rt_arm32_smf_cli_probe() -> i64
extern fn rt_arm32_smf_cli_load() -> i64
extern fn rt_arm32_smf_gui_probe() -> i64
extern fn rt_arm32_native_gui_process_render() -> i64

fn spl_start():
    serial_println("")
    serial_println("=== SimpleOS ARM32 FS exec boot ===")
    serial_println("SimpleOS ARM32 boot OK")

    if rt_arm32_nvfs_probe() == 1:
        serial_println("[arm32-nvfs] image read ok")
    else:
        serial_println("[arm32-nvfs] image read failed")
        serial_println("TEST FAILED")
        rt_qemu_exit_success()
        return

    if rt_arm32_smf_cli_probe() == 1:
        serial_println("FS_MOUNT_OK")
        serial_println("SMF_DISCOVERY_OK")
    else:
        serial_println("[arm32-smf] cli launch probe failed")
        serial_println("TEST FAILED")
        rt_qemu_exit_success()
        return

    if rt_arm32_smf_cli_load() == 1:
        serial_println("ELF_LOAD_OK arch=arm32 app=/sys/apps/hello_world.smf")
        serial_println("SMF_CLI_LAUNCH_OK app=/sys/apps/hello_world.smf")
    else:
        serial_println("[arm32-smf] cli elf load failed")
        serial_println("TEST FAILED")
        rt_qemu_exit_success()
        return

    if rt_arm32_smf_gui_probe() == 1:
        serial_println("[arm32-smf] gui package found app=/sys/apps/browser_demo.smf")
    else:
        serial_println("[arm32-smf] wm gui launch probe failed")
        serial_println("TEST FAILED")
        rt_qemu_exit_success()
        return

    if rt_arm32_native_gui_process_render() == 1:
        serial_println("SMF_WM_GUI_LAUNCH_OK app=/sys/apps/browser_demo.smf pid=1002 wm=arm32_desktop_shell_contract")
        serial_println("NATIVE_GUI_PROCESS_RENDER_OK app=/sys/apps/browser_demo.smf pid=1002")
    else:
        serial_println("[arm32-smf] native gui process render failed")
        serial_println("TEST FAILED")
        rt_qemu_exit_success()
        return

    serial_println("TEST PASSED")
    rt_qemu_exit_success()
