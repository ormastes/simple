fn _rv32_feature_id_valid(fid: i64) -> i32:
    if fid == 2:
        return 0
    if fid == 4:
        return 0
    if fid == 6:
        return 0
    if fid == 7:
        return 0
    1

fn _rv32_feature_num_queues_valid(value: i64) -> i32:
    if value < 0:
        return 1
    val ncqr: i64 = value & 0xFFFF
    val nsqr: i64 = (value >> 16) & 0xFFFF
    if value != ((nsqr << 16) | ncqr):
        return 1
    if ncqr >= 8:
        return 1
    if nsqr >= 8:
        return 1
    0

fn _rv32_feature_value_valid(fid: i64, value: i64) -> i32:
    if _rv32_feature_id_valid(fid) != 0:
        return 1
    if fid == 2:
        if value < 0:
            return 1
        if value >= 5:
            return 1
    if fid == 4:
        if value <= 313:
            return 1
    if fid == 6:
        if value < 0:
            return 1
        if value > 1:
            return 1
    if fid == 7:
        return _rv32_feature_num_queues_valid(value)
    0

fn _rv32_feature_default_valid(fid: i64, value: i64) -> i32:
    if fid == 6:
        if value != 1:
            return 1
    if fid == 7:
        if value != 458759:
            return 1
    0
