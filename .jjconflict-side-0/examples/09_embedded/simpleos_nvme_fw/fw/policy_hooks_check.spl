"""
policy_hooks_check — sandboxed dynamic policy hooks regression (research req 7).

Proves the GC-scoring policy hook is dynamically installable AND sandboxed:
  * a custom policy changes which CLOSED block GC selects (dynamic behavior change);
  * an "evil" policy still cannot lose committed data — because it can only SCORE the
    firmware's own CLOSED candidates (never name a block), GC only ever erases a CLOSED
    block and reclaim_block's data-loss guard stays unconditional;
  * installing a hook for a forbidden domain (WAL / checkpoint / recovery / bad-block) is
    rejected at the gate;
  * a hook reporting fuel over budget is discarded -> the default policy is used (modeled
    fuel bound);
  * clearing the hook reverts to the built-in greedy default.

Run: bin/simple run examples/09_embedded/simpleos_nvme_fw/fw/policy_hooks_check.spl
"""

use nvme_types.*
use sandbox.*
use hooks.*
use ftl.*

# Build a device with two CLOSED blocks of different value: block 0 = 64 valid (cold
# data, LBA 0..63) and block 1 = 3 valid (mostly stale).
fn build_two_closed() -> Ftl:
    var ftl: Ftl = ftl_new()
    var j: i64 = 0
    while j < PAGES_PER_BLOCK:
        ftl.write(j, 1000 + j)            # LBA 0..63 -> block 0
        j = j + 1
    ftl.write(100, 0xAA)                  # opens block 1; block 0 CLOSED (64 valid)
    j = 0
    while j < PAGES_PER_BLOCK - 1:
        ftl.write(101 + j, 2000 + j)      # LBA 101..163 fill block 1 (with 100 = 64)
        j = j + 1
    ftl.write(900, 0x55)                  # opens block 2; block 1 CLOSED (64 valid)
    j = 0
    while j < 61:
        ftl.write(100 + j, 7777)          # overwrite LBA 100..160 -> block 1 down to 3 valid
        j = j + 1
    ftl

fn main():
    var fail: i64 = 0

    # 1. Default greedy policy picks the fewest-valid CLOSED block (block 1).
    var a: Ftl = build_two_closed()
    val da: i64 = a.policy_gc_victim()
    print "default victim = {da}"
    fail = fail + expect_eq(da, 1, "default GC policy picks fewest-valid block 1")

    # 2. A custom (inverted) policy picks the MOST-valid CLOSED block (block 0) — a real
    #    behavior change — but still a CLOSED block (the hook scores, it never names one).
    var b: Ftl = build_two_closed()
    b.install_gc_policy(\bl, vl, er, fu: vote(0 - vl, 1))   # invert: most-valid block scores lowest
    val vb: i64 = b.policy_gc_victim()
    print "inverted-policy victim = {vb}"
    fail = fail + expect_eq(vb, 0, "custom GC policy changes selection to block 0")

    # 3. Even the 'evil' policy cannot lose data: GC reclaims block 0 (cold LBA 0..63) and
    #    relocates it safely.
    b.gc_once()
    fail = fail + expect_eq(b.read(0), 1000, "custom-policy GC preserves committed data (no loss)")
    fail = fail + expect_eq(b.read(63), 1063, "custom-policy GC preserves all relocated data")

    # 4. Forbidden-domain installs are rejected at the gate (never hook recovery/metadata).
    var c: Ftl = ftl_new()
    fail = fail + expect_eq(bool_to_int(c.try_load_policy(HOOK_WAL)), 0, "WAL hook install rejected")
    fail = fail + expect_eq(bool_to_int(c.try_load_policy(HOOK_CHECKPOINT)), 0, "checkpoint hook install rejected")
    fail = fail + expect_eq(bool_to_int(c.try_load_policy(HOOK_RECOVERY)), 0, "recovery hook install rejected")
    fail = fail + expect_eq(bool_to_int(c.try_load_policy(HOOK_BAD_BLOCK)), 0, "bad-block hook install rejected")
    fail = fail + expect_eq(bool_to_int(c.try_load_policy(HOOK_GC_SCORE)), 1, "GC-score hook install allowed")
    fail = fail + expect_eq(c.policy_rejected_installs(), 4, "four forbidden installs counted")

    # 5. A fuel-exceeding hook is discarded -> the default policy is used.
    var d: Ftl = build_two_closed()
    d.install_gc_policy(\bl, vl, er, fu: vote(0 - vl, 99999))   # would pick block 0, but over-fuel
    val vd: i64 = d.policy_gc_victim()
    print "over-fuel victim = {vd}"
    fail = fail + expect_eq(vd, 1, "over-fuel hook discarded -> default greedy (block 1)")
    var fa_ok: i64 = 0
    if d.policy_fuel_aborts() > 0:
        fa_ok = 1
    fail = fail + expect_eq(fa_ok, 1, "fuel aborts counted")

    # 6. Clearing the policy reverts to the default greedy selection.
    var e: Ftl = build_two_closed()
    e.install_gc_policy(\bl, vl, er, fu: vote(0 - vl, 1))
    e.clear_gc_policy()
    fail = fail + expect_eq(e.policy_gc_victim(), 1, "clear reverts to default greedy (block 1)")

    if fail == 0:
        print "POLICY HOOKS OK"
    else:
        print "POLICY HOOKS FAIL ({fail})"
