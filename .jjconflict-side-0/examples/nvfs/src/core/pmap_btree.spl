# NVFS core — B-tree pmap index (N5a + N5b).
#
# Replaces the flat _pmap_sidecar list with an O(log n) B-tree keyed by
# (arena_id, offset).  Node-pool representation avoids recursive struct
# definitions: children are indices (i64) into PmapBTree.nodes.
#
# FR-N3-001: Closed by this module.
# FR-NVFS-N5b-001: B-tree delete rebalancing — CLOSED by this file.
#
# Design: doc/05_design/nvfs_design_v2.md §17; N5a + N5b milestones.
#
# ---------------------------------------------------------------------------
# B-tree invariants (N5b)
# ---------------------------------------------------------------------------
# fanout = minimum degree t (parameter to pmap_btree_new).
# Convention used here: min_keys = fanout/2  (task spec, NOT CLRS t-1).
#   max_keys = 2*fanout - 1
#   min_keys = fanout / 2          (integer division; root exempt)
#   merge:   left.keys + separator + right.keys → 2*min_keys + 1 keys max
#   borrow:  move one key+child through parent separator (rotate)
# Node pool: merged-away nodes become unreferenced (no compaction needed;
#   pool indices are stable, so references from remaining nodes stay valid).
# Root shrink: if root has 0 keys after delete and is an internal node with
#   exactly 1 child, replace root with that child.
# Deletion strategy: top-down proactive fix-up (CLRS-style) — before
#   descending into a child, ensure it has > min_keys so leaf deletion never
#   causes underflow that requires post-hoc bubbling.

use std.fs_driver.error.{FsError}
use examples.nvfs.src.core.pmap.{PmapEntry}

# ---------------------------------------------------------------------------
# PmapKey — composite key for B-tree: (arena_id, offset)
# ---------------------------------------------------------------------------

struct PmapKey:
    """Composite B-tree key: arena_id (i64) + byte offset (i64)."""
    arena_id: i64
    offset:   i64

# ---------------------------------------------------------------------------
# PmapSidecarEntry — value stored at each leaf
# ---------------------------------------------------------------------------

struct PmapBTreeEntry:
    """Leaf payload stored per key in the B-tree.

    Mirrors PmapSidecarEntry: key fields plus length and the full PmapEntry.
    length is required by scrub (arena_readv_impl call).
    """
    arena_id: i64
    offset:   i64
    length:   i64
    entry:    PmapEntry

# ---------------------------------------------------------------------------
# PmapBTreeNode — one node in the pool
# ---------------------------------------------------------------------------

struct PmapBTreeNode:
    """Single B-tree node stored in the node pool.

    keys     — sorted PmapKey array (len <= 2*fanout - 1).
    entries  — PmapBTreeEntry payload, parallel to keys (leaves only;
               empty for internal nodes).
    children — child node indices (i64) into PmapBTree.nodes (internal
               nodes only; empty for leaves).
    is_leaf  — true if this node holds entries directly.
    """
    keys:     [PmapKey]
    entries:  [PmapBTreeEntry]
    children: [i64]
    is_leaf:  bool

# ---------------------------------------------------------------------------
# PmapBTree — root struct
# ---------------------------------------------------------------------------

struct PmapBTree:
    """Node-pool B-tree keyed by PmapKey.

    nodes   — flat pool of all nodes; indices are stable references.
    root    — index of the root node in nodes.
    fanout  — minimum degree t (max keys per node = 2*t - 1).
              Default fanout = 16 → max 31 keys per node.
    """
    nodes:  [PmapBTreeNode]
    root:   i64
    fanout: u32

# ---------------------------------------------------------------------------
# Key comparison helpers
# ---------------------------------------------------------------------------

fn _key_cmp(a: PmapKey, b: PmapKey) -> i64:
    """Compare two PmapKeys. Returns -1, 0, or 1."""
    if a.arena_id < b.arena_id:
        return -1
    if a.arena_id > b.arena_id:
        return 1
    # arena_id equal, compare offset
    if a.offset < b.offset:
        return -1
    if a.offset > b.offset:
        return 1
    0

fn _key_eq(a: PmapKey, b: PmapKey) -> bool:
    """Return true iff a == b."""
    _key_cmp(a, b) == 0

fn _key_lt(a: PmapKey, b: PmapKey) -> bool:
    """Return true iff a < b."""
    _key_cmp(a, b) < 0

# ---------------------------------------------------------------------------
# Node pool helpers
# ---------------------------------------------------------------------------

fn _node_alloc(tree: PmapBTree, node: PmapBTreeNode) -> i64:
    """Push node into the pool; return its index."""
    val idx = tree.nodes.len() as i64
    tree.nodes.push(node)
    idx

fn _empty_node(is_leaf: bool) -> PmapBTreeNode:
    """Construct a fresh empty node."""
    val empty_keys:     [PmapKey]         = []
    val empty_entries:  [PmapBTreeEntry]  = []
    val empty_children: [i64]             = []
    PmapBTreeNode(
        keys:     empty_keys,
        entries:  empty_entries,
        children: empty_children,
        is_leaf:  is_leaf
    )

# ---------------------------------------------------------------------------
# Public API: new
# ---------------------------------------------------------------------------

fn pmap_btree_new(fanout: u32) -> PmapBTree:
    """Create an empty PmapBTree with the given minimum degree (fanout).

    Default fanout = 16 (pass 16 for production use).
    The root starts as an empty leaf node at index 0.
    """
    var nodes: [PmapBTreeNode] = []
    val root_node = _empty_node(true)
    nodes.push(root_node)
    PmapBTree(nodes: nodes, root: 0, fanout: fanout)

# ---------------------------------------------------------------------------
# Lookup — O(log n)
# ---------------------------------------------------------------------------

fn _lookup_node(tree: PmapBTree, node_idx: i64, key: PmapKey) -> Option<PmapBTreeEntry>:
    """Recursive lookup in the subtree rooted at node_idx."""
    val node = tree.nodes[node_idx]
    val nkeys = node.keys.len() as i64

    # Binary search for the key.
    var lo: i64 = 0
    var hi: i64 = nkeys - 1
    var found_pos: i64 = -1

    while lo <= hi:
        val mid = lo + (hi - lo) / 2
        val cmp = _key_cmp(key, node.keys[mid])
        if cmp == 0:
            found_pos = mid
            lo = hi + 1   # break
        else:
            if cmp < 0:
                hi = mid - 1
            else:
                lo = mid + 1

    if found_pos >= 0:
        if node.is_leaf:
            return Some(node.entries[found_pos])
        else:
            # Key found in internal node — descend to right child for canonical copy.
            # (Internal nodes don't hold entries in this design; all data is at leaves.)
            return _lookup_node(tree, node.children[found_pos + 1], key)

    if node.is_leaf:
        return None

    # Determine child to descend into.
    var child_pos: i64 = 0
    var ci = 0
    while ci < nkeys:
        if _key_lt(node.keys[ci], key):
            child_pos = ci + 1
        ci = ci + 1

    _lookup_node(tree, node.children[child_pos], key)

fn pmap_btree_lookup(tree: PmapBTree, key: PmapKey) -> Option<PmapBTreeEntry>:
    """Look up key in the B-tree. Returns Some(entry) or None. O(log n)."""
    if tree.nodes.len() == 0:
        return None
    _lookup_node(tree, tree.root, key)

# ---------------------------------------------------------------------------
# Insert helpers
# ---------------------------------------------------------------------------

fn _max_keys(fanout: u32) -> i64:
    """Maximum keys per node = 2*fanout - 1."""
    (2 * fanout as i64) - 1

fn _split_child(tree: PmapBTree, parent_idx: i64, child_slot: i64):
    """Split the full child of parent at child_slot.

    Standard B-tree split: median key promoted to parent, child halved.
    The right half becomes a new node appended to the pool.
    """
    val fanout = tree.fanout as i64
    val mid = fanout - 1   # index of median key in child

    val child_idx = tree.nodes[parent_idx].children[child_slot]
    val child = tree.nodes[child_idx]

    # Build right sibling.
    var right_keys:     [PmapKey]        = []
    var right_entries:  [PmapBTreeEntry] = []
    var right_children: [i64]            = []

    var ki = mid + 1
    while ki < child.keys.len() as i64:
        right_keys.push(child.keys[ki])
        ki = ki + 1

    if child.is_leaf:
        var ei = mid + 1
        while ei < child.entries.len() as i64:
            right_entries.push(child.entries[ei])
            ei = ei + 1
    else:
        var ci2 = mid + 1
        while ci2 < child.children.len() as i64:
            right_children.push(child.children[ci2])
            ci2 = ci2 + 1

    val right_node = PmapBTreeNode(
        keys:     right_keys,
        entries:  right_entries,
        children: right_children,
        is_leaf:  child.is_leaf
    )
    val right_idx = _node_alloc(tree, right_node)

    # Trim child to left half (keys < mid; for leaf include entry at mid).
    var left_keys:    [PmapKey]        = []
    var left_entries: [PmapBTreeEntry] = []
    var left_children:[i64]            = []

    var lki = 0
    while lki < mid:
        left_keys.push(child.keys[lki])
        lki = lki + 1

    if child.is_leaf:
        # Leaf keeps mid entry; promote mid key to parent as separator.
        var lei = 0
        while lei < mid:
            left_entries.push(child.entries[lei])
            lei = lei + 1
    else:
        var lci = 0
        while lci <= mid:
            left_children.push(child.children[lci])
            lci = lci + 1

    tree.nodes[child_idx] = PmapBTreeNode(
        keys:     left_keys,
        entries:  left_entries,
        children: left_children,
        is_leaf:  child.is_leaf
    )

    # Promote median key into parent.
    val median_key = child.keys[mid]
    val parent = tree.nodes[parent_idx]

    # Insert median_key at child_slot in parent.keys.
    var new_parent_keys: [PmapKey] = []
    var pki = 0
    while pki < child_slot:
        new_parent_keys.push(parent.keys[pki])
        pki = pki + 1
    new_parent_keys.push(median_key)
    while pki < parent.keys.len() as i64:
        new_parent_keys.push(parent.keys[pki])
        pki = pki + 1

    # Insert right_idx at child_slot+1 in parent.children.
    var new_parent_children: [i64] = []
    var pci = 0
    while pci <= child_slot:
        new_parent_children.push(parent.children[pci])
        pci = pci + 1
    new_parent_children.push(right_idx)
    while pci < parent.children.len() as i64:
        new_parent_children.push(parent.children[pci])
        pci = pci + 1

    tree.nodes[parent_idx] = PmapBTreeNode(
        keys:     new_parent_keys,
        entries:  parent.entries,
        children: new_parent_children,
        is_leaf:  parent.is_leaf
    )

fn _insert_nonfull(tree: PmapBTree, node_idx: i64, new_entry: PmapBTreeEntry):
    """Insert new_entry into the subtree rooted at node_idx (node must not be full)."""
    val key = PmapKey(arena_id: new_entry.arena_id, offset: new_entry.offset)
    val node = tree.nodes[node_idx]
    val nkeys = node.keys.len() as i64

    if node.is_leaf:
        # Find insertion position (sorted).
        var pos: i64 = nkeys
        var si = 0
        while si < nkeys:
            if _key_lt(key, node.keys[si]):
                pos = si
                si = nkeys   # break
            else:
                if _key_eq(key, node.keys[si]):
                    # Overwrite existing entry.
                    var updated_entries: [PmapBTreeEntry] = []
                    var oi = 0
                    while oi < node.entries.len() as i64:
                        if oi == si:
                            updated_entries.push(new_entry)
                        else:
                            updated_entries.push(node.entries[oi])
                        oi = oi + 1
                    tree.nodes[node_idx] = PmapBTreeNode(
                        keys:     node.keys,
                        entries:  updated_entries,
                        children: node.children,
                        is_leaf:  node.is_leaf
                    )
                    return
                si = si + 1

        # Build new keys and entries arrays with inserted element at pos.
        var new_keys:    [PmapKey]        = []
        var new_entries: [PmapBTreeEntry] = []
        var ii = 0
        while ii < pos:
            new_keys.push(node.keys[ii])
            new_entries.push(node.entries[ii])
            ii = ii + 1
        new_keys.push(key)
        new_entries.push(new_entry)
        while ii < nkeys:
            new_keys.push(node.keys[ii])
            new_entries.push(node.entries[ii])
            ii = ii + 1

        tree.nodes[node_idx] = PmapBTreeNode(
            keys:     new_keys,
            entries:  new_entries,
            children: node.children,
            is_leaf:  node.is_leaf
        )
    else:
        # Find child to descend into.
        var child_pos: i64 = nkeys
        var ci = 0
        while ci < nkeys:
            if _key_lt(key, node.keys[ci]):
                child_pos = ci
                ci = nkeys   # break
            else:
                ci = ci + 1

        val child_idx = tree.nodes[node_idx].children[child_pos]
        val max_k = _max_keys(tree.fanout)
        if tree.nodes[child_idx].keys.len() as i64 >= max_k:
            _split_child(tree, node_idx, child_pos)
            # After split, determine which of the two halves to descend into.
            if _key_lt(tree.nodes[node_idx].keys[child_pos], key):
                val next_child = tree.nodes[node_idx].children[child_pos + 1]
                _insert_nonfull(tree, next_child, new_entry)
            else:
                val same_child = tree.nodes[node_idx].children[child_pos]
                _insert_nonfull(tree, same_child, new_entry)
        else:
            _insert_nonfull(tree, child_idx, new_entry)

# ---------------------------------------------------------------------------
# Public API: insert
# ---------------------------------------------------------------------------

fn pmap_btree_insert(tree: PmapBTree, arena_id: i64, offset: i64, length: i64, entry: PmapEntry) -> Result<(), FsError>:
    """Insert (or overwrite) a pmap entry keyed by (arena_id, offset).

    Performs a standard B-tree insert with leaf-split-on-overflow propagated
    up.  If the root is full, a new root is created (tree grows in height).
    O(log n).
    """
    val new_entry = PmapBTreeEntry(
        arena_id: arena_id,
        offset:   offset,
        length:   length,
        entry:    entry
    )

    val root_idx = tree.root
    val max_k = _max_keys(tree.fanout)

    if tree.nodes[root_idx].keys.len() as i64 >= max_k:
        # Root is full — create a new root, old root becomes its child.
        val new_root = PmapBTreeNode(
            keys:     [],
            entries:  [],
            children: [root_idx],
            is_leaf:  false
        )
        val new_root_idx = _node_alloc(tree, new_root)
        tree.root = new_root_idx
        _split_child(tree, new_root_idx, 0)
        _insert_nonfull(tree, new_root_idx, new_entry)
    else:
        _insert_nonfull(tree, root_idx, new_entry)

    Ok(())

# ---------------------------------------------------------------------------
# Delete rebalancing helpers (N5b)
# ---------------------------------------------------------------------------

fn _min_keys(fanout: u32) -> i64:
    """Minimum keys per non-root node = fanout / 2 (integer division)."""
    fanout as i64 / 2

fn _child_key_count(tree: PmapBTree, parent_idx: i64, child_slot: i64) -> i64:
    """Return the number of keys in parent.children[child_slot]."""
    val child_idx = tree.nodes[parent_idx].children[child_slot]
    tree.nodes[child_idx].keys.len() as i64

fn btree_borrow_from_left(tree: PmapBTree, parent_idx: i64, child_idx_slot: i64) -> bool:
    """Rotate one key+child from left sibling into child through parent.

    Returns true if borrow succeeded (left sibling had > min_keys).
    child_idx_slot is the position of the child in parent.children.
    Left sibling is at child_idx_slot - 1.
    """
    if child_idx_slot == 0:
        return false
    val left_slot = child_idx_slot - 1
    val left_nkeys = _child_key_count(tree, parent_idx, left_slot)
    val min_k = _min_keys(tree.fanout)
    if left_nkeys <= min_k:
        return false

    val parent = tree.nodes[parent_idx]
    val sep_pos = child_idx_slot - 1   # separator key index in parent
    val sep_key = parent.keys[sep_pos]

    val left_idx  = parent.children[left_slot]
    val child_idx = parent.children[child_idx_slot]
    val left  = tree.nodes[left_idx]
    val child = tree.nodes[child_idx]

    # The last key+entry of left sibling comes into child's front.
    val left_last_ki = left.keys.len() as i64 - 1

    # Build new child: prepend sep_key (and for leaves: left's last entry).
    var new_child_keys: [PmapKey] = []
    var new_child_entries: [PmapBTreeEntry] = []
    var new_child_children: [i64] = []

    if child.is_leaf:
        # For leaves: rotate left's last key+entry into child front.
        new_child_keys.push(left.keys[left_last_ki])
        new_child_entries.push(left.entries[left_last_ki])
        var ci2 = 0
        while ci2 < child.keys.len() as i64:
            new_child_keys.push(child.keys[ci2])
            new_child_entries.push(child.entries[ci2])
            ci2 = ci2 + 1
        new_child_children = child.children
    else:
        # For internal: rotate sep_key into child front, left's last child too.
        new_child_keys.push(sep_key)
        var ci2 = 0
        while ci2 < child.keys.len() as i64:
            new_child_keys.push(child.keys[ci2])
            ci2 = ci2 + 1
        new_child_entries = child.entries
        # Prepend left's last child pointer.
        val left_last_child = left.children[left.children.len() as i64 - 1]
        new_child_children.push(left_last_child)
        var cc = 0
        while cc < child.children.len() as i64:
            new_child_children.push(child.children[cc])
            cc = cc + 1

    tree.nodes[child_idx] = PmapBTreeNode(
        keys:     new_child_keys,
        entries:  new_child_entries,
        children: new_child_children,
        is_leaf:  child.is_leaf
    )

    # Trim left sibling.
    var new_left_keys: [PmapKey] = []
    var new_left_entries: [PmapBTreeEntry] = []
    var new_left_children: [i64] = []
    var lki = 0
    while lki < left_last_ki:
        new_left_keys.push(left.keys[lki])
        lki = lki + 1
    if left.is_leaf:
        var lei = 0
        while lei < left_last_ki:
            new_left_entries.push(left.entries[lei])
            lei = lei + 1
        new_left_children = left.children
    else:
        new_left_entries = left.entries
        var lci = 0
        while lci < left.children.len() as i64 - 1:
            new_left_children.push(left.children[lci])
            lci = lci + 1
    tree.nodes[left_idx] = PmapBTreeNode(
        keys:     new_left_keys,
        entries:  new_left_entries,
        children: new_left_children,
        is_leaf:  left.is_leaf
    )

    # Update separator in parent: for leaf rotation, new sep = new child's first key.
    var new_parent_keys: [PmapKey] = []
    var pki2 = 0
    while pki2 < parent.keys.len() as i64:
        if pki2 == sep_pos:
            if child.is_leaf:
                new_parent_keys.push(new_child_keys[0])
            else:
                new_parent_keys.push(left.keys[left_last_ki])
        else:
            new_parent_keys.push(parent.keys[pki2])
        pki2 = pki2 + 1
    tree.nodes[parent_idx] = PmapBTreeNode(
        keys:     new_parent_keys,
        entries:  parent.entries,
        children: parent.children,
        is_leaf:  parent.is_leaf
    )

    true

fn btree_borrow_from_right(tree: PmapBTree, parent_idx: i64, child_idx_slot: i64) -> bool:
    """Rotate one key+child from right sibling into child through parent.

    Returns true if borrow succeeded (right sibling had > min_keys).
    Right sibling is at child_idx_slot + 1.
    """
    val parent = tree.nodes[parent_idx]
    val right_slot = child_idx_slot + 1
    if right_slot >= parent.children.len() as i64:
        return false
    val right_nkeys = _child_key_count(tree, parent_idx, right_slot)
    val min_k = _min_keys(tree.fanout)
    if right_nkeys <= min_k:
        return false

    val sep_pos = child_idx_slot   # separator key index in parent
    val sep_key = parent.keys[sep_pos]

    val child_idx = parent.children[child_idx_slot]
    val right_idx = parent.children[right_slot]
    val child = tree.nodes[child_idx]
    val right = tree.nodes[right_idx]

    # Build new child: append sep_key (and for leaves: right's first entry).
    var new_child_keys: [PmapKey] = []
    var new_child_entries: [PmapBTreeEntry] = []
    var new_child_children: [i64] = []

    if child.is_leaf:
        var ci2 = 0
        while ci2 < child.keys.len() as i64:
            new_child_keys.push(child.keys[ci2])
            new_child_entries.push(child.entries[ci2])
            ci2 = ci2 + 1
        new_child_keys.push(right.keys[0])
        new_child_entries.push(right.entries[0])
        new_child_children = child.children
    else:
        var ci2 = 0
        while ci2 < child.keys.len() as i64:
            new_child_keys.push(child.keys[ci2])
            ci2 = ci2 + 1
        new_child_keys.push(sep_key)
        new_child_entries = child.entries
        var cc = 0
        while cc < child.children.len() as i64:
            new_child_children.push(child.children[cc])
            cc = cc + 1
        new_child_children.push(right.children[0])

    tree.nodes[child_idx] = PmapBTreeNode(
        keys:     new_child_keys,
        entries:  new_child_entries,
        children: new_child_children,
        is_leaf:  child.is_leaf
    )

    # Trim right sibling: drop first key+entry+child.
    var new_right_keys: [PmapKey] = []
    var new_right_entries: [PmapBTreeEntry] = []
    var new_right_children: [i64] = []
    var rki = 1
    while rki < right.keys.len() as i64:
        new_right_keys.push(right.keys[rki])
        rki = rki + 1
    if right.is_leaf:
        var rei = 1
        while rei < right.entries.len() as i64:
            new_right_entries.push(right.entries[rei])
            rei = rei + 1
        new_right_children = right.children
    else:
        new_right_entries = right.entries
        var rci = 1
        while rci < right.children.len() as i64:
            new_right_children.push(right.children[rci])
            rci = rci + 1
    tree.nodes[right_idx] = PmapBTreeNode(
        keys:     new_right_keys,
        entries:  new_right_entries,
        children: new_right_children,
        is_leaf:  right.is_leaf
    )

    # Update separator in parent.
    var new_parent_keys: [PmapKey] = []
    var pki2 = 0
    while pki2 < parent.keys.len() as i64:
        if pki2 == sep_pos:
            if child.is_leaf:
                new_parent_keys.push(right.keys[0])
            else:
                new_parent_keys.push(right.keys[0])
        else:
            new_parent_keys.push(parent.keys[pki2])
        pki2 = pki2 + 1
    tree.nodes[parent_idx] = PmapBTreeNode(
        keys:     new_parent_keys,
        entries:  parent.entries,
        children: parent.children,
        is_leaf:  parent.is_leaf
    )

    true

fn btree_merge_with_right(tree: PmapBTree, parent_idx: i64, child_idx_slot: i64):
    """Merge child at child_idx_slot with its right sibling.

    Pulls separator key from parent into the merged node (for internal nodes).
    For leaves: just concatenate keys+entries (separator goes away entirely).
    The right sibling node becomes unreferenced in the pool after merge.
    One key is removed from parent.
    """
    val parent = tree.nodes[parent_idx]
    val right_slot = child_idx_slot + 1
    val sep_pos = child_idx_slot   # index of separator key in parent

    val child_idx = parent.children[child_idx_slot]
    val right_idx = parent.children[right_slot]
    val child = tree.nodes[child_idx]
    val right = tree.nodes[right_idx]

    # Build merged node.
    var merged_keys: [PmapKey] = []
    var merged_entries: [PmapBTreeEntry] = []
    var merged_children: [i64] = []

    var mki = 0
    while mki < child.keys.len() as i64:
        merged_keys.push(child.keys[mki])
        mki = mki + 1

    if child.is_leaf:
        # Leaf merge: no separator key in merged node.
        var mei = 0
        while mei < child.entries.len() as i64:
            merged_entries.push(child.entries[mei])
            mei = mei + 1
        merged_children = child.children
    else:
        # Internal merge: pull separator key into merged node.
        merged_keys.push(parent.keys[sep_pos])
        merged_entries = child.entries
        var mci = 0
        while mci < child.children.len() as i64:
            merged_children.push(child.children[mci])
            mci = mci + 1
    # Append right node's keys, entries, children.
    var rki = 0
    while rki < right.keys.len() as i64:
        merged_keys.push(right.keys[rki])
        rki = rki + 1
    if child.is_leaf:
        var rei = 0
        while rei < right.entries.len() as i64:
            merged_entries.push(right.entries[rei])
            rei = rei + 1
    else:
        var rci = 0
        while rci < right.children.len() as i64:
            merged_children.push(right.children[rci])
            rci = rci + 1

    tree.nodes[child_idx] = PmapBTreeNode(
        keys:     merged_keys,
        entries:  merged_entries,
        children: merged_children,
        is_leaf:  child.is_leaf
    )

    # Remove separator key and right child pointer from parent.
    var new_parent_keys: [PmapKey] = []
    var new_parent_children: [i64] = []
    var pki = 0
    while pki < parent.keys.len() as i64:
        if pki != sep_pos:
            new_parent_keys.push(parent.keys[pki])
        pki = pki + 1
    var pci = 0
    while pci < parent.children.len() as i64:
        if pci != right_slot:
            new_parent_children.push(parent.children[pci])
        pci = pci + 1
    tree.nodes[parent_idx] = PmapBTreeNode(
        keys:     new_parent_keys,
        entries:  parent.entries,
        children: new_parent_children,
        is_leaf:  parent.is_leaf
    )

# ---------------------------------------------------------------------------
# Public API: remove (N5b — with rebalancing)
# ---------------------------------------------------------------------------

fn pmap_btree_remove(tree: PmapBTree, key: PmapKey) -> Option<PmapBTreeEntry>:
    """Remove and return the entry for key, or None if not present.

    Uses top-down proactive fix-up: before descending into a child we ensure
    it has more than min_keys, so deletion never leaves a node below minimum.
    After deletion, if root has 0 keys and 1 child, root shrinks (tree height
    decreases).  FR-NVFS-N5b-001: CLOSED.
    """
    val result = _lookup_node(tree, tree.root, key)
    match result:
        case None:
            return None
        case Some(found_entry):
            _delete_recursive(tree, tree.root, key)
            # Root shrink: if root is empty internal node with one child, replace.
            val root = tree.nodes[tree.root]
            if (not root.is_leaf) and (root.keys.len() == 0):
                tree.root = root.children[0]
            Some(found_entry)

fn _delete_recursive(tree: PmapBTree, node_idx: i64, key: PmapKey):
    """Recursively delete key from subtree rooted at node_idx.

    Assumes node_idx has > min_keys (guaranteed by caller for non-root nodes).
    For root, called directly.
    """
    val node = tree.nodes[node_idx]
    val nkeys = node.keys.len() as i64
    val min_k = _min_keys(tree.fanout)

    if node.is_leaf:
        # Simple leaf removal.
        var new_keys:    [PmapKey]        = []
        var new_entries: [PmapBTreeEntry] = []
        var ri = 0
        while ri < nkeys:
            if not _key_eq(node.keys[ri], key):
                new_keys.push(node.keys[ri])
                new_entries.push(node.entries[ri])
            ri = ri + 1
        tree.nodes[node_idx] = PmapBTreeNode(
            keys:     new_keys,
            entries:  new_entries,
            children: node.children,
            is_leaf:  node.is_leaf
        )
        return

    # Internal node: find child to descend into.
    var child_pos: i64 = nkeys
    var ci = 0
    while ci < nkeys:
        if _key_lt(key, node.keys[ci]):
            child_pos = ci
            ci = nkeys   # break
        else:
            ci = ci + 1

    # Proactive fix-up: ensure child has > min_keys before descending.
    val child_nkeys = _child_key_count(tree, node_idx, child_pos)
    if child_nkeys <= min_k:
        # Try borrow from left sibling.
        val borrowed_left = btree_borrow_from_left(tree, node_idx, child_pos)
        if not borrowed_left:
            # Try borrow from right sibling.
            val borrowed_right = btree_borrow_from_right(tree, node_idx, child_pos)
            if not borrowed_right:
                # Merge: prefer merge with right; if no right, merge left into child.
                val parent_after = tree.nodes[node_idx]
                if child_pos < parent_after.children.len() as i64 - 1:
                    # Merge child with its right sibling.
                    btree_merge_with_right(tree, node_idx, child_pos)
                    # After merge, child_pos still valid (left child absorbed right).
                else:
                    # No right sibling — merge left sibling with child.
                    # child becomes right side; merge left (child_pos-1) with child.
                    btree_merge_with_right(tree, node_idx, child_pos - 1)
                    # After merge, left sibling now has merged content at child_pos-1.
                    # Recurse into merged node (now at child_pos - 1).
                    _delete_recursive(tree, tree.nodes[node_idx].children[child_pos - 1], key)
                    return

    # Re-read node_idx after possible structural changes.
    val child_idx = tree.nodes[node_idx].children[child_pos]
    _delete_recursive(tree, child_idx, key)

# ---------------------------------------------------------------------------
# Public API: is_empty helper
# ---------------------------------------------------------------------------

fn pmap_btree_is_empty(tree: PmapBTree) -> bool:
    """Return true iff the B-tree contains zero entries."""
    tree.nodes[tree.root].keys.len() == 0

# ---------------------------------------------------------------------------
# Public API: range_iter (collect into list, inclusive)
# ---------------------------------------------------------------------------

fn pmap_btree_range_collect(tree: PmapBTree, start: PmapKey, end: PmapKey) -> [PmapBTreeEntry]:
    """Collect all entries with start <= key <= end (inclusive).

    Returns entries in ascending key order.  Implemented as an in-order
    traversal with early termination.  O(k + log n) where k = result size.
    """
    var out: [PmapBTreeEntry] = []
    _range_collect_node(tree, tree.root, start, end, out)
    out

fn _range_collect_node(tree: PmapBTree, node_idx: i64, start: PmapKey, end: PmapKey, out: [PmapBTreeEntry]):
    """In-order traversal collecting entries in [start, end]."""
    val node = tree.nodes[node_idx]
    val nkeys = node.keys.len() as i64

    if node.is_leaf:
        var i = 0
        while i < nkeys:
            val k = node.keys[i]
            if (not _key_lt(k, start)) and (not _key_lt(end, k)):
                out.push(node.entries[i])
            i = i + 1
        return

    # Internal node: interleave child descent with key checks.
    var i = 0
    while i < nkeys:
        val k = node.keys[i]
        # Descend into child[i] if it might contain keys >= start.
        if not _key_lt(k, start):
            _range_collect_node(tree, node.children[i], start, end, out)
        # Include separator key if in range.
        # (Internal nodes don't hold entries — skip.)
        i = i + 1

    # Descend into last child.
    _range_collect_node(tree, node.children[nkeys], start, end, out)

# ---------------------------------------------------------------------------
# Public API: snapshot (all entries, in-order)
# ---------------------------------------------------------------------------

fn pmap_btree_snapshot(tree: PmapBTree) -> [PmapBTreeEntry]:
    """Return all entries in ascending key order.

    Used by scrub and checksum passes.  O(n).
    """
    var out: [PmapBTreeEntry] = []
    _inorder_collect(tree, tree.root, out)
    out

fn _inorder_collect(tree: PmapBTree, node_idx: i64, out: [PmapBTreeEntry]):
    """In-order traversal collecting all leaf entries."""
    val node = tree.nodes[node_idx]
    val nkeys = node.keys.len() as i64

    if node.is_leaf:
        var i = 0
        while i < nkeys:
            out.push(node.entries[i])
            i = i + 1
        return

    var i = 0
    while i < nkeys:
        _inorder_collect(tree, node.children[i], out)
        i = i + 1
    _inorder_collect(tree, node.children[nkeys], out)
