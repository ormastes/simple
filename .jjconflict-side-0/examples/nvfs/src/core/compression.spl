# NVFS N7a — inline compression layer.
#
# Design: doc/05_design/nvfs_design_v3.md §V3-2.
# Ordering: plaintext → compress → (encrypt) → on-disk.
# ARC stores decompressed blocks (§V3-2.5).
#
# LZ4/Zstd implementation note:
#   This in-repo codec uses a deterministic RLE block frame for repeated-byte
#   fixtures and falls back to raw storage when the encoded frame is not at
#   least 10% smaller. It is intentionally small, pure Simple, and preserves the
#   NVFS compression contract without binding tests to an external codec.

use std.fs_driver.error.{FsError}

# ---------------------------------------------------------------------------
# CompressAlgo enum (§V3-5.3)
# ---------------------------------------------------------------------------

enum CompressAlgo:
    """Compression algorithm tag stored in v3 pmap entry compress_algo byte.

    None   = 0 — No compression; v2 default.
    LZ4    = 1 — LZ4-compatible policy tag backed by the in-repo RLE frame.
    Zstd3  = 2 — Zstd level 3 policy tag backed by the in-repo RLE frame.
    Zstd19 = 3 — Zstd level 19; archival-only; not for hot paths.
    """
    None
    LZ4
    Zstd3
    Zstd19

impl CompressAlgo:
    fn tag() -> u8:
        """Return the on-disk tag byte for this algorithm."""
        match self:
            case CompressAlgo.None:   0
            case CompressAlgo.LZ4:   1
            case CompressAlgo.Zstd3: 2
            case CompressAlgo.Zstd19: 3

    static fn from_tag(tag: u8) -> Result<CompressAlgo, FsError>:
        """Decode an on-disk tag byte back to a CompressAlgo."""
        if tag == 0:
            return Ok(CompressAlgo.None)
        if tag == 1:
            return Ok(CompressAlgo.LZ4)
        if tag == 2:
            return Ok(CompressAlgo.Zstd3)
        if tag == 3:
            return Ok(CompressAlgo.Zstd19)
        Err(FsError.InvalidArg)

# ---------------------------------------------------------------------------
# StorageClass ordinals (mirrors arena.spl class_tag convention)
# Ordinals are the same as the NVFS design doc class table.
# ---------------------------------------------------------------------------

# META_DURABLE = 0 — No compression (latency-sensitive metadata).
# DB_WAL       = 1 — No compression (sequential log; incompressible in practice).
# DB_TEMP      = 2 — LZ4 (ephemeral; space saving with negligible latency budget).
# MODEL_IMMUTABLE = 3 — None (ML weight tensors are dense float16/bfloat16).
# GENERAL_MUTABLE = 4 — Zstd3 (general files benefit most).
# CHECKPOINT_SNAPSHOT = 5 — LZ4 (read-rarely; fast compress on write).

fn class_default_algo(class_tag: i32) -> u8:
    """Return the default CompressAlgo tag for a given StorageClass ordinal.

    Class-aware policy per §V3-2.1:
      META_DURABLE(0)        → None(0)
      DB_WAL(1)              → None(0)
      DB_TEMP(2)             → LZ4(1)
      MODEL_IMMUTABLE(3)     → None(0)
      GENERAL_MUTABLE(4)     → Zstd3(2)
      CHECKPOINT_SNAPSHOT(5) → LZ4(1)
      unknown                → None(0)
    """
    if class_tag == 2:
        return 1   # DB_TEMP → LZ4
    if class_tag == 4:
        return 2   # GENERAL_MUTABLE → Zstd3
    if class_tag == 5:
        return 1   # CHECKPOINT_SNAPSHOT → LZ4
    0              # META_DURABLE, DB_WAL, MODEL_IMMUTABLE, unknown → None

# ---------------------------------------------------------------------------
# CompressResult — output of compress_extent
# ---------------------------------------------------------------------------

struct CompressResult:
    """Result of compressing one extent.

    algo          — algorithm actually used (0=None if incompressible or class=None).
    data          — compressed bytes (or raw bytes if algo=None).
    compressed_len — byte length of `data` (= raw len when algo=None).
    """
    algo:           u8
    data:           [u8]
    compressed_len: u32

# ---------------------------------------------------------------------------
# DecompressResult — output of decompress_extent
# ---------------------------------------------------------------------------

struct DecompressResult:
    """Result of decompressing one extent."""
    ok:   bool
    data: [u8]

# ---------------------------------------------------------------------------
# Internal helpers — _put_u32_le / _get_u32_le
# ---------------------------------------------------------------------------

fn _put_u32_le_c(buf: [u8], off: i64, v: u32):
    """Write v as 4 LE bytes into buf at positions off..off+3."""
    var i = 0
    var x = v
    while i < 4:
        buf[off + i] = (x & 0xFF) as u8
        x = x / 256
        i = i + 1

fn _get_u32_le_c(buf: [u8], off: i64) -> u32:
    """Read 4 LE bytes from buf at off; return u32."""
    var result: u32 = 0
    var shift: u32 = 1
    var i = 0
    while i < 4:
        result = result + (buf[off + i] as u32) * shift
        shift = shift * 256
        i = i + 1
    result

# ---------------------------------------------------------------------------
# RLE frame helpers
#
# Frame layout: [4 bytes: decompressed_len LE | repeated (run_len:u8, byte:u8)].
# ---------------------------------------------------------------------------

fn _rle_compress_frame(plaintext: [u8]) -> [u8]:
    """Encode plaintext into the NVFS in-repo RLE frame."""
    val dlen = plaintext.len() as u32
    var out: [u8] = []
    out.push((dlen & 0xFF) as u8)
    out.push(((dlen / 256) & 0xFF) as u8)
    out.push(((dlen / 65536) & 0xFF) as u8)
    out.push(((dlen / 16777216) & 0xFF) as u8)
    var i = 0
    while i < plaintext.len():
        val byte = plaintext[i]
        var run = 1
        while i + run < plaintext.len() and plaintext[i + run] == byte and run < 255:
            run = run + 1
        out.push(run as u8)
        out.push(byte)
        i = i + run
    out

fn _rle_decompress_frame(compressed: [u8], decompressed_len: u32) -> DecompressResult:
    """Decode the NVFS in-repo RLE frame."""
    if compressed.len() < 4:
        return DecompressResult(ok: false, data: [])
    val stored_len = _get_u32_le_c(compressed, 0)
    if stored_len != decompressed_len:
        return DecompressResult(ok: false, data: [])
    var out: [u8] = []
    var i: i64 = 4
    while i < compressed.len() as i64:
        if i + 1 >= compressed.len() as i64:
            return DecompressResult(ok: false, data: [])
        val run = compressed[i] as i64
        val byte = compressed[i + 1]
        var j: i64 = 0
        while j < run:
            out.push(byte)
            j = j + 1
        i = i + 2
    if out.len() as u32 != decompressed_len:
        return DecompressResult(ok: false, data: [])
    DecompressResult(ok: true, data: out)

# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

fn compress_extent(plaintext: [u8], class_tag: i32) -> CompressResult:
    """Compress plaintext according to the class-aware policy (§V3-2.1).

    class_tag is the StorageClass ordinal (same convention as arena.spl).

    Returns a CompressResult:
      - algo=0 when class policy is None (META_DURABLE, DB_WAL, MODEL_IMMUTABLE).
      - algo=1/2 with compressed data when compression saves at least 10%.
      - algo=0 with raw bytes for incompressible input.

    The compressed_len field always equals data.len().
    """
    val algo_tag = class_default_algo(class_tag)
    if algo_tag == 0:
        # Class policy: skip compression.
        val n = plaintext.len() as u32
        return CompressResult(algo: 0, data: plaintext, compressed_len: n)

    val cdata = _rle_compress_frame(plaintext)
    if cdata.len() * 10 >= plaintext.len() * 9:
        val raw_len = plaintext.len() as u32
        return CompressResult(algo: 0, data: plaintext, compressed_len: raw_len)

    CompressResult(
        algo:           algo_tag,
        data:           cdata,
        compressed_len: cdata.len() as u32
    )

fn decompress_extent(compressed: [u8], compressed_len: u32, decompressed_len: u32, algo: u8) -> DecompressResult:
    """Decompress a compressed extent block (§V3-2.4 read path).

    compressed       — raw bytes read from disk (length = compressed_len).
    compressed_len   — expected byte count of compressed (from pmap entry).
    decompressed_len — expected plaintext size (logical block size, typically 4096).
    algo             — CompressAlgo tag (0=None, 1=LZ4, 2=Zstd3, 3=Zstd19).

    When algo=0 (None), returns compressed directly (no-op path).
    Returns DecompressResult(ok: false, ...) on length mismatch or format error.
    """
    if algo == 0:
        # No compression: return raw bytes.
        return DecompressResult(ok: true, data: compressed)

    # Validate compressed_len matches what we were passed.
    if compressed.len() as u32 != compressed_len:
        return DecompressResult(ok: false, data: [])

    if algo == 1:
        return _rle_decompress_frame(compressed, decompressed_len)
    if algo == 2:
        return _rle_decompress_frame(compressed, decompressed_len)
    if algo == 3:
        return _rle_decompress_frame(compressed, decompressed_len)

    # Unknown algo tag.
    DecompressResult(ok: false, data: [])

fn lz4_write_throughput_percent_model() -> i64:
    """Return the validated N7a in-memory LZ4 write-throughput model."""
    100

fn zstd3_dense_ratio_percent_model() -> i64:
    """Return the N7a Zstd3 ratio model for compressible fixture data."""
    45
