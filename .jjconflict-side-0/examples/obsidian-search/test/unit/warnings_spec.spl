# Unit tests for search quality warnings module

use src.core.warnings.{SearchWarning, clear_warnings, add_warning, get_warnings, has_warnings, warning_to_json, warnings_to_json, make_search_quality_json}
use src.core.warning_rules.{evaluate_search_warnings, evaluate_raw_search_warnings}
use src.core.search_engine.{SearchResult}
use src.core.ranker.{ScoredResult}

describe "SearchWarnings":
    """Tests for warning accumulator and JSON formatting"""

    context "warning accumulator":
        """Module-level warning collection"""

        it "starts empty after clear":
            clear_warnings()
            expect(has_warnings()).to_equal(false)
            expect(get_warnings().len()).to_equal(0)

        it "accumulates warnings":
            clear_warnings()
            add_warning(SearchWarning(
                code: "SQ-001",
                severity: "info",
                message: "Test warning",
                action_type: "acknowledge",
                action_tool: "",
                action_reason: "Test reason"
            ))
            expect(has_warnings()).to_equal(true)
            expect(get_warnings().len()).to_equal(1)

        it "clears warnings between calls":
            clear_warnings()
            add_warning(SearchWarning(
                code: "SQ-001",
                severity: "info",
                message: "First",
                action_type: "acknowledge",
                action_tool: "",
                action_reason: "Reason"
            ))
            expect(get_warnings().len()).to_equal(1)
            clear_warnings()
            expect(get_warnings().len()).to_equal(0)

    context "JSON formatting":
        """Warning to JSON serialization"""

        it "formats single warning to JSON":
            val w = SearchWarning(
                code: "SQ-002",
                severity: "warning",
                message: "Low confidence",
                action_type: "use_tool",
                action_tool: "find_related",
                action_reason: "Graph discovery"
            )
            val json = warning_to_json(w)
            expect(json).to_contain("SQ-002")
            expect(json).to_contain("warning")
            expect(json).to_contain("find_related")

        it "formats search quality metadata":
            clear_warnings()
            add_warning(SearchWarning(
                code: "FL-001",
                severity: "info",
                message: "No embeddings",
                action_type: "acknowledge",
                action_tool: "",
                action_reason: "FR-20 needed"
            ))
            var suggestions: [text] = []
            suggestions.push("Use find_related")
            val json = make_search_quality_json("lexical_tf", 0.7, suggestions)
            expect(json).to_contain("lexical_tf")
            expect(json).to_contain("false")
            expect(json).to_contain("FL-001")

    context "warning rules":
        """Automatic warning evaluation"""

        it "emits zero-result warnings":
            var results: [ScoredResult] = []
            val quality = evaluate_search_warnings("nonexistent query", results)
            expect(quality).to_contain("SQ-003")
            expect(quality).to_contain("fuzzy_search")

        it "emits low confidence warning for low scores":
            var results: [ScoredResult] = []
            val sr = SearchResult(
                note_id: 1,
                path: "test.md",
                title: "Test",
                snippet: "content",
                bm25_score: 0.5,
                tags: "",
                mtime: 0
            )
            results.push(ScoredResult(result: sr, final_score: 0.5))
            val quality = evaluate_search_warnings("test", results)
            expect(quality).to_contain("SQ-002")

        it "always includes FL-001 baseline":
            var results: [ScoredResult] = []
            val sr = SearchResult(
                note_id: 1,
                path: "test.md",
                title: "Test",
                snippet: "",
                bm25_score: 10.0,
                tags: "",
                mtime: 0
            )
            results.push(ScoredResult(result: sr, final_score: 10.0))
            val quality = evaluate_search_warnings("test", results)
            expect(quality).to_contain("FL-001")

        it "suggests operators when none present":
            var results: [ScoredResult] = []
            val quality = evaluate_search_warnings("simple query", results)
            expect(quality).to_contain("QR-002")

        it "does not suggest operators when already used":
            var results: [ScoredResult] = []
            val quality = evaluate_search_warnings("tag:meeting project", results)
            # QR-002 should not be emitted
            expect(quality).to_contain("FL-001")

    context "raw search warnings":
        """Warnings for unranked SearchResult lists"""

        it "handles empty results":
            var results: [SearchResult] = []
            val quality = evaluate_raw_search_warnings("nothing", results)
            expect(quality).to_contain("SQ-003")
            expect(quality).to_contain("lexical_tf")
