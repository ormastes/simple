# Unit tests for LSP completion module

use src.lsp.lsp_completion.{handle_completion}

describe "LSP Completion":
    """Tests for wikilink and tag completion"""

    context "wikilink completion":
        """Completing [[wikilinks]]"""

        it "returns completion list JSON":
            # Completion with no vault initialized returns empty list
            val result = handle_completion("1", 0, 5)
            expect(result).to_contain("items")

    context "tag completion":
        """Completing #tags"""

        it "returns tag completion list":
            val result = handle_completion("1", 0, 1)
            expect(result).to_contain("items")
