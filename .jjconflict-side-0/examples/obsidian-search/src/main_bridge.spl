# Obsidian LSP-MCP Bridge — Entry Point
#
# Starts the LSP-MCP bridge server for Obsidian vault.
# Set OBSIDIAN_VAULT_PATH environment variable to your vault directory.
#
# Usage:
#   OBSIDIAN_VAULT_PATH=/path/to/vault simple run examples/obsidian-search/src/main_bridge.spl

use src.lsp_mcp.bridge_main.{start_bridge_server}

fn main() -> i64:
    start_bridge_server()
    0
