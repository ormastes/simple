# Maps to: AC-5, AC-9
# Run: bin/simple test test/dbfs/dbfs_recovery_spec.spl

"""
DBFS Recovery Specification

Verifies 5-step D5 recovery model using the power-cut harness:
  1. best-of-3 superblock replicas: highest gen + valid CRC wins
  2. only committed WAL records are replayed
  3. orphan arenas are reclaimed via arena_discard
  4. clean mount-generation is written after recovery
  5. partially-written superblock is rejected
"""

use std.spipe.*
use std.db.dbfs_engine.recovery.{DbfsRecovery, SuperblockReplica, RecoveryResult}
use std.db.dbfs_engine.wal.{WalRecord, WAL_RECORD_COMMIT}
use test.dbfs.power_cut_harness.{PowerCutHarness, FaultPoint}

describe "DBFS Recovery — superblock replica selection":
    """Best-of-3 replicas: highest gen with valid CRC."""

    it "picks replica with highest valid gen":
        val harness = PowerCutHarness.new()
        harness.write_replica(0, SuperblockReplica(gen: 3, crc_valid: true))
        harness.write_replica(1, SuperblockReplica(gen: 5, crc_valid: true))
        harness.write_replica(2, SuperblockReplica(gen: 4, crc_valid: true))
        val result = DbfsRecovery.recover(harness.device()).unwrap()
        expect(result.superblock_gen).to_equal(5)

    it "skips replica with invalid CRC":
        val harness = PowerCutHarness.new()
        harness.write_replica(0, SuperblockReplica(gen: 10, crc_valid: false))
        harness.write_replica(1, SuperblockReplica(gen: 3, crc_valid: true))
        harness.write_replica(2, SuperblockReplica(gen: 2, crc_valid: true))
        val result = DbfsRecovery.recover(harness.device()).unwrap()
        expect(result.superblock_gen).to_equal(3)

describe "DBFS Recovery — WAL replay":
    """Only committed records are replayed."""

    it "committed record is replayed after power-cut":
        val harness = PowerCutHarness.new()
        harness.inject_fault(FaultPoint.AfterWalFlush)
        harness.write_wal_record(WalRecord(txn_id: 1, record_type: WAL_RECORD_COMMIT, payload: "inode=42"))
        harness.mark_committed(txn_id: 1)
        val result = DbfsRecovery.recover(harness.device()).unwrap()
        expect(result.replayed_txn_ids.contains(1)).to_equal(true)

    it "uncommitted record is NOT replayed":
        val harness = PowerCutHarness.new()
        harness.inject_fault(FaultPoint.AfterWalAppend)
        harness.write_wal_record(WalRecord(txn_id: 7, record_type: WAL_RECORD_COMMIT, payload: "inode=99"))
        # txn_id 7 never got a COMMIT record
        val result = DbfsRecovery.recover(harness.device()).unwrap()
        expect(result.replayed_txn_ids.contains(7)).to_equal(false)

describe "DBFS Recovery — orphan reclamation":
    """Orphan arenas are discarded after crash."""

    it "orphan arenas are reclaimed via arena_discard":
        val harness = PowerCutHarness.new()
        harness.inject_fault(FaultPoint.AfterDataWrite)
        harness.mark_orphan_arena(arena_id: 99)
        val result = DbfsRecovery.recover(harness.device()).unwrap()
        expect(result.discarded_orphan_arena_ids.contains(99)).to_equal(true)

describe "DBFS Recovery — clean mount generation":
    """After recovery, a new clean checkpoint entry is written."""

    it "recovery writes a new clean checkpoint slot":
        val harness = PowerCutHarness.new()
        harness.inject_fault(FaultPoint.AfterWalFlush)
        val result = DbfsRecovery.recover(harness.device()).unwrap()
        expect(result.clean_mount_gen > 0).to_equal(true)

    it "mount generation increments from previous clean checkpoint":
        val harness = PowerCutHarness.new()
        harness.set_last_clean_gen(gen: 8)
        val result = DbfsRecovery.recover(harness.device()).unwrap()
        expect(result.clean_mount_gen).to_equal(9)
