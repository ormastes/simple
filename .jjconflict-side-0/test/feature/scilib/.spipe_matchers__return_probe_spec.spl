use std.testing.*
use std.ndarray.*

fn direct_make_vector() -> NDArray:
    make_f64_array([Float64.new(1.0), Float64.new(2.0)], Shape.new([Index.new(2)]))

fn pushed_vector() -> NDArray:
    var out: [Float64] = []
    out.push(Float64.new(1.0))
    out.push(Float64.new(2.0))
    array(out)

fn assigned_vector() -> NDArray:
    var out: [Float64] = []
    out.push(Float64.new(0.0))
    out.push(Float64.new(0.0))
    out[0] = Float64.new(1.0)
    out[1] = Float64.new(2.0)
    array(out)

fn assigned_make_vector() -> NDArray:
    var out: [Float64] = []
    out.push(Float64.new(0.0))
    out.push(Float64.new(0.0))
    out[0] = Float64.new(1.0)
    out[1] = Float64.new(2.0)
    make_f64_array(out, Shape.new([Index.new(2)]))

fn direct_make_matrix() -> NDArray:
    make_f64_array(
        [Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0)],
        Shape.new([Index.new(2), Index.new(2)])
    )

fn pushed_make_vector() -> NDArray:
    var out: [Float64] = []
    out.push(Float64.new(1.0))
    out.push(Float64.new(2.0))
    make_f64_array(out, Shape.new([Index.new(2)]))

fn pushed_make_matrix() -> NDArray:
    var out: [Float64] = []
    out.push(Float64.new(1.0))
    out.push(Float64.new(2.0))
    out.push(Float64.new(3.0))
    out.push(Float64.new(4.0))
    make_f64_array(out, Shape.new([Index.new(2), Index.new(2)]))

fn row_from_matrix_value(input: NDArray) -> NDArray:
    var out: [Float64] = []
    var col = 0
    while col < input.cols().value:
        out.push(input.get_f64_at([Index.new(1), Index.new(col)]))
        col = col + 1
    make_f64_array(out, Shape.new([Index.new(out.len())]))

fn flattened_rows_matrix() -> NDArray:
    var rows: [[Float64]] = []
    rows.push([Float64.new(1.0), Float64.new(2.0)])
    rows.push([Float64.new(3.0), Float64.new(4.0)])
    var flat: [Float64] = []
    var row = 0
    while row < rows.len():
        var col = 0
        while col < rows[row].len():
            flat.push(rows[row][col])
            col = col + 1
        row = row + 1
    make_f64_array(flat, Shape.new([Index.new(2), Index.new(2)]))

fn literal_rows_matrix() -> NDArray:
    var rows: [[Float64]] = []
    rows.push([Float64.new(1.0), Float64.new(2.0)])
    rows.push([Float64.new(3.0), Float64.new(4.0)])
    make_f64_array(
        [rows[0][0], rows[0][1], rows[1][0], rows[1][1]],
        Shape.new([Index.new(2), Index.new(2)])
    )

fn assigned_rows_matrix() -> NDArray:
    var rows: [[Float64]] = []
    rows.push([Float64.new(1.0), Float64.new(2.0)])
    rows.push([Float64.new(3.0), Float64.new(4.0)])
    var flat: [Float64] = []
    flat.push(Float64.new(0.0))
    flat.push(Float64.new(0.0))
    flat.push(Float64.new(0.0))
    flat.push(Float64.new(0.0))
    flat[0] = rows[0][0]
    flat[1] = rows[0][1]
    flat[2] = rows[1][0]
    flat[3] = rows[1][1]
    make_f64_array(flat, Shape.new([Index.new(2), Index.new(2)]))

fn reshape_matrix() -> NDArray:
    array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0)]).reshape(
        Shape.new([Index.new(2), Index.new(2)])
    )

fn scalar_add_free(input: NDArray, scalar: Float64) -> NDArray:
    val shape = input.shape
    var out: [Float64] = []
    var i = 0
    while i < input.len().value:
        out.push(Float64.new(0.0))
        i = i + 1
    i = 0
    while i < input.len().value:
        out[i] = Float64.new(input.get_f64(Index.new(i)).value + scalar.value)
        i = i + 1
    make_f64_array(out, shape)

fn scalar_mul_free(input: NDArray, scalar: Float64) -> NDArray:
    val shape = input.shape
    var out: [Float64] = []
    var i = 0
    while i < input.len().value:
        out.push(Float64.new(0.0))
        i = i + 1
    i = 0
    while i < input.len().value:
        out[i] = Float64.new(input.get_f64(Index.new(i)).value * scalar.value)
        i = i + 1
    make_f64_array(out, shape)

describe "ndarray return probes":
    it "direct_make_vector returns readable f64 data":
        val r = direct_make_vector()
        expect r.get_f64(Index.new(0)).value == 1.0
        expect r.get_f64(Index.new(1)).value == 2.0

    it "pushed_vector returns readable f64 data":
        val r = pushed_vector()
        expect r.get_f64(Index.new(0)).value == 1.0
        expect r.get_f64(Index.new(1)).value == 2.0

    it "assigned_vector returns readable f64 data":
        val r = assigned_vector()
        expect r.get_f64(Index.new(0)).value == 1.0
        expect r.get_f64(Index.new(1)).value == 2.0

    it "assigned_make_vector returns readable f64 data":
        val r = assigned_make_vector()
        expect r.get_f64(Index.new(0)).value == 1.0
        expect r.get_f64(Index.new(1)).value == 2.0

    it "direct_make_matrix returns readable shaped data":
        val r = direct_make_matrix()
        expect r.rows().value == 2
        expect r.cols().value == 2
        expect r.get_f64_at([Index.new(0), Index.new(0)]).value == 1.0
        expect r.get_f64_at([Index.new(1), Index.new(1)]).value == 4.0

    it "pushed_make_vector returns readable f64 data":
        val r = pushed_make_vector()
        expect r.get_f64(Index.new(0)).value == 1.0
        expect r.get_f64(Index.new(1)).value == 2.0

    it "pushed_make_matrix returns readable shaped data":
        val r = pushed_make_matrix()
        expect r.rows().value == 2
        expect r.cols().value == 2
        expect r.get_f64_at([Index.new(0), Index.new(0)]).value == 1.0
        expect r.get_f64_at([Index.new(1), Index.new(1)]).value == 4.0

    it "row_from_matrix_value returns readable row data":
        val input = direct_make_matrix()
        val r = row_from_matrix_value(input)
        expect r.get_f64(Index.new(0)).value == 3.0
        expect r.get_f64(Index.new(1)).value == 4.0

    it "flattened_rows_matrix returns readable shaped data":
        val r = flattened_rows_matrix()
        expect r.rows().value == 2
        expect r.cols().value == 2
        expect r.get_f64_at([Index.new(0), Index.new(0)]).value == 1.0
        expect r.get_f64_at([Index.new(1), Index.new(1)]).value == 4.0

    it "literal_rows_matrix returns readable shaped data":
        val r = literal_rows_matrix()
        expect r.rows().value == 2
        expect r.cols().value == 2
        expect r.get_f64_at([Index.new(0), Index.new(0)]).value == 1.0
        expect r.get_f64_at([Index.new(1), Index.new(1)]).value == 4.0

    it "assigned_rows_matrix returns readable shaped data":
        val r = assigned_rows_matrix()
        expect r.rows().value == 2
        expect r.cols().value == 2
        expect r.get_f64_at([Index.new(0), Index.new(0)]).value == 1.0
        expect r.get_f64_at([Index.new(1), Index.new(1)]).value == 4.0

    it "reshape_matrix returns readable shaped data":
        val r = reshape_matrix()
        expect r.rows().value == 2
        expect r.cols().value == 2
        expect r.get_f64_at([Index.new(0), Index.new(0)]).value == 1.0
        expect r.get_f64_at([Index.new(1), Index.new(1)]).value == 4.0

    it "scalar_add_free returns readable values":
        val input = direct_make_vector()
        val r = scalar_add_free(input, Float64.new(5.0))
        expect r.get_f64(Index.new(0)).value == 6.0
        expect r.get_f64(Index.new(1)).value == 7.0

    it "scalar_mul_free returns readable matrix values":
        val input = direct_make_matrix()
        val r = scalar_mul_free(input, Float64.new(2.0))
        expect r.get_f64_at([Index.new(0), Index.new(0)]).value == 2.0
        expect r.get_f64_at([Index.new(1), Index.new(1)]).value == 8.0

    it "method add_scalar on direct_make_vector returns readable values":
        val input = direct_make_vector()
        val r = input.add_scalar(Float64.new(5.0))
        expect r.get_f64(Index.new(0)).value == 6.0
        expect r.get_f64(Index.new(1)).value == 7.0

    it "method mul_scalar on direct_make_matrix returns readable values":
        val input = direct_make_matrix()
        val r = input.mul_scalar(Float64.new(2.0))
        expect r.get_f64_at([Index.new(0), Index.new(0)]).value == 2.0
        expect r.get_f64_at([Index.new(1), Index.new(1)]).value == 8.0

    it "local inline reshape produces readable shaped data":
        val input = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0), Float64.new(4.0)]).reshape(
            Shape.new([Index.new(2), Index.new(2)])
        )
        expect input.get_f64_at([Index.new(0), Index.new(0)]).value == 1.0
        expect input.get_f64_at([Index.new(1), Index.new(1)]).value == 4.0

    it "local inline array produces readable vector data":
        val input = array([Float64.new(1.0), Float64.new(2.0), Float64.new(3.0)])
        expect input.get_f64(Index.new(0)).value == 1.0
        expect input.get_f64(Index.new(2)).value == 3.0