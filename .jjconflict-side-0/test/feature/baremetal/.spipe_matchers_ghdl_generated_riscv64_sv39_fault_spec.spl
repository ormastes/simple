#!/usr/bin/env simple

use std.spec.*

val GENERATED_RUNNER = "src/lib/nogc_async_mut_noalloc/baremetal/ghdl_generated_rv64_sv39_fault_runner.shs"
val GENERATED_PROGRAM = "examples/09_embedded/fpga_riscv/sw/generated_rv64_sv39_fault_smoke.s"

extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_process_run_timeout(cmd: text, args: [text], timeout_ms: i64) -> (text, text, i32)

fn runner_tools_available() -> bool:
    val result = rt_process_run("bash", ["-lc", "command -v ghdl >/dev/null && command -v riscv64-linux-gnu-as >/dev/null && command -v riscv64-linux-gnu-ld >/dev/null && command -v riscv64-linux-gnu-objcopy >/dev/null"])
    result[2] == 0

describe "Generated RV64 GHDL Sv39 data page fault":
    it "sv39 fault runner exists and smoke source is present":
        expect rt_file_exists(GENERATED_RUNNER) == true
        expect rt_file_exists(GENERATED_PROGRAM) == true

    slow_it "runs a generated RV64 supervisor-mode Sv39 page fault smoke program":
        if not runner_tools_available():
            return "skip: ghdl or riscv binutils not available"
        val result = rt_process_run_timeout("bash", [GENERATED_RUNNER, GENERATED_PROGRAM, "--timeout=30"], 120000)
        val output = result[0] + result[1]
        expect result[2] == 0
        expect (output).contains("GENERATED_RV64_SV39_FAULT: PASS")
        expect (output).contains("CAUSE_WORD: 13")
        expect (output).contains("TVAL_WORD: 1073742080")