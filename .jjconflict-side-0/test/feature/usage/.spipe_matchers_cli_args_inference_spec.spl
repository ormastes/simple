"""
# CLI Args Inference Rules Specification

**Feature ID:** #CLI-008
**Category:** Language | CLI
**Status:** Draft

## Overview

Tests the type inference rules and struct shape validation for the cli keyword.
The compiler generates a typed struct from the cli block, where each field
corresponds to an option. This tests that the generated struct has the
correct shape, field names, and types.

## Syntax

```simple
cli:
    verbose: false
    output: "out.txt"
    count: 1
    rate: 0.5
    tags: ["a", "b"]

# Compiler generates:
# struct CliArgs:
#     verbose: bool
#     output: text
#     count: i64
#     rate: f64
#     tags: [text]
```

"""



# ============================================================================
# CLI Args Inference Rules
# ============================================================================

describe "CLI Args Inference Rules":
    # ## Type Inference and Struct Shape Validation
    #
    # Tests that the compiler generates correct typed structs from cli blocks.

    context "inference from literals":
        it "infers bool from boolean literal":
            # cli:
            #     flag: false
            # Generated field type should be bool
            val literal = false
            val inferred = "bool"
            expect inferred == "bool"

        it "infers text from string literal":
            # cli:
            #     name: "hello"
            # Generated field type should be text
            val literal = "hello"
            val inferred = "text"
            expect inferred == "text"

        it "infers i64 from integer literal":
            # cli:
            #     count: 42
            # Generated field type should be i64
            val literal = 42
            val inferred = "i64"
            expect inferred == "i64"

        it "infers f64 from float literal":
            # cli:
            #     rate: 3.14
            # Generated field type should be f64
            val literal = "3.14"
            val inferred = "f64"
            expect inferred == "f64"

    context "struct shape validation":
        it "generates struct with all fields":
            # cli:
            #     verbose: false
            #     output: "out.txt"
            #     count: 1
            # Generated struct should have exactly 3 fields
            val field_count = 3
            val field_names = ["verbose", "output", "count"]
            expect field_count == 3
            expect (field_names).contains("verbose")
            expect (field_names).contains("output")
            expect (field_names).contains("count")

        it "preserves field order":
            # Fields should appear in declaration order
            val fields = ["verbose", "output", "count"]
            expect fields[0] == "verbose"
            expect fields[1] == "output"
            expect fields[2] == "count"