# Test: seq tool
# Feature: TOOL-SEQ - Print number sequence
# @cover tools/shell/seq/seq_tool.spl

describe "seq tool":
    context "single argument":
        it "generates 1 to N":
            var nums: [i64] = []
            var i: i64 = 1
            while i <= 5:
                nums = nums.push(i)
                i = i + 1
            expect(nums.len()).to_equal(5)
            expect(nums[0]).to_equal(1)
            expect(nums[4]).to_equal(5)

    context "two arguments":
        it "generates FIRST to LAST":
            var nums: [i64] = []
            var i: i64 = 3
            while i <= 7:
                nums = nums.push(i)
                i = i + 1
            expect(nums.len()).to_equal(5)
            expect(nums[0]).to_equal(3)

    context "three arguments":
        it "generates with increment":
            var nums: [i64] = []
            var i: i64 = 0
            while i <= 10:
                nums = nums.push(i)
                i = i + 2
            expect(nums.len()).to_equal(6)
            expect(nums[0]).to_equal(0)
            expect(nums[5]).to_equal(10)
