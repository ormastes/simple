# Test: base64 tool
# Feature: TOOL-BASE64 - Encode/decode base64
# @cover tools/shell/base64/base64_tool.spl

describe "base64 tool":
    context "encoding":
        it "encodes empty string":
            val input = ""
            expect(input.len()).to_equal(0)

        it "produces padded output":
            # Base64 output length is always multiple of 4
            val output_len = 8
            expect(output_len % 4).to_equal(0)

    context "character set":
        it "uses standard base64 alphabet":
            val chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
            expect(chars.len()).to_equal(64)
