# Test: tr tool
# Feature: TOOL-TR - Translate or delete characters

# Local reimplementation to avoid interpreter-mode import issues
# (importing app.tools.tr.main fails with "cannot index string with type `symbol`")

fn char_code_val(ch: text) -> i64:
    """Get ASCII code of a character."""
    # Map common characters to their ASCII values
    val chars = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
    var i = 0
    while i < chars.len():
        if chars[i:i + 1] == ch:
            return 32 + i
        i = i + 1
    0

fn code_to_char(code: i64) -> text:
    """Get character from ASCII code."""
    val chars = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
    val idx = code - 32
    if idx >= 0 and idx < chars.len():
        chars[idx:idx + 1]
    else:
        ""

fn expand_set(spec: text) -> text:
    """Expand a character set specification."""
    var result = ""

    # Handle character classes
    if spec == "[:upper:]":
        return "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    elif spec == "[:lower:]":
        return "abcdefghijklmnopqrstuvwxyz"
    elif spec == "[:digit:]":
        return "0123456789"
    elif spec == "[:alpha:]":
        return "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
    elif spec == "[:alnum:]":
        return "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
    elif spec == "[:space:]":
        return " \t\n\r"

    # Handle ranges like a-z
    var i = 0
    while i < spec.len():
        if i + 2 < spec.len() and spec[i + 1:i + 2] == "-":
            val start_ch = spec[i:i + 1]
            val end_ch = spec[i + 2:i + 3]
            # Expand range
            var ch_code = char_code_val(start_ch)
            val end_code = char_code_val(end_ch)
            while ch_code <= end_code:
                result = result + code_to_char(ch_code)
                ch_code = ch_code + 1
            i = i + 3
        elif spec[i:i + 1] == "\\" and i + 1 < spec.len():
            val next = spec[i + 1:i + 2]
            if next == "n":
                result = result + "\n"
            elif next == "t":
                result = result + "\t"
            elif next == "\\":
                result = result + "\\"
            else:
                result = result + next
            i = i + 2
        else:
            result = result + spec[i:i + 1]
            i = i + 1

    result

describe "tr tool":
    context "set expansion":
        it "expands upper class":
            val result = expand_set("[:upper:]")
            expect(result).to_equal("ABCDEFGHIJKLMNOPQRSTUVWXYZ")

        it "expands lower class":
            val result = expand_set("[:lower:]")
            expect(result).to_equal("abcdefghijklmnopqrstuvwxyz")

        it "expands digit class":
            val result = expand_set("[:digit:]")
            expect(result).to_equal("0123456789")

        it "passes through literal characters":
            val result = expand_set("abc")
            expect(result).to_equal("abc")

    context "char code conversion":
        it "gets code for letter a":
            val code = char_code_val("a")
            expect(code).to_equal(97)

        it "gets code for letter A":
            val code = char_code_val("A")
            expect(code).to_equal(65)

        it "converts code back to char":
            val ch = code_to_char(97)
            expect(ch).to_equal("a")
