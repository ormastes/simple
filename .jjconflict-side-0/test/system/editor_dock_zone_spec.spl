# editor_dock_zone_spec
#
# Phase 2: Dock zones and formalized status bar.
# Verifies dock panel layout, status bar state, and session integration.

use std.spec

extern fn rt_file_read_text(path: text) -> text

fn read_text(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "dock zone — constants and structs":

    it "defines dock zone constants":
        val src = read_text("src/lib/editor/view/dock_zone.spl")
        expect(src.contains("val DOCK_LEFT: i64 = 0")).to_equal(true)
        expect(src.contains("val DOCK_RIGHT: i64 = 1")).to_equal(true)
        expect(src.contains("val DOCK_BOTTOM: i64 = 2")).to_equal(true)

    it "defines DockPanel struct":
        val src = read_text("src/lib/editor/view/dock_zone.spl")
        expect(src.contains("struct DockPanel:")).to_equal(true)
        expect(src.contains("id: text")).to_equal(true)
        expect(src.contains("label: text")).to_equal(true)
        expect(src.contains("zone: i64")).to_equal(true)
        expect(src.contains("icon: text")).to_equal(true)

    it "defines DockZoneLayout class":
        val src = read_text("src/lib/editor/view/dock_zone.spl")
        expect(src.contains("class DockZoneLayout:")).to_equal(true)
        expect(src.contains("panels: [DockPanel]")).to_equal(true)
        expect(src.contains("left_width: i64")).to_equal(true)
        expect(src.contains("right_width: i64")).to_equal(true)
        expect(src.contains("bottom_height: i64")).to_equal(true)
        expect(src.contains("left_visible: bool")).to_equal(true)
        expect(src.contains("right_visible: bool")).to_equal(true)
        expect(src.contains("bottom_visible: bool")).to_equal(true)
        expect(src.contains("active_left: text")).to_equal(true)
        expect(src.contains("active_right: text")).to_equal(true)
        expect(src.contains("active_bottom: text")).to_equal(true)

describe "dock zone — mutations":

    it "has toggle method":
        val src = read_text("src/lib/editor/view/dock_zone.spl")
        expect(src.contains("me toggle(zone: i64)")).to_equal(true)

    it "has set_active method":
        val src = read_text("src/lib/editor/view/dock_zone.spl")
        expect(src.contains("me set_active(zone: i64, panel_id: text)")).to_equal(true)

    it "has resize_zone method with clamping":
        val src = read_text("src/lib/editor/view/dock_zone.spl")
        expect(src.contains("me resize_zone(zone: i64, delta: i64)")).to_equal(true)

    it "has add_panel and remove_panel":
        val src = read_text("src/lib/editor/view/dock_zone.spl")
        expect(src.contains("me add_panel(panel: DockPanel)")).to_equal(true)
        expect(src.contains("me remove_panel(panel_id: text)")).to_equal(true)

describe "dock zone — queries":

    it "has compute_editor_rect":
        val src = read_text("src/lib/editor/view/dock_zone.spl")
        expect(src.contains("fn compute_editor_rect(total_w: i64, total_h: i64, tab_bar_h: i64, status_h: i64) -> SplitRect")).to_equal(true)

    it "has panel_count and visible_panels_in":
        val src = read_text("src/lib/editor/view/dock_zone.spl")
        expect(src.contains("fn panel_count() -> i64")).to_equal(true)
        expect(src.contains("fn visible_panels_in(zone: i64) -> [DockPanel]")).to_equal(true)

    it "has factory functions":
        val src = read_text("src/lib/editor/view/dock_zone.spl")
        expect(src.contains("fn dock_zone_layout_new() -> DockZoneLayout")).to_equal(true)
        expect(src.contains("fn dock_zone_layout_default() -> DockZoneLayout")).to_equal(true)

describe "status bar — struct and functions":

    it "defines StatusBarState struct":
        val src = read_text("src/lib/editor/view/status_bar.spl")
        expect(src.contains("struct StatusBarState:")).to_equal(true)
        expect(src.contains("mode: text")).to_equal(true)
        expect(src.contains("file_path: text")).to_equal(true)
        expect(src.contains("dirty: bool")).to_equal(true)
        expect(src.contains("cursor_row: i64")).to_equal(true)
        expect(src.contains("cursor_col: i64")).to_equal(true)
        expect(src.contains("line_count: i64")).to_equal(true)
        expect(src.contains("language_id: text")).to_equal(true)
        expect(src.contains("encoding: text")).to_equal(true)
        expect(src.contains("diagnostics_error_count: i64")).to_equal(true)
        expect(src.contains("diagnostics_warn_count: i64")).to_equal(true)
        expect(src.contains("git_branch: text")).to_equal(true)
        expect(src.contains("message: text")).to_equal(true)

    it "has status_bar_from_session":
        val src = read_text("src/lib/editor/view/status_bar.spl")
        expect(src.contains("fn status_bar_from_session(session: EditSession) -> StatusBarState")).to_equal(true)

    it "has status_bar_render_tui":
        val src = read_text("src/lib/editor/view/status_bar.spl")
        expect(src.contains("fn status_bar_render_tui(state: StatusBarState, width: i64) -> text")).to_equal(true)

    it "has status_bar_render_html":
        val src = read_text("src/lib/editor/view/status_bar.spl")
        expect(src.contains("fn status_bar_render_html(state: StatusBarState) -> text")).to_equal(true)

describe "session — dock layout integration":

    it "has dock_layout field on EditSession":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("dock_layout: DockZoneLayout")).to_equal(true)

    it "initializes dock_layout with default in constructor":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("dock_zone_layout_default()")).to_equal(true)
