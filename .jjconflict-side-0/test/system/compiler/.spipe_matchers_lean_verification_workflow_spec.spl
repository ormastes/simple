use std.spipe.*
use verification.lean.codegen as codegen
use verification.lean.runner as runner

describe "Lean Verification Workflow":
    context "Code generation":
        it "assembles Lean codegen state":
            val temp_root = "/tmp/simple-lean-verification-system"

            opts = codegen.LeanCodegenOptions.new()
            opts = opts.with_module_name("SystemDemo")
            opts = opts.with_output_dir(temp_root)
            opts = opts.with_stubs(false)

            gen = codegen.LeanCodegen.new(opts)

            func = codegen.LeanFunction.new("system_demo")
            func = func.add_param("x", "Int")
            func = func.with_return_type("Int")
            func = func.with_body("x")
            gen = gen.add_function(func)

            thm = codegen.LeanTheorem.new("system_demo_nonnegative", "system_demo x >= 0")
            thm = thm.add_param("x", "Int")
            gen = gen.add_theorem(thm)

            expect gen.options.module_name == "SystemDemo"
            expect gen.options.output_dir == temp_root
            expect gen.functions.len() == 1
            expect gen.theorems.len() == 1
            expect gen.functions[0].name == "system_demo"
            expect gen.theorems[0].name == "system_demo_nonnegative"

    context "Summary reporting":
        it "formats a mixed proof summary":
            val proven = runner.LeanCheckResult(
                file: "src/verification/proven.lean",
                success: true,
                stdout: "goals accomplished",
                stderr: "",
                goals_solved: 1,
                goals_remaining: 0,
                exit_code: Some(0)
            )
            val pending = runner.LeanCheckResult(
                file: "src/verification/pending.lean",
                success: true,
                stdout: "sorry",
                stderr: "",
                goals_solved: 0,
                goals_remaining: 2,
                exit_code: Some(0)
            )

            val summary = runner.VerificationSummary.from_results([proven, pending])
            expect summary.files_checked == 2
            expect summary.files_passed == 2
            expect summary.files_failed == 0
            expect summary.total_theorems == 3
            expect summary.proven_theorems == 1
            expect summary.unproven_theorems == 2
            expect summary.is_success() == true
            expect summary.is_fully_proven() == false
            expect (summary.format()).contains("Files: 2/2 passed")
            expect (summary.format()).contains("Theorems: 1/3 proven")
            expect (summary.format()).contains("Admitted (sorry): 2")