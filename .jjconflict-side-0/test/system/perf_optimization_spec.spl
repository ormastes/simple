# Performance Optimization - System Spec
#
# @cover src/lib/common/collections/persistent_dict.spl 80%
# @cover src/lib/common/collections/persistent_vec.spl 80%
# @cover src/lib/nogc_sync_mut/src/map.spl 60%
# @cover src/compiler/10.frontend/core/interpreter/hashmap.spl 90%
# @cover src/compiler/60.mir_opt/mir_opt/mod.spl 50%

use sspec.*

describe "PersistentDict hash-bucketed performance":
    it "should handle 1000 insertions without degradation":
        var dict = PersistentDict.empty()
        var i = 0
        while i < 1000:
            dict = dict.set("key_{i}", i)
            i = i + 1
        expect(dict.len()).to_equal(1000)

    it "should retrieve keys from a large dict correctly":
        var dict = PersistentDict.empty()
        var i = 0
        while i < 500:
            dict = dict.set("item_{i}", i * 10)
            i = i + 1
        expect(dict.get("item_0")).to_equal(0)
        expect(dict.get("item_250")).to_equal(2500)
        expect(dict.get("item_499")).to_equal(4990)
        expect(dict.get("nonexistent")).to_equal(nil)

    it "should maintain structural sharing on single-key mutation":
        var dict = PersistentDict.empty()
        var i = 0
        while i < 100:
            dict = dict.set("k_{i}", i)
            i = i + 1
        val dict2 = dict.set("k_50", 999)
        # Original unchanged
        expect(dict.get("k_50")).to_equal(50)
        # New dict has update
        expect(dict2.get("k_50")).to_equal(999)
        # Both have same size
        expect(dict.len()).to_equal(100)
        expect(dict2.len()).to_equal(100)

    it "should remove keys correctly":
        var dict = PersistentDict.empty()
        dict = dict.set("a", 1)
        dict = dict.set("b", 2)
        dict = dict.set("c", 3)
        val dict2 = dict.remove("b")
        expect(dict2.len()).to_equal(2)
        expect(dict2.get("a")).to_equal(1)
        expect(dict2.get("b")).to_equal(nil)
        expect(dict2.get("c")).to_equal(3)

    it "should support merge of two dicts":
        var d1 = PersistentDict.empty()
        d1 = d1.set("x", 1)
        d1 = d1.set("y", 2)
        var d2 = PersistentDict.empty()
        d2 = d2.set("y", 99)
        d2 = d2.set("z", 3)
        val merged = d1.merge(d2)
        expect(merged.len()).to_equal(3)
        expect(merged.get("x")).to_equal(1)
        expect(merged.get("y")).to_equal(99)
        expect(merged.get("z")).to_equal(3)

describe "PersistentVec chunked performance":
    it "should handle 1000 pushes":
        var vec = PersistentVec.empty()
        var i = 0
        while i < 1000:
            vec = vec.push(i)
            i = i + 1
        expect(vec.len()).to_equal(1000)

    it "should index correctly across chunk boundaries":
        var vec = PersistentVec.empty()
        var i = 0
        while i < 100:
            vec = vec.push(i * 3)
            i = i + 1
        expect(vec.get(0)).to_equal(0)
        expect(vec.get(31)).to_equal(93)
        expect(vec.get(32)).to_equal(96)
        expect(vec.get(99)).to_equal(297)

    it "should pop from chunked vec":
        var vec = PersistentVec.empty()
        var i = 0
        while i < 50:
            vec = vec.push(i)
            i = i + 1
        val vec2 = vec.pop()
        expect(vec2.len()).to_equal(49)
        expect(vec2.last()).to_equal(48)
        expect(vec.len()).to_equal(50)

    it "should set values correctly across chunks":
        var vec = PersistentVec.empty()
        var i = 0
        while i < 64:
            vec = vec.push(0)
            i = i + 1
        val vec2 = vec.set(33, 999)
        expect(vec2.get(33)).to_equal(999)
        expect(vec.get(33)).to_equal(0)

describe "Map hash-first comparison":
    it "should handle negative hash values without crash":
        # Keys that might produce negative hashes
        var map = Map.new()
        map.insert("very_long_key_name_that_might_overflow", 1)
        map.insert("another_potentially_negative_hash_key", 2)
        expect(map.len()).to_equal(2)
        match map.get("very_long_key_name_that_might_overflow"):
            Some(v): expect(v).to_equal(1)
            nil: expect(true).to_equal(false)

describe "MIR optimization pipeline":
    it "should include GVN and TCO in Speed pipeline":
        # Verify pass registration (structural check)
        val pipeline = optimizationpipeline_for_level(OptLevel.Speed)
        var has_gvn = false
        var has_tco = false
        for pass_name in pipeline.passes:
            if pass_name == "global_value_numbering":
                has_gvn = true
            if pass_name == "tail_call_optimization":
                has_tco = true
        expect(has_gvn).to_equal(true)
        expect(has_tco).to_equal(true)

    it "should include GVN and TCO in Aggressive pipeline":
        val pipeline = optimizationpipeline_for_level(OptLevel.Aggressive)
        var has_gvn = false
        var has_tco = false
        for pass_name in pipeline.passes:
            if pass_name == "global_value_numbering":
                has_gvn = true
            if pass_name == "tail_call_optimization":
                has_tco = true
        expect(has_gvn).to_equal(true)
        expect(has_tco).to_equal(true)
