# simple_lsp_protocol_live_spec
#
# Verifies the editor's configured Simple LSP stdio server surface.

use std.spec

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

describe "Simple LSP live protocol smoke":

    it "responds to initialize, didOpen, completion, definition, codeAction, and shutdown":
        val result = rt_process_run("python3", ["scripts/simple_lsp_protocol_smoke.py"])
        expect(result.2).to_equal(0)
        expect(result.0).to_contain("STATUS: PASS simple_lsp_protocol_smoke")
