# LLM Dashboard TUI Smoke Test (runs in interpreter mode)
#
# Tests that the TUI dashboard starts, handles keys, and exits cleanly.
# Run: bin/simple run test/system/llm_dashboard_tui_smoke.spl

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn dash_cmd(keys: text, delay: i64) -> text:
    """Build command that sends keys to dashboard after delay."""
    val tout = delay + 8
    return "(sleep {delay} && printf '{keys}') | timeout {tout} bin/simple run src/app/llm_dashboard/main.spl 2>/dev/null | cat"

fn main():
    var passed = 0
    var failed = 0

    print "=== LLM Dashboard TUI Smoke Tests ==="

    # Test 1: Quit on 'q'
    print "[1] quit on q"
    val (out1, _, c1) = rt_process_run("/bin/bash", ["-c", dash_cmd("q", 1)])
    if c1 == 0:
        print "  ok: exit 0"
        passed = passed + 1
    else:
        print "  FAIL: exit {c1}"
        failed = failed + 1

    # Test 2: Tab switch then quit
    print "[2] tab + quit"
    val (_, _, c2) = rt_process_run("/bin/bash", ["-c", dash_cmd("2q", 1)])
    if c2 == 0:
        print "  ok: exit 0"
        passed = passed + 1
    else:
        print "  FAIL: exit {c2}"
        failed = failed + 1

    # Test 3: Many rapid keys then quit
    print "[3] rapid keys"
    val (_, _, c3) = rt_process_run("/bin/bash", ["-c", dash_cmd("123456jjkkrcq", 1)])
    if c3 == 0:
        print "  ok: exit 0"
        passed = passed + 1
    else:
        print "  FAIL: exit {c3}"
        failed = failed + 1

    # Test 4: Produces output (screen rendering)
    print "[4] produces output"
    if out1.len() > 0:
        print "  ok: {out1.len()} bytes rendered"
        passed = passed + 1
    else:
        print "  FAIL: no output"
        failed = failed + 1

    print ""
    print "=== Results: {passed}/{passed + failed} passed ==="
    if failed == 0:
        print "ALL TESTS PASSED"
