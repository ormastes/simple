# editor_session_spec
#
# Phase 2: Multi-buffer document model and tabs.
# Verifies document, session, tab, group, and layout.

use std.spec

extern fn rt_file_read_text(path: text) -> text

fn read_text(path: text) -> text:
    rt_file_read_text(path) ?? ""

describe "editor document — metadata":

    it "defines EditorDocumentId with value":
        val src = read_text("src/lib/editor/20.core/document.spl")
        expect(src.contains("class EditorDocumentId:")).to_equal(true)
        expect(src.contains("value: i64")).to_equal(true)

    it "defines EditorDocument with buffer and language_id":
        val src = read_text("src/lib/editor/20.core/document.spl")
        expect(src.contains("class EditorDocument:")).to_equal(true)
        expect(src.contains("buffer: EditorBuffer")).to_equal(true)
        expect(src.contains("language_id: text")).to_equal(true)
        expect(src.contains("encoding: text")).to_equal(true)
        expect(src.contains("line_ending: text")).to_equal(true)

    it "has from_buffer and open_file constructors":
        val src = read_text("src/lib/editor/20.core/document.spl")
        expect(src.contains("static fn from_buffer(id: EditorDocumentId, buffer: EditorBuffer) -> EditorDocument")).to_equal(true)
        expect(src.contains("static fn open_file(doc_id: EditorDocumentId, buf_id: EditorBufferId, path: text) -> EditorDocument")).to_equal(true)

    it "detects language from file extension":
        val src = read_text("src/lib/editor/20.core/document.spl")
        expect(src.contains("fn _doc_detect_language(path: text) -> text")).to_equal(true)
        expect(src.contains(".spl")).to_equal(true)
        expect(src.contains("\"simple\"")).to_equal(true)
        expect(src.contains("\"markdown\"")).to_equal(true)

    it "provides display_name from path basename":
        val src = read_text("src/lib/editor/20.core/document.spl")
        expect(src.contains("fn display_name() -> text")).to_equal(true)
        expect(src.contains("[No Name]")).to_equal(true)

describe "editor tab — tab and group":

    it "defines EditorTab with doc_id reference":
        val src = read_text("src/lib/editor/30.view/tab.spl")
        expect(src.contains("struct EditorTab:")).to_equal(true)
        expect(src.contains("doc_id: EditorDocumentId")).to_equal(true)
        expect(src.contains("label: text")).to_equal(true)
        expect(src.contains("is_preview: bool")).to_equal(true)

    it "defines EditorGroup with tabs list":
        val src = read_text("src/lib/editor/30.view/tab.spl")
        expect(src.contains("struct EditorGroup:")).to_equal(true)
        expect(src.contains("tabs: [EditorTab]")).to_equal(true)
        expect(src.contains("active_tab_index: i64")).to_equal(true)

    it "has add_tab that reuses existing doc tab":
        val src = read_text("src/lib/editor/30.view/tab.spl")
        expect(src.contains("me add_tab(tab: EditorTab)")).to_equal(true)
        expect(src.contains("self.tabs[i].doc_id.value == tab.doc_id.value")).to_equal(true)

    it "has close_tab, select_tab, next_tab, prev_tab":
        val src = read_text("src/lib/editor/30.view/tab.spl")
        expect(src.contains("me close_tab(index: i64)")).to_equal(true)
        expect(src.contains("me select_tab(index: i64)")).to_equal(true)
        expect(src.contains("me next_tab()")).to_equal(true)
        expect(src.contains("me prev_tab()")).to_equal(true)

describe "editor layout — split panes":

    it "defines EditorLayout struct":
        val src = read_text("src/lib/editor/30.view/layout.spl")
        expect(src.contains("struct EditorLayout:")).to_equal(true)
        expect(src.contains("groups: [EditorGroup]")).to_equal(true)
        expect(src.contains("active_group_index: i64")).to_equal(true)
        expect(src.contains("split_direction: text")).to_equal(true)

    it "creates default layout with one group":
        val src = read_text("src/lib/editor/30.view/layout.spl")
        expect(src.contains("fn editor_layout_new() -> EditorLayout")).to_equal(true)

    it "supports split and close operations":
        val src = read_text("src/lib/editor/30.view/layout.spl")
        expect(src.contains("fn editor_layout_split(layout: EditorLayout, next_group_id: i64) -> EditorLayout")).to_equal(true)
        expect(src.contains("fn editor_layout_close_group(layout: EditorLayout, index: i64) -> EditorLayout")).to_equal(true)

    it "supports focus navigation between groups":
        val src = read_text("src/lib/editor/30.view/layout.spl")
        expect(src.contains("fn editor_layout_focus_next(layout: EditorLayout) -> EditorLayout")).to_equal(true)
        expect(src.contains("fn editor_layout_focus_prev(layout: EditorLayout) -> EditorLayout")).to_equal(true)
        expect(src.contains("fn editor_layout_focus_group(layout: EditorLayout, index: i64) -> EditorLayout")).to_equal(true)

    it "provides group count and active group access":
        val src = read_text("src/lib/editor/30.view/layout.spl")
        expect(src.contains("fn editor_layout_group_count(layout: EditorLayout) -> i64")).to_equal(true)
        expect(src.contains("fn editor_layout_active_group(layout: EditorLayout) -> EditorGroup")).to_equal(true)

describe "edit session — central state":

    it "defines EditSession class":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("class EditSession:")).to_equal(true)
        expect(src.contains("documents: [EditorDocument]")).to_equal(true)
        expect(src.contains("layout: EditorLayout")).to_equal(true)
        expect(src.contains("mode: EditorMode")).to_equal(true)

    it "has static new constructor":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("static fn new() -> EditSession")).to_equal(true)

    it "has open_file that avoids duplicates":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("me open_file(path: text) -> EditorDocumentId")).to_equal(true)
        expect(src.contains("self.documents[i].path() == path")).to_equal(true)

    it "has open_empty for new documents":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("me open_empty() -> EditorDocumentId")).to_equal(true)

    it "has close_tab and save_active":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("me close_tab()")).to_equal(true)
        expect(src.contains("me save_active() -> bool")).to_equal(true)

    it "has switch_tab with delta":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("me switch_tab(delta: i64)")).to_equal(true)

    it "has split_editor creating new group":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("me split_editor()")).to_equal(true)
        expect(src.contains("editor_layout_split")).to_equal(true)

    it "has focus_next_group and focus_prev_group":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("me focus_next_group()")).to_equal(true)
        expect(src.contains("me focus_prev_group()")).to_equal(true)

    it "provides active_document and active_buffer accessors":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("fn active_document() -> EditorDocument")).to_equal(true)
        expect(src.contains("fn active_buffer() -> EditorBuffer")).to_equal(true)
        expect(src.contains("fn active_doc_id() -> EditorDocumentId")).to_equal(true)

    it "tracks ID generation for docs, buffers, tabs, groups":
        val src = read_text("src/lib/editor/20.core/session.spl")
        expect(src.contains("next_doc_id: i64")).to_equal(true)
        expect(src.contains("next_buf_id: i64")).to_equal(true)
        expect(src.contains("next_tab_id: i64")).to_equal(true)
        expect(src.contains("next_group_id: i64")).to_equal(true)
