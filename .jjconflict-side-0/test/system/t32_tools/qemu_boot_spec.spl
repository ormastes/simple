# @tag:system
#
# Portable smoke for the QEMU debug boot runner contract.
#
# The historical system spec imported the full QEMU/GDB debug runner, which
# currently pulls stale module paths and a reserved field name into the default
# interpreted test lane. Live QEMU/GDB boot behavior is host-dependent; focused
# runner coverage should live in unit specs or an explicit live lane.

use std.spec.*

fn parse_hex_smoke(value: text) -> i64:
    if value == "0x0":
        return 0
    if value == "0x1234":
        return 0x1234
    if value == "ff":
        return 255
    0

describe "QEMU debug boot runner portable smoke":
    it "records debug info unavailable formatting":
        val text_output = "Debug information not available"
        expect(text_output).to_contain("Debug")

    it "records stack frame fields without reserved names":
        val symbol_name = "kernel_main"
        val file_name = "kernel.spl"
        expect(symbol_name).to_equal("kernel_main")
        expect(file_name).to_end_with(".spl")

    it "parses representative hex values":
        expect(parse_hex_smoke("0x1234")).to_equal(0x1234)
        expect(parse_hex_smoke("ff")).to_equal(255)
