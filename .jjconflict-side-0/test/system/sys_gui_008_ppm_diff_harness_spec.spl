# @tag:system
# @tag:sys-gui-008
#
# System spec — SYS-GUI-008 Round-3: PPM diff harness for
#               framebuffer↔virtio-gpu parity gate
#               (Row 4 of doc/03_plan/gui_drawing_layer_variations.md)
#
# Round-3 implemented (2026-04-15):
#   Phase 2+3: capture virtio-gpu scanout via QMP + commit baseline PPM
#   Phase 4:   cross-lane diff vs sys-gui-006 framebuffer baseline (≤1%)
#
# Prerequisites (both cleared):
#   (a) sys-gui-006 LIVE-GREEN — framebuffer baseline committed ✅
#   (b) virtio_gpu.spl DECODE_INT ram_write bug fixed (commit 3ab3ffeee9dd) ✅
#
# Five-phase rollout:
#   Phase 1 — scaffold (prior file, replaced)
#   Phase 2 — wire capture_qemu_vm + QMP screendump path         ← implemented here
#   Phase 3 — commit virtio baseline PPM via UPDATE_BASELINE=1   ← self-heal in Phase 2 it{}
#   Phase 4 — cross-lane diff vs. sys-gui-006 framebuffer PPM    ← implemented here
#   Phase 5 — CI gate + wall-clock budget (future)
#
# References:
#   - Round-3 plan:      doc/08_tracking/todo/sys_gui_008_round3_ppm_diff_plan_2026-04-15.md
#   - Long-form tracker: doc/08_tracking/todo/sys_gui_008_virtio_gpu_qemu.md
#   - QMP capture:       src/os/compositor/qemu_capture.spl
#   - Template spec:     test/system/simpleos_desktop_framebuffer_spec.spl
#   - Round-1/2 spec:    test/system/sys_gui_008_virtio_gpu_baseline_spec.spl

use std.spec.*

use os.kernel.arch.arch_context.{Architecture}
use os.qemu_runner.{OsTarget, build_os}
use os.compositor.qemu_capture.{capture_qemu_vm}
use os.compositor.screenshot_compare.{ComparisonResult, compare_with_profile}
use os.compositor.tolerance_profile.{ToleranceProfile, profile_wm_default}
use std.common.image.ppm_decode.{decode_ppm_to_argb, PpmImage}
use std.nogc_sync_mut.ffi.io.{file_read_bytes, file_write_bytes, dir_create_all}

use test.qemu.os.common.qemu_os_harness.{
    can_run_target, file_exists, spawn_guest_with_qmp, stop_guest,
    wait_for_serial_marker}

extern fn rt_get_cwd() -> text

# ===========================================================================
# Helpers — mirrors sys_gui_008_virtio_gpu_baseline_spec._virtio_gpu_target
# ===========================================================================

fn _virtio_gpu_target() -> OsTarget:
    OsTarget(
        arch: Architecture.X86_64,
        entry: "examples/simple_os/arch/x86_64/sys_gui_008_entry.spl",
        linker_script: "examples/simple_os/arch/x86_64/linker.ld",
        target_triple: "x86_64-unknown-none",
        output: "build/os/simpleos_sys_gui_008_x86_64.elf",
        qemu_system: "qemu-system-x86_64",
        qemu_machine: "q35",
        qemu_cpu: "qemu64",
        qemu_memory: "512M",
        qemu_bios: "",
        qemu_extra: [
            "-device", "virtio-gpu,disable-modern=on,disable-legacy=off",
            "-vga", "none",
            "-device", "isa-debug-exit,iobase=0xf4,iosize=0x04"
        ],
        gui_mode: false
    )

fn _build_once(target: OsTarget) -> bool:
    if file_exists(target.output):
        true
    else:
        build_os(target)

# ===========================================================================
# Spec
# ===========================================================================

describe "SYS-GUI-008 PPM-diff harness (Round-3)":
    """Round-3 PPM-diff harness for virtio-gpu framebuffer parity.

    Phase 2+3: captures virtio-gpu scanout via QMP and commits baseline.
    Phase 4: cross-lane diff against sys-gui-006 framebuffer baseline at ≤1%
    perceptual drift. Prerequisites: sys-gui-006 LIVE-GREEN ✅ and
    virtio_gpu.spl DECODE_INT fix ✅ (commit 3ab3ffeee9dd).

    See doc/08_tracking/todo/sys_gui_008_round3_ppm_diff_plan_2026-04-15.md."""

    it "captures virtio-gpu scanout via QMP screendump and commits baseline PPM":
        """Phase 2+3: spawn QEMU with virtio-gpu, gate on render-ready marker,
        capture PPM via QMP, then self-heal or compare against committed baseline."""
        val target = _virtio_gpu_target()
        val built = _build_once(target)
        if not built:
            print "[sys_gui_008_diff] build failed"
            expect(built).to_equal(true)
            return

        if not can_run_target(target):
            print "[sys_gui_008_diff] qemu-system-x86_64 not available, skipping"
            expect(true).to_equal(true)
            return

        val qmp_socket = "/tmp/sys_gui_008_diff_qmp.sock"
        val serial_log = "build/os/sys_gui_008_diff_serial.log"
        val cwd = rt_get_cwd()
        val baseline_dir = "test/baselines/simpleos_desktop_virtio_gpu"
        val baseline_path = "{cwd}/{baseline_dir}/desktop_scene.ppm"
        val capture_path = "{cwd}/build/os/sys_gui_008_virtio_capture.ppm"

        dir_create_all("build/os")
        dir_create_all(baseline_dir)

        match spawn_guest_with_qmp(target, qmp_socket, serial_log):
            Ok(handle):
                val saw_ready = wait_for_serial_marker(
                    handle, "[sys-gui-008] render-ready", 60000)
                if not saw_ready:
                    print "[sys_gui_008_diff] render-ready not seen within 60s"
                    stop_guest(handle)
                    expect(saw_ready).to_equal(true)
                    return

                val result = capture_qemu_vm(qmp_socket, capture_path)
                if not result.success:
                    print "[sys_gui_008_diff] QMP screendump failed: {result.error}"
                    stop_guest(handle)
                    expect(result.success).to_equal(true)
                    return

                stop_guest(handle)

                if not file_exists(baseline_path):
                    val raw = file_read_bytes(capture_path)
                    val wrote = file_write_bytes(baseline_path, raw)
                    print "[sys_gui_008_diff] baseline committed: {baseline_path}"
                    expect(wrote).to_equal(true)
                    return

                val base_raw = file_read_bytes(baseline_path)
                match decode_ppm_to_argb(base_raw):
                    Ok(img):
                        val profile = profile_wm_default()
                        val cmp = compare_with_profile(
                            result.pixels, img.pixels, result.width, result.height, profile)
                        val pct_whole = cmp.match_percentage / 100
                        val pct_frac = cmp.match_percentage % 100
                        print "[sys_gui_008_diff] virtio baseline match: {pct_whole}.{pct_frac}%"
                        expect(cmp.match_percentage >= 9900).to_equal(true)
                    Err(msg):
                        print "[sys_gui_008_diff] failed to decode baseline: {msg}"
                        expect(false).to_equal(true)
            Err(err):
                print "[sys_gui_008_diff] failed to spawn guest: {err}"
                expect(false).to_equal(true)

    it "diffs virtio-gpu baseline PPM against sys-gui-006 framebuffer PPM at ≤1% perceptual drift":
        """Phase 4: cross-lane diff between virtio-gpu and framebuffer baselines.
        Skips gracefully if virtio baseline not yet committed (run Phase 2+3 first).
        Asserts ≤1% perceptual drift (match_percentage >= 9900)."""
        val virtio_ppm = "test/baselines/simpleos_desktop_virtio_gpu/desktop_scene.ppm"
        val fb_ppm = "test/baselines/simpleos_desktop_framebuffer/desktop_scene.ppm"

        if not file_exists(virtio_ppm):
            print "[sys_gui_008_diff] virtio baseline not yet committed — run Phase 2+3 first"
            expect(true).to_equal(true)
            return

        val virtio_raw = file_read_bytes(virtio_ppm)
        val fb_raw = file_read_bytes(fb_ppm)

        match decode_ppm_to_argb(virtio_raw):
            Ok(vi):
                match decode_ppm_to_argb(fb_raw):
                    Ok(fi):
                        val profile = profile_wm_default()
                        val cmp = compare_with_profile(
                            vi.pixels, fi.pixels, vi.width, vi.height, profile)
                        val pct_whole = cmp.match_percentage / 100
                        val pct_frac = cmp.match_percentage % 100
                        print "[sys_gui_008_diff] cross-lane match: {pct_whole}.{pct_frac}%"
                        expect(cmp.match_percentage >= 9900).to_equal(true)
                    Err(msg):
                        print "[sys_gui_008_diff] failed to decode framebuffer baseline: {msg}"
                        expect(false).to_equal(true)
            Err(msg):
                print "[sys_gui_008_diff] failed to decode virtio baseline: {msg}"
                expect(false).to_equal(true)
