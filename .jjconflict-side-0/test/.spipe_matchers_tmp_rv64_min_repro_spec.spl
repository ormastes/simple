use std.spec
use hardware.rv64gc.core.rv64_regfile.Rv64RegFile
use hardware.rv64gc.core.rv64_execute.alu_execute
use hardware.rv64gc.core.rv64_decode.*
use hardware.riscv_common.pkg.riscv_types_pkg.AluOp

describe "rv64 min repro":
    it "rf direct write":
        var rf = Rv64RegFile.create()
        rf.write(10, 42)
        expect rf.read(10) == 42

    it "rf variable write":
        var rf = Rv64RegFile.create()
        val idx: i64 = 10
        rf.write(idx, 42)
        expect rf.read(10) == 42

    it "array literal index":
        val hello: [i64] = [0x48, 0x65, 0x6C, 0x6C, 0x6F]
        expect hello[0] == 0x48
        expect hello[4] == 0x6F

    it "array variable index":
        val hello: [i64] = [0x48, 0x65, 0x6C, 0x6C, 0x6F]
        val idx: i64 = 0
        expect hello[idx] == 0x48

    it "array mutable variable index":
        val hello: [i64] = [0x48, 0x65, 0x6C, 0x6C, 0x6F]
        var idx: i64 = 0
        expect hello[idx] == 0x48

    it "rf nested decode write":
        var rf = Rv64RegFile.create()
        val instr: i64 = 0x02A00513
        val rd = decode_rd(instr)
        val rs1_idx = decode_rs1(instr)
        val rs1_val = rf.read(rs1_idx)
        val imm = decode_imm_i(instr)
        val result = alu_execute(AluOp.Add, rs1_val, imm)
        rf.write(rd, result)
        expect rf.read(10) == 42

    it "rf decoded indices individually":
        var rf = Rv64RegFile.create()
        val instr: i64 = 0x02A00513
        val rd = decode_rd(instr)
        val rs1 = decode_rs1(instr)
        val imm = decode_imm_i(instr)
        expect rd == 10
        expect rs1 == 0
        expect imm == 42
        expect rf.read(rs1) == 0
        rf.write(rd, 42)
        expect rf.read(10) == 42

    it "rf nested call sites only":
        var rf = Rv64RegFile.create()
        val instr: i64 = 0x02A00513
        rf.write(decode_rd(instr), 42)
        expect rf.read(decode_rd(instr)) == 42

    it "rf decode write normalized":
        var rf = Rv64RegFile.create()
        val instr: i64 = 0x02A00513
        val idx = decode_rd(instr) + 0
        rf.write(idx, 42)
        expect rf.read(10) == 42

    it "array concat index":
        var uart_buffer: [i64] = []
        val hello: [i64] = [0x48, 0x65, 0x6C, 0x6C, 0x6F]
        var i = 0
        while i < hello.len():
            uart_buffer = uart_buffer + [hello[i]]
            i = i + 1
        expect uart_buffer.len() == 5
        expect uart_buffer[0] == 0x48

    it "array concat constant":
        var uart_buffer: [i64] = []
        uart_buffer = uart_buffer + [0x48]
        expect uart_buffer.len() == 1
        expect uart_buffer[0] == 0x48

    it "array concat variable":
        var uart_buffer: [i64] = []
        val ch: i64 = 0x48
        uart_buffer = uart_buffer + [ch]
        expect uart_buffer.len() == 1
        expect uart_buffer[0] == 0x48

    it "array concat via temp":
        var uart_buffer: [i64] = []
        val hello: [i64] = [0x48, 0x65, 0x6C, 0x6C, 0x6F]
        var i = 0
        while i < hello.len():
            val ch = hello[i]
            uart_buffer = uart_buffer + [ch]
            i = i + 1
        expect uart_buffer.len() == 5
        expect uart_buffer[0] == 0x48

    it "array push index":
        var uart_buffer: [i64] = []
        uart_buffer.push(0x48)
        uart_buffer.push(0x65)
        expect uart_buffer.len() == 2
        expect uart_buffer[0] == 0x48