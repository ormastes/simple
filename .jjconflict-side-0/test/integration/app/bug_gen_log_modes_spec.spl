use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_bug_gen_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + "/doc/08_tracking/bug && cat > " + FIXTURE_DIR + "/doc/08_tracking/bug/bug_db.sdn <<'EOF'\nbugs |id, severity, status, title, file, line, reproducible_by, created_at, updated_at, valid|\n    BUG-1, P1, Open, \"fixture bug\", src/main.spl, 7, test, 2026-05-24, 2026-05-24, true\nEOF"
    ])

fn _run_bug_gen(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/bug_gen/main.spl\" " + joined
    ])

describe "bug-gen log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_bug_gen(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_bug_gen(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"bug-gen\"")
        expect(out).to_contain("\"bugs\":1")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_bug_gen(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Generated doc/08_tracking/bug/recent_bugs.md (1 bugs)")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_bug_gen(["--log-mode=noisy"])
        expect(code).to_equal(1)
