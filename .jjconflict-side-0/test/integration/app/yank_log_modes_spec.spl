use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_yank(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/yank/main.spl\" " + joined
    ])

describe "yank log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_yank(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for missing arguments":
        val (out, err, code) = _run_yank(["--log-mode=json"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"command\":\"yank\"")
        expect(out).to_contain("\"status\":\"error\"")

    it "supports dot progress for missing arguments":
        val (out, err, code) = _run_yank(["--progress=dot"])
        expect(code).to_equal(1)
        expect(out).to_contain(".")
        expect(out).to_contain("Usage: simple yank")

    it "rejects invalid log mode":
        val (out, err, code) = _run_yank(["--log-mode=noisy"])
        expect(code).to_equal(1)
