use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_vscode_extension_old(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/vscode_extension_old/main.spl\" " + joined
    ])

describe "vscode extension old log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_vscode_extension_old(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("VSCode Extension Builder")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json ready output":
        val (out, err, code) = _run_vscode_extension_old(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"vscode-extension-old\"")
        expect(out).to_contain("\"status\":\"ready\"")

    it "supports json build plan output":
        val (out, err, code) = _run_vscode_extension_old([
            "--log-mode=json",
            "build",
            "--source",
            "sample",
            "--output",
            "dist",
            "--release"
        ])
        expect(code).to_equal(0)
        expect(out).to_contain("\"status\":\"planned\"")
        expect(out).to_contain("\"source\":\"sample\"")
        expect(out).to_contain("\"output\":\"dist\"")
        expect(out).to_contain("\"release\":true")

    it "supports dot progress for help output":
        val (out, err, code) = _run_vscode_extension_old(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("VSCode Extension Builder")

    it "rejects invalid log mode":
        val (out, err, code) = _run_vscode_extension_old(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "renders json unknown command output":
        val (out, err, code) = _run_vscode_extension_old(["--log-mode=json", "package"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"status\":\"error\"")
        expect(out).to_contain("Unknown command: package")
