use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_check_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + " && cat > " + FIXTURE_DIR + "/sample.spl <<'EOF'\nfn answer() -> i64:\n    42\nEOF"
    ])

fn _run_check(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/check/main.spl\" " + joined
    ])

describe "check log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_check(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_check(["--log-mode=json", "missing.spl"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"command\":\"check\"")
        expect(out).to_contain("\"status\":\"error\"")
        expect(out).to_contain("\"files\":1")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_check(["--progress=dot", "missing.spl"])
        expect(code).to_equal(1)
        expect(out).to_contain(".")
        expect(out).to_contain("ERROR: file not found: missing.spl")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_check(["--log-mode=noisy", "sample.spl"])
        expect(code).to_equal(1)
