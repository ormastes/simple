use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_lock_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + " && cat > " + FIXTURE_DIR + "/simple.sdn <<'EOF'\nname: lock-fixture\nversion: 4.5.6\ndependencies:\n  alpha: \"*\"\n  beta: \"*\"\ndev_dependencies:\n  gamma: \"*\"\nEOF"
    ])

fn _run_lock(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/lock/main.spl\" " + joined
    ])

describe "lock log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_lock(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports generate log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_lock(["generate", "--force", "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"generate\"")
        expect(out).to_contain("\"count\":3")

    it "validates generated lockfile":
        _setup_fixture()
        val (_gen_out, _gen_err, gen_code) = _run_lock(["generate", "--force"])
        expect(gen_code).to_equal(0)
        val (out, err, code) = _run_lock(["validate", "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"validate\"")
        expect(out).to_contain("\"status\":\"ok\"")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_lock(["generate", "--force", "--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Generated simple.lock with 3 packages")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_lock(["generate", "--log-mode=noisy"])
        expect(code).to_equal(1)
