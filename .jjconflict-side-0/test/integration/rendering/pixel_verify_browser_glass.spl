# Browser Engine Glass Theme Pixel Verification
#
# Tests the FULL browser engine pipeline with glass-themed HTML:
#   HTML string → DOM → CSS → Layout → Paint → Scene → Pixels
#
# This verifies:
#   1. HTML parsing (inline styles, <style> blocks)
#   2. CSS resolution (glass theme classes)
#   3. Layout computation (flexbox, block)
#   4. Paint generation (backgrounds, gradients, borders)
#   5. Scene execution → pixel buffer
#   6. Cross-module struct field access (LLVM backend)
#
# Build:
#   SIMPLE_LIB=$(pwd)/src src/compiler_rust/target/bootstrap/simple native-build \
#     --source src/lib --source src/compiler --source test/integration/rendering \
#     --entry test/integration/rendering/pixel_verify_browser_glass.spl \
#     -o /tmp/test_browser_glass --backend llvm --runtime-bundle all --entry-closure
# Run:
#   /tmp/test_browser_glass

use std.gc_async_mut.gpu.browser_engine.browser_renderer.{render_html_to_pixel_array}

extern fn rt_array_new(cap: i64) -> [u32]

fn main() -> i64:
    var pass_count = 0
    var fail_count = 0

    print "=== Browser Engine Glass Theme Pixel Verification ==="

    # ========================================================================
    # Test 1: Simple red div
    # ========================================================================
    print "\n=== Test 1: Red div background ==="
    val html1 = "<div style=\"background-color:#FF0000; width:100px; height:100px\">red</div>"
    print "  html1 len={html1.len()}"
    print "  html1 slice(0,5)='{html1.slice(0, 5)}'"
    print "  calling render_html_to_pixel_array..."
    val pixels1 = render_html_to_pixel_array(html1, 200, 200)
    print "  returned from render_html_to_pixel_array"
    val count1 = pixels1.len()
    print "  Pixel count: {count1} (expected: 40000)"

    if count1 == 40000:
        print "  PASS: pixel count matches"
        pass_count = pass_count + 1
    else:
        print "  FAIL: pixel count mismatch"
        fail_count = fail_count + 1

    # Check center pixel for red color (ARGB)
    val center_px = pixels1[100 * 200 + 50]
    print "  Center pixel (50,100): 0x{center_px}"
    # Red should be 0xFFFF0000 (ARGB)
    val red_channel = (center_px >> 16) & 0xFF
    print "  Red channel: {red_channel}"
    if red_channel > 200:
        print "  PASS: center pixel has strong red"
        pass_count = pass_count + 1
    else:
        print "  FAIL: center pixel red channel too low ({red_channel})"
        fail_count = fail_count + 1

    # ========================================================================
    # Test 2: Blue div
    # ========================================================================
    print "\n=== Test 2: Blue div background ==="
    val html2 = "<div style=\"background-color:#0000FF; width:200px; height:200px\"></div>"
    val pixels2 = render_html_to_pixel_array(html2, 200, 200)

    val center_px2 = pixels2[100 * 200 + 100]
    val blue_channel = center_px2 & 0xFF
    print "  Center pixel: 0x{center_px2}"
    print "  Blue channel: {blue_channel}"
    if blue_channel > 200:
        print "  PASS: center pixel has strong blue"
        pass_count = pass_count + 1
    else:
        print "  FAIL: center pixel blue channel too low ({blue_channel})"
        fail_count = fail_count + 1

    # ========================================================================
    # Test 3: Two colored divs
    # ========================================================================
    print "\n=== Test 3: Two colored divs (stacked) ==="
    val html3 = "<div style=\"background-color:#FF0000; width:200px; height:100px\"></div><div style=\"background-color:#00FF00; width:200px; height:100px\"></div>"
    val pixels3 = render_html_to_pixel_array(html3, 200, 200)

    # Top half should be red (row 50)
    val top_px = pixels3[50 * 200 + 100]
    val top_red = (top_px >> 16) & 0xFF
    print "  Top pixel (100,50): 0x{top_px}, R={top_red}"

    # Bottom half should be green (row 150)
    val bottom_px = pixels3[150 * 200 + 100]
    val bottom_green = (bottom_px >> 8) & 0xFF
    print "  Bottom pixel (100,150): 0x{bottom_px}, G={bottom_green}"

    if top_red > 200:
        print "  PASS: top div is red"
        pass_count = pass_count + 1
    else:
        print "  FAIL: top div red too low ({top_red})"
        fail_count = fail_count + 1

    if bottom_green > 200:
        print "  PASS: bottom div is green"
        pass_count = pass_count + 1
    else:
        print "  FAIL: bottom div green too low ({bottom_green})"
        fail_count = fail_count + 1

    # ========================================================================
    # Test 4: Glass-style dark panel
    # ========================================================================
    print "\n=== Test 4: Glass-style dark panel ==="
    val html4 = "<body style=\"background-color:#0A0A0F\"><div style=\"background-color:rgba(255,255,255,0.08); width:200px; height:200px\"></div></body>"
    val pixels4 = render_html_to_pixel_array(html4, 200, 200)

    # Center should be dark but not pure black (glass overlay on dark bg)
    val glass_px = pixels4[100 * 200 + 100]
    val glass_r = (glass_px >> 16) & 0xFF
    val glass_g = (glass_px >> 8) & 0xFF
    val glass_b = glass_px & 0xFF
    print "  Glass pixel: 0x{glass_px} R={glass_r} G={glass_g} B={glass_b}"

    # Should be very dark but not pure black (background shows through)
    if glass_r < 50 and glass_g < 50 and glass_b < 50:
        print "  PASS: glass panel is dark (as expected)"
        pass_count = pass_count + 1
    else:
        print "  FAIL: glass panel is too bright"
        fail_count = fail_count + 1

    # ========================================================================
    # Test 5: Style block CSS
    # ========================================================================
    print "\n=== Test 5: CSS style block ==="
    val html5 = "<style>.red-box { background-color: #FF0000; width: 100px; height: 100px; }</style><div class=\"red-box\"></div>"
    val pixels5 = render_html_to_pixel_array(html5, 200, 200)

    val style_px = pixels5[50 * 200 + 50]
    val style_red = (style_px >> 16) & 0xFF
    print "  Style block pixel (50,50): 0x{style_px} R={style_red}"
    if style_red > 200:
        print "  PASS: style block CSS applied correctly"
        pass_count = pass_count + 1
    else:
        print "  FAIL: style block CSS not applied (R={style_red})"
        fail_count = fail_count + 1

    # ========================================================================
    # Test 6: Red vs blue pixel-level comparison
    # ========================================================================
    print "\n=== Test 6: Pixel-level comparison (red vs blue) ==="
    var matching = 0
    var different = 0
    var max_diff = 0
    var i = 0
    val compare_count = 40000
    while i < compare_count:
        val pa = pixels1[i]
        val pb = pixels2[i]
        val dr = abs_i64(((pa >> 16) & 0xFF) - ((pb >> 16) & 0xFF))
        val dg = abs_i64(((pa >> 8) & 0xFF) - ((pb >> 8) & 0xFF))
        val db = abs_i64((pa & 0xFF) - (pb & 0xFF))
        val d = max3(dr, dg, db)
        if d > max_diff: max_diff = d
        if d == 0:
            matching = matching + 1
        else:
            different = different + 1
        i = i + 1

    print "  Matching: {matching}, Different: {different}, Max diff: {max_diff}"
    if different > 0:
        print "  PASS: red and blue buffers differ"
        pass_count = pass_count + 1
    else:
        print "  FAIL: red and blue buffers should differ"
        fail_count = fail_count + 1

    # ========================================================================
    # Test 7: Non-white check
    # ========================================================================
    print "\n=== Test 7: Non-white pixel verification ==="
    # Count non-white pixels in the red div render
    var non_white = 0
    i = 0
    while i < compare_count:
        if pixels1[i] != 0xFFFFFFFF:
            non_white = non_white + 1
        i = i + 1
    print "  Non-white pixels: {non_white} / {compare_count}"
    if non_white > 0:
        print "  PASS: render produced non-white pixels (not all-white bug)"
        pass_count = pass_count + 1
    else:
        print "  FAIL: all pixels are white — cross-module FieldGet bug still present"
        fail_count = fail_count + 1

    # ========================================================================
    # Summary
    # ========================================================================
    val total = pass_count + fail_count
    print "\n========================================"
    print "  Browser Engine Glass Pixel Summary"
    print "========================================"
    print "  Total checks: {total}"
    print "  Passed:       {pass_count}"
    print "  Failed:       {fail_count}"
    if fail_count == 0:
        print "  Result: ALL PASSED"
    else:
        print "  Result: {fail_count} FAILURES"
    print "========================================"

    return fail_count

fn abs_i64(x: i64) -> i64:
    if x < 0: return 0 - x
    x

fn max3(a: i64, b: i64, c: i64) -> i64:
    var m = a
    if b > m: m = b
    if c > m: m = c
    m

main()
