# Diagnostic test: layout_to_scene crash isolation

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode, be_dom_get_tag, be_dom_get_bg_color,
    be_dom_get_children, be_dom_set_style}
use std.gc_async_mut.gpu.browser_engine.css.{be_default_style, StyleProps}
use std.gc_async_mut.gpu.browser_engine.layout.{layout_to_scene, layout_tree, BeLayoutBox,
    layout_get_width, layout_get_height}
use common.render_scene.scene.{RenderScene}

fn main() -> i64:
    print "=== Layout Crash Diagnostic ==="

    print "\n--- A: Default div ---"
    var nodeA = BeDomNode.element("div")
    print "  created"
    val sceneA = layout_to_scene(nodeA, 100, 100)
    print "  OK"

    print "\n--- B: bg only ---"
    var nodeB = BeDomNode.element("div")
    be_dom_set_style(nodeB, "background-color", "#FF0000")
    val sceneB = layout_to_scene(nodeB, 100, 100)
    print "  OK"

    print "\n--- C: width only ---"
    var nodeC = BeDomNode.element("div")
    be_dom_set_style(nodeC, "width", "100px")
    val sceneC = layout_to_scene(nodeC, 100, 100)
    print "  OK"

    print "\n--- D: height only ---"
    var nodeD = BeDomNode.element("div")
    be_dom_set_style(nodeD, "height", "100px")
    val sceneD = layout_to_scene(nodeD, 100, 100)
    print "  OK"

    print "\n--- E: width+height ---"
    var nodeE = BeDomNode.element("div")
    be_dom_set_style(nodeE, "width", "100px")
    be_dom_set_style(nodeE, "height", "100px")
    val sceneE = layout_to_scene(nodeE, 100, 100)
    print "  OK"

    print "\n--- F: bg+width+height ---"
    var nodeF = BeDomNode.element("div")
    be_dom_set_style(nodeF, "background-color", "#FF0000")
    be_dom_set_style(nodeF, "width", "100px")
    be_dom_set_style(nodeF, "height", "100px")
    val sceneF = layout_to_scene(nodeF, 100, 100)
    print "  OK"

    print "\nDONE"
    return 0

main()
