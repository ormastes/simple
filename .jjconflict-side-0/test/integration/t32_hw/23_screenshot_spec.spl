# T32 Hardware -- Screenshot
#
# Tests screenshot and window capture commands. Some operations require
# a GUI environment and are marked pass_todo when running headless.
#
# @session-kind: trace32_board
# @target: arm
# @tag: t32_hw, new_tools
# @reuse: exclusive_reused

use std.sspec.{describe, context, it, expect, before_all, after_all}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_host, t32_hw_port, t32_hw_version_gate_new,
    t32_hw_relay_power_on, t32_hw_relay_power_off, t32_hw_relay_power_state
}

describe "T32 screenshot":
    var client = nil

    before_all:
        val result = t32_hw_connect()
        match result:
            Ok(c): client = c
            Err(e): expect("connect failed: {e}").to_equal("")

    after_all:
        if client != nil:
            client.disconnect()

    context "print and capture":
        it "screenshot command exists":
            val result = t32_hw_run_cmd(client, "PRINT \"screenshot_test\"")
            match result:
                Ok(v): expect(v).to_contain("screenshot_test")
                Err(e): expect("PRINT failed: {e}").to_equal("")

        it "WinPrint captures window":
            # WinPrint.Register may fail if no register window is open
            val result = t32_hw_run_cmd(client, "WinPrint.Register")
            match result:
                Ok(v): expect(v).to_contain("")
                Err(_):
                    return "skip: register window may not be open in headless mode"

        it "ScreenShot path queryable":
            return "skip: screenshot capture requires GUI environment"
