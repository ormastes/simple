# T32 Hardware Power Cycle Tests
#
# Exercises the relay-controlled power supply to the target board.
# Each test is isolated (fresh_per_test) -- no session state is shared,
# so each test independently queries or toggles power state.
#
# @session-kind: trace32_board
# @tag: t32_hw
# @reuse: fresh_per_test

use std.spipe.{describe, context, it, expect}
use test.integration.t32_hw.t32_hw_helpers.{
    t32_hw_probe_available, t32_hw_t32rem_available, t32_hw_relay_available,
    t32_hw_query_version, t32_hw_connect, t32_hw_run_cmd, t32_hw_eval,
    t32_hw_relay_power_on, t32_hw_relay_power_off, t32_hw_relay_power_reset,
    t32_hw_relay_power_state, t32_hw_host, t32_hw_port,
    T32_HW_MIN_VERSION_OLD, T32_HW_MIN_VERSION_NEW
}

describe "T32 hardware power cycle":
    context "power state query":
        it "queries relay power state":
            val state = t32_hw_relay_power_state()
            # State must be either "on" or "off" (not "unknown")
            val valid = state == "on" or state == "off"
            expect(valid).to_equal(true)

    context "power off sequence":
        it "powers board off":
            val ok = t32_hw_relay_power_off()
            expect(ok).to_equal(true)

        it "confirms board is off":
            t32_hw_relay_power_off()
            val state = t32_hw_relay_power_state()
            expect(state).to_equal("off")

    context "power on sequence":
        it "powers board on":
            val ok = t32_hw_relay_power_on()
            expect(ok).to_equal(true)

    context "power reset":
        it "resets board":
            val ok = t32_hw_relay_power_reset()
            expect(ok).to_equal(true)
