# Hardware Availability Check
# Shared utilities for detecting connected debug hardware.
# Integration tests use these helpers to make host/tool assumptions explicit.

extern fn rt_file_exists(path: text) -> bool
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn shell(command: text) -> text:
    val (stdout, stderr, code) = rt_process_run("/bin/sh", ["-c", command])
    if stdout.len() > 0:
        return stdout
    stderr

fn is_stm32h7_available() -> bool:
    val output = shell("st-info --probe 2>/dev/null")
    output.contains("002600213137510833333639")

fn is_stm32wb_available() -> bool:
    val output = shell("st-info --probe 2>/dev/null")
    output.contains("0671FF555755846687041216")

fn is_stlink_tools_available() -> bool:
    val output = shell("which st-info 2>/dev/null")
    output.len() > 0

fn is_t32_available() -> bool:
    rt_file_exists("/opt/t32/bin/pc_linux64/t32rem")

fn is_t32_usb_ready() -> bool:
    if not is_t32_available():
        return false
    val output = shell("/opt/t32/bin/pc_linux64/t32usbchecker 2>&1")
    output.contains("CONNECT request OK") or output.contains("USB communication OK")

fn is_openocd_available() -> bool:
    val output = shell("which openocd 2>/dev/null")
    output.len() > 0

fn is_gdb_available() -> bool:
    val output = shell("which gdb-multiarch 2>/dev/null")
    if output.len() > 0:
        return true
    val output2 = shell("which arm-none-eabi-gdb 2>/dev/null")
    output2.len() > 0

describe "Hardware detection":
    it "st-info tool check":
        val available = is_stlink_tools_available()
        expect(available == true or available == false).to_equal(true)

    it "T32 tool check":
        val available = is_t32_available()
        expect(available == true or available == false).to_equal(true)

    it "T32 USB readiness check":
        val available = is_t32_usb_ready()
        expect(available == true or available == false).to_equal(true)

    it "OpenOCD tool check":
        val available = is_openocd_available()
        expect(available == true or available == false).to_equal(true)
