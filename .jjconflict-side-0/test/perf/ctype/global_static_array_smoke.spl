# Native diagnostic for module-level static array initialization.

use ctype_lut_tables.{CTYPE_BYTE_SMOKE_TABLE, CTYPE_FLAG_TABLE}

extern fn rt_exit(code: i32) -> void

fn fail(msg: text, actual: i64):
    print "[ctype-static-array-error] {msg} actual={actual}"
    rt_exit(1)

fn main():
    if CTYPE_FLAG_TABLE[9] != 16:
        fail("i64 table tab entry", CTYPE_FLAG_TABLE[9])
    if CTYPE_FLAG_TABLE[48] != 1:
        fail("i64 table digit entry", CTYPE_FLAG_TABLE[48])
    if CTYPE_FLAG_TABLE[65] != 10:
        fail("i64 table uppercase hex entry", CTYPE_FLAG_TABLE[65])
    if CTYPE_FLAG_TABLE[97] != 12:
        fail("i64 table lowercase hex entry", CTYPE_FLAG_TABLE[97])
    if CTYPE_BYTE_SMOKE_TABLE[0] != 0:
        fail("u8 table zero entry", CTYPE_BYTE_SMOKE_TABLE[0])
    if CTYPE_BYTE_SMOKE_TABLE[3] != 16:
        fail("u8 table middle entry", CTYPE_BYTE_SMOKE_TABLE[3])
    if CTYPE_BYTE_SMOKE_TABLE[4] != 255:
        fail("u8 table max entry", CTYPE_BYTE_SMOKE_TABLE[4])
    print "[ctype-static-array] ok"
