extern fn rt_env_get(key: text) -> text
extern fn rt_file_read_text(path: text) -> text
extern fn rt_file_mmap_read_text(path: text) -> text
extern fn rt_file_mmap_len(path: text) -> i64
extern fn rt_file_write_text_at(path: text, offset: i64, data: text) -> i64
extern fn rt_file_write_text_at_cached(offset: i64, data: text) -> i64
extern fn rt_file_write_text_at_cached_repeat(iterations: i64, data: text) -> i64
extern fn rt_file_remove(path: text) -> bool
extern fn rt_file_size(path: text) -> i64
extern fn rt_time_now_unix_micros() -> i64

fn env_text(key: text, default_value: text) -> text:
    val value = rt_env_get(key) ?? ""
    if value.len() > 0:
        value
    else:
        default_value

fn env_i64(key: text, default_value: i64) -> i64:
    val value = env_text(key, "")
    if value.len() > 0:
        value.parse_int() ?? default_value
    else:
        default_value

fn chunk_4k() -> text:
    val seed = "simple-io-parity-0123456789abcdef\n"
    var chunk = seed
    while chunk.len() < 4096:
        chunk = chunk + chunk
    chunk.slice(0, 4096)

fn report(case_name: text, bytes_count: i64, iterations: i64, micros: i64, checksum: i64):
    print "[iobench] lang=simple case={case_name} bytes={bytes_count} iters={iterations} micros={micros} checksum={checksum}"

fn bench_read(path: text, iterations: i64):
    var checksum: i64 = 0
    var i: i64 = 0
    val start = rt_time_now_unix_micros()
    while i < iterations:
        val content = rt_file_read_text(path)
        checksum = checksum + content.len()
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    report("read_text", checksum, iterations, elapsed, checksum)

fn bench_mmap(path: text, iterations: i64):
    var checksum: i64 = 0
    var i: i64 = 0
    val start = rt_time_now_unix_micros()
    while i < iterations:
        val length = rt_file_mmap_len(path)
        checksum = checksum + length
        i = i + 1
    val elapsed = rt_time_now_unix_micros() - start
    report("mmap_text", checksum, iterations, elapsed, checksum)

fn bench_append_at(path: text, iterations: i64):
    rt_file_remove(path)
    val chunk = chunk_4k()
    var checksum: i64 = 0
    rt_file_write_text_at(path, 0, "")
    val start = rt_time_now_unix_micros()
    val wrote = rt_file_write_text_at_cached_repeat(iterations, chunk)
    if wrote < 0:
        print "[iobench-error] lang=simple case=append_at offset=0"
        return
    checksum = checksum + wrote
    val elapsed = rt_time_now_unix_micros() - start
    report("append_at", rt_file_size(path), iterations, elapsed, checksum)

fn main():
    val fixture = env_text("IO_PARITY_FIXTURE", "build/perf/io_parity/fixture.txt")
    val output = env_text("IO_PARITY_OUTPUT", "build/perf/io_parity/simple_append.out")
    val iterations = env_i64("IO_PARITY_ITERS", 64)
    bench_read(fixture, iterations)
    bench_mmap(fixture, iterations)
    bench_append_at(output, iterations)
