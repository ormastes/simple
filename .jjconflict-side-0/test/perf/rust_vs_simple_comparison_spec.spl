# Rust vs Simple Performance Comparison Benchmarks
#
# Measures identical operations under both the Rust bootstrap and self-hosted
# Simple binaries. Each benchmark uses rt_time_now_unix_micros() for timing,
# runs warmup iterations followed by measurement iterations, and prints results
# in a parseable [bench] format.
#
# Run:
#   src/compiler_rust/target/bootstrap/simple run test/perf/rust_vs_simple_comparison_spec.spl
#   bin/simple run test/perf/rust_vs_simple_comparison_spec.spl
#
# Output format:
#   [bench] category/name: avg=XXus min=XXus max=XXus iters=N

extern fn rt_time_now_unix_micros() -> i64

# ============================================================================
# Benchmark harness
# ============================================================================

val WARMUP = 10
val ITERS = 100

fn _arr_len(a: [i64]) -> i64:
    a.len()

fn _arr_get(a: [i64], i: i64) -> i64:
    a[i]

fn run_bench(name: text, f: fn() -> i64):
    # Warmup
    var w = 0
    while w < WARMUP:
        f()
        w = w + 1

    # Measurement
    var times: [i64] = []
    var i = 0
    while i < ITERS:
        val t0 = rt_time_now_unix_micros()
        f()
        val t1 = rt_time_now_unix_micros()
        val elapsed = t1 - t0
        if elapsed > 0:
            times.push(elapsed)
        i = i + 1

    # Stats
    val n = _arr_len(times)
    if n == 0:
        print "[bench] {name}: avg=0us min=0us max=0us iters=0"
        return

    var total: i64 = 0
    val first_t = _arr_get(times, 0)
    var min_t = first_t
    var max_t = first_t
    var idx = 0
    while idx < n:
        val t = _arr_get(times, idx)
        total = total + t
        if t < min_t:
            min_t = t
        if t > max_t:
            max_t = t
        idx = idx + 1

    val avg = total / n
    print "[bench] {name}: avg={avg}us min={min_t}us max={max_t}us iters={n}"

# ============================================================================
# 1. Variable Access
# ============================================================================

fn bench_local_var() -> i64:
    var x = 0
    var j = 0
    while j < 100:
        x = x + j
        j = j + 1
    x

fn bench_global_read() -> i64:
    # Reads a module-level val
    val result = ITERS + WARMUP
    result

var global_counter = 0

fn bench_global_write() -> i64:
    global_counter = global_counter + 1
    global_counter

# ============================================================================
# 2. Function Calls
# ============================================================================

fn identity(x: i64) -> i64:
    x

fn add_two(a: i64, b: i64) -> i64:
    a + b

fn bench_direct_call() -> i64:
    var sum = 0
    var j = 0
    while j < 100:
        sum = identity(sum) + add_two(j, 1)
        j = j + 1
    sum

fn fib(n: i64) -> i64:
    if n <= 1:
        n
    else:
        fib(n - 1) + fib(n - 2)

fn bench_recursive_fib() -> i64:
    fib(15)

fn bench_closure_call() -> i64:
    val f = fn(x): x + 1
    var sum = 0
    var j = 0
    while j < 100:
        sum = f(sum)
        j = j + 1
    sum

# ============================================================================
# 3. Collections — Array
# ============================================================================

fn bench_array_build() -> i64:
    var arr: [i64] = []
    var j = 0
    while j < 100:
        arr.push(j)
        j = j + 1
    arr.len()

fn bench_array_iterate() -> i64:
    var arr: [i64] = []
    var j = 0
    while j < 50:
        arr.push(j)
        j = j + 1
    var sum = 0
    for x in arr:
        sum = sum + x
    sum

fn bench_array_index() -> i64:
    var arr: [i64] = []
    var j = 0
    while j < 50:
        arr.push(j)
        j = j + 1
    var sum = 0
    var k = 0
    while k < 50:
        sum = sum + arr[k]
        k = k + 1
    sum

# ============================================================================
# 4. Control Flow
# ============================================================================

fn bench_if_else() -> i64:
    var result = 0
    var j = 0
    while j < 100:
        if j % 2 == 0:
            result = result + 1
        else:
            result = result - 1
        j = j + 1
    result

fn bench_match_int() -> i64:
    var result = 0
    var j = 0
    while j < 100:
        val r = j % 4
        match r:
            0: result = result + 1
            1: result = result + 2
            2: result = result + 3
            _: result = result + 4
        j = j + 1
    result

fn bench_while_loop() -> i64:
    var sum = 0
    var j = 0
    while j < 200:
        sum = sum + j
        j = j + 1
    sum

fn bench_for_loop() -> i64:
    var sum = 0
    for j in 0..200:
        sum = sum + j
    sum

# ============================================================================
# 5. String Operations
# ============================================================================

fn bench_string_concat() -> i64:
    var s = ""
    var j = 0
    while j < 50:
        s = s + "x"
        j = j + 1
    s.len()

fn bench_string_interpolation() -> i64:
    var s = ""
    var j = 0
    while j < 50:
        s = "{s}{j}"
        j = j + 1
    s.len()

# ============================================================================
# 6. Composite Workloads
# ============================================================================

fn factorial(n: i64) -> i64:
    if n <= 1:
        1
    else:
        n * factorial(n - 1)

fn bench_factorial() -> i64:
    var sum: i64 = 0
    var j = 0
    while j < 20:
        sum = sum + factorial(12)
        j = j + 1
    sum

fn bench_array_processing() -> i64:
    # Build, filter (manual), sum
    var arr: [i64] = []
    var j = 0
    while j < 100:
        arr.push(j)
        j = j + 1

    var evens: [i64] = []
    for x in arr:
        if x % 2 == 0:
            evens.push(x)

    var sum = 0
    for x in evens:
        sum = sum + x
    sum

fn bench_nested_loops() -> i64:
    var sum = 0
    var i = 0
    while i < 20:
        var j = 0
        while j < 20:
            sum = sum + i * j
            j = j + 1
        i = i + 1
    sum

# ============================================================================
# 7. Dict / Map Operations (built-in {text: X} syntax)
# ============================================================================

fn bench_dict_insert() -> i64:
    var d = {}
    var j = 0
    while j < 50:
        d["key_{j}"] = j
        j = j + 1
    j

fn bench_dict_lookup() -> i64:
    var d = {}
    var j = 0
    while j < 50:
        d["key_{j}"] = j
        j = j + 1

    var sum = 0
    var k = 0
    while k < 50:
        val v = d["key_{k}"]
        k = k + 1
    k

# ============================================================================
# 8. Object / Struct Operations
# ============================================================================

class Vec2:
    x: i64
    y: i64

fn vec2_add(a: Vec2, b: Vec2) -> Vec2:
    Vec2(x: a.x + b.x, y: a.y + b.y)

fn bench_struct_create() -> i64:
    var v = Vec2(x: 0, y: 0)
    var j = 0
    while j < 100:
        v = Vec2(x: j, y: j * 2)
        j = j + 1
    v.x + v.y

fn bench_struct_field_access() -> i64:
    val v = Vec2(x: 42, y: 99)
    var sum = 0
    var j = 0
    while j < 100:
        sum = sum + v.x + v.y
        j = j + 1
    sum

fn bench_struct_fn_call() -> i64:
    var v = Vec2(x: 0, y: 0)
    var j = 0
    while j < 50:
        v = vec2_add(v, Vec2(x: 1, y: 2))
        j = j + 1
    v.x + v.y

# ============================================================================
# Run all benchmarks
# ============================================================================

print "=== Rust vs Simple Performance Comparison ==="
print "Warmup: {WARMUP} iterations, Measurement: {ITERS} iterations"
print ""

# 1. Variable Access
print "--- Variable Access ---"
run_bench("variable/local_var", bench_local_var)
run_bench("variable/global_read", bench_global_read)
run_bench("variable/global_write", bench_global_write)

# 2. Function Calls
print ""
print "--- Function Calls ---"
run_bench("function/direct_call", bench_direct_call)
run_bench("function/recursive_fib15", bench_recursive_fib)
run_bench("function/closure_call", bench_closure_call)

# 3. Collections
print ""
print "--- Collections ---"
run_bench("collection/array_build", bench_array_build)
run_bench("collection/array_iterate", bench_array_iterate)
run_bench("collection/array_index", bench_array_index)

# 4. Control Flow
print ""
print "--- Control Flow ---"
run_bench("control/if_else", bench_if_else)
run_bench("control/match_int", bench_match_int)
run_bench("control/while_loop", bench_while_loop)
run_bench("control/for_loop", bench_for_loop)

# 5. String Operations
print ""
print "--- String Operations ---"
run_bench("string/concat", bench_string_concat)
run_bench("string/interpolation", bench_string_interpolation)

# 6. Composite Workloads
print ""
print "--- Composite Workloads ---"
run_bench("composite/factorial", bench_factorial)
run_bench("composite/array_processing", bench_array_processing)
run_bench("composite/nested_loops", bench_nested_loops)

# 7. Dict Operations
print ""
print "--- Dict Operations ---"
run_bench("dict/insert", bench_dict_insert)
run_bench("dict/lookup", bench_dict_lookup)

# 8. Struct Operations
print ""
print "--- Struct Operations ---"
run_bench("struct/create", bench_struct_create)
run_bench("struct/field_access", bench_struct_field_access)
run_bench("struct/fn_call", bench_struct_fn_call)

print ""
print "=== Benchmark Complete ==="

# Spec wrapper so this also passes as a test file
describe "Rust vs Simple Performance Comparison":
    slow_it "benchmark suite runs":
        expect(1).to_equal(1)
