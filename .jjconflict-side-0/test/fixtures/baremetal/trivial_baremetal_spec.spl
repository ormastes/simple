# Trivial baremetal test — verifies the compile-and-run pipeline.
#
# This file is compiled to a RISC-V ELF and run on QEMU with semihosting.
# It does NOT use SPipe (describe/it/expect) because the SPipe framework
# requires runtime features that may not be available in baremetal mode.
#
# Output uses SPipe-compatible format: "N examples, M failures"
# so the test runner can parse pass/fail counts correctly.

fn main() -> i64:
    var passed = 0
    var failed = 0

    # Test 1: Basic arithmetic
    val a = 2 + 3
    if a == 5:
        passed = passed + 1
    else:
        print "FAIL: arithmetic 2+3 expected 5, got something else"
        failed = failed + 1

    # Test 2: String literal
    val greeting = "hello"
    if greeting == "hello":
        passed = passed + 1
    else:
        print "FAIL: string literal mismatch"
        failed = failed + 1

    # Test 3: Boolean logic
    if true and not false:
        passed = passed + 1
    else:
        print "FAIL: boolean logic"
        failed = failed + 1

    # Print SPipe-compatible summary
    val total = passed + failed
    print "{total} examples, {failed} failures"

    if failed > 0:
        return 1
    return 0
