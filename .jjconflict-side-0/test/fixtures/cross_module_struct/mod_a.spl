## mod_a.spl — defines Foo struct and make_foo constructor fn in module A
## Fixture for interp_cross_module_struct_return_unit_2026-06-13 diagnosis
## NOTE: uses field named "label" (not "unit") to avoid the keyword-identifier bug.
## The actual repro for the "Unit" error is in mod_b_main.spl and mod_unit_param.spl.

struct Foo:
    x: i64
    label: text

fn make_foo(n: i64, label: text) -> Foo:
    Foo(x: n, label: label)

export Foo, make_foo
