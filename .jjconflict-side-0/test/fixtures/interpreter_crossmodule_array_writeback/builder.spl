fn bdd_crossmodule_append_values(dest: [i64], src: [i64]):
    var i = 0
    while i < src.len():
        dest.push(src[i])
        i = i + 1

fn bdd_crossmodule_build_values() -> [i64]:
    var values = [205]
    bdd_crossmodule_append_values(values, [3, 232])
    return values

export bdd_crossmodule_append_values, bdd_crossmodule_build_values
