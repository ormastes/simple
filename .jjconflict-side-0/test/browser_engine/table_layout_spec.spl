use std.spec.*
use std.gc_async_mut.gpu.browser_engine.layout.{
    LayoutContext, LayoutBox, layout_table, layout_context_new
}
use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{
    html_tree_builder_build
}
use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}

fn _table_layout(html: text) -> LayoutBox:
    val doc = html_tree_builder_build(html)
    val ctx = layout_context_new(600, 800)
    return layout_table(doc, ctx)

fn _cell_count(box_: LayoutBox) -> i32:
    var count = 0
    var i = 0
    while i < box_.children.len():
        val row = box_.children[i]
        count = count + row.children.len()
        i = i + 1
    return count

fn _row_count(box_: LayoutBox) -> i32:
    return box_.children.len()

fn _col_widths_sum(box_: LayoutBox) -> i32:
    if box_.children.len() == 0:
        return 0
    val first_row = box_.children[0]
    var sum = 0
    var i = 0
    while i < first_row.children.len():
        sum = sum + first_row.children[i].width
        i = i + 1
    return sum

# ============================================================================
# AC-5: Basic table layout — single table
# ============================================================================

describe "table layout basic table":
    it "AC-5: single-row single-cell table produces one row":
        val box_ = _table_layout("<table><tr><td>cell</td></tr></table>")
        val rows = _row_count(box_)
        expect(rows).to_equal(1)

    it "AC-5: two-row table produces two rows":
        val box_ = _table_layout("<table><tr><td>r1</td></tr><tr><td>r2</td></tr></table>")
        val rows = _row_count(box_)
        expect(rows).to_equal(2)

    it "AC-5: table has positive height":
        val box_ = _table_layout("<table><tr><td>cell</td></tr></table>")
        expect(box_.height).to_be_greater_than(0)

    it "AC-5: table width does not exceed container width":
        val box_ = _table_layout("<table><tr><td>cell</td></tr></table>")
        expect(box_.width).to_be_less_than(601)

# ============================================================================
# AC-5: Basic table layout — colspan
# ============================================================================

describe "table layout colspan":
    it "AC-5: cell with colspan=2 is wider than adjacent normal cell":
        val box_ = _table_layout(
            "<table><tr><td colspan=\"2\">wide</td><td>narrow</td></tr><tr><td>a</td><td>b</td><td>c</td></tr></table>")
        val first_row = box_.children[0]
        if first_row.children.len() > 0:
            val wide = first_row.children[0]
            val narrow = first_row.children[1]
            expect(wide.width).to_be_greater_than(narrow.width)
        else:
            expect(first_row.children.len()).to_be_greater_than(0)

# ============================================================================
# AC-5: Basic table layout — auto column width
# ============================================================================

describe "table layout auto column widths":
    it "AC-5: column widths sum equals table width for equal columns":
        val box_ = _table_layout(
            "<table><tr><td>a</td><td>b</td><td>c</td></tr></table>")
        val sum = _col_widths_sum(box_)
        expect(sum).to_equal(box_.width)

    it "AC-5: three equal columns have equal widths (auto layout)":
        val box_ = _table_layout(
            "<table><tr><td>a</td><td>b</td><td>c</td></tr></table>")
        val first_row = box_.children[0]
        if first_row.children.len() >= 2:
            val w0 = first_row.children[0].width
            val w1 = first_row.children[1].width
            expect(w0).to_equal(w1)
        else:
            expect(first_row.children.len()).to_be_greater_than(1)
