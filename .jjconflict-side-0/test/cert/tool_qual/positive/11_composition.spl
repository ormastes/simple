# Tool-qual positive case: composition (has-a struct field), NOT inheritance.
# Hand-computed: Engine.output() = power*2 = 50*2 = 100; Car.drive() delegates
# to the composed Engine field, so it also returns 100.
#
# SCOPE NOTE: mixin-based composition (`class X: use SomeMixin`) is NOT used
# here -- it misbehaves on the deployed binary (see
# known_defects/mixin_class_use_garbage_value.spl and
# known_defects/mixin_struct_use_runtime_error.spl). Plain struct-field
# composition + explicit delegation is the safe, correct composition idiom
# exercised by this case.
struct Engine:
    power: i64

    fn output() -> i64:
        self.power * 2

struct Car:
    engine: Engine
    name: text

    fn drive() -> i64:
        self.engine.output()

fn main():
    val c = Car(engine: Engine(power: 50), name: "X")
    print(c.drive())   # 100
    print(c.name)       # X
