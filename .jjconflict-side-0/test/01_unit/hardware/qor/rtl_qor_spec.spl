# RTL QoR unit tests.

use lib.nogc_sync_mut.hardware.qor.{RtlQorRun, RtlQorStore, compare_qor_runs, rtl_qor_run_markdown, rtl_qor_compare_markdown}

fn check(condition: bool):
    expect condition == true

fn baseline_run() -> RtlQorRun:
    RtlQorRun(
        run_id: "base",
        design: "rv32i_core",
        target: "ice40",
        toolchain: "ghdl-yosys",
        git_rev: "aaa",
        lut_count: 1000,
        ff_count: 500,
        bram_count: 2,
        dsp_count: 4,
        fmax_mhz: 40,
        cycles: 10000,
        passed: true
    )

fn candidate_run() -> RtlQorRun:
    RtlQorRun(
        run_id: "cand",
        design: "rv32i_core",
        target: "ice40",
        toolchain: "ghdl-yosys",
        git_rev: "bbb",
        lut_count: 920,
        ff_count: 480,
        bram_count: 2,
        dsp_count: 4,
        fmax_mhz: 45,
        cycles: 9700,
        passed: true
    )

describe "RTL QoR run model":
    it "computes area score with weighted hard macros":
        val run = baseline_run()
        expect run.area_score() == 2300

    it "serializes to SDN-style storage text":
        val sdn = baseline_run().to_sdn()
        check(sdn.starts_with("rtl_qor_run"))

describe "RTL QoR comparison":
    it "computes deltas and improvement predicates":
        val delta = compare_qor_runs(baseline_run(), candidate_run())
        expect delta.lut_delta == -80
        expect delta.ff_delta == -20
        expect delta.fmax_delta == 5
        check(delta.improved_area())
        check(delta.improved_fmax())

describe "RTL QoR store":
    it "stores runs and serializes them":
        val store = RtlQorStore.empty().with_run(baseline_run()).with_run(candidate_run())
        expect store.len() == 2
        val latest = store.latest_for_design("rv32i_core")
        check(latest.?)
        expect latest.unwrap().run_id == "cand"

describe "RTL QoR reports":
    it "renders run and comparison markdown":
        val run_md = rtl_qor_run_markdown(baseline_run())
        val compare_md = rtl_qor_compare_markdown(baseline_run(), candidate_run())
        check(run_md.contains("RTL QoR Run"))
        check(compare_md.contains("RTL QoR Delta"))
