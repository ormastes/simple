# @covers src/lib/common/html/entities.spl 80%
"""
# HTML Entity Encoding/Decoding Specification

**Feature IDs:** #LIB-HTML-001
**Category:** Stdlib
**Difficulty:** 2/5
**Status:** Implemented
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A

## Overview

Tests for `src/lib/common/html/entities.spl` covering HTML entity encoding,
decoding (named and numeric), character code conversion, and helper functions.
Targets 90%+ branch coverage by exercising both true and false paths of every
conditional branch.

## Key Concepts

| Concept | Description |
|---------|-------------|
| Named entity | Entities like `&lt;`, `&amp;`, `&copy;` |
| Numeric entity | Decimal `&#65;` or hex `&#x41;` |
| Encoding | Converting `<`, `>`, `&`, `"` to entity references |
| Decoding | Converting entity references back to characters |

## Related Specifications

- [HTML Parser](parser.md) - Uses decode_html_entities
- [HTML Serializer](serializer.md) - Uses encode_html_entities
"""

use lib.common.html.entities.{decode_html_entity, decode_html_entities, encode_html_entities, text_from_char_code, text_from_digit, text_from_upper, text_from_lower, is_digit}


# =============================================================================
# Test Group 1: decode_html_entity - Named Entities
# =============================================================================

describe "decode_html_entity":
    """
    ## Named Entity Decoding

    Tests that all named HTML entities are correctly decoded to their
    corresponding Unicode characters.
    """

    context "basic HTML entities":
        """
        ### Scenario: Core five HTML entities

        The five essential HTML entities used in markup: lt, gt, amp, quot, apos.
        """

        it "decodes lt to less-than":
            val result = decode_html_entity("lt")
            expect(result).to_equal("<")

        it "decodes gt to greater-than":
            val result = decode_html_entity("gt")
            expect(result).to_equal(">")

        it "decodes amp to ampersand":
            val result = decode_html_entity("amp")
            expect(result).to_equal("&")

        it "decodes quot to double quote":
            val result = decode_html_entity("quot")
            expect(result).to_equal("\"")

        it "decodes apos to apostrophe":
            val result = decode_html_entity("apos")
            expect(result).to_equal("'")

    context "whitespace and symbol entities":
        """
        ### Scenario: Non-breaking space and common symbols

        Entities for whitespace variants and frequently used symbols.
        """

        it "decodes nbsp to space":
            val result = decode_html_entity("nbsp")
            expect(result).to_equal(" ")

        it "decodes copy to copyright symbol":
            val result = decode_html_entity("copy")
            expect(result).to_equal("\u00A9")

        it "decodes reg to registered symbol":
            val result = decode_html_entity("reg")
            expect(result).to_equal("\u00AE")

        it "decodes trade to trademark symbol":
            val result = decode_html_entity("trade")
            expect(result).to_equal("\u2122")

    context "currency entities":
        """
        ### Scenario: Currency symbol entities

        Tests for euro, pound, yen, and cent entity decoding.
        """

        it "decodes euro to euro sign":
            val result = decode_html_entity("euro")
            expect(result).to_equal("\u20AC")

        it "decodes pound to pound sign":
            val result = decode_html_entity("pound")
            expect(result).to_equal("\u00A3")

        it "decodes yen to yen sign":
            val result = decode_html_entity("yen")
            expect(result).to_equal("\u00A5")

        it "decodes cent to cent sign":
            val result = decode_html_entity("cent")
            expect(result).to_equal("\u00A2")

    context "typographic entities":
        """
        ### Scenario: Section, degree, plus-minus, and other typographic entities
        """

        it "decodes sect to section sign":
            val result = decode_html_entity("sect")
            expect(result).to_equal("\u00A7")

        it "decodes deg to degree sign":
            val result = decode_html_entity("deg")
            expect(result).to_equal("\u00B0")

        it "decodes plusmn to plus-minus sign":
            val result = decode_html_entity("plusmn")
            expect(result).to_equal("\u00B1")

        it "decodes micro to micro sign":
            val result = decode_html_entity("micro")
            expect(result).to_equal("\u00B5")

        it "decodes para to pilcrow sign":
            val result = decode_html_entity("para")
            expect(result).to_equal("\u00B6")

        it "decodes middot to middle dot":
            val result = decode_html_entity("middot")
            expect(result).to_equal("\u00B7")

    context "fraction entities":
        """
        ### Scenario: Vulgar fraction entities
        """

        it "decodes frac14 to one quarter":
            val result = decode_html_entity("frac14")
            expect(result).to_equal("\u00BC")

        it "decodes frac12 to one half":
            val result = decode_html_entity("frac12")
            expect(result).to_equal("\u00BD")

        it "decodes frac34 to three quarters":
            val result = decode_html_entity("frac34")
            expect(result).to_equal("\u00BE")

    context "math operator entities":
        """
        ### Scenario: Multiplication and division entities
        """

        it "decodes times to multiplication sign":
            val result = decode_html_entity("times")
            expect(result).to_equal("\u00D7")

        it "decodes divide to division sign":
            val result = decode_html_entity("divide")
            expect(result).to_equal("\u00F7")

    context "card suit entities":
        """
        ### Scenario: Playing card suit entities
        """

        it "decodes hearts":
            val result = decode_html_entity("hearts")
            expect(result).to_equal("\u2665")

        it "decodes clubs":
            val result = decode_html_entity("clubs")
            expect(result).to_equal("\u2663")

        it "decodes diams":
            val result = decode_html_entity("diams")
            expect(result).to_equal("\u2666")

        it "decodes spades":
            val result = decode_html_entity("spades")
            expect(result).to_equal("\u2660")

    context "unknown named entities":
        """
        ### Scenario: Entity name not recognized

        When an unknown entity name is passed, the function returns
        the input unchanged (false branch of all named-entity ifs).
        """

        it "returns unknown entity unchanged":
            val result = decode_html_entity("unknown")
            expect(result).to_equal("unknown")

        it "returns empty string unchanged":
            val result = decode_html_entity("")
            expect(result).to_equal("")

        it "returns random text unchanged":
            val result = decode_html_entity("foobar")
            expect(result).to_equal("foobar")

    context "numeric decimal entities":
        """
        ### Scenario: Decimal numeric character references

        Entities like `#65` decode to ASCII character A.
        """

        it "decodes decimal entity for capital A":
            val result = decode_html_entity("#65")
            expect(result).to_equal("A")

        it "decodes decimal entity for space":
            val result = decode_html_entity("#32")
            expect(result).to_equal(" ")

        it "decodes decimal entity for exclamation mark":
            val result = decode_html_entity("#33")
            expect(result).to_equal("!")

        it "decodes decimal entity for digit 0":
            val result = decode_html_entity("#48")
            expect(result).to_equal("0")

        it "decodes decimal entity for digit 9":
            val result = decode_html_entity("#57")
            expect(result).to_equal("9")

        it "decodes decimal entity for lowercase a":
            val result = decode_html_entity("#97")
            expect(result).to_equal("a")

        it "decodes decimal entity for lowercase z":
            val result = decode_html_entity("#122")
            expect(result).to_equal("z")

        it "decodes decimal entity for Z":
            val result = decode_html_entity("#90")
            expect(result).to_equal("Z")

    context "numeric entity edge cases":
        """
        ### Scenario: Edge cases in numeric entity parsing

        Tests for code=0 (no conversion), code>=128 (out of ASCII range),
        invalid characters in numeric part, hex prefix, and empty numeric part.
        """

        it "returns entity unchanged for code 0":
            """
            When the parsed code is 0, the `code > 0` branch is false,
            so the entity is returned unchanged.
            """
            val result = decode_html_entity("#0")
            expect(result).to_equal("#0")

        it "returns entity unchanged for code >= 128":
            """
            When the parsed code is >= 128, the `code < 128` branch is false,
            so the entity is returned unchanged.
            """
            val result = decode_html_entity("#200")
            expect(result).to_equal("#200")

        it "returns entity unchanged for hex prefix":
            """
            Hex entities like `#x41` are not fully supported, so the
            `is_hex` branch returns the entity unchanged.
            """
            val result = decode_html_entity("#x41")
            expect(result).to_equal("#x41")

        it "returns entity unchanged for invalid decimal digits":
            """
            When a non-digit character is encountered, `valid` becomes false
            and the entity is returned unchanged.
            """
            val result = decode_html_entity("#abc")
            expect(result).to_equal("#abc")

        it "returns entity unchanged for mixed digits and letters":
            val result = decode_html_entity("#12a")
            expect(result).to_equal("#12a")

        it "handles hash with empty numeric part":
            """
            When `#` is followed by nothing, `num_part.length() > 0` is false,
            so the entity is returned unchanged.
            """
            val result = decode_html_entity("#")
            expect(result).to_equal("#")

        it "handles hash-x with empty hex part":
            """
            When `#x` is followed by nothing, `final_num.length() > 0` is false,
            so the entity is returned unchanged.
            """
            val result = decode_html_entity("#x")
            expect(result).to_equal("#x")


# =============================================================================
# Test Group 2: decode_html_entities (full string decoding)
# =============================================================================

describe "decode_html_entities":
    """
    ## Full String Entity Decoding

    Tests for the full-string decoder that finds `&entity;` patterns
    in text and replaces them with decoded characters.
    """

    context "single entity decoding":
        it "decodes a single lt entity in text":
            val result = decode_html_entities("&lt;")
            expect(result).to_equal("<")

        it "decodes a single gt entity in text":
            val result = decode_html_entities("&gt;")
            expect(result).to_equal(">")

        it "decodes a single amp entity in text":
            val result = decode_html_entities("&amp;")
            expect(result).to_equal("&")

    context "multiple entities in text":
        it "decodes mixed text and entities":
            val result = decode_html_entities("a &lt; b &amp; c &gt; d")
            expect(result).to_equal("a < b & c > d")

        it "decodes adjacent entities":
            val result = decode_html_entities("&lt;&gt;")
            expect(result).to_equal("<>")

        it "decodes entities at start and end":
            val result = decode_html_entities("&lt;hello&gt;")
            expect(result).to_equal("<hello>")

    context "plain text without entities":
        it "returns plain text unchanged":
            val result = decode_html_entities("hello world")
            expect(result).to_equal("hello world")

        it "returns empty string unchanged":
            val result = decode_html_entities("")
            expect(result).to_equal("")

    context "ampersand without semicolon":
        """
        ### Scenario: Incomplete entity references

        When `&` is found but no `;` follows within 20 characters,
        the `found_semi` check is false and the `&` is kept literally.
        """

        it "keeps bare ampersand as literal":
            val result = decode_html_entities("a & b")
            expect(result).to_equal("a & b")

        it "keeps ampersand without closing semicolon":
            val result = decode_html_entities("&nosemicolon")
            expect(result).to_equal("&nosemicolon")

    context "numeric entities in full text":
        it "decodes numeric entity in text":
            val result = decode_html_entities("&#65;")
            expect(result).to_equal("A")

        it "decodes mixed named and numeric entities":
            val result = decode_html_entities("&lt;&#65;&gt;")
            expect(result).to_equal("<A>")

    context "long non-entity after ampersand":
        """
        ### Scenario: Entity search limit

        When `&` is found and no `;` appears within 20 characters,
        the search stops (the `end_pos - i > 20` branch is true).
        """

        it "stops searching after 20 characters":
            val result = decode_html_entities("&abcdefghijklmnopqrstuvwxyz")
            expect(result).to_equal("&abcdefghijklmnopqrstuvwxyz")


# =============================================================================
# Test Group 3: encode_html_entities
# =============================================================================

describe "encode_html_entities":
    """
    ## HTML Entity Encoding

    Tests for encoding special HTML characters into entity references.
    Only `<`, `>`, `&`, and `"` are encoded.
    """

    context "individual character encoding":
        it "encodes less-than":
            val result = encode_html_entities("<")
            expect(result).to_equal("&lt;")

        it "encodes greater-than":
            val result = encode_html_entities(">")
            expect(result).to_equal("&gt;")

        it "encodes ampersand":
            val result = encode_html_entities("&")
            expect(result).to_equal("&amp;")

        it "encodes double quote":
            val result = encode_html_entities("\"")
            expect(result).to_equal("&quot;")

    context "passthrough characters":
        """
        ### Scenario: Characters that are NOT encoded

        Characters other than `<`, `>`, `&`, `"` pass through the
        else branches unchanged.
        """

        it "passes through plain text":
            val result = encode_html_entities("hello")
            expect(result).to_equal("hello")

        it "passes through single quote":
            val result = encode_html_entities("'")
            expect(result).to_equal("'")

        it "passes through numbers":
            val result = encode_html_entities("12345")
            expect(result).to_equal("12345")

        it "returns empty string unchanged":
            val result = encode_html_entities("")
            expect(result).to_equal("")

    context "mixed content encoding":
        it "encodes mixed HTML content":
            val result = encode_html_entities("<p>Hello & \"World\"</p>")
            expect(result).to_equal("&lt;p&gt;Hello &amp; &quot;World&quot;&lt;/p&gt;")

        it "encodes only special characters in mixed text":
            val result = encode_html_entities("a < b > c & d")
            expect(result).to_equal("a &lt; b &gt; c &amp; d")

    context "roundtrip encoding and decoding":
        it "roundtrip for basic HTML":
            val original = "<div>"
            val encoded = encode_html_entities(original)
            val decoded = decode_html_entities(encoded)
            expect(decoded).to_equal(original)

        it "roundtrip for ampersand":
            val original = "Tom & Jerry"
            val encoded = encode_html_entities(original)
            val decoded = decode_html_entities(encoded)
            expect(decoded).to_equal(original)


# =============================================================================
# Test Group 4: text_from_char_code
# =============================================================================

describe "text_from_char_code":
    """
    ## Character Code to Text Conversion

    Tests the ASCII character code to text conversion function covering
    space, punctuation, digits, uppercase, and lowercase ranges.
    """

    context "space and punctuation (32-47)":
        it "converts code 32 to space":
            expect(text_from_char_code(32)).to_equal(" ")

        it "converts code 33 to exclamation":
            expect(text_from_char_code(33)).to_equal("!")

        it "converts code 34 to double quote":
            expect(text_from_char_code(34)).to_equal("\"")

        it "converts code 35 to hash":
            expect(text_from_char_code(35)).to_equal("#")

        it "converts code 36 to dollar":
            expect(text_from_char_code(36)).to_equal("$")

        it "converts code 37 to percent":
            expect(text_from_char_code(37)).to_equal("%")

        it "converts code 38 to ampersand":
            expect(text_from_char_code(38)).to_equal("&")

        it "converts code 39 to apostrophe":
            expect(text_from_char_code(39)).to_equal("'")

        it "converts code 40 to open paren":
            expect(text_from_char_code(40)).to_equal("(")

        it "converts code 41 to close paren":
            expect(text_from_char_code(41)).to_equal(")")

        it "converts code 42 to asterisk":
            expect(text_from_char_code(42)).to_equal("*")

        it "converts code 43 to plus":
            expect(text_from_char_code(43)).to_equal("+")

        it "converts code 44 to comma":
            expect(text_from_char_code(44)).to_equal(",")

        it "converts code 45 to hyphen":
            expect(text_from_char_code(45)).to_equal("-")

        it "converts code 46 to period":
            expect(text_from_char_code(46)).to_equal(".")

        it "converts code 47 to forward slash":
            expect(text_from_char_code(47)).to_equal("/")

    context "digit range (48-57)":
        it "converts code 48 to 0":
            expect(text_from_char_code(48)).to_equal("0")

        it "converts code 49 to 1":
            expect(text_from_char_code(49)).to_equal("1")

        it "converts code 57 to 9":
            expect(text_from_char_code(57)).to_equal("9")

    context "punctuation between digits and uppercase (58-64)":
        it "converts code 58 to colon":
            expect(text_from_char_code(58)).to_equal(":")

        it "converts code 59 to semicolon":
            expect(text_from_char_code(59)).to_equal(";")

        it "converts code 60 to less-than":
            expect(text_from_char_code(60)).to_equal("<")

        it "converts code 61 to equals":
            expect(text_from_char_code(61)).to_equal("=")

        it "converts code 62 to greater-than":
            expect(text_from_char_code(62)).to_equal(">")

        it "converts code 63 to question mark":
            expect(text_from_char_code(63)).to_equal("?")

        it "converts code 64 to at sign":
            expect(text_from_char_code(64)).to_equal("@")

    context "uppercase letters (65-90)":
        it "converts code 65 to A":
            expect(text_from_char_code(65)).to_equal("A")

        it "converts code 77 to M":
            expect(text_from_char_code(77)).to_equal("M")

        it "converts code 90 to Z":
            expect(text_from_char_code(90)).to_equal("Z")

    context "lowercase letters (97-122)":
        it "converts code 97 to a":
            expect(text_from_char_code(97)).to_equal("a")

        it "converts code 109 to m":
            expect(text_from_char_code(109)).to_equal("m")

        it "converts code 122 to z":
            expect(text_from_char_code(122)).to_equal("z")

    context "out of range codes":
        """
        ### Scenario: Code outside supported ranges

        When the code does not match any known character, the function
        returns an empty string (all if branches are false).
        """

        it "returns empty for code 0":
            expect(text_from_char_code(0)).to_equal("")

        it "returns empty for code 31 (below space)":
            expect(text_from_char_code(31)).to_equal("")

        it "returns empty for code 128 (above ASCII)":
            expect(text_from_char_code(128)).to_equal("")


