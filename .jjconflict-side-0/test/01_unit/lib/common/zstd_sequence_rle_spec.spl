use std.spec.{describe, it, expect}
use std.common.compress.{CompressionCodec, CompressionError, decompress_bytes}

fn _expect_compression_error(err: CompressionError, kind: text, message_part: text):
    match err:
        CompressionError.InvalidHeader(message):
            expect(kind).to_equal("InvalidHeader")
            expect(message).to_contain(message_part)
        CompressionError.UnsupportedFeature(message):
            expect(kind).to_equal("UnsupportedFeature")
            expect(message).to_contain(message_part)
        CompressionError.TruncatedInput(message):
            expect(kind).to_equal("TruncatedInput")
            expect(message).to_contain(message_part)
        CompressionError.ChecksumMismatch(message):
            expect(kind).to_equal("ChecksumMismatch")
            expect(message).to_contain(message_part)
        CompressionError.CorruptStream(message):
            expect(kind).to_equal("CorruptStream")
            expect(message).to_contain(message_part)
        CompressionError.SizeLimitExceeded(limit):
            expect(kind).to_equal("SizeLimitExceeded")
            expect(limit >= 0).to_equal(true)

fn _zstd_frame(expected_size: i64, block: [u8]) -> [u8]:
    [
        0x28u8, 0xB5u8, 0x2Fu8, 0xFDu8,
        0xA0u8,
        (expected_size & 0xFF).to_u8(),
        ((expected_size >> 8) & 0xFF).to_u8(),
        ((expected_size >> 16) & 0xFF).to_u8(),
        ((expected_size >> 24) & 0xFF).to_u8(),
        block[0], block[1], block[2]
    ] + block.slice(3, block.len())

fn _compressed_block(last_block: bool, payload: [u8]) -> [u8]:
    val header = (if last_block: 1 else: 0) | (2 << 1) | (payload.len() << 3)
    [
        (header & 0xFF).to_u8(),
        ((header >> 8) & 0xFF).to_u8(),
        ((header >> 16) & 0xFF).to_u8()
    ] + payload

fn _raw_block(last_block: bool, payload: [u8]) -> [u8]:
    val header = (if last_block: 1 else: 0) | (payload.len() << 3)
    [
        (header & 0xFF).to_u8(),
        ((header >> 8) & 0xFF).to_u8(),
        ((header >> 16) & 0xFF).to_u8()
    ] + payload

describe "zstd rle sequence execution":
    it "decodes a one-sequence block with a normal offset":
        val frame = _zstd_frame(6, _compressed_block(true, [
            0x18u8,
            0x61u8, 0x62u8, 0x63u8,
            0x01u8,
            0x54u8,
            0x03u8, 0x02u8, 0x00u8,
            0x06u8
        ]))
        val decoded = decompress_bytes(frame, Some(CompressionCodec.zstd))
        expect(decoded.is_err()).to_equal(false)
        expect(decoded.unwrap()).to_equal([0x61u8, 0x62u8, 0x63u8, 0x63u8, 0x63u8, 0x63u8])

    it "supports overlap-safe matches for offset one":
        val frame = _zstd_frame(6, _compressed_block(true, [
            0x08u8,
            0x61u8,
            0x01u8,
            0x54u8,
            0x01u8, 0x02u8, 0x02u8,
            0x04u8
        ]))
        val decoded = decompress_bytes(frame, Some(CompressionCodec.zstd))
        expect(decoded.is_err()).to_equal(false)
        expect(decoded.unwrap()).to_equal([0x61u8, 0x61u8, 0x61u8, 0x61u8, 0x61u8, 0x61u8])

    it "supports rep1 offsets during rle sequence execution":
        val frame = _zstd_frame(4, _compressed_block(true, [
            0x08u8,
            0x61u8,
            0x01u8,
            0x54u8,
            0x01u8, 0x00u8, 0x00u8,
            0x01u8
        ]))
        val decoded = decompress_bytes(frame, Some(CompressionCodec.zstd))
        expect(decoded.is_err()).to_equal(false)
        expect(decoded.unwrap()).to_equal([0x61u8, 0x61u8, 0x61u8, 0x61u8])

    it "supports zero-literal shifted repeat offsets":
        val frame = _zstd_frame(7, _raw_block(false, [0x61u8, 0x62u8, 0x63u8, 0x64u8]) + _compressed_block(true, [
            0x00u8,
            0x01u8,
            0x54u8,
            0x00u8, 0x00u8, 0x00u8,
            0x01u8
        ]))
        val decoded = decompress_bytes(frame, Some(CompressionCodec.zstd))
        expect(decoded.is_err()).to_equal(false)
        expect(decoded.unwrap()).to_equal([0x61u8, 0x62u8, 0x63u8, 0x64u8, 0x61u8, 0x62u8, 0x63u8])

    it "carries repeat-offset history across compressed blocks":
        val frame = _zstd_frame(9, _compressed_block(false, [
            0x18u8,
            0x61u8, 0x62u8, 0x63u8,
            0x01u8,
            0x54u8,
            0x03u8, 0x02u8, 0x00u8,
            0x06u8
        ]) + _compressed_block(true, [
            0x00u8,
            0x01u8,
            0x54u8,
            0x00u8, 0x00u8, 0x00u8,
            0x01u8
        ]))
        val decoded = decompress_bytes(frame, Some(CompressionCodec.zstd))
        expect(decoded.is_err()).to_equal(false)
        expect(decoded.unwrap()).to_equal([0x61u8, 0x62u8, 0x63u8, 0x61u8, 0x62u8, 0x63u8, 0x63u8, 0x63u8, 0x63u8])

    it "rejects invalid match offsets after literals are copied":
        val frame = _zstd_frame(6, _compressed_block(true, [
            0x18u8,
            0x61u8, 0x62u8, 0x63u8,
            0x01u8,
            0x54u8,
            0x03u8, 0x03u8, 0x00u8,
            0x0Eu8
        ]))
        val decoded = decompress_bytes(frame, Some(CompressionCodec.zstd))
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "CorruptStream", "invalid match offset")
