            expect(false).to_equal(true)

fn expect_truncated_i64(result: Result<i64, CompressionError>, message_part: text):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.TruncatedInput(message):
            expect(message).to_contain(message_part)
        _:
            expect(false).to_equal(true)

fn expect_truncated_block_header(result: Result<XzBlockHeader, CompressionError>, message_part: text):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.TruncatedInput(message):
            expect(message).to_contain(message_part)
