use std.spec.{describe, it, expect}
use std.common.compress.{CompressionError}
use std.common.compress.lzma2_xz_format.{XzBlockHeader, _xz_read_u32_le, _xz_read_u64_le, _validate_lzma_range_decoder_init, _decompress_xz_stream, _parse_xz_index, _parse_block_header, _consume_alignment_zeroes, _vli_decode}

fn expect_truncated_u32(result: Result<u32, CompressionError>, message_part: text):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.TruncatedInput(message):
            expect(message).to_contain(message_part)
        _:
            expect(false).to_equal(true)

fn expect_truncated_u64(result: Result<u64, CompressionError>, message_part: text):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.TruncatedInput(message):
            expect(message).to_contain(message_part)
        _:
            expect(false).to_equal(true)

fn expect_truncated_unit(result: Result<(), CompressionError>, message_part: text):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.TruncatedInput(message):
            expect(message).to_contain(message_part)
        _:
            expect(false).to_equal(true)

fn expect_truncated_stream(result: Result<([u8], i64), CompressionError>, message_part: text):
    expect(result.is_err()).to_equal(true)
    val err = result.unwrap_err()
    match err:
        CompressionError.TruncatedInput(message):
            expect(message).to_contain(message_part)
