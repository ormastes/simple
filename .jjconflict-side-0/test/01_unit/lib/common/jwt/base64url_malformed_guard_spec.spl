use std.spec.{describe, it, assert_equal}
use std.common.jwt.encode.{base64url_decode, base64url_decode_to_bytes}

describe "JWT base64url malformed decode guard":
    it "ignores invalid text decode bytes":
        assert_equal(base64url_decode("a@GVs#bG8"), "hello")

    it "ignores invalid byte decode bytes":
        val decoded = base64url_decode_to_bytes("a@GVs#bG8")
        assert_equal(decoded.len(), 5)
        assert_equal(decoded[0].to_i64(), 104)

    it "returns empty output for only invalid bytes":
        assert_equal(base64url_decode("!!!"), "")
        assert_equal(base64url_decode_to_bytes("!!!").len(), 0)
