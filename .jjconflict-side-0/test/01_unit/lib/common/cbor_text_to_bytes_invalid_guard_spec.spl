use std.spec.{describe, it, assert_equal}
use std.common.cbor.types.{text_to_bytes}

describe "CBOR text to bytes invalid guard":
    it "fails closed for unsupported characters":
        assert_equal(text_to_bytes("\n").len(), 0)

    it "keeps supported ASCII conversion working":
        val result = text_to_bytes("A")
        assert_equal(result.len(), 1)
        assert_equal(result[0], 65)
