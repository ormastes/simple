# =============================================================================
# asym_spec.spl — KAT + round-trip tests for typed asymmetric-key wrappers
# =============================================================================
# Exercises: ed25519_typed_keypair, ed25519_typed_sign, ed25519_typed_verify,
#            x25519_typed, x25519_typed_pubkey,
#            ecdsa_p256_typed_sign, ecdsa_p256_typed_verify
#
# Ed25519 KAT (RFC 8032 §7.1 TEST 1 — empty message):
#   Probe verified under seed interpreter (pure Simple):
#   seed  = 9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60
#   pubkey= d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a
#   sig   = e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e065224901555fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b
#
# X25519 KAT (RFC 7748 §5.2 vector 2):
#   scalar= a546e36bf0527c9d3b16154b82465edd62144c0ac1fc5a18506a2244ba449ac4
#   u     = e6db6867583030db3594c1a424b15f7c726624ec26b3353b10a903a6d0ab1c4c
#   shared= c3da55379de9c6908e94ea4df28d084f32eccf03491c71f754b4075577a28552
#   The existing assertions exercise the pure-Simple Montgomery ladder directly.
#   Execution evidence for the extern-removal source change is pending.
#
# ECDSA-P256:
#   RUNTIME-ONLY — wraps rt_ecdsa_p256_* externs; structural type tests only.
#
# PERFORMANCE NOTE: Ed25519 sign takes ~30s per call under the interpreter
# (pure-Simple SHA-512 + scalar mul). This spec calls sign EXACTLY ONCE.
# Verify tests use Signature.from_hex() with the known oracle — no sign call.
# Test-runner 120s per-file limit: 1 keypair + 1 sign = ~60s total, fits.
# =============================================================================

use std.spec
use lib.common.bytes.span.{ByteSpan}
use lib.common.crypto.typed.ctypes.{SecretKey, PublicKey, Signature, SharedSecret}
use lib.common.crypto.typed.asym.{
    Ed25519KeyPair,
    ed25519_typed_keypair,
    ed25519_typed_sign,
    ed25519_typed_verify,
    x25519_typed,
    x25519_typed_pubkey,
    ecdsa_p256_typed_sign,
    ecdsa_p256_typed_verify
}

# =============================================================================
# Module-level input builders — avoids it-block var-mutation quirk
# (feedback_it_block_var_mutation.md). Each fn is called only as needed.
# =============================================================================

fn _seed1() -> [u8]:
    # RFC 8032 §7.1 TEST 1 seed (32 bytes)
    [
        0x9du8, 0x61u8, 0xb1u8, 0x9du8, 0xefu8, 0xfdu8, 0x5au8, 0x60u8,
        0xbau8, 0x84u8, 0x4au8, 0xf4u8, 0x92u8, 0xecu8, 0x2cu8, 0xc4u8,
        0x44u8, 0x49u8, 0xc5u8, 0x69u8, 0x7bu8, 0x32u8, 0x69u8, 0x19u8,
        0x70u8, 0x3bu8, 0xacu8, 0x03u8, 0x1cu8, 0xaeu8, 0x7fu8, 0x60u8
    ]

fn _kp1() -> Ed25519KeyPair:
    ed25519_typed_keypair(ByteSpan.new(_seed1()))

fn _msg1() -> ByteSpan:
    ByteSpan.new([])

fn _x25519_scalar() -> [u8]:
    # RFC 7748 §5.2 vector 2 scalar
    # a546e36bf0527c9d3b16154b82465edd62144c0ac1fc5a18506a2244ba449ac4
    [
        0xa5u8, 0x46u8, 0xe3u8, 0x6bu8, 0xf0u8, 0x52u8, 0x7cu8, 0x9du8,
        0x3bu8, 0x16u8, 0x15u8, 0x4bu8, 0x82u8, 0x46u8, 0x5eu8, 0xddu8,
        0x62u8, 0x14u8, 0x4cu8, 0x0au8, 0xc1u8, 0xfcu8, 0x5au8, 0x18u8,
        0x50u8, 0x6au8, 0x22u8, 0x44u8, 0xbau8, 0x44u8, 0x9au8, 0xc4u8
    ]

fn _x25519_u() -> [u8]:
    # RFC 7748 §5.2 vector 2 u-coordinate (32 bytes)
    # e6db6867583030db3594c1a424b15f7c726624ec26b3353b10a903a6d0ab1c4c
    [
        0xe6u8, 0xdbu8, 0x68u8, 0x67u8, 0x58u8, 0x30u8, 0x30u8, 0xdbu8,
        0x35u8, 0x94u8, 0xc1u8, 0xa4u8, 0x24u8, 0xb1u8, 0x5fu8, 0x7cu8,
        0x72u8, 0x66u8, 0x24u8, 0xecu8, 0x26u8, 0xb3u8, 0x35u8, 0x3bu8,
        0x10u8, 0xa9u8, 0x03u8, 0xa6u8, 0xd0u8, 0xabu8, 0x1cu8, 0x4cu8
    ]

fn _alice_priv() -> [u8]:
    # RFC 7748 §6.1 Alice private key
    [
        0x77u8, 0x07u8, 0x6du8, 0x0au8, 0x73u8, 0x18u8, 0xa5u8, 0x7du8,
        0x3cu8, 0x16u8, 0xc1u8, 0x72u8, 0x51u8, 0xb2u8, 0x66u8, 0x45u8,
        0xdfu8, 0x4cu8, 0x2fu8, 0x87u8, 0xebu8, 0xc0u8, 0x99u8, 0x2au8,
        0xb1u8, 0x77u8, 0xfbu8, 0xa5u8, 0x1du8, 0xb9u8, 0x2cu8, 0x2au8
    ]

# =============================================================================
# Ed25519 — RFC 8032 §7.1 TEST 1 keypair derivation
# _kp1() calls ed25519_typed_keypair (no sign) — fast under interpreter.
# =============================================================================

describe "ed25519_typed_keypair — RFC 8032 §7.1 TEST 1":
    it "public key hex matches oracle":
        expect(_kp1().public.hex()).to_equal("d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a")

    it "secret key len is 32":
        expect(_kp1().secret.len()).to_equal(32)

    it "public key len is 32":
        expect(_kp1().public.len()).to_equal(32)

# =============================================================================
# Ed25519 — RFC 8032 §7.1 TEST 1 sign (ONE sign call total for the file)
# =============================================================================

describe "ed25519_typed_sign — RFC 8032 §7.1 TEST 1 empty message":
    it "signature hex matches oracle and len is 64":
        val kp = _kp1()
        val sig = ed25519_typed_sign(kp.secret, kp.public, _msg1())
        expect(sig.hex()).to_equal("e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e065224901555fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b")
        expect(sig.len()).to_equal(64)

# =============================================================================
# Ed25519 — verify using oracle hex (no sign call; uses Signature.from_hex)
# =============================================================================

describe "ed25519_typed_verify — from_hex oracle inputs":
    it "accepts valid oracle signature":
        val pk = PublicKey.from_hex("d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a")
        val sig = Signature.from_hex("e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e065224901555fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b")
        expect(ed25519_typed_verify(pk, _msg1(), sig)).to_equal(true)

    it "rejects signature over wrong message":
        val pk = PublicKey.from_hex("d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a")
        val sig = Signature.from_hex("e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e065224901555fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b")
        var wrong: [u8] = [0x01u8]
        expect(ed25519_typed_verify(pk, ByteSpan.new(wrong), sig)).to_equal(false)

# =============================================================================
# X25519 KAT — RFC 7748 §5.2 vector 2
# The pure-Simple Montgomery ladder is the sole X25519 path. These existing
# assertions retain the RFC oracle; execution for the source change is pending.
# =============================================================================

describe "x25519_typed — RFC 7748 §5.2 KAT":
    it "shared secret hex matches oracle":
        val sk = SecretKey.new(_x25519_scalar())
        val peer = PublicKey.new(_x25519_u())
        val shared = x25519_typed(sk, peer)
        expect(shared.hex()).to_equal("c3da55379de9c6908e94ea4df28d084f32eccf03491c71f754b4075577a28552")

    it "shared secret len is 32":
        val sk = SecretKey.new(_x25519_scalar())
        val peer = PublicKey.new(_x25519_u())
        val shared = x25519_typed(sk, peer)
        expect(shared.len()).to_equal(32)

describe "x25519_typed_pubkey — RFC 7748 §6.1 Alice public key":
    it "pubkey hex matches oracle":
        val sk = SecretKey.new(_alice_priv())
        val pk = x25519_typed_pubkey(sk)
        expect(pk.hex()).to_equal("8520f0098930a754748b7ddcb43ef75a0dbf3a0d26381af4eba4a98eaa9b4e6a")

    it "pubkey len is 32":
        val sk = SecretKey.new(_alice_priv())
        val pk = x25519_typed_pubkey(sk)
        expect(pk.len()).to_equal(32)

# =============================================================================
# ECDSA-P256 — structural tests (runtime-only for sign/verify)
# Type construction tests run anywhere; sign/verify need rt_ecdsa_p256_* externs.
# =============================================================================

describe "ecdsa_p256_typed — Signature and PublicKey type construction":
    it "64-byte Signature wraps correctly":
        var fake_sig: [u8] = [
            0x01u8, 0x02u8, 0x03u8, 0x04u8, 0x05u8, 0x06u8, 0x07u8, 0x08u8,
            0x09u8, 0x0au8, 0x0bu8, 0x0cu8, 0x0du8, 0x0eu8, 0x0fu8, 0x10u8,
            0x11u8, 0x12u8, 0x13u8, 0x14u8, 0x15u8, 0x16u8, 0x17u8, 0x18u8,
            0x19u8, 0x1au8, 0x1bu8, 0x1cu8, 0x1du8, 0x1eu8, 0x1fu8, 0x20u8,
            0x21u8, 0x22u8, 0x23u8, 0x24u8, 0x25u8, 0x26u8, 0x27u8, 0x28u8,
            0x29u8, 0x2au8, 0x2bu8, 0x2cu8, 0x2du8, 0x2eu8, 0x2fu8, 0x30u8,
            0x31u8, 0x32u8, 0x33u8, 0x34u8, 0x35u8, 0x36u8, 0x37u8, 0x38u8,
            0x39u8, 0x3au8, 0x3bu8, 0x3cu8, 0x3du8, 0x3eu8, 0x3fu8, 0x40u8
        ]
        var sig = Signature.new(fake_sig)
        expect(sig.len()).to_equal(64)

    it "Signature.from_hex round-trips hex()":
        var sig = Signature.from_hex("e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e065224901555fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b")
        expect(sig.len()).to_equal(64)

    it "PublicKey.new wraps byte array":
        var fake_pk: [u8] = [0x04u8, 0x01u8, 0x02u8]
        var pk = PublicKey.new(fake_pk)
        expect(pk.len()).to_equal(3)
