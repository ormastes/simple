use std.spec.{describe, it, assert_equal}
use std.common.cbor.types.{bytes_append, bytes_concat}

describe "CBOR byte helper invalid guard":
    it "does not append malformed byte values":
        val original = [1, 2]
        val negative_result = bytes_append(original, -1)
        val high_result = bytes_append(original, 300)
        assert_equal(negative_result.len(), 2)
        assert_equal(high_result.len(), 2)
        assert_equal(negative_result[1], 2)
        assert_equal(high_result[1], 2)

    it "fails closed when concatenating malformed byte arrays":
        assert_equal(bytes_concat([1], [-1]).len(), 0)
        assert_equal(bytes_concat([300], [1]).len(), 0)

    it "keeps valid append and concat working":
        val appended = bytes_append([1], 255)
        val concatenated = bytes_concat([1, 2], [3, 255])
        assert_equal(appended.len(), 2)
        assert_equal(appended[1], 255)
        assert_equal(concatenated.len(), 4)
        assert_equal(concatenated[3], 255)
