use std.spec.{describe, it, assert_equal}
use std.common.encoding.utf8.{utf8_codepoint_byte_len, utf8_encode_one}

describe "utf8 codepoint byte length guards":
    it "keeps valid ASCII length":
        assert_equal(utf8_codepoint_byte_len(0x41), 1)

    it "uses replacement byte length for negative codepoints":
        assert_equal(utf8_codepoint_byte_len(-1), utf8_encode_one(-1).len())

    it "uses replacement byte length for above-range codepoints":
        assert_equal(utf8_codepoint_byte_len(0x110000), utf8_encode_one(0x110000).len())
