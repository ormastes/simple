"""
# Encoding text BOM stripping

Focused coverage for UTF-8 BOM stripping.
"""

use std.spec.*
use common.encoding.text_ops.{strip_utf8_bom}

describe "encoding text_ops strip_utf8_bom":
    it "removes a leading UTF-8 BOM codepoint":
        expect(strip_utf8_bom("﻿{\"ok\":true}")).to_equal("{\"ok\":true}")

    it "leaves content without a leading BOM unchanged":
        expect(strip_utf8_bom("{\"ok\":true}")).to_equal("{\"ok\":true}")

    it "does not remove non-leading BOM codepoints":
        expect(strip_utf8_bom("x﻿y")).to_equal("x﻿y")
