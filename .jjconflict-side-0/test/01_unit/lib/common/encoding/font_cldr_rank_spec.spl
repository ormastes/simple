use std.spec.*
use std.common.encoding.font_cldr_rank.{cldr_rank_languages}

val POPULATION_XML = "<supplementalData><territoryInfo>" +
    "<territory type=\"XA\" population=\"3\" literacyPercent=\"100.0\">" +
    "<languagePopulation type=\"iw\" populationPercent=\"50.0\"/>" +
    "<languagePopulation type=\"pt\" populationPercent=\"50.0\"/>" +
    "</territory>" +
    "<territory type=\"XB\" population=\"5\" literacyPercent=\"80.0\">" +
    "<languagePopulation type=\"he\" populationPercent=\"50.0\"/>" +
    "<languagePopulation type=\"de\" populationPercent=\"50.0\" literacyPercent=\"40.0\"/>" +
    "</territory>" +
    "<territory type=\"XC\" population=\"10\" literacyPercent=\"100.0\">" +
    "<languagePopulation type=\"de\" populationPercent=\"50.0\"/>" +
    "<languagePopulation type=\"it\" populationPercent=\"20.0\"/>" +
    "<languagePopulation type=\"fr\" populationPercent=\"20.0\"/>" +
    "</territory></territoryInfo></supplementalData>"

val METADATA_XML = "<supplementalData><metadata><alias>" +
    "<languageAlias type=\"iw\" replacement=\"he\" reason=\"deprecated\"/>" +
    "</alias></metadata></supplementalData>"

val LIKELY_XML = "<supplementalData><likelySubtags>" +
    "<likelySubtag from=\"de\" to=\"de_Latn_DE\"/>" +
    "<likelySubtag from=\"fr\" to=\"fr_Latn_FR\"/>" +
    "<likelySubtag from=\"he\" to=\"he_Hebr_IL\"/>" +
    "<likelySubtag from=\"it\" to=\"it_Latn_IT\"/>" +
    "<likelySubtag from=\"pt\" to=\"pt_Latn_BR\"/>" +
    "</likelySubtags></supplementalData>"

describe "CLDR literate-functional language ranking":
    it "canonicalizes, rounds half-up, aggregates, and breaks ties lexically":
        match cldr_rank_languages(POPULATION_XML, METADATA_XML, LIKELY_XML):
            case Ok(rows):
                expect(rows.len()).to_equal(5)
                expect(rows[0].language).to_equal("de")
                expect(rows[0].likely_script).to_equal("Latn")
                expect(rows[0].total).to_equal(6)
                expect(rows[0].script_totals.len()).to_equal(1)
                expect(rows[0].script_totals[0].script).to_equal("Latn")
                expect(rows[0].script_totals[0].total).to_equal(6)
                expect(rows[1].language).to_equal("he")
                expect(rows[1].likely_script).to_equal("Hebr")
                expect(rows[1].total).to_equal(4)
                expect(rows[1].script_totals[0].total).to_equal(4)
                expect(rows[2].language).to_equal("fr")
                expect(rows[2].total).to_equal(2)
                expect(rows[3].language).to_equal("it")
                expect(rows[3].total).to_equal(2)
                expect(rows[4].language).to_equal("pt")
                expect(rows[4].total).to_equal(2)
            case Err(message):
                fail("valid CLDR fixture failed: {message}")

    it "fails closed on malformed fixed-decimal input":
        val malformed = "<supplementalData><territoryInfo>" +
            "<territory type=\"XZ\" population=\"10\" literacyPercent=\"100\">" +
            "<languagePopulation type=\"fr\" populationPercent=\"oops\"/>" +
            "</territory></territoryInfo></supplementalData>"
        match cldr_rank_languages(malformed, METADATA_XML, LIKELY_XML):
            case Err(message):
                expect(message).to_contain("populationPercent")
            case Ok(_):
                fail("malformed populationPercent must not produce partial ranks")

    it "ignores commented and macrolanguage aliases and prefers territory likely scripts":
        val metadata = "<supplementalData><metadata><alias><!--" +
            "<languageAlias type=\"iw\" replacement=\"xx\" reason=\"deprecated\"/>" +
            "--><languageAlias type=\"iw\" replacement=\"he_Hebr\" reason=\"deprecated\"/>" +
            "<languageAlias type=\"he\" replacement=\"yi\" reason=\"macrolanguage\"/>" +
            "</alias></metadata></supplementalData>"
        val likely = "<supplementalData><likelySubtags>" +
            "<likelySubtag from=\"he_XA\" to=\"he_Latn_XA\"/>" +
            "<likelySubtag from=\"he\" to=\"he_Hebr_IL\"/>" +
            "<likelySubtag from=\"pt_XA\" to=\"pt_Cyrl_XA\"/>" +
            "<likelySubtag from=\"pt\" to=\"pt_Latn_BR\"/>" +
            "</likelySubtags></supplementalData>"
        match cldr_rank_languages(
            "<territory type=\"XA\" population=\"3\" literacyPercent=\"100\">" +
                "<languagePopulation type=\"iw_Latn\" populationPercent=\"50\"/>" +
                "<languagePopulation type=\"pt\" populationPercent=\"50\"/>" +
                "</territory>", metadata, likely):
            case Ok(rows):
                expect(rows[0].language).to_equal("he")
                expect(rows[0].likely_script).to_equal("Latn")
                expect(rows[0].script_totals[0].script).to_equal("Latn")
                expect(rows[1].language).to_equal("pt")
                expect(rows[1].likely_script).to_equal("Cyrl")
            case Err(message):
                fail("safe alias fixture failed: {message}")

    it "excludes undefined language rows":
        val population = "<territory type=\"XA\" population=\"1\" literacyPercent=\"100\">" +
            "<languagePopulation type=\"und\" populationPercent=\"100\"/></territory>"
        match cldr_rank_languages(population, METADATA_XML, LIKELY_XML):
            case Ok(rows):
                expect(rows.len()).to_equal(0)
            case Err(message):
                fail("und exclusion failed: {message}")
