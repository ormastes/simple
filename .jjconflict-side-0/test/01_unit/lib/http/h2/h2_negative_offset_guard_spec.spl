use std.spec.{describe, it, assert_equal}
use std.http.h2.h2_parser.{h2_parse_frame, h2_parse_frame_header}

fn _valid_window_update_bytes() -> [u8]:
    var bytes: [u8] = []
    bytes.push(0)
    bytes.push(0)
    bytes.push(4)
    bytes.push(0x8)
    bytes.push(0)
    bytes.push(0)
    bytes.push(0)
    bytes.push(0)
    bytes.push(1)
    bytes.push(0)
    bytes.push(0)
    bytes.push(0)
    bytes.push(10)
    bytes

describe "HTTP/2 parser negative offset guard":
    it "rejects negative frame header offsets":
        assert_equal(h2_parse_frame_header(_valid_window_update_bytes(), -1) == nil, true)

    it "rejects negative frame offsets":
        assert_equal(h2_parse_frame(_valid_window_update_bytes(), -1) == nil, true)
