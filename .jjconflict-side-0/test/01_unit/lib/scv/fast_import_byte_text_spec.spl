use std.spec
use std.scv.fast_import.{scv_fast_import_bytes_to_text}

describe "scv fast-import byte text conversion":
    it "decodes tag payload bytes without text.from_bytes":
        val decoded = scv_fast_import_bytes_to_text([82u8, 101u8, 108u8, 101u8, 97u8, 115u8, 101u8, 10u8, 13u8, 9u8, 255u8])
        expect(decoded).to_equal("Release\n\r\t?")
