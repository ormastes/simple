# GPU Queue / Event / Task Graph / USM — Wave 1 SYCL-parity specs.
# Plan: doc/03_plan/language/gpu_fpga/sycl_parity_unified_kernel_plan_2026-06-13.md
# All cases run on the CPU-deterministic path — no GPU hardware required.

use std.gpu.{GpuQueue, GpuEvent, GpuTaskGraph, GpuAccessGraph, launch_shape, default_launch_shape}
use std.gpu.{UsmBuffer, usm_malloc_device, usm_malloc_host, usm_malloc_shared}
use std.gpu.{gpu_none}
use std.gpu.{cpu_kernel_run_1d, gpu_global_id_x, gpu_block_dim_x, gpu_grid_dim_x}
use std.gpu.{GpuPipe}

# Module-level state for closure-free kernels (nested closures cannot
# mutate captured locals; module vars + module fns work everywhere).
var pf_sum = 0
var replay_trace: [i64] = []

fn work_ok() -> bool:
    true

fn work_fail() -> bool:
    false

fn pf_accumulate(i: i64) -> bool:
    pf_sum = pf_sum + i
    true

fn replay_exec(node: i64) -> bool:
    replay_trace.push(node)
    true

fn ident(i: i64) -> i64:
    i

fn add(a: i64, b: i64) -> i64:
    a + b

fn maxv(a: i64, b: i64) -> i64:
    if a > b: a else: b

# Kernel-shaped function for the W4.1 CPU executor: same indexing idiom a
# @gpu_kernel body uses (global id from block/thread intrinsics).
var kernel_hits: [i64] = []

fn mark_kernel():
    val idx = gpu_global_id_x()
    kernel_hits.push(idx)

describe "launch_shape (W1.3 descriptive range math)":

    it "computes exact grid for divisible ranges":
        val shape = launch_shape(1024, 256)
        expect(shape.grid_dim).to_equal(4)
        expect(shape.block_dim).to_equal(256)
        expect(shape.needs_tail_guard).to_equal(false)
        expect(shape.covers(1024)).to_equal(true)

    it "rounds grid up and flags the tail guard for ragged ranges":
        val shape = launch_shape(1000, 256)
        expect(shape.grid_dim).to_equal(4)
        expect(shape.needs_tail_guard).to_equal(true)
        expect(shape.covers(1000)).to_equal(true)

    it "fails closed on empty and invalid ranges":
        val zero = launch_shape(0, 256)
        expect(zero.grid_dim).to_equal(0)
        val bad = launch_shape(64, 0)
        expect(bad.grid_dim).to_equal(0)

    it "uses block size 256 by default":
        val shape = default_launch_shape(1)
        expect(shape.grid_dim).to_equal(1)
        expect(shape.block_dim).to_equal(256)

describe "GpuQueue submit/wait (W1.1 async model, CPU-deterministic)":

    it "completes a successful submission and reports wait success":
        var q = GpuQueue.create(gpu_none())
        val ev = q.submit(work_ok)
        expect(ev.is_complete()).to_equal(true)
        expect(q.wait()).to_equal(true)

    it "reports wait failure when a submission fails":
        var q = GpuQueue.create(gpu_none())
        val ev = q.submit(work_fail)
        expect(ev.is_complete()).to_equal(false)
        expect(q.wait()).to_equal(false)

    it "runs dependent work after a completed dependency":
        var q = GpuQueue.create(gpu_none())
        val first = q.submit(work_ok)
        val deps: [GpuEvent] = [first]
        val second = q.submit_after(work_ok, deps)
        expect(second.is_complete()).to_equal(true)
        expect(q.wait()).to_equal(true)

    it "fails closed when a dependency is incomplete":
        var q = GpuQueue.create(gpu_none())
        val failed = q.submit(work_fail)
        val deps: [GpuEvent] = [failed]
        val blocked = q.submit_after(work_ok, deps)
        expect(blocked.is_complete()).to_equal(false)
        expect(q.wait()).to_equal(false)

    it "parallel_for covers every index exactly once with implicit bounds":
        pf_sum = 0
        var q = GpuQueue.create(gpu_none())
        val ev = q.parallel_for(10, pf_accumulate)
        expect(ev.is_complete()).to_equal(true)
        expect(pf_sum).to_equal(45)

    it "parallel_reduce folds sum and max deterministically":
        var q = GpuQueue.create(gpu_none())
        val total = q.parallel_reduce_i64(100, 0, ident, add)
        expect(total).to_equal(4950)
        val biggest = q.parallel_reduce_i64(100, -1, ident, maxv)
        expect(biggest).to_equal(99)
        expect(q.wait()).to_equal(true)

    it "parallel_reduce over an empty range returns init":
        var q = GpuQueue.create(gpu_none())
        val r = q.parallel_reduce_i64(0, 7, ident, add)
        expect(r).to_equal(7)

describe "GpuTaskGraph (W1.4 record/replay)":

    it "schedules a diamond in dependency order":
        var g = GpuTaskGraph.create()
        val a = g.record("a")
        val b = g.record("b")
        val c = g.record("c")
        val d = g.record("d")
        g.depends(b, a)
        g.depends(c, a)
        g.depends(d, b)
        g.depends(d, c)
        val order = g.schedule()
        expect(order.len()).to_equal(4)
        expect(order[0]).to_equal(a)
        expect(order[3]).to_equal(d)

    it "replays all nodes of an acyclic graph":
        replay_trace = []
        var g = GpuTaskGraph.create()
        val a = g.record("a")
        val b = g.record("b")
        g.depends(b, a)
        val done = g.replay_with(replay_exec)
        expect(done).to_equal(2)
        expect(replay_trace.len()).to_equal(2)
        expect(replay_trace[0]).to_equal(a)

    it "refuses to schedule or replay a cyclic graph":
        var g = GpuTaskGraph.create()
        val x = g.record("x")
        val y = g.record("y")
        g.depends(x, y)
        g.depends(y, x)
        val order = g.schedule()
        expect(order.len()).to_equal(0)
        val done = g.replay_with(replay_exec)
        expect(done).to_equal(0)

describe "GpuAccessGraph implicit DAG (G3 buffer/accessor equivalent)":

    it "derives RAW edges into a diamond from buffer access sets":
        var ag = GpuAccessGraph.create()
        val producer = ag.record_task("write A", [], [0])
        val left = ag.record_task("A -> B", [0], [1])
        val right = ag.record_task("A -> C", [0], [2])
        val consumer = ag.record_task("B+C -> D", [1, 2], [3])
        val g = ag.build()
        val order = g.schedule()
        expect(order.len()).to_equal(4)
        expect(order[0]).to_equal(producer)
        expect(order[3]).to_equal(consumer)

    it "derives WAR and WAW edges so rewrites wait for readers":
        var ag = GpuAccessGraph.create()
        val w0 = ag.record_task("write A", [], [0])
        val r0 = ag.record_task("read A", [0], [])
        val w1 = ag.record_task("rewrite A", [], [0])
        val g = ag.build()
        val order = g.schedule()
        expect(order.len()).to_equal(3)
        expect(order[0]).to_equal(w0)
        expect(order[1]).to_equal(r0)
        expect(order[2]).to_equal(w1)

    it "leaves independent tasks unordered but schedulable":
        var ag = GpuAccessGraph.create()
        val t0 = ag.record_task("write A", [], [0])
        val t1 = ag.record_task("write B", [], [1])
        val g = ag.build()
        expect(g.schedule().len()).to_equal(2)
        expect(t0 != t1).to_equal(true)

describe "GpuEvent profiling (W4.2 host path)":

    it "records elapsed time only when profiling is enabled":
        var q = GpuQueue.create(gpu_none())
        val cold = q.submit(work_ok)
        expect(cold.elapsed_nanos).to_equal(0)
        q.enable_profiling()
        val warm = q.parallel_for(1000, pf_accumulate)
        expect(warm.is_complete()).to_equal(true)
        expect(warm.elapsed_nanos >= 0).to_equal(true)
        expect(warm.elapsed_ms() >= 0.0).to_equal(true)

describe "GpuQueue wait_result error model (W4.3)":

    it "returns Ok with the completed count when all submissions succeed":
        var q = GpuQueue.create(gpu_none())
        q.submit(work_ok)
        q.submit(work_ok)
        val r = q.wait_result()
        expect(r.is_ok()).to_equal(true)

    it "returns Err naming the first failed submission":
        var q = GpuQueue.create(gpu_none())
        q.submit(work_ok)
        q.submit(work_fail)
        val r = q.wait_result()
        expect(r.is_err()).to_equal(true)

describe "GpuPipe host FIFO (W3.3 emulation half)":

    it "preserves FIFO order through wraparound":
        var p = GpuPipe.create(3)
        expect(p.valid).to_equal(true)
        expect(p.try_write(10)).to_equal(true)
        expect(p.try_write(20)).to_equal(true)
        expect(p.read()).to_equal(10)
        expect(p.try_write(30)).to_equal(true)
        expect(p.try_write(40)).to_equal(true)
        expect(p.read()).to_equal(20)
        expect(p.read()).to_equal(30)
        expect(p.read()).to_equal(40)
        expect(p.is_empty()).to_equal(true)

    it "rejects writes when full and reads when empty":
        var p = GpuPipe.create(2)
        expect(p.try_write(1)).to_equal(true)
        expect(p.try_write(2)).to_equal(true)
        expect(p.is_full()).to_equal(true)
        expect(p.try_write(3)).to_equal(false)
        expect(p.read()).to_equal(1)
        expect(p.read()).to_equal(2)
        expect(p.can_read()).to_equal(false)
        expect(p.read()).to_equal(0)

    it "peek does not consume":
        var p = GpuPipe.create(2)
        expect(p.try_write(7)).to_equal(true)
        expect(p.peek()).to_equal(7)
        expect(p.len()).to_equal(1)
        expect(p.read()).to_equal(7)

    it "fails closed on non-positive capacity":
        val bad = GpuPipe.create(0)
        expect(bad.valid).to_equal(false)
        var bad2 = GpuPipe.create(-1)
        expect(bad2.try_write(1)).to_equal(false)

describe "cpu_kernel_run_1d generic CPU executor (W4.1)":

    it "runs a kernel-shaped body once per work-item with correct global ids":
        kernel_hits = []
        val executed = cpu_kernel_run_1d(10, 4, mark_kernel)
        expect(executed).to_equal(10)
        expect(kernel_hits.len()).to_equal(10)
        expect(kernel_hits[0]).to_equal(0)
        expect(kernel_hits[9]).to_equal(9)

    it "skips ragged tail items beyond total":
        kernel_hits = []
        val executed = cpu_kernel_run_1d(5, 4, mark_kernel)
        expect(executed).to_equal(5)
        expect(kernel_hits.len()).to_equal(5)
        expect(kernel_hits[4]).to_equal(4)

    it "restores single-thread intrinsic defaults after the launch":
        kernel_hits = []
        val executed = cpu_kernel_run_1d(3, 2, mark_kernel)
        expect(executed).to_equal(3)
        expect(gpu_global_id_x()).to_equal(0)
        expect(gpu_block_dim_x()).to_equal(1)
        expect(gpu_grid_dim_x()).to_equal(1)

    it "fails closed on invalid shapes":
        expect(cpu_kernel_run_1d(0, 4, mark_kernel)).to_equal(0)
        expect(cpu_kernel_run_1d(4, 0, mark_kernel)).to_equal(0)

describe "USM allocation trio (W1.2, fallback path)":

    it "allocates host memory that is readable and writable":
        var buf = usm_malloc_host(16)
        expect(buf.valid).to_equal(true)
        expect(buf.len()).to_equal(16)
        expect(buf.host_visible()).to_equal(true)
        expect(buf.write_u8(0, 7)).to_equal(true)
        expect(buf.read_u8(0)).to_equal(7)

    it "fails closed on out-of-range access and bad values":
        var buf = usm_malloc_host(4)
        expect(buf.write_u8(4, 1)).to_equal(false)
        expect(buf.write_u8(-1, 1)).to_equal(false)
        expect(buf.write_u8(0, 256)).to_equal(false)
        expect(buf.read_u8(4)).to_equal(-1)

    it "allocates device and shared memory on the None backend deterministically":
        val dev = usm_malloc_device(gpu_none(), 8)
        expect(dev.valid).to_equal(true)
        expect(dev.kind).to_equal("device")
        expect(dev.host_visible()).to_equal(true)
        val shared = usm_malloc_shared(gpu_none(), 8)
        expect(shared.valid).to_equal(true)
        expect(shared.kind).to_equal("shared")

    it "copies bytes between buffers fail-closed":
        var src = usm_malloc_host(4)
        var dst = usm_malloc_shared(gpu_none(), 4)
        expect(src.write_u8(0, 42)).to_equal(true)
        expect(src.write_u8(3, 9)).to_equal(true)
        expect(dst.copy_from(src, 4)).to_equal(true)
        expect(dst.read_u8(0)).to_equal(42)
        expect(dst.read_u8(3)).to_equal(9)
        expect(dst.copy_from(src, 5)).to_equal(false)

    it "rejects negative sizes and blocks use after free":
        val bad = usm_malloc_host(-1)
        expect(bad.valid).to_equal(false)
        var buf = usm_malloc_host(2)
        expect(buf.free()).to_equal(true)
        expect(buf.valid).to_equal(false)
        expect(buf.write_u8(0, 1)).to_equal(false)
        expect(buf.free()).to_equal(false)
