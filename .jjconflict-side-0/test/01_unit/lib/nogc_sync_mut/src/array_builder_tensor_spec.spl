use std.spec.*
use std.nogc_sync_mut.src.array_builder.{ArrayBuilder}
use std.nogc_sync_mut.src.tensor.{Device, Tensor}

describe "nogc_sync_mut source collection helpers":
    it "builds, grows, truncates, and clears typed arrays":
        var builder: ArrayBuilder<i64> = ArrayBuilder.with_capacity(2)
        builder.push(10)
        builder.push_unchecked(20)
        builder.push_safe(30)

        expect(builder.len()).to_equal(3)
        expect(builder.capacity()).to_equal(4)
        expect(builder.build()).to_equal([10, 20, 30])

        builder.truncate(2)
        expect(builder.build()).to_equal([10, 20])
        expect(builder.capacity()).to_equal(4)
        builder.push(40)
        builder.push(50)
        expect(builder.build()).to_equal([10, 20, 40, 50])
        expect(builder.capacity()).to_equal(4)
        builder.push(60)
        expect(builder.build()).to_equal([10, 20, 40, 50, 60])
        expect(builder.capacity()).to_equal(8)
        builder.clear()
        expect(builder.is_empty()).to_equal(true)
        expect(builder.build().len()).to_equal(0)

    it "uses the const rank parameter for tensor rank":
        val tensor = Tensor<i64, 2>(
            _handle: 0,
            _shape: [2, 3],
            _device: Device.cpu()
        )

        expect(tensor.ndim()).to_equal(2)
        expect(tensor.numel()).to_equal(6)
