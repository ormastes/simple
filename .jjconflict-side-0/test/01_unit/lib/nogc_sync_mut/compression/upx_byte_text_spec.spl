use std.spec
use std.nogc_sync_mut.compress.upx.{upx_path_bytes_to_text}

describe "nogc_sync_mut UPX path byte conversion":
    it "decodes path bytes without text.from_utf8":
        val decoded = upx_path_bytes_to_text([47u8, 116u8, 109u8, 112u8, 47u8, 117u8, 112u8, 120u8, 10u8, 13u8, 9u8, 255u8])
        expect(decoded).to_equal("/tmp/upx\n\r\t?")
