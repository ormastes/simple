# Skia Vulkan Backend — Hardening Spec
#
# Tests init guards on VulkanBackend.render_picture and .submit:
#   - vk_backend_new() returns initialized=false; render_picture/submit return
#     empty/false results without panicking.
#   - vk_backend_init(valid_ctx) returns initialized=true and allows real work.
#   - vk_backend_init(invalid_ctx) sets last_error and blocks render_picture.
#   - SkVulkanContext validity gating.
#
# Run: bin/simple test test/01_unit/lib/skia/vulkan_backend_harden_spec.spl

use std.spec.{describe, context, it, expect, assert_true, assert_false, assert_equal}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.picture.{SkPicture, SkPictureOp, sk_picture_empty}
use std.skia.backend.vulkan.backend.{
    VulkanBackend, VulkanSubmissionRecord, CommandBufferRecord,
    vk_backend_new, vk_backend_init,
    SkVulkanContext, sk_vulkan_context_default, sk_vulkan_context_init
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

fn _cull_rect() -> SkRect:
    SkRect(left: 0.0, top: 0.0, right: 100.0, bottom: 100.0)

fn _picture_n(n: i64) -> SkPicture:
    val empty_ops: [SkPictureOp] = []
    SkPicture(cull_rect: _cull_rect(), op_count: n, ops: empty_ops)

describe "SkVulkanContext — validity gating":

    context "default context":

        it "sk_vulkan_context_default is_valid returns false":
            val ctx = sk_vulkan_context_default()
            assert_false(ctx.is_valid())

    context "init context":

        it "sk_vulkan_context_init(0) is_valid returns true":
            val ctx = sk_vulkan_context_init(0)
            assert_true(ctx.is_valid())

        it "sk_vulkan_context_init(1) is_valid returns true":
            val ctx = sk_vulkan_context_init(1)
            assert_true(ctx.is_valid())

describe "VulkanBackend — init guards":

    context "vk_backend_new() is initialized (context-free pipeline path)":

        it "vk_backend_new returns initialized=true":
            val b = vk_backend_new()
            assert_true(b.initialized)

        it "vk_backend_new has empty last_error":
            val b = vk_backend_new()
            assert_equal(b.last_error, "")

        it "render_picture on vk_backend_new produces commands for ops":
            var b = vk_backend_new()
            val pic = _picture_n(2)
            val rec = b.render_picture(pic, _cull_rect())
            # 2 ops × 2 cmds (BindPipeline + Draw) = 4 commands
            assert_equal(rec.commands.len(), 4)

        it "submit on vk_backend_new with well-formed record reports ok":
            var b = vk_backend_new()
            val pic = _picture_n(1)
            val rec = b.render_picture(pic, _cull_rect())
            val sr = b.submit(rec)
            assert_true(sr.ok)

    context "vk_backend_init with invalid context":

        it "invalid context produces initialized=false backend":
            val ctx = sk_vulkan_context_default()
            val b = vk_backend_init(ctx)
            assert_false(b.initialized)

        it "invalid context backend has non-empty last_error":
            val ctx = sk_vulkan_context_default()
            val b = vk_backend_init(ctx)
            expect(b.last_error).to_not_equal("")

        it "render_picture on invalid-context backend returns empty record":
            val ctx = sk_vulkan_context_default()
            var b = vk_backend_init(ctx)
            val pic = _picture_n(2)
            val rec = b.render_picture(pic, _cull_rect())
            assert_equal(rec.commands.len(), 0)

    context "vk_backend_init with valid context":

        it "valid context produces initialized=true backend":
            val ctx = sk_vulkan_context_init(0)
            val b = vk_backend_init(ctx)
            assert_true(b.initialized)

        it "valid context backend has empty last_error":
            val ctx = sk_vulkan_context_init(0)
            val b = vk_backend_init(ctx)
            assert_equal(b.last_error, "")

        it "render_picture on valid-context backend produces commands for ops":
            val ctx = sk_vulkan_context_init(0)
            var b = vk_backend_init(ctx)
            val pic = _picture_n(2)
            val rec = b.render_picture(pic, _cull_rect())
            # 2 ops × 2 cmds (BindPipeline + Draw) = 4 commands
            assert_equal(rec.commands.len(), 4)

        it "submit on valid-context backend with well-formed record reports ok":
            val ctx = sk_vulkan_context_init(0)
            var b = vk_backend_init(ctx)
            val pic = _picture_n(1)
            val rec = b.render_picture(pic, _cull_rect())
            val sr = b.submit(rec)
            assert_true(sr.ok)
            assert_equal(sr.rejected_commands, 0)
