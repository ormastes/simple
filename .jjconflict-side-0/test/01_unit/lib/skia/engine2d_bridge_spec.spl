use std.spec.*
use std.skia.entity.geometry.{SkRect, sk_rect_make_xywh}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.color.{sk_color_argb}
use std.skia.entity.picture.{SkPicture, sk_picture_recorder_new, sk_picture_op_draw_rect}
use std.skia.bridge.engine2d_bridge.{skia_render_picture_on_engine2d, skia_render_picture_on_engine2d_reported}

# Record a real skia SkPicture via SkPictureRecorder: an opaque background rect
# covering the whole canvas, then a smaller opaque foreground rect at known
# coords. Replaying through the bridge must paint these pixels via the shared
# Engine2D backend lane.
#
# NB: we record through SkPictureRecorder rather than SkCanvas chaining because
# SkCanvas.draw_rect rebinds (copies) its recorder, dropping recorded ops, and
# SkCanvas.clear() discards its color arg. The recorder path is the genuine
# SkPicture op-recording API.
fn _record_two_rects(w: i32, h: i32, bg: i64, fg: i64) -> SkPicture:
    val full = SkRect(left: 0.0, top: 0.0, right: w.to_f64(), bottom: h.to_f64())
    val rec = sk_picture_recorder_new().begin_recording(full)
    rec.record(sk_picture_op_draw_rect(full, sk_paint_fill(bg)))
    # Foreground 8x6 rect at (4,3) — interior pixel (8,5) is inside.
    val fg_rect = sk_rect_make_xywh(4.0, 3.0, 8.0, 6.0)
    rec.record(sk_picture_op_draw_rect(fg_rect, sk_paint_fill(fg)))
    rec.finish_recording()

describe "SkiaEngine2DBridge":

    it "replays skia rect ops onto the shared Engine2D cpu_simd backend lane":
        val w = 24
        val h = 16
        val bg = sk_color_argb(255, 0x12, 0x34, 0x56)   # 0xFF123456
        val fg = sk_color_argb(255, 0xEF, 0x44, 0x44)   # 0xFFEF4444
        val pic = _record_two_rects(w, h, bg, fg)
        val pixels = skia_render_picture_on_engine2d(pic, w, h, "cpu_simd")

        # Buffer is the right size.
        expect(pixels.len()).to_equal(w * h)

        # A pixel INSIDE the fg rect (8,5) == the fg paint color.
        val inside = pixels[8 + 5 * w]
        expect(inside).to_equal(0xFFEF4444u32)

        # A pixel OUTSIDE the fg rect (20,14) == the background color.
        val outside = pixels[20 + 14 * w]
        expect(outside).to_equal(0xFF123456u32)

    it "replays the same picture on the software backend lane":
        val w = 24
        val h = 16
        val bg = sk_color_argb(255, 0x12, 0x34, 0x56)
        val fg = sk_color_argb(255, 0xEF, 0x44, 0x44)
        val pic = _record_two_rects(w, h, bg, fg)
        val pixels = skia_render_picture_on_engine2d(pic, w, h, "software")

        expect(pixels.len()).to_equal(w * h)
        expect(pixels[8 + 5 * w]).to_equal(0xFFEF4444u32)
        expect(pixels[20 + 14 * w]).to_equal(0xFF123456u32)

    it "reports both fill rects as mapped with nothing skipped":
        val w = 24
        val h = 16
        val bg = sk_color_argb(255, 0x12, 0x34, 0x56)
        val fg = sk_color_argb(255, 0xEF, 0x44, 0x44)
        val pic = _record_two_rects(w, h, bg, fg)
        val result = skia_render_picture_on_engine2d_reported(pic, w, h, "cpu_simd")

        expect(result.report.mapped_rects).to_equal(2)
        expect(result.report.skipped).to_equal(0)
