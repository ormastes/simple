use std.gc_async_mut.smtp.types.{response_parse_code, response_parse_message, response_is_multiline}

describe "SMTP response parsing":
    it "parses numeric response code":
        expect(response_parse_code("250 OK")).to_equal(250)

    it "returns zero for short response code":
        expect(response_parse_code("25")).to_equal(0)

    it "returns zero for malformed response code":
        expect(response_parse_code("2x0 bad")).to_equal(0)

    it "parses response message":
        expect(response_parse_message("250 OK")).to_equal("OK")

    it "detects multiline response marker":
        expect(response_is_multiline("250-hello")).to_equal(true)
