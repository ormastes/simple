# Metal 3D Backend — Hardening Spec
#
# Tests the Metal 3D backend hardening paths:
#   - init() allocates buffers and sets initialized=true
#   - last_error is "" after successful init
#   - draw methods are no-ops when not initialized
#   - last_error is set when methods called before init
#   - read_pixels() and read_depth() return empty arrays before init
#   - shutdown() sets initialized=false
#   - Extension methods return safe sentinel values when not initialized
#
# All tests run in interpreter mode (software rasterizer, no Metal device needed).
#
# Run: bin/simple test test/01_unit/lib/gc_async_mut/gpu/engine3d/backend_metal3d_hardening_spec.spl

use std.spec.{describe, it, expect, assert_true, assert_false, assert_equal}
use std.gc_async_mut.gpu.engine3d.backend_metal.{MetalBackend3D}
use std.gpu.engine3d.types3d.{
    Vertex3D, Material3DParams,
    MATERIAL_UNLIT, mat4_identity
}

fn _make_vertex(px: f32, py: f32, pz: f32) -> Vertex3D:
    Vertex3D(
        px: px, py: py, pz: pz,
        nx: 0.0, ny: 0.0, nz: 1.0,
        u: 0.0, v: 0.0,
        color: 0xFFFFFFFF
    )

fn _make_material() -> Material3DParams:
    Material3DParams(
        kind: MATERIAL_UNLIT,
        albedo: 0xFF0000FF,
        specular: 0xFFFFFFFF,
        shininess: 32.0,
        roughness: 0.5,
        metallic: 0.0
    )

describe "Metal 3D backend — create and init":

    it "create() returns uninitialized backend":
        val b = MetalBackend3D.create()
        assert_false(b.initialized)

    it "create() sets last_error to empty":
        val b = MetalBackend3D.create()
        assert_equal(b.last_error, "")

    it "init() returns true (software fallback always succeeds)":
        var b = MetalBackend3D.create()
        val result = b.init(64, 64)
        assert_true(result)

    it "initialized is true after init":
        var b = MetalBackend3D.create()
        b.init(64, 64)
        assert_true(b.initialized)

    it "last_error is empty after successful init":
        var b = MetalBackend3D.create()
        b.init(64, 64)
        assert_equal(b.last_error, "")

    it "width() returns correct value after init":
        var b = MetalBackend3D.create()
        b.init(64, 32)
        assert_equal(b.width(), 64)

    it "height() returns correct value after init":
        var b = MetalBackend3D.create()
        b.init(64, 32)
        assert_equal(b.height(), 32)

    it "buf is sized w*h after init":
        var b = MetalBackend3D.create()
        b.init(8, 8)
        assert_equal(b.buf.len(), 64)

    it "depth is sized w*h after init":
        var b = MetalBackend3D.create()
        b.init(8, 8)
        assert_equal(b.depth.len(), 64)

describe "Metal 3D backend — draw methods no-op when not initialized":

    it "clear() sets last_error when not initialized":
        var b = MetalBackend3D.create()
        b.clear(0xFF0000FF)
        assert_true(b.last_error.len() > 0)

    it "clear_depth() sets last_error when not initialized":
        var b = MetalBackend3D.create()
        b.clear_depth()
        assert_true(b.last_error.len() > 0)

    it "begin_frame() sets last_error when not initialized":
        var b = MetalBackend3D.create()
        b.begin_frame()
        assert_true(b.last_error.len() > 0)

    it "submit_triangle() sets last_error when not initialized":
        var b = MetalBackend3D.create()
        val v0 = _make_vertex(0.0, 0.0, 0.0)
        val v1 = _make_vertex(1.0, 0.0, 0.0)
        val v2 = _make_vertex(0.0, 1.0, 0.0)
        val mat = _make_material()
        val model = mat4_identity()
        b.submit_triangle(v0, v1, v2, mat, model)
        assert_true(b.last_error.len() > 0)

    it "draw_image() sets last_error when not initialized":
        var b = MetalBackend3D.create()
        val pixels: [u32] = [0xFF0000FFu32; 4]
        b.draw_image(0, 0, 2, 2, pixels)
        assert_true(b.last_error.len() > 0)

    it "draw_cube() sets last_error when not initialized":
        var b = MetalBackend3D.create()
        val model = mat4_identity()
        val mat = _make_material()
        b.draw_cube(model, mat)
        assert_true(b.last_error.len() > 0)

    it "buf remains empty when draw called before init":
        var b = MetalBackend3D.create()
        b.clear(0xFF0000FF)
        assert_equal(b.buf.len(), 0)

describe "Metal 3D backend — read_pixels and read_depth before init":

    it "read_pixels() returns empty array before init":
        val b = MetalBackend3D.create()
        val pixels = b.read_pixels()
        assert_equal(pixels.len(), 0)

    it "read_depth() returns empty array before init":
        val b = MetalBackend3D.create()
        val depth = b.read_depth()
        assert_equal(depth.len(), 0)

    it "read_pixels() returns w*h pixels after init":
        var b = MetalBackend3D.create()
        b.init(8, 8)
        val pixels = b.read_pixels()
        assert_equal(pixels.len(), 64)

    it "read_depth() returns w*h depths after init":
        var b = MetalBackend3D.create()
        b.init(8, 8)
        val depth = b.read_depth()
        assert_equal(depth.len(), 64)

describe "Metal 3D backend — clear writes pixels after init":

    it "clear() fills buf with given color":
        var b = MetalBackend3D.create()
        b.init(4, 4)
        b.clear(0xDEADBEEFu32)
        val pixels = b.read_pixels()
        assert_equal(pixels[0], 0xDEADBEEFu32)
        assert_equal(pixels[15], 0xDEADBEEFu32)

describe "Metal 3D backend — shutdown":

    it "shutdown sets initialized=false":
        var b = MetalBackend3D.create()
        b.init(16, 16)
        b.shutdown()
        assert_false(b.initialized)

    it "draw methods set last_error after shutdown":
        var b = MetalBackend3D.create()
        b.init(16, 16)
        b.shutdown()
        b.clear(0xFF0000FF)
        assert_true(b.last_error.len() > 0)

describe "Metal 3D backend ext — init guards on extension methods":

    it "create_shader returns -1 when not initialized":
        var b = MetalBackend3D.create()
        val result = b.create_shader("", "")
        assert_equal(result, -1)

    it "create_pipeline returns -1 when not initialized":
        var b = MetalBackend3D.create()
        val result = b.create_pipeline(0, true, 0, 0)
        assert_equal(result, -1)

    it "create_storage_buffer returns -1 when not initialized":
        var b = MetalBackend3D.create()
        val result = b.create_storage_buffer(256)
        assert_equal(result, -1)

    it "read_buffer returns empty when not initialized":
        var b = MetalBackend3D.create()
        val result = b.read_buffer(0)
        assert_equal(result.len(), 0)

    it "occlusion_query returns -1 when not initialized":
        var b = MetalBackend3D.create()
        val result = b.occlusion_query(0, 0, 4, 4)
        assert_equal(result, -1)

    it "read_texture returns empty when not initialized":
        var b = MetalBackend3D.create()
        val result = b.read_texture(0, 0, 0)
        assert_equal(result.len(), 0)

    it "create_shader sets last_error when not initialized":
        var b = MetalBackend3D.create()
        b.create_shader("", "")
        assert_true(b.last_error.len() > 0)

