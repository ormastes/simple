extern fn rt_file_read_text(path: text) -> text

fn _contains_quic_crypto_negative_guards(path: text) -> bool:
    val source = rt_file_read_text(path) ?? ""
    return source.to_contain("fn crypto_buffer_append(buf: [u8], data: [u8], offset: i64) -> [u8]:") and
        source.to_contain("if offset < 0:\n        return buf") and
        source.to_contain("fn parse_tls_handshake_header(data: [u8], offset: i64) -> (i64, i64, i64):") and
        source.to_contain("if offset < 0:\n        return (0, 0, 0)") and
        source.to_contain("out[offset + di] = data[di]") and
        source.to_contain("val msg_type = data[offset]")

describe "QUIC crypto negative offset guards":
    it "guards crypto buffer and handshake readers before indexed reads":
        expect(_contains_quic_crypto_negative_guards("src/lib/nogc_async_mut/io/quic/quic_crypto.spl")).to_equal(true)
