use std.spec.{describe, it, assert_equal}
use std.nogc_async_mut.io.tls_common.{bytes_to_wire}

describe "tls common wire byte guards":
    it "keeps empty wire bytes empty":
        assert_equal(bytes_to_wire([]), "")

    it "rejects negative wire bytes":
        assert_equal(bytes_to_wire([-1]), "")

    it "rejects wire bytes above 255":
        assert_equal(bytes_to_wire([65, 300]), "")
