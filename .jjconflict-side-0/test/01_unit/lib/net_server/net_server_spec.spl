"""Net Server — Unit Specification

@cover src/lib/nogc_sync_mut/net_server/listener.spl 80%
@cover src/lib/nogc_sync_mut/net_server/connection.spl 80%

Tests transport plumbing only: bind, accept, dispatch, echo.
No protocol logic is exercised.

Loopback Echo Pattern (single-threaded):
  1. Bind listener on 127.0.0.1:0 — OS assigns ephemeral port.
  2. Connect client — OS queues the connection.
  3. serve_once() with accept_timeout — OS returns the queued fd.
  4. Handler echoes bytes back; client reads and verifies.

Related:
  src/lib/nogc_sync_mut/net_server/listener.spl
  src/lib/nogc_sync_mut/net_server/connection.spl
  test/01_unit/lib/host_io/net_async_spec.spl
"""

use std.spec
use std.nogc_sync_mut.net_server.listener.{NetServer}
use std.nogc_sync_mut.net_server.connection.{ConnectionHandler}
use std.nogc_sync_mut.io.tcp.{TcpStream}
use std.io.types.{IoError}

# ============================================================================
# Echo handler — reads N bytes and writes them back
# ============================================================================

class EchoHandler with ConnectionHandler:
    """Reads exactly `read_size` bytes then writes them back verbatim."""
    read_size: i64
    received: [u8]
    did_run: bool

    me handle(stream: TcpStream) -> bool:
        val read_result = stream.read_exact(self.read_size)
        match read_result:
            Err(_):
                val _ = stream.close()
                return true
            Ok(data):
                self.received = data
                self.did_run = true
                val _ = stream.write_all(data)
                val _ = stream.flush()
                val _ = stream.close()
        return true

# ============================================================================
# StopHandler — immediately returns false to stop the serve loop
# ============================================================================

class StopHandler with ConnectionHandler:
    me handle(stream: TcpStream) -> bool:
        val _ = stream.close()
        return false

# ============================================================================
# Specs
# ============================================================================

describe "NetServer bind and local_addr":

    it "binds to ephemeral port and reports 127.0.0.1 address":
        val bind_result = NetServer.bind("127.0.0.1", 0)
        var srv = match bind_result:
            Err(_): panic("bind failed")
            Ok(s): s
        val addr_result = srv.local_addr()
        val addr = match addr_result:
            Err(_): panic("local_addr failed")
            Ok(a): a
        expect(addr.contains("127.0.0.1")).to_equal(true)
        expect(addr.len() > 9).to_equal(true)
        val _ = srv.close()

    it "is_open returns true after bind":
        val bind_result = NetServer.bind("127.0.0.1", 0)
        var srv = match bind_result:
            Err(_): panic("bind failed")
            Ok(s): s
        expect(srv.is_open()).to_equal(true)
        val _ = srv.close()

    it "is_open returns false after close":
        val bind_result = NetServer.bind("127.0.0.1", 0)
        var srv = match bind_result:
            Err(_): panic("bind failed")
            Ok(s): s
        val _ = srv.close()
        expect(srv.is_open()).to_equal(false)


describe "NetServer loopback echo — absolute oracle":
    # ASCII "Hello" = [72, 101, 108, 108, 111]
    # Single-threaded: connect first (OS queues), then serve_once accepts.

    it "serve_once dispatches connection and echoes payload byte-exactly":
        val bind_result = NetServer.bind("127.0.0.1", 0)
        var srv = match bind_result:
            Err(_): panic("bind failed")
            Ok(s): s
        val addr_result = srv.local_addr()
        val addr = match addr_result:
            Err(_): panic("local_addr failed")
            Ok(a): a

        # Client connects before accept — OS queues the SYN
        val c_result = TcpStream.connect(addr)
        var client = match c_result:
            Err(_): panic("connect failed")
            Ok(c): c

        # Set up echo handler (5 bytes)
        var handler = EchoHandler(read_size: 5, received: [], did_run: false)

        # Client writes [72, 101, 108, 108, 111] = "Hello"
        val payload: [u8] = [72, 101, 108, 108, 111]
        val w_result = client.write_all(payload)
        match w_result:
            Err(_): panic("client write failed")
            Ok(_): pass
        val _ = client.flush()

        # Server accepts and handles the queued connection
        val once_result = srv.serve_once(handler)
        val cont = match once_result:
            Err(e): panic("serve_once failed")
            Ok(c): c
        expect(cont).to_equal(true)

        # Read echo response on client side
        val r_result = client.read_exact(5)
        var echoed = match r_result:
            Err(_): panic("client read failed")
            Ok(d): d

        # Absolute oracle: byte-exact equality
        expect(echoed.len()).to_equal(5)
        expect(echoed[0]).to_equal(72)
        expect(echoed[1]).to_equal(101)
        expect(echoed[2]).to_equal(108)
        expect(echoed[3]).to_equal(108)
        expect(echoed[4]).to_equal(111)

        val _ = client.close()
        val _ = srv.close()

    it "handler receives the exact bytes the client sent":
        val bind_result = NetServer.bind("127.0.0.1", 0)
        var srv = match bind_result:
            Err(_): panic("bind failed")
            Ok(s): s
        val addr_result = srv.local_addr()
        val addr = match addr_result:
            Err(_): panic("local_addr failed")
            Ok(a): a

        val c_result = TcpStream.connect(addr)
        var client = match c_result:
            Err(_): panic("connect failed")
            Ok(c): c

        var handler = EchoHandler(read_size: 3, received: [], did_run: false)

        # ASCII "ABC" = [65, 66, 67]
        val payload: [u8] = [65, 66, 67]
        val w_result = client.write_all(payload)
        match w_result:
            Err(_): panic("client write failed")
            Ok(_): pass
        val _ = client.flush()

        val once_result = srv.serve_once(handler)
        match once_result:
            Err(_): panic("serve_once failed")
            Ok(_): pass

        expect(handler.did_run).to_equal(true)
        expect(handler.received.len()).to_equal(3)
        expect(handler.received[0]).to_equal(65)
        expect(handler.received[1]).to_equal(66)
        expect(handler.received[2]).to_equal(67)

        val _ = client.close()
        val _ = srv.close()


describe "NetServer serve_n bounded loop":

    it "serve_n handles exactly n connections":
        val bind_result = NetServer.bind("127.0.0.1", 0)
        var srv = match bind_result:
            Err(_): panic("bind failed")
            Ok(s): s
        val addr_result = srv.local_addr()
        val addr = match addr_result:
            Err(_): panic("local_addr failed")
            Ok(a): a

        # Pre-queue 2 connections before accepting
        val c1_result = TcpStream.connect(addr)
        var c1 = match c1_result:
            Err(_): panic("connect c1 failed")
            Ok(c): c

        val c2_result = TcpStream.connect(addr)
        var c2 = match c2_result:
            Err(_): panic("connect c2 failed")
            Ok(c): c

        # Tiny payload so EchoHandler doesn't block
        val payload: [u8] = [1]
        val _ = c1.write_all(payload)
        val _ = c1.flush()
        val _ = c2.write_all(payload)
        val _ = c2.flush()

        var handler = EchoHandler(read_size: 1, received: [], did_run: false)
        val n_result = srv.serve_n(handler, 2)
        match n_result:
            Err(_): panic("serve_n failed")
            Ok(_): pass

        # handler.did_run only reflects the last call (value copy semantics)
        expect(handler.did_run).to_equal(true)

        val _ = c1.close()
        val _ = c2.close()
        val _ = srv.close()


describe "NetServer stop via handler return false":

    it "serve_once returns Ok(false) when StopHandler returns false":
        val bind_result = NetServer.bind("127.0.0.1", 0)
        var srv = match bind_result:
            Err(_): panic("bind failed")
            Ok(s): s
        val addr_result = srv.local_addr()
        val addr = match addr_result:
            Err(_): panic("local_addr failed")
            Ok(a): a

        val c_result = TcpStream.connect(addr)
        var client = match c_result:
            Err(_): panic("connect failed")
            Ok(c): c

        var handler = StopHandler()
        val once_result = srv.serve_once(handler)
        val cont = match once_result:
            Err(_): panic("serve_once failed")
            Ok(c): c

        expect(cont).to_equal(false)

        val _ = client.close()
        val _ = srv.close()
