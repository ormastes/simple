use std.spec.*
use std.io_runtime.{rt_file_read_text}

describe "release workflow checker contracts":
    it "tracks every checker invoked by release workflows":
        val release = rt_file_read_text(".github/workflows/release.yml") ?? ""
        val publish = rt_file_read_text(".github/workflows/publish.yml") ?? ""
        val simpleos = rt_file_read_text(".github/workflows/simpleos-build.yml") ?? ""

        for path in [
            "scripts/check-executable-size-budgets.shs",
            "scripts/check_release_payload.shs",
            "scripts/check-simpleos-bootstrap-qemu.shs"
        ]:
            expect((rt_file_read_text(path) ?? "").len()).to_be_greater_than(0)
            expect(release).to_contain(path)
        expect((rt_file_read_text("scripts/check-mcp-release-assets.shs") ?? "").len()).to_be_greater_than(0)
        expect(publish).to_contain("scripts/check-mcp-release-assets.shs")
        expect(simpleos).to_contain("scripts/check-simpleos-bootstrap-qemu.shs")

    it "keeps the four wrappers fail closed at their current owners":
        val sizes = rt_file_read_text("scripts/check-executable-size-budgets.shs") ?? ""
        val payload = rt_file_read_text("scripts/check_release_payload.shs") ?? ""
        val os = rt_file_read_text("scripts/check-simpleos-bootstrap-qemu.shs") ?? ""
        val mcp = rt_file_read_text("scripts/check-mcp-release-assets.shs") ?? ""

        expect(sizes).to_contain("simple|simple.exe|simple-runtime")
        expect(sizes).to_contain("--skip-missing")
        expect(sizes).to_contain("SIMPLE_SIZE_BUDGET_NATIVE_LOADER_RLIB")
        expect(sizes).to_contain("SIMPLE_SIZE_BUDGET_NATIVE_ALL_A")
        expect(sizes).to_contain("release executable is not stripped")
        expect(payload).to_contain("bundled font path set differs from repository")
        expect(payload).to_contain("bundled font bytes differ")
        expect(payload).to_contain("unsafe archive path")
        expect(payload).to_contain("archive has multiple top-level payload roots")
        expect(payload).to_contain("archive symlink escapes payload root")
        expect(payload).to_contain("archive hardlink entries are not allowed")
        expect(os).to_contain("\"$SIMPLE_BIN\" os test \"--scenario=$1\"")
        expect(os).to_contain("run_scenario x64-nvme-fat32")
        expect(os).to_contain("run_scenario x64-full-stack")
        expect(os.contains("scripts/os_qemu_test.shs")).to_be(false)
        expect(mcp).to_contain("gh release download")
        expect(mcp).to_contain("sha256sum -c")
        expect(mcp).to_contain("release runtime missing bin/$NATIVE_NAME")
        expect(mcp).to_contain("SIMPLE_MCP_RELEASE_ASSET_DIR")
