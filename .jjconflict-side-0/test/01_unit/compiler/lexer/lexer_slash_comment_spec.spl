use compiler.frontend.core.lexer.{lex_init, lex_next, lex_token_text, lex_token_line, lex_token_col}

describe "CoreLexer slash comments":
    it "rejects C-style comments at their source location":
        lex_init("// note\nval y = 2\n")
        expect(lex_next()).to_equal(191)
        expect(lex_token_text()).to_equal("use # for comments")
        expect(lex_token_line()).to_equal(1)
        expect(lex_token_col()).to_equal(1)

    it "preserves division and division assignment":
        lex_init("/ /=")
        expect(lex_next()).to_equal(63)
        expect(lex_next()).to_equal(104)
