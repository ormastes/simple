extern fn rt_file_read_text(path: text) -> text

describe "HIR statement payload extraction source":
    it "keeps pre-dispatched payloads on their concrete parser types":
        val source = rt_file_read_text("src/compiler/20.hir/hir_lowering/statements.spl") ?? ""
        val lower_start = source.index_of("    me lower_hir_stmt(s: Stmt) -> HirStmt:") ?? -1
        expect(lower_start).to_be_greater_than(-1)
        val lower_body = source.substring(lower_start, source.len())

        expect(lower_body).to_contain("val v_name: text = match stmt_kind_value:")
        expect(lower_body).to_contain("val v_type: Type? = match stmt_kind_value:")
        expect(lower_body).to_contain("val v_init: Expr = match stmt_kind_value:")
        expect(lower_body).to_contain("val vr_init: Expr? = match stmt_kind_value:")
        expect(lower_body).to_contain("val as_target: Expr = match stmt_kind_value:")
        expect(lower_body).to_contain("val as_op: AssignOp? = match stmt_kind_value:")
        expect(lower_body).to_contain("val as_value: Expr = match stmt_kind_value:")
        expect(lower_body).to_contain("val expr_t: Expr = match stmt_kind_value:")

    it "extracts optional Return payload by pattern instead of the lossy enum helper":
        val source = rt_file_read_text("src/compiler/20.hir/hir_lowering/statements.spl") ?? ""
        val lower_start = source.index_of("    me lower_hir_stmt(s: Stmt) -> HirStmt:") ?? -1
        expect(lower_start).to_be_greater_than(-1)
        val lower_body = source.substring(lower_start, source.len())

        expect(lower_body).to_contain("case StmtKind.Return(rvalue):\n                    rvalue")
        expect(lower_body.contains("val rt_val: Expr = rt_enum_payload(stmt_kind_value)")).to_equal(false)
