enum MiniRecordResult:
    Ok(content_type: i64, data: [u8])
    Err(msg: text)

fn main():
    var bytes: [u8] = []
    bytes.push(0x41u8)
    val dec = MiniRecordResult.Ok(content_type: 0x17, data: bytes)

    var ct = -1
    var len = -1
    if val MiniRecordResult.Ok(inner_ct, dec_data) = dec:
        ct = inner_ct
        len = dec_data.len().to_i64()

    if ct == 23 and len == 1:
        print("PASS")
    else:
        print("FAIL ct={ct} len={len}")
