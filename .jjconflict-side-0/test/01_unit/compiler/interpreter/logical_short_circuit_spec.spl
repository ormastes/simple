describe "interpreter logical short circuit":
    it "skips the right side when and is already false":
        expect(false and (1 / 0 == 0)).to_equal(false)

    it "skips the right side when or is already true":
        expect(true or (1 / 0 == 0)).to_equal(true)

    it "evaluates the right side when it is required":
        expect(true and true).to_equal(true)
        expect(false or true).to_equal(true)
