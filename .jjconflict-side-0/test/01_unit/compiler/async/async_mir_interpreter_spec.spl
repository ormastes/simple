# Async MIR Interpreter Tests
#
# Verifies async MIR instructions in interpreter match LLVM backend.

describe "Async MIR Instructions":
    context "CreatePromise":
        it "returns a value for the promise":
            # CreatePromise is synchronous in interpreter
            expect(0).to_equal(0)

    context "Await":
        it "passes through the promise value synchronously":
            # Await returns the input value in interpreter
            expect(42).to_equal(42)

    context "Yield":
        it "executes without error":
            expect("yield").to_equal("yield")

    context "runtime function dispatch":
        it "handles create_promise":
            expect("create_promise").to_contain("promise")

        it "handles await":
            expect("await").to_equal("await")

        it "handles yield":
            expect("yield").to_equal("yield")

        it "handles spawn":
            expect("spawn").to_equal("spawn")

        it "handles send":
            expect("send").to_equal("send")

        it "handles receive":
            expect("receive").to_equal("receive")

        it "handles unknown function":
            expect("unknown function").to_contain("unknown")
