# # Formatter Core Unit Tests
#
# Direct in-process tests of `compiler.tools.formatter`
# (src/compiler/90.tools/formatter/main.spl) via `Formatter.format_source`,
# feeding literal source strings (no file I/O, no subprocess). See
# test/03_system/app/fmt_doccov_contract_spec.spl for the CLI-level contract
# (subprocess, fixtures, exit codes for `--check`/`--write`).
#
# Known seed-only caveat (2026-07-17): under both `run <spec>` and
# `test <spec>` on src/compiler_rust/target/release/simple, the 5 examples
# below genuinely execute and pass ("5 examples, 0 failures" /
# "Passed: 5"), but the file-level result is still reported FAIL / the
# process exits nonzero. This is the same seed/interpreter exit-code-taint
# class already documented for other specs (see
# test/01_unit/app/io/process_limits_enforcement_spec.spl and
# doc/08_tracking/bug/host_toolchain_seed_pinned_lint_fmt_doccov_unrunnable_2026-07-17.md)
# -- not a defect in the formatter logic under test here.

use compiler.tools.formatter.main.{make_formatter}

fn formatted_or_fail(source: text) -> text:
    val fmt = make_formatter()
    val result = fmt.format_source(source)
    match result:
        case Ok(formatted):
            formatted
        case Err(e):
            "FORMAT_ERROR: {e}"

describe "compiler.tools.formatter Formatter.format_source":
    """Feeds literal source strings directly to the formatter and checks
    specific, real rewrites it performs (not just "output != input")."""

    it "adds spaces around a binary + operator":
        val out = formatted_or_fail("fn add(a: i64, b: i64) -> i64:\n    a+b\n")
        assert_contains(out, "a + b")

    it "adds a space after a comma in a parameter list":
        val out = formatted_or_fail("fn add(a:i64,b:i64) -> i64:\n    a + b\n")
        assert_contains(out, "a:i64, b:i64")

    it "adds spaces around the -> return-type arrow":
        val out = formatted_or_fail("fn add(a: i64, b: i64)->i64:\n    a + b\n")
        assert_contains(out, ") -> i64:")

    it "preserves a hyphenated word in a full-line comment verbatim":
        """Regression: add_expression_spacing used to run on comment lines
        too, rewriting `pure-Simple` to `pure - Simple` and tripping the
        formatter's own lexical-equivalence guard (fixed 2026-07-17; see
        doc/08_tracking/bug/host_toolchain_seed_pinned_lint_fmt_doccov_unrunnable_2026-07-17.md)."""
        val out = formatted_or_fail("# a pure-Simple comment\nfn add(a: i64, b: i64) -> i64:\n    a + b\n")
        assert_contains(out, "# a pure-Simple comment")

    it "is idempotent: formatting already-formatted source changes nothing":
        val once = formatted_or_fail("fn add(a:i64,b:i64)->i64:\n    a+b\n")
        val twice = formatted_or_fail(once)
        assert_equal(once, twice)
