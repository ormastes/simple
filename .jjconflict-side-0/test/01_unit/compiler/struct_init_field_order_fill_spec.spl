# Regression spec: struct-init field values must land in the DECLARED field
# slot regardless of the order named args are written in, and a field
# omitted at the call site must zero/nil-fill rather than bleeding a
# neighboring argument's value into its slot.
#
# Mirrors Rust-seed fix 6b59a8c4bf7 ("lower struct-init fields by declared
# order with nil default fill"). Self-hosted mirror site:
# src/compiler/50.mir/_MirLoweringExpr/switch_operators_calls.spl
# `lower_struct_construct`.
#
# Surface bug (pre-fix): the field-selection loop there defaulted every
# declared field to `args[fi]` (or, once `fi` ran past the end of `args`, a
# repeated `args[0]`) and only overrode that guess when some LATER arg's
# NAME happened to match the field being visited. A field with no matching
# named arg (e.g. `Triple(b: 5)` omitting `a` and `c`) silently inherited an
# unrelated arg's value instead of a zero/nil fill -- and reading `args[0]`
# with zero args supplied was an out-of-bounds access.
#
# tag: unit

struct Triple:
    a: i64
    b: i64
    c: i64

describe "struct-init field ordering and omitted-field fill":
    it "fills omitted leading and trailing fields with zero, not a neighbor's value":
        val t = Triple(b: 5)
        expect(t.a).to_equal(0)
        expect(t.b).to_equal(5)
        expect(t.c).to_equal(0)

    it "fills an omitted middle field with zero":
        val t = Triple(a: 1, c: 3)
        expect(t.a).to_equal(1)
        expect(t.b).to_equal(0)
        expect(t.c).to_equal(3)

    it "keeps fully positional construction working":
        val t = Triple(1, 2, 3)
        expect(t.a).to_equal(1)
        expect(t.b).to_equal(2)
        expect(t.c).to_equal(3)

    it "keeps reordered named-arg construction working":
        val t = Triple(c: 3, a: 1, b: 2)
        expect(t.a).to_equal(1)
        expect(t.b).to_equal(2)
        expect(t.c).to_equal(3)

# Brace-form coverage. Mirrors Rust-seed fix 0ee3727522d ("nil-fill declared
# defaults in interpreter brace-form StructInit"): the hosted/interpreter
# `Expr::StructInit` handler for brace form `X { a: 1, c: 3 }` built the field
# map purely from spread base + explicit fields, never consulting the class's
# declared fields, so an omitted field was missing entirely ("class has no
# field named b") instead of nil/zero-filled. The paren-form path already
# pre-filled every declared field; this fix brought brace-form to parity.
#
# The omitted-field-value assertions live in the companion interpreter-view
# spec test/01_unit/compiler/regression/struct_init_omitted_field_nil_fill_spec.spl
# (asserts nil, matching the interpreter's own construction path, and
# verified green on the current seed) rather than duplicated here as `==0`
# (this file's `==0` assertions are the COMPILED/MIR-path zero-value
# semantic and are red under direct interpretation — see that file's header
# for the full explanation).
describe "struct-init field ordering and omitted-field fill (brace form)":
    it "keeps fully specified brace construction working":
        val t = Triple { a: 1, b: 2, c: 3 }
        expect(t.a).to_equal(1)
        expect(t.b).to_equal(2)
        expect(t.c).to_equal(3)

    it "keeps reordered brace-form fields working":
        val t = Triple { c: 3, a: 1, b: 2 }
        expect(t.a).to_equal(1)
        expect(t.b).to_equal(2)
        expect(t.c).to_equal(3)

    it "brace and paren forms produce identical structs for the same omitted-field input":
        val brace_t = Triple { b: 5 }
        val paren_t = Triple(b: 5)
        expect(brace_t.a).to_equal(paren_t.a)
        expect(brace_t.b).to_equal(paren_t.b)
        expect(brace_t.c).to_equal(paren_t.c)
