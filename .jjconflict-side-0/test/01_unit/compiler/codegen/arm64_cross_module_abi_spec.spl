# ARM64 (AArch64) Cross-Module ABI Codegen Spec
#
# Documents and pins arch-sensitive codegen behaviors for the aarch64 / arm64
# target (AAPCS64 ABI, LP64 pointer model, 8 integer argument registers x0-x7).
#
# Arch-sensitive behaviors covered:
#   1. Pointer width: arm64 is LP64 (64-bit pointer). A cross-module global
#      load for a pointer-typed val must be widened to 64 bits, unlike arm32
#      (ILP32, 32-bit pointer).
#   2. ABI: AAPCS64 — integer args in x0-x7 (8 registers), float in v0-v7,
#      16-byte stack alignment. Result in x0/x1. This differs from Cortex-M
#      (AAPCS / EABI, 32-bit, r0-r3 for args).
#   3. Target family classification: "aarch64-..." and "arm64-..." triples both
#      classify as the Aarch64 family. A regression here would cause the
#      compiler to mis-classify cross-module symbol mangling or ABI selection.
#   4. Module-level val constants: macOS arm64 (Apple Silicon) and Linux arm64
#      are OS-hosted targets. ELF/Mach-O loaders initialise BSS before main(),
#      so module-level val constants are NOT subject to the baremetal_module_val_zero
#      bug (doc/08_tracking/bug/baremetal_module_val_zero_bss_2026-05-20.md).
#      Cortex-M baremetal presets ARE subject to the bug (no_std=true, no_gc=true).
#   5. Cortex-M vs AArch64 family distinction: Thumb presets (thumbv7em, thumbv8m)
#      must NOT be classified as Aarch64 — they are Arm32.
#
# Reference:
#   - baremetal_cross_module_val_spec.spl — x86_64 data-export bug
#   - native_cross_module_abi_spec.spl — x86_64 function-import ABI bug
#   - riscv64_cross_module_abi_spec.spl — rv64 ABI contracts
#   - doc/08_tracking/bug/baremetal_module_val_zero_bss_2026-05-20.md (FIXED)
#   - doc/08_tracking/bug/aarch64_lowering_emit_aesimc_x86_symbol_collision_2026-05-03.md
#
# This spec is documentation-level (hosted tests cannot easily spawn an arm64
# cross-compile). The contract facts are pinned here so regressions in
# target_presets.spl or target_family.spl are immediately visible.
# When the cross-compile test harness is unified with test/unit, this spec
# can be expanded to compile and nm-verify actual arm64 object files.

use compiler.backend.target_presets.{
    preset_macos_arm64,
    preset_cortex_m4,
    preset_cortex_m0,
    preset_is_baremetal
}
use compiler.mir_opt.mir_opt.target_family.{
    TargetFamily,
    target_family_from_triple,
    target_family_enum_from_triple
}
use compiler.backend.backend.backend_types.{CodegenTarget}

# ============================================================================
# AArch64 LP64 ABI contracts
# ============================================================================

describe "arm64 cross-module ABI contracts":

    context "pointer width — LP64":
        it "macos-arm64 preset has 64-bit pointers":
            val preset = preset_macos_arm64()
            expect(preset.pointer_width).to_equal(64)

        it "cortex-m4 has 32-bit pointers (contrast)":
            # Cross-module pointer loads on Cortex-M must NOT be widened to 64-bit.
            val preset = preset_cortex_m4()
            expect(preset.pointer_width).to_equal(32)

        it "arm64 and cortex-m4 pointer widths differ":
            val arm64 = preset_macos_arm64()
            val cm4 = preset_cortex_m4()
            expect(arm64.pointer_width).to_not_equal(cm4.pointer_width)

    context "ABI — AAPCS64 / macho":
        it "macos-arm64 preset ABI is macho":
            val preset = preset_macos_arm64()
            expect(preset.abi).to_equal("macho")

        it "macos-arm64 preset arch is aarch64":
            val preset = preset_macos_arm64()
            expect(preset.arch).to_equal("aarch64")

        it "macos-arm64 preset OS is macos":
            val preset = preset_macos_arm64()
            expect(preset.os).to_equal("macos")

        it "macos-arm64 has float support":
            val preset = preset_macos_arm64()
            expect(preset.float_support).to_equal(true)

    context "target family classification":
        it "aarch64-apple-macosx triple classifies as Aarch64":
            val family = target_family_from_triple("aarch64-apple-macosx")
            expect(family).to_equal("Aarch64")

        it "arm64-apple-macosx triple also classifies as Aarch64":
            # Both aarch64-* and arm64-* must map to Aarch64.
            # A regression here would cause the compiler to mis-apply x86 or
            # Arm32 ABI selection to cross-module calls on Apple Silicon.
            val family = target_family_from_triple("arm64-apple-macosx")
            expect(family).to_equal("Aarch64")

        it "aarch64-unknown-linux-gnu classifies as Aarch64":
            val family = target_family_from_triple("aarch64-unknown-linux-gnu")
            expect(family).to_equal("Aarch64")

        it "thumbv7em triple classifies as Arm32 not Aarch64":
            # Cortex-M4 (Thumb2 / ARMv7-M) must be Arm32, not Aarch64.
            # Misclassification would apply LP64 ABI to a 32-bit MCU.
            val family = target_family_from_triple("thumbv7em-none-eabihf")
            expect(family).to_equal("Arm32")

        it "thumbv6m triple does not classify as Aarch64":
            # Note: target_family_from_triple recognises "thumbv7" as Arm32
            # but not "thumbv6m" (it falls through to Unknown). Either way,
            # it must NOT be classified as Aarch64, which would apply LP64 ABI
            # to a 32-bit Cortex-M0 target.
            val family = target_family_from_triple("thumbv6m-none-eabi")
            expect(family).to_not_equal("Aarch64")

        it "x86_64 triple does not classify as Aarch64":
            val family = target_family_from_triple("x86_64-unknown-linux-gnu")
            expect(family).to_not_equal("Aarch64")

    context "module-level val safety (non-baremetal)":
        it "macos-arm64 is NOT a baremetal preset":
            # The Mach-O loader initialises BSS before main(), so module-level
            # val constants are NOT zero. Baremetal val-zero bug is scoped to
            # no_std=true targets only.
            val preset = preset_macos_arm64()
            expect(preset_is_baremetal(preset)).to_equal(false)

        it "macos-arm64 has no_std=false":
            val preset = preset_macos_arm64()
            expect(preset.no_std).to_equal(false)

        it "cortex-m4 IS a baremetal preset (contrast)":
            # Cortex-M4 targets DO have the val-zero risk if BSS is cleared
            # before runtime-init; module-level vals must use function-local form.
            val preset = preset_cortex_m4()
            expect(preset_is_baremetal(preset)).to_equal(true)

        it "cortex-m0 IS a baremetal preset (contrast)":
            val preset = preset_cortex_m0()
            expect(preset_is_baremetal(preset)).to_equal(true)

    context "CodegenTarget AArch64 variant":
        it "CodegenTarget.AArch64 to_text is aarch64":
            # The to_text method drives symbol mangling in cross-module imports.
            # A regression (e.g. returning arm64 or armv8) would break import
            # symbol resolution for AArch64 cross-module calls.
            val target = CodegenTarget.AArch64
            expect(target.to_text()).to_equal("aarch64")

        it "CodegenTarget.AArch64 is_64bit":
            val target = CodegenTarget.AArch64
            expect(target.is_64bit()).to_equal(true)
