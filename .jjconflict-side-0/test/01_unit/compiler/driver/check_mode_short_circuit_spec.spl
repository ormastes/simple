use std.io.{file_read}

describe "compiler Check mode boundary":
    it "returns after fatal HIR analysis and before monomorphization":
        val source = file_read("src/compiler/80.driver/driver.spl")
        val phase3_done = source.index_of("log_phase(\"phase3:hir_typecheck:done\")") ?? -1
        val check_return = source.index_of(
            "if self.ctx.options.mode == CompileMode.Check:", phase3_done
        ) ?? -1
        val mono_start = source.index_of(
            "log_phase(\"phase4:monomorphize:start\")", phase3_done
        ) ?? -1

        expect(phase3_done).to_be_greater_than(-1)
        expect(check_return).to_be_greater_than(phase3_done)
        expect(mono_start).to_be_greater_than(check_return)
