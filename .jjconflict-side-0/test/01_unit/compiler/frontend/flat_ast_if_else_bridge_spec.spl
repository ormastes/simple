# Flat AST bridge if/else fidelity (M12 item 6)
#
# @cover src/compiler/10.frontend/flat_ast_bridge.spl 5%
#
# Regression guard: flat_ast_to_module previously hardcoded the If else slot to
# nil, dropping every else/elif branch when the self-hosted lean frontend builds
# a Module. This walks the bridge's output and asserts the else block is
# attached for if/else and if/elif/else, and is nil (not a spurious empty block)
# for a plain if. Discriminates the fix itself, not just the parser's elif arena
# (buggy bridge → all three return -2 "no-else"; fixed → 1 / -2 / 1).

use compiler.frontend.flat_ast_bridge.{parse_and_build_module}
use compiler.frontend.parser_types.*

# Returns: -1 no STMT_IF in fn body, -2 If with nil else, >=0 else-block stmt count.
fn if_else_else_count(src: text, fname: text) -> i64:
    val m = parse_and_build_module(src, fname + ".spl")
    val fn_ = m.functions[fname] ?? panic("missing fn " + fname)
    for s in fn_.body.stmts:
        match s.kind:
            case StmtKind.Expr(e):
                match e.kind:
                    case ExprKind.If(cond, then_, else_):
                        if else_ != nil:
                            return else_.stmts.len()
                        return -2
                    case _:
                        pass
            case _:
                pass
    return -1

describe "Flat AST bridge if/else fidelity (M12 item 6)":
    it "attaches the else block for if/else":
        val src = "fn f(n: i64) -> i64:\n    if n > 0:\n        return 1\n    else:\n        return 2\n"
        expect(if_else_else_count(src, "f")).to_equal(1)

    it "leaves else nil for a plain if (no spurious empty else block)":
        val src = "fn g(n: i64) -> i64:\n    if n > 0:\n        return 1\n    return 0\n"
        expect(if_else_else_count(src, "g")).to_equal(-2)

    it "attaches the else chain for if/elif/else":
        val src = "fn h(n: i64) -> i64:\n    if n > 90:\n        return 1\n    elif n > 50:\n        return 2\n    else:\n        return 3\n"
        expect(if_else_else_count(src, "h")).to_equal(1)
