# Flat AST bridge ForceUnwrap fidelity (M12 item 7)
#
# @cover src/compiler/10.frontend/flat_ast_bridge.spl 3%
#
# Regression guard: postfix `!` force-unwrap was parsed as expr_exists_check,
# collapsing it into the same ExprKind.ExistsCheck node as `.?` and losing the
# panic-on-nil vs nil-on-absent distinction. This walks the bridge output and
# asserts `expr!` now produces ExprKind.ForceUnwrap while `expr.?` stays
# ExprKind.ExistsCheck. Discriminating: buggy bridge → both "exists-check";
# fixed → "force-unwrap" / "exists-check".

use compiler.frontend.flat_ast_bridge.{parse_and_build_module}
use compiler.frontend.parser_types.*

fn first_unwrap_kind(src: text) -> text:
    val m = parse_and_build_module(src, "p.spl")
    for name in m.functions.keys():
        val fn_ = m.functions[name]
        for s in fn_.body.stmts:
            match s.kind:
                case StmtKind.Return(rv):
                    if rv != nil:
                        match rv.kind:
                            case ForceUnwrap(inner):
                                return "force-unwrap"
                            case ExistsCheck(inner):
                                return "exists-check"
                            case _:
                                pass
                case _:
                    pass
    return "none"

describe "Flat AST bridge ForceUnwrap fidelity (M12 item 7)":
    it "postfix ! produces a distinct ForceUnwrap node":
        val src = "fn f(x: i64) -> i64:\n    return x!\n"
        expect(first_unwrap_kind(src)).to_equal("force-unwrap")

    it ".? stays an ExistsCheck node (not conflated with !)":
        val src = "fn g(x: i64) -> i64:\n    return x.?\n"
        expect(first_unwrap_kind(src)).to_equal("exists-check")
