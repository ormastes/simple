use compiler.frontend.flat_ast_bridge.{parse_and_build_module}
use compiler.frontend.core.parser.{parser_diagnostic_emit_count_get, parser_diagnostics_suppressed_get, parser_has_errors}

describe "flat AST speculative interpolation diagnostics":
    it "does not publish recovered errors from brace-bearing literals":
        val braces = "{" + "\n    | raw code\n" + "}"
        val source = "fn code_text() -> text:\n    \"\"\"" + braces + "\"\"\"\n"
        val module = parse_and_build_module(source, "brace_literal.spl")

        expect(module.functions.contains("code_text")).to_equal(true)
        expect(parser_has_errors()).to_equal(false)
        expect(parser_diagnostics_suppressed_get()).to_equal(false)
        expect(parser_diagnostic_emit_count_get()).to_equal(0)
