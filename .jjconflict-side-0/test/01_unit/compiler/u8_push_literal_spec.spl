/// Verification spec: [u8].push(u8_literal) must preserve value
/// Bug: pushing a u8 literal directly writes 0 instead of the correct value.
/// Workaround: assign to var first. This spec verifies the fix.

use std.spec.*

fn build_key_direct() -> [u8]:
    var b: [u8] = []
    b.push(0x01u8)
    b.push(0x23u8)
    b.push(0x45u8)
    b.push(0x67u8)
    b.push(0x89u8)
    b.push(0xABu8)
    b.push(0xCDu8)
    b.push(0xEFu8)
    b

fn build_key_workaround() -> [u8]:
    var b: [u8] = []
    var x: u8 = 0x01u8
    b.push(x)
    x = 0x23u8
    b.push(x)
    x = 0x45u8
    b.push(x)
    x = 0x67u8
    b.push(x)
    x = 0x89u8
    b.push(x)
    x = 0xABu8
    b.push(x)
    x = 0xCDu8
    b.push(x)
    x = 0xEFu8
    b.push(x)
    b

describe "u8 push literal":
    it "direct push matches workaround push byte-for-byte":
        val direct = build_key_direct()
        val workaround = build_key_workaround()
        expect(direct.len()).to_equal(8)
        expect(workaround.len()).to_equal(8)
        expect(direct[0]).to_equal(workaround[0])
        expect(direct[1]).to_equal(workaround[1])
        expect(direct[2]).to_equal(workaround[2])
        expect(direct[3]).to_equal(workaround[3])
        expect(direct[4]).to_equal(workaround[4])
        expect(direct[5]).to_equal(workaround[5])
        expect(direct[6]).to_equal(workaround[6])
        expect(direct[7]).to_equal(workaround[7])

    it "direct push preserves exact values":
        val direct = build_key_direct()
        expect(direct[0]).to_equal(0x01u8)
        expect(direct[1]).to_equal(0x23u8)
        expect(direct[2]).to_equal(0x45u8)
        expect(direct[3]).to_equal(0x67u8)
        expect(direct[4]).to_equal(0x89u8)
        expect(direct[5]).to_equal(0xABu8)
        expect(direct[6]).to_equal(0xCDu8)
        expect(direct[7]).to_equal(0xEFu8)

    it "in-block direct push preserves value":
        var arr: [u8] = []
        arr.push(0x42u8)
        expect(arr[0]).to_equal(0x42u8)

    it "push decimal u8 literal":
        var arr: [u8] = []
        arr.push(65u8)
        expect(arr[0]).to_equal(65u8)

    it "push zero literal":
        var arr: [u8] = []
        arr.push(0u8)
        expect(arr[0]).to_equal(0u8)

    it "push max u8 literal":
        var arr: [u8] = []
        arr.push(255u8)
        expect(arr[0]).to_equal(255u8)
