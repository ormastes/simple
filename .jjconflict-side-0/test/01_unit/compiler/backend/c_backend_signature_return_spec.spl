extern fn rt_file_read_text(path: text) -> text

fn c_instruction_source() -> text:
    rt_file_read_text("src/compiler/70.backend/backend/_CBackendTranslate/instruction_lowering.spl") ?? ""

describe "C backend signature return metadata":
    it "does not map nil indirect-call signature returns through the type mapper":
        val source = c_instruction_source()
        expect(source).to_contain("if sig.return_type == nil: \"void\" else: self.type_mapper.map_type(sig.return_type)")
        expect(source.contains("val ret_ty = self.type_mapper.map_type(sig.return_type)")).to_equal(false)
