# @cover src/os/kernel/loader/smf.spl 80%
"""
# SMF loader hardening — malformed / hostile envelopes (Lane HARDEN-ROBUST)

TEST-ONLY: exercises the pure SMF envelope parser/extractor
(src/os/kernel/loader/smf.spl) with wrong magic, wrong role/arch/ABI bytes, a
truncated trailer, and bogus stub offsets, asserting every path fails closed
with the correct `SMF_ERR_*` classification or a nil header — never a crash,
never an out-of-bounds copy, never a stub accepted without ELF magic.

Byte fixtures are built by concatenation (no in-place index assignment) so the
whole spec runs green under `simple run` (seed interpreter). A single valid
envelope is included as a positive control so the rejections are meaningful.
"""

use std.spec
use os.kernel.loader.smf.{
    smf_check_magic, smf_has_header, smf_parse_header,
    smf_extract_executable_stub, smf_extract_executable_stub_for_arch,
    smf_extract_library_stub, smf_executable_entry_point_for_arch
}
use os.kernel.arch.arch_context.{Architecture}

# ---- byte fixture builders (concat-only) ----------------------------------

fn _zeros(n: i64) -> [u8]:
    var a: [u8] = []
    var i = 0
    while i < n:
        a = a + [0 as u8]
        i = i + 1
    a

fn _u32le(v: i64) -> [u8]:
    [(v & 0xFF).to_u8(), ((v >> 8) & 0xFF).to_u8(), ((v >> 16) & 0xFF).to_u8(), ((v >> 24) & 0xFF).to_u8()]

fn _u64le(v: i64) -> [u8]:
    _u32le(v) + _u32le(v >> 32)

fn _elf_stub(size: i64) -> [u8]:
    var s: [u8] = [0x7F as u8, 0x45 as u8, 0x4C as u8, 0x46 as u8]   # 0x7F 'E' 'L' 'F'
    if size > 4:
        s = s + _zeros(size - 4)
    s

# 128-byte SMF trailer: magic(0..4) entry_u64@44 stub_size_u32@52
# data_off_u32@56 role@60 arch@61 abi@62.
fn _smf_trailer(entry: i64, stub_size: i64, role: i64, arch: i64, abi: i64) -> [u8]:
    var t: [u8] = [83 as u8, 77 as u8, 70 as u8, 0 as u8]
    t = t + _zeros(40)
    t = t + _u64le(entry)
    t = t + _u32le(stub_size)
    t = t + _u32le(0)
    t = t + [role.to_u8(), arch.to_u8(), abi.to_u8()]
    t = t + _zeros(65)
    t

# 64-byte ELF stub at offset 0 then a trailer -> header_offset == 64.
fn _smf_exe(stub_size_field: i64, role: i64, arch: i64, abi: i64) -> [u8]:
    _elf_stub(64) + _smf_trailer(0x1000, stub_size_field, role, arch, abi)

# ---- Result helpers -------------------------------------------------------

fn _bytes_err(r: Result<[u8], text>) -> text:
    match r:
        case Ok(_v): "OK"
        case Err(e): e

fn _bytes_ok_len(r: Result<[u8], text>) -> i64:
    match r:
        case Ok(v): v.len().to_i64()
        case Err(_e): -1

fn _i64_err(r: Result<i64, text>) -> text:
    match r:
        case Ok(_v): "OK"
        case Err(e): e

fn _i64_ok(r: Result<i64, text>) -> i64:
    match r:
        case Ok(v): v
        case Err(_e): -1

# ---------------------------------------------------------------------------

describe "smf magic/header detection: fail closed":
    it "an all-zero 128-byte blob has no SMF magic or header":
        val a = _zeros(128)
        expect(smf_check_magic(a)).to_equal(false)
        expect(smf_has_header(a)).to_equal(false)
        val h = smf_parse_header(a)
        assert_true(h == nil)

    it "a bare ELF file is not mistaken for an SMF envelope":
        val a = _elf_stub(64)
        expect(smf_has_header(a)).to_equal(false)

    it "a tiny (<4 byte) blob is rejected, not OOB":
        val a = _zeros(2)
        expect(smf_has_header(a)).to_equal(false)
        assert_true(smf_parse_header(a) == nil)

describe "smf parse: truncated trailer":
    it "magic present but the 128-byte trailer does not fit -> nil header":
        # magic at offset 0, total length 64 (< 128): header_offset==0 but
        # off+128 > len, so parse must refuse.
        val a = [83 as u8, 77 as u8, 70 as u8, 0 as u8] + _zeros(60)
        assert_true(smf_parse_header(a) == nil)
        expect(_bytes_err(smf_extract_executable_stub(a))).to_equal("SMF_ERR_MALFORMED")

describe "smf executable extraction: metadata rejection (fail closed)":
    it "wrong magic -> SMF_ERR_MALFORMED":
        expect(_bytes_err(smf_extract_executable_stub(_zeros(256)))).to_equal("SMF_ERR_MALFORMED")

    it "wrong role (library role on an executable request) -> SMF_ERR_WRONG_ROLE":
        expect(_bytes_err(smf_extract_executable_stub(_smf_exe(64, 2, 1, 1)))).to_equal("SMF_ERR_WRONG_ROLE")

    it "wrong ABI byte -> SMF_ERR_ABI_MISMATCH":
        expect(_bytes_err(smf_extract_executable_stub(_smf_exe(64, 1, 1, 2)))).to_equal("SMF_ERR_ABI_MISMATCH")

    it "non-positive stub size -> SMF_ERR_MISSING_ELF":
        expect(_bytes_err(smf_extract_executable_stub(_smf_exe(0, 1, 1, 1)))).to_equal("SMF_ERR_MISSING_ELF")

    it "stub size larger than the header offset -> SMF_ERR_MALFORMED":
        expect(_bytes_err(smf_extract_executable_stub(_smf_exe(200, 1, 1, 1)))).to_equal("SMF_ERR_MALFORMED")

    it "declared stub carries no ELF magic -> SMF_ERR_MISSING_ELF":
        val a = _zeros(64) + _smf_trailer(0x1000, 64, 1, 1, 1)
        expect(_bytes_err(smf_extract_executable_stub(a))).to_equal("SMF_ERR_MISSING_ELF")

describe "smf arch gate (per-arch extraction)":
    it "an x86_64 stub requested as arm64 -> SMF_ERR_WRONG_ARCH":
        val a = _smf_exe(64, 1, 1, 1)   # arch byte 1 == x86_64
        expect(_bytes_err(smf_extract_executable_stub_for_arch(a, Architecture.Arm64))).to_equal("SMF_ERR_WRONG_ARCH")

    it "an arch-unspecified (0) stub is accepted for any arch":
        val a = _smf_exe(64, 1, 0, 1)   # arch byte 0 == unspecified
        expect(_bytes_err(smf_extract_executable_stub_for_arch(a, Architecture.Arm64))).to_equal("OK")

describe "smf library extraction: role gate":
    it "an executable envelope requested as a library -> SMF_ERR_WRONG_ROLE":
        expect(_bytes_err(smf_extract_library_stub(_smf_exe(64, 1, 1, 1)))).to_equal("SMF_ERR_WRONG_ROLE")

describe "smf entry-point extraction":
    it "a wrong-arch entry-point request fails closed":
        val a = _smf_exe(64, 1, 1, 1)
        expect(_i64_err(smf_executable_entry_point_for_arch(a, Architecture.Arm64))).to_equal("SMF_ERR_WRONG_ARCH")

    it "a valid envelope yields its declared entry point (positive control)":
        val a = _smf_exe(64, 1, 1, 1)
        expect(_i64_ok(smf_executable_entry_point_for_arch(a, Architecture.X86_64))).to_equal(4096i64)

describe "smf positive control: a valid envelope extracts cleanly":
    it "a well-formed x86_64 executable envelope returns its 64-byte ELF stub":
        val a = _smf_exe(64, 1, 1, 1)
        assert_true(smf_has_header(a))
        expect(_bytes_ok_len(smf_extract_executable_stub(a))).to_equal(64i64)
