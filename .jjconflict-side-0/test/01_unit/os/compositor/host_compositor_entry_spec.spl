# @cover src/os/compositor/host_compositor_entry.spl 80%
"""
# Host Compositor Entry Spec

Deterministic unit tests for the shared host compositor bootstrap boundary.
Tests avoid creating real host windows except for the TUI nil boundary, which
returns before touching SFFI.
"""

use std.spec.{describe, it, expect}
use common.ui.web_render_api.{WEB_RENDER_TARGET_SIMPLE_WEB}
use common.window_protocol.geometry.{Size}
use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}
use os.compositor.host_compositor_entry.{
    HOST_WM_IDLE_SLEEP_MS,
    HostBackendKind,
    HostDisplayMode,
    HostDisplayTransitionPhase,
    HostCompositor,
    HostWmAppProcess,
    HostWmConfig,
    HostWmHandle,
    HostWmLoopState,
    SimpleOsGuiAdapter,
    host_taskbar_dock_width,
    host_taskbar_item_width,
    host_taskbar_item_x,
    host_compositor_left_button,
    host_compositor_pointer_move,
    host_surface_geometry,
    host_surface_state,
    request_display_mode,
    ack_surface_resize,
    ack_surface_scale,
    ack_surface_event,
    fail_or_timeout_display_transition,
    host_wm_surface_failure_reason,
    host_wm_content_renderer_name,
    host_wm_force_direct_chrome,
    host_wm_chrome_force_direct,
    host_chrome_scene_html,
    host_chrome_scene_fingerprint,
    host_compositor_taskbar_model,
    host_taskbar_clock_label,
    HostedWindow,
    simpleos_gui_adapter_display_path_name,
    simpleos_gui_adapter_content_renderer_name,
    init_host_wm,
}
use os.userlib.ipc_protocol.{COMP_CREATE_WINDOW, COMP_DESTROY_WINDOW, COMP_UPDATE_TREE, COMP_FOCUS, COMP_RESIZE, COMP_MOVE, COMP_SET_TITLE, COMP_MINIMIZE, COMP_MAXIMIZE, COMP_RESTORE}
use std.gc_async_mut.gpu.browser_engine.simple_web_layout_engine2d_fast.{simple_web_layout_render_html_pixels_engine2d}
use common.ui.wm_chrome_theme.{wm_chrome_theme}
use common.color.convert.{int_to_hex}

var _fake_present_count: i64 = 0
var _capture_present_count: i64 = 0
var _capture_blue_count: i64 = 0
var _capture_white_count: i64 = 0
var _capture_engine_title_count: i64 = 0
var _capture_engine_content_count: i64 = 0
var _capture_blit_count: i64 = 0
var _capture_clear_color: u32 = 0u32
var _capture_taskbar_pass_count: i64 = 0
var _capture_texts: [text] = []

class FakeCompositorBackend:
    w: i32
    h: i32

impl CompositorBackend for FakeCompositorBackend:

    fn width() -> i32:
        self.w

    fn height() -> i32:
        self.h

    me clear(color: u32):
        _fake_present_count = _fake_present_count

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        _fake_present_count = _fake_present_count

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        _fake_present_count = _fake_present_count

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        _fake_present_count = _fake_present_count

    me put_pixel(x: i32, y: i32, color: u32):
        _fake_present_count = _fake_present_count

    me blit_pixels(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        _fake_present_count = _fake_present_count

    me present():
        _fake_present_count = _fake_present_count + 1

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        _fake_present_count = _fake_present_count + 1

    fn as_glass_capable() -> CompositorGlassCapable?:
        nil

class CaptureCompositorBackend:
    w: i32
    h: i32
    pixels: [u32]
    present_count: i64

    static fn with_color(width: i32, height: i32, color: u32) -> CaptureCompositorBackend:
        CaptureCompositorBackend(w: width, h: height, pixels: [color; width * height], present_count: 0)

impl CompositorBackend for CaptureCompositorBackend:

    fn width() -> i32:
        200

    fn height() -> i32:
        150

    me clear(color: u32):
        _capture_clear_color = color

    me fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32):
        if x == 0 and y == self.h - 56 and w == self.w and h == 56:
            _capture_taskbar_pass_count = _capture_taskbar_pass_count + 1
        if color == 0xFF2563EBu32:
            _capture_blue_count = _capture_blue_count + 1
        if color == 0xFFFFFFFFu32:
            _capture_white_count = _capture_white_count + 1
        if color == 0xFF2050A0u32:
            _capture_engine_title_count = _capture_engine_title_count + 1
        if color == 0xFF182230u32:
            _capture_engine_content_count = _capture_engine_content_count + 1
        _capture_present_count = _capture_present_count

    me draw_text(x: i32, y: i32, text_str: text, fg: u32, bg: u32):
        _capture_texts.push(text_str)
        if text_str.len() > 0 and fg == 0xFFFFFFFFu32:
            _capture_white_count = _capture_white_count + 1

    me draw_char_8x16(x: i32, y: i32, ch: u8, fg: u32, bg: u32):
        if fg == 0xFFFFFFFFu32:
            _capture_white_count = _capture_white_count + 1

    me put_pixel(x: i32, y: i32, color: u32):
        _capture_present_count = _capture_present_count

    me blit_pixels(x: i32, y: i32, w: i32, h: i32, pixels: [u32]):
        _capture_blit_count = _capture_blit_count + 1
        var row: i32 = 0
        while row < h:
            var col: i32 = 0
            while col < w:
                val src_idx = row * w + col
                if src_idx >= 0 and src_idx < pixels.len():
                    val color = pixels[src_idx]
                    if color == 0xFF2050A0u32:
                        _capture_engine_title_count = _capture_engine_title_count + 1
                    if color == 0xFF182230u32:
                        _capture_engine_content_count = _capture_engine_content_count + 1
                    self.put_pixel(x + col, y + row, pixels[src_idx])
                col = col + 1
            row = row + 1

    me present():
        _capture_present_count = _capture_present_count + 1

    me present_rect(x: i32, y: i32, w: i32, h: i32):
        _capture_present_count = _capture_present_count + 1

    fn as_glass_capable() -> CompositorGlassCapable?:
        nil

fn _count_color(pixels: [u32], color: u32) -> i32:
    var count = 0
    var i = 0
    while i < pixels.len():
        if pixels[i] == color:
            count = count + 1
        i = i + 1
    count

fn _count_captured_text(value: text) -> i32:
    var count = 0
    for captured in _capture_texts:
        if captured == value:
            count = count + 1
    count

fn _browser_config() -> HostWmConfig:
    HostWmConfig(
        backend: HostBackendKind.Browser,
        initial_size: Size.wh(320, 240),
        title: "browser-wm"
    )

fn _running_wm_service() -> HostWmLoopState:
    HostWmLoopState(running: true)

describe "host display transition state":

    it "applies out-of-order scale and resize acknowledgements with a matching nonce":
        val initial = host_surface_geometry(40, 60, 1280, 720, 1000)
        val requested = request_display_mode(host_surface_state(initial), HostDisplayMode.BorderlessFullscreen, 7, 100)
        expect(requested.accepted).to_be(true)
        expect(requested.mode_request_required).to_be(true)
        expect(requested.state.phase).to_equal(HostDisplayTransitionPhase.Requested)

        val scaled = ack_surface_scale(requested.state, 7, 1500, 200)
        expect(scaled.state.phase).to_equal(HostDisplayTransitionPhase.AwaitingResize)
        expect(scaled.state.mode).to_equal(HostDisplayMode.Windowed)
        val applied = ack_surface_resize(scaled.state, 7, host_surface_geometry(0, 0, 1920, 1080, 1500), 300)
        expect(applied.state.phase).to_equal(HostDisplayTransitionPhase.Applied)
        expect(applied.state.mode).to_equal(HostDisplayMode.BorderlessFullscreen)
        expect(applied.state.geometry.width).to_equal(1920)
        expect(applied.state.geometry.scale_milli).to_equal(1500)
        expect(applied.state.saved_windowed_geometry.x).to_equal(40)

    it "rejects stale events and coalesces only the same in-flight request":
        val initial = host_surface_state(host_surface_geometry(10, 20, 800, 600, 1000))
        val requested = request_display_mode(initial, HostDisplayMode.BorderlessFullscreen, 9, 100)
        val duplicate = request_display_mode(requested.state, HostDisplayMode.BorderlessFullscreen, 9, 110)
        expect(duplicate.accepted).to_be(true)
        expect(duplicate.mode_request_required).to_be(false)
        val stale = ack_surface_event(requested.state, 8, host_surface_geometry(0, 0, 1920, 1080, 1000), 120)
        expect(stale.accepted).to_be(false)
        expect(stale.state.phase).to_equal(HostDisplayTransitionPhase.Requested)

    it "rolls back geometry and mode on explicit failure or timeout":
        val initial = host_surface_state(host_surface_geometry(25, 35, 1024, 768, 1000))
        val requested = request_display_mode(initial, HostDisplayMode.BorderlessFullscreen, 11, 100)
        val resized = ack_surface_resize(requested.state, 11, host_surface_geometry(0, 0, 2560, 1440, 1000), 200)
        val failed = fail_or_timeout_display_transition(resized.state, 11, "fullscreen denied", 300)
        expect(failed.accepted).to_be(true)
        expect(failed.rolled_back).to_be(true)
        expect(failed.state.phase).to_equal(HostDisplayTransitionPhase.Failed)
        expect(failed.state.mode).to_equal(HostDisplayMode.Windowed)
        expect(failed.state.geometry.x).to_equal(25)
        expect(failed.state.geometry.width).to_equal(1024)
        expect(failed.state.failure_reason).to_equal("fullscreen denied")

        val retry = request_display_mode(failed.state, HostDisplayMode.BorderlessFullscreen, 12, 400)
        val timed_out = fail_or_timeout_display_transition(retry.state, 12, "", retry.state.deadline_micros + 1)
        expect(timed_out.accepted).to_be(true)
        expect(timed_out.state.failure_reason).to_equal("display transition timed out")

describe "HostBackendKind variants":

    it "includes platform-native backend variants":
        val sdl = HostBackendKind.Sdl2
        val cocoa = HostBackendKind.Cocoa
        val win32 = HostBackendKind.Win32
        val headless = HostBackendKind.Headless
        expect(sdl != cocoa).to_equal(true)
        expect(win32 != headless).to_equal(true)

    it "Headless backend creates a usable handle via init_host_wm":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Headless,
            initial_size: Size.wh(640, 480),
            title: "headless-wm"
        )
        val handle = init_host_wm(cfg)
        expect(handle != nil).to_equal(true)
        expect(handle.compositor.width).to_equal(640)
        expect(handle.compositor.height).to_equal(480)

describe "HostWmConfig":

    it "keeps title in the bootstrap contract":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Electron,
            initial_size: Size.wh(1280, 800),
            title: "electron-test"
        )
        expect(cfg.title).to_equal("electron-test")

    it "can name Tauri as a host WM shell adapter":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Tauri,
            initial_size: Size.wh(1280, 800),
            title: "tauri-test"
        )
        expect(cfg.backend).to_equal(HostBackendKind.Tauri)

describe "host surface failure boundaries":

    it "accepts a nonzero event loop and window surface":
        val reason = host_wm_surface_failure_reason(_browser_config(), 10, 20)
        expect(reason).to_equal(nil)

    it "accepts Tauri at the host surface contract boundary":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Tauri,
            initial_size: Size.wh(1280, 800),
            title: "tauri-wm"
        )
        val reason = host_wm_surface_failure_reason(cfg, 10, 20)
        expect(reason).to_equal(nil)

    it "documents the TUI stub boundary":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Tui,
            initial_size: Size.wh(80, 24),
            title: "tui-wm"
        )
        val reason = host_wm_surface_failure_reason(cfg, 10, 20)
        expect(reason ?? "").to_equal("tui host compositor bootstrap is not implemented")

    it "rejects zero-sized host surfaces before SFFI bootstrap":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Browser,
            initial_size: Size.wh(0, 240),
            title: "bad-size"
        )
        val reason = host_wm_surface_failure_reason(cfg, 10, 20)
        expect(reason ?? "").to_equal("host compositor size must be nonzero")

    it "returns nil for TUI without touching host window SFFI":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Tui,
            initial_size: Size.wh(80, 24),
            title: "tui-wm"
        )
        val result = init_host_wm(cfg)
        expect(result).to_equal(nil)

describe "host WM bootstrap":

    it "creates a Browser host WM handle on the shared compositor path":
        val handle = init_host_wm(_browser_config())
        expect(handle != nil).to_equal(true)
        expect(handle.event_loop_id).to_equal(1)
        expect(handle.window_id).to_equal(1)
        expect(handle.compositor.width).to_equal(320)
        expect(handle.compositor.height).to_equal(240)

    it "creates an Electron host WM handle on the shared compositor path":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Electron,
            initial_size: Size.wh(800, 600),
            title: "electron-wm"
        )
        val handle = init_host_wm(cfg)
        expect(handle != nil).to_equal(true)
        expect(handle.compositor.width).to_equal(800)
        expect(handle.compositor.height).to_equal(600)

    it "creates a Tauri host WM handle on the shared compositor path":
        val cfg = HostWmConfig(
            backend: HostBackendKind.Tauri,
            initial_size: Size.wh(1024, 768),
            title: "tauri-wm"
        )
        val handle = init_host_wm(cfg)
        expect(handle != nil).to_equal(true)
        expect(handle.compositor.width).to_equal(1024)
        expect(handle.compositor.height).to_equal(768)

describe "HostWmHandle loop behavior":

    it "runs one tick without host event polling when no event loop is attached":
        _fake_present_count = 0
        val backend = FakeCompositorBackend(w: 320, h: 240)
        var comp = HostCompositor.new(backend, Size.wh(320, 240))
        val handle = HostWmHandle(
            compositor: comp,
            wm: _running_wm_service(),
            event_loop_id: 0,
            window_id: 0,
            backend: HostBackendKind.Browser
        )
        val pumped = handle.pump_host_events()
        handle.run_once()
        expect(pumped).to_equal(0)
        expect(_fake_present_count).to_equal(1)

    it "renders hosted windows through the Simple Web app content path":
        # Pin the direct-draw chrome contract: this test validates the
        # byte-identical fallback path (clear + fill_rect + draw_text), which
        # must stay unchanged regardless of Metal availability.
        host_wm_force_direct_chrome(true)
        _capture_present_count = 0
        _capture_blue_count = 0
        _capture_white_count = 0
        _capture_engine_title_count = 0
        _capture_engine_content_count = 0
        _capture_blit_count = 0
        _capture_clear_color = 0u32
        val backend = CaptureCompositorBackend.with_color(80, 70, 0xFF000000u32)
        val comp = HostCompositor.new(backend, Size.wh(80, 70))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "Terminal", 8, 8, 40, 52, "ready", 900, "/sys/apps/terminal")
        comp.render_frame()
        host_wm_force_direct_chrome(false)
        expect(_capture_present_count).to_equal(1)
        expect(_capture_blue_count).to_be_greater_than(0)
        expect(_capture_white_count).to_be_greater_than(0)
        # Direct-draw fallback rasterizes chrome via fill_rect, not blit.
        expect(_capture_blit_count).to_equal(0)
        expect(_capture_clear_color).to_equal(0xFF0F172Au32)

    it "records compositor resize dimensions":
        val backend = FakeCompositorBackend(w: 320, h: 240)
        val comp = HostCompositor.new(backend, Size.wh(320, 240))
        comp.resize(640, 480)
        expect(comp.width).to_equal(640)
        expect(comp.height).to_equal(480)

    it "does not tick after the WM has stopped":
        _fake_present_count = 0
        val backend = FakeCompositorBackend(w: 320, h: 240)
        val comp = HostCompositor.new(backend, Size.wh(320, 240))
        val wm = HostWmLoopState(running: false)
        val handle = HostWmHandle(
            compositor: comp,
            wm: wm,
            event_loop_id: 0,
            window_id: 0,
            backend: HostBackendKind.Browser
        )
        handle.run_once()
        expect(_fake_present_count).to_equal(0)

    it "returns immediately from tick_forever when the WM is already stopped":
        _fake_present_count = 0
        val backend = FakeCompositorBackend(w: 320, h: 240)
        val comp = HostCompositor.new(backend, Size.wh(320, 240))
        val wm = HostWmLoopState(running: false)
        val handle = HostWmHandle(
            compositor: comp,
            wm: wm,
            event_loop_id: 1,
            window_id: 1,
            backend: HostBackendKind.Browser
        )
        handle.tick_forever()
        expect(_fake_present_count).to_equal(0)

    it "uses a nonzero idle sleep interval for tick_forever":
        expect(HOST_WM_IDLE_SLEEP_MS).to_be_greater_than(0)

    it "keeps Browser Electron and Tauri on the shared Simple Web content renderer":
        val browser = init_host_wm(HostWmConfig(backend: HostBackendKind.Browser, initial_size: Size.wh(320, 240), title: "browser-wm"))
        val electron = init_host_wm(HostWmConfig(backend: HostBackendKind.Electron, initial_size: Size.wh(320, 240), title: "electron-wm"))
        val tauri = init_host_wm(HostWmConfig(backend: HostBackendKind.Tauri, initial_size: Size.wh(320, 240), title: "tauri-wm"))

        expect(browser != nil).to_equal(true)
        expect(electron != nil).to_equal(true)
        expect(tauri != nil).to_equal(true)
        expect(host_wm_content_renderer_name(browser)).to_equal(WEB_RENDER_TARGET_SIMPLE_WEB)
        expect(host_wm_content_renderer_name(electron)).to_equal(WEB_RENDER_TARGET_SIMPLE_WEB)
        expect(host_wm_content_renderer_name(tauri)).to_equal(WEB_RENDER_TARGET_SIMPLE_WEB)

describe "HostCompositor hosted window state":

    it "renders one authoritative taskbar from real process window tray and clock state":
        host_wm_force_direct_chrome(true)
        _capture_taskbar_pass_count = 0
        _capture_texts = []
        val backend = CaptureCompositorBackend.with_color(400, 240, 0xFF000000u32)
        val comp = HostCompositor.new(backend, Size.wh(400, 240))
        comp.app_processes.push(HostWmAppProcess(title: "Pinned Editor", app_id: "/sys/apps/editor", source_path: "editor.spl", pid: 41, failed: false))
        comp.app_processes.push(HostWmAppProcess(title: "Broken Tool", app_id: "/sys/apps/broken", source_path: "broken.spl", pid: 42, failed: true))
        comp.apply_bridge_request(1, 11, COMP_CREATE_WINDOW.to_i64(), 0, "Live Terminal", 20, 60, 160, 100, "ready", 41, "/sys/apps/terminal")
        comp.apply_bridge_request(2, 12, COMP_CREATE_WINDOW.to_i64(), 0, "Live Browser", 190, 60, 160, 100, "ready", 43, "/sys/apps/browser")
        val first_id = comp.windows[0].id
        comp.apply_bridge_request(3, 11, COMP_MINIMIZE.to_i64(), first_id, "", 0, 0, 0, 0, "", 0, "")

        val taskbar = host_compositor_taskbar_model(comp)
        expect(taskbar.pinned.len()).to_equal(0)
        expect(taskbar.running[0].title).to_equal("Live Terminal")
        expect(taskbar.running[0].minimized).to_be(true)
        expect(taskbar.running[taskbar.running.len() - 1].title).to_equal("Live Browser")
        expect(taskbar.tray[0].label).to_equal("1/2 active")
        expect(host_taskbar_clock_label(45240000000)).to_equal("12:34")

        comp.render_frame()
        host_wm_force_direct_chrome(false)
        expect(_capture_texts.contains("Pinned Editor")).to_be(false)
        expect(_capture_texts.contains("Broken Tool")).to_be(false)
        expect(_capture_texts).to_contain("Live Terminal")
        expect(_capture_texts).to_contain("Live Browser")
        expect(_capture_texts).to_contain("1/2 active")
        expect(_capture_taskbar_pass_count).to_equal(1)
        # The minimized window has no titlebar draw. One captured title is the
        # authoritative taskbar object; a legacy second taskbar pass yields 2.
        expect(_count_captured_text("Live Terminal")).to_equal(1)

    it "creates, updates, minimizes, restores, and destroys hosted windows":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "Hosted App", 40, 50, 320, 180, "", 900, "/sys/apps/test")
        expect(comp.windows.len()).to_equal(1)
        expect(comp.windows[0].title).to_equal("Hosted App")
        expect(comp.windows[0].focused).to_equal(true)

        val wid = comp.windows[0].id
        comp.apply_bridge_request(2, 77, COMP_UPDATE_TREE.to_i64(), wid, "", 0, 0, 0, 0, "rendered content", 0, "/sys/apps/test")
        expect(comp.windows[0].content).to_equal("rendered content")

        comp.apply_bridge_request(3, 77, COMP_MINIMIZE.to_i64(), wid, "", 0, 0, 0, 0, "", 0, "/sys/apps/test")
        expect(comp.windows[0].minimized).to_equal(true)

        comp.apply_bridge_request(4, 77, COMP_RESTORE.to_i64(), wid, "", 0, 0, 0, 0, "", 0, "/sys/apps/test")
        expect(comp.windows[0].minimized).to_equal(false)
        expect(comp.windows[0].focused).to_equal(true)

        comp.apply_bridge_request(5, 77, COMP_DESTROY_WINDOW.to_i64(), wid, "", 0, 0, 0, 0, "", 0, "/sys/apps/test")
        expect(comp.windows.len()).to_equal(0)

    it "applies host bridge lifecycle requests through shared WM actions":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "One", 40, 50, 240, 160, "", 1, "/sys/apps/one")
        comp.apply_bridge_request(2, 88, COMP_CREATE_WINDOW.to_i64(), 0, "Two", 80, 90, 240, 160, "", 2, "/sys/apps/two")

        val first_id = comp.windows[0].id
        comp.apply_bridge_request(3, 77, COMP_MOVE.to_i64(), first_id, "", 120, 130, 0, 0, "", 0, "")
        comp.apply_bridge_request(4, 77, COMP_RESIZE.to_i64(), first_id, "", 0, 0, 320, 220, "", 0, "")
        comp.apply_bridge_request(5, 77, COMP_SET_TITLE.to_i64(), first_id, "One Renamed", 0, 0, 0, 0, "", 0, "")
        expect(comp.windows[0].x).to_equal(120)
        expect(comp.windows[0].y).to_equal(130)
        expect(comp.windows[0].w).to_equal(320)
        expect(comp.windows[0].h).to_equal(220)
        expect(comp.windows[0].title).to_equal("One Renamed")

        comp.apply_bridge_request(6, 77, COMP_FOCUS.to_i64(), first_id, "", 0, 0, 0, 0, "", 0, "")
        expect(comp.windows[comp.windows.len() - 1].id).to_equal(first_id)
        comp.apply_bridge_request(7, 77, COMP_MAXIMIZE.to_i64(), first_id, "", 0, 0, 0, 0, "", 0, "")
        expect(comp.windows[comp.windows.len() - 1].x).to_equal(0)
        expect(comp.windows[comp.windows.len() - 1].y).to_equal(48)
        expect(comp.windows[comp.windows.len() - 1].w).to_equal(640)
        expect(comp.windows[comp.windows.len() - 1].h).to_equal(384)

    it "maps taskbar hit to the expected window and restores focus":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 11, COMP_CREATE_WINDOW.to_i64(), 0, "One", 20, 60, 200, 140, "", 1, "/sys/apps/one")
        comp.apply_bridge_request(2, 22, COMP_CREATE_WINDOW.to_i64(), 0, "Two", 50, 90, 200, 140, "", 2, "/sys/apps/two")
        val first_id = comp.windows[0].id
        val dock_y = 480 - 62
        val first_x = host_taskbar_item_x(640, comp.windows.len(), 0)
        expect(comp.hit_taskbar(first_x + 20, dock_y + 16)).to_equal(first_id)
        comp.apply_bridge_request(3, 11, COMP_MINIMIZE.to_i64(), first_id, "", 0, 0, 0, 0, "", 0, "/sys/apps/one")
        comp.focus_window(first_id)
        expect(comp.windows[comp.windows.len() - 1].id).to_equal(first_id)
        expect(comp.windows[comp.windows.len() - 1].minimized).to_equal(false)
        comp.destroy_window(first_id)
        expect(comp.windows.len()).to_equal(1)
        expect(comp.windows[0].id).to_not_equal(first_id)

    it "keeps overflow taskbar entries clickable past four windows":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 11, COMP_CREATE_WINDOW.to_i64(), 0, "App 0", 20, 60, 200, 140, "", 1, "/sys/apps/app0")
        comp.apply_bridge_request(2, 12, COMP_CREATE_WINDOW.to_i64(), 0, "App 1", 30, 68, 200, 140, "", 2, "/sys/apps/app1")
        comp.apply_bridge_request(3, 13, COMP_CREATE_WINDOW.to_i64(), 0, "App 2", 40, 76, 200, 140, "", 3, "/sys/apps/app2")
        comp.apply_bridge_request(4, 14, COMP_CREATE_WINDOW.to_i64(), 0, "App 3", 50, 84, 200, 140, "", 4, "/sys/apps/app3")
        comp.apply_bridge_request(5, 15, COMP_CREATE_WINDOW.to_i64(), 0, "App 4", 60, 92, 200, 140, "", 5, "/sys/apps/app4")
        comp.apply_bridge_request(6, 16, COMP_CREATE_WINDOW.to_i64(), 0, "App 5", 70, 100, 200, 140, "", 6, "/sys/apps/app5")
        val count = comp.windows.len()
        val dock_w = host_taskbar_dock_width(640, count)
        val item_w = host_taskbar_item_width(640, count)
        val last_x = host_taskbar_item_x(640, count, 5)
        val dock_y = 480 - 62
        expect(dock_w).to_be_less_than(640)
        expect(comp.hit_taskbar(last_x + (item_w / 2), dock_y + 16)).to_equal(comp.windows[5].id)

    it "clamps dragged windows inside the visible desktop":
        val backend = FakeCompositorBackend(w: 320, h: 240)
        val comp = HostCompositor.new(backend, Size.wh(320, 240))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "Drag", 40, 70, 120, 90, "", 1, "/sys/apps/drag")
        val wid = comp.windows[0].id
        comp.dragging = true
        comp.drag_window_id = wid
        comp.drag_offset_x = 60
        comp.drag_offset_y = 40
        comp = host_compositor_pointer_move(comp, -20, 10)
        expect(comp.windows[0].x).to_equal(0)
        expect(comp.windows[0].y).to_equal(48)

    it "resizes windows from the visible bottom-right grip":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        var comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "Resize", 40, 70, 200, 160, "", 1, "/sys/apps/resize")
        comp = host_compositor_pointer_move(comp, 238, 228)
        comp = host_compositor_left_button(comp, true)
        expect(comp.resizing).to_equal(true)
        comp = host_compositor_pointer_move(comp, 280, 260)
        expect(comp.windows[0].w).to_equal(242)
        expect(comp.windows[0].h).to_equal(192)
        comp = host_compositor_left_button(comp, false)
        expect(comp.resizing).to_equal(false)

    it "routes host-native mouse resize through the shared input helper":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "Host Native Resize", 40, 70, 200, 160, "", 1, "/sys/apps/resize")
        comp.handle_mouse_move(238, 228)
        comp.handle_left_button(true)
        expect(comp.resizing).to_equal(true)
        comp.handle_mouse_move(280, 260)
        expect(comp.windows[0].w).to_equal(242)
        expect(comp.windows[0].h).to_equal(192)
        comp.handle_left_button(false)
        expect(comp.resizing).to_equal(false)
        expect(comp.resize_window_id).to_equal(0)

    it "clamps user resize to the hosted WM minimum size":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        var comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "Resize Min", 40, 70, 200, 160, "", 1, "/sys/apps/resize")
        comp = host_compositor_pointer_move(comp, 238, 228)
        comp = host_compositor_left_button(comp, true)
        comp = host_compositor_pointer_move(comp, 0, 0)
        expect(comp.windows[0].w).to_equal(160)
        expect(comp.windows[0].h).to_equal(120)
        comp = host_compositor_left_button(comp, false)

    it "records a visible failure window for a child that exits before creating a window":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.app_processes.push(HostWmAppProcess(
            title: "Broken",
            app_id: "/sys/apps/broken",
            source_path: "src/app/hosted_apps/broken.spl",
            pid: -1,
            failed: false
        ))
        comp.record_launch_failure(0)
        expect(comp.app_processes[0].failed).to_equal(true)
        expect(comp.windows.len()).to_equal(1)
        expect(comp.windows[0].title).to_equal("Broken failed")
        expect(comp.windows[0].content).to_contain("failed to create a window")

describe "SimpleOS GUI adapter proof":

    it "delivers display app events and input through the shared WM path":
        # Pin the direct-draw chrome contract for the deterministic adapter proof.
        host_wm_force_direct_chrome(true)
        _capture_present_count = 0
        _capture_blue_count = 0
        _capture_engine_title_count = 0
        _capture_engine_content_count = 0
        _capture_blit_count = 0
        _capture_clear_color = 0u32
        val backend = CaptureCompositorBackend.with_color(200, 150, 0xFF000000u32)
        val adapter = SimpleOsGuiAdapter.new(backend, Size.wh(200, 150))

        adapter.deliver_bridge_request(1, 44, COMP_CREATE_WINDOW.to_i64(), 0, "Terminal", 20, 30, 128, 92, "adapter-ready", 800, "/sys/apps/terminal")
        val window_id = adapter.compositor.windows[0].id
        adapter.deliver_pointer_move(146, 120)
        adapter.deliver_left_button(true)
        adapter.deliver_pointer_move(180, 145)
        adapter.deliver_left_button(false)
        adapter.render_framebuffer_frame()
        host_wm_force_direct_chrome(false)

        expect(simpleos_gui_adapter_display_path_name(adapter)).to_equal("simpleos-framebuffer")
        expect(simpleos_gui_adapter_content_renderer_name(adapter)).to_equal(WEB_RENDER_TARGET_SIMPLE_WEB)
        expect(adapter.delivered_bridge_events).to_equal(1)
        expect(adapter.delivered_input_events).to_equal(4)
        expect(adapter.presented_frames).to_equal(1)
        expect(adapter.compositor.windows[0].id).to_equal(window_id)
        expect(adapter.compositor.windows[0].w).to_be_greater_than(128)
        expect(adapter.compositor.windows[0].h).to_be_greater_than(92)
        expect(_capture_present_count).to_equal(1)
        expect(_capture_blue_count).to_be_greater_than(0)
        expect(_capture_clear_color).to_equal(0xFF0F172Au32)

fn _spec_argb_hex(color: u32) -> text:
    val r = ((color / 65536u32) % 256u32).to_i64()
    val g = ((color / 256u32) % 256u32).to_i64()
    val b = (color % 256u32).to_i64()
    "#" + int_to_hex(r) + int_to_hex(g) + int_to_hex(b)

fn _spec_window(id: i64, title: text, x: i32, y: i32, w: i32, h: i32, content: text) -> HostedWindow:
    HostedWindow(id: id, owner_port: 0, title: title, x: x, y: y, w: w, h: h, content: content, process_id: 0, app_id: "/sys/apps/x", minimized: false, focused: true)

describe "host chrome CSS/GUI-web lane":

    it "pins the direct-draw chrome contract when force-direct is set":
        host_wm_force_direct_chrome(true)
        expect(host_wm_chrome_force_direct()).to_equal(true)
        host_wm_force_direct_chrome(false)
        expect(host_wm_chrome_force_direct()).to_equal(false)

    it "expresses window chrome as themed HTML/CSS driven by wm_chrome_theme":
        val theme = wm_chrome_theme()
        val win = _spec_window(1, "Terminal", 10, 12, 120, 80, "hi")
        val html = host_chrome_scene_html([win], 200, 150)
        expect(html.contains(_spec_argb_hex(theme.accent))).to_equal(true)
        expect(html.contains(_spec_argb_hex(theme.host_window_body))).to_equal(true)
        expect(html.contains(_spec_argb_hex(theme.close_button))).to_equal(true)
        expect(html.contains(_spec_argb_hex(theme.compositor_bg))).to_equal(true)
        expect(html.contains("Terminal")).to_equal(true)

    it "fingerprints geometry and theme but not window content":
        val base = _spec_window(1, "Terminal", 10, 12, 120, 80, "one")
        val moved = _spec_window(1, "Terminal", 20, 12, 120, 80, "one")
        val recontent = _spec_window(1, "Terminal", 10, 12, 120, 80, "two")
        val fp_base = host_chrome_scene_fingerprint([base], 200, 150)
        expect(fp_base).to_equal(host_chrome_scene_fingerprint([base], 200, 150))
        expect(fp_base != host_chrome_scene_fingerprint([moved], 200, 150)).to_equal(true)
        expect(fp_base).to_equal(host_chrome_scene_fingerprint([recontent], 200, 150))

    it "rasterizes chrome pixels matching theme colors at expected coordinates":
        val theme = wm_chrome_theme()
        val w = 120
        val h = 80
        val win = _spec_window(1, "Terminal", 10, 10, 90, 60, "hi")
        val html = host_chrome_scene_html([win], w, h)
        val px = simple_web_layout_render_html_pixels_engine2d(html, w, h, "metal")
        expect(px.len()).to_equal(w * h)
        # Titlebar interior (left of the title text) rasterizes to the accent color.
        expect(px[(win.y + 2) * w + (win.x + 2)]).to_equal(theme.accent)
        # Window body below the titlebar rasterizes to host_window_body.
        expect(px[(win.y + 40) * w + (win.x + 2)]).to_equal(theme.host_window_body)
        # Desktop backdrop outside any window rasterizes to compositor_bg.
        expect(px[0]).to_equal(theme.compositor_bg)

describe "hosted WM mouse wheel + non-left buttons (FIX 1)":

    it "routes middle/right buttons through the compositor without touching chrome state":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "One", 40, 60, 200, 140, "", 1, "/sys/apps/one")
        comp.handle_mouse_button(2, true)
        expect(comp.last_button).to_equal(2)
        expect(comp.last_button_down).to_equal(true)
        # Right/middle have no chrome action yet: no drag/resize/focus side effect.
        expect(comp.dragging).to_equal(false)
        comp.handle_mouse_button(1, false)
        expect(comp.last_button).to_equal(1)
        expect(comp.last_button_down).to_equal(false)

    it "still runs full left-button chrome semantics through handle_mouse_button(0, ...)":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "Resize", 40, 70, 200, 160, "", 1, "/sys/apps/resize")
        comp.handle_mouse_move(238, 228)
        comp.handle_mouse_button(0, true)
        expect(comp.resizing).to_equal(true)

    it "accumulates wheel delta on the hovered window and leaves other windows untouched":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "One", 40, 60, 200, 140, "", 1, "/sys/apps/one")
        comp.apply_bridge_request(2, 88, COMP_CREATE_WINDOW.to_i64(), 0, "Two", 300, 60, 200, 140, "", 2, "/sys/apps/two")
        val one_id = comp.windows[0].id
        val two_id = comp.windows[1].id
        comp.handle_mouse_move(80, 100)
        comp.handle_mouse_wheel(0.0, 3.0)
        comp.handle_mouse_wheel(0.0, 2.0)
        expect(comp.scroll_offset_for(one_id)).to_equal(5.0)
        expect(comp.scroll_offset_for(two_id)).to_equal(0.0)

    it "is a no-op when the wheel event arrives over empty desktop":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "One", 40, 60, 200, 140, "", 1, "/sys/apps/one")
        comp.handle_mouse_move(500, 400)
        comp.handle_mouse_wheel(0.0, 4.0)
        expect(comp.scroll_offset_for(comp.windows[0].id)).to_equal(0.0)

describe "click-on-release chrome semantics (FIX 2)":

    it "does not close the window on mouse-down over the close button":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "One", 40, 60, 200, 140, "", 1, "/sys/apps/one")
        val close_x = 40 + 200 - 12
        val close_y = 60 + 12
        comp.handle_mouse_move(close_x, close_y)
        comp.handle_left_button(true)
        expect(comp.windows.len()).to_equal(1)
        expect(comp.armed_chrome_target).to_equal("close")

    it "closes the window on release-inside the close button":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "One", 40, 60, 200, 140, "", 1, "/sys/apps/one")
        val close_x = 40 + 200 - 12
        val close_y = 60 + 12
        comp.handle_mouse_move(close_x, close_y)
        comp.handle_left_button(true)
        comp.handle_left_button(false)
        expect(comp.windows.len()).to_equal(0)

    it "cancels the close action when the pointer drags away before release":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "One", 40, 60, 200, 140, "", 1, "/sys/apps/one")
        val close_x = 40 + 200 - 12
        val close_y = 60 + 12
        comp.handle_mouse_move(close_x, close_y)
        comp.handle_left_button(true)
        # Drag away into the window body (still inside the window, but no
        # longer over the 24x24 close-button corner) before releasing.
        comp.handle_mouse_move(40 + 100, 60 + 60)
        comp.handle_left_button(false)
        expect(comp.windows.len()).to_equal(1)
        expect(comp.armed_chrome_target).to_equal("")

    it "does not focus a taskbar item on mouse-down, only on release-inside":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 11, COMP_CREATE_WINDOW.to_i64(), 0, "One", 20, 60, 200, 140, "", 1, "/sys/apps/one")
        comp.apply_bridge_request(2, 22, COMP_CREATE_WINDOW.to_i64(), 0, "Two", 50, 90, 200, 140, "", 2, "/sys/apps/two")
        val first_id = comp.windows[0].id
        val dock_y = 480 - 62
        val first_x = host_taskbar_item_x(640, comp.windows.len(), 0)
        comp.handle_mouse_move(first_x + 20, dock_y + 16)
        comp.handle_left_button(true)
        # Still armed, not yet focused/reordered: "Two" (created last) is
        # still the top-of-stack / focused window.
        expect(comp.armed_chrome_target).to_equal("taskbar")
        expect(comp.windows[comp.windows.len() - 1].id).to_not_equal(first_id)
        comp.handle_left_button(false)
        expect(comp.windows[comp.windows.len() - 1].id).to_equal(first_id)

    it "cancels the taskbar focus action when the release lands on a different item":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 11, COMP_CREATE_WINDOW.to_i64(), 0, "One", 20, 60, 200, 140, "", 1, "/sys/apps/one")
        comp.apply_bridge_request(2, 22, COMP_CREATE_WINDOW.to_i64(), 0, "Two", 50, 90, 200, 140, "", 2, "/sys/apps/two")
        val first_id = comp.windows[0].id
        val second_id = comp.windows[1].id
        # Reorder so "One" is topmost/last (list becomes [Two, One]) — this
        # makes a spurious unconditional-fire-on-release distinguishable from
        # the correct release-inside-only behavior (see comments below).
        comp.focus_window(first_id)
        expect(comp.windows[comp.windows.len() - 1].id).to_equal(first_id)
        val dock_y = 480 - 62
        val one_item_x = host_taskbar_item_x(640, comp.windows.len(), 1)   # item1 == "One" (now last)
        val two_item_x = host_taskbar_item_x(640, comp.windows.len(), 0)  # item0 == "Two"
        # Arm on "One"'s own taskbar item (currently topmost — refocusing it
        # would be a no-op, so this alone can't hide a bug), then release over
        # "Two"'s item instead.
        comp.handle_mouse_move(one_item_x + 20, dock_y + 16)
        comp.handle_left_button(true)
        expect(comp.armed_chrome_target).to_equal("taskbar")
        expect(comp.armed_chrome_window_id).to_equal(first_id)
        comp.handle_mouse_move(two_item_x + 20, dock_y + 16)
        comp.handle_left_button(false)
        # Release-inside failed to match the armed target ("One"), so "Two"
        # must NOT have been focused: order stays [Two, One], "One" still last.
        expect(comp.windows[comp.windows.len() - 1].id).to_equal(first_id)
        expect(comp.armed_chrome_target).to_equal("")

describe "resize-corner hover arming honors minimized windows (FIX 2)":

    it "does not arm resize over a minimized window's stale screen rect":
        val backend = FakeCompositorBackend(w: 640, h: 480)
        val comp = HostCompositor.new(backend, Size.wh(640, 480))
        comp.apply_bridge_request(1, 77, COMP_CREATE_WINDOW.to_i64(), 0, "One", 40, 70, 200, 160, "", 1, "/sys/apps/resize")
        val wid = comp.windows[0].id
        comp.apply_bridge_request(2, 77, COMP_MINIMIZE.to_i64(), wid, "", 0, 0, 0, 0, "", 0, "/sys/apps/resize")
        comp.handle_mouse_move(238, 228)
        expect(comp.resize_window_id).to_equal(0)
