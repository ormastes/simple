            0xaf, 0x02, 0x1a, 0x68, 0xf7, 0x07, 0x51, 0x1a
        ]
        val exchange_hash: [u8] = [
            0xcd, 0x58, 0xa8, 0x0c, 0x62, 0xab, 0x3d, 0x09,
            0xce, 0x80, 0x0a, 0xe4, 0x6b, 0x5f, 0xbb, 0x77,
            0x9e, 0xb4, 0xd2, 0x3b, 0xa6, 0xcf, 0xef, 0xf9,
            0x5d, 0x2a, 0x2e, 0x95, 0x2b, 0xc2, 0x31, 0x5c
        ]
        val expected_signature: [u8] = [
            0xe0, 0xee, 0x07, 0xab, 0xb9, 0x60, 0x0e, 0xa8,
            0x32, 0x53, 0xe3, 0x24, 0x0a, 0xa5, 0x09, 0x10,
            0x2a, 0x18, 0x84, 0xc2, 0x77, 0x01, 0x02, 0x4b,
            0x90, 0x54, 0xfc, 0xef, 0x8f, 0x7b, 0xfe, 0xc7,
