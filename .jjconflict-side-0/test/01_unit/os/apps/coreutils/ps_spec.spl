"""
# coreutils/ps argument parsing
**Feature IDs:** #WAVE5-G9
**Category:** Userland coreutils
"""
use std.spec.*
use os.apps.coreutils.ps.{main_ps}

describe "ps argument parsing":
    """Argument handling paths."""

    it "--help returns 0":
        """Help is a no-op successful exit."""
        val rc = main_ps(["--help"])
        expect rc.to_equal(0i32)

    it "no args returns an i32":
        """No flags means real invocation path; still returns a status."""
        val rc = main_ps([])
        val is_int: bool = rc == 0i32 or rc != 0i32
        expect is_int.to_equal(true)
