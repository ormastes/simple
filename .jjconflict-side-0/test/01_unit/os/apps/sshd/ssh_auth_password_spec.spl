# @cover src/os/apps/sshd/ssh_auth.spl 40%
# Password authentication: constant-time compare behavior on the secret path.
use std.spipe.*
use os.apps.sshd.ssh_auth.{SshUserDb, sshd_create_default_users}

describe "ssh_auth constant-time password authentication":
    it "accepts the correct password for a known user":
        val db = sshd_create_default_users()
        expect(db.authenticate_password("root", "simpleos")).to_equal(true)

    it "rejects a wrong password of equal length":
        val db = sshd_create_default_users()
        # "simpleos" is 8 chars; "simpleoz" differs only in the last byte
        expect(db.authenticate_password("root", "simpleoz")).to_equal(false)

    it "rejects a wrong password of different length":
        val db = sshd_create_default_users()
        expect(db.authenticate_password("root", "simple")).to_equal(false)

    it "rejects an empty password":
        val db = sshd_create_default_users()
        expect(db.authenticate_password("root", "")).to_equal(false)

    it "rejects an unknown user even with a valid password of another user":
        val db = sshd_create_default_users()
        expect(db.authenticate_password("nobody", "simpleos")).to_equal(false)

    it "matches the correct user when multiple users exist":
        val db = sshd_create_default_users()
        expect(db.authenticate_password("user", "password")).to_equal(true)
        expect(db.authenticate_password("user", "simpleos")).to_equal(false)
