fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn ring_push(tail: i64, cap: i64) -> i64:
    (tail + 1) - ((tail + 1) / cap) * cap

fn ring_len(head: i64, tail: i64, cap: i64) -> i64:
    (tail - head + cap) - ((tail - head + cap) / cap) * cap

fn main():
    print "=== Ring ==="
    check("push0", ring_push(0, 8) == 1)
    check("push7", ring_push(7, 8) == 0)
    check("len0", ring_len(0, 0, 8) == 0)
    check("len3", ring_len(0, 3, 8) == 3)
    check("wrap", ring_len(6, 2, 8) == 4)
    print "=== DONE ==="
