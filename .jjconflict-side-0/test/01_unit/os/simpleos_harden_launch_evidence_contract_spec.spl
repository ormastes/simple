use std.spec.*
use std.io_runtime.{file_read}

describe "SimpleOS harden launch evidence contract":
    it "requires live SSHD listen auth and exec markers before matrix pass":
        val matrix = file_read("scripts/check/check-simpleos-hardening-evidence-matrix.shs")
        val ssh_spec = file_read("test/03_system/os/ssh_live_login_in_qemu_spec.spl")

        expect(matrix).to_contain("[sshd] SSH daemon listening on port 22")
        expect(matrix).to_contain("[sshd-session] auth ok user=root method=password")
        expect(matrix).to_contain("[sshd-session] exec command=true")
        expect(matrix).to_contain("SESSION OK shell simple.smf path=/usr/bin/simple.smf alias=/SYS/APPS/SIMPLSTC.SMF")
        expect(matrix).to_contain("SESSION OK shell simple path=/usr/bin/simple alias=/SYS/APPS/SIMPLSTC.SMF")
        expect(ssh_spec).to_contain("production `SshDaemon` packet stack")
        expect(ssh_spec).to_contain("OpenSSH authenticates as `root`")

    it "requires live QEMU WM service and framebuffer capture markers before matrix pass":
        val matrix = file_read("scripts/check/check-simpleos-hardening-evidence-matrix.shs")
        val gui_spec = file_read("test/03_system/gui/gui_entry_engine2d_wm_simple_web_spec.spl")

        expect(matrix).to_contain("[wm-demo] wm-service-ready")
        expect(matrix).to_contain("[integrated-demo] render-ready")
        expect(matrix).to_contain("shared-mdi-ready surfaces=5")
        expect(matrix).to_contain("windows-ready count=5")
        expect(matrix).to_contain("capture-before-input.ppm")
        expect(matrix).to_contain("capture-after-input.ppm")
        expect(gui_spec).to_contain("spawn_guest_with_qmp")
        expect(gui_spec).to_contain("qmp_keyboard_input")
