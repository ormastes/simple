# Desktop clipboard API specification
# Tests struct availability and module loading

use std.nogc_sync_mut.desktop.clipboard.{clipboard_read, clipboard_write, clipboard_has_text}

extern fn rt_file_read_text(path: text) -> text

fn clipboard_source() -> text:
    rt_file_read_text("src/lib/nogc_sync_mut/desktop/clipboard.spl") ?? ""

describe "Desktop Clipboard API":
    it "exposes clipboard_read function":
        expect(clipboard_source()).to_contain("fn clipboard_read()")

    it "exposes clipboard_write function":
        expect(clipboard_source()).to_contain("fn clipboard_write(content: text)")

    it "exposes clipboard_has_text function":
        expect(clipboard_source()).to_contain("fn clipboard_has_text()")
