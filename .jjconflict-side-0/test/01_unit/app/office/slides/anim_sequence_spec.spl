"""On-slide animation build sequence spec.

Verifies the per-element build order model in
`app.office.slides.anim_sequence`: click-count, the folded start-time
timeline (onClick / afterPrevious / withPrevious), total build duration,
PowerPoint-like `<p:timing>` XML export, and the plain-text build summary.

Timing convention under test (see anim_sequence.spl docstring for the full
rule): start_i = anchor + delay_ms_i, finish_i = start_i + duration_ms_i,
where anchor is 0 for the first step, the previous step's OWN start time
for "withPrevious", the previous step's finish time for "afterPrevious",
and the running max finish time over all prior steps for "onClick".

Ground truth for the 3-step fixture used throughout (title/bullet1/bullet2):
- title:   onClick,       dur 500, delay 0   -> start 0,   finish 500
- bullet1: afterPrevious, dur 300, delay 100 -> anchor = title finish (500),
  start = 500 + 100 = 600, finish = 600 + 300 = 900
- bullet2: withPrevious,  dur 300, delay 0   -> anchor = bullet1's OWN
  start (600), start = 600 + 0 = 600, finish = 600 + 300 = 900
- click_count = 1 (only title is onClick)
- total_ms = max(500, 900, 900) = 900
"""

use std.spec
use app.office.slides.anim_sequence.{AnimSequence, anim_step_new, anim_sequence_new, anim_sequence_add, sequence_click_count, step_start_time_ms, sequence_total_ms, sequence_to_xml, sequence_summary}

fn build_fixture() -> AnimSequence:
    val title = anim_step_new("title", "fadeIn", "entrance", "onClick", 500, 0)
    val bullet1 = anim_step_new("bullet1", "flyIn", "entrance", "afterPrevious", 300, 100)
    val bullet2 = anim_step_new("bullet2", "fadeIn", "entrance", "withPrevious", 300, 0)
    var seq = anim_sequence_new()
    seq = anim_sequence_add(seq, title)
    seq = anim_sequence_add(seq, bullet1)
    seq = anim_sequence_add(seq, bullet2)
    return seq

describe "anim_sequence: click count":
    """Only onClick steps consume a click; withPrevious/afterPrevious ride
    along on the previous click."""

    it "counts exactly one click for a title-onClick, two-follower build":
        val seq = build_fixture()
        expect(sequence_click_count(seq)).to_equal(1)

describe "anim_sequence: folded start-time timeline":
    """step_start_time_ms folds the whole list from step 0 using the
    documented anchor rule per trigger kind."""

    it "starts the first onClick step (title) at 0ms":
        val seq = build_fixture()
        expect(step_start_time_ms(seq, 0)).to_equal(0)

    it "starts the afterPrevious step (bullet1) at 600ms (title finish 500 + own delay 100)":
        val seq = build_fixture()
        expect(step_start_time_ms(seq, 1)).to_equal(600)

    it "starts the withPrevious step (bullet2) at the SAME 600ms as bullet1's own start":
        val seq = build_fixture()
        expect(step_start_time_ms(seq, 2)).to_equal(600)

describe "anim_sequence: total build duration":
    """sequence_total_ms is the max finish time across all steps."""

    it "finishes the whole build at 900ms":
        val seq = build_fixture()
        expect(sequence_total_ms(seq)).to_equal(900)

describe "anim_sequence: PowerPoint-like XML export":
    """sequence_to_xml emits a <p:timing> fragment with one <p:par>/<p:cTn>
    per step carrying effect, category, trigger, duration, and delay."""

    it "contains the timing wrapper, both effect names, and a trigger name":
        val seq = build_fixture()
        val xml = sequence_to_xml(seq)
        expect(xml).to_contain("<p:timing")
        expect(xml).to_contain("fadeIn")
        expect(xml).to_contain("flyIn")
        expect(xml).to_contain("onClick")

    it "carries duration and delay attributes for the afterPrevious step":
        val seq = build_fixture()
        val xml = sequence_to_xml(seq)
        expect(xml).to_contain("dur=\"300\"")
        expect(xml).to_contain("delay=\"100\"")

describe "anim_sequence: plain-text build summary":
    """sequence_summary renders one human-readable line per step using
    step_start_time_ms for the @<start>ms figure."""

    it "renders the title line with its computed start and duration":
        val seq = build_fixture()
        val summary = sequence_summary(seq)
        expect(summary[0]).to_equal("title fadeIn (entrance, onClick) @0ms +500ms")

    it "renders the bullet1 line at its folded 600ms start":
        val seq = build_fixture()
        val summary = sequence_summary(seq)
        expect(summary[1]).to_equal("bullet1 flyIn (entrance, afterPrevious) @600ms +300ms")

    describe "deliberate-fail probe (fixed to green)":
        """A probe that intentionally asserted the wrong total build time
        first (860ms, forgetting bullet1's afterPrevious delay), to confirm
        this example is actually exercised, then corrected to the true
        hand-computed value of 900ms."""

        it "has the correct total build duration of 900ms":
            val seq = build_fixture()
            expect(sequence_total_ms(seq)).to_equal(900)
