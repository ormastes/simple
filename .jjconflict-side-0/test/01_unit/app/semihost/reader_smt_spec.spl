use app.semihost.reader.{smt_json_id_end}

describe "semihost SMT JSON loading":
    it "rejects malformed string ids before integer parsing":
        expect(smt_json_id_end("x", 0)).to_equal(-1)

    it "returns the end offset for numeric string ids":
        expect(smt_json_id_end("123,", 0)).to_equal(3)
