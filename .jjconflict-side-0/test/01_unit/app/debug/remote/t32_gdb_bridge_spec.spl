# T32 GDB Bridge Tests
# Tests PRACTICE command formatting, struct creation, GDB server config.
# T32 connects to its own JTAG target (Power Debug II), not STM32 boards.

# --- Local copies ---

class T32GdbBridgeConfig:
    t32_host: text
    t32_port: i32
    gdb_port: i32
    target_name: text

impl T32GdbBridgeConfig:
    static fn for_t32_target() -> T32GdbBridgeConfig:
        T32GdbBridgeConfig(
            t32_host: "localhost",
            t32_port: 20000,
            gdb_port: 2331,
            target_name: "T32 Power Debug"
        )

    fn gdb_server_enable_cmd() -> text:
        "System.Option GDBSERVER ON"

    fn gdb_server_port_cmd() -> text:
        "GDBSERVER.PORT {self.gdb_port}"

    fn gdb_server_disable_cmd() -> text:
        "System.Option GDBSERVER OFF"

fn format_practice_do(script_path: text) -> text:
    "DO {script_path}"

# --- Tests ---

describe "T32GdbBridgeConfig creation":
    it "T32 target config has correct T32 port":
        val cfg = T32GdbBridgeConfig.for_t32_target()
        expect(cfg.t32_port).to_equal(20000)

    it "T32 target config has correct GDB port":
        val cfg = T32GdbBridgeConfig.for_t32_target()
        expect(cfg.gdb_port).to_equal(2331)

    it "T32 target config has correct name":
        val cfg = T32GdbBridgeConfig.for_t32_target()
        expect(cfg.target_name).to_equal("T32 Power Debug")

describe "T32 PRACTICE command formatting":
    it "GDB server enable command":
        val cfg = T32GdbBridgeConfig.for_t32_target()
        expect(cfg.gdb_server_enable_cmd()).to_equal("System.Option GDBSERVER ON")

    it "GDB server port command":
        val cfg = T32GdbBridgeConfig.for_t32_target()
        expect(cfg.gdb_server_port_cmd()).to_equal("GDBSERVER.PORT 2331")

    it "GDB server disable command":
        val cfg = T32GdbBridgeConfig.for_t32_target()
        expect(cfg.gdb_server_disable_cmd()).to_equal("System.Option GDBSERVER OFF")

    it "PRACTICE DO command":
        val cmd = format_practice_do("t32_startup.cmm")
        expect(cmd).to_equal("DO t32_startup.cmm")
