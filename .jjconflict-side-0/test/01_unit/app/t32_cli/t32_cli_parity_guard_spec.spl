# T32 CLI parity guard spec — ensures every MCP tool has a CLI command entry
# This is the critical enforcement test: if a new MCP tool is added to the
# server, this spec will fail until a matching CLI command is registered.

use app.t32_cli.commands.{all_cli_commands, all_mcp_tool_names}

describe "T32 CLI Parity Guard — count":
    it "total CLI commands is exactly 36":
        val cmds = all_cli_commands()
        expect(cmds.len()).to_equal(36)

    it "unique MCP tool mappings is exactly 36":
        val names = all_mcp_tool_names()
        expect(names.len()).to_equal(36)

    it "no CLI command has empty mcp_tool":
        val cmds = all_cli_commands()
        for cmd in cmds:
            expect(cmd.mcp_tool.len() > 0).to_equal(true)

describe "T32 CLI Parity Guard — session tools":
    it "has t32_sessions_list":
        expect(all_mcp_tool_names()).to_contain("t32_sessions_list")

    it "has t32_session_open":
        expect(all_mcp_tool_names()).to_contain("t32_session_open")

    it "has t32_session_resume":
        expect(all_mcp_tool_names()).to_contain("t32_session_resume")

    it "has t32_session_close":
        expect(all_mcp_tool_names()).to_contain("t32_session_close")

    it "has t32_session_info":
        expect(all_mcp_tool_names()).to_contain("t32_session_info")

    it "has t32_core_list":
        expect(all_mcp_tool_names()).to_contain("t32_core_list")

    it "has t32_core_select":
        expect(all_mcp_tool_names()).to_contain("t32_core_select")

    it "has t32_cmd_run":
        expect(all_mcp_tool_names()).to_contain("t32_cmd_run")

    it "has t32_cmm_run":
        expect(all_mcp_tool_names()).to_contain("t32_cmm_run")

    it "has t32_eval":
        expect(all_mcp_tool_names()).to_contain("t32_eval")

