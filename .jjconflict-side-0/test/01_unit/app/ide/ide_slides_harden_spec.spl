# IDE slides_compat hardening spec.
#
# Verifies that an empty presentation does not crash any slides_compat probe.

use std.spec
use app.ide.slides_compat.{ide_slide_compat_probe, ide_slide_compat_probe_empty}

describe "slides_compat: empty presentation does not crash":

    it "empty presentation probe returns non-negative slide count":
        val probe = ide_slide_compat_probe_empty()
        expect(probe.slide_count >= 0).to_equal(true)

    it "empty presentation outline_line_count is non-negative":
        val probe = ide_slide_compat_probe_empty()
        expect(probe.outline_line_count >= 0).to_equal(true)

    it "empty presentation design_count is non-negative":
        val probe = ide_slide_compat_probe_empty()
        expect(probe.design_count >= 0).to_equal(true)

    it "sample presentation has at least one slide":
        val probe = ide_slide_compat_probe()
        expect(probe.slide_count > 0).to_equal(true)

    it "sample presentation thumbnail is non-empty":
        val probe = ide_slide_compat_probe()
        expect(probe.thumbnail.len() > 0).to_equal(true)
