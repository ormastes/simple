use std.spec
use app.ui.web.wm_bridge.{WmBridge}
use app.ui.web.taskbar_runtime.{host_taskbar_runtime_reset, host_taskbar_runtime_enable}
use common.ui.builder.{column, label, build_tree_with_title}
use nogc_sync_mut.ui.session.{UISession, new_session}
use common.ui.window_surface_registry.{UI_SURFACE_KIND_SIMPLE_WEB}

fn _tree(title: text):
    build_tree_with_title(column("{title}_root", [label("{title}_label", title)]), title, "glass_dark")

fn _session_with_two_windows() -> UISession:
    var session = new_session(_tree("main"))
    val one = session.open_surface("surf1", _tree("one"))
    val two = session.open_surface("surf2", _tree("two"))
    val _x1 = session.set_surface_widget_prop("surf1", "one_root", "x", "10")
    val _y1 = session.set_surface_widget_prop("surf1", "one_root", "y", "40")
    val _w1 = session.set_surface_widget_prop("surf1", "one_root", "width", "300")
    val _h1 = session.set_surface_widget_prop("surf1", "one_root", "height", "200")
    val _x2 = session.set_surface_widget_prop("surf2", "two_root", "x", "80")
    val _y2 = session.set_surface_widget_prop("surf2", "two_root", "y", "120")
    val _w2 = session.set_surface_widget_prop("surf2", "two_root", "width", "300")
    val _h2 = session.set_surface_widget_prop("surf2", "two_root", "height", "200")
    session.bind_window_surface_with_kind("win1", "surf1", 42u64, "demo.one", "Window One", UI_SURFACE_KIND_SIMPLE_WEB)
    session.bind_window_surface_with_kind("win2", "surf2", 43u64, "demo.two", "Window Two", UI_SURFACE_KIND_SIMPLE_WEB)
    session.set_active_surface("surf1")
    session

describe "host web WM runtime loop wiring":
    it "routes host titlebar pointer steps through the shared WM bridge into session focus":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("embedded", false)
        var session = _session_with_two_windows()
        val bridge = WmBridge.new(session)

        val result = bridge.handle_host_wm_pointer_loop_step(90, 125, "left", "down", 800, 600)

        match result:
            Err(_):
                expect(false).to_equal(true)
            Ok(marker):
                expect(marker).to_contain("[host-wm] loop-step command=window_drag_begin")
                expect(marker).to_contain("window=win2")
                expect(bridge.session.active_surface()).to_equal("surf2")
                expect(bridge.last_host_wm_loop_marker()).to_contain("target=surf2")

    it "keeps unsupported host pointer gestures ignored without changing focus":
        host_taskbar_runtime_reset()
        host_taskbar_runtime_enable("embedded", false)
        var session = _session_with_two_windows()
        val bridge = WmBridge.new(session)

        val result = bridge.handle_host_wm_pointer_loop_step(90, 125, "right", "down", 800, 600)

        match result:
            Err(_):
                expect(false).to_equal(true)
            Ok(marker):
                expect(marker).to_contain("command=ignored")
                expect(bridge.session.active_surface()).to_equal("surf1")
