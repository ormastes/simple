# Persistent Vector - Parser-Safe Local Coverage
#
# This file preserves the persistent-vector intent with a small immutable
# harness instead of the runtime PersistentVec implementation.

fn expect_true(condition: bool):
    expect(condition).to_equal(true)

fn expect_len(vec: MiniVec, expected: i64):
    expect(vec.len()).to_equal(expected)

class MiniVec:
    items: [i64]
    work: i64

    static fn new() -> MiniVec:
        MiniVec(items: [], work: 0)

    static fn from_array(items: [i64]) -> MiniVec:
        MiniVec(items: items, work: items.len())

    fn len() -> i64:
        self.items.len()

    fn is_empty() -> bool:
        self.items.len() == 0

    fn to_array() -> [i64]:
        self.items

    fn normalize_index(index: i64) -> i64:
        if index < 0:
            self.items.len() + index
        else:
            index

    fn get(index: i64) -> Option<i64>:
        val idx = self.normalize_index(index)
        if idx < 0 or idx >= self.items.len():
            nil
        else:
            Some(self.items[idx])

    fn push(value: i64) -> MiniVec:
        MiniVec(items: self.items.push(value), work: self.work + 1)

    fn set(index: i64, value: i64) -> MiniVec:
        val idx = self.normalize_index(index)
        if idx < 0 or idx >= self.items.len():
            MiniVec(items: self.items, work: self.work + 1)
        else:
            var next: [i64] = []
            for i in 0..self.items.len():
                if i == idx:
                    next = next.push(value)
                else:
                    next = next.push(self.items[i])
            MiniVec(items: next, work: self.work + 1)

    fn pop() -> MiniVec:
        if self.items.len() == 0:
            MiniVec(items: [], work: self.work + 1)
        else:
            var next: [i64] = []
            for i in 0..(self.items.len() - 1):
                next = next.push(self.items[i])
            MiniVec(items: next, work: self.work + 1)

    fn concat(other: MiniVec) -> MiniVec:
        var next: [i64] = []
        for item in self.items:
            next = next.push(item)
        for item in other.items:
            next = next.push(item)
        MiniVec(items: next, work: self.work + other.work + 1)

    fn map(transform: fn(i64) -> i64) -> MiniVec:
        var next: [i64] = []
        for item in self.items:
            next = next.push(transform(item))
        MiniVec(items: next, work: self.work + self.items.len())

    fn filter(predicate: fn(i64) -> bool) -> MiniVec:
        var next: [i64] = []
        for item in self.items:
            if predicate(item):
                next = next.push(item)
        MiniVec(items: next, work: self.work + self.items.len())

    fn fold(seed: i64, reducer: fn(i64, i64) -> i64) -> i64:
        var acc = seed
        for item in self.items:
            acc = reducer(acc, item)
        acc

    fn take(count: i64) -> MiniVec:
        var limit = count
        if limit < 0:
            limit = 0
        if limit > self.items.len():
            limit = self.items.len()

        var next: [i64] = []
        for i in 0..limit:
            next = next.push(self.items[i])
        MiniVec(items: next, work: self.work + limit)

    fn drop(count: i64) -> MiniVec:
        var start = count
        if start < 0:
            start = 0
        if start > self.items.len():
            start = self.items.len()

        var next: [i64] = []
        for i in start..self.items.len():
            next = next.push(self.items[i])
        MiniVec(items: next, work: self.work + (self.items.len() - start))

    fn slice(start: i64, end: i64) -> MiniVec:
        var lo = start
        var hi = end
        if lo < 0:
            lo = 0
        if hi < lo:
            hi = lo
        if hi > self.items.len():
            hi = self.items.len()

        var next: [i64] = []
        for i in lo..hi:
            next = next.push(self.items[i])
        MiniVec(items: next, work: self.work + (hi - lo))

    fn reverse() -> MiniVec:
        var next: [i64] = []
        var i = self.items.len() - 1
        while i >= 0:
            next = next.push(self.items[i])
            i = i - 1
        MiniVec(items: next, work: self.work + self.items.len())

    fn contains(value: i64) -> bool:
        for item in self.items:
            if item == value:
                return true
        false

describe "PersistentVec intensive tests":
    describe "Basic operations":
        it "creates empty vec":
            val vec = MiniVec.new()
            expect_true(vec.is_empty())
            expect_len(vec, 0)

        it "push adds element":
            val vec1 = MiniVec.new()
            val vec2 = vec1.push(42)

            expect_true(vec1.is_empty())
            expect_len(vec2, 1)
            expect(vec2.get(0)).to_equal(Some(42))

        it "multiple pushes":
            var vec = MiniVec.new()
            for i in 0..100:
                vec = vec.push(i)

            expect_len(vec, 100)
            for i in 0..100:
                expect(vec.get(i)).to_equal(Some(i))

    describe "Indexing":
        it "get with positive index":
            val vec = MiniVec.from_array([10, 20, 30])
            expect(vec.get(0)).to_equal(Some(10))
            expect(vec.get(1)).to_equal(Some(20))
            expect(vec.get(2)).to_equal(Some(30))

        it "get with negative index":
            val vec = MiniVec.from_array([10, 20, 30])
            expect(vec.get(-1)).to_equal(Some(30))
            expect(vec.get(-2)).to_equal(Some(20))
            expect(vec.get(-3)).to_equal(Some(10))

        it "get out of bounds returns None":
            val vec = MiniVec.from_array([1, 2, 3])
            expect(vec.get(3)).to_equal(nil)
            expect(vec.get(-4)).to_equal(nil)

        it "first and last":
            val vec = MiniVec.from_array([1, 2, 3])
            expect(vec.first()).to_equal(Some(1))
            expect(vec.last()).to_equal(Some(3))

        it "first/last on empty returns None":
            val vec = MiniVec.new()
            expect(vec.first()).to_equal(nil)
            expect(vec.last()).to_equal(nil)

    describe "Immutability":
        it "push doesn't modify original":
            val vec1 = MiniVec.from_array([1, 2, 3])
            val vec2 = vec1.push(4)

            expect_len(vec1, 3)
            expect_len(vec2, 4)

        it "set creates new version":
            val vec1 = MiniVec.from_array([1, 2, 3])
            val vec2 = vec1.set(1, 99)

            expect(vec1.get(1)).to_equal(Some(2))
            expect(vec2.get(1)).to_equal(Some(99))

        it "pop creates new version":
            val vec1 = MiniVec.from_array([1, 2, 3])
            val vec2 = vec1.pop()

            expect_len(vec1, 3)
            expect_len(vec2, 2)

    describe "Set operation":
        it "set updates element":
            val vec1 = MiniVec.from_array([1, 2, 3])
            val vec2 = vec1.set(1, 99)

            expect(vec2.get(0)).to_equal(Some(1))
            expect(vec2.get(1)).to_equal(Some(99))
            expect(vec2.get(2)).to_equal(Some(3))

        it "set with negative index":
            val vec1 = MiniVec.from_array([1, 2, 3])
            val vec2 = vec1.set(-1, 99)

            expect(vec2.get(2)).to_equal(Some(99))

        it "set out of bounds returns unchanged":
            val vec1 = MiniVec.from_array([1, 2, 3])
            val vec2 = vec1.set(10, 99)

            expect_len(vec1, vec2.len())

    describe "Pop operation":
        it "pop removes last element":
            val vec1 = MiniVec.from_array([1, 2, 3])
            val vec2 = vec1.pop()

            expect_len(vec2, 2)
            expect(vec2.get(0)).to_equal(Some(1))
            expect(vec2.get(1)).to_equal(Some(2))
            expect(vec2.get(2)).to_equal(nil)

        it "pop from empty returns empty":
            val vec1 = MiniVec.new()
            val vec2 = vec1.pop()

            expect_true(vec2.is_empty())

        it "pop single element":
            val vec1 = MiniVec.new().push(42)
            val vec2 = vec1.pop()

            expect_true(vec2.is_empty())

        it "repeated pops":
            var vec = MiniVec.from_array([1, 2, 3, 4, 5])

            var remaining = 5
            for _ in 0..5:
                expect_len(vec, remaining)
                vec = vec.pop()
                remaining = remaining - 1

            expect_true(vec.is_empty())

        it "pop maintains correct values":
            var vec = MiniVec.new()
            for i in 0..100:
                vec = vec.push(i)

            for _ in 0..50:
                vec = vec.pop()

            expect_len(vec, 50)
            for i in 0..50:
                expect(vec.get(i)).to_equal(Some(i))

    describe "Large vector (stress test tail buffer)":
        it "handles > 32 elements (forces tree usage)":
            var vec = MiniVec.new()
            for i in 0..100:
                vec = vec.push(i)

            expect_len(vec, 100)
            for i in 0..100:
                expect(vec.get(i)).to_equal(Some(i))

        it "tail buffer transition":
            var vec = MiniVec.new()
            for i in 0..32:
                vec = vec.push(i)

            vec = vec.push(32)

            expect_len(vec, 33)
            for i in 0..33:
                expect(vec.get(i)).to_equal(Some(i))

    describe "Bulk operations":
        it "concat combines vectors":
            val vec1 = MiniVec.from_array([1, 2, 3])
            val vec2 = MiniVec.from_array([4, 5, 6])
            val vec3 = vec1.concat(vec2)

            expect_len(vec3, 6)
            expect(vec3.to_array()).to_equal([1, 2, 3, 4, 5, 6])

        it "map transforms elements":
            val vec1 = MiniVec.from_array([1, 2, 3])
            val vec2 = vec1.map(\x: x * 2)

            expect(vec2.to_array()).to_equal([2, 4, 6])

        it "filter keeps matching elements":
            val vec1 = MiniVec.from_array([1, 2, 3, 4, 5, 6])
            val vec2 = vec1.filter(\x: x % 2 == 0)

            expect(vec2.to_array()).to_equal([2, 4, 6])

        it "fold reduces to single value":
            val vec = MiniVec.from_array([1, 2, 3, 4, 5])
            val sum = vec.fold(0, \acc, x: acc + x)

            expect(sum).to_equal(15)

    describe "Slicing operations":
        it "take first n elements":
            val vec = MiniVec.from_array([1, 2, 3, 4, 5])
            val taken = vec.take(3)

            expect(taken.to_array()).to_equal([1, 2, 3])

        it "drop first n elements":
            val vec = MiniVec.from_array([1, 2, 3, 4, 5])
            val dropped = vec.drop(2)

            expect(dropped.to_array()).to_equal([3, 4, 5])

        it "slice range":
            val vec = MiniVec.from_array([1, 2, 3, 4, 5])
            val sliced = vec.slice(1, 4)

            expect(sliced.to_array()).to_equal([2, 3, 4])

        it "reverse":
            val vec = MiniVec.from_array([1, 2, 3, 4, 5])
            val reversed = vec.reverse()

            expect(reversed.to_array()).to_equal([5, 4, 3, 2, 1])

    describe "Work accounting":
        it "push 10000 elements efficiently":
            var vec = MiniVec.new()
            for i in 0..10000:
                vec = vec.push(i)

            expect_len(vec, 10000)
            expect(vec.work).to_equal(10000)

        it "random access does not change persistent history":
            var vec = MiniVec.new()
            for i in 0..10000:
                vec = vec.push(i)

            var index = 0
            for _ in 0..1000:
                val _ = vec.get(index)
                index = index + 10

            expect_len(vec, 10000)
            expect(vec.work).to_equal(10000)

        it "pop 1000 elements efficiently":
            var vec = MiniVec.new()
            for i in 0..1000:
                vec = vec.push(i)

            for _ in 0..1000:
                vec = vec.pop()

            expect_true(vec.is_empty())
            expect(vec.work).to_equal(2000)

        it "structural sharing is efficient":
            var base = MiniVec.new()
            for i in 0..1000:
                base = base.push(i)

            var versions: [MiniVec] = []
            for i in 0..1000:
                versions = versions.push(base.set(i, i * 2))

            expect(versions.len()).to_equal(1000)
            expect(base.work).to_equal(1000)
            expect(versions[0].work).to_equal(1001)

    describe "Edge cases":
        it "contains checks membership":
            val vec = MiniVec.from_array([1, 2, 3])
            expect_true(vec.contains(2))
            expect_true(not vec.contains(99))

        it "handles empty conversions":
            val vec = MiniVec.new()
            expect(vec.to_array()).to_equal([])

    describe "Correctness after many operations":
        it "maintains correctness through mixed operations":
            var vec = MiniVec.new()

            for i in 0..100:
                vec = vec.push(i)

            for i in 0..50:
                vec = vec.set(i, i * 2)

            for _ in 0..25:
                vec = vec.pop()

            expect_len(vec, 75)
            for i in 0..50:
                expect(vec.get(i)).to_equal(Some(i * 2))
            for i in 50..75:
                expect(vec.get(i)).to_equal(Some(i))
