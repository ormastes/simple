fn _parse_flag_value(args: [text], flag: text) -> text?:
    var i = 0
    while i < args.len():
        if args[i] == flag and i + 1 < args.len():
            return Some(args[i + 1])
        i = i + 1
    nil

fn _has_flag(args: [text], flag: text) -> bool:
    for arg in args:
        if arg == flag:
            return true
    false

fn _parse_csv_flags(raw: text) -> [text]:
    var result: [text] = []
    for part in raw.split(","):
        val cleaned = part.trim()
        if cleaned != "":
            result.push(cleaned)
    result

describe "ParseUtils":
    it "finds a flag value":
        val args = ["--mode", "fast", "--verbose"]
        val mode = _parse_flag_value(args, "--mode")
        expect mode == "fast"

    it "returns nil for a missing flag value":
        val args = ["--verbose"]
        val mode = _parse_flag_value(args, "--mode")
        expect mode == nil

    it "detects boolean flags":
        val args = ["--mode", "fast", "--verbose"]
        expect _has_flag(args, "--verbose") == true
        expect _has_flag(args, "--quiet") == false

    it "splits comma separated flags and drops blanks":
        val flags = _parse_csv_flags("native, , smf")
        expect flags.len() == 2
        expect flags[0] == "native"
        expect flags[1] == "smf"
