# ============================================================================
# 8. Flag Detection Edge Cases (12 tests)
# ============================================================================

describe "flag detection edge cases":
    it "EDGE: flag at end of args":
        val args = ["test", "file.spl", "--json"]
        val needs_rust = false
        expect needs_rust == false

    it "EDGE: flag at beginning (right after command)":
        val args = ["test", "--json", "file.spl"]
        val needs_rust = false
        expect needs_rust == false

    it "EDGE: flag in middle of args":
        val args = ["test", "a.spl", "--json", "b.spl"]
        val needs_rust = false
        expect needs_rust == false

    it "EDGE: only flag, no files":
        val args = ["lint", "--json"]
        val needs_rust = args.any(_1 == "--json" or _1 == "--fix")
        expect needs_rust == true

    it "EDGE: multiple non-rust flags":
        val args = ["test", "--verbose", "--list", "--show-tags"]
        val needs_rust = args.any(_1 == "--json" or _1 == "--watch" or _1 == "--parallel")
        expect needs_rust == false

    it "EDGE: args[1:] skips command name correctly":
        val args = ["test", "--verbose", "file.spl"]
        val check_args = args[1:]
        expect check_args.len() == 2
        expect check_args[0] == "--verbose"
        # Command name itself should never be checked for flags
        expect check_args.contains("test") == false

    it "EDGE: single letter flag -p matches exactly":
        val args = ["test", "-p"]
        val needs_rust = args.any(_1 == "-p")
        expect needs_rust == true

    it "EDGE: -p is not prefix of -pattern":
        val args = ["test", "-pattern"]
        val needs_rust = args.any(_1 == "-p")
        expect needs_rust == false

    it "EDGE: --capture-screenshots exact match":
        val args = ["test", "--capture-screenshots"]
        val needs_rust = args.any(_1 == "--capture-screenshots")
        expect needs_rust == true

    it "EDGE: --cleanup-runs exact match":
        val args = ["test", "--cleanup-runs"]
        val needs_rust = args.any(_1 == "--cleanup-runs")
        expect needs_rust == true

    it "EDGE: combined rust-only and normal flags":
        val args = ["test", "--verbose", "--watch", "--list"]
        val needs_rust = args.any(_1 == "--watch")
        expect needs_rust == true

    it "EDGE: no args at all (just command)":
        val args = ["test"]
        val check_args = args[1:]
        val needs_rust = check_args.any(_1 == "--json")
        expect needs_rust == false

# ============================================================================
# 9. Argument Slicing Edge Cases (8 tests)
# ============================================================================

describe "argument slicing edge cases":
    it "slice of single-element list is empty":
        val args = ["cmd"]
        val rest = args[1:]
        expect rest.len() == 0

    it "slice preserves all elements":
        val args = ["cmd", "a", "b", "c"]
        val rest = args[1:]
        expect rest.len() == 3
        expect rest[0] == "a"
        expect rest[1] == "b"
        expect rest[2] == "c"

    it "slice of two-element list gives one element":
        val args = ["cmd", "arg"]
        val rest = args[1:]
        expect rest.len() == 1
        expect rest[0] == "arg"

    it "EDGE: nested slicing":
        val args = ["cmd", "a", "b", "c", "d"]
        val rest = args[1:]
        val rest2 = rest[1:]
        expect rest2.len() == 3
        expect rest2[0] == "b"

    it "EDGE: slice with negative index":
        val args = ["a", "b", "c", "d"]
        val last = args[-1]
        expect last == "d"

    it "EDGE: full slice is identity":
        val args = ["a", "b", "c"]
        val full = args[0:]
        expect full.len() == 3

    it "EDGE: slice range":
        val args = ["cmd", "a", "b", "c", "d"]
        val mid = args[1:3]
        expect mid.len() == 2
        expect mid[0] == "a"
        expect mid[1] == "b"

    it "EDGE: step slice":
        val args = ["a", "b", "c", "d", "e", "f"]
        val evens = args[::2]
        expect evens.len() == 3
        expect evens[0] == "a"
        expect evens[1] == "c"
        expect evens[2] == "e"

# ============================================================================
# 10. Command-to-App Mapping (6 tests)
# ============================================================================

describe "command to app directory mapping":
    it "fmt maps to shared lint entry":
        val cmd = "fmt"
        val app_path = "src/app/cli/lint_entry.spl"
        expect app_path.ends_with("lint_entry.spl") == true

    it "spipe-docgen maps to spipe_docgen (hyphen to underscore)":
        val cmd = "spipe-docgen"
        val app_dir = "spipe_docgen"
        expect cmd.contains("-") == true
        expect app_dir.contains("-") == false

    it "test maps to test_runner_new (not test)":
        val cmd = "test"
        val app_dir = "test_runner_new"
        expect cmd != app_dir

    it "direct name commands: coverage, verify, dashboard, context, mcp, depgraph, lsp, dap":
        val direct = ["coverage", "verify", "dashboard", "context",
                      "mcp", "depgraph", "lsp", "dap"]
        for cmd in direct:
            val path = "src/app/{cmd}/main.spl"
            expect path.contains(cmd) == true

    it "EDGE: command name is not always the directory name":
        # These commands have different directory names
        val mapped = [["fmt", "cli/lint_entry"], ["lint", "cli/lint_entry"], ["fix", "cli/lint_entry"], ["test", "test_runner_new"], ["spipe-docgen", "spipe_docgen"], ["native-build", "cli/native_build_main"], ["vscode", "cli/vscode_entry"], ["electron", "cli/electron_entry"], ["security", "cli/security_entry"]]
        for pair in mapped:
            expect pair[0] != pair[1]

    it "EDGE: all app directories are snake_case or single word":
        val dirs = ["coverage", "dashboard", "verify",
                    "context", "mcp", "spipe_docgen", "depgraph", "lsp", "dap",
                    "test_runner_new", "cli/lint_entry", "cli/native_build_main",
                    "cli/vscode_entry", "cli/electron_entry", "cli/security_entry"]
        for dir in dirs:
            expect dir.contains("-") == false
            expect dir.contains(" ") == false

# ============================================================================
# 11. Dispatch Decision Logic (6 tests)
# ============================================================================

describe "dispatch decision logic":
    it "pure tools ignore env guard":
        val env_set = true
        val has_rust_flag = true
        val app_exists = true
        val is_pure = true
        val use_simple = is_pure and app_exists
        expect use_simple == true

    it "pure tools ignore Rust-only flags":
        val env_set = false
        val has_rust_flag = true
        val app_exists = true
        val is_pure = true
        val use_simple = is_pure and app_exists
        expect use_simple == true

    it "simple app used when no env guard and no rust flags":
        val env_set = false
        val has_rust_flag = false
        val app_exists = true
        val use_simple = not env_set and not has_rust_flag and app_exists
        expect use_simple == true

    it "pure app missing fails closed":
        val env_set = false
        val has_rust_flag = false
        val app_exists = false
        val is_pure = true
        val error = is_pure and not app_exists
        expect error == true

    it "EDGE: hybrid env guard still overrides":
        val env_set = true
        val has_rust_flag = false
        val is_pure = false
        val use_rust = not is_pure and env_set
        expect use_rust == true

    it "EDGE: app not found with no fallback errors":
        val app_exists = false
        val has_rust_fallback = false
        val error = not app_exists and not has_rust_fallback
        expect error == true

# ============================================================================
# 12. Integration: Full Dispatch Simulation (6 tests)
# ============================================================================

describe "full dispatch simulation":
    it "simulate fmt dispatch: normal args -> Simple":
        val args = ["fmt", "file.spl", "--check"]
        val env_set = false
        val needs_rust = args.any(_1 == "--json")
        val app_exists = true
        val dispatch = dispatch_decision(env_set, needs_rust, app_exists, false)
        expect dispatch == "simple"

    it "simulate fmt dispatch: --json -> Simple":
        val args = ["fmt", "--json", "file.spl"]
        val env_set = false
        val needs_rust = false
        val dispatch = dispatch_decision(env_set, needs_rust, true, false)
        expect dispatch == "simple"

    it "simulate context dispatch: env guard -> Simple":
        val args = ["context", "--help"]
        val env_set = true
        val needs_rust = false
        val dispatch = dispatch_decision(env_set, needs_rust, true, true)
        expect dispatch == "simple"

    it "simulate coverage dispatch: no fallback, app exists -> Simple":
        val dispatch = if true: "simple" else: "error"
        expect dispatch == "simple"

    it "simulate coverage dispatch: no fallback, app missing -> error":
        val dispatch = if false: "simple" else: "error"
        expect dispatch == "error"

    it "simulate test dispatch: --watch and normal both stay Simple":
        val args_watch = ["test", "--watch"]
        val args_normal = ["test", "my_spec.spl"]
        val watch_rust = false
        val normal_rust = false
        expect watch_rust == false
        expect normal_rust == false

# ============================================================================
# Helper Functions
# ============================================================================

fn dispatch_decision(env_set: bool, needs_rust: bool, app_exists: bool, is_pure: bool) -> text:
    if is_pure:
        if app_exists:
            return "simple"
        return "error"
    if env_set:
        return "rust"
    if needs_rust:
        return "rust"
    if app_exists:
        return "simple"
    return "rust"
