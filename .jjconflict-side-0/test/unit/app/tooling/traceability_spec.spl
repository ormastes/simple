"""
# Traceability Checker Specification

**Feature IDs:** #TRC-001
**Category:** Tooling
**Status:** Draft
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A
"""

use app.traceability.core.{
    count_traceability_manifest_default_warnings_by_code, count_traceability_manifest_single_root_warnings_by_code,
    normalize_slug, map_source_to_unit_candidates, map_source_dir_to_integration_candidates,
    extract_relative_paths, extract_trace_ids
}

describe "traceability helpers":
    it "normalizes date suffixed slugs":
        expect(normalize_slug("security_aop_architecture_2026-03-28")).to_equal("security_aop_architecture")

    it "extracts relative paths from markdown and plain text":
        val content = """
**Requirements:** [Req](doc/02_requirements/feature/security_aop.md)
Related test: doc/06_spec/security_aop_spec.md
"""
        val paths = extract_relative_paths(content)
        expect(paths).to_contain("doc/02_requirements/feature/security_aop.md")
        expect(paths).to_contain("doc/06_spec/security_aop_spec.md")

    it "extracts REQ and NFR identifiers":
        val ids = extract_trace_ids("REQ-SEC-001 NFR-PERF-001")
        expect(ids).to_contain("REQ-SEC-001")
        expect(ids).to_contain("NFR-PERF-001")

describe "source test mapping":
    it "maps compiler sources to unit candidates":
        val candidates = map_source_to_unit_candidates("src/compiler/85.mdsoc/layer_checker.spl")
        expect(candidates).to_contain("test/unit/compiler/mdsoc/layer_checker_spec.spl")

    it "maps lib sources to unit candidates":
        val candidates = map_source_to_unit_candidates("src/lib/common/security/sanitize.spl")
        expect(candidates).to_contain("test/unit/lib/security/sanitize_spec.spl")

    it "maps source directories to integration candidates":
        val candidates = map_source_dir_to_integration_candidates("src/compiler/85.mdsoc")
        expect(candidates).to_contain("test/integration/compiler/mdsoc/module_spec.spl")

describe "traceability analysis":
    it "warns when a requirement identifier is not covered":
        val manifest = """
@@ doc/02_requirements/feature/security_aop.md
# Security AOP

REQ-SEC-001:
The system shall ...
REQ-SEC-002:
The system shall ...
@@ doc/03_plan/security_aop.md
# Plan

**Requirements:** doc/02_requirements/feature/security_aop.md
@@ doc/05_design/security_aop.md
# Design

**Requirements:** doc/02_requirements/feature/security_aop.md
@@ doc/01_research/security_aop.md
# Research

**Requirements:** doc/02_requirements/feature/security_aop.md
@@ test/system/security_aop_spec.spl
**Requirements:** doc/02_requirements/feature/security_aop.md
**Plan:** doc/03_plan/security_aop.md
**Design:** doc/05_design/security_aop.md
**Research:** doc/01_research/security_aop.md

# @req REQ-SEC-001
"""
        expect(count_traceability_manifest_default_warnings_by_code(manifest, "all", "TRC401")).to_equal(1)

    it "warns on legacy requirement roots in specs":
        val manifest = """
@@ doc/02_requirements/feature/foo.md
# Foo
REQ-FOO-001:
@@ doc/03_plan/foo.md
# Foo Plan
@@ doc/05_design/foo.md
# Foo Design
@@ doc/01_research/foo.md
# Foo Research
@@ test/feature/foo_spec.spl
**Requirements:** doc/requirement/foo.md
**Plan:** doc/03_plan/foo.md
**Design:** doc/05_design/foo.md
**Research:** doc/01_research/foo.md

# @req REQ-FOO-001
"""
        expect(count_traceability_manifest_default_warnings_by_code(manifest, "spec", "TRC211")).to_equal(1)

    it "warns when docs point to raw specs":
        val manifest = """
@@ doc/02_requirements/feature/foo.md
# Foo
REQ-FOO-001:
@@ doc/01_research/foo.md
# Research

**Requirements:** doc/02_requirements/feature/foo.md
See test/foo_spec.spl for details.
"""
        expect(count_traceability_manifest_default_warnings_by_code(manifest, "doc", "TRC205")).to_equal(1)

    it "warns for opted-in source roots without unit tests":
        val manifest = """
@@ src/compiler/85.mdsoc/__init__.spl
export foo
@@ src/compiler/85.mdsoc/layer_checker.spl
fn check():
    1
"""
        expect(count_traceability_manifest_single_root_warnings_by_code(manifest, "src", "src/compiler/85.mdsoc", "TRC101")).to_equal(1)
        expect(count_traceability_manifest_single_root_warnings_by_code(manifest, "src", "src/compiler/85.mdsoc", "TRC111")).to_equal(1)
