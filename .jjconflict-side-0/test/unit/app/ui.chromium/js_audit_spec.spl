# Feature: Chromium Shell JS Engine Maturity Audit (V3, Row 5 — M9)
# Category: UI Components
# Status: Implemented
#
# Compile-only smoke spec. Verifies the M9 JS audit surface:
#
#   * `Test262Runner` tallies pass / fail / crash / skip cases and
#     respects the `negative` flag when classifying raw outcomes.
#   * The canonical `Test262Report` snapshots round-trip their numbers
#     and compute an honest pass-rate percentage.
#   * `js_audit_known_crashes` exposes a non-empty, well-formed crash
#     list — the "things V3 apps will hit and crash on" list the plan
#     doc asks for.
#
# No JS engine bring-up and no SFFI — the entire M9 decision surface
# is pure tallying logic plus frozen report snapshots, so the spec
# can exercise it directly without touching
# `examples/browser/feature/script/engine/`.

use app.ui.chromium.js_audit.{
    Test262Case,
    Test262Runner,
    js_audit_default_subset,
    OUTCOME_PASS,
    OUTCOME_FAIL,
    OUTCOME_CRASH,
    OUTCOME_SKIP
}
use app.ui.chromium.js_audit_report.{Test262Report}
use app.ui.chromium.js_audit_crash_list.{
    KnownCrash,
    js_audit_known_crashes,
    js_audit_crash_count
}

# =========================================================================
# Test Group 1: Test262Runner tallying
# =========================================================================

describe "Chromium M9 Test262Runner":
    """Pure tally logic for the JS audit runner."""

    it "fresh runner starts with zero totals":
        val r = Test262Runner.new("interpreter")
        expect(r.total() == 0).to_be_true()
        expect(r.pass_rate_pct() == 0).to_be_true()

    it "record(pass) bumps the pass bucket":
        var r = Test262Runner.new("interpreter")
        r.record(OUTCOME_PASS)
        expect(r.pass_count == 1).to_be_true()
        expect(r.total() == 1).to_be_true()

    it "record(fail) bumps only the fail bucket":
        var r = Test262Runner.new("interpreter")
        r.record(OUTCOME_FAIL)
        expect(r.fail_count == 1).to_be_true()
        expect(r.pass_count == 0).to_be_true()

    it "record(crash) bumps only the crash bucket":
        var r = Test262Runner.new("interpreter")
        r.record(OUTCOME_CRASH)
        expect(r.crash_count == 1).to_be_true()

    it "record(skip) bumps only the skip bucket":
        var r = Test262Runner.new("interpreter")
        r.record(OUTCOME_SKIP)
        expect(r.skip_count == 1).to_be_true()

    it "pass_rate_pct is 100 when every case passes":
        var r = Test262Runner.new("interpreter")
        r.record(OUTCOME_PASS)
        r.record(OUTCOME_PASS)
        r.record(OUTCOME_PASS)
        expect(r.pass_rate_pct() == 100).to_be_true()

    it "pass_rate_pct is 50 for one pass and one fail":
        var r = Test262Runner.new("interpreter")
        r.record(OUTCOME_PASS)
        r.record(OUTCOME_FAIL)
        expect(r.pass_rate_pct() == 50).to_be_true()

# =========================================================================
# Test Group 2: Negative-flag classification
# =========================================================================

describe "Chromium M9 Test262Runner.classify":
    """A negative case flips pass<->fail but leaves crash/skip alone."""

    it "non-negative pass stays pass":
        var r = Test262Runner.new("interpreter")
        val c = Test262Case.new("x", "1", false)
        expect(r.classify(c, OUTCOME_PASS) == OUTCOME_PASS).to_be_true()

    it "non-negative fail stays fail":
        var r = Test262Runner.new("interpreter")
        val c = Test262Case.new("x", "1", false)
        expect(r.classify(c, OUTCOME_FAIL) == OUTCOME_FAIL).to_be_true()

    it "negative case that threw becomes pass":
        var r = Test262Runner.new("interpreter")
        val c = Test262Case.new("neg", "throw 1", true)
        expect(r.classify(c, OUTCOME_FAIL) == OUTCOME_PASS).to_be_true()

    it "negative case that did not throw becomes fail":
        var r = Test262Runner.new("interpreter")
        val c = Test262Case.new("neg", "1", true)
        expect(r.classify(c, OUTCOME_PASS) == OUTCOME_FAIL).to_be_true()

    it "crash on a negative case is still a crash":
        var r = Test262Runner.new("interpreter")
        val c = Test262Case.new("neg", "1", true)
        expect(r.classify(c, OUTCOME_CRASH) == OUTCOME_CRASH).to_be_true()

    it "skip on a negative case is still a skip":
        var r = Test262Runner.new("interpreter")
        val c = Test262Case.new("neg", "1", true)
        expect(r.classify(c, OUTCOME_SKIP) == OUTCOME_SKIP).to_be_true()

    it "run_case bumps the resolved bucket, not the raw one":
        var r = Test262Runner.new("interpreter")
        val c = Test262Case.new("neg", "throw 1", true)
        val resolved = r.run_case(c, OUTCOME_FAIL)
        expect(resolved == OUTCOME_PASS).to_be_true()
        expect(r.pass_count == 1).to_be_true()
        expect(r.fail_count == 0).to_be_true()

# =========================================================================
# Test Group 3: Default subset shape
# =========================================================================

describe "Chromium M9 js_audit_default_subset":

    it "has exactly five baseline cases":
        val subset = js_audit_default_subset()
        expect(subset.len() == 5).to_be_true()

    it "contains a negative case":
        val subset = js_audit_default_subset()
        var found = false
        for c in subset:
            if c.negative:
                found = true
        expect(found).to_be_true()

    it "has at least four positive cases":
        val subset = js_audit_default_subset()
        var positives = 0
        for c in subset:
            if c.negative == false:
                positives = positives + 1
        expect(positives >= 4).to_be_true()

# =========================================================================
# Test Group 4: Test262Report snapshots
# =========================================================================

describe "Chromium M9 Test262Report":
    """Checked-in pass-rate snapshots — the `#2` acceptance criterion."""

    it "canonical interpreter snapshot is 5/0/0/0":
        val rep = Test262Report.canonical()
        expect(rep.pass_count == 5).to_be_true()
        expect(rep.fail_count == 0).to_be_true()
        expect(rep.crash_count == 0).to_be_true()
        expect(rep.skip_count == 0).to_be_true()

    it "canonical snapshot reports 100% pass rate":
        val rep = Test262Report.canonical()
        expect(rep.pass_rate_pct() == 100).to_be_true()

    it "canonical snapshot is tagged interpreter / m9-baseline":
        val rep = Test262Report.canonical()
        expect(rep.backend == "interpreter").to_be_true()
        expect(rep.subset == "m9-baseline").to_be_true()

    it "jit_today snapshot is all-skipped":
        val rep = Test262Report.jit_today()
        expect(rep.skip_count == 5).to_be_true()
        expect(rep.pass_count == 0).to_be_true()

    it "jit_today snapshot reports 0% pass rate":
        val rep = Test262Report.jit_today()
        expect(rep.pass_rate_pct() == 0).to_be_true()

    it "full_corpus_today is the `not run yet` sentinel":
        val rep = Test262Report.full_corpus_today()
        expect(rep.total() == 0).to_be_true()
        expect(rep.pass_rate_pct() == 0).to_be_true()
        expect(rep.subset == "test262-full").to_be_true()

# =========================================================================
# Test Group 5: Known-crash list
# =========================================================================

describe "Chromium M9 js_audit_known_crashes":
    """The `#3` acceptance criterion — "things V3 apps will hit and
    crash on" — rendered as an enumerable list."""

    it "is non-empty":
        val crashes = js_audit_known_crashes()
        expect(crashes.len() > 0).to_be_true()

    it "covers at least eight categories":
        # Anything shorter means we're hiding known gaps.
        expect(js_audit_crash_count() >= 8).to_be_true()

    it "every entry has a non-empty id":
        val crashes = js_audit_known_crashes()
        var ok = true
        for c in crashes:
            if c.id.len() == 0:
                ok = false
        expect(ok).to_be_true()

    it "every entry has a severity tag":
        val crashes = js_audit_known_crashes()
        var ok = true
        for c in crashes:
            val s = c.severity
            val valid = (s == "crash") || (s == "wrong-result") || (s == "unsupported")
            if valid == false:
                ok = false
        expect(ok).to_be_true()

    it "mentions the JIT backend gap":
        val crashes = js_audit_known_crashes()
        var found = false
        for c in crashes:
            if c.id == "JIT_BACKEND_DISABLED":
                found = true
        expect(found).to_be_true()

    it "mentions the test262 wiring gap":
        val crashes = js_audit_known_crashes()
        var found = false
        for c in crashes:
            if c.id == "TEST262_NOT_WIRED":
                found = true
        expect(found).to_be_true()
