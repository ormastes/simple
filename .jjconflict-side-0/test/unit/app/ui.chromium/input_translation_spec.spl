# Feature: Chromium Shell Input Translation (V3, Row 5 — M2)
# Category: UI Components
# Status: Implemented
#
# Compile-only smoke spec. Verifies the chromium shell's event bridge
# translates a handful of raw winit events into the right UIEvent and
# DOM `wheel` event values. No winit / FFI / compositor bring-up — the
# bridge functions are pure translators.

use app.ui.chromium.event_bridge.{
    ChromiumEventBridge,
    translate_key_event,
    translate_mouse_event,
    translate_wheel_ui_event,
    translate_wheel_dom_event
}
use common.ui.widget.{UIEvent}

# =========================================================================
# Test Group 1: Stateless key / mouse translation
# =========================================================================

describe "Chromium Event Bridge — stateless translation":

    it "maps escape to NormalMode":
        val ev = translate_key_event(27, 0)
        match ev:
            UIEvent.NormalMode =>
                expect(true).to_be_true()
            _ =>
                expect(false).to_be_true()

    it "maps Ctrl+Q to Quit via modifier bitmask":
        val ev = translate_key_event(113, 2)
        match ev:
            UIEvent.Quit =>
                expect(true).to_be_true()
            _ =>
                expect(false).to_be_true()

    it "maps Shift+Tab to FocusPrev":
        val ev = translate_key_event(9, 1)
        match ev:
            UIEvent.FocusPrev =>
                expect(true).to_be_true()
            _ =>
                expect(false).to_be_true()

    it "maps mouse press(button=0) to TouchPress":
        val ev = translate_mouse_event(120, 240, 0, "press")
        match ev:
            UIEvent.TouchPress(x, y) =>
                expect(x == 120).to_be_true()
                expect(y == 240).to_be_true()
            _ =>
                expect(false).to_be_true()

    it "maps positive wheel delta to FocusNext":
        val ev = translate_wheel_ui_event(3)
        match ev:
            UIEvent.FocusNext =>
                expect(true).to_be_true()
            _ =>
                expect(false).to_be_true()

    it "produces a DOM wheel event with type 'wheel'":
        val dom = translate_wheel_dom_event(42, 1000)
        expect(dom.type_name == "wheel").to_be_true()
        expect(dom.target_id == 42).to_be_true()

# =========================================================================
# Test Group 2: Modifier-state bridge
# =========================================================================

describe "Chromium Event Bridge — modifier round-trip":

    it "round-trips a Shift press through the modifier mask":
        var bridge = ChromiumEventBridge.new()
        bridge.update_modifier(16, true)
        expect(bridge.shift_down).to_be_true()
        expect(bridge.modifiers_mask() == 1).to_be_true()
        bridge.update_modifier(16, false)
        expect(not bridge.shift_down).to_be_true()
        expect(bridge.modifiers_mask() == 0).to_be_true()

    it "tracks Ctrl then produces Ctrl+C Quit on release edge":
        var bridge = ChromiumEventBridge.new()
        bridge.update_modifier(17, true)
        expect(bridge.ctrl_down).to_be_true()
        val result = bridge.on_key(99, true)
        match result:
            UIEvent.Quit =>
                expect(true).to_be_true()
            _ =>
                expect(false).to_be_true()
