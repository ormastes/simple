        "t32_dialog_click",
        "t32_error_check",
        "t32_resources_list",
        "t32_resource_read"
    ]

# Tools that are ONLY in full (not cold) — the ones that were unreachable
# when the default was "cold"
fn full_only_tools() -> [text]:
    [
        "t32_session_open",
        "t32_session_resume",
        "t32_session_close",
        "t32_core_list",
        "t32_core_select",
