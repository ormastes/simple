# # T32 MCP Dispatch Wiring Tests
#
# **Bug:** #6 — default frontend changed from `cold` to `full`
# **Category:** Integration / Module Test
# **Difficulty:** 2/5
# **Status:** Implemented
#
# ## Overview
#
# Self-contained SSpec tests verifying T32 MCP tool dispatch wiring:
# - All 36 tool names are recognized by the full dispatch
# - Cold frontend only handles a 13-tool subset
# - Tool name detection works for both compact and spaced JSON
# - JSON-RPC method routing covers all protocol methods
#
# No imports from t32_mcp.* or t32_lsp_mcp.* — all helpers are inlined.

use std.sspec.*

# ---------------------------------------------------------------------------
# Inline JSON helpers
# ---------------------------------------------------------------------------

fn Q() -> text:
    val q = "\""
    q

fn LB() -> text:
    "{"

fn RB() -> text:
    "}"

fn SB_L() -> text:
    "["

fn SB_R() -> text:
    "]"

fn js(value: text) -> text:
    Q() + escape_json(value) + Q()

fn jp(key: text, value: text) -> text:
    Q() + key + Q() + ":" + value

fn jo1(pair: text) -> text:
    LB() + pair + RB()

fn jo2(p1: text, p2: text) -> text:
    LB() + p1 + "," + p2 + RB()

fn jo3(p1: text, p2: text, p3: text) -> text:
    LB() + p1 + "," + p2 + "," + p3 + RB()

fn escape_json(s: text) -> text:
    var out = ""
    var i = 0
    while i < s.len():
        val ch = s.substring(i, i + 1)
        if ch == "\\":
            out = out + "\\\\"
        elif ch == Q():
            out = out + "\\" + Q()
        elif ch == "\n":
            out = out + "\\n"
        elif ch == "\t":
            out = out + "\\t"
        else:
            out = out + ch
        i = i + 1
    out

# ---------------------------------------------------------------------------
# Build a minimal JSON-RPC tools/call request for a given tool name
# ---------------------------------------------------------------------------

fn make_tools_call(tool_name: text) -> text:
    val id_pair = jp("id", js("test-1"))
    val jsonrpc_pair = jp("jsonrpc", js("2.0"))
    val method_pair = jp("method", js("tools/call"))
    val name_pair = jp("name", js(tool_name))
    val args_pair = jp("arguments", LB() + RB())
    val params = jo2(name_pair, args_pair)
    val params_pair = jp("params", params)
    LB() + jsonrpc_pair + "," + method_pair + "," + id_pair + "," + params_pair + RB()

# Build a minimal JSON-RPC request for an arbitrary method (no params)
fn make_method_request(method: text) -> text:
    val id_pair = jp("id", js("test-1"))
    val jsonrpc_pair = jp("jsonrpc", js("2.0"))
    val method_pair = jp("method", js(method))
    LB() + jsonrpc_pair + "," + method_pair + "," + id_pair + RB()

# ---------------------------------------------------------------------------
# Tool name detection — mirrors t32_detect_tool_name logic
# Checks for both "name":"tool" (compact) and "name": "tool" (spaced)
# ---------------------------------------------------------------------------

fn detect_tool_name(msg: text) -> text:
    val COLD_DETECT: [text] = [
        "t32_sessions_list",
        "t32_job_list",
        "t32_cmm_commands",
        "t32_field_get",
        "t32_field_set",
        "t32_history_tail",
        "t32_dialog_parse",
        "t32_dialog_get",
        "t32_dialog_set",
        "t32_dialog_click",
        "t32_error_check",
        "t32_resources_list",
        "t32_resource_read"
    ]
    for name in COLD_DETECT:
        val compact = Q() + "name" + Q() + ":" + Q() + name + Q()
        val spaced = Q() + "name" + Q() + ": " + Q() + name + Q()
        if msg.contains(compact) or msg.contains(spaced):
            return name
    # Fallback: scan for any "name":"<value>" pattern
    val marker = Q() + "name" + Q() + ":"
    val idx = msg.index_of(marker)
    if idx >= 0:
        val after = msg.substring(idx + marker.len(), msg.len())
        val trimmed = after.trim_start()
        if trimmed.len() > 0 and trimmed.substring(0, 1) == Q():
            val rest = trimmed.substring(1, trimmed.len())
            val end_q = rest.index_of(Q())
            if end_q >= 0:
                return rest.substring(0, end_q)
    ""

