# MCP T32 Implementation Fixes (F5) spec — dict field state, connection retry,
# SDN catalog errors, timeout parameters

# =============================================================================
# Inlined helpers — Dict-based field state
# =============================================================================

class FieldEntry:
    key: text
    value: text

class FieldStore:
    entries: [FieldEntry]

fn fs_new() -> FieldStore:
    FieldStore(entries: [])

fn fs_compound_key(session_id: text, field_key: text) -> text:
    session_id + ":" + field_key

fn fs_find_index(store: FieldStore, compound: text) -> i64:
    var i = 0
    for entry in store.entries:
        if entry.key == compound:
            return i
        i = i + 1
    -1

fn fs_set(store: FieldStore, session_id: text, field_key: text, value: text) -> FieldStore:
    val compound = fs_compound_key(session_id, field_key)
    val idx = fs_find_index(store, compound)
    var new_entries: [FieldEntry] = []
    if idx >= 0:
        var i = 0
        for entry in store.entries:
            if i == idx:
                new_entries.push(FieldEntry(key: compound, value: value))
            else:
                new_entries.push(entry)
            i = i + 1
    else:
        for entry in store.entries:
            new_entries.push(entry)
        new_entries.push(FieldEntry(key: compound, value: value))
    FieldStore(entries: new_entries)

fn fs_get(store: FieldStore, session_id: text, field_key: text) -> text:
    val compound = fs_compound_key(session_id, field_key)
    for entry in store.entries:
        if entry.key == compound:
            return entry.value
    ""

fn fs_delete(store: FieldStore, session_id: text, field_key: text) -> FieldStore:
    val compound = fs_compound_key(session_id, field_key)
    var new_entries: [FieldEntry] = []
    for entry in store.entries:
        if entry.key != compound:
            new_entries.push(entry)
    FieldStore(entries: new_entries)

fn fs_count(store: FieldStore) -> i64:
    store.entries.len()

# Field alias resolution (common T32 register short names)
fn resolve_field_alias(alias: text) -> text:
    val a = alias.to_lower()
    if a == "pc":
        return "register.pc"
    if a == "sp":
        return "register.sp"
    if a == "lr":
        return "register.lr"
    if a == "r0":
        return "register.r0"
    if a == "cpsr":
        return "register.cpsr"
    if a == "fp":
        return "register.fp"
    alias

# =============================================================================
# Inlined helpers — Connection retry logic
# =============================================================================

class ConnectAttempt:
    attempt_number: i64
    succeeded: bool
    error_msg: text

class ConnectResult:
    connected: bool
    total_attempts: i64
    error_msg: text
    session_id: text

fn retry_backoff_ms(attempt: i64) -> i64:
    # Exponential backoff: 1s, 2s, 4s
    if attempt == 1:
        return 1000
    if attempt == 2:
        return 2000
    if attempt == 3:
        return 4000
    1000

fn retry_connect(host: text, port: i64, fail_count: i64) -> ConnectResult:
    # Simulates connection with first `fail_count` attempts failing
    val max_attempts = 3
    var attempt = 0
    while attempt < max_attempts:
        attempt = attempt + 1
        if attempt > fail_count:
            return ConnectResult(
                connected: true,
                total_attempts: attempt,
                error_msg: "",
                session_id: "session_" + str(attempt)
            )
    ConnectResult(
        connected: false,
        total_attempts: max_attempts,
        error_msg: "T4200: Connection to {host}:{port} failed after {max_attempts} attempts",
        session_id: ""
    )

fn retry_connect_with_log(host: text, port: i64, fail_count: i64) -> [ConnectAttempt]:
    # Returns all attempts for inspection
    val max_attempts = 3
    var attempts: [ConnectAttempt] = []
    var attempt = 0
    while attempt < max_attempts:
        attempt = attempt + 1
        if attempt > fail_count:
            attempts.push(ConnectAttempt(
                attempt_number: attempt,
                succeeded: true,
                error_msg: ""
            ))
            return attempts
        else:
            attempts.push(ConnectAttempt(
                attempt_number: attempt,
                succeeded: false,
                error_msg: "ECONNREFUSED {host}:{port}"
            ))
    attempts

# =============================================================================
# Inlined helpers — SDN catalog parsing
# =============================================================================

class CatalogEntry:
    name: text
    description: text

class CatalogResult:
    entries: [CatalogEntry]
    error_msg: text
    has_error: bool

fn sdn_parse_line(line: text) -> CatalogEntry:
    # Parse "name: description" format
    var colon_pos = -1
    var i = 0
    for ch in line:
        if ch == ":":
            colon_pos = i
            return CatalogEntry(
                name: sdn_substr(line, 0, colon_pos).trim(),
                description: sdn_substr(line, colon_pos + 1, line.len()).trim()
            )
        i = i + 1
    CatalogEntry(name: "", description: "")

fn sdn_substr(s: text, start: i64, end: i64) -> text:
    var buf: [text] = []
    var i = 0
    for ch in s:
        if i >= start and i < end:
            buf.push(ch)
        i = i + 1
    buf.join("")

fn sdn_trim_text(s: text) -> text:
    s.trim()

fn sdn_parse_catalog(content: text, file_path: text) -> CatalogResult:
    if content == "":
        return CatalogResult(
            entries: [],
            error_msg: "SDN catalog file is empty: {file_path}",
            has_error: true
        )
    var entries: [CatalogEntry] = []
    var errors: [text] = []
    val lines = content.split("\n")
    for line in lines:
        val trimmed = line.trim()
        if trimmed == "":
            continue
        if trimmed.starts_with("#"):
            continue
        val entry = sdn_parse_line(trimmed)
        if entry.name == "":
            errors.push("Malformed line: {trimmed}")
        else:
            entries.push(entry)
    if errors.len() > 0:
        return CatalogResult(
            entries: entries,
            error_msg: "SDN parse errors in {file_path}: " + errors.join("; "),
            has_error: true
        )
    CatalogResult(entries: entries, error_msg: "", has_error: false)

fn sdn_parse_missing_file(file_path: text) -> CatalogResult:
    CatalogResult(
        entries: [],
        error_msg: "SDN catalog file not found: {file_path}",
        has_error: true
    )

# =============================================================================
# Inlined helpers — Timeout parameters
# =============================================================================

class TimeoutConfig:
    connect_timeout_ms: i64
    command_timeout_ms: i64
    practice_wait_timeout_ms: i64

fn default_timeout_config() -> TimeoutConfig:
    TimeoutConfig(
        connect_timeout_ms: 5000,
        command_timeout_ms: 5000,
        practice_wait_timeout_ms: 30000
    )

fn resolve_timeout(custom_timeout_ms: i64, default_ms: i64) -> i64:
    if custom_timeout_ms < 0:
        return -1  # signal: rejected
    if custom_timeout_ms == 0:
        return 0  # no timeout
    custom_timeout_ms

fn validate_timeout_ms(timeout_ms: i64) -> text:
    if timeout_ms < 0:
        return "T4300: Invalid timeout_ms: {timeout_ms}. Must be >= 0."
    ""

class ToolCallParams:
    tool_name: text
    timeout_ms: i64  # -1 = use default, 0 = no timeout, >0 = custom

fn effective_timeout(params: ToolCallParams, defaults: TimeoutConfig) -> i64:
    if params.timeout_ms < 0:
        # Use tool-specific default
        if params.tool_name == "t32_session_open":
            return defaults.connect_timeout_ms
        if params.tool_name == "t32_cmd_run":
            return defaults.command_timeout_ms
        if params.tool_name == "t32_cmm_run":
            return defaults.practice_wait_timeout_ms
        return defaults.command_timeout_ms
    if params.timeout_ms == 0:
        return 0
    params.timeout_ms

# =============================================================================
# Tests
# =============================================================================

describe "T32 MCP Implementation Fixes (F5)":

    # =========================================================================
    # Test Group 1: Dict-Based Field State (REQ-F5-001)
    # =========================================================================

    context "dict-based field state (REQ-F5-001)":

        it "set field stores value":
            var store = fs_new()
            store = fs_set(store, "s1", "register.pc", "0x08001234")
            expect(fs_count(store)).to_equal(1)

        it "get field retrieves stored value":
            var store = fs_new()
            store = fs_set(store, "s1", "register.pc", "0x08001234")
            val result = fs_get(store, "s1", "register.pc")
            expect(result).to_equal("0x08001234")

        it "get unknown field returns empty string":
            val store = fs_new()
            val result = fs_get(store, "s1", "nonexistent")
            expect(result).to_equal("")

        it "update existing field changes value":
            var store = fs_new()
            store = fs_set(store, "s1", "register.pc", "0x08001234")
            store = fs_set(store, "s1", "register.pc", "0x08001238")
            val result = fs_get(store, "s1", "register.pc")
            expect(result).to_equal("0x08001238")
            expect(fs_count(store)).to_equal(1)

        it "multiple fields stored independently":
            var store = fs_new()
            store = fs_set(store, "s1", "register.pc", "0x08001234")
            store = fs_set(store, "s1", "register.sp", "0x20001000")
            store = fs_set(store, "s1", "register.lr", "0x08000100")
            expect(fs_get(store, "s1", "register.pc")).to_equal("0x08001234")
            expect(fs_get(store, "s1", "register.sp")).to_equal("0x20001000")
            expect(fs_get(store, "s1", "register.lr")).to_equal("0x08000100")
            expect(fs_count(store)).to_equal(3)

        it "field key format uses session_id:field_key":
            val compound = fs_compound_key("sess_42", "register.pc")
            expect(compound).to_equal("sess_42:register.pc")

        it "get is O(1)-class with 100+ entries":
            var store = fs_new()
            var i = 0
            while i < 150:
                store = fs_set(store, "s1", "field_" + str(i), "val_" + str(i))
                i = i + 1
            # Verify first, middle, last entries are accessible
            expect(fs_get(store, "s1", "field_0")).to_equal("val_0")
            expect(fs_get(store, "s1", "field_75")).to_equal("val_75")
            expect(fs_get(store, "s1", "field_149")).to_equal("val_149")
            expect(fs_count(store)).to_equal(150)

        it "delete field removes it":
            var store = fs_new()
            store = fs_set(store, "s1", "register.pc", "0x08001234")
            store = fs_set(store, "s1", "register.sp", "0x20001000")
            store = fs_delete(store, "s1", "register.pc")
            expect(fs_get(store, "s1", "register.pc")).to_equal("")
            expect(fs_get(store, "s1", "register.sp")).to_equal("0x20001000")
            expect(fs_count(store)).to_equal(1)

        it "session-scoped isolation":
            var store = fs_new()
            store = fs_set(store, "session_A", "register.pc", "0xAAAAAAAA")
            store = fs_set(store, "session_B", "register.pc", "0xBBBBBBBB")
            expect(fs_get(store, "session_A", "register.pc")).to_equal("0xAAAAAAAA")
            expect(fs_get(store, "session_B", "register.pc")).to_equal("0xBBBBBBBB")
            expect(fs_count(store)).to_equal(2)

        it "common field aliases resolve correctly for pc":
            expect(resolve_field_alias("pc")).to_equal("register.pc")

        it "common field aliases resolve correctly for sp":
            expect(resolve_field_alias("sp")).to_equal("register.sp")

        it "common field aliases resolve correctly for lr":
            expect(resolve_field_alias("lr")).to_equal("register.lr")

        it "unknown alias passes through unchanged":
            expect(resolve_field_alias("custom_field")).to_equal("custom_field")

        it "alias resolution is case-insensitive":
            expect(resolve_field_alias("PC")).to_equal("register.pc")
            expect(resolve_field_alias("Sp")).to_equal("register.sp")

        it "delete nonexistent field is no-op":
            var store = fs_new()
            store = fs_set(store, "s1", "register.pc", "0x08001234")
            store = fs_delete(store, "s1", "register.sp")
            expect(fs_count(store)).to_equal(1)
            expect(fs_get(store, "s1", "register.pc")).to_equal("0x08001234")

    # =========================================================================
    # Test Group 2: Connection Retry (REQ-F5-002)
    # =========================================================================

    context "connection retry (REQ-F5-002)":

        it "first attempt succeeds - connected":
            val result = retry_connect("localhost", 20000, 0)
            expect(result.connected).to_equal(true)
            expect(result.total_attempts).to_equal(1)
            expect(result.session_id).to_start_with("session_")

        it "first fails second succeeds - connected after retry":
            val result = retry_connect("localhost", 20000, 1)
            expect(result.connected).to_equal(true)
            expect(result.total_attempts).to_equal(2)

        it "all 3 attempts fail - error with attempt count":
            val result = retry_connect("localhost", 20000, 3)
            expect(result.connected).to_equal(false)
            expect(result.total_attempts).to_equal(3)
            expect(result.error_msg).to_contain("3 attempts")

        it "exponential backoff timing 1s 2s 4s":
            val b1 = retry_backoff_ms(1)
            val b2 = retry_backoff_ms(2)
            val b3 = retry_backoff_ms(3)
            expect(b1).to_equal(1000)
            expect(b2).to_equal(2000)
            expect(b3).to_equal(4000)

        it "retry count in error message":
            val result = retry_connect("10.0.0.1", 20000, 5)
            expect(result.error_msg).to_contain("3 attempts")
            expect(result.error_msg).to_start_with("T4200")

        it "backend attempts field in result":
            val result = retry_connect("localhost", 20000, 2)
            expect(result.connected).to_equal(true)
            expect(result.total_attempts).to_equal(3)

        it "connection error includes host:port":
            val result = retry_connect("192.168.1.100", 20001, 10)
            expect(result.error_msg).to_contain("192.168.1.100:20001")

        it "retry does not duplicate sessions":
            val result = retry_connect("localhost", 20000, 1)
            expect(result.connected).to_equal(true)
            # Only one session_id, no duplicates
            expect(result.session_id).to_equal("session_2")

        it "attempt log records all tries":
            val attempts = retry_connect_with_log("localhost", 20000, 2)
            expect(attempts.len()).to_equal(3)
            expect(attempts[0].succeeded).to_equal(false)
            expect(attempts[1].succeeded).to_equal(false)
            expect(attempts[2].succeeded).to_equal(true)

        it "attempt log error messages include host:port":
            val attempts = retry_connect_with_log("myhost", 20005, 1)
            expect(attempts[0].error_msg).to_contain("myhost:20005")
            expect(attempts[0].succeeded).to_equal(false)
            expect(attempts[1].succeeded).to_equal(true)

    # =========================================================================
    # Test Group 3: SDN Catalog Error Handling (REQ-F5-003)
    # =========================================================================

    context "SDN catalog error handling (REQ-F5-003)":

        it "valid SDN parses correctly":
            val content = "flash_stm32: STM32 flash programming\nreset_target: Reset and halt target"
            val result = sdn_parse_catalog(content, "catalog.sdn")
            expect(result.has_error).to_equal(false)
            expect(result.entries.len()).to_equal(2)
            expect(result.entries[0].name).to_equal("flash_stm32")
            expect(result.entries[0].description).to_equal("STM32 flash programming")

        it "missing SDN file returns empty catalog with error":
            val result = sdn_parse_missing_file("/etc/t32/catalog.sdn")
            expect(result.entries.len()).to_equal(0)
            expect(result.has_error).to_equal(true)
            expect(result.error_msg).to_contain("not found")

        it "malformed SDN returns empty catalog with error":
            val content = "this has no colon separator"
            val result = sdn_parse_catalog(content, "bad.sdn")
            expect(result.entries.len()).to_equal(0)
            expect(result.has_error).to_equal(true)
            expect(result.error_msg).to_contain("Malformed")

        it "error message includes file path":
            val result = sdn_parse_missing_file("/opt/trace32/catalog.sdn")
            expect(result.error_msg).to_contain("/opt/trace32/catalog.sdn")

        it "no silent fallback to hardcoded entries":
            # Empty file must return empty entries, not hardcoded defaults
            val result = sdn_parse_catalog("", "empty.sdn")
            expect(result.entries.len()).to_equal(0)
            expect(result.has_error).to_equal(true)
            expect(result.error_msg).to_contain("empty")

        it "partial SDN parse returns valid entries plus error for invalid":
            val content = "good_entry: This is valid\nbad line without separator\nanother_good: Also valid"
            val result = sdn_parse_catalog(content, "mixed.sdn")
            expect(result.entries.len()).to_equal(2)
            expect(result.has_error).to_equal(true)
            expect(result.error_msg).to_contain("Malformed")
            expect(result.entries[0].name).to_equal("good_entry")
            expect(result.entries[1].name).to_equal("another_good")

        it "comments are skipped":
            val content = "# This is a comment\nflash: Flash tool"
            val result = sdn_parse_catalog(content, "commented.sdn")
            expect(result.has_error).to_equal(false)
            expect(result.entries.len()).to_equal(1)
            expect(result.entries[0].name).to_equal("flash")

        it "blank lines are skipped":
            val content = "entry_a: First\n\n\nentry_b: Second"
            val result = sdn_parse_catalog(content, "blanks.sdn")
            expect(result.has_error).to_equal(false)
            expect(result.entries.len()).to_equal(2)

    # =========================================================================
    # Test Group 4: Timeout Parameters (REQ-F5-004)
    # =========================================================================

    context "timeout parameters (REQ-F5-004)":

        it "default connect_timeout_ms is 5000":
            val config = default_timeout_config()
            expect(config.connect_timeout_ms).to_equal(5000)

        it "default command_timeout_ms is 5000":
            val config = default_timeout_config()
            expect(config.command_timeout_ms).to_equal(5000)

        it "default practice_wait_timeout_ms is 30000":
            val config = default_timeout_config()
            expect(config.practice_wait_timeout_ms).to_equal(30000)

        it "custom timeout_ms overrides default":
            val resolved = resolve_timeout(8000, 5000)
            expect(resolved).to_equal(8000)

        it "zero timeout_ms means no timeout":
            val resolved = resolve_timeout(0, 5000)
            expect(resolved).to_equal(0)

        it "negative timeout_ms rejected":
            val err = validate_timeout_ms(-1)
            expect(err).to_start_with("T4300")
            expect(err).to_contain("-1")

        it "effective timeout uses connect default for session_open":
            val params = ToolCallParams(tool_name: "t32_session_open", timeout_ms: -1)
            val defaults = default_timeout_config()
            val timeout = effective_timeout(params, defaults)
            expect(timeout).to_equal(5000)

        it "effective timeout uses practice default for cmm_run":
            val params = ToolCallParams(tool_name: "t32_cmm_run", timeout_ms: -1)
            val defaults = default_timeout_config()
            val timeout = effective_timeout(params, defaults)
            expect(timeout).to_equal(30000)

        it "effective timeout uses command default for cmd_run":
            val params = ToolCallParams(tool_name: "t32_cmd_run", timeout_ms: -1)
            val defaults = default_timeout_config()
            val timeout = effective_timeout(params, defaults)
            expect(timeout).to_equal(5000)

        it "custom timeout overrides tool-specific default":
            val params = ToolCallParams(tool_name: "t32_cmm_run", timeout_ms: 15000)
            val defaults = default_timeout_config()
            val timeout = effective_timeout(params, defaults)
            expect(timeout).to_equal(15000)

        it "zero timeout disables timeout for any tool":
            val params = ToolCallParams(tool_name: "t32_cmd_run", timeout_ms: 0)
            val defaults = default_timeout_config()
            val timeout = effective_timeout(params, defaults)
            expect(timeout).to_equal(0)

        it "positive timeout_ms validation passes":
            val err = validate_timeout_ms(5000)
            expect(err).to_equal("")

        it "zero timeout_ms validation passes":
            val err = validate_timeout_ms(0)
            expect(err).to_equal("")

        it "unknown tool falls back to command_timeout default":
            val params = ToolCallParams(tool_name: "t32_some_new_tool", timeout_ms: -1)
            val defaults = default_timeout_config()
            val timeout = effective_timeout(params, defaults)
            expect(timeout).to_equal(5000)
