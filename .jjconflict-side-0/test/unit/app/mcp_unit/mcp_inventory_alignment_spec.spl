# ============================================================================
# 3. Tool Family Completeness
# ============================================================================

describe "MCP Tool Family Completeness":
    """
    ## Tool Families

    Tools are organized into families. Each family must have all expected members.
    """

    context "when checking debug session family":
        it "has all 19 debug session tools":
            val debug_session_tools = [
                "debug_create_session", "debug_list_sessions",
                "debug_close_session", "debug_set_breakpoint",
                "debug_remove_breakpoint", "debug_continue", "debug_step",
                "debug_get_variables", "debug_stack_trace",
                "debug_evaluate", "debug_set_function_breakpoint",
                "debug_enable_breakpoint", "debug_get_source",
                "debug_watch", "debug_set_variable",
                "debug_set_data_breakpoint",
                "debug_list_data_breakpoints",
                "debug_remove_data_breakpoint", "debug_terminate"
            ]
            expect(debug_session_tools.len()).to_equal(19)

    context "when checking hardware debug family":
        it "has all 6 hardware debug tools":
            val hw_debug_tools = [
                "debug_trace_capture", "debug_coverage_collect",
                "debug_flash_program", "debug_system_reset",
                "debug_practice_script", "debug_openocd_monitor"
            ]
            expect(hw_debug_tools.len()).to_equal(6)

    context "when checking debug log family":
        it "has all 6 debug log tools":
            val log_tools = [
                "debug_log_enable", "debug_log_disable",
                "debug_log_clear", "debug_log_query",
                "debug_log_tree", "debug_log_status"
            ]
            expect(log_tools.len()).to_equal(6)

    context "when checking diagnostic family":
        it "has all 8 diagnostic tools":
            val diag_tools = [
                "simple_read", "simple_check", "simple_symbols",
                "simple_status", "simple_diagnostics", "simple_edit",
                "simple_multi_edit", "simple_run"
            ]
            expect(diag_tools.len()).to_equal(8)

    context "when checking VCS family":
        it "has all 8 VCS tools":
            val vcs_tools = [
                "simple_diff", "simple_log", "simple_squash",
                "simple_new", "simple_commit", "simple_push",
                "simple_rebase", "simple_pull"
            ]
            expect(vcs_tools.len()).to_equal(8)

    context "when checking CLI tools family":
        it "has all 6 CLI tools":
            val cli_tools = [
                "simple_test", "simple_build", "simple_format",
                "simple_lint", "simple_fix", "simple_doc_coverage"
            ]
            expect(cli_tools.len()).to_equal(6)

    context "when checking analysis family":
        it "has all 4 analysis tools":
            val analysis_tools = [
                "simple_dependencies", "simple_api_diff",
                "simple_context", "simple_search"
            ]
            expect(analysis_tools.len()).to_equal(4)

    context "when checking task family":
        it "has all 3 task tools":
            val task_tools = ["task_status", "task_cancel", "task_list"]
            expect(task_tools.len()).to_equal(3)

    context "when checking query family":
        it "has all 3 query tools":
            val query_tools = [
                "simple_ast_query", "simple_sem_query",
                "simple_query_schema"
            ]
            expect(query_tools.len()).to_equal(3)

    context "when checking test daemon family":
        it "has all 4 test daemon tools":
            val daemon_tools = [
                "test_daemon_run", "test_daemon_clean",
                "test_daemon_status", "test_daemon_stop"
            ]
            expect(daemon_tools.len()).to_equal(4)

    context "when checking API family":
        it "has the API tool":
            val api_tools = ["simple_api"]
            expect(api_tools.len()).to_equal(1)

    context "when validating family totals":
        it "all families sum to 78":
            val total = 19 + 6 + 6 + 8 + 8 + 6 + 4 + 3 + 3 + 4 + 1 + 1 + 9
            # 19 debug + 6 hw + 6 log + 8 diag + 8 vcs + 6 cli +
            # 4 analysis + 3 task + 3 query + 4 daemon + 1 api + 9 ui-access = 78
            expect(total).to_equal(78)

# ============================================================================
# 4. Protocol Method Coverage
# ============================================================================

describe "MCP Protocol Method Coverage":
    """
    ## Protocol Methods

    The MCP server handles 15 protocol methods in `start_server()`.
    """

    context "when checking protocol method count":
        it "handles all 15 protocol methods":
            val protocol_methods = [
                "initialize",
                "initialized",
                "notifications/initialized",
                "shutdown",
                "tools/list",
                "tools/call",
                "resources/list",
                "resources/templates/list",
                "resources/read",
                "prompts/list",
                "prompts/get",
                "completion/complete",
                "completions/complete",
                "logging/setLevel",
                "roots/list",
                "ping",
                "notifications/cancelled",
                "notifications/roots/list_changed"
            ]
            # Note: initialized and notifications/initialized share a branch,
            # as do completion/complete and completions/complete,
            # and notifications/cancelled and notifications/roots/list_changed.
            # FAIL-FIRST: 18 entries but expected 15 distinct methods
            expect(protocol_methods.len()).to_equal(15)
