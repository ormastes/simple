describe "AVX2 FP emit_vminps_ymm ymm2 ymm4 ymm6":
    # vminps ymm2, ymm4, ymm6 → [0xC4, 0xE1, 0x5C, 0x5D, 0xD6]
    # byte2: ~vvvv=(15-4)=11,L=1,pp=00 → 11*8+4=92
    # ModRM: mod=11,reg=2,rm=6 → 192+2*8+6=214
    it "byte2 is 0x5C (W=0 ~vvvv=11 L=1 pp=00)":
        val result = emit_vminps_ymm(2, 4, 6)
        expect result[2] == 92

    it "byte4 is ModRM 0xD6 (mod=11 reg=2 rm=6)":
        val result = emit_vminps_ymm(2, 4, 6)
        expect result[4] == 214

# ============================================================================
# VSQRTPS — VEX.256.0F.WIG 51 /r  (2-operand, vvvv=1111)
# emit_vsqrtps_ymm(rd, rm): vvvv=1111 (rn=0 → 15-0=15)
# ============================================================================

describe "AVX2 FP emit_vsqrtps_ymm ymm0 ymm0 golden":
    # vsqrtps ymm0, ymm0 → [0xC4, 0xE1, 0x7C, 0x51, 0xC0]
    # byte2: vvvv=1111(rn=0) → 15*8+4=124
    it "emits 5 bytes":
        val result = emit_vsqrtps_ymm(0, 0)
        expect result.len() == 5

    it "byte0 is 0xC4":
        val result = emit_vsqrtps_ymm(0, 0)
        expect result[0] == 196

    it "byte1 is 0xE1 (~R=1 ~X=1 ~B=1 mmmmm=1)":
        val result = emit_vsqrtps_ymm(0, 0)
        expect result[1] == 225

    it "byte2 is 0x7C (W=0 ~vvvv=1111 L=1 pp=00)":
        val result = emit_vsqrtps_ymm(0, 0)
        expect result[2] == 124

    it "byte3 is opcode 0x51":
        val result = emit_vsqrtps_ymm(0, 0)
        expect result[3] == 81

    it "byte4 is ModRM 0xC0 (mod=11 reg=0 rm=0)":
        val result = emit_vsqrtps_ymm(0, 0)
        expect result[4] == 192

describe "AVX2 FP emit_vsqrtps_ymm ymm3 ymm5":
    # vsqrtps ymm3, ymm5 → [0xC4, 0xE1, 0x7C, 0x51, 0xDD]
    # byte2: vvvv=1111 (rn=0 always) → 124
    # ModRM: mod=11,reg=3,rm=5 → 192+3*8+5=221
    it "byte2 is 0x7C (vvvv=1111 always for vsqrtps)":
        val result = emit_vsqrtps_ymm(3, 5)
        expect result[2] == 124

    it "byte4 is ModRM 0xDD (mod=11 reg=3 rm=5)":
        val result = emit_vsqrtps_ymm(3, 5)
        expect result[4] == 221

# ============================================================================
# VRSQRTPS — VEX.256.0F.WIG 52 /r  (2-operand, vvvv=1111)
# emit_vrsqrtps_ymm(rd, rm): vvvv=1111 (rn=0 → 15-0=15)
# ============================================================================

describe "AVX2 FP emit_vrsqrtps_ymm ymm0 ymm0 golden":
    # vrsqrtps ymm0, ymm0 → [0xC4, 0xE1, 0x7C, 0x52, 0xC0]
    it "emits 5 bytes":
        val result = emit_vrsqrtps_ymm(0, 0)
        expect result.len() == 5

    it "byte0 is 0xC4":
        val result = emit_vrsqrtps_ymm(0, 0)
        expect result[0] == 196

    it "byte2 is 0x7C (W=0 ~vvvv=1111 L=1 pp=00)":
        val result = emit_vrsqrtps_ymm(0, 0)
        expect result[2] == 124

    it "byte3 is opcode 0x52":
        val result = emit_vrsqrtps_ymm(0, 0)
        expect result[3] == 82

    it "byte4 is ModRM 0xC0":
        val result = emit_vrsqrtps_ymm(0, 0)
        expect result[4] == 192

describe "AVX2 FP emit_vrsqrtps_ymm ymm4 ymm6":
    # vrsqrtps ymm4, ymm6 → [0xC4, 0xE1, 0x7C, 0x52, 0xE6]
    # byte2: vvvv=1111 (rn=0 always) → 124
    # ModRM: mod=11,reg=4,rm=6 → 192+4*8+6=230
    it "byte2 is 0x7C (vvvv=1111 always for vrsqrtps)":
        val result = emit_vrsqrtps_ymm(4, 6)
        expect result[2] == 124

    it "byte4 is ModRM 0xE6 (mod=11 reg=4 rm=6)":
        val result = emit_vrsqrtps_ymm(4, 6)
        expect result[4] == 230
