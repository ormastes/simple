describe "AVX2 FP emit_vminps_ymm ymm0 ymm0 ymm0 golden":
    # vminps ymm0, ymm0, ymm0 → [0xC4, 0xE1, 0x7C, 0x5D, 0xC0]
    it "emits 5 bytes":
