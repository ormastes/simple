describe "AVX2 FP emit_vmaxps_ymm ymm1 ymm3 ymm5":
    # vmaxps ymm1, ymm3, ymm5 → [0xC4, 0xE1, 0x64, 0x5F, 0xCD]
    # byte2: ~vvvv=(15-3)=12,L=1,pp=00 → 12*8+4=100
    # ModRM: mod=11,reg=1,rm=5 → 192+1*8+5=205
    it "byte2 is 0x64 (W=0 ~vvvv=12 L=1 pp=00)":
        val result = emit_vmaxps_ymm(1, 3, 5)
        expect result[2] == 100

    it "byte4 is ModRM 0xCD (mod=11 reg=1 rm=5)":
