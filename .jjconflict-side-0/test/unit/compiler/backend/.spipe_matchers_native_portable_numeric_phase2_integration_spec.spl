use std.spec.{describe, it, expect}
use compiler.backend.backend.backend_types.{CodegenTarget}
use compiler.backend.portable_numeric_capabilities.{
    PortableNumericFeatureSelection,
    portable_numeric_preset_for_target,
    portable_numeric_capabilities_for_target,
    portable_numeric_lowering_plan_for_target,
    portable_numeric_default_plan_for_target
}

describe "Native portable numeric phase-2 integration scaffolding":
    it "maps native and host targets onto the current x86_64 portable numeric preset":
        val host_preset = portable_numeric_preset_for_target(CodegenTarget.Host)
        val native_caps = portable_numeric_capabilities_for_target(CodegenTarget.Native)
        val native_plan = portable_numeric_default_plan_for_target(CodegenTarget.Native)

        expect host_preset.name == "linux-x86_64"
        expect host_preset.arch == "x86_64"
        expect native_caps.has_scalar_fp == true
        expect native_caps.has_vector_simd == true
        expect native_caps.requires_runtime_simd_probe == true
        expect native_plan.lowering_modules_csv() == "scalar_fp,vector_simd,scalar_fallback,x86_avx"
        expect native_plan.diagnostics_csv() == "x86_avx_requires_runtime_probe"

    it "keeps RISC-V and scalar-only planning wired through exported helper functions":
        val rv64_plan = portable_numeric_default_plan_for_target(CodegenTarget.Riscv64)
        val rv64_scalar_only = portable_numeric_lowering_plan_for_target(
            CodegenTarget.Riscv64,
            PortableNumericFeatureSelection.scalar_only()
        )
        val rv32_plan = portable_numeric_default_plan_for_target(CodegenTarget.Riscv32)

        expect rv64_plan.capabilities.has_riscv_f == true
        expect rv64_plan.capabilities.has_riscv_d == true
        expect rv64_plan.capabilities.has_riscv_v == false
        expect rv64_plan.lowering_modules_csv() == "scalar_fp,scalar_fallback,riscv_fd"
        expect rv64_plan.diagnostics_csv() == "vector_simd_requested_but_target_lacks_vector_capability"
        expect rv64_scalar_only.lowering_modules_csv() == "scalar_fp,scalar_fallback,riscv_fd"
        expect rv64_scalar_only.diagnostics_csv() == ""
        expect rv32_plan.lowering_modules_csv() == "scalar_fallback"
        expect rv32_plan.diagnostics_csv() == "scalar_fp_requested_but_target_lacks_fp,vector_simd_requested_but_target_lacks_vector_capability"