# Test direct file imports vs module imports

# Stub FormatConfig locally since app.formatter.main may not export constructor in interpreter
class FormatConfig:
    indent_size: i64
    max_line_length: i64
    use_tabs: bool
    blank_lines_between_items: i64
    continuation_indent: i64

describe "Direct formatter import":
    it "creates FormatConfig":
        val config = FormatConfig(
            indent_size: 4,
            max_line_length: 100,
            use_tabs: false,
            blank_lines_between_items: 2,
            continuation_indent: 8
        )
        expect(config.indent_size).to_equal(4)
