# Indexed class mutation — regression spec for bug #28.
#
# Covers the `stack[i].method()` and `obj.field.method()` patterns where
# the receiver is a loaded slot and the method mutates `self`. Without the
# MIR-lowering write-back (mir_lowering_expr.spl::lower_method_call), the
# mutation is silently discarded because the receiver is a value copy.
#
# This spec exercises both the pure-Simple compiler path (once the
# self-hosted binary is rebuilt to include the fix) and the Rust seed
# interpreter (which has related partial fixes #18/#19). Both must agree.

use std.spec

class Counter:
    value: i64

    me inc():
        self.value = self.value + 1

    me add(n: i64):
        self.value = self.value + n


class Holder:
    inner: Counter


fn new_counter(v: i64) -> Counter:
    Counter(value: v)


fn new_holder() -> Holder:
    Holder(inner: new_counter(0))


describe "Indexed class mutation":
    it "stack[i].inc() persists the mutation":
        var stack: [Counter] = []
        stack.push(new_counter(0))
        stack[0].inc()
        stack[0].inc()
        stack[0].inc()
        expect(stack[0].value).to_equal(3)

    it "stack[i].add(n) persists the mutation":
        var stack: [Counter] = []
        stack.push(new_counter(10))
        stack[0].add(5)
        expect(stack[0].value).to_equal(15)

    it "stack[i].add applied twice accumulates":
        var stack: [Counter] = []
        stack.push(new_counter(0))
        stack[0].add(7)
        stack[0].add(8)
        expect(stack[0].value).to_equal(15)

    it "arr[i].push(x) on an inner array persists":
        var outer: [[i64]] = []
        outer.push([])
        outer[0].push(1)
        outer[0].push(2)
        outer[0].push(3)
        expect(outer[0].len()).to_equal(3)

    it "obj.field.inc() persists the mutation":
        var h = new_holder()
        h.inner.inc()
        h.inner.inc()
        expect(h.inner.value).to_equal(2)

    it "second slot in a multi-element stack is unaffected":
        var stack: [Counter] = []
        stack.push(new_counter(100))
        stack.push(new_counter(200))
        stack[0].inc()
        expect(stack[0].value).to_equal(101)
        expect(stack[1].value).to_equal(200)
