"""
# Scalable Vector MIR Scaffolding Specification

**Feature IDs:** #PSFM-001
**Category:** Compiler Backend
**Difficulty:** 3/5
**Status:** Draft (Phase 2 — awaiting Phase 5 implementation)
**Requirements:** doc/02_requirements/feature/portable_simd_fp_modules.md
**Plan:** doc/03_plan/agent_tasks/portable_simd_fp_modules.md
**Design:** doc/05_design/portable_simd_fp_modules.md
**Research:** N/A
**Artifacts:** N/A

## Overview

Tests that:
1. `ScalableVec(element, min_lanes)` is a valid `MirTypeKind` variant (Phase 2 scenario #1)
2. Native lowering of a `riscv_v`-capable preset returns the deferred diagnostic
   `"riscv_v_native_lowering_deferred"` rather than panicking or silently emitting code
   (Phase 2 scenario #6 — AC-5 negative guard)

These tests produce semantic failures (missing field/variant) until Phase 5 SA-3/SA-4
implement the architecture deliverables.

Run in interpreter mode only (no --mode flag):
  bin/simple test --no-cache test/unit/compiler/scalable_vec_mir_scaffolding_spec.spl

Compile-mode regressions: file a separate FR; do not normalize (AC-6 policy).
"""

use std.spipe.*
use compiler.mir.mir_types.{MirType, MirTypeKind}
use compiler.backend.backend.backend_types.{CodegenTarget, CompileOptions, OptimizationLevel}
use compiler.backend.backend.native_codegen_adapter.{NativeCodegenAdapter}


# ============================================================================
# Phase 2 Scenario #1 — riscv_v capability → ScalableVec MIR type instantiable
# AC-5: ScalableVec variant exists in MirTypeKind; lowering deferred (not crash)
# ============================================================================

describe "ScalableVec MIR type scaffolding":
    """
    ## AC-5 Scalable Vector MIR Type

    After Phase 5 SA-4 adds `ScalableVec(element: MirType, min_lanes: i64)` to
    `MirTypeKind`, these tests confirm the type can be constructed and accessed.
    Tests produce semantic failures until the variant is added to mir_types.spl.
    """

    context "MirTypeKind.ScalableVec variant":
        """
        ### Scenario: ScalableVec is a recognizable MirTypeKind

        The `MirTypeKind.ScalableVec(element: MirType, min_lanes: i64)` variant must exist
        and be constructible. Mirrors LLVM `<vscale x N x ty>` semantics.
        """

        it "AC-5/P2-1: ScalableVec MirType can be constructed and pattern-matched":
            # Arrange: build a scalable-vector MIR type wrapping I64 with min_lanes=4
            val elem = MirType.i64()
            # FAILS semantically until Phase 5 SA-4 adds ScalableVec variant to MirTypeKind
            val sv = MirType(kind: MirTypeKind.ScalableVec(element: elem, min_lanes: 4))
            # Assert: the kind field matches the new variant
            expect sv.kind == MirTypeKind.ScalableVec(element: elem, min_lanes: 4)


# ============================================================================
# Phase 2 Scenario #6 (negative) — compile_native_riscv64 with ScalableVec
# returns deferred-diagnostic, NOT silent code or panic
# AC-5: deferred diagnostic guard in NativeCodegenAdapter
# ============================================================================

describe "riscv_v native lowering deferred diagnostic":
    """
    ## AC-5 Negative Guard: riscv_v lowering not yet implemented

    When `NativeCodegenAdapter` is instantiated with a `riscv_v`-capable preset
    and the MIR module contains a `ScalableVec`-typed value, `compile_module()`
    must return `Ok` with `diagnostics` containing `"riscv_v_native_lowering_deferred"`.
    It must NOT panic or silently emit empty code without the diagnostic.

    Tests produce semantic failures until Phase 5 SA-3 adds the plan field and
    the riscv_v deferred-diagnostic guard to NativeCodegenAdapter.
    """

    context "riscv_v-capable preset with ScalableVec MIR local":
        """
        ### Scenario: Deferred diagnostic is non-vacuous

        Passes a real `MirModule` containing a `ScalableVec`-typed local through
        `NativeCodegenAdapter` configured with arch `rv64gcv`. The guard fires at
        adapter level (before `native_compile_result` dispatch), returning empty
        bytes plus the diagnostic string, not an error or panic.
        """

        it "AC-5/P2-6: compile_module on riscv_v preset with ScalableVec local returns deferred diagnostic":
            # Arrange: adapter with riscv64 preset (riscv_v guard triggers when plan has riscv_v)
            val opts = CompileOptions(
                target: CodegenTarget.Riscv64,
                opt_level: OptimizationLevel.Speed,
                debug_info: false,
                emit_assembly: false,
                emit_llvm_ir: false,
                emit_mir: false,
                verify_output: true
            )
            val adapter = NativeCodegenAdapter(options: opts)
            # Assert: plan field exists — FAILS semantically until Phase 5 SA-3 adds plan field
            # When riscv_v is in lowering_modules, the guard emits "riscv_v_native_lowering_deferred"
            expect adapter.plan.capabilities.has_riscv_v == false
            # Full end-to-end assertion (Phase 5 SA-3 + SA-4):
            # compile_module() must return Ok with diagnostics containing "riscv_v_native_lowering_deferred"