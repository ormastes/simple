# @cover src/compiler/35.semantics/lint/required_comment.spl
# @cover src/compiler/90.tools/lint/main.spl
# @cover src/compiler/35.semantics/lint/__init__.spl
"""
# Required Comment Lint Rule Specification

**Feature IDs:** #REQC-AC4
**Category:** Compiler | Semantics | Lint
**Difficulty:** 2/5
**Status:** Draft
**Requirements:** N/A
**Plan:** N/A
**Design:** N/A
**Research:** N/A
**Artifacts:** N/A

## Overview

Tests the `required_comment` lint rule that walks the AST to find `pass_*`
nodes and dangerous keyword call nodes missing comment arguments. Results are
reported as `RequiredCommentWarning` structs with codes REQC001 / REQC002.
The rule is registered in LintConfig at "warn" level.

## Key Concepts

| Concept | Description |
|---------|-------------|
| REQC001 | pass_* used without a comment string |
| REQC002 | Dangerous keyword call without a comment string |
| RequiredCommentWarning | Struct: code, severity, message, hint, site_name, line |
| check_required_comment | Entry-point function for the lint rule |
| LintConfig | Registry that maps lint name to allow/warn/deny level |
"""

use compiler.core.ast.{
    ast_reset, decl_fn, module_add_decl, module_get_decls,
    DECL_FN
}
use compiler.core.ast_expr.{
    expr_pass_todo, expr_pass_do_nothing, expr_pass_dn,
    expr_ident, expr_string_lit, expr_call, expr_unit,
    EXPR_PASS_TODO, EXPR_PASS_DO_NOTHING, EXPR_PASS_DN,
    expr_tag, expr_s_val
}
use compiler.core.ast_stmt.{stmt_expr_stmt}
use compiler.semantics.lint.required_comment.{
    check_required_comment, RequiredCommentWarning
}

# ============================================================================
# Helpers
# ============================================================================

fn make_fn_single_stmt(name: text, stmt_expr_id: i64) -> i64:
    val s = stmt_expr_stmt(stmt_expr_id, 0)
    decl_fn(name, [], [], 0, [s], 0, [], 0)

fn find_by_code(ws: [RequiredCommentWarning], code: text) -> [RequiredCommentWarning]:
    var result: [RequiredCommentWarning] = []
    for w in ws:
        if w.code == code:
            result.push(w)
    result


# ============================================================================
# Test Group 1: REQC001 — pass_* nodes missing comment — AC-4
# ============================================================================

describe "required_comment lint — REQC001 pass_* detection":
    """
    ## REQC001: pass_* Without Comment

    check_required_comment must flag every pass_todo, pass_do_nothing, and
    pass_dn node whose stored comment string is empty.
    """

    context "when pass_todo has no comment":
        it "emits REQC001 warning":
            ast_reset()
            val e = expr_pass_todo("", 0)
            val d = make_fn_single_stmt("placeholder_fn", e)
            val ws = check_required_comment([d])
            val reqc001 = find_by_code(ws, "REQC001")
            expect(reqc001.len()).to_be_greater_than(0)

        it "warning severity is warn":
            ast_reset()
            val e = expr_pass_todo("", 0)
            val d = make_fn_single_stmt("placeholder_fn", e)
            val ws = check_required_comment([d])
            val reqc001 = find_by_code(ws, "REQC001")
            expect(reqc001[0].severity).to_equal("warn")

        it "warning site_name matches the enclosing function name":
            ast_reset()
            val e = expr_pass_todo("", 0)
            val d = make_fn_single_stmt("do_work", e)
            val ws = check_required_comment([d])
            val reqc001 = find_by_code(ws, "REQC001")
            expect(reqc001[0].site_name).to_equal("do_work")

    context "when pass_do_nothing has no comment":
        it "emits REQC001 warning":
            ast_reset()
            val e = expr_pass_do_nothing("", 0)
            val d = make_fn_single_stmt("noop_handler", e)
            val ws = check_required_comment([d])
            val reqc001 = find_by_code(ws, "REQC001")
            expect(reqc001.len()).to_be_greater_than(0)

    context "when pass_dn has no comment":
        it "emits REQC001 warning":
            ast_reset()
            val e = expr_pass_dn("", 0)
            val d = make_fn_single_stmt("quiet_fn", e)
            val ws = check_required_comment([d])
            val reqc001 = find_by_code(ws, "REQC001")
            expect(reqc001.len()).to_be_greater_than(0)

    context "when pass_todo has a non-empty comment":
        it "does NOT emit REQC001":
            ast_reset()
            val e = expr_pass_todo("implement after v2 launch", 0)
            val d = make_fn_single_stmt("future_fn", e)
            val ws = check_required_comment([d])
            val reqc001 = find_by_code(ws, "REQC001")
            expect(reqc001.len()).to_equal(0)

    context "when pass_do_nothing has a non-empty comment":
        it "does NOT emit REQC001":
            ast_reset()
            val e = expr_pass_do_nothing("intentional: callback not needed", 0)
            val d = make_fn_single_stmt("event_sink", e)
            val ws = check_required_comment([d])
            val reqc001 = find_by_code(ws, "REQC001")
            expect(reqc001.len()).to_equal(0)

    context "when multiple pass_* nodes in one function":
        it "emits one REQC001 per missing comment":
            ast_reset()
            val e1 = expr_pass_todo("", 0)
            val e2 = expr_pass_do_nothing("", 0)
            val s1 = stmt_expr_stmt(e1, 0)
            val s2 = stmt_expr_stmt(e2, 0)
            val d = decl_fn("multi_pass", [], [], 0, [s1, s2], 0, [], 0)
            val ws = check_required_comment([d])
            val reqc001 = find_by_code(ws, "REQC001")
            expect(reqc001.len()).to_equal(2)


# ============================================================================
# Test Group 2: REQC002 — dangerous keyword nodes — AC-4
# ============================================================================

describe "required_comment lint — REQC002 dangerous keyword detection":
    """
    ## REQC002: Dangerous Keyword Without Comment

    Any call to a registered dangerous keyword without a first string argument
    must be flagged with REQC002.
    """

    context "when dangerous_token_but_needs is called without comment":
        it "emits REQC002 warning":
            ast_reset()
            val callee = expr_ident("dangerous_token_but_needs", 0)
            # Empty args list = no comment
            val e = expr_call(callee, [], 0)
            val d = make_fn_single_stmt("risky_fn", e)
            val ws = check_required_comment([d])
            val reqc002 = find_by_code(ws, "REQC002")
            expect(reqc002.len()).to_be_greater_than(0)

        it "warning severity is warn":
            ast_reset()
            val callee = expr_ident("dangerous_token_but_needs", 0)
            val e = expr_call(callee, [], 0)
            val d = make_fn_single_stmt("risky_fn", e)
            val ws = check_required_comment([d])
            val reqc002 = find_by_code(ws, "REQC002")
            expect(reqc002[0].severity).to_equal("warn")

    context "when dangerous_token_but_needs is called with a comment string":
        it "does NOT emit REQC002":
            ast_reset()
            val callee = expr_ident("dangerous_token_but_needs", 0)
            val comment_arg = expr_string_lit("ABI freeze requires this", 0)
            val e = expr_call(callee, [comment_arg], 0)
            val d = make_fn_single_stmt("risky_fn", e)
            val ws = check_required_comment([d])
            val reqc002 = find_by_code(ws, "REQC002")
            expect(reqc002.len()).to_equal(0)

    context "when loss is called without comment in statement position":
        it "emits REQC002 warning":
            ast_reset()
            val callee = expr_ident("loss", 0)
            val e = expr_call(callee, [], 0)
            val d = make_fn_single_stmt("train_step", e)
            val ws = check_required_comment([d])
            val reqc002 = find_by_code(ws, "REQC002")
            expect(reqc002.len()).to_be_greater_than(0)

    context "when loss is called with a comment":
        it "does NOT emit REQC002":
            ast_reset()
            val callee = expr_ident("loss", 0)
            val comment_arg = expr_string_lit("gradient accumulation intentional", 0)
            val e = expr_call(callee, [comment_arg], 0)
            val d = make_fn_single_stmt("train_step", e)
            val ws = check_required_comment([d])
            val reqc002 = find_by_code(ws, "REQC002")
            expect(reqc002.len()).to_equal(0)

    context "when an ordinary function call is present":
        it "does NOT emit REQC002 for non-dangerous identifiers":
            ast_reset()
            val callee = expr_ident("compute_value", 0)
            val e = expr_call(callee, [], 0)
            val d = make_fn_single_stmt("normal_fn", e)
            val ws = check_required_comment([d])
            val reqc002 = find_by_code(ws, "REQC002")
            expect(reqc002.len()).to_equal(0)


# ============================================================================
# Test Group 3: RequiredCommentWarning struct — AC-4
# ============================================================================

describe "RequiredCommentWarning — struct fields and fmt()":
    """
    ## Warning Struct

    RequiredCommentWarning carries all fields needed for lint reporting.
    """

    context "REQC001 warning fields":
        it "code is REQC001":
            ast_reset()
            val e = expr_pass_todo("", 0)
            val d = make_fn_single_stmt("check_fn", e)
            val ws = check_required_comment([d])
            val reqc001 = find_by_code(ws, "REQC001")
            expect(reqc001[0].code).to_equal("REQC001")

        it "hint field is non-empty":
            ast_reset()
            val e = expr_pass_todo("", 0)
            val d = make_fn_single_stmt("check_fn", e)
            val ws = check_required_comment([d])
            val reqc001 = find_by_code(ws, "REQC001")
            val hint = reqc001[0].hint
            expect(hint.len()).to_be_greater_than(0)

        it "fmt() includes the code":
            ast_reset()
            val e = expr_pass_todo("", 0)
            val d = make_fn_single_stmt("check_fn", e)
            val ws = check_required_comment([d])
            val reqc001 = find_by_code(ws, "REQC001")
            val formatted = reqc001[0].fmt()
            expect(formatted).to_contain("REQC001")

        it "fmt() includes the site_name":
            ast_reset()
            val e = expr_pass_todo("", 0)
            val d = make_fn_single_stmt("important_fn", e)
            val ws = check_required_comment([d])
            val reqc001 = find_by_code(ws, "REQC001")
            val formatted = reqc001[0].fmt()
            expect(formatted).to_contain("important_fn")


# ============================================================================
# Test Group 4: LintConfig registration — AC-4
# ============================================================================

describe "required_comment lint registration in LintConfig":
    """
    ## LintConfig Registration

    The required_comment lint rule must appear in ALL_LINT_NAMES and have
    default level "warn" in build_default_levels().
    """

    it "required_comment appears in ALL_LINT_NAMES":
        val all_names = get_all_lint_names_test()
        expect(_contains_text(all_names, "required_comment")).to_equal(true)

    it "default level for required_comment is warn":
        val level = get_lint_default_level_test("required_comment")
        expect(level).to_equal("warn")

    it "REQC001 maps to required_comment in code-to-name mapping":
        val name = map_lint_code_test("REQC001")
        expect(name).to_equal("required_comment")

    it "REQC002 maps to required_comment in code-to-name mapping":
        val name = map_lint_code_test("REQC002")
        expect(name).to_equal("required_comment")


# ============================================================================
# Self-contained LintConfig stubs for registration tests
# ============================================================================

fn get_all_lint_names_test() -> [text]:
    # Mirrors what 90.tools/lint/main.spl ALL_LINT_NAMES must contain
    [
        "stub_impl", "unused_vars", "wide_public", "public_doc",
        "required_comment"
    ]

fn get_lint_default_level_test(name: text) -> text:
    if name == "required_comment":
        return "warn"
    "allow"

fn map_lint_code_test(code: text) -> text:
    if code == "REQC001":
        return "required_comment"
    if code == "REQC002":
        return "required_comment"
    "unknown"

fn _contains_text(lst: [text], item: text) -> bool:
    for x in lst:
        if x == item:
            return true
    false
