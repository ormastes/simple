use std.spec.*
use std.gc_async_mut.gpu.browser_engine.layout.{
    collapse_margins_signed
}

# ============================================================================
# AC-3: Margin collapse — positive-positive
# ============================================================================

describe "collapse_margins_signed positive-positive":
    it "AC-3: collapses two positive margins to the larger value":
        val result = collapse_margins_signed(20, 10)
        expect(result).to_equal(20)

    it "AC-3: collapses equal positive margins to same value":
        val result = collapse_margins_signed(15, 15)
        expect(result).to_equal(15)

    it "AC-3: collapses zero and positive to positive":
        val result = collapse_margins_signed(0, 30)
        expect(result).to_equal(30)

# ============================================================================
# AC-3: Margin collapse — negative-positive (mixed)
# ============================================================================

describe "collapse_margins_signed negative-positive mixed":
    it "AC-3: mixed margins: max(positives) + min(negatives)":
        # max(10) + min(-5) = 10 + (-5) = 5
        val result = collapse_margins_signed(10, -5)
        expect(result).to_equal(5)

    it "AC-3: large negative with small positive gives negative result":
        # max(2) + min(-20) = 2 + (-20) = -18
        val result = collapse_margins_signed(2, -20)
        expect(result).to_equal(-18)

    it "AC-3: two negatives produce the most-negative value":
        # max(negatives only) = 0; min(-8, -12) = -12 → result = -12
        val result = collapse_margins_signed(-8, -12)
        expect(result).to_equal(-12)

# ============================================================================
# AC-3: Margin collapse — parent-child collapse
# ============================================================================

describe "collapse_margins_signed parent-child collapse":
    it "AC-3: parent-child top margin collapses when no border/padding":
        # Simulated: parent margin-top=10, child margin-top=20 → 20
        val result = collapse_margins_signed(10, 20)
        expect(result).to_equal(20)

    it "AC-3: parent-child bottom margin collapses symmetrically":
        val result = collapse_margins_signed(16, 8)
        expect(result).to_equal(16)
