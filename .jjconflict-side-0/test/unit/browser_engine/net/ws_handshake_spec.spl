# @cover src/lib/gc_async_mut/gpu/browser_engine/net/ws_handshake.spl 80%

use std.spipe.*
use std.gc_async_mut.gpu.browser_engine.net.ws_crypto.{compute_accept_key}
use std.gc_async_mut.gpu.browser_engine.net.ws_handshake.{validate_handshake_response}

fn ws_test_response(status_line: text, key: text) -> text:
    val accept = compute_accept_key(key)
    status_line + "\r\n" +
        "Upgrade: websocket\r\n" +
        "Connection: Upgrade\r\n" +
        "Sec-WebSocket-Accept: {accept}\r\n" +
        "\r\n"

describe "WebSocket handshake response validation":
    it "accepts a valid 101 upgrade response":
        val key = "dGhlIHNhbXBsZSBub25jZQ=="
        val result = validate_handshake_response(
            ws_test_response("HTTP/1.1 101 Switching Protocols", key),
            key,
            []
        )
        expect(result.is_ok()).to_equal(true)

    it "rejects non-101 status lines even when the body contains 101":
        val key = "dGhlIHNhbXBsZSBub25jZQ=="
        val accept = compute_accept_key(key)
        val raw = "HTTP/1.1 200 OK\r\n" +
            "Upgrade: websocket\r\n" +
            "Connection: Upgrade\r\n" +
            "Sec-WebSocket-Accept: {accept}\r\n" +
            "\r\n" +
            "body mentions 101"
        val result = validate_handshake_response(raw, key, [])
        expect(result.is_ok()).to_equal(false)

    it "rejects malformed status lines with a 101 token":
        val key = "dGhlIHNhbXBsZSBub25jZQ=="
        val result = validate_handshake_response(
            ws_test_response("NOTHTTP 101 Switching Protocols", key),
            key,
            []
        )
        expect(result.is_ok()).to_equal(false)
