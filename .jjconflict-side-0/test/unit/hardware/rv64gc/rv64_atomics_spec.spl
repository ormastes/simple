"""
# RV64 Atomics Unit Tests

**Feature IDs:** #RV64-ATOMICS-001
**Category:** Hardware
**Difficulty:** 3/5
**Status:** Draft

## Overview

Unit tests for RV64A extension: LR/SC pairs and AMO operations.
"""

# tag: only-compiled

import std.spec

use hardware.rv64gc.ext.rv64_atomics.{amo_execute, ReservationSet64, AmoOp}

class _ReservationSet:
    valid: bool
    addr: i64

    fn check(addr: i64) -> bool:
        self.valid and self.addr == addr

    me reserve(addr: i64):
        self.valid = true
        self.addr = addr

    me clear():
        self.valid = false

fn _create_rs() -> _ReservationSet:
    _ReservationSet(valid: false, addr: 0)

describe "LR.D / SC.D":
    """
    ## Load-Reserved / Store-Conditional (64-bit)
    """

    it "LR.D/SC.D success: reserve then conditional store succeeds":
        var rs = _create_rs()
        rs.reserve(0x80001000)
        expect(rs.check(0x80001000)).to_equal(true)

    it "SC.D fails after intervening store (reservation cleared)":
        var rs = _create_rs()
        rs.reserve(0x80001000)
        rs.clear()
        expect(rs.check(0x80001000)).to_equal(false)

    it "SC.D fails on wrong address":
        var rs = _create_rs()
        rs.reserve(0x80001000)
        expect(rs.check(0x80002000)).to_equal(false)

describe "AMO.D Operations":
    """
    ## Atomic Memory Operations (64-bit)

    Each AMO atomically loads a value, applies an operation, and stores the result.
    Returns the original value.
    """

    it "AMOADD.D: adds value":
        val result = amo_execute(AmoOp.Add, 100, 50)
        expect(result.old_value).to_equal(100)
        expect(result.new_value).to_equal(150)

    it "AMOSWAP.D: swaps value":
        val result = amo_execute(AmoOp.Swap, 100, 200)
        expect(result.old_value).to_equal(100)
        expect(result.new_value).to_equal(200)

    it "AMOAND.D: bitwise AND":
        val result = amo_execute(AmoOp.And, 0xFF, 0x0F)
        expect(result.old_value).to_equal(0xFF)
        expect(result.new_value).to_equal(0x0F)

    it "AMOOR.D: bitwise OR":
        val result = amo_execute(AmoOp.Or, 0xF0, 0x0F)
        expect(result.old_value).to_equal(0xF0)
        expect(result.new_value).to_equal(0xFF)

    it "AMOXOR.D: bitwise XOR":
        val result = amo_execute(AmoOp.Xor, 0xFF, 0x0F)
        expect(result.old_value).to_equal(0xFF)
        expect(result.new_value).to_equal(0xF0)

    it "AMOMAX.D: signed maximum":
        val result = amo_execute(AmoOp.Max, -10, 5)
        expect(result.old_value).to_equal(-10)
        expect(result.new_value).to_equal(5)

    it "AMOMAXU.D: unsigned maximum":
        val result = amo_execute(AmoOp.Maxu, 5, 0xFFFFFFFFFFFFFFFF)
        expect(result.old_value).to_equal(5)
        expect(result.new_value).to_equal(0xFFFFFFFFFFFFFFFF)

    it "AMOMIN.D: signed minimum":
        val result = amo_execute(AmoOp.Min, 10, -5)
        expect(result.old_value).to_equal(10)
        expect(result.new_value).to_equal(-5)

    it "AMOMINU.D: unsigned minimum":
        val result = amo_execute(AmoOp.Minu, 0xFFFFFFFFFFFFFFFF, 5)
        expect(result.old_value).to_equal(0xFFFFFFFFFFFFFFFF)
        expect(result.new_value).to_equal(5)

describe "LR.W / SC.W (32-bit)":
    """
    ## Word-sized Load-Reserved / Store-Conditional
    """

    it "LR.W/SC.W: reserve and check word address":
        var rs = _create_rs()
        rs.reserve(0x80001000)
        expect(rs.check(0x80001000)).to_equal(true)

    it "SC.W fails after clear":
        var rs = _create_rs()
        rs.reserve(0x80001000)
        rs.clear()
        expect(rs.check(0x80001000)).to_equal(false)

describe "AMO.W Operations (32-bit)":
    it "AMOADD.W: 32-bit add":
        val result = amo_execute(AmoOp.Add, 100, 50)
        expect(result.old_value).to_equal(100)
        expect(result.new_value).to_equal(150)

    it "AMOSWAP.W: swap":
        val result = amo_execute(AmoOp.Swap, 100, 200)
        expect(result.new_value).to_equal(200)

    it "AMOAND.W: bitwise AND":
        val result = amo_execute(AmoOp.And, 0xFF, 0x0F)
        expect(result.new_value).to_equal(0x0F)

    it "AMOOR.W: bitwise OR":
        val result = amo_execute(AmoOp.Or, 0xF0, 0x0F)
        expect(result.new_value).to_equal(0xFF)

    it "AMOXOR.W: bitwise XOR":
        val result = amo_execute(AmoOp.Xor, 0xFF, 0x0F)
        expect(result.new_value).to_equal(0xF0)

    it "AMOMAX.W: signed max":
        val result = amo_execute(AmoOp.Max, -10, 5)
        expect(result.new_value).to_equal(5)

    it "AMOMIN.W: signed min":
        val result = amo_execute(AmoOp.Min, 10, -5)
        expect(result.new_value).to_equal(-5)

    it "AMOMAXU.W: unsigned max":
        val result = amo_execute(AmoOp.Maxu, 5, 0xFFFFFFFF)
        expect(result.new_value).to_equal(0xFFFFFFFF)

    it "AMOMINU.W: unsigned min":
        val result = amo_execute(AmoOp.Minu, 0xFFFFFFFF, 5)
        expect(result.new_value).to_equal(5)
