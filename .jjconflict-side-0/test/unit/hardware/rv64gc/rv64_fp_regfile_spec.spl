"""
# RV64 FP Register File Unit Tests

**Feature IDs:** #RV64-FP-REGFILE-001
**Category:** Hardware
**Difficulty:** 2/5
**Status:** Draft

## Overview

Unit tests for 32×64-bit FP register file with NaN-boxing for F extension.
"""

import std.spec

use hardware.rv64gc.core.rv64_fpu_regfile.Rv64FpuRegFile

describe "FP Register File Initialization":
    it "all FP registers initialized to zero":
        val frf = Rv64FpuRegFile.create()
        expect(frf.read(0)).to_equal(0)
        expect(frf.read(31)).to_equal(0)

describe "FP Register Read/Write":
    it "write and read f1":
        var frf = Rv64FpuRegFile.create()
        frf.write(1, 0x3FF0000000000000)
        expect(frf.read(1)).to_equal(0x3FF0000000000000)

    it "write and read f31":
        var frf = Rv64FpuRegFile.create()
        frf.write(31, 0x4000000000000000)
        expect(frf.read(31)).to_equal(0x4000000000000000)

    it "overwrite preserves latest":
        var frf = Rv64FpuRegFile.create()
        frf.write(5, 100)
        frf.write(5, 200)
        expect(frf.read(5)).to_equal(200)

describe "NaN-Boxing":
    """
    ## NaN-Boxing for Single-Precision in Double Registers

    When writing a 32-bit float, upper 32 bits must be all 1s.
    When reading as single-precision, check upper bits are all 1s.
    """

    it "write_single NaN-boxes upper 32 bits":
        var frf = Rv64FpuRegFile.create()
        frf.write_single(1, 0x3F800000)
        val stored = frf.read(1)
        expect(stored).to_equal(0xFFFFFFFF3F800000)

    it "read_single extracts lower 32 bits when NaN-boxed":
        var frf = Rv64FpuRegFile.create()
        frf.write_single(1, 0x3F800000)
        expect(frf.read_single(1)).to_equal(0x3F800000)

    it "read_single returns canonical NaN when not NaN-boxed":
        var frf = Rv64FpuRegFile.create()
        frf.write(1, 0x0000000000000000)
        expect(frf.read_single(1)).to_equal(0x7FC00000)

    it "double-precision values stored directly":
        var frf = Rv64FpuRegFile.create()
        frf.write(1, 0x3FF0000000000000)
        expect(frf.read(1)).to_equal(0x3FF0000000000000)
