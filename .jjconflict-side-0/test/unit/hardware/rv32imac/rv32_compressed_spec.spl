"""
# RV32 Compressed Extension Unit Tests

**Feature IDs:** #RV32-RVC-001
**Category:** Hardware
**Difficulty:** 2/5
**Status:** In Progress

## Overview

Unit tests for RVC 16-to-32 bit instruction decompression.
"""

import std.spec

use hardware.rv32imac.core.rv32_compressed.{is_compressed, decompress_rvc, rvc_reg}
use hardware.rv32imac.core.rv32_decode.{decode_opcode, decode_rd, decode_rs1, decode_imm_i}
use hardware.rv32imac.pkg.rv32_isa_pkg.*

describe "RVC Detection":
    """
    ## Compressed Instruction Detection
    """

    it "detects 16-bit instructions (bits 1:0 != 11)":
        expect(is_compressed(0x0000)).to_equal(true)
        expect(is_compressed(0x0001)).to_equal(true)
        expect(is_compressed(0x0002)).to_equal(true)

    it "detects 32-bit instructions (bits 1:0 == 11)":
        expect(is_compressed(0x0003)).to_equal(false)
        expect(is_compressed(0x00000033)).to_equal(false)

describe "RVC Register Mapping":
    """
    ## Compressed Register to Full Register Mapping
    """

    it "maps 3-bit register 0 to x8":
        expect(rvc_reg(0)).to_equal(8)

    it "maps 3-bit register 7 to x15":
        expect(rvc_reg(7)).to_equal(15)

describe "RVC Quadrant 2 Decompression":
    """
    ## Quadrant 2 Instructions

    Tests C.SLLI, C.LWSP, C.SWSP, C.MV, C.ADD, C.JR, C.JALR.
    """

    it "decompresses C.MV (rd = rs2)":
        """
        C.MV x10, x11: bit12=0, rd=10, rs2=11
        Encoding: 0 | 01010 | 01011 | 10 = 0x852E (approx)
        Should expand to: ADD x10, x0, x11
        """
        # C.MV x1, x2: 1000_00001_00010_10
        val c_mv = 0x8092
        val expanded = decompress_rvc(c_mv)
        # Verify it's a 32-bit instruction
        if (expanded and 0x3) == 0x3:
            expect(decode_opcode(expanded)).to_equal(OP_OP)

describe "RVC Quadrant 1 Decompression":
    """
    ## Quadrant 1 Instructions

    Tests C.ADDI, C.LI, C.LUI, C.NOP.
    """

    it "decompresses C.NOP":
        """
        C.NOP: funct3=0, imm=0, rd=0, quadrant=1
        """
        val c_nop = 0x0001
        val expanded = decompress_rvc(c_nop)
        # Should become ADDI x0, x0, 0
        expect(decode_opcode(expanded)).to_equal(OP_OP_IMM)
        expect(decode_rd(expanded)).to_equal(0)

    it "decompresses C.LI (addi rd, x0, imm)":
        """
        C.LI x10, 5: funct3=010, imm=5, rd=10, q=1
        """
        val c_li = 0x4515  # C.LI x10, 5
        val expanded = decompress_rvc(c_li)
        expect(decode_opcode(expanded)).to_equal(OP_OP_IMM)
        expect(decode_rd(expanded)).to_equal(10)
        expect(decode_rs1(expanded)).to_equal(0)
