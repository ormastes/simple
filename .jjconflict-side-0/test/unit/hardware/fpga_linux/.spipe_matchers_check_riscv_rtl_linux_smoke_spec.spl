use std.spec.*

extern fn rt_file_read_text(path: text) -> text

describe "RISC-V RTL Linux smoke gate script":
    it "keeps RV32 and RV64 as symmetric public lane selectors":
        val script = rt_file_read_text("scripts/check-riscv-rtl-linux-smoke.shs")
        expect (script).contains("--rv32-only")
        expect (script).contains("--rv64-only")
        expect (script).contains("run_lane \"generated_rv32_linux\"")
        expect (script).contains("run_lane \"generated_rv64_linux\"")
        expect script.contains("--generated-rv64-only") == false