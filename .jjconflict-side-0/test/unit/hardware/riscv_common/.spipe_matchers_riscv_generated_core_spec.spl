use std.spec.*

use hardware.riscv_common.pkg.riscv_generated_core_pkg.{RiscvProofLane, GeneratedCoreShellContract}

describe "RISC-V generated core proof lanes":
    it "keeps generated RV32 and RV64 Linux lanes public and Linux-capable":
        expect RiscvProofLane.GeneratedRv32Linux.to_text() == "generated_rv32_linux"
        expect RiscvProofLane.GeneratedRv64Linux.to_text() == "generated_rv64_linux"
        expect RiscvProofLane.GeneratedRv32Linux.requires_linux_boot() == true
        expect RiscvProofLane.GeneratedRv64Linux.is_external_reference() == false

describe "RISC-V generated core shell contracts":
    it "defines RV32 on the Linux fw_jump/OpenSBI proof path":
        val shell = GeneratedCoreShellContract.rv32_linux()
        val metadata = shell.debug_metadata()
        expect shell.xlen_bits == 32
        expect shell.proof_lane == RiscvProofLane.GeneratedRv32Linux
        expect shell.boot.opensbi_fw_jump == true
        expect shell.boot.hartid_register == "a0"
        expect shell.boot.dtb_register == "a1"
        expect (shell.acceptance_markers()).contains("Linux version")
        expect shell.shell_services_summary() == "none"
        expect metadata.schema_version == "riscv_rtl_debuggability_lint/v1"
        expect metadata.lane_id == "rv32"
        expect (metadata.debug_outputs).contains("semi_trigger")
        expect metadata.source_map.len() > 10
        expect (metadata.report_markers).contains("DTB_PROBE_SEEN:")
        expect (metadata.report_markers).contains("FINAL_PC_HEX32:")
        expect metadata.runner_testbenches.len() == 2
        expect metadata.runner_testbenches[0].file_name == "tb_generated_rv32_linux_handoff.vhd"
        expect metadata.runner_testbenches[0].pass_marker == "GENERATED_RV32_LINUX_HANDOFF: PASS"
        expect metadata.runner_testbenches[1].file_name == "tb_generated_rv32_boot_info_real_dtb.vhd"
        expect metadata.runner_testbenches[1].pass_marker == "GENERATED_RV32_BOOT_INFO_REAL_DTB: PASS"

    it "defines RV64 on the Linux fw_jump/OpenSBI proof path":
        val shell = GeneratedCoreShellContract.rv64_linux()
        val metadata = shell.debug_metadata()
        expect shell.xlen_bits == 64
        expect shell.proof_lane == RiscvProofLane.GeneratedRv64Linux
        expect shell.boot.opensbi_fw_jump == true
        expect shell.boot.hartid_register == "a0"
        expect shell.boot.dtb_register == "a1"
        expect (shell.acceptance_markers()).contains("Linux version")
        expect (shell.interrupt_inputs).contains("supervisor_external")
        expect (shell.debug_outputs).contains("semi_trigger")
        expect metadata.lane_id == "rv64"
        expect (metadata.debug_outputs).contains("debug_pc")
        expect (metadata.report_markers).contains("TRAP_EDGE_PC_HEX32")
        expect (metadata.report_markers).contains("PC_LOW32:")
        expect (metadata.report_markers).contains("TRAP_CAUSE_WORD:")
        expect metadata.runner_testbenches.len() == 7
        expect metadata.runner_testbenches[0].file_name == "tb_generated_rv64_linux_handoff.vhd"
        expect metadata.runner_testbenches[0].pass_marker == "GENERATED_RV64_LINUX_HANDOFF: PASS"
        expect metadata.runner_testbenches[2].file_name == "tb_generated_rv64_boot_info_dtb.vhd"
        expect metadata.runner_testbenches[2].pass_marker == "GENERATED_RV64_BOOT_INFO_DTB: PASS"
        expect metadata.runner_testbenches[6].file_name == "tb_generated_rv64_sv39_fault.vhd"
        expect metadata.runner_testbenches[6].pass_marker == "GENERATED_RV64_SV39_FAULT: PASS"