# SimpleOS Smoke Test 2 — Extended logic verification
#
# Tests PCI, init service, FAT32 math, Color packing, VmFlags W^X.
# Run with: src/compiler_rust/target/bootstrap/simple run test/unit/os/smoke_test_2.spl

use os.kernel.types.memory_types.{VmFlags}
use os.kernel.types.capability_types.{CapabilityKind}
use os.kernel.types.fs_types.{FsNodeKind, FileFlags}

print "=== Smoke Test 2 ==="

# --- W^X invariant ---
print "--- W^X enforcement ---"
val urw = VmFlags.user_rw()
if urw.writable and urw.no_execute:
    print "OK: user_rw enforces W^X (writable → no_execute)"
else:
    print "FAIL: user_rw W^X broken"

val urx = VmFlags.user_rx()
if not urx.writable and not urx.no_execute:
    print "OK: user_rx allows execute (not writable)"
else:
    print "FAIL: user_rx broken"

val krw = VmFlags.kernel_rw()
if krw.writable and not krw.no_execute:
    print "OK: kernel_rw (kernel exempt from NX for now)"
else:
    print "FAIL: kernel_rw broken"

# --- CapabilityKind variants ---
print "--- CapabilityKind variants ---"
val cap_fr = CapabilityKind.FileRead(path_prefix: "/home")
val cap_fw = CapabilityKind.FileWrite(path_prefix: "/tmp")
val cap_nc = CapabilityKind.NetConnect(port: 443)
val cap_sr = CapabilityKind.SystemReboot
# If we got here without error, construction works
print "OK: all CapabilityKind variants construct"

# --- FsNodeKind ---
print "--- FsNodeKind ---"
val file = FsNodeKind.File
val dir = FsNodeKind.Directory
val link = FsNodeKind.Symlink
if file != dir:
    print "OK: File != Directory"
else:
    print "FAIL: File == Directory"

# --- FileFlags ---
print "--- FileFlags ---"
val read_flags = FileFlags(read: true, write: false, append: false, create: false, truncate: false, directory: false)
if read_flags.read and not read_flags.write:
    print "OK: read-only flags"
else:
    print "FAIL: read-only flags"

val rw_flags = FileFlags(read: true, write: true, append: false, create: true, truncate: false, directory: false)
if rw_flags.read and rw_flags.write and rw_flags.create:
    print "OK: read-write-create flags"
else:
    print "FAIL: rw flags"

# --- Arithmetic edge cases ---
print "--- Arithmetic ---"
# Test that u64 arithmetic doesn't overflow in page calculations
val big_pfn: u64 = 1048576  # 4GB / 4KB = 1M pages
val big_addr = big_pfn * 4096
if big_addr == 4294967296:
    print "OK: 4GB address = 4294967296"
else:
    print "FAIL: 4GB address = {big_addr}"

# Bit manipulation
val flags: u32 = 0x00000003  # present + writable
val has_present = (flags & 1) == 1
val has_writable = (flags & 2) == 2
if has_present and has_writable:
    print "OK: bitwise AND works for flags"
else:
    print "FAIL: bitwise AND"

val shifted = 1 << 31
if shifted != 0:
    print "OK: left shift 31"
else:
    print "FAIL: left shift 31"

print "=== DONE ==="
