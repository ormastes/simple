use std.spec
use os.kernel.arch.hal.{hal_reset_set_test_mode, hal_reset_requested_for_test}
use os.kernel.ipc.syscall.{_handle_system_reboot}
use os.kernel.types.syscall_types.{SyscallArgs}

"""System reboot syscall reset-facade coverage.

The reboot syscall normally does not return on real QEMU/hardware, so this
spec uses the HAL test latch to prove dispatch without touching the platform
reset register or firmware reset path.
"""

describe "system reboot syscall":
    """Verifies syscall id 16 behavior that can be checked in hosted tests."""

    it "routes reboot requests through the platform reset facade":
        hal_reset_set_test_mode(true)
        val result = _handle_system_reboot(
            SyscallArgs(
                id: 16,
                arg0: 0,
                arg1: 0,
                arg2: 0,
                arg3: 0,
                arg4: 0,
                arg5: 0
            )
        )
        expect(result.value).to_equal(0)
        expect(hal_reset_requested_for_test()).to_equal(true)
        hal_reset_set_test_mode(false)
