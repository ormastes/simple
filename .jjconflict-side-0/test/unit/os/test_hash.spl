fn check(n: text, v: bool):
    if v:
        print "OK: {n}"
    else:
        print "FAIL: {n}"

fn djb2_step(h: i64, c: i64) -> i64:
    h * 33 + c

fn main():
    print "=== Hash ==="
    check("init", djb2_step(5381, 47) == 177620)
    check("step2", djb2_step(177620, 104) == 5861564)
    check("diff", djb2_step(5381, 65) != djb2_step(5381, 66))
    check("zero", djb2_step(0, 0) == 0)
    print "=== DONE ==="
