#![allow(unnamed_duplicate_typed_args)]
# @tag: compositor, engine2d, glass
# @cover src/os/compositor/compositor_engine2d.spl 60%
#
# D2 Phase 2 — Engine2dCompositorBackend native CompositorGlassCapable.
#
# Verifies that `Engine2dCompositorBackend.as_glass_capable()` returns
# the backend itself (no longer nil as in Phase 1) and that each of the
# four glass operations does something visible against a CpuBackend-
# backed Engine2D — proving the path is wired end-to-end through
# Engine2D primitives with NO `rt_gui_*` calls.
#
# All four ops are exercised through the canonical `glass_dispatch.cap_*`
# helpers, matching how production callers reach them.

use std.spec.{describe, context, it, expect}
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use os.compositor.compositor_engine2d.{Engine2dCompositorBackend}
use os.compositor.glass_dispatch.{cap_blend_rect, cap_blur_region, cap_gradient_v, cap_read_pixel}

# ============================================================================
# Helpers
# ============================================================================

fn _make_backend(w: i32, h: i32, fill: u32) -> Engine2dCompositorBackend:
    var engine = Engine2D.create_with_backend(w, h, "cpu")
    engine.clear(fill)
    engine.present()
    Engine2dCompositorBackend.create(engine)

# ============================================================================
# Tests
# ============================================================================

describe "Engine2dCompositorBackend CompositorGlassCapable (D2 Phase 2)":
    """Engine2D path glass dispatch — native, no rt_gui_*."""

    context "as_glass_capable":
        """Backend opts back in to the glass subtrait in Phase 2."""

        it "opts in (returns non-nil, unlike Phase 1)":
            """Phase 1 returned nil; Phase 2 must return self."""
            val backend = _make_backend(16, 16, 0xFF000000)
            val cap = backend.as_glass_capable()
            expect(cap != nil).to_be_true()

    context "blend_rect":

        it "alpha-blends a coloured overlay onto the framebuffer":
            # Blend white at 50% alpha over a black background; the
            # affected pixel should land between black and white (every
            # channel strictly between 0 and 255).
            val backend = _make_backend(8, 8, 0xFF000000)
            cap_blend_rect(backend, 0, 0, 4, 4, 0xFFFFFFFF, 128u8)
            val sample = cap_read_pixel(backend, 1, 1)
            val r = (sample >> 16) & 0xFFu32
            val g = (sample >> 8) & 0xFFu32
            val b = sample & 0xFFu32
            expect(r > 0u32 and r < 255u32).to_be_true()
            expect(g > 0u32 and g < 255u32).to_be_true()
            expect(b > 0u32 and b < 255u32).to_be_true()

        it "leaves pixels outside the rect untouched":
            val backend = _make_backend(8, 8, 0xFF000000)
            cap_blend_rect(backend, 0, 0, 2, 2, 0xFFFFFFFF, 200u8)
            val outside = cap_read_pixel(backend, 7, 7)
            expect(outside == 0xFF000000u32).to_be_true()

    context "gradient_v":

        it "paints a vertical gradient via Engine2D draw_gradient_rect":
            val backend = _make_backend(4, 8, 0xFF808080)
            cap_gradient_v(backend, 0, 0, 4, 8, 0xFF000000, 0xFFFFFFFF)
            val top = cap_read_pixel(backend, 0, 0)
            val bottom = cap_read_pixel(backend, 0, 7)
            val top_r = (top >> 16) & 0xFFu32
            val bot_r = (bottom >> 16) & 0xFFu32
            # Top should be darker than bottom along the gradient axis.
            expect(top_r < bot_r).to_be_true()

    context "blur_region":

        it "averages neighbouring pixels (smooths a hard edge)":
            # Build a 4x4 framebuffer with a hard black/white split at
            # column 2. Blurring across the seam must produce an
            # in-between grey pixel — the proof that the impl is reading
            # AND writing through Engine2D, not just no-oping.
            val backend = _make_backend(4, 4, 0xFF000000)
            backend.engine.draw_rect_filled(2, 0, 2, 4, 0xFFFFFFFF)
            backend.engine.present()
            cap_blur_region(backend, 0, 0, 4, 4, 1u32)
            val seam = cap_read_pixel(backend, 1, 1)
            val seam_r = (seam >> 16) & 0xFFu32
            expect(seam_r > 0u32 and seam_r < 255u32).to_be_true()

    context "read_pixel":

        it "returns the framebuffer colour at (x, y)":
            val backend = _make_backend(4, 4, 0xFF112233)
            val px = cap_read_pixel(backend, 2, 2)
            expect(px == 0xFF112233u32).to_be_true()

        it "returns 0 for out-of-bounds reads":
            val backend = _make_backend(4, 4, 0xFFFFFFFF)
            val oob = cap_read_pixel(backend, 99, 99)
            expect(oob == 0u32).to_be_true()
