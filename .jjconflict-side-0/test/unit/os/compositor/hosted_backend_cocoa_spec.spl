# Hosted Cocoa Backend — compile-only trait coverage spec (Row 3 / Phase C)
#
# Smoke + trait method presence checks for `HostedCocoaBackend`.
# The SFFI bodies are runtime stubs, so all method calls that reach
# into Cocoa are wrapped in `if false: ...` guards — the compiler
# still resolves the signatures but the stubs are never invoked.

use std.spec.{describe, it, expect}
use os.compositor.hosted_backend_cocoa.{HostedCocoaBackend}
use os.compositor.display_backend.{CompositorBackend, CompositorGlassCapable}

describe "HostedCocoaBackend smoke":
    """Compile-only checks that HostedCocoaBackend implements CompositorBackend
    and CompositorGlassCapable. All SFFI-reaching calls are guarded by if false."""

    it "instantiates via the test seam without touching SFFI":
        """Verify new() constructs a backend with the given w/h fields set."""
        val be = HostedCocoaBackend.new(0, 0, 320, 240)
        expect(be.w).to_equal(320)
        expect(be.h).to_equal(240)

    it "exposes CompositorBackend trait methods":
        val be = HostedCocoaBackend.new(0, 0, 100, 50)
        # Width/height are pure accessors and read module state, which
        # defaults to zero on a fresh module load.
        val w = be.width()
        val h = be.height()
        expect(w + h).to_be_greater_than_or_equal(0)

    it "exposes lifecycle methods (resize/pump/free)":
        val be = HostedCocoaBackend.new(0, 0, 64, 64)
        # We don't call resize/pump/free here — the runtime stubs would
        # no-op but we want this spec to stay deterministic on every
        # host. The fact that these symbols compile is the assertion.
        expect(be.w).to_equal(64)
        expect(be.h).to_equal(64)

    it "CompositorBackend drawing methods exist (compile-only)":
        val be = HostedCocoaBackend.new(0, 0, 128, 128)
        if false:
            be.clear(0xFF000000)
            be.fill_rect(0, 0, 10, 10, 0xFFFFFFFF)
            be.draw_text(0, 0, "x", 0xFFFFFFFF, 0xFF000000)
            val ch: u8 = 65
            be.draw_char_8x16(0, 0, ch, 0xFFFFFFFF, 0xFF000000)
            be.put_pixel(0, 0, 0xFF0000FF)
            be.present()
            be.present_rect(0, 0, 64, 64)
        expect(true).to_be_true()

    it "as_glass_capable returns non-none (compile-only)":
        val be = HostedCocoaBackend.new(0, 0, 128, 128)
        if false:
            val gc = be.as_glass_capable()
        expect(true).to_be_true()

    it "CompositorGlassCapable methods exist (compile-only)":
        val be = HostedCocoaBackend.new(0, 0, 128, 128)
        if false:
            val alpha: u8 = 128
            be.blend_rect(0, 0, 64, 64, 0x80FFFFFF, alpha)
            val radius: u32 = 4
            be.blur_region(0, 0, 64, 64, radius)
            be.gradient_v(0, 0, 64, 64, 0xFF000000, 0xFFFFFFFF)
            val _px = be.read_pixel(0, 0)
        expect(true).to_be_true()

    it "lifecycle resize and pump methods exist (compile-only)":
        val be = HostedCocoaBackend.new(0, 0, 64, 64)
        if false:
            val _ok = be.resize(128, 128)
            val _ev = be.pump()
            be.free()
        expect(true).to_be_true()
