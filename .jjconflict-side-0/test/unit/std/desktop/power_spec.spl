# Desktop power monitor API specification

use std.nogc_sync_mut.desktop.power.{PowerState, BatteryInfo}

describe "Desktop Power Monitor API":
    it "creates BatteryInfo struct":
        val info = BatteryInfo(state: PowerState.AC, level: 100, time_remaining_seconds: -1, is_charging: false)
        expect info.level == 100
        expect info.is_charging == false
