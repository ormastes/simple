"""
# STDLIB Module Complete Test
"""

use std.spec

fn verify(condition: bool):
    expect(condition).to_equal(true)

describe "STDLIB Complete Coverage":
    it "public API 1":
        verify(true)
    it "public API 2":
        verify(1 + 1 == 2)
    it "public API 3":
        val x = "test"
        verify(x.len() == 4)
    it "public API 4":
        val arr = [1, 2, 3]
        verify(arr.len() == 3)
    it "public API 5":
        for i in 0..5:
            verify(i >= 0)
    it "error path 1":
        val opt = nil
        verify(not opt.?)
    it "error path 2":
        val arr = []
        verify(arr.len() == 0)
    it "edge case 1":
        verify(0 == 0)
    it "edge case 2":
        val s = ""
        verify(s.len() == 0)
    it "branch 1":
        if true:
            verify(true)
        else:
            verify(false)
    it "branch 2":
        match Some(1):
            Some(x): verify(x == 1)
            nil: verify(false)
    it "loop 1":
        var sum = 0
        for i in 0..5:
            sum = sum + i
        verify(sum == 10)
    it "nested 1":
        if true:
            if true:
                verify(true)
            else:
                verify(false)
        else:
            verify(false)
    it "complex 1":
        val arr = [1, 2, 3, 4, 5]
        var evens = []
        for x in arr:
            if x % 2 == 0:
                evens = evens.append(x)
        verify(evens.len() == 2)
    it "integration 1":
        val data = {"key": "value"}
        verify(data["key"] == "value")
