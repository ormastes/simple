# JIT Hotspot Test: ARM32 (LLVM)

use std.io

extern fn rt_jit_create_for_target(arch: text) -> i64
extern fn rt_jit_backend_name(handle: i64) -> text
extern fn rt_jit_compile_source(handle: i64, source: text) -> text
extern fn rt_jit_call_i64(handle: i64, name: text, arg: i64) -> i64
extern fn rt_jit_cleanup(handle: i64) -> i64

fn main():
    print("=== JIT Hotspot Test: ARM32 (LLVM) ===")

    val h = rt_jit_create_for_target("arm32")
    print("Handle: " + h.to_text())

    if h < 1:
        print("SKIP: arm32 JIT not available (need --features llvm)")
        return

    print("Backend: " + rt_jit_backend_name(h))

    val src = "fn triple(n: i64) -> i64:\n    return n * 3\n"
    val err = rt_jit_compile_source(h, src)
    if err != "":
        print("FAIL: compile error: " + err)
        rt_jit_cleanup(h)
        return

    val result = rt_jit_call_i64(h, "triple", 10)
    val expected: i64 = 30
    if result == expected:
        print("PASS: triple(10) = " + result.to_text())
    else:
        print("FAIL: triple(10) = " + result.to_text() + " expected " + expected.to_text())

    rt_jit_cleanup(h)
    print("DONE")
