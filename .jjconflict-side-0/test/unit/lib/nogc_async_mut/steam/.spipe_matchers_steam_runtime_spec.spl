# @cover src/lib/nogc_async_mut/steam/steam_runtime.spl

use std.spec
use std.nogc_async_mut.steam.steam_runtime.{
    steam_runtime_detect,
    steam_runtime_library_path,
    steam_runtime_rootfs_mount
}

describe "Steam runtime detection":
    it "detect with full soldier evidence returns is_ok=true":
        val info = steam_runtime_detect("steam-runtime abi-x86_64 soldier")
        expect info.is_ok == true
        expect info.generation == "soldier"
        expect info.abi == "x86_64"

    it "detect with sniper generation returns is_ok=true":
        val info = steam_runtime_detect("steam-runtime abi-x86_64 sniper")
        expect info.is_ok == true
        expect info.generation == "sniper"

    it "detect without steam-runtime token returns error":
        val info = steam_runtime_detect("abi-x86_64 soldier")
        expect info.is_ok == false
        expect info.error == "missing-steam-runtime"

    it "detect without abi-x86_64 token returns error":
        val info = steam_runtime_detect("steam-runtime soldier")
        expect info.is_ok == false
        expect info.error == "missing-abi-x86_64"

    it "detect without generation token returns error":
        val info = steam_runtime_detect("steam-runtime abi-x86_64")
        expect info.is_ok == false
        expect info.error == "missing-steam-linux-runtime-generation"

    it "library_path is non-empty for valid info":
        val info = steam_runtime_detect("steam-runtime abi-x86_64 soldier")
        val path = steam_runtime_library_path(info)
        expect (path).contains("soldier")

    it "library_path is empty for invalid info":
        val info = steam_runtime_detect("")
        val path = steam_runtime_library_path(info)
        expect path == ""

    it "rootfs_mount returns non-empty path for valid info":
        val info = steam_runtime_detect("steam-runtime abi-x86_64 soldier")
        val mount = steam_runtime_rootfs_mount(info)
        expect (mount).contains("pressure-vessel")

    it "rootfs_mount returns empty string for invalid info":
        val info = steam_runtime_detect("")
        expect steam_runtime_rootfs_mount(info) == ""