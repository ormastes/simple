# Specification for src/lib/nogc_async_mut/http_server/compression.spl
#
# Verifies the response-body compression dispatcher produces output that
# round-trips back to the original bytes via the typed compress façade,
# and that explicit error reasons (not silent identity fallback) are
# returned for codecs that are not yet wired.

use std.spipe.*
use std.common.compress.{CompressionCodec, decompress_bytes}
use std.http_server.types.{HttpResponseData}
use std.nogc_async_mut.http_server.compression.{
    compress_response_body,
    compress_response_for,
    supported_encodings,
}

fn _make_payload() -> [u8]:
    # 200 bytes of repetitive ASCII so compression produces output that round-
    # trips back to the original. Built directly as [u8] to avoid depending on
    # any text-to-bytes conversion API.
    val unit: [u8] = [
        0x61u8, 0x62u8, 0x63u8, 0x64u8, 0x65u8, 0x66u8, 0x67u8, 0x68u8,
        0x69u8, 0x6au8
    ]
    var bytes: [u8] = []
    var i: i64 = 0
    while i < 20:
        bytes = bytes + unit
        i = i + 1
    bytes

describe "Response-body compression dispatcher":

    it "lists zstd and lz4 as supported encodings":
        val codecs = supported_encodings()
        expect(codecs.len()).to_equal(2)
        expect(codecs[0]).to_equal("zstd")
        expect(codecs[1]).to_equal("lz4")

    it "compresses with zstd and round-trips back to identical bytes":
        val payload = _make_payload()
        val compressed_res = compress_response_body(payload, "zstd")
        expect(compressed_res.is_ok()).to_equal(true)
        val compressed = compressed_res.unwrap()
        expect(compressed.len() > 0).to_equal(true)
        # Auto-detect via magic bytes (zstd magic = 28 b5 2f fd) rather than
        # the codec-hint path so the spec is robust to detect_codec changes.
        val round_trip = decompress_bytes(compressed, nil)
        expect(round_trip.is_ok()).to_equal(true)
        val decoded = round_trip.unwrap()
        expect(decoded.len()).to_equal(payload.len())

    it "compresses with lz4 and round-trips back to identical bytes":
        val payload = _make_payload()
        val compressed_res = compress_response_body(payload, "lz4")
        expect(compressed_res.is_ok()).to_equal(true)
        val compressed = compressed_res.unwrap()
        expect(compressed.len() > 0).to_equal(true)
        # Auto-detect via lz4 frame magic (04 22 4d 18).
        val round_trip = decompress_bytes(compressed, nil)
        expect(round_trip.is_ok()).to_equal(true)
        val decoded = round_trip.unwrap()
        expect(decoded.len()).to_equal(payload.len())

    it "returns Err with a specific reason for gzip (not yet wired)":
        val out = compress_response_body([0x68u8, 0x69u8], "gzip")
        expect(out.is_err()).to_equal(true)

    it "returns Err with a specific reason for br (Phase 3)":
        val out = compress_response_body([0x68u8, 0x69u8], "br")
        expect(out.is_err()).to_equal(true)

    it "returns Err with a specific reason for deflate":
        val out = compress_response_body([0x68u8, 0x69u8], "deflate")
        expect(out.is_err()).to_equal(true)

    it "returns Err for empty encoding (caller should skip)":
        val out = compress_response_body([0x68u8, 0x69u8], "")
        expect(out.is_err()).to_equal(true)

    it "returns Err for identity encoding (caller should skip)":
        val out = compress_response_body([0x68u8, 0x69u8], "identity")
        expect(out.is_err()).to_equal(true)

    it "returns Err for unknown encoding":
        val out = compress_response_body([0x68u8, 0x69u8], "snappy")
        expect(out.is_err()).to_equal(true)

# ----------------------------------------------------------------------------
# compress_response_for — response-level compression decision
# ----------------------------------------------------------------------------

fn _resp_with_text_body(body: text) -> HttpResponseData:
    HttpResponseData(
        status: 200,
        reason: "OK",
        headers: [("Content-Type", "text/plain")],
        body: body,
        body_bytes: [],
        body_file: "",
        body_offset: 0,
        body_length: 0,
        chunked: false
    )

fn _resp_with_byte_body(body_bytes: [u8]) -> HttpResponseData:
    HttpResponseData(
        status: 200,
        reason: "OK",
        headers: [("Content-Type", "application/octet-stream")],
        body: "",
        body_bytes: body_bytes,
        body_file: "",
        body_offset: 0,
        body_length: 0,
        chunked: false
    )

# 300 bytes of repetitive ASCII — above the 256-byte minimum so eligible.
fn _make_eligible_payload() -> [u8]:
    val unit: [u8] = [
        0x61u8, 0x62u8, 0x63u8, 0x64u8, 0x65u8, 0x66u8, 0x67u8, 0x68u8,
        0x69u8, 0x6au8
    ]
    var bytes: [u8] = []
    var i: i64 = 0
    while i < 30:
        bytes = bytes + unit
        i = i + 1
    bytes

fn _has_header(headers: [(text, text)], name: text) -> bool:
    for h in headers:
        if h.0.lower() == name.lower():
            return true
    false

fn _get_header(headers: [(text, text)], name: text) -> text:
    for h in headers:
        if h.0.lower() == name.lower():
            return h.1
    ""

describe "compress_response_for — response-level decision":

    it "compresses with zstd when Accept-Encoding includes zstd":
        val payload = _make_eligible_payload()
        val resp = _resp_with_byte_body(payload)
        val out = compress_response_for(resp, "zstd, lz4")
        expect(out.body_bytes.len() > 0).to_equal(true)
        expect(out.body_bytes.len() < payload.len()).to_equal(true)
        expect(_get_header(out.headers, "content-encoding")).to_equal("zstd")
        expect(out.body).to_equal("")

    it "prefers zstd over lz4 (server preference order)":
        val payload = _make_eligible_payload()
        val resp = _resp_with_byte_body(payload)
        val out = compress_response_for(resp, "lz4, zstd")
        expect(_get_header(out.headers, "content-encoding")).to_equal("zstd")

    it "falls back to lz4 when client does not accept zstd":
        val payload = _make_eligible_payload()
        val resp = _resp_with_byte_body(payload)
        val out = compress_response_for(resp, "lz4")
        expect(_get_header(out.headers, "content-encoding")).to_equal("lz4")

    it "leaves response unchanged when no Accept-Encoding header is supplied":
        val payload = _make_eligible_payload()
        val resp = _resp_with_byte_body(payload)
        val out = compress_response_for(resp, "")
        expect(out.body_bytes.len()).to_equal(payload.len())
        expect(_has_header(out.headers, "content-encoding")).to_equal(false)

    it "leaves response unchanged when client only accepts unsupported codecs":
        val payload = _make_eligible_payload()
        val resp = _resp_with_byte_body(payload)
        # gzip is not in supported_encodings() yet (still Err in dispatcher).
        val out = compress_response_for(resp, "gzip")
        expect(_has_header(out.headers, "content-encoding")).to_equal(false)
        expect(out.body_bytes.len()).to_equal(payload.len())

    it "skips compression when body is too small":
        # 100-byte payload, below the 256-byte minimum.
        val small: [u8] = [
            0x41u8, 0x42u8, 0x43u8, 0x44u8, 0x45u8, 0x46u8, 0x47u8, 0x48u8,
            0x49u8, 0x4Au8
        ]
        var tiny: [u8] = []
        var i: i64 = 0
        while i < 10:
            tiny = tiny + small
            i = i + 1
        val resp = _resp_with_byte_body(tiny)
        val out = compress_response_for(resp, "zstd")
        expect(_has_header(out.headers, "content-encoding")).to_equal(false)
        expect(out.body_bytes.len()).to_equal(tiny.len())

    it "skips compression when chunked":
        var resp = _resp_with_byte_body(_make_eligible_payload())
        resp = HttpResponseData(
            status: resp.status,
            reason: resp.reason,
            headers: resp.headers,
            body: resp.body,
            body_bytes: resp.body_bytes,
            body_file: resp.body_file,
            body_offset: resp.body_offset,
            body_length: resp.body_length,
            chunked: true
        )
        val out = compress_response_for(resp, "zstd")
        expect(_has_header(out.headers, "content-encoding")).to_equal(false)

    it "skips compression when body_file is set (sendfile path)":
        var resp = _resp_with_byte_body(_make_eligible_payload())
        resp = HttpResponseData(
            status: resp.status,
            reason: resp.reason,
            headers: resp.headers,
            body: "",
            body_bytes: [],
            body_file: "/tmp/static.html",
            body_offset: 0,
            body_length: 1024,
            chunked: false
        )
        val out = compress_response_for(resp, "zstd")
        expect(_has_header(out.headers, "content-encoding")).to_equal(false)
        expect(out.body_file).to_equal("/tmp/static.html")

    it "skips compression when Content-Encoding header is already present":
        var resp = _resp_with_byte_body(_make_eligible_payload())
        resp = HttpResponseData(
            status: resp.status,
            reason: resp.reason,
            headers: [("Content-Type", "image/png"), ("Content-Encoding", "gzip")],
            body: resp.body,
            body_bytes: resp.body_bytes,
            body_file: resp.body_file,
            body_offset: resp.body_offset,
            body_length: resp.body_length,
            chunked: resp.chunked
        )
        val out = compress_response_for(resp, "zstd")
        # Encoding stays as the original "gzip" — we don't double-compress.
        expect(_get_header(out.headers, "content-encoding")).to_equal("gzip")

    it "removes any pre-existing Content-Length when compressing":
        var resp = _resp_with_byte_body(_make_eligible_payload())
        resp = HttpResponseData(
            status: resp.status,
            reason: resp.reason,
            headers: [("Content-Type", "text/plain"), ("Content-Length", "300")],
            body: resp.body,
            body_bytes: resp.body_bytes,
            body_file: resp.body_file,
            body_offset: resp.body_offset,
            body_length: resp.body_length,
            chunked: resp.chunked
        )
        val out = compress_response_for(resp, "zstd")
        expect(_has_header(out.headers, "content-length")).to_equal(false)
        expect(_get_header(out.headers, "content-encoding")).to_equal("zstd")
