# Tests for Phase 1 SIMD int bitwise / shift intrinsics.
#
# Feature: doc/08_tracking/feature_request/simd_int_intrinsics_for_crypto_2026-05-01.md
# Scope: 10 ops (xor / and / or / shl / shr) for i32x4 and i32x8.

use std.simd.{Vec4i, Vec8i}
use std.simd.{simd_xor_i32x4, simd_and_i32x4, simd_or_i32x4, simd_shl_i32x4, simd_shr_i32x4}
use std.simd.{simd_xor_i32x8, simd_and_i32x8, simd_or_i32x8, simd_shl_i32x8, simd_shr_i32x8}

describe "std.simd int bitwise/shift (i32x4)":
    describe "simd_xor_i32x4":
        it "self-XOR yields zero":
            val v = Vec4i(x: 0x12345678, y: -1, z: 7, w: 0x7FFFFFFF)
            val r = simd_xor_i32x4(v, v)
            expect r.x == 0
            expect r.y == 0
            expect r.z == 0
            expect r.w == 0

        it "XOR with zero is identity":
            val v = Vec4i(x: 1, y: 2, z: 3, w: 4)
            val z = Vec4i.zero()
            val r = simd_xor_i32x4(v, z)
            expect r.x == 1
            expect r.y == 2
            expect r.z == 3
            expect r.w == 4

    describe "simd_and_i32x4":
        it "AND with all-ones is identity":
            val v = Vec4i(x: 0x12345678, y: 0, z: 7, w: 0x7FFFFFFF)
            val ones = Vec4i.splat(-1)
            val r = simd_and_i32x4(v, ones)
            expect r.x == 0x12345678
            expect r.y == 0
            expect r.z == 7
            expect r.w == 0x7FFFFFFF

        it "AND with zero is zero":
            val v = Vec4i(x: 0x12345678, y: -1, z: 7, w: 0x7FFFFFFF)
            val z = Vec4i.zero()
            val r = simd_and_i32x4(v, z)
            expect r.x == 0
            expect r.y == 0
            expect r.z == 0
            expect r.w == 0

    describe "simd_or_i32x4":
        it "OR with all-ones is all-ones":
            val v = Vec4i(x: 0x12345678, y: 0, z: 7, w: 0x7FFFFFFF)
            val ones = Vec4i.splat(-1)
            val r = simd_or_i32x4(v, ones)
            expect r.x == -1
            expect r.y == -1
            expect r.z == -1
            expect r.w == -1

        it "OR with zero is identity":
            val v = Vec4i(x: 1, y: 2, z: 3, w: 4)
            val z = Vec4i.zero()
            val r = simd_or_i32x4(v, z)
            expect r.x == 1
            expect r.y == 2
            expect r.z == 3
            expect r.w == 4

    describe "simd_shl_i32x4 / simd_shr_i32x4":
        it "shr after shl by 8 round-trips low bits":
            # All values fit in low 24 bits so shl-then-shr is lossless.
            val v = Vec4i(x: 0x000000FF, y: 0x00007F7F, z: 0x000F0F0F, w: 0x00010203)
            val shifted = simd_shl_i32x4(v, 8)
            val back = simd_shr_i32x4(shifted, 8)
            expect back.x == 0x000000FF
            expect back.y == 0x00007F7F
            expect back.z == 0x000F0F0F
            expect back.w == 0x00010203

        it "shr is logical (zero-fill, not arithmetic)":
            # All-ones >> 1 should be 0x7FFFFFFF (logical fill), not -1.
            val v = Vec4i.splat(-1)
            val r = simd_shr_i32x4(v, 1)
            expect r.x == 0x7FFFFFFF
            expect r.y == 0x7FFFFFFF
            expect r.z == 0x7FFFFFFF
            expect r.w == 0x7FFFFFFF

        it "shl by 1 doubles a small positive":
            val v = Vec4i(x: 1, y: 2, z: 3, w: 4)
            val r = simd_shl_i32x4(v, 1)
            expect r.x == 2
            expect r.y == 4
            expect r.z == 6
            expect r.w == 8

describe "std.simd int bitwise/shift (i32x8)":
    describe "simd_xor_i32x8":
        it "self-XOR yields zero":
            val v = Vec8i(e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8)
            val r = simd_xor_i32x8(v, v)
            expect r.e0 == 0
            expect r.e3 == 0
            expect r.e7 == 0

    describe "simd_and_i32x8":
        it "AND with all-ones is identity":
            val v = Vec8i(e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8)
            val ones = Vec8i.splat(-1)
            val r = simd_and_i32x8(v, ones)
            expect r.e0 == 1
            expect r.e3 == 4
            expect r.e7 == 8

    describe "simd_or_i32x8":
        it "OR with all-ones is all-ones":
            val v = Vec8i(e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8)
            val ones = Vec8i.splat(-1)
            val r = simd_or_i32x8(v, ones)
            expect r.e0 == -1
            expect r.e4 == -1
            expect r.e7 == -1

    describe "simd_shl_i32x8 / simd_shr_i32x8":
        it "shr after shl by 8 round-trips low bits":
            val v = Vec8i(e0: 0xFF, e1: 0x7F7F, e2: 0xF0F0F, e3: 0x10203, e4: 0xABCDEF, e5: 0x112233, e6: 0xAA5555, e7: 0x7FFFFF)
            val shifted = simd_shl_i32x8(v, 8)
            val back = simd_shr_i32x8(shifted, 8)
            expect back.e0 == 0xFF
            expect back.e3 == 0x10203
            expect back.e7 == 0x7FFFFF

        it "shl by 1 doubles small positives":
            val v = Vec8i(e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8)
            val r = simd_shl_i32x8(v, 1)
            expect r.e0 == 2
            expect r.e7 == 16