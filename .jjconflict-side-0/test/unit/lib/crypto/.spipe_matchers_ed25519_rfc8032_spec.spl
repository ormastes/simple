# Ed25519 RFC 8032 §7.1 Test Vector Spec
#
# Exercises the Simple wrapper around os.crypto.ed25519 against the canonical
# RFC 8032 §7.1 reference values.  All four practical test vectors are covered:
#   T1   — empty message
#   T2   — single-byte message (0x72)
#   T3   — two-byte message (0xaf 0x82)
#   T_SHA_ABC — 64-byte message (SHA-512 of "abc")
#
# T_1024 (1023-byte message) is intentionally omitted.  Encoding 1023 literal
# bytes would cause severe interpreter slowdown with no additional coverage
# benefit over the four vectors above.
#
# Function signatures (os.crypto.ed25519):
#   ed25519_keypair_from_seed(seed: [u8]) -> ([u8], [u8])   # (seed, pubkey)
#   ed25519_sign(seed: [u8], pubkey: [u8], msg: [u8]) -> [u8]  # 64-byte sig
#   ed25519_verify(pubkey: [u8], msg: [u8], sig: [u8]) -> bool

use std.spipe.*
use os.crypto.ed25519.{ed25519_keypair_from_seed, ed25519_sign, ed25519_verify}

# ============================================================================
# RFC 8032 §7.1 — Test 1 — empty message
# ============================================================================

