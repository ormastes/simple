# ============================================================================
# RFC 8032 §7.1 — Test SHA(abc) — 64-byte message (SHA-512 of "abc")
# ============================================================================

val SEED_SABC: [u8] = [
    0x83u8, 0x3fu8, 0xe6u8, 0x24u8, 0x09u8, 0x23u8, 0x7bu8, 0x9du8,
    0x62u8, 0xecu8, 0x77u8, 0x58u8, 0x75u8, 0x20u8, 0x91u8, 0x1eu8,
