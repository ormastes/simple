# ============================================================================
# Helper: flip one byte at idx (for corruption tests)
# Must be module-level fn — it-block var rebinds do not persist across loops.
# ============================================================================

fn _flip_byte(bytes: [u8], idx: i64) -> [u8]:
    var out: [u8] = []
    var i: i64 = 0
    while i < bytes.len().to_i64():
        if i == idx:
            out.push((bytes[i.to_u64()].to_i64() ^ 0x01).to_u8())
        else:
            out.push(bytes[i.to_u64()])
        i = i + 1
    out

# ============================================================================
# Specs
# ============================================================================

describe "Ed25519 RFC 8032 §7.1 test vectors":

    # -------------------------------------------------------------------------
    # T1 — empty message (canary: deterministic sig must byte-match exactly)
    # -------------------------------------------------------------------------

    it "T1: derived public key matches RFC 8032 §7.1 vector":
        val kp = ed25519_keypair_from_seed(SEED_T1)
        expect kp.1 == PUB_T1

    it "T1: sign(empty) byte-matches RFC 8032 §7.1 expected signature":
        val kp = ed25519_keypair_from_seed(SEED_T1)
        val sig = ed25519_sign(kp.0, kp.1, [])
        expect sig == SIG_T1

    it "T1: signature verifies under the correct public key":
        expect ed25519_verify(PUB_T1, [], SIG_T1) == true

    it "T1: signature is rejected under a different public key":
        expect ed25519_verify(PUB_T2, [], SIG_T1) == false

    it "T1: signature is rejected when the first byte is flipped":
        val bad_sig = _flip_byte(SIG_T1, 0)
        expect ed25519_verify(PUB_T1, [], bad_sig) == false

    # -------------------------------------------------------------------------
    # T2 — single-byte message 0x72
    # -------------------------------------------------------------------------

    it "T2: derived public key matches RFC 8032 §7.1 vector":
        val kp = ed25519_keypair_from_seed(SEED_T2)
        expect kp.1 == PUB_T2

    it "T2: sign(0x72) byte-matches RFC 8032 §7.1 expected signature":
        val kp = ed25519_keypair_from_seed(SEED_T2)
        val sig = ed25519_sign(kp.0, kp.1, MSG_T2)
        expect sig == SIG_T2

    it "T2: signature verifies under the correct public key":
        expect ed25519_verify(PUB_T2, MSG_T2, SIG_T2) == true

    # -------------------------------------------------------------------------
    # T3 — two-byte message 0xaf 0x82
    # -------------------------------------------------------------------------

    it "T3: derived public key matches RFC 8032 §7.1 vector":
        val kp = ed25519_keypair_from_seed(SEED_T3)
        expect kp.1 == PUB_T3

    it "T3: sign(0xaf 0x82) byte-matches RFC 8032 §7.1 expected signature":
        val kp = ed25519_keypair_from_seed(SEED_T3)
        val sig = ed25519_sign(kp.0, kp.1, MSG_T3)
        expect sig == SIG_T3

    it "T3: signature verifies under the correct public key":
        expect ed25519_verify(PUB_T3, MSG_T3, SIG_T3) == true

    # -------------------------------------------------------------------------
    # T_SHA_ABC — 64-byte message (SHA-512("abc"))
    # -------------------------------------------------------------------------

    it "T_SHA_ABC: derived public key matches RFC 8032 §7.1 vector":
        val kp = ed25519_keypair_from_seed(SEED_SABC)
        expect kp.1 == PUB_SABC

    it "T_SHA_ABC: sign byte-matches RFC 8032 §7.1 expected signature":
        val kp = ed25519_keypair_from_seed(SEED_SABC)
        val sig = ed25519_sign(kp.0, kp.1, MSG_SABC)
        expect sig == SIG_SABC

    it "T_SHA_ABC: signature verifies under the correct public key":
        expect ed25519_verify(PUB_SABC, MSG_SABC, SIG_SABC) == true

    it "T_SHA_ABC: modified message is rejected":
        val bad_sig = _flip_byte(SIG_SABC, 32)
        expect ed25519_verify(PUB_SABC, MSG_SABC, bad_sig) == false