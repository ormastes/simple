# PEM RFC 7468 Known-Answer Tests
#
# Tests the pure-Simple PEM encoder/decoder in src/os/crypto/pem.spl.
#
# Coverage:
#   1. SPKI round-trip  — encode then decode recovers original DER + label
#   2. Multi-block      — pem_decode_all on two concatenated PEM blocks
#   3. Malformed: missing END marker
#   4. Malformed: label mismatch (BEGIN CERTIFICATE / END PUBLIC KEY)
#   5. Malformed: garbage in Base64 body
#   6. Empty-body rejection
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. Assertions only fire under compiled/native mode.
# _selftest() is called at module top-level so file-load exercises code.
#
# tag: crypto, pem, rfc7468

use std.spipe.*
use os.crypto.pem.{pem_encode, pem_decode, pem_decode_all, PemBlock}

# ============================================================================
# Test fixtures
# ============================================================================

# 32-byte synthetic DER body: 0x00..0x1f
fn _der_32() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < 32:
        out.push(i.to_u8())
        i = i + 1
    out

# Label for SPKI round-trip
fn _label_spki() -> [u8]:
    var out: [u8] = []
    var s = "PUBLIC KEY"
    var i = 0
    while i < s.len():
        out.push(s.char_code_at(i).to_u8())
        i = i + 1
    out

# Label for secondary block in multi-block test
fn _label_cert() -> [u8]:
    var out: [u8] = []
    var s = "CERTIFICATE"
    var i = 0
    while i < s.len():
        out.push(s.char_code_at(i).to_u8())
        i = i + 1
    out

# Compare two [u8] slices element-by-element; returns true if equal.
fn _u8_eq(a: [u8], b: [u8]) -> bool:
    if a.len() != b.len():
        return false
    var i: u64 = 0
    var equal = true
    while i < a.len() and equal:
        if a[i] != b[i]:
            equal = false
        i = i + 1
    equal

# Convert [u8] to text (ASCII) for label equality checks.
fn _u8_to_text(src: [u8]) -> text:
    var out = ""
    var i: u64 = 0
    while i < src.len():
        out = out + src[i].to_i64().chr()
        i = i + 1
    out

# Build a trivial PEM bytes value from a raw text string (for malformed inputs).
fn _text_to_u8(s: text) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < s.len():
        out.push(s.char_code_at(i).to_u8())
        i = i + 1
    out

# ============================================================================
# Top-level self-test — exercises round-trip so interpreter-mode file-load
# actually runs code (it-blocks do NOT execute in interpreter mode).
# ============================================================================

fn _selftest() -> bool:
    val der = _der_32()
    val label = _label_spki()
    val encoded = pem_encode(label, der)
    val decoded = pem_decode(encoded)
    if not decoded.is_ok():
        return false
    val block = decoded.unwrap()
    _u8_eq(block.der, der) and _u8_eq(block.label, label)

val _st = _selftest()

# ============================================================================
# Round-trip KATs
# ============================================================================

describe "PEM RFC 7468 — SPKI round-trip":

    it "encode+decode recovers original 32-byte DER":
        val der = _der_32()
        val label = _label_spki()
        val pem_bytes = pem_encode(label, der)
        val result = pem_decode(pem_bytes)
        expect(result.is_ok()).to_equal(true)
        val block = result.unwrap()
        expect(_u8_eq(block.der, der)).to_equal(true)

    it "encode+decode recovers original label PUBLIC KEY":
        val der = _der_32()
        val label = _label_spki()
        val pem_bytes = pem_encode(label, der)
        val result = pem_decode(pem_bytes)
        expect(result.is_ok()).to_equal(true)
        val block = result.unwrap()
        expect(_u8_to_text(block.label)).to_equal("PUBLIC KEY")

    it "encoded output starts with -----BEGIN PUBLIC KEY-----":
        val pem_bytes = pem_encode(_label_spki(), _der_32())
        val pem_text = _u8_to_text(pem_bytes)
        expect(pem_text.starts_with("-----BEGIN PUBLIC KEY-----")).to_equal(true)

    it "encoded output ends with -----END PUBLIC KEY-----\\n":
        val pem_bytes = pem_encode(_label_spki(), _der_32())
        val pem_text = _u8_to_text(pem_bytes)
        expect(pem_text.ends_with("-----END PUBLIC KEY-----\n")).to_equal(true)

    it "DER length is preserved through round-trip":
        val der = _der_32()
        val pem_bytes = pem_encode(_label_spki(), der)
        val result = pem_decode(pem_bytes)
        expect(result.is_ok()).to_equal(true)
        val block = result.unwrap()
        expect(block.der.len().to_i64()).to_equal(32)

# ============================================================================
# Multi-block
# ============================================================================

describe "PEM RFC 7468 — multi-block pem_decode_all":

    it "decodes two concatenated blocks":
        val pem1 = pem_encode(_label_spki(), _der_32())
        val pem2 = pem_encode(_label_cert(), _der_32())
        # Concatenate with a separator newline (explanatory text is silently ignored)
        val combined_text = _u8_to_text(pem1) + "\n" + _u8_to_text(pem2)
        val combined = _text_to_u8(combined_text)
        val result = pem_decode_all(combined)
        expect(result.is_ok()).to_equal(true)
        val blocks = result.unwrap()
        expect(blocks.len()).to_equal(2)

    it "first block has label PUBLIC KEY":
        val pem1 = pem_encode(_label_spki(), _der_32())
        val pem2 = pem_encode(_label_cert(), _der_32())
        val combined_text = _u8_to_text(pem1) + "\n" + _u8_to_text(pem2)
        val combined = _text_to_u8(combined_text)
        val result = pem_decode_all(combined)
        expect(result.is_ok()).to_equal(true)
        val blocks = result.unwrap()
        val b0: PemBlock = blocks[0]
        expect(_u8_to_text(b0.label)).to_equal("PUBLIC KEY")

    it "second block has label CERTIFICATE":
        val pem1 = pem_encode(_label_spki(), _der_32())
        val pem2 = pem_encode(_label_cert(), _der_32())
        val combined_text = _u8_to_text(pem1) + "\n" + _u8_to_text(pem2)
        val combined = _text_to_u8(combined_text)
        val result = pem_decode_all(combined)
        expect(result.is_ok()).to_equal(true)
        val blocks = result.unwrap()
        val b1: PemBlock = blocks[1]
        expect(_u8_to_text(b1.label)).to_equal("CERTIFICATE")

    it "empty input returns Ok with zero blocks":
        val result = pem_decode_all(_text_to_u8(""))
        expect(result.is_ok()).to_equal(true)
        val blocks = result.unwrap()
        expect(blocks.len()).to_equal(0)

# ============================================================================
# Malformed-rejection tests
# ============================================================================

describe "PEM RFC 7468 — malformed rejection":

    it "missing END marker → Err":
        # Valid BEGIN but no END
        val bad = _text_to_u8("-----BEGIN PUBLIC KEY-----\nYWJj\n")
        val result = pem_decode(bad)
        expect(result.is_err()).to_equal(true)

    it "label mismatch BEGIN CERTIFICATE / END PUBLIC KEY → Err":
        # pem_decode requires matching END label
        val bad_text = "-----BEGIN CERTIFICATE-----\nYWJj\n-----END PUBLIC KEY-----\n"
        val bad = _text_to_u8(bad_text)
        val result = pem_decode(bad)
        expect(result.is_err()).to_equal(true)

    it "no BEGIN marker at all → Err":
        val bad = _text_to_u8("just some random text with no markers")
        val result = pem_decode(bad)
        expect(result.is_err()).to_equal(true)

    it "empty body → Err":
        # BEGIN + END with no base64 content
        val bad_text = "-----BEGIN PUBLIC KEY-----\n-----END PUBLIC KEY-----\n"
        val bad = _text_to_u8(bad_text)
        val result = pem_decode(bad)
        expect(result.is_err()).to_equal(true)
