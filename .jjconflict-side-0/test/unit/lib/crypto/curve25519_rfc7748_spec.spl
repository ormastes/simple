# Curve25519 RFC 7748 §5.2 Test Vector Spec
#
# Exercises os.crypto.curve25519.x25519 against the canonical RFC 7748
# reference values for X25519 scalar multiplication and ECDH key exchange.
#
# Vectors covered:
#   TV1     — RFC 7748 §5.2 single scalar-mult, test vector 1
#   TV2     — RFC 7748 §5.2 single scalar-mult, test vector 2
#   ITER1   — RFC 7748 §5.2 iterated scalar-mult after 1 iteration
#   ECDH×4  — RFC 7748 §6.1 Diffie-Hellman exchange (Alice+Bob keygen + shared)
#
# The 1000-iteration and 1000000-iteration checks from RFC 7748 §5.2 are
# intentionally omitted: 1000 iterations is feasible in native mode but
# excessively slow under interpreter mode; 1M is unreasonable in any mode.
# The single-iteration check still exercises the core scalar-mult path.
#
# Function signatures (os.crypto.curve25519):
#   x25519(scalar: [u8], u_coord: [u8]) -> [u8]  # 32-byte output
#   x25519_base(scalar: [u8]) -> [u8]             # X25519(scalar, BASE_POINT)

use std.spipe.*
use os.crypto.curve25519.{x25519, x25519_base}

# ============================================================================
# RFC 7748 §5.2 — Test Vector 1
# ============================================================================

val SCALAR_TV1: [u8] = [
    0xa5u8, 0x46u8, 0xe3u8, 0x6bu8, 0xf0u8, 0x52u8, 0x7cu8, 0x9du8,
    0x3bu8, 0x16u8, 0x15u8, 0x4bu8, 0x82u8, 0x46u8, 0x5eu8, 0xddu8,
    0x62u8, 0x14u8, 0x4cu8, 0x0au8, 0xc1u8, 0xfcu8, 0x5au8, 0x18u8,
    0x50u8, 0x6au8, 0x22u8, 0x44u8, 0xbau8, 0x44u8, 0x9au8, 0xc4u8
]

val U_TV1: [u8] = [
    0xe6u8, 0xdbu8, 0x68u8, 0x67u8, 0x58u8, 0x30u8, 0x30u8, 0xdbu8,
    0x35u8, 0x94u8, 0xc1u8, 0xa4u8, 0x24u8, 0xb1u8, 0x5fu8, 0x7cu8,
    0x72u8, 0x66u8, 0x24u8, 0xecu8, 0x26u8, 0xb3u8, 0x35u8, 0x3bu8,
    0x10u8, 0xa9u8, 0x03u8, 0xa6u8, 0xd0u8, 0xabu8, 0x1cu8, 0x4cu8
]

val EXPECTED_TV1: [u8] = [
    0xc3u8, 0xdau8, 0x55u8, 0x37u8, 0x9du8, 0xe9u8, 0xc6u8, 0x90u8,
    0x8eu8, 0x94u8, 0xeau8, 0x4du8, 0xf2u8, 0x8du8, 0x08u8, 0x4fu8,
    0x32u8, 0xecu8, 0xcfu8, 0x03u8, 0x49u8, 0x1cu8, 0x71u8, 0xf7u8,
    0x54u8, 0xb4u8, 0x07u8, 0x55u8, 0x77u8, 0xa2u8, 0x85u8, 0x52u8
]

# ============================================================================
# RFC 7748 §5.2 — Test Vector 2
# ============================================================================

val SCALAR_TV2: [u8] = [
    0x4bu8, 0x66u8, 0xe9u8, 0xd4u8, 0xd1u8, 0xb4u8, 0x67u8, 0x3cu8,
    0x5au8, 0xd2u8, 0x26u8, 0x91u8, 0x95u8, 0x7du8, 0x6au8, 0xf5u8,
    0xc1u8, 0x1bu8, 0x64u8, 0x21u8, 0xe0u8, 0xeau8, 0x01u8, 0xd4u8,
    0x2cu8, 0xa4u8, 0x16u8, 0x9eu8, 0x79u8, 0x18u8, 0xbau8, 0x0du8
]

val U_TV2: [u8] = [
    0xe5u8, 0x21u8, 0x0fu8, 0x12u8, 0x78u8, 0x68u8, 0x11u8, 0xd3u8,
    0xf4u8, 0xb7u8, 0x95u8, 0x9du8, 0x05u8, 0x38u8, 0xaeu8, 0x2cu8,
    0x31u8, 0xdbu8, 0xe7u8, 0x10u8, 0x6fu8, 0xc0u8, 0x3cu8, 0x3eu8,
    0xfcu8, 0x4cu8, 0xd5u8, 0x49u8, 0xc7u8, 0x15u8, 0xa4u8, 0x93u8
]

val EXPECTED_TV2: [u8] = [
    0x95u8, 0xcbu8, 0xdeu8, 0x94u8, 0x76u8, 0xe8u8, 0x90u8, 0x7du8,
    0x7au8, 0xadu8, 0xe4u8, 0x5cu8, 0xb4u8, 0xb8u8, 0x73u8, 0xf8u8,
    0x8bu8, 0x59u8, 0x5au8, 0x68u8, 0x79u8, 0x9fu8, 0xa1u8, 0x52u8,
    0xe6u8, 0xf8u8, 0xf7u8, 0x64u8, 0x7au8, 0xacu8, 0x79u8, 0x57u8
]

# ============================================================================
# RFC 7748 §5.2 — Iterated scalar-mult
# Base point: u8 09 followed by 31 zero bytes
# After 1 iteration of (k, u) ← (X25519(k, u), k) starting from k=u=BASE_POINT
# ============================================================================

val BASE_POINT: [u8] = [
    0x09u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8
]

val EXPECTED_AFTER_1_ITER: [u8] = [
    0x42u8, 0x2cu8, 0x8eu8, 0x7au8, 0x62u8, 0x27u8, 0xd7u8, 0xbcu8,
    0xa1u8, 0x35u8, 0x0bu8, 0x3eu8, 0x2bu8, 0xb7u8, 0x27u8, 0x9fu8,
    0x78u8, 0x97u8, 0xb8u8, 0x7bu8, 0xb6u8, 0x85u8, 0x4bu8, 0x78u8,
    0x3cu8, 0x60u8, 0xe8u8, 0x03u8, 0x11u8, 0xaeu8, 0x30u8, 0x79u8
]

# ============================================================================
# RFC 7748 §6.1 — X25519 ECDH key exchange
# ============================================================================

val ALICE_PRIV: [u8] = [
    0x77u8, 0x07u8, 0x6du8, 0x0au8, 0x73u8, 0x18u8, 0xa5u8, 0x7du8,
    0x3cu8, 0x16u8, 0xc1u8, 0x72u8, 0x51u8, 0xb2u8, 0x66u8, 0x45u8,
    0xdfu8, 0x4cu8, 0x2fu8, 0x87u8, 0xebu8, 0xc0u8, 0x99u8, 0x2au8,
    0xb1u8, 0x77u8, 0xfbu8, 0xa5u8, 0x1du8, 0xb9u8, 0x2cu8, 0x2au8
]

val ALICE_PUB: [u8] = [
    0x85u8, 0x20u8, 0xf0u8, 0x09u8, 0x89u8, 0x30u8, 0xa7u8, 0x54u8,
    0x74u8, 0x8bu8, 0x7du8, 0xdcu8, 0xb4u8, 0x3eu8, 0xf7u8, 0x5au8,
    0x0du8, 0xbfu8, 0x3au8, 0x0du8, 0x26u8, 0x38u8, 0x1au8, 0xf4u8,
    0xebu8, 0xa4u8, 0xa9u8, 0x8eu8, 0xaau8, 0x9bu8, 0x4eu8, 0x6au8
]

val BOB_PRIV: [u8] = [
    0x5du8, 0xabu8, 0x08u8, 0x7eu8, 0x62u8, 0x4au8, 0x8au8, 0x4bu8,
    0x79u8, 0xe1u8, 0x7fu8, 0x8bu8, 0x83u8, 0x80u8, 0x0eu8, 0xe6u8,
    0x6fu8, 0x3bu8, 0xb1u8, 0x29u8, 0x26u8, 0x18u8, 0xb6u8, 0xfdu8,
    0x1cu8, 0x2fu8, 0x8bu8, 0x27u8, 0xffu8, 0x88u8, 0xe0u8, 0xebu8
]

val BOB_PUB: [u8] = [
    0xdeu8, 0x9eu8, 0xdbu8, 0x7du8, 0x7bu8, 0x7du8, 0xc1u8, 0xb4u8,
    0xd3u8, 0x5bu8, 0x61u8, 0xc2u8, 0xecu8, 0xe4u8, 0x35u8, 0x37u8,
    0x3fu8, 0x83u8, 0x43u8, 0xc8u8, 0x5bu8, 0x78u8, 0x67u8, 0x4du8,
    0xadu8, 0xfcu8, 0x7eu8, 0x14u8, 0x6fu8, 0x88u8, 0x2bu8, 0x4fu8
]

val SHARED_SECRET: [u8] = [
    0x4au8, 0x5du8, 0x9du8, 0x5bu8, 0xa4u8, 0xceu8, 0x2du8, 0xe1u8,
    0x72u8, 0x8eu8, 0x3bu8, 0xf4u8, 0x80u8, 0x35u8, 0x0fu8, 0x25u8,
    0xe0u8, 0x7eu8, 0x21u8, 0xc9u8, 0x47u8, 0xd1u8, 0x9eu8, 0x33u8,
    0x76u8, 0xf0u8, 0x9bu8, 0x3cu8, 0x1eu8, 0x16u8, 0x17u8, 0x42u8
]

# ============================================================================
# RFC 7748 §5.2 — Single scalar-mult test vectors
# ============================================================================

describe "Curve25519 RFC 7748 §5.2 single scalar-mult test vectors":
    it "TV1: scalar a546e36b... × u e6db6867... → c3da5537...":
        expect(x25519(SCALAR_TV1, U_TV1)).to_equal(EXPECTED_TV1)

    it "TV2: scalar 4b66e9d4... × u e5210f12... → 95cbde94...":
        expect(x25519(SCALAR_TV2, U_TV2)).to_equal(EXPECTED_TV2)

# ============================================================================
# RFC 7748 §5.2 — Iterated scalar-mult (1 iteration)
#
# RFC §5.2 defines the iteration as: (k, u) ← (X25519(k, u), k)
# Starting from k = u = BASE_POINT.
# After 1 step: new_k = X25519(BASE_POINT, BASE_POINT).
#
# The 1000-iteration and 1000000-iteration checks are omitted — too slow
# for interpreter mode. The 1-iteration check still validates the ladder path.
# ============================================================================

describe "Curve25519 RFC 7748 §5.2 iterated scalar-mult":
    it "after 1 iteration starting from BASE_POINT: 422c8e7a...":
        expect(x25519(BASE_POINT, BASE_POINT)).to_equal(EXPECTED_AFTER_1_ITER)

# ============================================================================
# RFC 7748 §6.1 — X25519 ECDH key exchange
# ============================================================================

describe "Curve25519 RFC 7748 §6.1 ECDH key exchange":
    it "Alice public key: x25519(alice_priv, base) == alice_pub":
        expect(x25519_base(ALICE_PRIV)).to_equal(ALICE_PUB)

    it "Bob public key: x25519(bob_priv, base) == bob_pub":
        expect(x25519_base(BOB_PRIV)).to_equal(BOB_PUB)

    it "Alice computes shared secret: x25519(alice_priv, bob_pub) == shared_secret":
        expect(x25519(ALICE_PRIV, BOB_PUB)).to_equal(SHARED_SECRET)

    it "Bob computes shared secret: x25519(bob_priv, alice_pub) == shared_secret":
        expect(x25519(BOB_PRIV, ALICE_PUB)).to_equal(SHARED_SECRET)
