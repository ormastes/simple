# ChaCha20-Poly1305 AEAD — Wycheproof + Boundary / Size Tests
#
# Pool A — Boundary / size cases (11 tests):
#   empty PT + empty AAD               → tag computed, round-trip OK
#   empty PT + 16-byte AAD             → AAD-only auth, round-trip OK
#   1-byte PT + 0-byte AAD             → minimal encryption
#   16-byte PT  (one Poly1305 block, exact padding boundary)
#   17-byte PT  (one block + 1 byte residual)
#   31-byte PT  (just under two Poly1305 blocks)
#   32-byte PT  (exact two Poly1305 blocks)
#   64-byte PT  (one full ChaCha20 block)
#   65-byte PT  (one full ChaCha20 block + 1 byte → forces counter increment)
#   128-byte PT (two full ChaCha20 blocks)
#   1024-byte PT (16 full ChaCha20 blocks; stress counter handling)
#
# Pool B — Wycheproof vectors (7 tests):
#   tcId 2  (Pseudorandom, empty msg + empty AAD)      → result: valid
#   tcId 3  (Pseudorandom, empty msg + 8-byte AAD)     → result: valid
#   tcId 4  (Pseudorandom, 1-byte msg + empty AAD)     → result: valid
#   tcId 5  (Pseudorandom, 1-byte msg + 8-byte AAD)    → result: valid
#   tcId 148 (ModifiedTag, bit-7 flip)                 → result: invalid (open → nil)
#   tcId 149 (ModifiedTag, bit-8 flip)                 → result: invalid (open → nil)
#   tcId 164 (ModifiedTag, all-zero tag)               → result: invalid (open → nil)
#   tcId 320 (InvalidNonceSize, 13-byte nonce)         → result: invalid (open → nil)
#   tcId 322 (InvalidNonceSize, 16-byte nonce)         → result: invalid (open → nil)
#
# Source: https://github.com/google/wycheproof/blob/master/testvectors_v1/chacha20_poly1305_test.json
# Boundary vectors generated with Python `cryptography` package (ChaCha20Poly1305 AEAD).
# All Pool A vectors verified against IETF ChaCha20-Poly1305 (RFC 7539 / RFC 8439).
#
# Execution note: it-block bodies verified in compiled mode.
# All vectors are byte-exact — no "close enough".

use std.spipe.*
use std.crypto.chacha20_poly1305.{chacha20_poly1305_seal, chacha20_poly1305_open}

# ============================================================================
# Pool A — shared key + nonce
#
# key   = 00 01 02 .. 1f  (32 bytes, ascending)
# nonce = 00 01 02 .. 0b  (12 bytes, ascending)
# ============================================================================

fn _key_b() -> [u8]:
    # 32-byte ascending key: 00 01 02 .. 1f
    [0x00u8, 0x01u8, 0x02u8, 0x03u8, 0x04u8, 0x05u8, 0x06u8, 0x07u8,
     0x08u8, 0x09u8, 0x0au8, 0x0bu8, 0x0cu8, 0x0du8, 0x0eu8, 0x0fu8,
     0x10u8, 0x11u8, 0x12u8, 0x13u8, 0x14u8, 0x15u8, 0x16u8, 0x17u8,
     0x18u8, 0x19u8, 0x1au8, 0x1bu8, 0x1cu8, 0x1du8, 0x1eu8, 0x1fu8]

fn _nonce_b() -> [u8]:
    # 12-byte ascending nonce: 00 01 02 .. 0b
    [0x00u8, 0x01u8, 0x02u8, 0x03u8, 0x04u8, 0x05u8, 0x06u8, 0x07u8,
     0x08u8, 0x09u8, 0x0au8, 0x0bu8]

fn _aad_16b() -> [u8]:
    # 16-byte ascending AAD: 10 11 12 .. 1f
    [0x10u8, 0x11u8, 0x12u8, 0x13u8, 0x14u8, 0x15u8, 0x16u8, 0x17u8,
     0x18u8, 0x19u8, 0x1au8, 0x1bu8, 0x1cu8, 0x1du8, 0x1eu8, 0x1fu8]

fn _pt_n(n: u64) -> [u8]:
    # Build plaintext bytes(range(n % 256)) for n <= 256
    # For n == 1024 use pattern (i*7+3)%256
    # Caller selects the right helper per test.
    var out: [u8] = []
    var i: u64 = 0u64
    while i < n:
        out.push((i % 256u64) as u8)
        i = i + 1u64
    out

fn _pt_1024() -> [u8]:
    # 1024-byte plaintext with pattern (i*7+3) % 256
    var out: [u8] = []
    var i: u64 = 0u64
    while i < 1024u64:
        out.push(((i * 7u64 + 3u64) % 256u64) as u8)
        i = i + 1u64
    out

# ============================================================================
# Pool A — KAT vectors (generated with `cryptography` ChaCha20Poly1305)
# key = 00..1f, nonce = 00..0b
# ============================================================================

fn _ct_size0() -> [u8]:
    # Empty PT, empty AAD → empty ciphertext
    []

