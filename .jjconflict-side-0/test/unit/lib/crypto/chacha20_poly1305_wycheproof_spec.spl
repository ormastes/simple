# ----------------------------------------------------------------------------
# Wycheproof helpers
# ----------------------------------------------------------------------------

fn _wyc_key_2021() -> [u8]:
    # Wycheproof key shared by ModifiedTag/InvalidNonceSize vectors
    # key: 202122232425262728292a2b2c2d2e2f303132333435363738393a3b3c3d3e3f
    [0x20u8, 0x21u8, 0x22u8, 0x23u8, 0x24u8, 0x25u8, 0x26u8, 0x27u8,
     0x28u8, 0x29u8, 0x2au8, 0x2bu8, 0x2cu8, 0x2du8, 0x2eu8, 0x2fu8,
     0x30u8, 0x31u8, 0x32u8, 0x33u8, 0x34u8, 0x35u8, 0x36u8, 0x37u8,
     0x38u8, 0x39u8, 0x3au8, 0x3bu8, 0x3cu8, 0x3du8, 0x3eu8, 0x3fu8]

fn _wyc_nonce_0001() -> [u8]:
    # nonce: 000102030405060708090a0b
    [0x00u8, 0x01u8, 0x02u8, 0x03u8, 0x04u8, 0x05u8, 0x06u8, 0x07u8,
     0x08u8, 0x09u8, 0x0au8, 0x0bu8]

fn _wyc_aad_000102() -> [u8]:
    # aad: 000102
    [0x00u8, 0x01u8, 0x02u8]

fn _wyc_valid_tag_empty_msg() -> [u8]:
    # Valid tag for key=2021.., nonce=0001.., aad=000102, msg=empty
    # Verified via comments in ModifiedTag vectors: "expected tag:f4409bb729039d0814ac514054323f44"
    [0xf4u8, 0x40u8, 0x9bu8, 0xb7u8, 0x29u8, 0x03u8, 0x9du8, 0x08u8,
     0x14u8, 0xacu8, 0x51u8, 0x40u8, 0x54u8, 0x32u8, 0x3fu8, 0x44u8]

describe "ChaCha20-Poly1305 Wycheproof — valid vectors":

    it "tcId 2 (Pseudorandom): empty msg, empty AAD → correct tag":
        # Wycheproof tcId 2, flags=[Pseudorandom], result=valid
        # key: 80ba3192c803ce965ea371d5ff073cf0f43b6a2ab576b208426e11409c09b9b0
        # iv:  4da5bf8dfd5852c1ea12379d
        # tag: 76acb342cf3166a5b63c0c0ea1383c8d
        val key: [u8] = [0x80u8, 0xbau8, 0x31u8, 0x92u8, 0xc8u8, 0x03u8, 0xceu8, 0x96u8,
                         0x5eu8, 0xa3u8, 0x71u8, 0xd5u8, 0xffu8, 0x07u8, 0x3cu8, 0xf0u8,
                         0xf4u8, 0x3bu8, 0x6au8, 0x2au8, 0xb5u8, 0x76u8, 0xb2u8, 0x08u8,
                         0x42u8, 0x6eu8, 0x11u8, 0x40u8, 0x9cu8, 0x09u8, 0xb9u8, 0xb0u8]
        val nonce: [u8] = [0x4du8, 0xa5u8, 0xbfu8, 0x8du8, 0xfdu8, 0x58u8, 0x52u8, 0xc1u8,
                           0xeau8, 0x12u8, 0x37u8, 0x9du8]
        val expected_tag: [u8] = [0x76u8, 0xacu8, 0xb3u8, 0x42u8, 0xcfu8, 0x31u8, 0x66u8, 0xa5u8,
                                  0xb6u8, 0x3cu8, 0x0cu8, 0x0eu8, 0xa1u8, 0x38u8, 0x3cu8, 0x8du8]
        val empty: [u8] = []
        val (_ct, tag) = chacha20_poly1305_seal(key, nonce, empty, empty)
        expect(_bytes_eq_b(tag, expected_tag)).to_equal(true)

    it "tcId 3 (Pseudorandom): empty msg, 8-byte AAD → correct tag":
        # Wycheproof tcId 3, flags=[Pseudorandom], result=valid
        # key: 7a4cd759172e02eb204db2c3f5c746227df584fc1345196391dbb9577a250742
