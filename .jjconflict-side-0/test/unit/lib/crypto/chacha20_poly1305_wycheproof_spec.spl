# ============================================================================
# Helpers (mirror existing spec style)
# ============================================================================

fn _bytes_eq_b(a: [u8], b: [u8]) -> bool:
    """Return true iff two byte arrays are identical."""
    if a.len() != b.len():
        return false
    var i: u64 = 0u64
    while i < a.len():
        if a[i] != b[i]:
            return false
        i = i + 1u64
    true

fn _open_eq_b(key: [u8], nonce: [u8], aad: [u8], ct: [u8], tag: [u8], expected: [u8]) -> bool:
    """Return true if open succeeds and plaintext matches expected."""
    if val Some(pt) = chacha20_poly1305_open(key, nonce, aad, ct, tag):
        _bytes_eq_b(pt, expected)
    else:
        false

fn _open_len_b(key: [u8], nonce: [u8], aad: [u8], ct: [u8], tag: [u8]) -> u64:
    """Return plaintext length on success, 0xFFFFFFFFFFFFFFFF on failure."""
    if val Some(pt) = chacha20_poly1305_open(key, nonce, aad, ct, tag):
        pt.len()
    else:
        0xFFFFFFFFFFFFFFFFu64

fn _open_is_nil_b(key: [u8], nonce: [u8], aad: [u8], ct: [u8], tag: [u8]) -> bool:
    """Return true if open returns nil (authentication failure)."""
    val result = chacha20_poly1305_open(key, nonce, aad, ct, tag)
    result == nil

# ============================================================================
# Pool A — boundary / size tests
# ============================================================================

describe "ChaCha20-Poly1305 boundary — empty PT + empty AAD":

    it "seal produces empty ciphertext, 16-byte tag (KAT)":
        # Boundary vector: key=00..1f, nonce=00..0b, empty PT, empty AAD
        # tag: 295a498b8841a1c5f55d4d606f731159
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), empty, empty)
        expect(ct.len()).to_equal(0u64)
        expect(_bytes_eq_b(tag, _tag_size0())).to_equal(true)

    it "round-trip: open(seal(empty)) recovers empty plaintext":
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), empty, empty)
        expect(_open_len_b(_key_b(), _nonce_b(), empty, ct, tag)).to_equal(0u64)

describe "ChaCha20-Poly1305 boundary — empty PT + 16-byte AAD":

    it "seal with 16-byte AAD + empty PT produces correct tag (KAT)":
        # Boundary vector: key=00..1f, nonce=00..0b, empty PT, aad=10..1f
        # tag: 7747d1fc06fb33eebb1acab76747ff42
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), _aad_16b(), empty)
        expect(ct.len()).to_equal(0u64)
        expect(_bytes_eq_b(tag, _tag_emptyPT_aad16())).to_equal(true)

    it "round-trip: open(seal(empty, aad16)) recovers empty plaintext":
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), _aad_16b(), empty)
        expect(_open_eq_b(_key_b(), _nonce_b(), _aad_16b(), ct, tag, empty)).to_equal(true)

describe "ChaCha20-Poly1305 boundary — 1-byte PT":

    it "seal 1-byte PT produces 1-byte ciphertext + correct tag (KAT)":
        # PT=00, empty AAD → ct=89, tag=04f0dd71889fd631f90e4584d25cbb92
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), empty, _pt_n(1u64))
        expect(ct.len()).to_equal(1u64)
        expect(_bytes_eq_b(ct, _ct_size1())).to_equal(true)
        expect(_bytes_eq_b(tag, _tag_size1())).to_equal(true)

    it "round-trip: 1-byte PT recovered correctly":
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), empty, _pt_n(1u64))
        expect(_open_eq_b(_key_b(), _nonce_b(), empty, ct, tag, _pt_n(1u64))).to_equal(true)

describe "ChaCha20-Poly1305 boundary — 16-byte PT (one Poly1305 block)":

    it "seal 16-byte PT: ciphertext byte-exact (KAT)":
        # Exact Poly1305 block boundary — padding path exercises 0 pad bytes
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), empty, _pt_n(16u64))
        expect(_bytes_eq_b(ct, _ct_size16())).to_equal(true)
        expect(_bytes_eq_b(tag, _tag_size16())).to_equal(true)

    it "round-trip: 16-byte PT recovered":
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), empty, _pt_n(16u64))
        expect(_open_eq_b(_key_b(), _nonce_b(), empty, ct, tag, _pt_n(16u64))).to_equal(true)

describe "ChaCha20-Poly1305 boundary — 17-byte PT (one block + 1 residual)":

    it "seal 17-byte PT: ciphertext byte-exact (KAT)":
        # First residual byte exercises the Poly1305 partial-block path
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), empty, _pt_n(17u64))
        expect(_bytes_eq_b(ct, _ct_size17())).to_equal(true)
        expect(_bytes_eq_b(tag, _tag_size17())).to_equal(true)

    it "round-trip: 17-byte PT recovered":
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), empty, _pt_n(17u64))
        expect(_open_eq_b(_key_b(), _nonce_b(), empty, ct, tag, _pt_n(17u64))).to_equal(true)

describe "ChaCha20-Poly1305 boundary — 31-byte PT (just under two Poly1305 blocks)":

    it "seal 31-byte PT: ciphertext byte-exact (KAT)":
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), empty, _pt_n(31u64))
        expect(_bytes_eq_b(ct, _ct_size31())).to_equal(true)
        expect(_bytes_eq_b(tag, _tag_size31())).to_equal(true)

    it "round-trip: 31-byte PT recovered":
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), empty, _pt_n(31u64))
        expect(_open_eq_b(_key_b(), _nonce_b(), empty, ct, tag, _pt_n(31u64))).to_equal(true)

describe "ChaCha20-Poly1305 boundary — 32-byte PT (exact two Poly1305 blocks)":

    it "seal 32-byte PT: ciphertext byte-exact (KAT)":
        val empty: [u8] = []
        val (ct, tag) = chacha20_poly1305_seal(_key_b(), _nonce_b(), empty, _pt_n(32u64))
        expect(_bytes_eq_b(ct, _ct_size32())).to_equal(true)
        expect(_bytes_eq_b(tag, _tag_size32())).to_equal(true)

