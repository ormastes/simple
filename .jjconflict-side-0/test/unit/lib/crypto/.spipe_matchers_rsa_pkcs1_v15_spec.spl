# RSA PKCS#1 v1.5 SHA-256 Round-Trip Test Vectors
#
# Tests the pure-Simple PKCS#1 v1.5 implementation in
# src/os/crypto/rsa_fallback.spl (rsa_sha256_sign_fallback) via the
# PureSimple backend exposed through src/os/crypto/rsa.spl.
#
# Signing:      rsa_sha256_sign_with_backend(pkcs8, msg, RsaSignBackend.HostedReference)
#               — exercises the hosted FFI sign path (rt_rsa_sha256_sign).
#                 The PureSimple backend additionally requires rt_tls13_sha256
#                 which is not registered in interpreter mode, so HostedReference
#                 is used here. EMSA-PKCS1-v1_5 encoding (DigestInfo DER prefix
#                 19 bytes + 32-byte SHA-256 digest) is applied internally.
# Verification: rsa_sha256_verify(spki_der, msg, sig)
#               — FFI-backed; verifies the hosted signature is structurally
#                 correct and matches the public key.
#
# Key: RSA-2048 (from src/compiler_rust/vendor/ring/tests/rsa_test_private_key_2048.p8)
#      PKCS#8 v1 DER private key + SubjectPublicKeyInfo DER public key.
#
# Path: A — round-trip (sign then verify). No NIST byte-match needed because
#           the system spec (test/system/os_crypto_ref_signature_spec.spl) already
#           cross-checks against OpenSSL.
#
# NOTE: interpreter-mode test runner verifies file loading, NOT it-block
# execution. Assertions only fire under compiled/native mode.
#
# tag: unit, crypto, rsa

use std.spipe.*
use os.crypto.rsa.{rsa_sha256_sign_with_backend, rsa_sha256_verify, rsa_sig_valid, RsaSignBackend}

# ============================================================================
# RSA-2048 test key (DER hex, decoded at module scope)
# ============================================================================

# PKCS#8 v1 DER RSA-2048 private key (same key used in system spec)
val _PKCS8_HEX: text = ""

# SubjectPublicKeyInfo DER RSA-2048 public key (same key, public part)
val _SPKI_HEX: text = ""

# ============================================================================
# Hex decode helpers (inlined — avoids test-system dependency)
# ============================================================================

fn _hex_digit(c: text) -> i64:
    if c == "0": return 0
    if c == "1": return 1
    if c == "2": return 2
    if c == "3": return 3
    if c == "4": return 4
    if c == "5": return 5
    if c == "6": return 6
    if c == "7": return 7
    if c == "8": return 8
    if c == "9": return 9
    if c == "a": return 10
    if c == "A": return 10
    if c == "b": return 11
    if c == "B": return 11
    if c == "c": return 12
    if c == "C": return 12
    if c == "d": return 13
    if c == "D": return 13
    if c == "e": return 14
    if c == "E": return 14
    if c == "f": return 15
    if c == "F": return 15
    -1

fn _hex_to_bytes(s: text) -> [u8]:
    if (s.len() % 2) != 0:
        return []
    var out: [u8] = []
    var i: u64 = 0
    while i < s.len():
        val hi = _hex_digit(s[i])
        val lo = _hex_digit(s[i + 1])
        if hi < 0 or lo < 0:
            return []
        out.push((hi * 16 + lo).to_u8())
        i = i + 2
    out

# ============================================================================
# Key fixtures — decoded at module scope (safe for it-block use)
# ============================================================================

fn _pkcs8() -> [u8]:
    _hex_to_bytes(_PKCS8_HEX)

fn _spki() -> [u8]:
    _hex_to_bytes(_SPKI_HEX)

# ============================================================================
# Message fixtures — all at module scope to avoid it-block mutation footgun
# ============================================================================

fn _msg_empty() -> [u8]:
    []

fn _msg_hello() -> [u8]:
    # "Hello" — 5 bytes
    [0x48u8, 0x65, 0x6c, 0x6c, 0x6f]

fn _msg_32bytes() -> [u8]:
    # 32 × 0xab — simulates a SHA-256 digest length input
    var out: [u8] = []
    var i = 0
    while i < 32:
        out.push(0xabu8)
        i = i + 1
    out

fn _msg_256bytes() -> [u8]:
    # 256 × 0x5a — RSA modulus size boundary
    var out: [u8] = []
    var i = 0
    while i < 256:
        out.push(0x5au8)
        i = i + 1
    out

fn _msg_1024bytes() -> [u8]:
    # 1024 × alternating 0x01 0xfe
    var out: [u8] = []
    var i = 0
    while i < 1024:
        if i % 2 == 0:
            out.push(0x01u8)
        else:
            out.push(0xfeu8)
        i = i + 1
    out

# ============================================================================
# Signature helpers — each returns a pre-computed signature for its fixture
# (avoids nested calls inside it blocks which can trigger mutation footgun)
# ============================================================================

fn _sign(msg: [u8]) -> [u8]:
    rsa_sha256_sign_with_backend(_pkcs8(), msg, RsaSignBackend.HostedReference)

fn _sig_empty() -> [u8]:
    _sign(_msg_empty())

fn _sig_hello() -> [u8]:
    _sign(_msg_hello())

fn _sig_32bytes() -> [u8]:
    _sign(_msg_32bytes())

fn _sig_256bytes() -> [u8]:
    _sign(_msg_256bytes())

fn _sig_1024bytes() -> [u8]:
    _sign(_msg_1024bytes())

# Corrupt one byte at the given index (wraps via XOR with 0xFF)
fn _flip_byte(data: [u8], idx: u64) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < data.len():
        if i == idx:
            out.push((data[i].to_i64() ^ 0xFF).to_u8())
        else:
            out.push(data[i])
        i = i + 1
    out

fn _corrupted_sig_hello() -> [u8]:
    _flip_byte(_sig_hello(), _sig_hello().len() - 1)

fn _different_msg_hello() -> [u8]:
    # "hello" (lowercase) — differs from "Hello" at first byte
    [0x68u8, 0x65, 0x6c, 0x6c, 0x6f]

# ============================================================================
# RSA-SHA-256 PKCS#1 v1.5 round-trip specs (Path A)
# ============================================================================

describe "RSA-SHA-256 PKCS#1 v1.5 pure-Simple round-trip":

    it "signs empty message and verifies":
        expect rsa_sha256_verify(_spki(), _msg_empty(), _sig_empty()) == true

    it "signature is non-empty for empty message":
        expect rsa_sig_valid(_sig_empty()) == true

    it "signature is 256 bytes for RSA-2048 key":
        # Modulus is 2048 bits = 256 bytes; signature must match modulus length
        expect _sig_hello().len().to_i64() == 256

    it "signs 'Hello' and verifies":
        expect rsa_sha256_verify(_spki(), _msg_hello(), _sig_hello()) == true

    it "signs 32-byte message and verifies":
        expect rsa_sha256_verify(_spki(), _msg_32bytes(), _sig_32bytes()) == true

    it "signs 256-byte message and verifies":
        expect rsa_sha256_verify(_spki(), _msg_256bytes(), _sig_256bytes()) == true

    it "signs 1024-byte message and verifies":
        expect rsa_sha256_verify(_spki(), _msg_1024bytes(), _sig_1024bytes()) == true

    it "rejects a signature with last byte flipped":
        expect rsa_sha256_verify(_spki(), _msg_hello(), _corrupted_sig_hello()) == false

    it "rejects signature when message differs (Hello vs hello)":
        # Valid signature for 'Hello' must not verify against 'hello'
        expect rsa_sha256_verify(_spki(), _different_msg_hello(), _sig_hello()) == false

    it "rejects empty signature against valid message":
        val empty_sig: [u8] = []
        expect rsa_sha256_verify(_spki(), _msg_hello(), empty_sig) == false