use std.spec.{describe, it, expect}
use std.fs_driver.block_device.{BlockDevice}
use std.fs_driver.fat32_core.{Fat32Core}

val FAT32_EOC: u32 = 0x0FFFFFF8
val FAT32_ATTR_ARCHIVE: u8 = 0x20
val FAT32_ATTR_LFN: u8 = 0x0F

struct SectorImage:
    lba: u64
    bytes: [u8]

class Fat32LfnMockBlockDevice:
    boot_sector: [u8]
    sectors: [SectorImage]

impl Fat32LfnMockBlockDevice:
    static fn new() -> Fat32LfnMockBlockDevice:
        Fat32LfnMockBlockDevice(boot_sector: _valid_boot_sector(), sectors: [])

    me fn with_sector(lba: u64, bytes: [u8]) -> Fat32LfnMockBlockDevice:
        self.sectors.push(SectorImage(lba: lba, bytes: bytes))
        self

impl BlockDevice for Fat32LfnMockBlockDevice:
    fn read_sector(lba: u64) -> Result<[u8], text>:
        if lba == 0u64:
            return Ok(self.boot_sector)
        for sector in self.sectors:
            if sector.lba == lba:
                return Ok(sector.bytes)
        Ok(_zero_sector())

    fn write_sector(lba: u64, data: [u8]) -> Result<bool, text>:
        Ok(true)

    fn sector_size() -> u32:
        512

fn _zero_sector() -> [u8]:
    var bytes: [u8] = []
    var i = 0
    while i < 512:
        bytes.push(0u8)
        i = i + 1
    bytes

fn _write_u32_le(bytes: [u8], offset: i32, value: u32):
    bytes[offset] = (value & 0xFFu32).to_u8()
    bytes[offset + 1] = ((value >> 8) & 0xFFu32).to_u8()
    bytes[offset + 2] = ((value >> 16) & 0xFFu32).to_u8()
    bytes[offset + 3] = ((value >> 24) & 0xFFu32).to_u8()

fn _valid_boot_sector() -> [u8]:
    var bytes = _zero_sector()
    bytes[11] = 0x00u8
    bytes[12] = 0x02u8
    bytes[13] = 0x01u8
    bytes[14] = 0x20u8
    bytes[15] = 0x00u8
    bytes[16] = 0x02u8
    _write_u32_le(bytes, 32, 131072u32)
    _write_u32_le(bytes, 36, 1008u32)
    _write_u32_le(bytes, 44, 2u32)
    bytes[510] = 0x55u8
    bytes[511] = 0xAAu8
    bytes

fn _fat_sector() -> [u8]:
    var bytes = _zero_sector()
    _write_u32_le(bytes, 8, FAT32_EOC)
    _write_u32_le(bytes, 20, FAT32_EOC)
    bytes

fn _root_with_browser_demo_lfn() -> [u8]:
    var bytes = _zero_sector()
    bytes[0] = 0x41u8
    bytes[1] = 'b' as u8
    bytes[3] = 'r' as u8
    bytes[5] = 'o' as u8
    bytes[7] = 'w' as u8
    bytes[9] = 's' as u8
    bytes[11] = FAT32_ATTR_LFN
    bytes[14] = 'e' as u8
    bytes[16] = 'r' as u8
    bytes[18] = '_' as u8
    bytes[20] = 'd' as u8
    bytes[22] = 'e' as u8
    bytes[24] = 'm' as u8
    bytes[28] = 'o' as u8
    bytes[30] = 0x00u8
    bytes[31] = 0x00u8

    bytes[32] = 'B' as u8
    bytes[33] = 'R' as u8
    bytes[34] = 'O' as u8
    bytes[35] = 'W' as u8
    bytes[36] = 'S' as u8
    bytes[37] = 'E' as u8
    bytes[38] = '~' as u8
    bytes[39] = '1' as u8
    bytes[43] = FAT32_ATTR_ARCHIVE
    bytes[58] = 0x05u8
    _write_u32_le(bytes, 60, 12345u32)
    bytes

fn _mounted_lfn_driver() -> Fat32Core:
    var dev = Fat32LfnMockBlockDevice.new()
    dev = dev.with_sector(32u64, _fat_sector())
    dev = dev.with_sector(2048u64, _root_with_browser_demo_lfn())
    var driver = Fat32Core.new(dev)
    val mounted = driver.mount()
    expect(mounted.is_ok()).to_equal(true)
    driver

describe "shared Fat32Core long filename directory reads":
    it "lists a single-slot LFN instead of the backing 8.3 alias":
        var driver = _mounted_lfn_driver()
        val entries = driver.read_dir_entries(2u32)
        expect(entries.is_ok()).to_equal(true)
        val listed = entries.unwrap()
        expect(listed.len()).to_equal(1)
        expect(listed[0].name).to_equal("browser_demo")
        expect(listed[0].inode.id).to_equal(5u64)
        expect(listed[0].size).to_equal(12345)

    it "resolves the LFN case-insensitively through shared Fat32Core":
        var driver = _mounted_lfn_driver()
        val lower = driver.resolve_path("/browser_demo")
        val upper = driver.resolve_path("/BROWSER_DEMO")
        expect(lower.is_ok()).to_equal(true)
        expect(upper.is_ok()).to_equal(true)
        expect(lower.unwrap().name).to_equal("browser_demo")
        expect(upper.unwrap().inode.id).to_equal(5u64)
