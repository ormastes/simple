# BrowserWindow unit tests

use std.spipe.*
use std.skia.entity.geometry.{SkRect}
use std.viz.entity.surface_id.{SurfaceId, FrameSinkId, LocalSurfaceId}
use std.viz.feature.display_compositor.{DisplayCompositor}
use std.content.entity.web_contents.{WebContents}
use std.content.feature.render_widget_host_view.{RenderWidgetHostView}
use std.gui.entity.browser_window.{BrowserWindow, WindowStyle}

fn _rect() -> SkRect:
    SkRect(left: 0.0, top: 0.0, right: 1280.0, bottom: 800.0)

fn _surface_id() -> SurfaceId:
    val fsi = FrameSinkId(client_id: 10, sink_id: 1)
    val lsi = LocalSurfaceId(parent_sequence_number: 1, child_sequence_number: 1)
    SurfaceId(frame_sink_id: fsi, local_surface_id: lsi)

fn _make_window() -> BrowserWindow:
    val wc = WebContents.new(10, _rect())
    val dc = DisplayCompositor.new(_rect())
    val view = RenderWidgetHostView.new(_surface_id(), _rect(), dc)
    BrowserWindow.new(99, "Test Window", _rect(), wc, view)

describe "BrowserWindow.new":
    it "sets id":
        val w = _make_window()
        expect w.id to_equal 99

    it "sets title":
        val w = _make_window()
        expect w.title to_equal "Test Window"

    it "sets bounds":
        val w = _make_window()
        expect w.bounds.right to_equal 1280.0

describe "WindowStyle.default":
    it "has frame=true":
        val s = WindowStyle.default()
        expect s.frame to_equal true

    it "has transparent=false":
        val s = WindowStyle.default()
        expect s.transparent to_equal false

describe "BrowserWindow visibility":
    it "show sets is_visible=true":
        var w = _make_window()
        w.show()
        expect w.is_visible to_equal true

    it "hide sets is_visible=false":
        var w = _make_window()
        w.show()
        w.hide()
        expect w.is_visible to_equal false

describe "BrowserWindow mutations":
    it "set_title updates":
        var w = _make_window()
        w.set_title("Updated")
        expect w.title to_equal "Updated"

    it "set_bounds updates":
        var w = _make_window()
        val new_bounds = SkRect(left: 0.0, top: 0.0, right: 640.0, bottom: 480.0)
        w.set_bounds(new_bounds)
        expect w.bounds.right to_equal 640.0
