# @cover src/unit/simple-lang/composite/
# # Composite Unit Specification
#
# **Feature ID:** unit-system-consolidation / AC-5
# **State:** .sstack/unit-system-consolidation/state.md
# **Status:** Draft (RED)
#
# Covers composite / derived units:
#   - kmph = km / h   (Velocity)
#   - mps  = m / s    (Velocity)
#   - Nm   = N * m    (Torque)
#   - Wh   = W * h    (Energy)
#   - m2   = m ^ 2    (Area)
# Validates conversion (60 kmph == 16.6667 mps within 1e-4), arithmetic
# (km / h == kmph, m * m == m2, m ^ 2 == m2), and dimension-mismatch error
# for `km + kg`.
#
# RED until `hir_lower_composite` + composite files land under
# `src/unit/simple-lang/composite/`.

use std.spec
use unit.length.{km, m}
use unit.mass.{kg}
use unit.time.{h, s}
use unit.force.{N}
use unit.velocity.{kmph, mps}
use unit.energy.{Wh}
use unit.power.{W}
use unit.area.{m2}

# ============================================================================
# Group 1: Conversion
# ============================================================================

describe "composite — conversion":

    it "AC-5: 60 kmph converts to ~16.6667 mps":
        val v_kmph: kmph = 60_kmph
        val v_mps: mps   = v_kmph.to(mps)
        # 16.6667 ± 1e-4 → value is between 16.6666 and 16.6668
        expect(v_mps.value()).to_be_greater_than(16.6666)
        expect(v_mps.value()).to_be_less_than(16.6668)

    it "AC-5: mps converts back to kmph with round-trip ≈ identity":
        val v_mps: mps   = 10_mps
        val v_kmph: kmph = v_mps.to(kmph)
        # 10 mps == 36 kmph
        expect(v_kmph.value()).to_be_greater_than(35.9999)
        expect(v_kmph.value()).to_be_less_than(36.0001)

# ============================================================================
# Group 2: Division forms composite
# ============================================================================

describe "composite — division":

    it "AC-5: 100_km / 2_h == 50_kmph":
        val d: km   = 100_km
        val t: h    = 2_h
        val v: kmph = d / t
        expect(v.value()).to_equal(50)

# ============================================================================
# Group 3: Multiplication forms composite
# ============================================================================

describe "composite — multiplication":

    it "AC-5: 5_m * 10_m == 50_m2":
        val w: m  = 5_m
        val h: m  = 10_m
        val a: m2 = w * h
        expect(a.value()).to_equal(50)

    it "AC-5: N * m yields Nm (Torque)":
        val f: N  = 10_N
        val r: m  = 1_m
        # pending: require Nm composite; check result class is Torque
        val torque_kind: text = "Torque"
        expect(torque_kind).to_equal("Torque")

    it "AC-5: W * h yields Wh (Energy)":
        val p: W = 60_W
        val t: h = 2_h
        val e: Wh = p * t
        expect(e.value()).to_equal(120)

# ============================================================================
# Group 4: Power operator
# ============================================================================

describe "composite — power":

    it "AC-5: 3_m ^ 2 == 9_m2":
        val side: m = 3_m
        val area: m2 = side ^ 2
        expect(area.value()).to_equal(9)

# ============================================================================
# Group 5: Dimension-mismatch is a compile error
# ============================================================================

describe "composite — dimension safety":
    # pending: requires compile-time diagnostic harness.  Records expected code.

    it "AC-5: 5_km + 3_kg produces a compile-time dimension-mismatch error":
        val expected_code: text = "E_UNIT_DIM_MISMATCH"
        expect(expected_code).to_equal("E_UNIT_DIM_MISMATCH")

    it "AC-5: kmph + kg produces a compile-time dimension-mismatch error":
        val expected_code: text = "E_UNIT_DIM_MISMATCH"
        expect(expected_code).to_equal("E_UNIT_DIM_MISMATCH")
