use std.spec.{describe, it, expect}
use std.common.compress.{CompressionError}
use std.common.compress.utilities.{
    CompressionSimdTier,
    decode_match_extension_length,
    append_literal_copy,
    append_self_overlap_copy,
    append_self_overlap_copy_for_tier,
    append_self_overlap_copy_scalar,
    append_self_overlap_copy_avx2,
    append_self_overlap_copy_neon,
    crc32_bytes,
    crc32_bytes_scalar,
    crc32_bytes_avx2,
    crc32_bytes_neon,
    xxhash32_bytes,
    xxhash32_bytes_scalar,
    xxhash32_bytes_avx2,
    xxhash32_bytes_neon
}

fn _expect_truncated(err: CompressionError, message_part: text):
    match err:
        CompressionError.TruncatedInput(message):
            expect (message).contains(message_part)
        CompressionError.InvalidHeader(message):
            expect "TruncatedInput" == "InvalidHeader: " + message
        CompressionError.UnsupportedFeature(message):
            expect "TruncatedInput" == "UnsupportedFeature: " + message
        CompressionError.ChecksumMismatch(message):
            expect "TruncatedInput" == "ChecksumMismatch: " + message
        CompressionError.CorruptStream(message):
            expect "TruncatedInput" == "CorruptStream: " + message
        CompressionError.SizeLimitExceeded(limit):
            expect "TruncatedInput" == "SizeLimitExceeded: " + limit.to_text()

fn _fixture_bytes() -> [u8]:
    "abcabcabcabcXYZ123abcabc".bytes()

describe "compression shared helper kernels":
    it "decodes repeated match extension bytes until a terminating lane":
        val decoded = decode_match_extension_length(15, [255u8, 255u8, 7u8], 0, "lz4 match extension")
        expect decoded.is_err() == false
        expect decoded.unwrap().length == 15 + 255 + 255 + 7
        expect decoded.unwrap().next_pos == 3

    it "fails closed when match extension bytes are truncated":
        val decoded = decode_match_extension_length(15, [255u8], 0, "lz4 match extension")
        expect decoded.is_err() == true
        _expect_truncated(decoded.unwrap_err(), "match extension")

    it "copies checked literal ranges and advances the cursor":
        val copied = append_literal_copy([0x00u8], _fixture_bytes(), 3, 6, "lz4 literal body")
        expect copied.is_err() == false
        expect copied.unwrap().out == [0x00u8, 0x61u8, 0x62u8, 0x63u8, 0x61u8, 0x62u8, 0x63u8]
        expect copied.unwrap().next_pos == 9

    it "fails closed when literal copy would read past the input":
        val copied = append_literal_copy([], _fixture_bytes(), 22, 4, "lz4 literal body")
        expect copied.is_err() == true
        _expect_truncated(copied.unwrap_err(), "literal body")

    it "keeps overlap-safe match copy parity across explicit scalar avx2 and neon entrypoints":
        val base = "ABCD".bytes()
        val scalar = append_self_overlap_copy_scalar(base, 4, 8)
        val avx2 = append_self_overlap_copy_avx2(base, 4, 8)
        val neon = append_self_overlap_copy_neon(base, 4, 8)
        val forced_scalar = append_self_overlap_copy_for_tier(base, 4, 8, CompressionSimdTier.scalar)
        val forced_avx2 = append_self_overlap_copy_for_tier(base, 4, 8, CompressionSimdTier.avx2)
        val forced_neon = append_self_overlap_copy_for_tier(base, 4, 8, CompressionSimdTier.neon)
        expect scalar.is_err() == false
        expect avx2.is_err() == false
        expect neon.is_err() == false
        expect forced_scalar.unwrap() == scalar.unwrap()
        expect forced_avx2.unwrap() == scalar.unwrap()
        expect forced_neon.unwrap() == scalar.unwrap()
        expect append_self_overlap_copy(base, 4, 8).unwrap() == scalar.unwrap()
        expect scalar.unwrap() == "ABCDABCDABCD".bytes()

    it "matches crc32 vectors across the forced-tier helper entrypoints":
        val bytes = _fixture_bytes()
        val scalar = crc32_bytes_scalar(bytes)
        expect scalar == crc32_bytes(bytes)
        expect crc32_bytes_avx2(bytes) == scalar
        expect crc32_bytes_neon(bytes) == scalar
        expect crc32_bytes_scalar("123456789".bytes()) == 0xCBF43926u32

    it "matches xxh32 vectors across the forced-tier helper entrypoints":
        val bytes = _fixture_bytes()
        val seed = 0x9747B28Cu32
        val scalar = xxhash32_bytes_scalar(bytes, seed)
        expect scalar == xxhash32_bytes(bytes, seed)
        expect xxhash32_bytes_avx2(bytes, seed) == scalar
        expect xxhash32_bytes_neon(bytes, seed) == scalar
        expect xxhash32_bytes_scalar("123456789".bytes(), 0u32) == 0x937BAD67u32