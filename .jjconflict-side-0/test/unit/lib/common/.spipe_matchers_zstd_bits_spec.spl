use std.spec.{describe, it, expect}
use std.common.compress.zstd_bits.{
    ZstdBackwardBits,
    zstd_read_u32_le,
    zstd_read_u64_le,
    zstd_bits_init,
    zstd_bits_peek,
    zstd_bits_consume,
    zstd_bits_read,
    zstd_bits_remaining
}
use std.common.compress.{CompressionError}

fn _expect_compression_error(err: CompressionError, kind: text, message_part: text):
    match err:
        CompressionError.InvalidHeader(message):
            expect kind == "InvalidHeader"
            expect (message).contains(message_part)
        CompressionError.UnsupportedFeature(message):
            expect kind == "UnsupportedFeature"
            expect (message).contains(message_part)
        CompressionError.TruncatedInput(message):
            expect kind == "TruncatedInput"
            expect (message).contains(message_part)
        CompressionError.ChecksumMismatch(message):
            expect kind == "ChecksumMismatch"
            expect (message).contains(message_part)
        CompressionError.CorruptStream(message):
            expect kind == "CorruptStream"
            expect (message).contains(message_part)
        CompressionError.SizeLimitExceeded(limit):
            expect kind == "SizeLimitExceeded"
            expect limit >= 0 == true

describe "zstd backward bit helpers":
    it "reads little-endian integers with bounded truncation checks":
        val data = [
            0x78u8, 0x56u8, 0x34u8, 0x12u8,
            0x08u8, 0x07u8, 0x06u8, 0x05u8,
            0x04u8, 0x03u8, 0x02u8, 0x01u8
        ]
        val word = zstd_read_u32_le(data, 0)
        expect word.is_err() == false
        expect word.unwrap() == 0x12345678u32
        val long = zstd_read_u64_le(data, 4)
        expect long.is_err() == false
        expect long.unwrap() == 0x0102030405060708u64
        val truncated = zstd_read_u32_le(data, 9)
        expect truncated.is_err() == true
        _expect_compression_error(truncated.unwrap_err(), "TruncatedInput", "4 bytes")

    it "peeks and consumes a reverse reservoir across the tail sentinel":
        val data = [0xABu8, 0xCDu8, 0x17u8]
        val init = zstd_bits_init(data, 0, data.len())
        expect init.is_err() == false
        val reader = init.unwrap()
        expect zstd_bits_remaining(reader) == 20
        val low = zstd_bits_peek(reader, 4)
        expect low.is_err() == false
        expect low.unwrap() == 0x07u32
        val after_low = zstd_bits_consume(reader, 4)
        expect after_low.is_err() == false
        val middle = zstd_bits_read(after_low.unwrap(), 8)
        expect middle.is_err() == false
        val (middle_byte, after_middle) = middle.unwrap()
        expect middle_byte == 0xCDu32
        val high = zstd_bits_peek(after_middle, 8)
        expect high.is_err() == false
        expect high.unwrap() == 0xABu32
        expect zstd_bits_remaining(after_middle) == 8

    it "fails closed on a missing tail mark":
        val init = zstd_bits_init([0xAAu8, 0x00u8], 0, 2)
        expect init.is_err() == true
        _expect_compression_error(init.unwrap_err(), "CorruptStream", "end mark")

    it "fails closed when the caller asks for more bits than remain":
        val init = zstd_bits_init([0x55u8, 0x01u8], 0, 2)
        expect init.is_err() == false
        val reader = init.unwrap()
        val full = zstd_bits_read(reader, 8)
        expect full.is_err() == false
        val (_byte, empty) = full.unwrap()
        val truncated = zstd_bits_peek(empty, 1)
        expect truncated.is_err() == true
        _expect_compression_error(truncated.unwrap_err(), "TruncatedInput", "bitstream bits")