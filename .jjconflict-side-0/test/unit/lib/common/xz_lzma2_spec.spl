use std.spec.{describe, it, expect}
use std.common.compress.{
    CompressionCodec,
    CompressionError,
    default_compression_options
}
use std.common.compress.lzma2.{lzma2_compress_xz, lzma2_compress_xz_for_tier, lzma2_decompress_xz, lzma2_decompress_xz_for_tier}
use std.common.compress.utilities.{CompressionSimdTier, crc32_bytes}
use std.io_runtime.{shell}

extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_file_read_bytes(path: text) -> [u8]

val TMP_ROOT = "/tmp/common_xz_lzma2_spec"

fn _expect_compression_error(err: CompressionError, kind: text, message_part: text):
    match err:
        CompressionError.InvalidHeader(message):
            expect(kind).to_equal("InvalidHeader")
            expect(message).to_contain(message_part)
        CompressionError.UnsupportedFeature(message):
            expect(kind).to_equal("UnsupportedFeature")
            expect(message).to_contain(message_part)
        CompressionError.TruncatedInput(message):
            expect(kind).to_equal("TruncatedInput")
            expect(message).to_contain(message_part)
        CompressionError.ChecksumMismatch(message):
            expect(kind).to_equal("ChecksumMismatch")
            expect(message).to_contain(message_part)
        CompressionError.CorruptStream(message):
            expect(kind).to_equal("CorruptStream")
            expect(message).to_contain(message_part)
        CompressionError.SizeLimitExceeded(limit):
            expect(kind).to_equal("SizeLimitExceeded")
            expect(limit >= 0).to_equal(true)

fn _write_bytes(path: text, data: [u8]):
    expect(rt_file_write_bytes(path, data)).to_equal(true)

fn _read_bytes(path: text) -> [u8]:
    rt_file_read_bytes(path) ?? []

fn _hex_encode(data: [u8]) -> text:
    val hex_chars = "0123456789abcdef"
    var out = ""
    var i = 0
    while i < data.len():
        val byte = data[i]
        out = out + hex_chars.char_at(((byte >> 4u8) & 0x0Fu8).to_i64())
        out = out + hex_chars.char_at((byte & 0x0Fu8).to_i64())
        i = i + 1
    out

fn _write_bytes_via_hex_shell(path: text, data: [u8]):
    val hex = _hex_encode(data)
    val run = shell("sh -c \"printf '%s' '" + hex + "' | xxd -r -p > '" + path + "'\"")
    if run.exit_code != 0:
        print(run.stdout)
        print(run.stderr)
    expect(run.exit_code).to_equal(0)

fn _ensure_tmp_root():
    val result = shell("mkdir -p '" + TMP_ROOT + "'")
    expect(result.exit_code).to_equal(0)

fn _payload(size: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < size:
        out.push((((i * 17) + (i / 13) + 23) % 251).to_u8())
        i = i + 1
    out

fn _repeat_byte(byte: u8, size: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < size:
        out.push(byte)
        i = i + 1
    out

fn _set_u32_le(data: [u8], pos: i64, value: u32) -> [u8]:
    var out = data
    out[pos] = (value & 0xFFu32).to_u8()
    out[pos + 1] = ((value >> 8) & 0xFFu32).to_u8()
    out[pos + 2] = ((value >> 16) & 0xFFu32).to_u8()
    out[pos + 3] = ((value >> 24) & 0xFFu32).to_u8()
    out

fn _read_vli(data: [u8], start: i64) -> (u64, i64):
    var value: u64 = 0u64
    var shift: u64 = 0u64
    var pos = start
    while true:
        val b = data[pos]
        value = value | ((b & 0x7Fu8).to_u64() << shift)
        pos = pos + 1
        if (b & 0x80u8) == 0u8:
            return (value, pos)
        shift = shift + 7u64

fn _first_block_header_size(data: [u8]) -> i64:
    (data[12].to_i64() + 1) * 4

fn _first_block_data_start(data: [u8]) -> i64:
    12 + _first_block_header_size(data)

fn _replace_first_chunk_prefix(data: [u8], prefix: [u8]) -> [u8]:
    var out = data
    val start = _first_block_data_start(data)
    var i = 0
    while i < prefix.len():
        out[start + i] = prefix[i]
        i = i + 1
    out

fn _first_filter_id_pos(data: [u8]) -> i64:
    var pos = 14
    val compressed = _read_vli(data, pos)
    pos = compressed.1
    val uncompressed = _read_vli(data, pos)
    pos = uncompressed.1
    pos

fn _repair_first_block_header_crc(data: [u8]) -> [u8]:
    val header_size = _first_block_header_size(data)
    val crc_pos = 12 + header_size - 4
    val crc = crc32_bytes(data.slice(12, crc_pos))
    _set_u32_le(data, crc_pos, crc)

fn _first_block_declared_compressed_size(data: [u8]) -> i64:
    _read_vli(data, 14).0.to_i64()

fn _first_block_check_pos(data: [u8]) -> i64:
    val start = _first_block_data_start(data)
    var pos = start + _first_block_declared_compressed_size(data)
    while (pos - start) % 4 != 0:
        pos = pos + 1
    pos

fn _read_u32_le_local(data: [u8], pos: i64) -> u32:
    data[pos].to_u32() |
        (data[pos + 1].to_u32() << 8) |
        (data[pos + 2].to_u32() << 16) |
        (data[pos + 3].to_u32() << 24)

fn _single_stream_crc64_check_pos(data: [u8]) -> i64:
    val footer_start = data.len() - 12
    val backward_size = ((_read_u32_le_local(data, footer_start + 4).to_i64()) + 1) * 4
    val index_start = footer_start - backward_size
    index_start - 8

describe "xz lzma2 codec":
    it "round-trips and host-xz decodes a framed stream":
        _ensure_tmp_root()
        val input = _payload(8192)
        val options = default_compression_options(CompressionCodec.lzma2)
        val encoded = lzma2_compress_xz(input, options)
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(false)
        expect(decoded.unwrap()).to_equal(input)

        val compressed_path = TMP_ROOT + "/multiblock.xz"
        val input_path = TMP_ROOT + "/multiblock.input"
        val output_path = TMP_ROOT + "/multiblock.out"
        _write_bytes_via_hex_shell(compressed_path, encoded)
        _write_bytes_via_hex_shell(input_path, input)
        val run = shell(
            "sh -c \"xz -q -d -f -c '" + compressed_path + "' > '" + output_path + "' && cmp -s '" + input_path + "' '" + output_path + "'\""
        )
        if run.exit_code != 0:
            print(run.stdout)
            print(run.stderr)
        expect(run.exit_code).to_equal(0)

    it "keeps xz framing and decode parity across scalar avx2 and neon tiers":
        val input = _payload(2048)
        val options = default_compression_options(CompressionCodec.lzma2)
        val scalar = lzma2_compress_xz_for_tier(input, options, CompressionSimdTier.scalar)
        val avx2 = lzma2_compress_xz_for_tier(input, options, CompressionSimdTier.avx2)
        val neon = lzma2_compress_xz_for_tier(input, options, CompressionSimdTier.neon)
        expect(avx2).to_equal(scalar)
        expect(neon).to_equal(scalar)
        expect(lzma2_compress_xz(input, options)).to_equal(scalar)
        expect(lzma2_decompress_xz_for_tier(scalar, CompressionSimdTier.scalar).unwrap()).to_equal(input)
        expect(lzma2_decompress_xz_for_tier(scalar, CompressionSimdTier.avx2).unwrap()).to_equal(input)
        expect(lzma2_decompress_xz_for_tier(scalar, CompressionSimdTier.neon).unwrap()).to_equal(input)

    it "emits a real compressed lzma2 chunk for repeated-byte runs when that beats the raw chunk":
        _ensure_tmp_root()
        val input = _repeat_byte(65u8, 275)
        val options = default_compression_options(CompressionCodec.lzma2)
        val encoded = lzma2_compress_xz(input, options)
        expect(encoded[_first_block_data_start(encoded)]).to_equal(0xE0u8)
        expect(_first_block_declared_compressed_size(encoded) < input.len()).to_equal(true)
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(false)
        expect(decoded.unwrap()).to_equal(input)

        val compressed_path = TMP_ROOT + "/repeat-byte-run.xz"
        val input_path = TMP_ROOT + "/repeat-byte-run.input"
        val output_path = TMP_ROOT + "/repeat-byte-run.out"
        _write_bytes_via_hex_shell(compressed_path, encoded)
        _write_bytes_via_hex_shell(input_path, input)
        val run = shell(
            "sh -c \"xz -q -d -f -c '" + compressed_path + "' > '" + output_path + "' && cmp -s '" + input_path + "' '" + output_path + "'\""
        )
        if run.exit_code != 0:
            print(run.stdout)
            print(run.stderr)
        expect(run.exit_code).to_equal(0)

    it "rejects misaligned xz stream padding":
        val options = default_compression_options(CompressionCodec.lzma2)
        val left = lzma2_compress_xz(_payload(64), options)
        val right = lzma2_compress_xz(_payload(96), options)
        val combined = left + [0x00u8] + right
        val decoded = lzma2_decompress_xz(combined)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "CorruptStream", "stream padding")

    it "decodes concatenated xz streams with aligned stream padding":
        val options = default_compression_options(CompressionCodec.lzma2)
        val left_payload = _payload(128)
        val right_payload = _payload(192)
        val left = lzma2_compress_xz(left_payload, options)
        val right = lzma2_compress_xz(right_payload, options)
        val combined = left + [0x00u8, 0x00u8, 0x00u8, 0x00u8] + right
        val decoded = lzma2_decompress_xz(combined)
        expect(decoded.is_err()).to_equal(false)
        expect(decoded.unwrap()).to_equal(left_payload + right_payload)

    it "rejects unsupported non-lzma2 filter chains with a typed error":
        val options = default_compression_options(CompressionCodec.lzma2)
        var encoded = lzma2_compress_xz(_payload(128), options)
        val filter_id_pos = _first_filter_id_pos(encoded)
        encoded[filter_id_pos] = 0x22u8
        encoded = _repair_first_block_header_crc(encoded)
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "UnsupportedFeature", "filter chains")

    it "rejects compressed lzma2 chunk controls explicitly":
        val options = default_compression_options(CompressionCodec.lzma2)
        var encoded = lzma2_compress_xz(_payload(128), options)
        encoded[_first_block_data_start(encoded)] = 0x80u8
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "CorruptStream", "dictionary reset")

    it "rejects invalid non-terminal lzma2 control bytes explicitly":
        val options = default_compression_options(CompressionCodec.lzma2)
        var encoded = lzma2_compress_xz(_payload(128), options)
        encoded[_first_block_data_start(encoded)] = 0x03u8
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "CorruptStream", "control")

    it "rejects compressed lzma2 chunks without required new properties in the first chunk":
        val options = default_compression_options(CompressionCodec.lzma2)
        val encoded = _replace_first_chunk_prefix(
            lzma2_compress_xz(_payload(128), options),
            [0xA0u8, 0x00u8, 0x00u8, 0x00u8, 0x04u8]
        )
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "CorruptStream", "properties")

    it "rejects too-short compressed lzma2 payloads after parsing their headers":
        val options = default_compression_options(CompressionCodec.lzma2)
        val encoded = _replace_first_chunk_prefix(
            lzma2_compress_xz(_payload(128), options),
            [0xE0u8, 0x00u8, 0x00u8, 0x00u8, 0x03u8, 0x00u8]
        )
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "CorruptStream", "compressed chunk size")

    it "rejects invalid compressed lzma2 property bytes":
        val options = default_compression_options(CompressionCodec.lzma2)
        val encoded = _replace_first_chunk_prefix(
            lzma2_compress_xz(_payload(128), options),
            [0xE0u8, 0x00u8, 0x00u8, 0x00u8, 0x04u8, 0x29u8]
        )
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "CorruptStream", "properties")

    it "rejects malformed compressed lzma2 range-decoder init bytes before unsupported-feature fallback":
        val options = default_compression_options(CompressionCodec.lzma2)
        val encoded = _replace_first_chunk_prefix(
            lzma2_compress_xz(_payload(128), options),
            [0xE0u8, 0x00u8, 0x00u8, 0x00u8, 0x04u8, 0x00u8, 0x01u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]
        )
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "CorruptStream", "range decoder init")

    it "parses compressed lzma2 chunk headers before falling back on body decode":
        # The fabricated chunk uses an unsupported props byte (0x00 -> LCLPPB
        # 0/0/0) that the new range decoder rejects with the explicit
        # LCLPPB-other-than-3/0/2 error string per the partial-LANDED scope.
        val options = default_compression_options(CompressionCodec.lzma2)
        val encoded = _replace_first_chunk_prefix(
            lzma2_compress_xz(_payload(128), options),
            [0xE0u8, 0x00u8, 0x00u8, 0x00u8, 0x04u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]
        )
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "UnsupportedFeature", "LZMA2 LCLPPB other than 3/0/2")

    it "reports footer crc corruption as a checksum mismatch":
        val options = default_compression_options(CompressionCodec.lzma2)
        var encoded = lzma2_compress_xz(_payload(128), options)
        encoded[encoded.len() - 12] = encoded[encoded.len() - 12] ^ 0x01u8
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "ChecksumMismatch", "footer crc32")

    it "reports header crc corruption as a checksum mismatch":
        val options = default_compression_options(CompressionCodec.lzma2)
        var encoded = lzma2_compress_xz(_payload(128), options)
        encoded[8] = encoded[8] ^ 0x01u8
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "ChecksumMismatch", "xz header crc32")

    it "reports block crc corruption as a checksum mismatch":
        val options = default_compression_options(CompressionCodec.lzma2)
        var encoded = lzma2_compress_xz(_payload(128), options)
        val check_pos = _first_block_check_pos(encoded)
        encoded[check_pos] = encoded[check_pos] ^ 0x01u8
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "ChecksumMismatch", "xz block crc32")

    it "reports host-default crc64 block corruption as a checksum mismatch":
        _ensure_tmp_root()
        val input = _payload(256)
        val input_path = TMP_ROOT + "/crc64-check-input.bin"
        val compressed_path = TMP_ROOT + "/crc64-check.xz"
        _write_bytes(input_path, input)
        val run = shell("xz -q -z -f -c '" + input_path + "' > '" + compressed_path + "'")
        if run.exit_code != 0:
            print(run.stdout)
            print(run.stderr)
        expect(run.exit_code).to_equal(0)
        var encoded = _read_bytes(compressed_path)
        val check_pos = _single_stream_crc64_check_pos(encoded)
        encoded[check_pos] = encoded[check_pos] ^ 0x01u8
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "ChecksumMismatch", "xz block crc64")

    it "reports index crc corruption as a checksum mismatch":
        val options = default_compression_options(CompressionCodec.lzma2)
        var encoded = lzma2_compress_xz(_payload(128), options)
        val footer_start = encoded.len() - 12
        encoded[footer_start - 1] = encoded[footer_start - 1] ^ 0x01u8
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "ChecksumMismatch", "xz index crc32")

    it "reports truncated block checks before unsupported compressed-chunk fallback":
        val options = default_compression_options(CompressionCodec.lzma2)
        var encoded = _replace_first_chunk_prefix(
            lzma2_compress_xz(_payload(128), options),
            [0xE0u8, 0x00u8, 0x00u8, 0x00u8, 0x04u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8]
        )
        encoded = encoded.slice(0, _first_block_check_pos(encoded) + 2)
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(true)
        _expect_compression_error(decoded.unwrap_err(), "TruncatedInput", "xz block check")

    it "decodes host-generated compressed xz streams via the pure-Simple range decoder":
        _ensure_tmp_root()
        val input = _payload(256)
        val input_path = TMP_ROOT + "/host-generated-input.bin"
        val compressed_path = TMP_ROOT + "/host-generated.xz"
        _write_bytes(input_path, input)
        val run = shell("xz -q -z -f -c '" + input_path + "' > '" + compressed_path + "'")
        if run.exit_code != 0:
            print(run.stdout)
            print(run.stderr)
        expect(run.exit_code).to_equal(0)
        val encoded = _read_bytes(compressed_path)
        val decoded = lzma2_decompress_xz(encoded)
        expect(decoded.is_err()).to_equal(false)
        expect(decoded.unwrap()).to_equal(input)
