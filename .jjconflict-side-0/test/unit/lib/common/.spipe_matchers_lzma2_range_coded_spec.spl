"""LZMA2 range-coded chunk decode interop spec.

Exercises the pure-Simple LZMA range decoder + LZMA2 chunk decoder restricted
to the `xz` default LCLPPB tuple (LC=3, LP=0, PB=2 -> props 0x5D). The
fixtures are pre-baked `xz -z --check=crc32` outputs of small test payloads;
keeping them as `[u8]` literals avoids spawning the host `xz` tool from this
spec and makes the test deterministic across hosts.

Status: LANDED 2026-05-01 (LCLPPB=3/0/2 only). See
`doc/08_tracking/feature_request/lzma2_full_lclppb_2026-05-01.md` for the
deferred-LCLPPB scope.
"""

use std.spec.{describe, it, expect}
use std.common.compress.{CompressionError}
use std.common.compress.lzma2.{lzma2_decompress_xz}
use std.io_runtime.{shell}

extern fn rt_file_write_bytes(path: text, data: [u8]) -> bool
extern fn rt_file_read_bytes(path: text) -> [u8]

val TMP_ROOT = "/tmp/lzma2_range_coded_spec"

fn _ensure_tmp_root():
    val result = shell("mkdir -p '" + TMP_ROOT + "'")
    expect result.exit_code == 0

fn _payload(size: i64) -> [u8]:
    """Deterministic synthetic payload identical to the existing xz-lzma2
    spec, so failures in this spec are directly comparable."""
    var out: [u8] = []
    var i = 0
    while i < size:
        out.push((((i * 17) + (i / 13) + 23) % 251).to_u8())
        i = i + 1
    out

fn _repetitive_payload(size: i64) -> [u8]:
    """Highly compressible payload to exercise non-trivial match/rep paths."""
    var out: [u8] = []
    val phrase: [u8] = [
        72u8, 101u8, 108u8, 108u8, 111u8, 44u8, 32u8, 87u8,
        111u8, 114u8, 108u8, 100u8, 33u8, 32u8
    ]
    while out.len() < size:
        var i = 0
        while i < phrase.len() and out.len() < size:
            out.push(phrase[i])
            i = i + 1
    out

# Pre-baked `xz -q -z -f --check=crc32 -c` of the 16-byte string "AAAAAAAAAAAAAAAA"
# (16 ASCII 'A'). A single range-coded LZMA2 chunk with control 0xE0, props 0x5D.
val FIXTURE_AAAA_INPUT_LEN: i64 = 16
val FIXTURE_AAAA_XZ: [u8] = [
    0xFDu8, 0x37u8, 0x7Au8, 0x58u8, 0x5Au8, 0x00u8, 0x00u8, 0x01u8,
    0x69u8, 0x22u8, 0xDEu8, 0x36u8, 0x02u8, 0x00u8, 0x21u8, 0x01u8,
    0x16u8, 0x00u8, 0x00u8, 0x00u8, 0x74u8, 0x2Fu8, 0xE5u8, 0xA3u8,
    0xE0u8, 0x00u8, 0x0Fu8, 0x00u8, 0x06u8, 0x5Du8, 0x00u8, 0x20u8,
    0xEDu8, 0x3Cu8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8,
    0x0Bu8, 0x57u8, 0x04u8, 0xBBu8, 0x00u8, 0x01u8, 0x1Eu8, 0x10u8,
    0x90u8, 0x9Au8, 0x70u8, 0xE9u8, 0x90u8, 0x42u8, 0x99u8, 0x0Du8,
    0x01u8, 0x00u8, 0x00u8, 0x00u8, 0x00u8, 0x01u8, 0x59u8, 0x5Au8
]

fn _expected_aaaa() -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < FIXTURE_AAAA_INPUT_LEN:
        out.push(65u8)  # 'A'
        i = i + 1
    out

describe "lzma2 range-coded chunk decode (LCLPPB 3/0/2)":

    it "decodes a 16-byte highly-repetitive xz fixture byte-for-byte":
        # Mostly-literal first byte then a single match: smallest interesting
        # range-coded chunk we can land deterministically without invoking a
        # host tool.
        val decoded = lzma2_decompress_xz(FIXTURE_AAAA_XZ)
        expect decoded.is_err() == false
        expect decoded.unwrap() == _expected_aaaa()

    it "round-trips synthetic 256-byte payload through host xz with crc32":
        # Exercises pos-slot >= 14 distance decode (direct + align bits) which
        # is where the u32 wrap-around bug originally surfaced before the
        # range decoder was ported.
        _ensure_tmp_root()
        val input = _payload(256)
        val input_path = TMP_ROOT + "/p256.bin"
        val xz_path = TMP_ROOT + "/p256.xz"
        expect rt_file_write_bytes(input_path, input) == true
        val run = shell("xz -q -z -f --check=crc32 -c '" + input_path + "' > '" + xz_path + "'")
        expect run.exit_code == 0
        val encoded = rt_file_read_bytes(xz_path) ?? []
        val decoded = lzma2_decompress_xz(encoded)
        expect decoded.is_err() == false
        expect decoded.unwrap() == input

    it "round-trips a 1024-byte repetitive payload through host xz with crc32":
        # Highly compressible -- lots of rep0/rep1 hits, exercises the
        # short-rep + matched-literal codepaths.
        _ensure_tmp_root()
        val input = _repetitive_payload(1024)
        val input_path = TMP_ROOT + "/rep1024.bin"
        val xz_path = TMP_ROOT + "/rep1024.xz"
        expect rt_file_write_bytes(input_path, input) == true
        val run = shell("xz -q -z -f --check=crc32 -c '" + input_path + "' > '" + xz_path + "'")
        expect run.exit_code == 0
        val encoded = rt_file_read_bytes(xz_path) ?? []
        val decoded = lzma2_decompress_xz(encoded)
        expect decoded.is_err() == false
        expect decoded.unwrap() == input

    it "rejects host-default xz (CRC64 check) with the existing typed error":
        # CRC64 is the host default; our facade still requires CRC32 so the
        # range decoder never fires. This pins the boundary.
        _ensure_tmp_root()
        val input = _payload(64)
        val input_path = TMP_ROOT + "/crc64.bin"
        val xz_path = TMP_ROOT + "/crc64.xz"
        expect rt_file_write_bytes(input_path, input) == true
        val run = shell("xz -q -z -f -c '" + input_path + "' > '" + xz_path + "'")
        expect run.exit_code == 0
        val encoded = rt_file_read_bytes(xz_path) ?? []
        val decoded = lzma2_decompress_xz(encoded)
        expect decoded.is_err() == true
        match decoded.unwrap_err():
            CompressionError.UnsupportedFeature(message):
                expect (message).contains("crc32")
            CompressionError.InvalidHeader(message):
                expect (message).contains("crc")
            CompressionError.CorruptStream(message):
                expect (message).contains("crc")
            CompressionError.TruncatedInput(message):
                expect false == true
            CompressionError.ChecksumMismatch(message):
                expect false == true
            CompressionError.SizeLimitExceeded(limit):
                expect false == true