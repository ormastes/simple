use lib.common.date.types.*
use lib.common.date.format.*
use lib.common.date.calculate.*

# Local wrappers for locale month_name/day_name to avoid name collision with date/types.spl
fn locale_month_name(month: i64, locale: (text, text, text, text)) -> text:
    var lang = locale.0
    if lang == "fr":
        if month == 1: return "janvier"
        if month == 2: return "février"
        if month == 3: return "mars"
        if month == 4: return "avril"
        if month == 5: return "mai"
        if month == 6: return "juin"
        if month == 7: return "juillet"
        if month == 8: return "août"
        if month == 9: return "septembre"
        if month == 10: return "octobre"
        if month == 11: return "novembre"
        if month == 12: return "décembre"
        return ""
    if lang == "es":
        if month == 1: return "enero"
        if month == 2: return "febrero"
        if month == 3: return "marzo"
        if month == 4: return "abril"
        if month == 5: return "mayo"
        if month == 6: return "junio"
        if month == 7: return "julio"
        if month == 8: return "agosto"
        if month == 9: return "septiembre"
        if month == 10: return "octubre"
        if month == 11: return "noviembre"
        if month == 12: return "diciembre"
        return ""
    if lang == "de":
        if month == 1: return "Januar"
        if month == 2: return "Februar"
        if month == 3: return "März"
        if month == 4: return "April"
        if month == 5: return "Mai"
        if month == 6: return "Juni"
        if month == 7: return "Juli"
        if month == 8: return "August"
        if month == 9: return "September"
        if month == 10: return "Oktober"
        if month == 11: return "November"
        if month == 12: return "Dezember"
        return ""
    if month == 1: return "January"
    if month == 2: return "February"
    if month == 3: return "March"
    if month == 4: return "April"
    if month == 5: return "May"
    if month == 6: return "June"
    if month == 7: return "July"
    if month == 8: return "August"
    if month == 9: return "September"
    if month == 10: return "October"
    if month == 11: return "November"
    if month == 12: return "December"
    ""

fn locale_day_name(day: i64, locale: (text, text, text, text)) -> text:
    var lang = locale.0
    if lang == "fr":
        if day == 1: return "lundi"
        if day == 2: return "mardi"
        if day == 3: return "mercredi"
        if day == 4: return "jeudi"
        if day == 5: return "vendredi"
        if day == 6: return "samedi"
        if day == 7: return "dimanche"
        return ""
    if lang == "es":
        if day == 1: return "lunes"
        if day == 2: return "martes"
        if day == 3: return "miércoles"
        if day == 4: return "jueves"
        if day == 5: return "viernes"
        if day == 6: return "sábado"
        if day == 7: return "domingo"
        return ""
    if lang == "de":
        if day == 1: return "Montag"
        if day == 2: return "Dienstag"
        if day == 3: return "Mittwoch"
        if day == 4: return "Donnerstag"
        if day == 5: return "Freitag"
        if day == 6: return "Samstag"
        if day == 7: return "Sonntag"
        return ""
    if day == 1: return "Monday"
    if day == 2: return "Tuesday"
    if day == 3: return "Wednesday"
    if day == 4: return "Thursday"
    if day == 5: return "Friday"
    if day == 6: return "Saturday"
    if day == 7: return "Sunday"
    ""

fn locale_month_name_short(month: i64, locale: (text, text, text, text)) -> text:
    var full = locale_month_name(month, locale)
    if full.length() >= 3:
        return full.substring(0, 3)
    return full

fn locale_day_name_short(day: i64, locale: (text, text, text, text)) -> text:
    var full = locale_day_name(day, locale)
    if full.length() >= 3:
        return full.substring(0, 3)
    return full

fn locale_format_date(year: i64, month: i64, day: i64, pattern: text, locale: (text, text, text, text)) -> text:
    var result = pattern
    var year_str = year.to_text()
    result = result.replace("yyyy", year_str)
    var month_full = locale_month_name(month, locale)
    result = result.replace("MMMM", month_full)
    var month_short = locale_month_name_short(month, locale)
    result = result.replace("MMM", month_short)
    var month_str = month.to_text()
    if month < 10:
        month_str = "0" + month_str
    result = result.replace("MM", month_str)
    var day_str = day.to_text()
    if day < 10:
        day_str = "0" + day_str
    result = result.replace("dd", day_str)
    return result

fn locale_format_time(hour: i64, minute: i64, second: i64, pattern: text, locale: (text, text, text, text)) -> text:
    var result = pattern
    var hour_str = hour.to_text()
    if hour < 10:
        hour_str = "0" + hour_str
    result = result.replace("HH", hour_str)
    var hour_12 = hour % 12
    if hour_12 == 0:
        hour_12 = 12
    var hour_12_str = hour_12.to_text()
    if hour_12 < 10:
        hour_12_str = "0" + hour_12_str
    result = result.replace("hh", hour_12_str)
    var ampm = "AM"
    if hour >= 12:
        ampm = "PM"
    result = result.replace("a", ampm)
    var minute_str = minute.to_text()
    if minute < 10:
        minute_str = "0" + minute_str
    result = result.replace("mm", minute_str)
    var second_str = second.to_text()
    if second < 10:
        second_str = "0" + second_str
    result = result.replace("ss", second_str)
    return result

fn locale_relative_time_seconds(seconds: i64, locale: (text, text, text, text)) -> text:
    var lang = locale.0
    var abs_seconds = seconds
    if abs_seconds < 0:
        abs_seconds = 0 - abs_seconds
    var future = seconds > 0
    if abs_seconds < 60:
        if lang == "fr":
            if future: return "dans quelques secondes"
            return "il y a quelques secondes"
        if lang == "es":
            if future: return "en unos segundos"
            return "hace unos segundos"
        if future: return "in a few seconds"
        return "a few seconds ago"
    if abs_seconds < 3600:
        var minutes = abs_seconds / 60
        var min_str = minutes.to_text()
        if lang == "fr":
            if future: return "dans " + min_str + " minutes"
            return "il y a " + min_str + " minutes"
        if lang == "es":
            if future: return "en " + min_str + " minutos"
            return "hace " + min_str + " minutos"
        if future: return "in " + min_str + " minutes"
        return min_str + " minutes ago"
    if abs_seconds < 86400:
        var hours = abs_seconds / 3600
        var hour_str = hours.to_text()
        if lang == "fr":
            if future: return "dans " + hour_str + " heures"
            return "il y a " + hour_str + " heures"
        if lang == "es":
            if future: return "en " + hour_str + " horas"
            return "hace " + hour_str + " horas"
        if future: return "in " + hour_str + " hours"
        return hour_str + " hours ago"
    var days = abs_seconds / 86400
    var day_str = days.to_text()
    if lang == "fr":
        if future: return "dans " + day_str + " jours"
        return "il y a " + day_str + " jours"
    if lang == "es":
        if future: return "en " + day_str + " días"
        return "hace " + day_str + " días"
    if future: return "in " + day_str + " days"
    return day_str + " days ago"

fn locale_time_ago(seconds: i64, locale: (text, text, text, text)) -> text:
    return locale_relative_time_seconds(seconds, locale)

fn locale_time_until(seconds: i64, locale: (text, text, text, text)) -> text:
    return locale_relative_time_seconds(seconds, locale)

# Local wrapper for date to_string to avoid builtin shadowing
fn date_to_string(date: any) -> text:
    var year = date[0]
    var month = date[1]
    var day = date[2]
    var year_str = text_from_i64(year)
    var month_str = text_from_i64(month)
    var day_str = text_from_i64(day)
    if month < 10:
        month_str = "0" + month_str
    if day < 10:
        day_str = "0" + day_str
    return year_str + "-" + month_str + "-" + day_str

fn check(condition: bool):
    expect(condition).to_equal(true)

# ============================================================================
# Test Group 1: date/types.spl - Constants and Day/Month Names
# ============================================================================

describe "Date Format - text_from_i64 helper":
    it "converts zero":
        expect(text_from_i64(0)).to_equal("0")

    it "converts positive number":
        expect(text_from_i64(42)).to_equal("42")

    it "converts negative number":
        expect(text_from_i64(-7)).to_equal("-7")

    it "converts single digit":
        expect(text_from_i64(5)).to_equal("5")

    it "converts large number":
        expect(text_from_i64(2025)).to_equal("2025")

# ============================================================================
# Test Group 11: date/calculate.spl - Date Arithmetic
# ============================================================================


describe "Date Calculate - to_days":
    it "converts epoch to day 1":
        expect(to_days((1, 1, 1))).to_equal(1)

    it "converts Jan 31 year 1 to day 31":
        expect(to_days((1, 1, 31))).to_equal(31)

    it "converts Feb 1 year 1 to day 32":
        expect(to_days((1, 2, 1))).to_equal(32)

    it "handles year crossing":
        # Year 1 has 365 days, so Jan 1 year 2 = day 366
        expect(to_days((2, 1, 1))).to_equal(366)

    it "handles leap year in calculation":
        # Year 4 is leap: days = 365*3 + 366 + 1 = 1462
        expect(to_days((5, 1, 1))).to_equal(1462)


describe "Date Calculate - add_days":
    it "adds days to a date":
        var result = add_days((2025, 1, 1), 10)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(1)
        expect(result[2]).to_equal(11)

    it "adds days crossing month boundary":
        var result = add_days((2025, 1, 30), 5)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(4)

    it "returns nil when result is before epoch":
        var result = add_days((1, 1, 1), -5)
        expect(result).to_equal(nil)


describe "Date Calculate - subtract_days":
    it "subtracts days from a date":
        var result = subtract_days((2025, 1, 15), 5)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(1)
        expect(result[2]).to_equal(10)


describe "Date Calculate - difference_in_days":
    it "returns positive for later date first":
        var diff = difference_in_days((2025, 1, 15), (2025, 1, 10))
        expect(diff).to_equal(5)

    it "returns negative for earlier date first":
        var diff = difference_in_days((2025, 1, 10), (2025, 1, 15))
        expect(diff).to_equal(-5)

    it "returns zero for same date":
        var diff = difference_in_days((2025, 1, 15), (2025, 1, 15))
        expect(diff).to_equal(0)


describe "Date Calculate - add_months":
    it "adds months within same year":
        var result = add_months((2025, 1, 15), 3)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(4)
        expect(result[2]).to_equal(15)

    it "adds months crossing year boundary":
        var result = add_months((2025, 11, 15), 3)
        expect(result[0]).to_equal(2026)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(15)

    it "clamps day when new month has fewer days":
        # Jan 31 + 1 month -> Feb 28 (2025 non-leap)
        var result = add_months((2025, 1, 31), 1)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(28)

    it "handles negative months":
        var result = add_months((2025, 3, 15), -2)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(1)
        expect(result[2]).to_equal(15)

    it "handles negative months crossing year boundary":
        var result = add_months((2025, 2, 15), -3)
        expect(result[0]).to_equal(2024)
        expect(result[1]).to_equal(11)
        expect(result[2]).to_equal(15)


describe "Date Calculate - subtract_months":
    it "subtracts months":
        var result = subtract_months((2025, 6, 15), 3)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(3)
        expect(result[2]).to_equal(15)


describe "Date Calculate - add_years":
    it "adds years to a normal date":
        var result = add_years((2025, 6, 15), 2)
        expect(result[0]).to_equal(2027)
        expect(result[1]).to_equal(6)
        expect(result[2]).to_equal(15)

    it "handles Feb 29 landing on non-leap year":
        # 2024 is leap, 2025 is not
        var result = add_years((2024, 2, 29), 1)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(28)

    it "handles Feb 29 landing on leap year":
        # 2024 is leap, 2028 is also leap
        var result = add_years((2024, 2, 29), 4)
        expect(result[0]).to_equal(2028)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(29)

    it "does not adjust non-Feb dates":
        var result = add_years((2024, 3, 15), 1)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(3)
        expect(result[2]).to_equal(15)

    it "does not adjust Feb 28":
        var result = add_years((2024, 2, 28), 1)
        expect(result[0]).to_equal(2025)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(28)


describe "Date Calculate - subtract_years":
    it "subtracts years":
        var result = subtract_years((2025, 6, 15), 5)
        expect(result[0]).to_equal(2020)

# ============================================================================
# Test Group 12: date/calculate.spl - Date Comparison
# ============================================================================


describe "Date Calculate - Comparison":
    context "equal":
        it "returns true for same dates":
            expect(equal((2025, 1, 15), (2025, 1, 15))).to_equal(true)

        it "returns false for different years":
            expect(equal((2025, 1, 15), (2024, 1, 15))).to_equal(false)

        it "returns false for different months":
            expect(equal((2025, 1, 15), (2025, 2, 15))).to_equal(false)

        it "returns false for different days":
            expect(equal((2025, 1, 15), (2025, 1, 16))).to_equal(false)

    context "before":
        it "returns true when date1 is earlier":
            expect(before((2025, 1, 1), (2025, 1, 2))).to_equal(true)

        it "returns false when date1 is later":
            expect(before((2025, 1, 2), (2025, 1, 1))).to_equal(false)

        it "returns false for same date":
            expect(before((2025, 1, 1), (2025, 1, 1))).to_equal(false)

    context "after":
        it "returns true when date1 is later":
            expect(after((2025, 1, 2), (2025, 1, 1))).to_equal(true)

        it "returns false when date1 is earlier":
            expect(after((2025, 1, 1), (2025, 1, 2))).to_equal(false)

        it "returns false for same date":
            expect(after((2025, 1, 1), (2025, 1, 1))).to_equal(false)

    context "compare":
        it "returns -1 for before":
            expect(compare((2025, 1, 1), (2025, 1, 2))).to_equal(-1)

        it "returns 1 for after":
            expect(compare((2025, 1, 2), (2025, 1, 1))).to_equal(1)

        it "returns 0 for equal":
            expect(compare((2025, 1, 1), (2025, 1, 1))).to_equal(0)

    context "before_or_equal":
        it "returns true for before":
            expect(before_or_equal((2025, 1, 1), (2025, 1, 2))).to_equal(true)

        it "returns true for equal":
            expect(before_or_equal((2025, 1, 1), (2025, 1, 1))).to_equal(true)

        it "returns false for after":
            expect(before_or_equal((2025, 1, 2), (2025, 1, 1))).to_equal(false)

    context "after_or_equal":
        it "returns true for after":
            expect(after_or_equal((2025, 1, 2), (2025, 1, 1))).to_equal(true)

        it "returns true for equal":
            expect(after_or_equal((2025, 1, 1), (2025, 1, 1))).to_equal(true)

        it "returns false for before":
            expect(after_or_equal((2025, 1, 1), (2025, 1, 2))).to_equal(false)

# ============================================================================
# Test Group 13: date/calculate.spl - Calendar Navigation
# ============================================================================


describe "Date Calculate - Calendar Navigation":
    context "first_day_of_month":
        it "returns first day":
            var result = first_day_of_month((2025, 3, 15))
            expect(result[2]).to_equal(1)
            expect(result[1]).to_equal(3)

    context "last_day_of_month":
        it "returns 31 for January":
            var result = last_day_of_month((2025, 1, 15))
            expect(result[2]).to_equal(31)

        it "returns 28 for February non-leap":
            var result = last_day_of_month((2025, 2, 10))
            expect(result[2]).to_equal(28)

        it "returns 29 for February leap":
            var result = last_day_of_month((2024, 2, 10))
            expect(result[2]).to_equal(29)

    context "first_day_of_year":
        it "returns January 1":
            var result = first_day_of_year((2025, 6, 15))
            expect(result[1]).to_equal(1)
            expect(result[2]).to_equal(1)

    context "last_day_of_year":
        it "returns December 31":
            var result = last_day_of_year((2025, 6, 15))
            expect(result[1]).to_equal(12)
            expect(result[2]).to_equal(31)

    context "first_day_of_quarter":
        it "returns Jan 1 for Q1":
            var result = first_day_of_quarter((2025, 2, 15))
            expect(result[1]).to_equal(1)
            expect(result[2]).to_equal(1)

        it "returns Apr 1 for Q2":
            var result = first_day_of_quarter((2025, 5, 15))
            expect(result[1]).to_equal(4)
            expect(result[2]).to_equal(1)

        it "returns Jul 1 for Q3":
            var result = first_day_of_quarter((2025, 8, 15))
            expect(result[1]).to_equal(7)
            expect(result[2]).to_equal(1)

        it "returns Oct 1 for Q4":
            var result = first_day_of_quarter((2025, 11, 15))
            expect(result[1]).to_equal(10)
            expect(result[2]).to_equal(1)

    context "last_day_of_quarter":
        it "returns Mar 31 for Q1":
            var result = last_day_of_quarter((2025, 2, 15))
            expect(result[1]).to_equal(3)
            expect(result[2]).to_equal(31)

        it "returns Jun 30 for Q2":
            var result = last_day_of_quarter((2025, 5, 15))
            expect(result[1]).to_equal(6)
            expect(result[2]).to_equal(30)

        it "returns Sep 30 for Q3":
            var result = last_day_of_quarter((2025, 8, 15))
            expect(result[1]).to_equal(9)
            expect(result[2]).to_equal(30)

        it "returns Dec 31 for Q4":
            var result = last_day_of_quarter((2025, 11, 15))
            expect(result[1]).to_equal(12)
            expect(result[2]).to_equal(31)

# ============================================================================
# Test Group 14: date/calculate.spl - nth_day_of_month and relatives
# ============================================================================


describe "Date Calculate - Nth Day of Month":
    it "finds 1st Monday of January 2025":
        # Jan 1, 2025 is Wednesday, so 1st Monday is Jan 6
        var result = nth_day_of_month((2025, 1, 1), 1, 1)
        check(result != nil)
        expect(result[2]).to_equal(6)

    it "finds 2nd Friday of January 2025":
        var result = nth_day_of_month((2025, 1, 1), 2, 5)
        check(result != nil)
        expect(result[2]).to_equal(10)

    it "returns nil for 5th Monday when it does not exist":
        # Not every month has a 5th Monday
        var result = nth_day_of_month((2025, 2, 1), 5, 1)
        expect(result).to_equal(nil)
