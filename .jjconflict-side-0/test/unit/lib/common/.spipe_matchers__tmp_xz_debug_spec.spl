use std.spec.{describe, it, expect}
use std.common.compress.{CompressionCodec, default_compression_options}
use std.common.compress.lzma2.{lzma2_compress_xz, lzma2_decompress_xz}

fn _payload(size: i64) -> [u8]:
    var out: [u8] = []
    var i = 0
    while i < size:
        out.push((((i * 17) + (i / 13) + 23) % 251).to_u8())
        i = i + 1
    out

describe "tmp xz debug":
    it "compresses":
        val encoded = lzma2_compress_xz(_payload(64), default_compression_options(CompressionCodec.lzma2))
        expect encoded.len() > 0 == true

    it "decompresses":
        val input = _payload(64)
        val encoded = lzma2_compress_xz(input, default_compression_options(CompressionCodec.lzma2))
        val decoded = lzma2_decompress_xz(encoded)
        expect decoded.is_err() == false
        expect decoded.unwrap() == input