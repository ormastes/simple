# @covers src/lib/common/math_repr.spl 85%
"""
# Math Repr Tokenizer Coverage

**Feature IDs:** #LIB-MATH-COV
**Category:** Stdlib
**Status:** Implemented

## Overview

Tests for tokenizer edge cases, branch gaps, operator paths,
number tokenization, and underscore alpha coverage.
"""

use std.math_repr.{to_text, to_debug, to_pretty, to_md, render_latex_raw}

# ============================================================================
# 5. math_repr — Tokenizer edge cases
# ============================================================================

describe "math_repr tokenizer edges":
    """
    ## Tokenizer Edge Cases

    Exercises less common tokenizer branches: dots, brackets, commas,
    whitespace handling, and unknown characters.
    """

    context "whitespace handling":
        it "handles extra spaces":
            expect(to_text("x  +  y")).to_equal("x + y")

        it "handles tabs":
            expect(to_text("x\t+\ty")).to_equal("x + y")

    context "dot and range tokens":
        it "handles dot-dot range in sum":
            val result = to_text("sum(i, 1..10) i")
            expect(result).to_contain("..")

    context "bracket tokens":
        it "handles square brackets for subscript":
            expect(to_text("a[0]")).to_equal("a[0]")

    context "comma tokens":
        it "handles commas in function args":
            expect(to_text("f(a, b, c)")).to_equal("f(a, b, c)")

    context "unknown characters":
        it "skips unknown characters gracefully":
            val result = to_text("x + y")
            expect(result).to_contain("x")
            expect(result).to_contain("y")

    context "empty input":
        it "handles empty string with fallback":
            # Empty input produces eof token; parser fallback returns "?" node
            val result = to_text("")
            expect(result).to_equal("?")


# ============================================================================
# 11. Tokenizer branch coverage gaps
# ============================================================================

describe "math_repr tokenizer branch gaps":
    """
    ## Tokenizer Branch Coverage

    Exercises tokenizer branches that were missed: standalone dot followed
    by non-dot char, decimal number before range operator, and specific
    operator paths.
    """

    context "dot followed by non-dot character":
        it "handles dot followed by identifier":
            val result = to_text("x.y")
            expect(result).to_contain("x")

    context "decimal number before range":
        it "handles number with decimal part":
            val result = to_text("3.14")
            expect(result).to_equal("3.14")

    context "division operator tokenization":
        it "tokenizes division in complex expression":
            val result = to_text("a / b + c")
            expect(result).to_contain("/")

        it "tokenizes multiple divisions":
            val result = to_text("a / b / c")
            expect(result).to_contain("/")

    context "parentheses tokenization":
        it "tokenizes nested parens":
            val result = to_text("((a + b))")
            expect(result).to_contain("(")
            expect(result).to_contain(")")

    context "bracket tokenization standalone":
        it "tokenizes brackets in subscript":
            val result = to_text("a[b]")
            expect(result).to_contain("[")
            expect(result).to_contain("]")

    context "comma tokenization":
        it "tokenizes commas in multi-arg function":
            val result = to_text("f(a, b, c)")
            expect(result).to_contain(",")

    context "unknown character skipping":
        it "skips at sign":
            val result = to_text("a @ b")
            expect(result).to_contain("a")

        it "skips hash character":
            val result = to_text("a # b")
            expect(result).to_contain("a")

    context "underscore in identifiers":
        it "tokenizes identifier starting with underscore":
            val result = to_text("_x")
            expect(result).to_contain("x")

        it "tokenizes identifier with embedded underscore":
            val result = to_text("a_b")
            expect(result).to_contain("a")

    context "is_alnum exercising is_digit false then is_alpha":
        it "exercises alnum branch for letter after number in ident":
            val result = to_text("x1y")
            expect(result).to_contain("x1y")


# ============================================================================
# 17. Tokenizer paths - ensure every operator char goes through tokenizer
# ============================================================================

describe "math_repr tokenizer operator paths":
    """
    ## Tokenizer Operator Paths

    Each operator character must be tokenized. This exercises the specific
    elif branches in _tokenize for each character type.
    """

    context "each operator individually":
        it "tokenizes plus only":
            val result = to_debug("1 + 2")
            expect(result).to_equal("Add(Num(1), Num(2))")

        it "tokenizes minus only":
            val result = to_debug("1 - 2")
            expect(result).to_equal("Sub(Num(1), Num(2))")

        it "tokenizes star only":
            val result = to_debug("1 * 2")
            expect(result).to_equal("Mul(Num(1), Num(2))")

        it "tokenizes slash only":
            val result = to_debug("1 / 2")
            expect(result).to_equal("Div(Num(1), Num(2))")

        it "tokenizes caret only":
            val result = to_debug("1^2")
            expect(result).to_equal("Pow(Num(1), Num(2))")

        it "tokenizes apostrophe only":
            val result = to_debug("x'")
            expect(result).to_contain("Transpose")

        it "tokenizes open paren only":
            val result = to_debug("(x)")
            expect(result).to_contain("Group")

        it "tokenizes close paren":
            val result = to_debug("(1)")
            expect(result).to_contain("Group")

        it "tokenizes open bracket":
            val result = to_debug("x[1]")
            expect(result).to_contain("Sub")

        it "tokenizes close bracket":
            val result = to_debug("a[0]")
            expect(result).to_contain("Sub")

        it "tokenizes comma in args":
            val result = to_debug("f(1, 2)")
            expect(result).to_contain("Call")

    context "expressions with only division":
        it "division-only expression":
            val result = to_text("10 / 5")
            expect(result).to_equal("10 / 5")

        it "division via pretty":
            val result = to_pretty("10 / 5")
            expect(result).to_contain("/")

        it "division via latex":
            val result = render_latex_raw("10 / 5")
            expect(result).to_contain("/")

    context "expressions with only parens and brackets":
        it "paren-only expression via text":
            val result = to_text("(1)")
            expect(result).to_equal("(1)")

        it "bracket-only expression via text":
            val result = to_text("x[0]")
            expect(result).to_equal("x[0]")


# ============================================================================
# 22. Number tokenization edge cases for decimal/range boundary
# ============================================================================

describe "math_repr number tokenization edges":
    """
    ## Number Tokenization Edges

    Exercises the decimal dot and range boundary in number tokenization.
    Specifically: decimal number followed by ".." range should not consume
    the dots as decimal.
    """

    context "number-dot-dot boundary":
        it "integer before range is not decimal":
            val result = to_debug("sum(i, 5..10) i")
            expect(result).to_contain("Num(5)")
            expect(result).to_contain("Num(10)")

        it "decimal number in simple expression":
            val result = to_debug("3.14")
            expect(result).to_equal("Num(3.14)")

        it "decimal followed by operator":
            val result = to_debug("3.14 + 1")
            expect(result).to_contain("Num(3.14)")

    context "single dot tokenization":
        it "dot between identifiers":
            val result = to_text("a.b")
            expect(result).to_contain("a")

        it "dot at end of input":
            val result = to_text("x.")
            expect(result).to_contain("x")

        it "standalone dot":
            val result = to_text(".")
            expect(result).to_contain("?")


# ============================================================================
# 23. _is_alpha underscore coverage
# ============================================================================

describe "math_repr underscore alpha coverage":
    """
    ## Underscore Alpha Coverage

    The underscore check in _is_alpha must evaluate to TRUE.
    """

    context "underscore as first alpha character":
        it "underscore-only identifier":
            # Underscore is alpha in _is_alpha; tokenized as identifier
            # But the output might strip leading underscore
            val result = to_text("_")
            expect(result).to_contain("?")

        it "underscore with trailing letters":
            # a_b is one identifier token since _ is alnum
            val result = to_text("a_b")
            expect(result).to_contain("a")

        it "underscore in middle of identifier":
            val result = to_text("x_y")
            expect(result).to_contain("x")


# ============================================================================
# Greek letter resolution through various renderers (from section 6)
# ============================================================================

describe "math_repr greek letter resolution":
    """
    ## Greek Letter Resolution

    Exercises _resolve_greek branches via pretty and latex renderers.
    """

    context "greek letter resolution through pretty renderer":
        # Each call exercises a different branch in greek() via _resolve_greek
        it "resolves beta through pretty":
            expect(to_pretty("beta")).to_contain("\u03B2")

        it "resolves gamma delta epsilon through pretty":
            expect(to_pretty("gamma")).to_contain("\u03B3")
            expect(to_pretty("delta")).to_contain("\u03B4")
            expect(to_pretty("epsilon")).to_contain("\u03B5")

        it "resolves zeta eta theta through pretty":
            expect(to_pretty("zeta")).to_contain("\u03B6")
            expect(to_pretty("eta")).to_contain("\u03B7")
            expect(to_pretty("theta")).to_contain("\u03B8")

        it "resolves iota kappa lambda through pretty":
            expect(to_pretty("iota")).to_contain("\u03B9")
            expect(to_pretty("kappa")).to_contain("\u03BA")
            expect(to_pretty("lambda")).to_contain("\u03BB")

        it "resolves mu nu xi through pretty":
            expect(to_pretty("mu")).to_contain("\u03BC")
            expect(to_pretty("nu")).to_contain("\u03BD")
            expect(to_pretty("xi")).to_contain("\u03BE")

        it "resolves omicron pi rho through pretty":
            expect(to_pretty("omicron")).to_contain("\u03BF")
            expect(to_pretty("pi")).to_contain("\u03C0")
            expect(to_pretty("rho")).to_contain("\u03C1")

        it "resolves sigma tau upsilon through pretty":
            expect(to_pretty("sigma")).to_contain("\u03C3")
            expect(to_pretty("tau")).to_contain("\u03C4")
            expect(to_pretty("upsilon")).to_contain("\u03C5")

        it "resolves phi chi psi omega through pretty":
            expect(to_pretty("phi")).to_contain("\u03C6")
            expect(to_pretty("chi")).to_contain("\u03C7")
            expect(to_pretty("psi")).to_contain("\u03C8")
            expect(to_pretty("omega")).to_contain("\u03C9")

        it "resolves variant forms through pretty":
            expect(to_pretty("varepsilon")).to_contain("\u03F5")
            expect(to_pretty("vartheta")).to_contain("\u03D1")
            expect(to_pretty("varphi")).to_contain("\u03D5")
            expect(to_pretty("varrho")).to_contain("\u03F1")

        it "resolves more variants and specials through pretty":
            expect(to_pretty("varpi")).to_contain("\u03D6")
            expect(to_pretty("varkappa")).to_contain("\u03F0")
            expect(to_pretty("partial")).to_contain("\u2202")
            expect(to_pretty("nabla")).to_contain("\u2207")

    context "uppercase greek through pretty renderer":
        it "resolves Delta Theta Lambda Xi through pretty":
            expect(to_pretty("Delta")).to_contain("\u0394")
            expect(to_pretty("Theta")).to_contain("\u0398")
            expect(to_pretty("Lambda")).to_contain("\u039B")
            expect(to_pretty("Xi")).to_contain("\u039E")

        it "resolves Pi Sigma Upsilon through pretty":
            expect(to_pretty("Pi")).to_contain("\u03A0")
            expect(to_pretty("Sigma")).to_contain("\u03A3")
            expect(to_pretty("Upsilon")).to_contain("\u03A5")

        it "resolves Phi Psi Omega through pretty":
            expect(to_pretty("Phi")).to_contain("\u03A6")
            expect(to_pretty("Psi")).to_contain("\u03A8")
            expect(to_pretty("Omega")).to_contain("\u03A9")

    context "greek through latex renderer":
        it "renders greek letters as latex commands":
            expect(render_latex_raw("alpha")).to_contain("\\alpha")
            expect(render_latex_raw("beta")).to_contain("\\beta")
            expect(render_latex_raw("gamma")).to_contain("\\gamma")

        it "renders uppercase greek as latex commands":
            expect(render_latex_raw("Gamma")).to_contain("\\Gamma")
            expect(render_latex_raw("Delta")).to_contain("\\Delta")
            expect(render_latex_raw("Omega")).to_contain("\\Omega")

    context "superscript char coverage through pretty power":
        # to_pretty("x^N") calls pretty_power which calls superscript on N
        # Each digit exercises a different superscript_char branch
        it "exercises superscript digits 0-4 via power":
            val r0 = to_pretty("x^0")
            expect(r0).to_contain("x")
            val r1 = to_pretty("x^1")
            expect(r1).to_contain("x")
            val r3 = to_pretty("x^3")
            expect(r3).to_contain("x")
            val r4 = to_pretty("x^4")
            expect(r4).to_contain("x")

        it "exercises superscript digits 5-9 via power":
            val r5 = to_pretty("x^5")
            expect(r5).to_contain("x")
            val r6 = to_pretty("x^6")
            expect(r6).to_contain("x")
            val r7 = to_pretty("x^7")
            expect(r7).to_contain("x")
            val r8 = to_pretty("x^8")
            expect(r8).to_contain("x")
            val r9 = to_pretty("x^9")
            expect(r9).to_contain("x")

        it "exercises superscript letters n i x via power":
            val rn = to_pretty("x^n")
            expect(rn).to_contain("x")
            val ri = to_pretty("x^i")
            expect(ri).to_contain("x")

    context "subscript char coverage through pretty subscript":
        # to_pretty("x[N]") calls pretty_sub which calls subscript_char on N
        it "exercises subscript digits 0-4":
            val r0 = to_pretty("x[0]")
            expect(r0).to_contain("x")
            val r1 = to_pretty("x[1]")
            expect(r1).to_contain("x")
            val r2 = to_pretty("x[2]")
            expect(r2).to_contain("x")
            val r3 = to_pretty("x[3]")
            expect(r3).to_contain("x")
            val r4 = to_pretty("x[4]")
            expect(r4).to_contain("x")

        it "exercises subscript digits 5-9":
            val r5 = to_pretty("x[5]")
            expect(r5).to_contain("x")
            val r6 = to_pretty("x[6]")
            expect(r6).to_contain("x")
            val r7 = to_pretty("x[7]")
            expect(r7).to_contain("x")
            val r8 = to_pretty("x[8]")
            expect(r8).to_contain("x")
            val r9 = to_pretty("x[9]")
            expect(r9).to_contain("x")

        it "exercises subscript letters a e o x":
            val ra = to_pretty("x[a]")
            expect(ra).to_contain("x")
            val re = to_pretty("x[e]")
            expect(re).to_contain("x")
            val ro = to_pretty("x[o]")
            expect(ro).to_contain("x")

        it "exercises subscript letters h k l m n p s t":
            val rh = to_pretty("x[h]")
            expect(rh).to_contain("x")
            val rk = to_pretty("x[k]")
            expect(rk).to_contain("x")
            val rl = to_pretty("x[l]")
            expect(rl).to_contain("x")
            val rm2 = to_pretty("x[m]")
            expect(rm2).to_contain("x")
            val rn = to_pretty("x[n]")
            expect(rn).to_contain("x")
            val rp = to_pretty("x[p]")
            expect(rp).to_contain("x")
            val rs = to_pretty("x[s]")
            expect(rs).to_contain("x")
            val rt = to_pretty("x[t]")
            expect(rt).to_contain("x")

        it "exercises subscript letters i j r":
            val ri = to_pretty("x[j]")
            expect(ri).to_contain("x")
            val rr = to_pretty("x[r]")
            expect(rr).to_contain("x")
