# @cover src/lib/common/image/png_decode.spl 85%
# @cover src/lib/common/image/deflate_inflate.spl 70%
# @tag: image, png, deflate, filter
#
# PNG Decode with DEFLATE Specification
#
# Verifies that the PNG decoder works with real DEFLATE-compressed IDAT
# data instead of the raw byte-copy stub. Tests filter reconstruction
# (None, Sub, Up, Paeth) and correct ARGB output from compressed PNGs.
#
# This spec complements png_decode_spec.spl (signature/header tests)
# by focusing on the decompression + filter pipeline.

use std.spec.{describe, context, it, expect}
use std.common.image.png_decode.{
    decode_png_to_argb, PngImage, decompress_idat, reconstruct_scanlines, paeth_predictor}

# ============================================================================
# Test Helpers — Minimal PNG Construction
# ============================================================================

# PNG signature bytes
val PNG_SIG: [u8] = [137, 80, 78, 71, 13, 10, 26, 10]

fn write_u32_be(val_: u32) -> [u8]:
    """Encode a u32 as big-endian 4 bytes."""
    var out: [u8] = []
    out = out + [((val_ >> 24) & 0xFF).to_u8()]
    out = out + [((val_ >> 16) & 0xFF).to_u8()]
    out = out + [((val_ >> 8) & 0xFF).to_u8()]
    out = out + [(val_ & 0xFF).to_u8()]
    out

fn make_ihdr_chunk(width: i32, height: i32, color_type: u8) -> [u8]:
    """Build an IHDR chunk (no CRC — decoder doesn't check CRC)."""
    var chunk: [u8] = []
    # Length: 13
    chunk = chunk + write_u32_be(13)
    # Type: IHDR = [73, 72, 68, 82]
    chunk = chunk + [73, 72, 68, 82]
    # Width (4 bytes BE)
    chunk = chunk + write_u32_be(width.to_u32())
    # Height (4 bytes BE)
    chunk = chunk + write_u32_be(height.to_u32())
    # Bit depth: 8
    chunk = chunk + [8]
    # Color type
    chunk = chunk + [color_type]
    # Compression, filter, interlace: 0, 0, 0
    chunk = chunk + [0, 0, 0]
    # CRC (dummy — decoder doesn't validate CRC)
    chunk = chunk + [0, 0, 0, 0]
    chunk

fn make_idat_chunk(data: [u8]) -> [u8]:
    """Build an IDAT chunk wrapping compressed data."""
    var chunk: [u8] = []
    chunk = chunk + write_u32_be(data.len().to_u32())
    # Type: IDAT = [73, 68, 65, 84]
    chunk = chunk + [73, 68, 65, 84]
    for b in data:
        chunk = chunk + [b]
    # CRC (dummy)
    chunk = chunk + [0, 0, 0, 0]
    chunk

fn make_iend_chunk() -> [u8]:
    """Build an IEND chunk."""
    var chunk: [u8] = []
    # Length: 0
    chunk = chunk + [0, 0, 0, 0]
    # Type: IEND = [73, 69, 78, 68]
    chunk = chunk + [73, 69, 78, 68]
    # CRC (dummy)
    chunk = chunk + [0, 0, 0, 0]
    chunk

fn make_zlib_stored(raw: [u8]) -> [u8]:
    """Wrap raw bytes in a zlib stored block (no compression).

    zlib header (2 bytes) + stored block header + raw data.
    """
    var out: [u8] = []
    # zlib header: CMF=0x78, FLG=0x01
    out = out + [0x78, 0x01]
    # Stored block: bfinal=1, btype=00 -> byte = 0x01
    out = out + [0x01]
    # LEN (little-endian u16)
    val len_ = raw.len().to_i32()
    out = out + [(len_ & 0xFF).to_u8(), ((len_ >> 8) & 0xFF).to_u8()]
    # NLEN (one's complement of LEN)
    val nlen = len_ ^ 0xFFFF
    out = out + [(nlen & 0xFF).to_u8(), ((nlen >> 8) & 0xFF).to_u8()]
    # Raw data
    for b in raw:
        out = out + [b]
    out

fn make_1x1_rgb_png_stored() -> [u8]:
    """Build a minimal 1x1 RGB PNG using stored DEFLATE block.

    Pixel: RGB(255, 0, 0) red.
    Raw scanline: [filter=0, R=255, G=0, B=0]
    """
    # Raw pixel data with filter byte: filter_none(0), R, G, B
    val raw_scanline: [u8] = [0, 255, 0, 0]
    val compressed = make_zlib_stored(raw_scanline)

    var png: [u8] = []
    for b in PNG_SIG:
        png = png + [b]
    for b in make_ihdr_chunk(1, 1, 2):  # color_type=2 (RGB)
        png = png + [b]
    for b in make_idat_chunk(compressed):
        png = png + [b]
    for b in make_iend_chunk():
        png = png + [b]
    png

fn make_2x1_rgb_png_stored() -> [u8]:
    """Build a 2x1 RGB PNG with two pixels: red and green."""
    # Raw scanline: [filter=0, R1=255, G1=0, B1=0, R2=0, G2=255, B2=0]
    val raw_scanline: [u8] = [0, 255, 0, 0, 0, 255, 0]
    val compressed = make_zlib_stored(raw_scanline)

    var png: [u8] = []
    for b in PNG_SIG:
        png = png + [b]
    for b in make_ihdr_chunk(2, 1, 2):
        png = png + [b]
    for b in make_idat_chunk(compressed):
        png = png + [b]
    for b in make_iend_chunk():
        png = png + [b]
    png

# ============================================================================
# Test Group 1: DEFLATE Integration in PNG
# ============================================================================

describe "PngDecode — DEFLATE decompression":
    """
    ## PNG IDAT Decompression via DEFLATE

    The decompress_idat function must call deflate_inflate to decompress
    zlib-wrapped IDAT data, then apply PNG filter reconstruction.
    These tests use stored blocks (btype=0) which are trivially decodable.
    """

    context "stored block IDAT":

        it "AC-1: decodes 1x1 RGB PNG with stored DEFLATE block":
            val png = make_1x1_rgb_png_stored()
            val result = decode_png_to_argb(png)
            expect(result.error?).to_equal(false)

        it "AC-1: 1x1 PNG produces exactly 1 pixel":
            val png = make_1x1_rgb_png_stored()
            val result = decode_png_to_argb(png)
            match result:
                Ok(img):
                    expect(img.pixels.len().to_i32()).to_equal(1)
                Err(msg):
                    expect(msg).to_equal("")

        it "AC-1: 1x1 red PNG pixel is correct ARGB":
            val png = make_1x1_rgb_png_stored()
            val result = decode_png_to_argb(png)
            match result:
                Ok(img):
                    # ARGB: 0xFF_FF_00_00 (alpha=255, red=255, green=0, blue=0)
                    val expected: u32 = 0xFFFF0000
                    expect(img.pixels[0]).to_equal(expected)
                Err(msg):
                    expect(msg).to_equal("")

        it "AC-1: 2x1 PNG produces exactly 2 pixels":
            val png = make_2x1_rgb_png_stored()
            val result = decode_png_to_argb(png)
            match result:
                Ok(img):
                    expect(img.pixels.len().to_i32()).to_equal(2)
                Err(msg):
                    expect(msg).to_equal("")

# ============================================================================
# Test Group 2: PNG Filter Reconstruction
# ============================================================================

describe "PngDecode — filter reconstruction":
    """
    ## PNG Filter Types

    PNG rows are prefixed with a filter byte (0-4):
    - 0: None (raw bytes)
    - 1: Sub (diff from left pixel)
    - 2: Up (diff from above pixel)
    - 3: Average
    - 4: Paeth

    reconstruct_scanlines undoes these filters to recover original pixel data.
    """

    context "filter type 0 (None)":

        it "AC-1: None filter passes through raw bytes":
            # 1x1 RGB: filter=0, R=100, G=200, B=50
            val raw: [u8] = [0, 100, 200, 50]
            val result = reconstruct_scanlines(raw, 1, 1, 3, 4)
            # After reconstruction, should be [100, 200, 50]
            expect(result.len().to_i32()).to_equal(3)

        it "AC-1: None filter preserves byte values":
            val raw: [u8] = [0, 100, 200, 50]
            val result = reconstruct_scanlines(raw, 1, 1, 3, 4)
            if result.len().to_i32() >= 1:
                expect(result[0]).to_equal(100)
            else:
                expect(result.len()).to_be_greater_than(0)

    context "filter type 1 (Sub)":

        it "AC-1: Sub filter adds left neighbor to current byte":
            # 2x1 RGB: filter=1, then bytes are deltas from left
            # First pixel raw, second pixel = diff from first
            # R1=100, G1=50, B1=25, dR2=10, dG2=5, dB2=3
            # After Sub: R2=100+10=110, G2=50+5=55, B2=25+3=28
            val raw: [u8] = [1, 100, 50, 25, 10, 5, 3]
            val result = reconstruct_scanlines(raw, 2, 1, 3, 7)
            # Output should be 6 bytes: [100, 50, 25, 110, 55, 28]
            expect(result.len().to_i32()).to_equal(6)

    context "filter type 2 (Up)":

        it "AC-1: Up filter adds above row byte to current":
            # 1x2 image (1 pixel wide, 2 rows):
            # Row 0: filter=0, R=100, G=50, B=25
            # Row 1: filter=2, dR=10, dG=5, dB=3
            # After Up: Row1 = Row0 + delta = [110, 55, 28]
            val raw: [u8] = [0, 100, 50, 25, 2, 10, 5, 3]
            val result = reconstruct_scanlines(raw, 1, 2, 3, 4)
            # Output: 6 bytes total (2 rows of 3 bytes)
            expect(result.len().to_i32()).to_equal(6)

    context "paeth predictor":

        it "AC-1: paeth_predictor(0, 0, 0) returns 0":
            val p = paeth_predictor(0, 0, 0)
            expect(p).to_equal(0)

        it "AC-1: paeth_predictor with identical inputs returns that value":
            val p = paeth_predictor(100, 100, 100)
            expect(p).to_equal(100)

        it "AC-1: paeth_predictor selects closest to prediction":
            # p = a + b - c = 10 + 20 - 5 = 25
            # pa = |25 - 10| = 15, pb = |25 - 20| = 5, pc = |25 - 5| = 20
            # min is pb -> returns b = 20
            val p = paeth_predictor(10, 20, 5)
            expect(p).to_equal(20)

# ============================================================================
# Test Group 3: decompress_idat Direct Testing
# ============================================================================

describe "PngDecode — decompress_idat":
    """
    ## Direct IDAT Decompression

    Tests decompress_idat function directly with known compressed data
    to verify the DEFLATE -> filter reconstruction pipeline.
    """

    context "stored block IDAT data":

        it "AC-1: decompress_idat returns non-empty for valid zlib stored data":
            # 1x1 RGB: raw scanline = [filter=0, R=255, G=0, B=0]
            val raw: [u8] = [0, 255, 0, 0]
            val compressed = make_zlib_stored(raw)
            val result = decompress_idat(compressed, 1, 1, 2)
            expect(result.len()).to_be_greater_than(0)

        it "AC-1: decompress_idat output has correct byte count for 1x1 RGB":
            val raw: [u8] = [0, 255, 0, 0]
            val compressed = make_zlib_stored(raw)
            val result = decompress_idat(compressed, 1, 1, 2)
            # After filter reconstruction: 1 pixel * 3 channels = 3 bytes
            expect(result.len().to_i32()).to_equal(3)

    context "empty or invalid IDAT":

        it "AC-1: decompress_idat returns empty for too-short input":
            val data: [u8] = [0x78]
            val result = decompress_idat(data, 1, 1, 2)
            expect(result.len().to_i32()).to_equal(0)
