# codex-system-test
# Focused SPipe coverage for deterministic JSON library behavior.

use lib.json.types.{json_number, json_string, json_object, json_array, json_is_object, json_to_number, json_to_string}
use lib.json.object_ops.{json_object_get}
use lib.json.parser.{json_parse, json_parse_with_error}
use lib.json.path_ops.{json_path_get, json_path_set}
use lib.json.serializer.{json_minify, json_beautify}
use lib.json.builder.{JsonBuilder}
use lib.json.utilities.{json_diff, json_patch, json_unflatten_object}
use lib.json.validation.{json_deep_equals}

describe "JSON Library Logic":
    describe "parser strictness":
        it "parses nested object and array values":
            val parsed = json_parse("{\"user\":{\"name\":\"Ada\",\"scores\":[1,2]}}")
            expect json_is_object(parsed) == true
            expect json_to_string(json_path_get(parsed, "user.name")) == "Ada"
            expect json_to_number(json_path_get(parsed, "user.scores.1")) == 2

        it "rejects trailing tokens after a valid value":
            val parsed = json_parse("{\"ok\":true} []")
            expect parsed == nil

            val result = json_parse_with_error("{\"ok\":true} []")
            expect result.0 == nil
            expect (result.1).contains("trailing")

        it "rejects trailing commas in objects":
            val parsed = json_parse("{\"ok\":true,}")
            expect parsed == nil

            val result = json_parse_with_error("{\"ok\":true,}")
            expect result.0 == nil
            expect (result.1).contains("Trailing comma")

        it "rejects trailing commas in arrays":
            val parsed = json_parse("[1,2,]")
            expect parsed == nil

            val result = json_parse_with_error("[1,2,]")
            expect result.0 == nil
            expect (result.1).contains("Unexpected token")

        it "reports unterminated strings":
            val result = json_parse_with_error("{\"name\":\"Ada}")
            expect result.0 == nil
            expect (result.1).contains("Unterminated string")

        it "decodes escaped slash and control escapes in strings":
            val parsed = json_parse("{\"path\":\"https:\\/\\/example.com\\b\\f\"}")
            expect json_to_string(json_path_get(parsed, "path")) == "https://example.com\b\f"

        it "keeps invalid trailing input unchanged during minify and beautify":
            val input = "{\"ok\":true} garbage"
            expect json_minify(input) == input
            expect json_beautify(input) == input

    describe "path write semantics":
        it "creates missing nested objects for dotted paths":
            val updated = json_path_set(json_object({}), "user.profile.name", json_string("Ada"))
            expect json_is_object(json_object_get(updated, "user")) == true
            expect json_to_string(json_path_get(updated, "user.profile.name")) == "Ada"

        it "preserves existing siblings when writing nested paths":
            val original = json_object({
                "user": json_object({
                    "id": json_number(7)
                })
            })
            val updated = json_path_set(original, "user.profile.name", json_string("Ada"))
            expect json_to_number(json_path_get(updated, "user.id")) == 7
            expect json_to_string(json_path_get(updated, "user.profile.name")) == "Ada"

    describe "unflatten behavior":
        it "builds nested objects from dotted keys":
            val flat = json_object({
                "user.name": json_string("Ada"),
                "user.age": json_number(37)
            })
            val nested = json_unflatten_object(flat)
            expect json_to_string(json_path_get(nested, "user.name")) == "Ada"
            expect json_to_number(json_path_get(nested, "user.age")) == 37

    describe "diff and patch behavior":
        it "applies object diffs back to the original object":
            val original = json_object({
                "user": json_object({
                    "name": json_string("Ada"),
                    "age": json_number(36)
                }),
                "tags": json_array([json_string("core")])
            })
            val updated = json_object({
                "user": json_object({
                    "name": json_string("Ada"),
                    "age": json_number(37)
                }),
                "tags": json_array([json_string("core")]),
                "active": json_string("yes")
            })

            val diff = json_diff(original, updated)
            val patched = json_patch(original, diff)

            expect json_deep_equals(patched, updated) == true

    describe "builder escaping":
        it "escapes object keys as well as values":
            val built = JsonBuilder.object()
                .field("say\"hi", "line\nbreak")
                .build()

            expect built == "{\"say\\\"hi\": \"line\\nbreak\"}"