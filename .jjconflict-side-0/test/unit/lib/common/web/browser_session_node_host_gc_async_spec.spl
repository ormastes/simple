use std.spec.*

use std.js.engine.js_error.{Logger, LogLevel}
use std.gc_async_mut.js.engine.interpreter as gc_js
use std.gc_async_mut.js.engine.interpreter_native.*
use std.gc_async_mut.js.engine.interpreter_object.*
use std.js.types.js_types.{JsValue}

fn _display_js(v: JsValue) -> text:
    match v:
        JsValue.Undefined: "undefined"
        JsValue.Null: "null"
        JsValue.Boolean(b): if b: "true" else: "false"
        JsValue.Number(n):
            var s = "{n}"
            if s.ends_with(".0"):
                s = s.slice(0, s.len() - 2)
            s
        JsValue.String(s): s
        JsValue.Object(id): "[object Object]"
        JsValue.Array(id): "[object Array]"
        JsValue.Function(id): "[Function]"
        JsValue.Symbol(id): "Symbol()"

fn _object_property_text(interp: gc_js.JsInterpreter, value: JsValue, key: text) -> text:
    match value:
        JsValue.Object(id): _display_js(interp.get_object_property(id, key))
        _: ""

describe "BrowserSession gc_async Node host require cache":
    it "reuses builtin module objects across node-prefixed aliases":
        var interp = gc_js.JsInterpreter.new(Logger.new(LogLevel.Error))

        val path = interp._native_node_require([JsValue.String(v: "path")])
        match path:
            JsValue.Object(path_id):
                interp.set_object_property(path_id, "cacheProbe", JsValue.String(v: "yes"))
            _:
                expect("missing path module").to_equal("object")

        expect(_object_property_text(interp, interp._native_node_require([JsValue.String(v: "node:path")]), "cacheProbe")).to_equal("yes")
