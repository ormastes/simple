use std.gc_async_immut.{VersionedSnapshot}

describe "gc_async_immut versioned native probe":
    it "constructs a snapshot":
        var snapshot = VersionedSnapshot.new("old")
        expect snapshot.current() == "old"

    it "updates a snapshot":
        var snapshot = VersionedSnapshot.new("old")
        snapshot.update("new")
        expect snapshot.current() == "new"
