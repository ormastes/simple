use std.spec

class ModuleRecord:
    name: text
    exports: [text]
    dependencies: [text]

    static fn new(name: text, exports: [text], dependencies: [text]) -> ModuleRecord:
        ModuleRecord(name: name, exports: exports, dependencies: dependencies)

    fn export_count() -> i64:
        self.exports.len()

    fn dependency_count() -> i64:
        self.dependencies.len()

    fn exports_symbol(symbol: text) -> bool:
        self.exports.contains(symbol)

fn resolve_load_order(root: ModuleRecord, deps: [ModuleRecord]) -> [text]:
    var order: [text] = []
    var i: i64 = 0
    while i < deps.len():
        order = order.push(deps[i].name)
        i = i + 1
    order = order.push(root.name)
    order

describe "Module System Spec":
    it "tracks module metadata":
        val module = ModuleRecord.new("app.main", ["run", "config"], ["std.io"])
        expect(module.export_count()).to_equal(2)
        expect(module.dependency_count()).to_equal(1)

    it "resolves dependency order before root":
        val io = ModuleRecord.new("std.io", ["print"], [])
        val config = ModuleRecord.new("app.config", ["load"], ["std.io"])
        val root = ModuleRecord.new("app.main", ["run"], ["std.io", "app.config"])
        val order = resolve_load_order(root, [io, config])
        expect(order[0]).to_equal("std.io")
        expect(order[1]).to_equal("app.config")
        expect(order[2]).to_equal("app.main")

    it "checks exported symbols":
        val module = ModuleRecord.new("math", ["sum", "avg"], [])
        expect(module.exports_symbol("sum")).to_equal(true)
        expect(module.exports_symbol("min")).to_equal(false)
