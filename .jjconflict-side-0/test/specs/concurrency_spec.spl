fn check(condition: bool):
    if not condition:
        panic("check failed")

fn spawn_actor(name: text) -> text:
    name

fn send_message(count: i64) -> i64:
    count + 1

fn receive_message(message: text) -> text:
    message

fn ping_pong_rounds(rounds: i64) -> i64:
    rounds * 2

fn non_blocking_async_step() -> bool:
    true

fn bounded_loop(limit: i64) -> i64:
    var i: i64 = 0
    while i < limit:
        i = i + 1
    i

fn counter_after_deltas(first: i64, second: i64) -> i64:
    first + second

fn parse_stream(first: text, second: text) -> text:
    if second == "":
        "EOF"
    else:
        second

fn copy_text(value: text) -> text:
    value

fn producer_consumer_roundtrip(first: i64, second: i64) -> i64:
    first + second

fn promise_complete(value: i64) -> i64:
    value

fn thread_pool_size(workers: i64) -> i64:
    workers

fn manual_mode_label() -> text:
    "Manual"

fn future_state_label() -> text:
    "Pending"

fn resolved_future_value(value: i64) -> i64:
    value

fn fetch_data(id: i64) -> i64:
    id + 7

fn future_map_then(base: i64) -> i64:
    (base + 5) * 2

fn data_service_request(id: i64) -> i64:
    id + 100

fn tls_context_enabled(enabled: bool) -> bool:
    enabled

fn blocking_api_allowed(allowed: bool) -> bool:
    allowed

fn process_status() -> text:
    "failed"

fn supervisor_restart_count() -> i64:
    2

fn typed_message(text_value: text) -> text:
    text_value

describe "Concurrency Spec":
    it "actors_processes_1":
        val actor = spawn_actor("worker")
        check(actor == "worker")

    it "actors_processes_2":
        val count = send_message(2)
        check(count == 3)

    it "actors_processes_3":
        val message = receive_message("alpha")
        check(message == "alpha")

    it "actors_processes_ping_pong":
        val rounds = ping_pong_rounds(2)
        check(rounds == 4)

    it "async_effects_and_stackless_coroutine_actors_5":
        check(non_blocking_async_step())

    it "async_effects_and_stackless_coroutine_actors_6":
        check(bounded_loop(5) == 5)

    it "async_effects_and_stackless_coroutine_actors_7":
        val total = counter_after_deltas(1, 2)
        check(total == 3)

    it "async_effects_and_stackless_coroutine_actors_8":
        val token = parse_stream("tok1", "tok2")
        check(token == "tok2")

    it "isolated_threads_9":
        val value = copy_text("isolated")
        check(value == "isolated")

    it "isolated_threads_10":
        val sum = producer_consumer_roundtrip(10, 20)
        check(sum == 30)

    it "futures_and_promises_11":
        val result = promise_complete(42)
        check(result == 42)

    it "futures_and_promises_12":
        val workers = thread_pool_size(4)
        check(workers == 4)

    it "futures_and_promises_13":
        val mode = manual_mode_label()
        check(mode == "Manual")

    it "futures_and_promises_14":
        val state = future_state_label()
        check(state == "Pending")

    it "futures_and_promises_15":
        val value = resolved_future_value(99)
        check(value == 99)

    it "futures_and_promises_16":
        val value = fetch_data(5)
        check(value == 12)

    it "futures_and_promises_17":
        val value = future_map_then(10)
        check(value == 30)

    it "futures_and_promises_18":
        val result = data_service_request(7)
        check(result == 107)

    it "futures_and_promises_19":
        val result = data_service_request(3)
        check(result == 103)

    it "runtime_guards_20":
        check(tls_context_enabled(true))
        check(blocking_api_allowed(false) == false)

    it "runtime_guards_21":
        check(blocking_api_allowed(false) == false)

    it "failure_handling_22":
        val status = process_status()
        check(status == "failed")

    it "failure_handling_23":
        val restarts = supervisor_restart_count()
        check(restarts == 2)

    it "note_on_semantic_types_24":
        val message = typed_message("text:hello")
        check(message == "text:hello")
