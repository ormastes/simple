# Web Dashboard Server and Router Specification
#
# Focused coverage for the main dashboard server entrypoint.

use std.sspec.*
use app.web_dashboard.server.{DashboardServer}

# ============================================================================
# Main dashboard router
# ============================================================================

describe "Web dashboard server router":
    """
    Covers the primary server routes without touching the network stack.
    """

    it "serves the main dashboard shell on /":
        val server = DashboardServer.new(4242)
        val resp = server.route_request("GET", "/", "")
        expect resp to_start_with "HTTP/1.1 200 OK"
        expect resp to_contain "Content-Type: text/html"
        expect resp to_contain "<!DOCTYPE html>"
        expect resp to_contain "Simple Compiler Dashboard"
        expect resp to_contain "id=\"view-status\""
        expect resp to_contain "id=\"view-terminal\""
        expect resp to_contain "id=\"view-gui\""
        expect resp to_contain "/api/tmux/sessions"
        expect resp to_contain "/ws/terminal?session="
        expect resp to_contain "window.location='/agents'"

    it "delegates /api/tmux to the tmux API router":
        val server = DashboardServer.new(4242)
        val resp = server.route_request("GET", "/api/tmux", "")
        expect (resp.contains("HTTP/1.1 200 OK") or resp.contains("HTTP/1.1 503 Unknown")) to_equal true
        expect resp to_contain "Content-Type: application/json"

    it "routes unknown paths to the index shell":
        val server = DashboardServer.new(4242)
        val resp = server.route_request("GET", "/does-not-exist", "")
        expect resp to_start_with "HTTP/1.1 200 OK"
        expect resp to_contain "Content-Type: text/html"
        expect resp to_contain "<html lang=\"en\">"
