# Minimal packed-pixel FNV-1a repro for native-build hash diagnostics.
#
# Expected hash matches the first four pixels of the C/Simple packed RGBA byte
# stream: 0xFF0000FF, 0xFF00FF00, 0xFFFF0000, 0xFF00FFFF.

fn fnv1a_pixels(pixels: [i64]) -> i64:
    var h: i64 = 2166136261
    var i: i64 = 0
    while i < pixels.len() as i64:
        val pix: i64 = pixels[i as i32]
        val low_byte: i64 = h & 0xFF
        h = h - low_byte + (low_byte xor (pix & 0xFF))
        h = (h * 16777619) & 0xFFFFFFFF
        val low_byte_g: i64 = h & 0xFF
        h = h - low_byte_g + (low_byte_g xor ((pix >> 8) & 0xFF))
        h = (h * 16777619) & 0xFFFFFFFF
        val low_byte_b: i64 = h & 0xFF
        h = h - low_byte_b + (low_byte_b xor ((pix >> 16) & 0xFF))
        h = (h * 16777619) & 0xFFFFFFFF
        val low_byte_a: i64 = h & 0xFF
        h = h - low_byte_a + (low_byte_a xor ((pix >> 24) & 0xFF))
        h = (h * 16777619) & 0xFFFFFFFF
        i = i + 1
    h

fn main():
    val pixels: [i64] = [0xFF0000FF, 0xFF00FF00, 0xFFFF0000, 0xFF00FFFF]
    print "FNV1A_NATIVE_REPRO hash={fnv1a_pixels(pixels)}"
