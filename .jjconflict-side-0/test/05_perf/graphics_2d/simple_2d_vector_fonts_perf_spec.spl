# codex-system-test
# @tag: rendering, engine2d, vector-font, performance
# @req NFR-001 NFR-002 NFR-003 NFR-004 NFR-005 NFR-007
"""# Simple 2D Vector Font Performance

Measures 31 paired cold/warm CPU draws of the repository-owned TTF fixture.
Font load, clear, readback, and reporting stay outside timed regions. The
bitmap row requires the pinned host's retained p50 and checksum through
`SIMPLE_2D_BITMAP_BASELINE_NS` and `SIMPLE_2D_BITMAP_BASELINE_CHECKSUM`.
"""

use std.spec.*
use std.gc_async_mut.gpu.engine2d.engine.{Engine2D}
use std.gc_async_mut.gpu.engine2d.color.{rgb}
use std.gc_async_mut.io.time_ops.{time_now_nanos}
use std.gc_async_mut.io.mod_stub.{env_get}
use std.nogc_sync_mut.sffi.io.{dir_create_all, file_write_bytes}
use test.fixtures.fonts.simple_2d_vector.font_fixture.{simple_2d_ascii_font_bytes}

val PERF_DIR = "build/test-artifacts/05_perf/graphics_2d/simple_2d_vector_fonts"
val PERF_FONT = "build/test-artifacts/05_perf/graphics_2d/simple_2d_vector_fonts/simple_ascii.ttf"
val SAMPLE_COUNT: i64 = 31
val CONTENT = "A A A A"

class FontPerfEvidence:
    backend: text
    cold_p50_ns: i64
    cold_p95_ns: i64
    warm_p50_ns: i64
    warm_p95_ns: i64
    bitmap_p50_ns: i64
    bitmap_p95_ns: i64
    bitmap_checksum: i64
    bitmap_checksum_mismatches: i64
    warm_hits: i64
    warm_misses: i64
    warm_requests: i64
    warm_rasterizations: i64
    checksum: i64
    checksum_mismatches: i64
    entries: i64
    bytes: i64
    bitmap_baseline_ns: i64
    bitmap_baseline_checksum: i64

fn sort_i64(values: [i64]) -> [i64]:
    var sorted = values
    var i: i64 = 1
    while i < sorted.len():
        val key = sorted[i]
        var j = i - 1
        while j >= 0 and sorted[j] > key:
            sorted[j + 1] = sorted[j]
            j = j - 1
        sorted[j + 1] = key
        i = i + 1
    sorted

fn percentile(sorted: [i64], numerator: i64) -> i64:
    if sorted.len() == 0:
        return 0
    var index = sorted.len() * numerator / 100
    if index >= sorted.len():
        index = sorted.len() - 1
    sorted[index]

fn framebuffer_checksum(engine: Engine2D) -> i64:
    val pixels = engine.read_pixels()
    var checksum: i64 = 0
    var i: i64 = 0
    while i < pixels.len():
        checksum = (checksum + pixels[i].to_i64() * (i + 1)) % 2147483647
        i = i + 1
    checksum

fn bitmap_baseline_ns() -> i64:
    val raw = env_get("SIMPLE_2D_BITMAP_BASELINE_NS") ?? ""
    if raw == "":
        return 0
    raw.to_i64()

fn bitmap_baseline_checksum() -> i64:
    val raw = env_get("SIMPLE_2D_BITMAP_BASELINE_CHECKSUM") ?? ""
    if raw == "":
        return 0
    raw.to_i64()

fn measure_font_performance() -> FontPerfEvidence:
    dir_create_all(PERF_DIR)
    file_write_bytes(PERF_FONT, simple_2d_ascii_font_bytes())
    val bg = rgb(3, 7, 11)
    val fg = rgb(240, 220, 180)
    var engine = Engine2D.create_with_backend(128, 72, "cpu")
    var cold_samples: [i64] = []
    var warm_samples: [i64] = []
    var warm_hits: i64 = 0
    var warm_misses: i64 = 0
    var warm_rasterizations: i64 = 0
    var checksum: i64 = 0
    var checksum_mismatches: i64 = 0
    var entries: i64 = 0
    var bytes: i64 = 0
    var i: i64 = 0
    while i < SAMPLE_COUNT:
        engine.unload_font()
        if not engine.load_font(PERF_FONT):
            engine.shutdown()
            return FontPerfEvidence(backend: "cpu", cold_p50_ns: 0, cold_p95_ns: 0, warm_p50_ns: 0, warm_p95_ns: 0, bitmap_p50_ns: 0, bitmap_p95_ns: 0, bitmap_checksum: 0, bitmap_checksum_mismatches: 1, warm_hits: 0, warm_misses: 1, warm_requests: 0, warm_rasterizations: 1, checksum: 0, checksum_mismatches: 1, entries: 0, bytes: 0, bitmap_baseline_ns: bitmap_baseline_ns(), bitmap_baseline_checksum: bitmap_baseline_checksum())
        engine.clear(bg)
        val cold_start = time_now_nanos()
        engine.draw_text(8, 8, CONTENT, fg, 24)
        cold_samples.push(time_now_nanos() - cold_start)
        val cold_checksum = framebuffer_checksum(engine)
        val before = engine.font_cache_stats()
        engine.clear(bg)
        val warm_start = time_now_nanos()
        engine.draw_text(8, 8, CONTENT, fg, 24)
        warm_samples.push(time_now_nanos() - warm_start)
        val warm_checksum = framebuffer_checksum(engine)
        checksum = warm_checksum
        if warm_checksum != cold_checksum:
            checksum_mismatches = checksum_mismatches + 1
        print "font_perf_pair index={i} cold_ns={cold_samples[cold_samples.len() - 1]} warm_ns={warm_samples[warm_samples.len() - 1]} cold_checksum={cold_checksum} warm_checksum={warm_checksum}"
        val after = engine.font_cache_stats()
        warm_hits = warm_hits + after.hits - before.hits
        warm_misses = warm_misses + after.misses - before.misses
        warm_rasterizations = warm_rasterizations + after.rasterizations - before.rasterizations
        entries = after.entries
        bytes = after.bytes
        i = i + 1

    engine.unload_font()
    var bitmap_samples: [i64] = []
    var bitmap_checksum: i64 = 0
    var bitmap_checksum_mismatches: i64 = 0
    i = 0
    while i < SAMPLE_COUNT:
        engine.clear(bg)
        val bitmap_start = time_now_nanos()
        engine.draw_text(8, 8, CONTENT, fg, 24)
        bitmap_samples.push(time_now_nanos() - bitmap_start)
        val current_bitmap_checksum = framebuffer_checksum(engine)
        if i == 0:
            bitmap_checksum = current_bitmap_checksum
        elif current_bitmap_checksum != bitmap_checksum:
            bitmap_checksum_mismatches = bitmap_checksum_mismatches + 1
        i = i + 1
    val backend = engine.backend_name()
    engine.shutdown()

    val cold = sort_i64(cold_samples)
    val warm = sort_i64(warm_samples)
    val bitmap = sort_i64(bitmap_samples)
    FontPerfEvidence(
        backend: backend,
        cold_p50_ns: percentile(cold, 50),
        cold_p95_ns: percentile(cold, 95),
        warm_p50_ns: percentile(warm, 50),
        warm_p95_ns: percentile(warm, 95),
        bitmap_p50_ns: percentile(bitmap, 50),
        bitmap_p95_ns: percentile(bitmap, 95),
        bitmap_checksum: bitmap_checksum,
        bitmap_checksum_mismatches: bitmap_checksum_mismatches,
        warm_hits: warm_hits,
        warm_misses: warm_misses,
        warm_requests: CONTENT.len() * SAMPLE_COUNT,
        warm_rasterizations: warm_rasterizations,
        checksum: checksum,
        checksum_mismatches: checksum_mismatches,
        entries: entries,
        bytes: bytes,
        bitmap_baseline_ns: bitmap_baseline_ns(),
        bitmap_baseline_checksum: bitmap_baseline_checksum(),
    )

describe "Simple 2D vector font performance":
    # @manual_section: Paired cold and warm rendering
    it "reuses cached glyphs and improves repeated text rendering":
        step("Load a vector font fixture")
        val evidence = measure_font_performance()

        step("Render the same text again")
        expect(evidence.cold_p50_ns).to_be_greater_than(0)
        expect(evidence.warm_p50_ns).to_be_greater_than(0)
        expect(evidence.warm_p50_ns * 100).to_be_less_than(evidence.cold_p50_ns * 75 + 1)

        step("Verify cache and performance evidence")
        expect(evidence.warm_hits).to_equal(evidence.warm_requests)
        expect(evidence.warm_misses).to_equal(0)
        expect(evidence.warm_rasterizations).to_equal(0)
        expect(evidence.entries).to_be_less_than(513)
        expect(evidence.bytes).to_be_less_than(33554433)
        expect(evidence.checksum).to_be_greater_than(0)
        expect(evidence.checksum_mismatches).to_equal(0)
        expect(evidence.backend).to_equal("cpu")
        expect(evidence.bitmap_checksum_mismatches).to_equal(0)
        expect(evidence.bitmap_baseline_ns).to_be_greater_than(0)
        expect(evidence.bitmap_baseline_checksum).to_be_greater_than(0)
        expect(evidence.bitmap_checksum).to_equal(evidence.bitmap_baseline_checksum)
        expect(evidence.bitmap_p50_ns * 100).to_be_less_than(evidence.bitmap_baseline_ns * 105 + 1)
        print "font_perf fixture=ttf-parser-demo license=MIT-OR-Apache-2.0 backend={evidence.backend} viewport=128x72 size=24 samples=31 cold_p50_ns={evidence.cold_p50_ns} cold_p95_ns={evidence.cold_p95_ns} warm_p50_ns={evidence.warm_p50_ns} warm_p95_ns={evidence.warm_p95_ns} bitmap_p50_ns={evidence.bitmap_p50_ns} bitmap_p95_ns={evidence.bitmap_p95_ns} bitmap_checksum={evidence.bitmap_checksum} bitmap_checksum_mismatches={evidence.bitmap_checksum_mismatches} bitmap_baseline_ns={evidence.bitmap_baseline_ns} bitmap_baseline_checksum={evidence.bitmap_baseline_checksum} warm_hits={evidence.warm_hits}/{evidence.warm_requests} warm_misses={evidence.warm_misses} warm_rasterizations={evidence.warm_rasterizations} cache_entries={evidence.entries} cache_bytes={evidence.bytes} checksum={evidence.checksum} checksum_mismatches={evidence.checksum_mismatches} max_rss_kb=outer-harness"
