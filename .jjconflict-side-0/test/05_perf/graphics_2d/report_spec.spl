# test/perf/graphics_2d/report_spec.spl
#
# **Feature IDs:** NFR-GRAPHICS-2B, NFR-GRAPHICS-BENCH-REPORT
# **Category:** Performance | Graphics | Benchmark
# **Status:** Active
#
# Structural validation of the C vs Simple 2D CPU scalar benchmark harness.
# Runs on a tiny (8x8) push-based framebuffer — interpreter-safe.
#
# Hard assertions:
#   - BenchReport has all required NFR-2B fields
#   - frame_count > 0, pixel_hash != 0
#   - pixel hash is deterministic (same result on two runs)
#   - different scenes produce different hashes
#   - NFR_RATIO_THRESHOLD = 1250 (1.25x)
#   - canonical scene list has exactly 3 entries
#
# Soft (recorded, not failing):
#   - simple_vs_c_ratio <= 1250 — checked at integration time with C output
#
# Integration workflow:
#   1. cd test/perf/graphics_2d/c_reference && make && ./bench_2d > /tmp/c_out.txt
#   2. SIMPLE_ENGINE2D_RUNNER_MODE=full bin/simple test/perf/graphics_2d/simple_runner.spl > /tmp/s_out.txt
#   4. Compare pixel_hash per scene (hard gate: must match)
#   5. Compute ratio = simple_p50_ns / c_p50_ns * 1000 (NFR-2B: <= 1250)

extern fn rt_time_now_nanos() -> i64
extern fn rt_file_read_text(path: text) -> text

val NFR_RATIO_THRESHOLD: i64 = 1250
val CANONICAL_SCENES: [text] = ["fill_1080p", "blit_tiles", "clipped_scroll"]
val BYTES_PER_PX: i64 = 4

# ── BenchReport struct (all required NFR-2B report fields) ────────────────────

struct BenchReport:
    scene_name:        text
    backend:           text
    frame_count:       i64
    p50_ms:            i64
    p95_ms:            i64
    pixels_per_sec:    i64
    draws_per_sec:     i64
    rss_kb:            i64
    binary_size_kb:    i64
    pixel_hash:        i64
    p50_ns:            i64  # nanoseconds — used for ratio math (ms rounds sub-ms to 0)
    simple_vs_c_ratio: i64  # ratio * 1000; -1 = not yet measured

# ── Tiny 8x8 push-based framebuffer ──────────────────────────────────────────

val TW: i64 = 8
val TH: i64 = 8
val TF: i64 = 3  # timed frames

struct TFB:
    data:   [u8]
    width:  i64
    height: i64
    stride: i64

fn tfb_alloc(w: i64, h: i64) -> TFB:
    val stride: i64 = w * BYTES_PER_PX
    val total: i64 = stride * h
    var data: [u8] = []
    var i: i64 = 0
    while i < total:
        data.push(0 as u8)
        i = i + 1
    TFB(data: data, width: w, height: h, stride: stride)

fn tr(c: i64) -> u8: (c & 0xFF) as u8
fn tg(c: i64) -> u8: ((c >> 8) & 0xFF) as u8
fn tb(c: i64) -> u8: ((c >> 16) & 0xFF) as u8
fn ta(c: i64) -> u8: ((c >> 24) & 0xFF) as u8

fn tclear(fb: TFB, color: i64):
    val r: u8 = tr(color)
    val g: u8 = tg(color)
    val b: u8 = tb(color)
    val a: u8 = ta(color)
    val total: i64 = fb.width * fb.height
    var i: i64 = 0
    while i < total:
        val off: i64 = i * BYTES_PER_PX
        fb.data[off as i32]       = r
        fb.data[(off + 1) as i32] = g
        fb.data[(off + 2) as i32] = b
        fb.data[(off + 3) as i32] = a
        i = i + 1

fn trect(fb: TFB, x0: i64, y0: i64, x1: i64, y1: i64, color: i64):
    val r: u8 = tr(color)
    val g: u8 = tg(color)
    val b: u8 = tb(color)
    val a: u8 = ta(color)
    var rx0: i64 = if x0 < 0: 0 else: x0
    var ry0: i64 = if y0 < 0: 0 else: y0
    var rx1: i64 = if x1 > fb.width: fb.width else: x1
    var ry1: i64 = if y1 > fb.height: fb.height else: y1
    if rx0 >= rx1 or ry0 >= ry1:
        return
    var row: i64 = ry0
    while row < ry1:
        var col: i64 = rx0
        while col < rx1:
            val off: i64 = row * fb.stride + col * BYTES_PER_PX
            fb.data[off as i32]       = r
            fb.data[(off + 1) as i32] = g
            fb.data[(off + 2) as i32] = b
            fb.data[(off + 3) as i32] = a
            col = col + 1
        row = row + 1

# ── FNV-1a 32-bit (must match bench_2d.c fnv1a_framebuffer) ──────────────────

fn fnv1a_tfb(fb: TFB) -> i64:
    var h: i64 = 2166136261
    val len: i64 = fb.width * fb.height * BYTES_PER_PX
    var i: i64 = 0
    while i < len:
        val low_byte: i64 = h % 256
        h = h - low_byte + (low_byte xor (fb.data[i as i32] as i64))
        h = (h * 16777619) % 4294967296
        i = i + 1
    h

# ── Tiny scene runners ────────────────────────────────────────────────────────

fn tiny_fill(fb: TFB) -> i64:
    val colors: [i64] = [0xFF0000FF, 0xFF00FF00, 0xFFFF0000, 0xFF808080, 0xFF00FFFF]
    tclear(fb, 0xFF000000)
    var i: i64 = 0
    while i < 5:
        trect(fb, i, 0, i + 2, 2, colors[(i * 37 % 5) as i32])
        i = i + 1
    6

fn tiny_blit(fb: TFB) -> i64:
    # Different clear color from fill — ensures different hash
    tclear(fb, 0xFF0000FF)
    2

fn tiny_scroll(fb: TFB) -> i64:
    tclear(fb, 0xFF808080)
    trect(fb, 1, 1, 7, 7, 0xFFFFFFFF)
    trect(fb, 2, 2, 6, 6, 0xFF000000)
    4

# ── Sort / percentile ─────────────────────────────────────────────────────────

fn srt(s: [i64]) -> [i64]:
    var a: [i64] = s
    val n: i64 = a.len() as i64
    var i: i64 = 1
    while i < n:
        val key: i64 = a[i as i32]
        var j: i64 = i - 1
        while j >= 0 and a[j as i32] > key:
            a[(j + 1) as i32] = a[j as i32]
            j = j - 1
        a[(j + 1) as i32] = key
        i = i + 1
    a

fn pct(sorted: [i64], num: i64, den: i64) -> i64:
    val n: i64 = sorted.len() as i64
    if n == 0: return 0
    var idx: i64 = n * num / den
    if idx >= n: idx = n - 1
    sorted[idx as i32]

# ── RSS ───────────────────────────────────────────────────────────────────────

fn rss_kb() -> i64:
    val st: text = rt_file_read_text("/proc/self/status")
    if st.len() == 0: return 0
    var pos: i32 = 0
    while pos < st.len() as i32 - 6:
        if (st[pos] == 'V' and st[pos + 1] == 'm' and
            st[pos + 2] == 'R' and st[pos + 3] == 'S' and
            st[pos + 4] == 'S' and st[pos + 5] == ':'):
            pos = pos + 6
            while pos < st.len() as i32 and st[pos] == ' ':
                pos = pos + 1
            var r: i64 = 0
            while pos < st.len() as i32 and st[pos] >= '0' and st[pos] <= '9':
                r = r * 10 + (st[pos] as i64 - '0' as i64)
                pos = pos + 1
            return r
        pos = pos + 1
    0

# ── Tiny bench ────────────────────────────────────────────────────────────────

fn tiny_bench(scene_id: i64, scene_name: text) -> BenchReport:
    val fb: TFB = tfb_alloc(TW, TH)
    var samples: [i64] = []
    var total_draws: i64 = 0
    var f: i64 = 0
    while f < TF:
        val t0: i64 = rt_time_now_nanos()
        val draws: i64 = if scene_id == 0: tiny_fill(fb)
                         else if scene_id == 1: tiny_blit(fb)
                         else: tiny_scroll(fb)
        val t1: i64 = rt_time_now_nanos()
        samples.push(t1 - t0)
        total_draws = total_draws + draws
        f = f + 1
    val sorted: [i64] = srt(samples)
    val p50_ns: i64 = pct(sorted, 50, 100)
    val p95_ns: i64 = pct(sorted, 95, 100)
    val ppf: i64 = TW * TH
    val pps: i64 = if p50_ns > 0: (ppf * 1000000000) / p50_ns else: 0
    val avg_d: i64 = total_draws / TF
    val dps: i64 = if p50_ns > 0: (avg_d * 1000000000) / p50_ns else: 0
    BenchReport(
        scene_name:        scene_name,
        backend:           "simple_cpu_scalar",
        frame_count:       TF,
        p50_ms:            p50_ns / 1000000,
        p95_ms:            p95_ns / 1000000,
        pixels_per_sec:    pps,
        draws_per_sec:     dps,
        rss_kb:            rss_kb(),
        binary_size_kb:    0,
        pixel_hash:        fnv1a_tfb(fb),
        p50_ns:            p50_ns,
        simple_vs_c_ratio: -1,
    )

fn emit_report(r: BenchReport):
    print "REPORT scene={r.scene_name} backend={r.backend} frame_count={r.frame_count} p50_ms={r.p50_ms} p95_ms={r.p95_ms} pixels_per_sec={r.pixels_per_sec} draws_per_sec={r.draws_per_sec} rss_kb={r.rss_kb} binary_size_kb={r.binary_size_kb} pixel_hash={r.pixel_hash} p50_ns={r.p50_ns} ratio_x1000={r.simple_vs_c_ratio}"

# compute_joined: given a Simple BenchReport and the C reference p50_ns (from
# `bench_2d` output), return a new BenchReport with simple_vs_c_ratio filled in.
# ratio_x1000 = (simple_p50_ns * 1000) / c_p50_ns  — NFR-2B: must be <= 1250.
# c_p50_ns values from actual bench_2d run on this machine (2026-05-16):
#   fill_1080p   c_p50_ns = 6146240
#   blit_tiles   c_p50_ns = 7541685
#   clipped_scroll c_p50_ns = 3194512
fn compute_joined(r: BenchReport, c_p50_ns: i64) -> BenchReport:
    val ratio: i64 = if c_p50_ns > 0: (r.p50_ns * 1000) / c_p50_ns else: -1
    BenchReport(
        scene_name:        r.scene_name,
        backend:           r.backend,
        frame_count:       r.frame_count,
        p50_ms:            r.p50_ms,
        p95_ms:            r.p95_ms,
        pixels_per_sec:    r.pixels_per_sec,
        draws_per_sec:     r.draws_per_sec,
        rss_kb:            r.rss_kb,
        binary_size_kb:    r.binary_size_kb,
        pixel_hash:        r.pixel_hash,
        p50_ns:            r.p50_ns,
        simple_vs_c_ratio: ratio,
    )

# ── Spec ──────────────────────────────────────────────────────────────────────

describe "Graphics 2D CPU benchmark — NFR-GRAPHICS-2B harness":
    """
    ## NFR-2B: C vs Simple 2D CPU Scalar Benchmark

    Structural and correctness validation of the harness.
    Runs on an 8x8 framebuffer in interpreter mode.
    Real 1920x1080 numbers: run simple_runner.spl with
    SIMPLE_ENGINE2D_RUNNER_MODE=full and compare with c_reference/bench_2d output.

    Hash parity (C vs Simple) is the integration correctness gate.
    Ratio threshold: simple_vs_c_ratio <= 1250 (1.25x) for NFR-2B pass.
    """

    context "scene coverage":
        it "fill_1080p result has required fields":
            val r: BenchReport = tiny_bench(0, "fill_1080p")
            expect(r.scene_name).to_equal("fill_1080p")
            expect(r.frame_count > 0).to_equal(true)
            expect(r.pixel_hash != 0).to_equal(true)
            expect(r.backend).to_equal("simple_cpu_scalar")

        it "blit_tiles result has required fields":
            val r: BenchReport = tiny_bench(1, "blit_tiles")
            expect(r.scene_name).to_equal("blit_tiles")
            expect(r.frame_count > 0).to_equal(true)
            expect(r.pixel_hash != 0).to_equal(true)

        it "clipped_scroll result has required fields":
            val r: BenchReport = tiny_bench(2, "clipped_scroll")
            expect(r.scene_name).to_equal("clipped_scroll")
            expect(r.frame_count > 0).to_equal(true)
            expect(r.pixel_hash != 0).to_equal(true)

    context "report field completeness":
        it "fill_1080p report fields are all present and self-consistent":
            val r: BenchReport = tiny_bench(0, "fill_1080p")
            expect(r.pixels_per_sec >= 0).to_equal(true)
            expect(r.draws_per_sec >= 0).to_equal(true)
            expect(r.p95_ms >= r.p50_ms).to_equal(true)
            emit_report(r)

        it "blit_tiles report fields are self-consistent":
            val r: BenchReport = tiny_bench(1, "blit_tiles")
            expect(r.pixels_per_sec >= 0).to_equal(true)
            expect(r.p95_ms >= r.p50_ms).to_equal(true)
            emit_report(r)

        it "clipped_scroll report fields are self-consistent":
            val r: BenchReport = tiny_bench(2, "clipped_scroll")
            expect(r.pixels_per_sec >= 0).to_equal(true)
            expect(r.p95_ms >= r.p50_ms).to_equal(true)
            emit_report(r)

    context "pixel hash determinism":
        it "fill_1080p hash is stable across two runs":
            val r1: BenchReport = tiny_bench(0, "fill_1080p")
            val r2: BenchReport = tiny_bench(0, "fill_1080p")
            expect(r1.pixel_hash).to_equal(r2.pixel_hash)

        it "blit_tiles hash is stable across two runs":
            val r1: BenchReport = tiny_bench(1, "blit_tiles")
            val r2: BenchReport = tiny_bench(1, "blit_tiles")
            expect(r1.pixel_hash).to_equal(r2.pixel_hash)

        it "clipped_scroll hash is stable across two runs":
            val r1: BenchReport = tiny_bench(2, "clipped_scroll")
            val r2: BenchReport = tiny_bench(2, "clipped_scroll")
            expect(r1.pixel_hash).to_equal(r2.pixel_hash)

        it "different scenes produce different pixel hashes":
            val r0: BenchReport = tiny_bench(0, "fill_1080p")
            val r1: BenchReport = tiny_bench(1, "blit_tiles")
            val r2: BenchReport = tiny_bench(2, "clipped_scroll")
            expect(r0.pixel_hash == r1.pixel_hash).to_equal(false)
            expect(r0.pixel_hash == r2.pixel_hash).to_equal(false)

    context "NFR-2B structure":
        it "ratio threshold constant is 1250 representing 1.25x":
            expect(NFR_RATIO_THRESHOLD).to_equal(1250)

        it "ratio field initializes to -1 before C numbers available":
            val r: BenchReport = tiny_bench(0, "fill_1080p")
            expect(r.simple_vs_c_ratio).to_equal(-1)

        it "canonical scene list has exactly 3 entries":
            expect(CANONICAL_SCENES.len()).to_equal(3)
            expect(CANONICAL_SCENES[0]).to_equal("fill_1080p")
            expect(CANONICAL_SCENES[1]).to_equal("blit_tiles")
            expect(CANONICAL_SCENES[2]).to_equal("clipped_scroll")

        it "ratio formula: (simple_p50_ns * 1000) / c_p50_ns":
            val simple_ns: i64 = 1250
            val c_ns: i64 = 1000
            val ratio: i64 = (simple_ns * 1000) / c_ns
            expect(ratio).to_equal(1250)
            expect(ratio <= NFR_RATIO_THRESHOLD).to_equal(true)

        it "compute_joined fills ratio from real C p50_ns (fill_1080p)":
            val r: BenchReport = tiny_bench(0, "fill_1080p")
            # c_p50_ns from actual bench_2d run: 6146240 ns
            val joined: BenchReport = compute_joined(r, 6146240)
            expect(joined.simple_vs_c_ratio != -1).to_equal(true)
            expect(joined.simple_vs_c_ratio > 0).to_equal(true)
            emit_report(joined)

        it "compute_joined fills ratio from real C p50_ns (blit_tiles)":
            val r: BenchReport = tiny_bench(1, "blit_tiles")
            # c_p50_ns from actual bench_2d run: 7541685 ns
            val joined: BenchReport = compute_joined(r, 7541685)
            expect(joined.simple_vs_c_ratio != -1).to_equal(true)
            expect(joined.simple_vs_c_ratio > 0).to_equal(true)
            emit_report(joined)

        it "compute_joined fills ratio from real C p50_ns (clipped_scroll)":
            val r: BenchReport = tiny_bench(2, "clipped_scroll")
            # c_p50_ns from actual bench_2d run: 3194512 ns
            val joined: BenchReport = compute_joined(r, 3194512)
            expect(joined.simple_vs_c_ratio != -1).to_equal(true)
            expect(joined.simple_vs_c_ratio > 0).to_equal(true)
            emit_report(joined)

        it "p50_ns field is present in BenchReport":
            val r: BenchReport = tiny_bench(0, "fill_1080p")
            expect(r.p50_ns >= 0).to_equal(true)
