# test/perf/bench/method_dispatch_bench.spl
#
# Run: bin/simple run test/perf/bench/method_dispatch_bench.spl

use std.io_runtime
use std.time_utils.{rt_time_now_nanos}

class Counter:
    value: i32
    total: i32

    static fn new() -> Counter:
        Counter(value: 0, total: 0)

    me fn increment():
        self.value = self.value + 1
        self.total = self.total + 1

    me fn add(n: i32):
        self.value = self.value + n
        self.total = self.total + 1

    me fn reset():
        self.value = 0

fn main():
    print("=== Method Dispatch Microbenchmark ===")

    val iterations = 100000

    # Bench 1: simple method calls with field mutation
    var c = Counter.new()
    val t0 = rt_time_now_nanos()
    var i = 0
    while i < iterations:
        c.increment()
        i = i + 1
    val t1 = rt_time_now_nanos()
    print("increment: done")
    print(t1 - t0)

    # Bench 2: method with argument
    var c2 = Counter.new()
    val t2 = rt_time_now_nanos()
    i = 0
    while i < iterations:
        c2.add(i)
        i = i + 1
    val t3 = rt_time_now_nanos()
    print("add: done")
    print(t3 - t2)

    # Bench 3: 3 methods per iteration
    var c3 = Counter.new()
    val t4 = rt_time_now_nanos()
    i = 0
    while i < iterations:
        c3.increment()
        c3.reset()
        c3.add(i)
        i = i + 1
    val t5 = rt_time_now_nanos()
    print("3methods: done")
    print(t5 - t4)

    # Bench 4: pure loop baseline (no method calls)
    var x = 0
    val t6 = rt_time_now_nanos()
    i = 0
    while i < iterations:
        x = x + 1
        i = i + 1
    val t7 = rt_time_now_nanos()
    print("pure_loop: done")
    print(t7 - t6)

    print("=== Done ===")
