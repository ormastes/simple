#!/bin/sh
set -eu

# Keep the expensive cross-language profile harness safe to inspect from
# automation. `--help` must print usage and exit before compilation starts.

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../../.." && pwd)"
cd "$ROOT_DIR"

fail() {
    echo "profile_help_contract=false"
    echo "error=$1"
    exit 1
}

output="$(timeout 5 sh scripts/check/check-cross-language-perf.shs --help 2>&1)" ||
    fail "help command failed"

printf '%s\n' "$output" | grep -Fq "Usage:" ||
    fail "missing usage text"

if printf '%s\n' "$output" | grep -Fq "Compiling workloads"; then
    fail "help started profile compilation"
fi

echo "profile_help_contract=true"
