# web_smf_workload.spl — standalone web-domain workload, runnable in any mode.
#
# Self-times the in-memory HTTP parse + response-serialize seam (the web-domain
# representative op, no socket) and prints RESULT|<name>|<elapsed_us>|<iters>.
# Oracles gate output (parse method == "GET" every time; serialized length > 0).
# web_bench_driver compiles this to SMF, runs it, and parses mode="smf" rows.

use std.nogc_sync_mut.http_server.types.{HttpResponse}
use std.nogc_sync_mut.http_server.response.{serialize_response}
use std.nogc_sync_mut.http_server.parser.{parse_request_line}

extern fn rt_time_now_unix_micros() -> i64

fn main():
    val req = "GET /index.html HTTP/1.1"
    val n: i64 = 5000

    val p0 = rt_time_now_unix_micros()
    var i: i64 = 0
    var ok: i64 = 0
    while i < n:
        val (method, path, version) = parse_request_line(req)
        if method == "GET":
            ok = ok + 1
        i = i + 1
    val p_us = rt_time_now_unix_micros() - p0

    val s0 = rt_time_now_unix_micros()
    var j: i64 = 0
    var slen: i64 = 0
    while j < n:
        val resp = HttpResponse.ok("hello")
        val s = serialize_response(resp)
        slen = slen + s.len()
        j = j + 1
    val s_us = rt_time_now_unix_micros() - s0

    if ok == n and slen > 0:
        print("RESULT|http_parse_request_line|{p_us}|5000")
        print("RESULT|http_serialize_response|{s_us}|5000")
