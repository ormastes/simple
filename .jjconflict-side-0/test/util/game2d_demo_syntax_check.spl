use std.game2d as g

class Game:
    pos: g.Vec2

    fn load(self):
        pass_do_nothing

    fn update(self, dt: f32):
        if g.input.key_down(g.Key.right):
            self.pos.x = self.pos.x + 120.0 * dt

    fn fixed_update(self, step: f32):
        val _ = step

    fn draw(self, ctx: g.Canvas):
        val _ = ctx

fn main():
    g.run(Game(pos: g.Vec2(x: 100.0, y: 100.0)), "Hello", 800, 600)
