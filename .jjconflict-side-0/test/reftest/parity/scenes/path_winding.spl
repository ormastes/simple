# path_winding scene — winding fill rule (nonzero), cull 200x200

use std.skia.entity.picture.{SkPicture, SkPictureOp, SkPictureOpKind, sk_picture_op_draw_path}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.path.{SkPath, sk_path_new}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.enums.{SkPathFillType}
use std.skia.entity.color.{sk_color_argb}

fn scene() -> SkPicture:
    val cull = SkRect(left: 0.0, top: 0.0, right: 200.0, bottom: 200.0)
    # 5-point star: self-intersecting path with winding fill type
    val p0 = sk_path_new()
    val p1 = p0.move_to(100.0, 10.0)
    val p2 = p1.line_to(61.8, 138.2)
    val p3 = p2.line_to(190.2, 52.6)
    val p4 = p3.line_to(9.8, 52.6)
    val p5 = p4.line_to(138.2, 138.2)
    val p6 = p5.close()
    val star = p6.with_fill_type(SkPathFillType.Winding)
    val paint = sk_paint_fill(sk_color_argb(255, 30, 80, 200))
    val ops = [SkPictureOp]()
    ops.push(sk_picture_op_draw_path(star, paint))
    SkPicture(cull_rect: cull, op_count: ops.len() as i64, ops: ops)
