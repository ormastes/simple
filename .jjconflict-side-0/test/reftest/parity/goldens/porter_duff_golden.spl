# Golden fixture: porter_duff — 4 DrawRects with blend modes SrcOver, Multiply, Screen, DstIn

use std.skia.backend.cpu.backend.{CpuBackend, cpu_backend_new}
use std.skia.backend.cpu.raster_prims.{Bitmap}
use std.skia.entity.picture.{SkPicture, SkPictureOp, sk_picture_op_draw_rect}
use std.skia.entity.paint.{SkPaint, sk_paint_fill}
use std.skia.entity.geometry.{SkRect}
use std.skia.entity.color.{sk_color_red, sk_color_blue, sk_color_green, sk_color_argb}
use std.skia.entity.enums.{SkBlendMode}

fn golden() -> Bitmap:
    val cull = SkRect(left: 0.0, top: 0.0, right: 256.0, bottom: 256.0)
    # Rect 1: SrcOver (top-left quadrant), red
    val rect1 = SkRect(left: 0.0, top: 0.0, right: 128.0, bottom: 128.0)
    val paint_base = sk_paint_fill(sk_color_red())
    val paint1 = paint_base.with_blend_mode(SkBlendMode.SrcOver)
    val op1 = sk_picture_op_draw_rect(rect1, paint1)
    # Rect 2: Multiply (top-right quadrant), blue
    val rect2 = SkRect(left: 128.0, top: 0.0, right: 256.0, bottom: 128.0)
    val paint_blue = sk_paint_fill(sk_color_blue())
    val paint2 = paint_blue.with_blend_mode(SkBlendMode.Multiply)
    val op2 = sk_picture_op_draw_rect(rect2, paint2)
    # Rect 3: Screen (bottom-left quadrant), green
    val rect3 = SkRect(left: 0.0, top: 128.0, right: 128.0, bottom: 256.0)
    val paint_green = sk_paint_fill(sk_color_green())
    val paint3 = paint_green.with_blend_mode(SkBlendMode.Screen)
    val op3 = sk_picture_op_draw_rect(rect3, paint3)
    # Rect 4: DstIn (bottom-right quadrant), semi-transparent red
    val rect4 = SkRect(left: 128.0, top: 128.0, right: 256.0, bottom: 256.0)
    val semi_red = sk_color_argb(128, 255, 0, 0)
    val paint_semi = sk_paint_fill(semi_red)
    val paint4 = paint_semi.with_blend_mode(SkBlendMode.DstIn)
    val op4 = sk_picture_op_draw_rect(rect4, paint4)
    val ops = [op1, op2, op3, op4]
    val picture = SkPicture(cull_rect: cull, op_count: 4, ops: ops)
    val backend = cpu_backend_new()
    backend.render_picture(picture, cull)
