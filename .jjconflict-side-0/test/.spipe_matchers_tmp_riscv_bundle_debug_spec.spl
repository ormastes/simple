use std.spec.*
use hardware.fpga_linux.riscv_fpga_linux.generate_default_riscv_fpga_rtl_bundle

describe "tmp":
    it "unwraps bundle":
        val result = generate_default_riscv_fpga_rtl_bundle("/tmp/simple_rv64_fpga_rtl_spec_debug")
        expect result.is_ok() == true
        val bundle = result.ok().unwrap()
        expect bundle.generated_files.len() == 7