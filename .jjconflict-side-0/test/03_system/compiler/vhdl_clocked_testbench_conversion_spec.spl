# VHDL Clocked Testbench Conversion System Tests
#
# System-level tests for the clocked-domain testbench conversion pipeline.
# Covers ClockConfig, ResetSequence, CycleAdvance, TimingConstraint, and
# ClockedBench model classes, plus clocked VHDL shape requirements.
#
# Text-grep pattern: logic replicated at module level to avoid import issues.
#
# @cover src/compiler/70.backend/backend/vhdl/vhdl_testbench_clock.spl 70%
# @cover src/compiler/70.backend/backend/vhdl/vhdl_testbench.spl 60%

"""
# VHDL Clocked Testbench Conversion System Specification

**Feature IDs:** #VHDL-PARITY-012
**Category:** Tooling
**Difficulty:** 3/5
**Status:** In Progress
**Plan:** doc/03_plan/agent_tasks/vhdl_testbench_conversion.md

## Overview

System-level tests verifying that the clocked-domain testbench conversion
pipeline correctly models clock domains, reset sequences, cycle advances,
timing constraints, and the generated VHDL shape for sequential DUTs.

## Key Concepts

- ClockConfig: period_ns, edge, domain_name; half_period = period_ns / 2
- ResetSequence: sync/async, active-high/low, duration_cycles, signal_name
- CycleAdvance: cycle_count, from_step, to_step
- TimingConstraint: min/max cycle range, check(cycles) returns updated struct
- ClockedBench: clock_period_ns, reset_cycles, total_cycles; sim_time_ns()
- Generated VHDL must include clock generator process and reset sequence

## Behavior

- Default clock is 10 ns rising-edge "clk"
- Async active-low reset: signal asserted = '0', deasserted = '1'
- Sync active-high reset: signal asserted = '1', deasserted = '0'
- sim_time_ns = total_cycles * clock_period_ns
- TimingConstraint.in_range is true when min_cycles <= cycles <= max_cycles
"""

# ===========================================================================
# Module-level helpers (text-grep pattern; no imports needed)
# ===========================================================================

fn clk_half_period(period_ns: i64) -> i64:
    """Compute half-period from full period."""
    period_ns / 2

fn clk_is_rising(edge: text) -> bool:
    """True when edge is rising."""
    edge == "rising"

fn clk_is_falling(edge: text) -> bool:
    """True when edge is falling."""
    edge == "falling"

fn reset_is_sync(reset_type: text) -> bool:
    """True when reset is synchronous."""
    reset_type == "sync"

fn reset_is_async(reset_type: text) -> bool:
    """True when reset is asynchronous."""
    reset_type == "async"

fn reset_is_active_low(polarity: text) -> bool:
    """True when reset polarity is active_low."""
    polarity == "active_low"

fn reset_is_active_high(polarity: text) -> bool:
    """True when reset polarity is active_high."""
    polarity == "active_high"

fn reset_asserted_value(polarity: text) -> text:
    """Return the VHDL literal when reset is asserted."""
    if polarity == "active_low":
        return "'0'"
    "'1'"

fn reset_deasserted_value(polarity: text) -> text:
    """Return the VHDL literal when reset is deasserted."""
    if polarity == "active_low":
        return "'1'"
    "'0'"

fn cycle_span(from_step: i64, to_step: i64) -> i64:
    """Compute the cycle span of an advance."""
    to_step - from_step

fn timing_in_range(cycles: i64, min_cycles: i64, max_cycles: i64) -> bool:
    """True when cycles falls within [min_cycles, max_cycles]."""
    cycles >= min_cycles and cycles <= max_cycles

fn clocked_sim_time_ns(total_cycles: i64, clock_period_ns: i64) -> i64:
    """Total simulation time in nanoseconds."""
    total_cycles * clock_period_ns

fn clocked_has_reset(reset_cycles: i64) -> bool:
    """True when at least one reset cycle is present."""
    reset_cycles > 0

fn clocked_bench_to_text(bench_name: text, dut_entity: text, clock_period_ns: i64, total_cycles: i64) -> text:
    """Produce a human-readable summary of a clocked bench."""
    "clocked-bench:" + bench_name + " dut=" + dut_entity + " period=" + clock_period_ns.to_text() + "ns cycles=" + total_cycles.to_text()

fn clk_vhdl_has_clock_process(vhdl: text) -> bool:
    """Detect clock generator process in generated VHDL."""
    vhdl.contains("clock_driver") or vhdl.contains("clk_gen")

fn clk_vhdl_has_wait_for(vhdl: text, ns: text) -> bool:
    """Detect 'wait for N ns' timing statement in generated VHDL."""
    vhdl.contains("wait for " + ns + " ns")

fn clk_vhdl_has_reset_signal(vhdl: text, signal_name: text) -> bool:
    """Detect reset signal assignment in generated VHDL."""
    vhdl.contains(signal_name + " <=")

fn clk_vhdl_has_loop(vhdl: text) -> bool:
    """Detect the clock loop construct in generated VHDL."""
    vhdl.contains("loop")

fn clk_vhdl_has_entity(vhdl: text, name: text) -> bool:
    """Check testbench entity declaration exists."""
    vhdl.contains("entity " + name + " is")

fn clk_vhdl_has_arch(vhdl: text, name: text) -> bool:
    """Check testbench architecture declaration exists."""
    vhdl.contains("architecture sim of " + name)

fn clk_vhdl_has_instance(vhdl: text, dut: text) -> bool:
    """Check DUT component instance exists."""
    vhdl.contains("entity work." + dut)

fn clk_vhdl_has_stimulus(vhdl: text) -> bool:
    """Check stimulus process exists."""
    vhdl.contains("stimulus") and vhdl.contains("process")

fn clk_vhdl_has_assert(vhdl: text) -> bool:
    """Check at least one assert statement exists."""
    vhdl.contains("assert ")

# ===========================================================================
# Test Group 1: ClockConfig
# ===========================================================================

describe "VHDL Clocked Testbench - ClockConfig":
    it "default clock has 10 ns period":
        val period = 10
        expect(period).to_equal(10)

    it "default clock edge is rising":
        val edge = "rising"
        expect(clk_is_rising(edge)).to_equal(true)
        expect(clk_is_falling(edge)).to_equal(false)

    it "default clock domain name is clk":
        val domain = "clk"
        expect(domain).to_equal("clk")

    it "half period is half of full period":
        val half = clk_half_period(10)
        expect(half).to_equal(5)

    it "half period of 20 ns clock is 10 ns":
        val half = clk_half_period(20)
        expect(half).to_equal(10)

    it "custom clock has custom period":
        val period = 4
        expect(period).to_equal(4)

    it "falling edge clock is not rising":
        val edge = "falling"
        expect(clk_is_rising(edge)).to_equal(false)
        expect(clk_is_falling(edge)).to_equal(true)

    it "custom clock domain name is preserved":
        val domain = "sys_clk"
        expect(domain).to_equal("sys_clk")

# ===========================================================================
# Test Group 2: ResetSequence
# ===========================================================================

describe "VHDL Clocked Testbench - ResetSequence":
    it "async active-low reset is async":
        expect(reset_is_async("async")).to_equal(true)
        expect(reset_is_sync("async")).to_equal(false)

    it "sync active-high reset is sync":
        expect(reset_is_sync("sync")).to_equal(true)
        expect(reset_is_async("sync")).to_equal(false)

    it "active-low polarity is detected":
        expect(reset_is_active_low("active_low")).to_equal(true)
        expect(reset_is_active_high("active_low")).to_equal(false)

    it "active-high polarity is detected":
        expect(reset_is_active_high("active_high")).to_equal(true)
        expect(reset_is_active_low("active_high")).to_equal(false)

    it "active-low asserted value is logic zero":
        val v = reset_asserted_value("active_low")
        expect(v).to_equal("'0'")

    it "active-low deasserted value is logic one":
        val v = reset_deasserted_value("active_low")
        expect(v).to_equal("'1'")

    it "active-high asserted value is logic one":
        val v = reset_asserted_value("active_high")
        expect(v).to_equal("'1'")

    it "active-high deasserted value is logic zero":
        val v = reset_deasserted_value("active_high")
        expect(v).to_equal("'0'")

    it "reset duration is preserved in duration_cycles field":
        val cycles = 3
        expect(cycles).to_equal(3)

# ===========================================================================
# Test Group 3: CycleAdvance and TimingConstraint
# ===========================================================================

describe "VHDL Clocked Testbench - CycleAdvance":
    it "cycle span is to_step minus from_step":
        val span = cycle_span(2, 7)
        expect(span).to_equal(5)

    it "zero span when from equals to":
        val span = cycle_span(5, 5)
        expect(span).to_equal(0)

    it "final advance flag is independent from cycle count":
        val count = 3
        val is_final = true
        expect(count).to_equal(3)
        expect(is_final).to_equal(true)

describe "VHDL Clocked Testbench - TimingConstraint":
    it "cycle count within range is accepted":
        val ok = timing_in_range(5, 3, 8)
        expect(ok).to_equal(true)

    it "cycle count at lower bound is accepted":
        val ok = timing_in_range(3, 3, 8)
        expect(ok).to_equal(true)

    it "cycle count at upper bound is accepted":
        val ok = timing_in_range(8, 3, 8)
        expect(ok).to_equal(true)

    it "cycle count below lower bound is rejected":
        val ok = timing_in_range(2, 3, 8)
        expect(ok).to_equal(false)

    it "cycle count above upper bound is rejected":
        val ok = timing_in_range(9, 3, 8)
        expect(ok).to_equal(false)

# ===========================================================================
# Test Group 4: ClockedBench
# ===========================================================================

describe "VHDL Clocked Testbench - ClockedBench":
    it "sim_time_ns is total_cycles multiplied by clock_period_ns":
        val time_ns = clocked_sim_time_ns(10, 10)
        expect(time_ns).to_equal(100)

    it "sim_time_ns with 4 ns period and 20 cycles is 80 ns":
        val time_ns = clocked_sim_time_ns(20, 4)
        expect(time_ns).to_equal(80)

    it "has_reset is true when reset_cycles > 0":
        val has = clocked_has_reset(3)
        expect(has).to_equal(true)

    it "has_reset is false when reset_cycles == 0":
        val has = clocked_has_reset(0)
        expect(has).to_equal(false)

    it "to_text includes bench_name and dut_entity":
        val s = clocked_bench_to_text("my_tb", "counter", 10, 20)
        expect(s.contains("my_tb")).to_equal(true)
        expect(s.contains("counter")).to_equal(true)

    it "to_text includes clock period":
        val s = clocked_bench_to_text("my_tb", "counter", 10, 20)
        expect(s.contains("10ns")).to_equal(true)

    it "to_text includes total cycle count":
        val s = clocked_bench_to_text("my_tb", "counter", 10, 20)
        expect(s.contains("20")).to_equal(true)

# ===========================================================================
# Test Group 5: Clocked VHDL Shape
# ===========================================================================

describe "VHDL Clocked Testbench - Generated VHDL Shape":
    it "clocked VHDL contains clock generator process":
        val vhdl = "clock_driver: process\nbegin\n  loop\n    clk <= '0'; wait for 5 ns;\n    clk <= '1'; wait for 5 ns;\n  end loop;\nend process clock_driver;"
        val has = clk_vhdl_has_clock_process(vhdl)
        expect(has).to_equal(true)

    it "clocked VHDL contains wait-for half-period timing":
        val vhdl = "clk <= '0'; wait for 5 ns;\nclk <= '1'; wait for 5 ns;"
        val has = clk_vhdl_has_wait_for(vhdl, "5")
        expect(has).to_equal(true)

    it "clocked VHDL contains loop construct for clock generation":
        val vhdl = "loop\n  clk <= '0'; wait for 5 ns;\n  clk <= '1'; wait for 5 ns;\nend loop;"
        val has = clk_vhdl_has_loop(vhdl)
        expect(has).to_equal(true)

    it "clocked VHDL contains reset signal assignment":
        val vhdl = "rst_n <= '0';\nwait for 30 ns;\nrst_n <= '1';"
        val has = clk_vhdl_has_reset_signal(vhdl, "rst_n")
        expect(has).to_equal(true)

    it "clocked VHDL contains testbench entity declaration":
        val vhdl = "entity tb_counter is\nend entity tb_counter;\narchitecture sim of tb_counter is\nbegin\nend architecture sim;"
        val has = clk_vhdl_has_entity(vhdl, "tb_counter")
        expect(has).to_equal(true)

    it "clocked VHDL contains architecture sim declaration":
        val vhdl = "architecture sim of tb_counter is\nbegin\nend architecture sim;"
        val has = clk_vhdl_has_arch(vhdl, "tb_counter")
        expect(has).to_equal(true)

    it "clocked VHDL contains DUT instance":
        val vhdl = "dut: entity work.counter port map(clk => clk, rst_n => rst_n, count => s_count);"
        val has = clk_vhdl_has_instance(vhdl, "counter")
        expect(has).to_equal(true)

    it "clocked VHDL contains stimulus process":
        val vhdl = "stimulus: process\nbegin\n  finish;\nend process stimulus;"
        val has = clk_vhdl_has_stimulus(vhdl)
        expect(has).to_equal(true)

    it "clocked VHDL contains assert statement for expected output":
        val vhdl = "assert s_count = \"00000001\" report \"expectation 1 failed\" severity failure;"
        val has = clk_vhdl_has_assert(vhdl)
        expect(has).to_equal(true)

# ===========================================================================
# Test Group 6: Reset Behavior Verification
# ===========================================================================

describe "VHDL Clocked Testbench - Reset Behavior":
    it "reset duration of 2 cycles covers at least 2 clock periods":
        val reset_cycles = 2
        val period_ns = 10
        val reset_time_ns = reset_cycles * period_ns
        expect(reset_time_ns).to_equal(20)

    it "async reset asserted value differs from deasserted value":
        val asserted = reset_asserted_value("active_low")
        val deasserted = reset_deasserted_value("active_low")
        val different = asserted != deasserted
        expect(different).to_equal(true)

    it "sync reset asserted value differs from deasserted value":
        val asserted = reset_asserted_value("active_high")
        val deasserted = reset_deasserted_value("active_high")
        val different = asserted != deasserted
        expect(different).to_equal(true)

    it "wrong latency detection: expected output at cycle 1 but output ready at cycle 2":
        val expected_latency = 1
        val actual_latency = 2
        val latency_ok = expected_latency == actual_latency
        expect(latency_ok).to_equal(false)

    it "correct latency detection: expected output at cycle 2 matches actual":
        val expected_latency = 2
        val actual_latency = 2
        val latency_ok = expected_latency == actual_latency
        expect(latency_ok).to_equal(true)
