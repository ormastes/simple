# =========================================================================
# Extended Coverage (With Responsive Variants)
# =========================================================================

describe "GUI Widget Matrix: Extended Coverage (Orientations + Viewports)":

    it "calculates coverage with orientations (mobile only)":
        val core_tests = 5640
        val mobile_devices = 2  # Phone + Tablet
        val orientations = 2    # Portrait + Landscape
        val desktop_devices = 1 # Desktop (no orientation)

        # Mobile: 5640 × (1/3) mobile devices × 2 orientations
        # = 5640 × (2/3) × 2 = 7,520 tests for orientations
        # Total with core: 5640 + 7520 = 13,160 tests
        val extended_tests = core_tests + (core_tests / 3 * 2 * 2)
        expect(extended_tests).to_be_greater_than(5640)


    it "calculates coverage with viewport size variations":
        val core_tests = 5640
        val phone_sizes = 3      # Small, Medium, Large
        val tablet_sizes = 3
        val desktop_sizes = 3

        # Each widget × layout × system gets tested at 3 sizes per device
        # 47 × 8 × 5 × 3 (devices) × 3 (sizes) = 16,920 tests
        val with_viewports = core_tests * 3
        expect(with_viewports).to_equal(16920)


    it "calculates total comprehensive coverage":
        # Core: 5,640
        # + Orientations: ~5,000 (mobile)
        # + Viewport variations: 11,280
        # + Breakpoint edges: ~2,000
        # + Interactions: ~7,000
        # + Accessibility: ~4,000
        # = ~34,920 - 45,000 tests total

        val comprehensive_estimate = 40000
        expect(comprehensive_estimate).to_be_greater_than(0)
