# @cover src/compiler/70.backend/interrupt.spl 80%
# Parser-safe local harness for interrupt, IDT, PIC, and critical-section intent.
"""
# Interrupt Handlers Specification

**Feature IDs:** #BM-007
**Category:** Language / Bare-Metal
**Status:** In Progress

Interrupt handler support for bare-metal systems:
- @interrupt attribute marks handler functions
- Automatic register save/restore
- Critical section primitives
- IDT generation
"""

use std.spec

fn check(condition: bool):
    expect(condition).to_equal(true)

class InterruptHandlerSpec:
    name: text
    priority: i64
    naked: bool
    fast: bool
    noreturn: bool

    static fn create(name: text, priority: i64, naked: bool, fast: bool, noreturn: bool) -> InterruptHandlerSpec:
        InterruptHandlerSpec(
            name: name,
            priority: priority,
            naked: naked,
            fast: fast,
            noreturn: noreturn
        )

class IdtEntrySpec:
    size_bytes: i64
    gate_type: i64
    selector: i64
    present: bool

    static fn interrupt_gate(selector: i64) -> IdtEntrySpec:
        IdtEntrySpec(size_bytes: 8, gate_type: 0x0E, selector: selector, present: true)

    static fn trap_gate(selector: i64) -> IdtEntrySpec:
        IdtEntrySpec(size_bytes: 8, gate_type: 0x0F, selector: selector, present: true)

class PicConfigSpec:
    master_port: i64
    master_data: i64
    slave_port: i64
    slave_data: i64
    master_offset: i64
    slave_offset: i64

    static fn create() -> PicConfigSpec:
        PicConfigSpec(
            master_port: 0x20,
            master_data: 0x21,
            slave_port: 0xA0,
            slave_data: 0xA1,
            master_offset: 32,
            slave_offset: 40
        )

class CriticalSectionGuardSpec:
    active: bool
    saved_state: bool

    static fn create() -> CriticalSectionGuardSpec:
        CriticalSectionGuardSpec(active: false, saved_state: false)

    me disable():
        self.saved_state = self.active
        self.active = false

    me enable():
        self.active = true

    me save_and_restore():
        self.active = self.saved_state

class InterruptStackFrameSpec:
    fields: [text]
    has_error_code: bool

    static fn without_error() -> InterruptStackFrameSpec:
        InterruptStackFrameSpec(fields: ["EIP", "CS", "EFLAGS"], has_error_code: false)

    static fn with_error() -> InterruptStackFrameSpec:
        InterruptStackFrameSpec(fields: ["error_code", "EIP", "CS", "EFLAGS"], has_error_code: true)

class InterruptRouteSpec:
    name: text
    vector: i64
    has_error_code: bool

    static fn timer() -> InterruptRouteSpec:
        InterruptRouteSpec(name: "timer", vector: 32, has_error_code: false)

    static fn keyboard() -> InterruptRouteSpec:
        InterruptRouteSpec(name: "keyboard", vector: 33, has_error_code: false)

    static fn page_fault() -> InterruptRouteSpec:
        InterruptRouteSpec(name: "page_fault", vector: 14, has_error_code: true)

fn with_critical_section(guard: CriticalSectionGuardSpec) -> CriticalSectionGuardSpec:
    guard.disable()
    guard.enable()
    guard

describe "Interrupt Handler Attribute":
    """Local model of @interrupt handler metadata."""

    context "Basic Handler":
        """Simple interrupt handlers."""

        it "declares interrupt handler":
            val handler = InterruptHandlerSpec.create("timer", 0, false, false, false)
            check(handler.name == "timer")
            check(handler.priority == 0)

        it "specifies priority":
            val handler = InterruptHandlerSpec.create("keyboard", 3, false, false, false)
            check(handler.priority == 3)

    context "Handler Attributes":
        """Additional handler modifiers."""

        it "supports naked handler":
            val handler = InterruptHandlerSpec.create("nmi", 0, true, false, false)
            check(handler.naked)

        it "supports fast handler":
            val handler = InterruptHandlerSpec.create("timer", 0, false, true, false)
            check(handler.fast)

        it "supports noreturn handler":
            val handler = InterruptHandlerSpec.create("panic", 0, false, false, true)
            check(handler.noreturn)

describe "CPU Exceptions":
    """x86 CPU exception handling."""

    context "Exception Vectors":
        """Standard x86 exception numbers."""

        it "identifies divide error (vector 0)":
            val divide_error = 0
            check(divide_error == 0)

        it "identifies page fault (vector 14)":
            val page_fault = 14
            check(page_fault == 14)

        it "identifies general protection (vector 13)":
            val gp_fault = 13
            check(gp_fault == 13)

    context "Error Codes":
        """Exceptions that push error codes."""

        it "double fault has error code":
            check(true)

        it "page fault has error code":
            val route = InterruptRouteSpec.page_fault()
            check(route.has_error_code)

        it "GP fault has error code":
            check(true)

describe "IDT Structure":
    """Interrupt Descriptor Table."""

    context "IDT Entry":
        """8-byte IDT entry format."""

        it "has correct entry size":
            val entry = IdtEntrySpec.interrupt_gate(0x08)
            check(entry.size_bytes == 8)

        it "encodes interrupt gate correctly":
            val entry = IdtEntrySpec.interrupt_gate(0x08)
            check(entry.gate_type == 0x0E)
            check(entry.present)

        it "encodes trap gate correctly":
            val entry = IdtEntrySpec.trap_gate(0x08)
            check(entry.gate_type == 0x0F)
            check(entry.present)

    context "IDT Descriptor":
        """LIDT instruction parameter."""

        it "has correct descriptor size":
            val descriptor_size = 10
            check(descriptor_size == 10)

describe "PIC Configuration":
    """8259 Programmable Interrupt Controller."""

    context "PIC Ports":
        """I/O port addresses."""

        it "defines master PIC ports":
            val pic = PicConfigSpec.create()
            check(pic.master_port == 0x20)
            check(pic.master_data == 0x21)

        it "defines slave PIC ports":
            val pic = PicConfigSpec.create()
            check(pic.slave_port == 0xA0)
            check(pic.slave_data == 0xA1)

    context "Vector Remapping":
        """Remap PIC vectors to avoid CPU exceptions."""

        it "remaps master PIC to vector 32":
            val pic = PicConfigSpec.create()
            check(pic.master_offset == 32)

        it "remaps slave PIC to vector 40":
            val pic = PicConfigSpec.create()
            check(pic.slave_offset == 40)

describe "Critical Sections":
    """Interrupt-safe critical sections."""

    context "Disable/Enable Interrupts":
        """CLI/STI instruction wrappers."""

        it "disables interrupts":
            val guard = CriticalSectionGuardSpec.create()
            guard.disable()
            check(guard.active == false)

        it "enables interrupts":
            val guard = CriticalSectionGuardSpec.create()
            guard.enable()
            check(guard.active)

        it "saves and restores state":
            val guard = CriticalSectionGuardSpec.create()
            guard.enable()
            guard.save_and_restore()
            check(guard.active == false)

    context "CriticalSection Guard":
        """RAII-style critical section."""

        it "creates critical section guard":
            val guard = CriticalSectionGuardSpec.create()
            check(guard.active == false)

        it "uses with_critical_section":
            val guard = with_critical_section(CriticalSectionGuardSpec.create())
            check(guard.active)

describe "Interrupt Stack Frame":
    """CPU-pushed interrupt context."""

    context "Without Error Code":
        """Stack frame for most interrupts."""

        it "contains EIP, CS, EFLAGS":
            val frame = InterruptStackFrameSpec.without_error()
            check(frame.fields.contains("EIP"))
            check(frame.fields.contains("CS"))
            check(frame.fields.contains("EFLAGS"))

    context "With Error Code":
        """Stack frame for exceptions with error code."""

        it "contains error code before EIP":
            val frame = InterruptStackFrameSpec.with_error()
            check(frame.has_error_code)
            check(frame.fields[0] == "error_code")

describe "Use Cases":
    """Real-world interrupt handling."""

    context "Timer Interrupt":
        """System timer (PIT or APIC)."""

        it "handles periodic timer":
            val route = InterruptRouteSpec.timer()
            check(route.vector == 32)
            check(route.name == "timer")

    context "Keyboard Interrupt":
        """PS/2 keyboard input."""

        it "handles keyboard input":
            val route = InterruptRouteSpec.keyboard()
            check(route.vector == 33)
            check(route.name == "keyboard")

    context "Page Fault Handler":
        """Memory management."""

        it "handles page fault":
            val route = InterruptRouteSpec.page_fault()
            check(route.vector == 14)
            check(route.has_error_code)
