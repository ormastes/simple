# # `simple lint` CLI Contract
#
# System-level contract test for the pure-Simple `simple lint` CLI path
# (src/app/cli/lint_entry.spl -> app.io.cli_lint_commands.run_lint_command ->
# compiler.tools.lint.main.run_lint_file). Spawns the real seed binary as a
# subprocess (no raw rt_* externs here — process_run comes from app.io.mod)
# against two fixtures under test/fixtures/lint/:
#   - clean.spl: no lint violations, must exit 0
#   - dirty.spl: a Deny-level (D001 direct db write) and a Warn-level (W001
#     unused var) violation, must exit nonzero and name both violations
#
# This guards against the historical regression where `run_lint_file` was
# imported-but-undefined (silent "function not found" at call time) and a
# `read_file` name collision between compiler.tools.formatter.main and
# compiler.tools.lint._LintMain silently zeroed out all lint findings.
#
# Uses app.io.cli_ops._cli_process_run (a pub facade, not a raw rt_* extern)
# rather than app.io.mod.process_run: the latter, spawned inside a describe/it
# block and run through the Rust seed's interpreter, taints the *whole spec
# file's own process exit code* (a pre-existing seed-interpreter artifact —
# reproduced independently on the already-checked-in
# test/01_unit/app/io/process_limits_enforcement_spec.spl, whose examples all
# pass yet the file-level run still exits nonzero under
# `src/compiler_rust/target/release/simple test`). _cli_process_run does not
# exhibit this; see doc/08_tracking/bug/host_toolchain_seed_pinned_lint_fmt_doccov_unrunnable_2026-07-17.md
# for the filed writeup.

use app.io.cli_ops.{_cli_process_run}

val SIMPLE_SEED = "src/compiler_rust/target/release/simple"
val LINT_ENTRY = "src/app/cli/lint_entry.spl"

describe "simple lint CLI contract":
    """The pure-Simple lint CLI path must exit 0 on a clean file and exit
    nonzero (naming the violations) on a file with real lint findings."""

    it "exits 0 and reports clean on a violation-free file":
        val (stdout, stderr, code) = _cli_process_run(SIMPLE_SEED, ["run", LINT_ENTRY, "lint", "test/fixtures/lint/clean.spl"])
        assert_equal(code, 0)
        assert_contains(stdout, "Lint passed: all files clean")

    it "exits nonzero and names both violations on a dirty file":
        val (stdout, stderr, code) = _cli_process_run(SIMPLE_SEED, ["run", LINT_ENTRY, "lint", "test/fixtures/lint/dirty.spl"])
        assert_not_equal(code, 0)
        assert_contains(stdout, "W001")
        assert_contains(stdout, "D001")
        assert_contains(stdout, "Lint failed in 1 file(s)")
