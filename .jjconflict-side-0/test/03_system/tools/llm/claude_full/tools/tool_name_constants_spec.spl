"""
# Claude Full Tool Name Constants

Mirrors one-line Claude tool constant files so the strict full-parity matrix
has executable evidence for the literal tool names used by command dispatch.
"""

use std.spec.*
use app.llm_caret.claude_full.tools.EnterPlanModeTool.constants.{ENTER_PLAN_MODE_TOOL_NAME}
use app.llm_caret.claude_full.tools.EnterWorktreeTool.constants.{ENTER_WORKTREE_TOOL_NAME}
use app.llm_caret.claude_full.tools.ExitWorktreeTool.constants.{EXIT_WORKTREE_TOOL_NAME}
use app.llm_caret.claude_full.tools.SendMessageTool.constants.{SEND_MESSAGE_TOOL_NAME}
use app.llm_caret.claude_full.tools.SkillTool.constants.{SKILL_TOOL_NAME}

describe "Claude full tool name constants":
    it "should expose plan and worktree tool names":
        step("Read the tool constants mapped from Claude tool constant files")
        expect(ENTER_PLAN_MODE_TOOL_NAME).to_equal("EnterPlanMode")
        expect(ENTER_WORKTREE_TOOL_NAME).to_equal("EnterWorktree")
        expect(EXIT_WORKTREE_TOOL_NAME).to_equal("ExitWorktree")

    it "should expose message and skill tool names":
        step("Read the remaining tool constants in this batch")
        expect(SEND_MESSAGE_TOOL_NAME).to_equal("SendMessage")
        expect(SKILL_TOOL_NAME).to_equal("Skill")
