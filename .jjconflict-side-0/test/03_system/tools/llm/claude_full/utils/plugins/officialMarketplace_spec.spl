"""
# Claude Full official marketplace

Pure Simple coverage for official marketplace constants.
"""

use std.spec.*
use app.llm_caret.claude_full.utils.plugins.officialMarketplace.*

describe "Claude full official marketplace":
    it "exposes the first-party marketplace source and name":
        step("Check official marketplace constants")
        val source = officialMarketplaceSource()
        expect(source.source).to_equal("github")
        expect(source.repo).to_equal("anthropics/claude-plugins-official")
        expect(officialMarketplaceName()).to_equal("claude-plugins-official")
