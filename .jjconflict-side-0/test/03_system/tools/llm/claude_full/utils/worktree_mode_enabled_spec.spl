"""
# Claude Full worktreeModeEnabled

Pure Simple coverage for unconditional worktree mode enablement.
"""

use std.spec.*
use app.llm_caret.claude_full.utils.worktreeModeEnabled.*

describe "Claude full worktreeModeEnabled":
    it "always enables worktree mode":
        step("Check unconditional enablement")
        expect(isWorktreeModeEnabled()).to_equal(true)

    it "documents the removed stale flag gate":
        step("Check source-backed rationale")
        expect(worktreeModePreviousFlagName()).to_equal("tengu_worktree_mode")
        expect(worktreeModeEnableReason()).to_contain("stale cached flag")
        expect(worktreeModeEnableReason()).to_contain("--worktree")
        expect(worktreeModeIssueReference()).to_equal("27044")
