#!/bin/sh
# Build AC-1 demo plugin fixture (.so + .sdn manifest).
# Idempotent. Writes absolute paths so the manifest is project-root-independent.

set -e
DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$DIR"

cc -shared -fPIC -O2 -o demo.so demo.c

{
  echo "plugins:"
  echo "    -"
  echo "        name: demo"
  echo "        library: ${DIR}/demo.so"
  echo "        version: \"0.1\""
  echo "        functions: [simple_demo_add]"
} > demo.sdn

echo "Built: ${DIR}/demo.so"
echo "Wrote: ${DIR}/demo.sdn"
