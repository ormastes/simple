# SimpleOS Boot Integration Test Specification
#
# @cover src/os/kernel/boot/kernel_entry.spl 80%
# @cover src/os/kernel/boot/init_services.spl 70%
# @cover src/os/kernel/memory/pmm.spl 60%
# @cover src/os/kernel/boot/limine_boot.spl 50%
#
# Tests the full x86_64 boot sequence from entry through service init.
# Validated via QEMU serial output capture (scripts/os_qemu_test.shs).
#
# These assertions verify the host-visible boot contracts that the QEMU
# integration lane depends on: serial markers, boot launcher flags, and the
# service initialization paths that emit tiered status.

import std.spec

use std.spec.{describe, it, expect, context}

extern fn rt_file_read_text(path: text) -> text

fn _read(path: text) -> text:
    rt_file_read_text(path) ?? ""

fn _kernel_entry() -> text:
    _read("src/os/kernel/boot/kernel_entry.spl")

fn _init_services() -> text:
    _read("src/os/kernel/boot/init_services.spl")

describe "SimpleOS x86_64 Boot Integration":

    context "Tier 1 -- Boot Smoke":
        it "kernel_main is called after Multiboot2 handoff":
            # Verified by: serial output contains "Hello from SimpleOS" within 10s
            expect(_kernel_entry()).to_contain("Hello from SimpleOS")

        it "serial output is initialized on COM1 at 115200 baud":
            # Verified by: serial_init() runs, serial_println produces output
            expect(_kernel_entry()).to_contain("Serial output working on COM1 at 115200 baud")

        it "boot banner is printed to serial":
            # Verified by: grep "Kernel booted" in serial log
            expect(_kernel_entry()).to_contain("Kernel booted via Multiboot2 on x86_64")

    context "Tier 2 -- Memory Initialization":
        it "PMM initializes with usable memory regions from boot info":
            # Verified by: serial output contains "PMM" or "pmm_init"
            expect(_read("src/os/kernel/memory/pmm.spl")).to_contain("fn pmm_init")

        it "VMM creates page tables for higher-half mapping":
            # Verified by: serial output contains "VMM" or page table messages
            expect(_read("src/os/kernel/memory/vmm.spl")).to_contain("fn vmm_init")

        it "identity maps low physical memory with large pages":
            # Verified by: kernel continues past memory init without page fault
            expect(_read("src/os/kernel/memory/vmm.spl")).to_contain("_identity_map_4gb()")

    context "Tier 3 -- Service Initialization":
        it "init_all_services runs without panic":
            # Verified by: serial output contains "[init] Starting SimpleOS services"
            expect(_init_services()).to_contain("[init] Starting SimpleOS services")

        it "PCI bus scan discovers devices on Q35 chipset":
            # Verified by: serial output contains "pcimgr" device dump
            expect(_init_services()).to_contain("pcimgr_dump_devices()")

        it "VFS initializes (with or without NVMe backing)":
            # Verified by: serial output contains "[init] Storage stack"
            expect(_init_services()).to_contain("[init] Storage stack:")

        it "network stack probes for VirtIO-net":
            # Verified by: serial output contains "[init] Network stack"
            expect(_init_services()).to_contain("[init] Network stack:")

    context "Tier 4 -- Shell / Main Loop":
        it "OS reaches main event loop or shell prompt":
            # Verified by: serial output contains "ready" or "shell"
            expect(_init_services()).to_contain("Service initialization complete")

        it "kernel does not triple-fault within QEMU timeout":
            # Verified by: QEMU exits via isa-debug-exit, not timeout/crash
            expect(_kernel_entry()).to_contain("Halting.")

    context "Tier 5 -- Display / Compositor":
        it "framebuffer backend initializes when VGA device is present":
            # Verified by: serial output contains "framebuffer" or "compositor"
            expect(_init_services()).to_contain("bga_init_framebuffer")

        it "display service reports status during init":
            # Verified by: serial output contains "[init] Display service"
            expect(_init_services()).to_contain("svc_display_ok")
