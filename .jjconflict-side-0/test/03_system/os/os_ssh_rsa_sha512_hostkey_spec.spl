"""
# SSH RSA-SHA2-512 Host Key Signing Specification

**Feature IDs:** N/A
**Category:** Infrastructure
**Difficulty:** 3/5
**Status:** Implemented

## Overview

End-to-end test of `ssh_sign_exchange_hash` for the `"rsa-sha2-512"` algorithm.
Verifies that the function correctly:
- Produces a well-formed SSH signature blob when an RSA PKCS#8 key is present.
- Returns an error when the RSA key is absent.
- Encodes the algorithm name `"rsa-sha2-512"` (not `"rsa-sha2-256"` or `"ssh-rsa"`)
  as the first SSH string in the signature blob.
- Produces a raw signature that round-trips through `rsa_sha512_verify`.

tag: system, ssh, crypto
"""

use std.spipe.*
use os.apps.sshd.ssh_kex.{HostKeySet, ssh_sign_exchange_hash}
use os.apps.sshd.ssh_packet.{ssh_get_text, ssh_get_string, SshTextResult, SshStringResult}
use os.apps.sshd.host_key_loader.{load_rsa_pkcs8_from_file}
use os.crypto.rsa.{rsa_sha512_verify}

extern fn rt_file_exists(path: text) -> bool
extern fn rt_file_read_bytes(path: text) -> [u8]
extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)
extern fn rt_dir_create(path: text, recursive: bool) -> bool
extern fn rt_text_to_bytes(s: text) -> [u8]

fn hex_to_bytes(s: text) -> [u8]:
    val hex_bytes = rt_text_to_bytes(s)
    if (hex_bytes.len() % 2) != 0:
        return []
    var out: [u8] = []
    var i: u64 = 0
    while i + 1 < hex_bytes.len():
        val hi = _hex_nibble(hex_bytes[i])
        val lo = _hex_nibble(hex_bytes[i + 1])
        out.push((hi << 4) | lo)
        i = i + 2
    out

fn _hex_nibble(c: u8) -> u8:
    if c >= 0x30 and c <= 0x39:
        return c - 0x30
    if c >= 0x61 and c <= 0x66:
        return c - 0x61 + 10
    if c >= 0x41 and c <= 0x46:
        return c - 0x41 + 10
    0

# ============================================================================
# Fixture helpers
# ============================================================================

fn _make_exchange_hash() -> [u8]:
    """32-byte synthetic exchange hash (deterministic, non-empty)."""
    var h: [u8] = []
    var i: u64 = 0
    while i < 32:
        h.push((i + 1).to_u8())
        i = i + 1
    h

val TEST_DIR = "/tmp/os_ssh_rsa_sha512_hostkey_spec"
val RSA_PEM = TEST_DIR + "/rsa.pem"
val RSA_PK8 = TEST_DIR + "/rsa.pk8"
val RSA_SPKI = TEST_DIR + "/rsa.spki"

fn _openssl_available() -> bool:
    val (_out, _err, code) = rt_process_run("which", ["openssl"])
    code == 0

fn _fixture_exists() -> bool:
    rt_file_exists(RSA_PK8) and rt_file_exists(RSA_SPKI)

fn _run_or_print(cmd: text, args: [text]) -> bool:
    val (out, err, code) = rt_process_run(cmd, args)
    if code != 0:
        print("{cmd} stdout: {out}")
        print("{cmd} stderr: {err}")
    code == 0

fn _ensure_rsa_fixture() -> bool:
    rt_dir_create(TEST_DIR, true)
    if _fixture_exists():
        return true
    if not _openssl_available():
        return false
    if not _run_or_print("openssl", [
        "genpkey",
        "-algorithm", "RSA",
        "-pkeyopt", "rsa_keygen_bits:2048",
        "-out", RSA_PEM
    ]):
        return false
    if not _run_or_print("openssl", [
        "pkcs8",
        "-topk8",
        "-nocrypt",
        "-in", RSA_PEM,
        "-outform", "DER",
        "-out", RSA_PK8
    ]):
        return false
    _run_or_print("openssl", [
        "pkey",
        "-in", RSA_PEM,
        "-pubout",
        "-outform", "DER",
        "-out", RSA_SPKI
    ])

fn _load_rsa_pkcs8() -> [u8]:
    match load_rsa_pkcs8_from_file(RSA_PK8):
        Ok(bytes):
            bytes
        Err(_msg):
            []

fn _load_bytes(path: text) -> [u8]:
    rt_file_read_bytes(path) ?? []

# ============================================================================
# Suite
# ============================================================================

describe "os_ssh_rsa_sha512_hostkey: rsa-sha2-512 host key signing":
    """
    ## rsa-sha2-512 Host Key Signing

    Exercises `ssh_sign_exchange_hash("rsa-sha2-512", ...)` end-to-end.
    Uses the same RSA 2048-bit PKCS#8 / SPKI fixtures from
    `os_crypto_ref_signature_spec`.
    """

    it "rsa-sha2-512 signs and the raw signature verifies with rsa_sha512_verify":
        if not _ensure_rsa_fixture():
            return "skip: openssl RSA fixture generation unavailable"
        val pkcs8 = _load_rsa_pkcs8()
        val spki = _load_bytes(RSA_SPKI)
        val exchange_hash = _make_exchange_hash()
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: pkcs8,
            ecdsa_p256_pkcs8: nil
        )
        val result = ssh_sign_exchange_hash("rsa-sha2-512", host_keys, exchange_hash)
        expect(result.is_ok()).to_equal(true)
        val blob = result.unwrap()
        expect(blob.len() > 0).to_equal(true)
        # Parse the SSH blob: first string is the algo name
        val r_algo = ssh_get_text(blob, 0)
        expect(r_algo.is_ok()).to_equal(true)
        val algo_result = r_algo.unwrap()
        expect(algo_result.value).to_equal("rsa-sha2-512")
        # Second string is the raw signature bytes
        val r_sig = ssh_get_string(blob, algo_result.next_offset)
        expect(r_sig.is_ok()).to_equal(true)
        val sig_result = r_sig.unwrap()
        val raw_sig = sig_result.data
        expect(raw_sig.len() > 0).to_equal(true)
        # Round-trip verify: raw_sig must verify against exchange_hash with SPKI
        val verified = rsa_sha512_verify(spki, exchange_hash, raw_sig)
        expect(verified).to_equal(true)

    it "rsa-sha2-512 signing fails when rsa_pkcs8 is nil":
        val exchange_hash = _make_exchange_hash()
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: nil,
            rsa_public_blob: nil,
            ecdsa_p256_pkcs8: nil
        )
        val result = ssh_sign_exchange_hash("rsa-sha2-512", host_keys, exchange_hash)
        expect(result.is_err()).to_equal(true)
        val msg = result.unwrap_err()
        expect(msg).to_contain("no RSA key")

    it "rsa-sha2-512 algo-header is correct in signature blob":
        if not _ensure_rsa_fixture():
            return "skip: openssl RSA fixture generation unavailable"
        val pkcs8 = _load_rsa_pkcs8()
        val exchange_hash = _make_exchange_hash()
        val host_keys = HostKeySet(
            ed25519_seed: nil,
            rsa_pkcs8: pkcs8,
            ecdsa_p256_pkcs8: nil
        )
        val result = ssh_sign_exchange_hash("rsa-sha2-512", host_keys, exchange_hash)
        expect(result.is_ok()).to_equal(true)
        val blob = result.unwrap()
        val r_algo = ssh_get_text(blob, 0)
        expect(r_algo.is_ok()).to_equal(true)
        val algo_result = r_algo.unwrap()
        # Must be exactly "rsa-sha2-512" — not "rsa-sha2-256" or "ssh-rsa"
        expect(algo_result.value).to_equal("rsa-sha2-512")
        expect(algo_result.value).to_not_equal("rsa-sha2-256")
        expect(algo_result.value).to_not_equal("ssh-rsa")
