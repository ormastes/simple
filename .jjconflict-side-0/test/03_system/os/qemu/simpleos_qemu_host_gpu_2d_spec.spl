fn run_cuda_readback_wrapper_self_test() -> text:
    val (out, err, code) = process_run("/bin/sh", ["scripts/check/check-cuda-generated-2d-readback.shs", "--self-test"])
    expect(code).to_equal(0)
    out

fn run_generated_2d_matrix_self_test() -> text:
    val (out, err, code) = process_run("/bin/sh", ["scripts/check/check-generated-2d-backend-readback-matrix-evidence.shs", "--self-test"])
    expect(code).to_equal(0)
    out

