# @tag: rendering, engine2d, metal, readback
# @cover src/lib/gc_async_mut/gpu/engine2d/backend_metal.spl 45%
#
# Verifies Engine2D read_pixels can use a real Metal framebuffer download for
# the subset of drawing operations currently implemented by GPU kernels.

use std.spec.{describe, context, it, expect}
use std.gc_async_mut.gpu.engine2d.backend_metal.{MetalBackend}
use std.nogc_sync_mut.env.platform.{is_macos}
extern fn rt_file_read_text(path: text) -> text

describe "Metal Engine2D framebuffer readback":

    it "constructs one-call readback arrays in the selected runtime owner":
        val core = rt_file_read_text("src/runtime/simple_core/core_array_ops.spl") ?? ""
        val gate = rt_file_read_text("scripts/check/check-simple-core-runtime-smoke.shs") ?? ""

        expect(core).to_contain("pub fn rt_u32s_from_raw(data_ptr: i64, count: i64) -> i64:")
        expect(core).to_contain("rt_typed_words_u32_push_known_at(result, i, word)")
        expect(gate).to_contain("rt_u32s_from_raw")

    it "retains unknown Metal submission dependencies in the runtime facade":
        val owner = rt_file_read_text("src/lib/nogc_sync_mut/io/metal_sffi.spl") ?? ""
        val backend = rt_file_read_text("src/lib/gc_async_mut/gpu/engine2d/backend_metal.spl") ?? ""

        expect(owner).to_contain("fn metal_sffi_quarantine_submission(command: i64, encoder: i64, source: i64, framebuffer: i64) -> bool:")
        expect(owner).to_contain("fn metal_sffi_reap_submission_quarantine() -> bool:")
        expect(owner).to_contain("metal_sffi_quarantine_release_proven(wait_succeeded, existing_command_released_after_wait)")
        expect(backend).to_contain("metal_sffi_quarantine_submission(")
        expect(owner).to_contain("fn metal_sffi_release_uncommitted_submission(command: i64, encoder: i64, source: i64):")
        expect(backend).to_contain("metal_sffi_release_uncommitted_submission(cmd, encoder, src_buf)")
        expect(backend).to_contain("Metal image composite commit failed")
        expect(backend).to_contain("Metal auxiliary image commit failed")
        expect(backend).to_not_contain("not committed or not metal_sffi_wait_completed")
        expect(backend).to_contain("self.d_framebuffer = 0")

    it "has a strict native proof for the unknown-command retention path":
        val probe = rt_file_read_text("test/02_integration/rendering/metal_sffi_quarantine_native_probe.spl") ?? ""

        expect(probe).to_contain("metal_sffi_quarantine_submission(0x5a5a5a, 0, 0, 0)")
        expect(probe).to_contain("fn _metal_registry_lifecycle_available() -> bool:")
        expect(probe).to_contain("val command_released = metal_sffi_destroy_command_buffer(command)")
        expect(probe).to_contain("if not metal_sffi_is_available() or not _metal_registry_lifecycle_available():")
        expect(probe).to_contain("if metal_sffi_reap_submission_quarantine():")
        expect(probe).to_contain("metal-sffi-quarantine: pass")

    context "raw GPU pixels":

        it "downloads clear and rect_filled pixels from the Metal framebuffer":
            if is_macos():
                var b = MetalBackend.create()
                expect(b.init(16, 16)).to_equal(true)
                b.clear(0x10203040 as u32)
                # Opaque fill (alpha=0xFF): overwrite semantics, the raw
                # framebuffer-download proof this spec exists for.
                b.draw_rect_filled(4, 4, 4, 4, 0xFF020304 as u32)
                # Semi-transparent fill (alpha=0x01): pins the src-over blend
                # contract shared bit-exact by the CPU mirror (color.blend())
                # and the Metal kernel (blend_src_over() in
                # backend_metal_msl.spl), added in commit 97e3699cd3.
                b.draw_rect_filled(8, 8, 4, 4, 0x01020304 as u32)
                expect(b.gpu_frame_complete).to_equal(true)
                val pixels = b.read_pixels()
                expect(pixels.len()).to_equal(256)
                expect(pixels[0]).to_equal(0x10203040 as u32)
                expect(pixels[4 + (4 * 16)]).to_equal(0xFF020304 as u32)
                # src-over blend of 0x01020304 over clear color 0x10203040:
                #   inv = 255 - 1 = 254
                #   r = (0x02*1 + 0x20*254) / 255 = 8130 / 255  = 31 = 0x1F
                #   g = (0x03*1 + 0x30*254) / 255 = 12195 / 255 = 47 = 0x2F
                #   b = (0x04*1 + 0x40*254) / 255 = 16260 / 255 = 63 = 0x3F
                #   a = 1 + (0x10*254) / 255       = 1 + 15      = 16 = 0x10
                # => 0x101F2F3F
                expect(pixels[8 + (8 * 16)]).to_equal(0x101F2F3F as u32)
                b.shutdown()
            else:
                expect(is_macos()).to_equal(false)

        it "applies set_clip to GPU-only Metal dispatch and restores full bounds after clear_clip":
            if is_macos():
                var b = MetalBackend.create()
                expect(b.init(8, 8)).to_equal(true)
                b.use_gpu_only()
                expect(b.width()).to_equal(8)
                expect(b.height()).to_equal(8)
                expect(b.mirror.width()).to_equal(8)
                expect(b.mirror.height()).to_equal(8)
                b.clear(0xff000000u32)
                b.set_clip(2, 2, 3, 2)
                b.draw_rect_filled(0, 0, 8, 8, 0xffff0000u32)
                b.clear_clip()
                b.draw_rect_filled(7, 7, 1, 1, 0xff00ff00u32)
                expect(b.gpu_frame_complete).to_equal(true)
                val pixels = b.read_pixels()
                expect(pixels[0]).to_equal(0xff000000u32)
                expect(pixels[2 + (2 * 8)]).to_equal(0xffff0000u32)
                expect(pixels[4 + (3 * 8)]).to_equal(0xffff0000u32)
                expect(pixels[5 + (3 * 8)]).to_equal(0xff000000u32)
                expect(pixels[7 + (7 * 8)]).to_equal(0xff00ff00u32)
                b.shutdown()
            else:
                expect(is_macos()).to_equal(false)

        it "fails closed for emulated image blending in GPU-only mode":
            if is_macos():
                var b = MetalBackend.create()
                expect(b.init(4, 4)).to_equal(true)
                b.use_gpu_only()
                b.clear(0xff000000u32)
                b.draw_image_blend(0, 0, 1, 1, [0x80ffffffu32])
                expect(b.gpu_frame_complete).to_equal(false)
                expect(b.read_pixels().len()).to_equal(0)
                b.shutdown()
            else:
                expect(is_macos()).to_equal(false)

        it "stays GPU-complete after draw_text via the glyph-atlas kernel (GPU-dict use case #2, W4)":
            if is_macos():
                var b = MetalBackend.create()
                expect(b.init(16, 16)).to_equal(true)
                b.clear(0x10203040 as u32)
                # draw_text now dispatches ONE kernel_glyph_atlas_blit (design
                # cpu_gpu_dual_algorithm W4) instead of the former per-lit-pixel
                # rect path, so it is a genuine GPU op that keeps the frame
                # GPU-complete. Parity vs the CPU oracle is proven bit-exact in
                # engine2d_gpu_offload_evidence.spl (text/text_edge rows,
                # device_readback). (The old expectation here — gpu_frame_complete
                # == false, from the pre-GPU-text era — was already failing.)
                b.draw_text(1, 1, "A", 0x01020304 as u32, 8)
                expect(b.gpu_frame_complete).to_equal(true)
                val pixels = b.read_pixels()
                expect(pixels.len()).to_equal(256)
                b.shutdown()
            else:
                expect(is_macos()).to_equal(false)

        it "blends a semi-transparent circle_filled identically on CPU mirror and Metal device (E1 fix)":
            if is_macos():
                var b = MetalBackend.create()
                expect(b.init(16, 16)).to_equal(true)
                b.clear(0x10203040 as u32)
                # Same src-over contract pinned by the rect_filled case above:
                # 0x01020304 over 0x10203040 => 0x101F2F3F. Before the fix,
                # kernel_draw_circle_filled wrote the raw 0x01020304 word with
                # no blend, so the device readback diverged from the CPU
                # mirror (which always blended via sw_hline_blend).
                b.draw_circle_filled(8, 8, 6, 0x01020304 as u32)
                expect(b.gpu_frame_complete).to_equal(true)
                val idx = 8 + (8 * 16)
                val mirror_pixels = b.mirror.read_pixels()
                val device_pixels = b.read_pixels()
                expect(mirror_pixels[idx]).to_equal(0x101F2F3F as u32)
                expect(device_pixels[idx]).to_equal(0x101F2F3F as u32)
                b.shutdown()
            else:
                expect(is_macos()).to_equal(false)

        it "blends a semi-transparent triangle_filled identically on CPU mirror and Metal device (E2 fix)":
            if is_macos():
                var b = MetalBackend.create()
                expect(b.init(16, 16)).to_equal(true)
                b.clear(0x10203040 as u32)
                # Same src-over contract as above, applied to the triangle
                # kernel: before the fix kernel_draw_triangle_filled wrote
                # the raw color with no blend.
                b.draw_triangle_filled(8, 2, 2, 14, 14, 14, 0x01020304 as u32)
                expect(b.gpu_frame_complete).to_equal(true)
                val idx = 8 + (8 * 16)
                val mirror_pixels = b.mirror.read_pixels()
                val device_pixels = b.read_pixels()
                expect(mirror_pixels[idx]).to_equal(0x101F2F3F as u32)
                expect(device_pixels[idx]).to_equal(0x101F2F3F as u32)
                b.shutdown()
            else:
                expect(is_macos()).to_equal(false)

        it "leaves the framebuffer unchanged for degenerate-dim draws on both lanes (E3/E4/E5 fix)":
            if is_macos():
                var b = MetalBackend.create()
                expect(b.init(16, 16)).to_equal(true)
                val bg = 0xFF203040 as u32
                b.clear(bg)
                # w>0,h<0 outline rect; r==0 filled circle; w==0 rounded rect.
                # Before the fix the CPU mirror still painted partial content
                # for each of these (edges / center pixel / vlines) while the
                # Metal dispatch guards no-op'd the whole call, so the two
                # buffers diverged from each other and from the plain clear.
                b.draw_rect(4, 4, 8, -3, 0xFFFF0000 as u32)
                b.draw_circle_filled(4, 4, 0, 0xFF00FF00 as u32)
                b.draw_rounded_rect(2, 2, 0, 8, 2, 0xFF0000FF as u32)
                expect(b.gpu_frame_complete).to_equal(true)
                val mirror_pixels = b.mirror.read_pixels()
                val device_pixels = b.read_pixels()
                var mirror_mismatches = 0
                var device_mismatches = 0
                var i = 0
                while i < mirror_pixels.len():
                    if mirror_pixels[i] != bg:
                        mirror_mismatches = mirror_mismatches + 1
                    if device_pixels[i] != bg:
                        device_mismatches = device_mismatches + 1
                    i = i + 1
                expect(mirror_mismatches).to_equal(0)
                expect(device_mismatches).to_equal(0)
                b.shutdown()
            else:
                expect(is_macos()).to_equal(false)
