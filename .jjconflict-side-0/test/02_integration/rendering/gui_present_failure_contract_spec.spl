extern fn rt_file_read_text(path: text) -> text
use std.spec.{describe, it, expect}

describe "GUI presentation failure contract":
    it "routes Chromium presentation through the typed owner":
        val backend = rt_file_read_text("src/app/ui.chromium/backend.spl") ?? ""
        val app = rt_file_read_text("src/app/ui.chromium/app.spl") ?? ""

        expect(backend).to_contain("use std.nogc_sync_mut.io.window_winit.{WinitWindow, winit_present_rgba}")
        expect(backend).to_not_contain("extern fn rt_winit_window_present_rgba")
        expect(backend).to_contain("me present_to_window() -> bool:")
        expect(app).to_contain("me render_active_tab() -> bool:")
        expect(app).to_contain("if presented:\n                self.tab_manager.active_tab().clear_dirty()")
        expect(app).to_contain("me run() -> bool:")
        expect(app).to_contain("if not presentation_ok:\n            self.running = false")

    it "fails the markdown GUI when initial or periodic presentation fails":
        val source = rt_file_read_text("src/app/office/md_wysiwyg_gui.spl") ?? ""

        expect(source).to_contain("if not winit_present_rgba(win, RW.to_i64(), RH.to_i64(), packed):")
        expect(source).to_contain("var present_failed = false")
        expect(source).to_contain("if present_failed:\n        return 2")

    it "closes Game2D after a failed native presentation":
        val source = rt_file_read_text("src/lib/nogc_sync_mut/game2d/backend/sdl_backend.spl") ?? ""

        expect(source).to_contain("use std.nogc_sync_mut.io.window_winit.{WinitWindow, winit_present_rgba}")
        expect(source).to_not_contain("extern fn rt_winit_window_present_rgba")
        expect(source).to_contain("val presented = winit_present_rgba(win, self.width, self.height, px)")
        expect(source).to_contain("if not presented:\n                self.should_close_flag = true\n                self.window.closed = true")
