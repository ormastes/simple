# Evidence harness: SIMPLE_WEB_GPU_PAINT per-primitive GPU offload parity.
#
# Proves that the new web-lane GPU-paint path (present_gpu_paint_readback in
# simple_web_html_engine2d_presenter.spl) composes a page frame from REAL
# per-primitive Engine2D backend calls — one draw_rect_filled per solid CSS box
# plus a residual blit — and that its Metal readback is BIT-EXACT with:
#   (a) the default upload-bound path (full CPU bitmap -> single draw_image), and
#   (b) the CPU software oracle framebuffer.
#
# The presenter prints the op-kind dispatch counts (rect=N gradient=M blit=K) for
# the GPU-paint frame, which is the proof that the GPU does per-primitive work
# rather than one giant upload+blit.
#
# Fixture mirrors test/fixtures/pixel_compare/css_boxes.html @ 320x240 (the
# tri-lane gate fixture). Metal is required; on non-macOS the harness reports a
# skip and the gate passes.

use std.gc_async_mut.gpu.browser_engine.simple_web_html_engine2d_presenter.{
    simple_web_layout_render_html_readback_paint}

fn ob() -> text: "{"
fn cb() -> text: "}"

fn css_boxes_html() -> text:
    val css = "html, body " + ob() + " margin: 0; padding: 0; width: 320px; height: 240px; overflow: hidden; background: #ffffff; " + cb() +
        " .box " + ob() + " width: 80px; height: 40px; margin: 8px; background: #2563eb; " + cb() +
        " .box-red " + ob() + " width: 60px; height: 30px; margin: 8px; padding: 4px; background: #ef4444; " + cb() +
        " .box-green " + ob() + " width: 100px; height: 20px; margin: 4px 8px; background: #22c55e; " + cb()
    "<!doctype html><meta charset='utf-8'><style>" + css + "</style><body>" +
        "<div class='box'></div><div class='box-red'></div><div class='box-green'></div></body>"

fn count_mismatch(a: [u32], b: [u32]) -> i32:
    if a.len() != b.len():
        return -1
    var mism = 0
    var i = 0
    while i < a.len():
        if a[i] != b[i]:
            mism = mism + 1
        i = i + 1
    mism

fn main() -> i64:
    val w = 320
    val h = 240
    val html = css_boxes_html()

    # (a) default upload-bound path through Metal (SIMPLE_WEB_GPU_PAINT=0)
    val cpu_lane = simple_web_layout_render_html_readback_paint(html, w, h, "metal", false)
    # (b) new per-primitive GPU-paint path through Metal (SIMPLE_WEB_GPU_PAINT=1)
    val gpu_lane = simple_web_layout_render_html_readback_paint(html, w, h, "metal", true)
    # (c) CPU software oracle framebuffer
    val oracle = simple_web_layout_render_html_readback_paint(html, w, h, "cpu", false)

    print "cpu_lane source={cpu_lane.source} px={cpu_lane.pixels.len()}"
    print "gpu_lane source={gpu_lane.source} px={gpu_lane.pixels.len()}"
    print "oracle   source={oracle.source} px={oracle.pixels.len()}"

    if gpu_lane.source == "cpu_fallback" or cpu_lane.source == "cpu_fallback":
        print "web-gpu-paint-parity: SKIP reason=metal-unavailable"
        print "SUMMARY: pass (skipped)"
        return 0

    val diff_lanes = count_mismatch(cpu_lane.pixels, gpu_lane.pixels)
    val diff_oracle = count_mismatch(oracle.pixels, gpu_lane.pixels)
    print "parity gpu_vs_upload_mism={diff_lanes} gpu_vs_cpu_oracle_mism={diff_oracle}"

    val ok = diff_lanes == 0 and diff_oracle == 0 and gpu_lane.pixels.len() == w * h
    if ok:
        print "SUMMARY: pass"
        return 0
    print "SUMMARY: fail"
    1
