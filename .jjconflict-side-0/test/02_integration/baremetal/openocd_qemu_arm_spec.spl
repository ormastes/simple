# OpenOCD QEMU ARM Integration Tests
# Tests QEMU ARM GDB connection, halt/resume/registers.
# NOTE: Requires qemu-system-arm to be available.
# These tests use local data-only validation since they can't connect to live QEMU.

# --- Local copies ---

class AdapterConfig:
    adapter_type: text
    host: text
    port: i32
    program: text
    architecture: text

impl AdapterConfig:
    static fn qemu_arm(host: text, port: i32, program: text) -> AdapterConfig:
        AdapterConfig(adapter_type: "gdb", host: host, port: port, program: program, architecture: "arm")

class AdapterCapabilities:
    can_reset: bool
    supports_memory: bool
    supports_registers: bool

impl AdapterCapabilities:
    static fn for_qemu_arm() -> AdapterCapabilities:
        AdapterCapabilities(can_reset: true, supports_memory: true, supports_registers: true)

# --- Tests ---

describe "QEMU ARM adapter config":
    slow_it "creates GDB adapter config for QEMU ARM":
        val cfg = AdapterConfig.qemu_arm("localhost", 3335, "test_arm.elf")
        expect(cfg.adapter_type).to_equal("gdb")
        expect(cfg.port).to_equal(3335)
        expect(cfg.architecture).to_equal("arm")

    slow_it "uses localhost for QEMU connections":
        val cfg = AdapterConfig.qemu_arm("localhost", 3335, "test.elf")
        expect(cfg.host).to_equal("localhost")

    slow_it "preserves program path":
        val cfg = AdapterConfig.qemu_arm("localhost", 3335, "/path/to/firmware.elf")
        expect(cfg.program).to_equal("/path/to/firmware.elf")

describe "QEMU ARM capabilities":
    slow_it "supports memory access":
        val caps = AdapterCapabilities.for_qemu_arm()
        expect(caps.supports_memory).to_equal(true)

    slow_it "supports register access":
        val caps = AdapterCapabilities.for_qemu_arm()
        expect(caps.supports_registers).to_equal(true)

    slow_it "supports reset":
        val caps = AdapterCapabilities.for_qemu_arm()
        expect(caps.can_reset).to_equal(true)
