use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_feature_gen_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + "/doc/08_tracking/feature && cat > " + FIXTURE_DIR + "/doc/08_tracking/feature/feature_db.sdn <<'EOF'\nfeatures |id, group, device, component, title, description, status, priority, source_file, requirement, research, plan, architecture, design, system_spec, spec_doc, implementation, unit_tests, integration_tests, guide, external_system, external_id, external_url, last_synced_at, created_at, updated_at, valid|\n    REQ-001,core,core,core,\"Sample feature\",\"Does work\",current,P1,,,,,,,,,,,,,,,,,2026-06-04,2026-06-04,true\n    REQ-002,tools,tools,tools,\"Planned feature\",\"Does later\",request,P2,,,,,,,,,,,,,,,,,2026-06-04,2026-06-04,true\nEOF"
    ])

fn _run_feature_gen(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && \"$REPO/src/compiler_rust/target/debug/simple\" feature-gen " + joined
    ])

describe "feature-gen log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_feature_gen(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_feature_gen(["--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"feature-gen\"")
        expect(out).to_contain("\"status\":\"ok\"")
        expect(out).to_contain("\"features\":2")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_feature_gen(["--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_contain(".")
        expect(out).to_contain("Done. Generated tracking docs for 2 features")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_feature_gen(["--log-mode=noisy"])
        expect(code).to_equal(1)
