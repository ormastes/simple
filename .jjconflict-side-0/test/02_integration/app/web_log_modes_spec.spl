use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

fn _run_web(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/web/main.spl\" " + joined
    ])

describe "web log mode CLI options":
    it "shows shared log options in help":
        val (out, err, code) = _run_web(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("simple web build")
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports log-mode json for missing subcommand output":
        val (out, err, code) = _run_web(["--log-mode=json"])
        expect(code).to_equal(1)
        expect(out).to_contain("\"command\":\"web\"")
        expect(out).to_contain("\"error\":\"missing web subcommand\"")

    it "supports dot progress for help output":
        val (out, err, code) = _run_web(["--progress=dot", "--help"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("simple web build")

    it "rejects invalid log mode":
        val (out, err, code) = _run_web(["--log-mode=noisy"])
        expect(code).to_equal(1)

    it "delegates web feature listing to the rust CLI":
        val (out, err, code) = _run_web(["features"])
        expect(code).to_equal(0)
        expect(out).to_contain("Simple Web Framework Features")
