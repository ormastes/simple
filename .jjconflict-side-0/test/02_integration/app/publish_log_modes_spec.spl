use std.spec.{describe, it, expect}

extern fn rt_process_run(cmd: text, args: [text]) -> (text, text, i64)

val FIXTURE_DIR = "/tmp/simple_publish_log_mode_fixture"

fn _setup_fixture():
    val (_out, _err, _code) = rt_process_run("/bin/sh", [
        "-c",
        "rm -rf " + FIXTURE_DIR + " && mkdir -p " + FIXTURE_DIR + " && cat > " + FIXTURE_DIR + "/simple.sdn <<'EOF'\npackage:\n  name: publish-fixture\n  version: 7.8.9\nEOF"
    ])

fn _run_publish(args: [text]) -> (text, text, i64):
    val joined = args.join(" ")
    rt_process_run("/bin/sh", [
        "-c",
        "REPO=$(pwd); cd " + FIXTURE_DIR + " && SIMPLE_LIB=\"$REPO/src\" \"$REPO/bin/simple\" run \"$REPO/src/app/publish/main.spl\" " + joined
    ])

describe "publish log mode CLI options":
    it "shows shared log options in help":
        _setup_fixture()
        val (out, err, code) = _run_publish(["--help"])
        expect(code).to_equal(0)
        expect(out).to_contain("--log-mode")
        expect(out).to_contain("--progress")

    it "supports dry-run log-mode json":
        _setup_fixture()
        val (out, err, code) = _run_publish(["--dry-run", "--log-mode=json"])
        expect(code).to_equal(0)
        expect(out).to_contain("\"command\":\"publish\"")
        expect(out).to_contain("\"dry_run\":true")
        expect(out).to_contain("\"name\":\"publish-fixture\"")
        expect(out).to_contain("\"version\":\"7.8.9\"")

    it "supports dot progress":
        _setup_fixture()
        val (out, err, code) = _run_publish(["--dry-run", "--progress=dot"])
        expect(code).to_equal(0)
        expect(out).to_start_with(".")
        expect(out).to_contain("Publishing publish-fixture@7.8.9")
        expect(out).to_contain("(dry run - no changes made)")

    it "rejects invalid log mode":
        _setup_fixture()
        val (out, err, code) = _run_publish(["--dry-run", "--log-mode=noisy"])
        expect(code).to_equal(1)
