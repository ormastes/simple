## Regression spec for bootstrap_cross status reporting.
##
## The status command must not report tiny placeholder outputs as built
## compiler stages. The build path already rejects outputs under 1 MiB; this
## spec keeps the audit/status path aligned with that gate.

use std.spec

extern fn rt_file_read_text(path: text) -> text?

describe "bootstrap_cross status":
    it "classifies sub-1MiB stage artifacts as invalid-small":
        val src = rt_file_read_text("src/os/port/bootstrap_cross.spl") ?? ""
        expect(src).to_contain("fn bootstrap_artifact_status(path: text) -> text:")
        expect(src).to_contain("if size_bytes < 1048576:")
        expect(src).to_contain("return \"invalid-small (")

    it "uses bootstrap_artifact_status for every stage in --status output":
        val src = rt_file_read_text("src/os/port/bootstrap_cross.spl") ?? ""
        expect(src).to_contain("stage 1:  ")
        expect(src).to_contain("bootstrap_artifact_status(s1)")
        expect(src).to_contain("bootstrap_artifact_status(s2)")
        expect(src).to_contain("bootstrap_artifact_status(s3)")
