# @cover src/lib/blink/dom/form_state.spl 80%
# @cover src/lib/blink/paint/paint_tree_walker.spl 80%
"""
# Blink Form Paint Specification

**Category:** Browser / Blink / Paint
**Status:** Active

## Overview

Tests the Phase B3 form-control paint path: <input> and <button> elements
registered on the paint walker must emit their composite paint ops
(background fill, optional border, text) in the correct order. Focused
<input> borders must use the accent color distinct from the unfocused
outline color. Also covers the FormState immutable data type.
"""

use std.spipe.*
use std.lib.blink.dom.form_state.{
    FormState, FormFieldEntry,
    form_state_empty, form_state_set_value, form_state_get_value,
    form_state_with_field, form_state_get_placeholder
}
use std.lib.blink.dom.interaction_state.{
    InteractionState, interaction_state_empty, interaction_state_with_focus
}
use std.lib.blink.layout.block_flow.{
    LayoutContext, LayoutBox, BoxGeometry,
    box_geometry_new, layout_box_new, layout_context_new
}
use std.lib.blink.paint.paint_tree_walker.{
    StyledBox, ImageEntry, FormFieldPaintEntry, PaintContext,
    paint_tree_new_with_forms, collect_display_list, finalize_paint
}
use std.common.color.types.{Color}
use examples.browser.entity.dom.paint_types.{PaintOp, DisplayList}

# ============================================================================
# Helpers
# ============================================================================

# Build an 800x600 layout context with a single box representing a form
# control at the viewport origin. box_id and width/height are caller-supplied.
fn make_single_box_ctx(box_id: i64, w: f64, h: f64) -> LayoutContext:
    val geo = box_geometry_new(w, h, 0.0, 0.0, 0.0)
    val box = layout_box_new(box_id, geo)
    val ctx = layout_context_new(800.0, 600.0)
    ctx.add_box(box)
    ctx.set_root(box_id)
    ctx.compute_layout()
    ctx

# Count DrawText ops that carry a specific expected text content.
fn count_draw_text_with(dl: DisplayList, expected: String) -> i64:
    var n: i64 = 0
    for op in dl.ops:
        match op:
            PaintOp.DrawText(x, y, text_content, font_size, color):
                if text_content == expected:
                    n = n + 1
            _:
                pass_do_nothing
    n

fn count_fill_rect_ops(dl: DisplayList) -> i64:
    var n: i64 = 0
    for op in dl.ops:
        match op:
            PaintOp.FillRect(x, y, w, h, color):
                n = n + 1
            _:
                pass_do_nothing
    n

fn count_draw_border_ops(dl: DisplayList) -> i64:
    var n: i64 = 0
    for op in dl.ops:
        match op:
            PaintOp.DrawBorder(x, y, w, h, widths, colors):
                n = n + 1
            _:
                pass_do_nothing
    n

# Class wrapping the four Color components of the first border op seen.
class BorderColorSnap:
    r: i64
    g: i64
    b: i64
    a: i64
    width: f64

fn first_border_color(dl: DisplayList) -> Option<BorderColorSnap>:
    var result: Option<BorderColorSnap> = None
    for op in dl.ops:
        match op:
            PaintOp.DrawBorder(x, y, w, h, widths, colors):
                if result is None:
                    val c = colors[0]
                    val bw = widths[0]
                    result = Some(BorderColorSnap(
                        r: c.r, g: c.g, b: c.b, a: c.a, width: bw
                    ))
            _:
                pass_do_nothing
    result

# ============================================================================
# FormState unit tests
# ============================================================================

describe "form_state data type":
    it "set_value then get_value round-trips":
        val s0 = form_state_empty()
        val s1 = form_state_set_value(s0, 42, "hello")
        expect(form_state_get_value(s1, 42)).to_equal("hello")

    it "get_value returns empty string for absent node":
        val s0 = form_state_empty()
        expect(form_state_get_value(s0, 99)).to_equal("")

    it "with_field replaces existing entry for same node_id":
        val s0 = form_state_empty()
        val e1 = FormFieldEntry(node_id: 5, value: "one", placeholder: "ph")
        val s1 = form_state_with_field(s0, e1)
        val e2 = FormFieldEntry(node_id: 5, value: "two", placeholder: "ph2")
        val s2 = form_state_with_field(s1, e2)
        expect(form_state_get_value(s2, 5)).to_equal("two")
        expect(form_state_get_placeholder(s2, 5)).to_equal("ph2")
        expect(s2.fields.len().to_i64()).to_equal(1)

    it "set_value preserves placeholder when a prior entry existed":
        val s0 = form_state_empty()
        val entry = FormFieldEntry(node_id: 7, value: "", placeholder: "search…")
        val s1 = form_state_with_field(s0, entry)
        val s2 = form_state_set_value(s1, 7, "typed")
        expect(form_state_get_value(s2, 7)).to_equal("typed")
        expect(form_state_get_placeholder(s2, 7)).to_equal("search…")

# ============================================================================
# <input> paint emission
# ============================================================================

describe "paint walker <input> emission":
    it "emits fill + border + text for an input with a value":
        val ctx = make_single_box_ctx(10, 160.0, 32.0)
        val styles = [StyledBox]()
        val fields = [FormFieldPaintEntry]()
        fields.push(FormFieldPaintEntry(
            layout_id: 10,
            value: "hello",
            placeholder: "",
            label: "",
            is_button: false,
            node_id: 10
        ))
        val pc = paint_tree_new_with_forms(ctx, styles, fields, interaction_state_empty())
        pc.paint_box(10, 0.0, 0.0)
        val dl = collect_display_list(pc)
        expect(dl.ops.len().to_i64() >= 3).to_equal(true)
        expect(count_fill_rect_ops(dl)).to_equal(1)
        expect(count_draw_border_ops(dl)).to_equal(1)
        expect(count_draw_text_with(dl, "hello")).to_equal(1)

    it "draws placeholder text when value is empty":
        val ctx = make_single_box_ctx(20, 160.0, 32.0)
        val styles = [StyledBox]()
        val fields = [FormFieldPaintEntry]()
        fields.push(FormFieldPaintEntry(
            layout_id: 20,
            value: "",
            placeholder: "search…",
            label: "",
            is_button: false,
            node_id: 20
        ))
        val pc = paint_tree_new_with_forms(ctx, styles, fields, interaction_state_empty())
        pc.paint_box(20, 0.0, 0.0)
        val dl = collect_display_list(pc)
        expect(count_draw_text_with(dl, "search…")).to_equal(1)

    it "focused input border differs from unfocused input border":
        val ctx = make_single_box_ctx(30, 160.0, 32.0)
        val styles = [StyledBox]()
        val fields_a = [FormFieldPaintEntry]()
        fields_a.push(FormFieldPaintEntry(
            layout_id: 30,
            value: "x",
            placeholder: "",
            label: "",
            is_button: false,
            node_id: 30
        ))
        # Unfocused walk
        val pc_u = paint_tree_new_with_forms(ctx, styles, fields_a, interaction_state_empty())
        pc_u.paint_box(30, 0.0, 0.0)
        val dl_u = collect_display_list(pc_u)
        val snap_u_opt = first_border_color(dl_u)

        # Focused walk — new ctx because compute_layout was already applied,
        # but we can reuse the same one safely: the walker only appends ops.
        val fields_b = [FormFieldPaintEntry]()
        fields_b.push(FormFieldPaintEntry(
            layout_id: 30,
            value: "x",
            placeholder: "",
            label: "",
            is_button: false,
            node_id: 30
        ))
        val pc_f = paint_tree_new_with_forms(ctx, styles, fields_b, interaction_state_with_focus(30))
        pc_f.paint_box(30, 0.0, 0.0)
        val dl_f = collect_display_list(pc_f)
        val snap_f_opt = first_border_color(dl_f)

        expect(snap_u_opt is None).to_equal(false)
        expect(snap_f_opt is None).to_equal(false)
        if val snap_u = snap_u_opt:
            if val snap_f = snap_f_opt:
                val colors_differ = (snap_u.r != snap_f.r) or (snap_u.g != snap_f.g) or (snap_u.b != snap_f.b) or (snap_u.a != snap_f.a)
                val widths_differ = snap_u.width != snap_f.width
                expect(colors_differ or widths_differ).to_equal(true)

# ============================================================================
# <button> paint emission
# ============================================================================

describe "paint walker <button> emission":
    it "emits fill + text for a button":
        val ctx = make_single_box_ctx(40, 120.0, 32.0)
        val styles = [StyledBox]()
        val fields = [FormFieldPaintEntry]()
        fields.push(FormFieldPaintEntry(
            layout_id: 40,
            value: "",
            placeholder: "",
            label: "Click me",
            is_button: true,
            node_id: 40
        ))
        val pc = paint_tree_new_with_forms(ctx, styles, fields, interaction_state_empty())
        pc.paint_box(40, 0.0, 0.0)
        val dl = collect_display_list(pc)
        expect(dl.ops.len().to_i64() >= 2).to_equal(true)
        expect(count_fill_rect_ops(dl)).to_equal(1)
        expect(count_draw_text_with(dl, "Click me")).to_equal(1)
