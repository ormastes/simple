# Bidi algorithm specification tests — UAX#9 simplified subset

use std.spipe.*
use std.skia.feature.text.bidi.{BidiClass, classify_bidi, compute_embedding_levels, reorder_visual, is_rtl}

describe "classify_bidi: character class detection":
    it "ASCII 'A' (U+0041 = 65) returns L":
        val cls = classify_bidi(65)
        expect cls to_equal BidiClass.L

    it "Hebrew alef (U+05D0 = 1488) returns R":
        val cls = classify_bidi(1488)
        expect cls to_equal BidiClass.R

    it "Arabic alif (U+0627 = 1575) returns AL":
        val cls = classify_bidi(1575)
        expect cls to_equal BidiClass.AL

    it "ASCII digit '0' (U+0030 = 48) returns EN":
        val cls = classify_bidi(48)
        expect cls to_equal BidiClass.EN

    it "ASCII space (U+0020 = 32) returns ON":
        val cls = classify_bidi(32)
        expect cls to_equal BidiClass.ON

describe "is_rtl: primary direction detection":
    it "sequence starting with Latin 'A' returns false":
        val cps: [i64] = [65, 66, 67]
        val result = is_rtl(cps)
        expect result to_equal false

    it "sequence starting with Hebrew alef (1488) returns true":
        val cps: [i64] = [1488, 1489, 1490]
        val result = is_rtl(cps)
        expect result to_equal true

describe "compute_embedding_levels: pure LTR text":
    it "pure ASCII Latin text with base LTR produces all level 0":
        # 'A'=65, 'B'=66, 'C'=67
        val cps: [i64] = [65, 66, 67]
        val levels = compute_embedding_levels(cps, false)
        val l0 = levels[0]
        val l1 = levels[1]
        val l2 = levels[2]
        expect l0 to_equal 0
        expect l1 to_equal 0
        expect l2 to_equal 0
