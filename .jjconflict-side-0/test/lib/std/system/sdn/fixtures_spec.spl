///
SDN Fixtures System Tests

Tests using real fixture files.
Validates fixture loading and error handling.

No mocks - tests with actual fixture files:
- Valid fixtures (config, data, primitives, etc.)
- Invalid fixtures (syntax errors)
- Large/complex fixtures
- Fixture-based workflows
///

use std.spec.*
use std.fs.*
use std.path.*
use std.sdn.document.SdnDocument
use std.sdn.parser.parse

describe "SDN Fixtures System Tests":
    context "valid fixtures":
        it "loads config example fixture":
            val fixture_path = find_fixture("config_example.sdn")

            val load_result1 = SdnDocument.from_file(fixture_path)
            match load_result1:
                Ok(doc):
                    # Verify basic structure
                    val app_name = doc.get("app.name")
                    val app_ver = doc.get("app.version")
                    val srv_port = doc.get("server.port")
                    val db_host = doc.get("database.host")
                    expect app_name.flatmap(|v| v.as_str()) == Some("MyService")
                    expect app_ver.flatmap(|v| v.as_str()) == Some("2.1.0")
                    expect srv_port.flatmap(|v| v.as_i64()) == Some(8080)
                    expect db_host.flatmap(|v| v.as_str()) == Some("localhost")

                    # Verify nested config
                    val max_conn = doc.get("server.config.max_connections")
                    val keep_alive = doc.get("server.config.keep_alive")
                    expect max_conn.flatmap(|v| v.as_i64()) == Some(1000)
                    expect keep_alive.flatmap(|v| v.as_bool()) == Some(true)

                    # Verify arrays
                    val features = doc.get("features")
                    match features:
                        Some(arr):
                            expect arr.is_array() == true
                        nil:
                            fail("Expected features array")
                Err(e):
                    fail("Failed to load config fixture: ${e}")

        it "loads data example fixture":
            val fixture_path = find_fixture("data_example.sdn")

            val load_result2 = SdnDocument.from_file(fixture_path)
            match load_result2:
                Ok(doc):
                    # Verify tables
                    val users = doc.get("users")
                    match users:
                        Some(table):
                            expect table.is_table() == true
                        nil:
                            fail("Expected users table")

                    val products = doc.get("products")
                    match products:
                        Some(table):
                            expect table.is_table() == true
                        nil:
                            fail("Expected products table")

                    # Verify nested orders
                    val order_user = doc.get("orders.order_1.user_id")
                    val order_status = doc.get("orders.order_1.status")
                    expect order_user.flatmap(|v| v.as_i64()) == Some(1)
                    expect order_status.flatmap(|v| v.as_str()) == Some("completed")

                    # Verify statistics
                    val total_users = doc.get("statistics.total_users")
                    expect total_users.flatmap(|v| v.as_i64()) == Some(5)
                Err(e):
                    fail("Failed to load data fixture: ${e}")

        it "loads primitives fixture":
            val fixture_path = find_fixture("primitives.sdn")

            val load_result3 = SdnDocument.from_file(fixture_path)
            match load_result3:
                Ok(doc):
                    # Integers
                    val int_pos = doc.get("int_positive")
                    val int_neg = doc.get("int_negative")
                    val int_zero = doc.get("int_zero")
                    expect int_pos.flatmap(|v| v.as_i64()) == Some(42)
                    expect int_neg.flatmap(|v| v.as_i64()) == Some(-17)
                    expect int_zero.flatmap(|v| v.as_i64()) == Some(0)

                    # Floats
                    val float_pos = doc.get("float_positive")
                    match float_pos:
                        Some(fv):
                            expect fv.is_float() == true
                        nil:
                            fail("Expected float_positive")

                    # Strings
                    val str_simple = doc.get("string_simple")
                    val str_spaces = doc.get("string_with_spaces")
                    expect str_simple.flatmap(|v| v.as_str()) == Some("hello")
                    expect str_spaces.flatmap(|v| v.as_str()) == Some("Hello, World!")

                    # Booleans
                    val bool_t = doc.get("bool_true")
                    val bool_f = doc.get("bool_false")
                    expect bool_t.flatmap(|v| v.as_bool()) == Some(true)
                    expect bool_f.flatmap(|v| v.as_bool()) == Some(false)

                    # Null
                    val null_val = doc.get("null_value")
                    match null_val:
                        Some(nv):
                            expect nv.is_null() == true
                        nil:
                            fail("Expected null_value")
                Err(e):
                    fail("Failed to load primitives fixture: ${e}")

        it "loads collections fixture":
            val fixture_path = find_fixture("collections.sdn")

            val load_result4 = SdnDocument.from_file(fixture_path)
            match load_result4:
                Ok(doc):
                    # Inline arrays
                    val simple_arr = doc.get("simple_array")
                    match simple_arr:
                        Some(arr):
                            expect arr.is_array() == true
                        nil:
                            fail("Expected simple_array")

                    # Inline dicts
                    val simple_dict = doc.get("simple_dict")
                    match simple_dict:
                        Some(dict):
                            expect dict.is_dict() == true
                        nil:
                            fail("Expected simple_dict")

                    # Empty collections
                    val empty_arr = doc.get("empty_array")
                    match empty_arr:
                        Some(arr):
                            expect arr.is_array() == true
                        nil:
                            fail("Expected empty_array")

                    val empty_dict = doc.get("empty_dict")
                    match empty_dict:
                        Some(dict):
                            expect dict.is_dict() == true
                        nil:
                            fail("Expected empty_dict")

                    # Nested collections
                    val deep_val = doc.get("nested_block.level1.level2.level3.value")
                    expect deep_val.flatmap(|v| v.as_str()) == Some("deep")
                Err(e):
                    fail("Failed to load collections fixture: ${e}")

        it "loads nested fixture":
            val fixture_path = find_fixture("nested.sdn")

            val load_result5 = SdnDocument.from_file(fixture_path)
            match load_result5:
                Ok(doc):
                    # 4-level nesting
                    val max_threads = doc.get("application.core.engine.settings.max_threads")
                    expect max_threads.flatmap(|v| v.as_i64()) == Some(8)

                    # 5-level nesting
                    val lead = doc.get("organization.departments.engineering.teams.backend.lead")
                    expect lead.flatmap(|v| v.as_str()) == Some("alice")

                    # Deep paths
                    val frontend_host = doc.get("config.services.web.frontend.host")
                    val cloud_provider = doc.get("system.infrastructure.cloud.provider")
                    expect frontend_host.flatmap(|v| v.as_str()) == Some("frontend.example.com")
                    expect cloud_provider.flatmap(|v| v.as_str()) == Some("aws")
                Err(e):
                    fail("Failed to load nested fixture: ${e}")

    context "invalid fixtures":
        it "detects bad indentation":
            val fixture_path = find_fixture("invalid/bad_indent.sdn")

            val r1 = SdnDocument.from_file(fixture_path)
            match r1:
                Ok(_):
                    fail("Should have failed for bad indentation")
                Err(e):
                    pass  # Expected error

        it "detects missing colon":
            val fixture_path = find_fixture("invalid/missing_colon.sdn")

            val r2 = SdnDocument.from_file(fixture_path)
            match r2:
                Ok(_):
                    fail("Should have failed for missing colon")
                Err(e):
                    pass  # Expected error

        it "detects unclosed bracket":
            val fixture_path = find_fixture("invalid/unclosed_bracket.sdn")

            val r3 = SdnDocument.from_file(fixture_path)
            match r3:
                Ok(_):
                    fail("Should have failed for unclosed bracket")
                Err(e):
                    pass  # Expected error

        it "detects invalid table":
            val fixture_path = find_fixture("invalid/invalid_table.sdn")

            val r4 = SdnDocument.from_file(fixture_path)
            match r4:
                Ok(_):
                    # May or may not fail depending on table validation
                    # Some parsers are lenient with table field counts
                    pass
                Err(e):
                    pass  # Error is acceptable

    context "fixture-based workflows":
        it "converts config fixture to JSON and back":
            val fixture_path = find_fixture("config_example.sdn")

            # Load SDN
            val load_r6 = SdnDocument.from_file(fixture_path)
            match load_r6:
                Ok(doc):
                    # Convert to JSON
                    val json_output = doc.to_json()

                    # Parse JSON
                    val json_parse_result = json.parse(json_output)
                    match json_parse_result:
                        Ok(json_value):
                            # Convert back to SDN
                            val sdn_value = json_to_sdn(json_value)
                            val sdn_output = to_sdn(sdn_value)

                            # Re-parse SDN
                            val reparse_result = parse(sdn_output)
                            match reparse_result:
                                Ok(final_value):
                                    # Verify key fields preserved
                                    val name_val = final_value.get("app.name")
                                    match name_val:
                                        Some(name):
                                            expect name.as_str() == Some("MyService")
                                        nil:
                                            fail("Lost app.name in round-trip")
                                Err(e):
                                    fail("Failed to re-parse SDN: ${e}")
                        Err(e):
                            fail("Invalid JSON output: ${e}")
                Err(e):
                    fail("Failed to load fixture: ${e}")

        it "modifies data fixture and persists":
            val fixture_path = find_fixture("data_example.sdn")
            val temp_path = "/tmp/sdn_fixture_test_${process.pid()}.sdn"

            # Copy fixture to temp file
            val read_result = fs.read_to_string(fixture_path)
            match read_result:
                Ok(content):
                    fs.write(temp_path, content)
                Err(e):
                    fail("Failed to copy fixture: ${e}")

            # Load and modify
            val load_r7 = SdnDocument.from_file(temp_path)
            match load_r7:
                Ok(doc):
                    # Update statistics
                    doc.set("statistics.total_users", SdnValue.i32(6))
                    doc.set("statistics.active_users", SdnValue.i32(5))

                    # Save changes
                    val write_result = doc.write_file(temp_path)
                    match write_result:
                        Ok(_):
                            pass
                        Err(e):
                            fail("Failed to save: ${e}")
                Err(e):
                    fail("Failed to load: ${e}")

            # Verify changes
            val verify_r8 = SdnDocument.from_file(temp_path)
            match verify_r8:
                Ok(doc):
                    val total = doc.get("statistics.total_users")
                    val active = doc.get("statistics.active_users")
                    expect total.flatmap(|v| v.as_i64()) == Some(6)
                    expect active.flatmap(|v| v.as_i64()) == Some(5)
                Err(e):
                    fail("Failed to verify: ${e}")

            # Cleanup
            fs.remove(temp_path)

### Helper Functions

fn find_fixture(name: text) -> text:
    """Find fixture file by name"""
    val candidates = [
        "simple/std_lib/test/fixtures/sdn/${name}",
        "./simple/std_lib/test/fixtures/sdn/${name}",
        "../../../fixtures/sdn/${name}",
        "test/fixtures/sdn/${name}"
    ]

    for path in candidates:
        val path_exists = fs.exists(path)
        if path_exists:
            return path

    fail("Fixture not found: ${name}")

fn json_to_sdn(json_value) -> SdnValue:
    """Convert JSON value to SDN value (stub - returns Null for compatibility)"""
    SdnValue.Null
