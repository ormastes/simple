# variants/ui/renderer/metal — renderer_select override
#
# Metal-first build target (Apple platforms): Metal leads, then CUDA for
# compute-heavy offload, then portable GPU backends, then CPU fallbacks.
# Always ends with "cpu".

fn renderer_priority_order() -> [text]:
    """Metal-first build: Metal, CUDA, then portable GPU, then CPU fallbacks."""
    ["metal", "cuda", "rocm", "vulkan", "opencl", "webgpu", "cpu_simd", "software", "cpu"]
