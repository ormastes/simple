FROM simple-tauri-android

ENV DEBIAN_FRONTEND=noninteractive

# Install emulator and system image
RUN sdkmanager "emulator" 2>&1 | tail -3

# Create AVD (Android Virtual Device)
RUN echo "no" | avdmanager create avd -n test_device -k "system-images;android-34;google_apis;x86_64" --device "pixel_6" 2>&1 | tail -3

# Install Xvfb for headless display + screenshot tools
RUN apt-get update && apt-get install -y xvfb imagemagick x11-utils 2>/dev/null | tail -3 && rm -rf /var/lib/apt/lists/*

COPY tools/docker/run-android-test.sh /app/run-android-test.sh
RUN chmod +x /app/run-android-test.sh

CMD ["/app/run-android-test.sh"]
