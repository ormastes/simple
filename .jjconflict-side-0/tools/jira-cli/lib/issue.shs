#!/bin/sh
# jira-cli issue subcommands — mirrors `gh issue`

# Depends on: config.shs, api.shs (sourced by main entry point)

cmd_issue() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    create)  cmd_issue_create "$@" ;;
    list)    cmd_issue_list "$@" ;;
    view)    cmd_issue_view "$@" ;;
    edit)    cmd_issue_edit "$@" ;;
    comment) cmd_issue_comment "$@" ;;
    move)    cmd_issue_move "$@" ;;
    close)   cmd_issue_close "$@" ;;
    reopen)  cmd_issue_reopen "$@" ;;
    delete)  cmd_issue_delete "$@" ;;
    *)
      echo "Work with Jira issues"
      echo ""
      echo "USAGE"
      echo "  jira issue <command> [flags]"
      echo ""
      echo "COMMANDS"
      echo "  create    Create a new issue"
      echo "  list      List issues in a project"
      echo "  view      View an issue"
      echo "  edit      Edit an issue"
      echo "  comment   Add a comment to an issue"
      echo "  move      Transition issue to a new status"
      echo "  close     Close an issue"
      echo "  reopen    Reopen an issue"
      echo "  delete    Delete an issue"
      ;;
  esac
}

cmd_issue_create() {
  jira_load_auth || return 1

  local type="Task" summary="" body="" project="" priority="Medium" labels="" assignee=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -t|--type)     type="$2"; shift 2 ;;
      -s|--summary)  summary="$2"; shift 2 ;;
      -b|--body)     body="$2"; shift 2 ;;
      -p|--project)  project="$2"; shift 2 ;;
      --priority)    priority="$2"; shift 2 ;;
      -l|--label)    labels="$2"; shift 2 ;;
      -a|--assignee) assignee="$2"; shift 2 ;;
      --no-input)    shift ;;
      *) echo "error: unknown flag: $1" >&2; return 1 ;;
    esac
  done

  project="${project:-$JIRA_DEFAULT_PROJECT}"
  if [ -z "$project" ]; then
    echo "error: project required. Use --project KEY or set default_project." >&2
    return 1
  fi

  # Interactive if no summary
  if [ -z "$summary" ]; then
    echo "? Issue summary:"
    printf "  > "
    read -r summary
  fi

  if [ -z "$body" ]; then
    echo "? Description (optional, press Enter to skip):"
    printf "  > "
    read -r body
  fi

  # Build request
  local req_body
  req_body=$(jq -n \
    --arg proj "$project" \
    --arg type "$type" \
    --arg summary "$summary" \
    --arg desc "$body" \
    --arg priority "$priority" \
    '{
      fields: {
        project: { key: $proj },
        issuetype: { name: $type },
        summary: $summary,
        priority: { name: $priority }
      }
    }
    | if $desc != "" then .fields.description = {
        type: "doc",
        version: 1,
        content: [{ type: "paragraph", content: [{ type: "text", text: $desc }] }]
      } else . end')

  local response
  response=$(jira_api "issue" -X POST --input <(echo "$req_body") --jq '.key + " " + .self' 2>&1)

  if [ $? -eq 0 ]; then
    local key url
    key=$(echo "$response" | awk '{print $1}')
    echo ""
    echo "✓ Created issue ${key}"
    echo "  ${JIRA_SERVER}/browse/${key}"
  else
    echo "error: failed to create issue" >&2
    echo "$response" >&2
    return 1
  fi
}

cmd_issue_list() {
  jira_load_auth || return 1

  local project="" jql="" limit=25 status="" type=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -p|--project) project="$2"; shift 2 ;;
      -q|--jql)     jql="$2"; shift 2 ;;
      -L|--limit)   limit="$2"; shift 2 ;;
      -s|--status)  status="$2"; shift 2 ;;
      -t|--type)    type="$2"; shift 2 ;;
      *) echo "error: unknown flag: $1" >&2; return 1 ;;
    esac
  done

  project="${project:-$JIRA_DEFAULT_PROJECT}"

  # Build JQL
  if [ -z "$jql" ]; then
    jql="ORDER BY updated DESC"
    [ -n "$project" ] && jql="project = ${project} ${jql}"
    [ -n "$status" ] && jql="status = '${status}' AND ${jql}"
    [ -n "$type" ] && jql="issuetype = '${type}' AND ${jql}"
  fi

  local response
  response=$(jira_api "search" -f "jql=${jql}" -f "maxResults=${limit}" \
    -f 'fields=["summary","status","issuetype","priority","assignee","updated"]')

  if [ $? -ne 0 ]; then
    return 1
  fi

  # Format output as table
  echo "$response" | jq -r '
    .issues[] |
    [.key, .fields.status.name, .fields.issuetype.name, .fields.priority.name,
     (.fields.assignee.displayName // "Unassigned"),
     .fields.summary[0:60]] |
    @tsv' | column -t -s $'\t' 2>/dev/null || \
  echo "$response" | jq -r '.issues[] | "\(.key)\t\(.fields.status.name)\t\(.fields.summary)"'
}

cmd_issue_view() {
  jira_load_auth || return 1

  local issue_key="$1"
  local json_fields="" web=0
  shift 2>/dev/null || true
  while [ $# -gt 0 ]; do
    case "$1" in
      --json)     json_fields="$2"; shift 2 ;;
      -w|--web)   web=1; shift ;;
      --comments) json_fields="comment"; shift ;;
      *) echo "error: unknown flag: $1" >&2; return 1 ;;
    esac
  done

  if [ -z "$issue_key" ]; then
    echo "error: issue key required" >&2
    return 1
  fi

  if [ "$web" -eq 1 ]; then
    open "${JIRA_SERVER}/browse/${issue_key}" 2>/dev/null || \
    xdg-open "${JIRA_SERVER}/browse/${issue_key}" 2>/dev/null || \
    echo "${JIRA_SERVER}/browse/${issue_key}"
    return 0
  fi

  local response
  response=$(jira_api "issue/${issue_key}")

  if [ $? -ne 0 ]; then
    return 1
  fi

  if [ -n "$json_fields" ]; then
    echo "$response" | jq ".fields.${json_fields} // .${json_fields}"
    return
  fi

  # Pretty print
  echo "$response" | jq -r '
    "Issue:    \(.key)",
    "Type:     \(.fields.issuetype.name)",
    "Status:   \(.fields.status.name)",
    "Priority: \(.fields.priority.name)",
    "Assignee: \(.fields.assignee.displayName // "Unassigned")",
    "Reporter: \(.fields.reporter.displayName // "Unknown")",
    "Created:  \(.fields.created)",
    "Updated:  \(.fields.updated)",
    "",
    "  \(.fields.summary)",
    ""'

  # Print description if present
  local desc
  desc=$(echo "$response" | jq -r '.fields.description.content[0].content[0].text // empty')
  if [ -n "$desc" ]; then
    echo "  $desc"
    echo ""
  fi

  echo "  ${JIRA_SERVER}/browse/$(echo "$response" | jq -r '.key')"
}

cmd_issue_comment() {
  jira_load_auth || return 1

  local issue_key="${1:-}"
  shift 2>/dev/null || true
  local body=""

  while [ $# -gt 0 ]; do
    case "$1" in
      -b|--body) body="$2"; shift 2 ;;
      *) echo "error: unknown flag: $1" >&2; return 1 ;;
    esac
  done

  if [ -z "$issue_key" ]; then
    echo "error: issue key required" >&2; return 1
  fi

  if [ -z "$body" ]; then
    echo "? Comment body:"
    printf "  > "
    read -r body
  fi

  local req_body
  req_body=$(jq -n --arg body "$body" '{
    body: {
      type: "doc",
      version: 1,
      content: [{ type: "paragraph", content: [{ type: "text", text: $body }] }]
    }
  }')

  jira_api "issue/${issue_key}/comment" -X POST --input <(echo "$req_body") -q

  if [ $? -eq 0 ]; then
    echo "✓ Comment added to ${issue_key}"
  fi
}

cmd_issue_move() {
  jira_load_auth || return 1

  local issue_key="${1:-}"
  local status="${2:-}"

  if [ -z "$issue_key" ] || [ -z "$status" ]; then
    echo "Usage: jira issue move <key> <status>" >&2
    return 1
  fi

  # Get available transitions
  local transitions
  transitions=$(jira_api "issue/${issue_key}/transitions" --jq '.transitions')

  # Find matching transition
  local transition_id
  transition_id=$(echo "$transitions" | jq -r --arg name "$status" \
    '.[] | select(.name == $name or (.name | ascii_downcase) == ($name | ascii_downcase)) | .id' | head -1)

  if [ -z "$transition_id" ]; then
    echo "error: no transition to '${status}' available" >&2
    echo "Available transitions:" >&2
    echo "$transitions" | jq -r '.[] | "  - \(.name)"' >&2
    return 1
  fi

  local req_body
  req_body=$(jq -n --arg id "$transition_id" '{ transition: { id: $id } }')

  jira_api "issue/${issue_key}/transitions" -X POST --input <(echo "$req_body") -q

  if [ $? -eq 0 ]; then
    echo "✓ ${issue_key} moved to '${status}'"
  fi
}

cmd_issue_edit() {
  jira_load_auth || return 1

  local issue_key="${1:-}"
  shift 2>/dev/null || true
  local summary="" body="" priority="" assignee=""

  while [ $# -gt 0 ]; do
    case "$1" in
      -s|--summary)  summary="$2"; shift 2 ;;
      -b|--body)     body="$2"; shift 2 ;;
      --priority)    priority="$2"; shift 2 ;;
      -a|--assignee) assignee="$2"; shift 2 ;;
      *) echo "error: unknown flag: $1" >&2; return 1 ;;
    esac
  done

  if [ -z "$issue_key" ]; then
    echo "error: issue key required" >&2; return 1
  fi

  local req_body='{"fields":{}}'
  [ -n "$summary" ] && req_body=$(echo "$req_body" | jq --arg s "$summary" '.fields.summary = $s')
  [ -n "$priority" ] && req_body=$(echo "$req_body" | jq --arg p "$priority" '.fields.priority = { name: $p }')

  if [ -n "$body" ]; then
    req_body=$(echo "$req_body" | jq --arg b "$body" '.fields.description = {
      type: "doc", version: 1,
      content: [{ type: "paragraph", content: [{ type: "text", text: $b }] }]
    }')
  fi

  jira_api "issue/${issue_key}" -X PUT --input <(echo "$req_body") -q

  if [ $? -eq 0 ]; then
    echo "✓ ${issue_key} updated"
  fi
}

cmd_issue_close() {
  cmd_issue_move "${1:-}" "Done"
}

cmd_issue_reopen() {
  cmd_issue_move "${1:-}" "To Do"
}

cmd_issue_delete() {
  jira_load_auth || return 1
  local issue_key="${1:-}"
  if [ -z "$issue_key" ]; then
    echo "error: issue key required" >&2; return 1
  fi

  echo "? Are you sure you want to delete ${issue_key}? (y/N)"
  printf "  > "
  read -r confirm
  case "$confirm" in
    y|Y|yes|YES)
      jira_api "issue/${issue_key}" -X DELETE -q
      if [ $? -eq 0 ]; then
        echo "✓ ${issue_key} deleted"
      fi
      ;;
    *) echo "Cancelled." ;;
  esac
}
