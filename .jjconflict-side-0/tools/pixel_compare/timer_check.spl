use std.js.engine.runtime.{JsRuntime}
use std.js.engine.js_error.{Logger, LogLevel}
var rt = JsRuntime.new(Logger.new("t", LogLevel.Error))
match rt.eval("var fired = 0; setTimeout(function(){ fired = 1; }, 5); fired"):
    Ok(v): print("T1 eval ok")
    Err(e): print("T1 err: " + e.message)
val ran = rt.drain_due_timers(999999)
print("T2 drained=" + ran.to_text())
match rt.eval("fired"):
    Ok(v):
        match v:
            JsValue.Number(n): print("T3 fired=" + n.to_text())
            _: print("T3 fired (non-number)")
    Err(e): print("T3 err: " + e.message)
use std.js.types.js_types.{JsValue}
