# Temporary probe (not committed): live google.com through the pure-Simple
# browser lane — fetch (FetchEngine), render (layout renderer), and run the
# page's inline scripts through the browser script pipeline. Reports each
# stage honestly.
use std.gc_async_mut.gpu.browser_engine.net.fetch.{FetchEngine}
use std.gc_async_mut.gpu.browser_engine.net.entity.request_types.{FetchRequest, RequestMode, RequestCredentials}
use std.gc_async_mut.gpu.browser_engine.net.entity.url_types.{Url}
use std.gc_async_mut.gpu.browser_engine.shared.logging.{Logger, LogLevel}
use std.gc_async_mut.gpu.browser_engine.html_tree_builder.{html_tree_builder_build_with_scripts}
use std.gc_async_mut.gpu.browser_engine.simple_web_html_layout_renderer.{
    simple_web_layout_render_html_software_pixels}

extern fn rt_file_write_text(path: text, content: text) -> bool

val out_dir = "/private/tmp/claude-501/-Users-ormastes-simple/f10f352f-2184-46d2-bf71-444e5c96b02f/scratchpad"

# --- Stage 1: fetch ---
val engine = FetchEngine.new(Logger.new("google-probe", LogLevel.Warn))
val req = FetchRequest(
    method: "GET",
    url: Url.parse("https://www.google.com/"),
    headers: "User-Agent: SimpleBrowser/0.1\r\nAccept: text/html\r\n",
    body: [],
    mode: RequestMode.NoCors,
    credentials: RequestCredentials.Omit)
val result = engine.fetch(req)
var html = ""
match result:
    Ok(resp):
        html = resp.body_text()
        print("STAGE-FETCH: status=" + resp.status.to_text() + " bytes=" + html.len().to_text())
    Err(e):
        print("STAGE-FETCH: FAIL " + e.message)
if html.len() == 0:
    print("GOOGLE-PROBE: FAIL (no body)")
else:
    val _ = rt_file_write_text(out_dir + "/google_live.html", html)

    # --- Stage 2: HTML parse (tree builder with today's depth/node caps) ---
    val tree = html_tree_builder_build_with_scripts(html)
    print("STAGE-HTML: scripts=" + tree.scripts.len().to_text() +
          " script_srcs=" + tree.src_paths.len().to_text() +
          " truncated=" + tree.truncated.to_text())

    # --- Stage 3: render (CSS through budgeted cascade) ---
    val w = 480
    val h = 360
    val px = simple_web_layout_render_html_software_pixels(html, w, h)
    print("STAGE-RENDER: pixels=" + px.len().to_text() + " expected=" + (172800).to_text())
    # save ARGB json for capture/compare
    var sb = "{\"format\":\"argb-u32\",\"pixels\":["
    var i = 0
    while i < px.len():
        if i > 0:
            sb = sb + ","
        sb = sb + px[i].to_text()
        i = i + 1
    sb = sb + "]}"
    val _ = rt_file_write_text(out_dir + "/google_live.argb.json", sb)
    print("STAGE-RENDER: saved argb json")
    print("GOOGLE-PROBE: DONE")
