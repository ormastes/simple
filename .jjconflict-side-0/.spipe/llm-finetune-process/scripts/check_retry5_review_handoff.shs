#!/bin/sh
set -eu

ATTEMPT_ID="${1:-llm_backed_app_server_dry_run_retry5}"
BASE_DIR="$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)"
ATTEMPT="${2:-${BASE_DIR}/attempts/${ATTEMPT_ID}.sdn}"
MANIFEST="${3:-${BASE_DIR}/data/${ATTEMPT_ID}_cache_manifest.sdn}"

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"

status_for() {
  sed -n 's/^STATUS: //p' | tail -1
}

value_for() {
  key="$1"
  sed -n "s/^${key}=//p" | tail -1
}

ATTEMPT_CHECK="$("${SCRIPT_DIR}/verify_attempt.shs" "$ATTEMPT")"
CACHE_CHECK="$("${SCRIPT_DIR}/check_retry5_cache_manifest.shs" "$ATTEMPT_ID" "$MANIFEST")"
DATA_CHECK="$("${SCRIPT_DIR}/check_retry5_data_access_gate.shs" "$ATTEMPT_ID" "$MANIFEST")"

attempt_status="$(printf '%s\n' "$ATTEMPT_CHECK" | status_for)"
cache_status="$(printf '%s\n' "$CACHE_CHECK" | status_for)"
data_status="$(printf '%s\n' "$DATA_CHECK" | status_for)"
training_allowed="$(printf '%s\n' "$DATA_CHECK" | value_for training_allowed)"
cache_result="$(printf '%s\n' "$CACHE_CHECK" | value_for result)"
data_result="$(printf '%s\n' "$DATA_CHECK" | value_for result)"
manifest="$(printf '%s\n' "$CACHE_CHECK" | value_for manifest)"
cache_path="$(printf '%s\n' "$CACHE_CHECK" | value_for cache_path)"
expected_checksum="$(printf '%s\n' "$CACHE_CHECK" | value_for expected_checksum)"
actual_checksum="$(printf '%s\n' "$CACHE_CHECK" | value_for actual_checksum)"
manifest_exists="$(printf '%s\n' "$CACHE_CHECK" | value_for manifest_exists)"
cache_path_exists="$(printf '%s\n' "$CACHE_CHECK" | value_for cache_path_exists)"
checksum_match="$(printf '%s\n' "$CACHE_CHECK" | value_for checksum_match)"

review_status="blocked"
review_result="BLOCKED_LICENSED_DATA_CACHE_NOT_READY"
next_action="obtain licensed data approval and write cache manifest with matching sha256 checksum"
status="WARN"

if [ "$attempt_status" = "PASS llm-finetune-attempt-record" ] &&
   [ "$cache_status" = "PASS retry5-cache-manifest" ] &&
   [ "$data_status" = "PASS retry5-data-access-gate" ] &&
   [ "$training_allowed" = "true" ]; then
  review_status="ready-for-training"
  review_result="READY_FOR_REAL_QLORA_AND_TARGET_EVAL"
  next_action="run real QLoRA training and target eval; do not accept until target_accuracy>=90.0 and handoff evidence pass"
  status="PASS"
fi

cat <<EOF
attempt_id=${ATTEMPT_ID}
attempt_record_status=${attempt_status:-missing}
cache_manifest_status=${cache_status:-missing}
data_access_status=${data_status:-missing}
manifest=${manifest:-missing}
cache_path=${cache_path:-missing}
expected_checksum=${expected_checksum:-missing}
actual_checksum=${actual_checksum:-missing}
manifest_exists=${manifest_exists:-false}
cache_path_exists=${cache_path_exists:-false}
checksum_match=${checksum_match:-false}
training_allowed=${training_allowed:-false}
cache_result=${cache_result:-missing}
data_result=${data_result:-missing}
normal_review_status=${review_status}
acceptance_allowed=false
acceptance_reason=target eval and app handoff evidence are still required after retry5
next_action=${next_action}
result=${review_result}
STATUS: ${status} retry5-review-handoff
EOF
