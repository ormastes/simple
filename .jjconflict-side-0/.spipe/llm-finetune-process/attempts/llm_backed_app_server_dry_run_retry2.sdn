attempt:
  attempt_id: "llm_backed_app_server_dry_run_retry2"
  goal: "Fixed-format data-quality retry before rerunning MedGemma QLoRA training/eval"
  app_or_server_target: "target_accuracy>=90.0 on 604 KorMedMCQA-derived samples after fixed-format data pass"

research:
  research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process.md"
  data_sources:
    - name: "retry2-fixed-format-synthetic-mcq-fixture"
      source: ".spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"
      license: "synthetic repo-local format fixture; real medical data still requires license review"
      download_command: "repo-local synthetic fixture; no external download"
      checksum: "not-recorded-synthetic-fixture"
      cache_path: ".spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"

requirements:
  feature_option: "local-qlora-medical-domain-retry"
  nfr_option: "accuracy-target-90-percent-with-604-sample-eval"
  selected_by: "retry1 decision handoff"
  selection_doc: "doc/02_requirements/language/tools/spipe_llm_finetune_process.md"

process_docs:
  requirements_doc: "doc/02_requirements/language/tools/spipe_llm_finetune_process.md"
  nfr_doc: "doc/02_requirements/nfr/spipe_llm_finetune_process.md"
  plan_doc: "doc/03_plan/ml/spipe_llm_finetune_process.md"
  architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_process.md"
  design_doc: "doc/05_design/app/spipe/spipe_llm_finetune_process.md"

model_research:
  research_doc: "doc/01_research/app/editor/spipe_llm_finetune_process_local.md"
  candidate_model: "google/medgemma-4b-it"
  license: "Health AI community license; production and clinical use require explicit review"
  context_length: "deployment context window must be reverified before serving"
  fit: "medical-domain base model with prior Korean MedGemma project evidence"
  constraints: "retry2 only proves fixed-format data-quality gate; no accepted model yet"
  decision: "continue-with-medgemma-after-format-gate"

model_architecture:
  architecture_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
  model_family: "MedGemma"
  data_strategy: "fixed-format MCQ JSONL gate before real KorMedMCQA-derived rerun"
  training_strategy: "rerun local QLoRA only after data-quality gate passes on real licensed data"
  deployment_target: "local app/server handoff only after target eval pass"
  fallback: "switch base model or retrieval/tool strategy if retry remains below target"

model:
  base_model: "google/medgemma-4b-it"
  base_model_revision: "not-pinned-in-existing-evidence"
  base_model_reason: "Keep prior candidate for retry2 while adding a fixed-format data-quality gate before rerun."
  deployment_target: "local app/server after accepted eval"

tuning:
  method: "local-qlora-retry"
  training_script: "provider-managed"
  training_command: "not run in retry2; first pass fixed-format data-quality gate, then rerun QLoRA/eval"
  model_artifact: "not-created"

evaluation:
  eval_command: ".spipe/llm-finetune-process/scripts/check_fixed_format_data_quality.shs .spipe/llm-finetune-process/data/llm_backed_app_server_dry_run_retry2_fixed_format_sample.jsonl"
  metrics: "records=3; invalid_records=0; format_gate=pass; model_accuracy=not-run"
  target: "fixed-format MCQ JSONL has id/question/choices A-D/answer/rationale before model rerun"
  result: "FORMAT_PASS_MODEL_EVAL_NOT_RUN"

decision:
  status: "retry-implementation"
  retry_target: "run licensed fixed-format KorMedMCQA data build, QLoRA training, and target_accuracy>=90.0 eval"
  next_attempt: "llm_backed_app_server_dry_run_retry3"
  notes: "Retry2 closes synthetic fixed-format gate only; do not accept model until real data/eval reaches target."

app_handoff:
  app_target: "medgemma_korean"
  usage: "do not deploy; retry2 has format-gate evidence only and model eval remains not run"
  handoff_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
  license_constraints: "Health AI community license plus dataset license review required before deployment"
  safety_eval: "not-run; refusal, boundary behavior, and clinical-disclaimer checks required before deployment"
  deployment_evidence: "not-deployable; synthetic format gate only and runtime/memory/latency/fallback evidence is pending"

retune:
  reason: "fixed-format synthetic data-quality gate passed but real training/eval still required"
  source_eval: ".spipe/llm-finetune-process/scripts/check_fixed_format_data_quality.shs"
  next_attempt: "llm_backed_app_server_dry_run_retry3"
  retry_target: "licensed real-data fixed-format build plus QLoRA rerun and target eval"
