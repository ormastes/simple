# LLM-backed app/server handoff evidence for SPipe fine-tune attempts.

app_handoffs:
  - attempt_id: "llm_backed_app_server_dry_run"
    app_target: "app/server"
    usage: "dry-run-process-scaffold"
    handoff_doc: "doc/05_design/spipe_llm_finetune_process.md"
    license_constraints: "not-applicable; dry-run scaffold only"
    safety_eval: "not-applicable; no model artifact or deployment"
    deployment_evidence: "not-deployable; scaffold evidence only"
  - attempt_id: "llm_backed_app_server_dry_run"
    app_target: "medgemma_korean"
    usage: "candidate medical QA model artifact handoff; not clinically accepted until retry reaches target and safety eval passes"
    handoff_doc: "doc/04_architecture/spipe_llm_finetune_model_architecture.md"
    license_constraints: "Health AI community license plus dataset license review required before deployment"
    safety_eval: "not-run; refusal, boundary behavior, and clinical-disclaimer checks required before deployment"
    deployment_evidence: "not-deployable; retry target eval, runtime, memory, latency, and fallback evidence pending"
  - attempt_id: "llm_backed_app_server_dry_run_retry1"
    app_target: "medgemma_korean"
    usage: "do not deploy; retry/eval blocker remains"
    handoff_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
    license_constraints: "Health AI community license plus dataset license review required before deployment"
    safety_eval: "not-run; refusal, boundary behavior, and clinical-disclaimer checks required before deployment"
    deployment_evidence: "not-deployable; target eval failed and runtime/memory/latency/fallback evidence is pending"
  - attempt_id: "llm_backed_app_server_dry_run_retry2"
    app_target: "medgemma_korean"
    usage: "do not deploy; retry2 has format-gate evidence only and model eval remains not run"
    handoff_doc: "doc/04_architecture/app/spipe/spipe_llm_finetune_model_architecture.md"
    license_constraints: "Health AI community license plus dataset license review required before deployment"
    safety_eval: "not-run; refusal, boundary behavior, and clinical-disclaimer checks required before deployment"
    deployment_evidence: "not-deployable; synthetic format gate only and runtime/memory/latency/fallback evidence is pending"
  - attempt_id: "llm_backed_app_server_dry_run_retry3"
    app_target: "medgemma_korean"
