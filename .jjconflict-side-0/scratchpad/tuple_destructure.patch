diff --git a/src/compiler/20.hir/hir_lowering/statements.spl b/src/compiler/20.hir/hir_lowering/statements.spl
index d695dae0fb1..ecbbb30c5c9 100644
--- a/src/compiler/20.hir/hir_lowering/statements.spl
+++ b/src/compiler/20.hir/hir_lowering/statements.spl
@@ -56,6 +56,70 @@ impl HirLowering:
             result = result.push(hir_item)
         result
 
+    # Lower a single source statement to zero-or-more HIR statements. Almost
+    # every statement is 1:1 -- the exception is literal-tuple destructuring
+    # (`val (a, b) = (x, y)`), which the parser encodes as a single
+    # StmtKind.Val whose `name` is the literal text "(a,b)" (see
+    # parse_tuple_destructure_val in parser_stmts.spl). That single source
+    # statement desugars into N ordinary `Let` bindings here, so callers that
+    # iterate over a block's statements must call this instead of
+    # `lower_hir_stmt` and splice the results (see lower_hir_block /
+    # lower_hir_block_unit in expressions.spl).
+    me lower_hir_stmt_multi(s: Stmt) -> [HirStmt]:
+        val stmt_kind_value: StmtKind = s.kind
+        val sk_disc: i64 = hir_stmt_kind_disc(stmt_kind_value)
+        val sk_dummy: Expr = Expr(kind: ExprKind.NilLit, span: s.span)
+        if sk_disc == hir_stmt_kind_disc(StmtKind.Val("", nil, sk_dummy)):
+            val v_name = match stmt_kind_value:
+                case StmtKind.Val(vname, _, _):
+                    vname
+                case _:
+                    ""
+            if v_name.len() > 1 and v_name[0:1] == "(":
+                val v_init = match stmt_kind_value:
+                    case StmtKind.Val(_, _, vinit):
+                        vinit
+                    case _:
+                        sk_dummy
+                return self.lower_hir_tuple_destructure_val(v_name, v_init, s.span)
+        [self.lower_hir_stmt(s)]
+
+    # Desugar `val (a, b, ...) = <literal tuple expr>` into N `Let` bindings,
+    # evaluating each element expression exactly once, left to right. Only a
+    # LITERAL tuple initializer (`ExprKind.TupleLit`) is supported -- anything
+    # else (a variable, a function call returning a tuple, ...) is a loud HIR
+    # error so a non-literal initializer never silently produces a wrong
+    # answer.
+    me lower_hir_tuple_destructure_val(joined_name: text, init: Expr, span: Span) -> [HirStmt]:
+        val inner = joined_name[1:joined_name.len() - 1]
+        val names = inner.split(",")
+        match init.kind:
+            case ExprKind.TupleLit(elements):
+                if elements.len() != names.len():
+                    # The "unresolved name:" prefix is REQUIRED for loudness:
+                    # driver.spl's _hir_lowering_error_is_fatal only promotes
+                    # HIR lowering errors with that prefix to fatal build
+                    # errors -- anything else is silently downgraded to a
+                    # warning and never surfaces.
+                    self.error("unresolved name: tuple destructure arity mismatch for `val (" + inner + ")`: " + names.len().to_text() + " name(s) on the left vs " + elements.len().to_text() + " value(s) on the right", span)
+                    [HirStmt(kind: HirStmtKind.Expr(HirExpr(kind: HirExprKind.Error, type_: nil, span: span)), span: span)]
+                else:
+                    var result: [HirStmt] = []
+                    var i = 0
+                    while i < names.len():
+                        val nm = names[i]
+                        val hir_init = self.lower_hir_expr(elements[i])
+                        val symbol = self.symbols.define(nm, SymbolKind.Variable, nil, span, false, false, nil)
+                        result = result.push(HirStmt(kind: HirStmtKind.Let(symbol, nil, hir_init), span: span))
+                        i = i + 1
+                    result
+            case _:
+                # "unresolved name:" prefix: see arity-mismatch note above --
+                # required so this stays a FATAL build error instead of a
+                # silently-downgraded warning.
+                self.error("unresolved name: tuple destructure `val (" + inner + ") = ...` requires a literal tuple initializer, e.g. `val (a, b) = (x, y)`; a non-literal initializer (variable, function call, ...) is not supported", span)
+                [HirStmt(kind: HirStmtKind.Expr(HirExpr(kind: HirExprKind.Error, type_: nil, span: span)), span: span)]
+
     me lower_hir_stmt(s: Stmt) -> HirStmt:
         if (hir_stmt_env_get("SIMPLE_BOOTSTRAP") ?? "") == "1":
             eprint("[hir-lower] lower_stmt:start")
