     # the function was always constructed with has_return_type=false and an
@@ -992,7 +1013,7 @@ fn convert_decl_fn(idx: i64) -> Function:
             fn_attributes.push(Attribute(name: "clocked", args: clocked_args, span: span))
     val converted: Function = parser_function_new(
