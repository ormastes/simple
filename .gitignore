# MCP config (platform-specific, installed via config/mcp/install.shs)
.mcp.json

# Build artifacts (consolidated under build/)
/build/
.simple_eval_*.spl

# Bootstrap compiler (Rust-built binary, too large for git)
/bin/bootstrap/compiler-rust/simple
/bin/simple-stub
/bootstrap_freebsd/

# Mold linker (auto-downloaded by simple mold-setup)
/bin/mold/

# QEMU resources (downloads and build artifacts)
/resources/qemu/

# Object files and native libraries
*.o
*.a
*.so
*.dylib
*.dll

# Rust build artifacts (all under src/compiler_rust/target/ or build/)
/rust/
**/target/
**/*.rs.bk
*.pdb

# Cargo.lock is typically committed for binaries, uncomment to ignore
# Cargo.lock

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Python bytecode
__pycache__/
*.pyc

# Cache files
**/*cache*.json
**/simple_watch_cache.json

# Claude Code local settings and worktrees
.claude/settings.local.json
.claude/worktrees/

# Local config overrides (not shared)
*.local.sdn

# jscpd report output
/report/

# Temporary files
/tmp/
.fileio_temp*/
*.tmp
*.temp
*.bak
*.backup
*.deleted
*.bak2
*.bak3

# Build directories (cmake/ninja output)
build/cross-*/

# Windows reserved device names
NUL
# Large runtime binaries removed - use bin/release/simple only

# Experimental run data now in build/experiments/

# Debug files
*.log
/debug/
!src/app/debug/

# Generated SMF files (Simple Module Format)
*.smf
.simple/
# .simple logs now in build/logs/

# Obsolete test formats (keep only .spl)
test/**/*.py
test/**/*.sdt

# Coverage output (now in build/coverage/)
lcov.info
*.profraw
*.profdata
htmlcov/

# Node.js (for jscpd)
node_modules/

# Backup and original files
*.orig

# Lean 4 build artifacts
verification/**/.lake/
verification/**/lake-manifest.json
**/.lake/

# Jujutsu version control
.jj/

# bin/simple is a platform-specific symlink created by setup.sh
bin/simple
bin/simple.freebsd

# Release binaries — platform dirs contain large native binaries
# Keep README.md but ignore everything else under bin/release/
bin/release/*
!bin/release/README.md
bin/srt2
*.spk

# Bootstrap stage binaries (build/bootstrap/stage{1,2,3}/<triple>/...)
build/bootstrap/

# Stale flat-layout stage binaries
bin/simple_bootstrap
bin/simple_stage2
bin/simple_stage2.exe
bin/simple_stage3
bin/simple_native
bin/simple_native.exe
bin/simple_stage4
bin/simple_stage4.exe

# Package build artifacts
package_tmp/
*.tar.gz
*.zip
*.deb

# Stale root dirs (runtime bug artifacts, old build output)
/nil/
/bootstrap/
/pkg-deb/

# Release artifacts now in build/release/

